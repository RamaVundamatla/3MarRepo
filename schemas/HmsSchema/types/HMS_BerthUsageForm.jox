    <JadeMethod name="doResizeGraphs" id="f4974748-b861-4052-b449-6e56615a492e">
        <source>doResizeGraphs();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2012	cnwndl1	Initial creation	Par 29120

*/

vars
	tmpBarWidth : Real;
	tmpBarHeight : Real;
	tmpBarTop : Real;
begin
	
	self.lblPeriod.left := 0;
	self.lblPeriod.width := self.shtBarGraph.width;
	tmpBarWidth := ( self.shtBarGraph.width / 2 ).Integer - 2;
	tmpBarHeight := ( ( self.shtBarGraph.height - self.lblPeriod.height ) / 2 ).Integer - 5;
	
	tmpBarTop := self.lblPeriod.top + self.lblPeriod.height;
	self.frmBar1.width := tmpBarWidth;
	self.frmBar1.height := tmpBarHeight;
	self.frmBar1.top := tmpBarTop;
	
	self.frmBar2.left := tmpBarWidth + 1;
	self.frmBar2.width := tmpBarWidth;
	self.frmBar2.height := tmpBarHeight;
	self.frmBar2.top := tmpBarTop;
	
	tmpBarTop := self.frmBar1.height + self.frmBar1.top;
	self.frmBar3.top := tmpBarHeight + 1;
	self.frmBar3.width := tmpBarWidth;
	self.frmBar3.height := tmpBarHeight;
	self.frmBar3.top := tmpBarTop;
	
	self.frmBar4.left := tmpBarWidth + 1;
	self.frmBar4.top := tmpBarHeight + 1;
	self.frmBar4.width := tmpBarWidth;
	self.frmBar4.height := tmpBarHeight;
	self.frmBar4.top := tmpBarTop;
	
	self.barGraph.redrawGraph();
	self.barGraph2.redrawGraph();	
	self.barGraph3.redrawGraph();	
	self.barGraph4.redrawGraph();	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doResizePies" id="791a77d4-9018-4ccb-803e-49fed815f22c">
        <source>doResizePies();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2012	cnwndl1	Initial creation	Par 29120

*/

vars

	tmpPieWidth : Real;
	tmpPieHeight : Real;
	tmpPieTop : Real;
	tmpPieCirc : Real;
	

begin

	self.lblPeriod_1.left := 0;
	self.lblPeriod_1.width := self.shtPieGraph.width;

	tmpPieWidth := ( ( self.shtPieGraph.width - 4 ) / 3 ).Integer - 1;
	tmpPieHeight := ( self.shtPieGraph.height - ( self.lblPeriod.height +  self.lblPeriod.top + 5 ) ).Integer - 2;
	
	if tmpPieWidth &lt; tmpPieHeight then
		tmpPieCirc := tmpPieWidth - 5;
	else
		tmpPieCirc := tmpPieHeight - 5;
	endif;
	
	
	tmpPieTop := self.lblPeriod.top + self.lblPeriod.height;
	self.frmPie1.width := tmpPieWidth;
	self.frmPie1.height := tmpPieHeight;
	self.frmPie1.top := tmpPieTop;
	self.pieGraph.top := 1;
	self.pieGraph.left := 0;
	self.pieGraph.width := tmpPieCirc;
	self.pieGraph.height := tmpPieCirc;
	self.tblLegend1.top := tmpPieCirc + 5;
	self.tblLegend1.left := -1;
	self.tblLegend1.width := tmpPieCirc;
	self.tblLegend1.height := tmpPieHeight - ( tmpPieCirc + 15 );
	
	self.frmPie2.left := tmpPieWidth;
	self.frmPie2.width := tmpPieWidth;
	self.frmPie2.height := tmpPieHeight;
	self.frmPie2.top := tmpPieTop;
	self.pieGraph2.top := 1;
	self.pieGraph2.left := 0;
	self.pieGraph2.width := tmpPieCirc;
	self.pieGraph2.height := tmpPieCirc;
	self.tblLegend2.top := tmpPieCirc + 5;
	self.tblLegend2.left := -1;
	self.tblLegend2.width := tmpPieCirc;
	self.tblLegend2.height := tmpPieHeight - ( tmpPieCirc + 15 );
	
	self.frmPie3.left := tmpPieWidth + tmpPieWidth;
	self.frmPie3.width := tmpPieWidth;
	self.frmPie3.height := tmpPieHeight;
	self.frmPie3.top := tmpPieTop;
	self.pieGraph3.top := 1;
	self.pieGraph3.left := 0;
	self.pieGraph3.width := tmpPieCirc;
	self.pieGraph3.height := tmpPieCirc;
	self.tblLegend3.top := tmpPieCirc + 5;
	self.tblLegend3.left := -1;
	self.tblLegend3.width := tmpPieCirc;
	self.tblLegend3.height := tmpPieHeight - ( tmpPieCirc + 15 );

	self.pieGraph.redrawGraph();
	self.pieGraph2.redrawGraph();
	self.pieGraph3.redrawGraph();
	
epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="doSearch" id="350f2ae9-518e-4372-ab56-1b1b767fae20">
        <updating/>
        <source>doSearch() updating, protected;
//--------------------------------------------------
// Created:	23 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpDate : Date;
	tmpHarbour : HMS_Harbour;
begin
	
	self.allVoyageAnalysisByGroupCode.purge;
	self.allVoyageAnalysisArray.purge;
	self.allBerthUsageByGroupType.purge;
	self.allBerthUsageByVesselType.purge;
	self.allBerthUsageByBerthCode.purge;
	
	self.allHarbours.clear();
	self.lstHarbours.allSelectedObjects.copy(self.allHarbours);		

	self.allTerminals.clear();
	self.lstTerminals.allSelectedObjects.copy(self.allTerminals);
	
	if self.allTerminals.isEmpty then
		foreach tmpHarbour in self.allHarbours do
			tmpHarbour.allTerminalsByCode.copy(self.allTerminals);
		endforeach;	
	endif;

	self.allWharves.clear();
	self.lstWharves.allSelectedObjects.copy(self.allWharves);		

	self.allBerths.clear();
	self.lstBerths.allSelectedObjects.copy(self.allBerths);	
	
	self.includeIncompleteItinerary := self.ckbNoItinerary.value;	
	
	if self.grpMonthRange.enabled then	//23 Feb 2012	NDL	Par 29120
		// from the 1st of the month
		tmpDate.setDate(1, self.cmbMonth.listIndex, self.cmbYear.text.Integer);	
		self.filterFromDT.setDate(tmpDate);
		
		// to the last day of the month
		tmpDate.setDate(tmpDate.cnEcDaysInMonth, tmpDate.month, tmpDate.year);
		self.filterToDT.setDate(tmpDate);	
		self.filterToDT.setTime('23:59'.Time);
	else	
		self.filterFromDT.setDate(self.txtFromDate.getDate);
		self.filterToDT.setDate(self.txtToDate.getDate);	
		self.filterToDT.setTime('23:59'.Time);
	endif;
	
	self.generateBerthUsage();	
	
	if self.tblData.rows &gt; self.tblData.fixedRows then
		self.frmSearch.visible := true;
		self.showHideSearcher();		
	else
		self.frmSearch.visible := false;
		self.showHideSearcher();
	endif;
	
	//self.drawBarGraphBerthVoyages();
	//self.drawBarGraphBerthUsage();
	self.drawBarGraphs();	//23 Feb 2012	NDL	Par 29120
	self.drawPieGraphs();	//23 Feb 2012	NDL	Par 29120
	//self.drawPieGraph();

	//23 Feb 2012	NDL	Par 29120
	if self.grpMonthRange.enabled then
		self.caption := Caption &amp; ' ' &amp; self.cmbMonth.text &amp; ' ' &amp; self.cmbYear.text;
	else
		self.caption := Caption &amp; ' ' &amp; self.txtFromDate.getDate.asStringJMT &amp; ' - ' &amp; self.txtToDate.getDate.asStringJMT;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSelectAll" id="aab0f116-82a8-4b7c-ae71-1293821f1d45">
        <source>doSelectAll(_lstTable : CMUI_ListTable input) protected;
//--------------------------------------------------
// Created:	25 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	numRows,
	idx	: Integer;
	tmpHarbour : HMS_Harbour;
	tmpWharf : HMS_Wharf;
begin
	if _lstTable = null then
		return;
	endif;
	
	_lstTable.setAllToTrue();
	
	numRows := _lstTable.rows;

	if _lstTable = self.lstHarbours then
		foreach idx in 1 to numRows do
			self.doHarbourSelect(idx);
		endforeach;
	elseif _lstTable = self.lstWharves then
		foreach idx in 1 to numRows do
			self.doWharfSelect(idx);
		endforeach;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_lstTable" type="CMUI_ListTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doWharfSelect" id="7fa2567f-c8d1-4cf1-b186-af37e11fef8f">
        <source>doWharfSelect(_row : Integer) protected;
//--------------------------------------------------
// Created:	24 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpWharf	: HMS_Wharf;
	tmpBerth	: HMS_Berth;
	selected 	: Boolean;
	idx			: Integer;
	user		: CM_User;
	passport	: CM_Passport;
	failedDAC  :CM_DataAccessController;
begin

	tmpWharf := self.lstWharves.accessRow(_row).itemObject.HMS_Wharf;
	
	if tmpWharf = null then
		return;
	endif;

	selected := self.lstWharves.allSelectedObjects.includes(tmpWharf);		

	passport := app.myPassport;
	user := passport.myUser;

	foreach tmpBerth in tmpWharf.allBerths do
		idx := null;
		if (not tmpBerth.canUserAccessSelf(user, failedDAC, passport)) then
			continue;
		endif;

		self.lstBerths.findObjectInRow(tmpBerth, idx);
					
		if selected then
			if idx &lt; 1 then
				self.lstBerths.addItemObject(tmpBerth.getDisplayString, tmpBerth);
			endif;
		elseif idx &gt; 0 then
			self.lstBerths.removeItem(idx);
			//	09 Oct 2012	NDL	Par 30490
			if self.lstBerths.allSelectedObjects.includes(tmpBerth) then
				self.lstBerths.allSelectedObjects.remove(tmpBerth);
			endif;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawBarGraph2" id="a5f1b0d0-1691-4bfe-a40e-2f57acebd62a">
        <source>drawBarGraph2();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 February 2012	cnwndl1	Initial creation	Par 29120

*/

vars

	cnt : Integer;
	berthCode : String;
	dtStart,
	dtEnd : TimeStamp;
	tmpVoyage : CM_Voyage;
	tmpCMIF : CMIF_BerthUsage;
	tmpBerth : HMS_Berth;
	iter : Iterator;
	visits : Integer;
	maxVisits : Integer;

begin

	self.barGraph2.clearGraph();
	self.barGraph2.init('Voyages / Berth ', ' ', 'Number of Voyages');
	self.barGraph2.backColor := backColor;

	foreach tmpBerth in self.allBerths do
		
		berthCode := tmpBerth.code;
		delete iter;
		iter := self.allBerthUsageByBerthCode.createIterator();
		//	09 Oct 2012	NDL	Par 30490
		//self.allBerthUsageByBerthCode.startKeyGeq(bthCode, iter);

		visits := null;		
		while iter.next(tmpCMIF) do
			//	09 Oct 2012	NDL	Par 30490
			//if tmpCMIF.berthCode &lt;&gt; bthCode then
			//	break;
			//endif;
			tmpVoyage := tmpCMIF.myVoyage;
			if (not global.isValidObject(tmpVoyage)) then
				continue;
			endif;
			if (not tmpVoyage.arrivedDT.isValid()) then
				continue;
			endif;
			if (not tmpVoyage.departedDT.isValid()) then
				continue;
			endif;

			if tmpVoyage.arrivedDT &gt; self.filterToDT then
				// future voyage
				continue;
			endif;						
	
			if tmpVoyage.arrivedDT &lt;= self.filterFromDT then
				dtStart := self.filterFromDT;
			else
				dtStart := tmpVoyage.arrivedDT;		
			endif;

			if tmpVoyage.departedDT &lt;= self.filterToDT then
				dtEnd := tmpVoyage.departedDT;
			else
				dtEnd := self.filterToDT;		
			endif;
				
			if dtStart &gt;= self.filterFromDT 
			and dtEnd &lt;= self.filterToDT then
				//	09 Oct 2012	NDL	Par 30490
				if not tmpCMIF.includesMovementTo(tmpBerth, self.filterFromDT, self.filterToDT) then
					continue;
				endif;
			
				visits := visits + 1;
			endif;
			
		endwhile;
		
		
		if maxVisits &lt; visits then
			maxVisits := visits;
		endif;
		cnt := cnt+1;
		self.barGraph2.addValue(berthCode, visits.String, visits, self.getColourForMonth(cnt));
		visits := 0;
					
	endforeach;		

	self.barGraph2.setMaxScaleLengthToValue(maxVisits);
	self.barGraph2.drawGraph();

epilog
	delete iter; 
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawBarGraph3" id="30680bf8-40ff-4305-b03a-a7feb8c5b2d1">
        <source>drawBarGraph3();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 February 2012	cnwndl1	Initial creation	Par 29120

*/

vars

	cnt : Integer;
	berthCode : String;
	dtStart,
	dtEnd : TimeStamp;
	tmpVoyage : CM_Voyage;
	tmpCMIF : CMIF_BerthUsage;
	tmpBerth : HMS_Berth;
	iter : Iterator;
	tmpHMSVoyData : HMS_VoyageData;
	nextMove,
	tmpMove : HMS_VoyageMovement;
	maxHours : Integer;
	hours : Integer;

begin

	self.barGraph3.clearGraph();
	self.barGraph3.init('Occupied Hours / Berth', ' ', 'Hours');
	self.barGraph3.backColor := backColor;

	foreach tmpBerth in self.allBerths do
		
		berthCode := tmpBerth.code;
		delete iter;
		iter := self.allBerthUsageByBerthCode.createIterator();
		self.allBerthUsageByBerthCode.startKeyGeq(berthCode, iter);

		hours := 0;		
		while iter.next(tmpCMIF) do
		//	09 Oct 2012	NDL	Par 30490
		//	if tmpCMIF.berthCode &lt;&gt; bthCode then
		//		break;
		//	endif;
			tmpVoyage := tmpCMIF.myVoyage;
			if (not global.isValidObject(tmpVoyage)) then
				continue;
			endif;
			if (not tmpVoyage.arrivedDT.isValid()) then
				continue;
			endif;
			if (not tmpVoyage.departedDT.isValid()) then
				continue;
			endif;

			if tmpVoyage.arrivedDT &gt; self.filterToDT then
				// future voyage
				continue;
			endif;						
	
			if tmpVoyage.arrivedDT &lt;= self.filterFromDT then
				dtStart := self.filterFromDT;
			else
				dtStart := tmpVoyage.arrivedDT;		
			endif;

			if tmpVoyage.departedDT &lt;= self.filterToDT then
				dtEnd := tmpVoyage.departedDT;
			else
				dtEnd := self.filterToDT;		
			endif;
				
			if dtStart &gt;= self.filterFromDT 
			and dtEnd &lt;= self.filterToDT then
				tmpHMSVoyData := tmpVoyage.myHMSVoyageData;
				if tmpHMSVoyData &lt;&gt; null then
					tmpMove := tmpVoyage.myHMSVoyageData.allVoyageMovements.getAtKeyGtr(tmpVoyage.arrivedDT).HMS_VoyageMovement;
				endif;
				if tmpMove &lt;&gt; null
		//		and tmpMove.moveType = HMSMovementTypeShift	//	09 Oct 2012	NDL	Par 30490
				then
					// get all the movements for this berth
					foreach tmpMove in tmpHMSVoyData.allVoyageMovements do
						if tmpMove.getMyBerth = tmpBerth then
							// movement is for this berth
							nextMove := tmpMove.getVoyageMovementNext();
							if nextMove &lt;&gt; null then
								if tmpMove.occursOnDTNEW &gt; dtStart then
									dtStart := tmpMove.occursOnDTNEW;
								endif;
								if nextMove.occursOnDTNEW &lt; dtEnd then
									dtEnd := nextMove.occursOnDTNEW;
								endif;								
								if dtStart &lt; dtEnd then
									hours := hours + dtStart.differenceInHours(dtEnd);
								endif;
							endif;
						endif;
															
					endforeach;
		//	09 Oct 2012	NDL	Par 30490
		//		elseif dtStart &lt; dtEnd then
		//			hours := hours + dtStart.differenceInHours(dtEnd);
				endif;
			endif;
			
		endwhile;
		
		cnt := cnt+1;
		if maxHours &lt; hours then
			maxHours := hours;
		endif;
		self.barGraph3.addValue(berthCode, hours.String, hours, self.getColourForMonth(cnt));
		hours := null;
					
	endforeach;		

	self.barGraph3.setMaxScaleLengthToValue(maxHours);
	self.barGraph3.drawGraph();

epilog
	delete iter; 
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawBarGraph4" id="3e1d7e91-ced6-4901-b790-d17978482e20">
        <source>drawBarGraph4();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 February 2012	cnwndl1	Initial creation	Par 29120

*/

vars

//	totValue,
	value,
	cnt : Integer;
	berthCode : String;
	dtStart,
	dtEnd : TimeStamp;
	tmpVoyage : CM_Voyage;
	tmpCMIF : CMIF_BerthUsage;
	tmpBerth : HMS_Berth;
	iter : Iterator;
	tmpHMSVoyData : HMS_VoyageData;
	nextMove,
	tmpMove : HMS_VoyageMovement;
	visits : Integer;
	maxValue : Integer;
	hours : Integer;

begin

	self.barGraph4.clearGraph();
	self.barGraph4.init('Average Hours / Voyage / Berth', ' ', 'Hours');
	self.barGraph4.backColor := backColor;


	foreach tmpBerth in self.allBerths do
		
		berthCode := tmpBerth.code;
		delete iter;
		iter := self.allBerthUsageByBerthCode.createIterator();
	//	09 Oct 2012	NDL	Par 30490
	//	self.allBerthUsageByBerthCode.startKeyGeq(bthCode, iter);

		hours := null;
		visits := null;	
		while iter.next(tmpCMIF) do
			//	09 Oct 2012	NDL	Par 30490
			//if tmpCMIF.berthCode &lt;&gt; bthCode then
			//	break;
			//endif;
			tmpVoyage := tmpCMIF.myVoyage;
			if (not global.isValidObject(tmpVoyage)) then
				continue;
			endif;
			if (not tmpVoyage.arrivedDT.isValid()) then
				continue;
			endif;
			if (not tmpVoyage.departedDT.isValid()) then
				continue;
			endif;

			if tmpVoyage.arrivedDT &gt; self.filterToDT then
				// future voyage
				continue;
			endif;						
	
			if tmpVoyage.arrivedDT &lt;= self.filterFromDT then
				dtStart := self.filterFromDT;
			else
				dtStart := tmpVoyage.arrivedDT;		
			endif;

			if tmpVoyage.departedDT &lt;= self.filterToDT then
				dtEnd := tmpVoyage.departedDT;
			else
				dtEnd := self.filterToDT;		
			endif;
				
			if dtStart &gt;= self.filterFromDT 
			and dtEnd &lt;= self.filterToDT then
			//	visits := visits + 1;	//	09 Oct 2012	NDL	Par 30490
				tmpHMSVoyData := tmpVoyage.myHMSVoyageData;
				if tmpHMSVoyData &lt;&gt; null then
					tmpMove := tmpVoyage.myHMSVoyageData.allVoyageMovements.getAtKeyGtr(tmpVoyage.arrivedDT).HMS_VoyageMovement;
				endif;
				if tmpMove &lt;&gt; null
			//	and tmpMove.moveType = HMSMovementTypeShift	//	09 Oct 2012	NDL	Par 30490
				then
					// get all the movements for this berth
					foreach tmpMove in tmpHMSVoyData.allVoyageMovements do
						if tmpMove.getMyBerth = tmpBerth then
							// movement is for this berth
							nextMove := tmpMove.getVoyageMovementNext();
							if nextMove &lt;&gt; null then
								if tmpMove.occursOnDTNEW &gt; dtStart then
									dtStart := tmpMove.occursOnDTNEW;
								endif;
								if nextMove.occursOnDTNEW &lt; dtEnd then
									dtEnd := nextMove.occursOnDTNEW;
								endif;								
								if dtStart &lt; dtEnd then
									hours := hours + dtStart.differenceInHours(dtEnd);
									visits := visits + 1;	//	09 Oct 2012	NDL	Par 30490
								endif;
							endif;
						endif;
															
					endforeach;
			//	09 Oct 2012	NDL	Par 30490
			//	elseif dtStart &lt; dtEnd then
			//		hours := hours + dtStart.differenceInHours(dtEnd);
				endif;
			endif;
			
		endwhile;
		
		cnt := cnt+1;
		
		if visits = 0 then
			value := 0;
		else
			value := ( hours / visits ).Integer;
		endif;
		if maxValue &lt; value then
			maxValue := value;
		endif;
		self.barGraph4.addValue(berthCode, value.String, value, self.getColourForMonth(cnt));
		hours := null;
		visits := null;
		value := null;
					
	endforeach;		

	self.barGraph4.setMaxScaleLengthToValue(maxValue);
	self.barGraph4.drawGraph();

epilog
	delete iter; 
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawBarGraphBerthUsage" id="04b4aa9f-6676-4e5f-b176-026d140e319f">
        <source>drawBarGraphBerthUsage() protected;
//--------------------------------------------------
// Created:	02 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	totValue,
	value,
	cnt : Integer;
	berthCode : String;
	dtStart,
	dtEnd : TimeStamp;
	tmpVoyage : CM_Voyage;
	tmpCMIF : CMIF_BerthUsage;
	tmpBerth : HMS_Berth;
	iter : Iterator;
	tmpHMSVoyData : HMS_VoyageData;
	nextMove,
	tmpMove : HMS_VoyageMovement;
begin

//	if (not self.shtBarGraph.visible) then
//		return;
//	endif;
	
	self.lblPeriod.caption := self.filterFromDT.date.shortFormatJMT() &amp; ' to ' &amp; self.filterToDT.date.shortFormatJMT();
	self.lblPeriod_1.caption := self.lblPeriod.caption;
	
//	app.mousePointer := MousePointer_HourGlass;

	self.barGraph.clearGraph();
	self.barGraph.init('Berth Occupancy', ' ', '% Occupied');
	self.barGraph.backColor := backColor;
	
	//totValue := self.filterFromDT.differenceInHours(self.filterToDT.cnEcAddHours(1));
	totValue := self.filterFromDT.getDifferenceInMinutes(self.filterToDT) + 1;	//	09 Oct 2012	NDL	Par 30490
	
	if totValue &lt; 1 then
		return;
	endif;

	foreach tmpBerth in self.allBerths do
		
		berthCode := tmpBerth.code;
		delete iter;
		iter := self.allBerthUsageByBerthCode.createIterator();
		self.allBerthUsageByBerthCode.startKeyGeq(berthCode, iter);

		value := null;		
		while iter.next(tmpCMIF) do
		//	09 Oct 2012	NDL	Par 30490
		//	if tmpCMIF.berthCode &lt;&gt; bthCode then
		//		break;
		//	endif;
			tmpVoyage := tmpCMIF.myVoyage;
			if (not global.isValidObject(tmpVoyage)) then
				continue;
			endif;
			if (not tmpVoyage.arrivedDT.isValid()) then
				continue;
			endif;
			if (not tmpVoyage.departedDT.isValid()) then
				continue;
			endif;

			if tmpVoyage.arrivedDT &gt; self.filterToDT then
				// future voyage
				continue;
			endif;						
	
			if tmpVoyage.arrivedDT &lt;= self.filterFromDT then
				dtStart := self.filterFromDT;
			else
				dtStart := tmpVoyage.arrivedDT;		
			endif;

			if tmpVoyage.departedDT &lt;= self.filterToDT then
				dtEnd := tmpVoyage.departedDT;
			else
				dtEnd := self.filterToDT;		
			endif;
				
			if dtStart &gt;= self.filterFromDT 
			and dtEnd &lt;= self.filterToDT then
				tmpHMSVoyData := tmpVoyage.myHMSVoyageData;
				if tmpHMSVoyData &lt;&gt; null then
					tmpMove := tmpVoyage.myHMSVoyageData.allVoyageMovements.getAtKeyGtr(tmpVoyage.arrivedDT).HMS_VoyageMovement;
				endif;
				if tmpMove &lt;&gt; null
			//	and tmpMove.moveType = HMSMovementTypeShift	//	09 Oct 2012	NDL	Par 30490
				then
					// get all the movements for this berth
					foreach tmpMove in tmpHMSVoyData.allVoyageMovements do
						if tmpMove.getMyBerth = tmpBerth then
							// movement is for this berth
							nextMove := tmpMove.getVoyageMovementNext();
							if nextMove &lt;&gt; null then
								if tmpMove.occursOnDTNEW &gt; dtStart then
									dtStart := tmpMove.occursOnDTNEW;
								endif;
								if nextMove.occursOnDTNEW &lt; dtEnd then
									dtEnd := nextMove.occursOnDTNEW;
								endif;								
								if dtStart &lt; dtEnd then
									//value := value + dtStart.differenceInHours(dtEnd);
									value := value + dtStart.getDifferenceInMinutes(dtEnd);	//	09 Oct 2012	NDL	Par 30490
								endif;
							endif;
						endif;
															
					endforeach;
			//	09 Oct 2012	NDL	Par 30490
			//	elseif dtStart &lt; dtEnd then
			//		value := value + dtStart.differenceInHours(dtEnd);
				endif;
			endif;
			
		endwhile;
		
		value := ((value / totValue) * 100).Integer;
		cnt := cnt+1;
		//self.barGraph.addValue(bthCode, '% ' &amp; value.String, value, self.getColourForMonth(cnt));
		self.barGraph.addValue(berthCode, value.String, value, self.getColourForMonth(cnt));	//	09 Oct 2012	NDL	Par 30490
		value := null;
					
	endforeach;		

	self.barGraph.setMaxScaleLengthToValue(100);
	self.barGraph.drawGraph();

epilog
	delete iter;
//	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawBarGraphBerthVoyages" id="660a53d5-9703-491d-9ed8-a6f82ffd4ec2">
        <source>drawBarGraphBerthVoyages() protected;
//--------------------------------------------------
// Created:	02 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	value,
	cnt : Integer;
	str : String;
	voyBerth,
	tmpBerth : HMS_Berth;
	tmpCMIF : CMIF_BerthUsage;
begin

	if (not self.shtBarGraph.visible) then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;

	self.barGraph.clearGraph();
	self.barGraph.init('Berth Usage', "Berth", 'Voyages');
	self.barGraph.backColor := backColor;
			
	foreach tmpBerth in self.allBerths do
	
		value := null;
		foreach tmpCMIF in self.allBerthUsageByGroupType do
			if (not global.isValidObject(tmpCMIF.myVoyage)) then
				continue;
			endif;			
	
			if tmpCMIF.myVoyage.getMyBerth() &lt;&gt; tmpBerth then
				continue;
			endif;

			value := value + 1;
			
		endforeach;

		str := tmpBerth.description;
		cnt := cnt+1;
		self.barGraph.addValue(str, null, value, self.getColourForMonth(cnt));
		
	endforeach;	

	self.barGraph.drawGraph();
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawBarGraphs" id="7d18edd5-a5e0-40c9-ae12-5d64e184c187">
        <source>drawBarGraphs();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2012	cnwndl1	Initial creation		Par 29120

*/

vars

begin

	if (not self.shtBarGraph.visible) then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;

	self.drawBarGraphBerthUsage();
	self.drawBarGraph2();	
	self.drawBarGraph3();	
	self.drawBarGraph4();	

epilog

	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="drawPieGraph" id="9c14cfe2-13a8-4c48-8bd5-d817d89be04f">
        <source>drawPieGraph() protected;
//--------------------------------------------------
// Created:	02 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	cnt,
	subTot,
	totValue,
	value : Integer;
	str : String;
	tmpCMIF : CMIF_BerthUsage;
	size : Integer;
	index : Integer;
	segColour : Integer;
	segLegend : String;
	segValue : Integer;
begin

//	if (not self.shtPieGraph.visible) then
//		return;
//	endif;
	
//	app.mousePointer := MousePointer_HourGlass;

	self.pieGraph.clearGraph();
//	self.pieGraph.isShowPieLegend := true;	
	self.pieGraph.backColor := backColor;
	
	totValue := self.allBerthUsageByVesselType.size;

	if totValue &lt; 1 then
		return;
	endif;
	
	foreach tmpCMIF in self.allBerthUsageByVesselType do
		if str &lt;&gt; null 
		and tmpCMIF.vesselTypeDesc &lt;&gt; str then
			value := ((value / totValue) * 100).Integer;
			if value &gt; 0 then
				cnt := cnt+1;
				self.pieGraph.addValue(str, value, self.getColourForMonth(cnt));
			endif;
			subTot := subTot + value;			
			value := null;
		endif;
				
		value := value + 1;
		str := tmpCMIF.vesselTypeDesc;				
	endforeach;

	value := ((value / totValue) * 100).Integer;
	subTot := subTot + value;
	if value &gt; 0 then
		cnt := cnt+1;
		self.pieGraph.addValue(str, value, self.getColourForMonth(cnt));	
	endif;

	if subTot &lt; 100 then
		value := (100 - subTot);
		self.pieGraph.doRounding(value);
	endif;	

	self.pieGraph.setTitle('Vists by Vessel Type');		
	self.pieGraph.drawGraph();
	
	//23 Feb 2012	NDL	Par 29120
	self.tblLegend1.clear();
	self.tblLegend1.rows := 1;
	self.tblLegend1.columns := 3;
	self.tblLegend1.setCellText( 1, 1, "Colour" &amp; Tab &amp; "Vessel Type" &amp; Tab &amp; "Percent");
	self.tblLegend1.accessRow(1).fontBold := true;
	
	size := self.pieGraph.getDataSize();
	if size &gt; 0 then
		foreach index in 1 to size do
			self.pieGraph.getSegmentDetails(	index,	//_index : Integer;
												segColour,	//_segColour : Integer;
												segLegend,	//_segLegend : String;
												segValue	//_segValue : Integer
												);
			self.tblLegend1.addItem("" &amp; Tab &amp; segLegend &amp; Tab &amp; segValue.String);
			self.tblLegend1.accessCell(self.tblLegend1.rows,1).backColor := segColour;
		endforeach;
	endif;
	
	

epilog
//	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawPieGraph2" id="535e26cb-7291-4ba8-adfb-42ffcf352736">
        <source>drawPieGraph2();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2012	cnwndl1	Initial creation		Par 29120

*/

vars

	operators : ObjectArray;
	visits : IntegerArray;
	iter : Iterator;
	operator : CM_Operator;
	obj : Object;
	tmpVoyage : CM_Voyage;
	dtStart,
	dtEnd : TimeStamp;
	totalVisits : Integer;
	visitCount : Integer;
	
	cnt,
	subTot,
	totValue,
	value : Integer;
	str : String;
	tmpCMIF : CMIF_BerthUsage;
	size : Integer;
	index : Integer;
	segColour : Integer;
	segLegend : String;
	segValue : Integer;
begin


	self.pieGraph2.clearGraph();	
	self.pieGraph2.backColor := backColor;
	
	self.pieGraph2.setTitle('Vists by Ship Operator');		
	self.pieGraph2.drawGraph();
	
	self.tblLegend2.clear();
	self.tblLegend2.rows := 1;
	self.tblLegend2.columns := 3;
	self.tblLegend2.setCellText( 1, 1, "Colour" &amp; Tab &amp; "Ship Operator" &amp; Tab &amp; "Percent");
	self.tblLegend2.accessRow(1).fontBold := true;
	
	totValue := self.allBerthUsageByVesselType.size;

	if totValue &lt; 1 then
		return;
	endif;
	
	
	iter := self.allBerthUsageByBerthCode.createIterator();
	create operators transient;
	create visits transient;
	
	while iter.next(tmpCMIF) do
		
		tmpVoyage := tmpCMIF.myVoyage;
		if (not global.isValidObject(tmpVoyage)) then
			continue;
		endif;
		if (not tmpVoyage.arrivedDT.isValid()) then
			continue;
		endif;
		if (not tmpVoyage.departedDT.isValid()) then
			continue;
		endif;

		if tmpVoyage.arrivedDT &gt; self.filterToDT then
			// future voyage
			continue;
		endif;						

		if tmpVoyage.arrivedDT &lt;= self.filterFromDT then
			dtStart := self.filterFromDT;
		else
			dtStart := tmpVoyage.arrivedDT;		
		endif;

		if tmpVoyage.departedDT &lt;= self.filterToDT then
			dtEnd := tmpVoyage.departedDT;
		else
			dtEnd := self.filterToDT;		
		endif;
			
		if dtStart &gt;= self.filterFromDT 
		and dtEnd &lt;= self.filterToDT then
			
			operator := tmpVoyage.myOperator;
			if operator = null then
				operator := tmpVoyage.getMyTerminal.getNullOperator;
			endif;
			
			index := operators.indexOf(operator);
			if index &lt; 1 then
				operators.add(operator);
				visits.add(1);
				totalVisits := totalVisits + 1;
			else
				visits[index] := visits[index] + 1;
				totalVisits := totalVisits + 1;
			endif;
		endif;
		
	endwhile;

	
	foreach obj in operators do
		operator := obj.CM_Operator;
		index := operators.indexOf(operator);
		
		visitCount := visits[index];
		value := ((visitCount / totValue) * 100).Integer;
		
		if value &gt; 0 then
			subTot := subTot + value;
			cnt := cnt+1;
			self.pieGraph2.addValue(operator.code, value, self.getColourForMonth(cnt));
		endif;
						
	endforeach;
	

	if subTot &lt; 100 then
		value := (100 - subTot);
		self.pieGraph2.doRounding(value);
	endif;	
		
	self.pieGraph2.drawGraph();	

	size := self.pieGraph2.getDataSize();
	if size &gt; 0 then
		foreach index in 1 to size do
			self.pieGraph2.getSegmentDetails(	index,	//_index : Integer;
												segColour,	//_segColour : Integer;
												segLegend,	//_segLegend : String;
												segValue	//_segValue : Integer
												);
			self.tblLegend2.addItem("" &amp; Tab &amp; segLegend &amp; Tab &amp; segValue.String);
			self.tblLegend2.accessCell(self.tblLegend2.rows,1).backColor := segColour;
		endforeach;
	endif;
	
	

epilog

	delete operators;
	delete visits;
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="drawPieGraph3" id="3320f94d-02ac-4c7b-8b67-bd568cba725e">
        <source>drawPieGraph3();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2012	cnwndl1	Initial creation	Par 29120
05/03/2015			cnwmh5	Tranisent Leak
11/03/2015			cnwmh5 	Transient Leaks
*/

vars

	tmpVoyage : CM_Voyage;
	shipLine : CM_ShippingLine;
	trade : CM_Trade;
	lineTrade : String;
	shipLineTrades : StringArray;
	iter : Iterator;	
	visits : IntegerArray;
	obj : Object;
	dtStart,
	dtEnd : TimeStamp;
	totalVisits : Integer;
	visitCount : Integer;
	
	cnt,
	subTot,
	totValue,
	value : Integer;
	str : String;
	tmpCMIF : CMIF_BerthUsage;
	size : Integer;
	index : Integer;
	segColour : Integer;
	segLegend : String;
	segValue : Integer;
begin


	self.pieGraph3.clearGraph();
	self.pieGraph3.backColor := backColor;
	
	self.pieGraph3.setTitle('Vists by Shipping Line/Trade');		
	self.pieGraph3.drawGraph();
	
	self.tblLegend3.clear();
	self.tblLegend3.rows := 1;
	self.tblLegend3.columns := 3;
	self.tblLegend3.setCellText( 1, 1, "Colour" &amp; Tab &amp; "Shipping Line/Trade" &amp; Tab &amp; "Percent");
	self.tblLegend3.accessRow(1).fontBold := true;
	
	totValue := self.allBerthUsageByVesselType.size;

	if totValue &lt; 1 then
		return;
	endif;
	
	iter := self.allBerthUsageByBerthCode.createIterator();
	create shipLineTrades transient;
	create visits transient;
	
	while iter.next(tmpCMIF) do
		
		tmpVoyage := tmpCMIF.myVoyage;
		if (not global.isValidObject(tmpVoyage)) then
			continue;
		endif;
		if (not tmpVoyage.arrivedDT.isValid()) then
			continue;
		endif;
		if (not tmpVoyage.departedDT.isValid()) then
			continue;
		endif;

		if tmpVoyage.arrivedDT &gt; self.filterToDT then
			// future voyage
			continue;
		endif;						

		if tmpVoyage.arrivedDT &lt;= self.filterFromDT then
			dtStart := self.filterFromDT;
		else
			dtStart := tmpVoyage.arrivedDT;		
		endif;

		if tmpVoyage.departedDT &lt;= self.filterToDT then
			dtEnd := tmpVoyage.departedDT;
		else
			dtEnd := self.filterToDT;		
		endif;
			
		if dtStart &gt;= self.filterFromDT 
		and dtEnd &lt;= self.filterToDT then
			
			lineTrade := null;
			shipLine := tmpVoyage.myShippingLine;
			if shipLine = null then
				lineTrade := "None / ";
			else
				lineTrade := shipLine.code &amp; " / ";
			endif;
			trade := tmpVoyage.myTrade;
			if trade = null then
				lineTrade := lineTrade &amp; "None";
			else
				if trade.code &lt;&gt; null then
					lineTrade := lineTrade &amp; trade.code;
				else
					lineTrade := lineTrade &amp; trade.description;
				endif;
			endif;
			if lineTrade.length &gt; 50 then
				lineTrade := lineTrade[1:47] &amp; "...";
			endif;
			
			index := shipLineTrades.indexOf(lineTrade);
			if index &lt; 1 then
				shipLineTrades.add(lineTrade);
				visits.add(1);
				totalVisits := totalVisits + 1;
			else
				visits[index] := visits[index] + 1;
				totalVisits := totalVisits + 1;
			endif;
		endif;
		
	endwhile;

	
	foreach lineTrade in shipLineTrades do
		index := shipLineTrades.indexOf(lineTrade);
		
		visitCount := visits[index];
		value := ((visitCount / totValue) * 100).Integer;
		
		if value &gt; 0 then
			subTot := subTot + value;
			cnt := cnt+1;
			self.pieGraph3.addValue(lineTrade, value, self.getColourForMonth(cnt));
		endif;
						
	endforeach;
	

	
	if subTot &lt; 100 then
		value := (100 - subTot);
		self.pieGraph3.doRounding(value);
	endif;	
		
	self.pieGraph3.drawGraph();
	
	size := self.pieGraph3.getDataSize();
	if size &gt; 0 then
		foreach index in 1 to size do
			self.pieGraph3.getSegmentDetails(	index,	//_index : Integer;
												segColour,	//_segColour : Integer;
												segLegend,	//_segLegend : String;
												segValue	//_segValue : Integer
												);
			self.tblLegend3.addItem("" &amp; Tab &amp; segLegend &amp; Tab &amp; segValue.String);
			self.tblLegend3.accessCell(self.tblLegend3.rows,1).backColor := segColour;
		endforeach;
	endif;
	
	

epilog
	delete iter;
	delete visits;
	delete shipLineTrades;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawPieGraphs" id="d4409127-6ff9-40c3-9a4e-2706b3b359bb">
        <source>drawPieGraphs();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2012	cnwndl1	Initial creation	Par 29120

*/

vars

begin

	app.mousePointer := MousePointer_HourGlass;
	
	if (not self.shtPieGraph.visible) then
		return;
	endif;

	self.drawPieGraph();
	self.drawPieGraph2();
	self.drawPieGraph3();

epilog

	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="generateAnalysisTotals" id="b9c1efd5-19e2-47cf-85a1-8ad22a80bfdd">
        <source>generateAnalysisTotals()protected;
//--------------------------------------------------
// Created:	29 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	idx,
	group : Integer;
	cargoSet,
	isGroupTotal : Boolean;
	tmpVesselCalls,
	tmpAnalyTotUnits,
	tmpAnalyTotTons,
	tmpAnalyTotal,
	tmpVoyageAnaly : CMIF_VoyageAnalysis;
begin
	
	foreach tmpVoyageAnaly in self.allVoyageAnalysisByGroupCode do
		isGroupTotal := tmpVoyageAnaly.isGroupTotal();

		if tmpVoyageAnaly.group &lt;&gt; group 
		and (not isGroupTotal) then
			if tmpAnalyTotal &lt;&gt; null then
				self.allVoyageAnalysisArray.add(tmpAnalyTotal);
				if tmpAnalyTotal.isVesselCall then
					if tmpVesselCalls = null then
						create tmpVesselCalls transient;
						tmpVesselCalls.setGroupCodeForTotal(tmpAnalyTotal.group, tmpAnalyTotal.unitsOfMeasure);
						tmpVesselCalls.addVoyageAnalysis(tmpAnalyTotal);
					elseif (not tmpVesselCalls.allVoyageAnalysis.includes(tmpAnalyTotal)) then
						tmpVesselCalls.addVoyageAnalysis(tmpAnalyTotal);				
					endif;
				endif;					
			endif;
							
			create tmpAnalyTotal transient;
			tmpAnalyTotal.setGroupCodeForTotal(tmpVoyageAnaly.group, tmpVoyageAnaly.unitsOfMeasure);			
			tmpAnalyTotal.addVoyageAnalysis(tmpVoyageAnaly);
			
		elseif tmpAnalyTotal &lt;&gt; null then
			tmpAnalyTotal.addVoyageAnalysis(tmpVoyageAnaly);
		endif;
		
		group := tmpVoyageAnaly.group;
		if (not isGroupTotal) then
			self.allVoyageAnalysisArray.add(tmpVoyageAnaly);		
		endif;

	endforeach;

	if tmpAnalyTotal &lt;&gt; null
	and tmpAnalyTotal.isVesselCall then
		if tmpVesselCalls = null then
			create tmpVesselCalls transient;
			tmpVesselCalls.setGroupCodeForTotal(tmpAnalyTotal.group, tmpAnalyTotal.unitsOfMeasure);
			tmpVesselCalls.addVoyageAnalysis(tmpAnalyTotal);																	
		elseif (not tmpVesselCalls.allVoyageAnalysis.includes(tmpAnalyTotal)) then
			tmpVesselCalls.addVoyageAnalysis(tmpAnalyTotal);
		endif;
	endif;
			
	if tmpAnalyTotTons &lt;&gt; null
	and (not self.allVoyageAnalysisArray.includes(tmpAnalyTotTons)) then
		self.allVoyageAnalysisArray.add(tmpAnalyTotTons);
	endif;

	if tmpAnalyTotUnits &lt;&gt; null
	and (not self.allVoyageAnalysisArray.includes(tmpAnalyTotUnits)) then
		self.allVoyageAnalysisArray.add(tmpAnalyTotUnits);
	endif;			

	if tmpAnalyTotal &lt;&gt; null
	and (not self.allVoyageAnalysisArray.includes(tmpAnalyTotal)) then
		self.allVoyageAnalysisArray.add(tmpAnalyTotal);
	endif;

	if tmpVesselCalls &lt;&gt; null
	and (not self.allVoyageAnalysisArray.includes(tmpVesselCalls)) then
		self.allVoyageAnalysisArray.add(tmpVesselCalls);
	endif;									
			
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="generateBerthUsage" id="155710a1-5e59-45a8-a764-f299f7c273df">
        <source>generateBerthUsage() protected;
//--------------------------------------------------
// Created:	05 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	includeFuture : Boolean;
	iter : Iterator;
	term : CM_Terminal;
	tmpFromDT : TimeStamp;
	tmpToDate,
	tmpFromDate : Date;
	tmpVoyage : CM_Voyage;
	tmpCMIF : CMIF_BerthUsage;
begin
	tmpFromDate := self.filterFromDT.date;
	tmpFromDT.setDate(tmpFromDate);
	tmpToDate := self.filterToDT.date;
	
	includeFuture := self.ckbIncludeFuture.value;

	foreach term in self.allTerminals do
		delete iter;
		iter := term.allVoyagesByDepartDTCode.createIterator();
		
		// get inclomplete voyages
		if self.includeIncompleteItinerary then
			while iter.next(tmpVoyage) do
				if tmpVoyage.departedDT.isValid() then
					break;
				endif;
				// depart date not set so assume it's a future voyage
				if self.includeObject(tmpVoyage) then
					create tmpCMIF transient;
					tmpCMIF.setFromVoyage(tmpVoyage);			
					self.allBerthUsageByGroupType.add(tmpCMIF);
					self.allBerthUsageByVesselType.add(tmpCMIF);			
					self.allBerthUsageByBerthCode.add(tmpCMIF);								
				endif;
			endwhile;
		endif;

		term.allVoyagesByDepartDTCode.startKeyGeq(tmpFromDT, null, iter);

		while iter.next(tmpVoyage) do
			if tmpVoyage.departedDT.isValid() then
				if tmpVoyage.departedDT.date &lt; tmpFromDate then
					// voyage has departed
					continue;
				elseif tmpVoyage.departedDT.date &gt; tmpToDate then
					// voyage departs after this period
					if tmpVoyage.arrivedDT.date &lt; tmpToDate then
						// voyage is in port over this period
					elseif includeFuture then
						// arrive after this period but thye want to include future voyages
					else
						// arrives and departs after period
						continue;					
					endif;
				endif;
				if self.includeObject(tmpVoyage) then				
					create tmpCMIF transient;
					tmpCMIF.setFromVoyage(tmpVoyage);
					self.allBerthUsageByGroupType.add(tmpCMIF);
					self.allBerthUsageByVesselType.add(tmpCMIF);
					self.allBerthUsageByBerthCode.add(tmpCMIF);																				
				endif;
			endif;
		endwhile;		
				
	endforeach;
		
	self.displayBerthUsage();

epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="generateVoyageStat" id="028de306-70fe-43cb-9dd2-61def2112f84">
        <source>generateVoyageStat()protected;
//--------------------------------------------------
// Created:	02 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	group : Integer;
	groupArray : IntegerArray;
	term : CM_Terminal;
	tmpStat : CM_VoyageStatistic;
	tmpDate : Date;
	iter : Iterator;
	tmpAnaly : CMIF_VoyageAnalysis;
begin

	create groupArray transient;
	groupArray.add(VoyageStat_PassengerVesselCall);
	groupArray.add(VoyageStat_CargoVesselCall);
		
	foreach group in groupArray do

		foreach term in self.allTerminals do
			delete iter;
			iter := term.allVoyageStatistics.createIterator();
			term.allVoyageStatistics.startKeyGeq(tmpDate, group, null, iter);
			while iter.next(tmpStat) do
				if tmpStat.monthYear &gt; self.filterToDT.date then
					break;
				endif;
				if tmpStat.group &lt;&gt; group then
					break;
				endif;
				create tmpAnaly transient;
								
			endwhile;
		endforeach;

	endforeach;

epilog
	delete groupArray;
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getColourForMonth" id="da737570-5457-4ec0-8230-ba1eecb9f10a">
        <source>getColourForMonth(_mth : Integer) : Integer protected;
//--------------------------------------------------
// Created:	02 December 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	if _mth = 1 then
		return Red;
	elseif _mth = 2 then
		return White;
	elseif _mth = 3 then
		return Yellow;
	elseif _mth = 4 then
		return Gray;
	elseif _mth = 5 then
		return Green;
	elseif _mth = 6 then
		return self.ColourPink;
	elseif _mth = 7 then
		return self.ColourBlueLight;
	elseif _mth = 8 then
		return Blue;
	elseif _mth = 9 then
		return self.ColourYellowLight;
	elseif _mth = 10 then
		return LightGreen;
	elseif _mth = 11 then
		return Purple;
	elseif _mth = 12 then
		return DarkBlue;
	else
		return app.getRandomColour();																				
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_mth" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
