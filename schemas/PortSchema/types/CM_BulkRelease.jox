    <JadeMethod name="setProxy" id="000d0e58-12ab-4b56-a842-8ba8d1447baf">
        <updating/>
        <source>setProxy(_releaseNumber			: String;
		_type					: Integer;
		_releaseByType			: Boolean;
		_status					: Integer;
		_allAvailabilityGrades	: IntegerArray;
		_bookingConfirmation,
		_carrierId,
		_cargoRemarks,
		_consigneeCode,
		_consigneeDesc,
		_consignorCode,
		_consignorDesc,
		_consignorVoyageCode 	: String;
		_dateRequested,
		_dateEstimatedRequired	: TimeStamp;
		_deliveryReasonCode		: Integer;
		_deliveryReasonDescr,
		_deliveryReleaseNumber	: String;
		_doorsDirection			: Integer;
		_freightPayerCode		: String;
		_bookingRef				: CM_BookingRef;
		_loadPort,
		_destinationPort,	//03 Nov 2009	NDL Par 21519
		_dischargePort			: CM_Port;
		_freightForwarderCode	: String;			// PAR 20646 - was CM_ConsigneeConsignor;
		_transferToTerminal,
		_terminal				: CM_Terminal;
		_operator				: CM_Operator;
		_operatorGroup			: CM_OperatorGroup;
		_voyage					: CM_Voyage;
		_businessUnit			: CM_Bank;
// TFS 2686			_removeStops,
		_fullRelease			: Boolean;
		_allPackLocations		: StringArray;
		_poolPartner			: CM_Operator;
		_dispatchLocn 			: String;
		_subTerminal 			: CM_SubTerminal;
		_subTerminalTarget 		: CM_SubTerminal; //cnwrd1 par 23219 17.3.2010
		_assignedTrain 			: CM_Train;	//04 Nov 2009	NDL Par 21519
		_allowCargoOnMultiRel 	: Boolean;
		_customsAgent			: String;			// cnwrl1 19/02/2010 PAR 22393
		_customsAssistance		: Boolean;			// cnwrl1 19/02/2010 PAR 22393
		_canBeHiLoCube			: Boolean;			// May 2011 cnwjre1 27097 POL CCMS 2043
		_needsReview			: Boolean;			// par 28696
		_stopEDIUpdates			: Boolean;			// par 29480 April 2012
		_allEDIFiles 			: CM_EDIFileArray;	// CCMS POL 2122 / PAR 28696 cmwrs1 
		_expiryTimeStamp 		: TimeStamp;		//13 Feb 2017	NLD	TFS 3368
		_myBOLIn 				: CM_BOLIn;			// jlgka1 TFS 41708
		_context				: String) updating; // ### TFS 53953 27June2022 NAVPW1

/*
----------   ----------  --------------------------------------------------
Created:	18 May 2007 By cnwth2

Purpose:	

/* Changes

Date		Name	TFS#			Description
============================================================================
11/08/2011	cnwdap1	 				set converted attribute
24/11/2011	cnwcs5	CCMS POL 2122 
					/ par 28696 	new property needs Review
07/11/2011	cnwrs1	CCMS POL 2122 
					/ PAR 28696 	new property allEDIFiles
23/04/2012	cnwcs5	CCMS POL 2172 
					/ par 29480 	Coparn release updates
21/11/2014	cnwrs1	Par xxxx 		EDI failing with string too long.
24/01/2019	jlgka1 41708			Add the new reference myBOLIn.
============================================================================*/
vars
	ediFile : CM_EDIFile;
begin
	self.raiseExceptionIfNotTransient(method);

	self.bookingConfirmation	:= _bookingConfirmation;
	self.carrierId				:= _carrierId;
	self.cargoRemarks			:= _cargoRemarks;
	self.code					:= _releaseNumber.trimBlanks.toUpper;
	self.consigneeCode			:= _consigneeCode;
	self.consignorCode			:= _consignorCode;
	self.consignorVoyageCode 	:= _consignorVoyageCode;
	self.converted				:= true;						// PAR #27972
	self.customsAgent			:= _customsAgent;				// cnwrl1 19/02/2010 PAR 22393
	self.customsAssistance		:= _customsAssistance;			// cnwrl1 19/02/2010 PAR 22393
	self.dateEstimatedRequired 	:= _dateEstimatedRequired;
	self.dateRequested 			:= _dateRequested;
	self.deliveryReasonCode		:= _deliveryReasonCode;
	self.deliveryReasonDescr	:= _deliveryReasonDescr.trimBlanks;
	self.deliveryReleaseNumber	:= _deliveryReleaseNumber.trimBlanks;
	self.doorsDirection			:= _doorsDirection;
	self.expiryTimeStamp		:= _expiryTimeStamp;	//13 Feb 2017	NDL	TFS 3368
	self.freightForwarderCode	:= _freightForwarderCode[1:5];	// PAR 20646
	self.freightPayerCode		:= _freightPayerCode;
	//self.myFreightForwarder 	:= _freightForwarder;		// removed for PAR 20646
	self.fullRelease 			:= _fullRelease;
	self.myLoadPort				:= _loadPort;
	self.myDestinationPort		:= _destinationPort; //03 Nov 2009	NDL	Par 21519
	self.myDischargePort 		:= _dischargePort;
	self.status 				:= _status;
	self.myVoyage 				:= _voyage;
	self.myBusinessUnit			:= _businessUnit;
// TFS 2686		self.removeStops			:= _removeStops;
	self.releaseByType			:= _releaseByType;
	self.type					:= _type;
	self.dispatchLocation		:=_dispatchLocn;
	self.consigneeDesc			:=_consigneeDesc;
	self.consignorDesc			:=_consignorDesc;
	// Update collections
	self.myPoolPartner 			:= _poolPartner;
	self.myBookingRefStock		:=	_bookingRef;
	self.myOperator				:=	_operator;
	self.myOperatorGroup		:=	_operatorGroup;
	self.myTransferToTerminal	:=	_transferToTerminal;
	self.myTerminal				:=	_terminal;
	self.mySubTerminal			:=  _subTerminal;//30/04/2009 cnwdz2 ccms1735
	self.mySubTerminalTarget	:=  _subTerminalTarget;//cnwrd1 par 23219 17.3.2010
	self.myAssignedTrain		:= _assignedTrain;	//04 Nov 2009	NDL	Par 21519
	self.allowCargoOnMultipleReleases := _allowCargoOnMultiRel;
	self.canBeHiLoCube			:= _canBeHiLoCube;	// May 2011 cnwjre1 27097 POL CCMS 2043
	self.needsReview			:= _needsReview;	// par 28696
	self.blockEDIUpdates 		:= _stopEDIUpdates;	// par 29481 May 2012
	self.myBOLIn				:= _myBOLIn; 		// jlgka1 TFS 41708
	self.context				:= _context;		// ### TFS 53953 27June2022 NAVPW1
	
	if self.myOperator &lt;&gt; null then
		//now PAR16612 cnwsh3 Was causing a 1048 exception when using a newly created operator.  
		self.myOperatorTerminal := self.myOperator.getOperatorTerminal(self.myTerminal, false);
	endif;
	
	self.allPackLocations.clear();
	if self.type = BR_TYPE_PACKING and _allPackLocations &lt;&gt; null then
		_allPackLocations.copy(self.allPackLocations);
	endif;
	
	//jlier1 TFS  53558 27/5/22
	if _allAvailabilityGrades &lt;&gt; null  and _allAvailabilityGrades &lt;&gt; self.allAvailabilityGrades then //if it is the same primitive array then this will clear itself and update it with nothing
		self.allAvailabilityGrades.clear();
		_allAvailabilityGrades.copy(self.allAvailabilityGrades);
	endif;
	
	if _allEDIFiles &lt;&gt; null then
		foreach ediFile in _allEDIFiles do
			if not self.allEDIFiles.includes(ediFile) then
				self.allEDIFiles.add(ediFile);
			endif;
		endforeach;
	endif;
end;</source>
        <Parameter name="_releaseNumber" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_releaseByType" type="Boolean"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_allAvailabilityGrades" type="IntegerArray"/>
        <Parameter name="_bookingConfirmation" type="String"/>
        <Parameter name="_carrierId" type="String"/>
        <Parameter name="_cargoRemarks" type="String"/>
        <Parameter name="_consigneeCode" type="String"/>
        <Parameter name="_consigneeDesc" type="String"/>
        <Parameter name="_consignorCode" type="String"/>
        <Parameter name="_consignorDesc" type="String"/>
        <Parameter name="_consignorVoyageCode" type="String"/>
        <Parameter name="_dateRequested" type="TimeStamp"/>
        <Parameter name="_dateEstimatedRequired" type="TimeStamp"/>
        <Parameter name="_deliveryReasonCode" type="Integer"/>
        <Parameter name="_deliveryReasonDescr" type="String"/>
        <Parameter name="_deliveryReleaseNumber" type="String"/>
        <Parameter name="_doorsDirection" type="Integer"/>
        <Parameter name="_freightPayerCode" type="String"/>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
        <Parameter name="_loadPort" type="CM_Port"/>
        <Parameter name="_destinationPort" type="CM_Port"/>
        <Parameter name="_dischargePort" type="CM_Port"/>
        <Parameter name="_freightForwarderCode" type="String"/>
        <Parameter name="_transferToTerminal" type="CM_Terminal"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_operatorGroup" type="CM_OperatorGroup"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_businessUnit" type="CM_Bank"/>
        <Parameter name="_fullRelease" type="Boolean"/>
        <Parameter name="_allPackLocations" type="StringArray"/>
        <Parameter name="_poolPartner" type="CM_Operator"/>
        <Parameter name="_dispatchLocn" type="String"/>
        <Parameter name="_subTerminal" type="CM_SubTerminal"/>
        <Parameter name="_subTerminalTarget" type="CM_SubTerminal"/>
        <Parameter name="_assignedTrain" type="CM_Train"/>
        <Parameter name="_allowCargoOnMultiRel" type="Boolean"/>
        <Parameter name="_customsAgent" type="String"/>
        <Parameter name="_customsAssistance" type="Boolean"/>
        <Parameter name="_canBeHiLoCube" type="Boolean"/>
        <Parameter name="_needsReview" type="Boolean"/>
        <Parameter name="_stopEDIUpdates" type="Boolean"/>
        <Parameter name="_allEDIFiles" type="CM_EDIFileArray"/>
        <Parameter name="_expiryTimeStamp" type="TimeStamp"/>
        <Parameter name="_myBOLIn" type="CM_BOLIn"/>
        <Parameter name="_context" type="String"/>
