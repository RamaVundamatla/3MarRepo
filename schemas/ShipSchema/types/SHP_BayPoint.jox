    <JadeMethod name="clearAttributes" id="2de3d492-b533-4632-b494-7db0bc1eb6c7">
        <updating/>
        <source>clearAttributes(_theMode : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if _theMode = REAL_MODE then
//		self.allTrackedItemAttributes.clear;
	elseif _theMode = QUEUE_MODE then
		self.allQueuedTrackedItemAttributes.clear;
	elseif _theMode = PLANNING_MODE then
		self.allPlanTrackedItemAttributes.clear;
	endif;


	if _theMode = REAL_MODE then
		self.displayColoursACT.clear;
		self.allTrackedItems.clear;
		self.bayActAttribute1 := null;
		self.bayActAttribute2 := null;
		self.bayActAttribute3 := null;
		self.bayActAttribute4 := null;
		self.bayActAttribute5 := null;
		self.bayActAttribute6 := null;

	elseif _theMode = PLANNING_MODE then
		self.displayColoursPRO.clear;
		self.allPlannedTrackedItems.clear;
		self.bayProAttribute1 := null;
		self.bayProAttribute2 := null;
		self.bayProAttribute3 := null;
		self.bayProAttribute4 := null;
		self.bayProAttribute5 := null;
		self.bayProAttribute6 := null;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_theMode" type="Integer"/>
    </JadeMethod>
