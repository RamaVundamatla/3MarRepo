    <JadeMethod name="getDisplayStringForAttribute" id="0d3fe849-d6b4-47df-8e25-9b0f32578ac3">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:			

Date		Who		Reason
26 July 2021	navab1	TFS 50669
07 Oct 2022		jlika1	TFS 54892 - POB - Vessel, Voyage and Movement EDI Messages
*/

vars

begin
	if _attrName = ETRow_Changed then
		if self.changed.isValid then
			return self.systemToLocalTime(self.changed).String;
		else
			return null;
		endif;
	elseif _attrName = ETRow_ChangedBy then
		return self.changedUser;
	elseif _attrName = ETRow_Created then
		if self.created.isValid then
			return self.systemToLocalTime(self.created).String;
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_CreatedBy then
		return self.createdUser;
	elseif _attrName = ETRow_Description then
		return self.description;
	elseif _attrName = ETRow_Interface then
		return self.interfaceName;
	elseif _attrName = ETRow_Terminal then
		if self.myTerminal &lt;&gt; null then
			return self.myTerminal.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_Status then
		return self.status;
	elseif _attrName = ETRow_ResponseCode then
		return self.responseCode.String;
	elseif _attrName = ETRow_RequestName then
		return self.requestName.String;
	elseif _attrName = ETRow_ClientType then
		return "";
	elseif _attrName = ETRow_DataType then 
		return "";
	elseif _attrName = ETRow_DomainName then 
		return "";
	elseif _attrName = ETRow_LastSuccessfullTS then
		return "";
	elseif _attrName = ETRow_ServiceVersion then 
		return "";	
	elseif _attrName = ETRow_IsSnapshot then
		return "";
	elseif _attrName = ETRow_DataAction then
		return "";
	elseif _attrName = ETRow_Sequence then
		return "";
	endif;

	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialiseActivity" id="4b76e98d-2cca-4edb-b4db-0cd3d1bc4c4e">
        <updating/>
        <source>initialiseActivity(_description, _interface : String; _terminal : CM_Terminal; _opsViewObject : CM_Object; _dataAction: Character; _dataType : String; _snapshot : Boolean; _oid : String) updating;
/*
Purpose:			

Date		Who		Reason
03 August 2021	navab1	TFS 50669
*/

vars

begin
	self.createdUser := app.getMyUserCode();
	self.created := app.actualTimeServer();
	self.myTerminal := _terminal;
	self.myRoot := app.myRoot;
	self.description := _description;
	self.interfaceName := _interface;
	self.status := BGP_OpsViewWSRequest.EWS_STATUS_BGP_CREATED;
epilog

end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_interface" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_opsViewObject" type="CM_Object"/>
        <Parameter name="_dataAction" type="Character"/>
        <Parameter name="_dataType" type="String"/>
        <Parameter name="_snapshot" type="Boolean"/>
        <Parameter name="_oid" type="String"/>
    </JadeMethod>
    <JadeMethod name="initialiseStatus" id="f9429d85-b941-4c27-99dd-66cfcf5bc4b0">
        <updating/>
        <source>initialiseStatus(_status : String; _manager : BGP_Manager) updating;
/*
Purpose:			

Date		Who		Reason
26 July 2021	navab1	TFS 50669
*/

vars

begin
	if self.status &lt;&gt; BGP_OpsViewWSRequest.EWS_STATUS_BGP_CREATED 
	and _status &lt;&gt; BGP_OpsViewWSRequest.EWS_STATUS_DELETED then
		self.changed := app.actualTimeServer();
		self.changedUser := app.getMyUserCode();
	endif;
	self.status := _status;
	
epilog

end;</source>
        <Parameter name="_status" type="String"/>
        <Parameter name="_manager" type="BGP_Manager"/>
    </JadeMethod>
