    <JadeMethod name="cnEcConfirmAction" id="19ea66d8-ab00-4680-8f03-04b73a568608">
        <source>cnEcConfirmAction(pActionName:String; pEntityName:String):Boolean;
// --------------------------------------------------------------------------------
// Created:		25 July 2000 by cnwdad1
//
// Purpose:		Returns a flag after asking the User for confirmation of an action.
//
// Parameters:	pAction - A description of the action to be performed.
//				pEntityName - The name of the entity to be actioned.
//
// Returns:		True if the User has confirmed the action, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	userResponse	: Integer;
	
begin
	userResponse	:=	app.msgBox(	$CNEC_CONFIRM_ACTION(pActionName, pEntityName),
									$CNEC_WARNING,
									MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	
	return (userResponse = MsgBox_Return_Yes);
end;</source>
        <Parameter name="pActionName" type="String"/>
        <Parameter name="pEntityName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcConfirmDelete" id="7071da42-980e-475a-8937-0f1c6186ea4a">
        <source>cnEcConfirmDelete(pEntityName:String):Boolean;
// --------------------------------------------------------------------------------
// Created:		25 July 2000 by cnwdad1
//
// Purpose:		Returns a flag after asking the User for confirmation of a delete.
//
// Parameters:	pEntityName (String) - The name of the entity to be deleted.
//
// Returns:		True if the User has confirmed the delete, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	userResponse	: Integer;
	
begin
	userResponse	:=	app.msgBox(	$CNEC_CONFIRM_DELETE(pEntityName),
									$CNEC_WARNING,
									MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	
	return (userResponse = MsgBox_Return_Yes);
end;</source>
        <Parameter name="pEntityName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcDocumentModel" id="4ab62a28-7699-4784-9338-9b46aba3dafb">
        <source>cnEcDocumentModel(pParameterObj:CnEcDocParameter):String;
// --------------------------------------------------------------------------------
// Created:		22 August 2000 by cnwdad1
//
// Purpose:		Generates HTML documentation files for an entire class model.  The
//				files will be produced in a directory structure (beneath the starting
//				base directory) that reflects the schema/class hierarchy.
//
// Parameters:	pParameterObj - The parameter object which holds all of the options
//					to identity what, and how, to document the classes.
//
// Returns:		Null if there are no errors, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 11/10/2000	cnwdad1		Added method to generate an index of the documented classes.
// 23/01/2003	cnwdad1		Added the ability to include an alias for class and
//							property names in the XML class document file.
// 24/01/2003	cnwdad1		Added support for a restricted collection of methods to
//							document, which are specified in the XML class file.
//							Also changed the supported format of the XML file.
// 26/01/2003	cnwdad1		Added support for alias class names in the short index.
// 19/02/2003	cnwdad1		Added the allClasses property to the pTheParameter parameter
//							so that hyperlinks will not be generated to classes that
//							are not included in the documentation.
// 04/04/2006	cnwdad1		Change the dynamic dictionary of sorted classes to be
//							case-sensitive.
// --------------------------------------------------------------------------------
vars
	topSchemaObj		: Schema;
	bottomSchemaObj		: Schema;
	nextSchemaObj		: Schema;
	schemaObj			: Schema;
	docFilePath			: String;
	allSchemas			: SchemaColl;
	allSchemaClasses	: ClassColl;
	classObj			: Class;
	propertyObj			: Property;
	methodObj			: Method;
	aliasName			: String;
	directoryObj		: FileFolder;
	classTreeName		: String;
	pathBackToIndex		: String;
	allSortedClasses	: DynaDictionary;
	totalClassCount		: Integer;
	docListObj			: CnEcDocModelList;
	docSchemaObj		: CnEcDocModelSchema;
	docClassObj			: CnEcDocModelClass;
	xmlClassDocObj		: CnEcXmlGroupInstance;
	xmlFeatureDocObj	: CnEcXmlStructureInstance;
	xmlTagObj			: CnEcXmlStructureInstance;
	
begin
	self.causeEvent(CNEC_DOCMODEL_STEP_STARTING, true, "Collecting schemas and classes...");
	app.doWindowEvents(0);
	
	// Validate the requested range of schemas.
	
	if pParameterObj.isClassInputFile then
		if pParameterObj.mySchemaTop &lt;&gt; pParameterObj.mySchemaBottom then
			return "The top and bottom schemas must be the same when using a file to specify the classes to document.";
		else
			create allSchemas transient;
			bottomSchemaObj	:=	pParameterObj.mySchemaBottom;
			allSchemas.add(bottomSchemaObj);
		endif;
	else
		if pParameterObj.isIncludeJadeClasses then
			topSchemaObj	:=	rootSchema;
		else
			topSchemaObj	:=	rootSchema.getSchema(pParameterObj.mySchemaTop.name);
		
			if topSchemaObj = null then
				return "Please specify the top level schema you wish to document up to.";
			endif;
		endif;
	
		if pParameterObj.mySchemaBottom = null then
			bottomSchemaObj	:=	topSchemaObj;
		else
			bottomSchemaObj	:=	topSchemaObj.getSchema(pParameterObj.mySchemaBottom.name);
	
			if bottomSchemaObj = null then
				return "The schema you wish to document down to does not exist (as a subschema of " &amp; topSchemaObj.name &amp; ").";
			endif;
		endif;
	
		// Scan backwards through the schema hierarchy until we get to the top.
	
		create allSchemas transient;
		nextSchemaObj	:=	bottomSchemaObj;
	
		while true do
			allSchemas.insert(1, nextSchemaObj);
	
			if nextSchemaObj = topSchemaObj then
				break;
			endif;
	
			nextSchemaObj	:=	nextSchemaObj.superschema;
		endwhile;
	endif;
	
	self.causeEvent(CNEC_DOCMODEL_STEP_SCHEMACOUNT, true, allSchemas.size());
	app.doWindowEvents(0);
	
	create docListObj transient;
	
	// If the classes and properties to document are specified by an XML input file,
	// then we'll build a list of them from the XML document, otherwise we'll build
	// a list of all classes from all of the schemas in the requested range.
	
	if pParameterObj.isClassInputFile then
		bottomSchemaObj	:=	pParameterObj.mySchemaBottom;
		docSchemaObj	:=	docListObj.createDocSchema(bottomSchemaObj);
		xmlClassDocObj	:=	pParameterObj.myXmlClassDoc;
		
		foreach xmlTagObj in xmlClassDocObj.allFields do
			if xmlTagObj.tagName.toLower() = self.DOC_MODEL_CLASS then
				classObj		:=	bottomSchemaObj.getClass(xmlTagObj.getTagAttribute(self.DOC_MODEL_NAME));
				
				if classObj = null then
					continue;
				endif;
				
				aliasName		:=	xmlTagObj.getTagAttribute(self.DOC_MODEL_ALIAS);
				docClassObj		:=	docSchemaObj.createDocClass(classObj, aliasName);
				
				if CnEcXmlGroupInstance.hasInstance(xmlTagObj) then
					foreach xmlFeatureDocObj in xmlTagObj.CnEcXmlGroupInstance.allFields do
						aliasName	:=	xmlFeatureDocObj.getTagAttribute(self.DOC_MODEL_ALIAS);
						
						if xmlFeatureDocObj.tagName.toLower() = self.DOC_MODEL_PROPERTY then
							propertyObj	:=	classObj.getProperty(xmlFeatureDocObj.getTagAttribute(self.DOC_MODEL_NAME));
							
							if propertyObj = null then
								continue;
							endif;
							
							docClassObj.createDocProperty(propertyObj, aliasName);
							
						elseif xmlFeatureDocObj.tagName.toLower() = self.DOC_MODEL_METHOD then
							methodObj	:=	classObj.getMethod(xmlFeatureDocObj.getTagAttribute(self.DOC_MODEL_NAME));
							
							if methodObj = null then
								continue;
							endif;
							
							docClassObj.createDocMethod(methodObj, aliasName);
							
						endif;
					endforeach;
				endif;
			endif;
		endforeach;
		
		docSchemaObj.resolveSuperclassAliases();
	else
		foreach schemaObj in allSchemas do
			docSchemaObj		:=	docListObj.createDocSchema(schemaObj);
			allSchemaClasses	:=	schemaObj.getAllClasses(pParameterObj.isIncludeJadeClasses);
			
			foreach classObj in allSchemaClasses do
				docSchemaObj.createDocClass(classObj, null);
			endforeach;
		endforeach;
	endif;
	
	pParameterObj.populateClassAndFeatureLists(docListObj);
	totalClassCount	:=	pParameterObj.allClasses.size();
	
	self.causeEvent(CNEC_DOCMODEL_STEP_CLASSCOUNT, true, totalClassCount);
	app.doWindowEvents(0);
	
	// Now search through all of the schemas' classes, documenting them as we go.
	
	create directoryObj transient;
	create allSortedClasses transient;
	allSortedClasses.setMembership(Class);
//	allSortedClasses.addMemberKey(Class::name.name, false, true);
	allSortedClasses.addMemberKey(Class::name.name, false, false);
	allSortedClasses.endKeys(false);
	
	foreach docSchemaObj in docListObj.allDocSchemas do
		self.causeEvent(CNEC_DOCMODEL_STEP_SCHEMA, true, docSchemaObj.schemaName);
		app.doWindowEvents(0);
		
		foreach docClassObj in docSchemaObj.allDocClasses do
			self.causeEvent(CNEC_DOCMODEL_STEP_CLASS, true, docClassObj.className);
			app.doWindowEvents(0);
			
			if not docClassObj.myClass.rootType().schema = docSchemaObj.mySchema then
				continue;
			endif;
			
			classTreeName			:=	docClassObj.myClass.cnEcGetClassTreeName();
			pathBackToIndex			:=	classTreeName &amp; global.cnEcGetFileSeparator();
			docFilePath				:=	pParameterObj.baseDirectory &amp; global.cnEcGetFileSeparator() &amp; classTreeName;
			directoryObj.fileName	:=	docFilePath;

			if not directoryObj.isValidPathName(docFilePath) then
				return "'" &amp; docFilePath &amp; "' is not a valid path name for the '" &amp; docClassObj.className &amp; "' class";
			endif;

			if not directoryObj.isAvailable() then
				directoryObj.make();
			endif;
			
			docClassObj.myClass.cnEcDocumentSelf(	pParameterObj,
													docClassObj.alias,
													docClassObj.superclassAlias,
													docClassObj.allDocProperties,
													docClassObj.allDocMethods,
													docFilePath,
													allSchemas,
													pathBackToIndex);
			
			allSortedClasses.add(docClassObj.myClass);
		endforeach;
	endforeach;
	
	// Finish up by building indexes and heading/preface pages.
	
	self.cnEcDocumentModelIndex(allSortedClasses, pParameterObj, docSchemaObj);
	self.cnEcDocumentModelHeadings(pParameterObj);
	self.causeEvent(CNEC_DOCMODEL_STEP_DONE, true, null);
	app.doWindowEvents(0);

	return null;
epilog
	delete docListObj;
	delete directoryObj;
	delete allSchemas;
	delete allSortedClasses;
	delete allSchemaClasses;
end;</source>
        <Parameter name="pParameterObj" type="CnEcDocParameter"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcDocumentModelHeadings" id="84968d66-4225-4e39-807e-0c0424bb1758">
        <source>cnEcDocumentModelHeadings(pParameterObj:CnEcDocParameter) protected;
// --------------------------------------------------------------------------------
// Created:		30 October 2002 by cnwdad2
//
// Purpose:		This method will (optionally) build two HTML file containing Heading
//				details and a Preface page for a model's documented classes.
//
// Parameters:	pParameterObj - A parameter object containing all of the settings
//					and options for the documented classes.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 25/02/2003	cnwdad1		Fixed a problem where the JADE and product logo file
//							names didn't require the "..\" prefix in the HTML.
// --------------------------------------------------------------------------------
vars
	parameterObj		: CnEcDocParameter;
	headingFileObj		: File;
	headingHtml			: String;
	prefaceFileObj		: File;
	prefaceHtml			: String;
	jadeLogoFileObj		: File;
	productLogoFileObj	: File;
	fileSeparator		: String;
	htmlPageObj			: CnEcHtmlPage;
	pageHeadObj			: CnEcPageHead;
	pageBodyObj			: CnEcPageBody;
	paragraphObj		: CnEcHtmlParagraphTag;
	imageObj			: CnEcHtmlImageTag;
	fontObj				: CnEcHtmlFontTag;
	rulerObj			: CnEcHtmlHorizontalRuleTag;
	
begin
	parameterObj	:=	pParameterObj;
	fileSeparator	:=	global.cnEcGetFileSeparator();
	create htmlPageObj transient;
	
	if parameterObj.isGenerateHeader then
		// First write the Jade and product logo image files to the base directory.
		
		create jadeLogoFileObj transient;
		jadeLogoFileObj.kind		:=	File.Kind_Binary;
		jadeLogoFileObj.fileName	:=	parameterObj.baseDirectory &amp; fileSeparator &amp; CNEC_CLASS_DOC_JADE_LOGO_NAME;
		jadeLogoFileObj.writeBinary(parameterObj.jadeLogo);
		
		if parameterObj.isProductLogo then
			create productLogoFileObj transient;
			productLogoFileObj.kind		:=	File.Kind_Binary;
			productLogoFileObj.fileName	:=	parameterObj.baseDirectory &amp; fileSeparator &amp; parameterObj.productLogoName;
			productLogoFileObj.writeBinary(parameterObj.productLogo);
		endif;
		
		// Start building the HTML page.
		
		create htmlPageObj transient;
		
		pageHeadObj				:=	htmlPageObj.myHead;
		pageHeadObj.headTitle	:=	"Class Documentation Heading - " &amp; parameterObj.mySchemaBottom.name;
		pageBodyObj				:=	htmlPageObj.myBody;
		
		// Do the Jade logo.
		
		paragraphObj			:=	pageBodyObj.createParagraph();
		paragraphObj.setParagraphAlign(CnEcHtmlTagObject.ALIGN_CENTER);
		imageObj				:=	paragraphObj.createImage();
// cnwdad1 25/02/2003.
//		imageObj.imageSource	:=	".." &amp; fileSeparator &amp; CNEC_CLASS_DOC_JADE_LOGO_NAME;
		imageObj.imageSource	:=	CNEC_CLASS_DOC_JADE_LOGO_NAME;
		
		// Do the Group Name.
		
		paragraphObj			:=	pageBodyObj.createParagraph();
		paragraphObj.setParagraphAlign(CnEcHtmlTagObject.ALIGN_CENTER);
		fontObj					:=	paragraphObj.createFont();
		fontObj.setFontSize(6, true);
		fontObj.fontValue		:=	parameterObj.groupName;
		
		// Do the Title.
		
		paragraphObj			:=	pageBodyObj.createParagraph();
		paragraphObj.setParagraphAlign(CnEcHtmlTagObject.ALIGN_CENTER);
		fontObj					:=	paragraphObj.createFont();
		fontObj.setFontSize(3, true);
		fontObj.fontValue		:=	parameterObj.docTitle;
		
		// Do the Version.
		
		paragraphObj			:=	pageBodyObj.createParagraph();
		paragraphObj.setParagraphAlign(CnEcHtmlTagObject.ALIGN_CENTER);
		fontObj					:=	paragraphObj.createFont();
		fontObj.setFontSize(2, true);
		fontObj.fontValue		:=	"Version " &amp; parameterObj.docVersion;
		
		// Do the Date.
		
		paragraphObj			:=	pageBodyObj.createParagraph();
		paragraphObj.setParagraphAlign(CnEcHtmlTagObject.ALIGN_CENTER);
		fontObj					:=	paragraphObj.createFont();
		fontObj.setFontSize(2, true);
		fontObj.fontValue		:=	"Date " &amp; parameterObj.docDate.format("dd MMMM yyyy");
		
		// Do the product logo and copyright stuff.
		
		rulerObj				:=	pageBodyObj.createHorizontalRule();
		rulerObj.setRuleAlign(CnEcHtmlTagObject.ALIGN_CENTER);
		
		paragraphObj			:=	pageBodyObj.createParagraph();
		paragraphObj.setParagraphAlign(CnEcHtmlTagObject.ALIGN_RIGHT);
		
		if parameterObj.isProductLogo then
			imageObj				:=	paragraphObj.createImage();
// cnwdad1 25/02/2003.
//			imageObj.imageSource	:=	".." &amp; fileSeparator &amp; theParameter.productLogoName;
			imageObj.imageSource	:=	parameterObj.productLogoName;
		endif;
		
		paragraphObj			:=	pageBodyObj.createParagraph();
		paragraphObj.setParagraphAlign(CnEcHtmlTagObject.ALIGN_RIGHT);
		fontObj					:=	paragraphObj.createFont();
		fontObj.setFontSize(2, false);
		fontObj.fontValue		:=	CrLf &amp; CrLf &amp; CrLf &amp; CrLf &amp; CrLf &amp; CrLf &amp; "Copyright © " &amp; parameterObj.docDate.String &amp; CrLf &amp; "Jade Software Corporation" &amp; CrLf &amp; "All rights reserved";
		
		headingHtml	:=	htmlPageObj.getHtml();
		
		create headingFileObj transient;
		
		// Open the heading file, build the HTML, and write it to the file.
	
		headingFileObj.openOutput(parameterObj.baseDirectory &amp; fileSeparator &amp; CNEC_CLASS_DOC_HEADING_NAME);
		headingFileObj.writeLine(headingHtml);
		
		delete htmlPageObj;
	endif;
	
	if parameterObj.isGeneratePreface then
		// Start building the HTML page.
		
		create htmlPageObj transient;
		
		pageHeadObj				:=	htmlPageObj.myHead;
		pageHeadObj.headTitle	:=	"Class Documentation Preface - " &amp; parameterObj.mySchemaBottom.name;
		pageBodyObj				:=	htmlPageObj.myBody;
		
		// Do the Overview.
		
		paragraphObj			:=	pageBodyObj.createParagraph();
		paragraphObj.setParagraphAlign(CnEcHtmlTagObject.ALIGN_LEFT);
		fontObj					:=	paragraphObj.createFont();
		fontObj.setFontSize(4, true);
		fontObj.fontValue		:=	"Overview";
		
		paragraphObj			:=	pageBodyObj.createParagraph();
		paragraphObj.setParagraphAlign(CnEcHtmlTagObject.ALIGN_LEFT);
		fontObj					:=	paragraphObj.createFont();
		fontObj.setFontSize(1, true);
		fontObj.fontValue		:=	parameterObj.productOverview;
		
		rulerObj				:=	pageBodyObj.createHorizontalRule();
		rulerObj.setRuleAlign(CnEcHtmlTagObject.ALIGN_CENTER);
		
		paragraphObj			:=	pageBodyObj.createParagraph();
		paragraphObj.setParagraphAlign(CnEcHtmlTagObject.ALIGN_LEFT);
		fontObj					:=	paragraphObj.createFont();
		fontObj.setFontSize(2, false);
		fontObj.fontValue		:=	CrLf &amp; CrLf &amp; CrLf &amp; CrLf &amp; CrLf &amp;
									"Jade Software Corporation Limited cannot accept any financial " &amp;
									"or other responsibilities that may be the result of your use of " &amp;
									"this information or software material, including direct, indirect, " &amp;
									"special or consequential damages, or loss of profits.  There are " &amp;
									"no warranties extended or granted by this document or software " &amp;
									"material";
		
		paragraphObj			:=	pageBodyObj.createParagraph();
		paragraphObj.setParagraphAlign(CnEcHtmlTagObject.ALIGN_LEFT);
		fontObj					:=	paragraphObj.createFont();
		fontObj.setFontSize(2, false);
		fontObj.fontValue		:=	CrLf &amp; CrLf &amp; CrLf &amp; CrLf &amp; CrLf &amp;
									"You should be very careful to ensure that the use of this software " &amp;
									"material and/or information complies with the laws, rules, and " &amp;
									"regulations of the juristictions with respect to which it is used.  " &amp;
									"No part of this document may be reproduced or transmitted in any " &amp;
									"form or by any means, electronic or mechanical, for any purpose, " &amp;
									"without the express written permission of Jade Software Corporation " &amp;
									"Limited.";
		
		paragraphObj			:=	pageBodyObj.createParagraph();
		paragraphObj.setParagraphAlign(CnEcHtmlTagObject.ALIGN_LEFT);
		fontObj					:=	paragraphObj.createFont();
		fontObj.setFontSize(2, false);
		fontObj.fontValue		:=	CrLf &amp; CrLf &amp; CrLf &amp; CrLf &amp; CrLf &amp;
									"The information contained herein is subject to change without " &amp;
									"notice.  Revisions may be issued to advise of such changes and/or " &amp;
									"additions";
		
		paragraphObj			:=	pageBodyObj.createParagraph();
		paragraphObj.setParagraphAlign(CnEcHtmlTagObject.ALIGN_LEFT);
		fontObj					:=	paragraphObj.createFont();
		fontObj.setFontSize(2, false);
		fontObj.fontValue		:=	CrLf &amp; CrLf &amp; CrLf &amp; CrLf &amp; CrLf &amp;
									"Copyright © " &amp; parameterObj.docDate.String &amp; " Jade Software Corporation Limited." &amp; CrLf &amp;
									"All rights reserved.";
		
		paragraphObj			:=	pageBodyObj.createParagraph();
		paragraphObj.setParagraphAlign(CnEcHtmlTagObject.ALIGN_LEFT);
		fontObj					:=	paragraphObj.createFont();
		fontObj.setFontSize(2, false);
		fontObj.fontValue		:=	CrLf &amp; CrLf &amp; CrLf &amp; CrLf &amp; CrLf &amp;
									"JADE is a trademark of Jade Software Corporation Limited.  All trade " &amp;
									"names referenced are the service mark, trademark, or registered " &amp;
									"trademark of the respective manufacturer";
		
		create prefaceFileObj transient;
		
		// Open the preface file, build the HTML, and write it to the file.
		
		prefaceHtml	:=	htmlPageObj.getHtml();
		
		prefaceFileObj.openOutput(parameterObj.baseDirectory &amp; global.cnEcGetFileSeparator() &amp; CNEC_CLASS_DOC_PREFACE_NAME);
		prefaceFileObj.writeLine(prefaceHtml);
		
		delete htmlPageObj;
	endif;
epilog
	delete headingFileObj;
	delete prefaceFileObj;
	delete jadeLogoFileObj;
	delete productLogoFileObj;
	delete htmlPageObj;
end;</source>
        <access>protected</access>
        <Parameter name="pParameterObj" type="CnEcDocParameter"/>
    </JadeMethod>
    <JadeMethod name="cnEcDocumentModelIndex" id="a5f457d5-1f75-4775-8ca7-f935ad3a53ae">
        <source>cnEcDocumentModelIndex(	pSortedClassNameColl:DynaDictionary;
						pParameterObj:CnEcDocParameter;
						pDocSchemaObj:CnEcDocModelSchema) protected;
// --------------------------------------------------------------------------------
// Created:		11 October 2000 by cnwdad1
//
// Purpose:		This method will build an HTML file containing an index (Unordered
//				HTML List) of a model's documented classes.
//
// Parameters:	pSortedClassNameColl - A collection of all classes
//					that have been documented.
//				pParameterObj - A parameter object containing all of the settings
//					and options for the documented classes.
//				pDocSchemaObj - A reference to the Schema being documented
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 26/01/2003	cnwdad1		Added support for alias class names in the short index.
// --------------------------------------------------------------------------------
vars
	htmlMainIndexFile	: File;

begin
	self.cnEcDocumentModelIndexShort(pSortedClassNameColl, pParameterObj.baseDirectory, pDocSchemaObj);
	self.cnEcDocumentModelIndexLong(pParameterObj.baseDirectory);
	
	// Next, create a main index of the two class index files.
	
	create htmlMainIndexFile transient;

	// Write the HTML header details. 

	htmlMainIndexFile.openOutput(pParameterObj.baseDirectory &amp; global.cnEcGetFileSeparator() &amp; CNEC_CLASS_DOC_MAIN_INDEX);
	htmlMainIndexFile.writeLine("&lt;HTML&gt;&lt;HEAD&gt;&lt;TITLE&gt;" &amp; CNEC_CLASS_DOC_MAIN_NAME &amp; "&lt;/TITLE&gt;&lt;/HEAD&gt;");
	htmlMainIndexFile.writeLine("&lt;BODY&gt;&lt;BASEFONT FACE=" &amp; 34.Character &amp; "Arial" &amp; 34.Character &amp;  " SIZE=" &amp; 34.Character &amp; "2" &amp; 34.Character &amp; "&gt;");
	htmlMainIndexFile.writeLine("&lt;H2&gt;&lt;P ALIGN=" &amp; 34.Character &amp; "center" &amp; 34.Character &amp; "&gt;&lt;STRONG&gt;" &amp; CNEC_CLASS_DOC_MAIN_NAME &amp; "&lt;/STRONG&gt;&lt;/H2&gt;&lt;/P&gt;"); 
	
	
	// Now write an "Unordered List" of class the index files.

	htmlMainIndexFile.writeLine("&lt;UL&gt;");

	if pParameterObj.isGenerateHeader then
		htmlMainIndexFile.writeLine("&lt;LI&gt;&lt;A HREF=" &amp; 34.Character &amp; CNEC_CLASS_DOC_HEADING_NAME &amp; 34.Character &amp; "&gt;" &amp; "Heading" &amp; "&lt;/A&gt;&lt;/LI&gt;");
	endif;
	
	if pParameterObj.isGeneratePreface then
		htmlMainIndexFile.writeLine("&lt;LI&gt;&lt;A HREF=" &amp; 34.Character &amp; CNEC_CLASS_DOC_PREFACE_NAME &amp; 34.Character &amp; "&gt;" &amp; "Preface" &amp; "&lt;/A&gt;&lt;/LI&gt;");
	endif;
	
	htmlMainIndexFile.writeLine("&lt;LI&gt;&lt;A HREF=" &amp; 34.Character &amp; CNEC_CLASS_DOC_NAME_INDEX &amp; 34.Character &amp; "&gt;" &amp; CNEC_CLASS_DOC_NAME_NAME &amp; "&lt;/A&gt;&lt;/LI&gt;");
	htmlMainIndexFile.writeLine("&lt;LI&gt;&lt;A HREF=" &amp; 34.Character &amp; CNEC_CLASS_DOC_HIERARCHY_INDEX &amp; 34.Character &amp; "&gt;" &amp; CNEC_CLASS_DOC_HIERARCHY_NAME &amp; "&lt;/A&gt;&lt;/LI&gt;");

	htmlMainIndexFile.writeLine("&lt;/UL&gt;");
	htmlMainIndexFile.writeLine("&lt;P&gt;End of Index&lt;/P&gt;");

	// Finally, write the closing HTML page tags.

	htmlMainIndexFile.writeLine("&lt;/BODY&gt;&lt;/HTML&gt;");
epilog
	delete htmlMainIndexFile;
end;</source>
        <access>protected</access>
        <Parameter name="pSortedClassNameColl" type="DynaDictionary"/>
        <Parameter name="pParameterObj" type="CnEcDocParameter"/>
        <Parameter name="pDocSchemaObj" type="CnEcDocModelSchema"/>
    </JadeMethod>
    <JadeMethod name="cnEcDocumentModelIndexLong" id="42a8b77a-8f7e-47e6-805c-4cccd529b309">
        <source>cnEcDocumentModelIndexLong(pBaseDirectory:String) protected;
// --------------------------------------------------------------------------------
// Created:		11 October 2000 by cnwdad1
//
// Purpose:		This method will build an HTML file containing an index (Unordered
//				HTML List) of a model's documented classes.
//
//				The hyperlink names in this index will include the full class hierarchy.
//
// Parameters:	pBaseDirectory (String) - The name of the base documentation file path.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlLongIndexFile	: File;
	fileFolderObj		: FileFolder;
	docFileNameArray	: CnEcArray;
	docFileNameObj		: CnEcArrayObject;
	relativePath		: String;		// Relative URL path to the class document from the index document.
	
begin
	create htmlLongIndexFile transient;

	// Open the index file and write the heading details.

	htmlLongIndexFile.openOutput(pBaseDirectory &amp; global.cnEcGetFileSeparator() &amp; CNEC_CLASS_DOC_HIERARCHY_INDEX);
	htmlLongIndexFile.writeLine("&lt;HTML&gt;&lt;HEAD&gt;&lt;TITLE&gt;" &amp; CNEC_CLASS_DOC_HIERARCHY_NAME &amp; "&lt;/TITLE&gt;&lt;/HEAD&gt;");
	htmlLongIndexFile.writeLine("&lt;BODY&gt;&lt;BASEFONT FACE=" &amp; 34.Character &amp; "Arial" &amp; 34.Character &amp;  " SIZE=" &amp; 34.Character &amp; "2" &amp; 34.Character &amp; "&gt;");
	htmlLongIndexFile.writeLine("&lt;H2&gt;&lt;P ALIGN=" &amp; 34.Character &amp; "center" &amp; 34.Character &amp; "&gt;&lt;STRONG&gt;" &amp; CNEC_CLASS_DOC_HIERARCHY_NAME &amp; "&lt;/STRONG&gt;&lt;/H2&gt;&lt;/P&gt;"); 

	// write a hyperlink back to the main index file.
	
	htmlLongIndexFile.writeLine("&lt;P&gt;&lt;A HREF=" &amp; 34.Character &amp; CNEC_CLASS_DOC_MAIN_INDEX &amp; 34.Character &amp; "&gt;Back To Main Index&lt;/A&gt;&lt;/P&gt;");

	// Get a list (array) of all file names beneath the "Object" directory,
	// then create an index of those files.
	
	create docFileNameArray transient;
	create fileFolderObj transient;

	fileFolderObj.fileName	:=	pBaseDirectory &amp; global.cnEcGetFileSeparator() &amp; "Object" &amp; global.cnEcGetFileSeparator();
	self.cnEcGetAllFileNames(fileFolderObj, docFileNameArray, true);

	// Next, write the details of each class documentation file (as an HTML Unordered List).

	htmlLongIndexFile.writeLine("&lt;UL&gt;");

	foreach docFileNameObj in docFileNameArray do
		// Strip out the name of the base file path (including the directory slash).
		// The rest of the name is the relative part (i.e. relative to this index file).
		relativePath	:=	docFileNameObj.getStringValue[(pBaseDirectory.length + 2):end];
		
		htmlLongIndexFile.writeLine("&lt;LI&gt;&lt;A HREF=" &amp; 34.Character &amp; relativePath &amp; 34.Character &amp; "&gt;" &amp; relativePath &amp; "&lt;/A&gt;&lt;/LI&gt;");
	endforeach;
	
	htmlLongIndexFile.writeLine("&lt;/UL&gt;");
	htmlLongIndexFile.writeLine("&lt;P&gt;End of Index&lt;/P&gt;");

	// Finally, write the closing HTML page tags.

	htmlLongIndexFile.writeLine("&lt;/BODY&gt;&lt;/HTML&gt;");
epilog
	delete htmlLongIndexFile;
	delete docFileNameArray;
	delete fileFolderObj;
end;</source>
        <access>protected</access>
        <Parameter name="pBaseDirectory" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcDocumentModelIndexShort" id="5205dd23-4f2c-4c14-9d78-ba346f6c9cc9">
        <source>cnEcDocumentModelIndexShort(pSortedClassNameColl:DynaDictionary;
							pBaseDirectory:String;
							pDocSchemaObj:CnEcDocModelSchema) protected;
// --------------------------------------------------------------------------------
// Created:		13 October 2000 by cnwdad1
//
// Purpose:		This method will build an HTML file containing an index (Unordered
//				HTML List) of a model's documented classes.
//
//				The hyperlink names in this index will include only the class name.
//
// Parameters:	pSortedClassNameColl - A collection of all classes that have been
//					documented.
//				pBaseDirectory - The name of the base documentation file path.
//				pDocSchemaObj - A reference to the Schema being documented
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 26/01/2003	cnwdad1		Added support for alias class names.
// --------------------------------------------------------------------------------
vars
	htmlShortIndexFile	: File;
	classObject			: Object;
	shortFileName		: String;		// The filename without the file path.
	relativePath		: String;		// Relative URL path to the class document from the index document.
	nameOfClass			: String;
	
begin
	create htmlShortIndexFile transient;

	// Open the index file and write the heading details.

	htmlShortIndexFile.openOutput(pBaseDirectory &amp; global.cnEcGetFileSeparator() &amp; CNEC_CLASS_DOC_NAME_INDEX);
	htmlShortIndexFile.writeLine("&lt;HTML&gt;&lt;HEAD&gt;&lt;TITLE&gt;" &amp; CNEC_CLASS_DOC_NAME_NAME &amp; "&lt;/TITLE&gt;&lt;/HEAD&gt;");
	htmlShortIndexFile.writeLine("&lt;BODY&gt;&lt;BASEFONT FACE=" &amp; 34.Character &amp; "Arial" &amp; 34.Character &amp;  " SIZE=" &amp; 34.Character &amp; "2" &amp; 34.Character &amp; "&gt;");
	htmlShortIndexFile.writeLine("&lt;H2&gt;&lt;P ALIGN=" &amp; 34.Character &amp; "center" &amp; 34.Character &amp; "&gt;&lt;STRONG&gt;" &amp; CNEC_CLASS_DOC_NAME_NAME &amp; "&lt;/STRONG&gt;&lt;/H2&gt;&lt;/P&gt;"); 

	// write a hyperlink back to the main index file.
	
	htmlShortIndexFile.writeLine("&lt;P&gt;&lt;A HREF=" &amp; 34.Character &amp; CNEC_CLASS_DOC_MAIN_INDEX &amp; 34.Character &amp; "&gt;Back To Main Index&lt;/A&gt;&lt;/P&gt;");

	// Next, write the details of each class documentation file (as an HTML Unordered List).

	htmlShortIndexFile.writeLine("&lt;UL&gt;");

	foreach classObject in pSortedClassNameColl do
		shortFileName	:=	classObject.Class.name;
		
		if pDocSchemaObj &lt;&gt; null then
			nameOfClass		:=	pDocSchemaObj.allDocClasses[shortFileName].alias;
			
			if nameOfClass = null then
				nameOfClass	:=	shortFileName;
			endif;
		endif;
		
		// Strip out the name of the base file path (including the directory slash).
		// The rest of the name is the relative part (i.e. relative to this index file).
		relativePath	:=	classObject.Class.cnEcGetClassTreeName() &amp; global.cnEcGetFileSeparator() &amp; shortFileName &amp; CNEC_CLASS_DOC_HTML_SUFFIX;
		
		htmlShortIndexFile.writeLine("&lt;LI&gt;&lt;A HREF=" &amp; 34.Character &amp; relativePath &amp; 34.Character &amp; "&gt;" &amp; nameOfClass &amp; "&lt;/A&gt;&lt;/LI&gt;");
	endforeach;
	
	htmlShortIndexFile.writeLine("&lt;/UL&gt;");
	htmlShortIndexFile.writeLine("&lt;P&gt;End of Index&lt;/P&gt;");

	// Finally, write the closing HTML page tags.

	htmlShortIndexFile.writeLine("&lt;/BODY&gt;&lt;/HTML&gt;");
epilog
	delete htmlShortIndexFile;
end;</source>
        <access>protected</access>
        <Parameter name="pSortedClassNameColl" type="DynaDictionary"/>
        <Parameter name="pBaseDirectory" type="String"/>
        <Parameter name="pDocSchemaObj" type="CnEcDocModelSchema"/>
    </JadeMethod>
    <JadeMethod name="cnEcEditTextFile" id="fe49c546-0328-4336-8afa-87a89fd6a46f">
        <source>cnEcEditTextFile(pFileName:String):Integer;
// --------------------------------------------------------------------------------
// Created:		15 June 2007 by cnwdad1
//
// Purpose:		Opens the specified text file in the default editor (i.e. Notepad).
//
// Parameters:	pFileName - The name of the text file to edit.  If this is null or
//					is not valid, the method will fail to open the editor.
//
// Returns:		The result value of the Windows call.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 22/11/2021	navmd1		TFS 52434 Add Unicode support
// --------------------------------------------------------------------------------
vars
	result : Integer;
begin
	if app.isUnicode() then
		result := call cnEcShellExecuteW(1, "edit", pFileName, null, null, 1);
	else
		result := call cnEcShellExecuteA(1, "edit", pFileName, null, null, 1);
	endif;
	
	return result;
end;</source>
        <Parameter name="pFileName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcExploreDirectory" id="c05306ca-7b92-4091-8709-e4ea795f8861">
        <source>cnEcExploreDirectory(pPathName:String):Integer;
// --------------------------------------------------------------------------------
// Created:		15 June 2007 by cnwdad1
//
// Purpose:		Opens a Windows Explorer window at the specified directory.
//
// Parameters:	pPathName - The name of the directory to explore.
//
// Returns:		The result value of the Windows call.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 22/11/2021	navmd1		TFS 52434 Add Unicode support
// --------------------------------------------------------------------------------
vars
	result : Integer;
begin
	if app.isUnicode() then
		result := call cnEcShellExecuteW(1, "explore", pPathName, null, null, 1);
	else
		result := call cnEcShellExecuteA(1, "explore", pPathName, null, null, 1);
	endif;
	
	return result;
end;</source>
        <Parameter name="pPathName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcFileException" id="afd9588f-7daf-4415-89b9-fe4b0fcd9cd4">
        <source>cnEcFileException(pExceptionObj:FileException):Integer;
// --------------------------------------------------------------------------------
// Created:		03 August 2000 by cnwdad2
//
// Purpose:		This is an exception handler specifically for File Exceptions.
//				This handler is intended to be for localized file operations only,
//				it is not meant to be armed globally.
//
// Parameters:	pExceptionObj - The raised exception object.
//
// Returns:		Passes back and "Abort Action" response.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 25/10/2000	cnwdad1		Changed to return a "Pass Back" value if the exception
//							occurred on the server node (message box dialogs cannot
//							be displayed on the server node, and there'd be no point
//							even if you could).
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	if node.isServerNode then
		return Ex_Pass_Back;
	else
		errorMessage	:=	pExceptionObj.text() &amp; CrLf &amp; CrLf &amp; "File: " &amp; pExceptionObj.file().fileName;

		app.msgBox(errorMessage, $CNEC_FILE_ERROR, MsgBox_Stop_Icon + MsgBox_OK_Only);
		return Ex_Abort_Action;
	endif;
end;</source>
        <Parameter name="pExceptionObj" type="FileException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcFileGet" id="1d577934-fa63-48e6-906c-7a125831d153">
        <source>cnEcFileGet(pIsFileMustExist:Boolean; pFileFilter:String):String;
// --------------------------------------------------------------------------------
// Created:		28 July 2000 by cnwdad1
//
// Purpose:		using a Windows File Open common dialog, allows the user to browse
//				for a file and return its name.
//
// Parameters:	pIsFileMustExist - rue if the file must exist, otherwise the user
//					can type the name of a file in the dialog to be returned.
//				pFileFilter - The file type filter (or null).
//
// Returns:		The name of the selected file, or null if the user cancels.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileOpenObj		: CMDFileOpen;
	fileName		: String;

begin
	create fileOpenObj transient;

	fileOpenObj.allowMultiSelect	:=	false;
	fileOpenObj.createPrompt		:=	false;
	fileOpenObj.defaultExt			:=	".*";
	fileOpenObj.fileMustExist		:=	pIsFileMustExist;
//	fileOpenObj.filter				:=	"All files|*.*";
//	fileOpenObj.filterIndex			:=	1;
	fileOpenObj.cnEcSetFilters(true, 1, pFileFilter);
	fileOpenObj.hideReadOnly		:=	false;
//	fileOpenObj.initDir				:=
	fileOpenObj.noReadOnlyReturn	:=	true;
	fileOpenObj.pathMustExist		:=	pIsFileMustExist;
	fileOpenObj.readOnly			:=	false;
	fileOpenObj.resetCurrentPath	:=	true;
	fileOpenObj.shareAware			:=	true;
	fileOpenObj.validate			:=	true;

	if fileOpenObj.open() = 0 then
		fileName	:=	fileOpenObj.fileName;
	endif;

	return fileName;
epilog
	delete fileOpenObj;
end;</source>
        <Parameter name="pIsFileMustExist" type="Boolean"/>
        <Parameter name="pFileFilter" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcFindTranslatableString" id="458332f3-2685-44c7-9abb-d6da0d0ea0ae">
        <source>cnEcFindTranslatableString(pIsCaseSensitive:Boolean; pAllStringNames:StringArray io);
// --------------------------------------------------------------------------------
// Created:		13 August 2002 by cnwdad1
//
// Purpose:		Searches through all Translatable Strings (in the current locale)
//				for a string entered by the user.
//
// Parameters:	pIsCaseSensitive - If true, then the search will be case-sensitive.
//				pAllStringNames - An array of names of the Translatable Strings
//					that matches the string being searched for.
//
// Returns:		The array of Translatable String names, as an output parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	searchString	: String;
	constantObj		: Constant;
	inputFormObj	: CnEcUserInputForm;
	allStrings		: ConstantNDict;

begin
	create inputFormObj;
	
	inputFormObj.setProperties("Translatable String Search", "Enter the Translatable String text to search for:", null);
	
	if inputFormObj.showModal() = CnEcBaseForm.CNEC_MODAL_UPDATE then
		searchString	:=	inputFormObj.getValue();
	else
		return;
	endif;
	
	if (not pIsCaseSensitive) then
		searchString	:=	searchString.toLower();
	endif;
	
	allStrings	:=	app.currentLocale.getAllTranslatableStrings();
	
	foreach constantObj in allStrings do
		if pIsCaseSensitive then
			if constantObj.getSource.pos(searchString, 1) &lt;&gt; null then
				pAllStringNames.add(constantObj.name);
			endif;
		else
			if constantObj.getSource.toLower().pos(searchString, 1) &lt;&gt; null then
				pAllStringNames.add(constantObj.name);
			endif;
		endif;
	endforeach;
epilog
	delete allStrings;
end;</source>
        <Parameter name="pIsCaseSensitive" type="Boolean"/>
        <Parameter name="pAllStringNames" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetAllFileNames" id="6e6fa06a-106d-4a61-ba8d-71d75ac80817">
        <source>cnEcGetAllFileNames(pFolderObj:FileFolder input; pFileNameArray:CnEcArray io; pIsIncludeSubdirectories:Boolean);
// --------------------------------------------------------------------------------
// Created:		11 October 2000 by cnwdad1
//
// Purpose:		This method will return a list of all file names in the directory
//				of the specified FileFolder (recursively if subdirectories are
//				to be included).
//
// Parameters:	pFolderObj - The file directory to scan.
//				pFileNameArray (CnEcArray) - The array of file names.
//				pIsIncludeSubdirectories (Boolean) - If true, then subdirecorties
//					will also be scanned.
//
// Returns:		The IO pFileNameArray parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileNodeObj		: FileNode;
	allFileNodes	: FileNodeArray;
	
begin
	allFileNodes	:=	pFolderObj.files();
	
	foreach fileNodeObj in allFileNodes do
		if fileNodeObj.isKindOf(File) then
			pFileNameArray.addString(fileNodeObj.File.fileName);
		elseif fileNodeObj.isKindOf(FileFolder) and pIsIncludeSubdirectories then
			self.cnEcGetAllFileNames(fileNodeObj.FileFolder, pFileNameArray, pIsIncludeSubdirectories);
		endif;
	endforeach;
end;</source>
        <Parameter name="pFolderObj" type="FileFolder" usage="input"/>
        <Parameter name="pFileNameArray" type="CnEcArray" usage="io"/>
        <Parameter name="pIsIncludeSubdirectories" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetAllPrinters" id="160be776-26f7-4ccb-a73e-c986187abf0e">
        <executionLocation>client</executionLocation>
        <source>cnEcGetAllPrinters(pPrinterArray:StringArray io) clientExecution;
// --------------------------------------------------------------------------------
// Created:		26 July 2000 by cnwdad1
//
// Purpose:		Populates the specified string array with a list of the printers
//				that are configured (visible to) the client.
//
// Parameters:	pPrinterArray (StringArray) - The array of prionter names.
//
// Returns:		The populate string array parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	localPrinters	: StringArray;
	stringIndex		: Integer;
	arraySize		: Integer;

begin
	global.cnEcGetAllServerPrinters(pPrinterArray);

	create localPrinters transient;
	app.printer.getAllPrinters(localPrinters);

	arraySize	:=	localPrinters.size();
	stringIndex	:=	1;

	foreach stringIndex in 1 to arraySize do
		pPrinterArray.add(localPrinters[stringIndex]);
	endforeach;
epilog
	if (not localPrinters = null) then
		delete localPrinters;
	endif;
end;</source>
        <Parameter name="pPrinterArray" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetAllServerPrinters" id="03dacd3d-7fbf-481c-811a-9fe449ef5145">
        <executionLocation>server</executionLocation>
        <source>cnEcGetAllServerPrinters(pPrinterArray:StringArray io) serverExecution;
// --------------------------------------------------------------------------------
// Created:		26 July 2000 by cnwdad1
//
// Purpose:		Populates the specified string array with a list of the printers
//				that are configured (visible to) the database server.
//
// Parameters:	pPrinterArray (StringArray) - The array of prionter names.
//
// Returns:		The populate string array parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (not pPrinterArray = null) then
		app.printer.getAllPrinters(pPrinterArray);
	endif;
end;</source>
        <Parameter name="pPrinterArray" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetCommandLineParameter" id="7e4dcc67-15b5-4748-830f-775c1dec335f">
        <source>cnEcGetCommandLineParameter(pParameterName:String; pParameterValue:String output):Boolean;
// --------------------------------------------------------------------------------
// Created:		18 June 2000 by cnwdad1
//
// Purpose:		Returns the value of a JADE.EXE Command Line parameter.
//
// Parameters:	pParameterName - The name of the Parameter.
//				pParameterValue - The value of the requested parameter.
//
// Returns:		True if the parameter name was found, false if not.  The value of
//				the parameter will be returned by the pParameterValue method parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 21/01/2002	cnwdad1		Changed to check for Unicode and to call the appropriate
//							External Function.
// --------------------------------------------------------------------------------
vars
	parameterName	: String;
	isFound			: Boolean;
	commandLine		: String;
	parameterPos	: Integer;
	tokenPos		: Integer;

begin
	parameterName	:=	pParameterName.toLower;
	
	if app.isUnicode() then
		commandLine		:=	call cnEcGetCommandLineW.toLower();
	else
		commandLine		:=	call cnEcGetCommandLineA.toLower();
	endif;

	parameterPos	:=	commandLine.pos(pParameterName, 1);
	isFound			:=	(parameterPos &gt; 0);

	if isFound then
		tokenPos	:=	commandLine.pos("=", parameterPos);		// Get the position of the parameter's assignment.

		if tokenPos &gt; parameterPos and tokenPos &lt; commandLine.length() then
			tokenPos		:=	tokenPos + 1;					// We don't want to include the "=" in the returned value.
			pParameterValue	:=	commandLine.getNextToken(tokenPos).trimBlanks();
		else
			pParameterValue	:=	null;
		endif;
	endif;
epilog
	return isFound;
end;</source>
        <Parameter name="pParameterName" type="String"/>
        <Parameter name="pParameterValue" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetConstants" id="820d7e2e-21ab-4324-bf6c-46fd71874b8c">
        <source>cnEcGetConstants(pCategoryName:String; pConstantColl:ConstantNDict io):Boolean;
// --------------------------------------------------------------------------------
// Created:		01 February 2000 by cnwdad1
//
// Purpose:		Returns a collection of Global Constants for the requested Category.
//
// Parameters:	pCategoryName (String) - The name of the category whose constants to get.
//				pConstantColl (ConstantNDict) - The collection of constants.
//
// Returns:		True if the constant category is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	categoryObj		: ConstantCategory;

begin
	categoryObj	:=	currentSchema.getConstantCategory(pCategoryName);

	if categoryObj = null then
		return false;
	else
		pConstantColl	:=	categoryObj.getConstants();
		return true;
	endif;
end;</source>
        <Parameter name="pCategoryName" type="String"/>
        <Parameter name="pConstantColl" type="ConstantNDict" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetEnvironmentVariable" id="3ed960b1-ed9b-4a54-bf8e-59708604b9ee">
        <source>cnEcGetEnvironmentVariable(pEnvironmentVariable:String):String;
// --------------------------------------------------------------------------------
// Created:		03 August 2000 by cnwdad2
//
// Purpose:		Returns the value for a Windows (DOS) Environment Variable (Refer
//				to the "DOS_Environment_Variables" category of Global Constants
//				for a list of pre-defined Enviroment Variables).  Note that this
//				method requires that the CardSchema's "karma.dll" library exists
//				in the JADE binaries directory.
//
// Parameters:	pEnvironmentVariable - The name of the Environment Variable
//				whose value is being sought.
//
// Returns:		The value of the Environment Variable (this value will be null if
//				the Environment Variable name is not valid).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	variableValue	: String;

begin
	call cnGetEnvironmentVariable(pEnvironmentVariable, variableValue, CNEC_DOSENV_MAX_RETURN_SIZE);
epilog
	return variableValue;
end;</source>
        <Parameter name="pEnvironmentVariable" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetFileSeparator" id="6009c6eb-3e05-459b-96b6-c5d94339e99f">
        <source>cnEcGetFileSeparator():Character;
// --------------------------------------------------------------------------------
// Created:		02 September 2002 by cnwdad1
//
// Purpose:		Determines the platform of the operating system on which the calling
//				node is running, and returns the appropriate file path separator,
//				i.e. a "\" (for Windows) or "/" (for Unix).
//
// Parameters:	None
//
// Returns:		The file name separator character.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.cnEcIsUnix() then
		return CNEC_SEPARATOR_UNIX;
	else
		return CNEC_SEPARATOR_WIN;
	endif;
end;</source>
        <ReturnType type="Character"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetHttpBinary" id="ccf4c7a7-d4f8-4089-8c25-3563248e53a3">
        <source>cnEcGetHttpBinary(pBinaryUrl:String; pIsServerExecution:Boolean; pUsePresentationFileSystem:Boolean; pBinaryData:Binary io):String;
// --------------------------------------------------------------------------------
// Created:		02 August 2000 by cnwdad1
//
// Purpose:		Fetches a binary file from an HTTP server.
//
// Parameters:	pBinaryUrl (String) - The URL from which to get the file.
//				pIsServerExecution (Boolean) - If true, then operation will be
//					performed on the server node.
//				pBinaryData (Binary) - The returned binary file.
//
// Returns:		Null if successful, otherwise returns an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 25/10/2000	cnwdad1		Added option for the fetching of the binary file to run
//							on the server node.  To guarantee the uniqueness of the
//							temporary (work) file name, also now sending the network
//							address of the requesting client to the operation.
//
// 14/05/2004	cnwdad1		Added the pUsePresentationFileSystem paramater.
// --------------------------------------------------------------------------------
vars
	workFileName	: String;
	
begin
	workFileName	:=	process.networkAddress;
	
	if workFileName = null then
		workFileName	:=	global.cnEcGetFileSeparator() &amp; "working.dat";
	else
		workFileName	:=	global.cnEcGetFileSeparator() &amp; workFileName &amp; ".dat";
	endif;

	if pIsServerExecution then
		return self.cnEcGetHttpBinaryServer(pBinaryUrl, workFileName, pBinaryData);
	else
		return self.cnEcGetHttpBinaryClient(pBinaryUrl, workFileName, pUsePresentationFileSystem, pBinaryData);
	endif;
end;</source>
        <Parameter name="pBinaryUrl" type="String"/>
        <Parameter name="pIsServerExecution" type="Boolean"/>
        <Parameter name="pUsePresentationFileSystem" type="Boolean"/>
        <Parameter name="pBinaryData" type="Binary" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetHttpBinaryClient" id="16b70431-1f84-4b44-9af9-f8fb11cb136a">
        <executionLocation>client</executionLocation>
        <source>cnEcGetHttpBinaryClient(pBinaryUrl:String;
						pWorkFile:String;
						pUsePresentationFileSystem:Boolean;
						pBinaryData:Binary io):String protected, clientExecution;
// --------------------------------------------------------------------------------
// Created:		25 October 2000 by cnwdad1
//
// Purpose:		Refer to the "cnEcGetHttpBinary" method on this class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14/05/2004	cnwdad1		Added the pUsePresentationFileSystem parameter.
// --------------------------------------------------------------------------------
begin
	return self.cnEcGetHttpBinaryFile(pBinaryUrl, pWorkFile, pUsePresentationFileSystem, pBinaryData);
end;</source>
        <access>protected</access>
        <Parameter name="pBinaryUrl" type="String"/>
        <Parameter name="pWorkFile" type="String"/>
        <Parameter name="pUsePresentationFileSystem" type="Boolean"/>
        <Parameter name="pBinaryData" type="Binary" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetHttpBinaryFile" id="6b6283af-5ff9-4bf3-b062-bb8c7c1fbf2b">
        <source>cnEcGetHttpBinaryFile(pBinaryUrl:String; pWorkFile:String; pUsePresentationFileSystem:Boolean; pBinaryData:Binary io):String protected;
// --------------------------------------------------------------------------------
// Created:		25 October 2000 by cnwdad1
//
// Purpose:		Refer to the "cnEcGetHttpBinary" method on this class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14/05/2004	cnwdad1		Added the pUsePresentationFileSystem parameter.
// --------------------------------------------------------------------------------
vars
	requestResponse	: String;
	protocol		: String;
	webServer		: String;
	sourceFile		: String;
	tempFileObj		: File;
	folderObj		: FileFolder;
	workingFileName	: String;

begin
	on FileException do global.cnEcFileException(exception);

	// Extract the URL's constituent parts (we don't need the 'protocol' however).

	requestResponse	:=	pBinaryUrl.cnEcGetURLParts(protocol, webServer, sourceFile);

	if requestResponse &lt;&gt; null then
		return requestResponse;
	endif;

	// Get the Windows "temp" directory.
	workingFileName		:=	global.cnEcGetEnvironmentVariable(CNEC_DOSENV_TEMP);

	if workingFileName = null then
		return $CNEC_FILE_CANT_FIND_TEMP(CNEC_DOSENV_TEMP);
	endif;

	// Check that the "Temp" directory is a valid file path...
	create folderObj transient;

	if not folderObj.isValidPathName(workingFileName) then
		return $CNEC_FILE_TEMP_NOT_VALID(workingFileName);
	endif;

	// Check that the "Temp" directory is available...

	folderObj.fileName	:=	workingFileName;

	if not folderObj.isAvailable then
		return $CNEC_FILE_TEMP_NOT_AVAILABLE(workingFileName);
	endif;

	// Append the working file name to the "Temp" directory...

	workingFileName	:=	workingFileName &amp; pWorkFile;

	// Next, get the file from the URL...

	requestResponse	:=	global.cnEcGetHttpFile(webServer, sourceFile, workingFileName, node.isServerNode, pUsePresentationFileSystem);

	// Now read the file in as a binary...

	if requestResponse &lt;&gt; null then
		return requestResponse;
	endif;

	create tempFileObj transient;
	tempFileObj.fileName	:=	workingFileName;
	tempFileObj.kind		:=	File.Kind_Binary;

	if tempFileObj.tryOpen() then
		pBinaryData		:=	tempFileObj.readBinary(tempFileObj.fileLength());
	else
		return $CNEC_FILE_CANNOT_OPEN(tempFileObj.fileName);
	endif;

	tempFileObj.purge();

	return null;
epilog
	delete tempFileObj;
	delete folderObj;
end;</source>
        <access>protected</access>
        <Parameter name="pBinaryUrl" type="String"/>
        <Parameter name="pWorkFile" type="String"/>
        <Parameter name="pUsePresentationFileSystem" type="Boolean"/>
        <Parameter name="pBinaryData" type="Binary" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetHttpBinaryServer" id="d4b23865-8a45-4b07-8777-9aa887da754c">
        <executionLocation>server</executionLocation>
        <source>cnEcGetHttpBinaryServer(pBinaryUrl:String; pWorkFile:String; pBinaryData:Binary io):String protected, serverExecution;
// --------------------------------------------------------------------------------
// Created:		25 October 2000 by cnwdad1
//
// Purpose:		Refer to the "cnEcGetHttpBinary" method on this class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.cnEcGetHttpBinaryFile(pBinaryUrl, pWorkFile, false, pBinaryData);
end;</source>
        <access>protected</access>
        <Parameter name="pBinaryUrl" type="String"/>
        <Parameter name="pWorkFile" type="String"/>
        <Parameter name="pBinaryData" type="Binary" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetHttpFile" id="d54bece8-79b4-4aa5-aa5d-befac1ebc6ae">
        <source>cnEcGetHttpFile(pWebServer:String;
				pFilePath:String;
				pTargetFile:String;
				pIsServerExecution:Boolean;
				pUsePresentationFileSystem:Boolean):String;
// --------------------------------------------------------------------------------
// Created:		02 August 2000 by cnwdad1
//
// Purpose:		Fetches a file from an HTTP Web Server.
//
// Parameters:	pWebServer (String) - The name of the web server,
//									 e.g. "www.discoverjade.com".
//				pFilePath (String) - The path of the file (includeing the file name),
//									 e.g. "/Images/jadelogo.jpg" (note the preceding slash).
//				pTargetFile (String) - The file name (including path) to which the
//									 received file will be written, e.g. "c:\temp\logo.jpg".
//				pIsServerExecution (Boolean) - A flag to indicate whether the
//									 operation should should be executed on the server.
//				pUsePresentationFileSystem - A boolean flag to indicate whether to use
//					the Presentation client's file system (not applicable for server
//					execution).
//
// Returns:		String - Null if the operation was successsful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14/05/2004	cnwdad1		Added the pUsePresentationFileSystem parameter.
// --------------------------------------------------------------------------------
begin
	if pIsServerExecution then
		return self.cnEcGetHttpFileServer(pWebServer, pFilePath, pTargetFile);
	else
		return self.cnEcGetHttpFileClient(pWebServer, pFilePath, pTargetFile, pUsePresentationFileSystem);
	endif;
end;</source>
        <Parameter name="pWebServer" type="String"/>
        <Parameter name="pFilePath" type="String"/>
        <Parameter name="pTargetFile" type="String"/>
        <Parameter name="pIsServerExecution" type="Boolean"/>
        <Parameter name="pUsePresentationFileSystem" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetHttpFileClient" id="09e0fba9-ea4e-4e13-96f9-3793730924f0">
        <executionLocation>client</executionLocation>
        <source>cnEcGetHttpFileClient(pWebServer:String; pFilePath:String; pTargetFile:String; pUsePresentationFileSystem:Boolean):String protected, clientExecution;
// --------------------------------------------------------------------------------
// Created:		02 August 2000 by cnwdad1
//
// Purpose:		Refer to the "cnEcGetHttpFile" method on this class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14/05/2004	cnwdad1		Added the pUsePresentationFileSystem parameter.
// --------------------------------------------------------------------------------
begin
	return self.cnEcGetHttpFileName(pWebServer, pFilePath, pTargetFile, pUsePresentationFileSystem);
end;</source>
        <access>protected</access>
        <Parameter name="pWebServer" type="String"/>
        <Parameter name="pFilePath" type="String"/>
        <Parameter name="pTargetFile" type="String"/>
        <Parameter name="pUsePresentationFileSystem" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetHttpFileName" id="21d95f05-4847-4917-897c-c71aff3d1c8a">
        <source>cnEcGetHttpFileName(pWebServer:String; pFilePath:String; pTargetFile:String; pUsePresentationFileSystem:Boolean):String protected;
// --------------------------------------------------------------------------------
// Created:		02 August 2000 by cnwdad1
//
// Purpose:		Refer to the "cnEcGetHttpFile" method on this class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14/05/2004	cnwdad1		Added the pUsePresentationFileSystem parameter.
// --------------------------------------------------------------------------------
vars
	httpConnectObj	: CnHttp;
	requestResult	: String;

begin
	create httpConnectObj transient;
	httpConnectObj.setServerName(pWebServer);
	requestResult	:=	httpConnectObj.cnConnect();

	if requestResult = CN_OK then
		requestResult	:=	httpConnectObj.cnGetFile(pFilePath, pTargetFile, pUsePresentationFileSystem);

		if requestResult = CN_OK then
			return null;
		endif;
	endif;

	return requestResult;
epilog
	delete httpConnectObj;
end;</source>
        <access>protected</access>
        <Parameter name="pWebServer" type="String"/>
        <Parameter name="pFilePath" type="String"/>
        <Parameter name="pTargetFile" type="String"/>
        <Parameter name="pUsePresentationFileSystem" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetHttpFileServer" id="db6a7798-9583-42ba-870f-410ff703b596">
        <executionLocation>server</executionLocation>
        <source>cnEcGetHttpFileServer(pWebServer:String; pFilePath:String; pTargetFile:String):String protected, serverExecution;
// --------------------------------------------------------------------------------
// Created:		02 August 2000 by cnwdad1
//
// Purpose:		Refer to the "cnEcGetHttpFile" method on this class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.cnEcGetHttpFileName(pWebServer, pFilePath, pTargetFile, false);
end;</source>
        <access>protected</access>
        <Parameter name="pWebServer" type="String"/>
        <Parameter name="pFilePath" type="String"/>
        <Parameter name="pTargetFile" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetRandomColor" id="452e8b9b-2c94-46ef-b072-9c9bd0ef6238">
        <source>cnEcGetRandomColor():Integer;
// --------------------------------------------------------------------------------
// Created:		05 April 2005 by cnwdad1
//
// Purpose:		Generates a random color, and returns the value.
//
// Parameters:	None
//
// Returns:		The random color value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	colour_red		: Integer;
	colour_green	: Integer;
	colour_blue		: Integer;
	randomSeed		: Integer;
	colorValue		: Integer;
	
begin
	colour_red		:=	255 * app.random31(randomSeed, 100);
	colour_green	:=	255 * app.random31(randomSeed, 100);
	colour_blue		:=	255 * app.random31(randomSeed, 100);
	
	colorValue	:=	colour_red + (colour_green * 256) + (colour_blue * 256 * 256);
//write val;
	return colorValue;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetReportModuleForm" id="9211b660-1d84-416f-ab7e-da79a81d83a1">
        <source>cnEcGetReportModuleForm(pReportFormObj:GUIClass):GUIClass;
// --------------------------------------------------------------------------------
// Created:		04 August 2000 by cnwdad1
//
// Purpose:		This is a factory method to return a form Class for the requested
//				type of Report form.  This method should be reimplemented if the
//				standard BaseSchema Report forms are reimplemented, such as for a
//				JUICE'd interface.
//
// Parameters:	pReportFormObj - The type of Report form being requested.
//
// Returns:		The GUI Class of the form corresponding to the requested form.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pReportFormObj = CnEcReportPrintServerSuper then
		return CnEcReportPrintServerForm;
	elseif pReportFormObj = CnEcReportStartForm then
		return CnEcReportStartForm;
	elseif pReportFormObj = CnEcReportQueueListForm then
		return CnEcReportQueueListForm;
	elseif pReportFormObj = CnEcReportCategoryEditSuper then
		return CnEcReportCategoryEditForm;
	elseif pReportFormObj = CnEcReportCategoryListSuper then
		return CnEcReportCategoryListForm;
	elseif pReportFormObj = CnEcReportEditSuper then
		return CnEcReportEditForm;
	elseif pReportFormObj = CnEcReportParameterSuper then
		return CnEcReportParameterForm;
	elseif pReportFormObj = CnEcReportParameterValueSuper then
		return CnEcReportParameterValueForm;
	elseif pReportFormObj = CnEcReportPreviewSuper then
		return CnEcReportPreviewForm;
	elseif pReportFormObj = CnEcReportPrinterSelectSuper then
		return CnEcReportPrinterSelectForm;
	elseif pReportFormObj = CnEcReportPrintStartSuper then
		return CnEcReportPrintStartForm;
	else
		CnEcBaseSchemaException.raise_(CNEC_X_17000, pReportFormObj.class().name &amp; " is an unknown Class to the BaseSchema Reporting facility.");
	endif;
end;</source>
        <Parameter name="pReportFormObj" type="GUIClass"/>
        <ReturnType type="GUIClass"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetReportParameterNames" id="aa1c31e9-5cf3-4405-9b33-96226c0aafd0">
        <source>cnEcGetReportParameterNames(pReportFormName:String; pNameArray:StringArray io):Boolean;
// --------------------------------------------------------------------------------
// Created:		08 August 2000 by cnwdad1
//
// Purpose:		Returns an array of parameter names that are defined on subclasses
//				of the CnEcReport Form Class as local Constants.  These paramater
//				name constants must have a name beginning with the value of the
//				"CNEC_PARAMETER_NAME_PREFIX" global constant.  Note that constant
//				values will be returned for all superclasses of the specified
//				Report form, upto and including the BaseSchema's CnEcReport form.
//
// Parameters:	pReportFormName (String) - The name of the Report form class.
//				pNameArray (StringArray) - The array of parameter names.
//
// Returns:		A string array of parameter names.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 22/08/2000	cnwdad1		Modified to also find parameter name constants on superclass
//							report form classes.
// --------------------------------------------------------------------------------
vars
	reportFormClass		: GUIClass;
	constantColl		: ConstantNDict;
	superClassColl		: ClassColl;
	superClassObj		: Class;
	classConstantObj	: Constant;
	namePrefixLength	: Integer;

begin
	pNameArray.clear();
	reportFormClass	:=	currentSchema.getClass(pReportFormName).GUIClass;
	
	if reportFormClass = null then
		return false;
	endif;
	
	create superClassColl transient;
	// Get all superclasses for the requested Report form class.
	reportFormClass.allSuperclassesUpTo(superClassColl, CnEcReport);
	// Now add the requested Report form class to the collection as well.
	superClassColl.add(reportFormClass);
	
	create constantColl transient;
	namePrefixLength	:=	CNEC_PARAMETER_NAME_PREFIX.length();
	
	foreach superClassObj in superClassColl do
		constantColl.clear();
		superClassObj.getConstants(constantColl);
		
		foreach classConstantObj in constantColl do
			if classConstantObj.name[1:namePrefixLength] = CNEC_PARAMETER_NAME_PREFIX then
				pNameArray.add(classConstantObj.valueAsString);
			endif;
		endforeach;
	endforeach;
	
	return true;
epilog
	delete superClassColl;
	delete constantColl;
end;</source>
        <Parameter name="pReportFormName" type="String"/>
        <Parameter name="pNameArray" type="StringArray" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetReportParameterTypes" id="645d671a-4634-428b-804e-58f19309b081">
        <source>cnEcGetReportParameterTypes(pClassColl:ClassColl io);
// --------------------------------------------------------------------------------
// Created:		07 August 2000 by cnwdad1
//
// Purpose:		Returns a collection of CnEcBaseEntity subclasses.  These classes
//				are used by the Report Initiation module for Report Parameter
//				type definitions.
//
// ********************************************************************************
// *  THIS METHOD SHOULD BE REIMPLEMENTED IN THE APPLICATION SCHEMA TO RETURN A   *
// *   COLLECTION OF SUBCLASSES FOR THAT APPLICATION'S CONCRETE MODEL CLASSES.    *
// ********************************************************************************
//
// Parameters:	pClassColl (ClassColl) - The collection of subclasses.
//
// Returns:		Nothing
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	CnEcBaseEntity.allSubclasses(pClassColl);
end;</source>
        <Parameter name="pClassColl" type="ClassColl" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetServerIniFileName" id="8d060725-1909-41f5-a3b5-d288bc302d9b">
        <executionLocation>server</executionLocation>
        <source>cnEcGetServerIniFileName():String serverExecution;
// --------------------------------------------------------------------------------
// Created:		19 April 2006 by cnwdad1
//
// Purpose:		Returns the name of the server node's initialization file.
//
// Parameters:	None
//
// Returns:		The name of the server node's initialization file.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return app.getIniFileName();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetTempDirectory" id="6f4a6138-346a-4ef6-9245-e59e26ccb74e">
        <source>cnEcGetTempDirectory():String;
// --------------------------------------------------------------------------------
// Created:		03 August 2000 by cnwdad2
//
// Purpose:		Returns the Windows (DOS) "Temp" directory.  Note that this method
//				requires that the CardSchema's "karma.dll" library exists in the
//				JADE binaries directory.
//
// Parameters:	None
//
// Returns:		The name of the directory.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 19/04/2004	cnwdad1		For thin clients, if karma.dll wasn't in the local binaries
//							directory, an exception would result - changed this method
//							to use the new native method to fetch the "temp" directory.
// --------------------------------------------------------------------------------
begin
// cnwdad1 19/04/2004 - Use native method instead of one that relies on karma.dll being present.
//	return global.cnEcGetEnvironmentVariable(CNEC_DOSENV_TEMP);
	return app.getTempDir();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsUnix" id="b43e48f4-80a6-4048-8942-d1c804ec2d8b">
        <source>cnEcIsUnix():Boolean;
// --------------------------------------------------------------------------------
// Created:		03 September 2002 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the node on which the
//				method is executed is running on a UNIX platform.
//
// Parameters:	None
//
// Returns:		True if the node is running on a UNIX platform, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	osPlatform		: Integer;
	osVersion		: String;
	osArchitecture	: Integer;
	
begin
	osPlatform		:=	node.getOSPlatform(osVersion, osArchitecture);
	
	return (osPlatform.bitAnd(Node.OSUnix) &lt;&gt; 0);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsValidHttpFile" id="16d18a51-0d96-436e-814d-71b4e8c40b33">
        <source>cnEcIsValidHttpFile(pFilePathName:String; pIsIgnoreEmpty:Boolean; pErrorMessage:String output):Boolean;
// --------------------------------------------------------------------------------
// Created:		28 September 2000 by cnwdad2
//
// Purpose:		This method will validate a remote file on an HTTP server.
//
// Parameters:	pFilePathName (String) - The name and path of the file, and
//					optionally the protocol (e.g. HTTP://).
//				pIsIgnoreEmpty (Boolean) - If true, then an empty file will
//					not be reported as invalid.
//				pErrorMessage (String) - If the file is not valid, then this
//					parameter will return the error message, otherwise a null
//					value will be returned.
//
// Returns:		True if the file is value, otherwise false (in which case an error
//				message will also be returned in the output parameter).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isValidFile		: Boolean;
	httpConnectObj	: CnHttp;
	requestResult	: String;
	protocol		: String;
	webServer		: String;
	sourceFile		: String;
	sourceFileSize	: Integer;

begin
	isValidFile		:=	true;
	pErrorMessage	:=	null;
	pFilePathName.cnEcGetURLParts(protocol, webServer, sourceFile);
	
	create httpConnectObj transient;
	httpConnectObj.setServerName(webServer);
	requestResult	:=	httpConnectObj.cnConnect();
	
	if requestResult = CN_OK then
		requestResult	:=	httpConnectObj.cnGetFileSize(sourceFile, sourceFileSize);
		
		if requestResult = CN_OK then
			if (not pIsIgnoreEmpty) and sourceFileSize = 0 then
				pErrorMessage	:=	$CNEC_FILE_EMPTY(sourceFile);
				isValidFile		:=	false;
			endif;
		else
			pErrorMessage	:=	requestResult;
			isValidFile		:=	false;
		endif;
	else
		pErrorMessage	:=	requestResult;
		isValidFile		:=	false;
	endif;
epilog
	delete httpConnectObj;
	return isValidFile;
end;</source>
        <Parameter name="pFilePathName" type="String"/>
        <Parameter name="pIsIgnoreEmpty" type="Boolean"/>
        <Parameter name="pErrorMessage" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsValidServerDirectory" id="cc1a2f62-151e-4e9e-b7d9-d3b43894d42a">
        <executionLocation>server</executionLocation>
        <source>cnEcIsValidServerDirectory(pDirectoryName:String):Boolean serverExecution;
// --------------------------------------------------------------------------------
// Created:		06 February 2001 by cnwdad1
//
// Purpose:		Validates a directory name relative to the JADE server node.
//
// Parameters:	pDirectoryName - The name of the directory to validate.
//
// Returns:		True if the directory is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileFolderObj	: FileFolder;
	
begin
	create fileFolderObj transient;
	fileFolderObj.fileName	:=	pDirectoryName;
	
	return fileFolderObj.isAvailable();
epilog
	delete fileFolderObj;
end;</source>
        <Parameter name="pDirectoryName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcMessage_UnknownError" id="63548f59-6c9f-4502-8769-b0bedfe8f351">
        <source>cnEcMessage_UnknownError(pErrorMessage:String);
// --------------------------------------------------------------------------------
// Created:		26 July 2000 by cnwdad1
//
// Purpose:		Displays a message box showing the specified message, plus a request
//				to contact the system administrator.  This is intended to be used
//				an unexpected error condition is detected but can't be resolved.
//
// Parameters:	pErrorMessage - An application error mesaage.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	pMessageString	: String;

begin
	if (pErrorMessage.trimBlanks.length = 0) then
		pMessageString	:=	$CNEC_FATAL_ERROR;
	else
		pMessageString	:=	pErrorMessage;
	endif;

	pMessageString	:=	pMessageString &amp; CrLf &amp; CrLf &amp; $CNEC_CONTACT_ADMINISTRATOR;
	app.msgBox(pMessageString, $CNEC_ERROR, MsgBox_Stop_Icon + MsgBox_OK_Only);
end;</source>
        <Parameter name="pErrorMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcOpenFile" id="1530e58b-0077-4f34-9093-a1833eaef3fa">
        <source>cnEcOpenFile(pFileName:String):Integer;
// --------------------------------------------------------------------------------
// Created:		13 June 2007 by cnwdad1
//
// Purpose:		This method will open specfied file using the default application
//				(including a web browser if the file name is a URL).
//
// Parameters:	pFileName - The name of the file to open.
//
// Returns:		The result value of the Windows call.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 22/11/2021	navmd1		TFS 52434 Add Unicode support
// --------------------------------------------------------------------------------
constants
	NO_FILE_ASSOC	: Integer = 31;
	OPEN_ERROR		: Integer = 32; // Any result &lt;= this indicates an error
	
vars
	result		: Integer;
	dirName		: String;
	message		: String;
	
begin
	if pFileName = null then
		return 0;
	endif;
	
	if app.isUnicode() then
		result	:=	call cnEcShellExecuteW(1, "open", pFileName, null, null, 1);
	else
		result	:=	call cnEcShellExecuteA(1, "open", pFileName, null, null, 1);
	endif;
	
	app.mousePointer	:=	Idle;
	dirName	:=	pFileName.cnEcGetPathOfFileName();
	
	if result = NO_FILE_ASSOC then
		message	:=	"Could not open file " &amp; pFileName &amp;
					" (in folder " &amp; dirName &amp;
					").  This is most likely because there is no " &amp;
					"program associated with files of this extension.";
		
		app.msgBox(	message,
					"File Open Failed",
					MsgBox_OK_Only + MsgBox_Stop_Icon);
		return result;
					
	elseif result &lt;= OPEN_ERROR then
		message	:=	"Could not open file " &amp; pFileName &amp;
					" (in folder " &amp; dirName &amp; ").";
		
		app.msgBox(	message,
					"File Open Failed",
					MsgBox_OK_Only + MsgBox_Stop_Icon);
		return result;
	endif;
	
	return result;
end;</source>
        <Parameter name="pFileName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcOpenIExplorer" id="78acd6f8-fbaf-43d4-a179-0aee9e227e68">
        <source>cnEcOpenIExplorer(pURL:String):Integer;
// --------------------------------------------------------------------------------
// Created:		13 June 2007 by cnwdad1
//
// Purpose:		This method will open an Internet Explorer window and direct it to
//				the specfied URL.
//
// Parameters:	pURL - The target web site.
//
// Returns:		The result value of the Windows call.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 22/11/2021	navmd1		TFS 52434 Add Unicode support
// --------------------------------------------------------------------------------
begin
	if pURL = null then
		if app.isUnicode() then
			return call cnEcShellExecuteW(1, "open", "IExplore", null, null, 1);
		else
			return call cnEcShellExecuteA(1, "open", "IExplore", null, null, 1);
		endif;
	else
		if app.isUnicode() then
			return call cnEcShellExecuteW(1, "open", "IExplore", pURL, null, 1);
		else
			return call cnEcShellExecuteA(1, "open", "IExplore", pURL, null, 1);
		endif;
	endif;
end;</source>
        <Parameter name="pURL" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
