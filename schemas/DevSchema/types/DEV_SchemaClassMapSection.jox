epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_content" type="String"/>
        <Parameter name="_contentArray" type="DEV_StringArray"/>
        <Parameter name="_devSchema" type="DEV_Schema"/>
    </JadeMethod>
    <JadeMethod name="setContent" id="e4756aa8-53eb-438e-a0bd-d5885cbd42ac">
        <updating/>
        <source>setContent(_newContent 				: DEV_StringArray; 
			_postSection2Content 	: String) updating;
/*

Purpose:			Sets the content on the class

Parameters:			_newContent				StringArray[max]	Contains the Map file definitions
					_postSection2Content	String				Contains the closing tag off the entire databaseDefinitions section

Return Value:		

Date				Who		Reason
14 November 2021	navmd1	Initial creation TFS 52202

*/

vars

begin
	self.content := _postSection2Content;
	
	if _newContent.size = 0 then
		self.contentArray.clear();
	else
		_newContent.copy(self.contentArray);
	endif;
	
epilog

end;</source>
        <Parameter name="_newContent" type="DEV_StringArray"/>
        <Parameter name="_postSection2Content" type="String"/>
    </JadeMethod>
</Class>
