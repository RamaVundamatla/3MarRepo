        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loadEDIReleaseComparison" id="c8bcae63-bd8a-49e5-859b-af5ce755fa59">
        <source>loadEDIReleaseComparison(_coll :ObjectArray; _release	:CM_BulkRelease):Boolean protected;
/*
Date		Who		Reason
01 August 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
19 Oct    2017  cnwma1  TFS #7475 POL - Missing functions under EDI Comparison
// 05 Dec 2017	jlgrs1	TFS 8146 - POL - EDI Release Comparison not supporting adds
*/
vars
	table	:CM_DataTable;
	obj		:Object;
	ediTI	:CM_EDIReleaseRequestTI;
	str		:String;
	detail	:CM_ReserveDetail;
	size, int, row, 
	backColour, foreColour	:Integer;
	colIdxEstimatedReqDT,
	colIdxRequestDT : Integer;
begin
	table := self.tblData;
	
	self.allDBObjects.clear;
	// just make code a bit easier
	size := _coll.size;

	// we dont show adds, we do now
	if _release &lt;&gt; null then
		self.doNotableAdd (_release);
	endif;
	// could be delete or update 
	self.findMatchesForEDI (_coll, self.allDBObjects, _release); 

	if self.allDBObjects.size &lt; size then
		self.allDBObjects[size] := null;
	endif;
	
	// _coll contains all EDI TIs for a release/message 
	if size &gt; 0 then
		while int &lt; size do
			int 	:= int + 1;
			ediTI 	:= _coll[int].CM_EDIReleaseRequestTI;
			detail	:= self.allDBObjects[int].CM_ReserveDetail;
	
			// display row for EDI TI
			str := null.String &amp; Tab &amp; self.SOURCE_EDI &amp; Tab &amp; ediTI.getAttributeStringForDefArray(table.allTblDataEntRows); 
			row := table.addItemObject (ediTI, str);
			
			//19.10.2017 cnwma1 TFS #7475 
			colIdxEstimatedReqDT := table.getColumnByRowName(ETRow_EstimatedRequiredDate);
			if colIdxEstimatedReqDT &lt;&gt; null then
				table.accessCell(row, colIdxEstimatedReqDT + table.fixedColumns).text := ediTI.estimatedRequiredDate.date.asStringJMT;
			endif;
			
			colIdxRequestDT := table.getColumnByRowName(ETRow_RequestDate);
			if colIdxRequestDT &lt;&gt; null then
				table.accessCell(row, colIdxRequestDT + table.fixedColumns).text := ediTI.requestDate.date.asStringJMT;
			endif;
			//19.10.2017 cnwma1 TFS #7475 
			
			self.doNotableAdd (ediTI);
			
			// set the colour - NOTE subschema copy method
			ediTI.getColoursForEDITrackedItem (self.myEDIData, null, foreColour, backColour);
			
			table.accessRow (row).foreColor := foreColour;
			table.accessRow (row).backColor := backColour;
						
			// I want to match 
			if detail &lt;&gt; null then
				str := null.String &amp; Tab &amp; self.SOURCE_DB &amp; Tab &amp; detail.getAttributeStringForDefArray(self.allEntTableRowsForDBItem); 
				row := table.addItemObject (detail, str);
				
				if colIdxEstimatedReqDT &lt;&gt; null then  
					if detail.myReserveHeader &lt;&gt; null then //19.10.2017 cnwma1 TFS #7475 
						table.accessCell(row, colIdxEstimatedReqDT + table.fixedColumns).text := detail.myReserveHeader.dateEstimatedRequired.date.asStringJMT;
					endif;
				endif;
				
				if colIdxRequestDT &lt;&gt; null then  
					if detail.myReserveHeader &lt;&gt; null then //19.10.2017 cnwma1 TFS #7475 
						table.accessCell(row, colIdxRequestDT + table.fixedColumns).text := detail.myReserveHeader.dateRequested.date.asStringJMT;
					endif;
				endif;
				
				self.doNotableAdd (detail);
			endif;
			
			// do the comparison
			self.showChanges (table, ediTI, detail);
		endwhile;
	endif; 
	
	while int &lt; self.allDBObjects.size do
		// we have some new details items
		int 	:= int + 1;
		detail 	:= self.allDBObjects[int].CM_ReserveDetail;
		
		if detail &lt;&gt; null then 
			str := null.String &amp; Tab &amp; self.SOURCE_DB &amp; Tab &amp; detail.getAttributeStringForDefArray(self.allEntTableRowsForDBItem); 
			row := table.addItemObject (detail, str);
			
			self.doNotableAdd (detail);
			
			// do the comparison
			self.showChanges (table, null, detail);
		endif;
	endwhile;
	
	return true;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="ObjectArray"/>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadEDITrackedItems" id="8584c1bc-4912-4ab1-87ef-dfbe3d4dcd07">
        <updating/>
        <source>loadEDITrackedItems(_dd :DynaDictionary) updating, protected;
/*
Date			Who		Reason
01 August 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
06 July 2016	cnwmc5	TFS 2148 - changed to account for 'AllowDuplicateReleaseNos'
						This will now find the correct Release Request, if the user has supplied the original Request Date
*/
vars
	table						:CM_DataTable;
	terminal					:CM_Terminal;
	obj							:Object;
	ediTI 						:CM_EDIReleaseRequestTI;
	lastMode, lastRelease	:String;
	row				:Integer;
	coll					: ObjectArray;
	found,
	allowDupes					: Boolean;
	lastDT						: TimeStamp;
	releaseRequest 				: CM_BulkRelease;
begin
	
	self.allEDITIs.clear;
	create coll transient;
	table 		:= self.tblData;
	terminal	:= self.myTerminal;
	allowDupes	:= terminal.getConfig(AllowDuplicateReleaseNos).Boolean;
	
	table.clearAllSelected;
	
	// expect fixedRows to be set up	
	foreach obj in _dd do
		ediTI := obj.CM_EDIReleaseRequestTI;
		
		if lastMode &lt;&gt; null then
			if lastMode &lt;&gt; ediTI.messageMode 
			or lastRelease &lt;&gt; ediTI.releaseRequestNumber 
			or (allowDupes and lastRelease = ediTI.releaseRequestNumber and lastDT &lt;&gt; ediTI.requestDate) then
				found := false;
								
				if allowDupes and lastDT &lt;&gt; null and self.loadEDIReleaseComparison (coll, terminal.getBulkReleaseFromCodeDate(lastRelease, lastDT)) then
					found := true;
				elseif self.loadEDIReleaseComparison (coll, terminal.getBulkReleaseFromCode(lastRelease)) then
					found := true;
				endif;
				
				if found then
					// add a row so we can see them grouped
					row := table.addItem (null);
					// set background colour to same colour as fixed rows/columns
					table.accessRow	(row).backColor := table.accessCell(1,1).backColor;	//25 Aug 2015	NDL	Par 36615
				endif;
				
				coll.clear;
			endif;
		endif;
		
		coll.add(ediTI);
		self.allEDITIs.add (ediTI);
		
		lastMode 	:= ediTI.messageMode;
		lastRelease := ediTI.releaseRequestNumber;
		if allowDupes  then
			lastDT := ediTI.requestDate;
		endif;
		
	endforeach;
	// deal with the last lot
	if not coll.isEmpty then	
			
		if allowDupes and ediTI.requestDate &lt;&gt; null then
			self.loadEDIReleaseComparison (coll, terminal.getBulkReleaseFromCodeDate(lastRelease, ediTI.requestDate));
		else
			self.loadEDIReleaseComparison (coll, terminal.getBulkReleaseFromCode(lastRelease));
		endif;
	endif;

epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="_dd" type="DynaDictionary"/>
    </JadeMethod>
