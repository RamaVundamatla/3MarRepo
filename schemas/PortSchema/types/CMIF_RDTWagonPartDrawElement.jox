    <JadeMethod name="drawFace" id="5245e0f8-beb3-4c73-b772-dd7b4a085b28">
        <source>drawFace(_x1: Real; _y1: Real; _x2: Real; _y2: Real; _frame: Frame input; _scaleFactor: Real; _isLandscape: Boolean; _flipH: Boolean; _flipV: Boolean; _mode : Integer) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2010	cnwjk3	Initial creation

*/

constants
	//       	       --BBGGRR
	WagonColour 	  = #00CC9966;


vars
	oldFontSize,
	wagonHeightPixels,
	x1, y1,
	x2, y2			: Real;
begin
	x1 := _x1;
	y1 := _y1;
	x2 := _x2;
	y2 := _y2;

	wagonHeightPixels := self.getSizeInPixels(2, _scaleFactor);
	
	self.gridPointsToElementPoints(x1, y1, x2, y2, _scaleFactor, _isLandscape, _flipH, _flipV);
	
	if self.partType = self.FRONT then
		if _flipH then
			self.drawWheels( x1, y1, x2, y2, _frame, _scaleFactor, 2 );
		else
			self.drawWheels( x1, y1, x2, y2, _frame, _scaleFactor, 1 );	
		endif;
	elseif self.partType = self.BACK then
		if _flipH then
			self.drawWheels( x1, y1, x2, y2, _frame, _scaleFactor, 0 );	
		else
			self.drawWheels( x1, y1, x2, y2, _frame, _scaleFactor, 0 );	
		endif;
	endif;
	
	oldFontSize := _frame.drawFontSize;	
	// Set font size
	if _scaleFactor &gt;= 1 and _scaleFactor &lt;= 3 then
		_frame.drawFontSize := 4 * _scaleFactor;
	elseif _scaleFactor &gt;= 1 then
		_frame.drawFontSize := 3 * _scaleFactor;	
	endif;
	
	_frame.drawFontBold := true;
	_frame.drawFillColor := WagonColour;

	//_frame.drawFilledRectangle(x1 + wheelWidthPixels, y1, x2, y2, LightBrown);	
	_frame.drawFilledRectangle(x1, y1, x2, y1 + wagonHeightPixels, WagonColour);	
	
	if (self.partType = self.FRONT or self.partType = self.BACK) and _scaleFactor &gt;= 1 and self.myWagon &lt;&gt; null then
		_frame.drawTextIn(self.myWagon.id, x1 + 2, y1, x2, y1 + wagonHeightPixels, Black);
	endif;
	
	if self.displayWagonPos and _scaleFactor &gt;= 1 and self.myWagon &lt;&gt; null then
		_frame.drawTextIn( app.getErrorString(Pos) &amp;  ": " &amp; self.myWagon.getPositionDescr(), x1 + 2, y1, x2, y1 + wagonHeightPixels, Black);	
	endif;
	
	if self.partType = self.StartOfWell then
		self.drawWellStart(_frame, x1, y1, x2, y2, _scaleFactor, _isLandscape, _flipH, _flipV, _mode, self.getWellId);
	elseif self.partType = self.EndOfWell then
		self.drawWellEnd(_frame, x1, y1, x2, y2, _scaleFactor, _isLandscape, _flipH, _flipV, _mode, self.getWellId);
	endif;
	
	
	_frame.drawFontBold := false;
	_frame.drawFontSize := oldFontSize;	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_scaleFactor" type="Real"/>
        <Parameter name="_isLandscape" type="Boolean"/>
        <Parameter name="_flipH" type="Boolean"/>
        <Parameter name="_flipV" type="Boolean"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawTopDown" id="bca85881-46a4-4fa0-b999-a11ff051af07">
        <source>drawTopDown(_x1: Real; _y1: Real; _x2: Real; _y2: Real; _frame: Frame input; _scaleFactor: Real; _isLandscape: Boolean; _flipH: Boolean; _flipV: Boolean; _mode : Integer) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwjk3	Initial creation

*/
constants
	//       	       --BBGGRR
	//WagonColour 	  = #00003399;
	WagonColour 	  = #00CC9966;

vars
	oldFontSize,
	gapPixels,
	x1, y1,
	x2, y2			: Real;
	wagonTxt,
	wagonPosTxt : String;
begin
	x1 := _x1;
	y1 := _y1;
	x2 := _x2;
	y2 := _y2;

	gapPixels := (_x2 - _x1).abs() - self.getSizeInPixels(self.widthFt, _scaleFactor);
	
	self.gridPointsToElementPoints(x1, y1, x2, y2, _scaleFactor, _isLandscape, _flipH, _flipV);
	
	_frame.drawFillColor := WagonColour;		
	if self.partType = self.FRONT and not self.myWagon.isBoxcar then
		//indicate the front;
		_frame.drawFilledRectangle(x1, y1, x2, y2, Yellow);
	else
		_frame.drawFilledRectangle(x1, y1, x2, y2, WagonColour);
	endif;
	
	_frame.drawLine(x1, y1, x1, y2, Black);
	_frame.drawLine(x2, y1, x2, y2, Black);
	
	

	oldFontSize := _frame.drawFontSize;	
	// Set font size
	if _scaleFactor &lt;= 1.5  then
		_frame.drawFontSize:=6;
	elseif _scaleFactor &gt; 1.5 and _scaleFactor &lt;= 3 then
		_frame.drawFontSize := 4 * _scaleFactor;
	elseif _scaleFactor &gt;= 1 then
		_frame.drawFontSize := 3 * _scaleFactor;	
	endif;
	
	_frame.drawFontBold := true;
	
	if self.partType = self.EndOfWell then
		self.drawWellEnd(_frame, x1, y1, x2, y2, _scaleFactor, _isLandscape, _flipH, _flipV, _mode, self.getWellId);
	endif;
	
	wagonTxt:=self.myWagon.id;
	wagonPosTxt:=app.getErrorString(Pos) &amp; ": " &amp; self.myWagon.getPositionDescr();
	
	if ((self.partType = self.FRONT or self.partType = self.BACK) and _scaleFactor &gt;= 1 and self.myWagon &lt;&gt; null)  then
		if _isLandscape then
			_frame.drawTextIn(wagonTxt, x1 + 2, y2, x1 + _frame.getTextExtent(wagonTxt), y2 + _frame.drawFontSize + 20, Black);
		elseif _scaleFactor &gt; 1 then
			_frame.drawFontSize := 8;
			_frame.drawTextIn(wagonTxt, x2 + 2, y1, x2 + gapPixels, y1 + _frame.drawFontSize + 20, Black);		
		endif;
	endif;

	if (self.displayWagonPos and _scaleFactor &gt;= 1 and self.myWagon &lt;&gt; null)  then		
		if _isLandscape then
			_frame.drawTextIn(wagonPosTxt, x1 + 2, y2, x1 + _frame.getTextExtent(wagonPosTxt), y2 + _frame.drawFontSize + 20, Black);	
		elseif _scaleFactor &gt; 1 then
			_frame.drawFontSize := 8;
			_frame.drawTextIn(wagonPosTxt, x2 + 2, y1, x2 + gapPixels, y1 + _frame.drawFontSize + 20, Black);
			
		endif;
	endif;
	
	
	if  ((_scaleFactor &gt;= 0.5 and _scaleFactor &lt; 1) and self.myWagon &lt;&gt; null ) then
		if (_flipH and self.partType = self.BACK) or
			(not _flipH and self.partType = self.FRONT) then
			if _isLandscape then
				_frame.drawTextIn(wagonTxt &amp; " " &amp; wagonPosTxt, x1 + 2, y2, x1 + _frame.getTextExtent(wagonTxt &amp; " " &amp; wagonPosTxt), y2 + _frame.drawFontSize + 20, Black);	
			elseif _scaleFactor &gt; 1 then
				_frame.drawFontSize := 8;
				_frame.drawTextIn(wagonTxt, x2 + 2, y1, x2 + gapPixels, y1 + _frame.drawFontSize + 20, Black);				
			endif;
		endif;
	endif;
	
	if self.partType = self.StartOfWell then
		self.drawWellStart(_frame, x1, y1, x2, y2, _scaleFactor, _isLandscape, _flipH, _flipV, _mode, self.getWellId);
	elseif self.partType = self.EndOfWell then
		self.drawWellEnd(_frame, x1, y1, x2, y2, _scaleFactor, _isLandscape, _flipH, _flipV, _mode, self.getWellId);
	endif;
	
	_frame.drawFontBold := false;
	_frame.drawFontSize := oldFontSize;			
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_scaleFactor" type="Real"/>
        <Parameter name="_isLandscape" type="Boolean"/>
        <Parameter name="_flipH" type="Boolean"/>
        <Parameter name="_flipV" type="Boolean"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWellId" id="54b5a9d7-fdc3-41c5-be4a-bc7b7e7d5e2a">
        <source>getWellId():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2014	cnwndl1	Initial creation

*/

vars

begin

	if self.myLocationController = null then
		return null;
	endif;
	if not self.myLocationController.isWellcarCont then
		return null;
	endif;
	
	return self.myLocationController.CM_WellcarWagonController.myWellcarWellVisit.id;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
