    <JadeMethod name="cmbCargoType_click" id="ea0b16db-7838-4f27-b100-02e8d5ae9aa7">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoType_click(combobox: ComboBox input) updating;
//18 November 2009	cnwml2
//+cnwml2 PAR21056

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars

begin
		
	self.myProxyObject.CM_TrackedItem.setCargoType(combobox.listObject.CM_CargoType.id);
	self.myProxyObject.CM_TrackedItem.setMyProduct(null);
		
	self.mnuShowAlphabetised.translateCaption_Unconditional( Xlat_0008343, app.myCurrentLocale ); 
	self.isShowingAlphabetised := false;
	self.tblAlpha.visible := false;
	self.mode := self.Mode_Update_CargoType;
	self.showThumbnailData(self.myProxyObject.CM_TrackedItem);
	self.mode := self.Mode_Update;
	self.setControlsForAddEdit();
	
	if app.myPassport.myTerminal.getCargoTypeFromAbbrevOrDescr(combobox.listObject.CM_CargoType.description).isTrailer then
		self.cmbTrailerType.style := 1;
	endif;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbCargoType_lostFocus" id="e8a60d05-bfd6-4f09-b2ae-a934aada40d5">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoType_lostFocus(combobox: ComboBox input) updating;
//18 November 2009	cnwml2
//+cnwml2 PAR21056

vars

begin
	//cnwjo3 ccms 1018.  When want to abort when combobox object collection does not include self.myProxyObject.CM_TrackedItem.myCargoType
	on UserInterfaceException do handleUnavailableCargoType(exception);
	
	//an error will occur here if proxies cargo type does not exist in combobox
	if self.myProxyObject &lt;&gt; null then
		combobox.listObject := self.myProxyObject.CM_TrackedItem.myCargoType;
	endif;

	if combobox.listObject &lt;&gt; null then
		self.tblInputTop.setValueByControlName(combobox.name, combobox.listObject.CM_CargoType.description);
	else
		self.tblInputTop.setValueByControlName(combobox.name, null);
	endif;

	combobox.doChangedCompareForEntryTable();

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbCarrier_lostFocus" id="c05a0d3a-afcb-4b61-a93a-b73655768673">
