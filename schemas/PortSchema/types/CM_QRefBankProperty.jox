    <JadeMethod name="setComboValues" id="842c4547-0639-412f-a963-aeb32062fa92">
        <source>setComboValues(comboBox					: ComboBox input; 
			   queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder; 
			   queryOperator			: CM_QueryOperator; 
			   passport					: CM_Passport);
/*---------------------------------------------------------------------------

Purpose:			

Parameters:			

Return Value:		
/****Changes

Date			Name		TFS#		Description
15 May 2014		cnwndl1					Initial creation
21 Aug 2018		jlgka1		40200		Add Terminal description to the list Argument

----------------------------------------------------------------------------*/

vars
	selectorCriteriaLine	: CM_SelectorCriteriaLine;
	userTerminal			: CM_UserTerminal;
	terminal				: CM_Terminal;
	object					: Object;
	objectSet				: ObjectSet;
	bank 					: CM_Bank;
	referenceLookup			: CM_QReferenceLookup;
	multiTerminal			: Boolean;
begin
	comboBox.clear();
	
	create objectSet transient;
	// 34364 company specific to terminal otherwise companies for terminals the user can see
	foreach selectorCriteriaLine in queryCriteriaLineHolder.allCriteriaLines do
		if selectorCriteriaLine.myQueryProperty.propertyName = 'myTerminal' or
		   selectorCriteriaLine.myQueryProperty.propertyName = 'getTerminal' then		   
				selectorCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objectSet);
				break;			
		endif;
	endforeach;
	if objectSet.isEmpty() then
		foreach userTerminal in app.myPassport.myUser.allUserTerminals do
			objectSet.add(userTerminal.getMyTerminal);
		endforeach;
	endif;
	
	multiTerminal := (objectSet.size &gt; 1);
	foreach object in objectSet do
		terminal := object.CM_Terminal;
		foreach bank in terminal.companies where bank.isBusinessUnit do
			if comboBox.findObject(bank) &lt; 1 then
				if multiTerminal then 
					comboBox.itemObject[comboBox.addItem(bank.code &amp; Tab &amp; bank.mailingName &amp; " (" &amp; terminal.code &amp; ")")] := bank;
				else
					comboBox.itemObject[comboBox.addItem(bank.code &amp; Tab &amp; bank.mailingName)] := bank;
				endif;
			endif;
		endforeach;
	endforeach;

	if CM_QReferenceLookup.hasInstance(queryOperator) then
		referenceLookup := queryOperator.CM_QReferenceLookup;
		if global.isValidObject(referenceLookup.mySelectionValue) and
		   comboBox.findObject(referenceLookup.mySelectionValue) &gt; 0  then
			comboBox.listObject := referenceLookup.mySelectionValue;
		endif;
	endif;

epilog
	delete objectSet;
end;</source>
        <Parameter name="comboBox" type="ComboBox" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="4334b4e4-f6f7-4e6e-bbbe-70d685785596">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine: CM_SelectorCriteriaLine): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation

*/

vars
	terminal : CM_Terminal;
	bank		: CM_Bank;
	tmpValue: String;
	
begin

	if _value.isKindOf( CM_Bank ) then
		return _value;
	endif;
	
	tmpValue := _value.String.toUpper();
	
	foreach terminal in app.myRoot.allTerminals do
		foreach bank in terminal.companies where bank.isBusinessUnit do
			if bank.code.toUpper() = tmpValue then
				return bank;
			endif;
		endforeach;
	endforeach;

	inheritMethod( _value, _criteriaLine );

end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="c5b0fe61-69f1-4c68-a07b-86434d97adf9">
        <source>translateToDisplayValue(_value: Any): String;
/*-----------------------------------------------------------------------------------------

Purpose:			

Parameters:			

Return Value:		

/****Changes

Date			Name		TFS#		Description
15 May 2014		cnwndl1					Initial creation
21 Aug 2018		jlgka1		40200		Remove Termninal code in the results Table display.
-----------------------------------------------------------------------------------------*/
begin
	if _value &lt;&gt; null then
		//return _value.CM_Bank.code &amp; " (" &amp;  _value.CM_Bank.terminal.code &amp; ")";
		return _value.CM_Bank.code;
	endif;
	return null;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="2668078b-b81c-49ca-b193-69a29a05e153">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation

*/

vars
	returnVal : CM_Bank;
	
begin
	if _value &lt;&gt; null and _value.isKindOf(CM_Bank) then
		returnVal := _value.CM_Bank;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="a22cfed4-05dd-4e07-b278-6b96cd67b7cc">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	terminal : CM_Terminal;
	bank : CM_Bank;

begin
	if _value &lt;&gt; null and _value.isKindOf(String) then
		terminal := app.myPassport.myTerminal;
		if terminal &lt;&gt; null then
			bank := terminal.companies[_value.String];
			if bank &lt;&gt; null then
				return bank;
			endif;
		endif;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
