        <source>bubbleHelp(set: Boolean; value: String io) updating, mapping, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/06/2024	navkc1 CR 63736 Task 63737: Jade - New Filter Control

*/

vars

begin
	inheritMethod(set, value);
	
	if set and self.myToolbarButtonTblFilter &lt;&gt; null then
		self.myToolbarButtonTblFilter.bubbleHelp := value;
	endif;

epilog

end;</source>
