    <JadeMethod name="validateAllSectionsAndByPos" id="1547940f-4003-414d-9d87-0812fbf54854">
        <source>validateAllSectionsAndByPos(_allSections : CM_VesselSectionByCodeDict; _allSectionsByPosition : CM_VesselSectionByPositionDict);

/*

Purpose:		Validate allSections and allSectionsByPosition	

Parameters:			

Return Value:		


Date			Who		Reason
19 October 2011	cnwmh5	Initial creation #28440

*/

vars
	realSection			: CM_VesselSection;
	section				: CM_VesselSection;
begin

	// get the real object
	realSection := self.pxyGetRealObject();
	
	// check the code
	section := _allSections[self.code];
	if section &lt;&gt; null and section &lt;&gt; realSection then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;
	
	// check the position
	section := _allSectionsByPosition[self.position];
	if section &lt;&gt; null and section &lt;&gt; realSection then
		app.raiseCMException1(VB_DUPLICATED_ITEM, "Position (" &amp; self.position.String &amp; ")", null, null);
	endif;

epilog

end;</source>
        <Parameter name="_allSections" type="CM_VesselSectionByCodeDict"/>
        <Parameter name="_allSectionsByPosition" type="CM_VesselSectionByPositionDict"/>
    </JadeMethod>
