        <length>61</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="aClassOID" id="6135b832-53ec-49fa-b452-d57f7a73bf7e">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="aClassProperty" id="051a83d1-5f26-46ba-a1b9-360e50c5ca1e">
        <length>61</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <ImplicitInverseRef name="aMySelectedObject" id="5c80fc21-3c68-465e-84a9-8184f6df1834">
        <embedded/>
        <type name="Object"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnClose" id="a59180bd-0673-4e4b-895b-704dc2e883d9">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnSelect" id="de79f0df-1795-4238-9dcf-0c05368dbdaa">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblLabel1" id="e7d3f0fb-c85d-4b2c-bcf2-c497bcd1fe2d">
        <embedded/>
        <type name="Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lstListBox1" id="1107f0a8-0c76-41af-aee5-97ff67dca28a">
        <embedded/>
        <type name="ListBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtToMatch" id="1885da6a-c189-4998-9c00-afba561e09e0">
        <embedded/>
        <type name="TextBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="bestGuessAtObject" id="502d483d-a983-44db-b5bf-dd63bd3e363c">
        <updating/>
        <source>bestGuessAtObject()updating, protected;

vars
	oidObj	: Object;

begin
	if txtToMatch.text &lt;&gt; "" then 
		lstListBox1.listIndex := lstListBox1.findStringExact(1, txtToMatch.text);
	endif;
	
	if self.aClassOID &lt;&gt; "" then
		oidObj	:=	self.aClassOID.asOid();
		
		if app.isValidObject(oidObj)
		and lstListBox1.findObject(oidObj) &gt; 0
		then
			lstListBox1.listIndex := lstListBox1.findObject(oidObj);
		else
			txtToMatch.text := self.aClassOID;	
		endif;
	endif;

	if lstListBox1.listIndex &gt; 0 then
		self.selectAndClose();
	endif;	 	 
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnClose_click" id="47c69f24-0e3b-4db2-b76e-6caa99f439b1">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(btn: Button input) updating;

begin
	self.unloadForm();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSelect_click" id="34fff7b0-0a01-4a4b-be9a-c4c87bc3ada8">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSelect_click(btn: Button input) updating;

begin
	app.mousePointer	:=	Busy;
	self.selectAndClose();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="c30dff2d-61fb-4b40-ac93-03c20e0277ff">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	app.mousePointer	:=	Busy;
	inheritMethod();
	self.loadForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadForm" id="b0d5f708-542e-4272-8f7b-c7bb2cb36d3f">
        <updating/>
        <source>loadForm()updating, protected;

vars
	oidObj		: Object;
	listDisplay	: String;
	
begin
	app.mousePointer	:=	Window.MousePointer_Default;
	
	lblLabel1.caption	:=	"Select a " &amp; self.aClassName &amp; " and press 'Select'";
	
	if self.aClassProperty = "getOidString" then
		foreach oidObj in app.myCnEcXmlSchema.getClass(self.aClassName).instances do
			listDisplay	:=	oidObj.getOidString();
//			lstListBox1.itemObject[lstListBox1.addItem(self.display())] := oidObj;
			lstListBox1.itemObject[lstListBox1.addItem(listDisplay)]	:=	oidObj;
		endforeach;
	else
		foreach oidObj in app.myCnEcXmlSchema.getClass(self.aClassName).instances do
			listDisplay	:=	oidObj.getPropertyValue(self.aClassProperty).String;
//			lstListBox1.itemObject[lstListBox1.addItem(self.display())] := oidObj;
			lstListBox1.itemObject[lstListBox1.addItem(listDisplay)]	:=	oidObj;
		endforeach;
	endif;
	
	self.bestGuessAtObject();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="selectAndClose" id="a51a9735-dcde-48c3-aa10-9d1fc957abfb">
        <updating/>
        <source>selectAndClose()updating, protected;

begin
	app.mousePointer		:= Busy; 
	self.aMySelectedObject	:= lstListBox1.listObject.Object;
	self.unloadForm();
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
