    <JadeMethod name="setForCreate" id="bb1b1d1e-3870-42ef-beb5-2dce686f9bf2">
        <updating/>
        <source>setForCreate(_pxyLine: CM_LogStockOrderLine) updating;
//--------------------------------------------------------------
//Created: 22 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_pxyLine);
	self.setForUpdate(_pxyLine);
end;</source>
        <Parameter name="_pxyLine" type="CM_LogStockOrderLine"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="3e216c95-4b77-4755-812d-0d6c23866ab3">
        <updating/>
        <source>setForUpdate(_pxyLine: CM_LogStockOrderLine) updating;
//--------------------------------------------------------------
//Created: 22 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	existingLot,
	newLogLot 		: CM_LogLot;
	voyCntrl,
	voyCntrl2,
	realLogVoyCntrl : CM_LogVoyageController;
begin

	inheritMethod(_pxyLine);

	//check to see if existing lot has to be deleted
	if self.myLogLot &lt;&gt; _pxyLine.myLogLot then
		if self.myLogLot &lt;&gt; null then
			exclusiveLock(self.myLogLot);			
			existingLot := self.myLogLot;
			self.myLogLot := null;
			if existingLot.checkCanBeDelete then
				existingLot.erase(NORMAL_ERASE);
			endif;
		endif;
	endif;	
	
	if _pxyLine.myLogLot &lt;&gt; null then
		if _pxyLine.myLogLot.isTransient then
			create newLogLot persistent;
			newLogLot.setForCreate(_pxyLine.myLogLot);			
			self.myLogLot := newLogLot;
//			global.causeEvent(newLogLot.myLogVoyage.myTerminal.getTerminalEvent(LogLot_Create_Event), false, newLogLot);									
			global.causeEvent(newLogLot.myLogVoyageStructure.myVoyage.myTerminal.getTerminalEvent(LogLot_Create_Event), false, newLogLot);									
		else
			if self.myLogLot &lt;&gt; _pxyLine.myLogLot then
//				global.causeEvent(_pxyLine.myLogLot.myLogVoyage.myTerminal.getTerminalEvent(LogLot_Update_Event), false, _pxyLine.myLogLot);						
				global.causeEvent(_pxyLine.myLogLot.myLogVoyageStructure.myVoyage.myTerminal.getTerminalEvent(LogLot_Update_Event), false, _pxyLine.myLogLot);						
			endif;						
			self.myLogLot := _pxyLine.myLogLot;
			if not self.isTransient and self.myLogLot &lt;&gt; null and not self.myLogLot.isTransient  then	//20 Jan 2014	NDL	Par 33264
				self.updateObjectEdition( self.myLogLot ); //15 Jan 2014	NDL	Par 33264
			endif;
		endif;
	endif;

	self.consigneeCode 			:= _pxyLine.consigneeCode;
	self.maxContractQuantity 	:= _pxyLine.maxContractQuantity;
	self.minContractQuantity 	:= _pxyLine.minContractQuantity;
	
	//Remove any controller that are no longer needed	
	foreach voyCntrl in self.allLogVoyageLocations do 			: loop
		foreach voyCntrl2 in _pxyLine.allLogVoyageLocations do
			if voyCntrl2.isTransient then
				if voyCntrl2.pxyGetRealObject = voyCntrl then
					continue loop;
				endif;
			else
				if voyCntrl2 = voyCntrl then
					continue loop;
				endif;
			endif;
		endforeach;
		self.allLogVoyageLocations.remove(voyCntrl);
	endforeach;
	
	//Add and/or create controllers
	foreach voyCntrl in _pxyLine.allLogVoyageLocations do
		if voyCntrl.isTransient then
			realLogVoyCntrl := voyCntrl.pxyGetRealObject;
		else
			realLogVoyCntrl := voyCntrl;
		endif;
		if realLogVoyCntrl = null then
			// Create new Log Voyage Controller
			create realLogVoyCntrl persistent;
			realLogVoyCntrl.setForCreate(voyCntrl);
		endif;
		if not self.allLogVoyageLocations.includes(realLogVoyCntrl) then
			self.allLogVoyageLocations.add(realLogVoyCntrl);
		endif;
	endforeach;

end;</source>
        <Parameter name="_pxyLine" type="CM_LogStockOrderLine"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_LogStockOrderLine" id="ebe6cb46-8cbe-4ae9-89e2-e4b3de20acb5">
        <updating/>
        <source>setFromCMIF_LogStockOrderLine(_cmif : CMIF_LogStockOrderLine) updating;
//--------------------------------------------------------------
//Created: 04 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	existingLot,
	newLogLot 	: CM_LogLot;
begin

	self.consigneeCode	:= _cmif.consigneeCode;
	self.maxContractQuantity := _cmif.maxContractQuantity;
	self.minContractQuantity := _cmif.minContractQuantity;

	inheritMethod(_cmif);
	
	//check to see if existing lot has to be deleted
	if self.myLogLot &lt;&gt; _cmif.myLogLot then
		if self.myLogLot &lt;&gt; null then
			exclusiveLock(self.myLogLot);			
			existingLot := self.myLogLot;
			self.myLogLot := null;
			if existingLot.checkCanBeDelete() then
				existingLot.erase(NORMAL_ERASE);
			endif;
		endif;
	endif;	

	if _cmif.myLogLot &lt;&gt; null then
		if _cmif.myLogLot.isTransient then
			create newLogLot persistent;
			newLogLot.setForCreate(_cmif.myLogLot);			
			self.myLogLot := newLogLot;
//			global.causeEvent(newLogLot.myLogVoyage.myTerminal.getTerminalEvent(LogLot_Create_Event), false, newLogLot);						
			global.causeEvent(newLogLot.myLogVoyageStructure.myVoyage.myTerminal.getTerminalEvent(LogLot_Create_Event), false, newLogLot);						
		else
			if self.myLogLot &lt;&gt; _cmif.myLogLot then
//				global.causeEvent(_cmif.myLogLot.myLogVoyage.myTerminal.getTerminalEvent(LogLot_Update_Event), false, _cmif.myLogLot);						
				global.causeEvent(_cmif.myLogLot.myLogVoyageStructure.myVoyage.myTerminal.getTerminalEvent(LogLot_Update_Event), false, _cmif.myLogLot);						
			endif;				
			self.myLogLot := _cmif.myLogLot;
		endif;
	endif;

end;</source>
        <Parameter name="_cmif" type="CMIF_LogStockOrderLine"/>
    </JadeMethod>
    <JadeMethod name="setMyStockOrderSummary" id="a6f2a9d1-ede5-4c81-b549-e9c730de7629">
        <updating/>
        <source>setMyStockOrderSummary() updating;
//--------------------------------------------------------------
//Created: 23 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	theSummary,
	existingSummary : CM_StockOrderSummary;
begin

	existingSummary := self.myStockOrderSummary;
	theSummary := self.myStockOrderHeader.getStockOrderSummary(self);
	
	if theSummary = null then
		//error
	elseif theSummary &lt;&gt; existingSummary then
		self.myStockOrderSummary := theSummary;
		if existingSummary &lt;&gt; null and existingSummary.allStockOrderLines.size = 0 then
			existingSummary.erase(NORMAL_ERASE);
		endif;
	endif;
			
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="2bd70d1c-f19a-47ae-8deb-f79a376b7648">
        <updating/>
        <source>setProxy(_product : CM_Product;
		_reqdQuantity, _maxContractQuantity, _minContractQuantity: Real;
		_logLot : CM_LogLot;
		_comments, _commentsOperator, _dischargePort, 
		_consigneeCode,	_operatorRef1, _operatorRef2 : String)updating;
//--------------------------------------------------------------
//Created: 22 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.setProxyForOrderLine(_product,	_reqdQuantity,_comments, _commentsOperator, _dischargePort, _operatorRef1, _operatorRef2, null);
	
	self.consigneeCode	:= _consigneeCode;
	self.myLogLot 		:= _logLot;
	self.maxContractQuantity := _maxContractQuantity;
	self.minContractQuantity := _minContractQuantity;
end;</source>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_reqdQuantity" type="Real"/>
        <Parameter name="_maxContractQuantity" type="Real"/>
        <Parameter name="_minContractQuantity" type="Real"/>
        <Parameter name="_logLot" type="CM_LogLot"/>
        <Parameter name="_comments" type="String"/>
        <Parameter name="_commentsOperator" type="String"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_consigneeCode" type="String"/>
        <Parameter name="_operatorRef1" type="String"/>
        <Parameter name="_operatorRef2" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateAllocation" id="bf83072e-79c7-4163-95d5-7f157e7504f6">
        <source>validateAllocation(_allocAmount : Decimal);
//--------------------------------------------------------------
//Created: 19 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	totAmount 	: Real;
	str			: String;	
begin
	inheritMethod(_allocAmount);
	
	totAmount := (_allocAmount + self.calAllocatedAmount());
	
	if self.lotNo &lt;&gt; null then
		str := self.lotNo;
	else
		str := self.consigneeCode &amp; '/' &amp; self.dischargePort;
	endif;
		
	if self.maxContractQuantity &gt; 0 and totAmount &gt; self.maxContractQuantity then
		app.raiseCMWarning3(StockOrderAllocMaxQty, totAmount.String, str, self.maxContractQuantity.String,
							ETRow_AllocQuantity, null, self);			
	endif;
	if self.minContractQuantity &gt; 0 and totAmount &lt; self.minContractQuantity then
		app.raiseCMWarning3(StockOrderAllocMinQty, totAmount.String, str, self.minContractQuantity.String,
							ETRow_AllocQuantity, null, self);			
	endif;	
end;</source>
        <Parameter name="_allocAmount" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="423fc16b-9aff-4ed8-ae8f-e452bc34806f">
        <source>validateForDelete();
//--------------------------------------------------------------
//Created: 24 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	if self.checkOnShip then
		app.raiseCMException2(StockOrderLoadedToShip, 'Log Lot' &amp; self.lotNo, 'the ship', null, null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="b3bf67c2-bbc1-4e84-803f-82dd1017fac1">
        <source>validateForUpdate(_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 25 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.checkOnShip then
		app.raiseCMException2(StockOrderLoadedToShip, 'Log Lot' &amp; self.lotNo, 'the ship', null, null);
		return;
	endif;	
	self.validateMe(_passport);
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="ba7d74bf-43e9-46de-b2cd-edf3b5175861">
        <source>validateMe(_passport : CM_Passport input) protected;
//--------------------------------------------------------------
//Created: 22 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if self.myProduct = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Product), ETRow_MyProduct, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Product), ETRow_MyProduct, null); // cnwdb2	PAR 35364
	endif;
	if self.reqdQuantity &lt;= 0 then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Required Volume', ETRow_ReqdQuantity, null);
		app.raiseCMException(Input_required_field_reqVol, ETRow_ReqdQuantity, null); // cnwdb2	PAR 35364


	endif;	
		
	if self.myLogLot &lt;&gt; null then
		if self.myLogLot.isTransient then
			self.myLogLot.validateForCreate();
			if (not _passport.noErrors) then
				return;
			endif;
		endif;
		if self.consigneeCode &lt;&gt; null and self.myLogLot.myConsignee &lt;&gt; null then
			if self.consigneeCode &lt;&gt; self.myLogLot.myConsignee.code then
				app.raiseCMWarning3(LogLotMismatch, self.myLogLot.lotNo,
									 'Customer ' &amp; self.myLogLot.myConsignee.code,
									 'Customer ' &amp; self.consigneeCode,
									  ETRow_Consignee, null, self);
			endif;
		endif;
		if self.dischargePort &lt;&gt; null and self.myLogLot.myDischargePort &lt;&gt; null then	
			if self.dischargePort &lt;&gt; self.myLogLot.myDischargePort.code then
				app.raiseCMWarning3(LogLotMismatch, self.myLogLot.lotNo,
									 'Discharge Port ' &amp; self.myLogLot.myDischargePort.code,
									 'Discharge Port ' &amp; self.dischargePort,
									  ETRow_DischargePort, null, self);				
			endif;
		endif;			
	endif;	
	if self.logSpeciesCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Species', ETRow_LogSpeciesCode, null);
		app.raiseCMException(Input_required_field_species, ETRow_LogSpeciesCode, null); // cnwdb2	PAR 35364


	endif;
	if self.logGradeCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Grade', ETRow_LogGradeCode, null);
		app.raiseCMException(Input_required_field_grade, ETRow_LogGradeCode, null);

	endif;
	if self.logLengthCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Length', ETRow_LogLengthCode, null);
		app.raiseCMException(Input_required_field_length, ETRow_LogLengthCode, null); // cnwdb2	PAR 35364
	endif;
	if _passport.noErrors then
		if self.maxContractQuantity &gt; 0 then
			if self.maxContractQuantity &lt; self.reqdQuantity then
				app.raiseCMException2(MeasureVolumeInvalid, 'Max Contract Quantity', 'Cannot be less than required volume.', ETRow_MaxContractQuantity, null);
			endif;
		endif;
		if self.minContractQuantity &gt; 0 then
			if self.minContractQuantity &gt; self.reqdQuantity then
				app.raiseCMException2(MeasureVolumeInvalid, 'Min Contract Quantity', 'Cannot be Greater than required volume.', ETRow_MinContractQuantity, null);
			endif;
		endif;		
	endif;	
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
