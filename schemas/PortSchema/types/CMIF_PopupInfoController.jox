    <JadeMethod name="setForCreate" id="783fd89e-7baa-4aa9-b39e-c058620c3d6f">
        <updating/>
        <source>setForCreate(_theObject : Object; _displayMode : Integer;
			_theFrame : Frame; _theTable : Table; _theToolbarFrame : Frame; 
			_thePictureFrame : Frame; _thePicture : Picture; _theButtonEnquiry : Button) updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// (theObject, self.frmPopupInfo,self.tblPopupInfo,self.frmToolBarPopup,self.frmPopupInfoPic1,self.picExtraInfoTI1,self.btnPopupEnq)

vars

begin
	self.myObject := _theObject;
	self.displayMode	:= _displayMode;
	self.theFrame := _theFrame; 
	self.theTable := _theTable; 
	self.theToolbarFrame := _theToolbarFrame;
	self.thePictureFrame := _thePictureFrame; 
	self.thePicture := _thePicture; 
	self.theButtonEnquiry := _theButtonEnquiry;
end;</source>
