    <ImplicitInverseRef name="myVentReading" id="f28e65f8-97c2-4300-b229-51bf924621e2">
        <embedded/>
        <type name="CM_VentReading"/>
    </ImplicitInverseRef>
    <JadeMethod name="setFromTransaction" id="30bb710a-bcd8-4ca9-a3bb-757b57b006e4">
