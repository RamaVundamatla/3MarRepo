    <JadeMethod name="create" id="d9d5175b-43f7-4449-96e8-998a1f57c4ee">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     03 January 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.name := SOP_TableMaintForm.Table_ContainerRange;
	self.permissionView	 := PmContainerRangeView;
	self.permissionMaint := PmContainerRangeMaint;
	self.myDataClass := CM_ContRange;
	
	self.linearType := app.getDefaultMeasurementForType(Type_Linear);	//18 Mar 2014	NDL	Par 33268
	self.volumeType := app.getDefaultMeasurementForType(Type_Volume);	//18 Mar 2014	NDL	Par 33268
	self.weightType := app.getDefaultMeasurementForType(Type_Weight);	//18 Mar 2014	NDL	Par 33268


end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="ad97aebf-643a-4156-a074-bd5a853a4d57">
        <updating/>
        <source>doDelete(pObj: CM_Object io) updating;
// ---------------------------------------------------------------------------
// Created:     02 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	app.myTrxDA.trxDeleteContRange(pObj.CM_ContRange, app.myPassport);

end;</source>
        <Parameter name="pObj" type="CM_Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="650988e2-7084-4d91-88f9-98c32eafd64b">
        <updating/>
        <source>doSave(): Boolean updating;

vars
	errObj:CM_Error;
	idx:Integer;
	tmpListBox:ListBox;
	ignoreWarnings,rtnValue:Boolean;
	proxyContRange:CM_ContRange;
	lLower,lUpper,lIsoType : String;
    lCubicmeters : Decimal [16,4];
    coolingType, voltageType : Integer; 
    lExtHeight,lExtLength,lExtWidth : Decimal [14,4];
    lIntHeight,lIntLength,lIntWidth : Decimal [14,4];
    lMaxKilos, lTareKilos : Decimal [14,4];
    lHeavyLift : Boolean;
	theForm : SOP_TableMaintForm;
begin
  	theForm := self.myForm; 
	lLower := theForm.tblInput1.getValueByName(ETRow_Lower).String;
	lUpper := theForm.tblInput1.getValueByName(ETRow_Upper).String;
	lIsoType := theForm.tblInput1.getValueByName(ETRow_IsoType).String;
	lHeavyLift := theForm.tblInput1.getValueByName(ETRow_HeavyLift).Boolean;

	coolingType := app.coolingTypeStringToENum(theForm.tblInput1.getValueByName(ETRow_CoolingType).String);
	voltageType := app.voltageTypeStringToENum(theForm.tblInput1.getValueByName(ETRow_VoltageType).String); 
	
	//18 Mar 2014	NDL	Par 33268
	lCubicmeters := self.getConvertedDisplayValue( ETRow_CubicMetres, self.volumeType );
	lExtHeight := self.getConvertedDisplayValue( ETRow_ExtHeight, self.linearType );
	lExtLength := self.getConvertedDisplayValue( ETRow_ExtLength, self.linearType );
	lExtWidth := self.getConvertedDisplayValue( ETRow_ExtWidth, self.linearType );
	lIntHeight := self.getConvertedDisplayValue( ETRow_IntHeight, self.linearType );
	lIntLength := self.getConvertedDisplayValue( ETRow_IntLength, self.linearType );
	lIntWidth := self.getConvertedDisplayValue( ETRow_IntWidth, self.linearType );
	lMaxKilos := self.getConvertedDisplayValue( ETRow_MaxKilos, self.weightType );
	lTareKilos := self.getConvertedDisplayValue( ETRow_TareKilos, self.weightType );
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_ContRange transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyContRange := theForm.myProxyObject.CM_ContRange;
	proxyContRange.setProxy(lLower, lUpper,lIsoType,
	                        lCubicmeters,
	                        lExtHeight,lExtLength,lExtWidth,
	                        lIntHeight,lIntLength,lIntWidth,
	                        lMaxKilos, lTareKilos,
	                        coolingType, voltageType, lHeavyLift);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateContRange(proxyContRange, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateContRange(proxyContRange, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
