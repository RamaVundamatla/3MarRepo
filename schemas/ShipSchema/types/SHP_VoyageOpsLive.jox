    <JadeMethod name="moveCargo" id="ec4591c6-45b0-4422-b815-222a3c9f49ca">
        <source>moveCargo(_mode : Integer; _all : Boolean; _table : CM_DataTable input);
/*
Purpose:			

Date		Who		Reason
01 March 2023	navab1	TFS CR 56806 TASK 56807
*/

vars
	moveController : CMIF_MoveController;
	targetLocn : CM_LocationsController;
	theReturn, height : Integer;
	addOnShip : Boolean;
	tiSet : CM_TISet;
	firstTI: CM_TrackedItem;
begin
	
	if self.myCurrentVoyage = null then
		return;
	endif;

	if _table = null then
		return;
	endif;
	
	if targetLocn = null then
		self.myTerminal.findLocationFromString(self.txtMoveLocation.text,true,targetLocn, height);
	endif;

	if targetLocn = null then
		self.myCurrentVoyage.findLocationFromString(self.txtMoveLocation.text,true,targetLocn);
	endif;
	
	if targetLocn = null then
		global.beep;
		app.msgBox(app.getErrorString(Please_select_locati_move_carg),app.getErrorString(Problem), MsgBox_OK_Only);
		return;
	endif;
	
	
	theReturn :=  app.msgBox(app.getErrorString1(Move_selected_cargo, targetLocn.getFullId()),app.getErrorString(Confirm_location),MsgBox_Yes_No);
	
	if theReturn = MsgBox_Return_No then
		return;
	endif;
	
	create tiSet transient;
	if global.isValidObject(app.myMoveController) then
		delete app.myMoveController;
	else
		app.myMoveController := null;
	endif;
		
	create moveController transient;
	app.myMoveController := moveController;
	self.getAllSelectedTIs(tiSet, _all, _table);
	if tiSet.isEmpty then
		app.msgBox(app.getErrorString(SelectItemToMove),app.getErrorString(Problem),MsgBox_OK_Only);
		return;
	endif;
	firstTI := tiSet.first;
	tiSet.remove(firstTI);
	moveController.setMyTrackedItem(firstTI);
	moveController.setAllOtherTrackedItems(tiSet);
	
	moveController.transferType := self.getVoyJobTransferType();
	moveController.setMyToPrimaryLocation(targetLocn);	
	moveController.isMoveToPlanned := false;

	moveController.setMoveMode(_mode); // REAL_MODE
	
	while true do
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			theReturn := app.showErrorWarningDialog(app.getErrorString(Move_cargo), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;


epilog
	delete tiSet;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_all" type="Boolean"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeCargoFromCollections" id="f17953cb-4118-4f21-bd48-d96e802d4f50">
        <source>removeCargoFromCollections(_ti : CM_TrackedItem);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 March 2024		jlizm1	Initial creation TFS 62763 Table auto updates

*/

vars

begin
	if _ti = null then
		return;
	endif;
	
	if self.allCargoBooked.includes(_ti) then
		self.allCargoBooked.remove(_ti);
	endif;
	
	if self.allCargoToBeWorked.includes(_ti) then
		self.allCargoToBeWorked.remove(_ti);
	endif;
	
	if self.allHazardous.includes(_ti) then
		self.allHazardous.remove(_ti);
	endif;
	
	if self.allMAFI.includes(_ti) then
		self.allMAFI.remove(_ti);
	endif;
	
	if self.allReefers.includes(_ti) then
		self.allReefers.remove(_ti);
	endif;
	
	if self.allTrailer.includes(_ti) then
		self.allTrailer.remove(_ti);
	endif;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="removeCargoFromTable" id="8523f23f-589b-472f-b442-a9578ff2374b">
        <updating/>
        <source>removeCargoFromTable(_ti : CM_TrackedItem; _table : CM_DataTable input; _sheet : CMUI_Sheet input) updating;
/*
Purpose:			

Date				Who		Reason
01 March 2023		navab1	TFS CR 56806 TASK 56807
19 March 2024		jlizm1	TFS 62763 Table auto updates
20 August 2024		jlizm1	TFS 65704 children of discharged mafi not automatically removed from table
*/

vars
	rowIdx : Integer;
	
begin

	_table.findObjectInRow(_ti,rowIdx);
	
	if rowIdx &gt; _table.fixedRows then
		if _table.row = rowIdx then
			// removing current row; clear bottom table too
			if self.myCurrentTrackedItem = _ti then
				self.myCurrentTrackedItem := null;
			endif;
			self.showChildCargo(null, self.getBottomTable(_table));
		endif;
		
		_table.removeItem(rowIdx);	
	endif;
	
	//jlier1 TFS 65275 19/7/24
	self.colourTableRows(_table);
	self.doSheetCaption(_sheet, _table);
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_sheet" type="CMUI_Sheet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="runVoyageOpsSummary" id="3061128e-0c38-42d1-986e-06e82cfeeb58">
        <source>runVoyageOpsSummary(_type : Integer; _table : Table input; _label : Label input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2024	jlier1	Initial creation 62270

*/

vars
	summaryGroup : CMIF_VoyageOpsSummaryGrp;
	sumRow		: CMIF_VoyageOpspSummaryRow;
	row,drawLineRow  : Integer;
	total : Integer;
	subTotal : String;
	cmqfVoyageOpsSummary : CMQF_VoyageOpsLiveSummary;
	allSummaryGroups : CMIF_VoyageOpsSummaryGrpArray;
begin
	if self.myCurrentVoyage = null then
		return;
	endif;
	_label.caption:=null;
	self.initVoyageOpsSummaryTable(_table);
	
	create cmqfVoyageOpsSummary transient;
	cmqfVoyageOpsSummary.setMyVoyage(self.myCurrentVoyage);
	cmqfVoyageOpsSummary.reportType:=_type;
	
	create allSummaryGroups transient;
	cmqfVoyageOpsSummary.filterObjects(allSummaryGroups,app.myPassport);
	
	_label.caption:=app.actualTimeAppServer.asStringJMT;
	_label.left:=self.lblLoadLastRefreshed.left;
	
	foreach summaryGroup in allSummaryGroups do
		if summaryGroup.allSummaryRows.first = null then
			continue;
		endif;
		total:=0;
		row:=_table.addItem(summaryGroup.name);
		_table.accessRow(row).gridBottom:=false;
		_table.accessRow(row).gridRight:=false;
		_table.accessRow(row).fontBold:=true;
		row:=_table.addItem(summaryGroup.header );
		_table.accessRow(row).fontBold:=true;
		_table.accessRow(row).gridBottom:=false;
		_table.accessRow(row).gridRight:=false;
		foreach sumRow in summaryGroup.allSummaryRows do
				row:=_table.addItem(Tab &amp; sumRow.pod &amp; Tab &amp; sumRow.type &amp; Tab &amp; sumRow.stackType &amp; Tab &amp; sumRow.quantity.asStringJMT &amp; Tab &amp; (sumRow.weight/1000).roundedTo(2).asStringJMT &amp; Tab &amp; sumRow.subTotal.zeroNotAllowed ); //jlier1	TFS 62967 22/3/24
				_table.accessRow(row).gridBottom:=false;
				_table.accessRow(row).gridRight:=false;
				total:=total + sumRow.subTotal;
		endforeach;
		_table.accessRow(row).gridBottom:=true;
		if total &lt;&gt; 0 then
			drawLineRow :=_table.addItem(Tab &amp;  Tab &amp; Tab  &amp; Tab  &amp; Tab &amp;  Tab &amp; total.asStringJMT);
			_table.accessRow(drawLineRow).gridBottom:=false;
			_table.accessRow(drawLineRow).gridRight:=false;
			//_table.accessCell(drawLineRow-1,7).gridBottom:=true;
		endif;
		
		row:=_table.addItem(null);
		_table.accessRow(row).gridBottom:=false;
		_table.accessRow(row).gridRight:=false;
	endforeach;
	
	
epilog
	if allSummaryGroups &lt;&gt; null then
		allSummaryGroups.purge;
		delete allSummaryGroups;
	endif;
	delete cmqfVoyageOpsSummary;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_label" type="Label" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCurrentVoyage" id="ace30ddd-891d-4c4d-ae67-15be36d3710a">
        <updating/>
        <source>setCurrentVoyage(_voyage : CM_Voyage) updating;
/*
Purpose:			

Date		Who		Reason
27 February 2023	navab1	TFS CR 56806 TASK 56807
*/

vars
	str : String;
	changed : Boolean;
begin
	changed := self.myCurrentVoyage &lt;&gt; _voyage;
	if changed 
	and self.myCurrentVoyage &lt;&gt; null then
		self.endNotificationForSubscriber(self.myCurrentVoyage);
		self.initVoyageOpsSummaryTable(self.tblVoySumLoad);  //jlier1 TFS 62270 13/2/24
		self.initVoyageOpsSummaryTable(self.tblVoySumDis);  //jlier1 TFS  62475 14/2/24
	endif;
	
	self.myCurrentVoyage := _voyage;
	app.setMyCurrentVoyage(_voyage);
	str := self.baseCaption;	
	str := getCaption(str);
	self.lblVoyageStatus.caption := self.myCurrentVoyage.statusDescription;
	
	if changed then
		self.clearFilters(true);
		self.buildComboConfirm();
	endif;	
	
	self.setCaption(str);
	self.setNavigatorHeading(str);
	
	self.setStartOpsButton();

	//jlier1 TFS 62270 1/2/24 
	if self.shtVoyageStatus.visible then
		self.lblLoadVesselName.caption:=self.myCurrentVoyage.vesselName;
		self.lblLoadVoyageCode.caption:=self.myCurrentVoyage.code;
		self.lblLoadArrivalDT.caption:=self.myCurrentVoyage.getArrivedDTLocalTZ.asStringJMT;
		self.lblDisVesselName.caption:=self.lblLoadVesselName.caption;
		self.lblDisVoyageCode.caption:=self.lblLoadVoyageCode.caption;
		self.lblDisArrivalDT.caption:=self.lblLoadArrivalDT.caption;
		
		if self.fldMain.topSheet = self.shtVoyageStatus then
			self.btnRunVoyLoadSum.click(self.btnRunVoyLoadSum);
			self.btnRunVoyDisSum.click(self.btnRunVoyDisSum);
		endif;
	endif;
	
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(Voyage_Update_Event), Response_Continuous, null);
	self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(TIEvent_Transit_Status_Update), Response_Continuous, null);
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setDefaultLocation" id="7ff20a81-f70b-410f-83d7-6365652718b6">
        <updating/>
        <source>setDefaultLocation(_location : CM_LocationsController) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 May 2024
TFS#		: 64049
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	self.myDefaultLocation := _location;
end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setStartOperations" id="ed2a371f-9018-4265-af35-2e96f1b11c02">
        <updating/>
        <source>setStartOperations() updating;
/*
Purpose:			

Date		Who		Reason
09 March 2023	navab1	TFS CR 56806 TASK 56807
*/

vars
	status, theReturn : Integer;
	voyage : CM_Voyage;
begin
	voyage	:= self.myCurrentVoyage;
	if voyage = null then
		global.beep;
		return;
	endif;
	
	status := voyage.myVoyageProcess.getWorkingStatus();
	
	if status = 0 then
		global.beep;
		return;
	endif;

	if app.msgBox(app.getErrorString(Confirm_voyage_status_change), app.getErrorString(Confirmation), MsgBox_Yes_No) = MsgBox_Return_No then
		return;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateVoyageVoyageStatus(voyage, status,false,app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Change_status), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setStartOpsButton" id="09df88ff-1d1a-400d-98d5-20042f3a4a79">
        <source>setStartOpsButton();
/*
Purpose:		the status are in an order (priority) so anything before the workign priority we will enable the button	

Date				Who		Reason
14 March 2023		navab1	TFS CR 56806 TASK 56807
18 October 2023		jlizm1	TFS 60661
*/

vars
	workingPriority, workingStatus : Integer;
	voyage : CM_Voyage;
	vprocess : CM_VoyageProcess;
	vstatus : CM_VoyageStatus;
	
begin
	self.btnStartOps.enabled := true;
	
	voyage:= self.myCurrentVoyage;
	if voyage = null then
		return;
	endif;
	
	vprocess := voyage.myVoyageProcess;
	if vprocess = null then
		return;
	endif;
	
	workingPriority := vprocess.getWorkingPriority();
	vstatus :=  vprocess.allStatusesById[voyage.status];
	
	self.btnStartOps.enabled := vstatus &lt;&gt; null and vstatus.priority &lt; workingPriority; // not working yet

	self.lblVoyageStatus.caption := voyage.statusDescription;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTableDataData" id="4f7c242f-ba84-4ee6-b90c-0319179bc3e9">
        <updating/>
        <source>setTableDataData(_theTable : CM_DataTable input; _collection : CM_TISet; _sheet : CMUI_Sheet input) updating;
/*
Purpose:			

Date				Who		Reason
01 March 2023		navab1	TFS CR 56806 TASK 56807
19 March 2024		jlizm1	TFS 62763 Table Updates
*/

vars
	ti : CM_TrackedItem;
	
begin
	_theTable.rows :=  _theTable.fixedRows;
	foreach ti in _collection discreteLock do
		self.addCargoToTable(ti, _theTable, _sheet);
	endforeach;
	
	if _sheet &lt;&gt; null then
		self.doSheetCaption(_sheet, _theTable);
	endif;

epilog

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
        <Parameter name="_collection" type="CM_TISet"/>
        <Parameter name="_sheet" type="CMUI_Sheet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="fda0f416-0386-4211-b9f3-764a3e99c374">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*
Purpose:			

Date		Who		Reason
01MAR2023	NAVAB1	CR 56806 TASK 56807 
08 Feb 2024 jlier1 TFS 62363
05 Jun 2024	jlika1	TFS 64480 CUX - Alternating Cell Colors not refreshed after adding a column to a sheet in Voyage Operations Live (Code difference copied to Wmast)
27 Jun 2024	jlika1	TFS 64887 CUX - Adding columns to child/onboard cargo detail column organizer shows blanks in Voyage Ops Live/FLP
*/

vars

	msg : String;
	cmifMonitor : CMIF_Monitor;
	ti, tilc : CM_TrackedItem;
	tis : CM_TISet;
begin
//	on Exception do self.handleInterruptExceptions(exception);
	/*
	if app.myPassport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;
*/

	app.mousePointer := self.MousePointer_HourGlass;
	
	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null, 'Cancel' , null, null, 'Reloading Table',  'Please Wait....');
	
	if _theTable = self.tblAllCargoTop then
		self.setTableDataData(_theTable,self.allCargoToBeWorked, self.shtAllCargo);
	elseif _theTable = self.tblHazardousTop then
		self.setTableDataData(_theTable,self.allHazardous, self.shtHazardous);
	elseif _theTable = self.tblReefersTop then
		self.setTableDataData(_theTable,self.allReefers, self.shtReefers);
	elseif _theTable = self.tblTrailersTop then
		self.setTableDataData(_theTable,self.allTrailer, self.shtTrailers);
	elseif _theTable = self.tblMAFITop then
		self.setTableDataData(_theTable,self.allMAFI, self.shtMAFI);
	elseif _theTable = self.tblBookingTop then
		self.setTableDataData(_theTable,self.allCargoBooked, self.shtBookingList);

	else // bottom table so get parent MAFI/Trailer
		if self.myCurrentTrackedItem &lt;&gt; null then
			if self.myCurrentTrackedItem.isKindOf(CM_TILC) then
				tilc := self.myCurrentTrackedItem;
			else 
				tilc := self.myCurrentTrackedItem.getCurrentTrailer();
			endif;
			if tilc &lt;&gt; null then
				create tis transient;
				tilc.CM_TILC.getAllOnboardTIs(tis);
				self.setTableDataData(_theTable,tis, null);
			endif;
		endif;
	endif;
	
	self.colourTableRows(_theTable);
	
epilog
	delete tis;
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	app.mousePointer := self.MousePointer_Default;
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTablePositionsFromXML" id="ff70da33-5dd2-4ee4-ae9a-fdba090c434b">
        <updating/>
        <source>setTablePositionsFromXML() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Dec 2025	navah1	Initial creation
15 Dec 2025	navah1	MTN-36400: CUX - If the user adjusts the bar at the bottom in the Voyage Operations Live screen the change doesnt remain if the screen is closed and reopened
*/

vars
	userWindow			: CM_UserWindow;
	theXML 				: String; 
	
begin
	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;
	
	self.splAllCargo.setTablePositionsFromXMLStr(theXML);
	self.splBooking.setTablePositionsFromXMLStr(theXML);
	self.splHazardous.setTablePositionsFromXMLStr(theXML);
	self.splReefers.setTablePositionsFromXMLStr(theXML);
	self.splTrailers.setTablePositionsFromXMLStr(theXML);
	self.splMAFI.setTablePositionsFromXMLStr(theXML);
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="2abf4b70-c5a5-4e97-bb92-e3fb76bb40f6">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Date				Who		Reason
27 February 2023	navab1	TFS CR 56806 TASK 56807
06 December 2023	jlizm1	TFS 61426 CUX FLP Screen Enhancements
08 Feb 2024 		jlier1 	TFS 62363
14/02/2024			jlika1	TFS 62427 CUX | FLP - Voyage Status Summary sheet access
02 July 2024		jlizm1	TFS 64940 VOL Cargo table not updating with mafi voyage update
10 Dec 2025			navah1	MTN-36400: CUX - If the user adjusts the bar at the bottom in the Voyage Operations Live screen the change doesnt remain if the screen is closed and reopened
*/

vars

begin
	self.baseCaption:=self.caption;
	self.lblVoyageStatus.caption := "";
	self.frmAdditionalConfigs.visible := false;
	self.btnQueueRTL.visible := false;

	inheritMethod();
	
	self.getXMLSettingsForSetup();

	self.initSplitterAndTables(self.splAllCargo, self.tblAllCargoTop,self.tblAllCargoBottom);
	self.initSplitterAndTables(self.splMAFI, self.tblMAFITop,self.tblMAFIBottom);
	self.initSplitterAndTables(self.splTrailers, self.tblTrailersTop,self.tblTrailersBottom);
	self.initSplitterAndTables(self.splReefers, self.tblReefersTop,self.tblReefersBottom);
	self.initSplitterAndTables(self.splHazardous, self.tblHazardousTop,self.tblHazardousBottom);
	self.initSplitterAndTables(self.splBooking, self.tblBookingTop,self.tblBookingBottom);
	
	self.setTablePositionsFromXML(); //10.12.2025 navah1 #MTN-36400 
	
	self.buildComboVoyages();
	self.buildComboTransferType();
	self.buildComboCargoType();
	self.buildComboCargoTypeOnShip();
	self.buildComboConfirm();
	self.buildComboIMEX();
	self.buildComboSite();
	self.buildCustPriorityButtons();

	self.initVoyageOpsSummaryTable(self.tblVoySumLoad); //jlier1 TFS 62270 13/2/24
	self.initVoyageOpsSummaryTable(self.tblVoySumDis); //jlier1 TFS 62475 13/2/24
	
	self.beginClassNotification(CM_TrackedItem, false, self.myTerminal.getTerminalEvent(TIEvent_PreNote_Add), Response_Continuous, 0);
	self.beginClassNotification(CM_TrackedItem, false, self.myTerminal.getTerminalEvent(EVENT_TI_Voyage_Chg), Response_Continuous, 0);
	
	self.shtVoyageStatus.visible :=  self.myTerminal.getConfig(ShowVoyStatSumInVoyOps).Boolean;
	
	self.picFiltered.visible := false;
//	self.fldMain.backColor := Red;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showChildCargo" id="9170004d-806c-457f-97d6-e72858caeb50">
        <updating/>
        <source>showChildCargo(_ti : CM_TrackedItem; _table : CM_DataTable input) updating;
/*
Purpose:			

Date				Who		Reason
01 March 2023		navab1	TFS CR 56806 TASK 56807
20 August 2024		jlizm1	TFS 65703 Alternate row colour in child table
24 August 2024		jlizm1	TFS 65704 children of discharged mafi not automatically removed from table
*/

vars
	child : CM_TrackedItem;
	onbard : CM_TISet;
	
begin
	if _table = null then
		return;
	endif;
	
	_table.rows := _table.fixedRows;
	
	if _ti = null then
		return;
	endif;
	
	foreach child in _ti.allChildren discreteLock do
		self.addCargoToTable(child,_table, null);
	endforeach;
	
	if _ti.isKindOf(CM_TILC) then
		create onbard transient;
		_ti.CM_TILC.getAllOnboardTIs(onbard);
		foreach child in onbard discreteLock do
			self.addCargoToTable(child,_table, null);
		endforeach;
	endif;
	
	self.colourTableRows(_table);
	
epilog
	delete onbard;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="a8e70b3e-d3cb-41a6-a59f-d3b1c4922288">
        <updating/>
        <source>showColumnOrganiser(_dataTable : CM_DataTable input)updating;
/*
Purpose:			

Date		Who		Reason
01MAR2023	NAVAB1	CR 56806 TASK 56807 
*/

vars

begin
	if _dataTable = null then
		return;
	endif;
	
	_dataTable.showColumnOrganiserFrm(self.myTerminal, _dataTable.allTblDataEntRows);

epilog

end;</source>
        <Parameter name="_dataTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showShortlandedCargo" id="027925b0-e0dc-44f5-8979-3d01f975746e">
        <updating/>
        <source>showShortlandedCargo(_pxyVoyage : CM_Voyage) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 February 2024
TFS#		: 62137
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	trackedItem			: CM_TrackedItem;
	transaction 		: CM_TITransaction;
	hasShortlanded		: Boolean;
	listOfTI			: CM_TISet;
	listOfSelectedTI	: CM_TISet;
	listTableSelectForm : CMUI_ListTableSelectForm;
	result				: Integer;
	txnParams			: CMIF_TITransactionController;
begin		
	create listOfTI transient;
	foreach trackedItem in self.myCurrentVoyage.allOnshipTIsByIdCargoType do		
		if (trackedItem.getImExStatus() = TI_IMEX_STATUS_IMPORT or trackedItem.getImExStatus() = TI_IMEX_STATUS_TRANSHIP) then
			hasShortlanded := false;
			foreach transaction in trackedItem.allTransactions  where transaction.type = TRANS_TYPE_SHORTLANDED  do
				hasShortlanded := true;
			endforeach;
			if not hasShortlanded then
				listOfTI.add(trackedItem);
			endif;
		endif;
	endforeach;
	
	if listOfTI.size = 0 then
		app.msgBox(app.getErrorString(There_cargo_shortland), app.getErrorString(Information),MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	create listTableSelectForm transient;
	listTableSelectForm.initForm(app.getErrorString(Shortland_manifested_cargo), listOfTI,CM_TrackedItem::getNiceName.name, true);
	listTableSelectForm.caption := app.getErrorString(Shortland_manifested_cargo);
	listTableSelectForm.btnOk.caption := app.getErrorString(Yes);
	listTableSelectForm.btnCancel.caption := app.getErrorString(No);
	result :=listTableSelectForm.showModal;
	if result = IDOK then		
		beginTransaction;
		create listOfSelectedTI transient;
		listTableSelectForm.lstSelect.allSelectedObjects.copy(listOfSelectedTI);	
		
		if listOfSelectedTI.size &gt; 0 then
			create txnParams transient;
			foreach trackedItem in listOfSelectedTI do
				txnParams.myTrackedItem := trackedItem;
				txnParams.userId 		:= app.getMyUserCode;
				txnParams.dateTime 		:= app.actualTimeServer;
				txnParams.type 			:= TRANS_TYPE_SHORTLANDED;
				trackedItem.createTransaction(txnParams, app.myPassport);
			endforeach;			
		endif;		
		commitTransaction;
	endif;
epilog
	delete listOfTI;
	delete listOfSelectedTI;
	delete txnParams;
end;</source>
        <Parameter name="_pxyVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="a7837f70-fd07-4741-b127-38eb73658e3f">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
/*
Purpose:			

Date		Who		Reason
14 March 2023	navab1	TFS CR 56806 TASK 56807
*/

vars

begin
	self.handleSystemNotifications(eventType, theObject.CM_Object);
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
