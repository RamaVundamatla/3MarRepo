    <JadeMethod name="addToolbarControls" id="1641faab-dc8b-488f-beaf-93e066e591d9">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	toolbar,
	toolbarSearcher	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	if app.myCurrentUserCan( self.myTerminal, PmAdmMachineRulesMaint ) then	//PAR 19657, 04 Sep 2009
		toolbar.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);	
		toolbar.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	endif;

	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
