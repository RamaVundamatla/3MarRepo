    <JadeMethod name="create" id="08f9c6f0-5246-4ecf-87b0-10cc7ea84c28">
        <updating/>
        <source>create() updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 February 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	oper 		: CM_QStringIsOneOf;
begin

	if self.isTransient then	//11 Jan 2012	NDL	Par 28953 
		return;
	endif;

	create oper as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(oper);
	
end;


</source>
    </JadeMethod>
    <JadeMethod name="getControlNameForOperator" id="73900a58-6e05-4410-b5d0-f5ea200c041f">
