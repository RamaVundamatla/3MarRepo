	topMMs : Real;
	leftMMs : Real;
	rightMMs : Real;
	bottomMMs : Real;

begin

	topMMs := 98;
	bottomMMs := 106;
	leftMMs := 0;	rightMMs := 25;		self.moveLabel( self.lblA, topMMs, leftMMs, rightMMs, bottomMMs );
//	leftMMs := 26;	rightMMs := 55;		self.moveLabel( self.lblB, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 25;	rightMMs := 65;		self.moveLabel( self.lblB, topMMs, leftMMs, rightMMs, bottomMMs );	//08 Apr 2013	NDL	Par 31404
