    <JadeMethod name="addToolbarControls" id="2bc5ae13-e9d5-4d17-a4f0-014f2681c533">
        <updating/>
        <source>addToolbarControls() updating, protected;

vars
	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnNextT, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSelectAllT, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSelectNoneT, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSearchT, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnResetT, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
end;</source>
        <access>protected</access>
    </JadeMethod>
