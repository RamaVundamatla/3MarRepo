    <JadeMethod name="btnRPSelect_click" id="e41d438d-82e4-4d2e-92af-061d0ca4e749">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRPSelect_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		18 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
// 19/07/2017	cnwma1	TFS #4938:POL - Resync transactions caused duplicate transactions in DSS and SQL Native extracts
// ---------------------------------------------------------------------------
//5/06/2018 	JLGNS1	Bug 38935: PNL - Transaction Resync doesn't include Freight Forwarder
vars
	torf : Boolean;
begin

	torf := not self.chkRPbusUnit.value;
	//par 16551
	if torf then
		self.btnRPSelect.bubbleHelp := "Unselect All";
	else
		/*
			Date		      Who		Reason
			30 June 2008	cnwdz2	    Par16551 - The bubbleHelp of the selectAll button should show the message
												   "Select All" when the check boxes are currently unchecked.
		*/
		self.btnRPSelect.bubbleHelp := "Select All";
	endif;
	self.chkRPbusUnit.value := torf;
	self.chkRPdestPort.value := torf;
	self.chkRPcomm.value := torf;
	self.chkRPcon.value := torf;
	self.chkRPconor.value := torf;
	self.chkRPcontents.value := torf;
	self.chkRPcustAg.value := torf;
	self.chkRPdischPort.value := torf;
	self.chkRPimex.value := torf;
	self.chkRPoperator.value := torf;
	self.chkRPquantity.value := torf;
	self.chkRPvolume.value := torf;
	self.chkRPweight.value := torf;
	self.chkRPLength.value := torf;  // 19.07.2017 cnwma1 TFS #4938
	self.chkRPfreightForwarder.value := torf;	//Bug 38935
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
