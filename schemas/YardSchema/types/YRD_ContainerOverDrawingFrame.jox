    <JadeMethod name="getObjects" id="0b0fad1e-ab0e-4fb3-ab43-3d9d41f3a502">
        <updating/>
        <source>getObjects(_objs : ObjectArray input; _ydc : YRD_ContainerDrawingController input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	tmpPoint : Point;
	x1,x2,x3,y1,y2,y3,idx : Integer;
	obj : Object;
begin
	if _ydc = null  or _objs = null then
		return;
	endif;
	
	foreach tmpPoint in self.allPoints do
		idx := idx + 1;
		if idx mod 2 = 0 then
			x2 := tmpPoint.x;
			y2 := tmpPoint.y;	

			if x1 &gt; x2 then
				x3 := x2;
				x2 := x1;
				x1 := x3;
			endif;
			if y1 &gt; y2 then
				y3 := y2;
				y2 := y1;
				y1 := y3;
			endif;
			_ydc.allGridObjects.findObjectsInDict(x1,y1,x2,y2,_objs,CM_LocationsController,false,false);

		else
			x1 := tmpPoint.x;
			y1 := tmpPoint.y;	
		
		endif;

	endforeach;
end;</source>
        <Parameter name="_objs" type="ObjectArray" usage="input"/>
        <Parameter name="_ydc" type="YRD_ContainerDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getObjectsRoRo" id="33afb34d-82c1-4729-90f6-8243676ca01b">
        <source>getObjectsRoRo(_objs : ObjectArray input; _ydc : YRD_RoRoLaneDrawingController);
// ---------------------------------------------------------------------------
// Created:		January 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	yrdForm : YRD_GridAreasForm;
	tmpPoint : Point;
	x1,x2,x3,y1,y2,y3,idx : Integer;
	olFrame : YRD_ContainerOverDrawingFrame;
	obj : Object;
begin
	if _ydc = null  or _objs = null then
		return;
	endif;
	
	foreach tmpPoint in self.allPoints do
		idx := idx + 1;
		if idx mod 2 = 0 then
			x2 := tmpPoint.x;
			y2 := tmpPoint.y;	

			if x1 &gt; x2 then
				x3 := x2;
				x2 := x1;
				x1 := x3;
			endif;
			if y1 &gt; y2 then
				y3 := y2;
				y2 := y1;
				y1 := y3;
			endif;
			_ydc.allDrawnObjects.findObjectsInDict(x1,y1,x2,y2,_objs,CM_LocationsController,false);

		else
			x1 := tmpPoint.x;
			y1 := tmpPoint.y;	
		
		endif;

	endforeach;
end;</source>
        <Parameter name="_objs" type="ObjectArray" usage="input"/>
        <Parameter name="_ydc" type="YRD_RoRoLaneDrawingController"/>
    </JadeMethod>
    <JadeMethod name="getPointsFromLCs" id="420596b4-52c7-4255-9624-47495d3e94c7">
        <source>getPointsFromLCs(_lcs : CM_LCSet; _yalloc : CM_YardAllocation);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 10/3/17	cnwer1		TFS 3148 - removed references to trailer ares form

vars
	ydc : YRD_ContainerDrawingController;
	anLC : CM_LocationsController;
	tmpPoint,key1, key2 : Point;
	minX,minY,maxX,maxY, idx : Integer;
	anObject : Object;
	yrdForm : Form;
begin
	yrdForm := self.getForm();
	if yrdForm  = null then
		return;
	endif;
	if yrdForm.isKindOf(YRD_GridAreasForm) or yrdForm.isKindOf(YRD_GridAreasOverviewForm)then
		ydc := self.getDrawingController();
	endif;

	foreach anLC in _lcs do
		if anLC.isShelf then
			if not ydc.allGridObjects.findObjectInDictGetXY(anLC.CM_RackShelfController.myLocation,key1, key2) then
				continue; // this may happen if the LC has been made into a sub block stack!!!!
			endif;
		else
			if not ydc.allGridObjects.findObjectInDictGetXY(anLC,key1, key2) then
				continue; // this may happen if the LC has been made into a sub block stack!!!!
			endif;
		endif;
		if minX = 0 then
			minX := key1.x;
		else
			minX := minX.min(key1.x);
		endif;
		if minY = 0 then
			minY := key1.y;
		else
			minY := minY.min(key1.y);
		endif;
		maxX := maxX.max(key2.x);
		maxY := maxY.max(key2.y);
	endforeach;

	tmpPoint.set(minX,minY);
	self.allPoints.add(tmpPoint);
	tmpPoint.set(maxX,maxY);
	self.allPoints.add(tmpPoint);

	anObject := self.allObjects.getAtKey(minX,minY,maxX,maxY);
	if anObject = null then
		self.allObjects.putAtKey(minX,minY,maxX,maxY, _yalloc);
	else
		// ### no duplicates are allowed. So adjust the Y2 as necessary, if there are more than 6 allocations with exactly the same locations the 7th, 8th etc will be ignored.
		if anObject &lt;&gt; _yalloc then
			foreach idx in 1 to 5 do
				anObject := self.allObjects.getAtKey(minX,minY,maxX,maxY - idx);
				if anObject = null then
					self.allObjects.putAtKey(minX,minY,maxX,maxY - idx, _yalloc);
					break;
				endif;
			endforeach;
		endif;
	endif;

end;</source>
        <Parameter name="_lcs" type="CM_LCSet"/>
        <Parameter name="_yalloc" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="getRectFrameBlocks" id="193262b6-3cad-4908-ba28-66949d6d3715">
        <updating/>
        <source>getRectFrameBlocks(_ya: CM_YardAllocation;
					_blocks : ObjectArray input; 
					_allProxyYABlocks : CM_YABlockArray input;
					_ydc : YRD_ContainerDrawingController input) updating;
/*
Purpose:			

Date		Who		Reason
05 February 2009	cnwjk3	SFW1030
*/
vars
	locations: CM_LCArray;
	x1,x2,y1,y2 : Integer;
	theRect : CMUI_ResizableRectFrame;
	block,
 	proxyBlock	: CM_YABlock;
	invalidBlock : Boolean;
	blockClass : Class;
	proxyDeckingOptions, newDeckingOptions: CM_YADeckingOptionsBlock;

begin		
	if _ydc = null  or _blocks = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, block,invalidBlock);
	
	foreach theRect in self.allRectFrames do
		if theRect.myObject &lt;&gt; null and theRect.myObject.CMIF_YABlock.myYardAllocation &lt;&gt; _ya then
			continue;
		endif;
		
		block := self.allYABlocksByRectFrame[theRect];	
		theRect.getIntPoints(x1, y1, x2, y2);
		if theRect.visible then
			create locations transient;
			//_ydc.allGridObjects.findObjectsInDict(x1-2,y1-2,x2+2,y2+2,locations,CM_LocationsController,false);
			_ydc.allGridObjects.findObjectsInDict(x1-2,y1-2,x2+2,y2+2,locations,CM_LocationsController,false,true);	//12 Mar 2012 NDL Par 28669 - Need to include gaps...
			
			if locations.size &gt; 0 then
				_blocks.add(locations);
				if block &lt;&gt; null then
					blockClass:=block.class;
				endif;
				
				if block &lt;&gt; null and not invalidBlock then
					create proxyBlock as blockClass transient;
					proxyDeckingOptions := block.myDeckingOptions;
					create newDeckingOptions transient;
					newDeckingOptions.setProxyFrom(block.myDeckingOptions);
					newDeckingOptions.setMyBlock(proxyBlock);

					proxyBlock.setMinMaxHeight(block.getMinHeight,block.getMaxHeight);
					proxyBlock.setStatus(block.status);
					_allProxyYABlocks.add(proxyBlock);
				else
					create proxyBlock as locations.first.myTerminalArea.yaGetBlockType transient;
					proxyBlock.setMinMaxHeight(1,locations.first.myTerminalArea.getHeightOfStack());	
					invalidBlock:=false;
				endif;
			else
				delete locations;
			endif;
		endif;		
	endforeach;
		
end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
        <Parameter name="_blocks" type="ObjectArray" usage="input"/>
        <Parameter name="_allProxyYABlocks" type="CM_YABlockArray" usage="input"/>
        <Parameter name="_ydc" type="YRD_ContainerDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedRectFrame" id="0930e00e-063a-42ea-b911-b13a984b7516">
        <source>getSelectedRectFrame() : CMUI_ResizableRectFrame;
/*
Purpose:			

Date		Who		Reason
09 February 2009	cnwjk3	SFW1030
*/
vars
	rect : CMUI_ResizableRectFrame;
begin
	foreach rect in self.allRectFrames do
		if rect.visible and rect.isSelected then
			return rect;
		endif;
	endforeach;		
	return null;
epilog

end;</source>
        <ReturnType type="CMUI_ResizableRectFrame"/>
    </JadeMethod>
    <JadeMethod name="getSelectedYA" id="97acd7e5-0276-4616-8504-4646ef65faae">
        <source>getSelectedYA() : CM_YardAllocation;
/*
Purpose:			

Date		Who		Reason
09 February 2009	cnwjk3	SFW1030
*/

vars
	form	: YRD_SatelliteViewForm;
	obj		: CM_YAEntity;
	invalidYAEntity : Boolean;
begin
	//16/02/2011 cnwdz2 par26991
	on Exception do app.handleDeletedObject(exception, obj, invalidYAEntity);
	
	form := self.form.YRD_SatelliteViewForm;
	obj := form.tblYAM.getSelectedObject();
	
	if obj &lt;&gt; null then 
		//16/02/2011 cnwdz2 par26991 dereference task to check it is still valid
		obj.edition();
		if invalidYAEntity then
			return null;
		endif;
		
		if obj.isKindOf(CM_YABlock) then
			return obj.CM_YABlock.myYardAllocationIn;
		elseif obj.isKindOf(CM_YABlockGroup) then
			return obj.CM_YABlockGroup.myYardAllocationIn;
		else
			return obj.CM_YardAllocation;
		endif;
	endif;
epilog

end;</source>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="getTotalNumberOfSlots" id="760b9e6c-423e-4268-b77d-686ce8ea3458">
        <source>getTotalNumberOfSlots(_rect : CMUI_ResizableRectFrame ) : Integer;

/*

Purpose: calculate total number of slots excluding slots in _rect  (unless you pass a null)			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2009	cnwjk3	SFW1030

*/

vars
	theRect 	: CMUI_ResizableRectFrame;
	numSlots	: Integer;
	cmifYABlock : CMIF_YABlock;
begin
	foreach theRect in self.allRectFrames do
		if theRect &lt;&gt; _rect and theRect.visible and theRect.myObject &lt;&gt; null then
			cmifYABlock := theRect.myObject.CMIF_YABlock;
			numSlots := numSlots +  cmifYABlock.numSlots;
		endif;
	endforeach;
	
	return numSlots;
epilog

end;</source>
