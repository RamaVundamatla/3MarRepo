    <JadeMethod name="addControl" id="82e6563e-cdfa-4ca9-9d3b-c98d94c7a922">
        <updating/>
        <source>addControl(pControlName : String) updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not self.allControls.includes(pControlName)) then
		self.allControls.add(pControlName);
	endif;

end;</source>
        <Parameter name="pControlName" type="String"/>
    </JadeMethod>
    <JadeMethod name="addRow" id="ae95929a-68dc-4319-b09c-11a496d7d0f0">
        <updating/>
        <source>addRow(pIdx : Integer; pRow : EntTableRow) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	itemIdx	: Integer;

begin

	itemIdx := self.allEntTableRows.indexOf(pRow);
	
	if itemIdx = 0 then
		if pIdx = 0 then
			self.allEntTableRows.add(pRow);
		else
			self.allEntTableRows[pIdx] := pRow;
		endif;
	else
		if itemIdx &lt; pIdx or pIdx = 0 then
			return false;
		elseif itemIdx &gt; pIdx then
			self.allEntTableRows.removeAt(itemIdx);
			self.allEntTableRows[pIdx] := pRow;
		endif;
	endif;
	
	if pRow.controlName &lt;&gt; null then
		self.allControls.add(pRow.controlName);
	endif;
	
	return true;
	
end;</source>
        <Parameter name="pIdx" type="Integer"/>
        <Parameter name="pRow" type="EntTableRow"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addRowByName" id="3bf7e40d-72cd-4e57-8f0c-0dadc9de7b31">
        <updating/>
        <source>addRowByName(pIdx : Integer; pName : String) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     05 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableRow	: EntTableRow;
	
begin

	entTableRow := self.myEntTableGroup.allEntTableRowsByName[pName];
	
	if entTableRow &lt;&gt; null then
		return self.addRow(pIdx, entTableRow);
	endif;
	
	return false;
	
end;</source>
        <Parameter name="pIdx" type="Integer"/>
        <Parameter name="pName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addView" id="e3baea2b-a554-4d4f-8275-46c8746023d9">
        <updating/>
        <source>addView(pName, pDescr : String) : EntTableView updating;
// ---------------------------------------------------------------------------
// Created:     15 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	view	: EntTableView;
	
begin

	create view;
	view.set(pName, pDescr, self);
	
	return view;
	
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pDescr" type="String"/>
        <ReturnType type="EntTableView"/>
    </JadeMethod>
    <JadeMethod name="clearRows" id="37723ba3-babd-46b2-b242-85338ce1c650">
        <updating/>
        <source>clearRows() updating;
// ---------------------------------------------------------------------------
// Created:     11 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.allEntTableRows.clear;
	self.allControls.clear;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="clearRowsGreaterThan" id="2fc51c8b-a86d-43b2-9bcf-ea999648b2a2">
        <source>clearRowsGreaterThan(pValue : Integer);
// ---------------------------------------------------------------------------
// Created:     19 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableRow	: EntTableRow;
	idx			: Integer;
	
begin

	while self.allEntTableRows.size &gt; pValue do
		entTableRow := self.allEntTableRows[pValue+1];
		if entTableRow.controlName &lt;&gt; null then
			self.allControls.remove(entTableRow.controlName);
		endif;
		self.allEntTableRows.remove(entTableRow);
	endwhile;

end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getEntTableRow" id="e0b8dab0-d49b-4998-8b1e-6fe65fcf2300">
        <source>getEntTableRow(_rowName:String):EntTableRow;
// --------------------------------------------------------------------------------
// Created:		11 February 2009 by cnwdad1
//
// Purpose:		Returns a reference to an EntTableRow with the specified name.
//
// Parameters:	_rowName - The name of the table row to return.
//
// Returns:		A reference to an EntTableRow object, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableRowObj	: EntTableRow;
	
begin
	foreach tableRowObj in self.allEntTableRows do
		if tableRowObj.name = _rowName then
			return tableRowObj;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="EntTableRow"/>
    </JadeMethod>
    <JadeMethod name="getEntTableRowByHeading" id="8adac54c-88b5-43e5-8e1f-3b34ecd4f811">
        <source>getEntTableRowByHeading(_heading:String):EntTableRow;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars
	tableRowObj	: EntTableRow;
	
begin
	foreach tableRowObj in self.allEntTableRows do
	//	if tableRowObj.getHeading(null,null,app.myCurrentLocale) = _heading then
		if tableRowObj.getRawHeadingValue = _heading then	//12 Nov 2009	-  NDL
			return tableRowObj;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_heading" type="String"/>
        <ReturnType type="EntTableRow"/>
    </JadeMethod>
    <JadeMethod name="getName" id="dc551afa-2c4e-4f2a-b9b0-3e8881a06ef3">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:     09 November 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.String &amp; ' (' &amp; self.name &amp; ')';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRowByControlName" id="1714f4f2-6146-40ec-a5df-eefa30aac92c">
        <source>getRowByControlName(pName : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     12 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx		: Integer;
	maxRows	: Integer;
	
begin

	maxRows := self.allEntTableRows.size;
	foreach idx in 1 to maxRows do
		if self.allEntTableRows[idx].controlName = pName then
			return idx;
		endif;
	endforeach;
	
	return 0;
			
end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRowByName" id="89d15820-de99-42f9-9297-6dae652bdf77">
        <source>getRowByName(_attrName : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     05 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	idx		: Integer;
	maxRows	: Integer;
	
begin

	maxRows := self.allEntTableRows.size;
	foreach idx in 1 to maxRows do
		if self.allEntTableRows[idx].name = _attrName then
			return idx;
		endif;
	endforeach;
	
	return 0;
			
end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRowByNameWithStartPos" id="f9c1fdd4-750f-4436-993b-a5c5a690b977">
        <source>getRowByNameWithStartPos(_attrName : String; _startPos: Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:     05 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	idx			: Integer;
	maxRows		: Integer;
	startRow	: Integer;
begin
	startRow := 1;
	if _startPos &gt; startRow then
		startRow := _startPos;
	endif;
	
	maxRows := self.allEntTableRows.size;
	
	foreach idx in startRow to maxRows do
		if self.allEntTableRows[idx].name = _attrName then
			return idx;
		endif;
	endforeach;
	
	return 0;
			
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_startPos" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getViewRows" id="471a88d5-6e35-48f8-ad72-de34db17e504">
        <source>getViewRows(_viewName:String):EntTableRowArray;
// --------------------------------------------------------------------------------
// Created:		22 February 2007 by cnwdad1
//
// Purpose:		Fetches the array of rows for the specified table View.
//
// Parameters:	_viewName - The name of the View who's rows are required.
//
// Returns:		A reference a View's array of rows, otherwise null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableViewObj	: EntTableView;
	
begin
	tableViewObj	:=	self.allEntTableViews[_viewName];
	
	if tableViewObj &lt;&gt; null then
		return tableViewObj.allEntTableRows;
	endif;
	
	return null;
end;</source>
        <Parameter name="_viewName" type="String"/>
        <ReturnType type="EntTableRowArray"/>
    </JadeMethod>
    <JadeMethod name="outputAsXML" id="0fe37195-7eb8-453c-ba14-74838c3c55c9">
        <source>outputAsXML() : String;
// ---------------------------------------------------------------------------
// Created:     27 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	xmlStr	: String;
	etRow	: EntTableRow;
	etView	: EntTableView;

begin

	xmlStr := self.formatAsXMLPrefix(XMLTag_EntTableDef) &amp;
			  self.formatAsXML(XMLTag_DefName, self.name.xmlReplaceReservedChars(true)) &amp;
			  self.formatAsXML(XMLTag_Descr, self.description.xmlReplaceReservedChars(true)) &amp;
			  self.formatAsXML(XMLTag_ConstantName, self.constantName.xmlReplaceReservedChars(true)) &amp;
			  self.formatAsXML(XMLTag_GroupName, self.myEntTableGroup.name.xmlReplaceReservedChars(true)) &amp;
			  self.formatAsXMLPrefix(XMLTag_Rows);
	
	foreach etRow in self.allEntTableRows do
		xmlStr := xmlStr &amp; self.formatAsXML(XMLTag_RowName, etRow.name);
	endforeach;
	
	xmlStr := xmlStr &amp; self.formatAsXMLSuffix(XMLTag_Rows);
	
	foreach etView in self.allEntTableViews where etView.myRTVehicleConfig = null do //epr par 24503
		xmlStr := xmlStr &amp; etView.outputAsXML();
	endforeach;
	  
	xmlStr := xmlStr &amp; self.formatAsXMLSuffix(XMLTag_EntTableDef);
	
	return xmlStr;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="removeControl" id="0e497b92-059f-49e3-9aaf-5ce3ef267724">
        <updating/>
        <source>removeControl(pControlName : String) updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.allControls.includes(pControlName) then
		self.allControls.remove(pControlName);
	endif;

end;</source>
        <Parameter name="pControlName" type="String"/>
    </JadeMethod>
    <JadeMethod name="set" id="e5543c81-a771-4415-a274-b69eaeabac1f">
        <updating/>
        <source>set(pName, pDescr, pAttrHeading, pValueHeading : String; pGroup : EntTableGroup; pRoot : EntTableDataRoot) updating;
// ---------------------------------------------------------------------------
// Created:     08 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if name &lt;&gt; pName then
		name := pName;
	endif;
	
	self.description	:= pDescr;
	
	attrHeading		:= pAttrHeading;
	valueHeading	:= pValueHeading;
	

	if myEntTableGroup &lt;&gt; pGroup then
		myEntTableGroup		:= pGroup;
	endif;
	
	if myEntTableDataRoot &lt;&gt; pRoot then
		myEntTableDataRoot := pRoot;
	endif;

end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pDescr" type="String"/>
        <Parameter name="pAttrHeading" type="String"/>
        <Parameter name="pValueHeading" type="String"/>
        <Parameter name="pGroup" type="EntTableGroup"/>
        <Parameter name="pRoot" type="EntTableDataRoot"/>
    </JadeMethod>
    <JadeMethod name="setConstantName" id="03cb584c-a052-454c-9bbc-89fefc50e4db">
        <updating/>
        <source>setConstantName() updating;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpName	: String;
	
begin

	tmpName := self.myEntTableDataRoot.translateConstantName(DefType, self.name);
	
	self.constantName := DefPrefix &amp; tmpName[1].toUpper &amp; tmpName[2:end];

end;</source>
    </JadeMethod>
    <JadeMethod name="setFromXMLElement" id="858fa9e2-f1af-45ca-9afa-97f247cf1a56">
        <updating/>
        <source>setFromXMLElement(_xmlElement : JadeXMLElement; pGroup : EntTableGroup; pRoot : EntTableDataRoot) updating;
// ---------------------------------------------------------------------------
// Created:     18 July 2001 by cnwrs2
//
// Purpose:     
/*
			&lt;RowName&gt;id&lt;/RowName&gt;
			&lt;RowName&gt;blah&lt;/RowName&gt;
			..
			&lt;RowName&gt;LastOne&lt;/RowName&gt;
*/
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	viewStr,
	viewName,
	tmpStr		: String;
	viewsToDelete : EntTableViewSet;
	entTableView: EntTableView;
	tmpElement	: JadeXMLElement;
	theXMLArray	: JadeXMLElementArray;
		
begin

	self.name 			:= _xmlElement.getTagValueOfName(XMLTag_DefName);
	self.description	:= _xmlElement.getTagValueOfName(XMLTag_Descr);

	// Add to the collections
	self.myEntTableGroup		:= pGroup;
	self.myEntTableDataRoot	:= pRoot;
	
	create theXMLArray transient;
	
	// Set the rows
	tmpElement := _xmlElement.getElementByTagName(XMLTag_Rows);
	if tmpElement &lt;&gt; null then
		self.setRowsFromXMLElement(tmpElement, theXMLArray);
	endif;
	
	create viewsToDelete transient;
	self.allEntTableViews.copy(viewsToDelete);
	
	_xmlElement.getElementsByTagName(XMLTag_EntTableView, theXMLArray);
	foreach tmpElement in theXMLArray do
		viewName := tmpElement.getTagValueOfName(XMLTag_ViewName);
		if viewName &lt;&gt; null then
			entTableView := self.allEntTableViews[viewName];
			
			
			if entTableView = null then
				create entTableView persistent;
			else
				// remove from to delete set
				viewsToDelete.remove(entTableView);
			endif;
			
			entTableView.setFromXMLElement(viewName, tmpElement, self);
		endif;
	endforeach;
	
	// Delete views no longer required
	
	foreach entTableView in viewsToDelete do
	
		if entTableView.myRTVehicleConfig &lt;&gt; null then
			continue;
		endif;
		
		delete entTableView;
	endforeach;
	
epilog
	delete theXMLArray;	
	delete viewsToDelete;
end;</source>
        <Parameter name="_xmlElement" type="JadeXMLElement"/>
        <Parameter name="pGroup" type="EntTableGroup"/>
        <Parameter name="pRoot" type="EntTableDataRoot"/>
    </JadeMethod>
    <JadeMethod name="setRowsFromXMLElement" id="bc9dc5d5-212a-40c4-8639-94899fb41157">
        <source>setRowsFromXMLElement(_xmlElement : JadeXMLElement; _xmlArray : JadeXMLElementArray input) protected;
// ---------------------------------------------------------------------------
// Created:     19 July 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	rowName	: String;
	pos		: Integer;
	row		: EntTableRow;
	group	: EntTableGroup;
	rowElement	: JadeXMLElement;
begin
	self.allEntTableRows.clear();
	self.allControls.clear();
	group := self.myEntTableGroup;
	
	_xmlElement.getElementsByTagName(XMLTag_RowName, _xmlArray);

	foreach rowElement in _xmlArray do
		rowName := rowElement.textData.xmlReplaceReservedChars(false);
		if rowName &lt;&gt; null then
			row := group.allEntTableRowsByName[rowName];
			if row &lt;&gt; null then
				self.allEntTableRows.add(row);
				if row.controlName &lt;&gt; null then
					self.allControls.add(row.controlName);
				endif;
			else
				// need an error here
				app.writeStatement('ERROR &gt;&gt; No ' &amp; rowName &amp; ' row found in group ' &amp; group.name &amp; ' - loading def before row?');
				app.writeLog('ERROR &gt;&gt; No ' &amp; rowName &amp; ' row found in group ' &amp; group.name &amp; ' - loading def before row?', 0);
			endif;
		endif;
	endforeach;

/*
	pos := 1;
	while (pos &gt; 0) do
		rowName := pStr.cnEcGetNextTagValueOfName(XMLTag_RowName, pos);
		if rowName &lt;&gt; null then
			row := group.allEntTableRowsByName[rowName];
			if row &lt;&gt; null then
				self.allEntTableRows.add(row);
				if row.controlName &lt;&gt; null then
					self.allControls.add(row.controlName);
				endif;
			else
				// need an error here
			endif;
		endif;
	endwhile;
*/

end;</source>
        <access>protected</access>
        <Parameter name="_xmlElement" type="JadeXMLElement"/>
        <Parameter name="_xmlArray" type="JadeXMLElementArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTransientReferences" id="7b837614-ca2b-4ed9-a61c-72362b43cbdb">
        <updating/>
        <source>setTransientReferences(pPersistent : EntTableDef; pGroup : EntTableGroup) updating;
// ---------------------------------------------------------------------------
// Created:     09 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tEntTableRow,
	entTableRow		: EntTableRow;
	tEntTableView,
	entTableView	: EntTableView;
	
begin

	foreach entTableRow in pPersistent.allEntTableRows do
		tEntTableRow := pGroup.allEntTableRowsByName[entTableRow.name];
		if tEntTableRow &lt;&gt; null then
			self.allEntTableRows.add(tEntTableRow);
		else
			// need an exception here
		endif;
	endforeach;
	
	foreach entTableView in pPersistent.allEntTableViews do
		tEntTableView := entTableView.cloneSelf(true);
		tEntTableView.setTransientReferences(entTableView, self, pGroup);
	endforeach;
	
	self.myEntTableGroup := pGroup;
	
end;</source>
        <Parameter name="pPersistent" type="EntTableDef"/>
        <Parameter name="pGroup" type="EntTableGroup"/>
    </JadeMethod>
</Class>
