    <JadeMethod name="updateSameAsSet" id="fff06235-7677-4e18-a9a3-680066987297">
        <lockReceiver/>
        <updating/>
        <source>updateSameAsSet(_set: SelfType) updating;
// ---------------------------------------------------------------------------
// Created:     27 May 2003 by cnwsb1
//
// Purpose:		Make this set the same as the passed in set (ie. same
//				set members).  Quickly checks if the two are already the
//				same, and does nothing if they are.
// ---------------------------------------------------------------------------
vars
	isIdentical : Boolean;
	member : MemberType;
	numItems : Integer;
	
begin
	exclusiveLock(self);
	sharedLock(_set);
	numItems := self.size;
	
	if numItems = _set.size then
		isIdentical := true;
		
		if numItems &gt; 0 then
			foreach member in self do
				if not _set.includes(member) then
					isIdentical := false;
					break;
				endif;
			endforeach;
		endif;
	endif;
	
	if not isIdentical then
		self.clear;
		_set.copy(self);
	endif;
	
epilog
	unlock(self);
	if _set &lt;&gt; null then
		unlock(_set);
	endif;
end;</source>
        <Parameter name="_set" type="SelfType"/>
    </JadeMethod>
</CollClass>
