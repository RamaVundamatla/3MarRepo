    <JadeMethod name="incrementColNumBy" id="2be385ff-b131-4898-9b2a-6b01dfe2e4ad">
        <methodInvocation>mapping</methodInvocation>
        <source>incrementColNumBy(set : Boolean; _value : Integer io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2009	cnwer1	Initial creation

*/

vars

begin
	if self.use40ftIds then
		_value:=2;
	else
		_value:=1;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="labelLengthCol" id="dc180a0f-4451-4991-9387-23cb41b04ca2">
        <methodInvocation>mapping</methodInvocation>
        <source>labelLengthCol(set : Boolean; _value : Integer io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2009	cnwer1	Initial creation

*/

vars

begin
	//if using 40 ft ids add 1 i.e. if 
	_value:=((self.numColumns * self.incrementColNumBy) + self.use40ftIds.Integer).String.length;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
