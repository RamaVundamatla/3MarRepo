    <JadeMethod name="processReeferMonitor" id="ae242a11-2586-4dac-a6af-a8f11786f19d">
        <updating/>
        <source>processReeferMonitor(_buf:Binary) updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/12/2009	cnwdap1		CCMS MES 1007 Any tracked item can now be a reefer, not just containers
// ---------------------------------------------------------------------------

vars
	id:				String;
	tempRecord:		Real;
	alarm:			String;
	//ti:			CM_Container;	// CCMS 1007
	ti:				CM_TrackedItem;	// CCMS 1007
	firstCommDT,
	timeStamp:		TimeStamp;
//	alert:			CM_SystemAlert;
	connectOnly,
	comm,
	allowConnect:	Boolean;
begin


	timeStamp	:= readTimeOfAct(_buf[11:14].String);
	id			:= _buf[25:4].String.trimBlanks &amp;_buf[30:7].String.trimBlanks;	//31 May 2011	NDL	Par 27630
	
	if _buf.length &gt; 263 then
		self.logMonitor("Buffer to end reads &lt;"&amp;_buf[240:end].String &amp; "&gt;");
		self.logMonitor("First communication time "&amp;_buf[251:14].String&amp;" "&amp;id);
		firstCommDT	:= self.readTimeOfActLMT(_buf[251:14].String);		//this is sent in local time NOT UTC
	endif;
	
	// check for null return temp before converting to Real
	if _buf[66:8].String.trimBlanks = "" then	
		//return is blank check supply
		if _buf[57:8].String.trimBlanks = "" then
			//supply is also blank - do nothing 
			self.logMonitor("Receive Reefer_Monitor received with null temp "&amp;timeStamp.String&amp;" "&amp;id);
			// par 12767 cmwrs1 oct 2006
			tempRecord := NULL_TEMPERATURE;
			connectOnly := true;
		else
			tempRecord := _buf[57:8].String.Real;	// tempSupply  9th char is alpha
		endif;
	else
		tempRecord := _buf[66:8].String.Real;	// tempReturn 9th char is alpha
	endif;
	
	//is it communicating?
	if _buf[142:1].String = "Y" then
		comm := true;			
	else
		comm := false;			
	endif;
	
	if comm
	or ((not comm) and self.connectNonComms) then 
		allowConnect := true;
	endif;
	
	if app.isDevelopmentSystem then		//using dummy system - all boxes non-comm
		alarm := "N";
		comm := true;
	else
		alarm := _buf[143:1].String;
	endif;
	
	//ti := app.getMyTerminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Container,id].CM_Container;	// CCMS 1007
	ti := app.getMyTerminalDO_NOT_USE.allOnsiteTIsByIdCargoType.getAtKeyGeq(id, TI_CargoType_Container);		// CCMS 1007
	if ti &lt;&gt; null and ti.id &lt;&gt; id then																// CCMS 1007
		ti := null;																					// CCMS 1007
	endif;																							// CCMS 1007

	if ti &lt;&gt; null then
		if self.requestIDs.includes(ti.id) then
			self.logMonitor("Notify comm status "&amp;timeStamp.String&amp;" "&amp;id);
			ti.causeEvent(app.getMyTerminalDO_NOT_USE.getTerminalEvent(EVENT_REFCON_RESPONSE), true, comm);
			self.requestIDs.remove(ti.id);
			return;
		endif;
		if alarm = "Y" then
			self.logMonitor("REFCON ALARM RECEIVED "&amp;timeStamp.String&amp;" "&amp;id);

			connectOnly := true;
		elseif alarm = "N" then
			//--------------
			// OK this is something we want to keep
			//--------------
			self.logMonitor("Receive Reefer_Monitor "&amp;timeStamp.String&amp;" "&amp;id&amp;" " &amp;tempRecord.String);
		else
			self.logMonitor("WARNING: Alarm setting invalid.  Reading incorrect field from buffer.  Contact developer.");
			connectOnly := true;
		endif;

		//self.createTempReading(ti.CM_Container, tempRecord, timeStamp, firstCommDT, false, true, allowConnect, connectOnly, _buf);
		self.createTempReading(ti, tempRecord, timeStamp, firstCommDT, false, true, allowConnect, connectOnly, _buf);	//18 Oct 2012	NDL	Par 30550
			
	else
		self.logMonitor("TI not found in the onsite collection.  " &amp; id);
	endif;
	
	
end;</source>
        <access>protected</access>
        <Parameter name="_buf" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="processReeferMonitorOLD" id="777f7e0c-05ad-4305-942b-12011b17857d">
        <updating/>
        <source>processReeferMonitorOLD(_buf:Binary) protected, updating;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	id				: String;
	tempSupply		: Real;
	alarm			: String;
	ti				: CM_TrackedItem;
	timeStamp		: TimeStamp;
	alert			: CM_SystemAlert;
	terminal		: CM_Terminal;

begin

//	self.logMonitor(method.name);
	terminal := app.getMyTerminalDO_NOT_USE();

	timeStamp := readTimeOfAct(_buf[11:14].String);
	id := _buf[25:4].String&amp;_buf[30:7].String;
	
	tempSupply := _buf[55:8].String.Real;

	self.monitorCount := self.monitorCount + 1;
//	self.logMonitor("Receive Reefer_Monitor "&amp;timeStamp.String&amp;" "&amp;id&amp;" " &amp;tempSupply.String &amp; " " &amp; self.monitorCount.String);
	self.logMonitor(id &amp; ' ' &amp; self.monitorCount.String);

	alarm := _buf[143:1].String;			//  JC WAS  _buf[134:1]
	ti := terminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Container,id];
	if ti &lt;&gt; null then
		return;
		beginTransaction;
		//setForTempReading
		//ti.CM_Container.addRefConTempReading(tempSupply, timeStamp, alarm);
//		ti.CM_Container.setForTempReading(tempSupply, timeStamp, alarm, _buf);
		if alarm = "Y" then
			self.logMonitor("     REFCON ALARM RECEIVED "&amp;timeStamp.String&amp;" "&amp;id);
			create alert;
			alert.details := "REFCON ALARM: Container "&amp;ti.id&amp;" has incorrect reading.";
			alert.setSeverity(SEVERE_WARNING);	//dont use severe_reefer_alert
			//-----------
			//Tell alert to add itself to system
			//-----------
			alert.add;
		elseif alarm = "N" then
			//OK
		else
			self.logMonitor("WARNING: Alarm setting invalid.  Reading incorrect field from buffer.  Contact developer.");
		endif;
		app.cmsCommitTransaction(app.myPassport);  // commits alert
		//commitTransaction;	
	else
		self.logMonitor("TI not found in the onsite collection.  " &amp; id);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_buf" type="Binary"/>
    </JadeMethod>
