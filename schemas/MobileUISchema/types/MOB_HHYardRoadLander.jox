<GUIClass name="MOB_HHYardRoadLander" id="29d89bff-7784-44c3-b2c4-f3f43b2f5f03">
    <superclass name="MOB_HandHeldForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="lblLocation" id="ab7552f0-5cc6-4ebe-956f-d0774188eb46">
        <embedded/>
        <type name="Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myHandHeldCheckerAgent" id="9f8d4a5e-cf9d-485b-9a16-4e099625528c">
        <embedded/>
        <type name="MOB_HandHeldCheckerAgent"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtLocation" id="4d3bcb1d-5a02-45dd-8adc-9c01336185d2">
        <embedded/>
        <type name="MOB_TextBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="doResizeControls" id="2e9054e2-f962-4947-8490-19a5a9adf991">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation

*/

vars

	top : Real;
	stdWidth : Real;
	stdHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	stdHeight := self.getStdControlHeight;

	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	
	if _initialSetup then
		self.txtLocation.visible := true;
	endif;
	self.txtLocation.move( self.resizedMargin,
						 top,
						 stdWidth,
						 stdHeight );
						 
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="5d66606b-9567-40c8-8b4e-96ee5f51f2be">
        <source>findLocation( errMsg : String output): CM_LocationsController;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2010	cnwndl1	Initial creation	CCMS MES 1005


*/

vars

	dataString : String;
	location : CM_LocationsController;
	tmpFoundHeight : Integer;

begin

	dataString := txtLocation.text.trimBlanks.toUpper;
	
	if dataString = null or dataString = lblLocation.caption.toUpper then
		// null location is valid.
		location := null;
		
	else
		self.myTerminal.findLocationFromString(dataString, true, location, tmpFoundHeight);
		
		if location = null then
			errMsg := errMsg &amp; app.getErrorString1(Location_NotFound, "'" &amp; dataString &amp; "'");
			
		endif;
	
	endif;
	
	return location;

epilog

end;</source>
        <Parameter name="errMsg" type="String" usage="output"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="313aec71-583b-4b99-a00a-d04b0a34f961">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2010	cnwndl1	Initial creation

*/

vars

	errMsg : String;
	
begin

	self.myMobileGenericAgent.setMyYardLocation( self.findLocation( errMsg ) );
	if errMsg &lt;&gt; null then
		self.msgBox(errMsg, app.getErrorString(Error), MsgBox_OK_Only, true);
		return;
	endif;
	
	self.gotoForm(MOB_HHYardRoadLanderMove, false);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="2382fae2-cc0a-412d-8ac1-267697d1e879">
        <updating/>
        <source>handleBtnTwo() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	self.myMobileGenericAgent.clearAll();
	self.doBackButtonClick();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupControls" id="147dc915-c25b-4902-b8b9-19ed0da63ccd">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2010	cnwndl1	Initial creation

*/

vars

	location : CM_LocationsController;
	
begin

	location := self.myMobileGenericAgent.myYardLocation;
			 
	self.doResizeControls(true);
						 
	if location &lt;&gt; null then
		self.txtLocation.text := location.getFullId;
	else
		self.txtLocation.text := lblLocation.caption.toUpper;
	endif;
						 
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a558984b-1f76-4abe-a0e0-585cefcb0ce5">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	
begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;

	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Next), app.getErrorString(Menu), null, null, null );
	
	self.setupControls();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="e3e7f00f-f4ac-4e0d-9a29-f96c8615aed9">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014249, locale);
	lblLocation.translateCaption(Xlat_0014250, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtLocation_gotFocus" id="e3f49d48-fcb6-463d-a00f-12eaf2db6bd3">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtLocation_gotFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	if txtLocation.text = lblLocation.caption.toUpper then
		//txtLocation.text := null;
		txtLocation.selStart := 0;
		txtLocation.selLength := lblLocation.caption.length;
	endif;


epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtLocation_lostFocus" id="d1cb4d80-24ce-4bc4-baaf-d277b14b60ff">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtLocation_lostFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin
	
	if txtLocation.text.trimBlanks = null then
		txtLocation.text := lblLocation.caption.toUpper;
	endif;
	
	txtLocation.selStart := 0;
	txtLocation.selLength := 0;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
