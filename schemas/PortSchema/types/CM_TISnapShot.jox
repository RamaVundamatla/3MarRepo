    <JadeMethod name="myHSCode" id="dbef438c-752b-4b3a-a7de-a6b8b94bcdfa">
        <methodInvocation>mapping</methodInvocation>
        <source>myHSCode(set: Boolean; _value: CM_HarmonizedSystem io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
15 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	
	code : CM_HarmonizedSystem;
	
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
