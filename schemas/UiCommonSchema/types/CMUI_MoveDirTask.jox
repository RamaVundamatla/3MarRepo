    <JadeMethod name="create" id="88663a29-1ca7-48e9-82c6-723f997420a5">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     09 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.permissionView		:= PmYardMoveView;
	self.permissionMaint	:= PmYardMoveMaint;	

end;</source>
    </JadeMethod>
    <JadeMethod name="createYardRequestProxy" id="698d1424-4d54-4e1f-8459-c618a7188ad7">
        <source>createYardRequestProxy(	_lcnStr : String ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

/****Changes

Date		Name	TFS#			Description
============================================================================
03/09/2014	cnwndl1					Initial creation
03/10/2018	jlgka1	40698			Add "heavyRated" in method call 
									setProxyYardDelivery as a result of changes
									in that method.
3 Nov 2022 	navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
============================================================================*/

vars
	br 					: CM_BulkRelease;
	reserve 			: CM_ReserveDetail;
	reserveSelection 	: CM_ReserveSelection;
	pxyJob 				: CM_YardInternalJob;
	realJob 			: CM_YardInternalJob;
	pxyReq 				: CM_YardDeliveryRequest;
	realReq				: CM_YardDeliveryRequest;
	count 				: Integer;
	userCode 			: String;
	allAvGrades			: IntegerArray;
	isoType				: String;
	operatorCode 		: String;
	isoGroup 			: String;
	cargoType 			: CM_CargoType;
	subCargoType 		: CM_Product;
	wleCount 			: Integer;
	totalQuantity 		: Integer;
	quantity 			: Integer;
	heavyRated 			: Boolean; //jlgka1 TFS # 40698
begin

	if self.myBaseObject &lt;&gt; null then
	
		if self.myBaseObject.isKindOf( CM_BulkRelease ) then
		
			br := self.myBaseObject.CM_BulkRelease;
			userCode := app.getMyUserCode();
			create allAvGrades transient;
			operatorCode := br.getOperatorCode;
			
			foreach reserve in br.allReserveDetails do
				if not reserve.isKindOf( CM_ReserveSelection ) then
					continue;
				endif;
				reserveSelection := reserve.CM_ReserveSelection;
				count := count + 1;
				
				delete pxyJob;
				delete pxyReq;
				allAvGrades.clear();
				isoType := null;
				cargoType := null;
				subCargoType := null;
				totalQuantity := 0;
				quantity := 0;
				
				cargoType := reserveSelection.myCargoType;
				subCargoType := reserveSelection.myProduct;
				
				if cargoType.allowDuplicates then
					totalQuantity := 1;
					quantity := reserveSelection.totalRequested;
				else
					totalQuantity := reserveSelection.totalRequested;
				endif;
				
				if not reserveSelection.allAvailabilityGrades.isEmpty then
					reserveSelection.allAvailabilityGrades.copy( allAvGrades );
				endif;
				if reserveSelection.myISOType &lt;&gt; null then
					isoType := reserveSelection.myISOType.code;
				endif;
				if reserveSelection.myISOGroup &lt;&gt; null then
					isoGroup := reserveSelection.myISOGroup.code;
				endif;
				
				heavyRated := reserveSelection.getHeavyRated(); // jlgka1 TFS # 40698;
				
				create pxyJob transient;
				pxyJob.setProxyYardDelivery(br.code &amp; "_" &amp; count.String ,self.myTerminal);
				pxyJob.setPriority( 1 );
				
				create pxyReq transient;
				pxyReq.setProxyYardDelivery(	isoType,	//_isoType : String;
												operatorCode,	//_operatorCode : String;
												null,	//_remarks : String;
												_lcnStr,	//_targetLocation : String;
												userCode,	//_userCode : String;
												reserveSelection.clean,	//_clean : Boolean;
												reserveSelection.bestPick,	//_bestPick	: Boolean;
												isoGroup,	//_isoGroup : String;
												pxyJob,	//_myJob : CM_Job;
												allAvGrades,	//_allAvGrades	: IntegerArray;
												totalQuantity,	//_totalRequested : Integer;
												br.mySubTerminal,	//_subTerminalObj : CM_SubTerminal;
												null,	//_sourceLocation : CM_LocationsController;
												null,	//_sourceTA : CM_TerminalArea;
												null,	//_sourceGridObj : CM_GridObject;
												null,	//_requiredByDT : TimeStamp ;
												br.mySubTerminalTarget,	//_targetSubTerminal : CM_SubTerminal ;
												br,	//_release	: CM_BulkRelease ;
												reserveSelection,	//_releaseItem : CM_ReserveDetail ;
												null,	//_rtQueue	: CM_RadioTelemetryQueue ;
												null,	//_myWORequestByType : CM_WorkOrderRequestByType
												heavyRated,	// jlgka1 TFS # 40698;
												null,	//3.11.2022	navsks20 TFS 52721
												null); //3.11.2022	navsks20 TFS 52721
												
				pxyReq.setPxyCargoTypeSubTypeQty(	cargoType,	//_cargoType : CM_CargoType;
													subCargoType,	//_subCargoType : CM_Product;
													quantity	//_quantity : Integer
													);
													
				//28 Aug 2019	NDL	TFS 46163
				pxyReq.setReserveDetail( reserveSelection );
		
				while true do
				
					app.myTrxCA.trxCreateYardInternalDeliveryR(pxyJob, realJob, pxyReq, realReq, true, app.myPassport);
					if app.myPassport.trxCompletedOK then
						break;
					endif;
					
					app.msgBox( app.myPassport.getAllErrorsAndWarningsAsStr, app.getErrorString(Error), MsgBox_OK_Only );
					return false;
					
				endwhile;
				
				if realJob &lt;&gt; null then
					wleCount := wleCount + realJob.workListEntries.size;
				endif;
				
			endforeach;
			
		endif;
	
	endif;
	
	app.mousePointer := MousePointer_Default;
	app.msgBox( wleCount.String &amp; " new yard director tasks created", app.getErrorString(Completed), MsgBox_OK_Only );
	
	return true;

epilog

	delete pxyJob;
	delete pxyReq;
	delete allAvGrades;

end;</source>
        <Parameter name="_lcnStr" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="e0dc8751-528c-4272-afb1-6fd4fc58869d">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
//--------------------------------------------------
// Created:	25 August 2003 By: cnwgd1
//--------------------------------------------------
vars
	rtValue : Integer;
begin
	if self.tblMove.hasChanged then
		rtValue := app.msgBox("You have changed data on the table." &amp; Cr &amp; "Do you want to continue?","Confirm Cancel",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if rtValue = MsgBox_Return_No then
			return;
		endif;
	endif;
	inheritMethod();
	self.unloadForm();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCreateDirTasks" id="178f023f-804f-496e-975b-261973ff8b76">
        <updating/>
        <source>doCreateDirTasks()updating, protected;
//--------------------------------------------------------------
//Created: 22 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars

	targetLocn : CM_LocationsController;
	lcnStr : String;
	result : Integer;
	
begin

	app.mousePointer := MousePointer_HourGlass;	
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();

	targetLocn := self.getTargetLocation(true);

	if targetLocn &lt;&gt; null then
		lcnStr := targetLocn.getFullId();
	else
		app.mousePointer := MousePointer_Default;
		app.msgBox( "Must select a valid location", app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	self.createYardRequestProxy( lcnStr );

epilog
	
	app.mousePointer := MousePointer_Default;	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="1130d516-aebb-4531-afd6-5cf6401832f9">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

	height	: Real;

begin

	self.fldMove.top := self.frmToolbar.height;
	
	height := self.clientHeight - self.frmToolbar.height;
	self.fldMove.height := height;	
	
	self.frmToolbar.repositionAfterResize();
	if self.multiItems.visible then
		self.multiItems.cnEcResizeContents();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="getTargetLocation" id="76c41d84-62a0-4be7-993e-49c81a56f7b5">
        <updating/>
        <source>getTargetLocation( _raiseError : Boolean ) : CM_LocationsController updating, protected;
//--------------------------------------------------------------
//Created: 07 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	targetController : CM_LocationsController;
	tmpTA : CM_TerminalArea;
	foundHeight : Integer;
	newLocn,
	tmpStr : String;
begin

	// Se if they have entered a location string
	newLocn := tblMove.getValueByName(ETRow_NewLocn).String;
	newLocn := newLocn.trimBlanks;
	tmpTA := self.cmbTermArea.listObject.CM_TerminalArea;
	
	if self.cmbYardLocation.listObject &lt;&gt; null then
		if tmpTA &lt;&gt; null and tmpTA.isRTGArea() then
			tmpStr := self.tblMove.getValueByName(ETRow_TerminalArea).String  &amp; self.tblMove.getValueByName(ETRow_YardLocation).String;
		else
			tmpStr := self.tblMove.getValueByName(ETRow_TerminalArea).String &amp; ' ' &amp; self.tblMove.getValueByName(ETRow_YardLocation).String;
		endif;
		// changed as full location (terminal + yard) can be listed in ETRow_NewLocn HG 11/01/05
		if tmpStr &lt;&gt; null then
			targetController := self.cmbYardLocation.listObject.CM_LocationsController;
		endif;
	elseif self.cmbTermArea.listObject &lt;&gt; null then
		tmpStr := self.tblMove.getValueByName(ETRow_TerminalArea).String;
		if tmpStr &lt;&gt; null then	
			targetController := self.cmbTermArea.listObject.CM_TerminalArea.getLocationsController();	
		endif;
	endif;
	
	if targetController &lt;&gt; null then
		if newLocn = null or newLocn = tmpStr.trimBlanks then
			return targetController;
		endif;
	endif;

	self.myTerminal.findLocationFromString(newLocn, false, targetController, foundHeight);

	if targetController = null then
		if _raiseError then
			app.raiseCMException1(ERR_INVALID_LOCN, newLocn, ETRow_NewLocn, null);
		endif;
	endif;

	return targetController;
	
end;</source>
        <access>protected</access>
        <Parameter name="_raiseError" type="Boolean"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getTargetLocationControllers" id="f0896d64-68b9-4e5a-97e0-9ff585e21ac7">
        <source>getTargetLocationControllers( _targetLocns : CM_LCArray io; _lcnStr : String output ):Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2011	cnwndl1	Initial creation	Par 28035
						Find the target location controllers for the selected areas in 'decking in' order 

*/

vars

	userSelectedLocns : CM_LCArray;
	allTargetAreaLocnsInOrder : CM_LCArray;
	targetString : String;
	looksLikeTermArea : Boolean;
	topLeft, bottomRight: CM_LocationsController;	
	targetTermArea : CM_TerminalArea;	
	targetLocn : CM_LocationsController;
	yaLocnCells: CM_YALocationCellArray;
	yaCell : CM_YALocationCell;
	locn : CM_YardController;
	yaAgent: CM_YAAgent;	
	msg : String;

begin

	_targetLocns.clear();
	
	// get the target area entered by the user and attempt to decipher it.
	targetString := tblMove.getValueByName(ETRow_NewLocn).String;
	_lcnStr := targetString;
	looksLikeTermArea := self.myTerminal.findYABlock(targetString, topLeft, bottomRight, null);
	
	//Ok we have something that thinks its a target terminal area.
	if looksLikeTermArea then
	
		if topLeft &lt;&gt; null and topLeft.myTerminalArea &lt;&gt; null then
			targetTermArea := topLeft.myTerminalArea.CM_TerminalArea;
		else
			msg := app.getErrorString1(Not_recognised_valid_location,targetString);
			app.msgBox(msg, app.getErrorString(Multi_move) ,MsgBox_OK_Only);
			return false;
		endif;
		
		if targetTermArea.isKindOf(CM_YardInterchangeArea) then
			msg := app.getErrorString(Select_area_not_interc_area);
			app.msgBox(msg, app.getErrorString(Multi_move) ,MsgBox_OK_Only);
			return false;
		endif;
		
		_lcnStr := targetTermArea.id;
		
		// convert the string to a range of locations.
		create yaAgent transient;
		create userSelectedLocns transient;
		
		yaAgent.findAllLocations(topLeft, bottomRight, userSelectedLocns);
		
		//get a collection of all locations in the terminal areas 'decking in' order.
		// but only the ones that have space available (I.e. nothing in or queued or planned to that specific cell)
		yaLocnCells := targetTermArea.myYADeckingOptions.allYALocationCellsIn;
		
	else
	
		msg := app.getErrorString1(Not_recognised_valid_location,targetString);
		app.msgBox(msg, app.getErrorString(Multi_move) ,MsgBox_OK_Only);
		return false;
		
	endif;
	
	create allTargetAreaLocnsInOrder transient;
	
	if yaLocnCells &lt;&gt; null then
		foreach yaCell in yaLocnCells do
			if yaCell.isAvailForMultiMove() then
				locn := yaCell.myYardController;
				if locn &lt;&gt; null then
					allTargetAreaLocnsInOrder.add( locn );
				endif;
			endif;
		endforeach;
	else
		//To deal with any that do not use decking options...
		msg := app.getErrorString1(Not_recognised_valid_location,targetString);
		app.msgBox(msg, app.getErrorString(Multi_move) ,MsgBox_OK_Only);
		return false;
		
	endif;
	
	// add in 'the decking in' order the ones that are in both collections.
	foreach targetLocn in allTargetAreaLocnsInOrder do
		if not userSelectedLocns.includes(targetLocn) then
			continue;
		endif;
		if not targetLocn.isAvailForMultiMove() then
			// it is occupied in some way. Actual, Queued or Planned.
			continue;
		endif;
		_targetLocns.add( targetLocn );
	endforeach;
	
	
	if _targetLocns.isEmpty then
		app.msgBox( app.getErrorString(No_Locs_Found_For_multi_move), app.getErrorString(Move_error),MsgBox_OK_Only);
		return false;
	endif;
	
	return true;

epilog

	delete userSelectedLocns;
	delete allTargetAreaLocnsInOrder;
	delete yaAgent;

end;</source>
        <access>protected</access>
        <Parameter name="_targetLocns" type="CM_LCArray" usage="io"/>
        <Parameter name="_lcnStr" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initForm" id="6a736e76-50ae-4ac7-a2eb-6f414d014679">
        <updating/>
        <source>initForm() updating;
//--------------------------------------------------------------
//Created: 22 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	entTableDef : EntTableDef;
	tmpModes : String;
	
begin
	
	self.shtItems.visible := false;

	self.tblMove.warningMethod := 'entTableWarning';
	entTableDef := app.myController.getEntTableDef(ETDef_QueueDirTasks);
	self.tblMove.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');

	tmpModes := app.getErrorString(Queued_Move);
	self.myAssistant.comboBoxMoveModeSpecific(self.tblMove, ETRow_MoveType, self.initMoveType,tmpModes);
	
	self.loadTACombos(null, null);
	
	self.tblMove.setFocus();
	self.tblMove.moveFirst();

	self.tblMove.goToRowByName(ETRow_TerminalAreaType);
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="9509e804-3bd4-49af-9038-2458c95fc07b">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------------------
//Created: 22 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	theActiveControl	: Control;
	
begin

	inheritMethod(keyCode, shift);
	if keyCode = J_key_Tab then

		tblMove.handleFormTab(keyCode, shift, btnCancelBase, btnMoveIt);

		theActiveControl := app.activeControl;
		if theActiveControl.parent.isKindOf(CM_EntryTable) then
			theActiveControl := theActiveControl.parent.Control;
		endif;
		if theActiveControl.isKindOf(CM_EntryTable) then
			theActiveControl.CM_EntryTable.handleTableTab(shift);
		endif;
		
	endif;
			
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="ee0b9522-62ee-4b72-b8b8-7d9ac10a0859">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	25 August 2003 By: cnwgd1
//--------------------------------------------------
vars

begin

	inheritMethod();
	self.initForm();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTACombos" id="a77e82f9-621e-4224-994c-4bdeeb76b413">
        <updating/>
        <source>loadTACombos(_taType : CM_TerminalAreaType; _theLocation : CM_LocationsController)protected, updating;
//--------------------------------------------------
// Created:	25 August 2003 By: cnwgd1
//--------------------------------------------------
vars
	
	ta		: CM_TerminalArea;
	type	: Integer;
	idx		: Integer;
begin
	
	type := TA_TYPE_NULL;
	
	if _taType &lt;&gt; null then
		type := _taType.type;
		if _theLocation &lt;&gt; null then
			ta := _theLocation.myTerminalArea;
		endif;
	endif;
	
	self.myAssistant.comboBoxTAType(cmbTAType, _taType, true);	
	self.tblMove.setValueByControlName(cmbTAType.name, cmbTAType.text);

	self.myAssistant.comboBoxTerminalArea(cmbTermArea, type, ta);	
	self.cmbTermArea.lostFocus(cmbTermArea);
	
	if ta = null then
		self.myAssistant.comboBoxLocationControllers(cmbYardLocation, null, false);		
	elseif (not ta.isKindOf(CM_BlockStack)) then 
		self.myAssistant.comboBoxLocationControllers(cmbYardLocation, ta.getLCsCollectionForDisplay, false);
		//epr par 15879 19/5/08 not checking for the index will mean in some cases you will get a 14008 exception
		idx := self.cmbYardLocation.findObject(_theLocation);
		if idx &gt; 0 then
			cmbYardLocation.listObject := _theLocation;		
		endif;
		self.cmbYardLocation.lostFocus(cmbYardLocation);		
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_taType" type="CM_TerminalAreaType"/>
        <Parameter name="_theLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="mnuInspectObject_click" id="9e36fbd3-24a8-4460-b9a1-859b597aae69">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuInspectObject_click(menuItem: MenuItem input) updating;
//--------------------------------------------------
// Created:	26 August 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.myBaseObject &lt;&gt; null then
		self.myBaseObject.inspect;
	endif;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyObject" id="5e03eb57-7f29-4e4f-8d6c-967d38eb5118">
        <updating/>
        <source>setMyObject( _obj : CM_Object ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2014	cnwndl1	Initial creation	Par 34717

*/

vars

	str : String;
	reserve : CM_ReserveDetail;
	count : Integer;

begin

	self.myBaseObject := _obj;
	
	if _obj.isKindOf( CM_BulkRelease ) then
		str := "Create Director tasks for ";
		foreach reserve in _obj.CM_BulkRelease.allReserveDetails do
			if reserve.isKindOf(CM_ReserveSelection) then
				count := count + 1;
				if count &gt; 4 then
					str := str &amp; "..."; 
					break;
				endif;
				if count &gt; 1 then
					str := str &amp; ", "; 
				endif;
				str := str &amp; reserve.getTotalRequestedDisplay() &amp; ' x ' &amp; reserve.CM_ReserveSelection.getProductISOTypeDescr();
			endif;
		endforeach;
		self.shtMove.caption := str;
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setTargetLocation" id="17963eff-270a-4ecc-9662-19e606746dc7">
        <updating/>
        <source>setTargetLocation()updating, protected;
//--------------------------------------------------
// Created:	25 August 2003 By: cnwgd1
//--------------------------------------------------
vars

	tmpStr : String;
	
begin

	if self.cmbTermArea.listObject.isKindOf(CM_RTGArea) then
		tmpStr := self.cmbTermArea.text &amp; self.cmbYardLocation.text;
	else
		tmpStr := self.cmbTermArea.text &amp; ' ' &amp; self.cmbYardLocation.text;
	endif;
	if tmpStr.trimBlanks &lt;&gt; null then
		self.tblMove.setValueByName(ETRow_NewLocn, tmpStr);
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f8779305-3024-4603-80e9-4c9f008edb79">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	25 August 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	self.fldMove.useSheetBackColors := true;
	self.fldMove.setDefaultSheetBackColors();
 	self.fldMove.initSheetBackColors();

end;</source>
