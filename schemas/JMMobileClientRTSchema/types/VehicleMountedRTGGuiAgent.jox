    <JadeMethod name="create" id="74c669dd-d47f-4726-a9fe-431e34e7f7f0">
        <updating/>
        <source>create() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	version: String;
	platform :Integer;
begin
	create self.myVehicleMountedRTGAgent transient;
	create self.myNotesObj transient;
	self.beginNotification(self.myVehicleMountedRTGAgent, MobileHandHeldThin::VehicleMountedAgent.Event_Server_Note, Response_Continuous , null);
	
	
epilog

end;</source>
    </JadeMethod>
