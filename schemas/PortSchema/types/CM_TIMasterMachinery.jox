    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="edi"/>
    <PrimAttribute name="isoType" id="e97ad7e8-810d-40a0-8d1e-27b91955fa2b">
        <length>5</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDefaultTareWeight" id="ffff5361-5ca4-4923-8b6e-6c9adcd63045">
        <source>getDefaultTareWeight(): Decimal;
// ---------------------------------------------------------------------------
// Created:     18 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	type		:CM_ISOType;
	tareWeight	:Decimal[14,4];
begin
/*	The tare weight  defaults to the tare weight from the ISO type */
	type	:= self.getISOTypeObject;
		
	if type &lt;&gt; null then
		tareWeight := type.tareKilos;
	endif;
	
	return tareWeight;		
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getISOTypeObject" id="7994b7eb-218d-4649-a291-0a9c0999e458">
        <source>getISOTypeObject(): CM_ISOType;
/* ---------------------------------------------------------------------------
Created:	14 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	return 	app.myRoot.allISOTypes[self.isoType];

end;</source>
        <ReturnType type="CM_ISOType"/>
    </JadeMethod>
    <JadeMethod name="getISOTypeString" id="e0ce01e4-b1b1-462b-9619-205a9c6cd475">
