    <JadeMethod name="doLogOnOff" id="937c061b-09b3-4995-9d94-010a46980671">
        <updating/>
        <source>doLogOnOff() protected, updating;
// -------------------------------------------
// Created 24 November 2005 by cnwdvb1
// -------------------------------------------
vars
	errorStr 				: String;
//	iniColorBackground		: Integer;
//	iniColorForeground		: Integer;
	sysColorBackGeneral		: Integer;
	sysColorForeGeneral		: Integer;
	sysColorBackTable		: Integer;
	sysColorForeTable		: Integer;
	userColorBackGeneral	: Integer;
	userColorForeGeneral	: Integer;
	userColorBackTable		: Integer;
	userColorForeTable		: Integer;
	portLogo				: Binary;

begin
	if self.aIsLoggedOn then
		self.aWarnings := false;
		self.queryDeleteButtonsMenu();	//delete all cloned buttons for RT Queries.  ccms1593. cnwvu1	April 2008

		while true do
			if not app.myRTGuiAgent.doLogOff(self.aState, errorStr, self.aWarnings) then
				if self.showMessage(errorStr, true) then
					continue;
				endif;
			else
				// Have to do this here because of the way errors work.
				self.setAviOnOff(false);
				self.setOnHoldBtn(false);
			endif;
			
			break;
		endwhile;
		
	else
		if self.aClientConnectionDetails = null then
			return;
		endif;
		
		self.aState := RadioTelemetryGuiAgent.LoggedOff;
		
		if app.myRTGuiAgent.doLogon(	self.txtUserName.text.toUpper(),
										self.txtNewPassword.text,
										self.aClientConnectionDetails,
										sysColorBackGeneral,
										sysColorForeGeneral,
										sysColorBackTable,
										sysColorForeTable,
										userColorBackGeneral,
										userColorForeGeneral,
										userColorBackTable,
										userColorForeTable,
										self.aMachineCode,
										self.aMachineLiftType,			// CCMS 1595 cnwyl1 27/11/07
										self.aPrimaryQueueId,			// PAR #16010
										self.aNumberOfAvailableQEntries,	// PAR #16010
										self.aCanChangeQueue,			// PAR #16010
										self.aCanRunSelectorQueries,
										self.aShowNumberOfQueueEntries,	// PAR #16010
										portLogo,
										self.aState,
										self.aResetState,
										errorStr,
										self.aLastTs) then
			
			self.adjustColorsAfterLogon(sysColorBackGeneral,
										sysColorForeGeneral,
										sysColorBackTable,
										sysColorForeTable,
										userColorBackGeneral,
										userColorForeGeneral,
										userColorBackTable,
										userColorForeTable);
			
			self.picLogo.picture := portLogo;
			self.tableOptionsDetailsPopulate();
			self.writeUseNameToIniFile();
			
			app.myRTGuiAgent.getQuerySet( self );	// ccms1593. cnwvu1	April 2008

		else
			self.showMessage(errorStr, true);
		endif;
	endif;
	
	self.updateFromState();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMove" id="41b52db2-f77d-4bf0-bcfc-eeb16773eb4d">
        <updating/>
        <source>doMove() protected, updating;
// -------------------------------------------
// Created 01 February 2006 by cnwdvb1
// -------------------------------------------
vars
	errorStr		: String;
	tandemTIid		: String;
begin
	if aMachineLiftType = TANDEM_LIFT then
		tandemTIid := self.txtContainerID2.text;
	endif;
	self.aWarnings := false;
	while true do
		if not app.myRTGuiAgent.moveTI(self, self.txtNewLocation.text.trimRight(), tandemTIid, errorStr, self.aState, self.aWarnings) then
			if self.showMessage(errorStr, true) then
				continue;
			endif;
		else
			self.updateFromState();
		endif;
		break;
	endwhile;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
