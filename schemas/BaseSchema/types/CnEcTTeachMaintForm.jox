    <JadeMethod name="chkCheckIsVisible_click" id="b164a3a8-39ca-46a2-844c-3327cee2daa2">
        <controlMethod name="CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkCheckIsVisible_click(checkbox: CheckBox input) updating;

