    <JadeMethod name="doCmbOverrideRsonsClick" id="bb4e2dfb-65b4-4951-b0d3-a14c0d425de5">
        <updating/>
        <source>doCmbOverrideRsonsClick( _combobox : ComboBox input ) updating, protected;

/*
Date			Who		Reason
30 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	overrideReason	: CM_StopOverridenReason;
	table			: CM_DataTable;
	
begin
	// which table are we currently working one
	if _combobox.parent = self.tblStopsAdd then
		table	:= self.tblStopsAdd;
	elseif _combobox.parent = self.tblStopsClear then
		table	:= self.tblStopsClear;
	else
		// what table are we working on?!
		return;
	endif;

	overrideReason	:= _combobox.listObject.CM_StopOverridenReason;
	table.accessCell( table.row, table.column ).itemObject	:= overrideReason;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doQueryUnload" id="149837c3-e0a6-40dc-a1d2-c576f3d3478c">
        <source>doQueryUnload(_cancel: Integer io; _reason: Integer) protected;
// ---------------------------------------------------------------------------
// Created:     10 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.isFormChanged then
		if not self.confirmCancel (app.getErrorString (The_Current_Item)) then
			_cancel := 1;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cancel" type="Integer" usage="io"/>
        <Parameter name="_reason" type="Integer"/>
    </JadeMethod>
