<GUIClass name="MB_BaseForm" id="5143ab55-f2b3-4e5b-8265-abd6d4055799">
    <superclass name="Form"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="keyDown" id="86124a4a-2965-4185-8bbe-f472fc09e806">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		07 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if keyCode = MB_Key_F11
	and shift.mbIsCtrlKey()
	and not shift.mbIsAltKey()
	and not shift.mbIsShiftKey()
	and app.isDevelopmentSystem()
	then
		self.inspect();
		
	elseif keyCode = MB_Key_F12
	and shift.mbIsCtrlKey()
	and not shift.mbIsAltKey()
	and not shift.mbIsShiftKey()
	and app.isDevelopmentSystem()
	then
		if shift.mbIsCtrlKey() then
			self.showActiveDetails();
		endif;
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="012d5024-62ff-4d4f-b0bc-eede99fa2afd">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		07 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
//app.writeStatement( self.class.name &amp; '::' &amp; method.name &amp;  ' 1. ');
	self.setupForm();
//app.writeStatement( self.class.name &amp; '::' &amp; method.name &amp;  ' 2. ');
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
