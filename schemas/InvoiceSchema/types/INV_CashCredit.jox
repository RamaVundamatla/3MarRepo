    <JadeMethod name="mnuCargoEnquiry_click" id="e5ea33ae-b559-4f79-a041-09eba5950f51">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCargoEnquiry_click(menuItem: MenuItem input) updating;

/*

Purpose:			32974
					33953 make it multi-select
Parameters:			

Return Value:		


Date		Who		Reason
12 November 2013	cnwjre1	Initial creation

*/

vars
	row		: Integer;
	table	: CM_DataTable;
	obj		: Object;
	tiArray : CM_TIArray;
begin
	// 32974 access to cargo enquiry for extra free storage days (and anything else like this)
	table := self.tblCharges;
	create tiArray transient;
	// 34226 from enquiry and make it the same as a double-click
	if self.myCashReceipt &lt;&gt; null then
		if table.row &gt;= table.fixedRows and
		   table.row &lt;= table.rows then
			obj := table.accessCell(table.row, 2).itemObject;
			if obj &lt;&gt; null and 
			   obj.isKindOf(CM_TrackedItem) then
				self.myAssistant.myTerminal := self.myTerminal;
				self.myAssistant.showCargoEnquiryForm(obj.CM_TrackedItem, self.myMasterMenuAction, false, false);	
			endif;
		endif;
	// regular cash collection
	else
		foreach row in table.fixedRows to table.rows do
			if table.accessCell(row, 2).selected then
				obj := table.accessCell(row, 2).itemObject;
				if obj &lt;&gt; null then 
					if obj.isKindOf(CM_TrackedItem) then
						tiArray.add(obj.CM_TrackedItem);
					endif;
				endif;
			endif;
		endforeach;
		if not tiArray.isEmpty() then
			if self.myAssistant.myTerminal = null then			// 33526 needs setting for cash receipt enquiry
				self.myAssistant.myTerminal := self.myTerminal;
			endif;
			self.myAssistant.showCargoEnquiryForTIs(tiArray[1].CM_TrackedItem, tiArray, self.myMasterMenuAction, false);
		endif;
	endif;

epilog
	delete tiArray;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuInspect_click" id="c11d3181-244a-45c2-952d-9051c708fe78">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuInspect_click(menuItem: MenuItem input) updating;
/*
Purpose:			
Date		Who		Reason
29 May 2014	cnwab1	Initial creation
18 Sep 2019	cnwma1	Bug 46582: Cash Credit are not being accounted for correctly	
*/

vars
	row : Integer;
	object : Object;
begin
	
	row := self.tblCharges.row;
	
	if row &gt; 0 	and row &lt;= self.tblCharges.rows then
		object := self.tblCharges.accessRow	(row).itemObject;
		if object &lt;&gt; null then
			object.inspect;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
