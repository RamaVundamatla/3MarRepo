    <JadeMethod name="erase" id="d8094de1-873c-46c8-a457-129ea7d4f439">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     20 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	proforma : CMQF_InvoiceProforma;

begin
	self.allCriteriaLineHolders.purge();
