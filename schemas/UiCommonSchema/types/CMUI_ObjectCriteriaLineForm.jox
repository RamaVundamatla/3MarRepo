        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2013	cnwndl1	Initial creation	Par 33184

*/

vars

begin

	self.initialSheetIndex := 1; 
	
	inheritMethod();
	
	if self.myParentForm &lt;&gt; null then
		self.centreOverParent( 0 );
	endif;
	
	self.handleMenusForModalDisplay();
	self.resizeForReportFormatMatch();
epilog

end;</source>
