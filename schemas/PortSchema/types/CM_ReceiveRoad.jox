    <JadeMethod name="locationYard" id="c324b397-3374-42bb-96b4-1dce419bd989">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>locationYard(set : Boolean; _value : String io) mapping, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2020	jlgndl1	Initial creation	TFS 49202

*/

vars

	trxDict : CM_TITransactionByTypeDateDict;
	trx : CM_TITransaction;
	lc : CM_LocationsController;
	ta : CM_TerminalArea;
	iter : Iterator;

begin

	if set then
		//all good, just let it happen
		return;
	endif;
	
	if _value &lt;&gt; null then
		//all good, just use what we got
	endif;

	//Ok so we get to here means we have no value, lets try to work it out;
	
	create trxDict transient;
	
	self.myTrackedItem.allTransactions.getAllTransactionsOfClass( CM_Move, trxDict, false );
	self.myTrackedItem.allTransactions.getAllTransactionsOfClass( CM_SetDown, trxDict, false );
	
	iter := trxDict.createIterator;
	while iter.next( trx ) do
		if trx.CM_Move.mode &lt;&gt; REAL_MODE then
			continue;
		endif;
		lc := trx.CM_Move.getTargetLocationsController();
		if lc &lt;&gt; null and lc.isYardLocation then
			ta := trx.CM_Move.getTargetTA();
			if ta &lt;&gt; null and not ta.isTransferArea then
				_value := lc.getFullId;
				break;
			endif;
		endif;
	endwhile;
	
	if _value &lt;&gt; null and process.isInTransactionState then
		self.locationYard := _value;
	endif;
	
epilog

	delete trxDict;
	delete iter;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="sendSAP" id="ae59f315-61ee-4f2f-8bad-8c459c20e0e1">
        <source>sendSAP();
/*
Purpose:			
					******** Don't Delete *********
Parameters:			

Return Value:		

Date		Who		Reason
09 April 2019	jlgndl1	Initial creation
11/06/2025	navcs2	MTN-34987  MTN -  Disable SAP Integration

*/

vars
	term : CM_Terminal;
	iter : Iterator;
	cashPayment : CM_CashPayment;
	inv : CM_Invoice;
	invLineSet : CM_InvoiceLineSet;
	invLine : CM_InvoiceLine;
	trxType : Integer;

begin
	
	/*
	Don't Delete SAP Integration not used any more 
	12.06.2025 MTN-34987
	*/
	
	return;				//12.06.2025 MTN-34987
	/*
	term := self.myTerminal;
	if term = null then		// during deferred updating
		term := self.myTrackedItem.myTerminal;
	endif;
	
	if not term.isSapFinancialEnabled then
		return;
	endif;
	
	create invLineSet transient;
	
	//find all prepay non sent invoice lines that are not related to 'to do tasks' and add to the sorted collection.
	iter := self.myTrackedItem.allCashPayments.createIterator;
	while iter.next( cashPayment ) do
		if cashPayment.myProformaDetail &lt;&gt; null then
			trxType := cashPayment.myProformaDetail.transactionType;
			if trxType = TRANS_TYPE_TODOTASK
			or trxType = TRANS_TYPE_TASKADD
			or trxType = TRANS_TYPE_TASKCOMPLETE
			or trxType &gt; TransactionTypeJMTMax 	//user defined, will be for a to do task
			then
				continue;
			endif;
		endif;
		invLine := cashPayment.myInvoiceLine;
		if invLine = null or invLine.invoice = null then
			continue;
		endif;
		if invLine.invoice.paymentType &lt;&gt; PaymentType_PrePay then
			continue;
		endif;
		if invLine.externalTS05.date.isValid then
			continue;
		endif;
		//if inv.hasWSDL112BgpForLine( invLine ) then	//14 May 2019	NDL	TFS 44248
		if invLine.invoice.hasWSDL112BgpForLine( invLine ) then	//20 May 2019	NDL	TFS 44248
			continue;
		endif;
		
		invLineSet.add( invLine );
			
	endwhile;
	
	if not invLineSet.isEmpty then
		self.doGroupAndSendSAP( invLineSet );
	endif;

epilog

	delete invLineSet;
	delete iter;
*/
end;</source>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="593277c1-81e3-4020-b8ed-efa78ea6e2cd">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2020	jlgndl1	Initial creation	TFS 49202
18 May 2022	navma1	ChangeRequest 53430: EUP - Sub Carrier registration in MTN
*/

vars
	truck 				: CM_Vehicle;
	originatingLocation,
	toPrimaryLocation	: CM_LocationsController;
	vvr					: CM_VehicleVisitRecord;
begin

	inheritMethod(_tiTransCntrl, _passport);
	
	originatingLocation := _tiTransCntrl.myOriginatingLocation;
	
	if originatingLocation &lt;&gt; null and originatingLocation.isVehicle then
		self.locationRoad := originatingLocation.getFullId();  // creating a receive during splitting off cargo during unload
		truck 			  := originatingLocation.CM_VehicleController.vehicle;
		if truck &lt;&gt; null then
			self.regNumber := truck.regNumber;
		endif;
		return;
	else
		self.locationRoad := _tiTransCntrl.myTrackedItem.locationId; // normal create during gate in
	endif;
	
	toPrimaryLocation:= _tiTransCntrl.myToPrimaryLocation;
	
	if toPrimaryLocation &lt;&gt; null then
		if toPrimaryLocation.isVehicle then
			truck := toPrimaryLocation.CM_VehicleController.vehicle;
			if self.locationRoad = null then
				self.locationRoad := toPrimaryLocation.getFullId();
			endif;
			if truck &lt;&gt; null then
				self.regNumber := truck.regNumber;
			endif;
		endif;
	endif;
	
	//21 Oct 2020	NDL	TFS 50113
	vvr := _tiTransCntrl.myVVR;
	
	if vvr &lt;&gt; null then
		self.myVehicleVisitRecord := vvr;							//18.5.2022 navma1 #53430
		self.trailerTypeCode      := vvr.getTrailerTypeCode( self );
	endif;

epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
