    <JadeMethod name="getWorkOrderTaskIdByClass" id="a5b324e8-6eec-43e7-8d2b-020fd925a83a">
        <source>getWorkOrderTaskIdByClass(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders

*/

vars
	wodTaskId : Integer;
begin
	if self.isKindOf(CM_WodBillingAdjustment) then
		wodTaskId := WO_TASK_BILLINGADJ;
	elseif self.isKindOf(CM_WodCargoRequest) then
		wodTaskId := WO_TASK_CARGOREQUEST;
	elseif self.isKindOf(CM_WodExtension) then
		wodTaskId := WO_TASK_EXTENSION;
	elseif self.isKindOf(CM_WodHMSRequestCancel) then
		wodTaskId := WO_TASK_HMSCANCEL;
	elseif self.isKindOf(CM_WodMarineServiceDetail) then
		wodTaskId := WO_TASK_MARINE;
	elseif self.isKindOf(CM_WodMarineServicesDepart) then
		wodTaskId := WO_TASK_MARINEDEPART;	
	elseif self.isKindOf(CM_WodMarineServicesInitial) then
		wodTaskId := WO_TASK_MARINEINITIAL;	
	elseif self.isKindOf(CM_WodPermitRequest) then
		wodTaskId := WO_TASK_PERMIT;	
	elseif self.isKindOf(CM_WodShiftMovement) then
		wodTaskId := WO_TASK_SHIFTMOVEMENT;	
	elseif self.isKindOf(CM_WodTimeChange) then
		wodTaskId := WO_TASK_TIMECHANGE;		
	elseif self.isKindOf(CM_WodVoyageCargoRequest) then
		wodTaskId := WO_TASK_CARGOINITIAL;	
	elseif self.isKindOf(CM_WodWaterRequest) then
		wodTaskId := WO_TASK_WATER;
	elseif self.isKindOf(CM_WodVoyageRequest) then
		wodTaskId := WO_TASK_NEWVOYAGE;
	endif;
	return wodTaskId;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
