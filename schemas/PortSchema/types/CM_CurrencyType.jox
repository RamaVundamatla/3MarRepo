    <JadeMethod name="setProxy" id="38d5e4ab-ecc4-4975-9790-76b0aa03aba1">
        <updating/>
        <source>setProxy(	_code : String;
			_currencySymbol : String;
			_description : String;
			_roundingInterval : Decimal;
			_roundingType : Integer
			)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2018	jlgndl1	Initial creation	TFS 37550

*/

vars

begin

	self.code := _code[1:10];
	self.currencySymbol := _currencySymbol[1:10];
	self.description := _description[1:200];
	self.roundingInterval := _roundingInterval;
	self.roundingType := _roundingType;
	
	self.myRoot := app.myRoot;

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_currencySymbol" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_roundingInterval" type="Decimal"/>
        <Parameter name="_roundingType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="fba62ddb-b96f-400b-a32e-7ccf3ab987c5">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2018	jlgndl1	Initial creation

*/

vars

	propName	: String;

begin

	if _property = null then
		return false;
	endif;
	
	
	propName := _property.name;
	
	if	propName = CM_CurrencyType::myRoot.name 
	or	propName = CM_CurrencyType::allCurrencyRates.name 
	then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
