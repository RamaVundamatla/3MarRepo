    <JadeMethod name="setFilterValues" id="711d5d9f-dbe2-44a8-85c0-ddd52a7f2769">
        <updating/>
        <source>setFilterValues() updating;
/*
Purpose:			
Return Value:		

Date		Who		Reason
13 September 2007	cnwer1	Initial creation - PAR#xxxx
23 september 2008	concms1	par 17346 - reset values if nothing selected in combos
//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
vars
	//dateFrom, dateTo : Date;
	//timeFrom, timeTo : Time;
	now : TimeStamp;
	locTsFrom, locTsTo : TimeStamp;
	sysTsFrom, sysTsTo : TimeStamp;
begin
	self.filterFromTS	:=null;
	self.filterToTS		:=null;
	
	//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	now := app.actualTimeServer;
	
// par 17346 - start - reset all values to null 
	self.filterFaultQuestion	:= null;
	self.filterFaultType		:= null;
	self.filterMachine			:= null;
	self.filterStatus			:= null;
	self.filterMachineType		:= null;
	self.filterUser				:= null;
// par 17346 - end


	//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	locTsFrom.setDate(tblSearch.getValueByName(ETRow_FromDate).Date);
	locTsFrom.setTime(tblSearch.getValueByName(ETRow_FromTime).Time);
	locTsTo.setDate(tblSearch.getValueByName(ETRow_ToDate).Date);
	locTsTo.setTime(tblSearch.getValueByName(ETRow_ToTime).Time);
	
	
	
	
	if locTsFrom &lt;&gt; null then
		sysTsFrom := self.localToSystemTime(locTsFrom);
		self.filterFromTS := sysTsFrom;
	endif;
	
	if locTsTo &lt;&gt; null then
		sysTsTo   := self.localToSystemTime(locTsTo);
		self.filterToTS := sysTsTo;
	endif;
	
		
	self.filterLastXHours:=tblSearch.getValueByName(ETRow_LastXhours).Integer;
	self.filterFaultsOnly:=tblSearch.getValueByName(ETRow_FaultsOnly).Boolean;
	
	//do this in the tblSearch lost focus but just for testing
	if self.filterLastXHours &gt; 0 then
		self.filterToTS:=now;
		self.filterFromTS:=self.filterToTS.addHours(-filterLastXHours);
	endif;
	
	if self.cmbFaultQuestion.listIndex &gt; 0 then
		self.filterFaultQuestion:=self.cmbFaultQuestion.listObject.CM_FaultQuestion;
	endif;
	
	if self.cmbFaultType.listIndex &gt; 0 then
		self.filterFaultType:=self.cmbFaultType.listObject.CM_FaultType;
	endif;
	if self.cmbFaultStatus.listIndex &gt; 0 then
		self.filterStatus:=self.cmbFaultStatus.listObject.CM_FaultStatus;
	endif;
	if self.cmbMachine.listIndex &gt; 0 then
		self.filterMachine:=self.cmbMachine.listObject.CM_Machine;
	endif;
	if self.cmbMachineType.listIndex &gt; 0 then
		self.filterMachineType:=self.cmbMachineType.listObject.CM_MachineType;
	endif;
	if self.cmbUser.listIndex &gt; 0 then
		self.filterUser:=self.cmbUser.listObject.CM_User;
	endif;

	
	
	

epilog

end;</source>
    </JadeMethod>
