    <JadeMethod name="isIntegral" id="e8f26e3a-4aec-420b-ba0c-6c5500483be0">
        <source>isIntegral(): Boolean;

//cnwjo3, "Just for documentation"
//An integral ISO type is only used for reefers
//and it means that the Container (or ISO Type) has
//a refridgerating unit inside (or part) of the container.
//Note, this does not include the POWER SOURCE.  A Power source
//can be in the terminal, on a ship or on a truck which powers the
//integral unit.  A non-intregral unit could be something like a 
//carbon dioxide based cooling reefer.  Where there is no refrigeration
//system, the container is just made cold and it stays that way for a while.

begin
	return typeAttributes.bitAnd(ISO_INTEGRAL) &lt;&gt; 0;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLengthOK" id="83951c1e-fde8-404e-b4c8-fbb660bdf893">
        <source>isLengthOK() : Boolean;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 24 July 2003
//
// Check to ensure only one length has been selected.
//
//----------------------------------------------------------

vars
	idx, num, size : Integer;
	lens : BooleanArray;
begin
	create lens transient;
	
	lens.add(self.is20ftLong);
	lens.add(self.is30ftLong);
	lens.add(self.is40ftLong);
	lens.add(self.is45ftLong);
	lens.add(self.is53ftLong);
	size := lens.size;
	
	foreach idx in 1 to size do
		if lens[idx] then
			num := num + 1;
		endif;
	endforeach;
//	if (self.is20ftLong and self.is40ftLong) or (self.is20ftLong and self.is45ftLong) or (self.is40ftLong and self.is45ftLong) then
	if num &gt; 1 then
		return false;
	endif;
	
	return true;
epilog
	delete lens;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMachinery" id="e31b359f-7740-42d3-bd4c-e652936a9ce2">
        <source>isMachinery(): Boolean;

begin

	return typeAttributes.bitAnd(ISO_MACHINERY) &lt;&gt; 0;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isNonStandardHeight" id="d320fea4-1a99-4067-a9f7-acc9cbc31f71">
        <source>isNonStandardHeight() : Boolean;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// rs 21 Aug 2003 : This method/concept is a bit of a problem as  
//                  what does "standard" mean ? The method implies that 8' containers
//                  are standard but as these are porthole reefer they are not common.
//                  Currently most 40' are hi cube ie 9'6" so arn't they standard ? 

// AKB 16AUG2003 confirmed with Sheryl Smith that this is mainly used to identify Hicubes i.e. 9'6" for under deck planning
vars

	tmpISOType	: CM_ISOType;
	
begin

	if self.is9ft6High then
		return true;
	endif;
	
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOpenTop" id="31f63013-00fd-45d6-9218-50474de113f9">
        <source>isOpenTop(): Boolean;

begin
	return typeAttributes.bitAnd(ISO_OPENTOP) &lt;&gt; 0;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOpsViewData" id="46deaa8e-6759-49bd-9043-17d436360b0a">
        <source>isOpsViewData(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2020	jlgma1	Initial creation

*/

vars

begin
	if self.isTransient then
		return false;
	endif;
	
	if not self.isContainer then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
