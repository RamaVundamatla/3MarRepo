/*		
Date		Who		Reason
22 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	wp			: CM_WorkPoint;
	terminal	: CM_Terminal;
begin
	wp := self.myWorkPoint;
	
	if wp = null then	
		terminal := self.getMyTerminal;
	
		if terminal &lt;&gt; null then
