    <JadeMethod name="cloneTable" id="86de6583-6181-49e7-9203-3fe8e9273d72">
        <source>cloneTable(	_table ,
			_cloneFromTable : CM_DataTable;
			_jobSheetStats : CMIF_JobSheetStats input;
			_isForPrint : Boolean)  protected;
/*

Date		Who		Reason
29 March 2017	cnwer1	Initial creation TFS

*/

vars
	tblCrane : CM_DataTable;
	job : CM_Job;
	voyageJob  : CM_VoyageJob;
	jobStats : CMIF_JobStats;
	theForeColour, theBackColor : Integer;
begin
	tblCrane := _table ;//self.tblStage.getControl(((_idx).String &amp; self.tblStage.tabIndex.String).Integer);
	
	
	if tblCrane &lt;&gt; _cloneFromTable then
		tblCrane.setColumnsFromOrganiser(_cloneFromTable.allTblDataEntRows,null);
	endif;
	tblCrane.resetColumns(false);
	if not self.myVoyageStats.include30s then
		tblCrane.removeColumnByEntRowName(ETRow_30sDone);
		tblCrane.removeColumnByEntRowName(ETRow_30sToDo);
	endif;
	if not self.myVoyageStats.include45s then
		tblCrane.removeColumnByEntRowName(ETRow_45sDone);
		tblCrane.removeColumnByEntRowName(ETRow_45sToDo);
	endif;
	
	if not self.myVoyageStats.include53s then
		tblCrane.removeColumnByEntRowName(ETRow_53sDone);
		tblCrane.removeColumnByEntRowName(ETRow_53sToDo);
	endif;
	
	self.setNumericColumnWidths(tblCrane);
	
	if _isForPrint then
		tblCrane.accessRow(1).backColor:=White;
		tblCrane.accessRow(1).height:=tblCrane.accessRow(1).height * 2;
		tblCrane.rows:=1;
	endif;
	
	foreach job in  _jobSheetStats.myJobSheet.allJobsByOrder discreteLock do
		if not job.isKindOf(CM_VoyageJob) then
			continue;
		endif;

		voyageJob:=job.CM_VoyageJob;
		jobStats:=_jobSheetStats.allJobStatsByJob[voyageJob];
		if jobStats = null then
			continue;
		endif;
		if _isForPrint then
			theForeColour:= White;
			theBackColor:=Black;
		else
			job.getRowColour(theForeColour, theBackColor);
		endif;
		tblCrane.updateItemObject(jobStats,theForeColour,theBackColor,app.myPassport);
		
	
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable"/>
        <Parameter name="_cloneFromTable" type="CM_DataTable"/>
        <Parameter name="_jobSheetStats" type="CMIF_JobSheetStats" usage="input"/>
        <Parameter name="_isForPrint" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cmbVoyage_click" id="8ca19283-adf5-4b8f-adbf-439ebc97f975">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyage_click(combobox: ComboBox input) updating;
/*

Date		Who		Reason
24 March 2017	cnwer1	Initial creation TFS

*/

vars
	voyage : CM_Voyage;
begin
	
	voyage:=combobox.listObject.CM_Voyage;
	if voyage = self.myCurrentVoyage then
		return;
	endif;
	self.setMyCurrentVoyage(voyage);
	self.initCraneWorkProgram;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
