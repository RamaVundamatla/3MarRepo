    <JadeMethod name="mnuBayMove1_click" id="f4a34450-1d0c-43f1-be09-47b0709fd88e">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuBayMove1_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

	gridObject : CM_GridObject;
	irrBlockCont : CM_IrregularBlockController;
	cm_ObjectArray	: CM_ObjectArray;
	tiArray	: CM_TIArray;
	obj : Object;
	ti : CM_TrackedItem;

begin

	obj := menuItem.userObject;
	
	if obj.isKindOf(CM_GridObject) then
		gridObject := obj.CM_GridObject;
	elseif obj.isKindOf(CM_IrregularBlockController) then
		irrBlockCont := obj.CM_IrregularBlockController;
	endif;
	
	if gridObject = null and irrBlockCont = null then
		return;
	endif;
	
	create cm_ObjectArray transient;
	self.findCargoFromObject( obj, cm_ObjectArray );	
	if cm_ObjectArray.isEmpty then
		return;
	endif;
	
	create tiArray transient;
	cm_ObjectArray.copy( tiArray );
	
