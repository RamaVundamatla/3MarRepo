<Class name="SIM_Gate" id="69c2b0bc-c02f-42ea-8fed-529a18f58d36">
    <superclass name="SIM_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <ImplicitInverseRef name="allTerminalAreas" id="5a191466-45b0-4f74-b7b4-83969ab2e2a9">
        <memberTypeInverse/>
        <type name="CM_TerminalAreaArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="maxArrivalTime" id="0ca0f68b-bc25-41d1-9449-e0427af4daeb">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="minArrivalTime" id="a00dca48-e72c-46ff-8c54-26b91e95abaa">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myGate" id="0faf1eac-1489-4a0a-8138-f96f181914f5">
        <embedded/>
        <type name="CM_Gate"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="add" id="b94f0fd7-3096-46f9-8b70-8334c3f7be14">
        <updating/>
        <source>add(_simTerminal: SIM_Terminal; _gateName: String; _min, _max: Integer) updating;

vars
	gateAreas: StringArray;
	prefix: String;
	ic: CM_YardInterchangeArea;
begin
	self.mySIMTerminal := _simTerminal;
	prefix := self.getPrefix;
	
	self.logMessage(LOG_BRIEF, "Add Gate " &amp; _gateName);
	
	self.maxArrivalTime := _max;
	self.minArrivalTime := _min;
	
	ic := self.dsl.addInterchangeArea(prefix&amp;_gateName&amp;"IC", null);
	create gateAreas transient;
	gateAreas.add(prefix&amp;_gateName&amp;"A;X;"&amp;CM_GateArea.AreaType_A.String&amp;";True;False;");
	
	self.myGate := self.dsl.addGate(self.mySIMTerminal.prefix&amp;_gateName, false, true, true, false, ic, gateAreas);
	
	self.dsl.addQueue(prefix&amp;_gateName&amp;"Q", ic, null, false);
epilog
	delete gateAreas;
end;</source>
        <Parameter name="_simTerminal" type="SIM_Terminal"/>
        <Parameter name="_gateName" type="String"/>
        <Parameter name="_min" type="Integer"/>
        <Parameter name="_max" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="useTerminalArea" id="b302fe67-df18-4953-80e5-eeabf9d1f7a7">
        <source>useTerminalArea(_terminalAreaName: String);
vars
	tas: StringArray;
	taName: String;
	ta: CM_TerminalArea;
	ya: CM_YardAllocation;
begin
	tas := _terminalAreaName.getTokens();
	foreach taName in tas do
		ta := self.dsl.getTerminalArea(self.getPrefix&amp;taName);
		self.allTerminalAreas.add(ta);
		ya := self.dsl.addYAToBlockStack(myGate.name&amp;"YA", YACriteriaType_SrcTermArea, self.myGate.getFirstAGate_IN(), ta.CM_BlockStack);
		self.dsl.updateYAPriority(ya, 99999);
	endforeach;
epilog
	delete tas;
end;</source>
        <Parameter name="_terminalAreaName" type="String"/>
    </JadeMethod>
</Class>
