    <JadeMethod name="exportCargoCSV" id="06449de9-537f-4ff3-882f-8b884ea5a785">
        <updating/>
        <source>exportCargoCSV(_file : File input; _line : String) updating;
// ---------------------------------------------------------------------------
// Created:		October 2009 By Andrew Bishop cnwab1
//
// Purpose:		
//	33095 put quotes around each field via csvEncode
// 24/05/2023	navkc1	CR 57927 Task 57923: Jade - Transaction Map Export Import
// ---------------------------------------------------------------------------

vars
	tranMap : CM_TranMap;
	tmctig : CMIF_TranMapController;
	tmpString : String;
begin
	tmpString := _line;

	if tmpString &lt;&gt; null then
		// 23659 write an extra empty column for missing Move, but not for resource maps as the Move column has already been written with resource details
		if self.myGroup.isTranMapCargo() and
		   not self.myGroup.isKindOf(CMIF_TMCTaskResourceTypeGroup) then
			if self.myGroup.myGroup.isKindOf(CMIF_TMCMoveGroup) then
				tmpString := tmpString &amp; "," &amp; self.extractName.csvEncode();
			else
				tmpString := tmpString &amp; ",," &amp; self.extractName.csvEncode();
			endif;
		elseif self.myGroup.isKindOf(CMIF_TMCEventGroup) or self.myGroup.isKindOf(CMIF_TMCWorkOrderGroup) then // 24/05/2023	navkc1	CR 57927 Task 57923
			tmpString := tmpString &amp; ",," &amp; self.extractName.csvEncode();
		else
			tmpString := tmpString &amp; "," &amp; self.extractName.csvEncode();
		endif;

	else
		tmpString := self.myGroup.extractName.csvEncode() &amp; "," &amp; self.extractName.csvEncode();
	endif;
	foreach tmctig in self.allGroupMembers do
		tmctig.exportCargoCSV(_file, tmpString);
	endforeach;


	
end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_line" type="String"/>
    </JadeMethod>
    <JadeMethod name="getItemCode" id="2124858a-b116-4cdc-8f8a-eee739312f12">
        <source>getItemCode() : String;
// 23659 Apr 2010 invoice transaction map extract to use codes instead of descriptions
//  in this case, the name is a key.
vars
	code	: String;
begin
	code := self.myDebtor.name;
	// 24051 extract debtor type as well
	if self.myDebtorMap.myDebtorType &lt;&gt; null then
		code := code &amp; ":" &amp; self.myDebtorMap.myDebtorType.code;
	endif;
	return code;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getItemLevel" id="fc189272-447d-4307-87d6-8ba5912fe6ce">
        <source>getItemLevel(): Integer;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return CMIF_TranMapController.TM_Level_11_Debtor;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getItemName" id="e886aecf-a4a6-49a8-ba57-2f68ceb9dfe6">
        <source>getItemName() : String;
/*

Purpose:			
		24051 debtor type, show if set
Parameters:			

Return Value:		

Date	Who	Reason
29 Jan 2020	February 2005 By Andrew Bishop cnwab1
14 Feb 2020 cnwma1 Bug 48541: ADP - FW: transaction map error
*/
vars
	name	: String;
begin
	name := self.myDebtor.name;
	if self.myDebtorMap.myDebtorType &lt;&gt; null then
		name := name &amp; " (by " &amp; self.myDebtorMap.myDebtorType.description &amp; ")";
	endif;
	
	return name;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPicture" id="a331e61f-45da-43f7-8acf-b86814c57285">
        <source>getPicture(form: INV_TransactionMap): Picture;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.hidePictures then
		return null;
	endif;
	return form.picDebtor;

end;</source>
        <Parameter name="form" type="INV_TransactionMap"/>
        <ReturnType type="Picture"/>
    </JadeMethod>
