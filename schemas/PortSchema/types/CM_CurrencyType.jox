    <JadeMethod name="validateUpdate" id="e3b3ea1b-6124-4d45-9906-84bd224eb878">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2018	jlgndl1	Initial creation	TFS 37550
13/06/2022 navds20 TFS 53760 DuplicateItem not Translatable
*/

vars

	tmpCurrencyType : CM_CurrencyType;
	realCurrencyType : CM_CurrencyType;

begin

	if self.code = null then
		app.raiseCMException(Input_required_field_code, null, null);
	else
		
		tmpCurrencyType := app.myRoot.allCurrencyTypes[self.code];
		if self.isTransient() then
			realCurrencyType := self.pxyGetRealObject();
		else
			realCurrencyType := self;
		endif;
		if tmpCurrencyType &lt;&gt; null
		and realCurrencyType &lt;&gt; tmpCurrencyType then
			//app.raiseCMException2(DuplicateItem, 'Currency Type', self.code, null, null); //13.06.2022 navds20 53760
			// Currency Type already exists for %1 : Currenc_type_already_exists
			app.raiseCMException1(Currenc_type_already_exists, self.code, null, null); //13.06.2022 navds20 53760
		endif;		
	endif;
	

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
