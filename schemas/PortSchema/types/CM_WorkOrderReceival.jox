    <JadeMethod name="getDisplayStringForAttribute" id="5c60db9a-eb41-4718-b32a-9fb1e7e141fa">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
//20/09/2019 	JLGNS1	Bug 46339 JMT - Event transaction does not resync
vars
	workOrder : CM_WorkOrderTI;
	invalid : Boolean;
	returnStr : String;
	book : CM_BookingRef;
begin
	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			on Exception do app.handleDeletedObject(exception, workOrder, invalid); 
			on Exception do app.handleDeletedObject(exception, book, invalid);
			workOrder := self.myWorkOrder;
			if workOrder &lt;&gt; null then
				 book := workOrder.getBooking(); // TFS 38524
				 if book &lt;&gt; null then
					returnStr := "Assigned to " &amp; workOrder.id &amp; " : Booking " &amp; book.bookingReference;
				else
					returnStr := "Assigned to " &amp; workOrder.id &amp; " : " &amp; workOrder.getDisplayString(); // TFS 38524
				endif;
			endif;
			return returnStr;			
		endif;
	endif;
	
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
