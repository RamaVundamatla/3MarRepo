//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(_proxyObj);
	
	// Set any non-key properties, and non-inverse references.
	
	// Set any key property values.
	
	// Set any inverse references.
end;</source>
        <Parameter name="_proxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="588bb1ca-c9de-4307-b41a-7df13376a52d">
        <updating/>
        <source>setForUpdate(_proxyObj:SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Standard method that is invoked from a transaction when the receiver
//				is created.
//
// Parameters:	_proxyObj - A reference to a proxy of the receiver.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(_proxyObj);
	
	// Set any non-key properties, and non-inverse references.
	
	self.destinationTranslation	:=	_proxyObj.destinationTranslation;
	
	// Set any key property values.
	
	// Set any inverse references.
	
	self.myTerminalAreaMaster	:=	_proxyObj.myTerminalAreaMaster;
end;</source>
        <Parameter name="_proxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="5f3a3f25-0617-473a-b9c9-8006ccffd175">
        <updating/>
        <source>setProxy(	_translationString:String;
			_destinationTranslation:String;
			_interfaceDefinitionObj:CM_InterfaceDefinition;
			_terminalAreaMasterObj:CM_TerminalAreaMaster) updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2008 by cnwdad1
//
// Purpose:		Standard method for setting a proxy object's properties.
//
// Parameters:	A list of the proxy's property values.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.translationString		:=	_translationString;
	self.destinationTranslation	:=	_destinationTranslation;
	self.myTerminalAreaMaster	:=	_terminalAreaMasterObj;
	self.myInterfaceDefinition	:=	_interfaceDefinitionObj;
end;</source>
        <Parameter name="_translationString" type="String"/>
        <Parameter name="_destinationTranslation" type="String"/>
        <Parameter name="_interfaceDefinitionObj" type="CM_InterfaceDefinition"/>
        <Parameter name="_terminalAreaMasterObj" type="CM_TerminalAreaMaster"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="0ad148ba-4d02-4c45-be04-6cefd0f03ad0">
        <source>validateMe(_readTransObj: SelfType; _passportObj: CM_Passport input) protected;
// --------------------------------------------------------------------------------
// Created:		08 September 2008 by cnwdad1:2
//
// Purpose:		Standard validation method to validate the receiver's property values,
//				and raises an exception if any of the data is not valid.
//
// Parameters:	_realDefinitionObj - A reference to the real (i.e. not a proxy) object.
//				_passportObj - A reference to the current user's Passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(_readTransObj, _passportObj);
	
	if self.destinationTranslation = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Destination", null, null);
		app.raiseCMException(Input_required_field_dest, null, null); // cnwdb2	PAR 35364

	endif;
	
	if self.myTerminalAreaMaster = null then
//		app.raiseCMException1(REQUIRED_FIELD, "Terminal Area", null, null);
		app.raiseCMException(Input_required_field_termArea, null, null); // cnwdb2	PAR 35364
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_readTransObj" type="SelfType"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
