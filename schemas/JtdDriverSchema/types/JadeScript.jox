    <JadeMethod name="jhpRunVoyagePlanner" id="35e51fc8-ad37-455a-9dd4-e84b5225675d">
        <source>jhpRunVoyagePlanner();

vars
	i,j:Integer; s,t,existingVoyageCode:String;
	tran:Ship;
begin
//	process.profiler.start;
	app.initialize;
	app.sequenceId:=6;
	create tran;
	app.profileName:="VoyagePlanner";
	tran.startup;
	tran.pauseTime:=100;
	tran.loopCount:=1;

	foreach i in 1 to 3 do
		app.doWindowEvents(1000);	tran.vp001_loadVoyageEnqForm;
		app.doWindowEvents(1000);	tran.vp002_createWorkingSet;
		app.doWindowEvents(1000);	tran.vp003_loadVoyageDefForm;
		app.doWindowEvents(1000);	tran.vp004_saveVoyageDef;
		app.doWindowEvents(1000);	tran.vp005_setVoyageData;
		app.doWindowEvents(1000);	tran.vp006_allocatePortainerCranes;
		app.doWindowEvents(1000);	tran.vp007_createTableViewForm;
		app.doWindowEvents(1000);	tran.vp008_createVoyageRTQueue;
		app.doWindowEvents(1000);	tran.vp009_createTableViewForm;
		app.doWindowEvents(1000);	tran.vp010_createCraneRTQueue;
		app.doWindowEvents(1000);	tran.vp015_loadEDIForm;
		app.doWindowEvents(1000);	tran.vp016_loadBaplieFile;
		app.doWindowEvents(1000);	tran.vp017_showData;
		app.doWindowEvents(1000);	tran.vp019_verifyEDIData;
		app.doWindowEvents(1000);	tran.vp020_dbLoadEDI;
		app.doWindowEvents(1000);	tran.vp021_makeBayPlanActual;
		app.doWindowEvents(1000);	tran.vp022_openShipPlanningForm;
		app.doWindowEvents(1000);	tran.vp023_viewAllHolds;
		app.doWindowEvents(1000);	tran.vp024_dischargeColorCoding;
		app.doWindowEvents(1000);	tran.vp027_viewDischargeColorCoding;
		app.doWindowEvents(1000);	tran.vp028_loadColorCodingForm;
		app.doWindowEvents(1000);	tran.vp029_fillLoadSlots;
		app.doWindowEvents(1000);	tran.vp031_allocateCranes;
		app.doWindowEvents(1000);	tran.vp038_dischargePlanning;
		app.doWindowEvents(1000);	tran.vp040_loadOOWForm;
		app.doWindowEvents(1000);	tran.vp041_queryOOW;
		app.doWindowEvents(1000);	tran.vp042_loadAllOOW;
		app.doWindowEvents(1000);	tran.vp045_loadJobOpsForm;
		app.doWindowEvents(1000);	tran.vp046_viewAll;
		
		//PAR #30631 
		
		app.doWindowEvents(1000);	tran.vp050_loadOOWCreationForm;
		app.doWindowEvents(1000);	tran.vp053_resetVoyageOOW;
		app.doWindowEvents(1000);	tran.vp054_autoAssignJobsToCranes;
		app.doWindowEvents(1000);	tran.vp055_loadCranesToOOW;
		app.doWindowEvents(1000);	tran.vp057_loadPlanning;
		
	endforeach;
epilog
//	app.doWindowEvents(10000);
	tran.stop;
	app.finalize; /* */

	delete tran;
/*	if process.profiler.isProfiling then
		process.profiler.report;
	endif; /* */
end;</source>
    </JadeMethod>
