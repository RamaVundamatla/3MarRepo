    <JadeMethod name="create" id="0ea34e7d-7871-49b7-9222-274253bff1c6">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		19 May 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setTimestampClient();
	self.setTimestampServer();
end;</source>
    </JadeMethod>
    <JadeMethod name="getGMTBiasClient" id="519fadb0-39ad-4abc-92e4-2bddb89bc73f">
        <executionLocation>client</executionLocation>
        <source>getGMTBiasClient():Integer clientExecution;
// --------------------------------------------------------------------------------
// Created:		17 May 2001 by cnwdad1
//
// Purpose:		Returns the number of hours that the client time is offset from GMT.
//
// Parameters:	None
//
// Returns:		The number of hours bias.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	gmtBias			: Integer;

begin
	self.timestampClient.cnGetGMTBias(gmtBias);
epilog
	return gmtBias;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getGMTBiasServer" id="47ad129f-45bf-43c9-a6c4-cfae1ba74b16">
        <executionLocation>server</executionLocation>
        <source>getGMTBiasServer():Integer serverExecution;
// --------------------------------------------------------------------------------
// Created:		19 May 2001 by cnwdad1
//
// Purpose:		Returns the number of hours that the server time is offset from GMT.
//
// Parameters:	None
//
// Returns:		The number of hours bias.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	gmtBias			: Integer;

begin
	self.timestampServer.cnGetGMTBias(gmtBias);
epilog
	return gmtBias;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getGMTTimestamp" id="adb70767-2778-47ea-83d3-d5b682ca009b">
        <source>getGMTTimestamp():TimeStamp;
// --------------------------------------------------------------------------------
// Created:		17 May 2001 by cnwdad1
//
// Purpose:		Returns the current timestamp for GMT.
//
// Parameters:	None
//
// Returns:		The current GMT timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	timestampGMT	: TimeStamp;
	
begin
	return timestampGMT.cnGMT();
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setTimestampClient" id="fef8adf5-205e-4301-96e6-4da55b7bb80e">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setTimestampClient() updating, protected, clientExecution;
// --------------------------------------------------------------------------------
// Created:		19 May 2001 by cnwdad1
//
// Purpose:		Set the timestamp for the client node.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	timestamp	: TimeStamp;
	
begin
	self.timestampClient	:=	timestamp;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTimestampServer" id="126631ef-6471-46ab-a47c-9bb693a51be7">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>setTimestampServer() updating, protected, serverExecution;
// --------------------------------------------------------------------------------
// Created:		19 May 2001 by cnwdad1
//
// Purpose:		Set the timestamp for the server node.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	timestamp	: TimeStamp;
	
begin
	self.timestampServer	:=	timestamp;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateMe" id="6f03fb0c-63a6-4c51-8278-8058a95224d5">
        <updating/>
        <source>updateMe(pTimestampClient:TimeStamp) updating;
// --------------------------------------------------------------------------------
// Created:		17 May 2001 by cnwdad1
//
// Purpose:		Update the receiver's timestamp value (client).
//
// Parameters:	pTimestampClient - The client node's timestamp value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.timestampClient	:=	pTimestampClient;
end;</source>
        <Parameter name="pTimestampClient" type="TimeStamp"/>
    </JadeMethod>
</Class>
