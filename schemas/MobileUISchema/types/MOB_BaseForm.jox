    <JadeMethod name="unload" id="dd8aa0ce-33b0-4aaa-beb5-47d244c9bdb3">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// Purpose:     PAR 25509 - Implement saved window settings for Mobile Devices
//
// ---------------------------------------------------------------------------
// ***************************************************************************
// This is similar to method UiCommonSchema::CM_BaseForm::unload.  
// Changes to this method may also need to be done in that method
// ***************************************************************************
vars
	realUserWindow	: CM_UserWindowForOpen;
	
begin
	self.allMeasurementControls.purge;
	
	if self.visible and 
	   app.getMyUser &lt;&gt; null and
	   self.isAllowedForSaveOnExit then
		realUserWindow := app.getUserWindow(self.name, true);	// returns a transient
		if realUserWindow &lt;&gt; null then
			realUserWindow.setProxy(app.getMyUser, self.name, self.getXMLSettingsForSave(), self.top, self.left, self.width, self.height, self.windowState);
		endif;
	endif;

	self.setdownForm();
end;
</source>
    </JadeMethod>
</GUIClass>
