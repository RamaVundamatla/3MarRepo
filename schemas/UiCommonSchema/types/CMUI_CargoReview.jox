    <JadeMethod name="mnuCustDocsTIUpdate_click" id="98aaae28-af8a-4017-bd4e-16e45888cad3">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCustDocsTIUpdate_click(menuItem: MenuItem input) updating;
/*
Purpose:			

Date		Who		Reason
21 September 2023	navab1	CR 60424 TASK 60549 
*/

vars
	form : CMUI_CustomDocsMaint;
	bank :CM_Bank;
	custDoc : CM_CustomDocument;
	ti : CM_TrackedItem;
begin	
	if self.tblCargo.accessedRow = null then
		return;
	endif;
	
	ti:= self.tblCargo.accessedRow.itemObject.CM_TrackedItem;
	if ti = null then
		return;
	endif;

	custDoc := ti.allCustomDocuments.getLastActive(); // ### TFS CR 60425 TASK 60828 13NOV2023 NAVAB1
	if custDoc = null then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	if custDoc &lt;&gt; null then
		form := app.loadForm(CMUI_CustomDocsMaint, CMUI_Assistant, false, false,false, self.myTerminal,null).CMUI_CustomDocsMaint;
		if form &lt;&gt; null then
			form.updateMode := true;
			form.setMyCustomDocument(custDoc);
			form.centreWindow();
			form.showModal;
		endif;
	endif;


epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuCustDocsUpdate_click" id="657d9741-37d1-4d4b-ae33-1ce739a17604">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCustDocsUpdate_click(menuItem: MenuItem input) updating;
/*
Purpose:			

Date		Who		Reason
21 September 2023	navab1	CR 60424 TASK 60549 
*/

vars

	form : CMUI_CustomDocsMaint;
	bank :CM_Bank;
	custDoc : CM_CustomDocument;
	ti : CM_TrackedItem;
	jdo : JadeDynamicObject;
	index : Integer;
	type : Type;
	value : Any;
	tiArray : CM_TIArray;
begin	
	if self.tblCargoGrouped.accessedRow = null then
		return;
	endif;

	jdo:= self.tblCargoGrouped.accessRow(self.tblCargoGrouped.row).itemObject.JadeDynamicObject;
	if jdo = null then
		return;
	endif;
	
	if jdo.getPropertyInfoByName(CMIF_CargoReviewQuery.CargoReviewAllTrackedItems,index,type,value) then
		
		create tiArray transient;
		value.CM_TIByCargoTypeIdDict.copy(tiArray);
	
		ti:= tiArray.first;
		if ti = null then
			return;
		endif;

		if ti.myCargoGroup &lt;&gt; null then// ### TFS CR 60699 TASK 60700 27SEP2023 NAVAB1
			custDoc := ti.myCargoGroup.allCustomDocuments.getLastActive(); // ### TFS CR 60425 TASK 60828 13NOV2023 NAVAB1
		else
			custDoc := ti.allCustomDocuments.getLastActive(); // ### TFS CR 60425 TASK 60828 13NOV2023 NAVAB1
		endif;
		if custDoc = null then
			app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
			return;
		endif;
		if custDoc &lt;&gt; null then
			form := app.loadForm(CMUI_CustomDocsMaint, CMUI_Assistant, false, false,false, self.myTerminal,null).CMUI_CustomDocsMaint;
			if form &lt;&gt; null then
				form.updateMode := true;
				form.setMyCustomDocument(custDoc);
				form.centreWindow();
				form.showModal;
			endif;
		endif;
	endif;

epilog
	delete tiArray;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
