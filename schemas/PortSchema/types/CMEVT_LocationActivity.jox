    <JadeMethod name="pxyCreateUpdateProxy" id="66a10793-06c4-4e78-96c4-fd645e3c9e07">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	proxy : SelfType;
	completedOK		: Boolean;

begin

	proxy := inheritMethod();

	if proxy &lt;&gt; null then
		proxy.myCargoType := myCargoType;
		proxy.myOperator := myOperator;
		proxy.mySourceLocation := mySourceLocation;
		proxy.mySourceTA := mySourceTA;
		proxy.mySourceTrain := mySourceTrain;
		proxy.mySourceVVR := mySourceVVR;
		proxy.mySourceVoyage := mySourceVoyage;
		proxy.myTargetLocation := myTargetLocation;
		proxy.myTargetTA := myTargetTA;
		proxy.myTargetTrain := myTargetTrain;
		proxy.myTargetVVR := myTargetVVR;
		proxy.myTargetVoyage := myTargetVoyage;
		proxy.myTrackedItem := myTrackedItem;
	endif;
	
	completedOK := true;
	return proxy;

epilog

	if not completedOK then
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="qrySelector" id="1357367a-a1e5-4f9b-a977-c7894139d26c">
        <source>qrySelector(_criteriaLineHolder: CM_QueryCriteriaLineHolder): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2021	navndl1	Initial creation	TFS 50906

*/

vars
	returnValue 			: Boolean;
	criteriaLine 			: CM_SelectorCriteriaLine;
	tmp : String;
	
begin

	if _criteriaLineHolder.allCriteriaByPropertyName.isEmpty then
		return true;
	endif;
	
	foreach criteriaLine in _criteriaLineHolder.allCriteriaByPropertyName do

	//	if criteriaLine.propName = CMEVT_LocationActivity::getVoyageCodes.name
	//	or criteriaLine.propName = CMEVT_LocationActivity::getTrainCodes.name
	//	or criteriaLine.propName = CMEVT_LocationActivity::getVvrVisitNumbers.name
	//	or criteriaLine.propName = CMEVT_LocationActivity::getTerminalAreaIds.name
	//	or criteriaLine.propName = CMEVT_LocationActivity::getYardLocationIds.name
	//	then
			//These are special ones only used to get the starting Collections to consider
			//for the query. Not used in the criteria itself, because their data comes from multiple places....
	//		returnValue := true;
	//	else
			returnValue := self.qrySelectorCriteria(criteriaLine);
	//	endif;
		if (not returnValue) then
			break;
		endif;
	endforeach;
	
	return returnValue;
end;</source>
        <Parameter name="_criteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="qrySelectorCriteria" id="8200b0c2-2ba5-4c0f-9d67-3b7bd97eaa03">
        <source>qrySelectorCriteria(_criteria: CM_SelectorCriteriaLine): Boolean;
/*
Purpose: a CMEVT_LocationActivity has a source and a target terminal area and location
			the selector returns a string array that has the source or the target or both in it.
			a move in the yard has both a source and a target, this method handles 2 terminals areas/ locations being compared to a string array.

Date		Who		Reason
19 July 2021	navab1	TFS 51515
*/

vars
	propValue : String; 
	retval : Boolean;
	oper : CM_QueryOperator;
	allvalues : StringArray;
	searchVal : String;
begin

	if _criteria.myQueryProperty.class = CM_QStrTerminalAreasMethod then
		create allvalues transient;
		oper := _criteria.myQueryOperator;
		propValue := _criteria.myQueryProperty.getValueForObject(self, oper).String;
		
		propValue.csvToStringArray(allvalues,",");
		foreach searchVal in allvalues do
			retval := _criteria.myQueryOperator.doMatch(searchVal);
			if retval then
				return true;
			endif;
		endforeach;
	elseif _criteria.myQueryProperty.class = CM_QStrYardLocationsMethod then
		create allvalues transient;
		oper := _criteria.myQueryOperator;
		propValue := _criteria.myQueryProperty.getValueForObject(self, oper).String;
		
		propValue.csvToStringArray(allvalues,",");
		foreach searchVal in allvalues do
			retval := _criteria.myQueryOperator.doMatch(searchVal);
			if retval then
				return true;
			endif;
		endforeach;
	else
		return inheritMethod(_criteria);
	endif;

epilog
	delete allvalues;
end;</source>
        <Parameter name="_criteria" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="recalculateBalance" id="49d23421-ff5a-4006-a29f-5f9a5a1332e5">
        <updating/>
        <source>recalculateBalance()updating;
/*

Purpose:			

Parameters:			Rebuilds a Balance Transaction that has been marked as 'needsRecalculation' to correct the totals.
					

Return Value:		

Date		Who		Reason
20 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	totQuantity : Integer;
	totWeight : Decimal[14,4];
	totVolume : Decimal[14,4];
	
	iter : Iterator;
	startAtObject : CMEVT_LocationActivity;
	la : CMEVT_LocationActivity;
	summedLas : CMEVT_LocationActivityByDate;

begin

	if self.myPrevBalance &lt;&gt; null then
		//starting balance
		totQuantity := self.myPrevBalance.quantity;
		totWeight := self.myPrevBalance.weight;
		totVolume := self.myPrevBalance.volume;
	endif;
	
	foreach la in self.allRelatedLocationActivities do
		if la.isLocationBalance then
			continue;
		endif;
		la.setMyLocationBalance( null );
	endforeach;
	
	iter := self.mySourceLocation.allLocationActivity.createIterator;
	if self.myPrevBalance = null then
		startAtObject := self.mySourceLocation.allLocationActivity.getAtKeyGtr( self.dateTime.cnEcAddDays( -1 ) );
		iter.startAtObject(startAtObject);
	else
		iter.startAtObject(self.myPrevBalance);
	endif;
	
	create summedLas transient;
	
	while iter.next( la ) do
	
		if la = self then
			break;
		elseif la = self.myPrevBalance then 
			continue;
		endif;
		//must match on operator and cargo type
		if la.cargoType &lt;&gt; self.cargoType then
			continue;
		endif;
		if la.operatorCode &lt;&gt; self.operatorCode then
			continue;
		endif;
		
		//add our transactions
		if la.isLocationDiscrepancyDecrease 
		or ( la.isLocationMove and la.mySourceLocation = self.mySourceLocation ) then
			totQuantity := totQuantity - la.quantity;
			totWeight := totWeight - la.weight;
			totVolume := totVolume - la.volume;
			summedLas.add( la );
		elseif la.isLocationDiscrepancyIncrease
		or ( la.isLocationMove and la.myTargetLocation = self.mySourceLocation ) then
			totQuantity := totQuantity + la.quantity;
			totWeight := totWeight + la.weight;
			totVolume := totVolume + la.volume;
			summedLas.add( la );
		endif;
		
	endwhile;
	
	foreach la in summedLas do
		la.setMyLocationBalance( self );
		la.setNeedsRecalculating( false, null );
	endforeach;
	
	self.quantity := totQuantity;
	self.weight := totWeight;
	self.volume := totVolume;
	
	self.needsRecalculation := false;
	
	if self.myNextBalance &lt;&gt; null then
		self.myNextBalance.recalculateBalance();
	endif;

epilog

	delete summedLas;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setCargoType" id="9a471f5a-ca88-4395-815f-f6b41212b86a">
        <updating/>
        <source>setCargoType( _cargoType : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	if self.cargoType &lt;&gt; _cargoType then
		self.cargoType := _cargoType;
		if self.cargoType &lt; 1 then
			self.myCargoType := null;
		else
			self.myCargoType :=  app.myRoot.allCargoTypesById[ self.cargoType ];
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreateLABalance" id="58f70483-bf15-4ede-93a7-5c266dd3baa4">
        <updating/>
        <source>setForCreateLABalance( _pxyObject : CMEVT_LocationActivity; _summedLas : CMEVT_LocationActivityByDate; _reCalcBalanceSet : CMEVT_LocationActivityByDate input )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	la : CMEVT_LocationActivity;

begin

	if not _pxyObject.isLocationBalance then
		return;
	endif;
	
	self.type := _pxyObject.type;
	self.myEventType := _pxyObject.myTerminal.myRoot.allEventTypesByType[self.type];
	self.setCargoType( _pxyObject.cargoType );
	self.setOperatorCode( _pxyObject.operatorCode );
	
	self.quantity := _pxyObject.quantity;
	self.weight := _pxyObject.weight;
	self.volume := _pxyObject.volume;
	self.dateTime := _pxyObject.dateTime;
	self.setLocalDateTime( null, _pxyObject.dateTime, _pxyObject.myTerminal );
	
	self.setNeedsRecalculating( _pxyObject.needsRecalculation, _reCalcBalanceSet );
	
	foreach la in _summedLas do
		la.setMyLocationBalance( self );
		la.setNeedsRecalculating( false, null );
	endforeach;
	
	self.setMyPrevBalance( _pxyObject.myPrevBalance );
	self.autoSetMyNextBalance( _pxyObject.mySourceLocation, _reCalcBalanceSet );
	self.sourceLocationStr := _pxyObject.sourceLocationStr;
	
	self.mySourceLocation := _pxyObject.mySourceLocation;
	self.mySourceTA := _pxyObject.mySourceTA;
	
	self.myTerminal := _pxyObject.myTerminal;

epilog

end;</source>
        <Parameter name="_pxyObject" type="CMEVT_LocationActivity"/>
        <Parameter name="_summedLas" type="CMEVT_LocationActivityByDate"/>
        <Parameter name="_reCalcBalanceSet" type="CMEVT_LocationActivityByDate" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateResync" id="bbf31e65-7360-4cc6-806f-fe0d15a51b10">
        <updating/>
        <source>setForUpdateResync(_controller: CMIF_TiTransactionResync; _passport: CM_Passport input) updating;
/*
Purpose:			

Date		Who		Reason
02JUN2021	NAVAB1	TFS 51219
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
*/


vars
	bu : CM_Bank;
begin
	
	bu := self.getBank();
	
	if bu = null then
		app.invLog(method.qualifiedName &amp;  " No business unit, no charge", LogINFO.String);
		return;
	endif;
	
	bu.createChargeInventory(self, true);
epilog

end;</source>
        <Parameter name="_controller" type="CMIF_TiTransactionResync"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromTiTransaction" id="db08f458-2791-46ee-9efa-8955ce1901d7">
        <updating/>
        <source>setFromTiTransaction( _tiTrx : CM_TITransaction; _tiTransCntrl: CMIF_TITransactionController ):Boolean updating;
/*

Purpose:			

Parameters:			Original creation of the Location Activity is always from an newly created TI
					Transaction. (Except Balance Transactions)

Return Value:		

Date		Who		Reason
12 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	ti : CM_TrackedItem;
	terminal : CM_Terminal;
	move : CM_Move;
	discrepancy : CM_BBDiscrepancy;

begin

	if _tiTrx = null then
		app.raiseCMException( Trans_suppl_creat_locat_event_, null, null );
		return false;
	endif;

	self.myOriginalTiTrx := _tiTrx;
	terminal := _tiTrx.myTerminal;
	self.dateTime := _tiTrx.dateTime;
	self.setLocalDateTime( null, _tiTrx.dateTime, terminal );
	
	ti := _tiTrx.myTrackedItem;
	if ti &lt;&gt; null then
		if terminal = null then
			terminal := ti.myTerminal;
		endif;
		self.myTrackedItem := ti;
		self.setCargoType( ti.cargoType );
		self.productCode := ti.productCode;
	else
		app.raiseCMException( NO_Cargo_found, null, null );
		return false;
	endif;
	
	self.commodity := _tiTrx.commodity;
	self.consignee := _tiTrx.consignee;
	self.consignor := _tiTrx.consignor;
	self.setOperatorCode( _tiTrx.operatorCode );
	self.stevedoreCode := _tiTrx.stevedoreCode;
	
	if _tiTrx.isKindOf( CM_Move ) then
		move := _tiTrx.CM_Move;
		if move.mode &lt;&gt; REAL_MODE then
			app.raiseCMException1( Invalid_move_mode_passed, method.qualifiedName, null, null );
			return false;
		endif;
		self.type := EVT_LocationMove;
		self.myEventType := terminal.myRoot.allEventTypesByType[self.type];
		self.sourceLocationStr := move.sourceLocn;
		self.targetLocationStr := move.targetLocn;
		//jlier1 MTN-34609 15/4/25
		if  _tiTransCntrl &lt;&gt; null and _tiTransCntrl.myOriginatingLocation &lt;&gt; null then
			self.setMySourceAttributes( _tiTransCntrl.myOriginatingLocation, true );
		else
			self.setMySourceAttributes( move.getSourceLocationsController(), true );
		endif;
		if  _tiTransCntrl &lt;&gt; null and _tiTransCntrl.myToPrimaryLocation &lt;&gt; null then
			self.setMyTargetAttributes(_tiTransCntrl.myToPrimaryLocation, true );
		else
			self.setMyTargetAttributes( move.getTargetLocationsController(), true );
		endif;
		
		if ti.myCargoType.isTrackByVolume then
			if _tiTransCntrl &lt;&gt; null and _tiTransCntrl.totalVolume &lt;&gt; null then
				self.volume := _tiTransCntrl.totalVolume;
			else
				self.volume := move.totalVolume;
			endif;
		elseif ti.myCargoType.isTrackByWeight then
			if _tiTransCntrl &lt;&gt; null and _tiTransCntrl.totalWeight &lt;&gt; null then
				self.weight := _tiTransCntrl.totalWeight;
			else
				self.weight := move.totalWeight;
			endif;
		else
			if _tiTransCntrl &lt;&gt; null and _tiTransCntrl.totalQuantity &lt;&gt; null then
				self.quantity := _tiTransCntrl.totalQuantity;
			else
				self.quantity := move.totalQuantity;
			endif;
		endif;

			
	elseif _tiTrx.isKindOf( CM_BBDiscrepancy ) then
	
		discrepancy := _tiTrx.CM_BBDiscrepancy;
		
		if discrepancy.quantityChange &lt; 0
		or discrepancy.weightChange &lt; 0
		then
			self.type := EVT_LocationDiscrepDecrease;
			self.myEventType := terminal.myRoot.allEventTypesByType[self.type];
			self.sourceLocationStr := ti.myPrimaryActualLocation.getFullId();
			self.setMySourceAttributes( ti.myPrimaryActualLocation, true );
			self.setMyTargetAttributes( null, true );
			
			if ti.myCargoType.isTrackByVolume then
				self.volume := ( discrepancy.weightChange / ti.getDensity ) * -1;
			elseif ti.myCargoType.isTrackByWeight then
				self.weight := ( discrepancy.weightChange ) * -1;
			else
				self.quantity := ( discrepancy.quantityChange ) * -1;
			endif;
			
		else
			self.type := EVT_LocationDiscrepIncrease;
			self.myEventType := terminal.myRoot.allEventTypesByType[self.type];
			self.targetLocationStr := ti.myPrimaryActualLocation.getFullId();
			self.setMySourceAttributes( null, true );
			self.setMyTargetAttributes( ti.myPrimaryActualLocation, true );
			
			if ti.myCargoType.isTrackByVolume then
				self.volume := discrepancy.weightChange / ti.getDensity;
			elseif ti.myCargoType.isTrackByWeight then
				self.weight := discrepancy.weightChange;
			else
				self.quantity := discrepancy.quantityChange;
			endif;
			
		endif;
		
		self.remarks := discrepancy.reason;
	
	else
		app.raiseCMException1( ERR_INVALID_TRANSTYPE, _tiTrx.class.name, null, null );
		return false;
	
	endif;
	
	self.setMovementDirection();	//13 Jul 2021	NDL	TFS 51528 - after source and target are set
	
	self.myPrevBalance := null;
	self.myTerminal := terminal;
	
	return true;

epilog

end;</source>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setHasBeenEdited" id="172b4576-5abf-454e-a648-e91d49743e71">
        <updating/>
        <source>setHasBeenEdited( _value : Boolean )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	if self.hasBeenEdited &lt;&gt; _value then
		self.hasBeenEdited := _value;
	endif;
	
	if _value then
		self.setNeedsRecalculating( true, null );
		if self.myLocationBalance &lt;&gt; null then
			self.myLocationBalance.setNeedsRecalculating( true, null );
			self.myLocationBalance := null;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setLocalDateTime" id="ba56fc61-e993-4efb-a816-d4867596d231">
        <updating/>
        <source>setLocalDateTime( _localDateTime : TimeStamp; _serverDateTime : TimeStamp; _terminal : CM_Terminal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	if _localDateTime.isValid then
		self.localDateTime :=_localDateTime;
		if  _terminal &lt;&gt; null and not _serverDateTime.isValid then
			self.dateTime := _localDateTime.localToSystemTimeUsingObject( _terminal );
		endif;
	endif;
	if _serverDateTime.isValid and _terminal &lt;&gt; null then
		self.localDateTime := _serverDateTime.systemToLocalTimeUsingObject( _terminal );
	endif;

epilog

end;</source>
        <Parameter name="_localDateTime" type="TimeStamp"/>
        <Parameter name="_serverDateTime" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setMovementDirection" id="4f6e15ed-75b0-4fa3-872b-809f6b3b42d5">
        <updating/>
        <source>setMovementDirection() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2021	navndl1	Initial creation	TFS 51528

	These ones existed at the time of writing
	but were not included in the reporting spec.
	They were to be excluded until ASPA required them,
	possibly in the future and were willing to pay for them.
		
		LocnActMoveStr_BargeToBarge;
		LocnActMoveStr_BargeToRail;
		LocnActMoveStr_BargeToRoad;
		LocnActMoveStr_RailToBarge;
		LocnActMoveStr_RailToRail;
		LocnActMoveStr_RailToRoad;
		LocnActMoveStr_RoadToBarge;
		LocnActMoveStr_RoadToRail;
		LocnActMoveStr_RoadToRoad;
		LocnActMoveStr_RoadToVessel;
		LocnActMoveStr_RoadToYard;
		LocnActMoveStr_VesselToRoad;
		LocnActMoveStr_VesselToVessel;
		LocnActMoveStr_YardToRoad;
		LocnActMoveStr_YardToYard;
		

*/

vars

begin
	
	// set up the movementDirection, the directionMode and directionType;
	
	if self.isSourceBarge and self.isTargetBarge then
		self.movementDirection := LocnActMoveDir_BargeToBarge;
		self.directionMode := app.getErrorString(LocnActMoveStr_BargeToBarge);
	//	self.directionType := app.getErrorString(Unknown);	//Not used by ASPA
		
	elseif self.isSourceBarge and self.isTargetTrain then
		self.movementDirection := LocnActMoveDir_BargeToRail;
		self.directionMode := app.getErrorString(LocnActMoveStr_BargeToRail);
	//	self.directionType := app.getErrorString(Unknown);	//Not used by ASPA
		
	elseif self.isSourceBarge and self.isTargetTruck then
		self.movementDirection := LocnActMoveDir_BargeToRoad;
		self.directionMode := app.getErrorString(LocnActMoveStr_BargeToRoad);
	//	self.directionType := app.getErrorString(Unknown);	//Not used by ASPA
		
	elseif self.isSourceBarge and self.isTargetVoyage then
		self.movementDirection := LocnActMoveDir_BargeToVessel;
		self.directionMode := app.getErrorString(LocnActMoveStr_BargeToVessel);
		self.directionType := self.TypeExport;
		
	elseif self.isSourceBarge and self.isTargetYard then
		self.movementDirection := LocnActMoveDir_BargeToYard;
		self.directionMode := app.getErrorString(LocnActMoveStr_BargeToYard);
		self.directionType := self.TypeStorage;
		
	elseif self.isSourceTrain and self.isTargetBarge then
		self.movementDirection := LocnActMoveDir_RailToBarge;
		self.directionMode := app.getErrorString(LocnActMoveStr_RailToBarge);
	//	self.directionType := app.getErrorString(Unknown);	//Not used by ASPA
		
	elseif self.isSourceTrain and self.isTargetTrain then
		self.movementDirection := LocnActMoveDir_RailToRail;
		self.directionMode := app.getErrorString(LocnActMoveStr_RailToRail);
	//	self.directionType := app.getErrorString(Unknown);	//Not used by ASPA
		
	elseif self.isSourceTrain and self.isTargetTruck then
		self.movementDirection := LocnActMoveDir_RailToRoad;
		self.directionMode := app.getErrorString(LocnActMoveStr_RailToRoad);
	//	self.directionType := app.getErrorString(Unknown);	//Not used by ASPA
		
	elseif self.isSourceTrain and self.isTargetVoyage then
		self.movementDirection := LocnActMoveDir_RailToVessel;
		self.directionMode := app.getErrorString(LocnActMoveStr_RailToVessel);
		self.directionType := self.TypeExport;
		
	elseif self.isSourceTrain and self.isTargetYard then
		self.movementDirection := LocnActMoveDir_RailToYard;
		self.directionMode := app.getErrorString(LocnActMoveStr_RailToYard);
		self.directionType := self.TypeStorage;
		
	elseif self.isSourceTruck and self.isTargetBarge then
		self.movementDirection := LocnActMoveDir_RoadToBarge;
		self.directionMode := app.getErrorString(LocnActMoveStr_RoadToBarge);
	//	self.directionType := app.getErrorString(Unknown);	//Not used by ASPA
		
	elseif self.isSourceTruck and self.isTargetTrain then
		self.movementDirection := LocnActMoveDir_RoadToRail;
		self.directionMode := app.getErrorString(LocnActMoveStr_RoadToRail);
	//	self.directionType := app.getErrorString(Unknown);	//Not used by ASPA
		
	elseif self.isSourceTruck and self.isTargetTruck then
		self.movementDirection := LocnActMoveDir_RoadToRoad;
		self.directionMode := app.getErrorString(LocnActMoveStr_RoadToRoad);
	//	self.directionType := app.getErrorString(Unknown);	//Not used by ASPA
		
	elseif self.isSourceTruck and self.isTargetVoyage then
		self.movementDirection := LocnActMoveDir_RoadToVessel;
		self.directionMode := app.getErrorString(LocnActMoveStr_RoadToVessel);
	//	self.directionType := app.getErrorString(Unknown);	//Not used by ASPA
		
	elseif self.isSourceTruck and self.isTargetYard then
		self.movementDirection := LocnActMoveDir_RoadToYard;
		self.directionMode := app.getErrorString(LocnActMoveStr_RoadToYard);
	//	self.directionType := app.getErrorString(Unknown);	//Not used by ASPA
		
	elseif self.isSourceVoyage and self.isTargetBarge then
		self.movementDirection := LocnActMoveDir_VesselToBarge;
		self.directionMode := app.getErrorString(LocnActMoveStr_VesselToBarge);
		self.directionType := self.TypeDomestic;
		
	elseif self.isSourceVoyage and self.isTargetTrain then
		self.movementDirection := LocnActMoveDir_VesselToRail;
		self.directionMode := app.getErrorString(LocnActMoveStr_VesselToRail);
		self.directionType := self.TypeDomestic;
		
	elseif self.isSourceVoyage and self.isTargetTruck then
		self.movementDirection := LocnActMoveDir_VesselToRoad;
		self.directionMode := app.getErrorString(LocnActMoveStr_VesselToRoad);
	//	self.directionType := app.getErrorString(Unknown);	//Not used by ASPA
		
	elseif self.isSourceVoyage and self.isTargetVoyage then
		self.movementDirection := LocnActMoveDir_VesselToVessel;
		self.directionMode := app.getErrorString(LocnActMoveStr_VesselToVessel);
	//	self.directionType := app.getErrorString(Unknown);	//Not used by ASPA
		
	elseif self.isSourceVoyage and self.isTargetYard then
		self.movementDirection := LocnActMoveDir_VesselToYard;
		self.directionMode := app.getErrorString(LocnActMoveStr_VesselToYard);
		self.directionType := self.TypeStorage;
		
	elseif self.isSourceYard and self.isTargetBarge then
		self.movementDirection := LocnActMoveDir_YardToBarge;
		self.directionMode := app.getErrorString(LocnActMoveStr_YardToBarge);
		self.directionType := self.TypeDomestic;
		
	elseif self.isSourceYard and self.isTargetTrain then
		self.movementDirection := LocnActMoveDir_YardToRail;
		self.directionMode := app.getErrorString(LocnActMoveStr_YardToRail);
		self.directionType := self.TypeDomestic;
		
	elseif self.isSourceYard and self.isTargetTruck then
		self.movementDirection := LocnActMoveDir_YardToRoad;
		self.directionMode := app.getErrorString(LocnActMoveStr_YardToRoad);
	//	self.directionType := app.getErrorString(Unknown);	//Not used by ASPA
		
	elseif self.isSourceYard and self.isTargetVoyage then
		self.movementDirection := LocnActMoveDir_YardToVessel;
		self.directionMode := app.getErrorString(LocnActMoveStr_YardToVessel);
		self.directionType := self.TypeExport;
		
	elseif self.isSourceYard and self.isTargetYard then
		self.movementDirection := LocnActMoveDir_YardToYard;
		self.directionMode := app.getErrorString(LocnActMoveStr_YardToYard);
	//	self.directionType := app.getErrorString(Unknown);	//Not used by ASPA

	endif;
	
	
	
	
	
	
	
	
		
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyBalanceForNeedsRecalc" id="7b6bb7f0-06fb-4541-b754-9274985c272d">
        <updating/>
        <source>setMyBalanceForNeedsRecalc() updating;
/*

Purpose: used on newly created move and discrepancy events	to set 'needs re calc' on their balance and future balances
				for the terminal area, cargo type operator and date.
				Setting my balance auto sets all linked future balances.
				only search for balances that do not need a recalc

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2021	navab1	Initial creation TFS 51515

*/

vars
	balanceActivity : CMEVT_LocationActivity;

	balanceTS : TimeStamp;
	balanceTime : Time;
begin
	if self.isLocationBalance then
		return;
	endif;
	
	self.setNeedsRecalculating(true,null); // ### TFS 51515 NAVAB1

	// When location activities for moves are created they are not linked to a balance, that is done by the BGP
	// Need to set the balance to needs recalc
	balanceTS := self.dateTime;
	// balances have the same time
	balanceTime.setTimeStrict(23,59,59,999);
	balanceTS.setTime(balanceTime);
	
	if self.mySourceTA &lt;&gt; null then
		balanceActivity := self.mySourceTA.allLocationActivityReCalc[EVT_LocationBalance, self.getCargoType(), self.getOperator(), false, balanceTS];
		if balanceActivity &lt;&gt; null then
			balanceActivity.setNeedsRecalculating( true, null );
		endif;
	endif;
	
	if self.myTargetTA&lt;&gt; null then
		balanceActivity := self.myTargetTA.allLocationActivityReCalc[EVT_LocationBalance, self.getCargoType(), self.getOperator(), false, balanceTS];
		if balanceActivity &lt;&gt; null then
			balanceActivity.setNeedsRecalculating( true, null );
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyLocationBalance" id="4580b173-c373-48eb-bc7e-2c9eb66896ca">
        <updating/>
        <source>setMyLocationBalance( _la : CMEVT_LocationActivity )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	if _la &lt;&gt; null and not _la.isLocationBalance then
		return;
	elseif self.isLocationBalance then
		return;
	endif;
	
	self.myLocationBalance := _la;  // I.e. The Location Activity Balance that this Location Activity is summed up within.

epilog

end;</source>
        <Parameter name="_la" type="CMEVT_LocationActivity"/>
    </JadeMethod>
    <JadeMethod name="setMyPrevBalance" id="8934d272-8dff-4ebd-9b63-4c10fc7b1be5">
        <updating/>
        <source>setMyPrevBalance( _la : CMEVT_LocationActivity )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	if _la &lt;&gt; null then
		if not _la.isLocationBalance then
			return;
		elseif not self.isLocationBalance then
			return;
		endif;
	endif;
	
	self.myPrevBalance := _la;  // I.e. The Location Activity Balance that this Location Activity Balance started from.

epilog

end;</source>
        <Parameter name="_la" type="CMEVT_LocationActivity"/>
    </JadeMethod>
    <JadeMethod name="setMySourceAttributes" id="1cd930df-6127-46be-b707-0567ee7ce64d">
        <updating/>
        <source>setMySourceAttributes( _mySourceLC : CM_LocationsController; _create : Boolean )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	wagon : CM_Wagon;
	truck : CM_Vehicle;
	trailer : CM_TILC;
	vvr : CM_VehicleVisitRecord;

begin

	
	if self.mySourceLocation &lt;&gt; _mySourceLC then
		self.mySourceLocation := _mySourceLC;
		if _mySourceLC = null then
			self.sourceLocationStr := null;
		else
			self.sourceLocationStr := self.mySourceLocation.getFullId;
		endif;
		if not _create then
			self.setHasBeenEdited( true );
		endif;
	endif;

	if self.mySourceLocation &lt;&gt; null then
	
		//17 Sep 2021	NDL	TFS 51991
		self.mySourceTrain := null;
		self.mySourceVoyage := null;
		self.mySourceVVR := null;
		self.mySourceTA := null;
		
		if self.mySourceLocation.isWagon then
			//from rail
			wagon := self.mySourceLocation.CM_WagonController.myWagon;
			if wagon &lt;&gt; null then
				if _create then
					self.mySourceTrain := wagon.myTrainInwards;
				elseif self.mySourceTrain &lt;&gt; wagon.myTrainInwards then
					self.mySourceTrain := wagon.myTrainInwards;
					self.setHasBeenEdited( true );
				endif;
			endif;
			
		elseif self.mySourceLocation.isVoyageController then
			//from voyage
			if _create then
				self.mySourceVoyage := self.mySourceLocation.CM_VoyageController.myVoyage;
			elseif self.mySourceVoyage &lt;&gt; self.mySourceLocation.CM_VoyageController.myVoyage then
				self.mySourceVoyage := self.mySourceLocation.CM_VoyageController.myVoyage;
				self.setHasBeenEdited( true );
			endif;
			
		elseif self.mySourceLocation.isVehicle or self.mySourceLocation.isTILCController then
			//from road
			if self.mySourceLocation.isVehicle then
				truck := self.mySourceLocation.CM_VehicleController.vehicle;
			elseif self.mySourceLocation.isTILCController then
				trailer := self.mySourceLocation.CM_TILCController.myTILC;
				if trailer &lt;&gt; null and trailer.myPrimaryActualLocation &lt;&gt; null and trailer.myPrimaryActualLocation.isVehicle then
					truck := trailer.myPrimaryActualLocation.CM_VehicleController.vehicle;
				else
					vvr := trailer.getVehicleVisitReceival;
				endif;
			endif;
			if truck &lt;&gt; null then
				vvr := truck.getCurrentVisit();
			endif;
			if vvr &lt;&gt; null then
				if _create then
					self.carrierCode := vvr.carrierCode; 
					self.mySourceVVR := vvr;
				elseif self.mySourceVVR &lt;&gt; vvr or self.carrierCode &lt;&gt; vvr.carrierCode then
					self.mySourceVVR := vvr;
					self.carrierCode := vvr.carrierCode; 
					self.setHasBeenEdited( true );
				endif;
			elseif vvr = null then
				if not _create and ( self.mySourceVVR &lt;&gt; null or self.carrierCode &lt;&gt; null )then
					self.mySourceVVR := null;
					self.carrierCode := null; 
					self.setHasBeenEdited( true );
				endif;
			endif;

		elseif self.mySourceLocation.isActivityTrackingLocation then
			//from yard
			if _create then
				self.mySourceTA := self.mySourceLocation.getMyTerminalArea();
			elseif self.mySourceTA &lt;&gt; self.mySourceLocation.getMyTerminalArea() then
				self.mySourceTA := self.mySourceLocation.getMyTerminalArea();
			endif;
		endif;
		
	else
	
		if not _create
		and ( self.mySourceTrain &lt;&gt; null
		or self.mySourceVoyage &lt;&gt; null
		or self.mySourceVVR &lt;&gt; null
		or self.mySourceTA &lt;&gt; null )
		then
			self.setHasBeenEdited( true );
		endif;
		
		self.mySourceTrain := null;
		self.mySourceVoyage := null;
		self.mySourceVVR := null;
		self.mySourceTA := null;
	
	endif;

epilog

end;</source>
        <Parameter name="_mySourceLC" type="CM_LocationsController"/>
        <Parameter name="_create" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMySourceAttributesExt" id="6a8cf058-7722-4edc-a2a7-342dd0ffb4d9">
        <updating/>
        <source>setMySourceAttributesExt( _mySourceObject : CM_Object ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	sourceTrain : CM_Train;
	sourceVoyage : CM_Voyage;
	sourceVvr : CM_VehicleVisitRecord;

begin

//	self.mySourceLocation := null; // we no longer know which actual location it came from 
	self.setMySourceAttributes( null, false );	//17 Sep 2021	NDL	TFS 51991

	if _mySourceObject &lt;&gt; null then
		if _mySourceObject.isKindOf( CM_Train ) then
			//from rail
			sourceTrain := _mySourceObject.CM_Train;
			if self.mySourceTrain &lt;&gt; sourceTrain then
				self.mySourceTrain := sourceTrain;
				self.sourceLocationStr := sourceTrain.code;
				self.setHasBeenEdited( true );
			endif;
			
			
		elseif _mySourceObject.isKindOf( CM_Voyage ) then
			//from voyage
			sourceVoyage := _mySourceObject.CM_Voyage;
			if self.mySourceVoyage &lt;&gt; sourceVoyage then
				self.mySourceVoyage := sourceVoyage;
				self.sourceLocationStr := sourceVoyage.code;
				self.setHasBeenEdited( true );
			endif;
			
		elseif _mySourceObject.isKindOf( CM_VehicleVisitRecord ) then
			//from road
			sourceVvr := _mySourceObject.CM_VehicleVisitRecord;
			if self.mySourceVVR &lt;&gt; sourceVvr then
				//VVR changed
				self.mySourceVVR := sourceVvr;	
				self.sourceLocationStr := sourceVvr.visitNumber;
				self.carrierCode := self.mySourceVVR.carrierCode;
				self.setHasBeenEdited( true );
			else
				//VVR is the same but carrier might be different
				if self.carrierCode &lt;&gt; self.mySourceVVR.carrierCode then
					self.carrierCode := self.mySourceVVR.carrierCode;
					self.setHasBeenEdited( true );
				endif;
			endif;

		else
			app.raiseCMException2( Object_not_expecte_type, "_mySourceObject", "Train, Voyage or VVR", null, null );
		endif;
		
	else
	
		if ( self.mySourceTrain &lt;&gt; null
		or self.mySourceVoyage &lt;&gt; null
		or self.mySourceVVR &lt;&gt; null )
		then
			self.setHasBeenEdited( true );
		endif;
		
		self.mySourceTrain := null;
		self.mySourceVoyage := null;
		self.mySourceVVR := null;
		self.carrierCode := null;
		if self.mySourceTA = null then
			self.sourceLocationStr := app.getErrorString(OffSite);
		endif;
	
	endif;

epilog

end;</source>
        <Parameter name="_mySourceObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setMyTargetAttributes" id="f8ed7c6a-7d45-4acd-9d55-632353eaf9cd">
        <updating/>
        <source>setMyTargetAttributes( _myTargetLC : CM_LocationsController; _create : Boolean )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	wagon : CM_Wagon;
	truck : CM_Vehicle;
	trailer : CM_TILC;
	vvr : CM_VehicleVisitRecord;

begin

	
	if self.myTargetLocation &lt;&gt; _myTargetLC then
		self.myTargetLocation := _myTargetLC;
		if _myTargetLC = null then
			self.targetLocationStr := null;
		else
			self.targetLocationStr := self.myTargetLocation.getFullId;
		endif;
		if not _create then
			self.setHasBeenEdited( true );
		endif;
	endif;
	
	if self.myTargetLocation &lt;&gt; null then
	
		//17 Sep 2021	NDL	TFS 51991
		self.myTargetTrain := null;
		self.myTargetVoyage := null;
		self.myTargetVVR := null;
		self.myTargetTA := null;
		
		if self.myTargetLocation.isWagon then
			//to rail
			wagon := self.myTargetLocation.CM_WagonController.myWagon;
			if wagon &lt;&gt; null then
				if _create then
					self.myTargetTrain := wagon.myTrainOutwards;
				elseif self.myTargetTrain &lt;&gt; wagon.myTrainOutwards then
					self.myTargetTrain := wagon.myTrainOutwards;
					self.setHasBeenEdited( true );
				endif;
			endif;
			
		elseif self.myTargetLocation.isVoyageController then
			//to voyage
			if _create then
				self.myTargetVoyage := self.myTargetLocation.CM_VoyageController.myVoyage;
			elseif self.myTargetVoyage &lt;&gt; self.myTargetLocation.CM_VoyageController.myVoyage then
				self.myTargetVoyage := self.myTargetLocation.CM_VoyageController.myVoyage;
				self.setHasBeenEdited( true );
			endif;
			
		elseif self.myTargetLocation.isVehicle or self.myTargetLocation.isTILCController then
			//to road
			if self.myTargetLocation.isVehicle then
				truck := self.myTargetLocation.CM_VehicleController.vehicle;
			elseif self.myTargetLocation.isTILCController then
				trailer := self.myTargetLocation.CM_TILCController.myTILC;
				if trailer &lt;&gt; null and trailer.myPrimaryActualLocation &lt;&gt; null and trailer.myPrimaryActualLocation.isVehicle then
					truck := trailer.myPrimaryActualLocation.CM_VehicleController.vehicle;
				else
					vvr := trailer.getVehicleVisitRelease;
				endif;
			endif;
			if truck &lt;&gt; null then
				vvr := truck.getCurrentVisit();
			endif;
			if vvr &lt;&gt; null then
				if _create then
					self.carrierCode := vvr.carrierCode;
					self.myTargetVVR := vvr;
				elseif self.myTargetVVR &lt;&gt; vvr or self.carrierCode &lt;&gt; vvr.carrierCode then
					self.carrierCode := vvr.carrierCode;
					self.myTargetVVR := vvr;
					self.setHasBeenEdited( true );
				endif;
			elseif vvr = null then
				if not _create then
					if self.myTargetVVR &lt;&gt; null then
						self.myTargetVVR := null;
						self.setHasBeenEdited( true );
					endif;
					if self.carrierCode &lt;&gt; null and ( self.mySourceVVR = null or self.mySourceVVR.carrierCode &lt;&gt; self.carrierCode ) then
						self.carrierCode := null;
						self.setHasBeenEdited( true );
					endif;
				endif;
			endif;
			
		elseif self.myTargetLocation.isActivityTrackingLocation then
			//to yard
			if _create then
				self.myTargetTA := self.myTargetLocation.getMyTerminalArea();
			elseif self.myTargetTA &lt;&gt; self.myTargetLocation.getMyTerminalArea() then
				self.myTargetTA := self.myTargetLocation.getMyTerminalArea();
				self.setHasBeenEdited( true );
			endif;
			
		endif;
		
	else
	
		if not _create
		and (self.myTargetTrain &lt;&gt; null
		or self.myTargetVoyage &lt;&gt; null
		or self.myTargetVVR &lt;&gt; null
		or self.myTargetTA &lt;&gt; null )
		then
			self.setHasBeenEdited( true );
		endif;
		
		self.myTargetTrain := null;
		self.myTargetVoyage := null;
		self.myTargetVVR := null;
		self.myTargetTA := null;
		
	endif;

epilog

end;</source>
        <Parameter name="_myTargetLC" type="CM_LocationsController"/>
        <Parameter name="_create" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyTargetAttributesExt" id="ce09ccc0-5809-4029-9f58-c0fe4ea40c41">
        <updating/>
        <source>setMyTargetAttributesExt( _myTargetObject : CM_Object ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	targetTrain : CM_Train;
	targetVoyage : CM_Voyage;
	targetVvr : CM_VehicleVisitRecord;

begin

//	self.myTargetLocation := null; // we no longer know which actual location it is going too 
	self.setMyTargetAttributes( null, false );	//17 Sep 2021	NDL	TFS 51991

	if _myTargetObject &lt;&gt; null then
		if _myTargetObject.isKindOf( CM_Train ) then
			//from rail
			targetTrain := _myTargetObject.CM_Train;
			if self.myTargetTrain &lt;&gt; targetTrain then
				self.myTargetTrain := targetTrain;
				self.targetLocationStr := targetTrain.code;
				self.setHasBeenEdited( true );
			endif;
			
			
		elseif _myTargetObject.isKindOf( CM_Voyage ) then
			//from voyage
			targetVoyage := _myTargetObject.CM_Voyage;
			if self.myTargetVoyage &lt;&gt; targetVoyage then
				self.myTargetVoyage := targetVoyage;
				self.targetLocationStr := targetVoyage.code;
				self.setHasBeenEdited( true );
			endif;
			
		elseif _myTargetObject.isKindOf( CM_VehicleVisitRecord ) then
			//from road
			targetVvr := _myTargetObject.CM_VehicleVisitRecord;
			if self.myTargetVVR &lt;&gt; targetVvr then
				//VVR changed
				self.myTargetVVR := targetVvr;	
				self.targetLocationStr := targetVvr.visitNumber;
				self.carrierCode := self.myTargetVVR.carrierCode;
				self.setHasBeenEdited( true );
			else
				//VVR is the same but carrier might be different
				if self.carrierCode &lt;&gt; self.myTargetVVR.carrierCode then
					self.carrierCode := self.myTargetVVR.carrierCode;
					self.setHasBeenEdited( true );
				endif;
			endif;

		else
			app.raiseCMException2( Object_not_expecte_type, "_myTargetObject", "Train, Voyage or VVR", null, null );
		endif;
		
	else
	
		if ( self.myTargetTrain &lt;&gt; null
		or self.myTargetVoyage &lt;&gt; null
		or self.myTargetVVR &lt;&gt; null )
		then
			self.setHasBeenEdited( true );
		endif;
		
		self.myTargetTrain := null;
		self.myTargetVoyage := null;
		self.myTargetVVR := null;
		if self.mySourceVVR = null or self.mySourceVVR.carrierCode = null then
			self.carrierCode := null;
		endif;
		if self.myTargetTA = null then
			self.targetLocationStr := app.getErrorString(OffSite);
		endif;
	
	endif;

epilog

end;</source>
        <Parameter name="_myTargetObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setNeedsRecalculating" id="d686e5ed-d534-4c80-81dd-de6f55f0bada">
        <updating/>
        <source>setNeedsRecalculating( _value : Boolean; _reCalcBalanceSet : CMEVT_LocationActivityByDate input )updating;
/*

Purpose:			

Parameters:					A flag that indicates that the values related to this guy have been changed, and some 	
							processing is required to re-align/update the related data in the database.

Return Value:		

Date		Who		Reason
16 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	self.needsRecalculation := _value;
	
	if self.isLocationBalance and _value = true and not self.isTransient then
		//If my balance needs recalculating then anyone who relied on me
		//for a starting balance will need recalculating too.
		if _reCalcBalanceSet &lt;&gt; null then
			_reCalcBalanceSet.addNoDuplicates( self, false );
		endif;
		if self.myNextBalance &lt;&gt; null then
			self.myNextBalance.setNeedsRecalculating( true, _reCalcBalanceSet );
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
        <Parameter name="_reCalcBalanceSet" type="CMEVT_LocationActivityByDate" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setNeedsRecalculation" id="b66548f0-3f3b-488d-9b46-4740e9fead41">
        <updating/>
        <source>setNeedsRecalculation(_needs : Boolean) updating;
/*
Purpose:			

Date		Who		Reason
19 July 2021	navab1	TFS 51515
*/

vars

begin
	self.needsRecalculation := _needs;
epilog

end;</source>
        <Parameter name="_needs" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setNewBalanceProxy" id="db175073-335b-4c86-8d02-366f67fcb0b0">
        <updating/>
        <source>setNewBalanceProxy(	_totQuantity : Integer;
						_totWeight : Decimal;
						_totVolume : Decimal;
						_dateTime : TimeStamp;
						_cargoType : CM_CargoType;
						_operator : CM_Operator;
						_lc : CM_LocationsController
						)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin
	
	self.type := EVT_LocationBalance;	
	self.setCargoType( _cargoType.id );
	self.setOperatorCode( _operator.code );
	
	if _cargoType.isTrackByVolume then
		self.volume := _totVolume;
	elseif _cargoType.isTrackByWeight then
		self.weight := _totWeight;
	else
		self.quantity := _totQuantity;
	endif;
	
	self.dateTime := _dateTime;
	self.setLocalDateTime( null, _dateTime, _lc.myTerminal );
	
	self.sourceLocationStr := _lc.getFullId;
	
	self.myPrevBalance := null;
	self.myLocationBalance := null;
	
	self.mySourceLocation := _lc;
	self.mySourceTA := _lc.myTerminalArea;
	
	self.myTerminal := _lc.myTerminal;
	
epilog

end;</source>
        <Parameter name="_totQuantity" type="Integer"/>
        <Parameter name="_totWeight" type="Decimal"/>
        <Parameter name="_totVolume" type="Decimal"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setOperatorCode" id="a983a9bf-1ee7-4da9-803a-49b815353c5e">
        <updating/>
        <source>setOperatorCode( _operatorCode : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	if self.operatorCode &lt;&gt; _operatorCode then
		self.operatorCode := _operatorCode;
		if self.operatorCode = null then
			self.myOperator := null;
		else
			self.myOperator :=  app.myRoot.allOperators[ self.operatorCode ];
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_operatorCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setPxyAmount" id="8baecf0f-cc95-4cd7-af5e-3d6a25b892bb">
        <updating/>
        <source>setPxyAmount(	_isVolume : Boolean;
				_isWeight : Boolean;
				_isQuantity : Boolean;
				_enteredAmount : Decimal
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	if _isVolume then
		self.volume := _enteredAmount;
	elseif _isWeight then
		self.weight := _enteredAmount;
	elseif _isQuantity then
		self.quantity := _enteredAmount.Integer;
	endif;
	
epilog

end;</source>
        <Parameter name="_isVolume" type="Boolean"/>
        <Parameter name="_isWeight" type="Boolean"/>
        <Parameter name="_isQuantity" type="Boolean"/>
        <Parameter name="_enteredAmount" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setPxySourceLocation" id="bd459811-a088-4144-96e0-9479c8d321ef">
        <updating/>
        <source>setPxySourceLocation( _sourceLocation : CM_LocationsController ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	self.mySourceLocation := _sourceLocation;

epilog

end;</source>
        <Parameter name="_sourceLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setPxyTargetLocation" id="04f32aa7-6a82-458b-8d50-253c8d3663f8">
        <updating/>
        <source>setPxyTargetLocation( _targetLocation : CM_LocationsController ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	self.myTargetLocation := _targetLocation;

