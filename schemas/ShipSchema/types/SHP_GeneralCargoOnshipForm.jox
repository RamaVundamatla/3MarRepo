    <JadeMethod name="clearNotableObjects" id="c15673aa-bf2d-4efe-9c72-67b6e62f9978">
        <source>clearNotableObjects() protected;

vars
	obj : Object;
begin

	foreach obj in self.allNotableObjects do
		endNotification(obj, Object_Update_Event);
	endforeach;

	self.allNotableObjects.clear;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cmbSearchBOL_displayEntry" id="486f74cb-0df2-418e-9221-588ce35f884c">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSearchBOL_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Dec 2012	cnwpjs1	Initial creation 37087

*/

vars
	invalidBOL : Boolean; 
begin 

	on Exception do app.handleDeletedObject(exception, obj.CM_Object, invalidBOL); 

	
	if obj.isKindOf(CM_BOLIn) then
		return obj.CM_BOLIn.number;
	endif;
	
	return null;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cmbSearchCType_displayEntry" id="700a2958-3e10-4455-8a63-aca1f5f129ed">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSearchCType_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2010	cnwmh5	Initial creation

*/

vars
	invalidCargoType : Boolean; 
begin 

	on Exception do app.handleDeletedObject(exception, obj.CM_Object, invalidCargoType); 

	
	if obj.isKindOf(CM_CargoType) then
		return obj.CM_CargoType.abbreviation &amp; " - " &amp; obj.CM_CargoType.description;
	endif;
	
	return null;
end;
</source>
