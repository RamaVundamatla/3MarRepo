    <JadeMethod name="doCheckTerminal" id="04d9ac4d-ef34-4f03-85dd-bde661d858da">
        <updating/>
        <source>doCheckTerminal() updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 January 2003		cnwth2	
//
// Purpose:     This method will check the terminal of the selected menuEntity
//				against the currently set terminal. If different it will cause event picked up
//				by the SuperAppForm that will then go through enabling/disabling toolbar buttons
//				depending on permissions for that use terminal
//			 
// ----------   ----------  --------------------------------------------------
vars
	selectedTerm,
	currentTerm		: CM_Terminal;
	user			: CM_User;
	ut				: CM_UserTerminal;
begin
	selectedTerm := self.lstTest.getTeminalOfCurrentEntity;

 	if selectedTerm &lt;&gt; self.myCurrentTerminal then
 		user := app.getMyUser;
 		ut := user.getUserTerminal(selectedTerm);
 		if ut &lt;&gt; null then
 			app.setMyTerminal(selectedTerm);
 			self.myCurrentTerminal := selectedTerm;
 		endif;
 	endif;
 	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doContextMenuEntity" id="df057756-d61a-4812-bbfc-93e878f3eb89">
        <updating/>
        <source>doContextMenuEntity(listbox: ListBox input; 
					conwin: Window input; 
					mouse: Boolean; 
					x, y : Integer):Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	x1, 
	y1					: Real;
	menuEntity			: CM_MenuEntity;
	userDtl				: CM_MenuUserDtl;
	user				: CM_User;
	terminal			: CM_Terminal;
	idx					: Integer;
begin

	idx := listbox.getListIndex(x,y);
	if idx &lt;= 0 then
		return false; 
	endif;
	
	menuEntity := listbox.itemObject[idx].CM_MenuEntity;
	if menuEntity = null then
		return false;
	endif;
	
	self.lstTest.listObject := menuEntity;	

	user := app.getMyUser;
	terminal := self.lstTest.getTeminalOfCurrentEntity();

	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if listbox.listIndex &lt; 0 then
	        y1 := 5;
	    else
	        y1 := listbox.positionTop(listbox.listIndex);
	    endif;
	endif;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   
	

	self.mnuOrganize.enabled		:= true;

	self.mnuResetFromSystem.visible	:= false;
	self.mnuResetAllUserMenus.visible := false;
	self.mnuSaveToAdmin.visible		:= false;
	self.mnuSaveToSystem.visible	:= false;

	if user.canDo(terminal, PmAdmOrganizeMenus) then
		self.mnuOrganize.visible	:= true;
		self.mnuLine2.visible		:= true;
	else
		self.mnuOrganize.visible	:= false;
		self.mnuLine2.visible		:= false;
	endif;

	self.mnuResetFromSystem.visible	:= true;
	
	if user.canDo(terminal, PmAdmAdminMenuAccess) then
		self.mnuSaveToAdmin.visible 	:= true;
		self.mnuResetAllUserMenus.visible := true;
	else
		self.mnuSaveToAdmin.visible 	:= false;
		self.mnuResetAllUserMenus.visible := false;
	endif;
		
	if app.isSpecial() then
		self.mnuSaveToSystem.visible 	:= true;
		self.mnuSaveAsJMT.visible 		:= true;
	else
		self.mnuSaveToSystem.visible 	:= false;
		self.mnuSaveAsJMT.visible 		:= false;
	endif;

	self.popupMenu(self.mnuOrganiseMenu, x1.Integer, y1.Integer);

end;</source>
        <access>protected</access>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
