    <JadeMethod name="clearBlanksFromCodes" id="6b4103bb-cfcf-4662-9472-1e11060ad4bc">
        <updating/>
        <source>clearBlanksFromCodes(_propNames: StringArray; _fixit:Boolean) updating;
// JC
vars
	property	: Property;
	propName,
	oldValue,
	newValue	: String;
begin
	on NormalException do clearInvalidRefException(exception,propName);
	
	
	foreach propName in _propNames do
		property := self.class.getProperty(propName);
		if property &lt;&gt; null then
			oldValue := self.getPropertyValue(propName).String;
			newValue := oldValue.trimBlanks;
			property := null;
			if newValue.length = oldValue.length then
				continue;
			endif;
			if newValue &lt;&gt; "" then
				if _fixit then
					self.setPropertyValue(propName,newValue);
					app.writeLog("Fixed " &amp; propName &amp; " for " &amp; self.class.name &amp; " " &amp; newValue,0);
				else
					app.writeLog("Did not fix " &amp; propName &amp; " for " &amp; self.class.name &amp; " " &amp; newValue,0);
				endif;
			endif;
		endif;
	
	endforeach;
	
	
end;</source>
        <Parameter name="_propNames" type="StringArray"/>
        <Parameter name="_fixit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearInvalidRefException" id="5867e3ef-8cab-4073-a0dc-fe749b432322">
        <updating/>
        <source>clearInvalidRefException(_ex: Exception; _pName: String) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     11 April 2001 by cnwrs1
//
// Purpose:     To allow serialisation of properties of each class     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	transState : Boolean;
begin
	on NormalException do null global;

	app.writeLog("&lt;"&amp;self.String&amp;"&gt;&lt;"&amp;_pName&amp;"&gt;",0);
	if _ex.errorCode = 1048 then 
		beginTransaction;
		transState := true;
	endif;
	if _ex.errorCode &lt;&gt; 1088 and 
	   _ex.errorCode &lt;&gt; 1239 then 
		self.setPropertyValue(_pName,null);
	endif;
	if transState then
		commitTransaction;
	endif;
epilog
    return Ex_Resume_Next;
end;</source>
        <Parameter name="_ex" type="Exception"/>
        <Parameter name="_pName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clearInvalidReferences" id="957e1817-8cf9-4533-9e83-ebae66cf4647">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>clearInvalidReferences(_propArray:ObjectArray; _fixit:Boolean) serverExecution, updating;
// ---------------------------------------------------------------------------
// Created:     11 April 2001 by cnwrs1
//
// Purpose:     To allow serialisation of properties of each class     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	property	: Property;
	object1,
	object2		: Object;
	str,
	message,
	pName,
	oidStr		: String;
 	classNo		: Integer;
	class		: Class;
begin
	on NormalException do clearInvalidRefException(exception, pName);
	foreach object1 in _propArray do
		property := object1.Property;
		pName := property.getName;
		self.setInvalidReference(pName, _fixit);
	endforeach;
end;</source>
        <Parameter name="_propArray" type="ObjectArray"/>
        <Parameter name="_fixit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="convertExtensionObjectValue" id="b266b41d-f6b8-4793-9fa0-369c9359a647">
        <updating/>
        <source>convertExtensionObjectValue(_extnProperty :String; _property :Property)updating;
/*
Purpose		Use this method to move data from an extnsion object to a real property
			as part of a major JMT upgrade.
			
			Note: This method assumes that the type of the extension property and the type
			of the real property are the same.
			
Date		Who		Reason
23/02/2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
//02 Jun 2013	cnwrs1	JMT821 cut 
// 31/07/2015 	cnwmh5	Add additional fields conversions
vars
	value				:Any;
	propertyName		:String;
	oldColl, newColl	:Collection;
	propertyType		:Type;
begin
	propertyName	:= _property.name;
	propertyType	:= _property.type;
	value 			:= self.getExtensionObjectValue (_extnProperty);
	
	if value = null then 
		// nothing to do - also if run twice don't want to override data
		// that was put across in the first place
		return;
	endif;
	
	if value.isKindOf (Collection) then	
		// need to copy collection values across
		oldColl := value.Collection;
		
		if oldColl.size &gt; 0  then		
			if not propertyType.isKindOf (CollClass) then
				// both properties must be collections
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Expecting collection class');
			endif;
			
			newColl	:= self.getPropertyValue (propertyName).Collection;
			
			// if membership of collections is NOT compatible there could be an exception!!!
			newColl.clear();
			oldColl.copy  (newColl);
		endif;
	elseif not propertyType.isKindOf (CollClass) then 
		// only want to do this for primitive properties
		if propertyType = Boolean then
			// for some reason we need to explicitly type-cast a boolean value so we don't
			// get an exception in setPropertyValue
			self.setPropertyValue (propertyName, value.Boolean);
		elseif propertyType = Date then
			self.setPropertyValue (propertyName, value.Date);
		elseif propertyType = Integer then
			self.setPropertyValue (propertyName, value.Integer);
		elseif propertyType = Decimal then
			self.setPropertyValue (propertyName, value.Decimal);
		elseif propertyType = Real then
			self.setPropertyValue (propertyName, value.Real);
		elseif propertyType = Time then
			self.setPropertyValue (propertyName, value.Time);
		elseif propertyType = TimeStamp then
			self.setPropertyValue (propertyName, value.TimeStamp);
		else
			self.setPropertyValue (propertyName, value);
		endif;
	endif;
	
	app.writeLog( method.qualifiedName &amp; ' Converted extension object value ' &amp; self.class.name &amp; '::' &amp; _property.name &amp; ' for ' &amp; self.asStringJMT, LogINFO);
	
	self.setExtensionObjectValue (_extnProperty, null);
epilog

end;</source>
        <Parameter name="_extnProperty" type="String"/>
        <Parameter name="_property" type="Property"/>
    </JadeMethod>
    <JadeMethod name="convertStringToQRCode" id="d28fd5bf-ebce-4e6d-998e-484165617cb5">
