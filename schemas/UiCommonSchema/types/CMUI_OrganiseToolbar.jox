    <JadeMethod name="clearfilter" id="8cd101ea-bef7-44b2-b378-5989e1a39ca3">
        <updating/>
        <source>clearfilter() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Sep 2023	navhl20	ChangeRequest 59988: MTN - Add a filter to Customize toolbar Multi Selection
20 Sep 2023 navhl20 Defect 60596: MTN - Customize toolbar Multi Selection filter issue
*/

vars 
	txtFilter : CMUI_TextBox;
begin
	txtFilter := self.txtfilter;
		
	if txtFilter.text &lt;&gt; "" then
		txtFilter.text := "";
		self.btnclear.enabled := true;
	endif;
	self.btnclear.enabled := false;
	//self.displayLists();						//20.9.2023 navhl20 #60596
	self.doFilterList();						//20.9.2023 navhl20 #60596
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayLists" id="1e1bebe0-49be-40b4-9c2f-55a51c0697a1">
        <updating/>
        <source>displayLists() updating;
// ---------------------------------------------------------------------------
// Created:     24 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	obj					: Object;
	menuEntity			: CM_MenuEntity;
	toolbarItem			: CM_MenuToolbar;
	menuHdrSystem		: CM_MenuHdrSystem;
	user				: CM_User;
	userTerminal		: CM_UserTerminal;
	terminal			: CM_Terminal;
	itemIncludedDict	: CM_MenuToolbarByIdDict;
	theLstIncluded,
	theLstNotIncluded	: CMUI_NavigatorListBox2;
	permissionValue		: Integer;
	dynaDict			: DynaDictionary;
	root				: CM_Root;
	canView				: Boolean;
	license				: Integer;
	sysItem			 	: CM_MenuDtlNav;
	isLicensed	: Boolean;

begin

	create dynaDict transient;
	dynaDict.setMembership(CM_MenuToolbar);
	dynaDict.addMemberKey('heading', false, false);
	dynaDict.endKeys(true);
	
	user := app.getMyUser();
	theLstIncluded := self.lstIncluded;
	theLstNotIncluded := self.lstNotIncluded;
	
	theLstIncluded.clear();
	theLstNotIncluded.clear();
	
	create itemIncludedDict transient;

	foreach menuEntity in user.myMenuUserToolbarRoot.allMenuUserToolbarItems do
		
		toolbarItem := menuEntity.CM_MenuUserToolbar.mySystemToolbar;
		if toolbarItem = null then
			continue;
		endif;
		
		if toolbarItem.menuId = toolbarItem.MENU_ID_SEP then
			self.mySeparator := toolbarItem;
			self.doAddSeparator();
			continue;
		endif;

		itemIncludedDict.add(toolbarItem);
		theLstIncluded.addMenuEntity(toolbarItem, null, 2);
	endforeach;
	//this is a hit for a member key dict - but at least we're in load state
	root := app.myRoot;
	root.allToolbarEntities.copy(dynaDict);
	
	foreach obj in dynaDict do : outerLoop
		toolbarItem := obj.CM_MenuToolbar;
		if toolbarItem.menuId = toolbarItem.MENU_ID_SEP then
			self.mySeparator := toolbarItem;
			continue;
		endif;
		
		if toolbarItem.getMenuId = "_TB428" then     //21/10/2014 cnwma1 PAR #34998
			if app.myRoot.isDeprecated("8.2.1") then
				continue;
			endif;
		endif;
		
		
		canView := false;
		permissionValue := toolbarItem.constantValue;
			
		sysItem := toolbarItem.myMenuDtlSystem;
		
		if sysItem &lt;&gt; null and app.isValidObject(sysItem) then//changed by cnwyl1 for par 15216
			isLicensed	:= false;
			foreach license in sysItem.allChildValues do
				if user.canDo(null, license) then
					isLicensed := true;
					break;
				endif;
			endforeach;

			if (not isLicensed) then
				continue outerLoop;
			endif;
			
			//foreach license in sysItem.allChildValues do
//				if not user.canDo(null, license) then
//					continue outerLoop;
//				endif;
//			endforeach;
		endif;
			
		if permissionValue &gt; 0 then
			foreach userTerminal in user.allUserTerminals do
				terminal := userTerminal.getRealTerminal;
				if user.canDo(terminal, permissionValue) then
					canView := true;
					break;
				endif;
			endforeach;
		else
			canView := true; //29230 29.3.2012
		endif;
		
		if not canView then
			continue;
		endif;
		
		if itemIncludedDict.includesKey(toolbarItem.menuId) then
			continue;
		endif;
		if  toolbarItem.menuId &lt;&gt; toolbarItem.MENU_ID_BOT then		//36586 navsaa30 21/11/25
			theLstNotIncluded.addMenuEntity(toolbarItem, null, 2);
		elseif toolbarItem.menuId = toolbarItem.MENU_ID_BOT and (app.myRoot.isClientJadeMaster or app.myRoot.licenseName = "JMT Testing") then
			theLstNotIncluded.addMenuEntity(toolbarItem, null, 2);
		endif;
	endforeach;

epilog
	delete dynaDict;
	delete itemIncludedDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="doAddRemoveItems" id="46585e14-1901-478f-99b8-f6b3d15d65b0">
        <source>doAddRemoveItems(_add : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     22 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuEntity				: CM_MenuEntity;
	idx,
	listCount				: Integer;
	lstBoxAddTo,
	lstBoxRemoveFrom		: CMUI_NavigatorListBox2;

begin
	if _add then
		lstBoxAddTo := self.lstIncluded;
		lstBoxRemoveFrom := self.lstNotIncluded;
	else
		lstBoxAddTo := self.lstNotIncluded;
		lstBoxRemoveFrom := self.lstIncluded;	
	endif;
	
	listCount := lstBoxRemoveFrom.listCount;
	
	foreach idx in listCount to 1 step -1 do
		if (not lstBoxRemoveFrom.itemSelected[idx]) then
			continue;
		endif;
		
		menuEntity := lstBoxRemoveFrom.itemObject[idx].CM_MenuEntity;
		
		lstBoxRemoveFrom.removeItem(idx);
		if CM_MenuToolbar.hasInstance(menuEntity) then
			lstBoxAddTo.addMenuEntity(menuEntity, null, 2);
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_add" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doAddSeparator" id="14146738-9f21-489b-a7d1-d5381d93aaf9">
        <source>doAddSeparator() protected;
// ---------------------------------------------------------------------------
// Created:     14 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	selectedTool			: CM_MenuToolbar;
	userTool				: CM_MenuUserToolbar;
	
begin
	create userTool transient;
	self.allClonedSeparatorsToPurge.add(userTool);
	userTool.setFromSystemToolbar(self.mySeparator);
	self.lstIncluded.addMenuEntity(userTool, null, 2);

end;</source>
        <access>protected</access>
    </JadeMethod>
