<Class name="HMS_HiLoTidalData" id="6ecc3484-f239-408f-97e2-654b30eadc12">
    <instanceVolatility>stable</instanceVolatility>
    <superclass name="HMS_TidalData"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="hms"/>
    <PrimAttribute name="height" id="334b4755-98ff-4515-8850-d64a2e97a749">
        <embedded/>
        <type name="Real"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="tideType" id="7c0c6471-8250-4f63-88f0-46f0f35341a8">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDataType" id="155f8d06-d68a-45cf-93bd-e7b1f616dea9">
        <source>getDataType(): Integer;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return HMS_TidalDataType_HiLo;

end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getValue" id="f314c23b-c2ae-43c0-a844-8493d3d60dee">
        <source>getValue(): Decimal;

/*

Created:	18 October 2006 By cnwth2

Purpose:	

Purpose:	

Date		Who		Reason
02 May 2008	cnwkpd1	PAR #16642 - signature change to return a Decimal, to correct issues with
					Real imprecision

*/

vars

begin
	return height.Decimal.roundedTo(2);


end;


</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="isHighTide" id="a7a27f83-dec6-4276-aa22-868aa4f68ff2">
        <source>isHighTide():Boolean;
// --------------------------------------------------------------------------------
// Created:		15 March 2007 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is a high tide.
//
// Parameters:	None
//
// Returns:		True if it's a high tide, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.tideType = HMS_TideType_High);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLowTide" id="a4361ff0-0879-46fc-af8f-e33e0899a257">
        <source>isLowTide():Boolean;
// --------------------------------------------------------------------------------
// Created:		15 March 2007 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is a low tide.
//
// Parameters:	None
//
// Returns:		True if it's a low tide, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.tideType = HMS_TideType_Low);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b1edd98e-ca06-4287-8305-dcc834b07c30">
        <updating/>
        <source>setForUpdate(_pxyTidalData: HMS_HiLoTidalData; _passport: CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod(_pxyTidalData, _passport);
	self.height := _pxyTidalData.height;
	self.tideType := _pxyTidalData.tideType;
	
end;


</source>
        <Parameter name="_pxyTidalData" type="HMS_HiLoTidalData"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="1d35bcd4-6323-454e-8dc5-5021432a9962">
        <updating/>
        <source>setProxy(_ts 			: TimeStamp;
		_tidalModelDef 	: HMS_TidalModelDefinition;
		_height			: Real;
		_tideType 		: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.ts 		:= _ts;
	self.myTidalModelDefinition := _tidalModelDef;
	self.height 	:= _height;
	self.tideType 	:= _tideType;
	
end;
</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_tidalModelDef" type="HMS_TidalModelDefinition"/>
        <Parameter name="_height" type="Real"/>
        <Parameter name="_tideType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="5dd887e3-f82c-4b77-8773-0c3799086720">
        <source>validateForUpdate(_passport: CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod(_passport);
	
// cnwdad1 16/10/2007 - See PAR #15135.  This change didn't go out with the hotfix for that PAR,
// but the change will go out with 7.5.3.
//	if self.height = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Tidal Data: Height', null,  null);
//	endif;
	
	if self.tideType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Tidal Data: Tide Type', null,  null);
		app.raiseCMException(Input_required_field_TideType, null,  null); // cnwdb2	PAR 35364
	endif;
end;


</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
