    <JadeMethod name="setProxyFromObject" id="7f09b5ae-58a8-4c47-a3c1-0a33c2edb242">
        <updating/>
        <source>setProxyFromObject(_object: CM_SOHLocation) updating;
/*

Date		Who		Reason
06 October 2015	cnwer1	Initial creation PAR

*/

vars
	productLog : CM_ProductLog;
begin
	inheritMethod(_object);
	
	self.volume:= _object.currentVolume;
	self.weight:= _object.currentWeightKgs;
	self.peiceCount:=_object.getNumberOfTrackedItems();
	self.docketCount:=_object.getNumberOfBOLIns();
	if _object.myProduct &lt;&gt; null and _object.myProduct.isKindOf(CM_ProductLog) then
		productLog:=_object.myProduct.CM_ProductLog;
		
		self.logGradeCode:=productLog.gradeCode;
		self.logLengthCode:=productLog.lengthCode;
		self.logSpeciesCode:=productLog.speciesCode;
		self.logTreatmentCode:=productLog.treatmentCode;
		self.logTypeCode:=productLog.typeCode;
		if productLog.myOperator &lt;&gt; null then
			self.operatorCode:=productLog.myOperator.code;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_SOHLocation"/>
    </JadeMethod>
</Class>
