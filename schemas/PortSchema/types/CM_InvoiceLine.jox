    <JadeMethod name="zzGetTerminalCode" id="1ea4b0d5-0dd4-4a19-950b-81a249dbb889">
        <source>zzGetTerminalCode() : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2023	navpw1	Initial creation TFS: 60965

*/

vars
	currentInvoice			: CM_Invoice;
	currentInvoiceLineDesc	: CM_InvoiceLineDesc;
	currentBank				: CM_Bank;
	terminal				: CM_Terminal;
	
begin
	currentInvoice := self.invoice;
	currentInvoiceLineDesc := self.invoiceLineDesc;
	
	if currentInvoice &lt;&gt; null then
		terminal := currentInvoice.myTerminal;
		
		if terminal &lt;&gt; null then
			return terminal.code;
			
		endif;
		
	endif;
	
	if currentInvoiceLineDesc = null then
		return null;
		
	endif;
	
	currentBank := currentInvoiceLineDesc.bank;
	if currentBank = null then
		return null;
		
	endif;
	
	terminal := currentBank.terminal;
	
	if terminal = null then
		return null;
		
	endif;
	
	return terminal.code;
	
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="zzGetTiDetails" id="48ced9e5-34dc-4083-8513-b97b34b9a028">
        <source>zzGetTiDetails() : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2023	navpw1	Initial creation TFS: 60965

*/

vars
	currentTrackedItem	: CM_TrackedItem;
	transactionEvent	: CM_EventTransaction;
	transactionWo		: CM_WOTransaction;
	transactionBOL		: CM_BOLTransaction;
	transactionHMS 	  	: HMS_VTMISTransaction;
	voyage				: CM_Voyage;
	invalidObject		: Boolean;
	
begin
	currentTrackedItem := self.trackedItem;
	if not self.manual then
		transactionHMS := self.myTransactionHMS;
		transactionEvent := self.myTransactionEvent;
		transactionWo := self.myTransactionWO;
		transactionBOL := self.myTransactionBOL;
		
		if transactionHMS &lt;&gt; null then
			voyage := transactionHMS.myVoyage;
			if voyage = null then
				return null;
			endif;
			on Exception do app.handleDeletedObject(exception, voyage, invalidObject);
			voyage.edition;
			on Exception do null;
			
			if invalidObject then
				return null;
			endif;
			
			return voyage.code;
			
		elseif transactionEvent &lt;&gt; null then
			return transactionEvent.getName();
			
		elseif transactionWo &lt;&gt; null then
			return transactionWo.getName();				// TFS 42161 noticed that WO Tran is missing from some methods
			
		elseif transactionBOL &lt;&gt; null then				//31 Oct 2019	NDL	TFS 47100
			return transactionBOL.getDisplayID();
			
		else
			if currentTrackedItem &lt;&gt; null then
				return currentTrackedItem.id;
			else
				return self.trackedItemId;
			endif;
		endif;
	endif;
	
	if currentTrackedItem &lt;&gt; null then
		return currentTrackedItem.id;
	endif;
	
	return null;
	
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="zzGetTransDeleted" id="03d58bc0-11e1-4deb-9cd5-6dc39ea1b7c3">
        <source>zzGetTransDeleted() : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2023	navpw1	Initial creation TFS: 60965

*/

vars
	transactionTI : CM_TITransaction;
	
begin
	transactionTI := self.myTransactionTI;
	
	if not self.manual then
		if transactionTI &lt;&gt; null and transactionTI.deleted then
			return app.getErrorString(Yes);
			
		endif;
		
	endif;
	
	return null;
	
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="zzGetVesselCode" id="3d48caa7-7185-4786-b06b-919d4348b1bd">
        <source>zzGetVesselCode() : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2023	navpw1	Initial creation TFS: 60965

*/

vars
	voyage			: CM_Voyage;
	invalidObject	: Boolean;
	vessel			: CM_Vessel;
	
begin
	voyage := self.getMyVoyageObject;
	
	if voyage = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception, voyage, invalidObject);
	voyage.edition;
	on Exception do null;
	
	if invalidObject then
		return null;
		
	endif;
	
	vessel := voyage.getMyVessel;
	
	if vessel &lt;&gt; null then
		return vessel.code;
		
	endif;
	
	return null;
	
end;</source>
