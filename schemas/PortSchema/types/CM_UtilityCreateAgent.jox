    <JadeMethod name="utlCreateDeckLayerLayout" id="31839bd1-6826-40f7-857f-49363e152306">
        <source>utlCreateDeckLayerLayout(_pxyDeckLayer : CM_DeckLayerLayout; _realDeckLayer : CM_DeckLayerLayout output; _moveToTop : Boolean; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     March 2011 ANDREW BISHOP
//
// RORO DECK DEFINITION
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	pxyDeckLayout	: CM_DeckLayout;
	realDeckLayout	: CM_DeckLayout;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValCA.valDeckLayerLayout(_pxyDeckLayer);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	create _realDeckLayer;
	_realDeckLayer.setForCreate(_pxyDeckLayer);
	
	// 34541 Oct 2014 prevent persistent - transient error - create deck layer for copy
	if _realDeckLayer.myDeckLayout = null and
	   _pxyDeckLayer.myDeckLayout &lt;&gt; null and 
	   _pxyDeckLayer.myDeckLayout.isTransient then
		pxyDeckLayout := _pxyDeckLayer.myDeckLayout;
			
		app.myUtilityCA.utlCreateDeckLayout(pxyDeckLayout, realDeckLayout , app.myPassport);
		_realDeckLayer.setDeckLayout(realDeckLayout);
	endif;

	if _moveToTop then // PAR 28330
		_realDeckLayer.myDeckLayout.moveLayerToTop(_realDeckLayer); // make it draw as the top layer
		
		if _realDeckLayer.type = ROROLayerType_GC 
		or _realDeckLayer.type = ROROLayerType_OOTL then
			_realDeckLayer.myDeckLayout.moveCCLayersToTop(); // PAR 28330
		endif;
	endif;

end;</source>
        <Parameter name="_pxyDeckLayer" type="CM_DeckLayerLayout"/>
        <Parameter name="_realDeckLayer" type="CM_DeckLayerLayout" usage="output"/>
        <Parameter name="_moveToTop" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateDeckLayout" id="d0ee7c4e-c463-442b-a63a-6fd2469f91eb">
        <source>utlCreateDeckLayout(_pxyObject : CM_DeckLayout; _realObject : CM_DeckLayout output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     March 2011 ANDREW BISHOP
//
// RORO DECK DEFINITION
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValCA.valDeckLayout(_pxyObject);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	create _realObject as _pxyObject.class persistent;
	_realObject.setForCreate(_pxyObject);

end;</source>
        <Parameter name="_pxyObject" type="CM_DeckLayout"/>
        <Parameter name="_realObject" type="CM_DeckLayout" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateDeckOptionsApplyRules" id="474ded5d-cf4c-4bcd-bda4-c23135492a2a">
        <updating/>
        <source>utlCreateDeckOptionsApplyRules(_newTerminalArea: CM_TerminalArea; _pxyDeckingOptions: CM_YADeckingOptionsTA; _updateToLevel: Integer; _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	08 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

//	For new terminal areas

vars
	realDeckingOptions		: CM_YADeckingOptions;
	pxyDeckingOptions		: CM_YADeckingOptionsTA;
	
begin
	app.setContinueCMExceptions(false);
	pxyDeckingOptions := _pxyDeckingOptions;

	if pxyDeckingOptions = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'proxy rules are null');
		return;
	endif;

	if _passport.hasErrors then
		return;
	endif;
	
	//new area - must reset heights
	pxyDeckingOptions.setHeightsForNewArea();
	
	//set the new area
	pxyDeckingOptions.setProxy(pxyDeckingOptions.showHeightsForCustom, pxyDeckingOptions.useReverseOfIn, _newTerminalArea);
	
	pxyDeckingOptions.validateForDecking();	//add validation - test if NOK for decking

	if _passport.hasErrors then
		return;
	endif;

	if _newTerminalArea.myYADeckingOptions = null then
		app.myUtilityCA.utlCreateDeckingOptions(pxyDeckingOptions, _passport);	//persist the DO
	else
		app.myUtilityUA.utlUpdateDeckingOptions(pxyDeckingOptions, realDeckingOptions, _updateToLevel, _passport);//utlCreateDeckingOptions(pxyDeckingOptions, _passport);	//persist the DO
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	if _newTerminalArea.myYADeckingOptions = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'no decking options found for new terminal area');
	else
		//apply rules to YALocationCells
		app.myUtilityUA.utlApplyDeckingRule(_newTerminalArea.myYADeckingOptions, _passport);
	endif;

end;</source>
        <Parameter name="_newTerminalArea" type="CM_TerminalArea"/>
        <Parameter name="_pxyDeckingOptions" type="CM_YADeckingOptionsTA"/>
        <Parameter name="_updateToLevel" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateDeckingOptions" id="c23e4973-9a12-4a2f-a538-654215d227b6">
        <updating/>
        <source>utlCreateDeckingOptions(_pxyDeckingOptions: CM_YADeckingOptions; _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	07 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	deckingOption			: CM_YADeckingOptions;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	_pxyDeckingOptions.validate();
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;	
	endif;

	app.setContinueCMExceptions(false);

	create deckingOption as _pxyDeckingOptions.class persistent;

	deckingOption.setForCreate(_pxyDeckingOptions);

	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(deckingOption);
	endif;

end;</source>
        <Parameter name="_pxyDeckingOptions" type="CM_YADeckingOptions"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateDefinedText" id="90e1b348-f985-44fa-9aaf-e270f5e5a897">
        <source>utlCreateDefinedText(_pxyDefinedText : CM_DefinedText input;
					   _newDefinedText : CM_DefinedText output;
					   _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who			Reason
10 October 2022 	navvt20     ChangeRequest 53424: MTN - MOB - Input Remarks - Jade

*/

vars

begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyDefinedText, 'Defined Text Proxy');
	_pxyDefinedText.validateForCreate();
	
	create _newDefinedText persistent;
	_newDefinedText.setForCreate(_pxyDefinedText);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newDefinedText);
	endif;

epilog

end;</source>
        <Parameter name="_pxyDefinedText" type="CM_DefinedText" usage="input"/>
        <Parameter name="_newDefinedText" type="CM_DefinedText" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
