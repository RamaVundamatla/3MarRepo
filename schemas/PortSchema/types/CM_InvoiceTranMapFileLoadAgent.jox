    <JadeMethod name="createDebtorMap" id="851a1455-a32d-4590-a168-a6062b6634b6">
        <updating/>
        <source>createDebtorMap(_debtorCode : String; _serviceBroker : CM_ServiceBroker; _debtorMapObj : CM_DebtorMap output) : Boolean updating, protected;

vars
	isDefault	: Boolean;
	debtorObj : CM_DebtorNode;
	proxyDebtorMap,
	debtorMapObj	: CM_DebtorMap;
	debtorTypeObj		: CM_DebtorType;
begin
	self.getDebtorDetails(_debtorCode, isDefault, debtorObj, debtorTypeObj);
	// there are no CM_DebtorMap instances for the default case, only for a specific debtor
	if isDefault then
		return true;
	endif;
	
	debtorMapObj := _serviceBroker.allDebtorMapsByDebtor[debtorObj.name];

	if debtorMapObj = null then
		create proxyDebtorMap transient;
		proxyDebtorMap.setProxy(debtorObj, _serviceBroker, debtorTypeObj);
		app.myTrxCA.trxCreateInvoiceTMDebtor(proxyDebtorMap, debtorMapObj, self.passport);
		if (not app.myPassport.trxCompletedOK) then
			self.setAllErrors('Creating debtor map (' &amp; _debtorCode &amp; '), row ' &amp; rowCount.String);
			return false;
		endif;

		createCount := createCount + 1;
	endif;
	
	_debtorMapObj := debtorMapObj;
	return true;
epilog
	delete proxyDebtorMap;
end;
</source>
        <access>protected</access>
        <Parameter name="_debtorCode" type="String"/>
        <Parameter name="_serviceBroker" type="CM_ServiceBroker"/>
        <Parameter name="_debtorMapObj" type="CM_DebtorMap" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
