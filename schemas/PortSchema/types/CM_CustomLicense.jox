        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="fc5734af-d8a9-4527-8c35-0324caef5e85">
        <source>validateForCreate();
// ##### CR59571 TASK 59573 NAVAB1 04AUG2023
vars
	customLicense : CM_CustomLicense;
begin
	if self.code = null then
		app.raiseCMException(NoCustomLicenseCodeEntered, null, null);
	endif;
	
	customLicense := self.myTerminal.allCustomLicenses[self.code];
	if customLicense &lt;&gt; null then
		app.raiseCMException1(CustomLicenseCodeInUsed, self.code, null, null);
	endif;
	
	self.validateForUpdate();
epilog

end;</source>
    </JadeMethod>
