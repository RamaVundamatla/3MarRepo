    <JadeMethod name="delete" id="223ee7ba-4fce-485a-9e1b-669b1d74f3b4">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 January 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars

begin
	delete self.allDischargePorts;
	delete self.cargoType;
	delete self.carrier;
	delete self.commodity;
	delete self.consignee;
	delete self.consignor;
	delete self.coolingType;
	delete self.destinationPort;
	delete self.dischargePort;
	delete self.imexStatusString;
	delete self.isoType;
	delete self.operatorCode;
	delete self.shippingLineCode;
	delete self.transportMode;
	delete self.voyageCode;
	delete self.mySubTerminal;
	
	//cnwmc5 - 20 August 2014 - PAR 34784
	if not self.allTIHazards.isEmpty then
		self.allTIHazards.purge;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAttachments" id="cfe36255-0770-48f7-91fb-ee222ca6fb4e">
        <source>getAttachments(obj: CM_TrackedItem) : String;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
21 Jan 2009	cnwdz2	Initial creation
*/
constants
	Delimiter	: String = "; ";
	
vars
	attachments : CM_TISet;
	attachment  : CM_TrackedItem;
	retVal		: String;
	delimLen	: Integer;
	
begin
	if obj &lt;&gt; null then
		delimLen := Delimiter.length() + 1; 
		
		foreach attachment in obj.allChildren do//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
			retVal := retVal &amp; Delimiter &amp; attachment.id;
			
		endforeach;	
		
		if retVal.length() &lt; delimLen then
			return null;
		else
			return retVal[delimLen:end]; //remove the first delimiter 
		endif;
		
	else
		return null;
		
	endif;
	
epilog
	
end;</source>
        <Parameter name="obj" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOptionalDischargePortsDesc" id="561bd76f-9d33-48c0-8bc4-fbd6c7e386d4">
        <source>getOptionalDischargePortsDesc(obj: CM_TrackedItem) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 September 2008	cnwkao1	Initial creation

*/
constants
	Delimiter	: String = ", ";
	
vars
	portCode	: String;
	retVal		: String;
	delimLen	: Integer;
	port		: CM_Port;
begin
	delimLen := Delimiter.length() + 1; 
	foreach portCode in obj.allDischargePorts do
		port := app.myRoot.allPorts.getAtKey(portCode);
//		retVal := retVal &amp; Delimiter &amp; port.portCode &amp; " (" &amp; port.countryCode &amp; ") " &amp; port.description;	// cnwrl1 29/05/2009 PAR 19672 - what it was
		retVal := retVal &amp; Delimiter &amp; port.portCode &amp; " (" &amp; port.getCountryCodeForDisplay( Tab ) &amp; ") " &amp; port.description;
	endforeach;	
	
	return retVal[delimLen:end]; //remove the first delimiter (+1 because not 0 based)
	
epilog

end;</source>
        <Parameter name="obj" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOptionalDischargePortsId" id="f21f5e6b-2d29-40db-acf9-a7e0321abf75">
        <source>getOptionalDischargePortsId(obj: CM_TrackedItem) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 September 2009	

*/
constants
	Delimiter	: String = ", ";
	
vars
	portCode	: String;
	retVal		: String;
	delimLen	: Integer;
	port		: CM_Port;
begin
	delimLen := Delimiter.length() + 1; 
	foreach portCode in obj.allDischargePorts do
		port := app.myRoot.allPorts.getAtKey(portCode);
//		retVal := retVal &amp; Delimiter &amp; port.portCode &amp; " (" &amp; port.countryCode &amp; ") " &amp; port.description;	// cnwrl1 29/05/2009 PAR 19672 - what it was
		retVal := retVal &amp; Delimiter &amp; port.getCountryCodeForDisplay( Tab )  &amp; port.portCode;
	endforeach;	
	
	return retVal[delimLen:end]; //remove the first delimiter (+1 because not 0 based)
	
epilog

end;</source>
        <Parameter name="obj" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setAllTIHazards" id="c7244c3d-7839-495d-aa68-bb9d1edda10e">
        <updating/>
        <source>setAllTIHazards(obj: CM_TrackedItem) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 September 2010	#cnwdz2	 25439

*/
vars
	tiHazard 	: CM_Hazard;
	wsTIHazard 	: WS_TIHazard;
	
begin

	foreach tiHazard in obj.allTIHazards do
		create wsTIHazard transient;
		wsTIHazard.setProxyFromObject( tiHazard );
		self.allTIHazards.add( wsTIHazard );
	endforeach;
	
epilog
	
end;</source>
        <Parameter name="obj" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsFromObject" id="689d4597-a330-47e7-8a00-e062823b92c7">
        <updating/>
        <source>setDefaultsFromObject(cargoId : String; _trackedItem: CM_TrackedItem) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09/01/2009	#cnwdz2	 
17/06/2013	cnwdap1	PAR #31700 Add numberOfItems
17/06/2013	cnwdap1	PAR #31800 Add clientRef, colour, itemDesc and markNumber
24/09/2013	cnwdap1	PAR #32215 CCMS DPH 2290 New Car Attributes
28/07/2015	cnwdap1	PAR #36682 Added Expiry Date field
*/
vars
	defCommodity	: CM_Commodity;
	defConsignee,
	defConsignor	: CM_ConsigneeConsignor;

	defDestination,
	defDischarge	: CM_Port;
	defISOType		: CM_ISOType;
	defOperator		: CM_Operator;
	defCargoType	: CM_CargoType;
	defVoyage		: CM_Voyage;
	defTransportMode	: Integer;	
	defStatus	: CM_IMEXStatus;	
	pConsignor  : CM_ConsigneeConsignor;	
	contRange	: CM_ContRange;
	container   : CM_Container;
	tmpInt		: Integer;
	invalidObject : Boolean;
	carrier		: CM_Carrier;
	subTerminal : CM_SubTerminal;
	pinNo		: CM_PinNo;
begin	
	if _trackedItem = null then		
		defTransportMode := TI_TRANSMODE_ROAD;
		defCargoType := app.myPassport.getDefaultCargoType();
		contRange := app.myRoot.lookupContainerRange(cargoId);
		if contRange &lt;&gt; null then
			defISOType := app.myRoot.allISOTypes[contRange.isoType];
			self.weightTotal := contRange.tareKilos.String;
			
			tmpInt := contRange.coolingType;
			create self.coolingType transient;
			self.coolingType.initFields(tmpInt);
		endif;	
		self.idTextBox   := cargoId;
	else
		self.cmObjectEdition := _trackedItem.edition();
		self.cmObjectId		 := _trackedItem.getOidAsString();	
	
		defCommodity 	 := app.getCargoFieldObject(_trackedItem, ETRow_Commodity).CM_Commodity;
		defConsignor	 := app.getCargoFieldObject(_trackedItem, ETRow_ConsignorCode).CM_ConsigneeConsignor;
		defConsignee	 := app.getCargoFieldObject(_trackedItem, ETRow_ConsigneeCode).CM_ConsigneeConsignor;
		defDestination	 := app.getCargoFieldObject(_trackedItem, ETRow_DestinationPort).CM_Port;
		defDischarge	 := app.getCargoFieldObject(_trackedItem, ETRow_DischargePort).CM_Port;
		defISOType		 := app.getCargoFieldObject(_trackedItem, ETRow_IsoType).CM_ISOType;			
		defVoyage		 := app.getCargoFieldObject(_trackedItem, ETRow_VoyageCode).CM_Voyage;
		defOperator		 := app.getCargoFieldObject(_trackedItem, ETRow_OperatorCode).CM_Operator;
		defCargoType	 := app.getCargoFieldObject(_trackedItem, ETRow_CargoType).CM_CargoType;
		defStatus        :=	_trackedItem.getImExStatusObject();
		defTransportMode := _trackedItem.receiptTransportMode;	
		
		//self.weightTotal:= _trackedItem.weight.truncatedTo(0).xasStringJMT();					//-cnwml2 MSL CCMS 1017
		//self.weightTotal := _trackedItem.totalWeight.xasStringWeightJMT();						//+cnwml2 MSL CCMS 1017
		self.weightTotal := _trackedItem.totalWeight.asStringWeightForWebInterface();	//26 Oct 2012	NDL	Par 30622
		self.idTextBox   := _trackedItem.id;
		self.alternativeId := _trackedItem.alternativeId;	//03 May 2013	NDL	Par 31506
		self.bookingReference := _trackedItem.bookingReference;
		pinNo	:= _trackedItem.myPinNo;
		if pinNo &lt;&gt; null then
			self.pinNo := pinNo.pinNo;
		endif;
		
		if defCommodity &lt;&gt; null then
			create self.commodity transient;
			self.commodity.setProxyFromObject(defCommodity);
		endif;
		
		
		if defConsignor &lt;&gt; null then
			create self.consignor transient;
			self.consignor.setProxyFromObject(defConsignor);		
		endif;
	
		if defConsignee &lt;&gt; null then
			create self.consignee transient;
			self.consignee.setProxyFromObject(defConsignee);		
		endif;
	
		if defDestination &lt;&gt; null then
			create self.destinationPort transient;
			self.destinationPort.setProxyFromObject(defDestination);			
		endif;	
	
		if defDischarge&lt;&gt; null then
			create self.dischargePort transient;
			self.dischargePort.setProxyFromObject(defDischarge);		
		endif;		
		
		create self.allDischargePorts transient;
		self.allDischargePorts.description := self.getOptionalDischargePortsDesc(_trackedItem);
		self.allDischargePorts.code := self.getOptionalDischargePortsId(_trackedItem);
	
		//17/09/2010 cnwdz2 par25439
		self.setAllTIHazards(_trackedItem);
		
		if defStatus &lt;&gt; null then
			create self.imexStatusString transient;
			self.imexStatusString.setProxyFromObject(defStatus);
		endif;
			
		if defVoyage &lt;&gt; null then
			invalidObject := false;
			on Exception do app.handleDeletedObject(exception, defVoyage, invalidObject);
			
			create self.voyageCode transient;
			self.voyageCode.setProxyFromObject(defVoyage);
			if defVoyage.myShippingLine &lt;&gt; null then
				create self.shippingLineCode transient;
				self.shippingLineCode.setProxyFromObject(defVoyage.myShippingLine);
			endif;
			
			if invalidObject then
				delete self.voyageCode;
				delete self.shippingLineCode;
			endif;
			
			on Exception do null;
			
		endif;
			
		if defOperator &lt;&gt; null then
			create self.operatorCode transient;
			self.operatorCode.setProxyFromObject(defOperator);		
		endif;	
		
		self.length := _trackedItem.length.Integer;
		self.width  := _trackedItem.width.Integer;
		self.height := _trackedItem.height.Integer;
		//self.volume := _trackedItem.getMyTotalVolume.asStringJMT(); //26/08/2010 cnwdz2 25440
		self.volume := _trackedItem.getMyTotalVolume.asStringForWebInterface();	//26 Oct 2012	NDL	Par 30622
		
		//14/06/2010 cnwdz2 par23027
		self.remarks := _trackedItem.remarks;
	//	self.expectedArrivalDate := _trackedItem.expectedArrivalDate.asStringJMT();
	//	self.expectedArrivalDate := _trackedItem.expectedArrivalDate.asStringForWebInterface();	//26 Oct 2012	NDL	30622
		self.expectedArrivalDate := _trackedItem.getExpectedArrivalDate.asStringForWebInterface();	//29 Jul 2013	NDL	Par 31763
	//	self.expectedArrivalTime := _trackedItem.expectedArrivalTime.asStringJMT();
	//	self.expectedArrivalTime := _trackedItem.expectedArrivalTime.asStringForWebInterface();	//26 Oct 2012	NDL	30622
		self.expectedArrivalTime := _trackedItem.getExpectedArrivalTime.asStringForWebInterface();	//29 Jul 2013	NDL	Par 31763
		
		if _trackedItem.isKindOf(CM_Container) then
			container := _trackedItem.CM_Container;
			self.humidity := container.getHumidity.asNullHumidity();	//02 Apr 2020	NDL	TFS 47958
			self.ventilation := container.getVentilation.asNullDecimal();
						
			if  container.isControlledAtmosphere then
				//cnwmc5 - PAR 32206 - 5 Sep 2013
				self.isControlledAtmosphere := isControlledAtmosphere.String;//app.getYesNo(container.isControlledAtmosphere);
				self.curtainsIn := container.getCurtainsIn.String;//app.getYesNo(container.getCurtainsIn);
				//29/05/2009 cnwdz2 refactored the following
				self.carbonDioxide := container.getCarbonDioxide.asNullCarbonDioxide();
				self.oxygen := container.getOxygen.asNullOxygen();
			endif;
			
			tmpInt := container.getCoolingType;
			create self.coolingType transient;
			self.coolingType.initFields(tmpInt);
			
			self.carriageTempC := container.getDisplayTemperature(false, true);
		
			//25/05/2009 cnwdz2 par19748
			self.packTempC := container.getDisplayPackTemperature(true); 
			//self.packDate := container.packDate.asStringJMT();
			self.packDate := container.packDate.asStringForWebInterface();	//26 Oct 2012	NDL	Par 30622
			if container.packTime &lt;&gt; NULL_TIME then
				//self.packTime := container.packTime.asStringJMT();
				self.packTime := container.packTime.asStringForWebInterface();	//26 Oct 2012	NDL	Par 30622
			endif;
			self.allowableTimeOffPower := container.getAllowableTimeOffPower.asNullDecimal();
			
			self.expiryDate := container.getExpiryDate.asStringForWebInterface;			// PAR #36682
		endif;
		
		if _trackedItem.carrier &lt;&gt; null then
			carrier := app.myRoot.allCarriers.getAtKey(_trackedItem.carrier);
			if carrier &lt;&gt; null then
				create self.carrier transient;
				self.carrier.setProxyFromObject(carrier);
			endif;
		endif;
		
		self.mark		:= _trackedItem.mark; //29/06/2011 cnwdz2 27784
		self.sealNum	:= _trackedItem.getSealNum();
		
		//cnwmc5 - 22/01/2013 - CCMS 2238 - PAR #30765
		self.sealNumCustoms		:= _trackedItem.getSealNumCustoms();
		self.sealNumShippers	:= _trackedItem.getSealNumShipper();
		self.sealNumVent		:= _trackedItem.getSealNumVent();
		
		subTerminal := _trackedItem.mySubTerminal; //22/04/2009 cnwdz2 ccms1735
		if subTerminal &lt;&gt; null then
			create self.mySubTerminal transient;
			self.mySubTerminal.setProxyFromObject(subTerminal);
		endif;
		
		self.hasAttachments	:= self.getAttachments(_trackedItem);	
		
		self.clientRef 			:= _trackedItem.clientRef;									// PAR #31800
		self.itemDesc 			:= _trackedItem.description;								// PAR #31800
		self.markNumber 		:= _trackedItem.markNumber;									// PAR #31800
		if _trackedItem.isKindOf(CM_BreakBulkGeneric) then									// PAR #31800
			self.colour 		:= _trackedItem.CM_BreakBulkGeneric.colour;					// PAR #31800
			self.numItems 		:= _trackedItem.CM_BreakBulkGeneric.unsplitQuantity.String;	// PAR #31700
		endif;																				// PAR #31800
		
		if _trackedItem.isKindOf(CM_Car) then												// PAR #32215
			self.colour				:= _trackedItem.CM_Car.colour;							// PAR #32215
			self.mark				:= _trackedItem.CM_Car.mark;							// PAR #32215
			self.model				:= _trackedItem.CM_Car.model;							// PAR #32215
			self.vehicleType			:= _trackedItem.CM_Car.carType;							// PAR #32215
			self.year				:= _trackedItem.CM_Car.year;							// PAR #32215
			self.trackingNumber1	:= _trackedItem.CM_Car.trackingNumber1;					// PAR #32215
			self.trackingNumber2	:= _trackedItem.CM_Car.trackingNumber2;					// PAR #32215
			self.docsReceived		:= _trackedItem.CM_Car.docsReceived.Date.asStringForWebInterface;	// PAR #32215
			self.docsSent			:= _trackedItem.CM_Car.docsSent.Date.asStringForWebInterface;		// PAR #32215
			self.docsCleared		:= _trackedItem.CM_Car.docsCleared.Date.asStringForWebInterface;	// PAR #32215
			self.docsReturned		:= _trackedItem.CM_Car.docsReturned.Date.asStringForWebInterface;	// PAR #32215
			self.isSelfPropelled		:= _trackedItem.CM_Car.selfPropelled;					// PAR #32215
			self.doors				:= _trackedItem.CM_Car.nbrDoors;						// PAR #32215
			self.newVehicle			:= _trackedItem.CM_Car.isNew;							// PAR #32215
		endif;																				// PAR #32215
	endif;
	
	if defISOType &lt;&gt; null then
		create self.isoType transient;
		self.isoType.setProxyFromObject(defISOType);
	endif;
		
	if defTransportMode &lt;&gt; null then
		create self.transportMode transient;
		self.transportMode.id			:= app.transportModeENumToString(defTransportMode);	
		self.transportMode.description	:= self.transportMode.id;
	endif;
			
	if defCargoType &lt;&gt; null then
		create self.cargoType transient;
		self.cargoType.setProxyFromObject(defCargoType);
	endif;
	
	
end;</source>
        <Parameter name="cargoId" type="String"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
