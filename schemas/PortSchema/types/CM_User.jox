    <JadeMethod name="canAccessWorkOrderStatus" id="e2b3e787-aee0-411f-9064-5ecb600229a8">
        <source>canAccessWorkOrderStatus(_workOrderStatus : Integer ; _term : CM_Terminal):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Mar 2023 navma1 ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task

*/

vars
	userTerminal  : CM_UserTerminal;
	securityRole  : CM_SecurityRole;
begin
	
	userTerminal := self.getUserTerminal(_term);
	securityRole := userTerminal.mySecurityRole;
	
	if securityRole = null then
		return false;
	endif;
	
	if  securityRole.allWorkOrderStatusMaint.includes(_workOrderStatus) then
		return true;
	endif;
	
	return false;
epilog

end;</source>
