    <JadeMethod name="txtBow_gotFocus" id="593a49b2-38da-486a-8976-6d335da7880d">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtBow_gotFocus(textbox: TextBox input) updating;
//--------------------------------------------------
// Created:	08 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.origValue := textbox.text;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtBow_lostFocus" id="9e122aae-4dac-47e6-9dfb-6acd4f2debca">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtBow_lostFocus(textbox: TextBox input) updating;
//--------------------------------------------------
// Created:	08 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	bow : Decimal[9,3];
begin
	if self.lastValidRow &gt; 1 then
		bow := self.tblPrefBerth.accessCell(self.lastValidRow, 3).cellControl.TextBox.text.Integer;	
		self.tblPrefBerth.accessedCell.text := bow.String;
		self.setMeterMarks(bow, self.lastValidRow);
	endif;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
