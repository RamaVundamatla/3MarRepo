    </JadeMethod>
    <JadeMethod name="trxCreateStopsForTIs" id="ebf7b4d4-15c7-4c78-9884-7f093bcd052a">
        <updating/>
        <source>trxCreateStopsForTIs(_tiSet : CM_TISet; _theStops : IntegerArray; _passport : CM_Passport input) updating;
//---------------------------------------
// Created: May 2006 By: cnwgd1
//---------------------------------------
vars
	tmpTI			: CM_TrackedItem;
	index			: Integer;
	stopsTable		: CM_StopsTable;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	// do the validation here
	self.raiseExceptionIfNull(_theStops, 'Stops Array');
	self.raiseExceptionIfNull(_tiSet, 'Cargo Set');	
	if _theStops.isEmpty() then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No Stops To Create');
	endif;
	if _tiSet.isEmpty() then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No Cargo Items selected');
	endif;	

// cnwrs1 May 2007 Par13378 Stops No longer necassary
/*	//CCMS1200 Can't add a CEDO stop or customs stop to a child as it may interfere with the parent discharge.
	foreach int in _theStops do
		tmpStop := app.myRoot.allStopsTable[int];
		if tmpStop &lt;&gt; null then
			if tmpStop.allProcessAreas.includes(StopProcessRemoveWhenChild) 
			or tmpStop.allSetAreas.includes(StopApplyExport) then
				isCEDOStop := true;
				break;
			endif;
		endif;
	endforeach;	
	if isCEDOStop then
		// cannot add CEDO stop to child cargo
		foreach tmpTI in _tiSet do
			if tmpTI.isChild then
				app.raiseCMException2(StopNotValidForCargoItem, tmpTI.id, tmpTI.getParent().id, null, null);
			endif;
		endforeach;	
	endif;
*/	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;
	
	// cnwrl1 11/05/2009 PAR 19574 - CCMS 1791 - start of coding
	// If the stop is for a stopsTable with requiresInfoType = DeliveryRelease
	// then the current deliveryRelease must be null.
	foreach index in _theStops do : stops_loop
		stopsTable	:= app.myRoot.allStopsTable[ index ];
		if stopsTable = null or stopsTable.requiresInfoType &lt;&gt; DeliveryRelease then
			continue stops_loop;
		endif;
		foreach tmpTI in _tiSet discreteLock do : ti_loop
			if tmpTI.deliveryRelease = null then
				continue ti_loop;
			endif;
			app.raiseCMException3(	WARN_STOP_ADD_CHECK,
									stopsTable.heading.display,
									tmpTI.id.display,
									app.getErrorString( Delivery_Release_Number ).display,
									null,
									null );
			return;
		endforeach ti_loop;
	endforeach stops_loop;
	
	app.setContinueCMExceptions(false);
	
	if _passport.myStateChangeController &lt;&gt; null then
		_passport.myStateChangeController.initForObjects(_tiSet);
	endif;
	
	beginTransaction;
	
	app.myUtilityCA.utlCreateStopsForTIs(_tiSet, _theStops, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_theStops" type="IntegerArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
