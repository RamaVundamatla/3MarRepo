    <JadeMethod name="createDefaultCriteriaLines" id="af0710e6-d95f-48da-abb8-30c5808ce0f7">
        <updating/>
        <source>createDefaultCriteriaLines() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
22 Dec 2022 navhl20 	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
12/09/2023	navkc1	CR 60429 Task 60445: UI - Cargo Review UI Changes - Queries
*/

vars
	criteriaLine			: CM_SelectorCriteriaLine;
	idx : Integer;
	now						: Date;
	//tblSheet				: JadeTableSheet;
	dateArray : DateArray;
	parentForm				: CM_BaseForm;
	criteriaHolder			: CM_QueryCriteriaLineHolder;
	tbl						: CM_DataTable;
	invalidLine				: Boolean;
begin
	tbl := self.tblCriteria;
	now := self.systemToLocalTime(app.actualTimeServer()).date();

	//has been created by the XML setup
	if not self.myCriteriaLineHolder.allCriteriaLines.isEmpty then
		return;
	endif;
	on Exception do app.handleDeletedObject(exception, criteriaLine, invalidLine);
	if (parentForm &lt;&gt; null) and (not parentForm.allSelectorCriteria.isEmpty) then
		foreach criteriaLine in parentForm.allSelectorCriteria do
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
			idx := tbl.addItem(criteriaLine.getDescriptionString);
			tbl.accessRow(idx).itemObject := criteriaLine;
	
			tbl.accessRow(idx).backColor := criteriaLine.getPerformanceColour;
		endforeach;
		
		return;
	endif;
	
	if (self.myQDef.mode &gt; BOLType_Min) and (self.myQDef.mode &lt; BOLType_Max) then
		self.myQDef.createCriteriaLine(CM_BOL::bolType.name, CM_QueryOperator.Operator_Equal, app.myRoot.allBOLTypes[self.myQDef.mode]);
		self.myQDef.createCriteriaLine(CM_BOL::isInward.name, CM_QueryOperator.Operator_Equal, true);
	//  CCMS 1262 Jan 2012 transaction enquiry and selector queries		
	elseif self.myQDef.type = CM_QueryDefinition.Transaction_Query_Type then
		// somewhat arbitrary criteria - important to show that there should be some selection based on either transaction type or date
		if self.myQDef.mode = CM_QueryDefinition.CargoTransaction_Query_Mode then
			self.myQDef.createCriteriaLine(CM_TITransaction::getTransactionType.name, CM_QueryOperator.Operator_Equal, app.myRoot.allTransactionTypes[TRANS_TYPE_REC_SHIP]);
			self.myQDef.createCriteriaLine(CM_TITransaction::dateTime.name, CM_QueryOperator.Operator_GreaterThan, now.cnEcAddMonths(-1));
		elseif self.myQDef.mode = CM_QueryDefinition.EventTransaction_Query_Mode then
			self.myQDef.createCriteriaLine(CM_EventTransaction::myEventType.name, CM_QueryOperator.Operator_Equal, app.myRoot.allEventTypesByType[EVT_VoyageArrival]);
			self.myQDef.createCriteriaLine(CM_EventTransaction::dateTime.name, CM_QueryOperator.Operator_GreaterThan, now.cnEcAddMonths(-1));
		elseif self.myQDef.mode = CM_QueryDefinition.HMSTransaction_Query_Mode then
			self.myQDef.createCriteriaLine(HMS_Transaction::transactionDT.name, CM_QueryOperator.Operator_GreaterThan, now.cnEcAddMonths(-1));
		elseif self.myQDef.mode = CM_QueryDefinition.BOLTransaction_Query_Mode then	//04 Nov 2019	NDL	TFS 47100
			self.myQDef.createCriteriaLine(CM_BOLTransaction::dateTime.name, CM_QueryOperator.Operator_GreaterThan, now.cnEcAddMonths(-1));
		elseif self.myQDef.mode = CM_QueryDefinition.Location_Activity_Query_Mode then	//13 Apr 2021	NDL	TFS 50906
			self.myQDef.createCriteriaLine(CMEVT_LocationActivity::dateTime.name, CM_QueryOperator.Operator_GreaterThan, now.cnEcAddMonths(-1));
		//Start 22.12.2022 navhl20 #54350[54269]
		elseif self.myQDef.mode = CM_QueryDefinition.WorkOrderTrans_Query_Mode then
			self.myQDef.createCriteriaLine(CM_WOTransaction::getTransactionType.name, CM_QueryOperator.Operator_Equal, app.myRoot.allTransactionTypes[TRANS_TYPE_WO_TIPACK_CREATED]);
			self.myQDef.createCriteriaLine(CM_WOTransaction::dateTime.name, CM_QueryOperator.Operator_GreaterThan, now.cnEcAddMonths(-1));
		//End 22.12.2022 navhl20 #54350[54269]
		endif;
	//14 May 2014	NDL	Par 34142
	elseif self.myQDef.type = CM_QueryDefinition.Invoicing_Query_Type then
		// No extras for this one, terminal gets added further down.
		
	//14 May 2014	NDL	Par 34142
	elseif self.myQDef.type = CM_QueryDefinition.Cash_Query_Type then
		create dateArray transient; dateArray.add(now.Date.cnEcAddMonths(-1)); dateArray.add(now.Date);
		if  self.myQDef.mode = CM_QueryDefinition.CashPayment_Query_Mode then
			self.myQDef.createCriteriaLine(CM_CashPayment::getReceiptDate.name, CM_QDateRange.Operator_Between, dateArray);
		elseif  self.myQDef.mode = CM_QueryDefinition.CashReceipt_Query_Mode then
			self.myQDef.createCriteriaLine(CM_CashPayment::dateTime.name, CM_QDateRange.Operator_Between, dateArray);
		endif;
		delete dateArray;
	elseif self.myQDef.type = CM_QueryDefinition.Audit_Query_Type then // TFS 8390
		if  self.myQDef.mode = CM_QueryDefinition.Audit_Query_Mode then
		//	self.createAndAddCriteriaLine(tblSheet,CM_AuditObject::type.name, CM_QueryOperator.Operator_Equal, "Update");
			self.myQDef.createCriteriaLine(CM_AuditObject::userCode.name, CM_QueryOperator.Operator_Equal, app.getMyUser);	//03 Sep 2019	NDL	TFS 45891 / 16 Oct 2019	NDL TFS 47013
			create dateArray transient; dateArray.add(now.Date - 1); dateArray.add(now.Date);
			self.myQDef.createCriteriaLine(CM_AuditObject::timestamp.name, CM_QueryOperator.Operator_Between, dateArray);	//03 Sep 2019	NDL	TFS 45891
		endif;
	endif;


	if self.myTerminal &lt;&gt; null then	
		if self.myQDef.type = CM_QueryDefinition.Invoicing_Query_Type then
			if self.queryMode = CM_QueryDefinition.InvoiceLine_Query_Mode then
				criteriaLine:=self.myQDef.createCriteriaLine(CM_InvoiceLine::getTerminal.name,  CM_QueryOperator.Operator_Equal, self.myTerminal);
			elseif self.queryMode = CM_QueryDefinition.Contract_Query_Mode then	//17/02/2023 navmv20 TFS 55626 Task 55688
				criteriaLine:=self.myQDef.createCriteriaLine(CM_InvoiceContract::myTerminal.name,  CM_QueryOperator.Operator_Equal, self.myTerminal); //17/02/2023 navmv20 TFS 55626 Task 55688
			else
				criteriaLine:=self.myQDef.createCriteriaLine(CM_Invoice::myTerminal.name,  CM_QueryOperator.Operator_Equal, self.myTerminal);
			endif;
		elseif self.myQDef.type = CM_QueryDefinition.TrackedItem_Query_Type then //12/09/2023	navkc1	CR 60429 Task 60445
			if self.queryMode = CM_QueryDefinition.TrackedItem_Query_Mode then
				criteriaLine:=self.myQDef.createCriteriaLine(CM_TrackedItem::myTerminal.name,  CM_QueryOperator.Operator_Equal, self.myTerminal);
			endif;
		endif;
		//12/09/2023	navkc1	CR 60429 Task 60445
		criteriaLine.setMyCriteriaLineHolder(self.myCriteriaLineHolder);
		idx := self.tblCriteria.addItem(criteriaLine.getDescriptionString);
		self.tblCriteria.accessRow(idx).itemObject := criteriaLine;
		self.tblCriteria.accessRow(idx).backColor := criteriaLine.getPerformanceColour;
	endif;
	//criteriaLine:=self.myQDef.createCriteriaLine(CM_Invoice::bank.name, CM_QueryOperator.Operator_Equal, self.myTerminal.getDefaultCompanyBank()); 17/02/2023 navmv20 TFS 55626 Task 55688
	//17/02/2023 navmv20 TFS 55626 Task 55688 - START
	if self.queryMode = CM_QueryDefinition.Contract_Query_Mode then
		criteriaLine:=self.myQDef.createCriteriaLine(CM_InvoiceContract::myBusinessUnit.name, CM_QueryOperator.Operator_Equal, self.myTerminal.getDefaultCompanyBank());
	elseif self.queryMode = CM_QueryDefinition.TrackedItem_Query_Mode then //12/09/2023	navkc1	CR 60429 Task 60445
		criteriaLine:=self.myQDef.createCriteriaLine(CM_TrackedItem::site.name, CM_QueryOperator.Operator_Equal, TI_SITE_ONSITE_str);
	else
		criteriaLine:=self.myQDef.createCriteriaLine(CM_Invoice::bank.name, CM_QueryOperator.Operator_Equal, self.myTerminal.getDefaultCompanyBank());
	endif;
	//17/02/2023 navmv20 TFS 55626 Task 55688 - END
	criteriaLine.setMyCriteriaLineHolder(self.myCriteriaLineHolder);
	idx := self.tblCriteria.addItem(criteriaLine.getDescriptionString);
	self.tblCriteria.accessRow(idx).itemObject := criteriaLine;
	self.tblCriteria.accessRow(idx).backColor := criteriaLine.getPerformanceColour;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="delete" id="86cb0b62-6d06-427d-8923-c9db34c0e60f">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	Task 55553: UI - New Selector Dialog
12/09/2023	navkc1	CR 60429 Task 60445: UI - Cargo Review UI Changes - Queries
*/

vars

begin
	if app.isValidObject(self.myCriteriaLineHolder) then
		delete self.myCriteriaLineHolder;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayCriteria" id="576888fc-1441-483d-b956-f6e62be4a705">
        <updating/>
        <source>displayCriteria()protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/

vars
	criteriaLine			: CM_SelectorCriteriaLine;
	queryProperty			: CM_QueryProperty;
	queryOperator			: CM_QueryOperator;
		
begin

	self.btnDown.enabled := false;	
	self.btnUp.enabled := false;	
	
	criteriaLine := self.tblCriteria.accessRow(self.tblCriteria.row).itemObject.CM_SelectorCriteriaLine;
	
	if criteriaLine = null then
		return;
	endif;
	
	queryProperty := self.myQDef.allQueryProperties[criteriaLine.myQueryProperty.propertyName];
	
	if queryProperty = null then
		//probably a deleted stop or todo task
		//query will still run but we can't set the controls below
		return;
	endif;
	
	queryOperator := queryProperty.allAllowedOperators[criteriaLine.myQueryOperator.description];


	self.tblCriteria.accessedRow.backColor := criteriaLine.getPerformanceColour;

	self.cmbAttribute.listObject := queryProperty;
	self.loadOperationCombo(queryProperty);
	self.cmbOperator.text := queryOperator.description;
	self.doCmbOperatorClick(criteriaLine.myQueryOperator);
	self.queryLineChanged := false;
	
	self.evaluateUpDown();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayResultColumns" id="0242d5fa-8e43-4f93-8895-8dffbef157a3">
        <source>displayResultColumns(_allColumns : StringArray; _theCargoBOLType : CM_CargoBOLType) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/
vars

	currentCol		: Integer;
	termStr,
	attrName		: String;
	queryProp		: CM_QueryProperty;
	tbl				: CM_DataTable;
	propDict		: CM_QueryPropertyDict;
	pos, revPos		: Integer;									// PAR #31155
	niceName		: String;									// PAR #31155
	measure			: String;									// PAR #31155
	fixedRowColour	: Integer;	//03 Sep 2019	NDL	TFS 4589
begin

	if self.myQDef = null then
		return;
	endif;
	
	propDict := self.myQDef.allQueryProperties;

	tbl := self.tblResults;
	tbl.columns := 0;
	if tbl.rows = 0 then
		tbl.rows := 1;
	endif;
	
	tbl.fixedRows := 1;
	
	foreach attrName in _allColumns do
		measure := null;										
		if attrName.isMeasurementType then						
			pos := attrName.pos("_", 1);						
			revPos := attrName.reversePos("_");					
			measure := attrName[revPos+1:end];					
			attrName := attrName[pos+1:revPos-pos-1];			
		endif;													
		queryProp := propDict[attrName];
		if queryProp = null then
			continue;
		endif;
		
		termStr := app.getTerminologyAlternate(_theCargoBOLType, self.myTerminal, queryProp.niceName, CM_TermExpressionSingular, queryProp.niceName);
		if measure &lt;&gt; null then								
			termStr := termStr &amp; Space &amp; measure;				
		endif;													
						
		currentCol := currentCol + 1;
		tbl.columns := currentCol;
		tbl.accessColumn(currentCol).itemObject := queryProp;
		tbl.setCellText(1, currentCol, termStr);
		fixedRowColour := queryProp.getPerformanceColour();
		if fixedRowColour = CM_QueryProperty.ComplexColour then	
			tbl.accessCell(1, currentCol).backColor := queryProp.getPerformanceColour();	
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_allColumns" type="StringArray"/>
        <Parameter name="_theCargoBOLType" type="CM_CargoBOLType"/>
    </JadeMethod>
    <JadeMethod name="displayResults" id="ea045fb5-8116-4361-85fd-787c2bfd18f1">
        <updating/>
        <source>displayResults() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/
vars
	any				: Any;
	partsDone,
	partsInJob		: Integer;
	monitor			: CMIF_Monitor;
	fixedRows		: Integer;
	lastUpdated		: Decimal [20];								
begin
	if not self.doMaxTableSizeCheck(self.myEnqController.numItemsFound, null) then
		return;
	endif;
  	
	self.modalDialogReturnValue := null;
	self.modalDialogShow(null, null, null, app.getErrorString(Cancel), app.getErrorString(CMUI_Displaying_Data), null);
	self.tblResults.rows := self.tblResults.fixedRows;
	partsInJob := self.myEnqController.allObjects.size();
	self.pbProgressBar.partsInJob := partsInJob;
	self.pbProgressBar.visible := true;
	fixedRows := self.tblResults.fixedRows;
	
	if app.myPassport.myCMIFMonitor = null then
		create monitor transient;
		app.myPassport.setMyCMIFMonitor(monitor);
	endif;	
	
	//foreach any in self.myEnqController.allObjects do
	foreach any in self.myEnqController.allObjects discreteLock do
		if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then		
			self.modalDialogUpdateInfo(app.getErrorString2(Displaying_items, partsDone.String, partsInJob.String));
			self.pbProgressBar.partsDone := partsDone;
			self.btnModalOpt2.doWindowEvents(0);
			self.frmModalDialog.refreshNow();
			if self.modalDialogReturnValue = self.ModalDialogReturn_Option2 then
				break;
			endif;
			lastUpdated := app.relativeMachineTime;														// PAR #35843
		endif;
		
		self.addResultsRow(any.Object);
		partsDone := partsDone + 1;
		
		if partsDone + fixedRows &gt;= JadeTableRowLimit then
			//user agreed earlier they only want first NNN
			break;
		endif;
	endforeach;
	

	self.staLine.caption := (self.tblResults.rows-self.tblResults.fixedRows).String &amp; ' rows found.';
	self.updateStatus();
epilog
	delete monitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doClear" id="6b87b529-d8db-4a1e-8566-4117d5224964">
        <updating/>
        <source>doClear()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
08/09/2023	navkc1	CR 60429 Task 60445: UI - Cargo Review UI Changes - Queries
*/

vars

begin
	self.cmbSelectorQuery.listIndex := 1;
	self.cmbAttribute.listIndex := -1;
	self.cmbOperator.listIndex := -1;
	self.cmbArgument.listIndex := -1;
	self.txtArgument.text := "";
	self.txtArgument1.text := "";
	self.txtFromDate.text := "";
	self.txtFromTime.text := "";
	self.txtToDate.text := "";
	self.txtToTime.text := "";
	self.tblResults.rows := 1;
	self.tblCriteria.rows := 0;
	self.txtQryDescription.text := null; //08/09/2023	navkc1	CR 60429 Task 60445
	self.txtQryName.text := null; //08/09/2023	navkc1	CR 60429 Task 60445
	self.myCurrentQuery := null; //08/09/2023	navkc1	CR 60429 Task 60445
	self.myCriteriaLineHolder.allCriteriaLines.purge();
	self.createDefaultCriteriaLines();
	self.staLine.caption := (self.tblResults.rows-self.tblResults.fixedRows).String &amp; ' rows found.';
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClearFilter" id="ded28318-fe39-4bf3-b987-e86442d5029d">
        <source>doClearFilter();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/

vars
	txtFilter	:	CMUI_TextBox;
	rowIndex	:	Integer;
begin
	txtFilter := self.txtArgFind;
	
	if txtFilter.text &lt;&gt; "" then
		txtFilter.text 				:= "";
		self.btnClear.enabled := true;
	endif;
	
	if txtFilter.text = "" then
		self.btnClear.enabled := false;
	endif;
	
	foreach rowIndex in 1 to self.tblArgument.rows do
		self.tblArgument.accessRow( rowIndex ).visible := true;
	endforeach;
	self.tblArgument.row:=1;
	self.tblArgument.topRow:=1;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbOperatorClick" id="d46d7516-1155-40be-864b-e39f4081dc1c">
        <updating/>
        <source>doCmbOperatorClick(_qOperator : CM_QueryOperator) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/
vars

begin
	self.queryLineChanged := true;
	self.setupArgumentView(_qOperator);

end;</source>
