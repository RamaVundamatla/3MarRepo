    <JadeMethod name="validateForDelete" id="008871c1-188d-4585-ad8b-77e6b3d74502">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     17 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gate	:CM_Gate;
begin
	inheritMethod();
	
	if not self.allGateDefaults.isEmpty then
		// used as default interchange area for 1 or more gates
		gate := self.allGateDefaults.first;
		
		app.raiseCMException1 (ICArea_Error1, gate.name, 'Interchange Area', null);
	endif;
epilog

end;</source>
    </JadeMethod>
