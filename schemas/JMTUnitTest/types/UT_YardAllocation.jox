    <JadeMethod name="iUpdateYAConfig" id="e9dc155d-36f1-4c02-8dcd-f75d3d130e85">
        <source>iUpdateYAConfig();
/*

Purpose:	Update YA Config		

Date		Who		Reason
22/04/2014	cnwma1	Initial creation

*/

vars
	pxyYaConfig,realYaConfig : CM_YAConfig;
	configOpts : CMIF_YAConfig;
	terminal   : CM_Terminal;
begin
	
	terminal := self.getTerminal();
	realYaConfig := terminal.myYAConfig;
	self.assertNotNull(realYaConfig);

	beginLoad;
	pxyYaConfig := realYaConfig.pxyCreateUpdateProxy();
	endLoad;
	pxyYaConfig.setPropertyValue("autoPlanOverstowRule", 1);
	pxyYaConfig.setPropertyValue("myYAOverstowHookCode",null);
	
	create configOpts transient;
	
	configOpts.autoPlanPreNotiEmail := "madwy@jadeworld.com";
	configOpts.fillOption := YAFillOption_InOrder ;

	app.myTrxUA.trxUpdateYAConfig(pxyYaConfig,configOpts,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog
	delete pxyYaConfig;
	delete configOpts;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tAddYA" id="90e00a29-c4eb-4fb7-a28f-f465d5350b1e">
        <source>tAddYA();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ta: CM_GridArea;
begin
	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");

	self.deleteYA("UT");
	
	create locations transient;
	locations.add(ta.allLocationsControllers.first.CM_YardController);
	ya := self.addYA1("UT", YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE, locations);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlocksIn.size = 1, "Locations not created");
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	self.assertTrueMsg(ya.allYABlocksIn.first.myDeckingOptions &lt;&gt; null, "Decking options are null");
epilog
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tAddYAForBlock" id="05978c0e-bf87-40a7-81ed-d51628d24f0d">
        <source>tAddYAForBlock();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	blockStack: CM_BlockStack;
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	operatorSet: CM_ObjectSet;
begin
	self.deleteYA("UT");
	deleteTerminalArea("UT_BLKST");
	blockStack := addBlockStack("UT_BLKST", 5, null);
	
	create locations transient;
	locations.add(blockStack.allLocationsControllers.first.CM_YardController);
	create operatorSet transient;
	operatorSet.add(app.myRoot.allOperators[self.getProfileStr(UT_Profile.P_OPERATOR)]);
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, operatorSet, locations);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlocksIn.size = 1, "Locations not created");
	self.assertTrueMsg(ya.allYABlocksIn.first.myDeckingOptions &lt;&gt; null, "Decking options are null");
	self.assertEqual(ya.allYABlocksIn.first.myDeckingOptions.allYALocationCellsIn.size, 1);
epilog
	delete locations;
	delete operatorSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tAddYAForOperator" id="63e2ed26-6f40-4999-8653-7669a5d57103">
        <source>tAddYAForOperator();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	operatorSet: CM_ObjectSet;
	ta: CM_GridArea;
begin
	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");
	self.deleteYA("UT");
	
	create locations transient;
	locations.add(ta.allLocationsControllers.first.CM_YardController);
	create operatorSet transient;
	operatorSet.add(app.myRoot.allOperators["DOUG"]);
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, operatorSet, locations);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlocksIn.size = 1, "Locations not created");
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	self.assertTrueMsg(ya.allCriteria.first.getDescription()  = "Operator (Item) DOUG", "Criteria has incorrect description " &amp; ya.allCriteria.first.getDescription());
	self.assertTrueMsg(ya.allYABlocksIn.first.myDeckingOptions &lt;&gt; null, "Decking options are null");
epilog
	delete locations;
	delete operatorSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tAddYAWithGroups" id="1763b83d-438e-43dc-ab6b-f70e876e200a">
        <source>tAddYAWithGroups();
// cnwndl1
//20 January 2009	cnwdw1	
//
vars
	st: CM_StraddleStack;
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	yaBlock1, yaBlock2, yaBlock3  : CM_YABlock;
	yaBlocksIn, yaBlocksOut: CM_YABlockArray;
	groupsIn, groupsOut: CM_YABlockGroupArray;
	group1, group2: CM_YABlockGroup;
begin
	self.deleteYA("UT");
	self.deleteTerminalArea("UTSTD");
	st := self.addStraddleStack("UTSTD", 6, 5, 3);

	create yaBlocksIn transient;
	create yaBlocksOut transient;
	
	yaBlock1 := st.allGridControllersByRowColumn[1, 1].yaBuildBlock(true, null);
	yaBlock1.allYardControllers.add(st.allGridControllersByRowColumn[1, 1]);
	yaBlock1.allYardControllers.add(st.allGridControllersByRowColumn[1, 2]);
	yaBlock1.setProxyDeckingOptions();
	
	yaBlock2 := st.allGridControllersByRowColumn[2, 1].yaBuildBlock(true, null);
	yaBlock2.allYardControllers.add(st.allGridControllersByRowColumn[2, 1]);
	yaBlock2.allYardControllers.add(st.allGridControllersByRowColumn[2, 2]);
	yaBlock2.setProxyDeckingOptions();

	yaBlock3 := st.allGridControllersByRowColumn[3, 1].yaBuildBlock(true, null);
	yaBlock3.allYardControllers.add(st.allGridControllersByRowColumn[3, 1]);
	yaBlock3.allYardControllers.add(st.allGridControllersByRowColumn[3, 2]);
	yaBlock3.setProxyDeckingOptions();

	// Create the Groups
	// Group 1 
	//	In
	//    UTSTD 01-01 01-02
	//    UTSTD 02-02 01-02
	//  Out 
	//    UTSTD 02-02 01-02
	//    UTSTD 01-01 01-02
	// Group 2 
	//  In
	//    UTSTD 03-03 01-02
	//  Out
	//    UTSTD 03-03 01-02
	create group1 transient;  
	yaBlocksIn.clear;
	yaBlocksIn.add(yaBlock1);
	yaBlocksIn.add(yaBlock2);
	yaBlocksOut.clear;
	yaBlocksOut.add(yaBlock2);
	yaBlocksOut.add(yaBlock1);
	group1.setProxy("Group 1", yaBlocksIn, yaBlocksOut);

	create group2 transient;  
	yaBlocksIn.clear;
	yaBlocksIn.add(yaBlock3);
	yaBlocksOut.clear;
	yaBlocksOut.add(yaBlock3);
	group2.setProxy("Group 2", yaBlocksIn, yaBlocksOut);

	create groupsIn transient;
	groupsIn.add(group1);
	groupsIn.add(group2);
	create groupsOut transient;
	groupsOut.add(group2);
	groupsOut.add(group1);
	
	ya := self.addYA1WithGroups("UT", YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE, groupsIn, groupsOut, YAFillOption_InOrder, YAFillOption_InOrder);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlockGroupsIn.size = 2, "Groups not created");
	self.assertEqual(ya.allYABlockGroupsIn.first.allYABlocksIn.size, 2);
	self.assertEqual(ya.allYABlockGroupsIn.first.allYABlocksOut.size, 2);
	self.assertEqual(ya.allYABlockGroupsIn.last.allYABlocksIn.size, 1);
	self.assertEqual(ya.allYABlockGroupsIn.last.allYABlocksOut.size, 1);
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	self.assertTrueMsg(ya.allYABlocksIn.first.myDeckingOptions &lt;&gt; null, "Decking options are null");
	
epilog
	delete yaBlocksIn;
	delete yaBlocksOut;
	delete groupsIn;
	delete groupsOut;
end;</source>
    </JadeMethod>
    <JadeMethod name="tBulkYardAllocations" id="9b6def5f-9051-4e1b-b74b-5f3ce5abb46a">
        <source>tBulkYardAllocations();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 26/09/2025	navdap1		Initial creation MTN-35616 ENT | Bulk Creation of Yard Allocations - Unit Tests
//02/10/2025	navkc1 JIRA 36151 AAT | RotaBox ISO Type and New Attributes - JADE
//
constants
	RebarCargoType : String = "REBAR";
	PaperCargoType : String = "UT_PAPER";
	MarkID : String = "MARK";
	IsoTypeID : String = "ISOT";
	ConsigneeID : String = "CONSEE";
	Voyage35616 : String = "VOYAGE35616";
	Block35616 : String = "BS35616";
	Mark35616_1 : String = "UT_35616_1";
	Mark35616_2 : String = "UT_35616_2";
	ISOType35616 : String = "3561";
	Consignee35616 : String = "35616";
	
vars
	terminal : CM_Terminal;
	currentDefaults, newDefaults : CM_YACriteriaTypeArray;
	realConfig, pxyConfig : CM_YAConfig;
	configOpts : CMIF_YAConfig;
	markCount, isoCount, consigneeCount : Integer;
	voyage : CM_Voyage;
	opStr : String;
	operator : CM_Operator;
	shippingLine : CM_ShippingLine;
	blockStack : CM_BlockStack;
	consignee : CM_ConsigneeConsignor;
	isoType : CM_ISOType;
	rebarCargoType, ut_PAPERCargoType : CM_CargoType;
	newTI : CM_TrackedItem;
	cmif : CMIF_BulkYAAgent;
	results : CM_BulkYACandidateResults;
	candidate : CM_BulkYACandidate;
	tiSet : CM_TISet;
	foundMark1, foundMark2, foundConsignee, foundISO : Boolean;
	ya : CM_YardAllocation;
	enabledYAs : ObjectSet;

begin
	// Basics - do we have a terminal, an operator, a shipping line, and a couple of cargo types
	terminal := self.getTerminal();
	self.assertNotNullMsg(terminal, "Terminal");
	opStr := self.getProfileStr(UT_Profile.P_OPERATOR);
	operator := app.myRoot.allOperators[opStr];
	self.assertNotNullMsg(operator, "Operator for " &amp; opStr);
	shippingLine := app.myRoot.allShippingLines["DAVE"];
	self.assertNotNullMsg(shippingLine, "Shipping Line DAVE");
	rebarCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(RebarCargoType);
	self.assertNotNullMsg(rebarCargoType, RebarCargoType &amp; " Cargo Type");
	ut_PAPERCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(PaperCargoType);
	self.assertNotNullMsg(ut_PAPERCargoType, PaperCargoType &amp; " Cargo Type");
	
	// Delete stuff - voyage (will also do cargo items), block stack, consignee, ISO type
	voyage := self.getVoyage(Voyage35616);
	self.deleteVoyage(Voyage35616);
	self.deleteTerminalArea(Block35616);
	self.deleteConsigneeConsignor(Consignee35616);
	self.deleteISOType(ISOType35616);
	// Check cargo items are gone
	self.assertNullMsg(terminal.allOnsiteTIsByIdCargoType[MarkID &amp; "00000001", rebarCargoType.id], "Rebar cargo items still exist on site");
	self.assertNullMsg(terminal.allOnsiteTIsByIdCargoType[IsoTypeID &amp; "0000001", TI_CargoType_Container], "Container cargo items still exist on site");
	self.assertNullMsg(terminal.allOnsiteTIsByIdCargoType[ConsigneeID &amp; "00000001", ut_PAPERCargoType.id], "UT_PAPER cargo items still exist on site");
	
	// Save off and set the default criteria for Bulk Yard Allocations
	create currentDefaults transient;
	realConfig := terminal.myYAConfig;
	realConfig.allDefaultBulkCriteriaTypes.copy(currentDefaults);
	
	// We're going to use Mark, ISO Type and Consignee as our default criteria
	create newDefaults transient;
	newDefaults.add(app.myRoot.allYACriteriaTypes[YACriteriaType_Mark]);
	newDefaults.add(app.myRoot.allYACriteriaTypes[YACriteriaType_ISO]);
	newDefaults.add(app.myRoot.allYACriteriaTypes[YACriteriaType_Consignee]);
	pxyConfig := app.createUpdateProxy(terminal.myYAConfig).CM_YAConfig;
	pxyConfig.setProxy(terminal, realConfig.allDefaultCriteriaTypes, realConfig.allDefaultSearchCriteriaTypes, newDefaults, realConfig.myYAOverstowHookCode.getCurrentJadeCode);
	create configOpts transient;
	configOpts.setFromTerminal(terminal);
	app.myTrxUA.trxUpdateYAConfig(pxyConfig, configOpts, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Passport has errors - " &amp; app.myPassport.getAllErrorsAndWarningsAsStr);
	self.assertTrueMsg(realConfig.allDefaultBulkCriteriaTypes.includes(app.myRoot.allYACriteriaTypes[YACriteriaType_Mark]), "YA Config doesn't include Mark");
	self.assertTrueMsg(realConfig.allDefaultBulkCriteriaTypes.includes(app.myRoot.allYACriteriaTypes[YACriteriaType_ISO]), "YA Config doesn't include ISO Type");
	self.assertTrueMsg(realConfig.allDefaultBulkCriteriaTypes.includes(app.myRoot.allYACriteriaTypes[YACriteriaType_Consignee]), "YA Config doesn't include Consignee");
	self.assertEqualMsg(realConfig.allDefaultBulkCriteriaTypes.size, 3, "YA Config doesn't have 3 Bulk YA Criteria");
	
	// Disable all yard allocations so they don't get in the way
	create enabledYAs transient;
	foreach ya in terminal.allYardAllocations where not ya.isDisabled do
		enabledYAs.add(ya);
	endforeach;
	self.disableAllYA(true);
	
	// Create a voyage, a block stack, a consignee and an ISO type
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage35616, "DAVEHOLD", operator.code, shippingLine.code, 2);
	self.assertNotNullMsg(voyage, "Voyage " &amp; Voyage35616);
	blockStack := self.addBlockStack(Block35616, 999, null);
	self.assertNotNullMsg(blockStack, "Block Stack " &amp; Block35616);
	consignee := self.addConsigneeConsignor(Consignee35616, "Created by Unit Test " &amp; method.qualifiedName, true, false, false);
	self.assertNotNullMsg(consignee, "Consignee " &amp; Consignee35616);
	isoType := self.addISOType(ISOType35616, "Created by Unit Test " &amp; method.qualifiedName, app.myRoot.allCargoTypesById[TI_CargoType_Container], true, false, false, false, false, false, false, false, false, false, false, false, false, true, false, false, false, false, false, false, false, false, false, 2200);
	self.assertNotNullMsg(isoType, "ISO Type " &amp; ISOType35616);
	
	// Create some cargo on site that matches some of the default criteria
	create tiSet transient;
	// Rebar with mark (split between 2 marks) and half with consignee
	markCount := 1;
	while markCount &lt;= 10 do
		newTI := self.addCargoBreakBulkAtLocation(MarkID &amp; markCount.String.padLeadingZeros(8), rebarCargoType, 10, blockStack.myLocationsController, terminal.getConfig(PortDestCode).String, TI_IMEX_STATUS_IMPORT, voyage, operator);
		beginTransaction;
		if markCount mod 2 = 0 then
			newTI.setPropertyValue(CM_TrackedItem::mark.name, Mark35616_1);
			newTI.setPropertyValue(CM_TrackedItem::consignee.name, consignee.code);
		else
			newTI.setPropertyValue(CM_TrackedItem::mark.name, Mark35616_2);
		endif;
		commitTransaction;
		tiSet.add(newTI);
		markCount += 1;
	endwhile;
	// Container with iso type and half with mark
	isoCount := 1;
	while isoCount &lt;= 10 do
		newTI := self.addContainerAtLocation(IsoTypeID &amp; isoCount.String.padLeadingZeros(7), operator, isoType.code, "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
		beginTransaction;
		newTI.setMyVoyage(voyage, app.myPassport);
		if isoCount mod 2 = 0 then
			newTI.setPropertyValue(CM_TrackedItem::mark.name, Mark35616_1);
		endif;
		commitTransaction;
		tiSet.add(newTI);
		isoCount += 1;
	endwhile;
	// UT_PAPER half with consignee and half with mark
	consigneeCount := 1;
	while consigneeCount &lt;= 10 do
		newTI := self.addCargoBreakBulkAtLocation(ConsigneeID &amp; consigneeCount.String.padLeadingZeros(8), ut_PAPERCargoType, 10, blockStack.myLocationsController, terminal.getConfig(PortDestCode).String, TI_IMEX_STATUS_IMPORT, voyage, operator);
		beginTransaction;
		if consigneeCount mod 2 = 0 then
			newTI.setPropertyValue(CM_TrackedItem::consignee.name, Consignee35616);
		else
			newTI.setPropertyValue(CM_TrackedItem::mark.name, Mark35616_1);
		endif;
		commitTransaction;
		tiSet.add(newTI);
		consigneeCount += 1;
	endwhile;
	
	// Make sure all of the cargo items are Import for the voyage we created
	foreach newTI in tiSet do
		self.assertTrueMsg(newTI.myVoyage = voyage, "Voyage for TI " &amp; newTI.id &amp; " is " &amp; newTI.voyageCode &amp; " instead of " &amp; voyage.code);
		self.assertTrueMsg(newTI.getImExStatus() = TI_IMEX_STATUS_IMPORT, "Imex Status for TI " &amp; newTI.id &amp; " is " &amp; newTI.getImExStatus().String &amp; " instead of " &amp; TI_IMEX_STATUS_IMPORT.String);
	endforeach;
	
	// Do the Bulk Yard Allocation calculations
	create cmif transient;
	cmif.setDetails(terminal, TI_IMEX_STATUS_IMPORT, tiSet);
	cmif.doCalculations();
	self.assertNotNullMsg(cmif.myBulkCandidateResults, "Candidate Results");
	
	// Check the results
	// There should be 4 candidates:
	// 1. Mark UT_35616_1 with 15 TIs
	// 2. Mark UT_35616_2 with 5 TIs
	// 3. ISO Type 3561 with 10 TIs
	// 4. Consignee 35616 with 10 TIs
	results := cmif.myBulkCandidateResults;
	self.assertEqualMsg(results.allCandidates.size, 4, "CM_BulkYACandidateResults has " &amp; results.allCandidates.size.String &amp; " candidates, should be 4");
	foreach candidate in results.allCandidates do
		if candidate.criteriaType = YACriteriaType_Mark then
			if candidate.criteriaValue = Mark35616_1 then
				foundMark1 := true;
				self.assertEqualMsg(candidate.allMatchingTIs.size, 15, "Candidate for Mark " &amp; Mark35616_1 &amp; " has " &amp; candidate.allMatchingTIs.size.String &amp; ", should be 15");
			elseif candidate.criteriaValue = Mark35616_2 then
				foundMark2 := true;
				self.assertEqualMsg(candidate.allMatchingTIs.size, 5, "Candidate for Mark " &amp; Mark35616_2 &amp; " has " &amp; candidate.allMatchingTIs.size.String &amp; ", should be 5");
			endif;
		elseif candidate.criteriaType = YACriteriaType_ISO then
			foundISO := true;
			self.assertEqualMsg(candidate.allMatchingTIs.size, 10, "Candiate for ISO Type " &amp; ISOType35616 &amp; " has " &amp; candidate.allMatchingTIs.size.String &amp; ", should be 10");
		elseif candidate.criteriaType = YACriteriaType_Consignee then
			foundConsignee := true;
			self.assertEqualMsg(candidate.allMatchingTIs.size, 10, "Candiate for consignee " &amp; Consignee35616 &amp; " has " &amp; candidate.allMatchingTIs.size.String &amp; ", should be 10");
		else
			self.assertIsOneOf(candidate.criteriaType, "Candidate has criteria type " &amp; candidate.criteriaType.String, YACriteriaType_Mark, YACriteriaType_ISO, YACriteriaType_Consignee);
		endif;
	endforeach;
	self.assertTrueMsg(foundMark1 and foundMark2 and foundISO and foundConsignee, "Found Mark 1: " &amp; foundMark1.getYesNo() &amp; CrLf &amp; "Found Mark 2: " &amp; foundMark2.getYesNo() &amp; CrLf &amp; " Found ISO Type: " &amp; foundISO.getYesNo() &amp; CrLf &amp; "Found Consignee: " &amp; foundConsignee.getYesNo());
	
	// Delete the results
	app.myTrxDA.trxDeleteBulkYACandidateResult(results, app.myPassport);
	self.assertTrueMsg(app.isValidObject(results) = false, "Bulk YA Candidate Results not deleted");
	
epilog
	// Restore the saved default criteria
	delete configOpts;
	delete pxyConfig;
	pxyConfig := app.createUpdateProxy(terminal.myYAConfig).CM_YAConfig;
	pxyConfig.setProxy(terminal, realConfig.allDefaultCriteriaTypes, realConfig.allDefaultSearchCriteriaTypes, currentDefaults, realConfig.myYAOverstowHookCode.getCurrentJadeCode);
	create configOpts transient;
	configOpts.setFromTerminal(terminal);
	app.myTrxUA.trxUpdateYAConfig(pxyConfig, configOpts, app.myPassport);
	delete configOpts;
	delete pxyConfig;
	
	// Re-enable yard allocations
	if enabledYAs &lt;&gt; null then
		beginTransaction;
		foreach ya in enabledYAs as CM_YardAllocation do
			ya.setPropertyValue(CM_YardAllocation::isDisabled.name, false);
		endforeach;
		commitTransaction;
	endif;
	delete enabledYAs;
	
	delete currentDefaults;
	delete newDefaults;
	delete tiSet;
	delete cmif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckAllocationOnlyRelease" id="bcf8e3e1-e1f3-4b99-8927-e923851a69a9">
        <source>tCheckAllocationOnlyRelease();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------------
// 10/11/2014	cnwdap1		Initial creation PAR #35092 Test Empty Release Strategy setting
//
vars
	straddleStack 	: CM_GridArea;
	blockStack		: CM_BlockStack;
	container		: CM_Container;
	ya				: CM_YardAllocation;
	release			: CM_BulkRelease;
	locations		: CM_LCArray;
	mtStrategy		: Integer;
	useBestPick		: Boolean;
	configOpts		: CMIF_YAConfig;
	realYAConfig	: CM_YAConfig;
	pxyYAConfig		: CM_YAConfig;
	operator		: CM_Operator;
	vvr				: CM_VehicleVisitRecord;
	truck			: CM_Vehicle;
	wle				: CM_WorkListEntry;
	singleGate		: CM_Gate;
	root			: CM_Root;
	terminal		: CM_Terminal;

begin
	// Scenario to check:
	//	Set Empty Container Release Strategy to "Allocations Only"
	//		Create a yard allocation covering a straddle stack, create a container in a block stack,
	//		a release request by type should fail to find the container.
	//	Set Empty Container Release Strategy to "Terminal Only" or "Allocations then Terminal"
	//		Release request by type should now find container
	self.deleteTerminalArea("UTSTRDP");
	self.deleteTerminalArea("UTBLOCKDP");
	self.deleteContainer("UTDP1234567");
	self.deleteYA("UTSTRDPYA");
	self.deleteReleaseRequest("UTRELREQDP");
	self.deleteVehicle("UTTRUCKDP");
	
	// Store the current value of the empty release strategy config so we can restore it later
	// And change it to Allocations Only
	terminal := self.getTerminal;
	self.setTerminalConfig(AutoPlanMTReleaseStrategy, 1);
	self.setTerminalConfig(UseBestPickDirector, true);
	
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	root := terminal.myRoot;
	operator := root.allOperators["MSC"];
	
	// create the yard areas
	straddleStack := self.addStraddleStack("UTSTRDP", 2, 2, 1);
	assertNotNullMsg(straddleStack, "Straddle Stack UTSTRDP not created");
	blockStack := self.addBlockStack("UTBLOCKDP", 10, null);
	assertNotNullMsg(blockStack, "Block Stack UTBLOCKDP not created");
	
	// create the container and move it to UTBLOCK
	operator := root.allOperators["MSC"];
	container := self.createContainer("UTDP1234567", "4400", "MT", operator, false).CM_Container;
	assertNotNullMsg(container, "Container UTDP1234567 not created");
	self.move(container, blockStack);
	assertEqualMsg(container.myPrimaryActualLocation, blockStack.myLocationsController, "Container UTDP1234567 not in UTBLOCKDP but in " &amp; container.myPrimaryActualLocation.getFullId);
	assertEqualMsg(container.operatorCode, "MSC", "Container UTDP1234567 has the wrong operator - should be MSC, is " &amp; container.operatorCode);
	
	// create a yard allocation that matches the container but does not cover the block stack
	create locations transient;
	locations.add(straddleStack.allLocationsControllers.first);
	locations.add(straddleStack.allLocationsControllers.last);
	ya := self.addYA("UTSTRDPYA", YACriteriaType_CargoType, "CONT",
							YACriteriaType_OperatorItem, "MSC",
							YACriteriaType_Commodity, "MT",
							locations, null	);
	assertNotNullMsg(ya, "Yard Allocation UTSTRDPYA not created");
	
	// Create the release request
	self.opts.purge;
	self.opts.addAssoc("ISOType", "4400");
	self.opts.addAssoc("FullRelease", false);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("Operator", operator);
	release := addReleaseByTypeRequestOpts(RELEASE, BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(release);
	
	// Auto plan the release - should fail because the only container that matches is not in an area covered by an allocation
	// Gate Out
	self.opts.purge();
	self.opts.addAssoc("release", release);
	vvr := self.gateOutContainer("UTTRUCKDP", "", "UTDRIVER", null, true, singleGate ,null);
	truck := self.getVehicle("UTTRUCKDP");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);

	// actual test
	wle := release.allRequestsBeingActioned.first.allWorkListEntries.first;
	self.assertEqualMsg(wle.myTrackedItem, null, "WLE has a tracked item assigned");
	self.assertTrueMsg(wle.allRTQueueEntries.isEmpty, "WLE has a queue entry and should not");
	
	// Reset Empty Release Strategy to Allocations Then Terminal
	self.setTerminalConfig(AutoPlanMTReleaseStrategy, 2);
	
	// now try planning the release again - should work this time
	self.queueWLE(wle);
	self.assertTrueMsg(not wle.allRTQueueEntries.isEmpty, "WLE has no queue entry and should have one");
		
epilog

	delete locations;
	delete configOpts;
	delete pxyYAConfig;
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;testing1&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tClearOnDepartYA" id="858578d0-05ec-445c-977b-9a40805a77ef">
        <source>tClearOnDepartYA();
//cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 June 2011	cnwndl1	Initial creation	Par 27786

*/

vars

	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ta: CM_GridArea;
	voyage, voy : CM_Voyage;
	criteria : CM_YACriteria;
	iter : Iterator;
	
begin

	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");

	self.deleteYA("UTAuto");
	
	create locations transient;
	locations.add(ta.allLocationsControllers.first.CM_YardController);
	ya := self.addYA1("UTAuto", YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE, locations);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlocksIn.size = 1, "Locations not created");
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	self.assertTrueMsg(ya.allYABlocksIn.first.myDeckingOptions &lt;&gt; null, "Decking options are null");
	
	//set expiryType to "clear on voyage departed".
	beginTransaction;
	ya.setPropertyValue("expiryType",YAExpiryType_VoyageClear);
	commitTransaction;
	self.assertTrueMsg(ya.expiryType = YAExpiryType_VoyageClear, "expiryType not set to YAExpiryType_VoyageClear");
	self.assertTrueMsg( not ya.haveAnyAssocVoyagesDeparted, "Yard Allocation incorrectly showing as having departed voyage(s)");
	
	self.deleteYA("UTAuto");
	
	//get a departed voyage
	iter := self.getTerminal.allVoyagesByDepartDTCode.createIterator;
	while iter.next(voy) do
		if voy.departedDT.isValid then
			voyage := voy;
			break;
		endif;
	endwhile;
	delete iter;
	
	self.assertTrueMsg( voyage &lt;&gt; null, "No voyage found.");
	self.assertTrueMsg( voyage.hasDeparted, "Voyage found is not departed.");
	
	ya := self.addYA1("UTAuto", YACriteriaType_Voyage, voyage.code, locations);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlocksIn.size = 1, "Locations not created");
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	self.assertTrueMsg(ya.allYABlocksIn.first.myDeckingOptions &lt;&gt; null, "Decking options are null");
	
	//set expiryType to "clear on voyage departed".
	beginTransaction;
	ya.setPropertyValue("expiryType",YAExpiryType_VoyageClear);
	//06 Sep 2011	NDL Par 28111
	ya.setPropertyValue("projected20",10);
	ya.setPropertyValue("projected30",10);
	ya.setPropertyValue("projected40",10);
	ya.setPropertyValue("projected45",10);
	ya.setPropertyValue("projected53",10);
	commitTransaction;
	
	self.assertTrueMsg(ya.expiryType = YAExpiryType_VoyageClear, "expiryType not set to YAExpiryType_VoyageClear");
	self.assertTrueMsg( ya.haveAnyAssocVoyagesDeparted, "Yard Allocation NOT showing as having departed voyage(s)");
	
	app.myTrxUA.trxClearYardAllocation(ya, app.myPassport);
	
	self.assertTrueMsg(ya.allYardControllers.isEmpty, "Locations not cleared - 1");
	self.assertTrueMsg(ya.allYABlocksIn.isEmpty, "Locations not cleared - 2");
	self.assertTrueMsg(ya.allYABlocksOut.isEmpty, "Locations not cleared - 3");
	self.assertTrueMsg(ya.allTerminalAreas.isEmpty, "Locations not cleared - 4");
	//06 Sep 2011	NDL Par 28111
	self.assertTrueMsg(ya.projected20 = 0, "Projected 20 not cleared");
	self.assertTrueMsg(ya.projected30 = 0, "Projected 30 not cleared");
	self.assertTrueMsg(ya.projected40 = 0, "Projected 40 not cleared");
	self.assertTrueMsg(ya.projected45 = 0, "Projected 45 not cleared");
	self.assertTrueMsg(ya.projected53 = 0, "Projected 53 not cleared");
	self.assertTrueMsg(ya.projectedGC = 0, "Projected GC not cleared");	//31 Mar 2021	NDL	TFS 49912
	
	foreach criteria in ya.allCriteria do
		if criteria.myYACriteriaType.type = YACriteriaType_Voyage then
			if not criteria.myYAData.CM_YADataObjects.allObjects.isEmpty then
				self.assertTrueMsg(false, "Voyage not cleared");
			endif;
		endif;
	endforeach;
	
	self.deleteYA("UTAuto");
	
	//get a NON departed voyage

	voyage := self.getTerminal.allVoyagesByDepartDTCode.first();
	self.assertTrueMsg( voyage &lt;&gt; null, "No voyage found.");
	self.assertTrueMsg( not voyage.hasDeparted, "Voyage found IS departed.");
	
	ya := self.addYA1("UTAuto", YACriteriaType_Voyage, voyage.code, locations);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlocksIn.size = 1, "Locations not created");
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	self.assertTrueMsg(ya.allYABlocksIn.first.myDeckingOptions &lt;&gt; null, "Decking options are null");
	
	//set expiryType to "clear on voyage departed".
	beginTransaction;
	ya.setPropertyValue("expiryType",YAExpiryType_VoyageClear);
	commitTransaction;
	
	self.assertTrueMsg(ya.expiryType = YAExpiryType_VoyageClear, "expiryType not set to YAExpiryType_VoyageClear");
	self.assertTrueMsg( not ya.haveAnyAssocVoyagesDeparted, "Yard Allocation is incorrectly showing as having departed voyage(s)");
	
	app.myTrxUA.trxClearYardAllocation(ya, app.myPassport);
	
	self.assertTrueMsg(not ya.allYardControllers.isEmpty, "Locations incorrectly cleared - 1");
	self.assertTrueMsg(not ya.allYABlocksIn.isEmpty, "Locations incorrectly cleared - 2");
	self.assertTrueMsg(not ya.allYABlocksOut.isEmpty, "Locations incorrectly cleared - 3");
	self.assertTrueMsg(not ya.allTerminalAreas.isEmpty, "Locations incorrectly cleared - 4");
	
	foreach criteria in ya.allCriteria do
		if criteria.myYACriteriaType.type = YACriteriaType_Voyage then
			if criteria.myYAData.CM_YADataObjects.allObjects.isEmpty then
				self.assertTrueMsg(false, "Voyage incorrectly cleared");
			endif;
		endif;
	endforeach;
		
epilog
	delete iter;		// PAR #27874
	delete locations;
	self.deleteYA("UTAuto");
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tDeleteYA" id="34854d19-3491-45fe-9890-b178c57e8421">
        <source>tDeleteYA();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	locations : CM_LCArray;
	ta: CM_GridArea;
begin
	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");
	self.deleteYA("UTTEST");
	create locations transient;
	locations.add(ta.allLocationsControllers.first.CM_YardController);
	self.addYA1("UTTEST", YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE, locations);

	self.deleteYA("UTTEST");
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Delete failed");
epilog
delete locations;	
end;</source>
