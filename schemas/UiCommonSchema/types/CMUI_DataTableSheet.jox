<GUIClass name="CMUI_DataTableSheet" id="1b64614f-395e-4007-8458-0c700dd3360b">
    <superclass name="CMUI_Sheet"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ExplicitInverseRef name="myDataTable" id="d33b7c75-41e6-4e34-8af3-960f84267a15">
        <embedded/>
        <type name="CM_DataTable"/>
        <access>readonly</access>
        <Inverse name="CM_DataTable::mySheet"/>
    </ExplicitInverseRef>
    <JadeMethod name="setCaption" id="105eea55-4267-4594-a585-68457a171cf0">
        <source>setCaption(_definition : Integer;_sheet : CMUI_DataTableSheet input;_locale : CM_Locale);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 November 2009	cnwmd1	Initial creation

*/

vars
	rowCount : Integer;
	rowDisplay : String;
begin
	if self.myDataTable &lt;&gt; null then
		rowCount := self.myDataTable.rows - self.myDataTable.fixedRows;
	endif;
	
	if rowCount &gt; 0 then
		rowDisplay := ' (' &amp; rowCount.String &amp; ')';
	endif;
	
	_sheet.translateCaption(_definition, _locale);
	_sheet.caption := _sheet.caption &amp; rowDisplay;
epilog

end;</source>
        <Parameter name="_definition" type="Integer"/>
        <Parameter name="_sheet" type="CMUI_DataTableSheet" usage="input"/>
        <Parameter name="_locale" type="CM_Locale"/>
    </JadeMethod>
