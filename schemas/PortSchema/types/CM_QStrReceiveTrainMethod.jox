    <JadeMethod name="setComboValues" id="2b2e3310-bf4c-4b1a-b0ae-05e73b59693d">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);

constants
	Max_Entries = 200;
vars
	count			: Integer;
	trainCode,
	queryTrainCode	: String;
	qrl				: CM_QReferenceLookup;
	trainDict		: CM_TrainByDepatureDTDict;
	currentTrain,
	train			: CM_Train;
	tmpTerm 		: CM_Terminal;
begin

	_combo.clear;
	
	if app.myPassport = null then
		return;
	endif;
	tmpTerm := app.myPassport.myTerminal;
	if tmpTerm = null then
		return;
	endif;
	
	if _queryOperator.isKindOf(CM_QStringLookup) then
		queryTrainCode := _queryOperator.CM_QStringLookup.selectionValue;
	elseif _queryOperator.isKindOf(CM_QStringLookupNotEqual) then
		queryTrainCode := _queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;
	create trainDict transient;
	self.getTrainsForTerminal( tmpTerm, trainDict );	//27 Apr 2021	NDL	TFS 50906
/*	foreach train in tmpTerm.allTrainsOnTerminal do
		if train.isNullTrain() then
			continue;
		endif;
		trainDict.add(train);
	endforeach;
	foreach train in tmpTerm.allTrainsDepartedReversed do
		if train.isNullTrain() then
			continue;
		endif;
		// don't show older trains past an arbitrary limit
		count := count + 1;
		if count &gt; Max_Entries then
			break;
		endif;
		trainDict.add(train);
	endforeach; */
	
	foreach train in trainDict do
		trainCode := train.getCodeDate();
		_combo.itemObject[_combo.addItem(trainCode)] := train;
		if trainCode = queryTrainCode then
			currentTrain := train;
		endif;
	endforeach;
	_combo.listObject := currentTrain;
	
epilog
	delete trainDict;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="1fdf536d-8312-403b-ae27-ec6910c9141d">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2021	navndl1	Initial creation	TFS 50906

*/

vars
	crit			: CM_SelectorCriteriaLine;
	train			: CM_Train;
	idx				: Integer;
	os				: ObjectSet;
	ut				: CM_UserTerminal;
	obj				: Object;
	multiTerminal	: Boolean;
	voyDescr, propname		: String;
	selectionValue	: Boolean;
	trainDict : CM_TrainByDepatureDTDict; 
begin
	
	_tbl.rows := 0;
	
	if _params = null then
		return;
	endif;
	
	propname := "myTerminal";
	crit := _params.allCriteriaByPropertyName.getAtKeyGeq(propname, null);
	if crit &lt;&gt; null and crit.propName &lt;&gt; propname then
		crit := null;
	endif;
	
	if crit = null then
		propname := "getTerminal";
		crit := _params.allCriteriaByPropertyName.getAtKeyGeq(propname, null);
		if crit &lt;&gt; null and crit.propName &lt;&gt; propname then
			crit := null;
		endif;
	endif;

	create os transient;
	
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(os);
	else
		foreach ut in _passport.myUser.allUserTerminals do
			os.add(ut.getMyTerminal);
		endforeach;
	endif;
	
	multiTerminal := (os.size &gt; 1);
	
	foreach obj in os do
	
		create trainDict transient;
		self.getTrainsForTerminal( obj.CM_Terminal, trainDict );
		
		foreach train in trainDict do
			selectionValue := false;
			if _operator &lt;&gt; null then
				if _operator &lt;&gt; null and 
				   _operator.CM_QStringIsOneOf.allSelectionValues.includes(train.code) then
					selectionValue := true;
				endif;
				
				_tbl.accessRow(_tbl.addItem(selectionValue.cnEcGetTableCheckBoxValue &amp; Tab &amp; train.code)).itemObject := train;
			endif;
			
		endforeach;
		
		delete trainDict;

		if idx &gt;= JadeTableRowLimit then		
			app.msgBox('Maximum number of entries in table exceeded.  Only the first ' &amp; JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
			break;
		endif;

	endforeach;
	
epilog
	delete os;
	delete trainDict;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="20192408-ef62-410f-9300-ed8d710deae0">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2021	navndl1	Initial creation	TFS 50906

*/

vars
	str				: String;
	numRows,
	idx				: Integer;
	train				: CM_Train;
	trainStrArray			: StringArray;  

begin

	create trainStrArray transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			train := _tbl.accessRow(idx).itemObject.CM_Train;
			trainStrArray.add(train.code);
		endif;
	endforeach;
	
	_op.setSearchValue(trainStrArray);

epilog
	delete trainStrArray;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="5af84d6d-b9e4-4f1d-a87c-db645b89ae94">
        <source>translateToDisplayValue(_value: Any): String;

vars

begin
	if _value.isKindOf (CM_Train) then	
		if _value &lt;&gt; null then
			return _value.CM_Train.getCodeDate();
		else
			return null;
		endif;
	endif;
	
	return _value.String;

end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="469b117d-99b1-44d8-9d4c-66c419ab59fe">
        <source>translateToSearchValue(_value: Any): Any;

vars
	invalidObj 		: Boolean;
	object			: CM_Train;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			
			return _value;
		endif;

		if _value.isKindOf(CM_Train) then
			object := _value.CM_Train;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.getCodeDate();
	endif;
	
	return returnVal;

end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="d8839c62-1137-4ba0-aa28-b211d0bfc519">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/09/2019	jlgdap1		Initial creation TFS 45769 JMT web Portal selector query parameters
//
vars
	pos : Integer;

begin
	if _value.isKindOf(CM_Train) then
		return _value.CM_Train.code;
	elseif _value.isKindOf(String) then
		pos := _value.String.pos(Space, 1);
		if pos &lt;&gt; null then
			return _value.String[1:pos-1];
		else
			return _value.String;
		endif;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
