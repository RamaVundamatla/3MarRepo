    <JadeMethod name="doClearComplete" id="efb394c6-15e5-4f40-a576-c6fe5f536939">
        <source>doClearComplete();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2009	cnwml2	Initial creation
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	self.chkReconciled.value := false;
	self.dateComplete.text := app.actualTimeServer.date.asStringJMT();// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.txtCompleteReaso.text := null;
epilog

end;</source>
