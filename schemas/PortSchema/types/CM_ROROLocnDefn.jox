    </JadeMethod>
    <JadeMethod name="getRotationStringForJRW" id="6a5e8287-4209-4173-9a4e-581ad5e622d5">
        <source>getRotationStringForJRW() : String;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 16 November 2011
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
// 16/11/2011	cnwsh3		CCMS MES 1009 PLAN Interface PAR28479
//							For PLANS report output.  No rule exists about a return string outside of the collection sizes at the moment.
//							Has not been established if a different value should be returned in the event of a collection of a different size.
//----------------------------------------------------------------------
//07 Jan 2013	cnwrs1	Par 30863	EDI RORO Deck Plan and Stowage Advice rotation 1X1
vars
	collectionSize : Integer;
begin
	collectionSize := self.allPlannedRotatedLocnDefns.size();
	
	if collectionSize = 0 then
		return null;
	elseif collectionSize = 1 then
		return '1X1';
	elseif collectionSize = 3 then
		return '1X3';
	elseif collectionSize = 5 then
		return '1X5';
	elseif collectionSize = 6 then
		return '2X3';
	elseif collectionSize = 10 then
		return '2X5';
	endif;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStatusDescription" id="c49768b1-3314-4ce5-a34a-9d75abbd164a">
        <source>getStatusDescription() : String;
// ---------------------------------------------------------------------------
// Created:     21 December 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
// 24/09/2012	cnwcs5	par 30089 - typo
vars
	temp : String;
begin
	if self.myAdjacentSlotAft &lt;&gt; null then
		temp := " AFT: " &amp; self.myAdjacentSlotAft.code;
	else
		temp := " NO AFT ";
	endif;
	
	if self.myAdjacentSlotFwd &lt;&gt; null then
		temp := temp &amp; " FWD: " &amp; self.myAdjacentSlotFwd.code;
	else
		temp := temp &amp; " NO FWD ";
	endif;
	
	if self.isRotatable then
		temp := temp &amp; " Is Rotatable";			// par 30089 Sept 2012
	else
		temp := temp &amp; " Is Not Rotatable";		// par 30089 Sept 2012
	endif;
	
	return temp;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTopRightLocnForRotationGrp" id="b6d3ade7-2cd2-45d5-9f21-83ee36178c78">
        <source>getTopRightLocnForRotationGrp(_items, _split : Integer) : CM_ROROLocnDefn;
// ---------------------------------------------------------------------------
// Created:     06 March 2012 by cnwab1
