    <JadeMethod name="loadGateLanes" id="edcbcd41-2ef5-4007-a5cc-f02b8d37f55f">
        <source>loadGateLanes()protected;
// ---------------------------------------------------------------------------
// Created:	14 May 2008 By Graeme Black cnwgb1 PAR 16483
// Status: Unfinished
// ---------------------------------------------------------------------------
// 25/08/2009	cnwcs5	ccms 1061 - road ops for changes
vars
	table		: CM_DataTable;
	lc			: CM_LocationsController;
	lane 		: CM_LaneController;
	idx 		: Integer;
	rowStr 		: String;
	inStr 		: String;
	outStr 		: String;
	closedStr 	: String;
begin
	if self.myAreaWithLanes = null then
		return;
	endif;
	
	table := self.tblGateLanes;
	
	foreach lc in self.myAreaWithLanes.allLocationsControllers do
		if not lc.isLaneController then
			continue;
		endif;
		
		lane 		:= lc.CM_LaneController;	
		closedStr 	:= UNCHECKED;
		inStr 	  	:= UNCHECKED;
		outStr 	  	:= UNCHECKED;
		
		if lane.laneDirection = lane.Is_Undecided then
			closedStr	:= CHECKED;
		elseif lane.laneDirection = lane.Is_In_Lane then
			inStr 		:= CHECKED;
		elseif lane.laneDirection = lane.Is_Out_Lane then
			outStr 		:= CHECKED;
		endif;
		
		if lane.isUnavailable then
			closedStr	:= CHECKED;
		endif;
		
		rowStr 	:= lane.getLaneNumber.String &amp; Tab &amp; inStr &amp; Tab &amp; outStr &amp; Tab &amp; closedStr;
		idx 	:= table.addItemObject(app.createUpdateProxy(lane), null);

		table.setCellValueByName (ETRow_GateLaneId, idx, lane.getLaneNumber.String);
		table.setCellValueByName (ETRow_IsInwards, idx, inStr);
		table.setCellValueByName (ETRow_IsOutwards, idx, outStr);
		table.setCellValueByName (ETRow_IsClosed, idx, closedStr);

		if lane.lockDirection then
			// don't let them change in/out
			table.accessCell (idx, table.getColumnByRowName (ETRow_IsInwards)).enabled	:= false;
			table.accessCell (idx, table.getColumnByRowName (ETRow_IsOutwards)).enabled	:= false;
		endif;
	endforeach;
	
	table.sortColumn[1] := 1;    
	table.sortAsc[1]    := true;
	table.sortCased[1]  := false;
	
	table.resort;
	
	table.parentAspect 		:= Table.ParentAspect_StretchBoth;
	table.userInputEnabled 	:= true;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblGateLanes_change" id="5791f2f5-792e-4b79-a8cf-de290de8bba4">
        <controlMethod name="Table::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblGateLanes_change(_table: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:	15 May 2008 By Graeme Black cnwgb1 PAR 16483
// Status: Unfinished
// ---------------------------------------------------------------------------
// 25/08/2009	cnwcs5	ccms1061 - closed independent of in/out
vars
	col_in, col_out	:Integer;
	cell			:JadeTableCell;
begin
	col_in 		:= _table.getColumnByRowName (ETRow_IsInwards);
	col_out		:= _table.getColumnByRowName (ETRow_IsOutwards);
	
	if _table.column = col_in then
		cell := _table.accessCell (_table.row, col_in);
		cell.text := CHECKED;
		cell := _table.accessCell (_table.row, col_out  );
		cell.text := UNCHECKED;
	elseif _table.column = col_out then
		cell := _table.accessCell (_table.row, col_out );
		cell.text := CHECKED;
		cell := _table.accessCell (_table.row, col_in );
		cell.text := UNCHECKED;
	endif;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="bce01996-6227-4c22-8932-d9aba2b63363">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008409, locale);
end;</source>
    </JadeMethod>
</GUIClass>
