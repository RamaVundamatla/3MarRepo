    <JadeMethod name="tblWagons_contextMenu" id="8d3d2e66-22c4-4c54-b79a-441a34c2e314">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWagons_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2009	cnwmd1	Initial creation

*/

vars
	wagon : CM_Wagon;
	
begin

	//self.mnuContext.visible := true;	// PAR 20108
	self.mnuInspectObject.visible := self.mnuInspectObject.userObject &lt;&gt; null and app.isAllowedToInspect();
	self.mnuColumnOrganiser.visible := true;
	self.mnuInTransit.visible := true;
	self.mnuInTransitNO.visible := true;
	self.mnuWagonCargoEnOUT.visible := true;
	self.mnuWagonCargoEnqIN.visible := true;
//	self.mnuWagonConfirmIN.visible := true;
//	self.mnuWagonConfirmOUT.visible := true;
	self.mnuWagonAudits.visible := false;	//12 June 2013	NDL	Par 31687
	
	wagon := self.tblWagons.allSelectedObjects.first.CM_Wagon;//cnwas3 PAR21447 CCMS SFW 1067 begin
	if wagon &lt;&gt; null and not wagon.allDamageInstanceByPos.isEmpty() then
		self.mnuWagonDamage.visible := true;
	else
		self.mnuWagonDamage.visible := false;
	endif;													//cnwas3 PAR21447 end
	
	//08 Jun 2020	NDL	TFS 49498
	if wagon &lt;&gt; null then
		self.mnuWagonConfirmIN.enabled := not wagon.confirmed;
		self.mnuWagonConfirmOUT.enabled := not wagon.confirmedOutwards and wagon.confirmed;
	else
		self.mnuWagonConfirmIN.enabled := false;
		self.mnuWagonConfirmOUT.enabled := false;
	endif;
	
	
	self.mnuWagonDelete.visible := true;
	self.mnuWagonEdit.visible := true;
	self.mnuWagonEnq.visible := true;
	self.mnuWagonNew.visible := true;
	self.mnuWagonTrans.visible := true;
	self.mnuSep1.visible := true;
	self.mnuSep2.visible := true;
	self.mnuSep3.visible := true;
	
	self.mnuPrint.visible := false;
	self.mnuRefresh.visible := false;
	self.mnuSep4.visible := false; 
	
	self.mnuWagonAudits.visible := wagon &lt;&gt; null and wagon.hasAudits;	//14 Jan 2021	NDL	TFS 50152

	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuInTransit.visible := false;
		self.mnuInTransitNO.visible := false;
		self.mnuWagonCargoEnOUT.visible := true;
		self.mnuWagonCargoEnqIN.visible := true;
		self.mnuWagonConfirmIN.visible := false;
		self.mnuWagonConfirmOUT.visible := false;	
		
		self.mnuWagonDelete.visible := false;
		self.mnuWagonEdit.visible := false;
		self.mnuWagonNew.visible := false;

	endif;
	
	return self.showContextMenu(mnuContext, table, conwin, mouse, x, y);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
