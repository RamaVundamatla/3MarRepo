    <JadeMethod name="cleanUpFiles" id="9d6f8d60-745e-4219-8add-32fad95d2e20">
        <source>cleanUpFiles(  _defDescription : String; _folderName : String ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 January 2014	cnwndl1	Initial creation	Par 33264

*/

vars

	searchName : String;
	ff : FileFolder;
	fileNode : FileNode;

begin

	searchName :=  _folderName &amp; "\" &amp; _defDescription &amp; "01Trackeditem";

	create ff;
	ff.usePresentationFileSystem := false;
	
	if not ff.isValidPathName( _folderName ) then
		self.assertTrueMsg( false,"Could not find folder " &amp; _folderName );
	endif;
	
	ff.fileName := _folderName;
	if not ff.isAvailable then
		self.assertTrueMsg( false,"File folder " &amp; _folderName &amp; " is not available." );
	endif;
	
	foreach fileNode in ff.files do
		if  fileNode.fileName.pos( searchName, 1 ) &gt; 0 then
			if not fileNode.cnEcRemove() then
				self.assertTrueMsg( false,"Delete of " &amp; fileNode.fileName &amp; " failed" );
			endif;
		endif;
	endforeach;

epilog

	delete ff;
	
end;</source>
        <access>protected</access>
        <Parameter name="_defDescription" type="String"/>
        <Parameter name="_folderName" type="String"/>
    </JadeMethod>
    <JadeMethod name="createDataDumpDef" id="411f2e36-aef2-4978-a886-ba7a191d5cc7">
        <source>createDataDumpDef( _defDescription : String; _folderName : String ):CM_DataDumpExtractDef protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2014	cnwndl1	Initial creation	Par 33264

*/

vars

	proxy : CM_DataDumpExtractDef;
	sysDataDumpClass : CM_DataDumpClass;
	pxyExtractClass : CM_DataDumpExtractClass;
	realDef : CM_DataDumpExtractDef;
	dataDumpFeature : CM_DataDumpFeature;
	schedule : CM_AutoSchedule;
	autoTask : CM_AutoTask;
	delObjArray : ObjectArray;
	obj : Object;

begin

	//do the big clean up first if we hit the clanger on the last run..
	realDef := app.myRoot.allDataDumpExtractDefs[_defDescription];
	if realDef &lt;&gt; null then

		create delObjArray transient;
		
		foreach autoTask in realDef.allAutoTasks do
			foreach schedule in autoTask.allAutoSchedules do
				delObjArray.add(schedule);
			endforeach;
			delObjArray.add(autoTask);
		endforeach;
	
		foreach obj in delObjArray do
			beginTransaction;
			delete schedule;
			commitTransaction;
		endforeach;
		
		if realDef &lt;&gt; null then
			beginTransaction;
			delete realDef;
			commitTransaction;
		endif;
		
		delete delObjArray;
		realDef := null;
	
	endif;

	create proxy transient;
	proxy.setProxy(	_defDescription,	//_description: String;
					2,	//_extractFormat: Integer;
					true,	//_isActive : Boolean;
					false,	//_createSQLStatements : Boolean;
					_folderName,	//_fileFolderName : String;
					null,	//_edbConnectionString : String;
					null,	//_edbPassword : String;
					null,	//_edbServerName : String;
					null,	//_edbUserName : String;
					null,	//_edbMachineDSN: String;
					null,	//_oidColumnName : String;
					0,	//_oidFormat : Integer; 
					null,	//_sqlDatabaseName : String;
					null,	//_sqlServerVersion : String;
					true,	//_definitionModified : Boolean;
					false,	//_useSQLControlTable : Boolean;
					self.getTerminal(),	//_terminal: CM_Terminal;
					0,	//_alertLimit : Integer;
					null	//_ignoreDeletesFromUser : CM_User	//07 Jan 2014	NDL	Par 33264
					);
					
	sysDataDumpClass := app.myRoot.allDataDumpClasses[CM_TrackedItem.name];
	
	create pxyExtractClass transient;
	pxyExtractClass.setDataDumpClass(sysDataDumpClass);
	
	foreach dataDumpFeature in sysDataDumpClass.allDataDumpFeatures do
		if dataDumpFeature.featureName = "id" then
			pxyExtractClass.allDataDumpFeatures.add(dataDumpFeature);
		endif;
	endforeach;
	
	proxy.allDataDumpExtractClasses.add(pxyExtractClass);
					
	app.myTrxCA.trxCreateDataDumpExtractDef( proxy, realDef, app.myPassport );
	
	return realDef;

epilog
	
	delete delObjArray;
	delete proxy;

end;</source>
        <access>protected</access>
        <Parameter name="_defDescription" type="String"/>
        <Parameter name="_folderName" type="String"/>
        <ReturnType type="CM_DataDumpExtractDef"/>
    </JadeMethod>
    <JadeMethod name="createExtractSchedule" id="9c0457c6-3fc3-4acd-a10c-64b0be8afcb7">
        <source>createExtractSchedule( _def : CM_DataDumpExtractDef; _bgpUser : CM_User ):CM_AutoSchedule protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2014	cnwndl1	Initial creation	Par 33264
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
*/

vars

	pxyAutoSched : CM_AutoSchedule;
	now : TimeStamp;
	pxyAutoExDB : CM_AutoTaskExternalDB;
	realAutoSched : CM_AutoSchedule;
	realAutoExDBTask : CM_AutoTask;
	allDays : BooleanArray;
	allTimes : TimeArray;
	
begin

	now := app.actualTimeServer;	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	create allDays transient;
	allDays[1] := true;
	allDays[2] := true;
	allDays[3] := true;
	allDays[4] := true;
	allDays[5] := true;
	allDays[6] := true;
	allDays[7] := true;
	create allTimes transient;
	allTimes[1] := "12:00".Time; 
	
	create pxyAutoSched transient;
	pxyAutoSched.setForDay(	"UTDSS EXTRACT",	//_description : String;
							now,	//_start : TimeStamp;
							now.cnEcAddDays(1),	//_stop : TimeStamp;
							allDays,	//_allDays : BooleanArray;
							allTimes	//_allTimes : TimeArray
							);
	pxyAutoSched.allRunDays[1] := true;
	pxyAutoSched.allRunTimes[1] := now.time;
	
	
	create pxyAutoExDB transient;
	pxyAutoExDB.setValueForRow(ETRow_BgpAutoDescription,"UTDSS EXTRACT");
	pxyAutoExDB.setValueForRow(ETRow_BgpAutoUser,_bgpUser);
	pxyAutoExDB.setValueForRow(ETRow_BgpAutoExtractDefs,_def);
	
	app.myTrxCA.trxCreateAutoTask(pxyAutoExDB, realAutoExDBTask, app.myPassport);
	self.assertTrueMsg( realAutoExDBTask &lt;&gt; null,"Database Extract Task not created. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	pxyAutoSched.allAutoTasks.add( realAutoExDBTask );
	
	app.myTrxCA.trxCreateAutoSchedule(pxyAutoSched, realAutoSched, app.myPassport);
	self.assertTrueMsg( realAutoExDBTask &lt;&gt; null,"Auto Schedule Task for Database Extract using our Definition not created. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	return realAutoSched;
	
epilog

	delete pxyAutoSched;
	delete pxyAutoExDB;
	delete allDays;
	delete allTimes;

end;</source>
        <access>protected</access>
        <Parameter name="_def" type="CM_DataDumpExtractDef"/>
        <Parameter name="_bgpUser" type="CM_User"/>
        <ReturnType type="CM_AutoSchedule"/>
    </JadeMethod>
    <JadeMethod name="doEnsureBGPRunning" id="717520fa-3673-42aa-81c8-4373084af21c">
        <source>doEnsureBGPRunning( _ctController : BGP_ChangeTrackerController output;
					_deaController : BGP_GenericController output;
					_bgpUser : CM_User output;
					_autoManagerStarted : BGP_Manager output;
					_ctManagerStarted : BGP_Manager output;
					_deaManagerStarted : BGP_Manager output
					)protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 January 2014	cnwndl1	Initial creation	Par 33264

*/

vars

	iter : Iterator;
	manager : BGP_Manager;
	autoManager : BGP_Manager;
	ctManager : BGP_Manager;
	deaManager : BGP_Manager;
	iter2 : Iterator;
	controller	: BGP_Controller;
	atController : BGP_AutoTimerController;
	
	schema : Schema;
	class : Class;
	obj : Object;
	notificationObj : Object;
	persistNoteObj : Object;
	eventType : Integer;
	
begin

	//make sure the AUTO Scheduler, Change Tracker and Data Extract tasks are running to process the Audit logs etc.
	iter := app.myRoot.allBGPManagers.createIterator;
	while iter.next(manager) do
		iter2 := manager.allBGPControllers.createIterator;
		while iter2.next(controller) do
			if controller.isKindOf( BGP_AutoTimerController ) then
				autoManager := manager;
				atController := controller.BGP_AutoTimerController;
				break;
			endif;
		endwhile;
		delete iter2;
	endwhile;
	delete iter;
	delete iter2;
	
	self.assertTrueMsg( atController &lt;&gt; null, "No Auto Schedule Background TASK found, can not test DSS.");
	
	if not autoManager.isRunning then
		self.doImmediateStartManagerAsync( autoManager );
		self.assertTrueMsg( autoManager.isRunning, "Auto Schedule Background Manager did not start, can not test DSS.");
		_autoManagerStarted := autoManager;
	endif;
	
	//try to find the RUNNING change tracker and data extract tasks
	iter := app.myRoot.allBGPManagers.createIterator;
	while iter.next(manager) do
		if manager.isRunning then
			iter2 := manager.allBGPControllers.createIterator;
			while iter2.next(controller) do
				if controller.isKindOf( BGP_ChangeTrackerController ) then
					if controller.isRunning then
						_ctController := controller.BGP_ChangeTrackerController;
					endif;
				endif;
				if controller.isKindOf(BGP_GenericController) then
					if controller.isRunning then
						if controller.allRequestClassesToProcess.includes(BGP_ExternalDBRequest.name) then
							_deaController := controller.BGP_GenericController;
							_bgpUser := controller.myUser;
						endif;
					endif;
				endif;
			endwhile;
			delete iter2;
		endif;
	endwhile;
	delete iter;
	delete iter2;
	
	if _ctController = null then
		iter := app.myRoot.allBGPManagers.createIterator;
		while iter.next(manager) do
			if _ctController &lt;&gt; null then
				break;
			endif;
			iter2 := manager.allBGPControllers.createIterator;
			while iter2.next(controller) do
				if controller.isKindOf( BGP_ChangeTrackerController ) then
					ctManager := manager;
					_ctController := controller.BGP_ChangeTrackerController;
					break;
				endif;
			endwhile;
			delete iter2;
		endwhile;
		delete iter;
		delete iter2;
		self.assertTrueMsg( _ctController &lt;&gt; null, "Change Tracker task not set up in a BGP mgr, can not test DSS.");
		if not ctManager.isRunning then
			self.doImmediateStartManagerAsync( ctManager );
			self.assertTrueMsg( ctManager.isRunning, "Background App Manager " &amp; ctManager.name &amp; " for Change Tracker task did not start, can not test DSS.");
			_ctManagerStarted := ctManager;
		endif;
		
		if not _ctController.isRunning then
			process.sleep(5000);
			process.sleep(5000); //05 Mar 2021	NDL
			self.assertTrueMsg( _ctController.isRunning, "Change Tracker task in (" &amp; ctManager.name &amp; ") did not start, can not test DSS.");
		endif;
		
		if _deaController = null then
			// need to re-check for a RUNNING dea task, in case it is within the ctManager, and has just been started.
			iter := app.myRoot.allBGPManagers.createIterator;
			while iter.next(manager) do
				if _deaController &lt;&gt; null then
					break;
				endif;
				if manager.isRunning then
					iter2 := manager.allBGPControllers.createIterator;
					while iter2.next(controller) do
						if controller.isKindOf(BGP_GenericController) then
							if controller.isRunning then
								if controller.allRequestClassesToProcess.includes("BGP_ExternalDBRequest") then
									_deaController := controller.BGP_GenericController;
									_bgpUser := controller.myUser;
									break;
								endif;
							endif;
						endif;
					endwhile;
					delete iter2;
				endif;
			endwhile;
			delete iter;
			delete iter2;
		endif;
		
	endif;
	
	if _deaController = null then
		iter := app.myRoot.allBGPManagers.createIterator;
		while iter.next(manager) do
			if _deaController &lt;&gt; null then
				break;
			endif;
			iter2 := manager.allBGPControllers.createIterator;
			if controller.isKindOf(BGP_GenericController) then
				if controller.allRequestClassesToProcess.includes(BGP_ExternalDBRequest.name) then
					_deaController := controller.BGP_GenericController;
					_bgpUser := controller.myUser;
					deaManager := manager;
					break;
				endif;
			endif;
			delete iter2;
		endwhile;
		delete iter;
		delete iter2;
		self.assertTrueMsg( _deaController &lt;&gt; null, "Data Extract task not set up in a BGP mgr, can not test DSS.");
		if not deaManager.isRunning then
			self.doImmediateStartManagerAsync( deaManager );
			self.assertTrueMsg( deaManager.isRunning, "Background App Manager " &amp; deaManager.name &amp; " for Data Extract task did not start, can not test DSS.");
			_deaManagerStarted := deaManager;
		endif;
	endif;
	
	self.assertTrueMsg( _ctController &lt;&gt; null, "Change Control task not running, can not test DSS.");
	self.assertTrueMsg( _deaController &lt;&gt; null, "Data Extract task not running, can not test DSS.");
	
	schema := rootSchema.getSchema("JSSChangeTrackingSchema");
	class := schema.getClass("JSSCTNotificationObject");
	notificationObj := class.firstSharedTransientInstance;
	
	if notificationObj &lt;&gt; null then
		persistNoteObj := notificationObj.getPropertyValue("myPersistentInstance").Object;
		if persistNoteObj &lt;&gt; null then
			eventType := User_Base_Event + 1;  // JSSCT_Nibbler_Note ( a constant in JSSChangeTrackingSchema)
			self.beginNotification(persistNoteObj, eventType, Response_Continuous, 2);
		endif;
	endif;
	
epilog

	delete iter;
	delete iter2;

end;</source>
        <access>protected</access>
        <Parameter name="_ctController" type="BGP_ChangeTrackerController" usage="output"/>
        <Parameter name="_deaController" type="BGP_GenericController" usage="output"/>
        <Parameter name="_bgpUser" type="CM_User" usage="output"/>
        <Parameter name="_autoManagerStarted" type="BGP_Manager" usage="output"/>
        <Parameter name="_ctManagerStarted" type="BGP_Manager" usage="output"/>
        <Parameter name="_deaManagerStarted" type="BGP_Manager" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doImmediateScheduleRunAsync" id="a5d8e548-c2f0-4fd1-aeb3-d04114fa058c">
        <source>doImmediateScheduleRunAsync( _schedule : CM_AutoSchedule input; _controller : BGP_Controller; _defDescription : String ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2014	cnwndl1	Initial creation	Par 33264

*/

vars
	
	startCount : Integer;
	counter : Integer;
	msg : String;
	leftToProcessCount : Integer;

begin

	app.myTrxUA.trxUpdateAutoScheduleRunTs( _schedule, 11, app.myPassport );
	
	// give the controller a chance to see the notification that there is something to process
	process.sleep(5000);
	
	//now wait for it to be processed
	startCount :=  _controller.getDDSQueuedRequestsFor(_defDescription);
	leftToProcessCount := startCount;
	while leftToProcessCount &gt; 0 do
		counter := counter + 1;
		if counter &gt; 300 then	//30 minutes   
			break;
		endif;
		leftToProcessCount :=  _controller.getDDSQueuedRequestsFor(_defDescription);
		process.sleep(6000); //6 seconds
	endwhile;
	
	if leftToProcessCount &gt; 0 then
		msg := "'doImmediateScheduleRunAsync', loop counter exceeds 300 (30 minutes). '" &amp; _controller.name &amp;
					"' leftToProcessCount = " &amp; leftToProcessCount.String &amp; " [ started at " &amp; startCount.String &amp; "]";
		self.assertTrueMsg( false, msg );
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_schedule" type="CM_AutoSchedule" usage="input"/>
        <Parameter name="_controller" type="BGP_Controller"/>
        <Parameter name="_defDescription" type="String"/>
    </JadeMethod>
    <JadeMethod name="doImmediateStartManagerAsync" id="a848d081-71a7-4775-a30a-e1d4fc84a269">
        <source>doImmediateStartManagerAsync( _bgpManager : BGP_Manager input )protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 January 2014	cnwndl1	Initial creation	Par 33264

*/

vars

	count : Integer;

begin

	_bgpManager.startAllBackGroundApps();
	
	process.sleep(2000);
	
	while not _bgpManager.isRunning do
		//allow another 20 seconds if needed. - Seems slower when in background.
		process.sleep(2000);
		count := count + 1;
		if count &gt; 10 then
			break;
		endif;
	endwhile;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_bgpManager" type="BGP_Manager" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doProcessTheChangesAndExtract" id="1687aa21-17cb-4fe1-ace7-eefd29e64131">
        <updating/>
        <source>doProcessTheChangesAndExtract(  _defDescription : String;
								_folderName : String;
								_ctController : BGP_ChangeTrackerController input;
								_schedule : CM_AutoSchedule input;
								_deaController : BGP_Controller
								) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 January 2014	cnwndl1	Initial creation	Par 33264

*/

vars

begin

	//get rid of any of our existing output test files before we start
	self.cleanUpFiles( _defDescription, _folderName );

	//Just because - Make sure any changed data has made it to the Audit logs
	process.sleep( 5000 ); 

	//Transfer the latest audit logs and let change tracker process them (I.e. create the change tracker objects)
	self.doTransferLogsAsync( _ctController );	
	
	//force an immediate run of the extract task associated with the schedule. (I.e Read The Change Tracker objects and create the files NOW.)
	self.doImmediateScheduleRunAsync( _schedule, _deaController, _defDescription );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_defDescription" type="String"/>
        <Parameter name="_folderName" type="String"/>
        <Parameter name="_ctController" type="BGP_ChangeTrackerController" usage="input"/>
        <Parameter name="_schedule" type="CM_AutoSchedule" usage="input"/>
        <Parameter name="_deaController" type="BGP_Controller"/>
    </JadeMethod>
    <JadeMethod name="doTransferLogsAsync" id="42b98479-cb54-4c27-8f16-2d589cddfac5">
        <updating/>
        <source>doTransferLogsAsync( _ctController : BGP_ChangeTrackerController ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2014	cnwndl1	Initial creation	Par 33264

*/

vars

	dba: JadeDatabaseAdmin;
	
	schema : Schema;
	class : Class;
	obj : Object;
	notificationObj : Object;
	persistNoteObj : Object;
	eventType : Integer;
	
	count : Integer;

begin

	schema := rootSchema.getSchema("JSSChangeTrackingSchema");
	class := schema.getClass("JSSCTNotificationObject");
	notificationObj := class.firstSharedTransientInstance;
	if notificationObj &lt;&gt; null then
		persistNoteObj := notificationObj.getPropertyValue("myPersistentInstance").Object;
	endif;

	create dba transient;
	dba.closeCurrentJournal;
	if dba &lt;&gt; null then
		delete dba;
	endif;
	
	app.doWindowEvents(5000);
	
	if persistNoteObj &lt;&gt; null and self.changeTrackerState = self.JSSCT_Nibbler_Terminating then
		self.changeTrackerState := 0;
		return;
	endif;
	
	
	while _ctController.numQueuedRequests &gt; 0 do
		app.doWindowEvents(2000);
	endwhile;
	
	//now wait for the last request to be processed
	while persistNoteObj &lt;&gt; null and self.changeTrackerState &lt;&gt; self.JSSCT_Nibbler_Terminating do
		app.doWindowEvents(500);
		if self.changeTrackerState = self.JSSCT_Nibbler_Terminating then
			self.changeTrackerState := 0;
			return;
		endif;
	endwhile;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ctController" type="BGP_ChangeTrackerController"/>
    </JadeMethod>
    <JadeMethod name="getUserCodeForDSSIgnore" id="4c26877d-4f1f-45ed-9013-29e0d1981c08">
        <source>getUserCodeForDSSIgnore():CM_User protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 January 2014	cnwndl1	Initial creation	Par 33264
31/07/2017		cnwmh5	Chnage to use new JLGSCHEDULE User
*/

vars

	rawUserCodeString : String;
	pos : Integer;
	userCodeString : String;
	user : CM_User;

begin

	rawUserCodeString := process.userCode;
	pos := rawUserCodeString.pos("_",1);
	if rawUserCodeString.pos("_",1) &gt; 2 then
		userCodeString := rawUserCodeString[1:pos - 1].toUpper;
	else
		userCodeString := rawUserCodeString[1:10].toUpper;
	endif;
	
	if userCodeString.length &gt; 10 then					// 06/11/2017 jlgmh5
		userCodeString := userCodeString[1:10].toUpper;
	endif;
	
	user := app.myRoot.allUsers.getAtKey( userCodeString );
	if user &lt;&gt; null then
		return user;
	endif;
	
	self.assertTrueMsg( false,"No User found matching " &amp; userCodeString );
	
	//Had to set up a JMT user code "JLGSCHEDULE" for the overnight run,
	//because this is the windows usercode thast the overnight run uses.

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="isStringValueWithinFiles" id="3354a5a6-76d5-4b02-a4c9-97a1c6955704">
        <source>isStringValueWithinFiles( _defDescription : String; _folderName : String; _searchValue : String ):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 January 2014	cnwndl1	Initial creation	Par 33264

*/

vars

	searchName : String;
	ff : FileFolder;
	fileNode : FileNode;
	file : File;
	fileLine : String;
	foundIt : Boolean;
	foundANode : Boolean;
	foundAFile : Boolean;

begin

	searchName :=  _folderName &amp; "\" &amp; _defDescription &amp; "01Trackeditem";

	create ff;
	ff.usePresentationFileSystem := false;
	
	if not ff.isValidPathName( _folderName ) then
		self.assertTrueMsg( false,"Could not find folder " &amp; _folderName );
	endif;
	
	ff.fileName := _folderName;
	if not ff.isAvailable then
		self.assertTrueMsg( false,"File folder " &amp; _folderName &amp; " is not available." );
	endif;
	
	foreach fileNode in ff.files do
		foundANode := true;
		if  fileNode.fileName.pos( searchName, 1 ) &gt; 0 then
			if not fileNode.cnEcIsFile then
				continue;
			endif;
			file := fileNode.File;
			file.kind := File.Kind_Unknown_Text;
			foundAFile := true;
			if not file.tryOpen then
				self.assertTrueMsg( false,"Unable to open File " &amp; file.fileName );
			endif;
			while not file.endOfFile do
				fileLine := file.readLine();
				if fileLine.pos(_searchValue,1) &gt; 0 then
//write "'" &amp; _searchValue &amp; "' found within '" &amp; fileLine &amp; "'";
					foundIt := true;
					break;
				endif;
			endwhile;
			file.close;
			if foundIt then
				return true;
			endif;
		endif;
	endforeach;
	
	if not foundANode then
		self.assertTrueMsg( false,"No files found in " &amp; _folderName );
	endif;
	if not foundAFile then
		self.assertTrueMsg( false,"File not found " &amp; searchName );
	endif;
	
	return false;

epilog

	delete ff;
	
end;</source>
        <access>protected</access>
        <Parameter name="_defDescription" type="String"/>
        <Parameter name="_folderName" type="String"/>
        <Parameter name="_searchValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setLatestAuditNumber" id="a5d0f33a-7a9c-4958-9c5b-52dec4f169df">
        <source>setLatestAuditNumber() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2014	cnwndl1	Initial creation

*/

constants

	SchemaName : String = "JSSChangeTrackingSchema";
	ClassName : String = "JSSCTNibblerManager";
	
vars

	dba: JadeDatabaseAdmin;
	latestJournalNumber : Integer;
	prevJournalNumber : Integer;
	schema : Schema;
	class : Class;
	obj : Object;

begin

	schema := rootSchema.getSchema(SchemaName);
	self.assertTrueMsg( schema &lt;&gt; null, "'" &amp; SchemaName &amp; "' not found, can NOT test DSS.");
	
	class := schema.getClass(ClassName);
	self.assertTrueMsg( class &lt;&gt; null, "'" &amp; ClassName &amp; "' not found in '" &amp; SchemaName &amp; "', can NOT test DSS.");
	
	obj := class.firstInstance;
	self.assertTrueMsg( obj &lt;&gt; null, "'" &amp; ClassName &amp; "' first instance not found, can NOT test DSS.");
	
	create dba transient;
	latestJournalNumber := dba.getCurrentLogNumber;
	prevJournalNumber := latestJournalNumber - 1;
	
	beginTransaction;
		exclusiveLock (obj);
		obj.setPropertyValue("lastAuditFileNumber", prevJournalNumber.Integer);
		obj.setPropertyValue("lastJade5Log", 0);
	commitTransaction;
	
	if dba &lt;&gt; null then
		delete dba;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tBasicChangeTracker" id="308e317c-f1c6-4186-8715-506542253fd8">
        <updating/>
        <source>tBasicChangeTracker() updating;
//cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2014	cnwndl1	Initial creation	Par 33264
01 Jul 2015	cnwkpd1	Remove hard-coded export directory

*/

constants
	DefDescription : String = "UTDSSXML";
	TiId1 : String = "UTDS0102030";
	TiId2 : String = "UTDS0102031";
	TiId3 : String = "UTDS0102032";
	
vars
	exportDir : String;
	
	ctController : BGP_ChangeTrackerController;
	deaController : BGP_GenericController;
	bgpUser : CM_User;
	autoManagerStarted : BGP_Manager;
	ctManagerStarted : BGP_Manager;
	deaManagerStarted : BGP_Manager;

	def : CM_DataDumpExtractDef;
	lastCTObject : Object;
	
	schedule : CM_AutoSchedule;
	autoTask : CM_AutoTask;
	
	ti1 : CM_TrackedItem;
	ti2 : CM_TrackedItem;
	ti3 : CM_TrackedItem;
	
	isLoad : Boolean;
	proxyTi : CM_TrackedItem;
	workStr : String;
	workStr2 : String;
	
	dssIgnoreUser : CM_User;
	
	doSleep : Boolean;

begin

	///self.xCheckBGPProcessDetails();						// 21/07/2014 cnwmh5 - TESTING ONLY
	
	exportDir := app.myCnCntrl.logPath;

	self.cleanUpFiles( DefDescription, exportDir );
	
	self.setLatestAuditNumber(); //10 Mar 2014	- Change to prev journal to try to lessen the amount of processing.

	//make sure the AUTO Scheduler and Change Tracker is running to process the Audit logs.
	self.doEnsureBGPRunning( ctController, deaController, bgpUser, autoManagerStarted, ctManagerStarted, deaManagerStarted );
	
	//create a basic XML Data Dump Definition to extract our changed Tracked Items
	def := self.createDataDumpDef( DefDescription, exportDir );
	self.assertTrueMsg( def &lt;&gt; null,"XML Data Dump Defintion not created Pre Testing");
	
	//create a Data Extract task using our definition, and a schedule to initiate against. 
	schedule := self.createExtractSchedule( def, bgpUser );
	self.assertTrueMsg( schedule &lt;&gt; null,"Schedule not created Pre Testing");
	
	//create 3 trackedItems for testing with
	self.deleteContainer(TiId1);
	self.deleteContainer(TiId2);
	self.deleteContainer(TiId3);
	
	// Delete any old files, transfer the Audit logs, and run the background tasks to get all current changes and create new extract files.
	self.doProcessTheChangesAndExtract( DefDescription,	//_defDescription : String;
										exportDir,	//_folderName : String;
										ctController,	//_ctController : BGP_ChangeTrackerController input;
										schedule,	//_schedule : CM_AutoSchedule input;
										deaController	//_deaController : BGP_Controller;
										);
										
	app.doWindowEvents(1);
	process.sleep(5000);
										
	ti1 := self.addContainer(	TiId1,	//_id: String;
								self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator : CM_Operator;
								"2200",	//_isoType : String;
								"MT",	//_commodity : String;
								TI_IMEX_STATUS_EXPORT	//_imexStatus : Integer
								);
	ti2 := self.addContainer(	TiId2,	//_id: String;
								self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator : CM_Operator;
								"2200",	//_isoType : String;
								"MT",	//_commodity : String;
								TI_IMEX_STATUS_EXPORT	//_imexStatus : Integer
								);
	ti3 := self.addContainer(	TiId3,	//_id: String;
								self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator : CM_Operator;
								"2200",	//_isoType : String;
								"MT",	//_commodity : String;
								TI_IMEX_STATUS_EXPORT	//_imexStatus : Integer
								);
	
	// Delete any old files, transfer the Audit logs, and run the background tasks to get all current changes and create new extract files.
	self.doProcessTheChangesAndExtract( DefDescription,	//_defDescription : String;
										exportDir,	//_folderName : String;
										ctController,	//_ctController : BGP_ChangeTrackerController input;
										schedule,	//_schedule : CM_AutoSchedule input;
										deaController	//_deaController : BGP_Controller;
										);
	
	
	app.doWindowEvents(1);
	process.sleep(5000);
	
	//check that the files created contain our 3 cargo items.
	if not self.isStringValueWithinFiles( DefDescription, exportDir, ti1.id ) then
		self.assertTrueMsg( false,"Could not find " &amp; ti1.id &amp; " in Test 1.");
	endif;
	if not self.isStringValueWithinFiles( DefDescription, exportDir, ti2.id ) then
		self.assertTrueMsg( false,"Could not find " &amp; ti2.id &amp; " in Test 2.");
	endif;
	if not self.isStringValueWithinFiles( DefDescription, exportDir, ti3.id ) then
		self.assertTrueMsg( false,"Could not find " &amp; ti3.id &amp; " in Test 3.");
	endif; 
	

	// make changes to ti1  and ti2, and delete ti3
	app.cmsBeginLoad(isLoad);
	proxyTi := ti1.pxyCreateUpdateProxy();
	app.cmsEndLoad(isLoad);
	
	proxyTi.zSetPxyTotalWeight(3025);
	proxyTi.zSetPxyRemarks("Updated once");
	proxyTi.zSetPxyBookingReference("UTNOTBOOKED");
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateTrackedItem(proxyTi,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete proxyTi;
	
	app.cmsBeginLoad(isLoad);
	proxyTi := ti2.pxyCreateUpdateProxy();
	app.cmsEndLoad(isLoad);
	
	proxyTi.zSetPxyTotalWeight(3025);
	proxyTi.zSetPxyRemarks("Updated once");
	proxyTi.zSetPxyBookingReference("UTNOTBOOKED");
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateTrackedItem(proxyTi,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete proxyTi;
	
	app.cmsBeginLoad(isLoad);
	proxyTi := ti3.pxyCreateUpdateProxy();
	app.cmsEndLoad(isLoad);
	
	proxyTi.zSetPxyTotalWeight(3025);
	proxyTi.zSetPxyRemarks("Updated once");
	proxyTi.zSetPxyBookingReference("UTNOTBOOKED");
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateTrackedItem(proxyTi,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete proxyTi;
	
	workStr := ti3.id;
	workStr2 := global.dataDumpFormatHex(ti3);
	self.deleteTrackedItem(ti3,false);
	
	
	// delete previous files, transfer the Audit logs again, and run the background tasks to get the changes since and extract into new files.
	self.doProcessTheChangesAndExtract( DefDescription,	//_defDescription : String;
										exportDir,	//_folderName : String;
										ctController,	//_ctController : BGP_ChangeTrackerController input;
										schedule,	//_schedule : CM_AutoSchedule input;
										deaController	//_deaController : BGP_Controller;
										);
	
	app.doWindowEvents(1);
	process.sleep(5000);
	
	if not self.isStringValueWithinFiles( DefDescription, exportDir, ti1.id ) then
		self.assertTrueMsg( false,"Could not find " &amp; ti1.id &amp; " in Test 4.");
	endif;
	if not self.isStringValueWithinFiles( DefDescription, exportDir, ti2.id ) then
		self.assertTrueMsg( false,"Could not find " &amp; ti2.id &amp; " in Test 5.");
	endif;
	//even though its updated, should NOT be included, because it was deleted
	if self.isStringValueWithinFiles( DefDescription, exportDir, workStr ) then
		self.assertTrueMsg( false,"Should not find " &amp; workStr &amp; " in Test 6.");
	endif; 
	//delete is identified with hex
	if not self.isStringValueWithinFiles( DefDescription, exportDir, workStr2 ) then
		self.assertTrueMsg( false,"Could not find " &amp; workStr2 &amp; " in Test 7.");
	endif;
	
	
	
	//set the ignoreDeletesForUser, to this user, then change ti1 and delete ti2, only t1i should show in the change tracker extract files
	//This attribute is actually only available via the thin client for SQL extracts, but is used for any type of extract where it is set.
	// So for testing purposes...
	dssIgnoreUser := self.getUserCodeForDSSIgnore();
	
	//05 Mar 2021	NDL	- Note that ChangeTracker actually users the 'windows' user code against the change tracker objects,
	//so in order for this test to work, the dssIgnoreUser 'CM_User' must have the same 'code' as the 'windows' sign on being
	//used. CM_User::id is only 10 chars long, so for this test to work correctly for step 10, the windows log on must be
	//10 chars long or less, and the CM_User::id must exactly match it.
	
	beginTransaction;
	def.setPropertyValue( CM_DataDumpExtractDef::ignoreDeletesFromUser.name, dssIgnoreUser );
	commitTransaction;
	
	app.myPassport.setMyUser(dssIgnoreUser);
	
	self.assertTrueMsg( def.ignoreDeletesFromUser = dssIgnoreUser,"CM_DataDumpExtractDef::ignoreDeletesFromUser not set to '" &amp; dssIgnoreUser.code &amp; "'");
	self.assertTrueMsg( app.myPassport.myUser = dssIgnoreUser,"app.myPassport.myUser not set to '" &amp; dssIgnoreUser.code &amp; "'");
	
	app.doWindowEvents(1);
	process.sleep(5000);
	
	app.cmsBeginLoad(isLoad);
	proxyTi := ti1.pxyCreateUpdateProxy();
	app.cmsEndLoad(isLoad);
	
	proxyTi.zSetPxyTotalWeight(4112);
	proxyTi.zSetPxyRemarks("Updated twice");
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateTrackedItem(proxyTi,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete proxyTi;
	
	app.cmsBeginLoad(isLoad);
	proxyTi := ti2.pxyCreateUpdateProxy();
	app.cmsEndLoad(isLoad);
	
	proxyTi.zSetPxyTotalWeight(4112);
	proxyTi.zSetPxyRemarks("Updated twice");
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateTrackedItem(proxyTi,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete proxyTi;
	
	workStr := ti2.id;
	workStr2 := global.dataDumpFormatHex(ti2);
	
	self.deleteTrackedItem(ti2,false);
	
	app.doWindowEvents(1);
	process.sleep(5000);
	
	// delete previous files, transfer the Audit logs again, and run the background tasks to get the changes since and extract into new files.
	self.doProcessTheChangesAndExtract( DefDescription,	//_defDescription : String;
										exportDir,	//_folderName : String;
										ctController,	//_ctController : BGP_ChangeTrackerController input;
										schedule,	//_schedule : CM_AutoSchedule input;
										deaController	//_deaController : BGP_Controller;
										);
	
	app.doWindowEvents(1);
	process.sleep(5000);
	
	if not self.isStringValueWithinFiles( DefDescription, exportDir, ti1.id ) then
		self.assertTrueMsg( false,"Could not find " &amp; ti1.id &amp; " in Test 8.");
	endif;
	//even though its updated, should NOT be included, because it was deleted
	if self.isStringValueWithinFiles( DefDescription, exportDir, workStr ) then
		self.assertTrueMsg( false,"Should not find " &amp; workStr &amp; " in Test 9.");
	endif;
	//Supposed to be ignoring deletes for this user, so we should not see this sucker...
	// See JSSChangeTrackingSchema  JSSCTChangeTrackingObject::isDeleteForUser
	if self.isStringValueWithinFiles( DefDescription, exportDir, workStr2 ) then
		self.assertTrueMsg( false,"Should not find " &amp; workStr2 &amp; " in Test 10. (ti = " &amp; workStr &amp; ", user = " &amp; dssIgnoreUser.code &amp; ")");
	endif;
	

epilog

	self.endNotificationForSubscriber( self );

	if ctManagerStarted &lt;&gt; null then
		ctManagerStarted.terminateProcessing(app.myPassport.userCode);
		doSleep := true;
	endif;
	if deaManagerStarted &lt;&gt; null then
		deaManagerStarted.terminateProcessing(app.myPassport.userCode);
		doSleep := true;
	endif;
	if autoManagerStarted &lt;&gt; null then
		autoManagerStarted.terminateProcessing(app.myPassport.userCode);
		doSleep := true;
	endif;
	
	if doSleep then
		// to give teh timer events time to complete, and so prevent / lessen
		// the opporunity for locking during the following deletes.
		process.sleep(2000);
	endif;
	
	if schedule &lt;&gt; null and not schedule.allAutoTasks.isEmpty then
		autoTask := schedule.allAutoTasks.first;
	endif;
	if schedule &lt;&gt; null then
		beginTransaction;
		delete schedule;
		commitTransaction;
	endif;
	if autoTask &lt;&gt; null then
		beginTransaction;
		delete autoTask;
		commitTransaction;
	endif;
	
	if def &lt;&gt; null then
		beginTransaction;
		delete def;
		commitTransaction;
	endif;
	
	self.deleteContainer(TiId1);
	self.deleteContainer(TiId2);
	self.deleteContainer(TiId3);

	delete proxyTi;

end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="false"&gt;SCHEDULE_Weekly&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tXMLExtractTfs51350" id="a7ff3f6a-7bdb-4a94-a997-57cda89c34df">
        <source>tXMLExtractTfs51350();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2021	navndl1	Initial creation	TFS 51359

*/

constants

	DumpDefDesc : String = "UT_XML_ORG";
vars

	proxyDdeDef : CM_DataDumpExtractDef;
	realDdeDef : CM_DataDumpExtractDef;
	pxyExtractClass : CM_DataDumpExtractClass;
	sysDataDumpClass : CM_DataDumpClass;
	dataDumpFeature : CM_DataDumpFeature;
	ddeAgent : CM_DataDumpExtractionAgent;
	objArray : ObjectArray;
	fileName : String;
	file : File;
	str : String;
	index : Integer;
	intArray : IntegerArray;
	
begin

	realDdeDef := app.myRoot.allDataDumpExtractDefs[DumpDefDesc];
	if realDdeDef &lt;&gt; null then
		app.myTrxDA.trxDeleteDataDumpExtractDef( realDdeDef, app.myPassport );
	endif;

	create proxyDdeDef transient;
	proxyDdeDef.setProxy(	DumpDefDesc,	//_description: String;
							2,	//_extractFormat: Integer;
							true,	//_isActive : Boolean;
							false,	//_createSQLStatements : Boolean;
							"C:\Temp",	//_fileFolderName : String;
							null,	//_edbConnectionString : String;
							null,	//_edbPassword : String;
							null,	//_edbServerName : String;
							null,	//_edbUserName : String;
							null,	//_edbMachineDSN: String;
							null,	//_oidColumnName : String;
							0,	//_oidFormat : Integer; 
							null,	//_sqlDatabaseName : String;
							null,	//_sqlServerVersion : String;
							true,	//_definitionModified : Boolean;
							false,	//_useSQLControlTable : Boolean;
							self.getTerminal(),	//_terminal: CM_Terminal;
							0,	//_alertLimit : Integer;
							null	//_ignoreDeletesFromUser : CM_User
							);
							
	sysDataDumpClass := app.myRoot.allDataDumpClasses[CM_Organisation.name];
	
	create pxyExtractClass transient;
	pxyExtractClass.setDataDumpClass(sysDataDumpClass);
	
	foreach dataDumpFeature in sysDataDumpClass.allDataDumpFeatures do
		if dataDumpFeature.featureName = "name" or dataDumpFeature.featureName = "edition" then
			pxyExtractClass.allDataDumpFeatures.add(dataDumpFeature);
		endif;
	endforeach;
	
	proxyDdeDef.allDataDumpExtractClasses.add(pxyExtractClass);
					
	app.myTrxCA.trxCreateDataDumpExtractDef( proxyDdeDef, realDdeDef, app.myPassport );
	self.assertTrueMsg( realDdeDef &lt;&gt; null, "No defintion created : " &amp; app.myPassport.getErrorsAndWarningsAsString );


	create objArray transient;
	objArray.add( CM_InternalOrganisation.firstInstance );
	objArray.add( CM_ExternalOrganisation.firstInstance );
	
	create ddeAgent transient;
	ddeAgent.initialise( null, false, false );
	ddeAgent.doExtractSelectedObjsXML( realDdeDef.description, objArray );
	fileName := realDdeDef.fileFolderName &amp; "/UT_XML_ORG01Organisation" &amp; ddeAgent.getExtractToDateTime &amp; "c.xml";
	ddeAgent.finalise;
	
	create file transient;
	file.fileName := fileName;
	file.mode := File.Mode_Input;
	file.shareMode :=	File.Share_Exclusive;
	if file.tryOpen then
		create intArray transient;
		while not file.endOfFile do
			str := file.readLine();
			index := index + 1;
			intArray.add( str.pos('object class="Organisation"',1) );
		endwhile;
		file.close;
		self.assertTrueMsg( intArray.size = 11, "Incorrect number of XML lines outout" );
		self.assertTrueMsg( intArray[3] &gt; 0, "Organisation not found in line 3 of XML output" );
		self.assertTrueMsg( intArray[7] &gt; 0, "Organisation not found in line 7 of XML output" );
	
	else
		self.assertTrueMsg( false, "Failed to open file : " &amp; fileName );
		
	endif;
	
	//clean up
	if realDdeDef &lt;&gt; null then
		app.myTrxDA.trxDeleteDataDumpExtractDef( realDdeDef, app.myPassport );
	endif;
	
	file.purge(); // All good delete it.

epilog

	delete proxyDdeDef;
	delete ddeAgent;
	delete objArray;
	delete file;
	delete intArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="uCheckFiles" id="8fddefe9-87e5-494e-ba51-c390681571e3">
        <source>uCheckFiles();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2014	cnwndl1	Initial creation

*/

constants

	ExportDir : String = "e:\cnwDmast\logs";
	DefDescription : String = "UTDSSXML";
	TiId1 : String = "UTDS0102030";
	
vars

begin

	self.isStringValueWithinFiles( DefDescription, ExportDir, TiId1 );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uListCTOs" id="b9741e7c-4b61-460a-9ae6-82a9e80ad792">
        <source>uListCTOs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 January 2014	cnwndl1	Initial creation	Par 33264

*/

vars

	schema : Schema;
	class : Class;
	obj : Object;
	iter : Iterator;
	value : String;
	outputStr : String;
	count : Integer;

begin

	schema := rootSchema.getSchema("JSSChangeTrackingSchema");
	class := schema.getClass("JSSCTChangeTrackingObject");
	obj := class.lastInstance;
	
	iter := class.instances.createIterator;
	while iter.back( obj ) do
		count := count + 1;
		if count &gt; 20 then
			break;
		endif;
		outputStr := obj.String;
		value := obj.getPropertyValue("userCode").String;
		outputStr := outputStr &amp; " " &amp; value;
		
	endwhile;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="userNotification" id="2db6c2b3-9a43-4e9c-8035-430b3a2c2f71">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 January 2014	cnwndl1	Initial creation	Par 33264

*/

vars

begin

	self.changeTrackerState := userInfo.String[1:4].Integer;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
