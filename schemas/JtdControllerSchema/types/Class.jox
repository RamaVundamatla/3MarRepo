<Class name="Class">
    <JadeMethod name="getMethodProfiles" id="50040d99-3df9-4a4e-a693-5fb7a5d0c421">
        <source>getMethodProfiles(mpa : JtdMethodProfileArray input);

// It is the caller's responsibility to clear mpa first if required.
// It is also the caller's responsibility to delete the contents of
// mpa when finished.

vars
	mp : JtdMethodProfile;
	subCls : Class;
	mth : Method;
	
begin
	if mpa = null then
		return;
	endif;

	if not self.abstract then
		foreach mth in self.methods do
			create mp transient;
			mp.jtdSetClassAndMethodNames(self.name, mth.name);
			mpa.add(mp);
		endforeach;
	endif;
	
	foreach subCls in self.subclasses do
		subCls.getMethodProfiles(mpa);
	endforeach;
end;</source>
        <Parameter name="mpa" type="JtdMethodProfileArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="jtdGetMethods" id="48c95ecf-c0e6-4909-8d96-3e6f3b4a8416">
        <source>jtdGetMethods() : MethodNDict;

begin
	return self.methods;
end;</source>
        <ReturnType type="MethodNDict"/>
    </JadeMethod>
    <JadeMethod name="jtdGetProperties" id="40c05e6c-b0a1-47f1-a938-4d00437c4de8">
        <source>jtdGetProperties() : PropertyNDict;

begin
	return self.properties;
end;</source>
        <ReturnType type="PropertyNDict"/>
    </JadeMethod>
</Class>
