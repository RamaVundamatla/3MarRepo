    <JadeMethod name="showRTQueueForm" id="d1c92164-bf76-4aa1-b3d9-b7948793b60c">
        <updating/>
        <source>showRTQueueForm(_queueEntry : CM_RTQueueEntry; _masterMenuAction : CMUI_MenuAction) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/12/2014	cnwdap1		Initial creation PAR #35397 CCM SSFW 1394 Voyage Rationalisation
//
vars
	form : Form;
	formClass : Class;
	assistClass	: Class;
	jrw : Schema;

begin
	jrw := rootSchema.getSchema("YardSchema");
	formClass := jrw.getClass("YRD_QueueForm");
	assistClass := jrw.getClass("YRD_Assistant");
	
	form := app.loadForm(formClass, assistClass, false, false, false, self.myTerminal, _masterMenuAction);
	if form = null then
		return;
	endif;
	
	form.show;
	if _queueEntry &lt;&gt; null then
		form.sendMsg("loadDataForFirstTime");
		form.setPropertyValue(CM_BaseForm::isFirstActivateComplete.name, true);
		form.sendMsgWithParams("doPositionQueueForTask", _queueEntry.allTasks.first);
	endif;
	
epilog

end;</source>
        <Parameter name="_queueEntry" type="CM_RTQueueEntry"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
