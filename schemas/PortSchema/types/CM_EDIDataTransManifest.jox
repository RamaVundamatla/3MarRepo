		_names.add(ETDef_EDITICargo);
		_names.add(ETDef_EDIHazDetailsTI);
		_names.add(ETDef_EDITISeal);
	endif;
	
	if self.myCargoOnSite &lt;&gt; null then
		_names.add(ETDef_EDITICargo);
	endif;
	
epilog

end;</source>
        <Parameter name="_names" type="StringArray" usage="input"/>
    </JadeMethod>
