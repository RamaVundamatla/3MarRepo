    <JadeMethod name="getGate" id="a946d32f-c110-4541-9bbc-ca8debea84f7">
        <source>getGate() : CM_Gate;
/*

Date		Who		Reason
15 October 2013	cnwer1	Initial creation PAR  32740

*/

vars
	
	gateArea		: CM_GateArea;
	gateAreaUsage 	: CM_GateAreaUsage;
	gate 			: CM_Gate;
begin
	if self.myGridArea.isKindOf(CM_GateArea) then
		gateArea := self.myGridArea.CM_GateArea;
	endif;

	if gateArea = null then
		return null;
	endif;
	
	foreach gateAreaUsage in gateArea.allGates_IN do
		if gateAreaUsage.myGate &lt;&gt; null then
			return gateAreaUsage.myGate;
		endif;
	endforeach;
	
	foreach gateAreaUsage in gateArea.allGates_OUT do
		if gateAreaUsage.myGate &lt;&gt; null then
			return gateAreaUsage.myGate;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Gate"/>
    </JadeMethod>
    <JadeMethod name="getGateLaneDirection" id="6744805a-55f6-4529-bbbe-0b99ed2722c2">
        <source>getGateLaneDirection():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2017	cnwns1	Initial creation

*/

vars
	
	gate 		: CM_Gate;
	gateArea 	: CM_GateArea;
	laneNumber	: Integer;
	laneCont	: CM_GateAreaLaneController;	
	usage		: CM_GateAreaUsage;
	isInGate 	: Boolean;
	isOutGate 	: Boolean;
begin
	gate := self.getGate;
	
	if gate.allGateAreas_IN.size &gt; 0 then
		foreach usage in gate.allGateAreas_IN do
			gateArea := usage.myGateArea;
			if gateArea &lt;&gt; null and gateArea.areaType = CM_GateArea.AreaType_P then
				if gateArea.laneCount &gt; 0 then
					foreach laneNumber  in 1 to gateArea.laneCount	do	
						laneCont := gateArea.getLaneByNumber(laneNumber).CM_GateAreaLaneController;
						if laneCont = self then
							isInGate := true;
						endif;
					endforeach;
				else	
					laneCont := gateArea.getLaneByNumber(1).CM_GateAreaLaneController;
					if laneCont = self then
						isInGate := true;
					endif;
				endif;	
			endif;
		endforeach;
	endif;

	
	if gate.allGateAreas_OUT.size &gt; 0 then
		foreach usage in gate.allGateAreas_OUT do
			gateArea := usage.myGateArea;
			if gateArea &lt;&gt; null and gateArea.areaType = CM_GateArea.AreaType_P then
				if gateArea.laneCount &gt; 0 then
					foreach laneNumber  in 1 to gateArea.laneCount	do	
						laneCont := gateArea.getLaneByNumber(laneNumber).CM_GateAreaLaneController;
						if laneCont = self then
							isOutGate := true;
						endif;
					endforeach;
				else	
					laneCont := gateArea.getLaneByNumber(1).CM_GateAreaLaneController;
					if laneCont = self then
						isOutGate := true;
					endif;
				endif;	
			endif;
		endforeach;
	endif;

	if isInGate and isOutGate then
		return Both;
	elseif isInGate then
		return IN_YO;
	elseif	isOutGate then
		return OUT_YO;
	else
		return null;
	endif;
	


	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getGateLaneNumber" id="5ce23b48-e9d4-41c1-8a70-0345ee2142b3">
        <source>getGateLaneNumber():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2017	cnwns1	Initial creation

*/

vars
	laneNumberString : String;
	directionString : String;
begin
		

		
	if self.isIn then
		directionString :=	" (" &amp; app.getErrorString( IN_YO) &amp; ")";
	elseif self.isOut then
		directionString :=	" (" &amp; app.getErrorString( OUT_YO) &amp; ")";
	endif;
			
	laneNumberString := self.getID;
	
	if laneNumberString &lt;&gt; null then
		laneNumberString := Space &amp;  app.getErrorString(Lane) &amp; Space &amp; laneNumberString;
	endif;
	
	return self.getGate.name &amp; laneNumberString &amp; directionString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
