    <JadeMethod name="doMatch" id="6fb3fc10-3539-4e45-a1c6-c4c8dd95d6b3">
        <source>doMatch(_value: String): Boolean;
// ---------------------------------------------------------------------------
// Created:     22 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	return self.searchValue &lt;&gt; _value;

end;</source>
