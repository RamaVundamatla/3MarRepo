    <JadeMethod name="dispAttrVals" id="3b098d89-a61b-46f4-86fe-ac121c7d3f1e">
        <options>4</options>
        <source>dispAttrVals(_obj : Object) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2025	navnk30	Initial creation

*/

constants
	Separator	: String = "::";
vars
	property		: Property;
	klass			: Class;
	klassName		: String;
begin
	klass := _obj.class;
	klassName := klass.name;
	foreach property in klass.cnGetProperties() do
		write klassName &amp; Separator &amp; property.name &amp; " = " &amp; _obj.getPropertyValue(property.name).String;
	endforeach;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
