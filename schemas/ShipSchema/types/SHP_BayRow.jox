<Class name="SHP_BayRow" id="11daee73-09bb-4ce1-bacc-68860b62c385">
    <superclass name="CMUI_GridRow"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="ship"/>
    <PrimAttribute name="onDeck" id="7e29809c-6c64-470c-b13e-1fad0cbb18e2">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="pileWeight" id="51891e52-54c2-44d6-b6b8-ddc9ee64ec3d">
        <length>11</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="amLidRow" id="9c890d34-14ec-4f7c-a81a-ad9fad684a1c">
        <source>amLidRow() : Boolean;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.allGridPointsByColumn.isEmpty then
		return false;
	elseif SHP_LidPoint.hasInstance(self.allGridPointsByColumn.last) then
		return true;
	endif;
	
	return false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawTierWeight" id="cf5bf183-ffd7-49bd-9945-4ee7b5c35da8">
        <updating/>
        <source>drawTierWeight(_theFrame : CMUI_GridAreaFrame input; _theScaleFactor : Real; _drawBG : Boolean) updating; 
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	offSet,aColour : Integer;
	thePileWeight : String;
	lastPoint : CMUI_GridPoint;
	theY, theX, theRowHeight, theSpaceX : Integer;
	theGridArea : CMUI_GridArea;
	largeOutput : Boolean;
begin
	theGridArea := _theFrame.myGridArea;
	if theGridArea.SHP_BayArea.displayMode = ShpDisplayMode_Defn then
		return;
	endif;
	aColour := Black;
	lastPoint := theGridArea.allGridPoints.last; 
	// we want the last bay point, not the lid point.
	// the lid points are drawn down low to allow us to draw the pile weights
	// note if there is only 1 row on deck it is for the hatch lid row and it means that there are not ONDECK slots
	if lastPoint.isKindOf(SHP_LidPoint) and theGridArea.allGridRows.size &gt; 1 then
		lastPoint := theGridArea.allGridRows[lastPoint.myGridRow.row - 1].allGridPointsByColumn.last; 
	endif;


	largeOutput := (theGridArea.SHP_BayArea.amPrinting and _theScaleFactor = theGridArea.SHP_BayArea.PrintScaleLarge);
	
	if largeOutput then
		theRowHeight	 := theGridArea.SHP_BayArea.PrintScaleLargeHeight;
	else
		theRowHeight	 := (SHP_BayArea.RowHeight * _theScaleFactor).Integer;
	endif;

	theX := (lastPoint.x2 + 2).Integer;
	theY := self.getYSpace(_theScaleFactor) + (theRowHeight * (self.row - 1));
	
	if _drawBG then
		_theFrame.drawFillColor := _theFrame.backColor;
		_theFrame.drawFilledRectangle(theX,theY,theX + 20, theY + 15,_theFrame.drawFillColor);
	endif;
	_theFrame.drawTextAt(self.pileWeight,theX,theY,aColour);
//write class.name &amp; '::' &amp; method.name &amp; '  ' &amp; _theFrame.drawFontSize.String &amp; ' ' &amp; _theFrame.drawFontName;
end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theScaleFactor" type="Real"/>
        <Parameter name="_drawBG" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getYSpace" id="b96d2cf3-b64c-4595-a90a-b9b854726cc6">
        <source>getYSpace(theScaleFactor : Real) : Integer;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theSpaceY: Integer;
	theGridArea : CMUI_GridArea;
begin
	theGridArea := self.myGridArea;

	if theGridArea.isKindOf(SHP_BayAreaAboveDeck) then

		if theGridArea.SHP_BayAreaAboveDeck.iAmPrinting then
			theSpaceY := theGridArea.SHP_BayAreaAboveDeck.getTopMargin();
			if  theScaleFactor = SHP_BayAreaAboveDeck.PrintScaleLarge then
				theSpaceY := theSpaceY + 10;
			endif;
		elseif theScaleFactor = 1 then
			theSpaceY := SHP_BayArea.TopMargin ;
		elseif theScaleFactor = 1.5 then
			theSpaceY := SHP_BayArea.TopMargin + 3;
		elseif theScaleFactor = 2 then
			theSpaceY := SHP_BayArea.TopMargin + 6;
		elseif theScaleFactor = 3 then
			theSpaceY := SHP_BayArea.TopMargin + 9;
		elseif theScaleFactor = 4 then
			theSpaceY := SHP_BayArea.TopMargin + 12;
		elseif theScaleFactor = 6 then
			theSpaceY := SHP_BayArea.TopMargin + 20;
		elseif theScaleFactor = 9 then
			theSpaceY := SHP_BayArea.TopMargin + 40;
		endif;
	else
		if theScaleFactor = 1.5 then		
			theSpaceY := 17;
		elseif theScaleFactor = 2 then		
			theSpaceY := 20;
		else
			theSpaceY := 25;
		endif;
/*
		if  (theGridArea.SHP_BayAreaAboveDeck.iAmPrinting and theScaleFactor = SHP_BayArea.PrintScaleSmall) then
			theSpaceY := 0;
		elseif  (theGridArea.SHP_BayAreaAboveDeck.iAmPrinting and theScaleFactor = SHP_BayArea.PrintScaleLarge) then
			theSpaceY := 23;
		elseif theScaleFactor = 1  then
			theSpaceY := 0;
		elseif theScaleFactor = 1.5 then
			theSpaceY := 2;
		elseif theScaleFactor = 2 then
			theSpaceY := 5;
		elseif theScaleFactor = 3 then
			theSpaceY := 10;
		elseif theScaleFactor = 4 then
			theSpaceY := 10;
		elseif theScaleFactor = 6 then
			theSpaceY := 20;
		elseif theScaleFactor = 9 then
			theSpaceY := 40;
		endif;
	*/
	endif;
	
	return theSpaceY;
end;</source>
        <Parameter name="theScaleFactor" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="507b04ef-8bec-4710-b9ef-2137b0927068">
        <updating/>
        <source>setForCreate(_label : String; _row : Integer; _bayArea : SHP_BayArea) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.label	:= _label;
	self.row	:= _row;

	self.myGridArea	:= _bayArea;
	self.onDeck := _bayArea.isKindOf(SHP_BayAreaAboveDeck);
end;</source>
        <Parameter name="_label" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_bayArea" type="SHP_BayArea"/>
    </JadeMethod>
    <JadeMethod name="setForCreateArray" id="670597a2-e3b1-4a20-bded-c6a92a277d36">
        <updating/>
        <source>setForCreateArray(_array : StringArray512; _bayArea : SHP_BayArea) : Integer updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin

	self.label		:= _array[2];
	self.row		:= _array[3].Integer;
//	self.pileWeight	:= _array[4];

	self.myGridArea	:= _bayArea;

	return self.row;

end;</source>
        <Parameter name="_array" type="StringArray512"/>
        <Parameter name="_bayArea" type="SHP_BayArea"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="66fcf8c6-4086-487e-be92-05fef6a54d86">
        <updating/>
        <source>setForUpdate() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	theBay : CM_BayVoyage;
	ordinalDeck, ordinalTier : Integer;
begin
	if self.onDeck then
		ordinalDeck := DeckOnDeck;
	else
		ordinalDeck := DeckUnderDeck;
	endif;
	theBay := self.myGridArea.SHP_BayArea.myBay.CM_BayVoyage;
	if self.myGridArea.SHP_BayArea.hasLidRow then
		ordinalTier := (self.myGridArea.allGridRows.size - 1) - (self.row - 1);
	else
		ordinalTier := self.myGridArea.allGridRows.size - (self.row - 1);
	endif;	
	self.pileWeight := (theBay.getTierPileWeight(ordinalDeck,ordinalTier) / 1000).Integer.String.padLeadingZeros(2);
	self.drawTierWeight(self.myGridArea.myGridAreaFrame,self.myGridArea.scaleXFactor,true);

end;</source>
    </JadeMethod>
</Class>
