    <JadeMethod name="convertErrorsWarningsToAlert" id="0924d18b-f071-49a7-a6e6-616c1db6fb56">
        <updating/>
        <source>convertErrorsWarningsToAlert(hdgToAdd : String; _errorSet : CM_ErrorSet) updating;
/*
 ------------------------------------------------------------------------
Created:			26 June 2002 by cnwdwq1
Purpose:			Called from R/T areas (and wherever else is required). Converts the errors
							and warnings generated by a TRX into an alert.
							hdgToAdd is the heading for the alert.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	err		: CM_Error;
	alert	: CM_SystemAlert;
begin
	create alert;
	alert.details := hdgToAdd;
	alert.setSeverity(SEVERE_ERROR);
	foreach err in _errorSet do
		alert.addLogEntry(err.text);
	endforeach;
	alert.add;
	self.commitAlert();
end;</source>
        <Parameter name="hdgToAdd" type="String"/>
        <Parameter name="_errorSet" type="CM_ErrorSet"/>
    </JadeMethod>
    <JadeMethod name="convertHSLtoRGB" id="d05ca6b6-1d80-4443-8303-fb2252edeb20">
        <source>convertHSLtoRGB(_hue,
				_sat,
				_lum: Integer input;
				_red,
				_green,
				_blue : Integer output);
/*

Purpose:	Input is HSL value of  colour, held in $h2, $s, $l as integer values
			// Output is RGB in normal 255 255 255 format, held in $r, $g, $b
			// Hue is converted using function hue_2_rgb, shown at the end of this code	
			// converted this method from java method found at http://www.artofwebdesign.net/colour/rgbtohsl.php 

Return Value:		


Date		Who		Reason
14 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	var1,
	var2 : Real;
	h,s,l : Real;
begin
	h:=_hue/240;
	s:=_sat/240;
	l:=_lum/240;
	if s = 0 then
		_red:=(l *255).Integer;
		_green:=(l * 255).Integer;
		_blue:=(l * 255).Integer;
	else
		if (l &lt; 0.5) then
            var2 := l * (1 + s);
        else
			var2 := (l + s) - (s * l);
		endif;
		
		var1:= 2 * l - var2;
		_red := (255 * self.convertHuetoRGB(var1,var2,h + (1 / 3))).rounded;
        _green := (255 * self.convertHuetoRGB(var1,var2,h)).rounded;
        _blue := (255 * self.convertHuetoRGB(var1,var2,h- (1 / 3))).rounded;	
	endif;

epilog

end;</source>
        <Parameter name="_hue" type="Integer" usage="input"/>
        <Parameter name="_sat" type="Integer" usage="input"/>
        <Parameter name="_lum" type="Integer" usage="input"/>
        <Parameter name="_red" type="Integer" usage="output"/>
        <Parameter name="_green" type="Integer" usage="output"/>
        <Parameter name="_blue" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="convertHuetoRGB" id="5c7c280a-67a3-46da-baaa-0a10f310e069">
        <source>convertHuetoRGB(_p1,_p2,_hue : Real input):Real;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	h : Real;
	v1,v2 :Real;
begin
	h:=_hue;
	v1:=_p1;
	v2:=_p2;
	if 	_hue &lt; 0 then
		h:=h+1;	
	endif;
	
	if 	_hue &gt; 1 then
		h:=h-1;
	endif;
	
	if ((6 * h) &lt; 1) then
		return (_p1 + (_p2 - _p1) * 6 *h);
	endif;
	
	if ((2 * h) &lt; 1) then
		return _p2;
	endif;

	if ((3 *  h) &lt; 2) then
		return (_p1 + (_p2 - _p1) * ((2 / 3 -  h) * 6));
    endif;

     return _p1;

epilog

end;</source>
        <Parameter name="_p1" type="Real" usage="input"/>
        <Parameter name="_p2" type="Real" usage="input"/>
        <Parameter name="_hue" type="Real" usage="input"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertKilosToPounds" id="3df19a06-7dbc-4421-8271-a7159fff9f25">
        <source>convertKilosToPounds(_terminal : CM_Terminal; _weight : Decimal) : Integer;
// ---------------------------------------------------------------------------
// Created:     19 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 29/04/2016		cnwmh5			Should be * not /
// ---------------------------------------------------------------------------
constants
	DIV =  2.2046226218;
vars
	
begin
	if _terminal = null then
		return _weight.Integer;
	endif;
	
	if _weight = 0 then
		return _weight.Integer;
	endif;
	
//	if not _terminal.getConfig().Boolean then
//		return _weight;
//	endif;

	return (_weight * DIV).Integer;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_weight" type="Decimal"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="convertMeasureForMaskDisplay" id="aa9599d7-ff91-485b-93e2-2d0befe7be08">
        <source>convertMeasureForMaskDisplay(_type : String; _value : Decimal) : String;
/*
Purpose:			Convert a measurement stored as metric to its display equivalent
					and format the result for display in a "feet and inches" edit mask

Parameters:			

Return Value:		

Date		Who		Reason
01/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	result : String;

begin
	result := self.convertMeasurementForDisplay(_type, _value);
	if result &lt;&gt; null then
		result := result.asFeetInchesForMask;
	endif;
	return result;
epilog

end;</source>
        <Parameter name="_type" type="String"/>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="convertMeasurementForDisplay" id="e775446c-e447-4404-aa4a-52d081f4e61f">
        <source>convertMeasurementForDisplay(_shortName : String; _value : Decimal) : String;
/*
Date		Who		Reason
21/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321
10/07/2013	cnwcs5	par 31942 - check NULL_VENTILATION
*/
vars
	measure 	: CM_MeasurementType;
	retVal	: String;


begin
	measure 	:= self.myRoot.allMeasurementTypesByShortName[_shortName];
	
	//21 Oct 2013	NDL	Par 32624
	if measure &lt;&gt; null then
		retVal := measure.convertMeasurementForDisplay( _value );
	endif;
	
	return retVal;
epilog

end;</source>
        <Parameter name="_shortName" type="String"/>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="convertMeasurementForStorage" id="c3d94fda-e7f8-478d-a4b5-7a3365918669">
        <source>convertMeasurementForStorage(_shortName : String; _value : Decimal) : Decimal;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321
14/03/2014	cnwdap1	PAR #33603 Check for locale or default decimal
06/08/2014	cnwdap1	PAR #34664 Truncate inches if somehow (normally through incorrectly-mapepd EDI field)
								we end up with more than 2 decimal places in a feet and inches field
18/04/2016	cnwdap1	TFS #1943 Ignore tiny differences in calculations
29/04/2024	jlika1	TFS 63742 CUX - 14075 error in MTN When we click on MAFI with long characters in Height field
*/
vars
	decimalSep		: String;
	measure 		: CM_MeasurementType;
	result			: Decimal [23,10];
	pos				: Integer;	
	inches			: Decimal [12,10];
	value			: Decimal [23,10];
	theEnd			: Integer;											// PAR #34664
	wholeResult		: Decimal [15, 0];									// TFS #1843	TFS3888
	diff			: Real;										// TFS #1843
	precisionError	: Boolean;
begin
	on Exception do app.handlePrecisionError(exception, precisionError);

	decimalSep := app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;
	measure := self.myRoot.allMeasurementTypesByShortName[_shortName];
	if measure &lt;&gt; null then
		if measure.isFeetAndInches then
			pos := _value.String.reversePos(decimalSep);
			if pos = null then											// PAR #33603
				pos := _value.String.reversePos(Period);				// PAR #33603
			endif;														// PAR #33603
			if pos &lt;&gt; null then
				theEnd := _value.String.length;						// PAR #34664
				if (theEnd - pos) &gt; 2 then							// PAR #34664
					theEnd := 2;									// PAR #34664
				else												// PAR #34664
					theEnd := theEnd - pos;							// PAR #34664
				endif;												// PAR #34664
				if theEnd = pos+1 then								// PAR #34664
					inches := 0;									// PAR #34664
				else												// PAR #34664
					inches := _value.String[pos+1:theEnd].Integer;	// PAR #34664
				endif;												// PAR #34664
				//inches := _value.String[pos+1:end].Integer;		// PAR #34664
				inches := inches / 12;
				value := _value.truncatedTo(0) + inches;
			else
				value := _value;
			endif;
		else
			value := _value;
		endif;
		result := (value * measure.conversionRate);
	endif;
	wholeResult := result.truncatedTo(0);									// TFS #1843	TFS3888 MAP 19/4/17
	if (result - wholeResult).abs &lt; Measure_AllowableDifference then		// TFS #1843
		result := wholeResult;												// TFS #1843
	endif;																	// TFS #1843
	
	if precisionError then				
		app.raiseCMException1(Many_digits_field_value, _value.asStringJMT &amp; " " &amp; _shortName, null, null);
	endif;
	
	return result;
epilog

end;</source>
        <Parameter name="_shortName" type="String"/>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="convertMeasurementFromTo" id="8a2e8f12-c15c-4e15-957b-f18275d9cee9">
        <source>convertMeasurementFromTo(_fromMeasure : String; _toMeasure : String; _value : Decimal) : String;

/*

Purpose:	Convert one measurement type to another		

Parameters:			

Return Value:		


Date		Who		Reason
21 March 2013	cnwrd1	Initial creation

*/

vars
	decimalSep	: String;
	fromMeasure,
 	toMeasure	: CM_MeasurementType;
	result		: Decimal [23,10];
	pos			: Integer;	
	inches		: Decimal [12,10];
	value		: Decimal [23,10];
	buildResult	: String;
	retVal		: String;

begin
	decimalSep := app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;
	fromMeasure := self.myRoot.allMeasurementTypesByShortName[_fromMeasure];
	toMeasure := self.myRoot.allMeasurementTypesByShortName[_toMeasure];
	
	if fromMeasure.measurementType &lt;&gt; toMeasure.measurementType then //not the same types!?!
		return null;
	endif;
	
	if fromMeasure &lt;&gt; null and  toMeasure &lt;&gt; null then
		if fromMeasure.isFeetAndInches then
			pos := _value.String.reversePos(decimalSep);
			if pos &lt;&gt; null then
				inches := _value.String[pos+1:end].Integer;
				inches := inches / 12;
				value := _value.truncatedTo(0) + inches;
			else
				value := _value;
			endif;
		else
			value := _value;
		endif;
		
		result := (value * fromMeasure.conversionRate) /  toMeasure.conversionRate;
		
		if toMeasure.isFeetAndInches then
			pos := result.String.reversePos(decimalSep);
			inches := result.String[pos:end].Decimal;
			inches := (12 * inches).roundedTo(0);
			if inches = 12 then
				result := result + 1;
				inches := 0;
			endif;
			buildResult := result.truncatedTo(0).String &amp; decimalSep &amp; inches.Integer.String;
			result := buildResult.Decimal;
		endif;
	endif;
	
	if result = null then
		retVal := null;
	else
		retVal := result.asStringJMTWithPrecision(toMeasure.getDecimalPrecision, false);
		if toMeasure.shortName = System_Type_Feet and inches &gt; 0 and inches &lt; 10 then
			retVal := retVal[1:retVal.length-1];
		elseif toMeasure.shortName = System_Type_Feet and inches = 0 then
			// remove the zeroes and the decimal place - just return a whole number
			retVal := retVal[1:retVal.length-3];
		endif;
	endif;
	
	return retVal;
epilog

end;</source>
        <Parameter name="_fromMeasure" type="String"/>
        <Parameter name="_toMeasure" type="String"/>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="convertPoundsToKilos" id="c5957b2d-d1cf-40be-b826-49b4a0b31c6d">
        <source>convertPoundsToKilos(_terminal : CM_Terminal; _weight : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:     19 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	DIV =  0.45359237;
vars
	
begin
	if _terminal = null then
		return _weight;
	endif;
	
	if _weight = 0 then
		return _weight;
	endif;
	
//	if not _terminal.getConfig().Boolean then
//		return _weight;
//	endif;

	return (_weight / DIV).Integer;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_weight" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="convertRGBToColor" id="ac99de2d-e311-4a38-a4ff-87f972e87f65">
        <source>convertRGBToColor(_red, _green, _blue : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:     29 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	return _red + (_green * 256) + (_blue * 256 * 256);

end;</source>
        <Parameter name="_red" type="Integer"/>
        <Parameter name="_green" type="Integer"/>
        <Parameter name="_blue" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="convertRGBtoHSL" id="22fb8c79-2d1c-4205-bb73-97aeeccde8d2">
        <source>convertRGBtoHSL(_red,
					_green,
					_blue : Integer input;
					_hue,
					_sat,
					_lum : Integer output);
/*

Purpose:		// Input is red, green and blue from above
				// Output is HSL 
				// converted this method from java method found at http://www.artofwebdesign.net/colour/rgbtohsl.php 
				// works well


Return Value:		


Date		Who		Reason
14 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	pMin,
	pMax,
	delMax: Real;
	h,
	s,
	l : Real;
	delR,
	delG,
	delB : Real;
	red,
	green,
	blue : Real;
begin
	//convert to fractions;
	red:=_red/255;
	green:=_green/255;
	blue:=_blue/255;
	
	pMin:=red.min(green);
	pMin:=pMin.min(blue);
	pMax:=red.max(green);
	pMax:=pMax.max(blue);
	delMax:=pMax-pMin;
	l:=(pMax + pMin)/2;
	if delMax = 0 then
		h:=0;
		s:=0;
	else
		if l &lt; 0.5 then
			s:=delMax/(pMax + pMin);
		else
			s:=delMax/(2 - pMax - pMin);
		endif;
		delR:= (((pMax - red) / 6) + (delMax / 2)) / delMax;
		delG:= (((pMax - green) / 6) + (delMax / 2)) / delMax;
		delB:= (((pMax- blue) / 6) + (delMax / 2)) / delMax;
		 
        if (red = pMax) then
            h:= delB - delG;
            
		elseif (green = pMax) then
            h := (1 / 3) + delR - delB;
		elseif (blue = pMax) then
            h := (2 / 3) + delG - delR;
         endif;

        if (h &lt; 0) then
            h := h + 1;
        endif;

        if (h &gt; 1) then
			h:= h - 1;
        endif;
	endif;
	_hue :=(h*240).rounded;
	_lum:=(l*240).rounded;
	_sat:=(s*240).rounded;

epilog

end;</source>
        <Parameter name="_red" type="Integer" usage="input"/>
        <Parameter name="_green" type="Integer" usage="input"/>
        <Parameter name="_blue" type="Integer" usage="input"/>
        <Parameter name="_hue" type="Integer" usage="output"/>
        <Parameter name="_sat" type="Integer" usage="output"/>
        <Parameter name="_lum" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="convertScannedCargoId" id="45d17a8e-b970-4865-801a-ca8833281962">
        <source>convertScannedCargoId( _term : CM_Terminal; _textBox : TextBox input; _isAlternateId : Boolean; _passedCmif : CMIF_IDConversion input ):String;
/*

Purpose:			

Parameters:			Scanned Vehicle VIN numbers sometimes contain extra characters
					as prefixes or suffixs, depending upon the manufacture.
					The displayed VIN number is always 17 characters, and for Oman is used as teh cargo id.
					
					Use _textBox by itself, to take the value directly from the text box, convert it and set
					back into the text box. 
					
					Supply the cmif to use, already populated to ( reset the optionally supplied texbox, or )
					to just return the converted string value.

Return Value:		

Date		Who		Reason
05 July 2016	cnwndl1	Initial creation	TFS 2275 / 2216

*/

vars

	cmif : CMIF_IDConversion;
	rawText : String;
	processedText : String;
	doDeleteCmif : Boolean;
	root : CM_Root;
	
begin

	if _passedCmif &lt;&gt; null and _passedCmif.scannedValue &lt;&gt; null then
		rawText := _passedCmif.scannedValue;
	elseif _textBox &lt;&gt; null then
		rawText := _textBox.text;
	endif;
	
	if rawText = null then
		return null;
	endif;

	if _passedCmif &lt;&gt; null then
		// if there is a passed in version then use it because it may have other context attributes
		// that are also populated that help the comversion.
		doDeleteCmif := false;
		cmif := _passedCmif;
		if cmif.myTerminal = null then
			cmif.myTerminal := _term;
		endif;
		if cmif.scannedValue = null then
			cmif.scannedValue := rawText;
		endif;
		if not cmif.isAlternateId then
			cmif.isAlternateId := _isAlternateId;
		endif;
	
	else
		doDeleteCmif := true;
		create cmif transient;
		cmif.myTerminal := _term;
		cmif.scannedValue := rawText;
		cmif.isAlternateId := _isAlternateId;
		cmif.callerName := null;	//18 Aug 2016	NDL	TFS 2567 - in 8.4.2.120, if we keep this crap, add a form ref to populate this.
		
	endif;
	
	root := app.myRoot;
	// default behaviour for the hook code is to call root::doConvertCargoId
	processedText :=  app.myHookAgent.runHookLinkPublic(HookType_CargoIdConversion,
														root,
														root,
														cmif
														).String;
		

	if _textBox &lt;&gt; null then
		_textBox.text := processedText;
	endif;
	
	return processedText;

epilog

	if doDeleteCmif then
		delete cmif;
	endif;

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_textBox" type="TextBox" usage="input"/>
        <Parameter name="_isAlternateId" type="Boolean"/>
        <Parameter name="_passedCmif" type="CMIF_IDConversion" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="convertStringToPDF417" id="c83951f0-30fe-489d-9b22-688982f5f24c">
        <source>convertStringToPDF417( _str : String ):Binary;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Oct 2015	cnwndl1	Initial creation	Par 36777
29 Oct 2015	cnwkpd1	PAR #36777 - Use external PDF417 generator

*/

vars
	bg				: CMIF_BarcodeGenerator;
	
begin
	create bg transient;
	return bg.generatePDF417Barcode(_str);

epilog
	delete bg;
	
end;</source>
        <Parameter name="_str" type="String"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="coolingTypeENumToString" id="bf817295-9a9e-44a6-aa18-ca99be66d62e">
        <source>coolingTypeENumToString(_coolingType : Integer; _short : Boolean):String;
//--------------------------------------------------
// Created:	2 June 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	if _coolingType = ContainerAirCooled then
		if _short then
			return 'AC';
		else	
			return ContainerAirCooledStr;
		endif;
	elseif _coolingType = ContainerWaterCooled then
		if _short then
			return 'WC';
		else	
			return ContainerWaterCooledStr;
		endif;
	elseif _coolingType = ContainerCooledNull then
		return ContainerCooledNullStr;		
	else
		return app.getErrorString(Unknown);
	endif;		

end;</source>
        <Parameter name="_coolingType" type="Integer"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
