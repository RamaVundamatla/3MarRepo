    <JadeMethod name="getWSCommodity" id="98ef98f2-3c8b-4ca9-9a34-310e9cf9f540">
        <source>getWSCommodity():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Nov 2023 navhl20 ChangeRequest 58756:[60740] EUP | VAS Mobile App - [53813.010] VAS Mobile App
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray

*/

vars
	ti 				: CM_TrackedItem;
	commodity,
	str				: String;
	invalidObject	: Boolean;
	edition			: Integer;
	objset			: CM_ObjectSet;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalidObject);
	
	create objset transient;
	
	foreach ti in self.allTrackedItems discreteLock do
		invalidObject := false;
		edition 	  := ti.edition;
		
		if invalidObject then
			continue;
		endif;
		
		objset.tryAddIfNotNull(ti.getCommodityObject());
	endforeach;
	
	if objset.isNotEmpty then
		return objset.listString(Comma,CM_Commodity::code.name);
	endif;
	
	return null;
epilog
	delete objset;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWSOperator" id="43aa0f21-029f-4cf0-a722-b84ac95ea8c8">
        <source>getWSOperator():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Nov 2023 navhl20 ChangeRequest 58756:[60740] EUP | VAS Mobile App - [53813.010] VAS Mobile App
06 Mar 2025 navma1 	MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	ti 				: CM_TrackedItem;
	operator,
	str				: String;
	invalidObject	: Boolean;
	edition			: Integer;
	objset	    	: CM_ObjectSet;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalidObject);
	
	create objset transient;
	foreach ti in self.allTrackedItems discreteLock do		//06.03.2025 navma1 #MTN-34179
		invalidObject := false;
		edition 	  := ti.edition;
		
		if invalidObject then
			continue;
		endif;
		
		objset.tryAddIfNotNull(ti.myOperator);
	endforeach;
	
	if objset.isNotEmpty then
		return objset.listString(Comma,CM_Operator::code.name);
	endif;
	
	return null;
epilog
	delete objset;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWSTerminalArea" id="53310462-b551-4957-955c-daec20424b9a">
        <source>getWSTerminalArea():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Nov 2023 navhl20 ChangeRequest 58756:[60740] EUP | VAS Mobile App - [53813.010] VAS Mobile App
21 Jun 2024 navhl20 Bug 64743: EUP | VAS: For multi-cargo groups, no data is shown for the location column.
01 Oct 2024 navhl20 Bug 32981 EUP - Todo Tasks Job complete for Partial Receive and Release Work orders
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	ti 				: CM_TrackedItem;
	tArea,
	str				: String;
	invalidObject	: Boolean;
	edition			: Integer;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalidObject);
	foreach ti in self.allTrackedItems discreteLock do			//06.03.2025 navma1 #MTN-34179
		invalidObject := false;
		edition 	  := ti.edition;
		
		if invalidObject then
			continue;
		endif;

		if ti.isCargoGroupItem then											//21.06.2024 navhl20 #64743
			tArea	:= ti.CM_CargoGroup.getCargoGroupDetailLocations();
		else
			tArea	:= ti.terminalAreaId;
		endif;
		
		if tArea &lt;&gt; null then												//01.10.2024 navhl20 #32981
			if str = null then
				str := str &amp; tArea;
			elseif not str.cnContains(tArea) then
				str := str &amp; Comma &amp; tArea;
			endif;
		endif;
	endforeach;
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
