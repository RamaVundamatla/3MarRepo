    <JadeMethod name="doIMVSwitch" id="6f4d6710-b45a-4d0b-a5df-ef595c6197ed">
        <source>doIMVSwitch(_task :CM_RTQueueTask; _imv :CM_Machine)protected;
// ---------------------------------------------------------------------------
// Created:     30 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// ---------------------------------------------------------------------------
vars
	proxy 	:CM_RTQueueTask;
	bln		:Boolean;
begin
	app.cmsBeginLoad(bln);
	proxy := _task.pxyCreateUpdateProxy();
	app.cmsEndLoad(bln);
	
	proxy.setProxyAllocMachine(_imv, _task.myEntry, _task.sourceLocation, _task.targetLocation, _task.ti);

	app.myTrxUA.trxUpdateTaskSwitchIMV (proxy, app.myPassport);
epilog
	app.cmsEndLoad(bln);				// 08/04/2011 cnwmh5 #27347
	delete proxy;
end;</source>
        <access>protected</access>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <Parameter name="_imv" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="findTaskForTI" id="e201c1d6-cef7-4242-a8f4-9ab5db7e62fb">
        <source>findTaskForTI(_machine :CM_Machine; _ti :CM_TrackedItem):CM_RTQueueTask protected;
// ---------------------------------------------------------------------------
// Created:     30 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	task :CM_RTQueueTask;
begin
	foreach task in _machine.allCurrentWorkingQueueTasks do
		if task.ti = _ti then
			return task;
		endif;
	endforeach;
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="getHistoryForTI" id="de34c271-5d32-4236-8839-81c56c1d5878">
        <source>getHistoryForTI(_type :Integer; _machine :CM_Machine; _id :String) :CM_MachineMoveHistory protected;
// ---------------------------------------------------------------------------
// Created:     25 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	history :CM_MachineHistory;
begin
	foreach history in _machine.history reversed do
		if history.isKindOf (CM_MachineLogOnOffHistory) then
			// not gonna find it
			break;
		endif;
		if history.CM_MachineMoveHistory.tiId &lt;&gt; _id then
			continue;
		endif;
		
		if history.type = _type then
			return history.CM_MachineMoveHistory;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_MachineMoveHistory"/>
    </JadeMethod>
    <JadeMethod name="tCorrectConfirmedIMV" id="dab93e2e-c13d-4aee-9edd-15fbc241b9af">
        <source>tCorrectConfirmedIMV();
/*

Purpose:			Testlink 01-742

Date		Who		Reason
08 April 2016	cnwmk3	Initial creation

*/
constants
	IMV1					= "IMV1";
	IMV2					= "IMV2";
vars
	rtgArea1, rtgArea2		: CM_RTGArea;
	rtgAreaQueue			: CM_SubQueue;
	tas						: StringArray;
	rtg, imv1, imv2			: CM_Machine;
	ti						: CM_Container;
	task					: CM_RTQueueTask;
begin
	self.deleteTerminalArea("UT_RTG1");
	rtgArea1 := self.addRTGArea("UT_RTG1", 5, 2, 5);
	
	self.deleteTerminalArea("UT_RTG2");
	rtgArea2 := self.addRTGArea("UT_RTG2", 5, 2, 5);
	
	// add machine rule
	self.addMachineRule (rtgArea1, rtgArea2, RTMoveMethod_11);
	
	// add queue
	self.deleteQueue("UTQueue");
	rtgAreaQueue := self.addQueueToTA("UTQueue", rtgArea1);
		
	create tas transient;
	tas.add(rtgArea1.id);
	tas.add(rtgArea2.id);
	
	// add RTG machine
	deleteMachine("129");
	rtg := self.addMachine(MACHINETYPE_RTG, "129", 120, tas, "UTQueue");
	self.assertNotNull(rtg);
	
	// log in as RTG
	app.isRTApp:=true;  
	self.machineLogon(rtg);
	
	// add IMV1
	imv1 := self.addIMV(IMV1, 93, tas, rtgAreaQueue.id);
	
	// add IMV2
	imv2 := self.addIMV(IMV2, 94, tas, rtgAreaQueue.id);
	
	// log IMV1 and IMV2
	self.machineLogon(imv1);
	self.machineLogon(imv2);
	
	// create a container
	self.deleteContainer("CONTR00001");
	ti := self.addContainerAtLocation("CONTR00001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200", "APPL", TI_IMEX_STATUS_EXPORT, rtgArea1.allLocationsControllers.first);
	self.assertNotNull(ti);
	
	// queue ti from rtgArea1 to rtgArea2
	self.moveQueued(ti, rtgArea2.allLocationsControllers.first);
	
	// check that ti appear in the RTG machine queue
	self.assertNotNull(rtgAreaQueue.allEntries.first);
	
	// select and accept using RTG machine
	task :=ti.getDirectorOrPickupTask();// self.machineTaskRequest(straddle1);
	assertEqual(task.taskType, TASK_PICKUP);
	self.machineAcceptTask(rtg, task);
	
	self.machinePickup(rtg);
	
	// Set down on IMV1
	self.machineSetdown(rtg, ti, IMV1);
	self.assertEqual(ti.myPrimaryActualLocation, imv1.myMachineController);
	
	task := self.findTaskForTI(imv1, ti);
	
	// Amend machine and select another logged in IMV vehicle, IMV 2.
	self.doIMVSwitch(task, imv2);
	
	task := imv2.allCurrentQueueTasks.first;
	assertEqual(task.taskType, TASK_MOVE);
	
	move(task.ti, rtgArea2.allLocationsControllers.first);
	self.assertEqual(ti.myPrimaryActualLocation, rtgArea2.allLocationsControllers.first);
	
	// Check the job can be completed.
	self.assertNull(imv2.allCurrentQueueTasks.first);
epilog
	
	app.isRTApp:=false; 

	delete tas;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDriverInitiatedMoves" id="d088e108-8ab4-4e36-9342-3073f598fd71">
        <source>tDriverInitiatedMoves();
// cnwrs1
/*
Date		Who		Reason
14 Nov 2012	cnwcs5	Initial creation - par 30730
//27 Jan 2016	cnwrs1	Cleanup garbage leftover from another unit test
*/
constants
	TrackedItem1 			= "UT100";
	TrackedItem2 			= "UT200";
	StraddleStack1 			= "UT_STA";
	QueueForStraddleStack1 	= "UT_STA_Q";
	StraddleStack2 			= "UT_STB";
	QueueForStraddleStack2 	= "UT_STB_Q";
	Straddle1 				= "UTS1";
vars
	ti1, ti2	: CM_TrackedItem;
	st1, st2	: CM_GridArea;
	q1, q2		: CM_RadioTelemetryQueue;
	tas			: StringArray;
	straddle	: CM_Machine;
	task		: CM_RTQueueTask;
	accept, pickup1, pickup2, setdown1, setdown2	: CM_MachineMoveHistory;
begin
	self.deleteContainer(TrackedItem1);
	self.deleteContainer(TrackedItem2);
//	self.deleteQueue("UTMHMTV");
	self.deleteQueue(QueueForStraddleStack1);
	self.deleteTerminalArea(StraddleStack1);
	self.deleteQueue(QueueForStraddleStack2);
	self.deleteTerminalArea(StraddleStack2);
	self.deleteMachine(Straddle1);
	self.deleteRTDevice("91");
	self.deleteTerminalArea(StraddleStack1);
	self.deleteTerminalArea(StraddleStack2);

	st1 := self.addStraddleStack(StraddleStack1, 2, 2, 2);
	q1 	:= self.addQueueToTA(QueueForStraddleStack1, StraddleStack1);
	self.assertNotNull(q1);
	
	st2 := self.addStraddleStack(StraddleStack2, 2, 2, 2);
	q2 	:= self.addQueueToTA(QueueForStraddleStack2, StraddleStack2);
	self.assertNotNull(q2);

	// move TI1 into straddle stack
	ti1 := self.addContainer(TrackedItem1, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti1, st1.allGridControllersByRowColumn[1, 1]);
	self.assertEqual(ti1.myPrimaryActualLocation, st1.allGridControllersByRowColumn[1, 1]);
	// move TI2 into straddle stack
	ti2 := self.addContainer(TrackedItem2, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti2, st1.allGridControllersByRowColumn[2, 1]);
	self.assertEqual(ti2.myPrimaryActualLocation, st1.allGridControllersByRowColumn[2, 1]);
	
	// assigning straddle to area ???
	create tas transient;
	tas.add(StraddleStack1); tas.add(StraddleStack2);
	self.addStraddle(Straddle1, 91, tas, QueueForStraddleStack2);
	
	straddle := self.getMachine(Straddle1);
	self.assertNotNull(straddle);
	self.machineLogon(straddle);
	
//	Test 1 - Simple driver initiated move move of ti2 from one place to another

	// do pickup of other cargo - like a driver initiated move of move of overstowed cargo.  this pickup will not have a task
	app.myTrxRT.trxRTGMoveTI(straddle, ti1, null, straddle.myMachineController, false, false, null, false, null, null, null,app.myPassport);
	// check history
	pickup1 := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(pickup1.type, CM_MachineHistory.Type_PickUp);
	self.assertEqual(pickup1.isStartOfLift, true);
	self.assertEqual(pickup1.isEndOfLift, false);
	self.assertEqual(pickup1.myPriorLiftHistory, null);
	self.assertEqual(pickup1.myPriorHistory, null);
	self.assertEqual(ti1.id, pickup1.tiId);		
			
	// do setdown
	app.myTrxRT.trxRTGMoveTI(straddle, ti1, null, st2.allGridControllersByRowColumn[1, 1], false, false, null, false, null, null,null, app.myPassport);
	
	setdown1 := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(setdown1.type, CM_MachineHistory.Type_SetDown);
	self.assertEqual(setdown1.isStartOfLift, false);
	self.assertEqual(setdown1.isEndOfLift, true);
	self.assertEqual(setdown1.myPriorLiftHistory, pickup1);
	self.assertEqual(setdown1.myPriorHistory, pickup1);
	self.assertEqual(ti1.id, setdown1.tiId);		
	self.assertEqual(pickup1.myNextLiftHistory, setdown1);
	self.assertEqual(pickup1.myNextHistory, setdown1);

	self.assertEqual(ti1.myPrimaryActualLocation, st2.allGridControllersByRowColumn[1, 1]);		

//	TEST 2 - Accept an RT task and then do driver initiated move then complete the RT task
	// queue TI1 to original location
	self.moveQueued(ti1, st1.allGridControllersByRowColumn[1, 1]);

	task := self.machineTaskRequest(straddle);
	self.assertNotNull(task);
	self.assertEqual(task.taskType, TASK_PICKUP);
	self.assertEqual(task.status, TASK_OFFERED);
	// if there is any rubbish left in the queue then reject it
	while task.tiId &lt;&gt; ti1.id do
		self.machineCancelTask(straddle);
		task := self.machineTaskRequest(straddle);
		self.assertNotNull(task);
		self.assertEqual(task.taskType, TASK_PICKUP);
		self.assertEqual(task.status, TASK_OFFERED);
	endwhile;
	// accept task
	self.machineAcceptTask(straddle, task);
	// check history
	accept := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(accept.type, CM_MachineHistory.Type_AcceptMove);
	self.assertEqual(accept.isStartOfLift, true);
	self.assertEqual(accept.isEndOfLift, false);
	self.assertEqual(accept.myPriorLiftHistory, null);
	self.assertEqual(accept.myPriorHistory, null);
	self.assertEqual(accept.tiId, ti1.id);
			
	// do driver initiated move of ti2 to other straddle stack
	// do pickup of other cargo - like a driver initiated move of move of overstowed cargo.  this pickup will not have a task
	app.myTrxRT.trxRTGMoveTI(straddle, ti2, null, straddle.myMachineController, false, false, null, false, null, null,null, app.myPassport);
	// check history
	pickup2 := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(pickup2.type, CM_MachineHistory.Type_PickUp);
	self.assertEqual(pickup2.isStartOfLift, false);
	self.assertEqual(pickup2.isEndOfLift, false);
	self.assertEqual(pickup2.myPriorLiftHistory, accept);
	self.assertEqual(pickup2.myPriorHistory, null);
	self.assertEqual(ti2.id, pickup2.tiId);		
			
	self.assertEqual(accept.myNextLiftHistory, pickup2);
	self.assertEqual(accept.myNextHistory, null);
			
	// do setdown of driver initiated move
	app.myTrxRT.trxRTGMoveTI(straddle, ti2, null, st2.allGridControllersByRowColumn[2, 1], false, false, null, false, null, null,null, app.myPassport);
	
	setdown2 := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(setdown2.type, CM_MachineHistory.Type_SetDown);
	self.assertEqual(setdown2.isStartOfLift, false);
	self.assertEqual(setdown2.isEndOfLift, false);
	self.assertEqual(setdown2.myPriorLiftHistory, pickup2);
	self.assertEqual(setdown2.myPriorHistory, pickup2);
	self.assertEqual(ti2.id, setdown2.tiId);		
	self.assertEqual(pickup2.myNextLiftHistory, setdown2);
	self.assertEqual(pickup2.myNextHistory, setdown2);

	self.assertEqual(ti2.myPrimaryActualLocation, st2.allGridControllersByRowColumn[2, 1]);		

	// do pickup for ti1
	self.machinePickup(straddle);
	pickup1 := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(pickup1.type, CM_MachineHistory.Type_PickUp);
	self.assertEqual(pickup1.isStartOfLift, false);
	self.assertEqual(pickup1.isEndOfLift, false);
	self.assertEqual(pickup1.myPriorLiftHistory, setdown2);
	self.assertEqual(pickup1.myPriorHistory, accept);
	self.assertEqual(ti1.id, pickup1.tiId);		
			
	self.assertEqual(accept.myNextLiftHistory, pickup2);
	self.assertEqual(accept.myNextHistory, pickup1);
			
	self.machineSetdown(straddle, ti1, StraddleStack1 &amp; " 010001");
	setdown1 := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(setdown1.type, CM_MachineHistory.Type_SetDown);
	self.assertEqual(setdown1.isStartOfLift, false);
	self.assertEqual(setdown1.isEndOfLift, true);
	self.assertEqual(setdown1.myPriorLiftHistory, pickup1);
	self.assertEqual(setdown1.myPriorHistory, pickup1);
	self.assertEqual(ti1.id, setdown1.tiId);		
			
	self.assertEqual(pickup1.myNextLiftHistory, setdown1);
	self.assertEqual(pickup1.myNextHistory, setdown1);
			
	self.assertEqual(ti1.myPrimaryActualLocation, st1.allGridControllersByRowColumn[1, 1]);
			
//	TEST 3 - Accept/pickup an RT task and then do driver initiated move then complete the RT task
	// queue TI1 to another location
	self.moveQueued(ti1, st2.allGridControllersByRowColumn[1, 1]);

	task := self.machineTaskRequest(straddle);
	
	self.assertEqual(task.taskType, TASK_PICKUP);
	self.assertEqual(task.status, TASK_OFFERED);
	
	// accept task
	self.machineAcceptTask(straddle, task);
	// check history
	accept := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(accept.type, CM_MachineHistory.Type_AcceptMove);
	self.assertEqual(accept.isStartOfLift, true);
	self.assertEqual(accept.isEndOfLift, false);
	self.assertEqual(accept.myPriorLiftHistory, null);
	self.assertEqual(accept.myPriorHistory, null);
	self.assertEqual(accept.tiId, ti1.id);
			
	// do pickup for ti1
	self.machinePickup(straddle);
	pickup1 := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(pickup1.type, CM_MachineHistory.Type_PickUp);
	self.assertEqual(pickup1.isStartOfLift, false);
	self.assertEqual(pickup1.isEndOfLift, false);
	self.assertEqual(pickup1.myPriorLiftHistory, accept);
	self.assertEqual(pickup1.myPriorHistory, accept);
	self.assertEqual(ti1.id, pickup1.tiId);		
			
	self.assertEqual(accept.myNextLiftHistory, pickup1);
	self.assertEqual(accept.myNextHistory, pickup1);

	// do driver initiated move of ti2 to other straddle stack
	// do pickup of other cargo - like a driver initiated move of move of overstowed cargo.  this pickup will not have a task
	app.myTrxRT.trxRTGMoveTI(straddle, ti2, null, straddle.myMachineController, false, false, null, false, null, null,null, app.myPassport);
	// check history
	pickup2 := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(pickup2.type, CM_MachineHistory.Type_PickUp);
	self.assertEqual(pickup2.isStartOfLift, false);
	self.assertEqual(pickup2.isEndOfLift, false);
	self.assertEqual(pickup2.myPriorLiftHistory, pickup1);
	self.assertEqual(pickup2.myPriorHistory, null);
	self.assertEqual(ti2.id, pickup2.tiId);		
			
	self.assertEqual(pickup1.myNextLiftHistory, pickup2);
	self.assertEqual(accept.myNextHistory, pickup1);
			
	// do setdown of driver initiated move
	app.myTrxRT.trxRTGMoveTI(straddle, ti2, null, st1.allGridControllersByRowColumn[2, 1], false, false, null, false, null, null, null,app.myPassport);
	
	setdown2 := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(setdown2.type, CM_MachineHistory.Type_SetDown);
	self.assertEqual(setdown2.isStartOfLift, false);
	self.assertEqual(setdown2.isEndOfLift, false);
	self.assertEqual(setdown2.myPriorLiftHistory, pickup2);
	self.assertEqual(setdown2.myPriorHistory, pickup2);
	self.assertEqual(ti2.id, setdown2.tiId);		
	self.assertEqual(pickup2.myNextLiftHistory, setdown2);
	self.assertEqual(pickup2.myNextHistory, setdown2);

	self.assertEqual(ti2.myPrimaryActualLocation, st1.allGridControllersByRowColumn[2, 1]);		
	
	// now do the setdown for the RT task
	self.machineSetdown(straddle, ti1, StraddleStack2 &amp; " 010001");
	
	setdown1 := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(setdown1.type, CM_MachineHistory.Type_SetDown);
	self.assertEqual(setdown1.isStartOfLift, false);
	self.assertEqual(setdown1.isEndOfLift, true);
	self.assertEqual(setdown1.myPriorLiftHistory, setdown2);
	self.assertEqual(setdown1.myPriorHistory, pickup1);
	self.assertEqual(ti1.id, setdown1.tiId);		
			
	self.assertEqual(setdown2.myNextLiftHistory, setdown1);
	self.assertEqual(pickup2.myNextHistory, setdown2);

	self.assertEqual(ti1.myPrimaryActualLocation, st2.allGridControllersByRowColumn[1, 1]);

//	TEST 4 - Accept/pickup an RT task and then do driver initiated pickup then complete the RT task the do driver initiated setdown
	// queue TI1 to another location
	self.moveQueued(ti1, st1.allGridControllersByRowColumn[1, 1]);

	task := self.machineTaskRequest(straddle);
	
	self.assertEqual(task.taskType, TASK_PICKUP);
	self.assertEqual(task.status, TASK_OFFERED);
	
	// accept task
	self.machineAcceptTask(straddle, task);
	// check history
	accept := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(accept.type, CM_MachineHistory.Type_AcceptMove);
	self.assertEqual(accept.isStartOfLift, true);
	self.assertEqual(accept.isEndOfLift, false);
	self.assertEqual(accept.myPriorLiftHistory, null);
	self.assertEqual(accept.myPriorHistory, null);
	self.assertEqual(accept.tiId, ti1.id);
			
	// do pickup for ti1
	self.machinePickup(straddle);
	pickup1 := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(pickup1.type, CM_MachineHistory.Type_PickUp);
	self.assertEqual(pickup1.isStartOfLift, false);
	self.assertEqual(pickup1.isEndOfLift, false);
	self.assertEqual(pickup1.myPriorLiftHistory, accept);
	self.assertEqual(pickup1.myPriorHistory, accept);
	self.assertEqual(ti1.id, pickup1.tiId);		
			
	self.assertEqual(accept.myNextLiftHistory, pickup1);
	self.assertEqual(accept.myNextHistory, pickup1);

	// do driver initiated move of ti2 to other straddle stack
	// do pickup of other cargo - like a driver initiated move of move of overstowed cargo.  this pickup will not have a task
	app.myTrxRT.trxRTGMoveTI(straddle, ti2, null, straddle.myMachineController, false, false, null, false, null, null,null, app.myPassport);
	// check history
	pickup2 := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(pickup2.type, CM_MachineHistory.Type_PickUp);
	self.assertEqual(pickup2.isStartOfLift, false);
	self.assertEqual(pickup2.isEndOfLift, false);
	self.assertEqual(pickup2.myPriorLiftHistory, pickup1);
	self.assertEqual(pickup2.myPriorHistory, null);
	self.assertEqual(ti2.id, setdown2.tiId);		
			
	self.assertEqual(pickup1.myNextLiftHistory, pickup2);
	self.assertEqual(accept.myNextHistory, pickup1);
			
	// now do the setdown for the RT task
	self.machineSetdown(straddle, ti1, StraddleStack1 &amp; " 010001");
	
	setdown1 := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(setdown1.type, CM_MachineHistory.Type_SetDown);
	self.assertEqual(setdown1.isStartOfLift, false);
	self.assertEqual(setdown1.isEndOfLift, false);
	self.assertEqual(setdown1.myPriorLiftHistory, pickup2);
	self.assertEqual(setdown1.myPriorHistory, pickup1);
	self.assertEqual(ti1.id, setdown1.tiId);		
			
	self.assertEqual(pickup2.myNextLiftHistory, setdown1);
	self.assertEqual(pickup2.myNextHistory, null);

	self.assertEqual(ti1.myPrimaryActualLocation, st1.allGridControllersByRowColumn[1, 1]);
			
	// do setdown of driver initiated move
	app.myTrxRT.trxRTGMoveTI(straddle, ti2, null, st1.allGridControllersByRowColumn[2, 1], false, false, null, false, null, null,null, app.myPassport);
	
	setdown2 := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(setdown2.type, CM_MachineHistory.Type_SetDown);
	self.assertEqual(setdown2.isStartOfLift, false);
	self.assertEqual(setdown2.isEndOfLift, true);
	self.assertEqual(setdown2.myPriorLiftHistory, setdown1);
	self.assertEqual(setdown2.myPriorHistory, pickup2);
	self.assertEqual(ti2.id, setdown2.tiId);		
	self.assertEqual(pickup2.myNextLiftHistory, setdown1);
	self.assertEqual(pickup2.myNextHistory, setdown2);

	self.assertEqual(ti2.myPrimaryActualLocation, st1.allGridControllersByRowColumn[2, 1]);		
	
//	TEST 5 - Accept an RT task and then do driver initiated pickup then pickup/setdown the RT task then do driver initiated setdown
	// queue TI1 to another location
	self.moveQueued(ti1, st1.allGridControllersByRowColumn[1, 1]);

	task := self.machineTaskRequest(straddle);
	
	self.assertEqual(task.taskType, TASK_PICKUP);
	self.assertEqual(task.status, TASK_OFFERED);
	
	// accept task
	self.machineAcceptTask(straddle, task);
	// check history
	accept := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(accept.type, CM_MachineHistory.Type_AcceptMove);
	self.assertEqual(accept.isStartOfLift, true);
	self.assertEqual(accept.isEndOfLift, false);
	self.assertEqual(accept.myPriorLiftHistory, null);
	self.assertEqual(accept.myPriorHistory, null);
	self.assertEqual(accept.tiId, ti1.id);
			
	// do driver initiated move of ti2 to other straddle stack
	// do pickup of other cargo - like a driver initiated move of move of overstowed cargo.  this pickup will not have a task
	app.myTrxRT.trxRTGMoveTI(straddle, ti2, null, straddle.myMachineController, false, false, null, false, null, null,null, app.myPassport);
			
	pickup1 := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(pickup1.type, CM_MachineHistory.Type_PickUp);
	self.assertEqual(pickup1.isStartOfLift, false);
	self.assertEqual(pickup1.isEndOfLift, false);
	self.assertEqual(pickup1.myPriorLiftHistory, accept);
	self.assertEqual(pickup1.myPriorHistory, null);
	self.assertEqual(pickup1.tiId, ti2.id);
	self.assertEqual(accept.myNextLiftHistory, pickup1);
	self.assertEqual(accept.myNextHistory, null);
			
	// do pickup for ti1
	self.machinePickup(straddle);
	// check history
	pickup2 := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(pickup2.type, CM_MachineHistory.Type_PickUp);
	self.assertEqual(pickup2.isStartOfLift, false);
	self.assertEqual(pickup2.isEndOfLift, false);
	self.assertEqual(pickup2.myPriorLiftHistory, pickup1);
	self.assertEqual(pickup2.myPriorHistory, accept);
	self.assertEqual(pickup2.tiId, ti1.id);
	self.assertEqual(pickup1.myNextLiftHistory, pickup2);
	self.assertEqual(accept.myNextHistory, pickup2);
			
	// now do the setdown for the RT task
	self.machineSetdown(straddle, ti1, StraddleStack1 &amp; " 010001");
	
	setdown1 := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(setdown1.type, CM_MachineHistory.Type_SetDown);
	self.assertEqual(setdown1.isStartOfLift, false);
	self.assertEqual(setdown1.isEndOfLift, false);
	self.assertEqual(setdown1.myPriorLiftHistory, pickup2);
	self.assertEqual(setdown1.myPriorHistory, pickup2);
	self.assertEqual(setdown1.tiId, ti1.id);
	self.assertEqual(pickup2.myNextLiftHistory, setdown1);
	self.assertEqual(pickup2.myNextHistory, setdown1);

	self.assertEqual(ti1.myPrimaryActualLocation, st1.allGridControllersByRowColumn[1, 1]);
			
	// do setdown of driver initiated move
	app.myTrxRT.trxRTGMoveTI(straddle, ti2, null, st1.allGridControllersByRowColumn[2, 1], false, false, null, false, null, null,null, app.myPassport);
	
	setdown2 := straddle.history.last.CM_MachineMoveHistory;
	self.assertEqual(setdown2.type, CM_MachineHistory.Type_SetDown);
	self.assertEqual(setdown2.isStartOfLift, false);
	self.assertEqual(setdown2.isEndOfLift, true);
	self.assertEqual(setdown2.myPriorLiftHistory, setdown1);
	self.assertEqual(setdown2.myPriorHistory, pickup1);
	self.assertEqual(setdown2.tiId, ti2.id);
	self.assertEqual(pickup1.myNextLiftHistory, pickup2);
	self.assertEqual(pickup1.myNextHistory, setdown2);

	self.assertEqual(ti2.myPrimaryActualLocation, st1.allGridControllersByRowColumn[2, 1]);		
	
	// logoff
	self.machineLogOff(straddle);
epilog 
	delete tas;
end;</source>
    </JadeMethod>
    <JadeMethod name="tIMVSwitch" id="3305858a-3177-402d-9c26-b3207e99e45f">
        <source>tIMVSwitch();
// cnwrs1
// ---------------------------------------------------------------------------
// Created:     15 November 2010 by cnwcs5
// Purpose:     Test move between straddle stacks via IMV
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	TrackedItem1 			= "UT100";
	TrackedItem2 			= "UT200";
	StraddleStack1 			= "UT_ST1";
	QueueForStraddleStack1 	= "UT_ST1_Q";
	StraddleStack2			= "UT_ST2";
	QueueForStraddleStack2 	= "UT_ST2_Q";
	Straddle1 				= "UTS1";
	Straddle2				= "UTS2";
	IMV1					= "UTI1";
	IMV2					= "UTI2";
vars
	ti1, ti2	: CM_TrackedItem;
	st1, st2	: CM_GridArea;
	q1, q2		: CM_RadioTelemetryQueue;
	tas			: StringArray;
	straddle1, straddle2, imv1, imv2	: CM_Machine;
	task1, task2,
	imvTask1, imvTask2: CM_RTQueueTask;
	accept11,accept12, accept13,
	pickup11, pickup12, pickup13, 
	setdown11, setdown12, setdown13	,
	accept21,accept22, accept23,
	pickup21, pickup22, pickup23, 
	setdown21, setdown22, setdown23, switch1, switch2: CM_MachineMoveHistory;
	history		: CM_MachineHistory;
	count		: Integer;
begin
	self.deleteContainer(TrackedItem1);
	self.deleteContainer(TrackedItem2);
	self.deleteQueue(QueueForStraddleStack1);
	self.deleteQueue(QueueForStraddleStack2);
	self.deleteTerminalArea(StraddleStack1);
	self.deleteTerminalArea(StraddleStack2);
	self.deleteMachine(Straddle1);
	self.deleteMachine(Straddle2);
	self.deleteMachine(IMV1);
	self.deleteMachine(IMV2);
	self.deleteRTDevice("91");
	self.deleteRTDevice("92");
	self.deleteRTDevice("93");
	self.deleteRTDevice("94");
	
	st1 := self.addStraddleStack(StraddleStack1, 2, 2, 2);
	q1 	:= self.addQueueToTA(QueueForStraddleStack1, StraddleStack1);
	assertNotNull(q1);
	
	st2 := self.addStraddleStack(StraddleStack2, 2, 2, 2);
	q2 	:= self.addQueueToTA(QueueForStraddleStack2, StraddleStack2);
	assertNotNull(q2);
	
	// add machine rule
	self.addMachineRule (st1, st2, RTMoveMethod_21);

	// move TI into straddle stack
	ti1 := self.addContainer(TrackedItem1, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti1, st1.allGridControllersByRowColumn[1, 1]);
	self.assertEqual(ti1.myPrimaryActualLocation, st1.allGridControllersByRowColumn[1, 1]);
	
	ti2 := self.addContainer(TrackedItem2, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti2, st1.allGridControllersByRowColumn[1, 2]);
	self.assertEqual(ti2.myPrimaryActualLocation, st1.allGridControllersByRowColumn[1, 2]);
	
	// queue TI to other straddle stack
	self.moveQueued(ti1, st2.allGridControllersByRowColumn[1, 1]);
	self.moveQueued(ti2, st2.allGridControllersByRowColumn[1, 2]);
	
	// assigning straddle to area ???
	create tas transient;
	tas.add(StraddleStack1); tas.add(StraddleStack2); 
	self.addStraddle(Straddle1, 91, tas, QueueForStraddleStack1);	
	tas.clear;
	tas.add(StraddleStack1); tas.add(StraddleStack2); 
	self.addStraddle(Straddle2, 92, tas, QueueForStraddleStack2);
	tas.clear;
	tas.add(StraddleStack1); tas.add(StraddleStack2); 
	self.addIMV(IMV1, 93, tas, QueueForStraddleStack1);
	self.addIMV(IMV2, 94, tas, QueueForStraddleStack1);
	
	// Work first straddle task - move to Area 2
	straddle1 := self.getMachine(Straddle1);
	assertNotNull(straddle1);
	beginTransaction;
	straddle1.addToQueue(q1, true, 0);
	commitTransaction;
	self.machineLogon(straddle1);
	
	straddle2 := self.getMachine(Straddle2);
	assertNotNull(straddle2);
	beginTransaction;
	straddle2.addToQueue(q2, true, 0);
	commitTransaction;
	self.machineLogon(straddle2);
	
	imv1 := self.getMachine(IMV1);
	assertNotNull(imv1);
	self.machineLogon(imv1);
	
	imv2 := self.getMachine(IMV2);
	assertNotNull(imv2);
	self.machineLogon(imv2);
//	--------------------------------------
//	FIRST PICKUP/SETDOWN FOR STRADDLE 1
// 	--------------------------------------	
	task1 := self.machineTaskRequest(straddle1);
	assertEqual(task1.taskType, TASK_PICKUP);
	assertEqual(task1.status, TASK_OFFERED);
	assertEqual(task1.tiId, ti1.id);
	
	self.machineAcceptTask(straddle1, task1);
	// check history
		accept11 := straddle1.history.last.CM_MachineMoveHistory;
			assertEqual(accept11.type, CM_MachineHistory.Type_AcceptMove);
			assertEqual(accept11.isStartOfLift, true);
			assertEqual(accept11.isEndOfLift, false);
			assertEqual(accept11.myPriorLiftHistory, null);
			assertEqual(accept11.myPriorHistory, null);
			assertEqual(accept11.machine, straddle1);

	self.machinePickup(straddle1);
		pickup11 := straddle1.history.last.CM_MachineMoveHistory;
			assertEqual(pickup11.type, CM_MachineHistory.Type_PickUp);
			assertEqual(pickup11.isStartOfLift, false);
			assertEqual(pickup11.isEndOfLift, false);
			assertEqual(pickup11.myPriorLiftHistory, accept11);
			assertEqual(pickup11.myPriorHistory, accept11);
			assertEqual(pickup11.machine, straddle1);
			
			assertEqual(accept11.myNextLiftHistory, pickup11);
			assertEqual(accept11.myNextHistory, pickup11);
	// setdown on IMV 1		
	self.machineSetdown(straddle1, ti1, IMV1);
		self.assertEqual(ti1.myPrimaryActualLocation, imv1.myMachineController);
			
		setdown11 := straddle1.history.last.CM_MachineMoveHistory;
			assertEqual(setdown11.type, CM_MachineHistory.Type_SetDown);
			assertEqual(setdown11.isStartOfLift, false);
			assertEqual(setdown11.isEndOfLift, true);
			assertEqual(setdown11.myPriorLiftHistory, pickup11);
			assertEqual(setdown11.myPriorHistory, pickup11);
			assertEqual(setdown11.machine, straddle1);
			assertEqual(pickup11.myNextLiftHistory, setdown11);
			assertEqual(pickup11.myNextHistory, setdown11);
			
		// now check IMV history
		accept12 := self.getHistoryForTI (CM_MachineHistory.Type_AcceptMove, imv1, ti1.id);
		pickup12 := self.getHistoryForTI (CM_MachineHistory.Type_PickUp, imv1, ti1.id);
		
		self.assertNotNull (accept12);
		self.assertNotNull (pickup12);
			assertEqual(accept12.type, CM_MachineHistory.Type_AcceptMove);
			assertEqual(accept12.isStartOfLift, true);
			assertEqual(accept12.isEndOfLift, false);
			assertEqual(accept12.myPriorLiftHistory, null);
			assertEqual(accept12.myPriorHistory, null);
			assertEqual(accept12.tiId, ti1.id);
			assertEqual(accept12.machine, imv1);
			
			assertEqual(pickup12.type, CM_MachineHistory.Type_PickUp);
			assertEqual(pickup12.isStartOfLift, false);
			assertEqual(pickup12.isEndOfLift, false);
			assertEqual(pickup12.myPriorLiftHistory, accept12);
			assertEqual(pickup12.myPriorHistory,accept12);
			assertEqual(pickup12.tiId, ti1.id);
			assertEqual(pickup12.machine, imv1);

//	--------------------------------------
//	SECOND PICKUP/SETDOWN FOR STRADDLE 1
// 	--------------------------------------
	task2 := self.machineTaskRequest(straddle2);
	assertEqual(task2.taskType, TASK_PICKUP);
	assertEqual(task2.status, TASK_OFFERED);
	assertEqual(task2.tiId, ti1.id);
	
	task1 := self.machineTaskRequest(straddle1);
	assertEqual(task1.taskType, TASK_PICKUP);
	assertEqual(task1.status, TASK_OFFERED);
	assertEqual(task1.tiId, ti2.id);
	
	self.machineAcceptTask(straddle1, task1);
	// check history
		accept21 := straddle1.history.last.CM_MachineMoveHistory;
			assertEqual(accept21.type, CM_MachineHistory.Type_AcceptMove);
			assertEqual(accept21.isStartOfLift, true);
			assertEqual(accept21.isEndOfLift, false);
			assertEqual(accept21.myPriorLiftHistory, null);
			assertEqual(accept21.myPriorHistory, null);
			assertEqual(accept21.machine, straddle1);

	self.machinePickup(straddle1);
		pickup21 := straddle1.history.last.CM_MachineMoveHistory;
			assertEqual(pickup21.type, CM_MachineHistory.Type_PickUp);
			assertEqual(pickup21.isStartOfLift, false);
			assertEqual(pickup21.isEndOfLift, false);
			assertEqual(pickup21.myPriorLiftHistory, accept21);
			assertEqual(pickup21.myPriorHistory, accept21);
			assertEqual(pickup21.machine, straddle1);
			assertEqual(accept21.myNextLiftHistory, pickup21);
			assertEqual(accept21.myNextHistory, pickup21);
	// setdown on IMV		
	self.machineSetdown(straddle1, ti2, IMV1);
		self.assertEqual(ti1.myPrimaryActualLocation, imv1.myMachineController);
			
		setdown21 := straddle1.history.last.CM_MachineMoveHistory;
			assertEqual(setdown21.type, CM_MachineHistory.Type_SetDown);
			assertEqual(setdown21.isStartOfLift, false);
			assertEqual(setdown21.isEndOfLift, true);
			assertEqual(setdown21.myPriorLiftHistory, pickup21);
			assertEqual(setdown21.myPriorHistory, pickup21);
			assertEqual(setdown21.machine, straddle1);
			assertEqual(pickup21.myNextLiftHistory, setdown21);
			assertEqual(pickup21.myNextHistory, setdown21);
			
		// now check IMV history
		accept22 := self.getHistoryForTI (CM_MachineHistory.Type_AcceptMove, imv1, ti2.id);
		pickup22 := self.getHistoryForTI (CM_MachineHistory.Type_PickUp, imv1, ti2.id);
		
		self.assertNotNull (accept22);
		self.assertNotNull (pickup22);
			assertEqual(accept22.type, CM_MachineHistory.Type_AcceptMove);
			assertEqual(accept22.isStartOfLift, false);
			assertEqual(accept22.isEndOfLift, false);
			assertEqual(accept22.myPriorLiftHistory, pickup12);
			assertEqual(accept22.myPriorHistory, null);
			assertEqual(accept22.tiId, ti2.id);
			assertEqual(accept22.machine, imv1);
			
			assertEqual(pickup22.type, CM_MachineHistory.Type_PickUp);
			assertEqual(pickup22.isStartOfLift, false);
			assertEqual(pickup22.isEndOfLift, false);
			assertEqual(pickup22.myPriorLiftHistory, accept22);
			assertEqual(pickup22.myPriorHistory,accept22);
			assertEqual(pickup22.tiId, ti2.id);
			assertEqual(pickup22.machine, imv1);

// 	----------------------------
// NOW DO THE IMV SWITCH
// ------------------------------
	imvTask1 := self.findTaskForTI (imv1, ti1);
	
	assertEqual(imvTask1.taskType, TASK_MOVE);
	assertEqual(imvTask1.status, TASK_WORKING);
	assertEqual(imvTask1.tiId, ti1.id);
	assertEqual (imvTask1.machine, imv1);
	
	self.doIMVSwitch (imvTask1, imv2);
	
	assertEqual (imvTask1.machine, imv2);
	
	switch1 := imv1.history.last.CM_MachineMoveHistory;
	
	assertNotNull (switch1);
	assertEqual (switch1.type, CM_MachineHistory.Type_Amendment);
	assertEqual (switch1.tiId, ti1.id);
	
	switch2 := imv2.history.last.CM_MachineMoveHistory;
	
	assertNotNull (switch2);
	assertEqual (switch2.type, CM_MachineHistory.Type_Amendment);
	assertEqual (switch2.tiId, ti1.id);
	
	assertEqual(accept12.type, CM_MachineHistory.Type_AcceptMove);
		assertEqual(accept12.machine, imv2);		// switch to IMV@
		assertEqual(accept12.isStartOfLift, true);
		assertEqual(accept12.isEndOfLift, false);
		assertEqual(accept12.myPriorLiftHistory, null);
		assertEqual(accept12.myPriorHistory, null);
		assertEqual(accept12.tiId, ti1.id);
		
		
		assertEqual(pickup12.type, CM_MachineHistory.Type_PickUp);
		assertEqual(pickup12.machine, imv2);		// switch to IMV2
		assertEqual(pickup12.isStartOfLift, false);
		assertEqual(pickup12.isEndOfLift, false);
		assertEqual(pickup12.myPriorLiftHistory, accept12);
		assertEqual(pickup12.myPriorHistory,accept12);
		assertEqual(pickup12.tiId, ti1.id);
			
	assertEqual(accept22.type, CM_MachineHistory.Type_AcceptMove);
		assertEqual(accept22.machine, imv1);
		assertEqual(accept22.isStartOfLift, true);
		assertEqual(accept22.isEndOfLift, false);
		assertEqual(accept22.myPriorLiftHistory, null);
		assertEqual(accept22.myPriorHistory, null);
		assertEqual(accept22.tiId, ti2.id);
		
		assertEqual(pickup22.type, CM_MachineHistory.Type_PickUp);
		assertEqual(pickup22.machine, imv1);
		assertEqual(pickup22.isStartOfLift, false);
		assertEqual(pickup22.isEndOfLift, false);
		assertEqual(pickup22.myPriorLiftHistory, accept22);
		assertEqual(pickup22.myPriorHistory,accept22);
		assertEqual(pickup22.tiId, ti2.id);
			
			
//	NOW SWITCH BACK
			
	self.doIMVSwitch (imvTask1, imv1);
	
	assertEqual (imvTask1.machine, imv1);
	
	switch1 := imv1.history.last.CM_MachineMoveHistory;
	
	assertNotNull (switch1);
	assertEqual (switch1.type, CM_MachineHistory.Type_Amendment);
	assertEqual (switch1.tiId, ti1.id);
	
	switch2 := imv2.history.last.CM_MachineMoveHistory;
	
	assertNotNull (switch2);
	assertEqual (switch2.type, CM_MachineHistory.Type_Amendment);
	assertEqual (switch2.tiId, ti1.id);
	
	assertEqual(accept12.type, CM_MachineHistory.Type_AcceptMove);
		assertEqual(accept12.isStartOfLift, true);
		assertEqual(accept12.isEndOfLift, false);
		assertEqual(accept12.myPriorLiftHistory, null);
		assertEqual(accept12.myPriorHistory, null);
		assertEqual(accept12.tiId, ti1.id);
		
		assertEqual(pickup12.type, CM_MachineHistory.Type_PickUp);
		assertEqual(pickup12.isStartOfLift, false);
		assertEqual(pickup12.isEndOfLift, false);
		assertEqual(pickup12.myPriorLiftHistory, accept12);
		assertEqual(pickup12.myPriorHistory,accept12);
		assertEqual(pickup12.tiId, ti1.id);
			
	assertEqual(accept22.type, CM_MachineHistory.Type_AcceptMove);
		assertEqual(accept22.isStartOfLift, false);
		assertEqual(accept22.isEndOfLift, false);
		assertEqual(accept22.myPriorLiftHistory, pickup12);
		assertEqual(accept22.myPriorHistory, null);
		assertEqual(accept22.tiId, ti2.id);
		
		assertEqual(pickup22.type, CM_MachineHistory.Type_PickUp);
		assertEqual(pickup22.isStartOfLift, false);
		assertEqual(pickup22.isEndOfLift, false);
		assertEqual(pickup22.myPriorLiftHistory, accept22);
		assertEqual(pickup22.myPriorHistory,accept22);
		assertEqual(pickup22.tiId, ti2.id);	
//	--------------------------------------
//	FIRST PICKUP/SETDOWN FOR STRADDLE 2
// 	--------------------------------------	
	//task := self.machineTaskRequest(straddle2);

	assertEqual(task2.taskType, TASK_PICKUP);
	assertEqual(task2.status, TASK_OFFERED);
	assertEqual(task2.tiId, ti1.id);
	
	self.machineAcceptTask(straddle2, task2);	
		accept13 := straddle2.history.last.CM_MachineMoveHistory;
			assertEqual(accept13.type, CM_MachineHistory.Type_AcceptMove);
			assertEqual(accept13.isStartOfLift, true);
			assertEqual(accept13.isEndOfLift, false);
			assertEqual(accept13.myPriorLiftHistory, null);
			assertEqual(accept13.myPriorHistory, null);

	self.machinePickup(straddle2);
		pickup13 := straddle2.history.last.CM_MachineMoveHistory;
			assertEqual(pickup13.type, CM_MachineHistory.Type_PickUp);
			assertEqual(pickup13.isStartOfLift, false);
			assertEqual(pickup13.isEndOfLift, false);
			assertEqual(pickup13.myPriorLiftHistory, accept13);
			assertEqual(pickup13.myPriorHistory, accept13);
			
			assertEqual(accept13.myNextLiftHistory, pickup13);
			assertEqual(accept13.myNextHistory, pickup13);
			
	// now check IMV history
		setdown12 := imv1.history.last.CM_MachineMoveHistory;
			assertEqual(setdown12.type, CM_MachineHistory.Type_SetDown);
			assertEqual(setdown12.isStartOfLift, false);
			assertEqual(setdown12.isEndOfLift, false);
			assertEqual(setdown12.myPriorLiftHistory, pickup22);
			assertEqual(setdown12.myPriorHistory, pickup12);
			
			assertEqual(pickup22.myNextLiftHistory, setdown12);
			assertEqual(pickup22.myNextHistory, null);
//------------------
// make sure it works with imv 1 logoff/logon here
//--------------------			
	self.machineLogOff(imv1);
	self.machineLogon(imv1);
	
	// SETDOWN TO TARGET AREA		
	self.machineSetdown(straddle2, ti1, "UT_ST2 010001");
	
	self.assertEqual(ti1.myPrimaryActualLocation, st2.allGridControllersByRowColumn[1, 1]);

		setdown13 := straddle2.history.last.CM_MachineMoveHistory;
			assertEqual(setdown13.type, CM_MachineHistory.Type_SetDown);
			assertEqual(setdown13.isStartOfLift, false);
			assertEqual(setdown13.isEndOfLift, true);
			assertEqual(setdown13.myPriorLiftHistory, pickup13);
			assertEqual(setdown13.myPriorHistory, pickup13);
			
			assertEqual(pickup13.myNextLiftHistory, setdown13);
			assertEqual(pickup13.myNextHistory, setdown13);
//	--------------------------------------
//	SECOND PICKUP/SETDOWN FOR STRADDLE 2
// 	--------------------------------------	
	task2 := self.machineTaskRequest(straddle2);
	assertEqual(task2.taskType, TASK_PICKUP);
	assertEqual(task2.status, TASK_OFFERED);
	assertEqual(task2.tiId, ti2.id);
	
	self.machineAcceptTask(straddle2, task2);	
		accept23 := straddle2.history.last.CM_MachineMoveHistory;
			assertEqual(accept23.type, CM_MachineHistory.Type_AcceptMove);
			assertEqual(accept23.isStartOfLift, true);
			assertEqual(accept23.isEndOfLift, false);
			assertEqual(accept23.myPriorLiftHistory, null);
			assertEqual(accept23.myPriorHistory, null);

	self.machinePickup(straddle2);
		pickup23 := straddle2.history.last.CM_MachineMoveHistory;
			assertEqual(pickup23.type, CM_MachineHistory.Type_PickUp);
			assertEqual(pickup23.isStartOfLift, false);
			assertEqual(pickup23.isEndOfLift, false);
			assertEqual(pickup23.myPriorLiftHistory, accept23);
			assertEqual(pickup23.myPriorHistory, accept23);
			
			assertEqual(accept23.myNextLiftHistory, pickup23);
			assertEqual(accept23.myNextHistory, pickup23);
			
	// now check IMV history
		setdown22 := imv1.history.last.CM_MachineMoveHistory;
			assertEqual(setdown22.type, CM_MachineHistory.Type_SetDown);
			assertEqual(setdown22.isStartOfLift, false);
			assertEqual(setdown22.isEndOfLift, true);
			assertEqual(setdown22.myPriorLiftHistory, setdown12);
			assertEqual(setdown22.myPriorHistory, pickup22);
			
			assertEqual(pickup22.myNextLiftHistory, setdown12);
			assertEqual(pickup22.myNextHistory, setdown22);
			
	// SETDOWN TO TARGET AREA		
	self.machineSetdown(straddle2, ti1, "UT_ST2 010002");
	
	self.assertEqual(ti1.myPrimaryActualLocation, st2.allGridControllersByRowColumn[1, 1]);

		setdown23 := straddle2.history.last.CM_MachineMoveHistory;
			assertEqual(setdown23.type, CM_MachineHistory.Type_SetDown);
			assertEqual(setdown23.isStartOfLift, false);
			assertEqual(setdown23.isEndOfLift, true);
			assertEqual(setdown23.myPriorLiftHistory, pickup23);
			assertEqual(setdown23.myPriorHistory, pickup23);
			
			assertEqual(pickup23.myNextLiftHistory, setdown23);
			assertEqual(pickup23.myNextHistory, setdown23);			
			
			
	self.machineLogOff(straddle1);
	self.machineLogOff(straddle2);
	self.machineLogOff(imv1);
	self.machineLogOff(imv2);

epilog
	delete tas;
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Fails&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tMachineDelay" id="4f351109-447d-4ffc-8846-be4d36765be6">
        <source>tMachineDelay();
/*

Purpose:			Create Machine Delay

Date		Who		Reason
02/05/2014cnwma1	Initial creation
// 10 Sep 2019	cnwrs1	TFS 46030
*/

constants 
	RTG = "RG25";
	RTGAREA ="750";
	VOY	    ="CAI1919";
vars
	delay : CM_Delay;
	machine : CM_Machine;
	tas: StringArray;
	rtgArea : CM_RTGArea;
	startDT, estEndDT, endDT : TimeStamp;
	voyage :CM_Voyage;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.deleteVoyage(VOY);
	//Delete Machine 
	self.deleteMachine(RTG);
	// Delete Terminal Area
	deleteTerminalArea(RTGAREA);
	
	// Add Terminal Area
	rtgArea := self.addRTGArea(RTGAREA,6,40,5);
	self.assertNotNull(rtgArea);
	
	
	voyage := self.addVoyageWithContainerStructur(VOY,"CAI","APL","APL");
	self.assertNotNull(voyage);
	
	// Add Machine 
	create tas transient;
	tas.add(RTGAREA); 
	machine:=self.addMachine(MACHINETYPE_RTG, RTG, null, tas, null);
	self.assertNotNull(machine);
	startDT := machine.createdTime.addHours(1);
	self.opts.purge;
	self.opts.addAssoc("Voyage",voyage);
	self.opts.addAssoc("Remarks","Delay Updated");
	//Create Delay
	 delay := self.createDelay(startDT,machine);
	
	//Update Delay
	self.opts.purge;
	self.opts.addAssoc("Remarks","Delay Updated");
	self.updateDelay(delay);
	self.assertEqual(delay.remarks,"Delay Updated");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete tas;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tMoveCraneJobs" id="e82c975c-19f9-4b90-a103-6ec828450051">
        <source>tMoveCraneJobs();
/*

Purpose:			PAR 36850

Date		Who		Reason
17 May 2016	cnwmk3	Initial creation
// 10 Sep 2019	cnwrs1	TFS 46030
*/
constants
	CraneTransferAreaId1		= "CTA9";
	CraneTransferAreaId2		= "CTA7";
	CraneId1					= "CRN9";
	CraneId2					= "CRN7";
	Voyage1						= "UT_VOY005";
	ContId						= "UT_0036850";
	ContId1						= "UT_0136850";
	Ship						= "UT_SHIP10";
vars
	cta1, cta2					: CM_CraneTransferArea;
	tas							: StringArray;
	crane1, crane2				: CM_Machine;
	loadPort, dischargePort		: CM_Port;
	voyage						: CM_Voyage;
	bayName						: String;
	slots, theSlots				: CM_SlotControllerArray;
	dischargeTi, loadTi			: CM_Container;
	voyageJob					: CM_VoyageJob;
	jobs						: CM_VoyageJobArray;
	wle							: CM_WorkListEntry;
	yardArea					: CM_YardInterchangeArea;
	job							: CM_Job;
	request						: CM_Request;
	wles						: CM_WLESet;
	vessel						: CM_Vessel;
	tmpLoadCC					: CMIF_LoadColorCode;
	slot						: CM_SlotController;
	jobsWithWarning				: CM_VoyageJobArray;
	requests					: CM_RequestSet;
	obj							: Object;
	jobNum						: String;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.setTerminalConfig("ReadyToShipPlanning", false);
	create jobs transient;
	create wles transient;
	create jobsWithWarning transient;
	create requests transient;
	
	// delete everything first
	self.deleteContainer(ContId);
	self.deleteTerminalArea("YI05");
	self.deleteVoyage(Voyage1);
	self.deleteVessel(Ship);
	self.deleteMachine(CraneId1);
	self.deleteMachine(CraneId2);
	
	//create vessel and voyage
	vessel := addVesselCellular(Ship, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	voyage := self.addVoyageWithContainerStructur(Voyage1, Ship, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(vessel);
	self.assertNotNull(voyage);
	
	// create the crane transfer area for CRN9
	cta1 := self.addCraneTransferArea(CraneTransferAreaId1);
	self.assertNotNull(cta1);
	// create the crane transfer area for CRN7
	cta2 := self.addCraneTransferArea(CraneTransferAreaId2);
	self.assertNotNull(cta2);
	
	// yard interchange area
	yardArea := self.addYardInterchangeArea("YI05", null, 5, 5);
	
	// create a crane CRN9
	create tas transient;
	tas.add(cta1.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta1);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	crane1 := self.addCrane(CraneId1, null, tas, null);
	self.assertNotNull(crane1);
	delete tas;
	// // create a crane CRN7
	create tas transient;
	tas.add(cta2.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta2);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	crane2 := self.addCrane(CraneId2, null, tas, null);
	self.assertNotNull(crane2);
	delete tas;
	
	loadPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	//create ti in the voyage slots for discharge 
	bayName := '01';
	create slots transient;
	self.getJobSlotControllers(Voyage1, bayName, DeckOnDeck, 1, 1, 1, slots);
	assertEqual(slots.size, 1);
	dischargeTi := self.addContainerAtLocnDisch(ContId , "2200", "GENL", TI_IMEX_STATUS_IMPORT, slots[1], loadPort, voyage);
	
	// Color code and Create Discharge Jobs for CRN9
	self.voyageDischargeColourCode(voyage);
	
	voyageJob := self.addVoyageJob(voyage, CraneId1, slots, true);
	jobNum := voyageJob.jobNum;
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job 1 not created");
	jobs.add(voyageJob);
	
	foreach wle in voyageJob.workListEntries do
		self.movePlannedWLE(wle.myTrackedItem, 	yardArea.getLocationsController, wle);
	endforeach;
	delete slots;
	
	//load to ops
	self.loadAllJobsToOps(voyage, true);	
	
	// get the requests that is to be moved to the other crane
	foreach job in jobs do
		foreach request in job.allRequests do
			foreach wle in request.allWorkListEntries do
				wles.add(wle);
			endforeach;
		endforeach;
	endforeach;
	foreach obj in wles do
		requests.addNoDuplicates(obj.CM_VoyageWLE.myRequest, false);
	endforeach;
	
	// create ti for loading to the voyage
	loadTi := self.addContainerForExport(ContId1, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),
				"2200",	"MT",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi, yardArea.getLocationsController);
	self.assertEqual(loadTi.myPrimaryActualLocation, yardArea.getLocationsController);
	self.setCargoReadyToShip(loadTi);
	self.deleteStops(loadTi);
	
	// create load jobs for CRN7
	create theSlots transient;
	self.getJobSlotControllers(Voyage1, bayName, DeckOnDeck, 2, 2, 1, theSlots);
	assertEqual(theSlots.size, 1);
	create tmpLoadCC transient;
	self.markSlotsAsLoadJob(theSlots, tmpLoadCC);
	self.markSlotsAsLoadCC(theSlots, tmpLoadCC, CM_SlotRequest.Attribute_Empty);
	voyageJob := self.addVoyageJob(voyage, CraneId2, theSlots, false);
	self.assertTrue(voyageJob &lt;&gt; null);
	
	foreach slot in theSlots do
		movePlannedRequestToJob(loadTi, slot, slot.getRequest(true));
	endforeach;
	
	// split or transfer a job from one crane(CRN9) to another crane(CRN7) as from Order of Work form
	app.myTrxUA.trxTransferVoyageJobsToCrane(false, jobs, jobsWithWarning, voyage.allJobSheets.first, PLANNING_MODE, requests, null, jobNum, true, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// test that CRN7 now has two jobs
	self.assertEqual(voyage.allJobSheets.first.allJobsByJobNum.size, 2);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete slots;
	delete jobs;
	delete wles;
	delete tmpLoadCC;
	delete theSlots;
	delete jobsWithWarning;
	delete requests;
	self.setTerminalConfig("ReadyToShipPlanning", true);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tMultiMachineMove" id="24d69909-f7d4-4d95-aa1c-e02caef9bf58">
        <source>tMultiMachineMove();
// cnwer1
// cnwdw1
// ---------------------------------------------------------------------------
// Created:     15 November 2010 by cnwcs5
// Purpose:     Test move between straddle stacks via IMV
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/03/2015	cnwmh5		Add testing of NoIMVmoveTEUs
// ---------------------------------------------------------------------------
constants
	TrackedItem1 			= "UT100";
	StraddleStack1 			= "UT_STA";
	QueueForStraddleStack1 	= "UT_STA_Q";
	StraddleStack2			= "UT_STB";
	QueueForStraddleStack2 	= "UT_STB_Q";
	Straddle1 				= "UTS1";
	Straddle2				= "UTS2";
	IMV1					= "UTI1";
	TrackedItem2			: String = "UTMHTEUIMV1";
	TrackedItem3			: String = "UTMHTEUIMV2";
vars
	ti			: CM_TrackedItem;
	ti2			: CM_TrackedItem;
	ti3			: CM_TrackedItem;
	st1, st2	: CM_GridArea;
	q1, q2		: CM_RadioTelemetryQueue;
	tas			: StringArray;
	straddle1, straddle2, imv1	: CM_Machine;
	task		: CM_RTQueueTask;
	accept1,accept2, accept3,
	pickup1, pickup2, pickup3, 
	setdown1, setdown2, setdown3		: CM_MachineMoveHistory;
	history		: CM_MachineHistory;
	count		: Integer;
begin
	self.deleteContainer(TrackedItem1);
	self.deleteContainer(TrackedItem2);
	self.deleteContainer(TrackedItem3);
	self.deleteQueue(QueueForStraddleStack1);
	self.deleteQueue(QueueForStraddleStack2);
	self.deleteTerminalArea(StraddleStack1);
	self.deleteTerminalArea(StraddleStack2);
	self.deleteMachine(Straddle1);
	self.deleteMachine(Straddle2);
	self.deleteMachine(IMV1);
	self.deleteRTDevice("91");
	self.deleteRTDevice("92");
	self.deleteRTDevice("93");
	
	st1 := self.addStraddleStack(StraddleStack1, 2, 2, 2);
	q1 	:= self.addQueueToTA(QueueForStraddleStack1, StraddleStack1);
	assertNotNull(q1);
	
	st2 := self.addStraddleStack(StraddleStack2, 2, 2, 2);
	q2 	:= self.addQueueToTA(QueueForStraddleStack2, StraddleStack2);
	assertNotNull(q2);
	
	// add machine rule
	self.addMachineRule (st1, st2, RTMoveMethod_21);

	// move TI into straddle stack
	ti := self.addContainer(TrackedItem1, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti, st1.allGridControllersByRowColumn[1, 1]);
	self.assertEqual(ti.myPrimaryActualLocation, st1.allGridControllersByRowColumn[1, 1]);
	// queue TI to other straddle stack
	self.moveQueued(ti, st2.allGridControllersByRowColumn[1, 1]);
	// assigning straddle to area ???
	create tas transient;
	tas.add(StraddleStack1); tas.add(StraddleStack2); 
	self.addStraddle(Straddle1, 91, tas, QueueForStraddleStack2);
	tas.clear;
	tas.add(StraddleStack1); tas.add(StraddleStack2); 
	self.addStraddle(Straddle2, 92, tas, QueueForStraddleStack1);
	tas.clear;
	tas.add(StraddleStack1); tas.add(StraddleStack2); 
	self.addIMV(IMV1, 93, tas, QueueForStraddleStack1);
	
	// Work first straddle task - move to Area 2
	straddle1 := self.getMachine(Straddle1);
	assertNotNull(straddle1);
	self.machineLogon(straddle1);
	
	straddle2 := self.getMachine(Straddle2);
	assertNotNull(straddle2);
	self.machineLogon(straddle2);
	
	imv1 := self.getMachine(IMV1);
	assertNotNull(imv1);
	self.machineLogon(imv1);
	
	task :=ti.getDirectorOrPickupTask();// self.machineTaskRequest(straddle1);
	assertEqual(task.taskType, TASK_PICKUP);
	//assertEqual(task.status, TASK_OFFERED);
	
	self.machineAcceptTask(straddle1, task);
	// check history
		accept1 := straddle1.history.last.CM_MachineMoveHistory;
			assertEqual(accept1.type, CM_MachineHistory.Type_AcceptMove);
			assertEqual(accept1.isStartOfLift, true);
			assertEqual(accept1.isEndOfLift, false);
			assertEqual(accept1.myPriorLiftHistory, null);
			assertEqual(accept1.myPriorHistory, null);

	self.machinePickup(straddle1);
		pickup1 := straddle1.history.last.CM_MachineMoveHistory;
			assertEqual(pickup1.type, CM_MachineHistory.Type_PickUp);
			assertEqual(pickup1.isStartOfLift, false);
			assertEqual(pickup1.isEndOfLift, false);
			assertEqual(pickup1.myPriorLiftHistory, accept1);
			assertEqual(pickup1.myPriorHistory, accept1);
			
			assertEqual(accept1.myNextLiftHistory, pickup1);
			assertEqual(accept1.myNextHistory, pickup1);
			
//------------------
// make sure it works with straddle 1 logoff/logon here
//--------------------			
	self.machineLogOff(straddle1);
	self.machineLogon(straddle1);
	
	process.sleep(1);		// To ensure Logon and Setdown history are in the correct order
	
	// setdown on IMV		
	self.machineSetdown(straddle1, ti, IMV1);
		self.assertEqual(ti.myPrimaryActualLocation, imv1.myMachineController);
			
		setdown1 := straddle1.history.last.CM_MachineMoveHistory;
			assertEqual(setdown1.type, CM_MachineHistory.Type_SetDown);
			assertEqual(setdown1.isStartOfLift, false);
			assertEqual(setdown1.isEndOfLift, true);
			assertEqual(setdown1.myPriorLiftHistory, pickup1);
			assertEqual(setdown1.myPriorHistory, pickup1);
			
			assertEqual(pickup1.myNextLiftHistory, setdown1);
			assertEqual(pickup1.myNextHistory, setdown1);
			
		// now check IMV history
		accept2 := self.getHistoryForTI (CM_MachineHistory.Type_AcceptMove, imv1, ti.id);
		pickup2 := self.getHistoryForTI (CM_MachineHistory.Type_PickUp, imv1, ti.id);
		
		self.assertNotNull (accept2);
		self.assertNotNull (pickup2);
			assertEqual(accept2.type, CM_MachineHistory.Type_AcceptMove);
			assertEqual(accept2.isStartOfLift, true);
			assertEqual(accept2.isEndOfLift, false);
			assertEqual(accept2.myPriorLiftHistory, null);
			assertEqual(accept2.myPriorHistory, null);
			assertEqual(accept2.tiId, ti.id);
			
			assertEqual(pickup2.type, CM_MachineHistory.Type_PickUp);
			assertEqual(pickup2.isStartOfLift, false);
			assertEqual(pickup2.isEndOfLift, false);
			assertEqual(pickup2.myPriorLiftHistory, accept2);
			assertEqual(pickup2.myPriorHistory,accept2);
			assertEqual(pickup2.tiId, ti.id);
			
	// now let straddle 2 work
	task :=ti.getDirectorOrPickupTask(); //self.machineTaskRequest(straddle2);
	assertEqual(task.taskType, TASK_PICKUP);
	//assertEqual(task.status, TASK_OFFERED);
	
	self.machineAcceptTask(straddle2, task);	
		accept3 := straddle2.history.last.CM_MachineMoveHistory;
			assertEqual(accept3.type, CM_MachineHistory.Type_AcceptMove);
			assertEqual(accept3.isStartOfLift, true);
			assertEqual(accept3.isEndOfLift, false);
			assertEqual(accept3.myPriorLiftHistory, null);
			assertEqual(accept3.myPriorHistory, null);

	self.machinePickup(straddle2);
		pickup3 := straddle2.history.last.CM_MachineMoveHistory;
			assertEqual(pickup3.type, CM_MachineHistory.Type_PickUp);
			assertEqual(pickup3.isStartOfLift, false);
			assertEqual(pickup3.isEndOfLift, false);
			assertEqual(pickup3.myPriorLiftHistory, accept3);
			assertEqual(pickup3.myPriorHistory, accept3);
			
			assertEqual(accept3.myNextLiftHistory, pickup3);
			assertEqual(accept3.myNextHistory, pickup3);
			
	// now check IMV history
		setdown2 := imv1.history.last.CM_MachineMoveHistory;
			assertEqual(setdown2.type, CM_MachineHistory.Type_SetDown);
			assertEqual(setdown2.isStartOfLift, false);
			assertEqual(setdown2.isEndOfLift, true);
			assertEqual(setdown2.myPriorLiftHistory, pickup2);
			assertEqual(setdown2.myPriorHistory, pickup2);
			
			assertEqual(pickup2.myNextLiftHistory, setdown2);
			assertEqual(pickup2.myNextHistory, setdown2);
//------------------
// make sure it works with straddle 2 logoff/logon here
//--------------------			
	self.machineLogOff(straddle2);
	self.machineLogon(straddle2);

	process.sleep(1);		// To ensure Logon and Setdown history are in the correct order
	
	// SETDOWN TO TARGET AREA		
	self.machineSetdown(straddle2, ti, StraddleStack2 &amp; " 010001");
	
	self.assertEqual(ti.myPrimaryActualLocation, st2.allGridControllersByRowColumn[1, 1]);

		setdown3 := straddle2.history.last.CM_MachineMoveHistory;
			assertEqual(setdown3.type, CM_MachineHistory.Type_SetDown);
			assertEqual(setdown3.isStartOfLift, false);
			assertEqual(setdown3.isEndOfLift, true);
			assertEqual(setdown3.myPriorLiftHistory, pickup3);
			assertEqual(setdown3.myPriorHistory, pickup3);
			
			assertEqual(pickup3.myNextLiftHistory, setdown3);
			assertEqual(pickup3.myNextHistory, setdown3);
			
	self.machineLogOff(straddle1);
	self.machineLogOff(straddle2);
	self.machineLogOff(imv1);
	
	//---------------------------------
	// Check NoUMVmoveTEUS config value
	//---------------------------------
	ti2 := self.addContainer(TrackedItem2, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.assertNotNull(ti2);
	self.move(ti2, st1.allGridControllersByRowColumn[1, 2]);
	self.assertEqual(ti2.myPrimaryActualLocation, st1.allGridControllersByRowColumn[1, 2]);
	self.moveQueued(ti2, st2.allGridControllersByRowColumn[1, 2]);

	ti3 := self.addContainer(TrackedItem3, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.assertNotNull(ti3);
	self.move(ti3, st1.allGridControllersByRowColumn[2, 1]);
	self.assertEqual(ti3.myPrimaryActualLocation, st1.allGridControllersByRowColumn[2, 1]);
	self.moveQueued(ti3, st2.allGridControllersByRowColumn[2, 1]);
	
	self.machineLogon(straddle1);
	self.machineLogon(straddle2);
	self.machineLogon(imv1);
	
	task :=ti2.getDirectorOrPickupTask();// self.machineTaskRequest(straddle1);
	self.machineAcceptTask(straddle1, task);
	self.machinePickup(straddle1);
	self.machineSetdown(straddle1, ti2, IMV1);
	
	self.setTerminalConfig(NoIMVmoveTEUs, 1);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(MACH_IMV_FULL);
	task := self.machineTaskRequest(straddle2);
	self.machineAcceptTask(straddle2, task);
	self.machinePickup(straddle2);
	self.machineSetdown(straddle2, ti3, IMV1);
	self.assertTrxError(MACH_IMV_FULL);
	
	self.setTerminalConfig(NoIMVmoveTEUs, 0);
	self.clearExpectedTrxErrors();
	
	self.machineSetdown(straddle2, ti3, IMV1);
	
	self.machineLogOff(straddle1);
	self.machineLogOff(straddle2);
	self.machineLogOff(imv1);
	
epilog
	self.setTerminalConfig(NoIMVmoveTEUs, 0);
	delete tas;
end;</source>
    </JadeMethod>
    <JadeMethod name="tMultiMachineMultiMove" id="d89c4f2c-62bd-466f-a15d-e8142e54e5fd">
        <source>tMultiMachineMultiMove();
// cnwer1
//cnwdw1
// ---------------------------------------------------------------------------
// Created:     15 November 2010 by cnwcs5
// Purpose:     Test move between straddle stacks via IMV
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	TrackedItem1 			= "UT100";
	TrackedItem2 			= "UT200";
	StraddleStack1 			= "UT_ST1";
	QueueForStraddleStack1 	= "UT_ST1_Q";
	StraddleStack2			= "UT_ST2";
	QueueForStraddleStack2 	= "UT_ST2_Q";
	Straddle1 				= "UTS1";
	Straddle2				= "UTS2";
	IMV1					= "UTI1";
vars
	ti1, ti2	: CM_TrackedItem;
	st1, st2	: CM_GridArea;
	q1, q2		: CM_RadioTelemetryQueue;
	tas			: StringArray;
	straddle1, straddle2, imv1	: CM_Machine;
	task, task2	: CM_RTQueueTask;
	accept11,accept12, accept13,
	pickup11, pickup12, pickup13, 
	setdown11, setdown12, setdown13	,
	accept21,accept22, accept23,
	pickup21, pickup22, pickup23, 
	setdown21, setdown22, setdown23: CM_MachineMoveHistory;
	history		: CM_MachineHistory;
	count		: Integer;
begin
	
	self.setTerminalConfig(NoIMVmoveTEUs, 0);
	self.deleteContainer(TrackedItem1);
	self.deleteContainer(TrackedItem2);
	self.deleteQueue(QueueForStraddleStack1);
	self.deleteQueue(QueueForStraddleStack2);
	self.deleteTerminalArea(StraddleStack1);
	self.deleteTerminalArea(StraddleStack2);
	self.deleteMachine(Straddle1);
	self.deleteMachine(Straddle2);
	self.deleteMachine(IMV1);
	self.deleteRTDevice("91");
	self.deleteRTDevice("92");
	self.deleteRTDevice("93");
	
	st1 := self.addStraddleStack(StraddleStack1, 2, 2, 2);
	q1 	:= self.addQueueToTA(QueueForStraddleStack1, StraddleStack1);
	assertNotNull(q1);
	
	st2 := self.addStraddleStack(StraddleStack2, 2, 2, 2);
	q2 	:= self.addQueueToTA(QueueForStraddleStack2, StraddleStack2);
	assertNotNull(q2);
	
	// add machine rule
	self.addMachineRule (st1, st2, RTMoveMethod_21);

	// move TI into straddle stack
	ti1 := self.addContainer(TrackedItem1, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti1, st1.allGridControllersByRowColumn[1, 1]);
	self.assertEqual(ti1.myPrimaryActualLocation, st1.allGridControllersByRowColumn[1, 1]);
	
	ti2 := self.addContainer(TrackedItem2, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti2, st1.allGridControllersByRowColumn[1, 2]);
	self.assertEqual(ti2.myPrimaryActualLocation, st1.allGridControllersByRowColumn[1, 2]);
	
	// queue TI to other straddle stack
	self.moveQueued(ti1, st2.allGridControllersByRowColumn[1, 1]);
	self.moveQueued(ti2, st2.allGridControllersByRowColumn[1, 2]);
	// assigning straddle to area ???
	create tas transient;
	tas.add(StraddleStack1); tas.add(StraddleStack2); 
	self.addStraddle(Straddle1, 91, tas, QueueForStraddleStack1);
	tas.clear;
	tas.add(StraddleStack1); tas.add(StraddleStack2); 
	self.addStraddle(Straddle2, 92, tas, QueueForStraddleStack2);
	tas.clear;
	tas.add(StraddleStack1); tas.add(StraddleStack2); 
	self.addIMV(IMV1, 93, tas, QueueForStraddleStack1);
	
	// Work first straddle task - move to Area 2
	straddle1 := self.getMachine(Straddle1);
	assertNotNull(straddle1);
	beginTransaction;
	straddle1.addToQueue(q1, true, 0);
	commitTransaction;
	self.machineLogon(straddle1);
	
	straddle2 := self.getMachine(Straddle2);
	assertNotNull(straddle2);
	beginTransaction;
	straddle2.addToQueue(q2, true, 0);
	commitTransaction;
	self.machineLogon(straddle2);
	
	imv1 := self.getMachine(IMV1);
	assertNotNull(imv1);
	self.machineLogon(imv1);
//	--------------------------------------
//	FIRST PICKUP/SETDOWN FOR STRADDLE 1
// 	--------------------------------------	
	task := ti1.getDirectorOrPickupTask();
	
	//self.machineTaskRequest(straddle1);
	assertEqual(task.taskType, TASK_PICKUP);
	//assertEqual(task.status, TASK_OFFERED);
	assertEqual(task.tiId, ti1.id);
	
	self.machineAcceptTask(straddle1, task);
	// check history
		accept11 := straddle1.history.last.CM_MachineMoveHistory;
			assertEqual(accept11.type, CM_MachineHistory.Type_AcceptMove);
			assertEqual(accept11.isStartOfLift, true);
			assertEqual(accept11.isEndOfLift, false);
			assertEqual(accept11.myPriorLiftHistory, null);
			assertEqual(accept11.myPriorHistory, null);

	self.machinePickup(straddle1);
		pickup11 := straddle1.history.last.CM_MachineMoveHistory;
			assertEqual(pickup11.type, CM_MachineHistory.Type_PickUp);
			assertEqual(pickup11.isStartOfLift, false);
			assertEqual(pickup11.isEndOfLift, false);
			assertEqual(pickup11.myPriorLiftHistory, accept11);
			assertEqual(pickup11.myPriorHistory, accept11);
			
			assertEqual(accept11.myNextLiftHistory, pickup11);
			assertEqual(accept11.myNextHistory, pickup11);
	// setdown on IMV		
	self.machineSetdown(straddle1, ti1, IMV1);
		self.assertEqual(ti1.myPrimaryActualLocation, imv1.myMachineController);
			
		setdown11 := straddle1.history.last.CM_MachineMoveHistory;
			assertEqual(setdown11.type, CM_MachineHistory.Type_SetDown);
			assertEqual(setdown11.isStartOfLift, false);
			assertEqual(setdown11.isEndOfLift, true);
			assertEqual(setdown11.myPriorLiftHistory, pickup11);
			assertEqual(setdown11.myPriorHistory, pickup11);
			
			assertEqual(pickup11.myNextLiftHistory, setdown11);
			assertEqual(pickup11.myNextHistory, setdown11);
			
		// now check IMV history
		accept12 := self.getHistoryForTI (CM_MachineHistory.Type_AcceptMove, imv1, ti1.id);
		pickup12 := self.getHistoryForTI (CM_MachineHistory.Type_PickUp, imv1, ti1.id);
		
		self.assertNotNull (accept12);
		self.assertNotNull (pickup12);
			assertEqual(accept12.type, CM_MachineHistory.Type_AcceptMove);
			assertEqual(accept12.isStartOfLift, true);
			assertEqual(accept12.isEndOfLift, false);
			assertEqual(accept12.myPriorLiftHistory, null);
			assertEqual(accept12.myPriorHistory, null);
			assertEqual(accept12.tiId, ti1.id);
			
			assertEqual(pickup12.type, CM_MachineHistory.Type_PickUp);
			assertEqual(pickup12.isStartOfLift, false);
			assertEqual(pickup12.isEndOfLift, false);
			assertEqual(pickup12.myPriorLiftHistory, accept12);
			assertEqual(pickup12.myPriorHistory,accept12);
			assertEqual(pickup12.tiId, ti1.id);

//	--------------------------------------
//	SECOND PICKUP/SETDOWN FOR STRADDLE 1
// 	--------------------------------------
	//task2 := self.machineTaskRequest(straddle2);
	task2:= ti1.getDirectorOrPickupTask();
	assertEqual(task2.taskType, TASK_PICKUP);
	//assertEqual(task2.status, TASK_OFFERED);
	assertEqual(task2.tiId, ti1.id);
	
	task :=ti2.getDirectorOrPickupTask(); // self.machineTaskRequest(straddle1);
	assertEqual(task.taskType, TASK_PICKUP);
	//assertEqual(task.status, TASK_OFFERED);
	assertEqual(task.tiId, ti2.id);
	
	self.machineAcceptTask(straddle1, task);
	// check history
		accept21 := straddle1.history.last.CM_MachineMoveHistory;
			assertEqual(accept21.type, CM_MachineHistory.Type_AcceptMove);
			assertEqual(accept21.isStartOfLift, true);
			assertEqual(accept21.isEndOfLift, false);
			assertEqual(accept21.myPriorLiftHistory, null);
			assertEqual(accept21.myPriorHistory, null);

	self.machinePickup(straddle1);
		pickup21 := straddle1.history.last.CM_MachineMoveHistory;
			assertEqual(pickup21.type, CM_MachineHistory.Type_PickUp);
			assertEqual(pickup21.isStartOfLift, false);
			assertEqual(pickup21.isEndOfLift, false);
			assertEqual(pickup21.myPriorLiftHistory, accept21);
			assertEqual(pickup21.myPriorHistory, accept21);
			
			assertEqual(accept21.myNextLiftHistory, pickup21);
			assertEqual(accept21.myNextHistory, pickup21);
	// setdown on IMV		
	self.machineSetdown(straddle1, ti2, IMV1);
		self.assertEqual(ti1.myPrimaryActualLocation, imv1.myMachineController);
			
		setdown21 := straddle1.history.last.CM_MachineMoveHistory;
			assertEqual(setdown21.type, CM_MachineHistory.Type_SetDown);
			assertEqual(setdown21.isStartOfLift, false);
			assertEqual(setdown21.isEndOfLift, true);
			assertEqual(setdown21.myPriorLiftHistory, pickup21);
			assertEqual(setdown21.myPriorHistory, pickup21);
			
			assertEqual(pickup21.myNextLiftHistory, setdown21);
			assertEqual(pickup21.myNextHistory, setdown21);
			
		// now check IMV history
		accept22 := self.getHistoryForTI (CM_MachineHistory.Type_AcceptMove, imv1, ti2.id);
		pickup22 := self.getHistoryForTI (CM_MachineHistory.Type_PickUp, imv1, ti2.id);
		
		self.assertNotNull (accept22);
		self.assertNotNull (pickup22);
			assertEqual(accept22.type, CM_MachineHistory.Type_AcceptMove);
			assertEqual(accept22.isStartOfLift, false);
			assertEqual(accept22.isEndOfLift, false);
			assertEqual(accept22.myPriorLiftHistory, pickup12);
			assertEqual(accept22.myPriorHistory, null);
			assertEqual(accept22.tiId, ti2.id);
			
			assertEqual(pickup22.type, CM_MachineHistory.Type_PickUp);
			assertEqual(pickup22.isStartOfLift, false);
			assertEqual(pickup22.isEndOfLift, false);
			assertEqual(pickup22.myPriorLiftHistory, accept22);
			assertEqual(pickup22.myPriorHistory,accept22);
			assertEqual(pickup22.tiId, ti2.id);
	
//	--------------------------------------
//	FIRST PICKUP/SETDOWN FOR STRADDLE 2
// 	--------------------------------------	
	//task := self.machineTaskRequest(straddle2);
	assertEqual(task2.taskType, TASK_PICKUP);
	//assertEqual(task2.status, TASK_OFFERED);
	assertEqual(task2.tiId, ti1.id);
	
	self.machineAcceptTask(straddle2, task2);	
		accept13 := straddle2.history.last.CM_MachineMoveHistory;
			assertEqual(accept13.type, CM_MachineHistory.Type_AcceptMove);
			assertEqual(accept13.isStartOfLift, true);
			assertEqual(accept13.isEndOfLift, false);
			assertEqual(accept13.myPriorLiftHistory, null);
			assertEqual(accept13.myPriorHistory, null);

	self.machinePickup(straddle2);
		pickup13 := straddle2.history.last.CM_MachineMoveHistory;
			assertEqual(pickup13.type, CM_MachineHistory.Type_PickUp);
			assertEqual(pickup13.isStartOfLift, false);
			assertEqual(pickup13.isEndOfLift, false);
			assertEqual(pickup13.myPriorLiftHistory, accept13);
			assertEqual(pickup13.myPriorHistory, accept13);
			
			assertEqual(accept13.myNextLiftHistory, pickup13);
			assertEqual(accept13.myNextHistory, pickup13);
			
	// now check IMV history
		setdown12 := imv1.history.last.CM_MachineMoveHistory;
			assertEqual(setdown12.type, CM_MachineHistory.Type_SetDown);
			assertEqual(setdown12.isStartOfLift, false);
			assertEqual(setdown12.isEndOfLift, false);
			assertEqual(setdown12.myPriorLiftHistory, pickup22);
			assertEqual(setdown12.myPriorHistory, pickup12);
			
			assertEqual(pickup22.myNextLiftHistory, setdown12);
			assertEqual(pickup22.myNextHistory, null);
//------------------
// make sure it works with imv 1 logoff/logon here
//--------------------			
	self.machineLogOff(imv1);
	self.machineLogon(imv1);

	process.sleep(1);		// To ensure Logon and Setdown history are in the correct order
	
	// SETDOWN TO TARGET AREA	
	self.machineSetdown(straddle2, ti1, "UT_ST2 010001");
	
	self.assertEqual(ti1.myPrimaryActualLocation, st2.allGridControllersByRowColumn[1, 1]);

		setdown13 := straddle2.history.last.CM_MachineMoveHistory;
			assertEqual(setdown13.type, CM_MachineHistory.Type_SetDown);
			assertEqual(setdown13.isStartOfLift, false);
			assertEqual(setdown13.isEndOfLift, true);
			assertEqual(setdown13.myPriorLiftHistory, pickup13);
			assertEqual(setdown13.myPriorHistory, pickup13);
			
			assertEqual(pickup13.myNextLiftHistory, setdown13);
			assertEqual(pickup13.myNextHistory, setdown13);
//	--------------------------------------
//	SECOND PICKUP/SETDOWN FOR STRADDLE 2
// 	--------------------------------------	
	task2 :=ti2.getDirectorOrPickupTask(); //self.machineTaskRequest(straddle2);
	assertEqual(task2.taskType, TASK_PICKUP);
	//assertEqual(task2.status, TASK_OFFERED);
	assertEqual(task2.tiId, ti2.id);
	
	self.machineAcceptTask(straddle2, task2);	
		accept23 := straddle2.history.last.CM_MachineMoveHistory;
			assertEqual(accept23.type, CM_MachineHistory.Type_AcceptMove);
			assertEqual(accept23.isStartOfLift, true);
			assertEqual(accept23.isEndOfLift, false);
			assertEqual(accept23.myPriorLiftHistory, null);
			assertEqual(accept23.myPriorHistory, null);

	self.machinePickup(straddle2);
		pickup23 := straddle2.history.last.CM_MachineMoveHistory;
			assertEqual(pickup23.type, CM_MachineHistory.Type_PickUp);
			assertEqual(pickup23.isStartOfLift, false);
			assertEqual(pickup23.isEndOfLift, false);
			assertEqual(pickup23.myPriorLiftHistory, accept23);
			assertEqual(pickup23.myPriorHistory, accept23);
			
			assertEqual(accept23.myNextLiftHistory, pickup23);
			assertEqual(accept23.myNextHistory, pickup23);
			
	// now check IMV history
		setdown22 := imv1.history.last.CM_MachineMoveHistory;
			assertEqual(setdown22.type, CM_MachineHistory.Type_SetDown);
			assertEqual(setdown22.isStartOfLift, false);
			assertEqual(setdown22.isEndOfLift, true);
			assertEqual(setdown22.myPriorLiftHistory, setdown12);
			assertEqual(setdown22.myPriorHistory, pickup22);
			
			assertEqual(pickup22.myNextLiftHistory, setdown12);
			assertEqual(pickup22.myNextHistory, setdown22);
			
	// SETDOWN TO TARGET AREA		
	self.machineSetdown(straddle2, ti1, "UT_ST2 010002");
	
	self.assertEqual(ti1.myPrimaryActualLocation, st2.allGridControllersByRowColumn[1, 1]);

		setdown23 := straddle2.history.last.CM_MachineMoveHistory;
			assertEqual(setdown23.type, CM_MachineHistory.Type_SetDown);
			assertEqual(setdown23.isStartOfLift, false);
			assertEqual(setdown23.isEndOfLift, true);
			assertEqual(setdown23.myPriorLiftHistory, pickup23);
			assertEqual(setdown23.myPriorHistory, pickup23);
			
			assertEqual(pickup23.myNextLiftHistory, setdown23);
			assertEqual(pickup23.myNextHistory, setdown23);			
			
			
	self.machineLogOff(straddle1);
	self.machineLogOff(straddle2);
	self.machineLogOff(imv1);

epilog
	delete tas;
end;</source>
