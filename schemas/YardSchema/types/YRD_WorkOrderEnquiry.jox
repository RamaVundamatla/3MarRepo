    <JadeMethod name="doClonedMenuClickSpecial" id="dc4e43d2-3732-4c28-92b4-253a965a7b5f">
        <updating/>
        <source>doClonedMenuClickSpecial(menuItem: MenuItem input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 December 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars

begin
	self.doCompleteTask(menuItem);
	
	inheritMethod(menuItem);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCompleteTask" id="76757800-813d-4c5b-9ec6-bcdba7d8957a">
        <source>doCompleteTask(menuItem : MenuItem input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Dec 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
06 Jun 2023 navma1  Bug 58265: MTN - Complete ToDo security role setting is missing for all the new event todo tasks.
*/

vars
	taskFormName 		: String;
	taskFormNameLength  : Integer;
	task 				: CM_WorkOrderDtl;
	passedAction 		: Integer;
	toDoSet				: Cm_ToDoTaskSet;
	toDoTask			: CM_ToDoTask;
begin
	
	if menuItem = null then
		return;
	endif;
	
	task 			   := menuItem.userObject.CM_WorkOrderDtl;
	taskFormName	   := CMUI_TasksForm.name;
	taskFormNameLength := taskFormName.length;
	
	if task.isKindOf(CM_WorkOrderToDoDtl) then
	
		create toDoSet transient;
		
		foreach toDoTask in task.CM_WorkOrderToDoDtl.allToDoTasks do		//06.06.2023 navma1 #58265
			if toDoTask.canUserSetComplete(app.myPassport) then
				toDoSet.addNoDuplicates(toDoTask,false);
			endif;
		endforeach;
		
		if menuItem.helpKeyword.length &gt; taskFormNameLength and menuItem.helpKeyword[1:taskFormNameLength] = taskFormName then
			passedAction := menuItem.helpKeyword[taskFormNameLength + 2:1].Integer;
			if toDoSet.size &gt; 0 then
				self.myAssistant.showTasksFormTasks(toDoSet,  true, passedAction, task.CM_WorkOrderToDoDtl);
			endif;
		endif;
	elseif task.isKindOf(CM_WodToDo) then
		if menuItem.helpKeyword.length &gt; taskFormNameLength and menuItem.helpKeyword[1:taskFormNameLength] = taskFormName then
			passedAction := menuItem.helpKeyword[taskFormNameLength + 2:1].Integer;
			self.myAssistant.showTasksForm(null, task.CM_WodToDo.allAvailableTIs,  true, passedAction);
		endif;
	endif;
	
epilog
	delete toDoSet;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCompleteToDoTask" id="425339e4-2f86-43e7-bc38-ae46443b1b04">
        <updating/>
        <source>doCompleteToDoTask() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Aug 2024 navlc30 Bug 65665: EUP | Complete Job button should not be available on the Unallocated tab for the VAS work orders
*/

vars
	task 				: CM_WorkOrderDtl;
	passedAction 		: Integer;
	toDoSet				: Cm_ToDoTaskSet;
	toDoTask			: CM_ToDoTask;	
	selObj 				: Object;
 	workOrder			: CM_WorkOrder;	
	job					: CM_Job;
	tiSet				: CM_TISet;
	ti					: CM_TrackedItem;
	wle					: CM_WorkListEntry;
	woToDoTask			: CM_WodToDo;
begin
	
	selObj := self.tblData.allSelectedObjects.first;
	
	workOrder := selObj.CM_WorkOrder;
	
	woToDoTask := workOrder.allWoDtls.first.CM_WodToDo;
	
	if woToDoTask = null then
		return;
	endif;
	
	job := woToDoTask.allJobs.first;

	if job.myWODtl &lt;&gt; null then
		task  := job.myWODtl;
	elseif job.myWorkOrderDtlToDo &lt;&gt; null then
		task  := job.myWorkOrderDtlToDo;
	endif;	
	
	if task = null then
		return;
	endif;

	if task.isKindOf(CM_WorkOrderToDoDtl) then
		create toDoSet transient;
		foreach toDoTask in task.CM_WorkOrderToDoDtl.allToDoTasks do		//06.06.2023 navma1 #58265
			if toDoTask.canUserSetComplete(app.myPassport) then
				toDoSet.addNoDuplicates(toDoTask,false);
			endif;
		endforeach;
		if toDoSet.size &gt; 0 then
			self.myAssistant.showTasksFormTasks(toDoSet,  true, passedAction, task.CM_WorkOrderToDoDtl);
		endif;
	elseif task.isKindOf(CM_WodToDo) then
		create tiSet transient;	
		foreach wle in job.workListEntries do
			ti := wle.CM_WOToDoWLE.myTrackedItem;
			if ti &lt;&gt; null then
				tiSet.addNoDuplicates(ti,false);
			endif;
		endforeach;
		
		// ### TFS CR 60699 TASK 60700 27SEP2023 NAVAB1
		if wle &lt;&gt; null and wle.isForToDoWOTransaction() then
			self.setToDoTaskComplete(wle);
		else 
			//self.myAssistant.showTasksForm(null, task.CM_WodToDo.allActionedTIs,  true, 2);	//19.7.2023 navhl20 #58333
			self.myAssistant.showTasksForm(null, tiSet,  true, 2);								//19.7.2023 navhl20 #58333
		endif;
	endif;
	
epilog
	delete toDoSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="d2fbf2dc-b120-4cfb-b48b-d95ceb87dc8d">
        <updating/>
        <source>doDelete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2009	cnwmd1	Initial creation

*/

vars
	workOrder : CM_WorkOrder;
	task 	  : CM_WorkOrderDtl;
	selObj 	  : Object;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin
	selObj := self.tblData.allSelectedObjects.first;
	
	if self.isEnqType_WorkOrder then
	
		if selObj = null then
			app.msgBox(app.getErrorString(Please_select_work_order), app.getErrorString(No_Work_order_selected), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	
		if selObj.isKindOf(CM_WorkOrder) then
			workOrder := selObj.CM_WorkOrder;
		else
			app.raiseUnexpectedProgramError(self.class.name, method.name, "unexpected class type");
		endif;
		
		if app.msgBox(app.getErrorString1(Lit_Confirm_Delete, app.getErrorString(Work_order) &amp; " " &amp; selObj.CM_WorkOrder.id), app.getErrorString(Confirm_Delete), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
			return;
		endif;
		
		app.mousePointer := MousePointer_HourGlass;
		
		//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxDA.trxDeleteWorkOrder(workOrder, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
			//	self.doRefresh(); //jlier1 MTN 34591 2/5/25 - notes will remove the deleted item -refresh is not needed
				break;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString(Work_order) &amp; " " &amp; app.getErrorString(Delete), app.myPassport, ErrWarnMode_Delete);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
		
		
	elseif self.isEnqType_Task() then
		
		if selObj = null then
			app.msgBox(app.getErrorString(Please_select_task), app.getErrorString(No_Task_selected), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	
		if selObj.isKindOf(CM_WorkOrderDtl) then
			task := selObj.CM_WorkOrderDtl;
		else
			app.raiseUnexpectedProgramError(self.class.name, method.name, "unexpected class type");
		endif;
		
		app.mousePointer := MousePointer_HourGlass;
		
		//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxDA.trxDeleteWorkOrderTask(task, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
			//	self.doRefresh(); //jlier1 MTN 34591 2/5/25 - notes will remove the deleted item -refresh is not needed
				break;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString(Task) &amp; " " &amp; app.getErrorString(Delete), app.myPassport, ErrWarnMode_Delete);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
	
	endif;
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doEditItem" id="519dd586-6393-4853-b978-08d68012b1de">
        <updating/>
        <source>doEditItem() updating;

/*

Purpose:			
- Old screen code removed at 20-Feb-2022
Parameters:			

Return Value:		


Date		Who		Reason
04/08/2009	cnwmd1	Initial creation
17/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
25 Apr 2022 navma1  ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
22/07/2022	navcs2 	ChangeRequest 54156: MTN - Work Order New UI Release
24/08/2022  namva1	ChangeRequest 54644: MTN - Work Order Refactor - IsSpecial
13/09/2022  navma1	ChangeRequest 54645: MTN - Work Order Refactor (Additional Changes and remove IsSpecial)
20/02/2022  navma1	Bug 56605: MTN - Cancelled voyages in voyage work orders issues and proxy deletion issues on exceptions
*/

vars
	workOrder   	: CM_WorkOrder;
	selObj			: Object;
	row		    	: Integer;
	invalid			: Boolean;
begin
	
	on Exception do app.handleDeletedObject(exception, selObj, invalid);
	
	row 	:= self.tblData.row;
	selObj := self.tblData.accessRow(row).itemObject;
	
	//27/05/2025	navkc1 JIRA MTN-34972
	if selObj &lt;&gt; null then
		selObj.edition();
	endif;
	//07/05/2025	navkc1 JIRA MTN-34592
	if invalid then
		return;
	endif;

	if self.isEnqType_WorkOrder then
	
		if selObj = null then
			app.msgBox(app.getErrorString(Please_select_work_order), app.getErrorString(No_Work_order_selected), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	
		if selObj.isKindOf(CM_WorkOrder) then
			workOrder := selObj.CM_WorkOrder;
		else
			app.raiseUnexpectedProgramError(self.class.name, method.name, "unexpected class type");
		endif;
		
		app.mousePointer := MousePointer_HourGlass;
		
		//24.08.2022 navma1 #54644
		self.showNewWorkOrder();
		
	elseif self.isEnqType_Task() then
		self.doShowTasks();  
	endif;
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doEnquireTypeChange" id="2836c5ff-d4df-41ca-bd55-4acfb6507187">
        <updating/>
        <source>doEnquireTypeChange()updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwmd1	Initial creation
10/03/2023	navcs2	ChangeRequest Task 57034:[57035]: EUP - Status bar to show work order count at Work order Enquiry Screen

*/

vars

begin
	self.setEnquiryType();
	self.initTblData();	
	
	if self.isEnqType_WorkOrder() then
		self.setCaption( app.getErrorString(Work_order) &amp; " " &amp; app.getErrorString(Enquiry) );
	elseif self.isEnqType_Task() then
		self.setCaption(app.getErrorString(Task) &amp; " " &amp; app.getErrorString(Enquiry));
	endif;
	self.setNavigatorHeading(self.caption);
	
	self.setStatusCaption();
	self.doRefresh();
	
	self.updateStatusBarCount();	//10.03.2023	navcs2 #57034:[57035]
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFilterTable" id="e5e4a646-1062-4a7e-822c-dc58cd8f87dc">
        <updating/>
        <source>doFilterTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Mar 2023 navhl20  ChangeRequest 57315:[57316] EUP - [Framework] - Allow Text filtering on the work order screen
*/

vars
	filterText 	: String;
	rowIdx,
	colIdx,
	start,
	rows		: Integer;
	cell 		: JadeTableCell;
	cellText 	: String;
	tbl			: CM_DataTable;
	
begin
   /*	//25/06/2024	navkc1 CR 64823 Task 64824
   rows		:= 0;
	filterText  := self.txtFilterBox.text.toUpper();
	tbl			:= self.tblData;
	
	tbl.rows := 0;
	self.initTblData();
	self.displayTable();
	
	if filterText = "" then
		self.clearFilter();
		return;
	else
		self.btnClearFilter.enabled := true;
	endif;

	start := tbl.fixedRows + 1;
	self.tblInfo.rows := 0;
	
	foreach rowIdx in start to tbl.rows do : rowLoop
		tbl.accessRow(rowIdx);
		
		foreach colIdx in 1 to tbl.columns do
			cell 	 := tbl.accessCell(rowIdx, colIdx);
			cellText := cell.text.toUpper;
			
			if cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then
				tbl.accessedRow.visible := true;
				rows := rows+1;
				continue rowLoop;
			endif;
		endforeach;
		
		tbl.accessedRow.visible := false;
	endforeach;*/
	
	//25/06/2024	navkc1 CR 64823 Task 64824
	if self.frmTblFilter &lt;&gt; null then
		rows := self.frmTblFilter.numOfRowVisible;
	endif;
	
	self.staStatusBar.caption := rows.String &amp; " rows found.";
epilog

end;</source>
