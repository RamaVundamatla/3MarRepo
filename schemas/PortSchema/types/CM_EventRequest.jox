    <JadeMethod name="isActioned" id="2c32b5d9-3b84-4a8e-a2a1-f3041b62c379">
        <source>isActioned() : Boolean;
//	13/12/2010 	cnwcs5 	ccms mes 1112 / par 24464 - new status
vars

begin
	return (self.status = EventRequestActioned) or 
		   (self.status = EventRequestCargoDeleted) or	// 13/12/2010 cnwcs5 ccms mes 1112 / par 24464
		   (self.status = EventRequestEmailed);
end;
</source>
