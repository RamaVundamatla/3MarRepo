    <JadeMethod name="closeLocation" id="4d8877af-106c-483e-9f67-572c1f37a281">
        <source>closeLocation(location: CM_LocationsController input): Boolean protected;

//03 July 2008	cnwdw1	
// Close the location - will stop it being used in yard allocations
vars
begin
	if not self.myMobileDataAgent.closeLocation(location) then
		self.checkAndShowErrors();
		return false;
	endif;
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="location" type="CM_LocationsController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createCmifTIFromID" id="e88329b5-8a70-4cea-bc39-551c4c9d4e12">
        <updating/>
        <source>createCmifTIFromID(_id : String)updating;
/*
	Created on 11 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	ti			: CM_TrackedItem;
	result 		: Integer;
	cmif_TI		: CMIF_TIGenCargo;
	cmif_rec	: CMIF_Receival;
	action 		: Integer;
begin
	ti := self.findTIForCMIF(_id, action);
	
	if ti = null then
		if action &lt;&gt; CMIF_TIGenCargo.Action_Move and self.myMobileDataAgent.findOnsiteCargoByID(_id) &lt;&gt; null then
			app.msgBox(	"There is already a tracked item onsite with this id",
									"",
									MsgBox_OK_Only);
			return;
		else
			result := app.msgBox(	app.getErrorString(Item_NotFound) &amp; CrLf &amp; app.getErrorString(Create_NewItem),
									app.getErrorString(Item_NotFound),
									MsgBox_Yes_No);
			
			if result = MsgBox_Return_Yes then
				cmif_TI := self.myMobileDataAgent.allCMIFs.last.CMIF_TIGenCargo;
				cmif_rec := app.myMobileGUIAgent.createNewCargoItem(_id, cmif_TI, self.myMobileDataAgent.myRoadJob);
				action := cmif_TI.Action_CreateItem;
			else
				return;
			endif;
		endif;
	endif;
	
	if ti &lt;&gt; null then
		self.myMobileDataAgent.createCMIFForTrackedItem(ti, action);
	elseif cmif_rec &lt;&gt; null then
		self.myMobileDataAgent.createCMIFforCMIFReceival(cmif_rec, action);
	endif;
	self.loadCount := self.loadCount + 1;


end;</source>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteObjectFromTable" id="47b1dec3-3d1f-4a05-8fed-aa36860081fa">
        <updating/>
        <source>deleteObjectFromTable(obj: CMIF_Object io) updating;
/*
	Created on 15 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	self.myMobileDataAgent.removeCMIF(obj);
	self.loadCount := self.loadCount - 1;
	self.loadTable(tbl_Items);
end;</source>
        <Parameter name="obj" type="CMIF_Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doCargoListSort" id="e1e6bfb3-470d-423e-9733-60a82a16d968">
        <updating/>
        <source>doCargoListSort() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2009	#cnwdz2	 ccms1801

*/

vars

begin
	if self.tbl_Items.row = 1 then
		if not self.cargoListSorted then
			self.tbl_Items.sortColumn[1]	:= 1;
			self.tbl_Items.sortAsc[1]		:= true;
			
			self.tbl_Items.resort();
			self.cargoListSorted := true;
		else
			self.loadTable(self.tbl_Items);
			self.cargoListSorted := false;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doChangeLocations" id="2285adee-c0b2-41fe-925b-7707d6056b57">
        <updating/>
        <source>doChangeLocations()updating;
/*
	Created on 23 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	loc : CM_LocationsController;
	selectedObjs : ObjectArray;
begin
	if self.myMobileDataAgent.allCMIFs.size = 0 then
		app.msgBox(app.getErrorString(MOB_CEScanLoadForm_ChangeLoc), app.getErrorString(Error), MsgBox_OK_Only);
		return;
	endif;
	loc := app.myMobileGUIAgent.getLocation(app.getErrorString(Change_locations));
	if loc &lt;&gt; null then	
		//20/05/2009 cnwdz2 ccms1801
		create selectedObjs transient;
		self.tbl_Items.getAllSelectedObjects(selectedObjs);
		if selectedObjs.size &gt; 0 then
			self.myMobileDataAgent.changeSelectedLocationsTo(selectedObjs,loc);
		else
			self.myMobileDataAgent.changeAllLocationsTo(loc);
		endif;
	endif;
	loadTable(tbl_Items);
epilog
	delete selectedObjs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doClearTable" id="3af5c87f-58f4-4585-abe7-0afbcd9e9ce1">
        <updating/>
        <source>doClearTable(_confirm : Boolean)updating;
/*
	Created on 21 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	num : Integer;
begin
	if _confirm then  
		num := self.myMobileDataAgent.allCMIFs.size; // this is a clear so decrement count.
	else
		num := 0; // this is a set down so do not decrement in this case
	endif;
	if self.myMobileDataAgent.allCMIFs.size &gt; 0 then
		if (not _confirm)
		or app.msgBox(app.getErrorString(Clear_load), "", MsgBox_Yes_No) = MsgBox_Return_Yes then
			self.loadCount := self.loadCount - num;
			self.myMobileDataAgent.allCMIFs.purge;
			loadTable(tbl_Items);
		endif;
	endif;
end;</source>
        <Parameter name="_confirm" type="Boolean"/>
    </JadeMethod>
