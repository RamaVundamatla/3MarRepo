    <JadeMethod name="validateDetailById" id="34f59f40-f834-4207-9872-04abde4a545b">
        <source>validateDetailById(_terminal : CM_Terminal) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 July 2024		navmd1	Initial creation TFS 63327
01 Aug  2024        navsp1  ChangeRequest 65383: MTN - /ReleaseRequest API further refinements
*/

vars
	cargoItem	: WS_ReleaseDetailByIdObject;
begin
	if self.cargo &lt;&gt; null then
		foreach cargoItem in self.cargo do
			// Make sure Id is not blank
			if cargoItem.cargoId = null then
				app.myPassport.addErrorFull(Cargo_item_not_found, app.getErrorString(Cargo_item_not_found), null, null,null);
			endif;
			
			// Make sure cargo type is valid
			if cargoItem.cargoTypeId = null then
				app.myPassport.addErrorFull(Input_required_field_cargoType, app.getErrorString(Input_required_field_cargoType), null, null,null);
			else
				if app.myRoot.getCargoTypeFromAbbrevOrDescr(cargoItem.cargoTypeId) = null then
					app.myPassport.addErrorFull(Cargot_not_valid_cargot_system, app.getErrorString1(Cargot_not_valid_cargot_system,  cargoItem.cargoTypeId), null, null,null);
				endif;
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="validateDetailByType" id="3701e4d6-e738-44b9-8fda-0bad0df4d870">
        <source>validateDetailByType(_terminal : CM_Terminal) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 July 2024		navmd1	Initial creation TFS 63327
01 Aug  2024        navsp1  ChangeRequest 65383: MTN - /ReleaseRequest API further refinements
*/

vars
	cargoItem	: WS_ReleaseDetailByTypeObject;
begin
	if self.releaseItems &lt;&gt; null then

		foreach cargoItem in self.releaseItems do
			// Make sure cargo type is valid
			if cargoItem.cargoTypeId = null then
				app.myPassport.addErrorFull(Input_required_field_cargoType, app.getErrorString(Input_required_field_cargoType), null, null,null);
			else
				if app.myRoot.getCargoTypeFromAbbrevOrDescr(cargoItem.cargoTypeId) = null then
					app.myPassport.addErrorFull(Cargot_not_valid_cargot_system, app.getErrorString1(Cargot_not_valid_cargot_system, cargoItem.cargoTypeId), null, null,null);
				endif;
			endif;
		endforeach;
	
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="validateRequest" id="b02fa344-668c-42d6-b595-7be87954b830">
        <source>validateRequest(_terminal : CM_Terminal input) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 July 2024		navmd1	Initial creation TFS 63327 Make sure common validation is all in one place
01 Aug  2024        navsp1  ChangeRequest 65383: MTN - /ReleaseRequest API further refinements
*/

vars
	
begin
	if self.id = null then
		app.myPassport.addErrorFull(Input_req_release_number, app.getErrorString(Input_req_release_number), null, null,null);
	endif;

	if self.requestType = null then
		app.myPassport.addErrorFull(Input_required_field_reqtype, app.getErrorString(Input_required_field_reqtype), null, null,null);
	else
		if not self.requestType.isOneOf(BR_TYPE_ROAD_STR, BR_TYPE_RAIL_STR, BR_TYPE_SHIP_STR, BR_TYPE_PACKING_STR) then
			app.myPassport.addErrorFull(Invalid_Release_Request_Type, app.getErrorString1(Invalid_Release_Request_Type, self.requestType), null, null,null);
		endif;
	endif;
	if self.operatorId = null then
		app.myPassport.addErrorFull(Input_required_field_operator, app.getErrorString(Input_required_field_operator), null, null,null);
	endif;
	
	if self.voyageId = null then
		app.myPassport.addErrorFull(Input_required_field_voyage, app.getErrorString(Input_required_field_voyage), null, null,null);
	else
		if WS_WebServiceAgent@findVoyage(_terminal, self.voyageId, null, false) = null then
			app.myPassport.addErrorFull(Voyage_not_found, app.getErrorString1(Voyage_not_found, self.voyageId), null, null,null);
		endif;
	endif;
	
	// Carrier is stored as a String on CM_BulkRelease, so lets make sure we have a valid one
	if self.carrierId &lt;&gt; null then
		if app.myRoot.allCarriers[self.carrierId] = null then
			app.myPassport.addErrorFull(ERR_Carrier_Unknown, app.getErrorString2(ERR_Carrier_Unknown,self.carrierId,null), null, null,null);
		endif;
	endif;
	
	// Consignee/or and freight forwarder code/description is (allegedly) set based on System Config Consignor_ee_AsText
	if not app.myRoot.getConfig(Consignor_ee_AsText).Boolean then
		if self.consigneeId &lt;&gt; null and app.myRoot.allConsigneeConsignors[self.consigneeId] = null then
			app.myPassport.addErrorFull(ERR_INVALID_CONSIGN, app.getErrorString1(ERR_INVALID_CONSIGN, self.consigneeId), null, null,null);
		endif;
		if self.consignorId &lt;&gt; null and app.myRoot.allConsigneeConsignors[self.consignorId] = null then
			app.myPassport.addErrorFull(ERR_INVALID_CONSIGN, app.getErrorString1(ERR_INVALID_CONSIGN, self.consignorId), null, null,null);
		endif;
		if self.freightForwarderId &lt;&gt; null and app.myRoot.allConsigneeConsignors[self.freightForwarderId] = null then
			app.myPassport.addErrorFull(ERR_INVALID_FreightForwarder, app.getErrorString1(ERR_INVALID_FreightForwarder, self.freightForwarderId), null, null,null);
		endif;
	endif;
	
	// Sub Terminal - only validate if subterminals are enabled for the terminal we're logged in to
	if _terminal.isSubTerminalsOn then
		if self.subTerminalId &lt;&gt; null then
			if _terminal.allSubTerminals[self.subTerminalId] = null then
				app.myPassport.addErrorFull(Subterminal_invalid, app.getErrorString(Subterminal_invalid), null, null,null);
			endif;
		elseif not _terminal.getConfig(IsSubTerminalAreaDefined).Boolean then
			app.myPassport.addErrorFull(Input_required_field_subTerm, app.getErrorString(Input_required_field_subTerm), null, null,null);
		endif;
	endif;
	
	// Destination Terminal - Inter-Terminal Transfer
	if self.destinationTerminalId &lt;&gt; null and app.myRoot.allTerminals[self.destinationTerminalId] = null then
		// This isn't validated in the thin client, but may as well do so here
		app.myPassport.addErrorFull(ERR_INVALID_DEST_PORT, app.getErrorString1(ERR_INVALID_DEST_PORT, self.destinationTerminalId), null, null,null);
	endif;
	
	// Discharge Port
	if self.dischargePortId &lt;&gt; null and app.myRoot.allPorts[self.dischargePortId] = null then
		app.myPassport.addErrorFull(Port_invalid, app.getErrorString1(Port_invalid, self.dischargePortId), null, null,null);
	endif;
	
	// Make sure we have at least 1 sensible cargo/item to add
	if self.releaseByType then
		if self.releaseItems = null or self.releaseItems.size = 0 then
			app.myPassport.addErrorFull(At_Least_One_RequestLine, app.getErrorString(At_Least_One_RequestLine), null, null,null);
		endif;
		self.validateDetailByType(_terminal);
	else
		if self.cargo = null or self.cargo.size = 0 then
			app.myPassport.addErrorFull(At_Least_One_CargoItem, app.getErrorString(At_Least_One_CargoItem), null, null,null);
		endif;
		self.validateDetailById(_terminal);
	endif;
	if app.myPassport.hasErrors then
		return false;
	else
		return true;
	endif;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
