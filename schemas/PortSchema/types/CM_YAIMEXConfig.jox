    <JadeMethod name="exportAsXMLInverseRef" id="f11cd6ab-8151-4cb1-abf8-1dbc830efdb5">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars

begin
	if _property = CM_YAIMEXConfig::allOpCriteria then
		return ExportAsChild;
	endif;

	return inheritMethod(_property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="dfdffd83-32d1-4293-a8ed-56e9ec595737">
        <source>getAuditText(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
01 August 2008	consw1	Initial creation

*/

vars
	txt	: String;
	ct : CM_YACriteriaType;
	ctDesc : String;

begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();

	//  Op Criteria
	foreach ct in self.allOpCriteria do
		if ctDesc &lt;&gt; null then
			ctDesc := ctDesc &amp; ", ";
		endif;
		ctDesc := ctDesc &amp; ct.description;
	endforeach;

	txt := txt &amp; 'Criteria Selected ' &amp; AuditStringSeparator &amp; ctDesc.length.String &amp; AuditStringSeparator &amp; ctDesc &amp; AuditStringSeparator;

	//  Group Label Criteria
	
	ctDesc := null;
	
	foreach ct in self.allGroupLabelCriteria do
		if ctDesc &lt;&gt; null then
			ctDesc := ctDesc &amp; ", ";
		endif;
		ctDesc := ctDesc &amp; ct.description;
	endforeach;

	txt := txt &amp; 'Group Criteria Selected ' &amp; AuditStringSeparator &amp; ctDesc.length.String &amp; AuditStringSeparator &amp; ctDesc &amp; AuditStringSeparator;

	return txt;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaByType" id="72b15a42-a98a-4981-be65-3752d9b4ba8d">
        <source>getCriteriaByType(_type : Integer) : CM_YACriteriaType;
/*
Purpose:			
Date		Who		Reason
27 May 2014	cnwab1	Initial creation
*/

vars
	yaCriType : CM_YACriteriaType;
begin
	if self.allOpCriteria &lt;&gt; null then
		foreach yaCriType in self.allOpCriteria  discreteLock do
			if yaCriType.type = _type then // YACriteriaType_IsTransShip
				return yaCriType;
			endif;
		endforeach;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_YACriteriaType"/>
    </JadeMethod>
    <JadeMethod name="importFromXMLDocReference" id="8fb92f41-9fbf-4f80-8b02-d00f3c1d5e36">
        <updating/>
        <source>importFromXMLDocReference(_property: Property; _xmlElement: JadeXMLElement input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	childNode : JadeXMLNode;
	criteriaTypeElement : JadeXMLElement;
	criteriaType : CM_YACriteriaType;
begin
	if _property = CM_YAIMEXConfig::allOpCriteria then
		foreach childNode in _xmlElement.childNodes do
			criteriaTypeElement:=childNode.JadeXMLElement.getElementByTagName(CM_YACriteriaType::type.name);	
			if criteriaTypeElement &lt;&gt; null then
				criteriaType:=app.myRoot.allYACriteriaTypes[criteriaTypeElement.textData.Integer];
				if criteriaType &lt;&gt; null then
					self.allOpCriteria.add(criteriaType);
				endif;
			endif;
		endforeach;
	else
		inheritMethod(_property, _xmlElement);
	endif;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="072d28e1-575b-4919-bc34-61e17aa247cb">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
01 August 2008	consw1	Initial creation
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars
	pxy	: CM_YAIMEXConfig;
	completedOK		: Boolean;
	
begin
	pxy := inheritMethod();

	pxy.myYAConfig := self.myYAConfig;
	pxy.myIMEXStatus := self.myIMEXStatus;
	pxy.myDefaultColourType := self.myDefaultColourType; //cnwrd1 ccms 2115 par 28185 12.9.2011

	self.allGroupLabelCriteria.copy(pxy.allGroupLabelCriteria);
	self.allOpCriteria.copy(pxy.allOpCriteria);
	
	// cnwjk3 SFW1030
	pxy.colour := self.colour;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="53046919-463e-44f9-8a77-5707dbf2cd75">
        <updating/>
        <source>setForCreate( _yaConfig : CM_YAConfig; _imexStatus : Integer; _defaultColourType : CM_YACriteriaType ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
31 July 2008	consw1	Initial creation

*/

vars

begin
	self.myIMEXStatus := app.myRoot.allImexStatuses[_imexStatus];
	self.myYAConfig := _yaConfig;
	self.myDefaultColourType := _defaultColourType;
epilog

end;</source>
        <Parameter name="_yaConfig" type="CM_YAConfig"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="_defaultColourType" type="CM_YACriteriaType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5f3b637f-7316-4cb4-aa1e-43f915615eb7">
        <updating/>
        <source>setForUpdate(_proxyYAIMEXConfig: CM_YAIMEXConfig) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
31 July 2008	consw1	Initial creation

*/

vars

begin
	self.allOpCriteria.clear;
	_proxyYAIMEXConfig.allOpCriteria.copy(self.allOpCriteria);
	
	self.allGroupLabelCriteria.clear;
	_proxyYAIMEXConfig.allGroupLabelCriteria.copy(self.allGroupLabelCriteria);
	
	self.colour := _proxyYAIMEXConfig.colour; 
	self.myDefaultColourType := _proxyYAIMEXConfig.myDefaultColourType; //cnwrd1 ccms 2115 par 28185 12.9.2011
	
epilog

end;</source>
        <Parameter name="_proxyYAIMEXConfig" type="CM_YAIMEXConfig"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="708f970a-72f4-4325-be97-14faa4ed4b03">
        <updating/>
        <source>setProxy(_opCriteriaColl, _groupLabelCriteriaColl : CM_YACriteriaTypeArray; _colour : Integer; _defaultColourType : CM_YACriteriaType) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
31 July 2008	consw1	Initial creation

*/

vars
 
begin
	self.raiseExceptionIfNotTransient(method);

	self.allOpCriteria.clear;
	if _opCriteriaColl &lt;&gt; null then
		_opCriteriaColl.copy(self.allOpCriteria);
	endif;
	
	self.allGroupLabelCriteria.clear;
	if _groupLabelCriteriaColl &lt;&gt; null then
		_groupLabelCriteriaColl.copy(self.allGroupLabelCriteria);
	endif;
	// cnwjk3 SFW1030
	self.colour := _colour;
	
	self.myDefaultColourType := _defaultColourType; //cnwrd1 ccms 2115 par 28185 12.9.2011
epilog

end;</source>
        <Parameter name="_opCriteriaColl" type="CM_YACriteriaTypeArray"/>
        <Parameter name="_groupLabelCriteriaColl" type="CM_YACriteriaTypeArray"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_defaultColourType" type="CM_YACriteriaType"/>
    </JadeMethod>
