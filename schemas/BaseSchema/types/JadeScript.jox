    <JadeMethod name="cnwdad1_Test_WeekDay_Methods" id="2bcd21f4-379d-495b-a9b8-7dfe1723d92b">
        <source>cnwdad1_Test_WeekDay_Methods();
// --------------------------------------------------------------------------------
// Created:		20 December 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	testDate	: Date;
	
begin
//	testDate.setDate(04, 04, 2005);
	write "Current age for 10/07/1962: " &amp; "10/07/1962".Date.cnEcCurrentAge();
	write "Days in month for " &amp; testDate.shortFormat() &amp; ": " &amp; testDate.cnEcDaysInMonth().String;
	write "Days in year for " &amp; testDate.shortFormat() &amp; ": " &amp; testDate.cnEcDaysInYear().String;
	write "Century for " &amp; testDate.shortFormat() &amp; ": " &amp; testDate.cnEcGetCentury().String;
	write "Last Monday for " &amp; testDate.shortFormat() &amp; ": " &amp; testDate.cnEcGetLastMonday().shortFormat();
	write "Last Sunday for " &amp; testDate.shortFormat() &amp; ": " &amp; testDate.cnEcGetLastSunday().shortFormat();
	write "Next Monday for " &amp; testDate.shortFormat() &amp; ": " &amp; testDate.cnEcGetNextMonday().shortFormat();
	write "Next Sunday for " &amp; testDate.shortFormat() &amp; ": " &amp; testDate.cnEcGetNextSunday().shortFormat();
	write "Previous week day for " &amp; testDate.shortFormat() &amp; ": " &amp; testDate.cnEcGetPreviousWeekDay().shortFormat();
	write "Next week day for " &amp; testDate.shortFormat() &amp; ": " &amp; testDate.cnEcGetNextWeekDay().shortFormat();
	write "Week number for " &amp; testDate.shortFormat() &amp; ": " &amp; testDate.cnEcGetWeek().String;
	write "Is " &amp; testDate.shortFormat() &amp; " in a leap year: " &amp; testDate.cnEcIsLeapYear().cnEcGetYesNo() &amp; CrLf;
	
	write testDate.dayName() &amp; " " &amp; testDate.shortFormat() &amp; " is a week day: " &amp; testDate.cnEcIsWeekDay().cnEcGetYesNo();
	testDate	:=	testDate.cnEcAddDays(1);
	write testDate.dayName() &amp; " " &amp; testDate.shortFormat() &amp; " is a week day: " &amp; testDate.cnEcIsWeekDay().cnEcGetYesNo();
	testDate	:=	testDate.cnEcAddDays(1);
	write testDate.dayName() &amp; " " &amp; testDate.shortFormat() &amp; " is a week day: " &amp; testDate.cnEcIsWeekDay().cnEcGetYesNo();
	testDate	:=	testDate.cnEcAddDays(1);
	write testDate.dayName() &amp; " " &amp; testDate.shortFormat() &amp; " is a week day: " &amp; testDate.cnEcIsWeekDay().cnEcGetYesNo();
	testDate	:=	testDate.cnEcAddDays(1);
	write testDate.dayName() &amp; " " &amp; testDate.shortFormat() &amp; " is a week day: " &amp; testDate.cnEcIsWeekDay().cnEcGetYesNo();
	testDate	:=	testDate.cnEcAddDays(1);
	write testDate.dayName() &amp; " " &amp; testDate.shortFormat() &amp; " is a week day: " &amp; testDate.cnEcIsWeekDay().cnEcGetYesNo();
	testDate	:=	testDate.cnEcAddDays(1);
	write testDate.dayName() &amp; " " &amp; testDate.shortFormat() &amp; " is a week day: " &amp; testDate.cnEcIsWeekDay().cnEcGetYesNo();
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_WildcardSearch" id="bd8d78fb-ce27-4cc7-a0f5-8bd228c7df05">
        <source>cnwdad1_Test_WildcardSearch();
// --------------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	WILDCARD_STRING		: String = "ach";
//	WILDCARD_STRING		: String = "*ll*";
//	WILDCARD_STRING		: String = "a*m?ll*";
	MAX_STRING_VALUES	: Integer = 1000;
	
vars
	wildcardSearchObj	: CnEcWildcardSearch;
	spellRootObj		: CnEcSpellRoot;
	spellWordObj		: CnEcSpellWord;
	arrayElementObj		: CnEcArrayObject;
	startTime			: Integer;
	readCount			: Integer;
	
begin
	startTime	:=	app.clock();
	create wildcardSearchObj transient;
	
	write "Adding " &amp; MAX_STRING_VALUES.String &amp; " search string values...";
	spellRootObj	:=	CnEcSpellRoot.firstInstance;
	
	foreach spellWordObj in spellRootObj.allSpellWords do
		readCount	:=	readCount + 1;
		wildcardSearchObj.addSearchValue(spellWordObj.name);
		
		if readCount = MAX_STRING_VALUES then
			break;
		endif;
	endforeach;
	
	write "Parsing wildcard tokens...";
	wildcardSearchObj.isExactMatch	:=	false;
	wildcardSearchObj.parseWildcards(WILDCARD_STRING, false);
	
	write "Searching string values...";
	if wildcardSearchObj.doMultiSearch() then
		write "Found the following values:";
		
		foreach arrayElementObj in wildcardSearchObj.allSearchResults do
			write arrayElementObj.stringValue;
		endforeach;
	else
		write "The wildcard search failed.";
	endif;
epilog
	delete wildcardSearchObj;
	write "Search complete in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_Wildcard_Match" id="0926d1ac-bd43-4852-8013-de77e78f6a9d">
        <source>cnwdad1_Test_Wildcard_Match();
// --------------------------------------------------------------------------------
// Created:		22 January 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	wildcardSearchObj	: CnEcWildcardSearch;
	startTime			: Integer;
	valueCount			: Integer;
	
begin
	startTime	:=	app.clock();
	create wildcardSearchObj transient;
	
	wildcardSearchObj.isExactMatch	:=	true;
	wildcardSearchObj.parseWildcards("*Schema", true);
	
	if wildcardSearchObj.doSearch("BaseSchema") then
		write "The string matched the wildcard pattern.";
	else
		write "The string did not match the wildcard pattern.";
	endif;
epilog
	delete wildcardSearchObj;
	write "Search complete in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_XHandler" id="028a05e0-d6c3-43a9-99f6-b9a61d0a4086">
        <source>cnwdad1_Test_XHandler(pTheException:Exception):Integer;
// --------------------------------------------------------------------------------
// Created:		17 March 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	exceptionDetails	: String;
	
begin
	exceptionDetails	:=	pTheException.cnEcGetDetails();
	
	app.msgBox(exceptionDetails, "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
//	write exceptionDetails;
	
	return Ex_Abort_Action;
end;</source>
        <Parameter name="pTheException" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_XML_EntityConvert" id="75e82809-492e-4e3e-99d2-cd1b7c6b572c">
        <source>cnwdad1_Test_XML_EntityConvert();
// --------------------------------------------------------------------------------
// Created:		22 December 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	entityString	: String;
	charString		: String;
	startTime		: Integer;
	
begin
	startTime		:=	app.clock();
	entityString	:=	"This is a test entity string.  Ampersand is &amp;amp;. Lessthan is &amp;lt;. Greaterthan is &amp;gt;. Apostrophe is &amp;apos;. Quote is &amp;quot;.";
	charString		:=	"This is a test character string.  Ampersand is &amp;. Lessthan is &lt;. Greaterthan is &gt;. Apostrophe is '. Quote is " &amp; '"' &amp; ".";
	
	write entityString;
	write entityString.cnEcXmlReplaceReservedChars(true);
	write CrLf;
	write charString;
	write charString.cnEcXmlReplaceReservedChars(false);
epilog
	write "XML Convert completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_XML_FileParser" id="124ad1a1-5367-4e17-bc71-ff512dd936a6">
        <source>cnwdad1_Test_XML_FileParser();
// --------------------------------------------------------------------------------
// Created:		04 November 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theFile		: File;
	theParser	: CnEcXmlParser;
	theXmlGroup	: CnEcXmlStructureInstance;
	xmlDocument	: String;
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	
	create theFile transient;
	create theParser transient;
	create theXmlGroup as CnEcXmlGroupInstance transient;
	theFile.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
	if theFile.cnEcSetOpenName(true, false, null) then
		xmlDocument	:=	theFile.readString(theFile.fileLength());
		theParser.parseToMsgStructure(xmlDocument, theXmlGroup);
		write "XML Parser completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
		theXmlGroup.cnEcInspectModal();
	endif;
epilog
	delete theFile;
	delete theParser;
	delete theXmlGroup;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_XML_Output" id="84216e2c-042d-456c-a916-6119cf558344">
        <source>cnwdad1_Test_XML_Output(pTheObject:Object): String;
// --------------------------------------------------------------------------------
// Created:		10 March 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	formatName	: String;
	isDebug		: Boolean;
	maxObjects	: Integer;
	parsedCount	: Integer;
	maxOutput	: Integer;

begin
	formatName	:=	"Default OID";	// Must be a valid CnEcXmlFormat.name
	isDebug		:=	false;			// If true include empty tags for empty values, otherwise leave empty ones out.
	maxObjects	:=	0;				// Maximum number of Objects allowed to parse if zero, no Object count checks done.
	parsedCount	:=	0;				// Number of objects parsed to date.
	maxOutput	:=	0;				// Maximum size in Kb of the output string.

//	on CnEcXmlException do handleException(exception);

	return null;
//	return pTheObject.cnEcXmlFormat(	formatName,
//										isDebug,
//										maxObjects,
//										parsedCount,
//										maxOutput);
end;</source>
        <Parameter name="pTheObject" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_XML_Parser" id="f24fcf57-ef63-4f8a-a5ca-365a25a57d3d">
        <source>cnwdad1_Test_XML_Parser();
// --------------------------------------------------------------------------------
// Created:		04 April 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theParser	: CnEcXmlParser;
	theXmlGroup	: CnEcXmlStructureInstance;
	xmlMessage	: String;
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	
	create theParser transient;
	create theXmlGroup as CnEcXmlGroupInstance transient;
	
	xmlMessage	:=	'&lt;!--This is a test XML message--&gt;' &amp; CrLf &amp;
					'&lt;example&gt;' &amp; CrLf &amp;
//					Tab &amp; '&lt;song xml:lang="de"&gt;Sagt mir wo die Blumen sind&lt;/song&gt;' &amp; CrLf &amp;
					Tab &amp; '&lt;song xml:lang="de"&gt;Sagt mir wo die Blumen sind' &amp; CrLf &amp;
					Tab &amp; Tab &amp; '&lt;question xml:lang="en-GB"&gt;' &amp; CrLf &amp;
					Tab &amp; Tab &amp; Tab &amp; 'What is your favourite colour of flower ?' &amp; CrLf &amp;
					Tab &amp; Tab &amp; '&lt;/question&gt;' &amp; CrLf &amp;
					Tab &amp; Tab &amp; '&lt;question xml:lang="en-US"&gt;' &amp; CrLf &amp;
					Tab &amp; Tab &amp; Tab &amp; 'What is your favorite color of flower ?' &amp; CrLf &amp;
					Tab &amp; Tab &amp; '&lt;/question&gt;' &amp; CrLf &amp;
					Tab &amp; Tab &amp; '&lt;question xml:lang="X-INVERSE"&gt;' &amp; CrLf &amp;
					Tab &amp; Tab &amp; Tab &amp; 'What flower is your color ?' &amp; CrLf &amp;
					Tab &amp; Tab &amp; '&lt;/question&gt;' &amp; CrLf &amp;
					Tab &amp; '&lt;/song&gt;' &amp; CrLf &amp;
					'&lt;/example&gt;' &amp; CrLf &amp;
					'&lt;!--This is the end of the message--&gt;';
	
	theParser.parseToMsgStructure(xmlMessage, theXmlGroup);
	write "XML Parser completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
	
	theXmlGroup.cnEcInspectModal();
epilog
	delete theParser;
	delete theXmlGroup;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_XML_Part_Extract" id="867b6a7d-3d14-411b-8a53-52e215e3b155">
        <source>cnwdad1_Test_XML_Part_Extract();
// --------------------------------------------------------------------------------
// Created:		10 March 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	// You must have set up the format "ExtractFormat".
	XML_FORMAT		: String = "ExtractFormat";
	
vars
	inputFile		: String;
	noidFile		: String;
	errorFile		: String;
	logFile			: String;
	outputFile		: String;
	theOidTableRoot	: CnEcOidTable;
	allObjects		: ObjectArray;
	theHubble		: CnEcHubble;
	theRole 		: CnEcBaseRoot;
	thePermission	: CnEcBaseEntity;
	startTime		: Integer;

begin
	startTime	:=	app.clock();
	inputFile 	:=	"";
	errorFile 	:=	"";
	logFile 	:=	"";
	noidFile	:=	"c:\ExportNoid.txt";
	outputFile 	:=	"c:\ExportData.txt"; 
	
	//****************  Start of Export *****************
	
	create allObjects transient;
	
	foreach theRole in CnEcBaseRoot.instances do	
		allObjects.add(theRole);
	endforeach; 
	
	foreach thePermission in CnEcBaseEntity.instances do	
		allObjects.add(thePermission);
	endforeach; 		
	
	create theOidTableRoot transient;
	create theHubble transient;
	
	theHubble.initializeMe(	errorFile,
							inputFile,
							noidFile,
							logFile,
							outputFile,
							XML_FORMAT,
							theOidTableRoot,
							allObjects);
							
	theHubble.export((allObjects.size() div 10), false);
	
	//******************  End of Export *******************
epilog
	delete allObjects;
	delete theOidTableRoot;
	delete theHubble;
	
	write "XML Part Extract completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_X_Details" id="b0ee1225-e9da-45b8-aa57-c91072a67a6f">
        <source>cnwdad1_Test_X_Details();
// --------------------------------------------------------------------------------
// Created:		17 March 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theFile		: File;
	
begin
	on Exception do self.cnwdad1_Test_XHandler(exception);
	
	create theFile transient;
	theFile.open();
epilog
	delete theFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Transform_Write" id="6fc23a2e-f676-4039-a4b5-2575bb052608">
        <source>cnwdad1_Transform_Write(pName:String) protected;
// --------------------------------------------------------------------------------
// Created:		14 June 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theSoundexValue		: CnEcSoundex;
	theMetaphoneValue	: CnEcMetaphone;
	
begin
	create theSoundexValue transient;
	create theMetaphoneValue transient;
	
	theSoundexValue.updateMe(pName);
	theMetaphoneValue.updateMe(pName);
	
	write pName.padBlanks(14) &amp;
	"  " &amp;
	theMetaphoneValue.getTransform(0).padBlanks(6) &amp;
	"     " &amp;
	theSoundexValue.getTransform(0);
epilog
	delete theSoundexValue;
	delete theMetaphoneValue;
end;</source>
        <access>protected</access>
        <Parameter name="pName" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnwdad1_TranslateWindowsError" id="7e635422-fa2a-4ad8-be6e-a241868871cd">
        <source>cnwdad1_TranslateWindowsError(pErrorCode:Integer):String;
// --------------------------------------------------------------------------------
// Created:		14 August 2002 by cnwdad1
//
// Purpose:		Translates a windows error code into its corresponding message.
//
// Parameters:	pErrorCode - The windows error code.
//
// Returns:		The error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;
	
begin
	if pErrorCode = 0 then
		errorMessage	:=	"The operation completed successfully.";
	elseif pErrorCode = 1 then
		errorMessage	:=	"Incorrect function.";
	elseif pErrorCode = 2 then
		errorMessage	:=	"The system cannot find the file specified.";
	elseif pErrorCode = 3 then
		errorMessage	:=	"The system cannot find the path specified.";
	elseif pErrorCode = 4 then
		errorMessage	:=	"The system cannot open the file.";
	elseif pErrorCode = 5 then
		errorMessage	:=	"Access is denied.";
	elseif pErrorCode = 6 then
		errorMessage	:=	"The handle is invalid.";
	elseif pErrorCode = 7 then
		errorMessage	:=	"The storage control blocks were destroyed.";
	elseif pErrorCode = 8 then
		errorMessage	:=	"Not enough storage is available to process this command.";
	elseif pErrorCode = 9 then
		errorMessage	:=	"The storage control block address is invalid.";
	elseif pErrorCode = 10 then
		errorMessage	:=	"The environment is incorrect.";
	elseif pErrorCode = 11 then
		errorMessage	:=	"An attempt was made to load a program with an incorrect format.";
	elseif pErrorCode = 12 then
		errorMessage	:=	"The access code is invalid.";
	elseif pErrorCode = 13 then
		errorMessage	:=	"The data is invalid.";
	elseif pErrorCode = 14 then
		errorMessage	:=	"Not enough storage is available to complete this operation.";
	elseif pErrorCode = 15 then
		errorMessage	:=	"The system cannot find the drive specified.";
	elseif pErrorCode = 16 then
		errorMessage	:=	"The directory cannot be removed.";
	elseif pErrorCode = 17 then
		errorMessage	:=	"The system cannot move the file to a different disk drive.";
	elseif pErrorCode = 18 then
		errorMessage	:=	"There are no more files.";
	elseif pErrorCode = 19 then
		errorMessage	:=	"The media is write protected.";
	elseif pErrorCode = 20 then
		errorMessage	:=	"The system cannot find the device specified.";
	elseif pErrorCode = 21 then
		errorMessage	:=	"The device is not ready.";
	elseif pErrorCode = 22 then
		errorMessage	:=	"The device does not recognize the command.";
	elseif pErrorCode = 23 then
		errorMessage	:=	"Data error (cyclic redundancy check).";
	elseif pErrorCode = 24 then
		errorMessage	:=	"The program issued a command but the command length is incorrect.";
	elseif pErrorCode = 25 then
		errorMessage	:=	"The drive cannot locate a specific area or track on the disk.";
	elseif pErrorCode = 26 then
		errorMessage	:=	"The specified disk or diskette cannot be accessed.";
	elseif pErrorCode = 27 then
		errorMessage	:=	"The drive cannot find the sector requested.";
	elseif pErrorCode = 28 then
		errorMessage	:=	"The printer is out of paper.";
	elseif pErrorCode = 29 then
		errorMessage	:=	"The system cannot write to the specified device.";
	elseif pErrorCode = 30 then
		errorMessage	:=	"The system cannot read from the specified device.";
	elseif pErrorCode = 31 then
		errorMessage	:=	"A device attached to the system is not functioning.";
	elseif pErrorCode = 32 then
		errorMessage	:=	"The process cannot access the file because it is being used by another process.";
	elseif pErrorCode = 33 then
		errorMessage	:=	"The process cannot access the file because another process has locked a portion of the file.";
	elseif pErrorCode = 34 then
		errorMessage	:=	"The wrong diskette is in the drive. Insert %2 (Volume Serial Number: %3) into drive %1.";
	elseif pErrorCode = 36 then
		errorMessage	:=	"Too many files opened for sharing.";
	elseif pErrorCode = 38 then
		errorMessage	:=	"Reached the end of the file.";
	elseif pErrorCode = 39 then
		errorMessage	:=	"The disk is full.";
	elseif pErrorCode = 50 then
		errorMessage	:=	"The request is not supported.";
	elseif pErrorCode = 51 then
		errorMessage	:=	"Windows cannot find the network path. Verify that the network path is correct and the destination computer is not busy or turned off. If Windows still cannot find the network path, contact your network administrator.";
	elseif pErrorCode = 52 then
		errorMessage	:=	"You were not connected because a duplicate name exists on the network. Go to System in the Control Panel to change the computer name and try again.";
	elseif pErrorCode = 53 then
		errorMessage	:=	"The network path was not found.";
	elseif pErrorCode = 54 then
		errorMessage	:=	"The network is busy.";
	elseif pErrorCode = 55 then
		errorMessage	:=	"The specified network resource or device is no longer available.";
	elseif pErrorCode = 56 then
		errorMessage	:=	"The network BIOS command limit has been reached.";
	elseif pErrorCode = 57 then
		errorMessage	:=	"A network adapter hardware error occurred.";
	elseif pErrorCode = 58 then
		errorMessage	:=	"The specified server cannot perform the requested operation.";
	elseif pErrorCode = 59 then
		errorMessage	:=	"An unexpected network error occurred.";
	elseif pErrorCode = 60 then
		errorMessage	:=	"The remote adapter is not compatible.";
	elseif pErrorCode = 61 then
		errorMessage	:=	"The printer queue is full.";
	elseif pErrorCode = 62 then
		errorMessage	:=	"Space to store the file waiting to be printed is not available on the server.";
	elseif pErrorCode = 63 then
		errorMessage	:=	"Your file waiting to be printed was deleted.";
	elseif pErrorCode = 64 then
		errorMessage	:=	"The specified network name is no longer available.";
	elseif pErrorCode = 65 then
		errorMessage	:=	"Network access is denied.";
	elseif pErrorCode = 66 then
		errorMessage	:=	"The network resource type is not correct.";
	elseif pErrorCode = 67 then
		errorMessage	:=	"The network name cannot be found.";
	elseif pErrorCode = 68 then
		errorMessage	:=	"The name limit for the local computer network adapter card was exceeded.";
	elseif pErrorCode = 69 then
		errorMessage	:=	"The network BIOS session limit was exceeded.";
	elseif pErrorCode = 70 then
		errorMessage	:=	"The remote server has been paused or is in the process of being started.";
	elseif pErrorCode = 71 then
		errorMessage	:=	"No more connections can be made to this remote computer at this time because there are already as many connections as the computer can accept.";
	elseif pErrorCode = 72 then
		errorMessage	:=	"The specified printer or disk device has been paused.";
	elseif pErrorCode = 80 then
		errorMessage	:=	"The file exists.";
	elseif pErrorCode = 82 then
		errorMessage	:=	"The directory or file cannot be created.";
	elseif pErrorCode = 83 then
