    <JadeMethod name="setTableCreditTotal" id="ae9ad115-9aa7-4d8e-94ee-9c6cf841f600">
        <source>setTableCreditTotal(_enableCheck : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jul 2019	jlgsl4	TFS 44274 - Cash Credit
17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/

vars
	table		   : CM_DataTable;
	row,
	rowTotalCredit : Integer;
begin
	table := self.tblCharges;
	
	if _enableCheck then
		row := 2;
		while row &lt;= table.rows do
					
			if table.accessCell(row, 3).text = "Credit Total" then
				rowTotalCredit := row;
				break;
			endif;
			row := row + 1;
			
		endwhile;
		if rowTotalCredit &gt; 1 then
			table.accessCell(rowTotalCredit, 6).text 	:=  self.creditTotal.roundedTo(2).asCurrencyJMT &amp; Space &amp; 'Cr';
		endif;
	else
		table.accessCell(table.rows, 6).text 			:=  self.creditPrevCreated.roundedTo(2).asCurrencyJMT &amp; Space &amp; 'Cr';
	endif;
	
	table.accessCell(table.rows, 6).fontUnderline       := true;
	
epilog

end;</source>
        <Parameter name="_enableCheck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="4fe1eab0-25f0-45dd-b201-bb2b06fac71b">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 Jul 2019	jlgsl4	TFS 44274 - JMT - Add Business Unit to Cash Credit
*/

vars

begin

	if not app.isCashOnlyEnabled then
		self.unloadForm;
		return;
	endif;
	
	self.mnuTableContext.visible	:= false;
	self.isSelectorCapable 			:= true;
	self.tblCharges.visible 		:= true;

	self.chkBoxSelected := true.cnEcGetTableCheckBoxValue;
	
	if self.myCurrentBank = null then 
		self.myCurrentBank := self.myTerminal.getDefaultCompanyBank(); 
	endif;
	
	self.caption := self.caption &amp; " " &amp; self.myCurrentBank.code; 
	self.setNavigatorHeading(self.caption);
	inheritMethod();
	
	// set current bank for receipt report
	if self.myAssistant = null then
		create self.myAssistant as INV_Assistant transient;
	    self.myAssistant.setMyTerminal(self.myTerminal);
	endif;
	
	
	self.setInitialControlValues();
	
	self.openWithSavedSettings();

	self.chkPrintRec.caption := "Print Credit";
	
	if self.myCashReceipt &lt;&gt; null then
		self.populateFromQuery();
	endif;
	

	self.doCmbBankBuild(); 
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblCharges_click" id="29c2f7fc-94d9-44a2-b4c8-f0e8572e25ef">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCharges_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/12/2012	cnwer1	Initial creation HAT 2189
23 Jul 2019	jlgsl4	TFS 44274 - Cash Credit
18 Sep 2019	cnwma1	Bug 46582: Cash Credit are not being accounted for correctly
*/

vars
	text : String;
	selected : Boolean;
	obj			: Object;
	invoiceLine	: CM_InvoiceLine;
	proformaDetail	: CM_ProformaDetails;
	cashPayment     : CM_CashPayment;
begin

	text:= table.getCellText(table.row, table.column);
	
	if table.accessCell(table.row, table.column).inputType = Table.InputType_CheckBox then
			selected := (text = "1");				
			
			obj := table.accessRow(table.row).itemObject;
			
			if obj &lt;&gt; null and obj.isKindOf(CM_CashPayment) then 
				cashPayment := obj.CM_CashPayment;
			endif;
			
			self.doRowSelectDeselect(selected, cashPayment);
	endif;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblCharges_contextMenu" id="641b6695-2690-4cbd-b260-493c2efc06f7">
