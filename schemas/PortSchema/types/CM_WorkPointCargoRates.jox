    <JadeMethod name="getDaysToComplete" id="1a100cb4-7379-4700-8804-559b19834e95">
        <source>getDaysToComplete( _obj : CM_Object; _gangs : Integer; _doRounding : Boolean ):Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/03/2018	jlgndl1	Initial creation	37447
21/11/2018	jlgdap1	TFS 42054 PEL1 Etmal Calculations are incorrect
*/

vars

	iter : Iterator;
	firstTi : CM_TrackedItem;
	ti : CM_TrackedItem;
	addQty : Boolean;
	addVol : Boolean;
	addWt : Boolean;
	qty : Integer;
	vol : Decimal[16,4];
	wt : Decimal[16,4];
	totalHrs : Decimal[16,2];
	hrsPerDay : Decimal[4,2];
	elapsedDays : Decimal[6,2];
	rem : Decimal[3,2];
	retValue : Decimal[6,2];
	
	voyJob : CM_VoyageJob;
	wodCargoRequest : CM_WodCargoRequest;
	wle : CM_WorkListEntry;
	density : Decimal [16,4];
	
	roundingHrs : Integer;
	term : CM_Terminal;
	hrsInt : Integer;
	daysDec : Decimal[4,2];
	

begin

	//14 Jun 2018	NDL	TFS 39167
	if _obj &lt;&gt; null and _obj.isKindOf(CM_VoyageJob) then
		voyJob := _obj.CM_VoyageJob;
	elseif _obj &lt;&gt; null and _obj.isKindOf(CM_WodCargoRequest) then
		wodCargoRequest := _obj.CM_WodCargoRequest;
	elseif _obj &lt;&gt; null and _obj.isKindOf( CM_WorkListEntry ) then	//03 Aug 2018	NDL	TFS 40048
		wle := _obj.CM_WorkListEntry;
	else
		return 0.0;
	endif;

	if voyJob &lt;&gt; null and not voyJob.allReceiveTrackedItems.isEmpty then
		iter := voyJob.allReceiveTrackedItems.createIterator;
	elseif voyJob &lt;&gt; null and not voyJob.allReleaseTrackeditems.isEmpty then
		iter := voyJob.allReleaseTrackeditems.createIterator;
	endif;
	
	if self.targetRatePHQuantity &gt; 0 then
		addQty := true;
	elseif self.targetRatePHVolume &gt; 0 then
		addVol := true;
	elseif self.targetRatePHWeight &gt; 0 then
		addWt := true;
	endif;
	
	// total up what we have to move
	if voyJob &lt;&gt; null then 
		while iter.next( ti ) do
			if addQty then
				qty := qty + ti.totalQuantity.max(1);
			elseif addVol then
				vol := vol + ti.totalVolume;
			elseif addWt then
				wt := wt + ti.totalWeight;
			endif;
		endwhile;
		
	elseif wodCargoRequest &lt;&gt; null then	//14 Jun 2018	NDL	TFS 39167
		qty := wodCargoRequest.totalQuantity.max(1);
		vol := wodCargoRequest.totalVolume;
		wt := wodCargoRequest.totalWeight;
		
	elseif wle &lt;&gt; null then	//03 Aug 2018	NDL	TFS 40048
		if addQty then
			qty := wle.quantity;
			if qty = 0 and wle.myTrackedItem &lt;&gt; null then
				qty := wle.myTrackedItem.totalQuantity.max(1);
			endif;
		elseif addVol or addWt then
			wt := wle.weight;
			if wt = 0 and wle.myTrackedItem &lt;&gt; null then
				wt := wle.myTrackedItem.totalWeight;
			endif;
			if addVol and wle.myTrackedItem &lt;&gt; null then
				density := wle.myTrackedItem.getDensity();
				vol := ( wt / density );
			endif;
		endif;
		
	endif;
	
	if qty &lt;= 0 and vol &lt;= 0 and wt &lt;= 0 then
		return 0.0;
	endif;
	
	//divide up to get how many hrs
	if addQty then
		totalHrs := ( qty / self.targetRatePHQuantity ).Decimal.roundedTo(2);
	elseif addVol then
		totalHrs := ( vol / self.targetRatePHVolume ).Decimal.roundedTo(2);
	elseif addWt then
		totalHrs := ( wt / self.targetRatePHWeight ).Decimal.roundedTo(2);
	endif;
	
	if totalHrs &lt;= 0 then
		return 0.0;
	endif;
	
	//03 Aug 2018	NDL	TFS 40048
	if _gangs &gt; 1 then
		totalHrs := totalHrs / _gangs;
	endif;
	//epr TFS 41310 23/10/18 
	//if self.dailyHoursWorkable &gt; 0 and totalHrs &gt; self.dailyHoursWorkable then	// TFS 42054
	if self.dailyHoursWorkable &gt; 0 then												// TFS 42054
		hrsPerDay := self.dailyHoursWorkable;
	else
		hrsPerDay := 24.0;
	endif;
	
	elapsedDays := ( totalHrs / hrsPerDay ).Decimal.roundedTo(2);
	
/*	// round up to the nearest 1/4 day
	retValue := elapsedDays.Integer;
	rem := elapsedDays mod 1;
	if rem &gt; 0 then
		if rem &gt; .75 then
			retValue := retValue + 1;
		elseif rem &gt; .5 then
			retValue := retValue + .75;
		elseif rem &gt; .25 then
			retValue := retValue + .5;
		else
			retValue := retValue + .25;
		endif;
	endif; */
/*	
	//14 Aug 2018	NDL	TFS 40267 - make the rounding softer values
	term := self.myWorkPoint.myTerminal;
	if term &lt;&gt; null then
		roundingHrs := term.getConfig(TotDaysReqRoundedToHours).Integer; 
		// can be one of 1,2,3,4,6,8 or 12
	endif;
	
	if roundingHrs = 0 then
		retValue := elapsedDays;
	else
		retValue := elapsedDays.Integer;
		rem := elapsedDays mod 1;
		
		if rem &gt; 0 then
			hrsInt := 24;
			while true do
				daysDec := (hrsInt / 24).Decimal; // The percentage of a day to round up
				hrsInt := hrsInt - roundingHrs; // the lowest hours we round up from.
				if ( rem * 24 ) &gt; hrsInt then
					retValue := retValue + daysDec;
					break;
				endif;
				if hrsInt &lt;= 0 then
					//should never get to here.
					break;
				endif;
			endwhile;
		endif;
	endif;
*/	
	if not _doRounding then	//20 Aug 2018	NDL - Pelindo changes their minds again.....
		// Now decided no rounding at individual line level....
		retValue := elapsedDays;
	else
		term := self.myWorkPoint.myTerminal;
		retValue := term.applyRoundingToValue( elapsedDays );
	endif;
	
	return retValue;

epilog

	delete iter;

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_gangs" type="Integer"/>
        <Parameter name="_doRounding" type="Boolean"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="8b021e0a-1ae4-4a9e-b03c-a912dfb9e825">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2018	jlgndl1	Initial creation

*/

vars

begin

	if _attrName = ETRow_CargoType then
		if self.myCargoType &lt;&gt; null then
			return  self.myCargoType.description;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_DailyHoursWorkable then
		return dailyHoursWorkable.asStringJMT;
			
	elseif _attrName = ETRow_JobType then
		return getJobTypeStr;
		
				
	elseif _attrName = ETRow_Product then
		if self.myProduct &lt;&gt; null then
			return  self.myProduct.description;
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_TargetRate then
		return self.getTargetRateStr;
	
	elseif _attrName = ETRow_TransferType then
		return getTransferTypeStr;
				
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJobTypeStr" id="b9c4e8f8-37fd-443f-b7b0-92cc3896dd17">
        <source>getJobTypeStr():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2018	jlgndl1	Initial creation	TFS 37437

*/

vars

begin

	if self.jobType = -1 then
		return app.getErrorString(Default);
		
	elseif self.jobType = JOB_TYPE_DISCHARGE then
		return app.getErrorString(SHP_Discharge);
		
	elseif self.jobType = JOB_TYPE_LOAD then
		return app.getErrorString(SHP_Load);
		
	elseif self.jobType = JOB_TYPE_SOB then
		return app.getErrorString(SHP_Shift_On_Board);
		
	else
		return app.getErrorString(Unknown);
		
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTargetRateStr" id="d1287315-d3b2-4552-a03c-21f8aff40c0a">
        <source>getTargetRateStr():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2018	jlgndl1	Initial creation	TFS 37437

*/

vars

	measurementType : CM_MeasurementType;
	measurementTypeString : String;

begin

	if self.targetRatePHQuantity &gt; 0 then
		return self.targetRatePHQuantity.asStringJMT;
		
	elseif self.targetRatePHVolume &gt; 0 then
		if self.myProduct &lt;&gt; null then
			measurementType := self.myProduct.getDefaultMeasurementForType(Type_Volume);
		elseif self.myCargoType &lt;&gt; null then
			measurementType := self.myCargoType.getDefaultMeasurementForType(Type_Volume);
		endif;
		if measurementType &lt;&gt; null then
			measurementTypeString := measurementType.shortName;
		endif;
		
		if measurementType = null then
			return self.targetRatePHVolume.asStringJMT();	
		else
			return app.convertMeasurementForDisplay(measurementTypeString, self.targetRatePHVolume) &amp; " " &amp; measurementTypeString;
		endif;
		
	elseif self.targetRatePHWeight &gt; 0 then
		if self.myProduct &lt;&gt; null then
			measurementType := self.myProduct.getDefaultMeasurementForType(Type_Weight);
		elseif self.myCargoType &lt;&gt; null then
			measurementType := self.myCargoType.getDefaultMeasurementForType(Type_Weight);
		endif;
		if measurementType &lt;&gt; null then
			measurementTypeString := measurementType.shortName;
		endif;
		
		if measurementType = null then
			return self.targetRatePHWeight.asStringJMT();	
		else
			return app.convertMeasurementForDisplay(measurementTypeString, self.targetRatePHWeight) &amp; " " &amp; measurementTypeString;
		endif;
		
	else
		return app.getErrorString(Unknown);
		
	endif;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTransferTypeStr" id="66ed3417-c20a-443b-8b65-d02cc8f5685a">
        <source>getTransferTypeStr():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2018	jlgndl1	Initial creation	TFS 37437

*/

vars

	voyJobTfrType : CM_VoyageJobTransferType;

begin

	
	voyJobTfrType := app.myRoot.allVoyageJobTransferTypes.getAtKey( self.transferType );
	if voyJobTfrType &lt;&gt; null then
		return voyJobTfrType.description;
		
	else
		return app.getErrorString(Unknown);
		
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
