    <JadeMethod name="doClearCtrlShftG" id="e15a92d6-fc72-4672-a660-1f7a7430f9b5">
        <updating/>
        <source>doClearCtrlShftG() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sept 2024	navab1	CR 66065 : MTN - Generate quick list of selected column data

*/

vars
	str       : String;

	col, option, timeRemaining : Integer;
	strs : StringArray;
	cols : IntegerArray;
begin

	create cols transient;
	create strs transient;

	if self.helpKeyword &lt;&gt; null then
		self.helpKeyword.getTokensForDelimiter("|", strs);
		
		foreach str in strs do
			col := str.Integer;
			if col &gt; 0 then
				cols.add(col);
			endif;
		endforeach;
	else
		cols.add(self.column);
	endif;

	self.helpKeyword := "";
	if self.getTimerStatus(self.Timer_CTRL_SHFT_G, option, timeRemaining) then
		self.endTimer(self.Timer_CTRL_SHFT_G);
	endif;
	
	foreach col in cols do
		self.accessCell(1, col).fontBold := false;
	endforeach;

	app.copyStringToClipboard("");
	
epilog
	delete cols;
	delete strs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doGenerateMultiSelectionColist" id="903d24d1-3282-4b5f-91a4-c6b4a81b2c58">
        <updating/>
        <source>doGenerateMultiSelectionColist() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sept 2024	navab1	CR 66065 : MTN - Generate quick list of selected column data

*/

vars
	messageLogForm : CMUI_MessageLogForm;
	str, 		   
	type, 		   
	dtStr,          
	caption , itemStr       : String;
	tmpUser	: CM_User;
	col, row, option, timeRemaining : Integer;
	strs : StringArray;
	cols : IntegerArray;
begin

	create cols transient;
	create strs transient;

	type := "Ctrl G Plus - ";
	if self.helpKeyword &lt;&gt; null then
		self.helpKeyword.getTokensForDelimiter("|", strs);
		
		foreach str in strs do
			col := str.Integer;
			if col &gt; 0 then
				cols.add(col);
			endif;
		endforeach;
		if strs.size &gt; 1 then
			type := "Ctrl G Plus Plus - ";
		endif;
	else
		cols.add(self.column);
	endif;

	self.doClearCtrlShftG();
	
	foreach col in cols do
		self.accessCell(1, col).fontBold := false;
	endforeach;

	foreach row in self.fixedRows to self.rows do
		foreach col in cols do
	
			if col &lt; 1 or col &gt; self.columns then
				continue;
			endif;

			itemStr := self.accessCell(row,col).text;
			
			str := str &amp; itemStr  &amp; Tab;
		endforeach;
		str := str &amp; CrLf;
	endforeach;
	
	if app.class.name = "DevSchema" then
		app.copyStringToClipboard(str);
		write str;
		return;
	endif;
		
	create messageLogForm transient;
	if str &lt;&gt; null then
		dtStr   := app.actualTimeServer.asStringJMT;
		caption := type &amp;app.getErrorString(Generated_list) &amp; Space  &amp; dtStr;
		create messageLogForm transient;	
		
		messageLogForm.width 			  := 800;
		messageLogForm.caption 			  := caption ;
		messageLogForm.myXMLString 		  := str;		
		messageLogForm.isXMLResponse 	  := false;		
		messageLogForm.centreOverParent(1);
		messageLogForm.statusLine.zOrder(1);
		messageLogForm.statusLine.caption := app.getErrorString(Total) &amp; Space  &amp; self.allSelectedObjects.size.String;
		
		messageLogForm.show;						
		
		app.copyStringToClipboard(str);
		
	endif;
	
epilog
	delete cols;
	delete strs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doGenerateMultiSelectionList" id="db731a6b-d7c9-45e4-8baa-7e6248c6b05f">
        <source>doGenerateMultiSelectionList();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 April 2021	navma1	ChangeRequest 51055: MTN - Generate quick list of selected items IDs

*/

vars
	messageLogForm : CMUI_MessageLogForm;
	obj 		   : Object;
	str, 		   
	type, 		   
	dtStr,          
	attrName,       
	caption        : String;

begin
	
	if self.allSelectedObjects.isEmpty then
		return;
	endif;
	
	obj := self.allSelectedObjects.first;
	
	self.getGeneratedListType(obj,type,attrName);
	
	if type = null then
		// Not the right object to be listed
		return;
	endif;
	
	str := self.allSelectedObjects.listString(CrLf,attrName);
	
	
	create messageLogForm transient;
	if str &lt;&gt; null then
		dtStr   := app.actualTimeServer.asStringJMT;
		caption := type &amp; Space &amp;app.getErrorString(Generated_list) &amp; Space  &amp; dtStr;
		create messageLogForm transient;			
		
		messageLogForm.width 			  := 400;
		messageLogForm.caption 			  := caption ;
		messageLogForm.myXMLString 		  := str;		
		messageLogForm.isXMLResponse 	  := false;		
		messageLogForm.centreOverParent(1);
		messageLogForm.statusLine.zOrder(1);
		messageLogForm.statusLine.caption := app.getErrorString(Total) &amp; Space  &amp; self.allSelectedObjects.size.String;
		messageLogForm.show;						
		
		
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPositionCalendar" id="95f48246-80b1-4fc6-9075-e654f448a32b">
        <updating/>
        <source>doPositionCalendar(pCalendarFormObj:CMUI_CalendarSelectForm io; pCellObj:JadeTableCell) updating, protected;
// --------------------------------------------------------------------------------
// Created:		14 February 2003 by cnwdad1
//
// Purpose:		Positions the pop-up calendar form next to the cell of the calling 
//				table control.
//
// Parameters:	pCalendarFormObj - The pop-up calendar form.
//				pCellObj - The cell for which the Calendar was invoked.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlObj			: Control;
	parentFormObj		: Form;
	screenTop			: Real;
	screenLeft			: Real;
	screenHeight		: Real;
	screenWidth			: Real;
	posControlLeft		: Real;
	posControlTop		: Real;
	posFormLeft			: Real;
	posFormTop			: Real;
	
begin
	// Starting with self, well work up the tree of the control's parents.
	
	controlObj	:=	self;
	
	while not controlObj.parent.isKindOf(Form) do
		controlObj	:=	controlObj.parent.Control;
	endwhile;
	
	// Get the screen and date mask control dimensions.
	
	parentFormObj	:=	controlObj.parent.Form;
	parentFormObj.getDeskTopWorkArea(screenLeft, screenTop, screenWidth, screenHeight);
	posControlLeft	:=	self.positionLeft;
	posControlTop	:=	self.positionTop;
	self.windowToScreen(posControlLeft, posControlTop);
	
	// We'll start by placing the calendar form at the right if the table cell.
	
	posFormLeft	:=	posControlLeft + pCellObj.getCellWidth();
	posFormTop	:=	posControlTop;
	
	// Now work out where to place the calendar form.
	
	if (posFormLeft + pCalendarFormObj.width) &gt; screenWidth then
		// The right-hand edge of the form is outside the screen area, so try putting
		// the calendar form on the left-hand side of the table cell.
		posFormLeft	:=	posControlLeft - pCalendarFormObj.width;
		
		if posFormLeft &lt; screenLeft then
			// The left-hand edge of the form is outside the screen area, so try putting
			// the calendar form immediately beneath the table cell.
			posFormLeft	:=	posControlLeft;
			posFormTop	:=	posControlTop + self.accessRow(pCellObj.row).height;
		endif;
	endif;
	
	if (posFormTop + pCalendarFormObj.height) &gt; screenHeight then
		// The bottom edge of the form is outside the screen area, so try putting
		// the calendar form above the table cell.
		posFormTop	:=	(posControlTop + self.accessRow(pCellObj.row).height) - pCalendarFormObj.height;
		
		if posFormTop &lt; screenTop then
			// The top edge of the form is outside the screen area, so we'll reset the
			// calendar form positions to zero and let the form center itself when it loads.
			posFormLeft	:=	0;
			posFormTop	:=	0;
		endif;
	endif;
	
	// Set the coordinates of the pop-up calendar form.
	
	pCalendarFormObj.setPosition(posFormLeft.Integer, posFormTop.Integer);
end;</source>
        <access>protected</access>
        <Parameter name="pCalendarFormObj" type="CMUI_CalendarSelectForm" usage="io"/>
        <Parameter name="pCellObj" type="JadeTableCell"/>
    </JadeMethod>
    <JadeMethod name="doPositionCalendarTime" id="edc94e62-cd14-43f6-ae0f-9230317db9b0">
        <updating/>
        <source>doPositionCalendarTime(pCalendarFormObj:CMUI_CalendarTimeSelectForm io; pCellObj:JadeTableCell) updating, protected;
// --------------------------------------------------------------------------------
// Created:		31 August 2023 by navra1
//
// Purpose:		Positions the pop-up calendar time form next to the cell of the calling 
//				table control.
//
// Parameters:	pCalendarFormObj - The pop-up calendar form.
//				pCellObj - The cell for which the Calendar was invoked.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlObj			: Control;
	parentFormObj		: Form;
	screenTop			: Real;
	screenLeft			: Real;
	screenHeight		: Real;
	screenWidth			: Real;
	posControlLeft		: Real;
	posControlTop		: Real;
	posFormLeft			: Real;
	posFormTop			: Real;
	
begin
	// Starting with self, well work up the tree of the control's parents.
	
	controlObj	:=	self;
	
	while not controlObj.parent.isKindOf(Form) do
		controlObj	:=	controlObj.parent.Control;
	endwhile;
	
	// Get the screen and date mask control dimensions.
	
	parentFormObj	:=	controlObj.parent.Form;
	parentFormObj.getDeskTopWorkArea(screenLeft, screenTop, screenWidth, screenHeight);
	posControlLeft	:=	self.positionLeft;
	posControlTop	:=	self.positionTop;
	self.windowToScreen(posControlLeft, posControlTop);
	
	// We'll start by placing the calendar form at the right if the table cell.
	
	posFormLeft	:=	posControlLeft + pCellObj.getCellWidth();
	posFormTop	:=	posControlTop;
	
	// Now work out where to place the calendar form.
	
	if (posFormLeft + pCalendarFormObj.width) &gt; screenWidth then
		// The right-hand edge of the form is outside the screen area, so try putting
		// the calendar form on the left-hand side of the table cell.
		posFormLeft	:=	posControlLeft - pCalendarFormObj.width;
		
		if posFormLeft &lt; screenLeft then
			// The left-hand edge of the form is outside the screen area, so try putting
			// the calendar form immediately beneath the table cell.
			posFormLeft	:=	posControlLeft;
			posFormTop	:=	posControlTop + self.accessRow(pCellObj.row).height;
		endif;
	endif;
	
	if (posFormTop + pCalendarFormObj.height) &gt; screenHeight then
		// The bottom edge of the form is outside the screen area, so try putting
		// the calendar form above the table cell.
		posFormTop	:=	(posControlTop + self.accessRow(pCellObj.row).height) - pCalendarFormObj.height;
		
		if posFormTop &lt; screenTop then
			// The top edge of the form is outside the screen area, so we'll reset the
			// calendar form positions to zero and let the form center itself when it loads.
			posFormLeft	:=	0;
			posFormTop	:=	0;
		endif;
	endif;
	
	// Set the coordinates of the pop-up calendar form.
	
	pCalendarFormObj.setPosition(posFormLeft.Integer, posFormTop.Integer);
end;</source>
        <access>protected</access>
        <Parameter name="pCalendarFormObj" type="CMUI_CalendarTimeSelectForm" usage="io"/>
        <Parameter name="pCellObj" type="JadeTableCell"/>
    </JadeMethod>
    <JadeMethod name="doPrintTable" id="9e3e11f8-0d87-47ad-a3e8-d0774970e1cb">
        <updating/>
        <source>doPrintTable(_tblPrintParams: CMIF_PrintTableParams input) updating;

// ############## PLEASE USE CM_BASEFORM::doPrintOutTable










// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
/*

Need to fix this to use CM_GenericTablePrint and have proper heading, etc
(refer to doPrintTable2).  Also need to handle when called from a modal
form so will also show the print-preview form modally.

*/
constants
	WidthPad	: Real = 2;
	
vars
	lRow, lCol			: Integer;
//	idx,
	lLeft, hRow			: Integer;
	lLine 				: String;
	lControl 			: Control;
	lNow 				: TimeStamp;
	lFontSize			: Real;
//	lScale2, 
//	lWidth,	lWidth2		: Real;
	lScale 				: Decimal[9,6];
	pxyJadeReport		: JadeReport;
	closePr, newRpt,
	smallFont,
	useTblFont,
	useTblColours		: Boolean;
	prntFrame			: Frame;
	prntLabel			: Label;
	currentCell			: JadeTableCell;
	localParams			: CMIF_PrintTableParams;
	
begin
	localParams		:= _tblPrintParams;
	closePr			:= localParams.closePrinter;
	newRpt			:= localParams.newReport;
	smallFont		:= localParams.useSmallFont;
	useTblFont		:= localParams.useTableFontAttributes;
	useTblColours	:= localParams.useTableColours;
	prntFrame		:= localParams.printFrame;
	prntLabel		:= localParams.printLabel;
	pxyJadeReport	:= localParams.jadeReport;
	lNow			:= self.systemToLocalTime(app.actualTimeServer());	// 10/6/16 cnwmp6 TFS 488 - Multi timezone support
	
	if (not closePr) and pxyJadeReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "JadeReport transient required if closePrinter is false");
		return;
	endif;

	// Set print preview to false to force to object rather than printer output.
	if pxyJadeReport = null then
		create pxyJadeReport transient;
	endif;
	
	if newRpt then
		app.printer.printPreview := false;
		app.printer.setReport(pxyJadeReport);
	endif;

	if app.printer.orientation = Print_Landscape then
		prntFrame.width := 1100;
	else
		prntFrame.width := 690;
	endif;
	
	if smallFont then
		//prntFrame.height := 12;
		prntFrame.height := 14;//par 13709
	else
		prntFrame.height := 25;
	endif;
	
	prntFrame.top := 0;
	prntFrame.left := 10;
	prntFrame.visible := true;
	prntFrame.backColor := White;
	prntFrame.boundaryWidth := 0;
	prntFrame.bevelInnerWidth := 0;
	prntFrame.bevelOuterWidth := 0;

	prntLabel.width := prntFrame.width;
	prntLabel.top := 0;
	prntLabel.left := 0;
	prntLabel.height := prntFrame.height;
	prntLabel.visible := true;
	prntLabel.caption := lNow.String &amp; " " &amp; _tblPrintParams.title &amp; " " &amp; app.getMyUserCode;
	prntLabel.fontBold := true;
	prntLabel.backColor := White;
	prntLabel.foreColor := Black;
	prntLabel.fontName := "Ariel"; //self.fontName;
	
	if smallFont then
		prntLabel.fontSize := 7;
	else
		prntLabel.fontSize := 10;
	endif;
	
	app.printer.print(prntFrame);
	prntLabel.caption := null;
	app.printer.print(prntFrame);
	prntLabel.visible := false;

	lLeft := 0;
	
	foreach lCol in 1 to self.columns do
		lLeft := lLeft + self.accessColumn(lCol).width;
	endforeach;
	
	if lLeft &lt;= prntFrame.width then
		lFontSize := self.fontSize;
		lScale := 1;
	else
		lFontSize := self.fontSize;
		lScale := 1;
	endif;
	
	lLeft := 0;
	
	foreach lCol in 1 to self.columns do
		// ignore any hidden columns
		if not self.accessColumn(lCol).visible then
			continue;
		endif;
		
		lControl :=  prntLabel.getControl(lCol);
		
		if lControl = null then
			lControl := prntLabel.loadControl(lCol);
		endif;
		
		if localParams.colWidths.isEmpty or lCol &gt; localParams.colWidths.size then
			lControl.width := (self.accessColumn(lCol).width + WidthPad) * lScale;
		else
			lControl.width := localParams.colWidths[lCol];
		endif;
		
		lControl.left := lLeft;
		lLeft := lLeft + lControl.width.Integer;
		lControl.height := prntLabel.height;
		lControl.top := 1;
		lControl.fontName := self.fontName;
		lControl.fontSize := lFontSize * lScale;
		lControl.visible := true;
		lControl.enabled := true;
		lControl.backColor := White;
		lControl.parent := prntLabel.parent;
		lControl.foreColor := Black;
	endforeach;

	foreach lRow in 1 to self.rows do
		// ignore any hidden rows
		if not self.accessRow(lRow).visible then
			continue;
		endif;
		
		lLine := null;

		// Print Header, after first page
		if app.printer.getPrintPosition + prntFrame.height &gt;= app.printer.pageHeight 
		and self.fixedRows &lt;&gt; 0
		then
			hRow := 1;
			
			foreach lCol in 1 to self.columns do
				// ignore any hidden columns
				if not self.accessColumn(lCol).visible then
					continue;
				endif;
				
				lControl := prntLabel.getControl(lCol);
				lControl.Label.caption := self.accessCell(hRow,lCol).text;
				lControl.fontBold := true;
			endforeach;
			
			app.printer.print(prntFrame);
		endif;
		
		lLine := null;

		foreach lCol in 1 to self.columns do
			// ignore any hidden columns
			if not self.accessColumn(lCol).visible then
				continue;
			endif;
			
			lControl := prntLabel.getControl(lCol);

			// ####################
			// Print Yes No for Check Box
			currentCell := self.accessCell(lRow,lCol);
			
			if ( currentCell.cellControl &lt;&gt; null and currentCell.cellControl.isKindOf(CheckBox))
			or currentCell.inputType = Table.InputType_CheckBox
			then
//				if currentCell.text = "0" then
				if currentCell.text.Integer = 0 then // PAR 8930
					lControl.Label.caption := "  No";
				else
					lControl.Label.caption := "  Yes";
				endif;
			else
				lControl.Label.caption := "  " &amp; currentCell.text;
			endif;
			
			if lRow &lt;= self.fixedRows then
				lControl.fontBold := true;
				continue;
			else
				lControl.fontBold := false;
			endif;
			
			if useTblFont then
				lControl.fontBold := currentCell.fontBold;
				lControl.fontItalic := currentCell.fontItalic;
				lControl.fontName := currentCell.fontName;
				lControl.fontSize := currentCell.fontSize;
				lControl.fontStrikethru := currentCell.fontStrikethru;
				lControl.fontUnderline := currentCell.fontUnderline;
				lControl.foreColor := currentCell.foreColor;
			endif;
			
			if useTblColours then
				lControl.backColor := currentCell.backColor;
			endif;
		endforeach;
		
		app.printer.print(prntFrame);
	endforeach;

	if closePr then
		app.printer.close();
		app.printPreview(pxyJadeReport, true);
		_tblPrintParams.jadeReport := null;		// null this out so the calling program does not delete then pxy we are viewing
	endif;
epilog
	foreach lCol in 1 to self.columns do
		lControl := prntLabel.getControl(lCol);
		
		if lControl &lt;&gt; null then
			delete lControl;
		endif;
	endforeach;

	prntFrame.visible	:=	false;
	prntLabel.visible	:=	false;
	
	if closePr then
		app.printer.close();
	endif;
	
//	delete pxyJadeReport (handled in printPreview above);
end;</source>
        <Parameter name="_tblPrintParams" type="CMIF_PrintTableParams" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doPrintTable2" id="a56c15b5-66b9-4568-9d04-941b5e2b6d49">
        <source>doPrintTable2(_message : String; _header : String; _title : String);

// ############## PLEASE USE CM_BASEFORM::doPrintOutTable




















// ---------------------------------------------------------------------------
// Created:     13 March 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	gtptmpTable:        CM_GenericTablePrint;
	rowString:           String;
	pd:                  CMS_Progress;
	doPrint:             Boolean;
	bShift:              Boolean;
	state:               Integer;
	now:                 TimeStamp;
	hdrStr, dateStr				: String;
	tmpTable : Table;
	tmpJadeReport  : JadeReport;
begin
	tmpTable := self;
	now := self.systemToLocalTime(app.actualTimeServer());	// 10/6/16 cnwmp6 TFS 488 - Multi timezone support
	
	app.mousePointer := MP_HOURGLASS;
	app.printer.suppressDialog := true;

	create gtptmpTable transient;
	create pd transient;
	pd.setBackground(self.backColor);
	pd.show;
	pd.raiseExceptionOnAbort := false;
	
	pd.setAction(_message);
	hdrStr := _header; 
	app.printer.setMargins(Print_Landscape,0,0,10,10);

	pd.progress.partsInJob := tmpTable.rows - 1;

	// setup header information
	gtptmpTable.frHeader.width := app.printer.pageWidth;
	gtptmpTable.setHeaders(hdrStr, null);
	create tmpJadeReport transient;
	tmpJadeReport.description := _title[1:tmpJadeReport.description.length];	// Par13724
	app.printer.setReport(tmpJadeReport);

	app.printer.setHeader(gtptmpTable.frHeader);

	// set footer
	gtptmpTable.frFooter.width := app.printer.pageWidth;
	gtptmpTable.lblTheUser.caption := app.getMyUserCode;
	gtptmpTable.lblTheDatePrinted.caption := now.String;
	app.printer.setFooter(gtptmpTable.frFooter);

	gtptmpTable.printTable(tmpTable, true, pd);

	//app.printer.print(gtptmpTable.frTable);

	if pd.aborted then
		app.printer.abort;
		return;
	endif;
	pd.unloadForm;

epilog
	app.printer.close;
	app.printPreview(tmpJadeReport, true);
	delete pd;
	delete gtptmpTable;
	app.mousePointer := MP_DEFAULT;


end;</source>
        <Parameter name="_message" type="String"/>
        <Parameter name="_header" type="String"/>
        <Parameter name="_title" type="String"/>
    </JadeMethod>
    <JadeMethod name="findObjectInRow" id="8b4d6d7a-8eb8-4017-9292-47d910cad910">
        <updating/>
        <source>findObjectInRow(_obj : Object; _rowIdx : Integer io) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     15 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx,
	startPos,
	numRows		: Integer;
	found		: Boolean;
	
begin
	if _obj = null then
		return found;
	endif;
	
	numRows := self.rows;
	if _rowIdx &gt; numRows then
		return found;
	endif;
	startPos := (self.fixedRows + 1).max(_rowIdx);
	if startPos &gt; numRows then
		return found;
	endif;	 
	
	foreach idx in startPos to numRows do
		if self.accessRow(idx).itemObject = _obj then
			found 	:= true;
			_rowIdx := idx;
			break;
		endif;
	endforeach;

epilog
	return found;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findStringInColumn" id="598e0ded-faaf-46bb-96fe-cadce9f87017">
        <updating/>
        <source>findStringInColumn(_str : String; _colIdx: Integer; _rowIdx : Integer io) : Boolean updating;
// Find an exact match of the string in the text of all the non fixed rows
vars
	idx,
	startPos,
	numRows		: Integer;
	found		: Boolean;
	
begin
	if _str = null then
		return false;
	endif;
	
	numRows := self.rows;
	if _rowIdx &gt; numRows then
		return false;
	endif;
	startPos := (self.fixedRows + 1).max(_rowIdx);
	if startPos &gt; numRows then
		return false;
	endif;	 
	
	foreach idx in startPos to numRows do
		if self.accessCell(idx, _colIdx).text = _str then
			found 	:= true;
			_rowIdx := idx;
			break;
		endif;
	endforeach;

epilog
	return found;
end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_colIdx" type="Integer"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="fitTextToCell" id="85e3d431-bcf4-4c70-95c5-1be1eb38db15">
        <source>fitTextToCell(pInputText : String; pOutputText : String output; pCellWidth : Integer; pCellHeight : Integer output);
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     Take the input text string, and insert Cr/Lf characters as necessary to fit the string in the 
//				cell width passed in.
//
// Parameters:  None
//
// Returns:     pOutputText updated with the string to place in the cell, and pCellHeight updated with the minimum
//				cell height required to display all the multi-line text
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	NewLine = CrLf;
	Space = ' ';

vars
 	currentPos, tempPos, i, j : Integer;
 	tempString, line, tempLine, token : String;
	removeNewLines : Boolean;
begin

	// Copy input string, and strip out any new line characters and tabs
	tempString := pInputText;
	
	 // ### JIRA 34988 29MAY2025 NAVAB1
	removeNewLines := true;
	if tempString.pos(Cash_cargo_not_paid.String, 1) &gt; 0 then
		removeNewLines:= false;
	endif;
	
	if removeNewLines then
		tempString := tempString.replaceString(NewLine, Space);
	endif;
 	tempString := tempString.replaceString(Tab, Space);
 	tempString := tempString.eliminateContiguousSpaces();

	// If the resulting string will fit in the cell, then return
	if self.getTextExtent(tempString) &lt; pCellWidth then
		pOutputText := tempString;
		return;
	endif;

	// Build up a multi-line string 
	currentPos := 1;
	pOutputText := null;
	line := null;
	while currentPos &lt;= tempString.length do
		// First get the next token, not including its trailing space
		tempPos := tempString.pos(Space, currentPos);
		if tempPos = 0 then
			tempPos := tempString.length + 1;
		endif;
		token := tempString[currentPos:tempPos - currentPos];

		// now check if the current line will still fit in the cell
		if line = null then
			tempLine := token;
		else
			tempLine := line &amp; Space &amp; token;
		endif;

		// if the line so far fits in the cell, then move currentPos past this token
		if self.getTextExtent(tempLine) &lt; pCellWidth then
			line := tempLine;
			currentPos := tempPos + 1;

    	else
    		// current token puts current line over boundary
			if line &lt;&gt; null then
				if pOutputText = null then
					pOutputText := line;
				else
					pOutputText := pOutputText &amp; NewLine &amp; line;
				endif;
				line := null;
			else
				// current token is too big to fit in a cell, so we need to break
				//  it up
  				line := token;

				currentPos := tempPos + 1;
         	endif;
		endif;

  	endwhile;

	if line &lt;&gt; null then
		if pOutputText = null then
			pOutputText := line;
		else
			pOutputText := pOutputText &amp; NewLine &amp; line;
		endif;
	endif;

epilog	
	pCellHeight := self.getTextHeight(pOutputText) + 5;


end;</source>
        <Parameter name="pInputText" type="String"/>
        <Parameter name="pOutputText" type="String" usage="output"/>
        <Parameter name="pCellWidth" type="Integer"/>
        <Parameter name="pCellHeight" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="formatRow" id="ad2ae90d-fb64-4cd3-b49d-792cf95de056">
        <updating/>
        <source>formatRow(rowIndex: Integer) updating;
//15 June 2009	cnwdw1	
// PAR 19910
vars
	cell: JadeTableCell;
	row: JadeTableRow;
	heading, value: String;
	count, rowHeight: Integer;
begin
	heading := self.accessCell(rowIndex, CM_EntryTable.ColumnHeading).text;
	value := self.accessCell(rowIndex, CM_EntryTable.ColumnValue).text;
	if self.showGroups then
		if heading.length &gt; 0 and heading[1] = "$" then
			self.gridLines := false;
			self.defaultRowHeight := 18;
			cell := self.accessCell(rowIndex, CM_EntryTable.ColumnHeading);
			cell.alignment := Table.Alignment_Left;
			cell.text := heading[2:end];
			cell.backColor := LightGray;
			cell := self.accessCell(rowIndex, CM_EntryTable.ColumnValue);
			cell.backColor := LightGray;
			cell.fontName := "Webdings";
			cell.alignment := Table.Alignment_Right;
			cell.fontSize := 12;
			cell.text := "5";
		else
			cell := self.accessCell(rowIndex, CM_EntryTable.ColumnHeading);
			cell.alignment := Table.Alignment_Right;
			cell.text := heading&amp;":";
			cell.backColor := White;
		endif;
	endif;
	//expand row if text has carrage returns
	count := value.countOccurrences(Cr);
	if count &gt; 0 then
		rowHeight:= self.accessRow(rowIndex).height;
		self.accessedRow.height := rowHeight * (count+1);
	endif;

end;</source>
        <Parameter name="rowIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllCellObjects" id="a290e5d3-4350-4ed2-ab1d-dd25733b2c87">
        <updating/>
        <source>getAllCellObjects(_objSet : Set input) updating;
// ---------------------------------------------------------------------------
// Created:		February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	numRows,
	numCols,
	i, j	: Integer;
	obj		: Object;
begin

	numRows := self.rows;
	numCols := self.columns;

	foreach i in 1 to numRows do
		foreach j in 1 to numCols do
			self.accessCell(i,j);
			obj := self.accessedCell.itemObject;
			if obj &lt;&gt; null then
				_objSet.add(obj);
			endif;
		endforeach;
	endforeach;
				
end;</source>
        <Parameter name="_objSet" type="Set" usage="input"/>
    </JadeMethod>
