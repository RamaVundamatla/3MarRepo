    <JadeMethod name="getDataEntities" id="1c8500ba-5edc-4b6e-85e5-74efc889a564">
        <updating/>
        <source>getDataEntities(): String updating;
/**
 * Lists all exportable/importable classes grouped by permission category
 *
 * REST Endpoint: GET /dataEntities?internalAPI=true
 * Security: Requires valid JWT access token
 * Date 		Who  Reason 
 * 6 Jan 2026 naviv1 Initial creation - MTN-36802 - JADE Rest API - Export Import Data Entities List API Endpoint
 */
constants
	ENTITIES = "entities";
	UID = "Uid";
	VALUE = "Value";
vars
    passport: CM_Passport;
    term: CM_Terminal;
    exportClass: CM_ExportImportClass;
    categoryMap: DynaDictionary;
    entityArray: JadeDynamicObjectArray;
    categoryName: String;
    hasSystemPermission: Boolean;
    hasTerminalPermission: Boolean;
    jsonResponse: String;
    jdo: JadeDynamicObject;
    jdoEntities: JadeDynamicObject;
    jdoEntity: JadeDynamicObject;
begin
    on CM_Exception do self.handleCMException(exception);
    on LockException do self.handleLockExceptions(exception);
    
    create categoryMap transient;
    categoryMap.setMembership(JadeDynamicObjectArray);
    categoryMap.addExternalKey(String, 100, false, false);
    categoryMap.endKeys(false);
    
    self.initialisePassport();
    passport := app.myPassport;
    
    if self.httpStatusCode &lt;&gt; HttpResponseOK then
        app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
        return jsonResponse;
    endif;
    
    if passport.hasErrors then
        self.httpStatusCode := HttpResponseUnauthorized;
        return jsonResponse;
    endif;
    
    term := passport.myTerminal;
    if term = null then
        self.httpStatusCode := HttpResponseSystemError;
        return jsonResponse;
    endif;
    
    hasSystemPermission := passport.myUser.canDo(term,PmAdmSystemExportMaint) 
                          or passport.myUser.canDo(term,PmAdmSystemImportMaint);
    hasTerminalPermission := passport.myUser.canDo(term,PmAdmTerminalExportMaint) 
                            or passport.myUser.canDo(term,PmAdmTerminalImportMaint);
    
    if not hasSystemPermission and not hasTerminalPermission then
        self.httpStatusCode := HttpResponseForbidden;
        return jsonResponse;
    endif;
    
    // Build final JSON structure
    create jdo transient;
    
    create jdoEntities transient;
    jdo.addProperty(ENTITIES, JadeDynamicObject);
    
    // Collect data by category and build JSON simultaneously
    foreach exportClass in app.myRoot.allExportImportClasses do
        if not exportClass.isExportable then
            continue;
        endif;
        
        categoryName := exportClass.category;
        if categoryName.isOneOf(ExportImportSystemAdmin,ExportImportSystemScreen) then
            if not hasSystemPermission then continue; endif;
        elseif categoryName.isOneOf(ExportImportTerminalAdmin,ExportImportTerminalScreen) then
            if not hasTerminalPermission then continue; endif;
        else
            continue;
        endif;
        
        // Get or create array for category
        entityArray := categoryMap[categoryName].JadeDynamicObjectArray;
        if entityArray = null then
            create entityArray transient;
            categoryMap.putAtKey(categoryName, entityArray);
            // Add property to jdoEntities when creating new category
            jdoEntities.addProperty(categoryName, JadeDynamicObjectArray);
            jdoEntities.setPropertyValue(categoryName, entityArray);
        endif;
        
        // Create entity object
        create jdoEntity transient;
        jdoEntity.addProperty(UID, String);
        jdoEntity.setPropertyValue(UID, exportClass.displayName);
        jdoEntity.addProperty(VALUE, String);
        jdoEntity.setPropertyValue(VALUE, exportClass.displayName);
        entityArray.add(jdoEntity);
    endforeach;
    
    jdo.setPropertyValue(ENTITIES, jdoEntities);
    
    // Serialize to JSON
    jdo.deserializeJSON(jsonResponse);
    
    self.httpStatusCode := HttpResponseOK;
    
    return jsonResponse;
    
epilog
    delete categoryMap;
    delete jdo;
    delete jdoEntities;
    self.finaliseJSONResponse(jsonResponse);
    return jsonResponse;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefinedText" id="701e4aa5-d94d-44be-8058-c7c362f5e2e9">
        <updating/>
        <source>getDefinedText(_context : String):WS_DefinedTextResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
11 October 2022	navvt20		ChangeRequest 53424: MTN - MOB - Input Remarks - Jade

*/

vars
	response 	 : WS_DefinedTextResponse;
	definedText  : CM_DefinedText;
	wsDamageCode : WS_DefinedText;
	terminal 	 : CM_Terminal;
	iter		 : Iterator;
	context		 : String;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	
	terminal := app.myPassport.myTerminal;
	
	if terminal = null then
		self.httpStatusCode := HttpResponseNotFound;
		return response;
	endif;
	
	iter:=terminal.allTerminalDefinedText.createIterator;
	terminal.allTerminalDefinedText.startKeyGeq(_context.Integer,null,iter);
	while iter.next(definedText) do
		if definedText.context &lt;&gt; _context.Integer then
			break;
		endif;
		
		create wsDamageCode transient;
		wsDamageCode.setProxyFromObject(definedText);
		response.allDefinedText.add(wsDamageCode);
	endwhile;
	
	return response;
epilog
	delete iter;
	finaliseResponse(response);
end;</source>
        <Parameter name="_context" type="String"/>
        <ReturnType type="WS_DefinedTextResponse"/>
    </JadeMethod>
    <JadeMethod name="getDeliveryReleaseReasons" id="e3b71b89-3064-4b16-8af5-77f9b3be9408">
