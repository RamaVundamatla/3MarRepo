epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFunctionCode" id="cf4ba522-3902-4ff7-bd2b-996521f8990f">
        <source>getFunctionCode(_description :String):Integer;
/****Changes

Date		Name	TFS#						Description
============================================================================
23 Nov 2011	cnwcs5	CCMS POL 2122 / par 28696	Initial creation - Empty Releases via COPARN
13/09/2012	cnwcs5	CCMS POL 2216 - 			changes for functional spec
24/09/2012	cnwcs5	CCMS POL 2097 - 			changes for functional spec
28/02/2013	cnwcs5	CCMS POL 2220 - 			changes for functional spec
25/03/2013	cnwcs5	CCMS POL 2097 / par 31259
03/07/2013	cnwcs5	par 31942 - 				FTX segment processing for Coparn/IFTMCS booking
11 Sep 2014	cnwma1	PAR#34855 CCMS 2351: 		Hapag-Lloyd Release Request Enhancements
14 Jun 2016 cnwma1	TFS #2048 POL - 			HSD EDI Empty Release Request
21 Aug 2017	jlgrs1	TFS 6564 					add Coparn and Coreor RFF and NAD translation
03 Jun 2018	jlgrs1	TFS 38357 					SNO Fix Xlations from TFS 6797
06/11/2018	jlgka1	39185, 39187				Add IFCSUM FTX+AAA Rules.
============================================================================*/
vars

begin
	if _description = self.Function_BGM_1_1_Booking_Desc then
		return self.Function_BGM_1_1_Booking;
		
	elseif _description = self.Function_BGM_1_1_Release_Desc then 
		return self.Function_BGM_1_1_Release;
	elseif _description = self.Function_BGM_1_1_Prenote_Desc then //epr TFS 2744 13/2/17
		return self.Function_BGM_1_1_Prenote;
		
	elseif _description = self.Function_UNH_1_1_Release_Desc then  //cnwma1 TFS #2048 14/06/2016 
		return self.Function_UNH_1_1_Release;
		
	elseif _description = self.Function_UNH_1_1_Booking_Desc then  //cnwma1 TFS #2048 14/06/2016 
		return self.Function_UNH_1_1_Booking;
		
	elseif _description = self.Function_DTM_1_1_ReqDT_Desc then
		return self.Function_DTM_1_1_ReqDT;	
		
	elseif _description = self.Function_DTM_1_1_EstReqDT_Desc then
		return self.Function_DTM_1_1_EstReqDT;
		
	elseif _description = self.Function_FTX_1_1_BkRemark_Desc then
		return self.Function_FTX_1_1_BookingRemark;
		
	elseif _description = self.Function_FTX_3_1_Stowage_Desc then	//07 Jun 2017	NDL	TFS 4454
		return Function_FTX_3_1_Stowage;
		
	elseif _description = self.Function_FTX_4_1_BkIgnore_Desc then
		return self.Function_FTX_4_1_BookingIgnore;
		
	elseif _description = self.Function_FTX_4_1_BookVent_Desc then
		return self.Function_FTX_4_1_BookingVent;
		
	elseif _description = self.Function_FTX_4_1_Heavy_Desc then
		return self.Function_FTX_4_1_Heavy;
		
	elseif _description = self.Function_FTX_4_1_EstReqDT_Desc then      //cnwma1 TFS #2048 14/06/2016 
		return self.Function_FTX_4_1_EstReqDT;
		
	elseif _description = self.Function_FTX_4_1_MTGText_Desc then
		return self.Function_FTX_4_1_MTGradeText;
		
	elseif _description = self.Function_MEA_3_2_Heavy_Desc then
		return self.Function_MEA_3_2_Heavy;
		
	elseif _description = self.Function_TMP_1_1_MTGTemp_Desc then
		return self.Function_TMP_1_1_MTGradeTemp;
	elseif _description = self.Function_RFF_1_1_RELNo_Desc then   //11/09/2014 cnwma1 PAR#34855  CCMS POL 2351
		return self.Function_RFF_1_1_RelNo;						  
	elseif _description = self.Function_NAD_1_1_AM_Desc then
		return self.Function_NAD_1_1_AM;
	elseif _description = self.Function_NAD_1_1_CA_Desc then
		return self.Function_NAD_1_1_CA;
	elseif _description = self.Function_NAD_1_1_CC_Desc then
		return self.Function_NAD_1_1_CC;
	elseif _description = self.Function_NAD_1_1_CN_Desc then
		return self.Function_NAD_1_1_CN;
	elseif _description = self.Function_NAD_1_1_CU_Desc then
		return self.Function_NAD_1_1_CU;
	elseif _description = self.Function_NAD_1_1_CZ_Desc then
		return self.Function_NAD_1_1_CZ;
	elseif _description = self.Function_NAD_1_1_FW_Desc then
		return self.Function_NAD_1_1_FW;
	elseif _description = self.Function_NAD_1_1_SH_Desc then
		return self.Function_NAD_1_1_SH;
	elseif _description = self.Function_NAD_1_1_SPC_Desc then
		return self.Function_NAD_1_1_SPC;
	elseif _description = self.Fnct_NAD_n_1_CargoOper_Desc then
		return self.Fnct_NAD_n_1_CargoOper;
	elseif _description = self.Fnct_NAD_n_1_Consignee_Desc then
		return self.Fnct_NAD_n_1_Consignee;
	elseif _description = self.Fnct_NAD_n_1_Consignor_Desc then
		return self.Fnct_NAD_n_1_Consignor;
	elseif _description = self.Fnct_NAD_n_1_CustomAgent_Desc then
		return self.Fnct_NAD_n_1_CustomAgent;
	elseif _description = self.Fnct_NAD_n_1_FreightForwd_Desc then
		return self.Fnct_NAD_n_1_FreightForwd;
	elseif _description = self.Fnct_NAD_n_1_RecCarrier_Desc then
		return self.Fnct_NAD_n_1_RecCarrier;
	elseif _description = self.Fnct_NAD_n_1_RelCarrier_Desc then
		return self.Fnct_NAD_n_1_RelCarrier;
	elseif _description = self.Fnct_NAD_n_1_WghtCertNam_Desc then
		return self.Fnct_NAD_n_1_WghtCertNam;
	elseif _description = self.Fnct_NAD_n_1_WghtCertRef_Desc then
		return self.Fnct_NAD_n_1_WghtCertRef;
	elseif _description = self.Function_RFF_1_1_ACW_Desc then
		return self.Function_RFF_1_1_ACW;
	elseif _description = self.Function_RFF_1_1_ANN_Desc then
		return self.Function_RFF_1_1_ANN;
	elseif _description = self.Function_RFF_1_1_BN_Desc then
		return self.Function_RFF_1_1_BN;
	elseif _description = self.Function_RFF_1_1_RE_Desc then
		return self.Function_RFF_1_1_RE;
	elseif _description = self.Function_RFF_1_1_REO_Desc then
		return self.Function_RFF_1_1_REO;
	elseif _description = self.Function_RFF_1_1_SQ_Desc then
		return self.Function_RFF_1_1_SQ;
	elseif _description = self.Function_RFF_1_1_VON_Desc then
		return self.Function_RFF_1_1_VON;
	elseif _description = self.Fnct_RFF_1_1_Booking_Desc then
		return self.Fnct_RFF_1_1_Booking;
	elseif _description = self.Fnct_RFF_1_1_EntryNumber_Desc then
		return self.Fnct_RFF_1_1_EntryNumber;
	elseif _description = self.Fnct_RFF_1_1_BOL_Desc then
		return self.Fnct_RFF_1_1_BOL;
	elseif _description = self.Fnct_RFF_1_1_CarrierRef_Desc then
		return self.Fnct_RFF_1_1_CarrierRef;
	elseif _description = self.Fnct_RFF_1_1_CustomerRef_Desc then
		return self.Fnct_RFF_1_1_CustomerRef;
	elseif _description = self.Fnct_RFF_1_1_Release_Desc then
		return self.Fnct_RFF_1_1_Release;
	elseif _description = self.Fnct_RFF_1_1_Sequence_Desc then
		return self.Fnct_RFF_1_1_Sequence;
	elseif _description = self.Function_FTX_21_1_Mafis_Desc then 	// jlgka1 TFS 39187, 39185
		return self.Function_FTX_21_1_Mafis;						// jlgka1 TFS 39187, 39185
	elseif _description = self.Function_FTX_21_1_IgnoreSegDsc then 		// jlgka1 TFS 39187, 39185
		return self.Function_FTX_21_1_IgnoreSeg;							// jlgka1 TFS 39187, 39185	
	else
		return null;
	endif;
end;</source>
        <Parameter name="_description" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFunctionDescription" id="51d8c529-e395-4e2d-9f97-8fdef81756e9">
        <source>getFunctionDescription():String;
/****Changes

Date		Name	TFS#						Description
============================================================================
22 Nov 2011	cnwcs5	 CCMS POL 2122 / par 28696	Initial creation - Empty Releases via COPARN
13/09/2012	cnwcs5	CCMS POL 2216 - 			changes for functional spec
24/09/2012	cnwcs5	CCMS POL 2097 - 			changes for functional spec
28/02/2013	cnwcs5	CCMS POL 2220 - 			changes for functional spec
25/03/2013	CNWCS5	ccms POL 2097 / par 31259
03/07/2013	cnwcs5	par 31942 - 				FTX segment processing for Coparn/IFTMCS bookings
11 Sep 2014	cnwma1	PAR#34855 CCMS 2351: 		Hapag-Lloyd Release Request Enhancements
14 Jun 2016 cnwma1	TFS #2048 POL - 			HSD EDI Empty Release Request
21 Aug 2017	jlgrs1	TFS 6564 					add Coparn and Coreor RFF and NAD translation
03 Jun 2018	jlgrs1	TFS 38357 					SNO Fix Xlations from TFS 6797
06/11/2018	jlgka1	39185, 39187				Add IFCSUM FTX+AAA Rules.
============================================================================*/
vars
	code	:Integer;
begin
	code := self.function;
	
	if code = self.Function_BGM_1_1_Booking then
		return self.Function_BGM_1_1_Booking_Desc;
		
	elseif code = self.Function_BGM_1_1_Release then
		return self.Function_BGM_1_1_Release_Desc;
		
	elseif code = self.Function_BGM_1_1_Prenote then //epr TFS 2744 21/2/17
		return self.Function_BGM_1_1_Prenote_Desc;
	elseif code = self.Function_UNH_1_1_Release then 	//cnwma1 TFS #2048 14/06/2016 
		return self.Function_UNH_1_1_Release_Desc;
		
	elseif code = self.Function_UNH_1_1_Booking then       //cnwma1 TFS #2048 14/06/2016 
		return self.Function_UNH_1_1_Booking_Desc;
	
	
	elseif code = self.Function_DTM_1_1_ReqDT then
		return self.Function_DTM_1_1_ReqDT_Desc;
		
	elseif code = self.Function_DTM_1_1_EstReqDT then
		return self.Function_DTM_1_1_EstReqDT_Desc;
		
	elseif code = self.Function_FTX_1_1_BookingRemark then
		return self.Function_FTX_1_1_BkRemark_Desc;
		
	elseif code = self.Function_FTX_3_1_Stowage then	//07 Jun 2017	NDL	TFS 4454
		return self.Function_FTX_3_1_Stowage_Desc;
		
	elseif code = self.Function_FTX_4_1_BookingIgnore then
		return self.Function_FTX_4_1_BkIgnore_Desc;
		
	elseif code = self.Function_FTX_4_1_BookingVent then
		return self.Function_FTX_4_1_BookVent_Desc;
		
	elseif code = self.Function_FTX_4_1_Heavy then
		return self.Function_FTX_4_1_Heavy_Desc;
		
	elseif code = self.Function_FTX_4_1_MTGradeText then
		return self.Function_FTX_4_1_MTGText_Desc;
		
	elseif code = self.Function_FTX_4_1_EstReqDT then   //cnwma1 TFS #2048 14/06/2016 
		return self.Function_FTX_4_1_EstReqDT_Desc;
		
	elseif code = self.Function_TMP_1_1_MTGradeTemp then
		return self.Function_TMP_1_1_MTGTemp_Desc;
		
	elseif code = self.Function_MEA_3_2_Heavy then
		return self.Function_MEA_3_2_Heavy_Desc;
		
	elseif code = self.Function_TMP_1_1_MTGradeTemp then
		return self.Function_TMP_1_1_MTGTemp_Desc;
	
	elseif code = self.Function_RFF_1_1_RelNo then  //11/09/2014 cnwma1 PAR#34855  CCMS POL 2351
		return self.Function_RFF_1_1_RELNo_Desc;	
	elseif code = self.Function_NAD_1_1_AM then
		return self.Function_NAD_1_1_AM_Desc;
	elseif code = self.Function_NAD_1_1_CA then
		return self.Function_NAD_1_1_CA_Desc;
	elseif code = self.Function_NAD_1_1_CC then
		return self.Function_NAD_1_1_CC_Desc;
	elseif code = self.Function_NAD_1_1_CN then
		return self.Function_NAD_1_1_CN_Desc;
	elseif code = self.Function_NAD_1_1_CU then
		return self.Function_NAD_1_1_CU_Desc;
	elseif code = self.Function_NAD_1_1_CZ then
		return self.Function_NAD_1_1_CZ_Desc;
	elseif code = self.Function_NAD_1_1_FW then
		return self.Function_NAD_1_1_FW_Desc;
	elseif code = self.Function_NAD_1_1_SH then
		return self.Function_NAD_1_1_SH_Desc;
	elseif code = self.Function_NAD_1_1_SPC then
		return self.Function_NAD_1_1_SPC_Desc;
	elseif code = self.Fnct_NAD_n_1_CargoOper then
		return self.Fnct_NAD_n_1_CargoOper_Desc;
	elseif code = self.Fnct_NAD_n_1_Consignee then
		return self.Fnct_NAD_n_1_Consignee_Desc;
	elseif code = self.Fnct_NAD_n_1_Consignor then
		return self.Fnct_NAD_n_1_Consignor_Desc;
	elseif code = self.Fnct_NAD_n_1_CustomAgent then
		return self.Fnct_NAD_n_1_CustomAgent_Desc;
	elseif code = self.Fnct_NAD_n_1_FreightForwd then
		return self.Fnct_NAD_n_1_FreightForwd_Desc;
	elseif code = self.Fnct_NAD_n_1_RecCarrier then
		return self.Fnct_NAD_n_1_RecCarrier_Desc;
	elseif code = self.Fnct_NAD_n_1_RelCarrier then
		return self.Fnct_NAD_n_1_RelCarrier_Desc;
	elseif code = self.Fnct_NAD_n_1_WghtCertNam then
		return self.Fnct_NAD_n_1_WghtCertNam_Desc;
	elseif code = self.Fnct_NAD_n_1_WghtCertRef then
		return self.Fnct_NAD_n_1_WghtCertRef_Desc;
	elseif code = self.Function_RFF_1_1_ACW then
		return self.Function_RFF_1_1_ACW_Desc;
	elseif code = self.Function_RFF_1_1_ANN then
		return self.Function_RFF_1_1_ANN_Desc;
	elseif code = self.Function_RFF_1_1_BN then
		return self.Function_RFF_1_1_BN_Desc;
	elseif code = self.Function_RFF_1_1_RE then
		return self.Function_RFF_1_1_RE_Desc;
	elseif code = self.Function_RFF_1_1_REO then
		return self.Function_RFF_1_1_REO_Desc;
	elseif code = self.Function_RFF_1_1_SQ then
		return self.Function_RFF_1_1_SQ_Desc;
	elseif code = self.Function_RFF_1_1_VON then
		return self.Function_RFF_1_1_VON_Desc;
	elseif code = self.Fnct_RFF_1_1_Booking then
		return self.Fnct_RFF_1_1_Booking_Desc;
	elseif code = self.Fnct_RFF_1_1_EntryNumber then
		return self.Fnct_RFF_1_1_EntryNumber_Desc;
	elseif code = self.Fnct_RFF_1_1_BOL then
		return self.Fnct_RFF_1_1_BOL_Desc;
	elseif code = self.Fnct_RFF_1_1_CarrierRef then
		return self.Fnct_RFF_1_1_CarrierRef_Desc;
	elseif code = self.Fnct_RFF_1_1_CustomerRef then
		return self.Fnct_RFF_1_1_CustomerRef_Desc;
	elseif code = self.Fnct_RFF_1_1_Release then
		return self.Fnct_RFF_1_1_Release_Desc;
	elseif code = self.Fnct_RFF_1_1_Sequence then
		return self.Fnct_RFF_1_1_Sequence_Desc;
	elseif code = self.Function_FTX_21_1_Mafis then  		// jlgka1 TFS 39187, 39185
		return self.Function_FTX_21_1_Mafis_Desc;			// jlgka1 TFS 39187, 39185	
	elseif code = self.Function_FTX_21_1_IgnoreSeg then	// jlgka1 TFS 39187, 39185
		return self.Function_FTX_21_1_IgnoreSegDsc;	// jlgka1 TFS 39187, 39185		
	else
		return null;
	endif;
end;</source>
