    <JadeMethod name="actionItems" id="f66809eb-9f91-47fa-a003-79512a5c806c">
        <updating/>
        <source>actionItems(_woActionIF: CMIF_WorkOrderAction; _passport: CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 03/07/2018	jlgdap1		Initial creation TFS 39165 PEL1 Voyage Work Order Transactions
//
vars

	status : CM_VoyageStatus;
	voyage : CM_Voyage;
begin

	if _passport.noErrors then
		self.setIsComplete;
		// create the appropriate transaction for billing  purposes
		self.createWorkOrderTransaction(TRANS_TYPE_WO_VOYAGEREQUEST);
		

		// TFS 41539
		if self.hasCargo then
			voyage := self.getMyVoyageObject();
			if voyage &lt;&gt; null 
			and voyage.myVoyageProcess.isMTNWOProcess then	 //jlier1 TFS 51963 1/10/21	
				status := app.myRoot.allVoyageStatuses[Voyage_Status_CargoReqPending];	
				voyage.setStatusFromObject(status);
			endif;
		
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cargoOperatorDescDischarge" id="25522d9b-d100-4002-b66e-20466a0bb539">
        <source>cargoOperatorDescDischarge():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 October 2018	jlgndl1	Initial creation	TFS 41407

*/

vars

	operator : CM_Operator;
	
begin

	if self.cargoOperatorCodeDischarge &lt;&gt; null then
		operator := app.myRoot.allOperators.getAtKey( self.cargoOperatorCodeDischarge );
	endif;
	
	if operator &lt;&gt; null then
		return operator.description;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
