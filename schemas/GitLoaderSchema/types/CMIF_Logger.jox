<Class name="CMIF_Logger" id="00234855-a616-4960-8596-d5f89f2f2bbe">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="gitloader"/>
    <CompAttribute name="allLogs" id="af066761-4540-4584-9b7e-91948baae3a4">
        <type name="HugeStringArray"/>
        <access>protected</access>
    </CompAttribute>
    <JadeMethod name="getLogs" id="53994530-e27b-4b93-9dba-dc63d1dc9afb">
        <source>getLogs(): String;
//21 September 2010	cnwdw1	
//
vars
	logs, log: String;
begin
	foreach log in self.allLogs do
		logs := logs &amp; log &amp; CrLf;
	endforeach;
	logs.replaceChar(Tab, ' ');
	return logs;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="log" id="331ddb18-5e3a-4cee-897d-0d724e511c68">
        <source>log(_message: String);
//21 September 2010	cnwdw1	
//
constants
    MAXSIZE = 2040;
vars
	l, s: Integer;
begin	
	l := _message.length;
	s := 1; 
	while s &lt;= l do
		allLogs.add(_message[s:MAXSIZE]);
		s := s+MAXSIZE;
	endwhile;
end;
</source>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
</Class>
