    <JadeMethod name="incrementTime" id="5951ed57-1e65-4211-b03f-2d770d8288f2">
        <source>incrementTime(ts:TimeStamp):TimeStamp;

vars
	stamp	: TimeStamp;
	t1,t2,t3 : Time;
	d : Date;
begin
	stamp := ts;
	d  := ts.date;
	t1 := ts.time;
	t2 := ts.time;

	t2 := (t1 + (minutesPerPixel * (60000)).Integer);
	stamp.setTime(t2);
	if t1 &gt; t2 then
		d := d + 1;
		stamp.setDate(d);
	endif;
	return stamp;
end;</source>
        <Parameter name="ts" type="TimeStamp"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="initControl" id="28c2284e-743f-4c32-b851-7ef84e140d08">
        <updating/>
        <source>initControl()updating;
//--------------------------------------------------
// Created:	10 May 2004 By: cnwgd1
//--------------------------------------------------
vars
	
	tmpForm	: HMS_GraphicalViewX;
begin
	
	tmpForm := self.myGraphicalView;
	
	self.myScrollingFrame := tmpForm.frmScrollingMain;
	self.myLabelFrame := tmpForm.frmScrollablMain.myVLabels;
	self.myLabelFrame.ignoreSkin := true;
	self.myLabelFrame.backColor := tmpForm.backColor;
	self.setupControls();

end;</source>
