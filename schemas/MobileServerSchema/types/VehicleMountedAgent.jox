    </JadeMethod>
    <JadeMethod name="loadTableFromRTQueueEntries" id="00ea70c7-fc04-437a-a29a-2d00876d7370">
        <updating/>
        <source>loadTableFromRTQueueEntries(_table: Table input; _allRTQueueEntries : CM_RTQueueEntryArray) updating;
/*

Purpose:	 loads passed in entries and does not do the machine query assignment	

Parameters:			

Return Value:		


Date		Who		Reason
23 April 2010	cnwer1	Initial creation
28 Jun 2010	cnwkpd1	PAR #24763 - Prevent 1090 and 14051 exceptions.  Ensure allAvailableRTQueueEntries
					is not populated with null objects
02 Sep 2010 cnwer1 	PAR 25206
*/

vars

begin

	self.myMachQEntryTableSynchAgent.setTableDetails(_table,self.getEntTableView(_table),self.getHeaderTopRow(_table));
	self.myMachQEntryTableSynchAgent.doLoadFromRTQueueEntries(_table,_allRTQueueEntries);

end;</source>
