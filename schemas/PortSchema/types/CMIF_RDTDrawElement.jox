		self.drawGridTopColumnHeaderTopDown(_x1, _y1, _x2, _y2, _frame, _scaleFactor, _isLandscape, _flipH, _flipV, _mode, _isGapCol);
	elseif _mode = self.MODE_FACE then
		self.drawGridTopColumnHeaderTopDown(_x1, _y1, _x2, _y2, _frame, _scaleFactor, _isLandscape, _flipH, _flipV, _mode, _isGapCol);
	elseif _mode = self.MODE_END then
