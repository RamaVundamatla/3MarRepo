    <JadeMethod name="setCurrentItem" id="d1524e6b-da9d-40f5-b3cf-773358888af3">
        <updating/>
        <source>setCurrentItem(deckItem : CM_DeckItemLayout) updating;
/*
Purpose:			
Date		Who		Reason
18 April 2011	cnwab1	Initial creation
*/

vars
	isResizable	: Boolean;
	idx : Integer;
begin
	if deckItem = null then
		return;
	endif;
	if self.myCurrentProxyItemLayout &lt;&gt; null then
		self.endNotification(self.myCurrentProxyItemLayout, EVENT_RORO_ITEM_UPDATE);
	endif;
	self.myCurrentProxyItemLayout := deckItem;
	self.doBuildRealItems();	// PAR 27501
	// ### tell parent form that we have selected a layer
	if self.myCurrentProxyItemLayout.isVisible then // PAR 27515
		self.myCurrentProxyItemLayout.causeEvent(EVENT_RORO_ITEM_SELECT,true,null);
	endif;
	
	if self.myUIStylesFrame &lt;&gt; null then
		self.myUIStylesFrame.causeEvent(EVENT_RORO_ITEM_SELECT,true,self.myCurrentProxyItemLayout);
	endif;
	self.beginNotification(self.myCurrentProxyItemLayout, EVENT_RORO_ITEM_UPDATE, Response_Continuous, null);
	
	self.txtItemCode.text := deckItem.code;
	self.txtItemDesc.text := deckItem.description;
	self.txtItemRemarks.text := deckItem.remarks;
	
	self.cmbLayerRealItem.listObject := null;
	if self.cmbLayerRealItem.findObject(deckItem.myDeckItem) &gt; 0 then
		self.cmbLayerRealItem.listObject := deckItem.myDeckItem;
	endif;
	self.tblDimensions.rows := self.tblDimensions.fixedRows;
	self.txtItemCode.setFocus();
	
	self.doListItemDimensions();
	self.tblLayerItems.deselectAll();
	
	if self.tblLayerItems.findObjectInRow(deckItem, idx) then
		self.tblLayerItems.selectRow(idx,false);
	endif;
	// 28763 Dec 2011 vessel definition, RORO containers are not resizable
	isResizable := self.myCurrentProxyItemLayout.isResizeable();
	self.btnDltItemDim.enabled := isResizable;
	self.btnNewItemDim.enabled := isResizable;
	self.tblDimensions.enabled := isResizable;

epilog

end;</source>
        <Parameter name="deckItem" type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="setFrames" id="68216f62-3869-4dcd-ae12-1f805f9b82ab">
        <updating/>
        <source>setFrames(_colour : Integer) updating;
/*

Date		    Who			Reason
28 March 2011	cnwas3	  Initial creation

*/

vars
	deckToolbar, layerToolbar, dimToolbar : CMUI_Toolbar;
begin
	
	deckToolbar := self.frmToolbar;
	layerToolbar := self.toolbarLayItems;
	dimToolbar := self.toolbarItemDim;		
	
	
	deckToolbar.visible := true;
	deckToolbar.stretchWidth := false;
	//deckToolbar.width := self.btnLayerItems.left;
	deckToolbar.width := self.btnLayerItems.left - 2;						// 12/03/2013 cnmwh5 #31723
	deckToolbar.distanceFromRight := self.btnLayerItems.width + 5;	
	deckToolbar.top := 22;
	deckToolbar.left := self.grpLayers.left + 2;	
	deckToolbar.bevelColor := self.backColor;	
	
	self.btnLayerItems.top := deckToolbar.top - self.grpLayers.top;
	self.btnLayerItems.distanceFromRight := 3;	
		
		
	layerToolbar.visible := true;
	layerToolbar.top := 16;	
	//layerToolbar.distanceFromRight := 1;
	layerToolbar.distanceFromRight := self.btnItemDimension.width + 5;		// 12/03/2013 cnmwh5 #31723
	layerToolbar.left := 2;	
	layerToolbar.bevelColor := self.backColor;	
	
	self.btnItemDimension.top := layerToolbar.top;	
	self.btnItemDimension.zOrder(1);	
	
	
	dimToolbar.visible := true;
	dimToolbar.top := 16;	
	dimToolbar.left := 2;
	//dimToolbar.distanceFromRight := 1;
	dimToolbar.distanceFromRight := dimToolbar.left;					// 12/03/2013 cnmwh5 #31723
	
	dimToolbar.bevelColor := self.backColor;	

epilog

end;</source>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
