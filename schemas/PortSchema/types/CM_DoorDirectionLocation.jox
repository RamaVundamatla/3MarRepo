    <JadeMethod name="getDoorDirectionWording" id="bde9d33c-4960-4995-a75b-26a8bc44cd6d">
        <source>getDoorDirectionWording() : String;

// Created by cnwdvb1 on 16 August 2007

vars

begin

	return self.myDoorDirectionRule.doorDirectionWording;
	
end;</source>
