    <JadeMethod name="trxUpdateTrackedItem" id="e13289f9-cdb8-459e-a350-6e457aa1a9d8">
        <updating/>
        <source>trxUpdateTrackedItem(	_pxyTI 			: CM_TrackedItem input; 
						_comment		: String;
						_updateMode 		: Integer;
						_txnControllerDict 	: CMIF_TITxnContrlrByTypeDTDict;
						_passport 			: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     12 September 2003	cnwth2
//	
// Purpose:     
// 	25-Apr-2024	naviv1		Bug 63861 - CUX | PUT/cargo API - Allows Multiple prenotes with same Booking Id		 
// ----------   ----------  --------------------------------------------------
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	_passport.useTITransactionDeferUpdate := true;		//25.04.2024 naviv1	#63861
	_passport.useTIDictDeferUpdate := true;				//25.04.2024 naviv1	#63861

	beginTransaction;

	app.myUtilityUA.utlUpdateTrackedItem(_pxyTI, _comment, _updateMode, _txnControllerDict, null, null, _passport);//cnwrd1 28.8.09 par 20545
	
	if _passport.noErrors then					//25.04.2024 naviv1	#63861
		_passport.doDeferredUpdates();		
	endif;	
	
epilog
	self.finaliseActivityWithPassport(_passport);	

end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_updateMode" type="Integer"/>
        <Parameter name="_txnControllerDict" type="CMIF_TITxnContrlrByTypeDTDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTrackedItemFromTBA" id="5b204a11-364e-49bd-82a4-4dd1dd37a609">
        <updating/>
        <source>trxUpdateTrackedItemFromTBA(	_pxyTI 			: CM_TrackedItem input; 
						_comment		: String;
						_updateMode 		: Integer;
						_tbaMatch : CM_TrackedItem;
						_passport 			: CM_Passport input) updating;
/*
Purpose:	TFS 45590		
Date				Who			Reason
NOVEMBER 2019		JLGAB1 initial creation
*/

vars
	ti			: CM_TrackedItem;
	nullObject	: CM_Object;
	information : StringArray512;
	theTerminal : CM_Terminal;
	theVoyage : CM_Voyage;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;

	app.myUtilityUA.utlUpdateTrackedItem(_pxyTI, _comment, _updateMode, null, null, null, _passport);
	
	if _passport.noErrors() then
		if _tbaMatch &lt;&gt; null then
		
			ti := _pxyTI.pxyGetRealObject().CM_TrackedItem;
			
			if ti &lt;&gt; null then
				if ti.myMatchedTBA &lt;&gt; _tbaMatch then // From the manual screen
					ti.myMatchedTBA := _tbaMatch;
				endif;
				
				if not _tbaMatch.isPlannedToShip then // If planned this info is created when the planned FM is moved to the real TI
					create information transient;
					information.add("REAL : " &amp; ti.id);
					information.add("TBA : " &amp; _tbaMatch.id);
					information.add("REAL Manually Updated From TBA");
					ti.createInfomationTransaction("Matched to TBA " &amp; _tbaMatch.id, information, null, app.myPassport);
				endif;
				
				ti.matchAndQueueToTBA(null,_passport); // Pass null for WLE as this will be a road WLE which in this case we do not have
				
				theTerminal := ti.myTerminal;
				theVoyage := ti.myVoyage;
				
				if theVoyage &lt;&gt; null and theTerminal &lt;&gt; null then
					app.myEventManager.createSingleObjInfoNoteEvt(theVoyage,
						theTerminal.getTerminalEvent(EVENT_PLANNING_TI_PLANNED),
						ti);
				endif;
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);	
	delete information;
end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_updateMode" type="Integer"/>
        <Parameter name="_tbaMatch" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTrackedItems" id="441f7fbb-2f94-4da7-90b8-9879ada8afd9">
        <updating/>
        <source>trxUpdateTrackedItems(pTISet 			: CM_TISet; 
					pUpdateMode 	    : Integer;
					_txnControllerDict  : CMIF_TITxnContrlrByTypeDTDict;
					_passport 			: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     Takes an array of CM_TrackedItems (which should be proxies) and updates.
//
// Parameters:  The array of interface objects.
//				pUpdateMode	from constants category "TI_UpdateModes"
//				Also dict of proxy transactions - to be copied onto 
//				CMIF_TIUpdateController::allPxyTITransactions
//
// Returns:     True if successful.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23 May 2024  navma1		Bug 64224: MTN - DeadLocks Caused by Future Actors
// ---------------------------------------------------------------------------
vars
	ti			: CM_TrackedItem;
	firstTi		: CM_TrackedItem;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	_passport.useTITransactionDeferUpdate := true;
	_passport.useTIDictDeferUpdate 		  := true;
	
	if pTISet.isEmpty then											//23.05.2024 navma1 #64224
		return;
	endif;
	
	firstTi := pTISet.first;
	app.myPassport.setMyTerminal(firstTi.myTerminal);				//23.05.2024 navma1 #64224		
	beginTransaction;
	
	foreach ti in pTISet do
		// setting the serminal on the passport for each TI, in case the selector has retrieved items from different terminals
		//app.myPassport.setMyTerminal(ti.myTerminal);				//23.05.2024 navma1 #64224
		app.myUtilityUA.utlUpdateTrackedItem(ti, null, pUpdateMode, _txnControllerDict, null, null, _passport); //cnwrd1 28.8.09 par 20545
		if (not _passport.noErrors) then
			break;
		endif;
	endforeach;

	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);	
end;</source>
        <Parameter name="pTISet" type="CM_TISet"/>
        <Parameter name="pUpdateMode" type="Integer"/>
        <Parameter name="_txnControllerDict" type="CMIF_TITxnContrlrByTypeDTDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTrackedItemsBatch" id="e036c171-05ac-4bc2-b1aa-b8ae36103352">
        <updating/>
        <source>trxUpdateTrackedItemsBatch(	pTISet : CM_TISet; 
							pUpdateMode : Integer;
							_txnControllerDict : CMIF_TITxnContrlrByTypeDTDict;
							_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     Takes an array of CM_TrackedItems (which should be proxies) and updates.
//
// Parameters:  The array of interface objects.
//				pUpdateMode	from constants category "TI_UpdateModes"
//				Also dict of proxy transactions - to be copied onto 
//				CMIF_TIUpdateController::allPxyTITransactions
//
// Returns:     True if successful.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti			: CM_TrackedItem;
	nullObject	: CM_Object;
	count		: Integer;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	_passport.useTITransactionDeferUpdate := true;
	_passport.useTIDictDeferUpdate := true;
	
	beginTransaction;
	
	foreach ti in pTISet do
		
		app.myUtilityUA.utlUpdateTrackedItem(ti, null, pUpdateMode, _txnControllerDict, null, null, _passport); //cnwrd1 28.8.09 par 20545
		if (not _passport.noErrors) then
			break;
		endif;
		
		// Par 15187
		count := count + 1;
		if count mod 20 = 0 then
			commitTransaction;
			beginTransaction;
			count := 0;
		endif;
		
	endforeach;

	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;
	
		
epilog
	self.finaliseActivityWithPassport(_passport);	
end;</source>
        <Parameter name="pTISet" type="CM_TISet"/>
        <Parameter name="pUpdateMode" type="Integer"/>
        <Parameter name="_txnControllerDict" type="CMIF_TITxnContrlrByTypeDTDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTrade" id="e5c84219-6764-43c0-9fc7-f2f0c9ccf733">
        <updating/>
        <source>trxUpdateTrade(	pProxyTrade : CM_Trade;
				_updateVoyagePortsOfCall : Boolean;
				_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:      12 May 2003 by cnwsgp1

// ---------------------------------------------------------------------------
vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateTrade(pProxyTrade, _passport);
	
	if not _passport.noErrors then
		return;
	endif;
	
	if _updateVoyagePortsOfCall then
		app.myUtilityUA.utlUpdateAllTradeVoyagesPoC(pProxyTrade,_passport);
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pProxyTrade" type="CM_Trade"/>
        <Parameter name="_updateVoyagePortsOfCall" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
