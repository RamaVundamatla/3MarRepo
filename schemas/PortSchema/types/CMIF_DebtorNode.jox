    <JadeMethod name="createRelatedEntities" id="5354a91d-ca36-4634-9405-ce48ed8b83d9">
        <updating/>
        <source>createRelatedEntities(	_pxyObject : CM_Object input;
						_realObject: CM_Object io;
						_isCreate : Boolean;
						_autoGenerateId : String input;
						_debtorHexOid:String;
						_passport : CM_Passport input;
						_cmifDebtor : CMIF_DebtorNode input;
						_realDebtorNode : CM_DebtorNode;
						_createIfMissing : Boolean;
						_updateEntityDescriptions : Boolean;
						_entityCount : Integer) updating;
/*

Purpose: ***Generic method (Rule/Syntax) for creating all the related entities	(Carrier, Consignor, CustomsAgent, Operator, ShippingLine, Stevedore).	

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2023	navsp1	Initial creation TFS ChangeRequest 57447: EUP - Customer Update - Process Customer info from API method

*/

vars
	pxyCode : String;
	entityCode, entityCodeLinked : String;
	debtorHexOid : String;
	debtor : CM_Debtor;
begin
	debtorHexOid := _debtorHexOid;

	if _pxyObject.isKindOf(CM_Carrier) then			
		pxyCode 	:= _pxyObject.CM_Carrier.code;
		_realObject := app.myRoot.allCarriers[pxyCode];
	elseif _pxyObject.isKindOf(CM_ConsigneeConsignor) then
		pxyCode 	:= _pxyObject.CM_ConsigneeConsignor.code;
		_realObject := app.myRoot.allConsigneeConsignors[pxyCode];
	elseif _pxyObject.isKindOf(CM_CustomsAgent) then
		pxyCode 	:= _pxyObject.CM_CustomsAgent.code;
		_realObject := app.myRoot.allCustomsAgents[pxyCode];
	elseif _pxyObject.isKindOf(CM_Operator) then
		pxyCode 	:= _pxyObject.CM_Operator.code;
		_realObject := app.myRoot.allOperators[pxyCode];
	elseif _pxyObject.isKindOf(CM_ShippingLine) then
		pxyCode 	:= _pxyObject.CM_ShippingLine.code;
		_realObject := app.myRoot.allShippingLines[pxyCode];
	elseif _pxyObject.isKindOf(CM_Stevedore) then
		pxyCode 	:= _pxyObject.CM_Stevedore.code;
		_realObject := app.myRoot.allStevedores[pxyCode];
	endif;
		
	//Create
	if _isCreate then
		if pxyCode = null then
			//Rule 1.1. If code is null and Rel Ent not exists then create Rel Ent using auto generate id. If rel ent already exists then auto id will be incremented.
			while true do	
				if _cmifDebtor.getRealRelatedEntityObject(_pxyObject, _autoGenerateId) = null then
					_realObject := _cmifDebtor.createRelatedEntity(_cmifDebtor, _realDebtorNode, _pxyObject, _passport, _autoGenerateId);
					app.writeLog(method.qualifiedName &amp; "New entity ("&amp;pxyCode&amp;") created", LogDEBUG);
					break;
				else
					_autoGenerateId.incrementHex();
					app.writeLog(method.qualifiedName &amp; "Entitycode incremented", LogDEBUG);
				endif;					
			endwhile;
		else
			//1.2. if code is not null and Rel Ent exists then link the Rel Ent, and update the Rel Ent if 'updateEntityDescription' is 'true'. 				
			if _realObject &lt;&gt; null then
				_cmifDebtor.updateRelatedEntity(_pxyObject, _realDebtorNode, _passport, _updateEntityDescriptions);
			else
				//1.3. Related ent will be created if they dont exist
				_realObject := _cmifDebtor.createRelatedEntity(_cmifDebtor, _realDebtorNode, _pxyObject, _passport, pxyCode);
				app.writeLog(method.qualifiedName &amp; "New entity ("&amp;pxyCode&amp;") created", LogDEBUG);
			endif;
		endif;
		
	//Update
	else				
		
		if pxyCode = null then
			
			//2.1. If code is null and no linked Rel Ent exists, then create Rel Ent using Rule 1.1 if 'createIfMissing' is 'true'.					
			if _entityCount = 0 then						
				if _createIfMissing then
					// If code is null and there are existing linked related entities(not same type) then use the same code as all of the existing entities. Based on the hexoid. -- ****Need to confirm????
					debtor := _realDebtorNode.CM_Debtor;
					entityCodeLinked := _cmifDebtor.getLinkedRelatedEntityCode(debtor, debtorHexOid);
					
					_realObject := _cmifDebtor.createRelatedEntity(_cmifDebtor, _realDebtorNode, _pxyObject, _passport, entityCodeLinked);	
					/*while true do	
						//If the rel ent does not exists, create it.
						if entityCodeLinked &lt;&gt; null or not _cmifDebtor.isAnyRelEntExistsWithSameCode(_autoGenerateId) then							
							_realObject := _cmifDebtor.createRelatedEntity(_cmifDebtor, _realDebtorNode, _pxyObject, _passport, entityCodeLinked);							
							break;
						else
							//1.1: If rel ent already exists then auto id will be incremented						
							_autoGenerateId.incrementHex();
							app.writeLog(method.qualifiedName &amp; "Entitycode incremented", LogDEBUG);
						endif;					
					endwhile;*/						
				//Raise Error
				else
					app.raiseCMException1(REQUIRED_FIELD, "Code" ,null, null);
					app.writeLog(method.qualifiedName &amp; "Rule Failed : Code is null and 'CreateIfMissing' is 'false'", LogDEBUG);
				endif;
			
			//2.3. If code is null and more than one linked Rel Ent exists, then raise an exception.
			elseif _entityCount &gt; 1 then						
				app.raiseCMException(No_matches_found, null, null);
				app.writeLog(method.qualifiedName &amp; "Rule Failed : Code is null and more than one linked entity", LogDEBUG);
			
			else
				//2.2. If code is null and only one linked Rel Ent exists, then update the Rel Ent if 'updateEntityDescription' is 'true'.
				if _updateEntityDescriptions then
					_cmifDebtor.updateRelatedEntity(_pxyObject, _realDebtorNode, _passport, _updateEntityDescriptions);
				endif;
				
			endif;
		else
			//2.4. If code is not null and Rel Ent exists, then update Rel Ent if 'updateEntityDescription' is 'true'.
			if _realObject &lt;&gt; null then	
				_cmifDebtor.updateRelatedEntity(_pxyObject, _realDebtorNode, _passport, _updateEntityDescriptions);
				
			else					
				//2.5. If code is not null and 'NO' Rel Ent exists then create Rel Ent if 'createIfMissing' is 'true'.
				if _createIfMissing then
					_realObject := _cmifDebtor.createRelatedEntity(_cmifDebtor, _realDebtorNode, _pxyObject, _passport, pxyCode);
					app.writeLog(method.qualifiedName &amp; "New entity ("&amp;pxyCode&amp;") created", LogDEBUG);
				else
					//2.6. If code is not null and 'NO' Rel Ent exists, then raise an exception if 'createIfMissing' is 'false'. 
					app.raiseCMException(No_matches_found, null, null);
					app.writeLog(method.qualifiedName &amp; "Rule Failed : Code is not null and no entity exists", LogDEBUG);
				endif;
			
			endif;
			 
		endif;				
		
	endif;
			
epilog

end;</source>
        <Parameter name="_pxyObject" type="CM_Object" usage="input"/>
        <Parameter name="_realObject" type="CM_Object" usage="io"/>
        <Parameter name="_isCreate" type="Boolean"/>
        <Parameter name="_autoGenerateId" type="String" usage="input"/>
        <Parameter name="_debtorHexOid" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_cmifDebtor" type="CMIF_DebtorNode" usage="input"/>
        <Parameter name="_realDebtorNode" type="CM_DebtorNode"/>
        <Parameter name="_createIfMissing" type="Boolean"/>
        <Parameter name="_updateEntityDescriptions" type="Boolean"/>
        <Parameter name="_entityCount" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createRelatedEntity" id="a1cf5fa3-0b2e-4618-8700-80610e08d578">
        <updating/>
        <source>createRelatedEntity(_cmifDebtor : CMIF_DebtorNode input; _realDebtorNode :CM_DebtorNode; _pxyObject : CM_Object input; _passport : CM_Passport input; _entityCode : String) : CM_Object updating, protected;
/*

Purpose: Create related entity for each type.			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2023	navsp1	Initial creation TFS ChangeRequest 57447: EUP - Customer Update - Process Customer info from API method

*/

vars
	pxyCarrier, realCarrier : CM_Carrier;
	pxyConsign, realConsign : CM_ConsigneeConsignor;
	pxyCustomsAgents, realCustomsAgents : CM_CustomsAgent;
	pxyOperator, realOperator : CM_Operator;
	pxyShippingLine, realShippingLine : CM_ShippingLine;
	pxyStevedore, realStevedore : CM_Stevedore;
	realObject : CM_Object;
begin
	if _pxyObject.isKindOf(CM_Carrier) then
		pxyCarrier := _pxyObject.CM_Carrier;
		pxyCarrier.setPropertyValue(CM_Carrier::code.name, _entityCode);						
		// Force-update the collection
		_cmifDebtor.allCarriers.rebuild;
		pxyCarrier.setDebtor(_realDebtorNode.CM_Debtor);
		app.myUtilityCA.utlCreateCarrier(pxyCarrier, realCarrier, _passport);		
		realObject := realCarrier;
		
	elseif _pxyObject.isKindOf(CM_ConsigneeConsignor) then
		pxyConsign := _pxyObject.CM_ConsigneeConsignor;
		pxyConsign.setPropertyValue(CM_ConsigneeConsignor::code.name, _entityCode);						
		// Force-update the collection
		_cmifDebtor.allConsignors.rebuild;
		pxyConsign.setDebtor(_realDebtorNode.CM_Debtor);
		app.myUtilityCA.utlCreateConsigneeConsignor(pxyConsign, realConsign, _passport);
		realObject := realConsign;
		
	elseif _pxyObject.isKindOf(CM_CustomsAgent) then
		pxyCustomsAgents := _pxyObject.CM_CustomsAgent;
		pxyCustomsAgents.setPropertyValue(CM_CustomsAgent::code.name, _entityCode);						
		// Force-update the collection
		_cmifDebtor.allCustomsAgents.rebuild;
		pxyCustomsAgents.setDebtor(_realDebtorNode.CM_Debtor);
		app.myUtilityCA.utlCreateCustomsAgent(pxyCustomsAgents, realCustomsAgents, _passport);
		realObject := realCustomsAgents;
		
	elseif _pxyObject.isKindOf(CM_Operator) then
		pxyOperator := _pxyObject.CM_Operator;
		pxyOperator.setPropertyValue(CM_Operator::code.name, _entityCode);						
		// Force-update the collection
		_cmifDebtor.allOperators.rebuild;
		pxyOperator.setDebtor(_realDebtorNode.CM_Debtor);
		app.myUtilityCA.utlCreateOperator(pxyOperator,null, realOperator, _passport);
		realObject := realOperator;
		
	elseif _pxyObject.isKindOf(CM_ShippingLine) then
		pxyShippingLine := _pxyObject.CM_ShippingLine;
		pxyShippingLine.setPropertyValue(CM_ShippingLine::code.name, _entityCode);						
		// Force-update the collection
		_cmifDebtor.allShippingLines.rebuild;
		pxyShippingLine.setDebtor(_realDebtorNode.CM_Debtor);
		app.myUtilityCA.utlCreateShippingLine(pxyShippingLine, realShippingLine, _passport);
		realObject := realShippingLine;
		
	elseif _pxyObject.isKindOf(CM_Stevedore) then
		pxyStevedore := _pxyObject.CM_Stevedore;
		pxyStevedore.setPropertyValue(CM_Stevedore::code.name, _entityCode);						
		// Force-update the collection
		_cmifDebtor.allStevedores.rebuild;
		pxyStevedore.setDebtor(_realDebtorNode.CM_Debtor);
		app.myUtilityCA.utlCreateStevedore(pxyStevedore, realStevedore, _passport);
		realObject := realStevedore;		
	endif;
	
	
	app.writeLog(method.qualifiedName &amp; "New related entity (code : "&amp;_entityCode&amp;") created", LogDEBUG);
	return realObject;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cmifDebtor" type="CMIF_DebtorNode" usage="input"/>
        <Parameter name="_realDebtorNode" type="CM_DebtorNode"/>
        <Parameter name="_pxyObject" type="CM_Object" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_entityCode" type="String"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getDebtorAlternativeAddress" id="2caa24c0-bfdc-4ecf-b967-045811063c5f">
        <source>getDebtorAlternativeAddress() : CMIF_Address;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2023	navra1	Initial creation for 57447

*/

vars
	address : CMIF_Address;
begin	
	
	foreach address in self.addresses discreteLock do
		if address.isAlternative then
			return address;
		endif;
	endforeach;
	
	return null ;
epilog

end;</source>
        <ReturnType type="CMIF_Address"/>
    </JadeMethod>
    <JadeMethod name="getDefaultDebtorAddress" id="2113e64c-42b3-4c83-be7a-70d17e9f1873">
