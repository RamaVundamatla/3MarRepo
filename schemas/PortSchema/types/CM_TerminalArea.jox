    <JadeMethod name="getYardAllocationsAsString" id="f69da8c1-d4b0-4dad-a725-819251050fca">
        <source>getYardAllocationsAsString():String;
/*
Date		Who		Reason
01 Nov 2012	cnwcs5	Initial creation - par 30475
*/
vars
	str : String;
	ya 	: CM_YardAllocation;
begin
	foreach ya in self.allYardAllocations where ya.includeInYardDisplays() do
		if str = null then
			str :=  ya.code; 
		else
			str := str &amp; "; " &amp; ya.code; 
		endif;		
	endforeach;

	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleAutoRestrictionsFrom" id="df16bd24-6a01-435f-b078-3df77f1e530b">
        <updating/>
        <source>handleAutoRestrictionsFrom(_moveController : CMIF_MoveController; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     01 July 2004	cnwth2
//
// Purpose:     Assumes the move is at the point where the TI is now in it's destination
//
//				IF self.doAutoRestrictions is turned off OR
//				   the from and to locations controllers are within the same terminal area then
//					do nothing 
//				ELSE
//					loop through all locations controllers testing emptyness AND TI not the one we're moving
//					if the TI is the LAST one remaining then
//						clear any existing restrictions and set the self.isEmpty flag to true
//					endif;
//				endif;
// ----------   ----------  --------------------------------------------------
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/10/2008	consw1		SFW1030 - Remove unused auto plan flags

vars
	origLC, lc	: CM_LocationsController;
	ya			: CM_YardAllocation;
begin

	if (not self.autoRestrictionsEnabled) or 
	   _moveController.moveMode &lt;&gt; REAL_MODE then
		return;
	endif;

	origLC := _moveController.myOriginatingLocation;
	
	if origLC = null or
	   origLC.myTerminalArea &lt;&gt; self then
		return;
	endif; 
	
	if (not origLC.allTrackedItems.isEmpty) then
		return;
	endif;
	
	//bail out at the first possible Opportunity 
	foreach lc in self.allLocationsControllers where lc &lt;&gt; origLC do
		if (not lc.allTrackedItemsById.isEmpty) then
			return;
		endif;
	endforeach;
	
	self.isEmpty := true;
	
	foreach ya in self.allYardAllocations where ya.includeInYardDisplays do
		app.removeAutoYardAllocation(self, ya);
	endforeach;
end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleAutoRestrictionsTo" id="e9ea432b-9c0b-4028-91bc-c5fc607476a4">
        <updating/>
        <source>handleAutoRestrictionsTo(_moveController : CMIF_MoveController; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     01 July 2004	cnwth2
//
// Purpose:     
//
//
//				IF (self.doAutoRestrictions is turned off) OR
//				   (the from and to locations controllers are within the same terminal area) THEN
//					do nothing 
//				ELSEIF (self.isEmpty = true and there are no existing restrictions) THEN
//					create a locationRestriction based on the TI's state and associate it with self;
//				ENDIF;
// ----------   ----------  --------------------------------------------------
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/10/2008	consw1		SFW1030 - Remove unused auto plan flags
// 07/11/2012	cnwcs5		par 30475 - remove location restriction
vars
	toLC				: CM_LocationsController;
	tmpTI				: CM_TrackedItem;
begin
	if not self.myTerminal.isAutoPlanningEnabled() then   //SFW1030 04/08/2008
		return;
	endif;
	
	if not self.autoRestrictionsEnabled then
		return;
	endif;
	
	
	tmpTI := _moveController.myTrackedItem;
	
	if tmpTI = null then
		return;
	endif;
	
	toLC := _moveController.myToPrimaryLocation;
	
	if toLC = null or toLC.myTerminalArea &lt;&gt; self then
		return;
	endif; 
	

	if (_moveController.moveMode &lt;&gt; REAL_MODE) or  (not self.isEmpty) or(self.allYardAllocations.hasActiveAllocations()) then
		return;
	endif;
	
	self.isEmpty := false;
	
	app.createAutomaticYardAllocation(self, tmpTI);
	
	self.causeEvent(self.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),false,self);
	self.causeEvent(self.myTerminal.getTerminalEvent(Event_TALocation_Create),false, null);	// par 30675
end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="hasAccessFull" id="7d3a113d-dea2-442b-93f9-6ac84870a966">
