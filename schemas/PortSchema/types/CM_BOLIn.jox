    <JadeMethod name="setProxyDocketReconcile" id="4dcac3a2-52d0-4bd5-a341-33fc393b39fb">
        <updating/>
        <source>setProxyDocketReconcile(_docketNumber : String; _numItems : Integer) updating;
// -----------------------------------------------------------------------------
// Created:		05 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 29 Nov 2013	cnwkpd1	PAR #33107 - Docket number changes corrupting dictionary keys
// -----------------------------------------------------------------------------
begin

	exclusiveLock(self);
	
	if self.number &lt;&gt; _docketNumber then
//		self.number := _docketNumber;			// PAR #33107
		self.setNumber(_docketNumber);	
	endif;
	
	self.numItems	:= _numItems;

end;</source>
        <Parameter name="_docketNumber" type="String"/>
        <Parameter name="_numItems" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromEDI" id="f6536ac2-4caa-49c0-b02e-0824624cec22">
        <updating/>
        <source>setProxyFromEDI(_ediTI : CM_EDIBOLHdrTI) updating;
//
// ccms1008 1056 cnwrs1 Jan 2010
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------------
// 25/11/2013	cnwdap1		PAR #33019 CMS DPH 2285 New BOL Fields
// 29 Nov 2013	cnwkpd1		PAR #33107 - Docket number changes corrupting dictionary keys
// 09/09/2015   cnwma1      PAR #36797 Can't create BOL via EDI
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 

vars

begin
//	self.number := _ediTI.id[ 1 : CM_BOLIn::number.getLengthForString() ];	// cnwrl1 16/03/2010 PAR 23186 - what it was
//	self.number := _ediTI.id;
	self.setNumber(_ediTI.id);				// PAR #33107
	self.bolType := _ediTI.bolType;
	self.carrierCode := _ediTI.carrierCode;
	self.dateTime := app.serverTimestampAtTrxStart;
	self.destinationPort := _ediTI.destinationPort;
	self.setDirectDelivery( false );	//29 Jan 2013	NDL	Par 31102
	self.dischargePort := _ediTI.dischargePort;
	self.loadPortCode := _ediTI.loadPort;
	self.notifyParty := _ediTI.notifyParty;
	
	//cnwmc5 - 23 July 2014 - CCMS 2353 PEN
	//NOTE: numItems is being used as the CUSTOMS number of items entered, NOT as the traditional numItems on the BOL
	//self.numItems := _ediTI.numItems;
	self.numItems := self.numItems + _ediTI.allDetails.size;
	self.customsQuantityEntered := _ediTI.numItems;
	self.customsQuantityReleased := 0;
	
	self.myOperator := app.myRoot.allOperators[_ediTI.operatorCode];
//	self.vehicle := _ediTI.regNumber;
	self.remarks := _ediTI.remarks;
	self.transportMode := app.transModeToCode(_ediTI.transportMode);
	self.myReceivalTerminal := _ediTI.getMyTerminal();
	if _ediTI.subTerminalCode = null then
		self.mySubTerminal := self.myTerminal.getConfig(MySubTerminalForBOLIn).CM_SubTerminal;
	else
		self.mySubTerminal := self.myTerminal.allSubTerminals[_ediTI.subTerminalCode];
	endif;
//	if _ediTI.voyageCode &lt;&gt; null and 			// cnwrl1 09/06/2010 PAR 24299 - what it was
	if _ediTI.getVoyageCode() &lt;&gt; null and 
	   self.myTerminal &lt;&gt; null then
//		self.myVoyage := self.myTerminal.lookupVoyage(_ediTI.voyageCode, null, false);	// cnwrl1 09/06/2010 PAR 24299 - what it was
		self.myVoyage := self.myTerminal.lookupVoyage(_ediTI.getVoyageCode(), null, false);
	endif;
	
	self.clientRef1 := _ediTI.getServiceOrderNbr;			// PAR #33019
	self.clientRef2 := _ediTI.getPONbr;						// PAR #33019
	self.vehicle := _ediTI.getVehicle;						// PAR #36797
end;
</source>
        <Parameter name="_ediTI" type="CM_EDIBOLHdrTI"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromCMIF_BOL" id="55d83ebb-47ec-4ad4-8053-f55db4bf82a5">
        <updating/>
        <source>setPxyFromCMIF_BOL(_intFace: CMIF_BOLIn; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 09 July 2002 By: cnwsb1
//--------------------------------------------------------------
vars
	
begin
	inheritMethod(_intFace, _passport);	
	
	// NB: allTrackedItems can contain a mixture of proxies and persistents
	if self.bolType &lt;&gt; BOLType_Log then	
		self.setTIsForCreateGeneralDocket(_intFace.allTrackedItems, _passport);
	endif;
	
	self.opid := _intFace.opid;
	//self.loggingOrganisation	:= _intFace.loggingOrganisation; //#cnwdz2	 CCMS 1108 par22177 
	self.setLoggingOrganisation(_intFace.loggingOrganisation);
	self.loggingOperation		:= _intFace.loggingOperation;
	self.unloadPoint			:= _intFace.unloadPoint;
	if _intFace.myVoyage &lt;&gt; null then
		self.myVoyage 			:= _intFace.myVoyage;
	elseif _intFace.voyageCode &lt;&gt; null and _intFace.myTerminal &lt;&gt; null then
		self.myVoyage 			:= _intFace.myTerminal.lookupVoyage (_intFace.voyageCode, null, false);
	endif;
		
	// CCMS1089. Docket Correction - Log Docket has been matched today. We can edit it today still.
	if self.isMatchedTodayForDocketCorrect() and not _intFace.updateFromBolInXML then //cnwrd1 par 29841 ccms 1121 
		self.origLocationControllerId 	:= null;
		self.origTerminalAreaId 		:= null;
		self.setOrigLocation();
	endif;

	// managing docket errors in the CM_BOLIn 	// #24818 01/07/2010
	if not self.allDocketErrors.isEmpty() then
		self.allDocketErrors.clear;
	endif;
	_intFace.allDocketErrors.copy(self.allDocketErrors);

	
end;</source>
        <Parameter name="_intFace" type="CMIF_BOLIn"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTIsForCreateGeneralDocket" id="62949e12-9bed-426c-901d-63f3bd6ec276">
        <updating/>
        <source>setTIsForCreateGeneralDocket(_tiDict: CM_TISet; _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	11 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	realTI,
	pxyTI : CM_TrackedItem;
begin
	foreach pxyTI in _tiDict do
		if pxyTI.isTransient and (not self.isTransient) then
			//Create a persistent version of the proxy object
			realTI := self.myTerminal.createTrackedItem(pxyTI, _passport);
		else
			realTI := pxyTI;	//Just attach the passed in object
		endif;
		self.attachTI(realTI);
	endforeach;

end;</source>
        <Parameter name="_tiDict" type="CM_TISet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTIsForUpdateGeneralCargo" id="ef24de0a-c139-4545-8296-1d307a092b76">
        <updating/>
        <source>setTIsForUpdateGeneralCargo(_cmifBOLIn: CMIF_BOLIn; _passport : CM_Passport input) updating, protected;
//----------------------------------------------------------------
//	Created:	12 April 2006	by Jason Chapman  (cnwjc2)
//
//	Only call this from setForUpdateGeneralDocket
//----------------------------------------------------------------
vars
	deleteTIs,
	origTIs		: CM_TIByCargoTypeIdDict;
	realTI,
	proxyTI		: CM_TrackedItem;
	expectedEdition,
	idx,
	arraySize	: Integer;
	tiUpdateCntrlr : CMIF_TIUpdateController;
	attach		: CMIF_InOutAttachment;
	cmif		: CMIF_TIObject;
	moveController	: CMIF_MoveController;
begin

	create deleteTIs transient;
	create origTIs transient;

	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	
	self.allTrackedItems.copy(origTIs);
	
	foreach realTI in origTIs do
		exclusiveLock(realTI);
		if realTI.state = TI_STATE_NOTIFIED then
			deleteTIs.add(realTI);
		endif;
	endforeach;

	// as notified items are not on the terminal just erase and recreate the kids
	while deleteTIs.size &gt; 0 do
		realTI := deleteTIs.last;
		deleteTIs.remove(realTI);
		realTI.erase(NORMAL_ERASE);
	endwhile;

	create moveController transient;
	moveController.setMoveMode(REAL_MODE);
	moveController.setJobForMove(self.myYardJob);		
	moveController.isSystemMove := true;

	foreach cmif in _cmifBOLIn.allSubItems do
		attach := cmif.CMIF_InOutAttachment;
		proxyTI := attach.myProxyTrackedItem;
		if proxyTI.isTransient and (not self.isTransient) then
			// If this is an issue then need to set this elsewhere - rjs
			//proxyTI.setPropertyValue("isValid", true);
			realTI := null;
			proxyTI.pxyGetRealObjectAndEdition(realTI, expectedEdition);
			if realTI = null then
				//validate proxyTI 
				realTI := self.myTerminal.createTrackedItem(proxyTI, _passport);
			else
				//Update the child object
				realTI.setForUpdate(proxyTI, tiUpdateCntrlr, null, true, _passport); //cnwrd1 28.8.09 par 20545
			endif;
		else		//'Proxy' child is real object
			realTI := proxyTI;	//Just attach the passed in object
		endif;
		
		//move it
		self.attachTI(realTI);
		
		if realTI.myPrimaryActualLocation = attach.myLocationsController then
			continue;
		endif;
		
		moveController.setMyToPrimaryLocation(attach.myLocationsController);
		moveController.setMyTrackedItem(realTI);		
		//firstTime := false;
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	endforeach;

epilog
	delete moveController;
	delete origTIs;
	delete deleteTIs;
	delete tiUpdateCntrlr;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifBOLIn" type="CMIF_BOLIn"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="d9a91fdc-6c14-400f-8e5f-49dc57299de3">
        <source>showThumbnailData(pHeadings: HugeStringArray input; pData: HugeStringArray input; _terminal : CM_Terminal);
//--------------------------------------------------------------
//Created: 23 January 2002 By: cnwgd1
//--------------------------------------------------------------
// DATE 				WHO 		REASON
// 28 July 2022 		navvt20 	Bug 54199: EUP - Tables with Operator/Stevedore not adhering to the configuration
begin
	pHeadings.clear();
	pData.clear();
	
	//+cnwml2 PAR22842
	if self.bolType = BOLType_GeneralDocket then
		pHeadings.add('Docket Created Date');
		pData.add(self.systemToLocalTime(self.dateTime).date.shortFormatJMT());	// 27/4/16 cnwmp6 TFS 488 - Multi timezone support
		
		pHeadings.add('Docket Match Date');
		pData.add(self.systemToLocalTime(self.matchTime).date.shortFormatJMT());	// 27/4/16 cnwmp6 TFS 488 - Multi timezone support
	else
		if self.bolType = BOLType_GeneralBillOfLading then
			pHeadings.add('BOL Created Date');
			pData.add(self.systemToLocalTime(self.dateTime).date.shortFormatJMT());	// 27/4/16 cnwmp6 TFS 488 - Multi timezone support
			
			pHeadings.add('BOL Match Date');
			pData.add(self.systemToLocalTime(self.matchTime).date.shortFormatJMT());	// 27/4/16 cnwmp6 TFS 488 - Multi timezone support
		elseif self.bolType = BOLType_Log then
			pHeadings.add('Docket Created Date');
			pData.add(self.systemToLocalTime(self.dateTime).date.shortFormatJMT());	// 27/4/16 cnwmp6 TFS 488 - Multi timezone support
			
			pHeadings.add('Docket Match Date');
			pData.add(self.systemToLocalTime(self.matchTime).date.shortFormatJMT());	// 27/4/16 cnwmp6 TFS 488 - Multi timezone support
		endif;
		
		//+cnwml2 MSL CCMS 1071 start
		pHeadings.add(app.getString(Voyage));
		if self.myVoyage &lt;&gt; null then
			pData.add(self.myVoyage.code);
		else
			pData.add(null);
		endif;
		
		pHeadings.add(app.getString(Operator));
		if self.myOperator &lt;&gt; null then
			//pData.add(self.myOperator.code);			// 28.07.2022 navvt20 TFS 54199
		    // START 28 JULY 2022 navvt20 TFS 54199
			if app.myRoot.getConfig(ComboByNameOperator).Boolean then
				pData.add(self.myOperator.description);
			else
				pData.add(self.myOperator.code);
			endif;
			// END 28 JULY 2022 navvt20 TFS 54199
		else
			pData.add(null);
		endif;	
		
		pHeadings.add(app.getString(Status));
		if self.status &lt;&gt; null then
			pData.add(self.statusDescription);
		else
			pData.add(null);
		endif;
		
		pHeadings.add(app.getString(Reconciled));
		if self.reconciledDate &lt;&gt; null then
			pData.add(app.getString(Yes));
		else
			pData.add(app.getString(No));
		endif;
		
		pHeadings.add(app.getString(Received));
		pData.add(self.allTrackedItems.size.asStringJMT());
		//+cnwml2 MSL CCMS 1071 end
	
		if self.myExtension &lt;&gt; null then
			self.myExtension.showThumbnailData(pHeadings, pData, _terminal);
		endif;
	endif;
end;</source>
        <Parameter name="pHeadings" type="HugeStringArray" usage="input"/>
        <Parameter name="pData" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="unloadPoint" id="50e7e2b9-4f2b-49a4-988f-6e66b8b6062f">
        <methodInvocation>mapping</methodInvocation>
        <source>unloadPoint(set: Boolean; _value: String io) mapping;

// cnwdvb1 22 November 2002 

vars

begin

	if set then
		global.setExtraData(self.allExtraData, self, BOL_ExtraData_UnloadPoint, _value);
		if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
			self.updateObjectEdition(self);	//14 Jan 2014	NDL	Par 33264
		endif;
	else
		global.getExtraData(self.allExtraData, BOL_ExtraData_UnloadPoint, _value);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateTIsFromBOL" id="a5ae0463-acdc-48a9-be31-a9d621004a15">
        <updating/>
        <source>updateTIsFromBOL(_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 23 May 2002 By: cnwgd1
//--------------------------------------------------------------

vars

begin

	if self.myExtension = null then
		return;
	endif;

	if self.numTIs &gt; 0 then
		self.myExtension.updateTIsFromBOL(_passport);
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateBOLNumber" id="8a030a37-3ffe-4f0f-bf60-2cb0616bed5e">
        <source>validateBOLNumber(pControl: CMIF_TIUpdateController);
//--------------------------------------------------
// Created:	24 March 2006 By: cnwgd1
//--------------------------------------------------
vars
	realBOL	: CM_BOL;
begin
	
	// Method added as a temp fix for PASHA, the dict should probably be changed??
	
	if self.transportMode = TI_TRANSMODE_SHIP then
		if self.isTransient then
			realBOL := self.pxyGetRealObject();
			if realBOL &lt;&gt; null and realBOL.number = self.number then
			//This is an update and the number has not changed, so nothing to do here
				return;
			endif;
		endif;	
		// it's coming in by boat
		if self.myVoyage &lt;&gt; null then
			if self.myVoyage.allBOLInByTypeStatusNumDT.includesKey(self.bolType, self.status, self.number, self.dateTime) then
				//app.raiseCMException2(DuplicateItem, bolTypeDesc &amp; ' ', self.number, null, null);		//13.07.2022 navsrk20 53760
				app.raiseCMException2(Bol_already_exists, bolTypeDesc, self.number, null, null);		//13.07.2022 navsrk20 53760
			endif;
		endif;
	else
		inheritMethod(pControl);
	endif;
end;</source>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="edfd2c96-e33d-4627-8a1f-dbf3ff6d7aff">
        <source>validateForCreate(pControl: CMIF_TIUpdateController input; _headerOnly: Boolean; _passport: CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(pControl, _headerOnly, _passport);

	if self.bolType = BOLType_Log then
		self.validateLoggingOrgCreate();
	endif;
end;</source>
        <Parameter name="pControl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_headerOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForCreateCusCar" id="5feb5b42-9fb1-403c-be16-ff19ce8d0321">
