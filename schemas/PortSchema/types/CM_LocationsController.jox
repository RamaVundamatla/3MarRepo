    <JadeMethod name="getAllTIToBeOfMode" id="ea063e07-25cb-4c28-bc66-822f2e870c5b">
        <source>getAllTIToBeOfMode(_mode : Integer; _otherTIs : CM_TISet input; _otherWLEs : CM_WLESet input; _isLoad : Boolean) ;
/*
Purpose:			
Date		Who		Reason
21 September 2011	cnwab1	Initial creation
*/

vars
	aTI : CM_TrackedItem;
	aWLE : CM_WorkListEntry;
begin
	if _otherTIs = null then
		return;
	endif;
	
	foreach aTI in self.allTrackedItems discreteLock do
		
		aWLE := aTI.getVoyageWLEUnactioned(_isLoad);
		
		if _mode = PLANNING_MODE then
			if aTI.myPrimaryPlannedLocation = null 
			and aWLE &lt;&gt; null // has colour coding
			then
				_otherTIs.add(aTI);
				_otherWLEs.add(aWLE);
			endif;
		elseif _mode = QUEUE_MODE then
			if aTI.myPrimaryQueuedLocation = null
			and aWLE &lt;&gt; null // has colour coding
			then			
				_otherTIs.add(aTI);
				_otherWLEs.add(aWLE);
			endif;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_otherTIs" type="CM_TISet" usage="input"/>
        <Parameter name="_otherWLEs" type="CM_WLESet" usage="input"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
