    <JadeMethod name="validateForCreate" id="30b72a7e-a719-4a51-b478-0d252008e3ae">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.validateForUpdate();		// cnwrl1 06/11/2009 PAR 19278
	
	/* cnwrl1 06/11/2009 PAR 19278 - what it was
	if self.myFinancialPeriodEnd.allFinancialPeriodEndDates[self.dateTime] &lt;&gt; null then
		app.raiseCMException3(ERR_DUPLICATE_KEY,"Financial Period Date", self.dateTime.String,"It must be unique for financial period " &amp; self.myFinancialPeriodEnd.description, null,null);
	endif;
	cnwrl1 06/11/2009 PAR 19278 - what it was */
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="0dd4021b-ac4c-4a8f-ac0d-24159cbd1e01">
