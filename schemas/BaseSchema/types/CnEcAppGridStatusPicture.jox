    <DbClassMap file="_usergui"/>
    <JadeMethod name="click" id="64f73372-7e77-4167-a1de-7410c747e174">
        <updating/>
        <source>click(pict: CnEcAppGridStatusPicture input) updating;

vars

begin
	// If in print preview mode ...
	if app.printer.printPreview then
		// ...disable event handling
		return;
	endif;
	inheritMethod(pict);
	parent.CnEcAppGridStatusLabel.click(parent.CnEcAppGridStatusLabel);
end;</source>
        <Parameter name="pict" type="CnEcAppGridStatusPicture" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="9ab2cfdf-34cf-498d-920d-5ba6073281b4">
        <updating/>
        <source>create() updating;

begin
	borderStyle := Window.BorderStyle_None;
	visible := false;
end;</source>
    </JadeMethod>
