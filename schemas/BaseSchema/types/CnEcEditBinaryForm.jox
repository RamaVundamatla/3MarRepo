    <ImplicitInverseRef name="btnCancel" id="57a470ee-3f32-43df-8ddb-1d15499a47bf">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnOk" id="181365ba-2419-4474-b48a-1babc994c57f">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="line3D1" id="2653d2da-a285-402e-936b-b119c07e35ec">
        <embedded/>
        <type name="CnEcLine3D"/>
    </ImplicitInverseRef>
    <PrimAttribute name="loadBinary" id="73351103-dbdd-4a45-a219-c4ea623a7963">
        <embedded/>
        <type name="Boolean"/>
        <access>protected</access>
    </PrimAttribute>
    <ImplicitInverseRef name="optEdit" id="6c504071-633c-4474-998b-8a7fc7d3ed1f">
        <embedded/>
        <type name="OptionButton"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="optLoad" id="ab325014-1b6e-4ae5-9012-711379dd1c03">
        <embedded/>
        <type name="OptionButton"/>
    </ImplicitInverseRef>
    <JadeMethod name="btnCancel_click" id="b4849db7-4037-40ee-92a3-c060d1c630d5">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		06 February 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.modalResult	:=	0;
	unloadForm();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="c86faae5-5013-4970-b6e7-116ef0c6cd87">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		06 February 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.statusMsg('Editing binary data...');

	if self.formValidate() then
		self.formUpdate();
		self.modalResult	:=	1;
		unloadForm();
	endif;
epilog
	self.statusMsg('');
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="formLoad" id="9086fee9-0b28-47eb-b6df-1d6e77ab840c">
        <updating/>
        <source>formLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	optEdit.enabled		:=	true;
	optLoad.value		:=	true;
	self.modalResult	:=	0;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="formUpdate" id="f1d0aef5-e10d-4ed0-8d6d-39ede2af24b2">
        <updating/>
        <source>formUpdate() updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		Standard form update method.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if optLoad.value then
		self.loadBinary	:=	true;	// want to load binary data from a file.
	else
		self.loadBinary	:=	false;	// want to edit binary data instead.
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getLoadBinary" id="ab309f9e-f388-46b2-8f78-b8a77c6bb213">
        <source>getLoadBinary() : Boolean;
// --------------------------------------------------------------------------------
// Created:		06 February 1999 by cnwdad1
//
// Purpose:		Sets a flag to indicate whether the binary data must be loaded from
//				a disk file.
//
// Parameters:	None
// Returns:		True if the binary must be read from disk, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.loadBinary;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="load" id="5d933963-ec75-4dc4-8297-0b03938f0341">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		06 February 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	centreWindow();
	self.formLoad();
epilog
	self.statusMsg("");
end;</source>
    </JadeMethod>
</GUIClass>
