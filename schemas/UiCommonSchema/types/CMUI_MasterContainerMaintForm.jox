    <JadeMethod name="setForReefer" id="1977f4a8-65b1-4c59-be4e-447e046404f6">
        <source>setForReefer(_isReefer : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 August 2008	cnwrd1	Initial creation
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
*/

vars

begin

	self.grpReefer.visible :=  _isReefer;
	
	self.cmbGenerator.visible := _isReefer; //27.02.2018 cnwma1 ChangeRequest #36813
	self.lblGenerator.visible := _isReefer; //27.02.2018 cnwma1 ChangeRequest #36813
	if _isReefer = false then
		self.chkCommunicating.value := false;
		self.cmbCoolingType.text := '';
		self.cmbVoltageType.text := '';
		self.cmbGenerator.text   := '';   //27.02.2018 cnwma1 ChangeRequest #36813
	endif;

epilog

end;</source>
        <Parameter name="_isReefer" type="Boolean"/>
    </JadeMethod>
