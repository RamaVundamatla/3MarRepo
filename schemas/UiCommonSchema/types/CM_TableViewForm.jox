        <source>doTblDataSearch(_searchStr : String) updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theObject	: Object;
	startRow,
	endRow,
	tmpCol,
	idx			: Integer;

begin

	if _searchStr = null then
		return;
	endif;

	theObject := self.tblData.doSearch(_searchStr, self.columnForTblDataSearch);

	if theObject &lt;&gt; null then
		self.zShowThumbnailData(theObject);
	endif;

end;</source>
