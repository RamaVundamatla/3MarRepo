/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2016	cnwndl1	Initial creation	TFS 2843 / 2604
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
*/

vars

begin

	_types.add(CM_EDICargoOnSiteTI);
	_types.add(CM_EDIHazDetailsTI);
	_types.add(CM_EDISealTI);

epilog

end;</source>
        <Parameter name="_types" type="ClassColl" usage="input"/>
