    <JadeMethod name="getDetailLine" id="f0ec63a6-c2f9-4952-948a-738dd1056954">
        <source>getDetailLine():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2021	navndl1	Initial creation	TFS 

*/

vars

begin

	return 	self.time.String &amp; Tab &amp;
			self.elapsedSecs.String &amp; Tab &amp; 
		//	self.cpuSecs.String &amp; Tab &amp;
			self.methodName &amp; Tab &amp; 
			self.computerName &amp; Tab &amp; 
			self.appName &amp; Tab &amp; 
			self.userName;


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHeaderLine" id="e6874bc6-5848-4b7b-ba32-8ea343f62ab1">
        <options>4</options>
        <source>getHeaderLine():String typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2021	navndl1	Initial creation	TFS 

*/

vars

begin

	return 	"Time" &amp; Tab &amp;
			"Elapsed" &amp; Tab &amp; 
		//	"CPU" &amp; Tab &amp;
			"Method" &amp; Tab &amp; 
			"Computer" &amp; Tab &amp;
			"App Name" &amp; Tab &amp;
			"User Name";


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="populateFromTranlogLine" id="8e7fce25-2bb7-4c31-9957-47133732df32">
        <updating/>
        <source>populateFromTranlogLine( _line : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2021	navndl1	Initial creation	TFS 

*/

vars

	strArray : CnStringArray;

	dateStr : String;//Date	1
	timeStr : String;//Time	2
	//Computer	3
	//Server	4
	//IP Address	5	
	//App Name	6
	//User	7
	//Tran Id	8	
	//Elapsed (msecs)	9	
	//CPU (msecs)	10	
	//DB Tran Id	11
	//Proc Id	12
	//Error?	13
	//GetObjs	14
	//LockObjs	15
	//Unlocks	16
	//Creates	17
	//Updates	18
	//Deletes	19
	//Commits	20
	//Events	21
	//Server Executions		22
	//Server Execution Time	23	
	//LockQ Time	24
	//TC AppServer Msgs	25	
	//TC AppServer Bytes	26
	//TC Client Msgs	27
	//TC Client Bytes	28
	//TC Net Time	29
	//Perceived Response	30	
	//Level	31

begin

	strArray := _line.cnGetTokens(",");
	
	if strArray &lt;&gt; null then
		dateStr := strArray[1];
		timeStr := strArray[2];
		
		self.date.setDate( dateStr[7:2].Integer, dateStr[5:2].Integer, dateStr[1:4].Integer);//Date	1
		self.time.setTime(  timeStr[1:2].Integer, timeStr[3:2].Integer, timeStr[5:2].Integer, 0 );//Time	2
		self.computerName := strArray[3];	//Computer	3
		self.serverName := strArray[4];	//Server	4
		self.ipAddress := strArray[5];	//IP Address	5	
		self.appName := strArray[6];	//App Name	6
		self.userName := strArray[7]; //User	7
		self.methodName := strArray[8]; //Tran Id	8	
		self.elapsedSecs := strArray[9].Integer / 1000;	//Elapsed (secs)	9	
		self.cpuSecs := strArray[10].Integer / 1000;	//CPU (msecs)	10	
		self.dbTranId := strArray[11].Integer64;	//DB Tran Id	11
		self.procId := strArray[12].Integer;	//Proc Id	12
		//xxx := strArray[13];	//Error?	13
		self.getObjs := strArray[14].Integer;	//GetObjs	14
		self.lockObjs := strArray[15].Integer;	//LockObjs	15
		self.unlocks := strArray[16].Integer;	//Unlocks	16
		self.creates := strArray[17].Integer;	//Creates	17
		self.updates := strArray[18].Integer;	//Updates	18
		self.deletes := strArray[19].Integer;	//Deletes	19
		self.commits := strArray[20].Integer;	//Commits	20
		self.events := strArray[21].Integer;	//Events	21
		//xxx := strArray[22];	//Server Executions		22
		//xxx := strArray[23];	//Server Execution Time	23	
		//xxx := strArray[24];	//LockQ Time	24
		//xxx := strArray[25];	//TC AppServer Msgs	25	
		//xxx := strArray[26];	//TC AppServer Bytes	26
		//xxx := strArray[27];	//TC Client Msgs	27
		//xxx := strArray[28];	//TC Client Bytes	28
		//xxx := strArray[29];	//TC Net Time	29
		//xxx := strArray[30];	//Perceived Response	30	
		//xxx := strArray[31];	//Level	31
	endif;
		
epilog

	delete strArray;

end;</source>
        <Parameter name="_line" type="String"/>
    </JadeMethod>
    <JadeMethod name="writeLine" id="fb30117a-5b95-484e-9dac-87b808e86f11">
        <source>writeLine();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2021	navndl1	Initial creation	TFS 

*/

vars

begin

	write self.time.String &amp; Tab &amp; self.elapsedSecs.String &amp; Tab &amp; self.methodName &amp; Tab &amp; self.computerName &amp; "/" &amp; self.appName &amp; "/" &amp; self.userName;

epilog

end;</source>
    </JadeMethod>
</Class>
