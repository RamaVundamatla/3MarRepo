    <JadeMethod name="camsRunAdhoc" id="0e3790cd-f66e-4182-b6e9-54edd40572b8">
        <source>camsRunAdhoc();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 13 March 2023	navdap1		Initial creation TFS 
//
constants
	//CAMProtocol : String = "STW_CAms_receiveShip";
	//CAMProtocol : String = "Suzano Delivery Confirmation";
	CAMProtocol : String = "CMA CODECO - 33356";
	/*StartDate	: Date = '20/10/2023'.Date;// setup start and end dates/time and protocol to use
	EndDate1	: Date = '20/10/2023'.Date;
	StartTime	: Time = '13:00:00:000'.Time;
	EndTime		: Time = '15:00:00:000'.Time;*/
	StartDate	: Date = '05/02/2025'.Date;// setup start and end dates/time and protocol to use
	EndDate1	: Date = '05/02/2025'.Date;
	StartTime	: Time = '22:30:00:000'.Time;
	EndTime		: Time = '22:35:00:000'.Time;
	//Terminal1	: String = 'SPT';
	Terminal1	: String = 'DAVE';
vars
	camProtocol		: CM_CamProtocol;
	runDateTime		: TimeStamp;
	startDateTime	: TimeStamp;
	endDateTime		: TimeStamp;
	valDate			: Date;
	valTime			: Time;
	terminal		: CM_Terminal;
	camsController : CM_CamControllerAgent;
begin
	app.initialize();
	app.changeLogLevel(LogDEBUG);
	// setup start and end dates/time and protocol to use
	valDate := StartDate;
	valTime := StartTime;
	startDateTime.setDate(valDate);
	startDateTime.setTime(valTime);
	if not startDateTime.isValid() then
		write 'startDateTime is not valid';
		return;
	endif;
	
	valDate := EndDate1;
	valTime := EndTime;
	endDateTime.setDate(valDate);
	endDateTime.setTime(valTime);
	if not endDateTime.isValid() then
		write 'endDateTime is not valid';
		return;
	endif;
	
	runDateTime := app.actualTimeServer;
	app.hideDebug	:= false;			// false implies do not hide debugging - helps with display messages
	terminal		:= app.myRoot.allTerminals[Terminal1];
	if terminal = null then
		app.writeStatement('Can not find required terminal ' &amp; Terminal1);
		return;
	endif;
	app.myPassport.setMyTerminal(terminal);
	
	camProtocol := terminal.camProtocols[CAMProtocol];
	if camProtocol = null then
		app.writeStatement("Cannot find required cam protocol description");
		return;
	endif;
	
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	
	on Exception do null global;
	
	app.setPassBackExceptions(true, true);
	create camsController transient;
	camsController.setMyTerminal(terminal);
	camsController.adhocTask(camProtocol, startDateTime, endDateTime, runDateTime, true, true);	//this does runs the adhoc cams
epilog
	delete camsController;
end;</source>
    </JadeMethod>
    <JadeMethod name="camsRunNotAdhoc" id="a7468268-ebdc-4736-999b-29965196cd48">
        <source>camsRunNotAdhoc();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12 September 2023	navdap1		Initial creation TFS 
//
constants
	Terminal1 : String = 'DAVE';
vars
	terminal : CM_Terminal;
	bgpRequest : BGP_CamsRequest;
begin
	app.initialize;
	terminal := app.myRoot.allTerminals[Terminal1];
	if terminal = null then
		app.writeStatement('Can not find required terminal ' &amp; Terminal1);
		return;
	endif;
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	app.changeLogLevel(LogDEBUG);
	create bgpRequest transient;
	bgpRequest.setPropertyValue(BGP_CamsRequest::myTerminal.name, terminal);
	bgpRequest.setPropertyValue(BGP_CamsRequest::myUser.name, app.myPassport.myUser);
	bgpRequest.action();
epilog
	delete bgpRequest;
end;</source>
    </JadeMethod>
    <JadeMethod name="casting" id="2f07d49c-9645-4451-99e0-45ff219367ee">
        <source>casting();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22 February 2024	navdap1		Initial creation TFS 
//
vars
	intString, numberString, numberIntString, todayString, nowString : String;
	number : Decimal [12,4];
	int : Integer;
	today : Date;
	now : TimeStamp;
	
begin
	number := 1234.56;
	int := 9876;
	// today and now are initialised to "now" by default
	
	intString := int.String;
	numberString := number.String;
	numberIntString := number.Integer.String;
	write numberString &amp; Tab &amp; number.String;
	write intString &amp; Tab &amp; numberIntString &amp; Tab;
	
	todayString := today.String;
	nowString := now.String;
	write todayString &amp; Tab &amp; nowString;
end;</source>
    </JadeMethod>
    <JadeMethod name="casting2" id="0a3306ea-6bf9-4c91-b874-83741871d1ea">
        <source>casting2();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22 February 2024	navdap1		Initial creation TFS 
//
vars
	release : CM_BulkRelease;
	detail : CM_ReserveDetail;
begin
	release := app.myPassport.myTerminal.allBulkReleasesByCodeDate.getAtKeyGeq("RELEASE", null);
	foreach detail in release.allReserveDetails do 				// have to use CM_ReserveDetail at this level
		if detail.isReserveSelection() then
			write detail.CM_ReserveSelection.colour;			// this attribute only exists at CM_ReserveSelection level
		else
			write detail.CM_ReserveTI.anyAmtAnyIdAllowedAmount;	// this attribute only exists at CM_ReserveTI level
		endif;
		write detail.cargoMatchVesselCode;						// this attribute exists at CM_ReserveDetail level
	endforeach;													// so is available to both subclass types without typecasting
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="checkBinStuff" id="2a2a9589-30dd-43eb-83b9-532eaaa4847b">
        <source>checkBinStuff();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 26 April 2023	navdap1		Initial creation TFS 
//
vars
	classId    : Integer;
	instanceId : Integer;
	bin        : Binary[6];

begin
	classId    := 2367;
	instanceId := 14672743;

	if classId = null then
		return;
	endif;
		
	bin := classId.asBinary(2) &amp; instanceId.asBinary(4);
	write bin;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="countPins" id="3000241a-e161-4df9-afe1-5fcecca7b02c">
        <source>countPins();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23 January 2024	navdap1		Initial creation TFS 
//
vars
	pin : CM_PinNo;
	terminal : CM_Terminal;
	months : StringArray;
	counts : IntegerArray;
	month : String;
	idx : Integer;

begin
	app.initialize;
	terminal := app.myRoot.allTerminals["UT"];
	if terminal = null then
		write "No UT Terminal";
		return;
	endif;
	
	create months transient;
	create counts transient;
	
	foreach pin in terminal.allPinNos discreteLock do
		month := pin.created.date.monthName &amp; pin.created.date.year.String;
		idx := months.indexOf(month);
		if idx = null then
			months.add(month);
			idx := months.indexOf(month);
		endif;
		if idx &gt; counts.size then
			counts.atPut(idx, null);
		endif;
		counts[idx] := counts[idx] + 1;
	endforeach;
	
	foreach idx in 1 to months.size do
		write months[idx] &amp; Tab &amp; counts[idx].String;
	endforeach;
epilog
	delete months;
	delete counts;
end;</source>
    </JadeMethod>
    <JadeMethod name="createRoadTransportManifest" id="c4f463c6-5141-4271-b207-8ec8f489656e">
        <source>createRoadTransportManifest();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23 July 2025	navdap1		Initial creation TFS 
//
constants
	NumberOfItemsToCreate : Integer = 2000;
	CargoIdBase : String = "TRX";
	CargoGroupBase : String = "CGR";
	ExternalRef : String = "EXTREF-5";
	DifferentCargoGroups : Boolean = false;
	Header : String = '{
  "Header": {
    "Sender": "TAP",
    "Receiver": "EBTA",
    "Date": "2024-10-10T00:25:12",
    "Type": "Manifest",
    "Status": "Create",
    "Number": "241010-001",
    "Id": "a976df20-dc69-4ef1-943d-aa9165789cf8",
    "HeaderReferences": {
      "HeaderReference": [
        {
          "ReferenceName": "ReferenceCustomer",
          "ReferenceValue": "355427"
        },
        {
          "ReferenceName": "ReferenceInternal",
          "ReferenceValue": "INT241010001"
        }
      ]
    }
  },
';
	Transports : String = '  "Transports": {
    "Transport": [
      {
        "TransportationMode": "Road",
        "EstimatedDateTimeOfArrival": "2024-10-10T08:00:00+2:00",
        "CarrierParty": {
          "Code": "MYTTONS",
          "Name": "Myttons Carriers"
        },
        "TruckInfo": {
          "TransportReferenceCustomer": "' &amp; ExternalRef &amp; '",
          "TansportReferenceInternal": "INTREF"
        },
        "Goods": {
          "Good": [';
	Goods1 : String = '{
              "MovementType": "Import",
              "GoodsOwner": {
                "Code": "APL",
                "Name": "Tim Pettus Operator"
              },
              "ID": "1",
              "KeyMarks": "';
	Goods2 : String = '",
              "Reference": "TAP",
              "MillOrderNumber": "M575145",
              "MillOrderLineNumber": "1",
              "Remarks": "Test for NTO-808",
              "Width": 1000.0,
              "Length": null,
              "Diameter": 1250.0,
              "LengthUOM": "Millimeter",
              "Grammage": 50.0,
              "PiecesPerPack": 1,
              "Type": "Break-Bulk",
              "CargoType": "STEEL",
              "PackageType": "UNITS",
              "Quality": "COIL",
              "QuantityExpected": 50,
              "GrossWeightExpected": 20250.0,
              "NettWeightExpected": 20194.0,
              "WeightUOM": "Kilogram",
              "Mill": {
                "Name": "KYMI MILL"
              },
              "Buyer": {
                "Name": "ppxRL GOULD PAPIERS FRANCE"
              },
              "LoadingPort": "USJAX",
              "CountryOfOrigin": "US",
              "OperatorVoyageNumber": "Voyage Number Operator 1 ",
              "Items": {
                "Item": [';
	Item1 : String = '                  {
                    "ItemId": "';
	Item2 : String = '",
                    "ItemBarcode1": "202410117H4",
                    "ItemBarcode2": "14545321",
                    "QuantityExpected": 1,
                    "GrossWeightExpected": 1450.0,
                    "Quality": "COIL",
                    "NettWeightExpected": 1446.0,
                    "PiecesPerPack": 1
                  },';
	EndOfFile : String = '
                ]
              }
            }
          ]
        }
      }
    ]
  }
}
';

vars
	message : String;
	cargoGroupId, cargoId, id : Integer;
	file : File;
	
begin
	message := Header &amp; Transports;
	if not DifferentCargoGroups then
		message := message &amp; Goods1 &amp; CargoGroupBase &amp; 1.String.padLeadingZeros(5) &amp; Goods2;
	endif;
	
	foreach id in 1 to NumberOfItemsToCreate do
		cargoGroupId += 1;
		cargoId += 1;
		
		if DifferentCargoGroups and (id mod 5 = 0 or id = 1) then
			if id &gt; 1 then
				message := message.cnEcStripAtEnd(",") &amp; "]}}," &amp; Goods1 &amp; CargoGroupBase &amp; cargoGroupId.String.padLeadingZeros(5) &amp; Goods2;
			else
				message := message &amp; Goods1 &amp; CargoGroupBase &amp; cargoGroupId.String.padLeadingZeros(5) &amp; Goods2;
			endif;
		endif;
		
		message := message &amp; Item1 &amp; CargoIdBase &amp; cargoId.String.padLeadingZeros(5) &amp; Item2;
		
	endforeach;
	
	message := message.cnEcStripAtEnd(",") &amp; EndOfFile;
	
	create file transient;
	file.openOutput("c:\CorporateFileArea\RoadManifest_" &amp; NumberOfItemsToCreate.String &amp; ".json");
	file.writeLine(message);
	
epilog
	if file &lt;&gt; null then
		file.close;
	endif;
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="dapReadJournal" id="cec4c78b-c0b5-45ea-a440-c7a7449f42da">
        <source>dapReadJournal();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Jul 2009	cnwkpd1	Otago Support - read journal files

*/

vars
	file: File;
	lyne: String;
	jDir: String;
	jaa: JadeAuditAccess;
	journalNum: Integer;
	offset: Integer;
	time: Time;
	date: Date;
	type: Integer;
	objType: Integer;
	startTs,
	ts: TimeStamp;
	serial: Decimal[12, 0];
	tranId: Decimal[12, 0];
	strOid: String;
	classNum: Integer;
	editn: Integer;
	userSlot: Integer;
	userName: String;
	byUserSlot: Integer;
	byUserName: String;
	
	jdo					: JadeDynamicObject;
	dict				: DynaDictionary;
	logClassNum			: Integer;
	startJournalNum		: Integer;
	
begin
	jDir:= "C:\temp\PNL\journals";
	startJournalNum:= 914655;
	
	create file transient;
	//file.usePresentationFileSystem := false;
	//file.openOutput("D:\cnwdmast\server\c_misc\mpd\msl\jaa_journal_dump_" &amp; startJournalNum.String &amp; ".txt");
	file.openOutput("C:\Temp\PNL\jaa_journal_dump_" &amp; startJournalNum.String &amp; ".txt");
	
	if file.isAvailable then
	
		create dict transient;
		dict.setMembership(JadeDynamicObject);
		dict.addExternalKey(Decimal, 20, false, true);
		dict.endKeys(false);
		
		logClassNum := CM_MovementLog.number;
	
		journalNum := startJournalNum;
				
		create jaa;

		jaa.getJournal(jDir, journalNum, offset);
			
		while jaa.getNextRecord(type, objType, offset, ts, serial, tranId, strOid, classNum, editn) do
			lyne:= ts.dataDumpFormat &amp; ' ' &amp; serial.String &amp; ' (' &amp;
				journalNum.String &amp; ', ' &amp; offset.String &amp; ') ';
			if tranId &lt;&gt; null then
				lyne := lyne &amp; tranId.String &amp; ' ';
			endif;
			
			if type = jaa.Jaa_Type_BeginTransaction then
				lyne:= lyne &amp; 'beginTransaction';
				create jdo transient;
				jdo.addProperty("tranId", Decimal);
				jdo.setPropertyValue("tranId", tranId);
				jdo.addProperty("tranStart", TimeStamp);
				jdo.setPropertyValue("tranStart", ts);
				
				jdo.addProperty("createsLog", Boolean);
				
				dict.putAtKey(tranId, jdo);
				
			elseif type = jaa.Jaa_Type_CommitTransaction then
				lyne:= lyne &amp; 'commitTransaction';
				
				jdo := dict.getAtKey(tranId).JadeDynamicObject;
				if jdo = null then
					write "beginTransaction; not found for commitTransaction; - tranId " &amp; tranId.String;
				else
					if jdo.getPropertyValue("createsLog").Boolean then
						startTs := jdo.getPropertyValue("tranStart").TimeStamp;
						write lyne &amp; " creates logs, elapsed time = " &amp; (ts - startTs).String;
					endif;
				endif;						
					
			elseif type = jaa.Jaa_Type_AbortTransaction then
				lyne:= lyne &amp; 'abortTransaction';
			elseif type = jaa.Jaa_Type_UserSignOn then
				lyne:= lyne &amp; 'signOn';
				jaa.getUserData(userName, userSlot);
				lyne:= lyne &amp; ' index=' &amp; userSlot.String &amp; ', name=' &amp; userName;
			elseif type = jaa.Jaa_Type_UserSignOff then
				lyne:= lyne &amp; 'signOff';
				jaa.getUserData(userName, userSlot);
				lyne:= lyne &amp; ' index=' &amp; userSlot.String &amp; ', name=' &amp; userName;
			elseif type = jaa.Jaa_Type_ChangeUser then
				lyne:= lyne &amp; 'changeUser';
				jaa.getChangeUserData(userName, userSlot, byUserName,byUserSlot);
				lyne:= lyne &amp; ' index=' &amp; userSlot.String &amp;
					', name=' &amp; userName &amp;
					', by index=' &amp; byUserSlot.String &amp;
					', name=' &amp; byUserName;
			elseif type = jaa.Jaa_Type_DatabaseOpen then
				lyne:= lyne &amp; 'dbOpen';
			elseif type = jaa.Jaa_Type_DatabaseClose then
				lyne:= lyne &amp; 'dbClose';
			elseif type = jaa.Jaa_Type_NoAuditDiscontinuity then
				lyne:= lyne &amp; 'disc-noAudit';
			elseif type = jaa.Jaa_Type_ReorgDiscontinuity then
				lyne:= lyne &amp; 'disc-reorg';
			elseif type = jaa.Jaa_Type_AuditSwitch then
				lyne:= lyne &amp; 'disc-switch';
			elseif type = jaa.Jaa_Type_Create then
				lyne:= lyne &amp; 'create';
				if objType = jaa.Jaa_Object_Object then
					lyne:= lyne &amp; ' object';
					
					if classNum = logClassNum then
						jdo := dict.getAtKey(tranId).JadeDynamicObject;
						if jdo = null then
							write "beginTransaction; not found for create - tranId " &amp; tranId.String;
						else
							jdo.setPropertyValue("createsLog", true);
						endif;
					endif;
					
				elseif objType = jaa.Jaa_Object_Blob then
					lyne:= lyne &amp; ' blob';
				elseif objType = jaa.Jaa_Object_Collection then
					lyne:= lyne &amp; ' collection';
				endif;
				lyne := lyne &amp; ' ' &amp; strOid;
			elseif type = jaa.Jaa_Type_Delete then
				lyne:= lyne &amp; 'delete';
				if objType = jaa.Jaa_Object_Object then
					lyne:= lyne &amp; ' object';
				elseif objType = jaa.Jaa_Object_Blob then
					lyne:= lyne &amp; ' blob';
				elseif objType = jaa.Jaa_Object_Collection then
					lyne:= lyne &amp; ' collection';
				endif;
				lyne := lyne &amp; ' ' &amp; strOid;
			elseif type = jaa.Jaa_Type_Update then
				lyne:= lyne &amp; 'update';
				if objType = jaa.Jaa_Object_Object then
					lyne:= lyne &amp; ' object';
				elseif objType = jaa.Jaa_Object_Blob then
					lyne:= lyne &amp; ' blob';
				elseif objType = jaa.Jaa_Object_Collection then
					lyne:= lyne &amp; ' collection';
				endif;
				lyne := lyne &amp; ' ' &amp; strOid;
			endif;
			file.writeLine(lyne);
//			write lyne;
		endwhile;
	endif;

epilog
	delete jaa;
	delete file;
	if dict &lt;&gt; null then
		dict.purge();
		delete dict;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="oneStopGetSlots" id="94e6af4d-21cb-4a05-a56f-d0fa7348dd05">
        <source>oneStopGetSlots();
// TFS 52268
vars
	extWeb : CM_1StopVBSWebServiceDef;
	url : String;
	verb : String;
	agent : CM_1StopVBSConsumerAgent;
	terminal : CM_Terminal;
	bookingRequest : CMIF_1StopBookingRequest;
	requestData : String;
	resultCode : Integer;
	resultString : String;
	response : CMIF_Object;
	pxyActivity, requestActivity : CM_EWSActivity1Stop;
begin
	extWeb := CM_1StopVBSWebServiceDef.instances.first.CM_1StopVBSWebServiceDef;
	url := "https://aatau20-dev.vbs.1-stop.biz/VBSWebServices/api/Timeslot/Search";//extWeb.baseEndPointBookingSlots;
	verb := "POST";
	terminal := extWeb.myTerminal;
	
	app.initialize;
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	create agent transient;
	agent.my1StopWebService := extWeb;
	create bookingRequest transient;
	bookingRequest.carrierCode := "WAXT";
	//bookingRequest.containerId := "PICK1702221";
	//bookingRequest.pinNumber := "3896";
	requestData := agent.buildVBSlotRequestMessage(extWeb, bookingRequest);
	write requestData;
	//return;
	
	// log the request
/*	app.writeLog(method.qualifiedName &amp; Tab &amp; "Sending request to 1-Stop: '" &amp; requestData &amp; "'", LogDEBUG);
	create pxyActivity transient;
	pxyActivity.initialiseActivity(	bookingRequest.getActivityDescription &amp; CrLf &amp; requestData, 
									extWeb.name, 
									terminal, 
									null,
									"A".Character,
									"1-Stop VBS Request",
									false,
									null	);
	requestActivity := app.myTrxCA.trxCreateEWSActivityHistory(pxyActivity, app.myPassport).CM_EWSActivity1Stop;
	delete pxyActivity;*/
	
	// now send the request
	agent.context := agent.Context_SlotRequest;
	resultString := agent.doSendHTTPRequest(url, verb, agent.getAdditionalHeadersForHTTP(), requestData, resultCode);
	write "'" &amp; resultCode.String &amp; "'" &amp; Tab &amp; "'" &amp; resultString &amp; "'";
	
	if resultCode &lt;&gt; HttpResponseOK or resultString = null then
		response := null;
		//if requestActivity &lt;&gt; null then
		//	app.myTrxUA.trxUpdateEWSActivityStatus(requestActivity, BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_FAILURE, app.myPassport);
		//endif;
		write "failed";
		return;
	endif;
	
	// Log the response
/*	app.writeLog(method.qualifiedName &amp; Tab &amp; "Response from 1-Stop was " &amp; resultCode.String &amp; ":" &amp; resultString, LogDEBUG);
	create pxyActivity transient;
	pxyActivity.initialiseActivity(	bookingRequest.getActivityDescription &amp; CrLf &amp; resultString, 
									extWeb.name, 
									terminal, 
									null,
									"A".Character,
									"1-Stop VBS Response",
									false,
									null	);
	requestActivity := app.myTrxCA.trxCreateEWSActivityHistory(pxyActivity, app.myPassport).CM_EWSActivity1Stop;
	delete pxyActivity;*/
	
	// Convert the result string to a JSON object then to a CMIF_1StopRoadExitResponse
	if not agent.parseJSONResponse(resultString, agent.Context_SlotRequest, response) then
		app.writeLog(method.qualifiedName &amp; " JSON Exception - unable to parse 1-Stop VBS Road Exit response. Check Activty History for request/response.", LogERROR);
	endif;
	
	response.inspectModal;
	
epilog
	delete agent;
end;</source>
    </JadeMethod>
    <JadeMethod name="oneStopRoadExit" id="017fef35-68a6-4c54-922b-6ed583aaacbb">
        <source>oneStopRoadExit();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21 February 2022	navdap1		Initial creation TFS 52268
//
vars
	extWeb : CM_1StopVBSWebServiceDef;
	url : String;
	verb : String;
	visit : CM_VehicleVisitRecord;
	agent : CM_1StopVBSConsumerAgent;
	terminal : CM_Terminal;
	roadExitMsg : CMIF_1StopRoadExitRequest;
	response : CMIF_Object;
	roadExitResponse : CMIF_1StopRoadExitResponse;
	talkedTo1Stop : Boolean;
	requestData : String;
	resultCode : Integer;
	resultString : String;

begin
	extWeb := CM_1StopVBSWebServiceDef.firstInstance;
	url := extWeb.baseEndPointGateEvent;
	verb := "POST";
	
	visit := "2314.87".asOid.CM_VehicleVisitRecord;
	terminal := extWeb.myTerminal;
	
	app.initialize;
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	create roadExitMsg transient;
	roadExitMsg.myVehicleVisit := visit;
	
	create agent transient;
	requestData := agent.buildRoadExitRequestMessage(extWeb, roadExitMsg);
	
	// log the request
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Sending request to 1-Stop: '" &amp; requestData &amp; "'", LogINFO);
	
	// now send the request
	agent.context := agent.Context_RoadExit;
	resultString := agent.doSendHTTPRequest(url, verb, agent.getAdditionalHeadersForHTTP(), requestData, resultCode);
	write resultString;
	
	if resultCode &lt;&gt; HttpResponseOK or resultString = null then
		response := null;
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Failed to talk to 1-Stop - response is " &amp; resultCode.String &amp; CrLf &amp; resultString, LogINFO);
		return;
	endif;
	
	// Convert the result string to a JSON object then to a CMIF_1StopRoadExitResponse
	if not agent.parseJSONResponse(resultString, agent.Context_RoadExit, response) then
		app.writeLog(method.qualifiedName &amp; " JSON Exception - unable to parse 1-Stop VBS Road Exit response. Check Activty History for request/response.", LogERROR);
		app.raiseCMException(MACS3_JSON_PARSE_ERR, null, null);
		return;
	endif;
	
	roadExitResponse := response.CMIF_1StopRoadExitResponse;
	roadExitResponse.inspectModal;
epilog
	delete agent;
	delete roadExitMsg;
	delete roadExitResponse;
end;</source>
    </JadeMethod>
    <JadeMethod name="oneStopSlotRequest" id="01cce52a-c979-43b6-ac17-9ea6aae7384f">
        <source>oneStopSlotRequest();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14 November 2022	navdap1		Initial creation TFS 
//
vars
	terminal : CM_Terminal;
	bookingRequest : CMIF_1StopBookingRequest;
	agent : CM_1StopVBSConsumerAgent;
	url : String;
	verb : String;
	requestData : String;
	resultCode : Integer;
	resultString : String;
	response : CMIF_Object;
	pxyActivity, requestActivity : CM_EWSActivity1Stop;
	xml : JadeXMLDocument;
	xmlElement : JadeXMLElement;
	startTime, endTime : TimeStamp;
	jsonHelper : CMIF_JsonHelper;
	jsonPostData : String;
begin
	app.initialize();
	terminal := app.myRoot.allTerminals["FICT"];
	if terminal = null then
		return;
	endif;
	
	create bookingRequest transient;
	bookingRequest.carrierCode := "WAXT";
	bookingRequest.pinNumber := "9588";
	//bookingRequest.containerId := "ANGL1234567";
	//bookingRequest.containerId := "PKUP1234567";
	url := terminal.myActive1StopVBSWebServiceDef.baseEndPointBookingSlots;
	verb := "POST";
	
	create agent transient;
	agent.my1StopWebService := terminal.myActive1StopVBSWebServiceDef;
	//requestData := agent.buildVBSlotRequestMessage(terminal.myActive1StopVBSWebServiceDef, bookingRequest);
	startTime.setDate(app.actualTimeServer.date);
	startTime.setTime(null);
	endTime.setDate(startTime.date + 1);
	endTime.setTime("23:59:59".Time);
	
	create xml transient;
	xml.outputDeclaration := false;
	xml.addElement("Body");
	
	xmlElement := xml.getElementByTagName("Body");
	xmlElement.addElement("BookingDateZoneStart").setText(startTime.asJSONFormat);
	xmlElement.addElement("BookingDateZoneEnd").setText(endTime.asJSONFormat);
	xmlElement.addElement("CarrierCode").setText(bookingRequest.carrierCode);
	xmlElement.addElement("ContainerNumber").setText(bookingRequest.containerId);
	xmlElement.addElement("ReferenceNumber").setText(bookingRequest.pinNumber);
	xmlElement.addElement("SlotStatus").setText("CONFIRMED");
	xmlElement.addElement("SlotStatus").setText(" ");
	xmlElement.addElement("TruckRego").setText(bookingRequest.truckReg);
	
	create jsonHelper transient;
	jsonPostData := jsonHelper.convertXMLToJson(xml.writeToString);
	requestData := jsonPostData;
	
	// log the request
	/*app.writeLog(method.qualifiedName &amp; Tab &amp; "Sending request to 1-Stop: '" &amp; requestData &amp; "'", LogDEBUG);
	create pxyActivity transient;
	pxyActivity.initialiseActivity(	_bookingRequest.getActivityDescription &amp; CrLf &amp; requestData, 
									self.myActive1StopVBSWebServiceDef.name, 
									self, 
									null,
									"A".Character,
									CM_1StopVBSWebServiceDef.Type_SlotRequest,
									false,
									null	);
	requestActivity := app.myTrxCA.trxCreateEWSActivityHistory(pxyActivity, app.myPassport).CM_EWSActivity1Stop;
	delete pxyActivity;*/
	
	// now send the request
	agent.context := agent.Context_SlotRequest;
	resultString := agent.doSendHTTPRequest(url, verb, agent.getAdditionalHeadersForHTTP(), requestData, resultCode);
	
	if resultCode = HttpResponseNoContent then
		create response as CMIF_1StopBookingResponse transient;
		response.CMIF_1StopBookingResponse.success := false;
		response.CMIF_1StopBookingResponse.description := HttpResponseNoContent.String;
		//if requestActivity &lt;&gt; null then
		//	app.myTrxUA.trxUpdateEWSActivityStatus(requestActivity, BGP_OpsViewWSRequest.EWS_STATUS_BGP_NODATA, app.myPassport);
		//endif;
		app.writeLog("NODATA: Response from 1-Stop was" &amp; resultCode.String &amp; ":" &amp; resultString, LogERROR);
		return;
	elseif resultCode &lt;&gt; HttpResponseOK or resultString = null then
		//if requestActivity &lt;&gt; null then
		//	app.myTrxUA.trxUpdateEWSActivityStatus(requestActivity, BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_FAILURE, app.myPassport);
		//endif;
		app.writeLog("FAILED: Response from 1-Stop was" &amp; resultCode.String &amp; ":" &amp; resultString, LogERROR);
		return;
	endif;
	
	// Log the response
	app.writeLog("Response from 1-Stop was " &amp; resultCode.String &amp; ":" &amp; resultString, LogDEBUG);
	/*create pxyActivity transient;
	pxyActivity.initialiseActivity(	_bookingRequest.getActivityDescription &amp; CrLf &amp; resultString, 
									self.myActive1StopVBSWebServiceDef.name, 
									self, 
									null,
									"A".Character,
									CM_1StopVBSWebServiceDef.Type_SlotRequestResponse,
									false,
									null	);
	requestActivity := app.myTrxCA.trxCreateEWSActivityHistory(pxyActivity, app.myPassport).CM_EWSActivity1Stop;
	delete pxyActivity;*/
	
	// Convert the result string to a JSON object then to a CMIF_1StopBookingResponse
	if not agent.parseJSONResponse(resultString, agent.Context_SlotRequest, response) then
		app.writeLog(" JSON Exception - unable to parse 1-Stop VBS response. Check Activty History for request/response.", LogERROR);
		//app.raiseCMException(MACS3_JSON_PARSE_ERR, null, null);
		return;
	endif;
	
	if response &lt;&gt; null then
		response.CMIF_1StopBookingResponse.inspectModal;
	endif;
	
epilog
	delete agent;
	delete pxyActivity;
	delete response;
	delete bookingRequest;
	delete xml;
	delete jsonHelper;
end;</source>
    </JadeMethod>
    <JadeMethod name="temp" id="232bb4a9-77cb-419c-8afe-bb275a35cd9f">
        <source>temp();
vars
	terminal : CM_Terminal;
	iter : Iterator;
	booking : CM_BookingRef;
	bookingItem : CM_BRefItemContainer;
	prenote : CM_TrackedItem;
	ti : CM_TrackedItem;
	allBookingItems : CM_BookingRefItemSet;
	
begin
	// Get a collection of booking items
	terminal := app.myRoot.allTerminals["DAVE"];
	
	iter := terminal.allBookingRefsByRef.createIterator;
	
	// read all the bookings in the terminal
	while iter.next(booking) do
		ti := booking.allTIs.first;
		// if the booking has a TI, get a booking item for the TI
		if ti &lt;&gt; null then
			create bookingItem transient;
			bookingItem := booking.getBookingRefItemForTI(ti).CM_BRefItemContainer;
			allBookingItems.add(bookingItem);
		else
			// if the booking has no TI, make one up based on a prenote
			prenote := terminal.createTrackedItem(null, app.myPassport);
			bookingItem := prenote.getBookingItemForMe(null).CM_BRefItemContainer;
			allBookingItems.add(bookingItem);
		endif;
	endwhile;
	
epilog
	delete bookingItem;
	delete prenote;
	allBookingItems.purge;
end;</source>
    </JadeMethod>
    <JadeMethod name="testEUPAuth" id="5e4f11f5-976d-42d3-aeb9-cff8126a0c96">
        <source>testEUPAuth();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 01 June 2022	navdap1		Initial creation TFS 
//
//client_id: 8be1b478-fa9b-4ace-8464-929e5134f45c
//grant_type: client_credentials
//scope: 7481a22c-a3b0-4444-b69c-a5ccc62b4cab/.default
//client_secret: ENa8Q~IP1F-dkg.5RFjA2_khk~.hjj4-wxtffcJQ
vars
	agent : CM_APIConsumerAgent;
	tenantId : String;
	requestData : String;
	returnVal : String;
	error : Integer;

begin
	create agent transient;
	agent.timeoutSeconds := 10;
	agent.createActivityHistory := false;
	
	tenantId := "4f604bd1-00fb-4aae-b3a1-79091a246031";
	requestData := "client_id=8be1b478-fa9b-4ace-8464-929e5134f45c&amp;grant_type=client_credentials&amp;scope=https://integration-api-test.euroports.com/Full.Access/.default&amp;client_secret=ENa8Q~IP1F-dkg.5RFjA2_khk~.hjj4-wxtffcJQ";
	
	returnVal := agent.doSendHTTPRequest(	"https://login.microsoft.com/" &amp; tenantId &amp; "/oauth2/v2.0/token",
											"POST",
											null,
											requestData,
											error	);
	
	// did we get a token?
	if returnVal = null then
		write "Bugger " &amp; error.String;
		return;
	endif;
	
	write app.actualTimeServer.String &amp; CrLf &amp; returnVal;
epilog
	delete agent;
end;</source>
    </JadeMethod>
    <JadeMethod name="testStringStuff" id="f5eeead7-8814-47b2-825d-f77106deee01">
        <source>testStringStuff();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28 August 2024	navdap1		Initial creation TFS 
//
vars
	sepPos, nextSepPos, rangePos, sepCount, rangeCount : Integer;
	thousands : String;
	_sourceString : String;
	secondRange : Integer;

begin
	_sourceString := "12,156-13,456,14564-15,892";
	if _sourceString = null then
		return;
	endif;
	_sourceString := _sourceString.trimBlanks;
	_sourceString := _sourceString.stripTrailingChar(Comma);
	
	thousands := app.getMyLocaleInfoJMT.numericInfo.thousandSeparator;
	
	if thousands = "." then
		_sourceString := _sourceString.cnRemoveChars(thousands);
	else
		// If the separator is a comma, it gets a bit more complex
		// See how many separators we have compared to range markers first
		// Less separators? Must be no thousands separators, just range separators
		// e.g. 19500-25400, 28000-31500, 32000-45000
		sepCount := _sourceString.countOccurrences(thousands);
		rangeCount := _sourceString.countOccurrences(Hyphen);
		if sepCount &lt; rangeCount then
			return;
		endif;
		
		// If we have something like 19,500-21,200, 35,700-40,000
		if _sourceString.pos(", ", 1) &lt;&gt; null then
			_sourceString.replace(", ", "  ");
			_sourceString.cnRemoveChars(",");
		endif;
		
		// Look for separators that are just thousands separators, and leave the range separators alone
		sepPos := 1;
		while sepPos &gt; null do
			if secondRange &gt; 1 then
				secondRange := null;
			endif;
			
			// find the first separator
			sepPos := _sourceString.pos(thousands, sepPos);
			if sepPos = null then
				return;
			endif;
			// and the next one
			if sepPos &lt;&gt; null then
				nextSepPos := _sourceString.pos(thousands, sepPos+1);
			endif;
			// find the next range separator
			rangePos := _sourceString.pos(Hyphen, sepPos);
			// if the separator is before the range separator, remove it
			if ((sepPos &lt;&gt; null and sepPos &lt; rangePos) or (sepPos &lt;&gt; null and rangePos = null))
			and (secondRange = null) then
				_sourceString := _sourceString[1:sepPos-1] &amp; _sourceString[sepPos+1:end];
				secondRange := null;
			endif;
			// if the next range position is greater than this separator and the next, ignore the next separator
			if rangePos &gt; sepPos and rangePos &gt; nextSepPos then
				secondRange += 1;
				sepPos := nextSepPos - 1;
			endif;
			// got to the end? break
			if rangePos = null then
				break;
			endif;
		endwhile;
	endif;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="testStringStuff2" id="4a0310e0-3fa0-48d4-aeff-4642aeecb9af">
        <source>testStringStuff2();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 02 September 2024	navdap1		Initial creation TFS 
//
vars
	sourceLength, charPos, sepPos, rangePos, nextRangePos, sepCount : Integer;
	thousands, decimal, char : String;
	_sourceString, resultStr, tempStr : String;
	ranges : StringArray;

begin
	_sourceString := "12,156-13,456,14,564-15,892";
	write "Start: " &amp; _sourceString;
	if _sourceString = null then
		return;
	endif;
	_sourceString := _sourceString.trimBlanks;
	_sourceString := _sourceString.stripTrailingChar(Comma);
	sourceLength := _sourceString.length;
	
	thousands := app.getMyLocaleInfoJMT.numericInfo.thousandSeparator;
	decimal := app.getMyLocaleInfoJMT.numericInfo.decimalSeparator;
	//thousands := ".";
	//decimal := ",";
	
	if thousands = "." then
		_sourceString := _sourceString.cnRemoveChars(thousands);
	else
		if _sourceString.pos(thousands,1) = null then
			return;
		endif;
		
		create ranges transient;
		
		// Go through the supplied string looking hyphens
		charPos := 1;
		while charPos &lt;= sourceLength do
			char := _sourceString[charPos];
			if char = Hyphen then
				rangePos := charPos;
				
				// Found a hyphen - how many thousands separators are there before the next hyphen
				// 1 means we have 12300,23400- or similar
				// 2 means we have 12,300,23400- or 12300,23,400- or similar
				// 3 means we have 12,300,23,400- or similar
				nextRangePos := _sourceString.pos(Hyphen, rangePos+1);
				if nextRangePos = null then
					nextRangePos := _sourceString.length;
				endif;
				if nextRangePos = _sourceString.length then
					// we're the last "range" type entry - just remove the separators
					tempStr := _sourceString[sepPos:end];
					//write "1: " &amp; tempStr;
					tempStr := tempStr.cnRemoveChars(thousands);
					//write "2: " &amp; tempStr;
					_sourceString := _sourceString[1:rangePos-5] &amp; _sourceString[rangePos-4:end].cnRemoveChars(thousands);
					break;
				else
					sepCount := _sourceString[rangePos:nextRangePos-rangePos].countOccurrences(thousands);
					if sepCount = 1 then
						sepPos := _sourceString.pos(thousands, rangePos);
						resultStr := _sourceString[1:sepPos-1];
					elseif sepCount = 3 then
						// remove the first and last thousands separators
						sepPos := _sourceString.pos(thousands, rangePos);
						_sourceString := _sourceString[1:sepPos-1] &amp; _sourceString[sepPos+1:end];
						sepPos := _sourceString.pos(thousands, rangePos);
						sepPos := _sourceString.pos(thousands, sepPos+1);
						_sourceString := _sourceString[1:sepPos-1] &amp; _sourceString[sepPos+1:end];
					else
						ranges.clear;
						tempStr := _sourceString[rangePos+1:nextRangePos-1-rangePos];
						tempStr.getTokensForDelimiter(Comma, ranges);
						if ranges[1].Integer &gt; ranges[2].Integer then
							// there is a non-separated number at the start
							tempStr := ranges[1] &amp; Comma &amp; ranges[2] &amp; ranges[3];
						else
							// there is a non-separated number at the end
							tempStr := ranges[1] &amp; ranges[2] &amp; Comma &amp; ranges[3];
						endif;
						_sourceString := _sourceString[1:rangePos] &amp; tempStr &amp; _sourceString[nextRangePos:end];
					endif;
				endif;
			elseif char = Comma then
				sepPos := charPos;
			endif;
			
			charPos := charPos + 1;
			sourceLength := _sourceString.length;
			
		endwhile;
		
		// Double check - sometimes there is a thousands separator left before the first range character
		sepPos := _sourceString.pos(thousands, 1);
		rangePos := _sourceString.pos(Hyphen, 1);
		if rangePos &gt; sepPos then
			_sourceString := _sourceString[1:sepPos-1] &amp; _sourceString[sepPos+1:end];
		endif;
	endif;
	
	write "END: " &amp; _sourceString &amp; CrLf;
	
epilog
	delete ranges;
end;</source>
    </JadeMethod>
</Class>
