    <JadeMethod name="setSessionTIs" id="978ff662-0fcc-40ad-8207-54003fada17f">
        <source>setSessionTIs() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 July 2010	cnwer1	Initial creation PAR 24945

*/

vars
	machine : CM_Machine;
	agent 	: CM_MobileAgent;
	allTIs	: CM_TISet;
	rtQueueTask 	: CM_RTQueueTask;
begin
	
	if app.myVMAgent = null then
		return;
	endif;
	
	machine:=app.myVMAgent.myMachine;
	
	if machine.allCurrentQueueTasks = null then
		return;
	endif;
	
	create allTIs transient;
	
	foreach rtQueueTask in machine.allCurrentQueueTasks do
		if rtQueueTask.ti = null then
			continue;
		endif;
		allTIs.addNoDuplicates(rtQueueTask.ti,false);
	
	endforeach;
	
	if allTIs.size = 0 then
		return;
	endif;
	
	agent:=self.getSessionAgent;
	
	agent.allFoundTIs.clear;
	allTIs.copy(agent.allFoundTIs);
	
	agent.setMySelectedTI(allTIs.first);
epilog
	delete allTIs;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setdownForm" id="fd04e379-79ca-4f36-8f40-5f06cdbb0c09">
        <updating/>
        <source>setdownForm() updating, protected;
begin
	inheritMethod();
	self.endNotifications();
	
	if  app.myLogonAgent &lt;&gt; null and app.myLogonAgent.isKindOf(VehicleMountedLogonAgent) then
		return;
	endif;
	
	if not app.isOnDevice() and not self.modal then
		self.getSessionAgent().setLastScreenPosition(self.left.Integer, self.top.Integer, self.width.Integer, self.height.Integer );
	endif;
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupCmdButtons" id="876d4502-8986-4397-9ccc-0cf3add55a1d">
        <updating/>
        <source>setupCmdButtons(_numButtons: Integer; _label1, _label2, _label3, _label4, _label5 : String) protected, updating;
// ---------------------------------------------------------------------------
// Created:	31 December 2008 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
	top    : Real;
	width  : Real;
	left   : Real;
	height : Real;
	backLabel : String;
	backAlignment : Integer;
	backButton : Button;
	stdHeight : Real;
begin

	stdHeight := self.getStdControlHeight;
	// Hide everything while we muck around
	self.btnFive.visible := _numButtons &gt; 4 and _numButtons &lt;=5 ;
	self.btnFour.visible := _numButtons &gt; 3 and _numButtons &lt;=5;
	self.btnThree.visible := _numButtons &gt; 2 and _numButtons &lt;=5;
	self.btnTwo.visible :=  _numButtons &gt; 1 and _numButtons &lt;=5;
	self.btnOne.visible := _numButtons &gt; 0 and _numButtons &lt;=5;
	backButton:=null;
	
	if _numButtons &lt; 1 or _numButtons &gt; 5 then
		return;
	endif;
	
	self.btnFive.enabled := self.btnFive.visible ;
	self.btnFour.enabled := self.btnFour.visible;
	self.btnThree.enabled :=self.btnThree.visible;
	self.btnTwo.enabled :=  self.btnTwo.visible;
	self.btnOne.enabled := self.btnOne.visible;
	
	
	// Setup Labels
	if _label1 &lt;&gt; null then
		if _label1 = BACK_BUTTON then
			self.btnOne.caption := app.getBackButtonCaption;
			backButton:=self.btnOne;
		else
			self.btnOne.caption := _label1;
		endif;
	endif;
	if _label2 &lt;&gt; null then
		if _label2 = BACK_BUTTON then
			self.btnTwo.caption := app.getBackButtonCaption;
			backButton:=self.btnTwo;
		else
			self.btnTwo.caption := _label2;
		endif;
	endif;
	if _label3 &lt;&gt; null then
		if _label3 = BACK_BUTTON then
			self.btnThree.caption := app.getBackButtonCaption;
			backButton:=self.btnThree;
		else
			self.btnThree.caption := _label3;
		endif;
	endif;
	if _label4 &lt;&gt; null then
		if _label4 = BACK_BUTTON then
			self.btnFour.caption := app.getBackButtonCaption;
			backButton:=self.btnFour;
		else
			self.btnFour.caption := _label4;
		endif;
	endif;
	if _label5 &lt;&gt; null then
		if _label5 = BACK_BUTTON then
			self.btnFive.caption := app.getBackButtonCaption;
			backButton:=self.btnFive;
		else
			self.btnFive.caption := _label5;
		endif;
	endif;
	
	// Setup Positions
//	height := stdHeight + (self.MARGIN * 2); //epr par 30678 better size for btns
	height := stdHeight + 4; //epr par 30678 better size for btns
	top := self.clientHeight - self.getSearcherHeight();// + self.getSessionAgent.deviceHeightOffset;
	//top:=self.btnOne.top;
	width := ( (self.clientWidth -2 ) / _numButtons ) - 2;
	if width &gt; 100 then // Let's not have really wide buttons - they're ugly
		width := 100;
	endif;
	left := self.clientWidth - width - 2;
	self.btnOne.move( left, top, width, height );
	if _numButtons &gt; 1 then
		left := left - width -2;
		self.btnTwo.move( left, top, width, height );
		if _numButtons &gt; 2 then
			left := left - width -2;
			self.btnThree.move( left, top, width, height );
			if _numButtons &gt; 3 then
				left := left - width -2;
				self.btnFour.move( left, top, width, height );
				if _numButtons &gt; 4 then
					left := left - width -2;
					self.btnFive.move( left, top, width, height );
				endif;
			endif;
		endif;
	endif;

	
	
	if app.myVMAgent &lt;&gt; null and backButton &lt;&gt; null then
		self.moveVMButtons(backButton);
	endif;
	
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_numButtons" type="Integer"/>
        <Parameter name="_label1" type="String"/>
        <Parameter name="_label2" type="String"/>
        <Parameter name="_label3" type="String"/>
        <Parameter name="_label4" type="String"/>
        <Parameter name="_label5" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="6556dac5-5d32-40ba-b9fa-f3f156f8cfd8">
        <updating/>
        <source>setupForm() updating, protected;
//
// 23/03/2010	cnwdap1		PAR #23350 Cargo check table buttons were visible on Help screen (F1)
//
vars
	left, top, width, height : Integer;
	cmdButtonTop : Integer;
begin

	self.setResizeableMarginAndFontSize();
	
	inheritMethod();
	
	//17 Feb 2015	NDL	Par 35604
	if app.name = "HandHeldApp" 
	or app.name = "HandHeldDebugApp"
	or app.name = "HandHeldWithDevApp"
	then
		if self.isKindOf(MOB_HandHeldLogonForm) then
			self.useHHResizeCode := false;
		else
			self.useHHResizeCode := true;
		endif;
	endif;
	
	self.setNotifications();
	if app.myVMAgent &lt;&gt; null then
		self.allowClose:=false;
	endif;
	
	self.controlBox := true;
	
	
	//epr par 30700 8/11/12 don't want modal dialog opening maximised
	if app.openMaximised and not self.modal then					// 31/08/2011 cnwmh5 #28091
		self.maxButton := false;
		self.minButton := false;
		self.windowState := self.WindowState_Maximized;
		//epr par 25955 8/10/10
		if app.myVMAgent &lt;&gt; null then
			self.borderStyle := self.BorderStyle_None;
			if app.isOnDevice then
				self.controlBox := false;
			else
				self.controlBox := true;
			endif;
		endif;
	else
		if not app.openMaximised and app.allowMaximiseButton then	//07 Dec 2015	NDL	Par 37269
			self.maxButton := true;
		else
			self.maxButton := false;
		endif;
		self.minButton := true;
		self.borderStyle := BorderStyle_Sizable;
		
		if not self.modal then
			self.getSessionAgent().getLastScreenPosition( left, top, width, height );
			if width &lt;&gt; 0 and height &lt;&gt; 0 then
				self.move( left, top, width, height);
			endif;
		endif;
		
	endif;
	//epr TFS 4245 5/5/17
	if self.myTerminal &lt;&gt; null and self.myTerminal.getConfig(HhHideTitleBarButtons).Boolean then // TFS 3809
		self.controlBox := false;
		self.maxButton := false;
		self.minButton := false;
	endif;
	
	//30 May 2017	NDL	TFS 4587
	showHazDetsOnButtons := false;
	if self.myTerminal &lt;&gt; null and self.myTerminal.getConfig(HhIncludeHazDet).Boolean then
		showHazDetsOnButtons := true;
	endif;
	
	self.setupHelpForm();
	cmdButtonTop:=(self.clientHeight - self.btnOne.height - 2).Integer;
	
	self.btnOne.top:=cmdButtonTop;
	self.btnOne.parentAspect:=Control.ParentAspect_AnchorBoth;
	self.btnTwo.top:=cmdButtonTop;
	self.btnTwo.parentAspect:=Control.ParentAspect_AnchorBoth;
	self.btnThree.top:=cmdButtonTop;
	self.btnThree.parentAspect:=Control.ParentAspect_AnchorBoth;
	self.btnFour.top:=cmdButtonTop;
	self.btnFour.parentAspect:=Control.ParentAspect_AnchorBoth;
	self.btnFive.top:=cmdButtonTop;
	self.btnFive.parentAspect:=Control.ParentAspect_AnchorBoth;
	
//	self.btnSearch.parentAspect:=Control.ParentAspect_AnchorRight;
//	self.cmbSearchItem.parentAspect:=Control.ParentAspect_StretchRight;
	// PAR #23350 Cargo Check table buttons should be not visible
	// Make invisible in code here to avoid having to include whole form in hitfix
	// but also changed visible setting on the form for next standard release
	self.btnButton.visible	:= false;
	self.btnCross.visible	:= false;
	self.btnTick.visible	:= false;

end;
</source>
        <access>protected</access>
    </JadeMethod>
