    <JadeMethod name="getTasksAsJSON" id="7e824a9b-5710-475e-8c57-3944e10a8125">
        <source>getTasksAsJSON(	_allTasks 	: CM_RTQueueTaskArray io) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021 jlier1 TFS 52595
1 Nov 2022 	jlier1 TFS 54676 - mafi changes where target is a MAFI
20 Mar 2023 jlier1  57064       Refactored JSON returned - changes so numbers are returned as numbers, timestamp and  measurement fields as objects
*/
vars
	cmifVehicleAppJSON : CMIF_VehicleAppJSON;
begin		
	
	create cmifVehicleAppJSON transient; //57064
