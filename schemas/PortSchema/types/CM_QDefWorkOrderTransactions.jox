	qProp.set('Truck License Plate', CM_WOTransaction::getRegNumber.name, self.className);								//20.06.2024 navhl20 #64718
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
