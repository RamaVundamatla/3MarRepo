    <JadeMethod name="handleShowModal" id="7a62a057-e3f1-4682-b317-1fed27b52152">
        <updating/>
        <source>handleShowModal():Integer updating;

vars
	sa:StringArray;
	meth:String;
	atcgModalCount:Integer;
begin
	create sa transient;
	myYRD_AddTempReading:=app.getForm('YRD_AddTempReading').CM_BaseForm;
	myYRD_AddTempReading.show;
	sa.add('rr014m_YATR_picture_click');

	foreach meth in sa do
		if pauseAndStop(2000) then return 0; endif;  // "safe" way to add a delay
		//app.logMessage(self.class.name&amp;"::"&amp;meth&amp;" starting");
		retCode:=self.sendMsg(meth).Integer;
		if retCode = 0 then
			//app.logMessage(self.class.name&amp;"::"&amp;meth&amp;" succeeded");
		else
			app.logMessage(self.class.name&amp;"::"&amp;meth&amp;" failed with error code "&amp;retCode.String);
			app.atcgReplayFailure:=true;
			break;
		endif;
	endforeach;

	if app.isValidObject(myYRD_AddTempReading) then
		myYRD_AddTempReading.unloadForm;  // 16:14:44
	endif;
	myYRD_AddTempReading:=null;
	return 0;
epilog
	delete sa;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="rr010_YRMF_mnuTblVCloneTop_cli" id="63bf3096-71b7-4303-b3d0-f2863f7f7c4b">
        <updating/>
        <source>rr010_YRMF_mnuTblVCloneTop_cli():Integer updating;

vars
	tblData:Table;
	mnuAddReading:MenuItem;
begin
	tblData:=myYRD_ReeferMonitorForm.getPropertyValue('tblData').Table;
	tblData.row:=loopCount mod (tblData.rows - 1) + 2;  // process next row, wrap at end, skip fixed row #1
	tblData.topRow:=(tblData.row - 2).max(2);  // keep current row in view
	tblData.column:=3;
	tblData.rowColumnChg(tblData);
	app.logMessage(method.qualifiedName&amp;" tblData.row="&amp;tblData.row.String&amp;" loopCount="&amp;loopCount.String&amp;" id="&amp;tblData.accessCell(tblData.row, 1).text);
	tblData.contextMenu(tblData, tblData, false, 0, 0);
	mnuAddReading:=myYRD_ReeferMonitorForm.getPropertyValue('mnuAddReading').MenuItem;
	myYRD_ReeferMonitorForm.sendMsgWithParams('mnuAddReading_click', mnuAddReading);
	
	doEndOfLoop;
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="rr014m_YATR_picture_click" id="2c02e673-ffa8-4b10-a4a7-2d0bea37c201">
        <updating/>
        <source>rr014m_YATR_picture_click():Integer updating;

vars
	tblReefers:Table;
	btnSaveAndClose:Button;
	temp:Decimal[4,1];
begin
	tblReefers:=myYRD_AddTempReading.getPropertyValue('tblReefers').Table;
	tblReefers.row:=2;
	tblReefers.column:=5;
	tblReefers.click(tblReefers);
	temp:=tblReefers.accessCell(2, 2).text.Decimal;
	temp:=temp - 0.1 + (loopCount mod 3) * 0.1;  // set to last reading +- 0.1
	tblReefers.accessCell(2, 5).text:=temp.String;
	//app.logMessage(method.qualifiedName&amp;" id="&amp;tblReefers.accessCell(2, 1).text&amp;" loopCount="&amp;loopCount.String&amp;" newTemp="&amp;tblReefers.accessCell(2, 5).text);
	app.logMessage(method.qualifiedName);
	btnSaveAndClose:=myYRD_AddTempReading.getPropertyValue('btnSaveAndClose').Button;
	btnSaveAndClose.click(btnSaveAndClose);
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
