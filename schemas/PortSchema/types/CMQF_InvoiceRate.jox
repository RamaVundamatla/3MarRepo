    <JadeMethod name="getOIDAndDescForAttribute" id="4b723d3e-12f8-40de-8f1e-59d15982a232">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid: String output): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2010	cnwrd1	Initial creation

*/

vars
	str : String;
	company : CM_Bank;
	runDate			: Date;
begin
	runDate := app.actualTimeServer().Date;	// 28/4/16 cnwmp6 TFS 488 - Multi timezone support
		
	if _attrName = ETRow_Company then
		if self.getMyBank &lt;&gt; null then //At this point we only report on one company/bus unit 22/04/2010 cnwsh3
			company := self.getMyBank;
			_oid := company.getOidAsString();
			return company.getNameWithTerminalString();
		endif;
		
	elseif _attrName = ETRow_Debtor then
		if self.getMyDebtor &lt;&gt; null then
			_oid := self.getMyDebtor.getOidAsString(); 
			return self.getMyDebtor.name;
		endif;

	elseif _attrName = ETRow_ServiceGroup then
		if self.getMyServiceGroup &lt;&gt; null then
			_oid := self.getMyServiceGroup.getOidAsString(); 
			return self.getMyServiceGroup.name;
		endif;
		
	elseif _attrName = ETRow_Service then
		if self.getMyService &lt;&gt; null then
			_oid := self.getMyService.getOidAsString(); 
			return self.getMyService.name;
		endif;
		
	elseif _attrName = ETRow_EffectiveDate then	
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.effectiveDateType, self.effectiveDateFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.effectiveDateType,self.effectiveDateFactor);
		endif;
	elseif _attrName = ETRow_EffectiveTime then	
		return self.effectiveDateTime.time().asStringJMT();
	
	elseif _attrName = ETRow_ExpiryDateFrom then	
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.expiryDateFromType, self.expiryDateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.expiryDateFromType,self.expiryDateFromFactor);
		endif;
		
	elseif _attrName = ETRow_ExpiryDateTo then	
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.expiryDateToType, self.expiryDateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.expiryDateToType,self.expiryDateToFactor);
		endif;
				
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);

epilog
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processDebtor" id="6e7e7773-e897-4701-94f5-29a2e6109584">
        <source>processDebtor( _debtor : CM_DebtorNode; _company : CM_Bank; _ts : TimeStamp; _allSelectedServices : CM_ObjectArray; _collection: Collection input );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2010	cnwrd1	Initial creation

*/

vars
	obj				: Object;
	service 		: CM_Service;
	rateEntry 		: CM_RateEntry;
	rate			: Real;
	tmpNode			: CM_DebtorNode;
	tmpInvRateIF 	: CMIF_InvRateReporter;
	costPerUnitLabels	: StringArray;
	costPerUnitLabel	: String;
	iter				: Iterator;
	i					: Integer;
	calculationType : CM_CalculationType;	//29 Jun 2018	NDL	TFS 39338
	calcType : Integer;	//29 Jun 2018	NDL	TFS 39338
	subTerm : CM_SubTerminal;	//29 Jun 2018	NDL	TFS 39338
	tidalClass : HMS_TidalClass;	//29 Jun 2018	NDL	TFS 39338
begin


	// 24052 multi-select services
	foreach obj in _allSelectedServices do
		service := obj.CM_Service;
		rateEntry := _debtor.getServiceTimeRate(service, _ts);
		if rateEntry &lt;&gt; null then
			rate := rateEntry.getDerivedCostPerUnit(_ts);
			
			//rate entry is what we want!!!!
			//need to filter for expiry time if we have a from/to - assuming these have been set properly...
			 if (( self.expiryDateFrom &lt;&gt; null and rateEntry.expiryTimestamp.date &gt;= self.expiryDateFrom ) or self.expiryDateFrom = null )
				and
				(( self.expiryDateTo &lt;&gt; null and rateEntry.expiryTimestamp.date &lt;= self.expiryDateTo ) or self.expiryDateTo = null )
				then
				//create a CMIF and add to collection	
				
				
					create costPerUnitLabels transient;
					rateEntry.getCostPerUnitLabels(costPerUnitLabels);
					
					//29 Jun 2018	NDL	TFS 39338
					calculationType := service.myCalculationType;
					if calculationType&lt;&gt; null then
						calcType := calculationType.calculationType;
					endif;
		
					i		:=	1;
					iter	:=	costPerUnitLabels.createIterator();
		
					while iter.next(costPerUnitLabel) do	
					
						create tmpInvRateIF transient;
						
						if costPerUnitLabel = service.name then
							tmpInvRateIF.allUnitCost	:=	null;
						else
							tmpInvRateIF.allUnitCost :=	costPerUnitLabel;	// Non-null will indicate a multi-line rate.
						endif;
						
						if calcType = INV_CALC_TYPE_DAYSINCE_SUBTERM then	//29 Jun 2018	NDL	TFS 39338
							subTerm := rateEntry.getMyTerminal.allSubTerminals.getMatchingDesc( costPerUnitLabel );
							tmpInvRateIF.costPerUnit :=	rateEntry.getCPUforObject( subTerm ).String;
							
						elseif calcType = INV_CALC_TYPE_TIDAL_CLASS then	//29 Jun 2018	NDL	TFS 39338
							tidalClass := app.myRoot.allTidalClasses.getMatchingDesc( costPerUnitLabel );
							tmpInvRateIF.costPerUnit :=	rateEntry.getCPUforObject( tidalClass ).String;
							
						else
							if rateEntry.allCostPerUnits.size &lt; i then 
								tmpInvRateIF.costPerUnit	:=	"0";
							else
								tmpInvRateIF.costPerUnit	:=	rateEntry.allCostPerUnits[i].String;
							endif;
						endif;
			
						//tmpInvRateIF.allUnitCost := ?;
						
						//tmpInvRateIF.costPerUnit := rateEntry.costPerUnit.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true) ;
						
						if _debtor.isKindOf(CM_Debtor) then
							tmpInvRateIF.debtorCode			:=	_debtor.CM_Debtor.decfinName;
							
							tmpInvRateIF.debtorGroup := 'D';
						else
							tmpInvRateIF.debtorGroup := 'G';
					
						endif;
					
		
						tmpInvRateIF.debtorName := _debtor.name;								
						tmpInvRateIF.debtorGroup := 'D'; //?
						tmpInvRateIF.effectiveTimestamp := rateEntry.startTimestamp; 
						tmpInvRateIF.expiryTimestamp := rateEntry.expiryTimestamp;
						if service.genLCode &lt;&gt; null then
							tmpInvRateIF.glCode := service.genLCode.code;
						endif;
						tmpInvRateIF.myBank := _company;
						tmpInvRateIF.myDebtor := _debtor;
						tmpInvRateIF.myService := service;
						tmpInvRateIF.overrideFlag := (rateEntry.rate.CM_DebtorRate.debtorNode = _debtor);
						tmpInvRateIF.serviceName := service.name;
						
						_collection.add(tmpInvRateIF);
					
					i	:=	i + 1;
					endwhile;
					
					delete costPerUnitLabels;
					delete iter;
					
				endif;
		endif;
	endforeach;


	// don't show the children of the Root debtor, so that the default rates can be shown alone, plus any selected debtors for comparison
//	if  not _debtor.isRootDebtorGroup then
		foreach tmpNode in _debtor.allChildDebtorNodes do
			self.processDebtor(tmpNode, _company, _ts, _allSelectedServices , _collection);
		endforeach;
	//endif;

epilog
	delete costPerUnitLabels;
	delete iter;
end;</source>
        <Parameter name="_debtor" type="CM_DebtorNode"/>
        <Parameter name="_company" type="CM_Bank"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_allSelectedServices" type="CM_ObjectArray"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setDatesForTemplateRun" id="a8585b30-202c-4dfb-b782-222963fd8309">
        <updating/>
        <source>setDatesForTemplateRun(_runDate: Date) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2010	cnwrd1	Initial creation

*/

vars

begin
	inheritMethod(_runDate);

	self.effectiveDateTime.setDate( self.setDateFromTemplate(self.effectiveDateType, self.effectiveDateFactor, _runDate));
	self.expiryDateFrom := self.setDateFromTemplate(self.expiryDateFromType, self.expiryDateFromFactor, _runDate);
	self.expiryDateTo := self.setDateFromTemplate(self.expiryDateToType, self.expiryDateToFactor, _runDate);

epilog

end;

























</source>
        <Parameter name="_runDate" type="Date"/>
    </JadeMethod>
