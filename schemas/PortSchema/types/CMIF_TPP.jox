    <JadeMethod name="addFileProductionHeader" id="f44df3d9-67b1-4614-9a21-12531ba65c39">
        <options>4</options>
        <source>addFileProductionHeader(file : File io) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2019	jlger1	Initial creation  42036: PEL1 - SAP TPP Report

*/

vars

begin
	file.writeLine(
		"TERMINAL"          &amp; "," &amp;
		"YEAR"              &amp; "," &amp;
		"MONTH"             &amp; "," &amp;
		"SERVICE NAME"   	&amp; "," &amp;
		"BUSINESS UNIT"     &amp; "," &amp;
		"PRODUCTION CODE"   &amp; "," &amp;
		"EXTERNAL INVOICE NUMBER"   &amp; "," &amp;
		"PANDU PELUM GRK"   &amp; "," &amp;
		"PANDU PELUM GT"   &amp; "," &amp;
		"TUNDA PELUM JAM"   &amp; "," &amp;
		"TUNDA PELUM GT"   &amp; "," &amp;
		"TAMBAT PELUM"   &amp; "," &amp;	
		"TAMBAT LAINNYA PELUM"   &amp; "," &amp;
		"FLOATING FENDER"   &amp; "," &amp;
		"OIL SPILL RESPONSE"   &amp; "," &amp;
		"ALUR"   &amp; "," &amp;
		"KEPIL"   &amp; "," &amp;
		"FRESHWATER (TON)"  &amp; "," &amp;
		"Dermaga (PK) "   &amp; "," &amp;
		"Captive Cargo (PK)"   &amp; "," &amp;
		"Shifting On Vessel (PK)"   &amp; "," &amp;
		"Buka/Tutup Palka"   &amp; "," &amp;
		"OH/OW/OL (PK)"   &amp; "," &amp;
		"Lift On/Lift Off (PK)"   &amp; "," &amp;
		"Extra Movement"   &amp; "," &amp;
		"Reefer Container"   &amp; "," &amp;
		"Penumpukan (PK)"   &amp; "," &amp;
		"Haulage (PK)"   &amp; "," &amp;
		"Alih Kapal"   &amp; "," &amp;
		"BATAL MUAT (PK)"   &amp; "," &amp;
		"Cargo Type"   &amp; "," &amp;
		"Jasa Dermaga"   &amp; "," &amp;
		"Pipa Terpadu"   &amp; "," &amp;
		"Penumpukan Gudang (GD)"   &amp; "," &amp;
		"Penumpukan Lapangan (LAP)"   &amp; "," &amp;
		"Tank Storage"   &amp; "," &amp;
		"Bongkar Muat per Paket"   &amp; "," &amp;
		"Sharing"   &amp; "," &amp;
		"Toeslag"   &amp; "," &amp;
		"Monitoring"   &amp; "," &amp;
		"Kontribusi"   &amp; "," &amp;
		"Tagihan Minimum (Pelum)"   &amp; "," &amp;
		"Stevedoring"   &amp; "," &amp;
		"Cargodoring"   &amp; "," &amp;
		"Receiving/Delivery"   &amp; "," &amp;
		"Pas Container"   &amp; "," &amp;
		"Pas Cargo"  &amp; "," &amp;
		"Shipping (MS)"   &amp; "," &amp;
		"Pilotage (MS)"   &amp; "," &amp;
		"Tug and Assist (MS)"   &amp; "," &amp;
		"Various Ship Providers (MS)"   &amp; "," &amp;
		"Docking Facility (MS)"   &amp; "," &amp;
		"Marine Logistik (MS)"   &amp; "," &amp;
		"Other Marine Service (MS)"   &amp; "," &amp;
		"Stuffing (DEPO)"   &amp; "," &amp;
		"Stripping (DEPO)"   &amp; "," &amp;
		"Penumpukan (DEPO)"   &amp; "," &amp;
		"Lift On/Lift Off (DEPO)"   &amp; "," &amp;
		"Fumigasi (DEPO)"   &amp; "," &amp;
		"Repair Container (DEPO)"   &amp; "," &amp;
		"Cleaning Container (DEPO)"   &amp; "," &amp;
		"Checking Gate In (DEPO)"   &amp; "," &amp;
		"Jasa Survei (DEPO)"   &amp; "," &amp;
		"Administrasi Nota"   &amp; "," &amp;
		"Administrasi IT"   &amp; "," &amp;
		"PANDU PRV GRK"   &amp; "," &amp;
		"PANDU PRV GT"   &amp; "," &amp;
		"TUNDA PRV MILIK JAM"   &amp; "," &amp;
		"TUNDA PRV MILIK GT/JAM"   &amp; "," &amp;
		"TUNDA PRV NON JAM"   &amp; "," &amp;
		"TUNDA PRV NON GT/JAM"   &amp; "," &amp;
		"TAMBAT TERSUS/TUKS"   &amp; "," &amp;
		"TAMBAT MINIMUM TERSUS/TUKS"   &amp; "," &amp;
		"UOM"
		);

epilog

end;</source>
        <Parameter name="file" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addFileProductionLine" id="fac2e010-63b9-46f8-8de5-a506d36fcda6">
        <source>addFileProductionLine(file : File io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2019	jlger1	Initial creation  42036: PEL1 - SAP TPP Report

*/

vars
	line : String;
begin

	line:=self.termCode &amp; "," &amp;
			self.year         	&amp; "," &amp;
			self.month        	&amp; "," &amp;
			self.serviceName  	&amp; "," &amp;
			self.businessUnit  	&amp; "," &amp;
			self.productionCode  &amp; "," &amp;
			self.externalInvoiceNbr ;

	if self.isPilotageServiceGLCode then
		if self.productionQty.Integer = 1 then
			line:=line &amp; "," &amp; self.productionQty &amp;",";
		else
			line:=line &amp; ",," &amp; self.productionQty;
		endif;
	else
		line:=line &amp; ",,"; 
	endif;
	
	if self.isTugServiceGLCode then
		if self.productionQty.Integer &lt;= 99 then
			line:=line &amp; "," &amp; self.productionQty &amp;",";
		else
			line:=line &amp; ",," &amp; self.productionQty;
		endif;
	else
		line:=line &amp; ",,"; 
	endif;		
			
	if self.isBerthageServiceGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;		
	
	if self.isOtherBerthageGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	
	if self.isFloatingFenderGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	
	if self.isOilSpillGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	if self.isAlurGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	if self.isMooringBoatGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	
	if self.isFreshWaterGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	if self.isContainerTermGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	if self.isCaptiveCargoGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	if self.isShiftingVesselGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	if self.isHatchCoverGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	if self.isOHGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	if self.isLOLOGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	if self.isExtraMoveGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	if self.isReeferContGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	if self.isStorageGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	if self.isHaulageGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	if self.isSwitchingVesselGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	if self.isCancelledLoadGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	line:=line &amp; "," &amp; self.cargoType;
	if self.isJasaDermagaGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	if self.isPipesGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;		
	if self.isWarehouseGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;	
	if self.isYardGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;		
	if self.isTankGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;		
	if self.isPerPackageGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;	
	if self.isSharingGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;		
	if self.isToeslagGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;		
	if self.isMonitoringGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	if self.isContributionGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;		
	if self.isMinChargeGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;		
	if self.isStevedoringGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	if self.isCargodoringGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;		
	if self.isDeliveryGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;		
	if self.isPasContainerGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;		
	if self.isPasCargoGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	if self.isShippingRevGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;

	if self.isPilotageRevGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;

	if self.isTugAssistRevGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	if self.isVariousShipGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;

	if self.isDockingFacGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;

	if self.isMarineLogGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;

	if self.isOtherMarineGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	if self.isStuffingRevGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	
	if self.isStrippingRevGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	
	if self.isStorageRevGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	
	if self.isLOLORevGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	
	if self.isFumigationRevGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	
	if self.isRepairContGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	if self.isCleaningContGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	
	if self.isCheckingGateInGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	
	if self.isSurveyServiceGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	
	if self.isInvoiceAdminGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	
	if self.isITAdminGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	
	if self.isPilotageSerRevGLCode then
		if self.productionQty.Integer = 1 then
			line:=line &amp; "," &amp; self.productionQty &amp;",";
		else
			line:=line &amp; ",," &amp; self.productionQty;
		endif;
	else
		line:=line &amp; ",,"; 
	endif;
	
	if self.isOwnedTugSerRevGLCode then
		if self.productionQty.Integer &lt;= 99 then
			line:=line &amp; "," &amp; self.productionQty &amp;",";
		else
			line:=line &amp; ",," &amp; self.productionQty;
		endif;
	else
		line:=line &amp; ",,"; 
	endif;
	if self.isNonOwnedTugSerRevGLCode then
		if self.productionQty.Integer &lt;= 99 then
			line:=line &amp; "," &amp; self.productionQty &amp;",";
		else
			line:=line &amp; ",," &amp; self.productionQty;
		endif;
	else
		line:=line &amp; ",,"; 
	endif;	
	if self.isBerthageRevGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	
	if self.isMinChargeRevGLCode then
		line:=line &amp; "," &amp; self.productionQty;
	else
		line:=line &amp; ","; 
	endif;
	
	line:=line &amp; "," &amp; self.uOM;
	
	file.writeLine(line);
epilog

end;</source>
        <Parameter name="file" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addFileRevenueHeader" id="93344fbf-760f-4800-a2c0-6b3f8f0c31f4">
        <options>4</options>
        <source>addFileRevenueHeader(file : File io) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2019	jlger1	Initial creation  42036: PEL1 - SAP TPP Report

*/

vars

begin
	file.writeLine(
		"TERMINAL"          &amp; "," &amp;
		"YEAR"              &amp; "," &amp;
		"MONTH"             &amp; "," &amp;
		"SERVICE NAME"   	&amp; "," &amp;
