    <JadeMethod name="acceptSpecificTask" id="86ec9898-b95a-4d7a-b475-5e7283831ccd">
        <updating/>
        <source>acceptSpecificTask(_queueEntry : DTO_RTQueueEntry input;
				   _dto : DTO_EnquiryGradingTasks input; 
				   _stateInfo : DTO_StateInfo input) : Boolean updating;

/*

Purpose:			Accept the specific task in the passed in Queue Entry


Return Value:		True if successfully accepted


Date		Who		Reason
14 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	passport		: CM_Passport;
	rtQueueTask		: CM_RTQueueTask;
	queueEntry		: CM_RTQueueEntry;
	invalidObject	: Boolean;
	
begin
	passport := app.myPassport;
	
	queueEntry := _queueEntry.myRealQueueEntry.CM_RTQueueEntry;
	if queueEntry &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, queueEntry, invalidObject);
		
		rtQueueTask	:= queueEntry.allTasks.first;
	endif;
	
	if queueEntry = null or invalidObject then
		_stateInfo.errorString := app.getErrorString1(Err_QueueEntryNotFound, null);
		_stateInfo.guiState	:= self.Error;
		return false;
	endif;

	app.myTrxRT.trxAcceptSpecifiedTask(rtQueueTask, self.myMediator, null, passport);
	if not passport.trxCompletedOK then
		_stateInfo.errorString :=  passport.getAllErrorsWarningsAsString();
		_stateInfo.guiState	:= self.Error;
		return false;
	endif;
	
	_dto.setFromMediator(self.myMediator);
	
	self.setMediatorState(self.AcceptedTask);
	_stateInfo.guiState	:= self.AcceptedTask;
		
	return true;
	

epilog

end;</source>
        <Parameter name="_queueEntry" type="DTO_RTQueueEntry" usage="input"/>
        <Parameter name="_dto" type="DTO_EnquiryGradingTasks" usage="input"/>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="acceptTask" id="ec4b9689-6a5c-4dfb-8826-7da3625687a5">
        <updating/>
        <source>acceptTask(_stateInfo : DTO_StateInfo input) : Boolean updating;
// -------------------------------------------
// Created 12 January 2006 by cnwdvb1
// -------------------------------------------
vars

	passport	: CM_Passport;
	task		: CM_RTQueueTask;

begin

	passport := app.myPassport;
	
	app.myTrxRT.trxAcceptTask(self.myMediator, passport);
	if not passport.trxCompletedOK then
		_stateInfo.errorString :=  passport.getAllErrorsWarningsAsString();
		_stateInfo.guiState	:= self.Error;
		return false;
	endif;
	
	self.setMediatorState(self.AcceptedTask);
	_stateInfo.guiState	:= self.AcceptedTask;
		
	return true;

end;</source>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="actionDirectorTask" id="cee46240-a6c2-45c0-8c0a-acf3972ddb61">
        <updating/>
        <source>actionDirectorTask(_tiId	: String; _dto : DTO_EnquiryGradingTasks input; _stateInfo : DTO_StateInfo input) : Boolean updating;
// -------------------------------------------
// Created 03 February 2006 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
25 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Signature change for trxActionDirectorTask
					
*/

vars

	passport	: CM_Passport;
	task		: CM_RTQueueTask;
	guiState,
	extraInfo	: Integer;

begin

	passport := app.myPassport;
	passport.warningsAcknowledged := _stateInfo.warningsAcknowledged;
		
	app.myTrxRT.trxActionDirectorTask(_tiId, null, self.myMediator, false, false, null,null,null, passport);
	if not passport.trxCompletedOK then
		_stateInfo.errorString :=  passport.getAllErrorsWarningsAsString();
		_stateInfo.guiState	:= self.Error;
		return false;
	endif;
	
	_dto.setFromMediator(self.myMediator);
	
	self.setMediatorState(self.AcceptedTask);
	_stateInfo.guiState := self.AcceptedTask;
	
	return true;
epilog
	_stateInfo.hasWarningsOnly := ((not passport.hasErrors) and (passport.hasWarnings));
end;</source>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_dto" type="DTO_EnquiryGradingTasks" usage="input"/>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="automaticGetNextTask" id="e252208f-63e9-4d5e-acac-e24786222025">
        <source>automaticGetNextTask(): Boolean;

vars

begin
	//epr CCMS 1099 config automatic get next task moved to new object
	if self.myMediator.machine &lt;&gt; null then
		return (self.myMediator.machine.currentQueueTask = null and self.myMediator.machine.automaticGetNextTask);
	endif;
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="bindMediator" id="05cb2afd-fee9-426b-8acd-b9c71315de18">
        <updating/>
        <source>bindMediator(_terminalCode, _deviceID : String; _user : CM_User) : Integer updating;
// -------------------------------------------
// Created 10 January 2006 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
09 Mar 2010	cnwkpd1	PAR #23022 - For using a Mediator, the Device ID must be numeric
08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	mediator	: CM_RadioTelemetryMediator;
	terminal	: CM_Terminal;
	device		: CM_RadioTelemetryDevice;
	deviceID	: String;
	rtnValue	: Integer;
	machine		: CM_Machine;
	machineID	: String;
	invalidMed	: Boolean;
	tmpMediator	: CM_RadioTelemetryMediator;
	
begin

	terminal := app.myRoot.allTerminals[_terminalCode.toUpper];
	if terminal = null then
		// RJS 4 Jun - changed to give a useful error message 
		app.raiseCMException1(Invalid_terminal,_terminalCode.toUpper, null, null);
		//app.raiseCMException1(UnableToBindMediator, 'Invalid Terminal', null, null);
		return rtnValue;
	endif;
	
	app.myPassport.setMyTerminal(terminal);
	
	deviceID := _deviceID.toUpper();
	
	device	:= terminal.radioTelemetry.allRTDevices[deviceID];
	if device = null then
		// Problem.
		if app.isUnitTestGarbageCollect then
			return rtnValue;
		endif;
		app.raiseCMException1(UnableToBindMediator, 'Invalid Device', null, null);
		return rtnValue;
	endif;
	
	// PAR #23022 - add in check for numeric device id
	if not device.id.isInteger then
		machine := device.getMachine();
		if machine &lt;&gt; null then
			machineID := machine.id;
		else
			machineID := device.id;
		endif;
		app.raiseCMException1(ERR_MACH_NON_NUM_RT, machineID, null, null);
		return rtnValue;
	endif;

	// PAR #23022 - Rework check to allow for invalid mediator without isValidObject
	tmpMediator := self.myMediator;
	if tmpMediator &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, tmpMediator, invalidMed);
		
		if tmpMediator.device &lt;&gt; device or tmpMediator.myActiveTerminal &lt;&gt; terminal then
			app.raiseCMException1(UnableToBindMediator, 'Invalid pre existing mediator set up', null, null);
			// Raise exception;
			return 0;
		endif;

		if not invalidMed then
			mediator := tmpMediator;
			return rtnValue;
		endif;
	endif;

	// Is there a mediator left in an invalid state.
	mediator := terminal.allActiveMediators[deviceID.Integer].CM_RadioTelemetryMediator;

	if mediator = null then
		create self.myMediator persistent;
		self.myMediator.setAttributesForRadioTelemetry(device,deviceID.Integer, _user);
		self.myMediator.setActiveTerminal(terminal);
	else
		/**********************************************************/
		// Need to write code here to see what state mediator is in.
		// Check it against the passed in parameters.
		self.myMediator := mediator;
		rtnValue := self.DisruptedMediator;
		self.myMediator.setAttributesForRadioTelemetry(device,deviceID.Integer, _user);
	endif;
	
	
	
	if self.myMediator.machine = null then
		app.raiseCMException1(UnableToBindMediator, 'Machine is null', null, null);
		return 0;
	endif;

	return rtnValue;
end;</source>
        <Parameter name="_terminalCode" type="String"/>
        <Parameter name="_deviceID" type="String"/>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="changePassword" id="78e2fbf4-038d-43ec-a238-2d2af2e84002">
        <updating/>
        <source>changePassword(_userCode, _oldPass, _newPass, _newPass2 : String; _stateInfo : DTO_StateInfo input) : Boolean updating;
// -------------------------------------------
// Created 08 February 2006 by cnwdvb1
// -------------------------------------------
vars

	passport	: CM_Passport;
	user		: CM_User;
	userEdition	: Integer;
	
begin

	passport := app.myPassport;
	passport.warningsAcknowledged := _stateInfo.warningsAcknowledged;
		
	app.myTrxRT.trxChangePassword(_userCode, _oldPass, _newPass, _newPass2, user, userEdition, passport);
	if not passport.trxCompletedOK then
		_stateInfo.errorString :=  passport.getAllErrorsWarningsAsString();
		_stateInfo.guiState	:= self.Error;
		return false;
	endif;
	
	self.setMediatorState(self.LoggedOn_Reset);
	_stateInfo.guiState := self.LoggedOn_Reset;
	return true;
	
epilog
	_stateInfo.hasWarningsOnly := ((not passport.hasErrors) and (passport.hasWarnings));
end;</source>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_oldPass" type="String"/>
        <Parameter name="_newPass" type="String"/>
        <Parameter name="_newPass2" type="String"/>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
