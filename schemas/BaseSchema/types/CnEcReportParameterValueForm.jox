    <JadeMethod name="btnBrowse_click" id="54129a20-348f-476d-a572-ecbc951c35a2">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBrowse_click(btn: Button input) updating;

begin
	app.mousePointer	:=	Busy;
	self.doBrowse();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnCancel_click" id="485804c0-d02a-4f14-88c1-4b717489dde8">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;

begin
	modalResult	:=	1;
	unloadForm();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOK_click" id="90e45c5d-c2b9-466c-8870-17e85b9bebba">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOK_click(btn: Button input) updating;

begin
	app.mousePointer	:=	Busy;

	if self.doFormUpdate(false) then
		modalResult	:=	0;
		unloadForm();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbValue_displayEntry" id="76f22abc-8ebe-4c22-aeb3-db4ed8c98089">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbValue_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;

begin
	return obj.Object.cnEcReportDisplay();
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
