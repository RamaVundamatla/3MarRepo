    <JadeMethod name="setupForm" id="798ba921-a806-4575-8be9-4f33f8b1c466">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/05/2018	jlgndl1	Initial creation	TFS 38560
13/06/2018	jlgdap1	TFS 39165 Voyage WO Transactions
17 Aug 2018	NDL	TFS 40127
*/

vars

begin
	
//	self.frmMain.left := 1;
//	self.frmMain.top := 1;
	self.frmMain.borderStyle := 0;
	self.frmHarbour.borderStyle := 0;
	
//	self.btnClose.top := self.frmHarbour.top + self.frmHarbour.height - 5;
//	self.frmMain.height := self.frmHarbour.top + self.btnUpdate.top + 50;
//	self.clientWidth := ( self.frmMain.width + 2 ).Integer;
//	self.clientHeight := ( self.frmMain.height + 2 ).Integer;
//	self.minimumWidth := self.width.Integer;
//	self.minimumHeight := self.height.Integer;
	
	allowUpdate := app.getMyUser.canDo( null, self.permissionMaint );

	inheritMethod();
	
	if self.myAssistant = null then
		create self.myAssistant transient;
	endif;
	
	self.centreOverParent(1);
	
	self.populateCmbHarbours();
	self.setupResources(null);
	
	self.cmbHarbour.setFocus();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupResources" id="bd472938-f405-4164-a692-fa077e2f7596">
        <source>setupResources(_harbour : HMS_Harbour);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/09/2018	jlgdap1		Initial creation TFS 40488 PEL1 Resources For Shift Movements
//
vars
	processHarbour : CM_ProcessHarbour;

begin

	self.lstShiftResources.caption := null;
	self.lstShiftResources.multiSelect := ListBox.MultiSelect_Extended;
	self.lstShiftResources.formDisplayEntryMethodName := SOP_ProcessHarbourForm::displayResourceDescription.name;
	self.lstShiftResources.availableHeading := app.getErrorString(Available);
	self.lstShiftResources.selectedHeading := app.getErrorString(Selected);
	self.lstShiftResources.myBaseForm := null;
	self.lstShiftResources.mySelectedListBox.sorted := false;
	
	//18 Feb 2019	NDL	TFS 43374
	self.lstExtResources.caption := null;
	self.lstExtResources.multiSelect := ListBox.MultiSelect_Extended;
	self.lstExtResources.formDisplayEntryMethodName := SOP_ProcessHarbourForm::displayResourceDescription.name;
	self.lstExtResources.availableHeading := app.getErrorString(Available);
	self.lstExtResources.selectedHeading := app.getErrorString(Selected);
	self.lstExtResources.myBaseForm := null;
	self.lstExtResources.mySelectedListBox.sorted := false;
	
	//23 Nov 2018	NDL	TFS 41980
	self.lstEquipResources.caption := null;
	self.lstEquipResources.multiSelect := ListBox.MultiSelect_Extended;
	self.lstEquipResources.formDisplayEntryMethodName := SOP_ProcessHarbourForm::displayResourceTypeDescrip.name;
	self.lstEquipResources.availableHeading := app.getErrorString(Available);
	self.lstEquipResources.selectedHeading := app.getErrorString(Selected);
	self.lstEquipResources.myBaseForm := null;
	self.lstEquipResources.mySelectedListBox.sorted := false;
	
	if _harbour = null then
		return;
	endif;
	
	self.lstShiftResources.setAvailable(_harbour.allResources, true);
	self.lstExtResources.setAvailable(_harbour.allResources, true);	//18 Feb 2019	NDL	TFS 43374
	self.lstEquipResources.setAvailable(app.myRoot.allResourceTypes, true);	//23 Nov 2018	NDL	TFS 41980
	
	processHarbour := self.myVoyageProcess.allProcessHarbours[self.myVoyageProcess, _harbour];
	if processHarbour = null then
		return;
	endif;
	
	self.lstShiftResources.setSelected(processHarbour.allHMSResourcesForShift);
	self.lstExtResources.setSelected(processHarbour.allHMSResourcesForExt);//18 Feb 2019	NDL	TFS 43374
	self.lstEquipResources.setSelected(processHarbour.allHMSResourceTypeForEquip);	//23 Nov 2018	NDL	TFS 41980

epilog

end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0c2171f4-79a6-433b-a693-996350dc1420">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 25 February 2019 08:06:39.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023081, locale);
	btnClose.translateCaption(Xlat_0023082, locale);
	btnDelete.translateCaption(Xlat_0023083, locale);
	btnUpdate.translateCaption(Xlat_0023084, locale);
	lblHarbour.translateCaption(Xlat_0023085, locale);
	lblResBilAdj.translateCaption(Xlat_0023226, locale);
	lblResEquip.translateCaption(Xlat_0023113, locale);
	lblResExtension.translateCaption(Xlat_0023114, locale);
	lblResShift.translateCaption(Xlat_0023086, locale);
	lblResWater.translateCaption(Xlat_0023087, locale);
	lstEquipResources.translateCaption(Xlat_0023115, locale);
	lstExtResources.translateCaption(Xlat_0023227, locale);
	lstShiftResources.translateCaption(Xlat_0023088, locale);
end;</source>
    </JadeMethod>
</GUIClass>
