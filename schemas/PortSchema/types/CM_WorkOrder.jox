    <JadeMethod name="getCashReceiptList" id="f0f375f3-24f7-4d51-bac7-0477fb6e4822">
        <source>getCashReceiptList(_short : Boolean) : String;
 /*

Purpose:			// TFS 39349

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2018	jlgab1	Initial creation

*/

vars
	cashRec :	CM_CashReceipt;
	str : String;
begin

	foreach cashRec in self.allCashReceipts	discreteLock do
		if str = null then
			if  _short then
				str := cashRec.externalInvoiceNumber;
			else
				str := app.getErrorString1(Cash_receipt_work_order, self.getDisplayString()) &amp;   cashRec.externalInvoiceNumber;
			endif;
		else
			str := str &amp; ", " &amp; cashRec.externalInvoiceNumber;
		endif;
		
	endforeach;
	
   return str;

epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
