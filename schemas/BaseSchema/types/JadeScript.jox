    <JadeMethod name="cnwdad1_Test_Evaluate" id="f792c5a3-72d4-4e7c-824c-3b1e8be1c6fc">
        <source>cnwdad1_Test_Evaluate();
// --------------------------------------------------------------------------------
// Created:		27 August 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnValue		: Any;
	errorMessage	: String;
	expression		: String;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	
	// Calculate the value of PI.
//	expression		:=	"22/7";
//	errorMessage	:=	process.cnEcEvaluate(expression, Real, app, returnValue);

	// Calculate the integer value of PI, then get the result in words.
	expression		:=	"(22 div 7).cnEcAsWords(app.currentLocaleInfo)";
	errorMessage	:=	process.cnEcEvaluate(expression, String, app, returnValue);
	
	if errorMessage = null then
		write returnValue;
	else
		write errorMessage;
	endif;
epilog
	write "Evaluation complete in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_ExceptionHandler" id="5730bba5-3345-4134-a148-ac62ce259faf">
        <source>cnwdad1_Test_ExceptionHandler();
// --------------------------------------------------------------------------------
// Created:		13 August 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	stringValue	: String[10];
	
begin
	on Exception do app.cnEcXHandler(exception);
	
	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);
	app.cnEcInitializeBaseSchema();
	
	// Uncomment the following to test the CnEcExceptionForm.
//	stringValue	:=	"Something that is too long.";
	
	// Uncomment the following to test the BaseSchema error dialog.
	CnEcBaseSchemaException.raise_(CNEC_X_83003, "Could not open the clipboard.");
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_ExploreDirectory" id="0c03ae8a-3c77-4ef9-a01b-900b29fc277b">
        <source>cnwdad1_Test_ExploreDirectory() protected;
// --------------------------------------------------------------------------------
// Created:		15 June 2007 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	write global.cnEcExploreDirectory("c:\temp");
	//write global.cnEcExploreDirectory(null);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_External_Process" id="be129d1d-d679-48f8-917a-b44ac782bd36">
        <source>cnwdad1_Test_External_Process();
// --------------------------------------------------------------------------------
// Created:		19 September 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	processResult	: Integer;
	returnValue		: Integer;
	allArguments	: StringArray;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	create allArguments transient;
	
	allArguments.add("d:\jade\system\");
	returnValue	:=	node.createExternalProcess(	null,//"c:\temp\",
												"c:\temp\directory.bat",
												allArguments,
												null,
												false,
												true,
												processResult);

	write "Return Value: " &amp; returnValue.String;
	write "Process Result: " &amp; processResult.String;
epilog
	delete allArguments;
	
	write "External process started in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_FileEx_Handler" id="908f8643-7c76-40a6-a0d9-3838f9bb180e">
        <source>cnwdad1_Test_FileEx_Handler();
// --------------------------------------------------------------------------------
// Created:		03 August 2000 by cnwdad2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileObj		: File;
	fileData	: String;

begin
	on FileException do global.cnEcFileException(exception);

	create fileObj;
	fileObj.fileName	:=	"c:\junk\junk.dat";
//	fileObj.kind		:=	File.Kind_ANSI; // 26/2/16  cnwns1 PAR 36286 unicode version

	if fileObj.tryOpen then
		fileObj.writeString(fileData);
	else
		app.msgBox(	$CNEC_FILE_CANNOT_OPEN(fileObj.fileName),
					$CNEC_FILE_ERROR,
					MsgBox_Stop_Icon + MsgBox_OK_Only);
	endif;
epilog
	delete fileObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_FileName_Methods" id="20ae48e0-1462-4738-b929-2e5ca76242cf">
        <source>cnwdad1_Test_FileName_Methods();
// --------------------------------------------------------------------------------
// Created:		08 May 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileObj		: File;
begin
	create fileObj transient;
	
	if fileObj.cnEcSetOpenName(true, false, null) then
		write "Is it a file    : " &amp; fileObj.cnEcIsFile().String;
		write "Is it a folder  : " &amp; fileObj.cnEcIsFolder().String;
		write "Is it available : " &amp; (not fileObj.cnEcIsNotAvailable()).String;
		write "Full Name       : " &amp; fileObj.fileName;
		write "File Extension  : " &amp; fileObj.cnEcFileExt();
		write "File Path       : " &amp; fileObj.cnEcFilePath();
		write "File Stem       : " &amp; fileObj.cnEcFileStem();
		write "Unqualified Name: " &amp; fileObj.cnEcUnqualName();
		write "Attributes      : " &amp; fileObj.cnEcGetAttributes();
	endif;
epilog
	delete fileObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_FileNode_Copy" id="e8f6338b-582e-46f0-8fe2-a3b0c36888ac">
        <source>cnwdad1_Test_FileNode_Copy();
// -----------------------------------------------------------------------------
// Created:		18 January 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	folderObj	: FileFolder;
	fileNodeObj	: FileNode;
	result		: Integer;
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	create folderObj transient;
	folderObj.fileName	:=	"c:\temp\test";
	
	if folderObj.cnEcCopy("c:\darrell") then
		write "Copy worked.";
	else
		write "Copy failed.";
	endif;
epilog
	delete folderObj;
	
	write "File node copy completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
