    <JadeMethod name="dataIsFiltered" id="ee8da16a-62f2-4053-b3c1-94cc4b92a0c2">
        <source>dataIsFiltered() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29/08/2008	cnwkao1	Initial creation
12/02/2019	jlgdap1	TFS 43062 PEL1 Container Services - Changed in Web Portal
28/06/2022	navsrk20	Task 53922: Implement shipping line in WS_TrackedItemQueryRequest
*/

vars
	retVal : Boolean;
begin
	retVal := false;
	if self.filterBookingRef &lt;&gt; null or
		self.filterCarrier &lt;&gt; null or
		self.filterConsignee &lt;&gt; null or
		self.filterConsignor &lt;&gt; null or
		self.filterDateFrom &lt;&gt; null or
		self.filterDateTo &lt;&gt; null or
		self.filterExcludeLocation &lt;&gt; null or
		self.filterIMEX &lt;&gt; null or
		self.filterId &lt;&gt; null or
		self.filterOperator &lt;&gt; null or
		self.filterPIN &lt;&gt; null or 
		self.filterTiType &lt;&gt; null or 
		self.filterVoyage &lt;&gt; null or
		self.filterAssignedTrain &lt;&gt; null or
		self.filterIntendedReleaseMode &lt;&gt; null or
		self.filterTransportMode &lt;&gt; null or 
		self.filterMark &lt;&gt; null or
		self.filterCustomsEntryNumber &lt;&gt; null or		// TFS 43062
		self.filterAlternativeId &lt;&gt; null or
		self.filterShippingLine &lt;&gt; null then	//28.06.2022 navsrk20 TFS 53922
		/* 
		The following were added for Cargo Enquiry - however, they aren't needed for this method
		self.filterISOType &lt;&gt; null or
		self.filterTAType &lt;&gt; null or 
		self.filterTerminalArea &lt;&gt; null or 
		self.filterYardLocation &lt;&gt; null or
		self.filterSite &lt;&gt; null then
		*/
		retVal := true;
	endif;
	
	return retVal;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="0f807b13-1a0a-4c79-a24e-17d38e63f4cf">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2016	cnwmc5	Initial creation

*/

vars

begin
	self.filterAvailabilityGrades.purge();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMulitIdExactSearch" id="330ba77d-4c02-48a8-bb29-819e150c5a5b">
        <source>doMulitIdExactSearch( _tiArray : CM_TIArray input; _maxIds : Integer ) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 October 2017		jlger1	Initial creation tfs 7380
29 May 2024			jlizm1	TFS 62775 Web Portal public multi id search 

*/

vars
	multiIDs			: StringArray;
	id 					: String;
	multiRequest 		: WS_TrackedItemQueryRequest;
	enqController 		: CM_EnqControllerTI;
	webServiceAgent		: WS_WebServiceAgent;
	qDef				: CM_QueryDefinition;
	critLine 			: CM_SelectorCriteriaLine;
	count				: Integer;
begin
	
	create multiIDs transient;
	self.filterId.getTokensForDelimiter(",",multiIDs);
	if multiIDs.size &lt;= 1 then
		return false;		
	endif;
	
	multiRequest :=self.cloneSelf(true);
	count := 0;
	
	foreach id in multiIDs do
		if id = null then
			continue;
		endif;
		
		if _maxIds &gt; 0 and count = _maxIds then
			break;
		endif;
		
		multiRequest.filterId:=id.trimBlanks.trimBlankCharacters[1:30];
		
		if enqController &lt;&gt; null then
			if enqController.myCriteriaLineHolder &lt;&gt; null then
				delete enqController.myCriteriaLineHolder;
			endif;
		endif;
		delete enqController;
		//delete qDef;
		create enqController transient;
		delete webServiceAgent;
		create webServiceAgent transient;
	
		//setup the query from the request
		webServiceAgent.setupTiSelectorQuery( multiRequest,true, enqController, qDef );
		// run the query
		enqController.doQuery( qDef );
		app.writeLog(enqController.myCriteriaLineHolder.allCriteriaLines.size.String, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
		app.writeLog("Enquiry Controller search for " &amp; multiRequest.filterId.String &amp; " found  " &amp;  enqController.allObjects.size.String, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
		
		enqController.allObjects.copyNoDups(_tiArray);
		//do the alt ID search 
		//9/5/22 jlier1 TFS 53249
		if enqController.id &lt;&gt; null and enqController.site = SEL_QUERYSITE_ONSITE  then
			//check onsite alt id
			critLine := enqController.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::id.name);	
			if critLine &lt;&gt; null then
				critLine.setMyCriteriaLineHolder(null);
				delete critLine;
			endif;
			critLine:=qDef.createCriteriaLine( CM_TrackedItem::alternativeId.name, CM_QueryOperator.Operator_Equal,  enqController.id);
			if critLine &lt;&gt; null then
				critLine.setMyCriteriaLineHolder(enqController.myCriteriaLineHolder);
			endif;
			enqController.altId:= enqController.id;
			enqController.doOnSiteAltIdSearch();	
			enqController.allObjects.copyNoDups(_tiArray);
		endif;
		
		count := count + 1;
		
	endforeach;
	 
	return true;
	
	
epilog
	delete multiIDs;
	delete multiRequest;
	delete webServiceAgent;
	if enqController &lt;&gt; null then
		if enqController.myCriteriaLineHolder &lt;&gt; null then
			delete enqController.myCriteriaLineHolder;
		endif;
	endif;
	delete enqController;
end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_maxIds" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMultiBOLIdsSearch" id="e79cc3f2-32f7-460e-ae11-b0700f3c80f4">
        <source>doMultiBOLIdsSearch( _tiArray : CM_TIArray input; _maxIds : Integer ) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 February 2024	jlier1	Initial creation 59754 
29 May 2024			jlizm1	TFS 62775 Web Portal public multi id search 
04 April 2025		navdap1	MTN-14781 CPL | Increase BOL Field Length
*/

vars
	multiIDs			: StringArray;
	id 					: String;
	multiRequest 		: WS_TrackedItemQueryRequest;
	enqController 		: CM_EnqControllerTI;
	webServiceAgent		: WS_WebServiceAgent;
	qDef				: CM_QueryDefinition;
	count				: Integer;
begin
	
	create multiIDs transient;
	self.filterBOL.getTokensForDelimiter(",",multiIDs);
	if multiIDs.size &lt;= 1 then
		return false;		
	endif;
	
	multiRequest :=self.cloneSelf(true);
	count := 0;
	
	foreach id in multiIDs do
		if id = null then
			continue;
		endif;
		
		if _maxIds &gt; 0 and count = _maxIds then
			break;
		endif;
		
		multiRequest.filterBOL:=id.trimBlanks.trimBlankCharacters[1:35];	// MTN-14781
		
		if enqController &lt;&gt; null then
			if enqController.myCriteriaLineHolder &lt;&gt; null then
				delete enqController.myCriteriaLineHolder;
			endif;
		endif;
		delete enqController;
		create enqController transient;
		delete webServiceAgent;
		create webServiceAgent transient;
		//setup the query from the request
		webServiceAgent.setupTiSelectorQuery( multiRequest,true, enqController, qDef );
		// run the query
		enqController.doQuery( qDef );
		app.writeLog(enqController.myCriteriaLineHolder.allCriteriaLines.size.String, LogDEBUG);	
		app.writeLog("Enquiry Controller search for BOL " &amp; multiRequest.filterBOL.String &amp; " found  " &amp;  enqController.allObjects.size.String, LogDEBUG);	
		enqController.allObjects.copyNoDups(_tiArray);

		count := count + 1;
		
	endforeach;
	 
	return true;
	
	
epilog
	delete multiIDs;
	delete multiRequest;
	delete webServiceAgent;
	if enqController &lt;&gt; null then
		if enqController.myCriteriaLineHolder &lt;&gt; null then
			delete enqController.myCriteriaLineHolder;
		endif;
	endif;
	delete enqController;
end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_maxIds" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
