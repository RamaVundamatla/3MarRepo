// ---------------------------------------------------------------------------
// Created:     18 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.tblBGPReports.showColumnOrganiserFrm(self.myTerminal, null);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showTableForReport" id="b5d2807a-13de-4519-ad8b-3299152ce60b">
        <updating/>
        <source>showTableForReport(_reportMenuItem :CM_MenuEntity; _loadReportOptions: Boolean) updating, protected;
// -----------------------------------------------------------------------------
// Created:		14 May 2002 by cnwka1
//
// Purpose:		
//
// Changed On	By			Reason
// -----------------------------------------------------------------------------
// 12/10/2020	jlgdap1		TFS 49898 PIBT Report Maintenance Window AvailableFormat setting issue
vars
	jrwReport		: JadeReportWriterReport;
	defaultOutputDest,
	row				: Integer;
	tbl				: CM_EntryTable;
	entTableDef		: EntTableDef;
	qryReport		: CM_QryReport;
	selectorCriteriaToDisplay	: CM_QueryCriteriaHolderArray;
	templateRpt					: BGP_ReportRequest;
	terminal		: CM_Terminal;
	defaultOutputDesc : String;				// TFS 49898
begin
	tbl := self.tblParameter;
	//PAR22361 - cnwsh3 - 18/02/2010 - Remove references to CM_MenuUserReport.myReportRequest 
	//mapped method.  Now using getBGPReportRequest method
	if CM_MenuUserReport.hasInstance(_reportMenuItem) then
		templateRpt := _reportMenuItem.CM_MenuUserReport.getBGPReportRequest();
	endif;
	
	qryReport := self.myReportAgent.myQryReport;
	if qryReport = null then
		return;
	endif;
	
	//cnwmc5 - 11 March 2016 - PAR 37496 - moved from showTableForTemplate because of new calling order..
	if templateRpt &lt;&gt; null and templateRpt.myFilter &lt;&gt; null then
		self.myReportAgent.allTerminals.clear();
		self.tblTerminals.allSelectedObjects.clear();
		templateRpt.myFilter.allTerminals.copy(self.myReportAgent.allTerminals);
		
		foreach row in 1 to self.tblTerminals.rows do
			terminal := self.tblTerminals.accessRow(row).itemObject.CM_Terminal;
			
			if terminal = null then
				continue;
			endif;
			
			if templateRpt.myFilter.allTerminals.includes(terminal) then
				self.tblTerminals.accessCell(row, 1).text := 1.String;
				self.tblTerminals.allSelectedObjects.add(terminal);
			else
				self.tblTerminals.accessCell(row, 1).text := 0.String;
			endif;
		endforeach;
	endif;	
	
	entTableDef := self.myReportAgent.myEntTableDef;

	tbl.rows := self.tblParameter.fixedRows;
	tbl.allEntRowTransients.purge();
	tbl.setPropertyValue('myEntTableDef', null);
	tbl.userInputEnabled := true;

	jrwReport := self.myReportAgent.myJRWReport;
	
	if _loadReportOptions then
		self.loadReportOptionCombos(qryReport,_reportMenuItem);
	endif;

	if jrwReport &lt;&gt; null then
		defaultOutputDest := jrwReport.getDefaultOutputDestination();
		defaultOutputDesc := self.myReportAgent.getFormatDescriptionForType(defaultOutputDest);		// TFS 49898
		if self.cmbFormat.findStringExact(1, defaultOutputDesc) &gt; 0 then							// TFS 49898
			self.cmbFormat.text := self.myReportAgent.getFormatDescriptionForType(defaultOutputDest);
			self.tblPrintOptions.setValueByName(ETRow_FormatOption, self.cmbFormat.text);
		endif;																						// TFS 49898
		self.setPrintOptionsView();
	endif;
	
	if entTableDef &lt;&gt; null then
		tbl.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	
		if self.myReportAgent.myQryReport.hasViewFilter() then	
			tbl.showHideRowsByList(qryReport.CM_QryReportUser.allVisibleRows, CM_EntryTable.ShowHideRows, false);
		else
			tbl.showHideRowsByViewName(qryReport.tableDefViewName, CM_EntryTable.ShowHideRows, false);
		endif;
	endif;

	tbl.optimiseHeadingColumn();
	self.createReportController();

	self.loadControlsForReport(entTableDef);

	////////////////////////////////////////////////////////
	//Ugly piece of code specifically for the ship log list
	if (qryReport.getIdPrefix = '_rpt') and (qryReport.menuId = qryReport.getIdPrefix &amp; CM_RepShipLogList.String)  then	
		row := tbl.setValueByName(ETRow_ExtraDetail, '-- Dbl Click to Add/Update --');
		tbl.accessCell(row, CM_EntryTable.ColumnValue).inputType := Table.InputType_None; 
	endif;
	///////////////////////////////////////////////////////
	
	self.lblRepName.visible := true;
	if (not qryReport.isFormBasedReport) then
		self.lblRepName.caption := 'JRW Report : ' &amp; qryReport.getJRWFileNames();
	else
		self.lblRepName.caption := 'Non JRW report';
	endif;
	
	if qryReport.mySelectorQuery &lt;&gt; null then
		// cnwrl1 11/11/2009 PAR 19951
		self.lblRepName.caption := app.getString( Selector_Query, self.lblRepName.caption, qryReport.mySelectorQuery.heading );
	
		//if it's a template then show the query stuff saved on the static request object
		if templateRpt &lt;&gt; null then
			if templateRpt.myFilter &lt;&gt; null then
				selectorCriteriaToDisplay := templateRpt.myFilter.allQueryCriteriaHolders;
			endif;
		else
			selectorCriteriaToDisplay := qryReport.mySelectorQuery.allCriteriaLineHolders;
		endif;
		self.myReportAgent.showTableForSelectorReport(selectorCriteriaToDisplay);
		
	endif;
	// 35875 show the description along with the name
	if qryReport.reportDescription &lt;&gt; null then
		self.lblRepName.caption := self.lblRepName.caption &amp; CrLf &amp; qryReport.reportDescription;
	endif;

	self.myReportAgent.loadJRWParams();
	
	tbl.optimiseHeadingColumn();
	tbl.moveFirst();
	
end;</source>
