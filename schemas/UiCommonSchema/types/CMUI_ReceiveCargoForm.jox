    <JadeMethod name="cmbCarrier_displayEntry" id="1e6bd608-9f83-4c02-bbab-e04faf436765">
        <controlMethod name="CMUI_FieldComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCarrier_displayEntry(_combobox: CMUI_FieldComboBoxControl input; _obj: Any; _index: Integer):String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24/07/2009	cnwdap1	Initial creation
08/06/2010	cnwas3 par 24344
11/08/2011	cnwdap1	PAR #27972 Bulk release type no longer translatable, replaced by strnig constants
15/01/2015   cnwma1		 PAR #35462 Carrier Drop-down Fields	
*/

vars
	carrier : CM_Carrier;
	failedDAC  :CM_DataAccessController;
begin
	carrier := _obj.CM_Carrier;
	////////////////////////////////////////////////////////////
	if (not carrier.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;
	
	if carrier.isNotAvailableForEntry then
		if _combobox.listObject &lt;&gt; carrier then
			return null;
		endif;
	endif;	

	//if self.cmbTransportMode.getString() = app.getErrorString(BR_TYPE_DESCR_RAIL) then		// PAR #27972
	if self.cmbTransportMode.getString() = BR_TYPE_RAIL_STR then								// PAR #27972
		if not carrier.isRail then
			return null;
		endif;
	//elseif self.cmbTransportMode.getString()  = app.getErrorString(BR_TYPE_DESCR_ROAD) then	// PAR #27972
	elseif self.cmbTransportMode.getString()  = BR_TYPE_ROAD_STR then							// PAR #27972
		if not carrier.isRoad then
			return null;
		endif;
	endif;
	
	//return carrier.getYADisplay;   						  // 15/1/2015 cnwma1 PAR #35462
	if app.myRoot.getConfig(CarrierCmbOrdDescr).Boolean then  // 15/1/2015 cnwma1 PAR #35462
		return carrier.getDescriptionTabCode;
	else
		return carrier.getYADisplay;
	endif;
	
epilog

end;</source>
        <Parameter name="_combobox" type="CMUI_FieldComboBoxControl" usage="input"/>
        <Parameter name="_obj" type="Any"/>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
