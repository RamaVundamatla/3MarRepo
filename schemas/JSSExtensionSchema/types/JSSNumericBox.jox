    <JadeMethod name="controlNamePrefix" id="542d0cd5-4857-4733-811f-4e6b7bfbef51">
        <source>controlNamePrefix(): String;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "nub";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="delete" id="182acf02-1fb2-4882-b9f1-633d097b2783">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	delete self.myNumberFormat;
end;</source>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="9160ef79-b3dc-4ce6-b994-0daa88c6fc3b">
        <updating/>
        <source>gotFocus(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	textValue		: String;
	
begin
	inheritMethod(textbox);
	
	textValue	:=	textbox.text.jssAsNumeric(self.myNumberFormat);
	
	self.setIsIgnoreState(true);
	textbox.text	:=	null;
	self.dataType	:=	self.DataType_SignedNumeric;
	self.decimals	:=	self.userDecimals;
	self.setIsIgnoreState(false);
	textbox.text	:=	textValue;
	
	if self.selectionStyle = TextBox.SelectionStyle_SelectAll then
		textbox.selStart	:=	0;
		textbox.selLength	:=	textValue.length;
	endif;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="jssDate" id="d041de77-7e71-4670-b42e-3e6ce7983ac3">
        <source>jssDate(): Date;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Returns the receiver's numeric Julian day number as a date.
//
// Parameters:	None
//
// Returns:		The current date setting.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dateValue	: Date;
	
begin
	dateValue	:=	self.text.Integer.Date;
	
	if dateValue.isValid() then
		return dateValue;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="jssDecimal" id="8f9a6042-a133-4324-b62d-6c2c37ba3d1b">
        <source>jssDecimal(): Decimal;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Returns the receiver's currency value as a Decimal value.
//
// Parameters:	None
//
// Returns:		The decimal value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.text.jssAsNumeric(self.myNumberFormat).Decimal;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="jssInteger" id="7074250b-091d-4eb4-8fb1-c923605c3132">
        <source>jssInteger(): Integer;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Returns the receiver's currency value as an Integer value.
//
// Parameters:	None
//
// Returns:		The integer value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.text.jssAsNumeric(self.myNumberFormat).Integer;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssReal" id="8cb26968-6377-427b-974c-e27c6db926fb">
        <source>jssReal(): Real;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Returns the receiver's currency value as a Real value.
//
// Parameters:	None
//
// Returns:		The real value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.text.jssAsNumeric(self.myNumberFormat).Real;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="jssTime" id="f6b01cb4-ef6a-4c4a-9f69-6cdcd715dd01">
        <source>jssTime(): Time;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Returns the receiver's number as a time, assuming that the value
//				is the number of milliseconds since midnight.
//
// Parameters:	None
//
// Returns:		The current time setting.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	timeValue	: Time;
	
begin
	timeValue	:=	self.text.jssAsNumeric(self.myNumberFormat).Integer.Time;
	
	if timeValue.isValid() then
		return timeValue;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="jssTimeStamp" id="3bd5d966-3928-4ca0-a8c6-1ea59ffae48e">
        <source>jssTimeStamp(): TimeStamp;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		This reimplementation returns a null value since a time stamp value
//				is not relevant in the context of this control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return null;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="7d92838f-0c61-4e83-9fe9-ec8d837d033e">
        <updating/>
        <source>lostFocus(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	textValue	: String;
	
begin
	textValue		:=	textbox.text.Decimal.userNumberFormat(self.myNumberFormat);
	self.dataType	:=	self.DataType_AlphaNumeric;
	
	if textValue &lt;&gt; null then
		textbox.text	:=	textValue;
	endif;
	
	inheritMethod(textbox);
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setAlignment" id="5022b4d0-fa94-4d2f-8337-4a80dff97864">
        <updating/>
        <source>setAlignment() updating, protected;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Sets the receiver's alignment to be right-aligned.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.alignment		:=	self.Alignment_Right;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setIsIgnoreState" id="06c12dd5-dc3d-45aa-a226-f7ae83b76609">
        <updating/>
        <source>setIsIgnoreState(pIsOverride:Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Sets a flag to indicate that the "text" mapping method should ignore
//				the formatting while the receiver's text is formatted back to a
//				numeric value for user input.
//
// Parameters:	pIsOverride - If true, the mapping method won't format the text.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isIgnoreState	:=	pIsOverride;
end;</source>
        <access>protected</access>
        <Parameter name="pIsOverride" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setUserDecimals" id="1af8ed53-7269-4c3d-9649-dffc4b6ecc30">
        <updating/>
        <source>setUserDecimals(pUserDecimals:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Sets the number of decimal places the developer wishes to use.
//
// Parameters:	pUserDecimals - The number of decimal places.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.numberLayout = self.LAYOUT_INTEGER then
		self.userDecimals					:=	0;
		self.myNumberFormat.decimalPlaces	:=	0;
	else
		self.userDecimals					:=	pUserDecimals;
		self.myNumberFormat.decimalPlaces	:=	pUserDecimals;
	endif;
end;</source>
        <Parameter name="pUserDecimals" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="text" id="e48c16c7-a2d9-4e9f-a570-2dbd86090bb0">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>text(set: Boolean; value: String io) updating, mapping;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	workValue	: String;
	
begin
	if set
	and (not self.isIgnoreState)
	and self.myNumberFormat &lt;&gt; null
	then
		if self.dataType = self.DataType_AlphaNumeric then
			if self.numberLayout = self.LAYOUT_DECIMAL then
				value	:=	self.myNumberFormat.jssStripNonNumeric(value).Decimal.userNumberFormat(self.myNumberFormat);
				
				if self.isStripDecimalZeros then
					value	:=	value.jssStripDecimalZeros();
				endif;
				
			elseif self.numberLayout = self.LAYOUT_INTEGER then
				value	:=	self.myNumberFormat.jssStripNonNumeric(value).Integer.userNumberFormat($JSS_NO_DECIMALS);
				
			elseif self.numberLayout = self.LAYOUT_REAL then
				value	:=	self.myNumberFormat.jssStripNonNumeric(value).Real.userNumberFormat(self.myNumberFormat);
				
			endif;
		else
			value 	:=	value.jssAsNumeric(self.myNumberFormat);
		endif;
	endif;
	
	inheritMethod(set, value);
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="4ca89b65-7a1c-4857-ba21-1a3afa312d52">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);

	create self.myNumberFormat transient;
	self.myNumberFormat.jssCopyInfo(app.currentLocaleInfo.numericInfo);
	
	if self.numberLayout = null then
		self.numberLayout	:=	self.LAYOUT_DECIMAL;
	endif;
	
	if self.numberLayout &lt;&gt; self.LAYOUT_INTEGER then
		self.myNumberFormat.decimalPlaces	:=	self.userDecimals;
	endif;
	
	self.setAlignment();
	self.dataType		:=	self.DataType_AlphaNumeric;
	self.text			:=	self.text;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
