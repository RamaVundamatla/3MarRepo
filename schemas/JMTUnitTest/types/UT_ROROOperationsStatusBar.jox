    <JadeMethod name="xGCDCStatusBarStep8" id="509b8cf2-8c79-4de5-baa6-c3d1c2cce44e">
        <updating/>
        <source>xGCDCStatusBarStep8() updating;

/*

Purpose:		Plan the load items and check that the status bar is correct	

Date			Who		Reason
15/05/2013		cnwmh5	Initial creation

*/

vars

	voyageJob							: CM_VoyageJob;
	realAlloc							: CM_VoyageAllocation;
	
	tis									: CM_TIArray;
	locationArray						: StringArray;
	
	iter								: Iterator;
	
	locn								: String;
	index								: Integer;
	
begin

	app.writeLog("STEP 8", LogINFO);
	app.writeLog("Plan the load items.  Please wait...", LogINFO);
	
	iter := self.myVoyage.allVoyageAllocations.createIterator;
	iter.next(realAlloc);
	iter.next(realAlloc);
	
	
	create tis transient;
	create locationArray transient;
	locationArray.add("D4211082");
	locationArray.add("D4210684"); // D4230684
	
	index := 1;
	iter.next(realAlloc);
	foreach locn in locationArray do
		self.roroLCs.clear();
		tis.clear();
		self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code,  null, locn, self.roroLCs, true, 1); 
		tis.add(self.tisToPlanArray[index]);
		self.planTIsRORO(tis, self.roroLCs, realAlloc.allRequests.first.CM_RORORequest);
		self.assertNoTrxErrorsOrWarnings();
		index := index + 1;
		if index = 2 then
			iter.next(realAlloc);
		endif;
	endforeach;
	

	app.writeLog("Checking Status Bar (ACTUAL) details are correct.  Please wait...", LogINFO);
	self.locationArray.clear();
	self.statusArray.clear();
