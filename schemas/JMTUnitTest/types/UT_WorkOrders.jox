    <JadeMethod name="xAddVoyage" id="1e0ca9cc-ef69-4fca-b1cb-e01022bb6979">
        <source>xAddVoyage(_vslID ,_voyageID : String):CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2023 navma1 ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation

*/

vars
	vessel 		: CM_Vessel;
	voyage 		: CM_Voyage;
	shipLine	: String;
begin
	
	shipLine := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString();
	
	vessel := self.addVesselWithHolds(_vslID, 2, 2);
	self.assertTrueMsg(vessel &lt;&gt; null ,"Vessel Item has not been created correctly");
	
	
	voyage := self.addVoyageWithGeneralCargoStruc(_voyageID, vessel.name, vessel.myOperator.code,shipLine	, 0);
	
	self.assertTrueMsg(voyage &lt;&gt; null ,"Voyage Item has not been created correctly");
	
	return voyage;
epilog

end;</source>
        <Parameter name="_vslID" type="String"/>
        <Parameter name="_voyageID" type="String"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="xAddWOIMSR" id="56ce95e2-6772-45f8-b361-d989ce9464ce">
        <source>xAddWOIMSR(_voyage 				: CM_Voyage input;
			_berth	    		: HMS_Berth input;
		   _occurOnDT			: TimeStamp;
		   _bowMarkTo,
		   _draftAft,
		   _draftFwd    		: Decimal;
		   _hasRamp,
		   _starboardBerthed 	: Boolean
		   );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2022		navma1	Initial creation
24 Mar 2023 			navhl20 ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
*/

vars
	voyageStatus		    : CM_VoyageStatus;
	pxyWorkOrder		    : CM_WorkOrderVoyage;
	pxyWorkOrderVoyageDtl   : CM_WorkOrderVoyageDtl;
	errors				    : String;
	terminal				: CM_Terminal;
	realWorkOrder 		    : CM_WorkOrder;
begin

	terminal     := _voyage.myTerminal;
	voyageStatus := app.myRoot.allVoyageStatuses[_voyage.status];
	
	create pxyWorkOrder transient;
	pxyWorkOrder.setProxy(null,
						  null,
						  false,
						  app.actualTimeAppServer,
						  app.myPassport.myUser,
						  null,
						  null,
						  terminal,
												null,null,null, WO_STATUS_PENDING);
												
		pxyWorkOrder.setMyVoyage(_voyage);
		
		if voyageStatus.isInitialMarineService then
			create pxyWorkOrderVoyageDtl  as CM_WodMarineServicesInitial transient;
			pxyWorkOrderVoyageDtl.setTowingVoyage(null);
			pxyWorkOrderVoyageDtl.CM_WodMarineServicesInitial.setPxyMarineDetails(_berth, 
																				_draftAft,
																				_draftFwd,
																				_bowMarkTo, 
																				_hasRamp, 
																				_starboardBerthed); 
		endif;
		//pxyWorkOrderVoyageDtl.setProxy(_occurOnDT,null,false);																		//24.3.2023 navhl20	#57301[57303]
		pxyWorkOrderVoyageDtl.setProxyReqByDT(_occurOnDT);																				//24.3.2023 navhl20	#57301[57303]
	
	pxyWorkOrderVoyageDtl.setParent(pxyWorkOrder);
	
	app.myTrxCA.trxCreateWorkOrder(pxyWorkOrder,realWorkOrder,app.myPassport);
	
	if app.myPassport.hasErrors then
		errors := app.myPassport.getErrorsAsString;
		self.assertTrueMsg(false ,
						  'Error : Failed Creating IMSR : ' 			  	  &amp;   pxyWorkOrder.id 	  &amp; CrLf &amp; 
						  'Trx Errors: '						 		 	  &amp;    errors  );
	endif;
epilog
	delete pxyWorkOrder;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_berth" type="HMS_Berth" usage="input"/>
        <Parameter name="_occurOnDT" type="TimeStamp"/>
        <Parameter name="_bowMarkTo" type="Decimal"/>
        <Parameter name="_draftAft" type="Decimal"/>
        <Parameter name="_draftFwd" type="Decimal"/>
        <Parameter name="_hasRamp" type="Boolean"/>
        <Parameter name="_starboardBerthed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xAddWOVoyageRequest" id="9294a2fb-4fa3-41b2-b186-ced973d4a9a4">
        <source>xAddWOVoyageRequest(_code : String;_hasCargo :Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 February 2022		navma1	Initial creation

*/

vars
	vessel 					: CM_Vessel;
	helper 					: UT_Helper;
	operCode				: String;
	cargoLoadOperator,
	cargoDischargeOperator,
	operator 				: CM_Operator;
	now,
	arrivalDT,
	departureDT 			: TimeStamp;
	woVoyProcess			: CM_VoyageProcess;
	terminal				: CM_Terminal;
	lastPort,
	lastPortOfCall,
	nextPortOfCall,
	originPort				: CM_Port;
	pxyVoyage,	
	voyage					: CM_Voyage;
	externalRef				: String;
	visitType 		    	: HMS_VisitType;
	vesselCategory 	    	: HMS_VesselCategory;
begin
	
	terminal 		  := self.getTerminal();
	woVoyProcess	  := app.myRoot.allVoyageProcesses['MTNWO']; 
	operCode 		  :=  self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	operator 		  := app.myRoot.allOperators[operCode];
	lastPort		  := app.myRoot.allPorts["NZNSN"];
	lastPortOfCall	  := app.myRoot.allPorts["NZAKL"];
	nextPortOfCall	  := app.myRoot.allPorts["NZBLU"];
	originPort		  := app.myRoot.allPorts["NZWLG"];
	
	create helper as UT_HelperAdmSys transient;
	
	helper.code 			:= _code;
	helper.doDeleteFirst	:= true;
	helper.myOperator       := operator;
	
	vessel := helper.UT_HelperAdmSys.xCreateVessel('HOLD',true);
	
	
	arrivalDT.setDate(now.date()+2);
	arrivalDT.setTime(now.time());
	departureDT := arrivalDT.addDays(3);
	
	
	pxyVoyage:= vessel.createProxyVoyageRequest(terminal,
												'UT'&amp; _code,
												operator,
												arrivalDT,
												departureDT,
												_hasCargo,
												null, 
												externalRef, 
												originPort,
												lastPortOfCall,
												nextPortOfCall,
												lastPort,
												vesselCategory,
												visitType,
												cargoLoadOperator,
												cargoDischargeOperator,
												woVoyProcess,
												app.myPassport);
	
	pxyVoyage.setStatusFromObject(app.myRoot.allVoyageStatuses[Voyage_Status_VoyReqSubmitted]);
	
	app.myPassport.setWarningsIgnored(true);
	
	app.myTrxCA.trxCreateVoyageRequest(pxyVoyage,
										vessel,
										operator, operator, operator,
										null,null,null,null,
										false,
										_code &amp;"Remarks",
										null,
										app.myPassport);
										
	voyage := self.getVoyage('UT'&amp; _code);
	
	self.assertTrueMsg(voyage &lt;&gt; null, "Voyage :" &amp; 'UT'&amp; _code &amp; 'is null' );
	self.assertTrueMsg(not voyage.allWorkOrders.isEmpty , 'Voyage Work order has not been created');
	
	
epilog
	delete pxyVoyage;
	delete helper;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_hasCargo" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xAddWorkOrderCargoDetail" id="d6c661d9-30c3-45f4-8f3c-42f654311742">
        <source>xAddWorkOrderCargoDetail(_taskType : Integer;_tiset : CM_TISet; _todoSet : CM_ToDoTaskDescSet):CM_WorkOrderDtl;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Apr 2023 navma1 ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
18 Apr 2023 navhl20 ChangeRequest 55442:[57629] EUP - Pack Cargo Work Order - Enhancement
04 Jul 2023	navma1	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
05 Jul 2024 navhl20	ChangeRequest 61368: EUP* | Adding Pack Reserve Child to Packing Work order Release Request
*/

vars
	pxyWod  		: CM_WorkOrderDtl;
	term		    : CM_Terminal;
	terminal 		: CM_Terminal;
	realWorkOrder,
	pxyWorkOrder	: CM_WorkOrderTI;
	pxyWODtl,
	realWODtl 		: CM_WorkOrderDtl;
	autoQ,
	autoRTQ 		: Boolean;
	taskType		: Integer;
	dtRequired,
	dtStart			: TimeStamp;
	toDoTaskID 		: Integer;
	toDoTask 		: CM_ToDoTaskDesc;
	root		    : CM_Root;
	target,
	unpackLoc		: CM_TerminalArea;
	todoSet 		: CM_ToDoTaskDescSet;
	tiSet			: CM_TISet;
	ti				: CM_TrackedItem;
	vessel			: CM_Vessel;
	voyage 			: CM_Voyage;
	operator		: CM_Operator;
	subTerm1		: CM_SubTerminal;
	release			: CM_BulkRelease;
	code			: String;
	relDate			: TimeStamp;
begin
	term := self.getMyTerminal();
	
	if self.opts.includesKey("targetTA") then
		target := term.allTerminalAreas[opts.str('targetTA')].CM_TerminalArea;
	endif;
	
	if self.opts.includesKey("unpackTA") then
		unpackLoc := term.allTerminalAreas[opts.str('unpackTA')].CM_TerminalArea;
	endif;
	
	if self.opts.includesKey("autoRTQ") then
		autoRTQ := opts.bool("autoRTQ");
	endif;
	
	if self.opts.includesKey("dtRequired") then
		dtRequired := opts.str("dtRequired").TimeStamp;
	endif;
	
	
	if _taskType = WO_TASK_MOVE then
		create pxyWod as CM_WodMove transient;		
		pxyWod.CM_WodMove.setProxyMove( null,target,autoRTQ, null);
	
	elseif _taskType = WO_TASK_TODO then
		create pxyWod as CM_WodToDo transient;
		if _todoSet &lt;&gt; null then													//29.3.2023 navhl20	#56614[56615]
			pxyWod.CM_WodToDo.setPxyWoToDo(false, null, null, _todoSet);
			pxyWod.CM_WodToDo.setProxyAllToDoRequests( _todoSet );	
		endif;
		
	elseif _taskType = WO_TASK_PACK then
		create pxyWod as CM_WodPack transient;
		
		self.deleteSubTerminal("SubTerm1");
		subTerm1 := self.addSubTerminal("SubTerm1", SubTermType_Depot_Int);
		operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
		self.deleteContainer("Pack1CNT");
		vessel := self.addVesselWithHolds("UT_VHOLDS", 2, 2);
		voyage := self.addVoyageWithGeneralCargoStruc("UT_VHOLDS", vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
		create tiSet transient;

		//pxyWod.CM_WodPack.setProxyWodPack(_tiset, null, null, null, null, null, operator, subTerm1, voyage, "MT", null, null, true);					//18.4.2023 navhl20 #55442[57629] //05.07.2024 navhl20 #61368
		pxyWod.CM_WodPack.setProxyWodPack(_tiset, null, null, null, null, null, operator, subTerm1, voyage, "MT", null, null, null, true);				//05.07.2024 navhl20 #61368
		
	elseif _taskType = WO_TASK_UNPACK then
		create pxyWod as CM_WodUnpack transient;
		
		pxyWod.CM_WodUnpack.setProxyWodUnpack( unpackLoc );	
		//04.11.2021 navma1 #52248
		if _todoSet &lt;&gt; null then													//29.3.2023 navhl20	#56614[56615]
			pxyWod.CM_WodUnpack.setProxyAllToDoRequests( _todoSet );	
		endif;
		
	elseif _taskType = WO_TASK_EXPORTRETURN then
		create pxyWod as CM_WodExportReturn transient;
	elseif _taskType = WO_TASK_CHANGEVOYAGE then
		create pxyWod as CM_WodNullVoyage transient; 
	elseif _taskType = WO_TASK_RECEIVE then
		create pxyWod as CM_WodReceive transient;
	elseif _taskType = WO_TASK_RELEASE then
		create pxyWod as CM_WodRelease transient;
		pxyWod.CM_WodRelease.setProxyWodRelease(release , 1, null, null,null,null, null);		//31.03.2023	navcs2  #55440:[54990]

	endif;
	
	if _todoSet &lt;&gt; null then													//04.3.2023 navhl20	#56614[56615]
		pxyWod.CM_WodPack.setProxyAllToDoRequests( _todoSet );	
	endif;
	
	return pxyWod;
epilog

end;</source>
        <Parameter name="_taskType" type="Integer"/>
        <Parameter name="_tiset" type="CM_TISet"/>
        <Parameter name="_todoSet" type="CM_ToDoTaskDescSet"/>
        <ReturnType type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="xApproveWorkOrder" id="5438dd0c-8806-4510-b401-bc4277671792">
        <source>xApproveWorkOrder(_wo : CM_WorkOrder io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2022		navma1	Initial creation
02 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
*/

vars
	errors : String;
begin
	
	app.myTrxUA.trxUpdateWOApproved(_wo,false,null,null, app.myPassport);		//02.05.2024 navhl20 #63971
	
	if app.myPassport.hasErrors then
		errors := app.myPassport.getErrorsAsString;
		self.assertTrueMsg(false ,
						  'Error : Failed Approving Work order : ' 			  &amp;   _wo.id 	  &amp; CrLf &amp; 
						  'Trx Errors: '						 		 	  &amp;    errors  );
	endif;
	
epilog

end;</source>
        <Parameter name="_wo" type="CM_WorkOrder" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xCheckWorkOrder" id="683b321e-57b7-49b1-94b7-c54b6d458c70">
        <source>xCheckWorkOrder(_wod    	: CM_WorkOrderDtl;
				_status 	: Integer;
				_count		: Integer;
				_transType  : Integer;
				_actioned   : Boolean;
				_useDD		: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2023 navma1 ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
15 Feb 2024	navpw1	TFS: 59411 (62272) - Added support for release by type

*/

vars
	workOrder : CM_WorkOrder;
	useJobs   : Boolean;
	cnt	      : Integer;
	
begin
	
	useJobs := self.getMyTerminal.isUseYardJobsForCargoWo;
	
	/*
	Work Order Detail is not null;
	*/
	self.assertNotNull(_wod);
	
	
	/*
	Work Order is not null
	*/
	
	if _wod &lt;&gt; null then
		workOrder := _wod.myParent;
	endif;
	
	self.assertNotNullMsg(workOrder, "The work order is null");
	
	/*
	Check Status 
	*/
	
	self.assertEqualMsg(workOrder.taskStatus ,  _status, "The work order  status should :"     &amp; app.workOrderStatusEnumToString(_status));	
	self.assertTrueMsg(workOrder.requiredByDT.isValid,   "Work Order must have a valid required by Date");
	self.assertTrueMsg(_wod.requiredByDT.isValid,   	 "Work Order Task must have a valid required by Date");
	
	/*
	Check Transaction Type
	*/
	
	self.xCheckWorkOrderTransaction(_wod,_transType);
	
	
	if _status = WO_STATUS_USERENTRY then
		cnt := _wod.CM_WorkOrderTIDtl.allSelectedTIs.size;
		self.assertTrueMsg(cnt = _count, "The work order detail has no Selected TIs populated , AllSelected Must have :" &amp; _count.String &amp;" TI and Currently only : "&amp; cnt.String );
		self.assertEqualMsg(_wod.status , _status, "The work order task status should :" &amp; app.workOrderStatusEnumToString(_status));
	endif;
	
	/*
	Approved Status Check 
	*/
	
	if _status = WO_STATUS_APPROVED then
		if not _actioned then
			cnt := _wod.CM_WorkOrderTIDtl.allAvailableTIs.size;
			self.assertTrueMsg(cnt = _count, "The work order detail has no Actioned TIs populated , allAvailableTIs Must have :" &amp; _count.String &amp;" TI and Currently only : "&amp; cnt.String );
			self.assertEqualMsg(_wod.status , 	        _status, "The work order task status should :" &amp; app.workOrderStatusEnumToString(_status));	
		endif;
		
		if not _wod.isKindOf(CM_WodExportReturn) then
			/*
			Export Return Work Order go From Approved to Complete
			*/
			if _actioned then
				self.assertEqualMsg(_wod.status , WO_STATUS_ACTIONED, "The work order task status should :" &amp; app.workOrderStatusEnumToString(_status));	
				cnt := _wod.CM_WorkOrderTIDtl.allActionedTIs.size;
				self.assertTrueMsg(cnt = _count, "The work order detail has no Actioned TIs populated , Allactioned Must have :" &amp; _count.String &amp;" TI and Currently only : "&amp; cnt.String );
				
				if _count &gt; 0 then //Added for release by type as the available tis will be empty
					cnt := _wod.CM_WorkOrderTIDtl.allAvailableTIs.size;
					self.assertTrueMsg(cnt &lt;&gt; _count, "The work order Detail Should have Empty , allAvailableTIs :" &amp; _count.String &amp;" and Currently only : "&amp; cnt.String );
				endif;
			endif;
		endif;
		
		
	endif;
	
	/*
	Action Status Check
	*/
	
	/*
	Check Jobs
	*/
	if _actioned then
		if useJobs then
			self.xCheckWorkOrderJob(_wod,_status,_count,_useDD);
		endif;
	endif;
	
	/*
	Part Complete Check
	*/
	if _status = WO_STATUS_PARTCOMPLETE then
		if _wod.status = WO_STATUS_COMPLETE then
			self.assertEqualMsg(_wod.status , WO_STATUS_COMPLETE, "The work order task status should :" &amp; app.workOrderStatusEnumToString(_status));
		else
			self.assertEqualMsg(_wod.status , _status, "The work order task status should :" &amp; app.workOrderStatusEnumToString(_status));
		endif;
	endif;
	
	/*
	Complete Check 
	*/
	
	if _status = WO_STATUS_COMPLETE then
		self.assertEqualMsg(_wod.status , _status, "The work order task status should :" &amp; app.workOrderStatusEnumToString(_status));	
		cnt := _wod.CM_WorkOrderTIDtl.allCompleteTIs.size;
		
		self.assertTrueMsg(cnt = _count, "The work order detail has no Completed TIs populated , AllCompleted Must have :" &amp; _count.String &amp;" TI and Currently only : "&amp; cnt.String );
		self.xCheckWorkOrderTransaction(_wod,_transType);
		
		cnt := workOrder.CM_WorkOrderTI.allTIs.size;
		if workOrder.allWoDtls.size = 1 then
			self.assertTrueMsg(cnt = _count, "The work order Should have Empty , AllTIs :" &amp; _count.String &amp;" and Currently only : "&amp; cnt.String );
		else
			self.assertTrueMsg(cnt = (workOrder.allWoDtls.first.CM_WorkOrderTIDtl.allCompleteTIs.size + workOrder.allWoDtls.last.CM_WorkOrderTIDtl.allCompleteTIs.size) , "The work order Should have Empty , AllTIs :" &amp; _count.String &amp;" and Currently only : "&amp; cnt.String );
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_wod" type="CM_WorkOrderDtl"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_count" type="Integer"/>
        <Parameter name="_transType" type="Integer"/>
        <Parameter name="_actioned" type="Boolean"/>
        <Parameter name="_useDD" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xCheckWorkOrderDetail" id="b853b705-3823-43ef-818f-8653060e597c">
        <source>xCheckWorkOrderDetail(_wod			: CM_WorkOrderDtl;
						_status		: Integer;
						_count		: Integer;
						_transType	: Integer;
						_actioned	: Boolean;
						_useDD		: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
31 January 2024		navpw1	Initial creation TFS: 59411 (61855)
15 February 2024	navpw1	TFS: 59411 (62272) - Added support for release by type

*/

constants
	Param1					: String = "%1";
	Param2					: String = "%2";
	Param3					: String = "%3";
	Param4					: String = "%4";
	WodStatusMessage		: String = "The work order detail status is incorrect, Expected: '%1' | Actual: '%2'";
	WodIncorrectNumberOf	: String = "The work order detail has an incorrect number of %1 populated '%2' Expected: '%3' | Actual: '%4'";
	
vars
	workOrder : CM_WorkOrder;
	useJobs   : Boolean;
	cnt	      : Integer;
	
begin
	useJobs := self.getMyTerminal.isUseYardJobsForCargoWo;
	
	/*
	Work Order Detail is not null;
	*/
	self.assertNotNull(_wod);
	
	/*
	Work Order is not null
	*/
	if _wod &lt;&gt; null then
		workOrder := _wod.myParent;
	endif;
	
	self.assertNotNullMsg(workOrder, "workOrder");
	self.assertTrueMsg(_wod.requiredByDT.isValid, "Work Order Task must have a valid required by Date");
	
	/*
	1- Check Work List Entries
	*/
	if _wod.isWodTI then
		cnt := _wod.CM_WorkOrderTIDtl.allJobs.first.workListEntries.size;
		self.assertTrueMsg(cnt &gt; 0, "No Work list entries have been created for this work order detail : " &amp; _wod.taskID);
		self.assertTrueMsg(cnt = _count ,"Work List Entries has not been created correctly for Work Order Detail: '" &amp; _wod.taskID &amp; "' Expected: " &amp;
							_count.String &amp; " | Actual: " &amp; cnt.String);
	endif;
	
	/*
	Check Transaction Type
	*/
	self.xCheckWorkOrderTransaction(_wod,_transType);
	
	if _status = WO_STATUS_USERENTRY then
		cnt := _wod.CM_WorkOrderTIDtl.allSelectedTIs.size;
		self.assertTrueMsg(cnt = _count, WodIncorrectNumberOf.replace(Param1, "Selected TIs").replace(Param2, "allSelectedTIs").replace(Param3, _count.String).replace(Param4, cnt.String));
		self.assertEqualMsg(_wod.status, _status, WodStatusMessage.replace(Param1, app.workOrderStatusEnumToString(_status)).replace(Param2, app.workOrderStatusEnumToString(_wod.status)));
	endif;
	
	/*
	Approved Status Check 
	*/
	if _status = WO_STATUS_APPROVED then
		if not _actioned then
			cnt := _wod.CM_WorkOrderTIDtl.allAvailableTIs.size;
			self.assertTrueMsg(cnt = _count, WodIncorrectNumberOf.replace(Param1, "Actioned TIs").replace(Param2, "allAvailableTIs").replace(Param3, _count.String).replace(Param4, cnt.String));
			self.assertEqualMsg(_wod.status, _status, WodStatusMessage.replace(Param1, app.workOrderStatusEnumToString(_status)).replace(Param2, app.workOrderStatusEnumToString(_wod.status)));
		endif;
		
		if not _wod.isKindOf(CM_WodExportReturn) then
			/*
			Export Return Work Order go From Approved to Complete
			*/
			if _actioned then
				self.assertEqualMsg(_wod.status, WO_STATUS_ACTIONED, WodStatusMessage.replace(Param1, app.workOrderStatusEnumToString(WO_STATUS_ACTIONED)).replace(Param2, app.workOrderStatusEnumToString(_wod.status)));
				cnt := _wod.CM_WorkOrderTIDtl.allActionedTIs.size;
				self.assertTrueMsg(cnt = _count, WodIncorrectNumberOf.replace(Param1, "Actioned TIs").replace(Param2, "allActionedTIs").replace(Param3, _count.String).replace(Param4, cnt.String));
				
				cnt := _wod.CM_WorkOrderTIDtl.allAvailableTIs.size;
				self.assertTrueMsg(cnt &lt;&gt; _count, WodIncorrectNumberOf.replace(Param1, "Available TIs").replace(Param2, "allAvailableTIs").replace(Param3, _count.String).replace(Param4, cnt.String));
				
			endif;
		endif;
		
		
	endif;
	
	/*
	Action Status Check
	*/
	
	/*
	Check Jobs
	*/
	if _actioned then
		if useJobs then
			self.xCheckWorkOrderJob(_wod,_status,_count,_useDD);
		endif;
	endif;
	
	/*
	Part Complete Check
	*/
	if _status = WO_STATUS_PARTCOMPLETE then
		if _wod.status = WO_STATUS_COMPLETE then
			self.assertEqualMsg(_wod.status, WO_STATUS_COMPLETE, WodStatusMessage.replace(Param1, app.workOrderStatusEnumToString(WO_STATUS_COMPLETE)).replace(Param2, app.workOrderStatusEnumToString(_wod.status)));
		else
			self.assertEqualMsg(_wod.status, _status, WodStatusMessage.replace(Param1, app.workOrderStatusEnumToString(_status)).replace(Param2, app.workOrderStatusEnumToString(_wod.status)));
		endif;
	endif;
	
	/*
	Complete Check 
	*/
	if _status = WO_STATUS_COMPLETE then	
		self.assertEqualMsg(_wod.status, _status, WodStatusMessage.replace(Param1, app.workOrderStatusEnumToString(_status)).replace(Param2, app.workOrderStatusEnumToString(_wod.status)));
		cnt := _wod.CM_WorkOrderTIDtl.allCompleteTIs.size;
		self.assertTrueMsg(cnt = _count, WodIncorrectNumberOf.replace(Param1, "Completed TIs").replace(Param2, "allCompleteTIs").replace(Param3, _count.String).replace(Param4, cnt.String));
		self.xCheckWorkOrderTransaction(_wod,_transType);
		
		cnt := workOrder.CM_WorkOrderTI.allTIs.size;
		if workOrder.allWoDtls.size = 1 then
			self.assertTrueMsg(cnt = _count, WodIncorrectNumberOf.replace(Param1, "All TIs").replace(Param2, "allTIs").replace(Param3, _count.String).replace(Param4, cnt.String));
		else
			//This looks wrong probably should be using a loop. first and last doesn't give you the values in between on the first woDtl and last wODtl
			self.assertTrueMsg(cnt = (workOrder.allWoDtls.first.CM_WorkOrderTIDtl.allCompleteTIs.size + workOrder.allWoDtls.last.CM_WorkOrderTIDtl.allCompleteTIs.size), WodIncorrectNumberOf.replace(Param1, "All TIs").replace(Param2, "allTIs").replace(Param3, (workOrder.allWoDtls.first.CM_WorkOrderTIDtl.allCompleteTIs.size + workOrder.allWoDtls.last.CM_WorkOrderTIDtl.allCompleteTIs.size).String).replace(Param4, cnt.String));
		endif;
	endif;
	
end;</source>
        <Parameter name="_wod" type="CM_WorkOrderDtl"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_count" type="Integer"/>
        <Parameter name="_transType" type="Integer"/>
        <Parameter name="_actioned" type="Boolean"/>
        <Parameter name="_useDD" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xCheckWorkOrderJob" id="48e8aeb9-f4cd-4e2b-be79-7aefb930f286">
        <source>xCheckWorkOrderJob(_wod    	: CM_WorkOrderDtl;
				   _status 	: Integer;
				   _count   : Integer;
				   _useDD   : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2023 navma1 ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
21 Dec 2023 navhl20 Bug 61861: EUP | Work Order Transport Mode change - issues
15 Feb 2024	navpw1	TFS: 59411 (62272) - Added support for release by type
12 Sep 2024	navpw1	TFS: 65623 (65624) - Added support for Any Id Any Amount

*/

vars
	job			: CM_Job;
	jobTiCount,
	cnt			: Integer;
	wle			: CM_WorkListEntry;
	request		: CM_Request;
	woClass		: Class;
	
begin
	cnt := _wod.CM_WorkOrderTIDtl.allJobs.size;
	job := _wod.CM_WorkOrderTIDtl.allJobs.first;
	
	self.assertTrueMsg(cnt &gt; 0, "No Work order jobs have been created for this work order detail : " &amp; _wod.taskID);
	
	/*
	Check job Type
	*/

	woClass  := _wod.getWodJobClass();
	self.assertTrueMsg(job.isKindOf(woClass), "The request is null or of the wrong type");
	
	
	/*
	Check Request Type
	*/
	request := job.allRequests.first;
	woClass  := _wod.getWodJobRequestClass;
	self.assertTrueMsg(request.isKindOf(woClass), "The request is null or of the wrong type");
	
	/*
	1- When Need to have update tranaction
	*/
	
	if _wod.isKindOf(CM_WodToDo) and _wod.CM_WodToDo.myWorkOrderDetail = null then					//21.11.2023 navhl20 #61861
		self.assertTrueMsg(_wod.CM_WorkOrderTIDtl.allWODtlTransactions.size &gt;1 , 
		"Incorrect amount of transactions have been created ,At this stage there must be at least 2 Transactions");
	endif;
	
	
	self.assertTrueMsg(job &lt;&gt; null,"Job has not been created for work order detail : " &amp; _wod.taskID);
	
	/*
	2- Check Work List Entries
	*/
	
	cnt := job.workListEntries.size;
	if self.opts.includesKey(UT_WO_OPTS_ReleaseByTypeCount) then
		self.assertTrueMsg(cnt = self.opts.int(UT_WO_OPTS_ReleaseByTypeCount), "Work List Entries has not been created correctly Expected: " &amp;
							self.opts.int(UT_WO_OPTS_ReleaseByTypeCount).String &amp; " | Actual: " &amp; cnt.String);
	else
		self.assertTrueMsg(cnt = _count, "Work List Entries has not been created correctly Expected: " &amp;
							_count.String &amp; " | Actual: " &amp; cnt.String);
	endif;
	
	foreach wle in job.workListEntries do 
		if wle.myTrackedItem = null then
			self.assertTrueMsg(wle.myTrackedItem = null, "Work List entry doesn't have tracked Item : " &amp; _wod.taskID);
		endif;
	endforeach;
	
	
	if _useDD then
	// workPoint Job sheet &lt;&gt; null
	//myOperWle .status = current status 
		if _status = WO_STATUS_APPROVED then
			self.assertTrueMsg(wle.CM_WOWLE.myOperationalWLE.status = JOB_UNACTIONED,"Work List Operation Status must be unactioned : " &amp; _wod.taskID);
		endif;
	endif;
	/*
	3- Check Job Tracked Items
	*/
	
	if job.isWorkOrderJob then
		cnt := job.CM_WorkOrderJob.allTrackedItems.size;
		if self.opts.includesKey(UT_OPTS_WorkOrderJobTICount) then
			jobTiCount :=  self.opts.int(UT_OPTS_WorkOrderJobTICount);
			self.assertTrueMsg(cnt = jobTiCount, 
			"The jobs tracked items set has not been populated it must have :" &amp;jobTiCount.String &amp; " Currently only : " &amp; cnt.String);
		elseif self.opts.bool(UT_OPTS_IsAnyAmount) then
			self.assertTrueMsg(cnt = _count-1, 
			"The jobs tracked items set has not been populated it must have :" &amp;(_count-1).String &amp; " Currently only : " &amp; cnt.String);
		else
			self.assertTrueMsg(cnt = _count, 
			"The jobs tracked items set has not been populated it must have :" &amp;_count.String &amp; " Currently only : " &amp; cnt.String);
		endif;
	endif;
	/*
	4- Check Work order status
	*/
	if _status = WO_STATUS_COMPLETE then
		foreach wle in job.workListEntries do
			self.assertTrueMsg(wle.status = JOB_COMPLETE,"Work List Status must be complete : " &amp; _wod.taskID);
			if _useDD then
				self.assertTrueMsg(wle.CM_WOWLE.myOperationalWLE.status = JOB_COMPLETE,"Work List Operation Status must be complete : " &amp; _wod.taskID);
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_wod" type="CM_WorkOrderDtl"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_count" type="Integer"/>
        <Parameter name="_useDD" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xCheckWorkOrderTransaction" id="5f0c5470-ec60-495c-bcef-a3e1442397cf">
        <source>xCheckWorkOrderTransaction(_wod 		: CM_WorkOrderDtl;
						   _transType	: Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2023 navma1 ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation

*/

vars
	woTrans : CM_WOTransaction;
	found	: Boolean;
begin
	
	foreach woTrans in _wod.allWODtlTransactions do 
		
		if woTrans.type = _transType then
			found := true;
			break;
		endif;
	endforeach;
	
	if not found then
		self.assertNotEqual( found = false, "The expected Transaction not created : " &amp; app.getWorkOrderTransactionStr(_transType));
	endif;
epilog

end;</source>
        <Parameter name="_wod" type="CM_WorkOrderDtl"/>
        <Parameter name="_transType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xCreateJobSheet" id="ad139385-343a-4c5b-8144-7d06c023c96d">
        <source>xCreateJobSheet():CM_WorkPointJobSheet;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jun 2023	navhl20	ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
28 Jun 2023 navma1  Bug 58920: MTN - 1090 Exception when actioning the Release Cargo Work Order for Export Bookings
12 Sep 2024	navpw1	TFS: 65623 (65624) - Made it so that the correct type of work point/ job sheet is created

*/
constants
	WPJS: String  =  	"UTHL58543JSS";
vars
	myPxyWorkPointJobSheet,
	realJobSheet				: CM_WorkPointJobSheet;
	workPoint					: CM_WorkPoint;
	pxyWorkOrder,
	workOrder					: 	CM_WorkOrder;
	startDT,
	now,
	endDT,
	shiftDT						: 	TimeStamp;
	tmpTime   					: 	Time;
	allShiftsDays				: 	CM_ShiftStartDateCodeDict;
	shift,
	shift1						: 	CM_Shift;
	allJobArr					: 	CM_JobSet;
	wpjs 						: String;			//TFS 60623
begin
	wpjs := WPJS;									//TFS 60623
	if self.opts.includesKey("WPJobSheet") then		//TFS 60623
		wpjs := self.opts.str("WPJobSheet").String;	//TFS 60623
	endif;											//TFS 60623
	self.xDeleteJobSheet(wpjs);						//28.06.2023 navma1 #58920
	
	//now := app.actualTimeServer();
	now := app.actualTimeServer().addDays(-30);
	
	startDT.setDate(now.date());
	tmpTime.setTime(0,0,0,0);
	startDT.setTime(tmpTime);
	
	
	endDT.setDate(now.date() + 30);
	tmpTime.setTime(23,59,59,0);
	endDT.setTime(tmpTime);
	
	create allShiftsDays transient;
	allShiftsDays.purge;
	self.getMyTerminal().getShiftsFromRange(allShiftsDays, startDT, endDT);
	
	if self.opts.includesKey("Shift") then				//22.03.2024 navhl20 #62863
		shiftDT := self.opts.timestamp("Shift");
	endif;
	
	//Create JobSheet
	if allShiftsDays.isNotEmpty then
		shift := allShiftsDays.first;
	endif;
	
	if self.opts.includesKey(UT_OPTS_CreateWorkPoint) and self.opts.includesKey(UT_OPTS_WorkPointId) then
		workPoint := self.getMyTerminal.allWorkPointsByCode[self.opts.str(UT_OPTS_WorkPointId)];
		if workPoint = null then
			workPoint := self.addWorkPoint(self.opts.str(UT_OPTS_WorkPointId), false);
		else
			self.deleteWorkPoint(self.opts.str(UT_OPTS_WorkPointId));
			workPoint := self.addWorkPoint(self.opts.str(UT_OPTS_WorkPointId), false);
		endif;
	else
		workPoint := self.getMyTerminal.allWorkPointsByCode["UT_WPROAD"];
	endif;
	
	realJobSheet := self.getMyTerminal.allJobSheetsForWorkPoints[shift.startDateTime];
	if realJobSheet &lt;&gt; null then
		app.myTrxDA.trxDeleteWorkPointJobSheet(realJobSheet, app.myPassport);
	endif;
	
	if shiftDT.isValid then								//22.03.2024 navhl20 #62863
		foreach shift1 in allShiftsDays do
			if shift1.startDateTime &lt;= shiftDT and shift1.endDateTime &gt;= shiftDT then
				shift := shift1;
				break;
			endif;
		endforeach;
	endif;
	
	create myPxyWorkPointJobSheet transient;
	myPxyWorkPointJobSheet.setProxy(shift,self.getMyTerminal,workPoint,shift.startDateTime,wpjs,"","","");
	
	app.myTrxCA.trxCreateWorkPointJobSheet(myPxyWorkPointJobSheet, realJobSheet, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	return realJobSheet;
epilog
	delete myPxyWorkPointJobSheet;
	if allShiftsDays &lt;&gt; null then
		allShiftsDays.purge;
		delete allShiftsDays;
	endif;
end;</source>
        <ReturnType type="CM_WorkPointJobSheet"/>
    </JadeMethod>
    <JadeMethod name="xCreateJobSheetShip" id="82168822-3897-4908-af68-39b473fa18c9">
        <source>xCreateJobSheetShip(_id : String):CM_WorkPointJobSheet;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Dec 2023 navhl20 ChangeRequest 58400:[61619] EUP | Ship Operations in DD - [54176.050] Mobile App changes
22 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
*/
constants
	
vars
	myPxyWorkPointJobSheet,
	realJobSheet				: CM_WorkPointJobSheet;
	workPoint					: CM_WorkPoint;
	pxyWorkOrder,
	workOrder					: 	CM_WorkOrder;
	startDT,
	now,
	endDT,
	shiftDT						: 	TimeStamp;
	tmpTime   					: 	Time;
	allShiftsDays				: 	CM_ShiftStartDateCodeDict;
	shift,
	shift1: 	CM_Shift;
	allJobArr					: 	CM_JobSet;
begin
	
	self.xDeleteJobSheet(_id);
	//now := app.actualTimeServer();				//22.03.2024 navhl20 #62863
	now := app.actualTimeServer().addDays(-30);		//22.03.2024 navhl20 #62863
	
	startDT.setDate(now.date());
	tmpTime.setTime(0,0,0,0);
	startDT.setTime(tmpTime);
	
	
	endDT.setDate(now.date() + 30);
	tmpTime.setTime(23,59,59,0);
	endDT.setTime(tmpTime);
	
	create allShiftsDays transient;
	allShiftsDays.purge;
	self.getMyTerminal().getShiftsFromRange(allShiftsDays, startDT, endDT);
	
	if self.opts.includesKey("Shift") then				//22.03.2024 navhl20 #62863
		shiftDT := self.opts.timestamp("Shift");
	endif;
	
	//Create JobSheet
	if allShiftsDays.isNotEmpty then
		shift := allShiftsDays.first;
	endif;
	workPoint := self.addWorkPoint("WP_62863",false);
	
	realJobSheet := self.getMyTerminal.allJobSheetsForWorkPoints[shift.startDateTime];
	if realJobSheet &lt;&gt; null then
		app.myTrxDA.trxDeleteWorkPointJobSheet(realJobSheet, app.myPassport);
	endif;
	
	if shiftDT.isValid then								//22.03.2024 navhl20 #62863
		foreach shift1 in allShiftsDays do
			if shift1.startDateTime &lt;= shiftDT and shift1.endDateTime &gt;= shiftDT then
				shift := shift1;
				break;
			endif;
		endforeach;
	endif;
	
	create myPxyWorkPointJobSheet transient;
	myPxyWorkPointJobSheet.setProxy(shift,self.getMyTerminal,workPoint,shift.startDateTime,_id,"","","");
	
	app.myTrxCA.trxCreateWorkPointJobSheet(myPxyWorkPointJobSheet, realJobSheet, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	return realJobSheet;
epilog
	delete myPxyWorkPointJobSheet;
	if allShiftsDays &lt;&gt; null then
		allShiftsDays.purge;
		delete allShiftsDays;
	endif;
end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_WorkPointJobSheet"/>
    </JadeMethod>
    <JadeMethod name="xCreateWorkOrder" id="9bcd66e3-f24d-452a-bb0c-d392bd4ab7c7">
        <source>xCreateWorkOrder(_pxyWorkOrder : CM_WorkOrder io;
				_realWorkOrder : CM_WorkOrder io;
				_id 		   : String;
				_woStatus 	   : Integer;
				_allWod		   : CM_WorkOrderDtlArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
18 Apr 2023 navhl20 ChangeRequest 57569:[57601] EUP - [Framework] Refactor Actioning Work Order Tasks
*/

vars
	totalReq      : Integer;
	dtRequired,
	dtStart	      :	TimeStamp;
	remarks       : String;
	emails        : CM_EmailEntityByTypeNameDict;
	wodDtl		  : CM_WorkOrderDtl;
begin
	
	
	deleteWorkOrder(_id);
	
	if self.opts.includesKey("DtRequired") then
		dtRequired := self.opts.str("DtRequired").TimeStamp;
	endif;
	
	
	if self.opts.includesKey("Remarks") then
		remarks := self.opts.str("Remarks");
	endif;
	
	create emails transient;
	
	_pxyWorkOrder.setProxy(		
			emails, 							//_allEmailAddresses
			null, 								//_customerReference
			false, 								//_emailNotification
			app.actualTimeServer, 				//_enteredByDT
			app.getMyUser(), 					//_enteredByUser 
			'',									//_approvedBy
			app.getMyUser().myOrganisation, 	// _myOrganisation
			app.myPassport.myTerminal, 			//_myTerminal
			remarks,  							//_remarks
			dtRequired,							//_requiredByDT
			dtStart, 							//_startAtDT
			_woStatus 							//_taskStatus    WO_STATUS_USERENTRY
			);
			
			
	_pxyWorkOrder.setID( _id );	
	
	foreach wodDtl in _allWod do
		_pxyWorkOrder.setProxyWorkOrderTask( wodDtl, dtRequired, null, false,null, null);
	endforeach;
	
	app.myTrxCA.trxCreateWorkOrder(_pxyWorkOrder, _realWorkOrder, app.myPassport);	
	if app.myPassport.hasErrors  and app.myPassport.allErrors.includesErrorCode(TaskCargoTypeMismatch) then
		assertTrxError(TaskCargoTypeMismatch);
		self.clearExpectedTrxErrors();
	else
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	endif;
epilog
	delete emails;
end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrder" usage="io"/>
        <Parameter name="_realWorkOrder" type="CM_WorkOrder" usage="io"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_woStatus" type="Integer"/>
        <Parameter name="_allWod" type="CM_WorkOrderDtlArray"/>
    </JadeMethod>
    <JadeMethod name="xCreateWorkOrderDetail" id="1829b541-033a-4023-811a-c8b6e33fa4a3">
        <source>xCreateWorkOrderDetail(_pxyWod  	: CM_WorkOrderDtl input;
					   _detailType  : Integer;
					   _todoTaskSet : CM_ToDoTaskDescSet;
					   _allTIs      : CM_TISet;
					   _allChilds   : CM_TISet);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
17 Apr 2023 navhl20 ChangeRequest 57322:[57323] EUP - VAS Task linked with Receive Cargo work Order
18 Apr 2023 navhl20 ChangeRequest 55442:[57629] EUP - Pack Cargo Work Order - Enhancement
16 May 2023 navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
06 Jun 2023 navma1  ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
27 Jun 2023 navlw1	ChangeRequest 58730: EUP | Link bill of lading item to Receive work orders
28 Jun 2023 navma1  Bug 58920: MTN - 1090 Exception when actioning the Release Cargo Work Order for Export Bookings
04 Jul 2023	navma1	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
25 Jul 2023	navlw1	ChangeRequest 58336:[59189] EUP | Delivery Dispatch Screen - Unit Tests [Receive Rail]
25 Jul 2023	navlw1	ChangeRequest 58336:[59296] EUP | Delivery Dispatch Screen - Unit Tests [Release Rail]
27 Jul 2023	navlw1	ChangeRequest 58336:[58723] EUP | Delivery Dispatch Screen - Unit Tests Unit Test for Release by Type Splitable cargo items
30 Aug 2023 navhl20 ChangeRequest 59819:[60443] EUP | Delivery Dispatch Screen - Unit Tests - [3]
09 Oct 2023	navhl20	ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
12 Dec 2023 navhl20 ChangeRequest 58400:[61619] EUP | Ship Operations in DD - [54176.050] Mobile App changes
05 Jul 2024 navhl20	ChangeRequest 61368: EUP* | Adding Pack Reserve Child to Packing Work order Release Request
20 Dec 2024	navhl20 Bug MTN-33681: MTN - Unexpected Program error on the Road Gate form
*/


vars
	terminal 			 : CM_Terminal;
	autoRTQ 			 : Boolean;
	requiredByDT,
	arrivedDT,
	relDate				 : TimeStamp;
	toDoTaskID 			 : Integer;
	toDoTask 			 : CM_ToDoTaskDesc;
	root		  		 : CM_Root;
	target,
	unpackLoc			: CM_TerminalArea;
	voyage 				: CM_Voyage;
	train				: CM_Train;
	operator			: CM_Operator;
	subTerm1			: CM_SubTerminal;
	code 				: String;
	transportMode 		: Integer;
	booking				: CM_BookingRef;
	transObj			: Object;
	release				: CM_BulkRelease;
	todoSet				: CM_ToDoTaskDescSet;
	bol					: CM_BOL;
	bookingRefItem		: CM_BookingRefItem;
	woId				: String;
	reserveDetail,
	reserveChild   	    : CM_ReserveDetail; // 27.07.2023 navlw1 tfs #58723
begin
	
	if self.opts.includesKey("WOId") then
		woId := opts.str("WOId").String;
	endif;
	
	/*
	Delete Work Order First
	*/
	self.deleteWorkOrderNoValidation(woId);
	
	root 	 := CM_Root.firstInstance;
	terminal := app.myPassport.myTerminal;

	/*
	Work Order DTL
	*/
	
	if self.opts.includesKey("RequiredByDT") then
		requiredByDT := opts.str("RequiredByDT").TimeStamp;
	endif;
	
	/*
	Change Voyage and Pack
	*/
	
	if self.opts.includesKey("Voyage") then
		code 	  := opts.str("Voyage");
		arrivedDT := opts.timestamp("dtArrived").TimeStamp;
		voyage 	  := terminal.allVoyagesByCode[code,arrivedDT];
	endif;
	
	/*
	Pack
	*/
	
	if self.opts.includesKey("SubTerminal") then
		code 	 := opts.str("SubTerminal");
		subTerm1 := terminal.allSubTerminals[code];
	endif;
		
	/*
	Move
	*/
	if self.opts.includesKey("AutoRTQ") then
		autoRTQ := opts.bool("AutoRTQ");
	endif;
	
	if self.opts.includesKey("TargetTA") then
		target := terminal.allTerminalAreas[opts.str('TargetTA')].CM_TerminalArea;
	endif;
	
	/*
	Receive
	*/
	if self.opts.includesKey("booking") then
		code 	:= opts.str("booking");
		booking := terminal.allBookingRefsByRef[code];
	endif;
	
	if self.opts.includesKey(UT_OPTS_Booking) then
		code 	:= opts.str(UT_OPTS_Booking);
		booking := terminal.allBookingRefsByRef[code];
	endif;
	
	if self.opts.includesKey("bol") then							//10.5.2023 navhl20 #56631[56185]
		bol := self.opts.obj("bol").CM_BOL;
	endif;
	
	if self.opts.includesKey("transportMode") then					 //28.06.2023 navma1 #58920
		transportMode:= opts.int("transportMode");
	endif;
	
	if self.opts.includesKey("transObj") and opts.includesKey("dtArrived") then 
		code 	  := opts.str("transObj");
		arrivedDT := opts.timestamp("dtArrived").TimeStamp;
		if transportMode = TI_TRANSMODE_RAIL then // 25.07.2023 navlw1 #58336[59189];
			transObj := terminal.allTrainsOnTerminal[code,arrivedDT];
			train := transObj.CM_Train;
		else
			transObj  := terminal.allVoyagesByCode[code,arrivedDT];
		endif;
	elseif self.opts.includesKey("VoyageObj") then						//9.10.2023 navhl20 #59638
		transObj := self.opts.obj("VoyageObj").CM_Voyage;
	endif;

	/*
	Release
	*/
	if opts.includesKey("bulkReleaseCode") and opts.includesKey("bulkReleaseDT") then
		code 	:=  opts.str("bulkReleaseCode");
		relDate := opts.timestamp("bulkReleaseDT").TimeStamp;
		release := terminal.allBulkReleasesByCodeDate[code, relDate];
		if release &lt;&gt; null and release.releaseByType then
			reserveDetail := release.allReserveDetails.first(); // 27.07.2023 navlw1 tfs #58723
			reserveChild  := release.allReservePackingChildren.first();
		endif;
	endif;
	
	if self.opts.includesKey("reserve") then							//20.12.2024 navhl20 #33681
		reserveDetail := self.opts.obj("reserve").CM_ReserveDetail;
	endif;
	
	/*
	UnPack
	*/
	if self.opts.includesKey("UnpackTA") then
		unpackLoc := terminal.allTerminalAreas[opts.str('UnpackTA')].CM_TerminalArea;
	endif;
	
	/*
	Todo
	*/
	if self.opts.includesKey("ToDoTaskID") then
		toDoTaskID := opts.int("ToDoTaskID");
	endif;
	
	if toDoTaskID &lt;&gt; null then
		toDoTask := root.allToDoTaskDescriptions[toDoTaskID];
	endif;
	
	_pxyWod.setRequiredByDT(requiredByDT);								//02.06.2023 navma1 #58296
	if _allTIs &lt;&gt; null and _allTIs.isNotEmpty then // 27.07.2023 navlw1 tfs #58723
		_allTIs.copyNoDups(_pxyWod.CM_WorkOrderTIDtl.allSelectedTIs);
	endif;
	
	if _pxyWod.isKindOf(CM_WodMove) then
		_pxyWod.CM_WodMove.setProxyMove(null,target,autoRTQ,null);
		
	elseif _pxyWod.isKindOf(CM_WodPack) then
		operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
		//_pxyWod.CM_WodPack.setProxyWodPack(_allChilds, null, null, null, null, null, operator, subTerm1, voyage, "MT", null, release, true); //18.4.2023 navhl20 #55442[57629]		//30.8.2023 navhl20 #59819[60443] //05.07.2024 navhl20 #61368
		_pxyWod.CM_WodPack.setProxyWodPack(_allChilds, null, null, null, null, null, operator, subTerm1, voyage, "MT", null, release, reserveChild, true);		//05.07.2024 navhl20 #61368
		
	elseif _pxyWod.isKindOf(CM_WodExportReturn) then
	
	elseif _pxyWod.isKindOf(CM_WodNullVoyage) then
		_pxyWod.CM_WodNullVoyage.setProxyWodNullVoyage(voyage);
	elseif _pxyWod.isKindOf(CM_WodReceive) then
		if bol &lt;&gt; null then																				//16.5.2023 navhl20 #56631[56185]
			_pxyWod.CM_WodReceive.setProxyWodReceival(null, null, bol, null, null, transObj,transportMode);
		else
			if booking &lt;&gt; null then																		//06.06.2023 navma1 #58339
				bookingRefItem := booking.allBookingRefItems.first;
			endif;
			_pxyWod.CM_WodReceive.setProxyWodReceival(booking, bookingRefItem, null, null, null, transObj,transportMode);		//17.4.2023 navhl20 #57322[57323]
		endif;
		
	elseif _pxyWod.isKindOf(CM_WodRelease) then
		if transObj.isKindOf(CM_Voyage) then
			voyage := transObj.CM_Voyage;
		endif;
		_pxyWod.CM_WodRelease.setProxyWodRelease(release, transportMode, voyage, train, booking, bookingRefItem, reserveDetail);				//04.07.2023 navma1 #58952
	
	elseif _pxyWod.isKindOf(CM_WodToDo) then
		if _todoTaskSet &lt;&gt; null then
			_pxyWod.CM_WodToDo.setPxyWoToDo(false, null, null, _todoTaskSet);
		else
			create todoSet transient;
			todoSet.add(toDoTask);
			_pxyWod.CM_WodToDo.setPxyWoToDo(false, null, null, todoSet);
		endif;
		
	elseif _pxyWod.isKindOf(CM_WodUnpack) then
		_pxyWod.CM_WodUnpack.setProxyWodUnpack( unpackLoc );
	endif;
	
	if _pxyWod.isWorkOrderTIDtl then
		if _pxyWod.CM_WorkOrderTIDtl.canAddTodoTaskToCargoWO then
			if _todoTaskSet &lt;&gt; null and _todoTaskSet.isNotEmpty then
			_pxyWod.CM_WorkOrderTIDtl.setProxyAllToDoRequests( _todoTaskSet );
			endif;
		endif;
	endif;
epilog
	delete todoSet;
end;</source>
        <Parameter name="_pxyWod" type="CM_WorkOrderDtl" usage="input"/>
        <Parameter name="_detailType" type="Integer"/>
        <Parameter name="_todoTaskSet" type="CM_ToDoTaskDescSet"/>
        <Parameter name="_allTIs" type="CM_TISet"/>
        <Parameter name="_allChilds" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="xDeleteJobSheet" id="40d6712a-1b2d-4ee5-80c7-bb8f6f9b8a6f">
        <source>xDeleteJobSheet(_id :String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Jun 2023 navma1 Bug 58920: MTN - 1090 Exception when actioning the Release Cargo Work Order for Export Bookings

*/

vars
	wpJobSheet : CM_WorkPointJobSheet;
begin
	wpJobSheet := self.getMyTerminal.getWorkPointJobSheet(_id);
	
	if wpJobSheet&lt;&gt; null then
		app.myTrxDA.trxDeleteWorkPointJobSheet(wpJobSheet,app.myPassport);
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	endif;
epilog

end;</source>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
    <JadeMethod name="xGetJobSheet" id="fca232c2-2df3-4095-95f8-835fd19ff1cd">
        <source>xGetJobSheet(_workPointCode, _jobSheetExternalName : String; _terminal : CM_Terminal) : CM_WorkPointJobSheet;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2024	navpw1	Initial creation JIRA: MTN-14770

*/

vars
	jobSheet			: CM_WorkPointJobSheet;
	workPoint			: CM_WorkPoint;
	assertChecks		: Boolean;
	
begin
	assertChecks := true; //Should always assert unless explicitly told not to
	
	if self.opts.includesKey(UT_OPTS_AssertChecks) then
		assertChecks := self.opts.bool(UT_OPTS_AssertChecks);
	endif;
	
	workPoint := _terminal.allWorkPointsByCode[_workPointCode];
	if assertChecks then
		self.assertTrueMsg(workPoint &lt;&gt; null, "Could not find work point for code: '" &amp; _workPointCode &amp; "'");
	elseif workPoint = null then
		return null;
	endif;
	
	foreach jobSheet in workPoint.allJobSheets as CM_WorkPointJobSheet do
		if jobSheet.externalName &lt;&gt; _jobSheetExternalName then
			continue;
		endif;
		return jobSheet;
	endforeach;
	
	if assertChecks then
		self.assertTrueMsg(false, "Could not find job sheet by external name: '" &amp; _jobSheetExternalName &amp; "'");
	endif;
	
	return null;
	
end;</source>
        <Parameter name="_workPointCode" type="String"/>
        <Parameter name="_jobSheetExternalName" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_WorkPointJobSheet"/>
    </JadeMethod>
    <JadeMethod name="xLoadTranMapWorkOrder" id="412f76b6-f31d-428d-a68d-6ff887b31ebf">
        <source>xLoadTranMapWorkOrder();
/*
Purpose: TFS 51904  Work Orders. If there is an estimate for a cargo work order, when it is apporved create an invoice from the cash receipt, if the payment type is prepay.

Date		Who		Reason
01NOV2021	NAVAB1	TFS 51904
*/

vars
	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;

begin
	fileName    := "CargoLoaded";
	mapName := "UT_WOMove1";
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?
Cargo,UT_WOMove1,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,**Any**,All,UT_LineTypeWOMove' &amp; CrLf;
	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := self.getTerminal().getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	self.assertTrueMsg(bank.currentTransactionMap = cargoMap, "loadTranMapWorkOrder1 " &amp; mapName&amp; " is not current map");
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="xUnApproveWorkOrder" id="baecdbae-576d-4ebe-9583-f3e08359d588">
        <source>xUnApproveWorkOrder(_wo : CM_WorkOrder io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Sep 2024	navah1	Initial creation
11 Sep 2024 navah1  Bug 65907: EUP - Error 1310 when actioning work order that has been un - approved before
*/

vars
	errors : String;
begin 

	app.myTrxUA.trxWOUnApprove(_wo,app.myPassport);
	if app.myPassport.hasErrors then
		errors := app.myPassport.getErrorsAsString;
		self.assertTrueMsg(false ,
						  'Error : Failed Un-Approving Work order : ' 		  &amp;   _wo.id 	  &amp; CrLf &amp; 
						  'Trx Errors: '						 		 	  &amp;    errors  );
	endif;
	
epilog

end;</source>
        <Parameter name="_wo" type="CM_WorkOrder" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xValidateVoyageStatus" id="1cfe0cd5-f67a-4437-9194-893ef86367f4">
        <source>xValidateVoyageStatus(_voyage : CM_Voyage; _expectedStatus : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2022		navma1	Initial creation

*/

vars
	current	,
	expected : CM_VoyageStatus;
begin
	
	expected := app.myRoot.allVoyageStatuses[_expectedStatus];
	current  := app.myRoot.allVoyageStatuses[_voyage.status];
	
	if _voyage.status &lt;&gt; _expectedStatus then
		
		assertTrueMsg(false , 
					'Voyage Code : ' 			&amp;	 _voyage.code &amp; CrLf   &amp;
					'Expected Satus :'			&amp;    expected.description  &amp; CrLf  &amp;
					'Current Satus :'			&amp;    current.description );
		
	endif;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_expectedStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xValidateWorkOrderStatus" id="3404f0a7-778d-4095-8652-86bfc60ca120">
        <source>xValidateWorkOrderStatus(_wo			   : CM_WorkOrder;
						 _expectedStatus   : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2022		navma1	Initial creation

*/

vars
	current	,
	expected : CM_VoyageStatus;
begin

	if _wo.taskStatus &lt;&gt; _expectedStatus then
		
		assertTrueMsg(false , 
					'Work Order Code : ' 		&amp;	 _wo.id &amp; CrLf   &amp;
					'Expected Satus :'			&amp;    expected.description  &amp; CrLf  &amp;
					'Current Satus :'			&amp;    current.description );
		
	endif;
	
epilog

end;</source>
        <Parameter name="_wo" type="CM_WorkOrder"/>
        <Parameter name="_expectedStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xWorkOrderAnyIdAnyAmtLoad" id="f2d8f05c-47d9-483d-9a16-3ddeb28f846a">
        <source>xWorkOrderAnyIdAnyAmtLoad(_workOrder			: CM_WorkOrder io;
							_wod				: CM_WorkOrderDtl;
							_vehicleName, 
							_driverName, 
							_gateName			: String;
							_releaseRequest		: CM_BulkRelease;
							_reserveDetail		: CM_ReserveDetail;
							_vbsTimeSlot		: CM_VehicleBookingTimeSlot io;
							_workPoint, 
							_workPointJobSheet	: String;
							_tisToLoad			: CM_TIArray;
							_testLoadFail		: Boolean;
							_tiToFail			: CM_TrackedItem;
							_cargoType			: CM_CargoType;
							_terminalUTHelper	: UT_HelperAdmTerm input;
							_terminal			: CM_Terminal);
/*

Purpose:			Runs Code for Any Id Any Amount Load. Can partially or fully load vehicles with cargo that allows duplicates

Parameters:			_workOrder			CM_WorkOrder				The work order to use for processing the load to truck (Required)
					_wod				CM_WorkOrderDtl				The work order detail to use for processing the load to truck (Required)
					_vehicleName		String						The vehicle name to use for the vehicle visit record
					_driverName			String						The driver name for the vehicle visit record
					_gateName			String						The gate name to use for the vehicle visit record
					_releaseRequest		CM_BulkRelease				The bulk release to use for loading the truck (Required)
					_reserveDetail		CM_ReserveDetail			The reserve detail line to use for loading the truck (Required)
					_vbsTimeSlot		CM_VehicleBookingTimeSlot	The vehicle booking time slot to use for loading the truck (Optional)
					_workPoint			String						The work point for the work order job
					_workPointJobSheet	String						The work point job sheet for the work order job
					_tisToLoad			CM_TIArray					The tis to laod inside an array
					_testLoadFail		Boolean						Whether we need to test for a failure
					_tiToFail			CM_TrackedItem				The ti that should fail load testing
					_cargoType			CM_CargoType				The cargo type we are laoding to the truck
					_terminalUTHelper	UT_HelperAdmTerm			The terminal helper used to create data
					_terminal			CM_Terminal					The terminal we are using to load the truck

Return Value:		NONE

Date				Who		Reason
20 November 2024	navpw1	Initial creation JIRA: MTN-14770

*/

vars
	foundAnyAmount,
	foundPlaceholderWoWle,
	expectFailure,
	ctAllowDuplicates				: Boolean;
	wsCompleteTruckRequest,
	wsPutCargoLoadToReleaseRequest,
	truckOid,
	cargoOid,
	operatorStr,
	trackedItemId					: String;
	loopVar,
	trackedItemsAssigned,
	operationalWlesAssigned,
	wowlesCompleted,
	countTisToLoad,
	countTisToLoadPlusPlaceholder	: Integer;
	gate							: CM_GateArea;
	job								: CM_Job;
	roadJob							: CM_RoadJob;
	pxyWorkPointJobSheet,
	realJobSheet					: CM_WorkPointJobSheet;
	allJobArr						: CM_JobSet;
	ti								: CM_TrackedItem;
	wle,
	operationalWle					: CM_WorkListEntry;
	woJob							: CM_WOReleaseCargoJob;
	wowle							: CM_WOWLE;
	vehicle							: CM_Vehicle;
	vvr								: CM_VehicleVisitRecord;
	
begin
	/*
	** Setup/Check Section
	*/
	self.assertNotNullMsg(_workOrder, "Passed in null work order " &amp; method.name &amp; " | _workOrder");
	self.assertNotNullMsg(_wod, "Passed in null work order detail " &amp; method.name &amp; " | _wod");
	self.assertNotNullMsg(_terminal, "Passed in null terminal " &amp; method.name &amp; " | _terminal");
	self.assertNotNullMsg(_releaseRequest, "Passed in null release request " &amp; method.name &amp; " | _releaseRequest");
	self.assertNotNullMsg(_tisToLoad, "Passed in null ti set " &amp; method.name &amp; " | _tisToLoad");
	self.assertNotNullMsg(_cargoType, "Passed in null cargo type " &amp; method.name &amp; " | _cargoType");
	
	if _testLoadFail then
		self.assertNotNullMsg(_tiToFail, "Passed in null ti to fail " &amp; method.name &amp; " | _tiToFail");
	endif;
	
	self.assertTrueMsg(_tisToLoad.isNotEmpty, "_tisToLoad is empty" &amp; method.name);
	
	ctAllowDuplicates := _cargoType.isAllowDuplicates;
	
	/*
	** Start Helper Method
	*/
	
	// Create vehicle visit
	vvr := _terminalUTHelper.xCreateVehicleVisitRecord(_vehicleName, _driverName, _driverName, null, _terminal, _gateName);
	self.assertNotNullMsg(vvr, "vvr");
	
	//Attach VBS Slot to VVR
	_vbsTimeSlot := _terminalUTHelper.xUpdateVbsTimeSlot(_vbsTimeSlot, app.actualTimeAppServer(), app.actualTimeAppServer(), _vbsTimeSlot.myVehicleBookingTerminal, _vbsTimeSlot.myCarrier, null, _vbsTimeSlot.myDriver, _vbsTimeSlot.myVehicle, self.createdByUnitTest(null), true,
														false, null, vvr, _vbsTimeSlot.myVBTimeSlotType, _vbsTimeSlot.id, null, null, null, _vbsTimeSlot.myVBTimeSlotType.preGateInCheck, _vbsTimeSlot.myVBTimeSlotType.preGateOutCheck, _vbsTimeSlot.myVBTimeSlotType.kioskCheck, null, null);
	self.assertNotNullMsg(_vbsTimeSlot, method.name &amp; " Update: _vbsTimeSlot");
	
	// Approve &amp; Action the work order
	self.xApproveWorkOrder(_workOrder);
	
	self.opts.purge;
	if ctAllowDuplicates then
		self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, 1);
	else
		self.opts.addAssoc(UT_WO_OPTS_ReleaseByTypeCount, _reserveDetail.totalRequested);
	endif;
	
	self.xCheckWorkOrder(_wod, WO_STATUS_APPROVED, 0, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	
	//Create Gate Entity
	_terminalUTHelper.opts.purge;
	_terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyId, true);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_IsAnyAmount, true);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_Vbsti, _vbsTimeSlot.allVehicleBookingItems.first);
	_terminalUTHelper.opts.addAssoc(UT_OPTS_Weight, _vbsTimeSlot.allVehicleBookingItems.first.maxWeight);
	vvr := _terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null, 1, _releaseRequest);
	
	self.assertEqualMsg(vvr.vehicle.allRoadJobs.size, 1, "Expecting only 1 Road Job");
	_terminalUTHelper.opts.purge();
	
	//Move Vehicle to Lane
	gate := self.getPGate(_gateName);
	
	self.moveVehicleToLane(vvr.vehicle, gate, 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(gate, 1));
	
	_terminalUTHelper.xMoveVehicleToYard(vvr.vehicle);
	
	foreach job in _terminal.myWOJobSheet.allJobsByRequiredDTPriority do
		if job.getWorkOrder() = _workOrder and job.isKindOf(CM_RoadJob) then
			roadJob := job.CM_RoadJob;
			break;
		endif;
	endforeach;
	
	self.assertNotNullMsg(roadJob, "roadJob");
	
	realJobSheet := self.xGetJobSheet(_workPoint, _workPointJobSheet, _terminal);
	self.assertNotNullMsg(realJobSheet, "realJobSheet");
	self.assertEqualMsg(realJobSheet.externalName, _workPointJobSheet, "realJobSheet does not match expected externalName: '" &amp; _workPointJobSheet &amp; "' Found: '" &amp; realJobSheet.externalName &amp; "'");
	
	//Allocate job to jobSheet
	create allJobArr transient;
	pxyWorkPointJobSheet := app.createUpdateProxy(realJobSheet).CM_WorkPointJobSheet;
	
	allJobArr.add(roadJob);
	app.myTrxUA.trxUpdateWOJobSheet(allJobArr, pxyWorkPointJobSheet, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(roadJob, "roadJob");
	
	vehicle := roadJob.myVehicle;
	
	loopVar := 1;
	while loopVar &lt;= _tisToLoad.size do
		ti := _tisToLoad[loopVar];
		//Add checks for warnings and exclude them
		wsPutCargoLoadToReleaseRequest := '{
		"isAcknowledged": "",
		"warningsAcknowledged": true,
		"releaseOid": "' &amp; _releaseRequest.getOidAsString() &amp; '",
		"reserveDetailOid": "' &amp; _reserveDetail.getOidAsString() &amp; '",
		"targetLocationOid": "' &amp; vehicle.getOidAsString() &amp; '",
		"amount": ' &amp; ti.totalQuantity.asStringJMT &amp; '
		}';
		cargoOid := ti.getOidAsString();
		operatorStr := null;
		expectFailure := false;
		
		self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoLoadToRelease.name, operatorStr, wsPutCargoLoadToReleaseRequest, cargoOid, expectFailure);
		self.assertNoTrxErrorsOrWarnings();
		
		loopVar += 1;
	endwhile;
	
	if _testLoadFail then
		ti := _tiToFail;
		
		wsPutCargoLoadToReleaseRequest := '{
		"isAcknowledged": "",
		"warningsAcknowledged": true,
		"releaseOid": "' &amp; _releaseRequest.getOidAsString() &amp; '",
		"reserveDetailOid": "' &amp; _reserveDetail.getOidAsString() &amp; '",
		"targetLocationOid": "' &amp; vehicle.getOidAsString() &amp; '",
		"amount": ' &amp; ti.totalQuantity.asStringJMT &amp; '
		}';
		cargoOid := ti.getOidAsString();
		operatorStr := null;
		expectFailure := true;
		
		//Web errors should only check the code not worry about text can be complicated to construct
		self.opts.purge;
		self.opts.addAssoc("ExpectedResponse", "Code :" &amp; Vbs_max_weight_exceeded_load.String &amp; ". " &amp; app.getErrorString1(Vbs_max_weight_exceeded_load, app.getWeightForDefaultDisplay(_vbsTimeSlot.allVehicleBookingItems.first.maxWeight) &amp; ' x ' &amp; _reserveDetail.getCargoTypeDescr &amp; Space &amp; _reserveDetail.getProductISOTypeDescr()));
		self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargoLoadToRelease.name, operatorStr, wsPutCargoLoadToReleaseRequest, cargoOid, expectFailure);
		self.opts.purge;
		self.logMessage("Expected Exception Raised: '" &amp; app.getErrorString1(Vbs_max_weight_exceeded_load, app.getWeightForDefaultDisplay(_vbsTimeSlot.allVehicleBookingItems.first.maxWeight) &amp; ' x ' &amp; _reserveDetail.getCargoTypeDescr &amp; Space &amp; _reserveDetail.getProductISOTypeDescr()));
		
	endif;
	
	self.logMessage("Proceeding to Complete Work Order, Release Request and Road Exit the Road Job");
	
	countTisToLoad := _tisToLoad.size;
	countTisToLoadPlusPlaceholder := countTisToLoad + 1;
	
	//Verify Road Job has right amount of wle's. Should be the loaded amount plus the placeholder Wle
	self.assertTrueMsg(roadJob.workListEntries.size = countTisToLoadPlusPlaceholder, "Road Job WLE Count Expected: '" &amp; countTisToLoadPlusPlaceholder.String &amp; "' | Actual: '" &amp; roadJob.workListEntries.size.String &amp; "");
	
	//Verify WLE's on Road Job
	foreach wle in roadJob.workListEntries do
		if wle.isAnyAmount then
			self.logMessage("Wle is Any Amount");
			self.assertTrueMsg(wle.myRequest &lt;&gt; null, "wle.myRequest | Request is null on wle");
			self.assertTrueMsg(wle.myRequest.isDeliveryRequest, "Expected a delivery request to be assigned to this wle");
			self.assertTrueMsg(wle.myRequest.isAnyId, "Expected the Request to be Any Id");
			self.assertTrueMsg(wle.myRequest.isAnyAmount, "Expected the Request to be Any Amount");
			
			self.assertTrueMsg(wle.isAnyId, "Expected the wle to be Any Id");
			self.assertTrueMsg(wle.isAnyAmount, "Expected the wle to be Any Amount");
			foundAnyAmount := true;
			continue;
			
		endif;
		
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		//Verify that the wle request is kind of CM_TiRequest if not a wle for any amount
		self.assertTrueMsg(wle.myRequest.isKindOf(CM_TIRequest), "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has a tracked item assigned
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle request has a tracked item assigned
		self.assertTrueMsg(wle.myRequest.CM_TIRequest.trackedItem &lt;&gt; null, "wle.myRequest.CM_TIRequest.trackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify that the wle has the correct quantity
		self.assertTrueMsg(wle.quantity = wle.myTrackedItem.totalQuantity, "wle.quantity should be set to Tracked Item Quantity. Expected: '" &amp; wle.myTrackedItem.totalQuantity.String &amp; "' | Actual: '" &amp; wle.quantity.String &amp; "'");
		
		//Verify that the wle request has the correct quantity
		if ctAllowDuplicates then
			self.assertTrueMsg(wle.myRequest.CM_TIRequest.quantity = wle.myTrackedItem.totalQuantity, "wle.myRequest.CM_TIRequest.quantity should be set to Tracked Item Quantity. Expected: '" &amp; wle.myTrackedItem.totalQuantity.String &amp; "' | Actual: '" &amp; wle.myRequest.CM_TIRequest.quantity.String &amp; "'");
		else
			self.assertTrueMsg(wle.myRequest.CM_TIRequest.quantity = 0, "wle.myRequest.CM_TIRequest.quantity should be set to 0. Expected: '0' | Actual: '" &amp; wle.myRequest.CM_TIRequest.quantity.String &amp; "'");
		endif;
		
		//Verify Yard WLES link to Work Order WLES
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		
		//Verify Work Order WLE has quantity matching yard wle
		self.assertEqualMsg(wle.quantity, wle.myWorkOrderWLE.quantity, "The quantity on the Work Order wle should match the yard wle");
		
	endforeach;
	
	self.assertTrueMsg(foundAnyAmount, "Expected one of the road job wles to be an any id, any amount wle");
	
	self.opts.purge;
	_terminalUTHelper.opts.purge;
	
	//Verify Work Order is part complete
	self.opts.addAssoc(UT_OPTS_IsAnyAmount, true);
	if ctAllowDuplicates then
		self.xCheckWorkOrder(_wod, WO_STATUS_PARTCOMPLETE, countTisToLoadPlusPlaceholder, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	else
		self.opts.addAssoc(UT_OPTS_WorkOrderJobTICount, countTisToLoad); //We have only loaded 2 tracked items to work order
		self.xCheckWorkOrder(_wod, WO_STATUS_PARTCOMPLETE, _reserveDetail.totalRequested, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	endif;
	
	self.opts.purge;
	_terminalUTHelper.opts.purge;
	
	//Verify Work order has 16 wles
	self.assertTrueMsg(_wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := _wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	if ctAllowDuplicates then
		self.assertTrueMsg(woJob.workListEntries.size = countTisToLoadPlusPlaceholder, "Expected Work Order Job to have '" &amp; countTisToLoadPlusPlaceholder.String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	else
		self.assertTrueMsg(woJob.workListEntries.size = _reserveDetail.totalRequested, "Expected Work Order Job to have '" &amp; _reserveDetail.totalRequested.String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	endif;
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		//if wowle.myTrackedItem = null then
		if wowle.myTrackedItem = null and not foundPlaceholderWoWle then
			self.logMessage("Wowle is the placeholder one");
			self.assertTrueMsg(wowle.myRequest &lt;&gt; null, "wle.myRequest | Request is null on wle");
			self.assertTrueMsg(wowle.myRequest.isWOReleaseCargoRequest, "Expected a delivery request to be assigned to this wle");
			self.assertTrueMsg(wowle.status = JOB_UNACTIONED, "Expected the Wowle to be unactioned");
			
			//Check has operationalWle with any id any amount
			operationalWle := wowle.myOperationalWLE;
			self.assertTrueMsg(operationalWle &lt;&gt; null, "myOperationalWLE is null on wowle");
			self.assertTrueMsg(operationalWle.myRequest &lt;&gt; null, "myOperationalWLE.myRequest | Request is null on wle");
			self.assertTrueMsg(operationalWle.myRequest.isDeliveryRequest, "Expected a delivery request to be assigned to this myOperationalWLE");
			self.assertTrueMsg(operationalWle.myRequest.isAnyId, "Expected the Request to be Any Id on the myOperationalWLE");
			self.assertTrueMsg(operationalWle.myRequest.isAnyAmount, "Expected the Request to be Any Amount on the myOperationalWLE");
			self.assertTrueMsg(operationalWle.isAnyId, "Expected the myOperationalWLE to be Any Id");
			self.assertTrueMsg(operationalWle.isAnyAmount, "Expected the myOperationalWLE to be Any Amount");
			
			foundPlaceholderWoWle := true;
			continue;
			
		endif;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wowle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		if not ctAllowDuplicates and trackedItemId = "No Tracked Item Assigned" then //These are allowed to be unassigned from a operationalWle
			continue;
		endif;
		
		self.assertTrueMsg(wowle.myOperationalWLE &lt;&gt; null, "wowle.myOperationalWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wowle.status = JOB_COMPLETE, "Expected the Wowle to be complete");
		
	endforeach;
	
	//Verify 1 Work Order wle is unactioned
	self.assertTrueMsg(foundPlaceholderWoWle, "Could not find the placeholder wowle on the work order job");
	
	//Do complete pack load by request
	wsCompleteTruckRequest := '{
	"targetLocationOid": "",
	"isAcknowledged": "",
	"warningsAcknowledged": false
	}';
	truckOid := vehicle.getOidAsString();
	operatorStr := null;
	expectFailure := false;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCompleteTruck.name, operatorStr, wsCompleteTruckRequest,truckOid, expectFailure);
	self.assertNoTrxErrorsOrWarnings();
	
	
	//Verify that work order is part completed 
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_WorkOrderJobTICount, countTisToLoad);
	if ctAllowDuplicates then
		self.xCheckWorkOrder(_wod, WO_STATUS_PARTCOMPLETE, countTisToLoadPlusPlaceholder, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	else
		self.xCheckWorkOrder(_wod, WO_STATUS_PARTCOMPLETE, _reserveDetail.totalRequested, TRANS_TYPE_WO_TIREC_UPDATED, true, false);
	endif;
	
	//Verify Work order has 15 wles
	self.assertTrueMsg(_wod.CM_WodRelease.allJobs.size &gt; 0, "Expected Work Order Detail to have a job assigned");
	
	woJob := _wod.CM_WodRelease.allJobs.first.CM_WOReleaseCargoJob;
	if ctAllowDuplicates then
		self.assertTrueMsg(woJob.workListEntries.size = countTisToLoadPlusPlaceholder, "Expected Work Order Job to have '" &amp; countTisToLoadPlusPlaceholder.String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	else
		self.assertTrueMsg(woJob.workListEntries.size = _reserveDetail.totalRequested, "Expected Work Order Job to have '" &amp; _reserveDetail.totalRequested.String &amp; "' wle's assigned | Actual: '" &amp; woJob.workListEntries.size.String &amp; "'");
	endif;
	
	//Verify Work Order wles have yard wle's assigned
	foreach wle in woJob.workListEntries do
		self.assertTrueMsg(wle.isWorkOrderWle, "Expected a work order wle");
		wowle := wle.CM_WOWLE;
		
		if wowle.myTrackedItem &lt;&gt; null then
			trackedItemsAssigned += 1;
		endif;
		
		if wowle.myOperationalWLE &lt;&gt; null then
			operationalWlesAssigned += 1;
		endif;	
		
		if wowle.status = JOB_COMPLETE then
			wowlesCompleted += 1;
		endif;
		
	endforeach;
	
	//Verify 2 wowle's have tracked items assigned
	self.assertEqualMsg(trackedItemsAssigned, countTisToLoad, "Checking Work Order wles with Tracked Items Assigned Expected:'" &amp; countTisToLoad.String &amp; "' | Actual: '" &amp; trackedItemsAssigned.String &amp; "'");
	
	//Verify 2 wowle's have a operational wle assigned
	self.assertEqualMsg(operationalWlesAssigned, countTisToLoad, "Checking Work Order wles with Operational Wle Assigned Expected:'" &amp; countTisToLoad.String &amp; "' | Actual: '" &amp; operationalWlesAssigned.String &amp; "'");
	
	//Verify 2 wowle's are complete
	self.assertEqualMsg(wowlesCompleted, countTisToLoad, "Checking Work Order wles that are complete Expected:'" &amp; countTisToLoad.String &amp; "' | Actual: '" &amp; wowlesCompleted.String &amp; "'");
	
	//Verify road job is complete
	self.assertTrueMsg(roadJob.status = JOB_COMPLETE, "Expected the road job to be complete");
	
	//Verify Road Job has 15 wles
	self.assertEqualMsg(roadJob.workListEntries.size, countTisToLoad, "Expected Road Job to have '" &amp; countTisToLoad.String &amp; "' wle's assigned");
	
	//Verify Yard wles have Work Order wle's assigned
	foreach wle in roadJob.workListEntries do
		if wle.myTrackedItem &lt;&gt; null then
			trackedItemId :=  wle.myTrackedItem.id;
		else
			trackedItemId := "No Tracked Item Assigned";
		endif;
		
		self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "wle.myTrackedItem is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		self.assertTrueMsg(wle.myWorkOrderWLE &lt;&gt; null, "wle.myWorkOrderWLE is null for wle for tracked item: '" &amp; trackedItemId &amp; "'");
		//Verify Work Order wle is complete
		self.assertTrueMsg(wle.status = JOB_COMPLETE, "Expected the wle to be complete");
		
	endforeach;
	
	//Do Road Exit
	self.roadExit(vvr);
	
epilog
	delete allJobArr;
	delete pxyWorkPointJobSheet;
	
end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrder" usage="io"/>
        <Parameter name="_wod" type="CM_WorkOrderDtl"/>
