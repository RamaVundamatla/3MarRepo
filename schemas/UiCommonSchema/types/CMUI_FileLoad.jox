	self.lblFileName.visible :=false;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="init" id="68931627-4960-4f37-b37e-cc73e814cb94">
        <updating/>
        <source>init(_masterObj : CM_Object; _caption : String) updating;
/*
Date				Who		Reason
21 Mar 2022			navsrk20 TFS 52821 EUP - Documents Linked to Cargo Types	
31 Mar 2022			navhl20  TFS 53185 Screen validation issue for File Attachment
*/
vars

begin
	self.btnOk.enabled := false;          																													//31.03.2022	navhl20 	TFS #53185
	self.myMasterObject := _masterObj;
	//self.caption := 'File Load for ' &amp; _caption;																											//21.03.2022	navsrk20	TFS #52821
	if self.myMasterObject &lt;&gt; null and self.myMasterObject.isKindOf(CM_CargoBOLType) then																	//21.03.2022	navsrk20	TFS #52821
		self.caption := 'File Load for ' &amp; self.myMasterObject.CM_CargoBOLType.abbreviation &amp; " " &amp; self.myMasterObject.CM_CargoBOLType.description;		//21.03.2022	navsrk20	TFS #52821
	else																																					//21.03.2022	navsrk20	TFS #52821
		self.caption := 'File Load for ' &amp; _caption;																										//21.03.2022	navsrk20	TFS #52821
	endif;																																					//21.03.2022	navsrk20	TFS #52821
end;
</source>
        <Parameter name="_masterObj" type="CM_Object"/>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="load" id="a9e91fd8-c4d2-46bf-9336-c892da9f47ef">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// ---------------------------------------------------------------------------
// Created:     24 January 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	self.beginClassNotification(CM_FileData,false,Object_Create_Event,Response_Continuous,null);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadCategory" id="719380c1-b46f-4513-8059-b3e4cd8bf827">
        <source>loadCategory();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 December 2022	navvt20	TFS CR 55299 Task 55520: UI - File Load and File Attachment UI changes

*/

vars
	fileCategory : CM_FileDataCategory;
	category : Integer;
begin
	if self.myMasterObject &lt;&gt; null then
		category := self.myMasterObject.getFileCategory(); // ### TFS CR 55299 TASK 55985 28DEC2022 NAVAB1
		foreach fileCategory in app.myRoot.allFileDataCategories where fileCategory.categoryContext = category do // ### TFS CR 55299 TASK 55985 28DEC2022 NAVAB1
			self.cmbCategory.itemObject[ self.cmbCategory.addItem( fileCategory.description ) ] := fileCategory;
		endforeach;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="acee5d46-f630-424b-8bfe-a607ed7be7a4">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 December 2022	navvt20	TFS CR 55299 Task 55520: UI - File Load and File Attachment UI changes
15 February 2023    navds21 ChangeRequest 56625:[56517] EUP - Print Documents at Kiosk
*/

vars
	workOrder : CM_WorkOrder;
begin
	inheritMethod();	
	self.loadCategory();
	self.txtFileName.enabled := false;				  		//TFS 56155
	
	if self.myMasterObject.isKindOf(CM_WorkOrder) then		//22.2.2023 navhl20	#56625[56517]
		workOrder := self.myMasterObject.CM_WorkOrder;
		if workOrder.allowAttachDocsToPrintKiosk() then
			self.chkAutoPrint.visible := true;
			if workOrder.taskStatus = WO_STATUS_CANCELLED 
			or workOrder.taskStatus = WO_STATUS_COMPLETE 
			or workOrder.archived then
				self.chkAutoPrint.enabled := false;
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="60266965-3dfa-47ed-8d61-e7b558820d89">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 16 February 2023 14:10:32.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017364, locale);
	btnBrowse.translateCaption(Xlat_0005072, locale);
	chkAutoPrint.translateCaption(Xlat_0025572, locale);
	lblCategory.translateCaption(Xlat_0025255, locale);
	lblDescription.translateCaption(Xlat_0005073, locale);
	lblFileName.translateCaption(Xlat_0005074, locale);
	lblHeading.translateCaption(Xlat_0005075, locale);
	lblRemarks.translateCaption(Xlat_0025256, locale);
end;</source>
    </JadeMethod>
</GUIClass>
