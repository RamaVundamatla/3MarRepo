    <JadeMethod name="addObjectsToTable" id="0206463a-e5cc-4899-943b-60c67b5ffd5d">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwer1	Initial creation HAT 2189

*/

vars
	iter : Iterator;
	dutyDoc	: CM_DutyDoc;
	dutyDocTerminal : CM_DutyDocTerminalRoot;
		breakOut : Boolean;
begin
	
	dutyDocTerminal:=app.myDutyDocRoot.allDutyDocTerminalRoots[self.myTerminal];
	
	if self.filterBillNum &lt;&gt; null then
		iter:=dutyDocTerminal.allDutyDocsById.createIterator;
		dutyDocTerminal.allDutyDocsById.startKeyGeq(self.filterBillNum,iter);
	else
		if self.filterTicket &lt;&gt; null then
			iter:=dutyDocTerminal.allDutyDocsByTicket.createIterator;
			dutyDocTerminal.allDutyDocsByTicket.startKeyGeq(self.filterTicket,iter);
		else
			iter:=dutyDocTerminal.allDutyDosByStatus.createIterator;
			if self.filterStatus &lt;&gt; null then
				dutyDocTerminal.allDutyDosByStatus.startKeyGeq(self.filterStatus,null,iter);
			endif;
		endif;
	endif;
	
	
	while iter.next(dutyDoc) do
		if self.filterBillNum &lt;&gt; null then
			if not dutyDoc.id.startsWith(self.filterBillNum) then
				break;
			endif;
		else
			if self.filterTicket &lt;&gt; null then
				if not dutyDoc.ticket.startsWith(self.filterTicket) then
					break;
				endif;
			else
				if self.filterStatus &lt;&gt; null then
					if dutyDoc.status &lt;&gt; self.filterStatus then
						break;
					endif;
				endif;
			endif;
		endif;	
			
		if self.includeObject(dutyDoc, app.myPassport) then
			self.addObjectToTable(dutyDoc, _numItems, breakOut);
			
			if breakOut then
				break;
			endif;
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
