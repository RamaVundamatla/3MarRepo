    <JadeMethod name="populateSect4" id="fd1eba5f-4fbc-4373-9a8d-c44a287149d3">
        <updating/>
        <source>populateSect4( _doLayoutCheck : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2015	cnwndl1	Initial creation Par 36777

*/

vars

	parentWidth : Real;
	frame : CMUI_Frame;
	
	topMMs : Real;
	leftMMs : Real;
	rightMMs : Real;
	bottomMMs : Real;
	
	topPixels : Real;
	heightPixels : Real;
	
	adjustedHeight : Real;
	commonMaxHeight : Real;
	bottomOfPrint : Real;
	

begin

	frame := self.frmSect4;

	parentWidth := frame.width - 1;

//	if _doLayoutCheck then
//		frame.borderStyle := 1;
//		frame.caption := frame.name &amp; "@" &amp; leftMMs.String &amp; "," &amp; topMMs.String &amp; "-" &amp; rightMMs.String &amp; "," &amp; bottomMMs.String &amp; "mm";
