    <JadeMethod name="tIFCSUM_MSC" id="4a83405f-89e7-43f3-b9e7-1967de918a55">
        <source>tIFCSUM_MSC();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 October 2023	jlirs1	Initial creation

*/
constants
	OperatorCode = "MSC";
	BoatName = "XLBOATMSC";
	VoyageName1 = "KE304R_1";
	VoyageName2 = "KE304R_2";
	VoyageName3 = "KE304R_3";
	EDIPartyName : String = "IFCSUMAUBNE94B";
vars
	passport : CM_Passport;
	operator : CM_Operator;
	voyage : CM_Voyage;
	vessel : CM_Vessel;
	ediData : CM_EDIData;
	ediFile : CM_EDIFile;
	ediParty : CM_EDIParty;
	rules : CM_EDIPartyRules;
	cargoType : CM_CargoType;
	carCargoType : CM_CargoType;
	hondaConsign : CM_ConsigneeConsignor;
	hondaMake : CM_VehicleMake;
	ti : CM_TrackedItem;
	tempStr : String;
	ediText : String;
	port : CM_Port;
begin

	self.setTerminalConfig(ProcIFCSUMPortAuthority, true);
	passport := app.myPassport;
	operator := app.myRoot.allOperators.getAtKey(OperatorCode);
	self.assertNotNullMsg(operator, 'MSC operator not found in set up');

	self.deleteVoyage(VoyageName1);
	voyage	:= self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage);
	self.deleteVoyage(VoyageName2);
	voyage	:= self.getVoyage(VoyageName2);
	self.assertIsDeleted(voyage);
	self.deleteVoyage(VoyageName3);
	voyage	:= self.getVoyage(VoyageName3);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel	:= self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// now set up cleanly
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VoyageName1, BoatName, OperatorCode, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	voyage := self.addVoyageWithContainerStructur(VoyageName2, BoatName, OperatorCode, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	voyage := self.addVoyageWithContainerStructur(VoyageName3, BoatName, OperatorCode, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	beginTransaction;
	if voyage &lt;&gt; null then
		port := app.myRoot.allPorts["AUBNE"];
		if not voyage.includesPort(port) then
			voyage.addPortToAllPorts(port);
		endif;
		if not voyage.allOperators.includes(operator) then
			voyage.allOperators.add(operator);
		endif;
	endif;
	commitTransaction;

	carCargoType := app.myRoot.allCargoTypesById.getAtKey(7);
	hondaConsign := app.myRoot.allConsigneeConsignors.getAtKey("00172");
	if hondaConsign = null then
		hondaConsign := self.addConsigneeConsignor("00172","HONDA AUSTRALIA PTY",true,true,false);
	endif;
	hondaMake := app.myDutyDocRoot.allVehicleMakes.getAtKey("HONDA");
	self.assertTrueMsg(hondaMake &lt;&gt; null, "Vehicle Make of 'HONDA' not found during setup.");

	self.deleteEDIParty(EDIPartyName&amp;"_"&amp;OperatorCode);
	if app.isRunningInDMAST() then
		cargoType := app.myRoot.allCargoTypesById.getAtKey(10046);		//Cannon
	elseif app.isRunningInWMAST() then
		cargoType := app.myRoot.allCargoTypesById.getAtKey(10056);		//Cannon
	endif;
	
	ediParty := self.createEDIParty(EDIPartyName&amp;"_"&amp;OperatorCode, method.qualifiedName &amp; " Unit Test", "MSCA_TEST", operator); 
	self.createEDIPartyIFCSUMPOB49B(ediParty, hondaConsign, carCargoType, hondaMake, false, false, false, null, cargoType, false);
	rules := ediParty.getRulesForFileType(EDIFileType_IFCSUM94B);
	beginTransaction;
	rules.setPropertyValue(CM_EDIPartyIFCSUMRules::oneMEAPerGID.name, true);
	commitTransaction;

	ediText := self.xMSC_TANIA_KE304R_PortTest1;
	// load the edi data, verify and load to database
	ediFile	:= self.ediLoadFileName(ediText, EDIFileType_IFCSUMAUBNE94B, "IFCSUM", "IFCSUM_"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediDBLoad(ediFile); 
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
    ediData := ediFile.ediData;
    self.assertNotNull(ediData);
	self.assertEqualMsg(ediData.allEDITrackedItems.size, 3, "Total number of ediTis");
	voyage	:= self.getVoyage(VoyageName1);
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 2, "Total number of on ship Tis");
	foreach ti in voyage.allOnshipTIsByIdCargoType do
		if ti.id = "BMOV2100683" then
			self.assertEqualMsg(ti.cargoTypeDescr, "ISO Container", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.getPortOfOrigin(), "AUBEL", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.billOfLading, "MEDUD5003360", "For Cargo On Ship");
			self.assertEqualMsg(ti.dischargePort, "MYTPP", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.loadPort, "NZPOE", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.destinationPort, "MYTPP", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.quantity, 1, "For Cargo On Ship"); 
			self.assertEqualMsg(ti.weight.String, "23158.0000", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.totalVolume.String, "13.9900", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.commodity, "TBA", "For Cargo On Ship");
			self.assertEqualMsg(ti.consignee, "", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.getImExStatusString, "Export", "For Cargo on ship");
		elseif ti.id = "BMOV2349573" then
			self.assertEqualMsg(ti.cargoTypeDescr, "ISO Container", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.getPortOfOrigin(), "AUBEL", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.billOfLading, "MEDUD5003360", "For Cargo On Ship");
			self.assertEqualMsg(ti.dischargePort, "MYTPP", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.loadPort, "NZPOE", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.destinationPort, "MYTPP", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.quantity, 1, "For Cargo On Ship"); 
			self.assertEqualMsg(ti.weight.String, "22422.0000", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.totalVolume.String, "13.9900", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.commodity, "TBA", "For Cargo On Ship");
			self.assertEqualMsg(ti.consignee, "", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.getImExStatusString, "Export", "For Cargo on ship");
		endif;
	endforeach;

	
	ediText := self.xMSC_TANIA_KE304R_PortTest2;
	// load the edi data, verify and load to database
	ediFile	:= self.ediLoadFileName(ediText, EDIFileType_IFCSUMAUBNE94B, "IFCSUM", "IFCSUM_"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
    ediData := ediFile.ediData;
    self.assertNotNull(ediData);
	self.assertEqualMsg(ediData.allEDITrackedItems.size, 3, "Total number of ediTis");
	voyage	:= self.getVoyage(VoyageName2);
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 2, "Total number of on ship Tis");
	foreach ti in voyage.allOnshipTIsByIdCargoType do
		if ti.id = "BMOW2100683" then
			self.assertEqualMsg(ti.cargoTypeDescr, "ISO Container", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.getPortOfOrigin(), "AUBEL", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.billOfLading, "MEDUD5003362", "For Cargo On Ship");
			self.assertEqualMsg(ti.dischargePort, "MYTPP", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.loadPort, "NZPOE", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.destinationPort, "MYPEN", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.quantity, 1, "For Cargo On Ship"); 
			self.assertEqualMsg(ti.weight.String, "23158.0000", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.totalVolume.String, "13.9900", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.commodity, "TBA", "For Cargo On Ship");
			self.assertEqualMsg(ti.consignee, "", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.getImExStatusString, "Export", "For Cargo on ship");
		elseif ti.id = "BMOW2349573" then
			self.assertEqualMsg(ti.cargoTypeDescr, "ISO Container", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.getPortOfOrigin(), "AUBEL", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.billOfLading, "MEDUD5003362", "For Cargo On Ship");
			self.assertEqualMsg(ti.dischargePort, "MYTPP", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.loadPort, "NZPOE", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.destinationPort, "MYPEN", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.quantity, 1, "For Cargo On Ship"); 
			self.assertEqualMsg(ti.weight.String, "22422.0000", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.totalVolume.String, "13.9900", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.commodity, "TBA", "For Cargo On Ship");
			self.assertEqualMsg(ti.consignee, "", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.getImExStatusString, "Export", "For Cargo on ship");
		endif;
	endforeach;

	
	
	ediText := self.xMSC_TANIA_KE304R_PortTest3;
	// load the edi data, verify and load to database
	ediFile	:= self.ediLoadFileName(ediText, EDIFileType_IFCSUMAUBNE94B, "IFCSUM", "IFCSUM_"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
    ediData := ediFile.ediData;
    self.assertNotNull(ediData);
	self.assertEqualMsg(ediData.allEDITrackedItems.size, 3, "Total number of ediTis");
	voyage	:= self.getVoyage(VoyageName3);
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 2, "Total number of on ship Tis");
	foreach ti in voyage.allOnshipTIsByIdCargoType do
		if ti.id = "BMOV2100684" then
			self.assertEqualMsg(ti.cargoTypeDescr, "ISO Container", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.getPortOfOrigin(), "MYPKG", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.billOfLading, "MEDUD5003363", "For Cargo On Ship");
			self.assertEqualMsg(ti.dischargePort, "AUSYD", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.loadPort, "NZPOE", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.destinationPort, "AUSYD", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.quantity, 1, "For Cargo On Ship"); 
			self.assertEqualMsg(ti.weight.String, "23158.0000", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.totalVolume.String, "13.9900", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.commodity, "TBA", "For Cargo On Ship");
			self.assertEqualMsg(ti.consignee, "", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.getImExStatusString, "Export", "For Cargo on ship");
		elseif ti.id = "BMOV2349574" then
			self.assertEqualMsg(ti.cargoTypeDescr, "ISO Container", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.getPortOfOrigin(), "MYPKG", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.billOfLading, "MEDUD5003363", "For Cargo On Ship");
			self.assertEqualMsg(ti.dischargePort, "AUSYD", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.loadPort, "NZPOE", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.destinationPort, "AUSYD", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.quantity, 1, "For Cargo On Ship"); 
			self.assertEqualMsg(ti.weight.String, "22422.0000", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.totalVolume.String, "13.9900", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.commodity, "TBA", "For Cargo On Ship");
			self.assertEqualMsg(ti.consignee, "", "For Cargo On Ship"); 
			self.assertEqualMsg(ti.getImExStatusString, "Export", "For Cargo on ship");
		endif;
	endforeach;
	write "Fin.";
epilog

end;</source>
