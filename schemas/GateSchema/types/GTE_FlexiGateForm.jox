/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2016	cnwndl1	Initial creation	TFS 2473

*/

vars

	carrier : CM_Carrier;

begin

	if eventTag = 2473 then
		if fldrDetails.topSheet = self.shtTransfers then
			carrier := self.cmbCarrier.listObject.CM_Carrier;
			self.populateTblBulkRelease( carrier );
		endif;
