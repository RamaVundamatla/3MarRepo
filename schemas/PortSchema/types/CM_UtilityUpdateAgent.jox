Parameters:			

Return Value:		

Date		Who		Reason
29/11/2022 navmv20 TFS CR 55299 TASK 55516: Jade - Write TRX for new file category

*/

vars
	realFileDataCategory	: CM_FileDataCategory;
	expectedEdition 		: Integer;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyFileDataCategory, 'File Data Category proxy');
	
	_pxyFileDataCategory.pxyGetRealObjectAndEdition(realFileDataCategory, expectedEdition);
	self.raiseExceptionIfNull(realFileDataCategory, 'File Data Category');
	
	_pxyFileDataCategory.validateForUpdate();
		
	if not _passport.noErrors then
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realFileDataCategory, true);
	endif;
	
	realFileDataCategory.setForUpdate(_pxyFileDataCategory);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realFileDataCategory, false);
	endif;
epilog

end;

</source>
        <Parameter name="_pxyFileDataCategory" type="CM_FileDataCategory" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateFiles" id="2e8cbcf0-97b3-44fd-8f82-db6e6a34c7fe">
        <source>utlUpdateFiles(_pxyFiles : CM_FileDataSet input; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
26 August 2022		jlizm1	Initial creation TFS 54298 EUP - Simplified Voyage Work Order Process
01 Dec 2022 		navvt20 TFS CR 55299  Task 55520: UI - File Load and File Attachment UI changes
*/

vars
	pxyFileData	: CM_FileData;
	realFileData : CM_FileData;
	edition : Integer;
begin
	
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	self.raiseExceptionIfNull(_pxyFiles, 'Files');
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	foreach pxyFileData in _pxyFiles do
		pxyFileData.raiseExceptionIfNotProxy(method);
		pxyFileData.pxyGetRealObjectAndEdition(realFileData, edition);
		
		if realFileData = null then	
			app.raiseCMException1(ProxyMgrCannotLocateReal, CM_FileData.name, null, null);
			return;
		endif;
		
		realFileData.setForUpdate(pxyFileData);	// 1 dec 2022 navvt20 TFS 55520
	endforeach;

epilog

end;</source>
        <Parameter name="_pxyFiles" type="CM_FileDataSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateFinancialPeriodMap" id="976a74be-7d07-4a84-8c9b-46a1fa3858e0">
        <source>utlUpdateFinancialPeriodMap(_pxyMapping : CM_DebtorBankInvTypeDtl input; 	_passport : CM_Passport input);
// 23510
vars
	cancelSave		: Boolean;
	realInvoiceDescDebtor	: CM_DebtorBankInvTypeDtl;
	expectedEdition	: Integer;
begin

	self.initialiseActivity();

	_pxyMapping.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyMapping.pxyGetRealObjectAndEdition(realInvoiceDescDebtor, expectedEdition);
	
	if realInvoiceDescDebtor = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_DebtorInvoiceLineDesc.name, null, null);
		return;
	endif;

	app.myValUA.valFinancialPeriodMap(realInvoiceDescDebtor, _pxyMapping);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realInvoiceDescDebtor);

	if _passport.noErrors and realInvoiceDescDebtor.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Invoice Desc Debtor Mapping', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceDescDebtor, true);
	endif;
	
	if _passport.noErrors then
		realInvoiceDescDebtor.setForUpdate(_pxyMapping);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceDescDebtor, false);
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_MAPPING_UPDATE), false, realInvoiceDescDebtor);
	endif;

end;</source>
        <Parameter name="_pxyMapping" type="CM_DebtorBankInvTypeDtl" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateFormCustomisation" id="5aef65bf-5dc0-491a-8510-1652668671f8">
        <source>utlUpdateFormCustomisation(_proxy :CM_FormConfigForm; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     03 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
