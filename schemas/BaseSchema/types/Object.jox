<Class name="Object">
    <JadeMethod name="cnEcExceptionDetails" id="513535e0-f511-4ae4-b780-288f3400427f">
        <source>cnEcExceptionDetails(pExceptionObj:Exception):String;

vars
	errorDetails	: String;
	errorObject		: Object;
	errorItem		: String;

begin
	errorDetails	:=	"* Error " &amp; pExceptionObj.errorCode.String &amp; ": " &amp;
						pExceptionObj.text() &amp; " " &amp;
						pExceptionObj.extendedErrorText;
	
	errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; " Application: " &amp; app.name &amp; CrLf &amp;
						"      Schema: " &amp; currentSchema.name &amp; CrLf &amp;
						"        Type: " &amp; pExceptionObj.class().name;
	
	if pExceptionObj.reportingMethodDesc &lt;&gt; null then
		if pExceptionObj.reportingMethodDesc.isKindOf(PrimMethodCallDesc) then
			errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "    Reported: " &amp;
								pExceptionObj.reportingMethodDesc.receiverAsString().String &amp; " " &amp;
								pExceptionObj.reportingMethodDesc.getName();
		else
			errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "    Reported: " &amp;
								pExceptionObj.reportingMethodDesc.getReceiver().String &amp; " " &amp;
								pExceptionObj.reportingMethodDesc.getName();
		endif;
	endif;

	if pExceptionObj.currentMethodDesc &lt;&gt; null then
		if pExceptionObj.currentMethodDesc.isKindOf(PrimMethodCallDesc) then
			errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "   Caused by: " &amp;
								pExceptionObj.currentMethodDesc.receiverAsString().String &amp; " " &amp;
								pExceptionObj.currentMethodDesc.getName();
		else
			errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "   Caused by: " &amp;
								pExceptionObj.currentMethodDesc.getReceiver().String &amp; " " &amp;
								pExceptionObj.currentMethodDesc.getName();
		endif;
	endif;

	errorObject	:=	pExceptionObj.errorObject();
	errorItem	:=	pExceptionObj.errorItem;

 	if app.isValidObject(errorObject) then
		errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "Error Object: " &amp; errorObject.String;
	endif;

 	if errorItem &lt;&gt; null then
		errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "  Error Item: " &amp; errorItem;
	endif;
	
	errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; " Continuable: " &amp; pExceptionObj.continuable.cnEcGetYesNo();
	errorDetails	:=	errorDetails.trimBlanks() &amp; CrLf &amp; "   Resumable: " &amp; pExceptionObj.resumable.cnEcGetYesNo();
epilog
	return errorDetails;
end;</source>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetDuplicate" id="b3564ac8-f705-4048-b5c4-717a5e6b9504">
        <source>cnEcGetDuplicate(pFormat : CnEcXmlFormat; pInput: CnEcXmlStructureInstance):Object;
	// reimplement for an XML merge.
vars

begin
	return null;
end;

// 	code example: 	That could be reimplemented on a class called Person.
//					where 'employeeNumber' and 'dateOfBirth' determine a unique person
//					within a collection on Root called allEmployees 	

/*
vars

	empNumber		: Integer;
	birthDate		: Date;
	person			: Person;
	 
begin

	empNumber := cnEcXMLGetTheAttributeValue(pFormat, pInput, "Person","employeeNumber" ).Integer;
	birthDate := cnEcXMLGetTheAttributeValue(pFormat, pInput, "Person","dateOfBirth" ).Date; 
	
	if empNumber &lt;&gt; 0 and birthDate.isValid then	
		person :=  app.myRoot.allEmployees.getAtKey(empNumber,birthDate).Person;
	endif;

epilog

	return person;
	
end; */</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetExtractString" id="556c918b-b9cc-4065-ab5e-dd0f8daec1ad">
