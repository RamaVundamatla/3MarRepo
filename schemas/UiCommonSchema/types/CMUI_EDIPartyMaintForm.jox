        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasChangedX12315Rules" id="989de10b-50bf-4fd4-86a4-39acfc881879">
        <source>hasChangedX12315Rules():Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 February 2014	cnwrd1	Initial creation
 //cnwrd1 par #36184
26 Feb 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
*/

vars

begin
	return self.tblActions315.rows &gt; self.tblActions315.fixedRows or self.chkCreateBOLs.value or self.chkIsImport.value;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadData" id="b05dc420-9a8e-420d-aa2a-43d25371ad6b">
        <updating/>
        <source>loadData(_party :CM_EDIParty) updating, protected;
/****Changes

Date		Name	TFS#						Description
=======================================================================================================
21/11/2011	cnwcs5	CCMS POL 2122 / par 28696 - Initial creation - Empty Releases via COPARN
23/04/2012	cnwcs5	CCMS POL 2172 / par 29480 - coparn release updates
30/08/2012	cnwcs5	par 30097 
15/10/2012	cnwcs5	par 30483 - 				tab key does not work when table has no data
19/02/2013	cnwcs5	CCMS PNL 2243 / par 31185
24/07/2013	cnwcs5	par 31942
03/07/2015	cnwma1  PAR #36337  CCMS 2502 TFS 375  DPH - Consignor in the N1*SH
06/07/2015 	cnwma1  PAR# 36526 					Patch for Baplie File MEA segment
12/09/2016	cnwdap1	TFS 2566 					AAT EDI IFCSUM Party Rules
21/03/2017	cnwdap1	TFS 3734 					AAT Issues with IFCSUM
27/03/2017	cnwdap1	TFS 3825 					AAT PIA+5 used as Commodity
06/06/2017	cnwdap1	TFS 4434 					SNO COPARN Prenotes and bookings
21/08/2017	jlgrs1	TFS 6564 					add Coparn and Coreor RFF and NAD translation
22/08/2017	jlgdap1	TFS 6632 					Make COPARN Prenoets optional
31/08/2017	jlgrs1	TFS 6797 					SNO SpecialStow
14/11/2017	jlgrs1	TFS 5705  					SNO - EDIDataBooking Prenote release Req
18/04/2018	jlgrs1	TFS 8296 					add release req and prenotes to X12 301
10/08/2018	jlggb1	TFS 39344 					Ignore Expiry Dates
06/11/2018	jlgka1	39185, 39187				Add IFCSUM Rules for the FTX+AAA Ignore Remarks and
												ISO Container Cargo creation.
02/05/2019	jlgzm1	TFS 43425					SNO Append new bookings rather than replace
01/08/2019	jlgka1 	TFS 45467					SNO - Clean attribute in release request
02/02/2023	jlika1	TFS 56385					POB - IFCSUM Tranship				
14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
28 Aug 2023	jlirs1	TFS 59170 (57770) IFCSUM Breakbulk and Mixed Cargo BOP
04 Mar 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
22 Aug 2024	navlw1	TFS 65152: NSW | IFCSUM Enhancements
17 Mar 2025	naviv1	JIRA MTN-34341 NSW | 34310.020 Setting Operators on Voyage from IFCSUM files
========================================================================================================*/
vars
	assistant	: CMUI_Assistant;
	partyRules	: CM_EDIPartyRules;
	coparnRules	: CM_EDIPartyCoparnRules;
	voyage		: CM_Voyage;
	code,string	: String;
	row			: Integer;
	ifcsumRules	: CM_EDIPartyIFCSUMRules;			// TFS 2566
	invalid 	: Boolean;
	str 		: String;
begin
	assistant	:= self.myAssistant;
	self.btnFTXTransform.enabled:=false;
	self.btnNADTransform.enabled:=false;
	
	if _party &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, _party, invalid);
		self.txtName.text := _party.name;
		if invalid then 
			return;
		endif;
		self.txtDescription.text		:= _party.description;
		self.txtSenders.text			:= _party.getSendersAsString;	
		self.chkOnlyUseXlation.value			:=_party.onlyUseXlationOpForXlation; //jlier1	TFS 57187 22/3/23
		self.cmbXLOperator.setObject (_party.myTranslationOperator);
		
		foreach partyRules in _party.allEDIPartyRules do
			if partyRules.isKindOf (CM_EDIPartyCoparnRules) then
				coparnRules := partyRules.CM_EDIPartyCoparnRules;
				
				self.cmbSubTerminal.setIndexFromObject (coparnRules.myDefaultSubTerminal);
				self.cmbCarrier.setIndexFromObject (coparnRules.myDefaultCarrier);
				
				self.cmbReleaseType.setIndexForItemData (coparnRules.defaultReleaseType);
				self.cmbReleaseStatus.setIndexForItemData (coparnRules.defaultReleaseStatus);	// par 31185 feb 2013
				
				self.cmbVoyage.setIndexFromObject (coparnRules.myDefaultVoyage);
				
				self.cmbDeliveryReaso.text := (coparnRules.defaultDeliveryReasonDesc);
				self.cmbGradeDry.setIndexFromObject (app.myRoot.allAvailabilityGrades[coparnRules.defaultAvailabilityGrade]);
				self.cmbGradeReefer.setIndexFromObject (app.myRoot.allAvailabilityGrades[coparnRules.defaultAvailabilityGradeReefer]);
				self.cmbGenType.setIndexFromObject (coparnRules.myISOTypeForEQD_plus_RD);
				
				self.chkDelActioned.value			:= coparnRules.allowDelActioned;				// par 30097 Aug 2012
				self.chkDelArchived.value			:= coparnRules.allowDelArchived;				// par 30097 Aug 2012
				self.chkDelComplete.value			:= coparnRules.allowDelCompleted;				// par 30097 Aug 2012
				self.chkUpdActioned.value			:= coparnRules.allowUpdActioned;				// par 30097 Aug 2012
				self.chkUpdArchived.value			:= coparnRules.allowUpdArchived;				// par 30097 Aug 2012
				self.chkUpdCompleted.value			:= coparnRules.allowUpdCompleted;				// par 30097 Aug 2012
		
				self.chkEmailUpdate.value			:= coparnRules.sendEmailForUpdates;
				self.chkEmailDelete.value			:= coparnRules.sendEmailForDeletes;	
				self.chkEmailUpdErr.value			:= coparnRules.sendEmailForBlockedUpd;			// par 29481 May 2012
				self.chkEmailDelErr.value			:= coparnRules.sendEmailForBlockedDel;			// par 29481 May 2012
				self.chkUseISOGrpRR.value			:= coparnRules.useISOGroupForReleaseRequests;
				self.chkCreateGenRR.value			:= coparnRules.createReleaseForEQA_plus_RD;
				self.chkResetComplete.value			:= coparnRules.resetCompletedOnQtyIncrease;		// par 31185 Feb 2013
				self.chkRelByType.value				:= coparnRules.releaseByTypeOnly; 				// cnwrd1 33790
				self.chkUpdateVGM.value 			:= coparnRules.updateVGMForOnsiteCargo;			// TFS 4434
				self.chkPrenotes.value				:= coparnRules.createPrenotesForEQDWithID;		// TFS 6632
				self.chkAppendNewBookings.value 	:= coparnRules.appendNewBookings; 			// TFS 43425
				self.chkUseGateDoc.value 			:= coparnRules.getCoparnEDIDataStyle;
				self.chkReleaseIncNonClean.value 	:= coparnRules.defaultReleaseIncludeNonClean;	//jlgka1 TFS 45467
								
				self.loadRules (self.tblActionsCoparn, coparnRules.allEDIPartyRules, EDIFileType_Coparn);
				
			elseif partyRules.isKindOf (CM_EDIPartyIFTMCSRules) then
				self.loadRules (self.tblActionsIFTMCS, partyRules.allEDIPartyRules, EDIFileType_IFTMCS03A);
			elseif partyRules.isKindOf (CM_EDIPartyQatarRules) then	//29 Jun 2015	NDL	Par 36543
				self.loadRules (self.tblActionsQatar, partyRules.allEDIPartyRules, EDIFileType_XML_Milaha_Customs);
			elseif partyRules.isKindOf (CM_EDIPartyX12315Rules) then
				self.chkCreateBOLs.value := partyRules.CM_EDIPartyX12315Rules.createBOLs;
				self.chkIsImport.value := partyRules.CM_EDIPartyX12315Rules.isImport;		//26 Feb 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
				self.loadRules (self.tblActions315, partyRules.allEDIPartyRules, EDIFileTypeX12_315_4010); //cnwrd1 par #36184
			elseif partyRules.isKindOf (CM_EDIPartyX12301Rules) then       				//03/06/2015 cnwma1 PAR #36337
				self.chkUseN1SH.value := partyRules.CM_EDIPartyX12301Rules.useN1SH;
				self.chkUsePrenoteFromN7.value := partyRules.CM_EDIPartyX12301Rules.prenoteN7;
				self.chkUseRelReqFromY4.value := partyRules.CM_EDIPartyX12301Rules.relReqY4;
				self.cmbSubTerminal_1.setIndexFromObject(partyRules.CM_EDIPartyX12301Rules.myDefaultSubTerminal);
				self.cmbCarrier_1.setIndexFromObject(partyRules.CM_EDIPartyX12301Rules.myDefaultCarrier);
				self.cmbReleaseTypeX12301.setIndexForItemData(partyRules.CM_EDIPartyX12301Rules.defaultReleaseType);
				self.cmbReleaseStatusX12301.setIndexForItemData(partyRules.CM_EDIPartyX12301Rules.defaultReleaseStatus);	// par 31185 feb 2013
				self.cmbVoyage_1.setIndexFromObject(partyRules.CM_EDIPartyX12301Rules.myDefaultVoyage);
				self.cmbDeliveryReaso_1.text := partyRules.CM_EDIPartyX12301Rules.defaultDeliveryReasonDesc;
				self.cmbGradeDry_1.setIndexFromObject(app.myRoot.allAvailabilityGrades[partyRules.CM_EDIPartyX12301Rules.defaultAvailabilityGrade]);
				self.cmbGradeReefer_1.setIndexFromObject(app.myRoot.allAvailabilityGrades[partyRules.CM_EDIPartyX12301Rules.defaultAvailabilityGradeReefer]);
				self.cmbGenType_1.setIndexFromObject(partyRules.CM_EDIPartyX12301Rules.myISOTypeForGen);
			elseif partyRules.isKindOf (CM_EDIPartyBaplieRules) then       				//06/07/2015 cnwma1 PAR #36526
				self.chkEnableAtmo.value := partyRules.CM_EDIPartyBaplieRules.enableAtmosphere;
			elseif partyRules.isKindOf(CM_EDIPartyCoprarRules) then
				self.loadRules(self.tblActionsCoprar, partyRules.allEDIPartyRules, EDIFileType_Coprar);
			elseif partyRules.isKindOf(CM_EDIPartyCoreorRules) then
				self.chkIgnoreExpiryDates.value := partyRules.CM_EDIPartyCoreorRules.ignoreExpiryDates;
				self.loadRules(self.tblActionsCoreor, partyRules.allEDIPartyRules, EDIFileType_Coreor);
			elseif partyRules.isKindOf( CM_EDIPartyCuscarRules) then
				if partyRules.CM_EDIPartyCuscarRules.ediTypeShipManifest then
					self.optShipManifest.value := true;
					self.optBayPlan.value := false;
				else
					self.optBayPlan.value := true;
					self.optShipManifest.value :=	false;
				endif;
								
				self.loadRules (self.tblActionsCuscar, partyRules.CM_EDIPartyCuscarRules.allEDIPartyRules, EDIFileType_CusCar);	//cnwrd1 par 34193				
				self.cmbChildCargoTyp.setIndexFromObject( partyRules.CM_EDIPartyCuscarRules.myChildCargoTypeDefault); //cnwrd1 par 34193
				
			elseif partyRules.isKindOf(CM_EDIPartyIFCSUMRules) then											// TFS 2566
				ifcsumRules := partyRules.CM_EDIPartyIFCSUMRules;											// TFS 2566
				self.chkCreateForGID.value := ifcsumRules.createCargoFromGID;								// TFS 2566
				self.optPCI.value := ifcsumRules.cargoSegmentIsPCI;											// TFS 2566
				self.optSGP.value := not ifcsumRules.cargoSegmentIsPCI;										// TFS 2566
				self.optBGM.value := ifcsumRules.voyageFromBGM;												// TFS 2566
				self.optTDT.value := not ifcsumRules.voyageFromBGM;											// TFS 2566
				self.chkGIDMEA.value := ifcsumRules.oneMEAPerGID;			// TFS 3734
				self.chkPIAComm.value := ifcsumRules.pia5IsCommodity;		// TFS 3825
				self.chkUseDischargeAsDestination.value := ifcsumRules.useDiscPortAsDestPort; //jlgka1 TFS 39187, 39185
				self.cmbIFCSUMISOType.setIndexFromObject( ifcsumRules.myISOTypeGroup); // jlgka1 TFS 39185		
				self.loadRulesIFCSUM (self.tblActionsIFCSUM, ifcsumRules.allEDIPartyRules, EDIFileType_IFCSUM94B, CM_EDIIFCSUMRule);	// TFS 2566
				self.loadRulesIFCSUMHS (self.tblActionIFCSUMHS, ifcsumRules.allEDIPartyRules, EDIFileType_IFCSUM94B, CM_EDIIFCSUMHSRule);		// TFS 65152
				self.loadRulesIFCSUM (self.tblActionsIFCSUMDet, ifcsumRules.allEDIPartyRules, EDIFileType_IFCSUM94B, CM_EDIEDIFactRule);	// jlgka1 TFS 39187, 39185	
				self.cmbIFCSUMCargoType.setIndexFromObject(ifcsumRules.myDefaultCargoType);		//14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
				self.chkUseSystemids.value := ifcsumRules.useSystemGeneratedIds;			//28 Aug 2023	jlirs1	TFS 59170 (57770) IFCSUM Breakbulk and Mixed Cargo BOP

				//jlier1 TFS 55788 12/12/22
				self.chkPIAHSCode.value:=ifcsumRules.piaIsHSCode;
				self.chkMEACargoWeight.value :=ifcsumRules.meaIsCargoWeight;
				self.chkPortsToVoyage.value :=ifcsumRules.addPortsToVoyage;
				self.chkOperatorsToVoyage.value :=ifcsumRules.addOperatorsToVoyage; //JIRA-34341
				self.chkNoBOLHeader.value :=ifcsumRules.doNotCreateBOL;
				self.chkEQDTranshipCargo.value :=ifcsumRules.eqdCreateTranship;	//jlika1 TFS 56385
				self.optExpOnsite.value:=ifcsumRules.eqdExportCargoSite = TI_SITE_ONSITE;
				self.optExpOnship.value:=ifcsumRules.eqdExportCargoSite = null or ifcsumRules.eqdExportCargoSite = TI_SITE_ONSHIP;
				self.optImpOnsite.value:=ifcsumRules.eqdImportCargoSite = TI_SITE_ONSITE;
				self.optImpOnship.value:=ifcsumRules.eqdImportCargoSite = null or ifcsumRules.eqdImportCargoSite = TI_SITE_ONSHIP;
				self.btnFTXTransform.enabled:=ifcsumRules.myFTXTransform &lt;&gt; null;
				self.btnFTXTransform.userObject:=ifcsumRules.myFTXTransform;
				self.btnNADTransform.enabled:=ifcsumRules.myNADTransform &lt;&gt; null;
				self.btnNADTransform.userObject:=ifcsumRules.myNADTransform;
				self.txtIFCSUMYardLoc.text	:= ifcsumRules.defaultLocationID;
				self.chkNoOverideDischarge.value:= ifcsumRules.dontOverrideFileDischargePort; //jlier1 TFS 57156 22/3/23
				self.cmbIFCSUMCargoOp.setObject(ifcsumRules.myCargoOperator);
				self.chkDivideWeightByGID.value:=ifcsumRules.divideWeightVolumeByGIDCount; //jlier1 TFS 57426 14/4/23
				self.chkOnlyFirstValidNAD.value:=ifcsumRules.onlyUseFirstValidNAD;  //jlier1 TFS 56234 14/4/23
				self.txtIFCSUMNADPos.text:=ifcsumRules.nadSegmentStart.asStringJMT; //jlier1 TFS 57604 19/4/23
				self.chkDontIgnoreEQDTE.value := ifcsumRules.dontIgnoreEQDTE;		//MTN-33705
				self.chkFullShipperDesc.value := ifcsumRules.isFullShipperDesc;		//MTN-33703
			elseif partyRules.isKindOf(CM_EDIPartyCAMIRRules) then
				self.chkIsImportCamir.value := partyRules.CM_EDIPartyCAMIRRules.isImport;		//04 Mar 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
			endif;
			
		endforeach;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_party" type="CM_EDIParty"/>
    </JadeMethod>
    <JadeMethod name="loadRules" id="5f938dfe-0e0a-4e2e-8a30-cfd5adf6aa81">
        <source>loadRules(_table :CM_DataTable input; _coll :CM_EDIRulesSet; _type :Integer) protected;
/*
Date		Who		Reason
03 Jul 2013	cnwcs5	Initial Creation - par 31942
*/
vars
	ediRule :CM_EDIRule;
	row		:Integer;
	todoTaskDesk : CM_ToDoTaskDesc;
	stopsTable : CM_StopsTable;
begin
	_table.rows	:= _table.fixedRows;
		
	foreach ediRule in _coll do
		row := _table.addItem (ediRule.getItem &amp; Tab &amp; ediRule.getValue);
		
		self.doSelectItem (_table, row, _type);
		
		_table.accessCell (row, 3).text :=  ediRule.getFunctionDescription;
		
		if _type = EDIFileType_CusCar then
			_table.accessCell (row, 4).text :=  ediRule.CM_EDICUSCARRule.matchText;
			
			todoTaskDesk := self.getToDoTaskDescFromShrtDesc(ediRule.CM_EDICUSCARRule.todoTask);
			
			if todoTaskDesk &lt;&gt; null then
				_table.accessCell (row, 5).text :=  todoTaskDesk.description;
			else
				_table.accessCell (row, 5).text :=  ediRule.CM_EDICUSCARRule.todoTask;
			endif;
			//_table.accessCell (row, 5).text := ;		
			//self.doSelectItemCuscar (_table, row, _type);
		endif;
		
		if _type = EDIFileTypeX12_315_4010 then
			stopsTable := self.getStopsTableFromHeading(ediRule.CM_EDI315Rule.stopTable);
			
			if stopsTable &lt;&gt; null then
				_table.accessCell (row, 4).text :=  stopsTable.heading;
			else
				_table.accessCell (row, 4).text :=  ediRule.CM_EDI315Rule.stopTable;
			endif;
		endif;
		
		//29 Jun 2015	NDL	Par 36543
		if _type = EDIFileType_XML_Milaha_Customs then
			stopsTable := self.getStopsTableFromHeading(ediRule.CM_QatarRule.stopTable);
			
			if stopsTable &lt;&gt; null then
				_table.accessCell (row, 4).text :=  stopsTable.heading;
			else
				_table.accessCell (row, 4).text :=  ediRule.CM_QatarRule.stopTable;
			endif;
		endif;
		
		if _type = EDIFileType_IFCSUM94B then																								// TFS 2566
			self.cmbConsignees.listIndex := self.cmbConsignees.findStringExact(1, ediRule.CM_EDIIFCSUMRule.consignee);						// TFS 2566
			self.cmbCargoType.listIndex := self.cmbCargoType.findObject(app.myRoot.allCargoTypesById[ediRule.CM_EDIIFCSUMRule.cargoType]);	// TFS 2566
			self.cmbMakes.listIndex := self.cmbMakes.findStringExact(1, ediRule.CM_EDIIFCSUMRule.make);										// TFS 2566
		endif;																																// TFS 2566
		
	endforeach;
	
	// par 30483 oct 2012 - tab key only works when table has non-fixed rows
	if _table.rows = _table.fixedRows then
		_table.tabKey := null;
	else
		_table.tabKey := J_key_Tab;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_coll" type="CM_EDIRulesSet"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadRulesIFCSUM" id="231493db-f1a8-4839-b37a-43236506b72b">
        <source>loadRulesIFCSUM(_table : CM_DataTable input; _coll : CM_EDIRulesSet; _type : Integer; ediType : Any) protected;
/*
Date		Who		Reason
03 Jul 2013	cnwcs5	Initial Creation - par 31942
*/
vars
	ediRule :CM_EDIRule;
	row		:Integer;
	todoTaskDesk : CM_ToDoTaskDesc;
	stopsTable : CM_StopsTable;
begin
	_table.rows	:= _table.fixedRows;
		
	foreach ediRule in _coll do
		if (ediType.Object = CM_EDIIFCSUMRule and ediRule.isKindOf(CM_EDIIFCSUMRule)) or 
		   (ediType.Object = CM_EDIEDIFactRule and ediRule.isKindOf(CM_EDIEDIFactRule)) then
				
			row := _table.addItem (ediRule.getItem &amp; Tab &amp; ediRule.getValue);
			
			self.doSelectItem (_table, row, _type);
			
			_table.accessCell (row, 3).text :=  ediRule.getFunctionDescription;
			
			if ediRule.isKindOf(CM_EDIIFCSUMRule) then																							
				self.cmbConsignees.listIndex := self.cmbConsignees.findStringExact(1, ediRule.CM_EDIIFCSUMRule.consignee);						
				self.cmbCargoType.listIndex := self.cmbCargoType.findObject(app.myRoot.allCargoTypesById[ediRule.CM_EDIIFCSUMRule.cargoType]);	
				self.cmbMakes.listIndex := self.cmbMakes.findStringExact(1, ediRule.CM_EDIIFCSUMRule.make);										
			endif;																																
		endif;
	endforeach;
	
	// par 30483 oct 2012 - tab key only works when table has non-fixed rows
	if _table.rows = _table.fixedRows then
		_table.tabKey := null;
	else
		_table.tabKey := J_key_Tab;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_coll" type="CM_EDIRulesSet"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="ediType" type="Any"/>
    </JadeMethod>
    <JadeMethod name="loadRulesIFCSUMHS" id="d5af307b-b8f7-4de3-b472-5ddfc66ff686">
        <source>loadRulesIFCSUMHS(_table : CM_DataTable input; _coll : CM_EDIRulesSet; _type : Integer; ediType : Any) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 August 2024	navlw1	TFS 65152: NSW | IFCSUM Enhancements
23 October 2024	navdap1	MTN-33167 NSW | FR - IFCSUM - Unable to Open EDI Party Definition After Adding HS Code to Cargo Type Mapping

*/

vars
	ediRule 		: CM_EDIRule;
	row				: Integer;
	cargoTypeHs		: CM_CargoType;
begin
	_table.rows	:= _table.fixedRows;
	foreach ediRule in _coll do
		if ediType.Object = CM_EDIIFCSUMHSRule and ediRule.isKindOf(CM_EDIIFCSUMHSRule) then
			
			// hs code/ hs description
			row := _table.addItem (ediRule.getFunctionDescription);
			
			self.doSelectItem (_table, row, _type);
			// Cargo Type
			_table.accessCell (row, 2).text :=  ediRule.getValue;
			// Cargo_Subtype
			_table.accessCell (row, 3).text :=  ediRule.getItem;
			
			if ediRule.isKindOf(CM_EDIIFCSUMHSRule) then																							
				self.cmbHSCodes.listIndex := self.cmbHSCodes.findObject(app.myRoot.allHSCodes[ediRule.CM_EDIIFCSUMHSRule.getFunctionDescription]);
				self.cmbCargoTypeHS.listIndex := self.cmbCargoTypeHS.findObject(app.myRoot.allCargoTypesById[ediRule.CM_EDIIFCSUMHSRule.cargoType]);	// MTN-33167
				if ediRule.CM_EDIIFCSUMHSRule.cargoType &lt;&gt; null then
					cargoTypeHs := app.myRoot.allCargoTypesById[ediRule.CM_EDIIFCSUMHSRule.cargoType];
					if cargoTypeHs &lt;&gt; null then
						self.myAssistant.comboBoxProduct(self.cmbCargoSubtype,cargoTypeHs,null,null);
					endif;
				endif;
				self.cmbCargoSubtype.listIndex := self.cmbCargoSubtype.findStringExact(1, ediRule.CM_EDIIFCSUMHSRule.getItem());											
			endif;																																
		endif;
	endforeach;

	if _table.rows = _table.fixedRows then
		_table.tabKey := null;
	else
		_table.tabKey := J_key_Tab;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_coll" type="CM_EDIRulesSet"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="ediType" type="Any"/>
    </JadeMethod>
    <JadeMethod name="populateCargoSubType" id="e9698912-3707-4084-8d11-1e285a57d61e">
        <source>populateCargoSubType(_cargoId : Integer; _cargoDec : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 August 2024	navlw1	TFS 65152: NSW | IFCSUM Enhancements

*/

vars
	cargo : CM_CargoType;
begin
	self.cmbCargoSubtype.clear();
	
	if _cargoId &lt;&gt; null then
		cargo := app.myRoot.allCargoTypesById[_cargoId];
	endif;
	if _cargoDec &lt;&gt; null then
		cargo := app.myRoot.allCargoTypesByDescription[_cargoDec];
	endif;
	
	if cargo &lt;&gt; null then
		self.myAssistant.comboBoxProduct(self.cmbCargoSubtype,cargo,null,null);
	endif;
epilog

end;</source>
        <Parameter name="_cargoId" type="Integer"/>
        <Parameter name="_cargoDec" type="String"/>
    </JadeMethod>
    <JadeMethod name="processHSCodeFile" id="1b38e3cf-82cc-4402-a3f1-2ef979a487e7">
        <updating/>
        <source>processHSCodeFile(_copyToServer : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2024	navsp1	Initial creation MTN-33228

*/
constants
	Comma 	: String = ",";	
vars
	loadFile		: File;
	fileArray		: FileNodeArray;
	ediForm			: CMUI_EDIForm;
	rules 			: CM_EDIPartyIFCSUMRules;
	party 			: CM_EDIParty;
	line			: String;
	hsCode, 
	cargoTypeStr, 
	cargoSubType 	: String;
	ediHSRule		: CM_EDIIFCSUMHSRule;
	cargoTypeInt	: Integer;
	cargoType 		: CM_CargoType;
	partyRules,
	pxyPartyRules	: CM_EDIPartyRules;
	objArray		: CM_ObjectArray;
	lineArray		: StringArray;
	result			: Integer;
begin
	delete pxyPartyRules;
	party := self.myCurrentEDIParty;
	partyRules :=self.getProxyEDIPartyRules(party, EDIFileType_IFCSUM94B);

	rules	:= partyRules.CM_EDIPartyIFCSUMRules;
	
	if party = null then
		return;
	endif;
	
	create loadFile transient;
	loadFile.fileName	:= self.txtFileName.text.trimBlanks();
	
	if loadFile.fileName = null then
		return;
	endif;
	loadFile.open();	
	create lineArray transient;
	create 	objArray transient;
	while not loadFile.endOfFile do
		hsCode			:= null;  
		cargoTypeStr	:= null; 
		cargoSubType 	:= null;
		line := loadFile.readLine();
		lineArray.clear();
		line.getTokensForDelimiter(Comma, lineArray);
		
		if lineArray.size = 0 then
			continue;
		endif;
		
		//HS Code
		hsCode			:= lineArray[1].trimBlanks();
		
		if app.myRoot.allHSCodesActive[hsCode] = null then
			app.myPassport.addErrorFull(Invalid_hsCode_specified, app.getErrorString1(Invalid_hsCode_specified, hsCode), null, null, null); //MTN-33537
		endif;
		
		//Cargotype
		if lineArray.size &gt; 1 then
			cargoTypeStr	:= lineArray[2].trimBlanks();
		endif;
		
		cargoType := app.myRoot.allCargoTypesByDescription[cargoTypeStr].CM_CargoType;
		if cargoType &lt;&gt; null then
			cargoTypeInt	:= cargoType.id;
		else
			app.myPassport.addErrorFull(Cargo_Type_Invalid, app.getErrorString1(Cargo_Type_Invalid, cargoTypeStr), null, null, null);		//MTN-33537
		endif;	
		
		//Cargo subtype
		if lineArray.size &gt; 2 then
			cargoSubType	:= lineArray[3].trimBlanks();
		endif;
		
		if (cargoType &lt;&gt; null and cargoType.isSubCargoTypeRequired) and (cargoSubType= null or cargoType.allProducts.getAtKeyGeq(null, cargoSubType) = null) then	//MTN-33537
			app.myPassport.addErrorFull(CargoSubtype_Invalid, app.getErrorString2(CargoSubtype_Invalid, cargoTypeStr, cargoSubType), null, null, null);				//MTN-33537
		endif;																																						//MTN-33537
		
		create ediHSRule as CM_EDIIFCSUMHSRule transient;
		ediHSRule.CM_EDIIFCSUMHSRule.setProxyIFCSUMHS(cargoSubType, hsCode, cargoTypeInt, rules);
		ediHSRule.setMyEDIPartyRules(partyRules);		
		objArray.add(ediHSRule);
		
	endwhile;
	
	while true do																//navsp1 30.Apr.25 UT fixes
		if objArray.size &gt; 0 and app.myPassport.allErrors.size = 0 then		
			app.myTrxUA.trxUpdateIFCSUMHSCodes(objArray, app.myPassport);
		endif;
		
		if not app.myPassport.hasErrors and app.myPassport.trxCompletedOK then	//MTN-33537
			self.showHideLoadFile(false);
			self.loadData(party);												//MTN-33537
			self.txtFileName.text := null; 										//MTN-33537
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);	//MTN-33537
			
			if app.myPassport.noErrors and result = IDOK then																		//MTN-33537
				// there must have just been warnings that the user has acknoledged so ..											//MTN-33537
				app.myPassport.warningsAcknowledged	:= true;																		//MTN-33537
			endif;																													//MTN-33537
			app.myPassport.clearErrorsWarnings();																					//MTN-33537
			return;																													//MTN-33537
		endif;
	endwhile;
	
epilog
	delete ediForm;
	delete fileArray;
	delete pxyPartyRules;
	delete lineArray;
end;</source>
        <Parameter name="_copyToServer" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCorrectComboStyle" id="d9dba51a-d849-41aa-beea-2b4163acde64">
        <updating/>
        <source>setCorrectComboStyle() updating;
/*
Purpose:	During the change to 22.0.24 some combo boxes had their STYLE set to zero, this is a patchable way to fix that.				

Date		Who		Reason
11 June 2024	navab1	BUG 64462
*/

vars

begin
	inheritMethod();

	self.cmbCarrier.style := 2;
	self.cmbCarrier_1.style := 2;
	self.cmbChildCargoTyp.style := 2;
	self.cmbDeliveryReaso.style := 2;
	self.cmbDeliveryReaso_1.style := 2;
	self.cmbGenType.style := 2;
	self.cmbGenType_1.style := 2;
	self.cmbGradeDry.style := 2;
	self.cmbGradeDry_1.style := 2;
	self.cmbGradeReefer.style := 2;
	self.cmbGradeReefer_1.style := 2;
	self.cmbIFCSUMISOType.style := 2;
	self.cmbReleaseStatus.style := 2;
	self.cmbReleaseStatusX12301.style := 2;
	self.cmbReleaseType.style := 2;
	self.cmbReleaseTypeX12301.style := 2;
	self.cmbSubTerminal.style := 2;
	self.cmbSubTerminal_1.style := 2;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromForm" id="bdb5b525-4e55-49c1-8653-eab88b89cfc5">
        <source>setProxyFromForm(_proxy :CM_EDIParty input) protected;
/****Changes

Date		Name	TFS#							Description
============================================================================
22 Nov 2011	cnwcs5	CCMS POL 2122 / par 28696 		Initial creation - - Empty Releases via COPARN
23/04/2012	cnwcs5	CCMS POL 2172 / par 29480 - 	coparn release updates
30/08/2012	cnwcs5	par 30097 - 					configure update/delete rules
19/02/2013	cnwcs5	CCMS PNL 2243 / par 31185
03/07/2013	cnwcs5	par 31942	
03/07/2015 	cnwma1  PAR #36337  CCMS 2502 TFS 375  	DPH - Consignor in the N1*SH
06/07/2015 	cnwma1 	PAR# 36526 						Patch for Baplie File MEA segment
20/03/2017	cnwdap1	TFS 3734 						AAT Issues with IFCSUM
27/03/2017	cnwdap1	TFS 3825 						AAT PIA+5 used as Commodity
02/06/2017	cnwdap1	TFS 4434 						SNO COPARN VGM Updates
21/08/2017	jlgrs1	TFS 6564 						add Coparn and Coreor RFF and NAD translation
22/08/2017	jlgdap1	TFS 6632 						Make COPARN Prenotes optional
31/08/2017	jlgrs1	TFS 6797 						SNO SpecialStow
14/11/2017	jlgrs1	TFS 5705 - 						SNO - EDIDataBooking Prenote release Req
18/04/2018	jlgrs1	TFS 8296 						add release req and prenotes to X12 301
10/08/2018	jlggb1	TFS 39344 						Ignore COREOR expiry dates
30/10/2018	jlgka1	TFS 39187, 39185				Add Action Rules in IFCSUM.
02/05/2019	jlgzm1	TFS 43425 						SNO Append new bookings rather than replace
01/08/2019	jlgka1 	TFS 45467						SNO - Clean attribute in release request
02/02/2023	jlika1	TFS 56385						POB - IFCSUM Tranship					
14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
28 Aug 2023	jlirs1	TFS 59170 (57770) IFCSUM Breakbulk and Mixed Cargo BOP
04 Mar 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
23/08/2024	navlw1	TFS 65152: NSW | IFCSUM Enhancements
17 Mar 2025	naviv1	JIRA MTN-34341 NSW | 34310.020 Setting Operators on Voyage from IFCSUM files
============================================================================*/
vars
	coparnRules 		: CM_EDIPartyCoparnRules;
	iftmcsRules			: CM_EDIPartyIFTMCSRules;
	x12315Rules 		: CM_EDIPartyX12315Rules;
	x12301Rules 		: CM_EDIPartyX12301Rules;   //03/06/2015 cnwma1 PAR #36337
	baplieRules 		: CM_EDIPartyBaplieRules;   //06/07/2015 cnwma1 PAR #36526
	coprarRules 		: CM_EDIPartyCoprarRules;
	coreorRules 		: CM_EDIPartyCoreorRules;
	cuscarRules 		: CM_EDIPartyCuscarRules;
	qatarRules  		: CM_EDIPartyQatarRules;
	ifcsumRules			: CM_EDIPartyIFCSUMRules;		// TFS 2566
	camirRules : CM_EDIPartyCAMIRRules;
	combo				: CMUI_ComboBox;
	index				: Integer;
	gradeDry			: Integer;
	gradeReefer			: Integer;
	releaseType			: Integer;
	releaseStatus		: Integer;
	rows 				: Integer;
	row					: Integer;
	col					: Integer;
	table				: CM_DataTable;
	grade				: CM_MTGrade;
	aCargoType 			: CM_CargoType;
	invokePurge			: Boolean; 			// jlgka1 TFS 39187, 39185
	mafiISOTypeGroup	: CM_ISOTypeGroup;	// jlgka1 TFS 39185
	eqdExpSite,
	eqdImpSite 			: Integer;
begin
	invokePurge := true;
	_proxy.setProxy (self.txtName.text.trimBlanks, self.txtDescription.text.trimBlanks,
						self.txtSenders.text, self.cmbXLOperator.listObject.CM_Operator, self.myTerminal,self.chkOnlyUseXlation.value);
	
	coparnRules := _proxy.getRulesForFileType (EDIFileType_Coparn).CM_EDIPartyCoparnRules;
	
	if coparnRules = null and self.hasChangedCoparnRules then 
		// we did not have coparn rules before but now we do so create some
		coparnRules := self.getProxyEDIPartyRules (_proxy, EDIFileType_Coparn).CM_EDIPartyCoparnRules;
	endif;
	
	if coparnRules &lt;&gt; null then 
		// get release type
		combo := self.cmbReleaseType;	
		index := combo.listIndex;
		if index &gt; 0 then
			releaseType := combo.itemData[index];
		endif;
		
		// get release status (par 31185 feb 2013)
		combo := self.cmbReleaseStatus;	
		index := combo.listIndex;
		if index &gt; 0 then
			releaseStatus := combo.itemData[index];
		endif;
		
		// get grade (dry) code
		combo := self.cmbGradeDry;	
		index := combo.listIndex;
		if index &gt; 0 then
			grade := combo.itemObject[index].CM_MTGrade;
			if grade &lt;&gt; null then
				gradeDry := grade.code;
			endif;
		endif;
		
		// get grade (reefer) code
		combo := self.cmbGradeReefer;
		index := combo.listIndex;
		if index &gt; 0 then
			grade := combo.itemObject[index].CM_MTGrade;
			if grade &lt;&gt; null then
				gradeReefer := grade.code;
			endif;
		endif;
		
		coparnRules.setProxy (self.chkUpdActioned.value, self.chkUpdArchived.value, self.chkUpdCompleted.value,
					self.chkDelActioned.value, self.chkDelArchived.value, self.chkDelComplete.value,
					self.chkEmailUpdate.value, self.chkEmailDelete.value, self.chkEmailUpdErr.value, self.chkEmailDelErr.value, self.chkResetComplete.value, 
					self.chkUseISOGrpRR.value, self.chkCreateGenRR.value, 
					self.cmbSubTerminal.listObject.CM_SubTerminal, self.cmbCarrier.listObject.CM_Carrier,
					releaseType, releaseStatus, self.cmbVoyage.listObject.CM_Voyage, self.cmbDeliveryReaso.text,
					gradeDry, gradeReefer, self.cmbGenType.listObject.CM_ISOType,
					self.chkRelByType.value, 			// cnwrd1 par 33790
					self.chkUpdateVGM.value,			// TFS 4434
					self.chkPrenotes.value,				// TFS 6632
					self.chkAppendNewBookings.value,	// TFS 43425
					self.chkUseGateDoc.value,
					self.chkReleaseIncNonClean.value);		// jlgka1 TFS 45467
					
		// rules from the table - we just replace them all 
		self.setProxyRules (self.tblActionsCoparn, coparnRules, invokePurge); // jlgka1 TFS 39187, 39185
	endif;
	
	iftmcsRules := _proxy.getRulesForFileType (EDIFileType_IFTMCS03A).CM_EDIPartyIFTMCSRules;
	coreorRules := _proxy.getRulesForFileType(EDIFileType_Coreor).CM_EDIPartyCoreorRules;
	
	if iftmcsRules = null and self.hasChangedIFTMCSRules then 
		// we did not have IFTMCS rules before but now we do so create some
		iftmcsRules := self.getProxyEDIPartyRules (_proxy, EDIFileType_IFTMCS03A).CM_EDIPartyIFTMCSRules;
	endif;
	
	if iftmcsRules &lt;&gt; null then
		self.setProxyRules (self.tblActionsIFTMCS, iftmcsRules, invokePurge); // jlgka1 TFS 39187, 39185
	endif;
	
	//29 Jun 2015	NDL	Par 36543
	qatarRules := _proxy.getRulesForFileType (EDIFileType_XML_Milaha_Customs).CM_EDIPartyQatarRules;
	if qatarRules = null and self.hasChangedQatarRules then 
		qatarRules := self.getProxyEDIPartyRules (_proxy, EDIFileType_XML_Milaha_Customs).CM_EDIPartyQatarRules;
	endif;
	if qatarRules &lt;&gt; null then
		self.setProxyRules (self.tblActionsQatar, qatarRules, invokePurge); // jlgka1 TFS 39187, 39185
	endif;

	
	x12315Rules := _proxy.getRulesForFileType(EDIFileTypeX12_315_4010).CM_EDIPartyX12315Rules;
	
	if x12315Rules = null and self.hasChangedX12315Rules then
		x12315Rules := self.getProxyEDIPartyRules (_proxy, EDIFileTypeX12_315_4010).CM_EDIPartyX12315Rules;		
	endif;
	
	if x12315Rules &lt;&gt; null then
		x12315Rules.setProxy(self.chkCreateBOLs.value, self.chkIsImport.value);
		self.setProxyRules( self.tblActions315, x12315Rules, invokePurge); // jlgka1 TFS 39187, 39185 //cnwrd1 par #36184
	endif;
	
	x12301Rules := _proxy.getRulesForFileType (EDIFileTypeX12_301_4010).CM_EDIPartyX12301Rules;   //03/06/2015 cnwma1 PAR #36337
	
	if x12301Rules = null and self.hasChangedX12301Rules then  									  //03/06/2015 cnwma1 PAR #36337
		x12301Rules := self.getProxyEDIPartyRules (_proxy, EDIFileTypeX12_301_4010).CM_EDIPartyX12301Rules;	
	endif;
	
	if x12301Rules &lt;&gt; null then																	  //03/06/2015 cnwma1 PAR #36337
		// get release type
		combo := self.cmbReleaseTypeX12301;	
		index := combo.listIndex;
		if index &gt; 0 then
			releaseType := combo.itemData[index];
		endif;
		
		// get release status (par 31185 feb 2013)
		combo := self.cmbReleaseStatusX12301;	
		index := combo.listIndex;
		if index &gt; 0 then
			releaseStatus := combo.itemData[index];
		endif;
		
		// get grade (dry) code
		combo := self.cmbGradeDry_1;	
		index := combo.listIndex;
		if index &gt; 0 then
			grade := combo.itemObject[index].CM_MTGrade;
			if grade &lt;&gt; null then
				gradeDry := grade.code;
			endif;
		endif;
		
		// get grade (reefer) code
		combo := self.cmbGradeReefer_1;
		index := combo.listIndex;
		if index &gt; 0 then
			grade := combo.itemObject[index].CM_MTGrade;
			if grade &lt;&gt; null then
				gradeReefer := grade.code;
			endif;
		endif;
		x12301Rules.setProxy(self.chkUseN1SH.value, self.chkUsePrenoteFromN7.value, self.chkUseRelReqFromY4.value, self.cmbGenType_1.listObject.CM_ISOType, self.cmbVoyage_1.listObject.CM_Voyage, self.cmbSubTerminal_1.listObject.CM_SubTerminal, self.cmbCarrier_1.listObject.CM_Carrier, releaseType, releaseStatus, self.cmbDeliveryReaso_1.text, gradeDry, gradeReefer);
	endif;
	
	baplieRules := _proxy.getRulesForFileType (EDIFileType_Baplie20).CM_EDIPartyBaplieRules;   //06/07/2015 cnwma1 PAR #36526
	
	if baplieRules = null and self.hasChangedBaplieRules then  									  //06/07/2015 cnwma1 PAR #36526
		baplieRules := self.getProxyEDIPartyRules (_proxy, EDIFileType_Baplie20).CM_EDIPartyBaplieRules;	
	endif;
	
	if baplieRules &lt;&gt; null then																	 //06/07/2015 cnwma1 PAR #36526
		baplieRules.setProxy(self.chkEnableAtmo.value);
	endif;
	
	coreorRules := _proxy.getRulesForFileType (EDIFileType_Coreor).CM_EDIPartyCoreorRules;
	if coreorRules = null and self.hasChangedCoreorRules then 
		// we did not have Coreor rules before but now we do so create some
		coreorRules := self.getProxyEDIPartyRules (_proxy, EDIFileType_Coreor).CM_EDIPartyCoreorRules;
	endif;
	if coreorRules &lt;&gt; null then
		coreorRules.setProxy ( self.chkIgnoreExpiryDates.value); //39344 10 August 2018 jlggb1 ignore expiry dates
		self.setProxyRules(self.tblActionsCoreor, coreorRules, invokePurge); // jlgka1 TFS 39187, 39185
	endif;

	coprarRules := _proxy.getRulesForFileType(EDIFileType_Coprar).CM_EDIPartyCoprarRules;
	if coprarRules = null and self.hasChangedCoprarRules then 
		// we did not have Coreor rules before but now we do so create some
		coprarRules := self.getProxyEDIPartyRules(_proxy, EDIFileType_Coprar).CM_EDIPartyCoprarRules;
	endif;
	if coprarRules &lt;&gt; null then
		self.setProxyRules(self.tblActionsCoprar, coprarRules, invokePurge); // jlgka1 TFS 39187, 39185
	endif;

	cuscarRules := _proxy.getRulesForFileType(EDIFileType_CusCar).CM_EDIPartyCuscarRules;
	
	if cuscarRules = null and self.hasChangedCuscarRules then
		cuscarRules := self.getProxyEDIPartyRules (_proxy, EDIFileType_CusCar).CM_EDIPartyCuscarRules;		
	endif;
	
	if cuscarRules &lt;&gt; null then
			combo := self.cmbChildCargoTyp;	
		index := combo.listIndex ;
		
		if index &gt; 0 then
			aCargoType := combo.itemObject [index].CM_CargoType;
		endif;
		
		cuscarRules.setProxy( aCargoType, optShipManifest.value);
		
		self.setProxyRules (self.tblActionsCuscar, cuscarRules, invokePurge); // jlgka1 TFS 39187, 39185 //cnwrd1 34193
	endif;
	
	ifcsumRules := _proxy.getRulesForFileType(EDIFileType_IFCSUM94B).CM_EDIPartyIFCSUMRules;				// TFS 2566
	if ifcsumRules = null and (self.hasChangedIFCSUMRules) then												// TFS 2566
		ifcsumRules := self.getProxyEDIPartyRules(_proxy, EDIFileType_IFCSUM94B).CM_EDIPartyIFCSUMRules;	// TFS 2566
	endif;																									// TFS 2566
	if ifcsumRules &lt;&gt; null then																				// TFS 2566
		//ifcsumRules.setProxy(self.optPCI.value, self.chkCreateForGID.value, self.optBGM.value);			// TFS 2566
		// jlgka1 TFS 39185 --&gt;
		combo := self.cmbIFCSUMISOType;	
		index := combo.listIndex ;
		
		if index &gt; 0 then
			mafiISOTypeGroup := combo.itemObject [index].CM_ISOTypeGroup;
		endif;
		
		if self.optExpOnsite.value then
			eqdExpSite:=TI_SITE_ONSITE;
		elseif self.optExpOnship.value then
			eqdExpSite:=TI_SITE_ONSHIP;
		endif;
		if self.optImpOnsite.value then
			eqdImpSite:=TI_SITE_ONSITE;
		elseif self.optImpOnship.value then
			eqdImpSite:=TI_SITE_ONSHIP;
		endif;
		// jlgka1 TFS 39185 &lt;--
		ifcsumRules.setProxy(self.optPCI.value, 
								self.chkCreateForGID.value,
								self.optBGM.value,
								self.chkGIDMEA.value, 
								self.chkPIAComm.value, 
								self.chkUseDischargeAsDestination.value,
								mafiISOTypeGroup,
								self.chkPIAHSCode.value,
								self.chkMEACargoWeight.value,
								self.chkPortsToVoyage.value,
								self.chkOperatorsToVoyage.value,
								self.chkNoBOLHeader.value,
								eqdExpSite,
								eqdImpSite,
								self.txtIFCSUMYardLoc.text,
								self.chkEQDTranshipCargo.value,
								self.cmbIFCSUMCargoOp.listObject.CM_Operator,
								self.chkNoOverideDischarge.value,
								self.chkOnlyFirstValidNAD.value,  //jlier1 TFS 56234 14/4/23
								self.chkDivideWeightByGID.value,
								self.txtIFCSUMNADPos.text.Integer, //jlier1 TFS 57452 13/4/23
								self.cmbIFCSUMCargoType.listObject.CM_CargoType,		//14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
								self.chkUseSystemids.value,								//28 Aug 2023	jlirs1	TFS 59170 (57770) IFCSUM Breakbulk and Mixed Cargo BOP
								self.chkDontIgnoreEQDTE.value, 							//MTN-33705
								self.chkFullShipperDesc.value);							//MTN-33703
		self.setProxyRules(self.tblActionsIFCSUM, ifcsumRules, invokePurge); // jlgka1 TFS 39187, 39185;												// TFS 2566		
		invokePurge := false;
		self.setProxyRules(self.tblActionIFCSUMHS, ifcsumRules, invokePurge); // navlw1 #65152
		self.setProxyRules(self.tblActionsIFCSUMDet, ifcsumRules, invokePurge); // jlgka1 TFS 39187, 39185;
	endif;
	
	//04 Mar 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
	camirRules := _proxy.getRulesForFileType(EDIFileTypeCAMIR_CustomsStatus).CM_EDIPartyCAMIRRules;				
	if camirRules = null and 
	   self.hasChangedCAMIRRules() then												
		camirRules := self.getProxyEDIPartyRules(_proxy, EDIFileTypeCAMIR_CustomsStatus).CM_EDIPartyCAMIRRules;
	endif;																									
	if camirRules &lt;&gt; null then
		camirRules.setProxy(self.chkIsImportCamir.value);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_proxy" type="CM_EDIParty" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyRules" id="ec5ed592-a2f9-4dc7-9301-74e01358a80d">
        <source>setProxyRules(_table :CM_DataTable input; _rules : CM_EDIPartyRules input; invokePurge : Boolean)protected;
/****Changes

Date		Name	TFS#			Description
============================================================================
04 Jul 2013	cnwcs5	par 31942	Initial Creation - 
03 Jul 2015 cnwma1  PAR #36337  CCMS 2502 TFS 375  DPH - Consignor in the N1*SH
09 Sep 2016	cnwdap1	TFS 2566 		AAT EDI IFCSUM rules
21 Aug 2017	jlgrs1	TFS 6564 		add Coparn and Coreor RFF and NAD translation
31 Aug 2017	jlgrs1	TFS 6797 		SNO SpecialStow
6  Nov 2018 jlgka1	39185, 39187	Add FTX.21 Rules for Remarks Ignore Text and 
									ISO Container - MAFI Cargo creation.
23/08/2024	navlw1	TFS 65152: NSW | IFCSUM Enhancements
14/10/2024	navcs2	MTN-33034 NSW | FR - IFCSUM - Issues with HS Code to Cargo Type and Sub-Type Mappings
============================================================================*/
vars
	row, rows 				: Integer;
	pxyRule					: CM_EDIRule;
	todoTaskDesc 			: String;
	aToDoTaskDesc 			: CM_ToDoTaskDesc;
	todoDeskShortDesc 		: String;
	aStopDesc				: String;
	aStopTable 				: CM_StopsTable;
	idx 					: Integer;				// TFS 2566
	cargoType, cargoTypeHS  : Integer;				// TFS 2566
	consignee 				: String;				// TFS 2566
	make 					: String;				// TFS 2566
	hsCode, cargoSubType	: String;
	rules 					: CM_EDIPartyIFCSUMRules;
begin
	// rules from the table - we just replace them all 
	if invokePurge then
		_rules.allEDIPartyRules.purge;
	endif;
	
	rows	:= _table.rows;
	row		:= _table.fixedRows;
	
	if rows &gt; row then
		foreach row in row + 1 to rows do
		
			if _rules.isKindOf(CM_EDIPartyCoparnRules) then
				create pxyRule as CM_EDIEDIFactRule transient;
			elseif _rules.isKindOf(CM_EDIPartyCuscarRules) then
				create pxyRule as CM_EDICUSCARRule transient;
			elseif _rules.isKindOf(CM_EDIPartyIFTMCSRules) then
				create pxyRule as CM_EDIEDIFactRule transient;
			elseif _rules.isKindOf(CM_EDIPartyX12315Rules) then
				create pxyRule as CM_EDI315Rule transient;
			elseif _rules.isKindOf(CM_EDIPartyX12301Rules) then   //03/06/2015 cnwma1 PAR #36337
				continue;
			elseif _rules.isKindOf(CM_EDIPartyQatarRules) then	//29 Jun 2015	NDL	Par 36543
				create pxyRule as CM_QatarRule transient;
				aStopDesc := _table.accessCell (row, 4).text;	
				pxyRule.CM_QatarRule.setProxyQatar( pxyRule.getFunctionCode (_table.accessCell (row, 3).text), aStopDesc );
				pxyRule.setMyEDIPartyRules (_rules);
				continue;
			elseif _rules.isKindOf(CM_EDIPartyCoreorRules) then													// TFS 2566
				create pxyRule as CM_EDIEDIFactRule transient;
			elseif _rules.isKindOf(CM_EDIPartyCoprarRules) then													// TFS 2566
				create pxyRule as CM_EDIEDIFactRule transient;
			elseif _rules.isKindOf(CM_EDIPartyIFCSUMRules) then													// TFS 2566
				if _table.name = self.tblActionsIFCSUM.name then
					consignee := null;																				// TFS 2566
					cargoType := null;																				// TFS 2566
					make := null;																					// TFS 2566
					idx := self.cmbConsignees.findString(1, _table.accessCell(row, 1).text);						// TFS 2566
					if idx &gt; 0 then																					// TFS 2566
						if self.cmbConsignees.itemObject[idx] &lt;&gt; null then											// TFS 2566
							consignee := self.cmbConsignees.itemObject[idx].CM_ConsigneeConsignor.code;				// TFS 2566
						endif;																						// TFS 2566
					endif;																							// TFS 2566
					idx := self.cmbCargoType.findStringExact(1, _table.accessCell(row, 2).text);					// TFS 2566
					if idx &gt; 0 then																					// TFS 2566
						if self.cmbCargoType.itemObject[idx] &lt;&gt; null then											// TFS 2566
							cargoType := self.cmbCargoType.itemObject[idx].CM_CargoType.id;							// TFS 2566
						endif;																						// TFS 2566
					endif;																							// TFS 2566
					idx := self.cmbMakes.findStringExact(1, _table.accessCell(row, 3).text);						// TFS 2566
					if idx &gt; 0 then																					// TFS 2566
						if self.cmbMakes.itemObject[idx] &lt;&gt; null then												// TFS 2566
							make := self.cmbMakes.itemObject[idx].CM_VehicleMake.make;								// TFS 2566
						endif;																						// TFS 2566
					endif;
				endif;																								// TFS 2566
				if _table.name = self.tblActionIFCSUMHS.name then													// #65152
					hsCode := null;
					cargoType := null;
					cargoSubType := null;																			// 14/10/2024	navcs2	MTN-33034
					idx := self.cmbHSCodes.findString(1, _table.accessCell(row, 1).text);
					if idx &gt; 0 then
						if self.cmbHSCodes.itemObject[idx] &lt;&gt; null then											
							hsCode := self.cmbHSCodes.itemObject[idx].CM_HarmonizedSystem.id;				
						endif;																						
					endif;
					idx := self.cmbCargoTypeHS.findStringExact(1, _table.accessCell(row, 2).text);
					if idx &gt; 0 then																					
						if self.cmbCargoTypeHS.itemObject[idx] &lt;&gt; null then											
							cargoTypeHS := self.cmbCargoTypeHS.itemObject[idx].CM_CargoType.id;							
						endif;																						
					endif;
					self.populateCargoSubType(cargoTypeHS,null);
					idx := self.cmbCargoSubtype.findStringExact(1, _table.accessCell(row, 3).text);
					if idx &gt; 0 then	
						if self.cmbCargoSubtype.itemObject[idx] &lt;&gt; null then											
							cargoSubType := self.cmbCargoSubtype.itemObject[idx].CM_Product.code;							
						endif;		
					endif;
				endif;																							// #65152
				if cargoType &lt;&gt; null or consignee &lt;&gt; null or make &lt;&gt; null then									// TFS 2566
					create pxyRule as CM_EDIIFCSUMRule transient;												// TFS 2566
					pxyRule.CM_EDIIFCSUMRule.setProxyIFCSUM(cargoType, consignee, make, self.optPCI.value);		// TFS 2566
					pxyRule.setMyEDIPartyRules(_rules);															// TFS 2566
					continue;																					// TFS 2566
				elseif hsCode &lt;&gt; null or cargoType &lt;&gt; null then 												// navlw1 #65152
					rules := _rules.CM_EDIPartyIFCSUMRules;
					create pxyRule as CM_EDIIFCSUMHSRule transient;
					pxyRule.CM_EDIIFCSUMHSRule.setProxyIFCSUMHS(cargoSubType,hsCode,cargoTypeHS,rules);
					pxyRule.setMyEDIPartyRules(_rules);	
					continue;
				else
					create pxyRule as CM_EDIEDIFactRule transient; // jlgka1 TFS 39187
				endif;																							// TFS 2566																								
			endif;			
											
			pxyRule.setProxy (_table.accessCell (row, 1).text, _table.accessCell (row, 2).text, pxyRule.getFunctionCode (_table.accessCell (row, 3).text));
			
			if pxyRule.isKindOf(CM_EDICUSCARRule) then
			
				todoTaskDesc := _table.accessCell (row, 5).text;
				aToDoTaskDesc := self.getToDoTaskDescFromDesc(todoTaskDesc);
				if aToDoTaskDesc &lt;&gt; null then
					todoDeskShortDesc := aToDoTaskDesc.shortDescription;
				endif;
				pxyRule.CM_EDICUSCARRule.setProxyCuscar(_table.accessCell (row, 4).text,todoDeskShortDesc);
			endif;
			
			if pxyRule.isKindOf(CM_EDI315Rule) then
				aStopDesc := _table.accessCell (row, 4).text;
				/*aStopTable := self.getStopsTableFromHeading( aStopDesc);
				if aStopTable &lt;&gt; null then
					
				endif;	*/		
				pxyRule.CM_EDI315Rule.setProxy315(aStopDesc);
			endif;
			
			pxyRule.setMyEDIPartyRules (_rules);
		endforeach;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_rules" type="CM_EDIPartyRules" usage="input"/>
        <Parameter name="invokePurge" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupActionsTable" id="88a561a7-b76e-439e-a166-0b0eb85a2e92">
        <source>setupActionsTable(_table :CM_DataTable input; _updates :Boolean; _heading, _comboList :String) protected;
/*
Date		Who		Reason
03 Jul 2013	cnwcs5	Initial Creation - par 31942
*/
vars

begin
	_table.rows 		:= _table.fixedRows;
	_table.columns 		:= 3;
	_table.selectMode	:= Table.SelectMode_WholeRows;
	
	if _updates then
		_table.tabStop		:= true;
		_table.showFocus	:= false;

		// set combo values - we will need to make this more flexible when we have more options
		_table.accessColumn(1).inputType	:= Table.InputType_ComboBox;
		_table.accessedColumn.comboList 	:= _comboList;		
		_table.accessColumn(2).inputType 	:= Table.InputType_TextBox;
		_table.accessedColumn.maxLength		:= null;	
		_table.accessColumn(3).inputType 	:= Table.InputType_ComboBox;
		_table.accessedColumn.comboList 	:= null;
		
		_table.autoSize := _table.AutoSize_Column;
	endif;

	_table.setCellText (1, 1, _heading);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_updates" type="Boolean"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_comboList" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupActionsTable315" id="1757a0d9-1eab-45ba-a9c4-1feec522e6b4">
