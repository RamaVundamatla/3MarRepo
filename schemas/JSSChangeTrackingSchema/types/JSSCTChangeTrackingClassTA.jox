<Class name="JSSCTChangeTrackingClassTA" id="89aac9f0-a89d-40cd-808b-b3cd7fa152b6">
    <superclass name="JSSCTTransactionAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="jssct_transient"/>
    <PrimAttribute name="className" id="141a5075-069e-44b1-af9a-b818baae11bd">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="initializing" id="e1fd82e4-6988-4f60-95c9-c45661816a83">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="isDelete" id="a4962ee0-cbf5-46b4-8be1-af1f591ab708">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myChangeTrackingClass" id="33817d4a-203e-4252-8980-52f85a547da1">
        <embedded/>
        <type name="JSSCTChangeTrackingClass"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myChangeTrackingRoot" id="f3e725ba-8f88-49ad-bc6c-7f0d1bad24b6">
        <embedded/>
        <type name="JSSCTChangeTrackingRoot"/>
    </ImplicitInverseRef>
    <JadeMethod name="doCreate" id="5743ff43-8b25-4c27-b271-d533c4e76876">
        <updating/>
        <source>doCreate(): Boolean updating, protected;
/*
*/
begin
	create self.myChangeTrackingClass persistent;
	self.myChangeTrackingClass.setClassName(self.className);
	self.myChangeTrackingClass.setIsDelete(self.isDelete);
	self.myChangeTrackingClass.setInitializing(self.initializing);
	if self.isDelete then
		self.myChangeTrackingRoot.allDeleteClasses.add(self.myChangeTrackingClass);
	else
		self.myChangeTrackingRoot.allChangeClasses.add(self.myChangeTrackingClass);
	endif;
	return (true);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="8975fb82-1d15-4297-82e4-b1831e2be8a5">
        <updating/>
        <source>doDelete(): Boolean updating, protected;
/*
*/
begin
	if self.isDelete then
		self.myChangeTrackingRoot.allDeleteClasses.remove(self.myChangeTrackingClass);
	else
		self.myChangeTrackingRoot.allChangeClasses.remove(self.myChangeTrackingClass);
	endif;
	self.myChangeTrackingClass.allChangesByOid.purge;

	delete self.myChangeTrackingClass;

	return (true);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdate" id="97dea27d-614d-487b-81e5-c2d072adfc0a">
        <updating/>
        <source>doUpdate(): Boolean updating, protected;

vars

begin
	self.myChangeTrackingClass.setInitializing(self.initializing);

	return (true);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lockEntityCreate" id="0d9b17f6-a0dc-4b89-b1e3-75d4420cb98a">
        <source>lockEntityCreate(): Boolean protected;

vars
	rtn: Boolean;
begin
	if self.isDelete then
		rtn := self.tryLockingObject(self.myChangeTrackingRoot.allDeleteClasses);
	else
		rtn := self.tryLockingObject(self.myChangeTrackingRoot.allChangeClasses);
	endif;
	return (rtn);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
