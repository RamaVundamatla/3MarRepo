    <JadeMethod name="addTIToTable" id="a94fcf40-32b9-44c0-b6a0-4092b59a409a">
        <updating/>
        <source>addTIToTable(tbl : CM_MobTable io; item : CMIF_TIGenCargo)updating;
/*
	Created on 10 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/
constants
	TableEntryPos = 2;
vars
	row, 
	col			: Integer;
	cell 		: JadeTableCell;
begin
	if item &lt;&gt; null then
		tbl.addItemAt(getItemDisplay(item), 2);
		tbl.accessRow(2).itemObject := item;
	endif;
end;</source>
        <Parameter name="tbl" type="CM_MobTable" usage="io"/>
        <Parameter name="item" type="CMIF_TIGenCargo"/>
    </JadeMethod>
