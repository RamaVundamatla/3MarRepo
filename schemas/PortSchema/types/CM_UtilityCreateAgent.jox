        <source>utlCreateYATemplate(_proxyYATemplate: CM_YATemplate; _yATemplate: CM_YATemplate output;
						_yardAllocation : CM_YardAllocation; _passport : CM_Passport input);
vars
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	app.myValCA.valYATemplate(_proxyYATemplate);
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	create _yATemplate persistent;
	_yATemplate.setForCreate(_proxyYATemplate, _yardAllocation);

	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_yATemplate);
	endif;

	if _passport.noErrors() then
		// ### NOTES
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(Event_YATemplateCreate), false, _yATemplate);
	endif;
end;</source>
