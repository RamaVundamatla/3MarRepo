    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="chkIncludeAttach" id="37dc1dcf-ac53-40da-9d2a-76e824184f98">
        <embedded/>
        <type name="CMUI_CheckBox"/>
