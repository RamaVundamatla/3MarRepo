    <JadeMethod name="setControlsForAddEdit" id="c4371399-8911-4238-97fe-412b5de57ee7">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
//
// Date				Who		Reason
// 13 December 2022	navvt20	TFS CR 55621 Task 55695: UI - UOM Maint
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	self.populateEntDetailTable();
	self.tblEntDetail.setFocus;
	if self.mode = self.Mode_Add then
		self.tblEntDetail.goToRowByName(ETRow_Code);
		self.tblEntDetail.enableRowByName(ETRow_Code);
	else
		self.tblEntDetail.goToRowByName(ETRow_Description);
		self.tblEntDetail.disableRowByName(ETRow_Code);
	endif;
end;</source>
    </JadeMethod>
