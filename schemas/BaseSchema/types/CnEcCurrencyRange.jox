    <DbClassMap file="basedvr"/>
    <ImplicitInverseRef name="myCurrencyFrom" id="ed7647c2-9027-43a3-9542-b620f693bb1d">
        <embedded/>
        <type name="CnEcCurrency"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myCurrencyTo" id="28af9883-fc52-40f7-b3d6-29ec3801d1cd">
        <embedded/>
        <type name="CnEcCurrency"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="33b75236-76f7-43f4-b931-67b666cd50ed">
        <updating/>
        <source>create() updating;
// -----------------------------------------------------------------------------
// Created:		28 January 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if self.isTransient() then
		create self.myCurrencyFrom transient;
		create self.myCurrencyTo transient;
	else
		create self.myCurrencyFrom;
		create self.myCurrencyTo;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="008e8af0-f33f-46df-a0ac-c443bdc6b86e">
        <updating/>
        <source>delete() updating;
// -----------------------------------------------------------------------------
// Created:		28 January 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	delete self.myCurrencyFrom;
	delete self.myCurrencyTo;
end;</source>
    </JadeMethod>
    <JadeMethod name="getCurrencyFrom" id="0e6c730b-4a25-407a-ae34-e4fdc64066b2">
        <source>getCurrencyFrom():Decimal;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Return the currency from value.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myCurrencyFrom.getDecimalizedAmount();
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getCurrencyTo" id="8b41a861-81aa-470b-ab57-3493b71ec83e">
        <source>getCurrencyTo():Decimal;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Return the currency to value.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myCurrencyTo.getDecimalizedAmount();
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setCurrencyFrom" id="ba5a994d-ef8f-45a8-aad5-611d935d9c8f">
        <updating/>
        <source>setCurrencyFrom(pCurrencyFromObj:CnEcCurrency) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Set the currency from value object.
//
// Parameters:	pCurrencyFromObj - The currency from object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateRange(pCurrencyFromObj.amount, self.myCurrencyTo.amount) then
		self.myCurrencyFrom	:=	pCurrencyFromObj;
	endif;
end;</source>
        <Parameter name="pCurrencyFromObj" type="CnEcCurrency"/>
    </JadeMethod>
    <JadeMethod name="setCurrencyTo" id="d1d7ad2a-02df-4eb5-9178-453c9cbfab18">
        <updating/>
        <source>setCurrencyTo(pCurrencyToObj:CnEcCurrency) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Set the currency to value object.
//
// Parameters:	pCurrencyToObj - The currency to object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateRange(self.myCurrencyFrom.amount, pCurrencyToObj.amount) then
		self.myCurrencyTo	:=	pCurrencyToObj;
	endif;
end;</source>
        <Parameter name="pCurrencyToObj" type="CnEcCurrency"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="28aab282-a6f7-4972-9344-a9b985407f0d">
        <updating/>
        <source>updateMe(pCurrencyFrom:Real; pCurrencyTo:Real) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Update the receiver's currency range.
//
// Parameters:	pCurrencyFrom - The currency from value.
//				pCurrencyTo - The currency to value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateRange(pCurrencyFrom, pCurrencyTo) then
		self.myCurrencyFrom.setAmount(pCurrencyFrom);
		self.myCurrencyTo.setAmount(pCurrencyTo);
	endif;
end;</source>
        <Parameter name="pCurrencyFrom" type="Real"/>
        <Parameter name="pCurrencyTo" type="Real"/>
    </JadeMethod>
</Class>
