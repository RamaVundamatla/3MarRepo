    <JadeMethod name="create" id="4160dff9-6e74-4e7c-94b0-282de25af4af">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     17 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.name := SOP_TableMaintForm.Table_Carrier;
	self.permissionView	 := PmAdmCarriertableView;
	self.permissionMaint := PmAdmCarriertableMaint;
	self.myDataClass := CM_Carrier;
