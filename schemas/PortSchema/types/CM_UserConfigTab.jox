<Class name="CM_UserConfigTab" id="d0516fb5-6030-42c3-9bb9-f44ef0c9df7c">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>CCMS 1776 Cargo Enquiry user-definable layout</text>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="allAttributes" id="a7a8e4ba-dc48-4361-a0ce-091c30e6bf68">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <type name="CM_UserConfigAttributeArray"/>
        <access>readonly</access>
        <Inverse name="CM_UserConfigAttribute::myUserConfigTab"/>
