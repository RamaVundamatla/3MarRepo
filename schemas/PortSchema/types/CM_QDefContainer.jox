<Class name="CM_QDefContainer" id="69e44a12-76d3-4f90-a591-a3cc108552a4">
    <superclass name="CM_QDefTrackedItem"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="1d121278-7075-4e6f-86fe-b4b921d5f276">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     14 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.className := 'CM_Container';

end;</source>
    </JadeMethod>
    <JadeMethod name="createProperties" id="2cced8b8-1d72-482c-8009-e0370ad2104c">
        <source>createProperties();
// ---------------------------------------------------------------------------
// Created:     14 March 2003		cnwth2	
//
// Purpose:     		 
//
/****Changes

Date		Name		TFS#			Description
============================================================================
02/12/2009	cnwdap1		CCMS MES 1007 	Move reefer properties from CM_Container to CM_TrackedItem
22/07/2010	cnwcs5		CCMS SFW 1156 
						(Par 23706)  	New property 'Is Empty'
Oct 2010	cnwjre1		CCMS 1043 		Snapshot Summary Invoicing set allocationAttribute
20/10/2010	cnwcs5		par 25608 	 	Move seal properteis to tracked item
21/08/2014	cnwdap1		PAR #33235 		Measurement types in Summaries
18/05/2016	cnwdap1		TFS #1699 		Verified Gross Mass changes
10/10/2018	jlgka1		TFS #40200		Add CM_QStrWghtAuthorityProperty for 
										"Authorized Person for Certified Weight List" 
										and "Weight Certified By List".
1/05/2019 	JLGNS1		ChangeRequest 42504: SPT - Reefer Monitoring Display MT Filtering
07/10/2019	jlgdap1		TFS 46869 correct Container Length settings
05/11/2019	jlgdap1		TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
============================================================================*/
vars

	tmpProp		: CM_QueryProperty;
begin
	inheritMethod();
	
	create tmpProp as CM_QAvailabilityGradeProperty persistent;
	tmpProp.set('Availability Grade', 'availabilityGrade', self.className);
	tmpProp.allocationAttribute := YACriteriaType_AvGrade;
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

	create tmpProp as CM_QCOUTypeProperty persistent;
	tmpProp.set('COU Type', 'clipOnUnitType', self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Is Chilled', 'isChilled', self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Is Clean', 'isClean', self.className);
	tmpProp.allocationAttribute := YACriteriaType_Clean;
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
		
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Is Flat Rack', CM_Container::isFlat.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Is Fantainer', CM_Container::isFantainer.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Is Open Top', CM_Container::isOpenTop.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Is Tank', CM_Container::isTank.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Is Crib', CM_Container::isCrib.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//05 Feb 2018	NDL	TFS 36752
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Is Frame', CM_Container::isFrame.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Is Half Height', CM_Container::isHalfHeight.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanMethod persistent;
	tmpProp.set('Is Hi-Cubed', CM_Container::isHighCube.name, self.className);	
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QContentsStatusLookup persistent;
	tmpProp.set('Contents Status', 'contentsStatus', self.className);
	tmpProp.allocationAttribute := YACriteriaType_ContentsStatus;
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Is Connected', 'isConnected', self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Is Heavy Duty', 'isHeavyDuty', self.className);
	tmpProp.allocationAttribute := YACriteriaType_HeavyDuty;
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

	create tmpProp as CM_QStrISOTypeProperty persistent;
	tmpProp.set('ISO Type', 'isoType', self.className);
	tmpProp.allocationAttribute := YACriteriaType_ISO;
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

	create tmpProp as CM_QStrISOGroupProperty persistent;
	tmpProp.set('ISO Type Group', 'isoGroup', self.className);
	tmpProp.allocationAttribute := YACriteriaType_ISOGroup;
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);

	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Is To Be Inspected', 'isToBeInspected', self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Monitor Connection', 'monitorConnection', self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Requires Power', 'requiresPower', self.className);
	tmpProp.allocationAttribute := YACriteriaType_RequiresPower;
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Requires Temperature', 'requiresTemperature', self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//cnwmc5 - 24 Feb 2016 - PAR 37579 - change to accessor method...
	//create tmpProp as CM_QDecimalTemperatureProperty persistent;
	//tmpProp.set('Temperature (F)', 'temperatureInFahrenheit', self.className);
	create tmpProp as CM_QDecimalTemperatureMethod persistent;
	tmpProp.set('Temperature (F)', CM_Container::getTemperatureFahrenheit.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QBooleanProperty persistent;
	tmpProp.set('Is Controlled Atmosphere', 'isControlledAtmosphere', self.className);
	tmpProp.allocationAttribute := YACriteriaType_IsCA;
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//CCMS  #1601 for Port Otago 09/11/2007
	
	create tmpProp as CM_QDateProperty persistent;
	tmpProp.set('Wash Date', CM_Container::washDT.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	// PAR 16415... 22 May 2008 cnwgb1
	// TFS 46869 Container Length is not a measurement type, it's just 20, 30, 40, 45, 53 etc
	// TFS 46869 Reinstate old correct code
	create tmpProp as CM_QContainerLengthMethod persistent;
	tmpProp.set('Container Length', CM_Container::getActualLength.name, self.className);
	tmpProp.allocationAttribute := YACriteriaType_ContainerLength;
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	//self.createMeasurementProperties(CM_QContainerLengthMethod, Type_Linear, 'Container Length', CM_Container::getActualLength.name, self.className, YACriteriaType_ContainerLength);

	//create tmpProp as CM_QDecimalProperty persistent;																										// PAR #33235
	//tmpProp.set( 'Over Length Front', CM_Container::overLengthFront.name, self.className);																// PAR #33235
	//self.allQueryProperties.add(tmpProp);																													// PAR #33235
	self.createMeasurementProperties(CM_QDecimalProperty, Type_Linear, 'Over Length Front', CM_Container::overLengthFront.name, self.className, null);		// PAR #33235
	
	//create tmpProp as CM_QDecimalProperty persistent;																										// PAR #33235
	//tmpProp.set( 'Over Length Rear', CM_Container::overLengthRear.name, self.className);																	// PAR #33235
	//self.allQueryProperties.add(tmpProp);																													// PAR #33235
	self.createMeasurementProperties(CM_QDecimalProperty, Type_Linear, 'Over Length Rear', CM_Container::overLengthRear.name, self.className, null);		// PAR #33235
	
	//create tmpProp as CM_QDecimalProperty persistent;																										// PAR #33235
	//tmpProp.set( 'Over Width Left', CM_Container::overWidthLeft.name, self.className);																	// PAR #33235
	//self.allQueryProperties.add(tmpProp);																													// PAR #33235
	self.createMeasurementProperties(CM_QDecimalProperty, Type_Linear, 'Over Width Left', CM_Container::overWidthLeft.name, self.className, null);			// PAR #33235
	
	//create tmpProp as CM_QDecimalProperty persistent;																										// PAR #33235
	//tmpProp.set( 'Over Width Right', CM_Container::overWidthRight.name, self.className);																	// PAR #33235
	//self.allQueryProperties.add(tmpProp);																													// PAR #33235
	self.createMeasurementProperties(CM_QDecimalProperty, Type_Linear, 'Over Width Right', CM_Container::overWidthRight.name, self.className, null);		// PAR #33235
	
	//create tmpProp as CM_QDecimalProperty persistent;																										// PAR #33235
	//tmpProp.set ('Over Height', CM_Container::overHeight.name, self.className);																			// PAR #33235
	//self.allQueryProperties.add(tmpProp);																													// PAR #33235
	self.createMeasurementProperties(CM_QDecimalProperty, Type_Linear, 'Over Height', CM_Container::overHeight.name, self.className, null);					// PAR #33235
	
	// 29810 add availability grade value itself
	// this property is used in the results but not the query - see CM_QIntegerMethod::propertyAvailableInCombo
	create tmpProp as CM_QIntegerMethod persistent;
	tmpProp.set('AG', CM_Container::getAvailabilityGrade.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringProperty persistent;																	// TFS #1699
	tmpProp.set("Authorized Person for Certified Weight Code", CM_TrackedItem::weightCertifiedName.name, self.className);	// TFS #1699
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);																				// TFS #1699
	
	create tmpProp as CM_QStringProperty persistent;																	// TFS #1699
	tmpProp.set("Weight Certified By Code", CM_TrackedItem::weightCertifiedReference.name, self.className);					// TFS #1699
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);		
	
	//--&gt; TFS 40200 jlgka1 10/10/2018
	create tmpProp as CM_QStrWghtAuthorityMethod persistent;														
	tmpProp.CM_QStrWghtAuthorityMethod.type := tmpProp.CM_QStrWghtAuthorityMethod.CertifyingAuthority;			
	tmpProp.set("Authorized Person for Certified Weight List", CM_TrackedItem::getWeightCertifiedName.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);																			
	
	create tmpProp as CM_QStrWghtAuthorityMethod persistent;														
	tmpProp.CM_QStrWghtAuthorityMethod.type := tmpProp.CM_QStrWghtAuthorityMethod.CertifyingPerson;				
	tmpProp.set("Weight Certified By List", CM_TrackedItem::getWeightCertifiedReference.name, self.className);				
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);																			
	//&lt;-- TFS 40200 jlgka1 10/10/2018
	
	// TFS 46405 start
	create tmpProp as CM_QFlatRackStatusProperty persistent;
	tmpProp.set("Flat Rack Status", CM_Container::getFlatRackStatus.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	// TFS 46405 end
end;</source>
    </JadeMethod>
</Class>
