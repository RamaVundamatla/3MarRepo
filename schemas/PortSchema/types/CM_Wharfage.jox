<Class name="CM_Wharfage" id="ab1945f1-c28e-43ee-bc85-47208c6fe347">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <JadeMethod name="getDisplayStringForAttribute" id="cdd8e109-68e8-43e6-8cb0-621aecfae637">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:	TFS 42882		
Date				Who			Reason
SEPTEMBER 2019		JLGAB1 initial creation
*/

vars
	lDetail : String;
	amountDisplay : String;
	drstr : String;
begin

	if _attrName = ETRow_Details then
		if self.deleted then
			return self.getDeletedDetails();	
		else
		
			if self.isDirectReleaseMove then
				drstr := " DR ";
			endif;
			amountDisplay := '(' &amp; self.getAmountDisplay() &amp; ') ';
			if amountDisplay &lt;&gt; "() " then
				lDetail:= app.getErrorString(Wharfage) &amp; drstr &amp; " " &amp; amountDisplay &amp; " "  &amp; lDetail;
			else
				lDetail:= app.getErrorString(Wharfage) &amp; drstr &amp;  " " &amp; lDetail;
			endif;
			return lDetail;
		endif;
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="9c9702bc-04fd-4746-9976-fbdab7bcda79">
        <updating/>
        <source>setMyTrackedItem(pTI : CM_TrackedItem; _tiTransCntrl: CMIF_TITransactionController ) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 13/06/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//
vars
	priorLocation : CM_LocationsController;
	void : Integer;

begin
	inheritMethod(pTI, _tiTransCntrl);

	// if we are a tranship on site, set stevedore from the import voyage
	// this is for invoicing purposes
	if self.imExStatus = TI_IMEX_STATUS_TRANSHIP then
		app.myPassport.myTerminal.findLocationFromString(pTI.priorLocation, false, priorLocation, void);
		if priorLocation &lt;&gt; null and priorLocation.isKindOf(CM_VoyageController) and priorLocation.CM_VoyageController.myVoyage = self.myTrackedItem.myVoyageTranshipImport then
			self.stevedoreCode := pTI.getStevedoreForTranshipImport();
		endif;
	endif;
epilog

end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
    </JadeMethod>
    <JadeMethod name="useSourceTI" id="e28364db-dcfc-45bd-ad21-a9e4f109a0a3">
        <source>useSourceTI(): Boolean;
/*
Purpose:			

Date		Who		Reason
12 April 2023	navab1	TFS 57512
*/

vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
