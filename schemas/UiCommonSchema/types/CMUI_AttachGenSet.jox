    <JadeMethod name="create" id="61058c73-a070-4cee-aa92-8d667e03d8b2">
        <updating/>
        <source>create() updating;
/* ---------------------------------------------------------------------------
Created:	26 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.permissionView  := PmAdmConnectView;
	self.permissionMaint := PmAdmConnectMaint;

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="20e866c4-a765-45d8-b85c-02390c47968f">
        <updating/>
        <source>doOK() updating;
/* ---------------------------------------------------------------------------
Created:	26 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
08/04/2011		cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
------------------------------------------------------------------------------*/
vars
	nowTimeStamp,
	localTimeStamp,
	connectTimeStamp: TimeStamp;
	connectParams	: CMIF_ConnectParams;
	loadState		: Boolean;
	date			: Date;
	time			: Time;
	pxyTI,
	pxyGen			: CM_TrackedItem;
	
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	if self.myTrackedItem = null then
		return;
	endif;
	if self.cmbGenSet.listIndex	= -1 then
		app.msgBox( app.getErrorString(ERR_selectGenSet), null , MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	date := txtDate.text.asDateJMT();
	time := txtTime.text.asTimeJMT();
	
	if date.isValid() and time.isValid() then
		 
		localTimeStamp.setDate(date);
		localTimeStamp.setTime(time);
		connectTimeStamp := self.localToSystemTime(localTimeStamp);// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	else
		nowTimeStamp := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		connectTimeStamp := nowTimeStamp;
	endif;

	create connectParams transient;

 	app.cmsBeginLoad(loadState);
 	pxyTI := self.myTrackedItem.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);

	connectParams.dateTime := connectTimeStamp;
	connectParams.noCharge := self.chkCharge.value;	//Par 17972
	connectParams.myTerminal := self.myTerminal;
	connectParams.myTrackedItem := pxyTI;
	connectParams.locationsController := self.myTrackedItem.getPrimaryLocation(REAL_MODE);
	connectParams.userId := app.getMyUserCode();
	connectParams.action := ACTION_ATTACH;	
	connectParams.radioTelemetryUser := false;
	app.cmsBeginLoad(loadState);
	pxyGen := self.cmbGenSet.itemObject[self.cmbGenSet.listIndex].CM_TrackedItem.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	connectParams.myOtherTrackedItem := pxyGen;
	connectParams.type := TRANS_TYPE_AttachGenerator;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateAttach(connectParams, app.myPassport);	
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Connect', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	inheritMethod(); //closing the form
	
epilog
	app.cmsEndLoad(loadState);		// 08/04/2011 cnwmh5 #27347
	delete pxyTI;
	delete pxyGen;
	
	if connectParams &lt;&gt; null then
		connectParams.allTrackedItems.purge(); // proxies
		delete connectParams;
	endif;

	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadData" id="daa5e1d8-8dca-4c87-9a42-d0803a418c50">
        <updating/>
        <source>loadData() updating;
/* ---------------------------------------------------------------------------
Created:	26 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
------------------------------------------------------------------------------*/
vars
	aTS : TimeStamp;
	
begin

	self.setCmbGenSet();
	
	aTS :=	self.systemToLocalTime(app.actualTimeServer);// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.txtDate.text := aTS.date.asStringJMT();
	self.txtTime.text := aTS.time.asStringJMT();

end;</source>
    </JadeMethod>
    <JadeMethod name="setCmbGenSet" id="8e1eaf3c-c973-4d37-9192-dfacd0eb873e">
        <source>setCmbGenSet();
/* ---------------------------------------------------------------------------
Created:	26 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
11/03/2010		cnwdap1	PAR #23111 CM_Generator.relatedTo should be reefersRelatedTo - missed as part of chanegs for CCMS MES 1007
14/07/2025		naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
------------------------------------------------------------------------------*/
vars
	ti				: CM_TrackedItem;
	dict			: CM_TIByCargoTypeIdDict;
	iter			: Iterator;
//	tiId,
	idStr,
	str				: String;
	cargoType,
	genType			: Integer;
	ls,
	itemAdded,
	maxCountExceeded: Boolean;
	count			: Integer;
	isForContainer	: Boolean;
	
begin
//	app.writeStatement(class.name &amp; ' pCargoType ' &amp; pCargoType.String &amp; ', pState ' &amp; pState.String);
	cmbGenSet.clear;

	dict := self.myTerminal.allOnsiteTIsByCargoTypeId;	// all on-site TI_STATE_NORMAL

	if dict = null then
		return;
	endif;

	if self.myTrackedItem.isKindOf(CM_Container) then
		isForContainer := true;
	elseif self.myTrackedItem.isKindOf(CM_TILC) then
		isForContainer := false;
	else
		app.raiseUnexpectedProgramError( class.name, method.name, 'The form not designerd for other TrackedItem type' );
		return;
	endif;
	
	app.cmsBeginLoad(ls);
	
	iter := dict.createIterator;
	dict.startKeyGeq( TI_CargoType_Generator, null, iter );
	while iter.next(ti) do
	
		iter.getCurrentKeys(cargoType, idStr);  //MTN-35226
		if cargoType &lt;&gt; TI_CargoType_Generator then
			break;
		endif;
		
		if ti.CM_Generator.myGeneratorType = null then
			continue;	// for standAlone generators, type can be null
		endif;
		//if ti.CM_Generator.relatedTo.size &gt; 0 or ti.CM_Generator.myChassis &lt;&gt; null then			// PAR #23111
		if ti.CM_Generator.reefersRelatedTo.size &gt; 0 or ti.CM_Generator.myChassis &lt;&gt; null then		// PAR #23111
			continue;	// the generator is already attached either to a container or to a chassis
		endif;
		
		itemAdded := false;
		if isForContainer then
			if ti.CM_Generator.myGeneratorType.isNoseMounted then
				itemAdded := true;
			endif;
		else
			if ti.CM_Generator.myGeneratorType.isUnderSlung then
				itemAdded := true;
			endif;
		endif;
		
		if itemAdded then
			cmbGenSet.itemObject[cmbGenSet.addItem(idStr)] := ti;				
			count := count + 1;
			if count &gt;= 29999 then
				//jade limit for a combo - this'll happen for 
				//logs every time - possibly other cargo types too
				maxCountExceeded := true;
				break;
			endif;
		endif;
		
	endwhile;
	
	app.cmsEndLoad(ls);
	
	if maxCountExceeded then
		app.msgBox('There were more than 32,000 tracked items of selected type.' &amp; CrLf &amp;
					'Only the first 32,000 have been listed', ' Maximum entries exceeded', MsgBox_Exclamation_Mark_Icon);
	endif;

epilog
	delete iter;
	app.cmsEndLoad(ls);


end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="fd9fc21b-7696-4ef6-81e9-cb08f15fd93e">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2008	cnwer1	Initial creation

*/

vars

begin

	inheritMethod();
	self.setCaption( self.myTrackedItem.id &amp; " attach a Generator Set" );
	
	//self.myAssistant.comboBoxGeneratorType( self.cmbGenSet, null );
	self.loadData();

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="8b668dba-d015-48c5-abfc-219911e365b5">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017253, locale);
	lblCharge.translateCaption(Xlat_0009751, locale);
	lblDate.translateCaption(Xlat_0009752, locale);
	lblGenSet.translateCaption(Xlat_0009753, locale);
	lblTime.translateCaption(Xlat_0009754, locale);
end;</source>
    </JadeMethod>
</GUIClass>
