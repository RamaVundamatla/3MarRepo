    <JadeMethod name="isCMIFDataMatch" id="b916d063-d3f0-45cc-94b8-a20fb498bb7f">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataBoolean): Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 14 August 2023
TFS#		: 58429
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	return _cmifAutoPlan.isItemised_Match(_yaData);
end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataBoolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
