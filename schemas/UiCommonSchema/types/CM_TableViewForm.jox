    <JadeMethod name="createProxiesForEdit" id="ca6c89f5-aaf0-41a8-b7b6-ed9d28a9ecfc">
        <updating/>
        <source>createProxiesForEdit() updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 March 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	obj			: Object;
	tmpProxy	: CM_Object;

begin
	if self.doingMultiEdit then
		if self.useProxyObject then
			self.myCurrentObject := self.useDiffObjInTblData(self.myCurrentObject); // CCMS 1282 AKB2004NOV
			// create a proxy got each of the selected objects.
			foreach obj in self.tblData.allSelectedObjects do
				obj := self.useDiffObjInTblData(obj); // CCMS 1282 AKB2004NOV
				tmpProxy := self.createUpdateProxy(obj.CM_Object);
				self.allProxyObjects.add(tmpProxy);
				
				if obj = self.myCurrentObject then
					self.myProxyObject := tmpProxy;
				endif;
			endforeach;
		endif;
		self.objectEdition := -1;
	else
		if self.useProxyObject then
			obj := self.useDiffObjInTblData(self.myCurrentObject.CM_Object); // CCMS 1282 AKB2004NOV
			self.myCurrentObject := obj;// CCMS 1282 AKB2004NOV
			
			self.myProxyObject := self.createUpdateProxy(self.myCurrentObject.CM_Object);
			self.allProxyObjects.add(self.myProxyObject);
		endif;
		self.objectEdition := self.myCurrentObject.edition;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createUpdateProxy" id="890d672a-5b3a-420a-afee-8247e80e0b1f">
