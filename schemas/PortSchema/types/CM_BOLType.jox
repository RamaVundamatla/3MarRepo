<Class name="CM_BOLType" id="9b22c0da-860b-4b92-855f-3c98591d3eeb">
    <superclass name="CM_CargoBOLType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>See category BOLTypeConstants</text>
    <DbClassMap file="terminal"/>
    <CompAttribute name="allToDoReqsPostRelease" id="93aa166c-d28d-41f3-8471-8a320bfe4a44">
        <type name="StringArray"/>
        <access>readonly</access>
        <text>
This is a list of "CM_ToDoRequestType" codes that are
performed after a BOL has been released (ie. the load
onto truck task has been done).</text>
    </CompAttribute>
    <CompAttribute name="allToDoReqsPreReceival" id="4ab4585a-0a03-41aa-8ea5-f5968ebd65f8">
        <type name="StringArray"/>
        <access>readonly</access>
        <text>
This is a list of "CM_ToDoRequestType" codes that are
performed prior to a BOL being received (ie. before the 
unload task has been done).</text>
    </CompAttribute>
    <ExplicitInverseRef name="myRoot" id="a11b0778-5138-41f2-8e14-ba4db0f39735">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Root"/>
        <access>readonly</access>
        <Inverse name="CM_Root::allBOLTypes"/>
    </ExplicitInverseRef>
    <JadeMethod name="getYADisplay" id="acd24c15-b6c4-4b26-bc68-a75eb3abfc28">
        <source>getYADisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

begin
	if app.myPassport.myTerminal &lt;&gt; null and not self.allTerminals.includes(app.myPassport.myTerminal) then
		return null;
	endif;
	
	if self.id &gt; TI_CargoBOLType_JMTMax and not app.myRoot.isClientCentrePort then	
		return null;																
	endif;																			
	
	return self.abbreviation &amp; Tab &amp; self.description;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYAIdentifier" id="83769a44-5d81-47f5-a9ab-c62c4023cb49">
        <source>getYAIdentifier(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

begin
	return self.abbreviation.toUpper();
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasToDoRequests" id="efb236fa-c6d6-4817-8643-1f5d81681a39">
        <source>hasToDoRequests(): Boolean;
//-----------------------------------------
//Created: October 2002 By: cnwgd1
//-----------------------------------------
vars

begin
	if self.allToDoReqsPreReceival.isEmpty then
		return false;
	endif;
	
	return true;			
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDefaultSelectorColumns" id="492b784a-5ee0-47cb-9bfc-f895a65ec16e">
        <updating/>
        <source>setDefaultSelectorColumns(_qDef : CM_QueryDefinition) updating;

vars
	qProp		: CM_QueryProperty;
	visColArray		: StringArray;
begin
	visColArray := self.allSelectorVisibleColumns;
	visColArray.clear();
	//add a few visible columns as a default - just a lame startup
	qProp := _qDef.allQueryProperties['number'];
	if qProp &lt;&gt; null then
		visColArray.add(qProp.propertyName);
	endif;
	
	qProp := _qDef.allQueryProperties['carrierCode'];
	if qProp &lt;&gt; null then
		visColArray.add(qProp.propertyName);
	endif;
	
	qProp := _qDef.allQueryProperties['myOperator'];
	if qProp &lt;&gt; null then
		visColArray.add(qProp.propertyName);
	endif;

end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="46abc924-36bd-4df0-8aaf-e754c88dc2b4">
        <updating/>
        <source>setForCreate(pProxyBOLType : CM_BOLType) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.setForUpdate(pProxyBOLType);
	self.myRoot := pProxyBOLType.myRoot;

end;</source>
        <Parameter name="pProxyBOLType" type="CM_BOLType"/>
    </JadeMethod>
    <JadeMethod name="setGateInOutExtraTblRecieve" id="d68a9876-f994-470e-a51b-ef2ed4c6877b">
        <updating/>
        <source>setGateInOutExtraTblRecieve(_view :String) updating;
// ---------------------------------------------------------------------------
// Created:     21 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
