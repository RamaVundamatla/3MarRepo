    <JadeMethod name="createAndCheckCriteria" id="56d4ad10-c751-41fe-80d0-113afb906725">
        <source>createAndCheckCriteria(	_operator : CM_Operator;
						_cargoType : CM_CargoType;
						_cargoSubTypeCode : String;
						_isoTypeCode : String;
						_trailerTypeCode : String;
						_criteria : CMIF_Array io	) : CM_ObjectMatchCriteria;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars
	pxyCriteria : CM_YACriteria;
	realOpCrit : CM_ObjectMatchCriteria;
	opCrit : CM_OperatorCarrierCriteria;
	cmifCriterion : CMIF_YACriteriaPriority;

begin
	if _cargoType &lt;&gt; null then
		create pxyCriteria transient;
		pxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType], _cargoType.getYAIdentifier, "Cargo Type");
		cmifCriterion := pxyCriteria.getTransient();
		_criteria.add(cmifCriterion);
	endif;
	if _cargoSubTypeCode &lt;&gt; null then
		create pxyCriteria transient;
		if _cargoType &lt;&gt; null then
			pxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_Product], _cargoType.getYAIdentifier &amp; " - " &amp; _cargoSubTypeCode, "Cargo Subt");
		else
			pxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_Product], _cargoSubTypeCode, "Cargo Subt");
		endif;
		cmifCriterion := pxyCriteria.getTransient();
		_criteria.add(cmifCriterion);
	endif;
	if _isoTypeCode &lt;&gt; null then
		create pxyCriteria transient;
		pxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_ISO], _isoTypeCode, "ISO Type");
		cmifCriterion := pxyCriteria.getTransient();
		_criteria.add(cmifCriterion);
	endif;
	if _trailerTypeCode &lt;&gt; null then
		create pxyCriteria transient;
		pxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_TrailerType], _trailerTypeCode, "Trailer Ty");
		cmifCriterion := pxyCriteria.getTransient();
		_criteria.add(cmifCriterion);
	endif;
	// see if we have a matching carrier criteria
	realOpCrit := null;
	foreach opCrit in _operator.allOperatorCarrierCriteria discreteLock do
		if opCrit.matchesCriteria(_criteria) then
			realOpCrit := opCrit;
			break;
		endif;
	endforeach;
	
	return realOpCrit;
epilog
	
end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_cargoSubTypeCode" type="String"/>
        <Parameter name="_isoTypeCode" type="String"/>
        <Parameter name="_trailerTypeCode" type="String"/>
        <Parameter name="_criteria" type="CMIF_Array" usage="io"/>
        <ReturnType type="CM_ObjectMatchCriteria"/>
    </JadeMethod>
    <JadeMethod name="getCargoType" id="8a52ba04-473b-4c76-8d35-04b94c27cd44">
        <source>getCargoType(_value : String) : CM_CargoType;
//
// 15 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
//
vars
	cargoType : CM_CargoType;
	cargoTypeId : Integer;
	cargoTypeCode : String;
	foundMatch : Boolean;
	xlationOperator : CM_Operator;
begin
	xlationOperator := self.getXlationOperator();
	cargoTypeId := _value.Integer;
	if cargoTypeId &lt;&gt; null then
		cargoType := app.myRoot.allCargoTypesById[cargoTypeId];
	endif;
	if cargoType = null then
		cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(_value);
	endif;
	if cargoType = null and
	   xlationOperator &lt;&gt; null then
		cargoTypeId := xlationOperator.getXlationSystemCode(_value, XLATION_TYPE_CARGOTYPE_BYOP, foundMatch).Integer;
		cargoType := app.myRoot.allCargoTypesById[cargoTypeId];
	endif;
	return cargoType;
epilog

end;</source>
        <Parameter name="_value" type="String"/>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="141cd532-804b-48f2-9bd5-b45a70479e90">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// 15 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
//
vars

begin
	if _attrName = ETRow_CargoTypes then
		if self.allEDITrackedItems.isEmpty then
			return null;
		else
			return self.allEDITrackedItems.first.CM_EDICarrierAccessCTTI.cargoTypeDescr;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
