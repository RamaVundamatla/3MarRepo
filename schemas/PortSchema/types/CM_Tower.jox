    <JadeMethod name="setProxy" id="54ba04eb-d23f-415b-97b8-53b3e458a4e5">
        <updating/>
        <source>setProxy(_nextSlideFault,_prevSlideFault,_remarks : String; 
_nextSlideDisabled,_prevSlideDisabled,_nonOperational : Boolean; 
_nextPortHole,_prevPortHole : CM_Container;_temperature:Real) updating;
