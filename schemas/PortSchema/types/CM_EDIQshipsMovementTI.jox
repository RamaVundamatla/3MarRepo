    <JadeMethod name="canUserSet" id="2ec846a7-7c3c-4ffb-a86a-4d471403f664">
        <source>canUserSet(_propName: String): Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 07 November 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description
21/02/2023		JLIKA1		56562		MTN - POB Qships - Cannot edit data under vessel tab.
****************************************************/
begin
	if _propName = CM_EDIQshipsMovementTI::myQshipsVoyageTI.name then		
		return false;
	else
		return inheritMethod(_propName);
	endif;
end;</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="8e68280c-b358-427a-87f8-5fbe0ea46464">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 28 October 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description
06/12/2024		navmd1		MTN-33628	Fix Voyage Movement 'Occurs On' time not showing in users Terminal timezone
****************************************************/

begin
	if _attrName = ETRow_FromBerth then		
		return self.fromBerth;
	elseif _attrName = ETRow_MoveType then
		return self.moveType;
	elseif _attrName = ETRow_OccursOnDT then
		if self.occursOnDT.isValid() then
			return self.systemToLocalTime(self.occursOnDT).shortCurrentLocaleFormat();
		else
			return "";
		endif;
	elseif _attrName = ETRow_PilotCode then
		return self.pilotCode;
	elseif _attrName = ETRow_QshipStatus then
		if self.qshipStatus = MovementStatus_Planned then 
			return app.getErrorString(Planned);
		elseif self.qshipStatus = MovementStatus_ConfirmedPlan then
			return app.getErrorString(PlanConfirmed);
		elseif self.qshipStatus = MovementStatus_Actual then
			return app.getErrorString(Actual);
		elseif self.qshipStatus = MovementStatus_Cancelled then
			return app.getErrorString(Cancelled); //25/01/2026	navkc1 JIRA MTN 37062
		else
			return "";
		endif;		
	elseif _attrName = ETRow_SideTo then
		return self.sideTo.asStringJMT;
	elseif _attrName = ETRow_ToBerth then
		return self.toBerth;
	elseif _attrName = ETRow_TugCode then
		return self.tugCode;
	elseif _attrName = ETRow_TugCount then
		return self.tugCount.asStringJMT;
	elseif _attrName = ETRow_VoyageCode then		
		return self.myQshipsVoyageTI.voyageId;
	endif;

	return inheritMethod(_attrName, _short);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setClearBerthTime" id="69d13e31-7408-4053-8220-ec0909c3db96">
        <updating/>
        <source>setClearBerthTime(_value : TimeStamp) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2024	navsp1	Initial creation TFS ChangeRequest 63842: NSW | OnePort Integration Dev

*/

vars

begin
	self.clearBerthTime := _value;
epilog

end;</source>
        <Parameter name="_value" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="fc943e99-8f6f-4156-bd49-76a8cf4ac165">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 07 November 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description
21/02/2023		JLIKA1		56562		MTN - POB Qships - Cannot edit data under vessel tab.
****************************************************/
vars
	prop : Property;
	propDict : PropertyNDict;	
begin
	
	propDict := CM_EDIQshipsMovementTI.getProperties;	

	foreach prop in propDict do
		if self.canUserSet(prop.name) then		   			
			self.setPropertyValue(prop.name, _proxyEDITI.getPropertyValue(prop.name));
		endif;
	endforeach;
	
	inheritMethod(_proxyEDITI);
end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
