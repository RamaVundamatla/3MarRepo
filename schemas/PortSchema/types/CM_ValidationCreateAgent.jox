    <JadeMethod name="valEmailRequest" id="81d771c8-12ac-464b-ab92-afca6baddfe9">
        <source>valEmailRequest(_alertDescription, _toAddress, _fromAddress : String; _passport : CM_Passport);

// cnwdvb1 11 February 2003 
//16/01/2023 navmv20 TFS 55307 Task 55514: Jade - Email Invoice Attachments Jade Code
vars

	user 			: CM_User;
	userString,
	terminalCode	: String;
	terminal	: CM_Terminal;

begin

	user := _passport.myUser;
	
	if user &lt;&gt; null then
		userString := app.getErrorString(User) &amp; ' = ' &amp; user.code;
	else
		userString := app.getErrorString(User) &amp; ' ' &amp; app.getErrorString(Unknown);
	endif;
	
	terminal := _passport.myTerminal;
	if terminal &lt;&gt; null then
		terminalCode := app.getErrorString(Terminal) &amp; ' ' &amp; terminal.code;
	else
		terminalCode := app.getErrorString(Terminal) &amp; ' ' &amp; app.getErrorString(Unknown);
	endif;
	
	if _toAddress = null then
		app.raiseCMException3(Inval_email_add_destin_ext, _alertDescription, userString, terminalCode, null, null);
		return;
	endif;
	
	if _fromAddress = null then
		app.raiseCMException3(Inval_email_add_sender_ext, _alertDescription, userString, terminalCode, null, null);
		return;
	endif;

	//if app.isDevelopmentSystem then
	if app.isDevelopmentSystem and not app.isJMTUnitTest() then					// 15/06/2015 cnwmh5
		//if _toAddress.toLower.pos("jade" ,1) = 0 and _toAddress.toLower.pos("navis.com" ,1) = 0 then // 28 Jan 2020	NDL 	//16/01/2023 navmv20 TFS 55307 TASK 55514
		if _toAddress.toLower.pos("jade" ,1) = 0 and _toAddress.toLower.pos("navis.com" ,1) = 0 and _toAddress.toLower.pos("kaleris.com" ,1) = 0 and _toAddress.toLower.pos("altimetrik.com" ,1) = 0 then //16/01/2023 navmv20 TFS 55307 TASK 55514
			app.raiseCMException(Email_Development, null, null);
			return;
		endif;
	endif;
	


end;</source>
        <Parameter name="_alertDescription" type="String"/>
        <Parameter name="_toAddress" type="String"/>
        <Parameter name="_fromAddress" type="String"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
