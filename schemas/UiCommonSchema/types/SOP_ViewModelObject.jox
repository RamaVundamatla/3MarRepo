    <JadeMethod name="doSelected" id="ef5f6030-29b0-4a61-b06f-b23db6e2529b">
        <updating/>
        <source>doSelected() updating;
// -----------------------------------------------------------------------------
// Created:		18 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.myForm.btnNewChildTV.enabled		:= self.canAddChild;
	self.myForm.btnNewTV.enabled 		:= self.canAddPeer;
	self.myForm.btnDeleteTV.enabled 	:= self.canDelete;
	self.myForm.btnEditTV.enabled 		:= self.canEdit;
	self.showThumbnail(self.myObject);
end;</source>
    </JadeMethod>
