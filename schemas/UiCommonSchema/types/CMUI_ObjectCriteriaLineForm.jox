        <source>setBaseData(	_context : Integer;
				_contextObj : CM_Object;
				_myObjectMatchCriteria : CM_ObjectMatchCriteria;
				_myListForm : CMUI_ObjectCriteriaListForm;
				_myParentForm: CM_BaseForm
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2013	cnwndl1	Initial creation	Par 33184

*/

vars

begin
	
	self.context := _context;
	self.contextObject := _contextObj;
	self.myObjectMatchCriteria := _myObjectMatchCriteria;
	self.myListForm := _myListForm;
	self.myParentForm := _myParentForm;		// 1/3/18 MAP TFS37340
epilog

end;</source>
