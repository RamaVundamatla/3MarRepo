    <JadeMethod name="applyDelayOverlapMinutes" id="8fa4fc53-ff3b-44ad-aa9d-b97e3d8d54e8">
        <source>applyDelayOverlapMinutes( 	delay : CM_Delay;
							minuteDelayArray : BooleanArray input;
							delaysApplied : ObjectSet input
							) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 April 2012	cnwndl1	Initial creation	Par 293679

*/

vars

	
	delayMinute : TimeStamp;
	index : Integer;
	workTSInterval : TimeStampInterval;
	endDelayMinute : TimeStamp;
	minuteInterval :TimeStampInterval;
	localExchangeEnd : TimeStamp;
	

begin

	if not self.exchangeStart.Date.isValid then	// 28 Aug 2012	NDL	Par 30279
		// this one has no details yet.
		return;
	endif;

	localExchangeEnd := self.getExchangeEnd;
	if delay.startDT &gt;= localExchangeEnd then
		// delay started after this exchange period
		return;
	endif;
	
	if delay.getEndDT &lt;= self.exchangeStart then
		// delay ended before this exchange period
		return;
	endif;
		
	// establish the first minute and the relative index the delay overlapped.
	if delay.startDT &lt;= self.exchangeStart then
		delayMinute := self.exchangeStart;
		index := 1;
	else
		delayMinute := delay.startDT;
		workTSInterval := delay.startDT - self.exchangeStart;
		index := workTSInterval.asMinutes.Integer + 1;  // minutes into the exchange period.
	endif;
		
	//establish the last minute that overlapped.
	if delay.getEndDT &lt;= localExchangeEnd then
		endDelayMinute := delay.getEndDT;
	else
		endDelayMinute := localExchangeEnd;
	endif;
	
	//24 Sep 2012	NDL	Par 30357
	if delayMinute &gt;= endDelayMinute then
		return;
	endif;
	delaysApplied.addNoDuplicates(delay,false);
	
	// register the overlap minutes into the array.
	minuteInterval.set(0,60000);  // one minute.
	while true do
		if delayMinute &gt;= endDelayMinute then
			return;
		endif;
		minuteDelayArray[index] := true;
		delayMinute := delayMinute + minuteInterval;
		index := index + 1;
		//delaysApplied.add(delay);
	endwhile;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="delay" type="CM_Delay"/>
        <Parameter name="minuteDelayArray" type="BooleanArray" usage="input"/>
        <Parameter name="delaysApplied" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="applyMinutesUp" id="67ea6b6e-ca70-459b-9a36-ee3d8c29a615">
        <source>applyMinutesUp( minuteUpArray : BooleanArray input;  _startTS : TimeStamp; _endTS : TimeStamp );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	localExchangeEnd : TimeStamp;
	availableStartTS : TimeStamp;
	index : Integer;
	workTSInterval : TimeStampInterval;
	endAvailableTS : TimeStamp;
	minuteInterval : TimeStampInterval;

begin

	if not self.exchangeStart.Date.isValid then	// 28 Aug 2012	NDL	Par 30279
		// this one has no details yet.
		return;
	endif;

	localExchangeEnd := self.getExchangeEnd;
	
	if _startTS &gt; localExchangeEnd then
		return;
	endif;
	
	if _endTS &lt; self.exchangeStart then
		return;
	endif;
	
	
	// establish the first minute and the relative index that we were available.
	if _startTS &lt;= self.exchangeStart then
		availableStartTS := self.exchangeStart;
		index := 1;
	else
		availableStartTS := _startTS;
		workTSInterval := _startTS - self.exchangeStart;
		index := workTSInterval.asMinutes.Integer + 1;// minutes into the exchange period.
	endif;
		
	//establish the last minute that overlapped.
	if _endTS &lt;= localExchangeEnd then
		endAvailableTS := _endTS;
	else
		endAvailableTS := localExchangeEnd;
	endif;
		
	// register the overlap minutes into the array.
	minuteInterval.set(0,60000);  // one minute.
	while true do
		if availableStartTS &gt;= endAvailableTS then
			return;
		endif;
		minuteUpArray[index] := true;
		availableStartTS := availableStartTS + minuteInterval;
		index := index + 1;
	endwhile;


epilog

end;</source>
        <Parameter name="minuteUpArray" type="BooleanArray" usage="input"/>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="craneWorkPointId" id="d725c06e-69da-457d-9f6d-e0669cc3e8b6">
        <methodInvocation>mapping</methodInvocation>
        <source>craneWorkPointId(set : Boolean; _value : String io) mapping;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

begin

	if set then
		return;
	else
		if self.myCrane &lt;&gt; null then
			_value := self.myCrane.id;
		elseif self.myWorkPoint &lt;&gt; null then
			_value := self.myWorkPoint.code;
		else
			_value := null;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDelayedMinutes" id="1ba41a20-d614-4373-8970-832b525f5e0c">
        <source>getDelayedMinutes():Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	minuteDelayArray : BooleanArray;
	delaysApplied : ObjectSet;	//ObjectArray;
	iter : Iterator;
	delay : CM_Delay;
//	index : Integer;
	count : Integer;
	
	bool : Boolean;
	delays : CM_ObjectSet;
	localExchangeEnd : TimeStamp;

begin

	if not self.exchangeStart.Date.isValid then
		return 0;
	endif;

	create minuteDelayArray transient;
	create delaysApplied transient;

	iter := self.myVoyage.allDelays.createIterator;
	while iter.next( delay ) do
		self.applyDelayOverlapMinutes( 	delay,	//delay : CM_Delay;
										minuteDelayArray,	//minuteDelayArray : BooleanArray input;
										delaysApplied	//delaysApplied : ObjectArray input
										);
	endwhile;
	
	/*
	if self.myCrane &lt;&gt; null then
		delete iter;
		iter := self.myCrane.allDelays.createIterator;
		while iter.next( delay ) do
			if delaysApplied.includes(delay) then
				continue;
			endif;
			self.applyDelayOverlapMinutes( 	delay,	//delay : CM_Delay;
											minuteDelayArray,	//minuteDelayArray : BooleanArray input;
											delaysApplied	//delaysApplied : ObjectArray input
											);
		endwhile;
	endif;
	
	if self.myWorkPoint &lt;&gt; null then
		delete iter;
		iter := self.myWorkPoint.allDelays.createIterator;
		while iter.next( delay ) do
			if delaysApplied.includes(delay) then
				continue;
			endif;
			self.applyDelayOverlapMinutes( 	delay,	//delay : CM_Delay;
											minuteDelayArray,	//minuteDelayArray : BooleanArray input;
											delaysApplied	//delaysApplied : ObjectArray input
											);
		endwhile;
	endif;
	*/
	
	//24 Sep 2012	NDL	Par 30357
	create delays transient;
	localExchangeEnd := self.getExchangeEnd;
	if self.myCrane &lt;&gt; null then
		self.myCrane.allDelays.getDelaysForPeriod( delays, self.exchangeStart, localExchangeEnd );
	endif;
	if self.myWorkPoint &lt;&gt; null then
		self.myWorkPoint.allDelays.getDelaysForPeriod( delays, self.exchangeStart, localExchangeEnd );
	endif;
	
	if not delays.isEmpty then
		delete iter;
		iter := delays.createIterator;
		while iter.next( delay ) do
			if delaysApplied.includes(delay) then
				continue;
			endif;
			self.applyDelayOverlapMinutes( 	delay,	//delay : CM_Delay;
											minuteDelayArray,	//minuteDelayArray : BooleanArray input;
											delaysApplied	//delaysApplied : ObjectArray input
											);
		endwhile;
	endif;
	
/*	foreach index in 1 to minuteDelayArray.size do
		if minuteDelayArray[index] then
			count := count + 1;
		endif;
	endforeach; */
	
	//24 Sep 2012	NDl	Par 30357
	foreach bool in minuteDelayArray do
		if bool then
			count := count + 1;
		endif;
	endforeach;
	
	return count;
	
epilog

	delete iter;
	delete minuteDelayArray;
	delete delaysApplied;
	delete delays;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="e94cec1d-50a3-4333-be3f-9836c30c207d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 March 2012	cnwndl1	Initial creation	Par 29369
25 September 2018	cnwma1	ChangeRequest 41080: PEL1 - Assigning Operators ID to Cranes/Work-Points
*/

vars

begin

	if _attrName = ETRow_Crane then
		if self.myCrane &lt;&gt; null then
			return self.myCrane.id;
		elseif self.myWorkPoint &lt;&gt; null then
			return self.myWorkPoint.code;
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_ExchangeStart then
		return self.exchangeStart.asStringJMT;
	
	elseif _attrName = ETRow_ExchangeEnd then
		return self.exchangeEnd.asStringJMT;
	
	elseif _attrName = ETRow_LabourStart then
		return self.labourStart.asStringJMT;
	
	elseif _attrName = ETRow_LabourEnd then
		return self.labourEnd.asStringJMT;
	
	elseif _attrName = ETRow_Remarks then
		return remarks;
	
	//25.09.2018 cnwma1 TFS #41080
	elseif _attrName = ETRow_CraneOpr then
		if self.myUser &lt;&gt; null then
			return self.myUser.code;
		else
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
		
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExchangeEnd" id="e6c169bf-ba69-4edc-905d-171913fecaff">
        <source>getExchangeEnd():TimeStamp;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	returnTs : TimeStamp;
	shipExchEnd : TimeStamp;

begin

	returnTs := app.actualTimeServer;
	
	shipExchEnd := self.myVoyage.shipExchangeCompleteDT;
	if shipExchEnd.Date.isValid and shipExchEnd &lt; returnTs then
		returnTs := shipExchEnd;
	endif;
	
	if exchangeEnd.Date.isValid and exchangeEnd &lt; returnTs then
		returnTs := exchangeEnd;
	endif;
	
	return returnTs;

epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getExchangeEndLocalTZ" id="fcb9b859-d20b-45bd-b657-2d540fd06dd5">
        <source>getExchangeEndLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2016	cnwns1	Initial creation
// 07 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	returnTs : TimeStamp;
	shipExchEnd : TimeStamp;

begin

	returnTs := app.actualTimeServer;
	
	shipExchEnd := self.myVoyage.shipExchangeCompleteDT;
	if shipExchEnd.Date.isValid and shipExchEnd &lt; returnTs then
		returnTs := shipExchEnd;
	endif;
	
	if exchangeEnd.Date.isValid and exchangeEnd &lt; returnTs then
		returnTs := exchangeEnd;
	endif;
	
	return self.systemToLocalTime(returnTs);

epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
