    <JadeMethod name="displayBay" id="6b4539a4-9830-4db0-a6c4-bd8365356ada">
        <source>displayBay( _obj : Object ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

begin

	if _obj = null or not _obj.isKindOf( CM_Bay ) then
		return null;
	endif;
	
	return app.getErrorString1( Bay_And_ID, _obj.CM_Bay.id );

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="f7fdc918-6c93-4adb-911f-a69fda54b9b4">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

begin

	app.mousePointer := Window.MousePointer_HourGlass;

	if self.validateAndPopulate then
		if self.chkProfileSumm.value then
			self.printProfileSummaryReport();
		endif;
		if self.myScanPlanAgent.doPrint() then
//			inheritMethod();
		endif;
	endif;

epilog

	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="836dd34f-a05e-4f8f-b696-f33404927366">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 September 2020	jlgndl1	Initial creation

*/

vars

	xmlStr : String;

begin

	xmlStr := inheritMethod();
	
	xmlStr := xmlStr &amp; global.formatAsXML(self.optA3.name, self.optA3.value.String );
	xmlStr := xmlStr &amp; global.formatAsXML(self.optA4.name, self.optA4.value.String );
	
	xmlStr := xmlStr &amp; global.formatAsXML(self.optOneBay.name, self.optOneBay.value.String );
	xmlStr := xmlStr &amp; global.formatAsXML(self.optTwoBay.name, self.optTwoBay.value.String );
	xmlStr := xmlStr &amp; global.formatAsXML(self.optThreeBay.name, self.optThreeBay.value.String );
	xmlStr := xmlStr &amp; global.formatAsXML(self.optSixBay.name, self.optSixBay.value.String );
	xmlStr := xmlStr &amp; global.formatAsXML(self.optTwelveBay.name, self.optTwelveBay.value.String );
	
	xmlStr := xmlStr &amp; global.formatAsXML(self.optOnePage.name, self.optOnePage.value.String );
	xmlStr := xmlStr &amp; global.formatAsXML(self.optPageAll.name, self.optPageAll.value.String );
	
	xmlStr := xmlStr &amp; global.formatAsXML(self.optColNone.name, self.optColNone.value.String );
	xmlStr := xmlStr &amp; global.formatAsXML(self.optColDPort.name, self.optColDPort.value.String );
	xmlStr := xmlStr &amp; global.formatAsXML(self.optColOp.name, self.optColOp.value.String );
	xmlStr := xmlStr &amp; global.formatAsXML(self.optColComm.name, self.optColComm.value.String );
	xmlStr := xmlStr &amp; global.formatAsXML(self.optColISO.name, self.optColISO.value.String );
	xmlStr := xmlStr &amp; global.formatAsXML(self.optColLPort.name, self.optColLPort.value.String );
	
	xmlStr := xmlStr &amp; global.formatAsXML(self.optSlotAct.name, self.optSlotAct.value.String );
	xmlStr := xmlStr &amp; global.formatAsXML(self.optSlotProp.name, self.optSlotProp.value.String );
	xmlStr := xmlStr &amp; global.formatAsXML(self.optSlotLoad.name, self.optSlotLoad.value.String );
	xmlStr := xmlStr &amp; global.formatAsXML(self.optSlotDisc.name, self.optSlotDisc.value.String );
	xmlStr := xmlStr &amp; global.formatAsXML(self.optSlotDandL.name, self.optSlotDandL.value.String );
	
	xmlStr := xmlStr &amp; global.formatAsXML(self.optROBGrey.name, self.optROBGrey.value.String );
	xmlStr := xmlStr &amp; global.formatAsXML(self.optROBWhite.name, self.optROBWhite.value.String );
	
	xmlStr := xmlStr &amp; global.formatAsXML(self.chkCargoList.name, self.chkCargoList.value.String );
	xmlStr := xmlStr &amp; global.formatAsXML(self.chkProfileSumm.name, self.chkProfileSumm.value.String );
	xmlStr := xmlStr &amp; global.formatAsXML(self.chkPreview.name, self.chkPreview.value.String );
	
	return xmlStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
