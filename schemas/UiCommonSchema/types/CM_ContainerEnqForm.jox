        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnMoveIt_click" id="a9b058f6-a096-4806-aacf-460a67b2dbd5">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnMoveIt_click(btn: Button input) updating;
//--------------------------------------------------
// Created:	23 December 2003 By: cnwgd1
//--------------------------------------------------
vars

	tiArray	: CM_TIArray;
	ti : CM_TrackedItem;
begin
	create tiArray transient;

	// Par 10205 populate move it screen if veiwing individual cargo
	if 	self.useTblData	= false then 
		ti := self.myCurrentObject.CM_TrackedItem;
		tiArray.add(ti);	
	elseif CM_TrackedItem.hasInstance(self.myCurrentObject) then
		self.tblData.allSelectedObjects.copy(tiArray);
	else
		return;		
	endif;
	
	if tiArray.size = 0 then
		return;
	endif;
	
	if tiArray.size &lt; 2 then
		//01 Oct 2018	NDL	TFS 39186
		if tiArray.first.isCargoGroupItem then
			self.myAssistant.showMoveItForm(tiArray, PLANNING_MODE);
			return;
		endif;
		
		//self.myAssistant.showMoveItForm(tiArray, REAL_MODE);
		self.myAssistant.showMoveItForm(tiArray, self.getMoveMode);	//25 Aug 2011	NDL	Par 28035
	else
		self.myAssistant.showMoveItForm(tiArray, AUTO_PLAN_MODE);
	endif;
	
epilog
	delete tiArray;
end;</source>
