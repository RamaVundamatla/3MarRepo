    <JadeMethod name="trxCheckTiAgaintRequest" id="7527d991-2680-433f-845d-ab1d3359dbce">
        <updating/>
        <source>trxCheckTiAgaintRequest(_ti : CM_TrackedItem; _request : CM_Request; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 10 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	// Always initialize the activity first
	// This won't work correctly as we are not calling finalize cause we
	// aren't in a tranasaction as this is just a tester trx. 
//	self.initialiseActivityWithPassport(_passport, method);

	_passport.initialiseTransaction();	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(true);

	_ti.testAgainstRequest(_request);		


end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
