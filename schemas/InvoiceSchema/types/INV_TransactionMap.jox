    <JadeMethod name="doReplace" id="e03ee7a1-b91b-4d2a-b774-ff8900ca8a3c">
        <updating/>
        <source>doReplace() updating, protected;

vars
	count	: Integer;
	edition	: Integer;
	invalidObject	: Boolean;
	finObj		: CM_FinancialObject;
	fromILD		: CM_InvoiceLineDesc;
	toILD		: CM_InvoiceLineDesc;
begin

	fromILD := self.cmbILDFrom.listObject.CM_InvoiceLineDesc;
	toILD := self.cmbILDTo.listObject.CM_InvoiceLineDesc;

	if self.modePropertyUpdate = self.ModeProperty_CargoType then
		finObj := self.myCurrentMapTIService;
	elseif self.modePropertyUpdate = self.ModeProperty_ProductGroup then
		finObj := self.myCurrentMapProdGrp;
	elseif self.modePropertyUpdate = self.ModeProperty_Product then
		finObj := self.myCurrentMapProduct;
	elseif self.modePropertyUpdate = self.ModeProperty_IMEX then
		finObj := self.myCurrentMapIMEX;
	elseif self.modePropertyUpdate = self.ModeProperty_Contents then
		finObj := self.myCurrentMapContents;
	elseif self.modePropertyUpdate = self.ModeProperty_Commodity then
		finObj := self.myCurrentMapCommodity;
	elseif self.modePropertyUpdate = self.ModeProperty_TransType then
		finObj := self.myCurrentMapServiceBroker;
	elseif self.modePropertyUpdate = self.ModeProperty_Debtor then
		finObj := self.myCurrentMapDebtor;
	endif;
	if finObj &lt;&gt; null then
		// 33535 handle the transaction map entity being deleted under us by another user
		on Exception do app.handleDeletedObject( exception, finObj, invalidObject );
		edition := finObj.edition;
		if invalidObject then
			self.resetReplace();
			return;
		endif;

		count := app.myTrxUA.trxReplaceTMInvoiceLineType(finObj, fromILD, toILD, app.myPassport);
		self.statusLine.caption := count.String &amp; " invoice line types replaced";
	endif;
	
	self.frmReplace.visible := false;
	self.lstData.enabled := true;
	self.frmToolbar.enabled := true;
	
	if count &gt; 0 then
		self.doQuery();		// refresh at the end
	endif;
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="7b8ea047-07e4-4acf-9ef1-31a9a52da31c">
        <updating/>
        <source>doResize() updating;

vars

begin
	self.splMain.height := self.clientHeight - self.frmToolbar.height - self.statusLine.height - 1;	//24 May 2018	NDL	TFS 38789
	inheritMethod();
	//self.splMain.height := self.clientHeight - self.frmToolbar.height - self.statusLine.height - 1;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveMakeActive" id="fe917cae-2034-4ea7-b9a2-beef1a86b44a">
        <updating/>
        <source>doSaveMakeActive() updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theReturn : Integer;
begin

	while true do
		if self.myCurrentMapTM &lt;&gt; null then
			app.myTrxUA.trxUpdateBankTMActive(self.myCurrentMapTM,app.myPassport);
		elseif self.myCurrentMapTMVoyage &lt;&gt; null then
			app.myTrxUA.trxUpdateBankTMVActive(self.myCurrentMapTMVoyage,app.myPassport);
		elseif self.myCurrentMapTMEvent &lt;&gt; null then
			app.myTrxUA.trxUpdateBankTMEActive(self.myCurrentMapTMEvent,app.myPassport);
		elseif self.myCurrentMapTMWorkOrder &lt;&gt; null then // TFS 39236
			app.myTrxUA.trxUpdateBankTMWOActive(self.myCurrentMapTMWorkOrder,app.myPassport); // TFS 39236
		elseif self.myCurrentMapTMBOL &lt;&gt; null then //01 Nov 2019	NDL TFS 47100
			app.myTrxUA.trxUpdateBankTMBOLActive(self.myCurrentMapTMBOL,app.myPassport); //01 Nov 2019	NDL TFS 47100
		elseif self.myCurrentMapTMSS &lt;&gt; null then
			app.myTrxUA.trxUpdateBankTMSActive(self.myCurrentMapTMSS, app.myPassport);
		elseif self.myCurrentMapTMCargoAllocation &lt;&gt; null then // PAR 35833
			app.myTrxUA.trxUpdateBankTMCAActive(self.myCurrentMapTMCargoAllocation); // PAR 35833
		elseif self.myCurrentMapTMInventory &lt;&gt; null then  // ### TFS 51219 25MAY2021 NAVAB1
			app.myTrxUA.trxUpdateBankTMInventActive(self.myCurrentMapTMInventory);  // ### TFS 51219 25MAY2021 NAVAB1
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Make Transaction Map Active", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveTMBOL" id="6cf52015-83a2-44b3-9331-1a1e61e7fb21">
