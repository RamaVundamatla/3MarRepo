    <JadeMethod name="removeSpriteChanges" id="22f2fd06-134f-44b5-add8-23bbd0889e61">
        <source>removeSpriteChanges(_dragPic : HMS_GraphicalDragPicture io);
//--------------------------------------------------
// Created:	17 August 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.backoutSpriteChanges(_dragPic);
	delete _dragPic;		
