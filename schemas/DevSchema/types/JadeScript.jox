    <JadeMethod name="rs2" id="1203851e-4bd6-42a7-bcc5-6f87e53c0105">
        <source>rs2();

vars
	carrier : CM_Carrier;
	carrier1 : CM_Carrier;
	carrier2 : CM_Carrier;
	carrier3 : CM_Carrier;
	carrier4 : CM_Carrier;
	operator1 : CM_Operator;
	operator2 : CM_Operator;
	opCrit : CM_OperatorCarrierCriteria;
	opCrit1 : CM_OperatorCarrierCriteria;
	opCrit2 : CM_OperatorCarrierCriteria;
begin
	app.initialize;
	app.initialize;
	operator1 := app.myRoot.allOperators["MSK"];
	operator2 := app.myRoot.allOperators["APL"];
	carrier1 := app.myRoot.allCarriers["UT_OTHER"];
	carrier2 := app.myRoot.allCarriers["DOUG"];
	carrier3 := app.myRoot.allCarriers["UTCAR2"];
	foreach opCrit in operator1.allOperatorCarrierCriteria do
		if opCrit.allCriteria.first.myYACriteriaType.type = YACriteriaType_CargoType and
		   opCrit.allCriteria.first.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType.id = 1 then
			opCrit1 := opCrit;
		endif;
	endforeach;
	foreach opCrit in operator2.allOperatorCarrierCriteria do
		if opCrit.allCriteria.first.myYACriteriaType.type = YACriteriaType_CargoType and
		   opCrit.allCriteria.first.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType.id = 1 then
			opCrit2 := opCrit;
		endif;
	endforeach;
	beginTransaction;
	opCrit1.allCarriers.add(carrier1);
	opCrit1.allCarriers.add(carrier2);
	opCrit1.allCarriers.add(carrier3);
	opCrit2.allCarriers.add(carrier2);
	commitTransaction;
end;
</source>
    </JadeMethod>
