    <JadeMethod name="printAudit" id="e16466c9-60c4-42cf-baa9-20b06e67eafc">
        <updating/>
        <source>printAudit(auditObj: CM_Audit; cleared: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

constants
	Details_Width = 250;
	Remarks_Width = 340;
	After_Object_Spacing = 3;
vars

begin
	lblAuditNo.caption := auditObj.sequenceNum.String;
	lblAuditType.caption := auditObj.getTypeDescription;
	lblTrackedItem.caption := auditObj.getTrackedItemId;
	if auditObj.getDateTime.isValid then
		lblEditDate.caption := auditObj.getDateTime.date.shortFormatJMT();
	else
		lblEditDate.caption :=  "";
	endif;
	lblEditedBy.caption := auditObj.getUserId;

	lblDetails.caption := auditObj.getDetails;
	lblDetails.width := Details_Width;

	if cleared then
		frDetails.height := lblDetails.height;
	else
		frDetails.height := lblDetails.height + After_Object_Spacing;
	endif;

	app.printer.print(frDetails);

	if cleared then
		lblClearedByCode.caption := auditObj.clearingUserId &amp; app.getErrorString(INV_On) &amp;
									auditObj.clearedDateTime.date.shortFormatJMT();
		lblRemarks.caption := auditObj.clearingRemarks;
		lblRemarks.width := Remarks_Width;
		frQualification.height := lblRemarks.height + After_Object_Spacing;

		app.printer.print(frQualification);
	endif;

end;</source>
        <Parameter name="auditObj" type="CM_Audit"/>
        <Parameter name="cleared" type="Boolean"/>
    </JadeMethod>
</GUIClass>
