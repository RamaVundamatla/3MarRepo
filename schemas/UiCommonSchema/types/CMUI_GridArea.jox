    <JadeMethod name="drawGridArea" id="6c69e4fd-bc33-426a-9044-98ce7b44631b">
        <updating/>
        <source>drawGridArea() updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gridPoint	: CMUI_GridPoint;
	gridFrame	: CMUI_GridAreaFrame;
	
begin
	gridFrame := self.myGridAreaFrame;
	if gridFrame &lt;&gt; null then
		gridFrame.clearGraphics;
		self.drawSpecialBefore();	
		foreach gridPoint in self.allGridPoints do
			gridPoint.drawSelf(gridFrame);
		endforeach;
		self.drawSpecialAfter();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
