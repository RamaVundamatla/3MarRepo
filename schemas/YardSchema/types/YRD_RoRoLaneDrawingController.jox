    <JadeMethod name="userNotification" id="6bf8e008-40d3-456e-bd58-99220406fe80">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
26 May 2008	cnwkpd1	PAR #16814 - Handle invalid objects in notifications

*/

vars
	userInfoStr		: String;
	noteRecord		: CMIF_NotificationRecord;
	invalidObject	: Boolean;
begin
	
	if self.currentlyMinimised then
		if userInfo.isKindOf(Object) then
			//userInfoStr := userInfo.Object.getOidString();
			userInfoStr := self.getOidStringForObject(userInfo.Object);
		else
			userInfoStr := userInfo.String;
		endif;
		
		noteRecord := self.allNotificationsReceived[eventType, theObject, eventTag, userInfoStr];
		if noteRecord = null then
			create noteRecord transient;
			noteRecord.eventType := eventType;
			noteRecord.myObject := theObject;
			noteRecord.eventTag := eventTag;
			noteRecord.userInfoString := userInfoStr;
			allNotificationsReceived.add(noteRecord);
		endif;
		
		return;//processed when minimised state ends
	endif;
	
	on Exception do app.handleDeletedObject(exception, theObject, invalidObject);	// PAR #16814
	
	if userInfo &lt;&gt; null then
		if (eventType = self.noteTALocationCreate 
			or eventType = self.noteTALocationUpdate 
			or eventType = self.noteTALocationDelete) then
			self.userNotificationLocation(eventType,theObject,eventTag,userInfo);

		elseif (eventType = self.noteTAYardAllocationCreate
			or eventType = self.noteTAYardAllocationUpdate
			or eventType = self.noteTAYardAllocationDelete) then
			self.userNotificationYardAllocLines(eventType,theObject,eventTag,userInfo);
		elseif eventType = self.noteTAMove then
			self.userNotificationAreaUpdate(eventType,theObject,eventTag,userInfo);
		else
			inheritMethod(eventType, theObject, eventTag, userInfo);
		endif;
	else
		inheritMethod(eventType, theObject, eventTag, userInfo);
	endif;
epilog
	endLoad;
	self.drawFromNote := false;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userNotificationAreaUpdate" id="9d26477b-ba75-4df1-9c37-4c1d3b410403">
        <updating/>
        <source>userNotificationAreaUpdate(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
26 May 2008	cnwkpd1	PAR #16810 - Replace global.commonResumInvalidObjHandler
10/03/2011	cnwmh5	PAR #27142 - Change where handleDeletedObject is armed
*/

vars
	anLC : CM_LocationsController;
	gotException : Boolean;
begin

	if userInfo.isKindOf(CM_LocationsController) then
		anLC := userInfo.CM_LocationsController;
	endif;
	
	if anLC = null then
		return;
	else
		on Exception do app.handleDeletedObject(exception, anLC, gotException);		// PAR #16810
		anLC := anLC.getGroundLC(REAL_MODE);
	endif;
			
	if eventType = self.noteTAMove or eventType = self.noteTIUpdate then
		// ###########################
		// Check to see if this location controller is on our form
		self.drawFromNote := true;
	
		self.drawObject(self.myDrawingFrame, anLC);
		
		if gotException then
			// Exception handler resumes here if anLC was invalid.
			return;
		endif;
	endif;
epilog
	self.drawFromNote := false;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userNotificationLocation" id="eae4a7b9-6406-4f99-a60a-548590745bb5">
        <updating/>
        <source>userNotificationLocation(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 07/11/2012	cnwcs5	par 30475 - remove location restrictions

vars
	lController	: CM_LocationsController;
	anObject 	: Object;
	aLabRest 	: CM_LabourRestriction;
	aSBS 		: CM_SubBlockStack;
	theLCS 		: CM_LCArray;
	oidStr 		: String;
	lcHolder 	: CMIF_LocationControllersByOid;
begin

	anObject := userInfo.Object;


	if anObject &lt;&gt; null then
		if anObject.isKindOf(CM_TerminalArea)  then
			self.drawSelf(true);
			return;
		elseif eventType = self.noteTALocationDelete then // DELETE
			if anObject.isKindOf(CM_LabourRestriction) or anObject.isKindOf(CM_SubBlockStack) then
				create theLCS transient;
				
				oidStr := self.getOidStringForObject(anObject);
				
				lcHolder := self.allOIDSbyOIDString[oidStr];
				
				if lcHolder &lt;&gt; null then
					lcHolder.allLocationControllers.copy(theLCS);
					self.allOIDSbyOIDString.remove(lcHolder);
					delete lcHolder;
				endif;
			elseif anObject.isKindOf(CM_TerminalSubArea) then 
				return; // ignore as not drawn by this controller. the event is fired on delete for this for the location maint screen. 
			endif;
		else // CREATE or UPDATE
			create theLCS transient;
			
			if anObject.isKindOf(CM_LabourRestriction) then
				aLabRest := anObject.CM_LabourRestriction;
				aLabRest.allLocationControllers.copy(theLCS);
			
			elseif anObject.isKindOf(CM_SubBlockStack) then
				aSBS := anObject.CM_SubBlockStack;
				aSBS.allByPassedControllers.copy(theLCS);
			endif;
			
			if eventType = self.noteTALocationUpdate then // UPDATE
				if anObject.isKindOf(CM_LabourRestriction) or anObject.isKindOf(CM_SubBlockStack) then
					oidStr := self.getOidStringForObject(anObject);
					// check this collection incase of a resize
					lcHolder := self.allOIDSbyOIDString[oidStr];
					if lcHolder &lt;&gt; null then
						lcHolder.allLocationControllers.clear();
						theLCS.copy(lcHolder.allLocationControllers);
					endif;
					
				endif;
			endif;
		endif;
	else
		return;
	endif;

	self.drawFromNote := true;
	foreach lController in theLCS do
		self.drawObject(self.myDrawingFrame, lController);
	endforeach;
epilog
	self.drawFromNote := false;
	delete theLCS;
end;</source>
