    <PrimAttribute name="dateOfNote" id="9cfa1235-fd49-4b6a-969f-f625e353f561">
        <embedded/>
        <type name="Date"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myHarbour" id="83e734a2-e116-4512-b836-ed647b7ec745">
        <kind>child</kind>
