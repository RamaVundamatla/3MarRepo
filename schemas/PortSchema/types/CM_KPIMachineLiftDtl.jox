    <JadeMethod name="createKPIMoveDtl" id="3a1a7719-82cf-4ef3-aba3-d1d4522e452d">
        <source>createKPIMoveDtl(_history :CM_MachineMoveHistory):CM_KPIMachineMoveDtl protected;
// ---------------------------------------------------------------------------
// Created:     04 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	kpiMove		:CM_KPIMachineMoveDtl;
	historyType	:Integer;
begin
	if self.isTransient then
		create kpiMove transient;
	else
		create kpiMove persistent;
	endif;
	
	historyType := _history.type;
	
	if historyType = CM_MachineHistory.Type_Move then
		kpiMove.setForMove (_history, null);
	elseif historyType = CM_MachineHistory.Type_SetDown then
		kpiMove.setForSetDown (_history, null);
	endif;
	
	return kpiMove;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_history" type="CM_MachineMoveHistory"/>
        <ReturnType type="CM_KPIMachineMoveDtl"/>
    </JadeMethod>
    <JadeMethod name="getLiftAcceptTimeLocalTZ" id="e935cea5-13ae-4ed2-962c-97120765946f">
        <source>getLiftAcceptTimeLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2016	cnwns1	Initial creation
// 02 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.acceptTS);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getMyMachine" id="790c99db-ad44-431e-95d5-48e200479eb4">
