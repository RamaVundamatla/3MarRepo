    <JadeMethod name="zAutomationQuery" id="d9f061e6-6d1a-4678-97d6-3689b8cc69ff">
        <updating/>
        <source>zAutomationQuery(_dataKey, _tableName, _rowName : String; _result : String output) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/03/2020	jlgdap1		Initial creation TFS 48992 MTN Automation Testing - Table Navigation
//
vars
	idx : Integer;
	ctrl : Control;
	table : CM_BaseTable;
	row, column, dataRow : Integer;

begin
	// we've got a table name, find the table
	foreach idx in 1 to self.controlCount do
		ctrl := self.controls(idx);
		//write ctrl.name;
		if ctrl.isKindOf(CM_BaseTable) and ctrl.name = _tableName then
			table := ctrl.CM_BaseTable;
			break;
		endif;
	endforeach;
	if table = null then
		_result := "No table " &amp; _tableName &amp; " found!";
		return;
	endif;
	
	// search for data key to get the row it's in
	foreach row in table.fixedRows + 1 to table.rows do : rowLoop
		foreach column in table.fixedColumns + 1 to table.columns do
			if table.accessCell(row, column).text = _dataKey then
				dataRow := row;
				break rowLoop;
			endif;
		endforeach;
	endforeach;
	if dataRow = null then
		_result := "No match on data key " &amp; _dataKey &amp; " found!";
		return;
	endif;
	
	// now search for the row name in the fixed row to get the column we want
	if table.isKindOf(CM_DataTable) then
		column := table.CM_DataTable.allTblDataColPropertyNames.indexOf(_rowName);
		if column = null then
			_result := "No match on row name " &amp; _rowName &amp; " found!";
			return;
		endif;
		_result := table.accessCell(dataRow, column).text;
		return;
	else
		foreach column in table.fixedColumns + 1 to table.columns do
			if table.accessCell(1, column).text = _rowName then
				_result := table.accessCell(dataRow, column).text;
				return;
			endif;
		endforeach;
	endif;
	_result := "No match on row name " &amp; _rowName &amp; " found!";
	
epilog

end;</source>
        <Parameter name="_dataKey" type="String"/>
        <Parameter name="_tableName" type="String"/>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_result" type="String" usage="output"/>
    </JadeMethod>
