    <JadeMethod name="getLeftVisibleItems" id="a46844bf-e2dd-4248-ae66-509627c21806">
        <source>getLeftVisibleItems(_targetColl : Collection);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.

*/

vars
	listIndex,
	listSize	: Integer;
	itemObj		: Object;
	targetColl	: Collection;
	
begin	
	targetColl	:=	_targetColl;
	listSize := self.myAvailableListBox.listCount();
	
	foreach listIndex in 1 to listSize do
		itemObj	:=	self.myAvailableListBox.itemObject[listIndex];
		if global.isValidObject(itemObj) then
			targetColl.tryAdd(itemObj);
		endif;
	endforeach;
	
epilog
	
end;</source>
