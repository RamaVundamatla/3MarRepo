        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getShiftTimestamps" id="5652cb6d-e72a-4648-92d9-edfc856ef0b4">
        <source>getShiftTimestamps(workShifts : TimeStampArray input) ;
// ---------------------------------------------------------------------------
// Created:		03 April 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars	
	tsTmp, tsFrom, tsTo, tsStrFrom, tsStrTo : TimeStamp;
	trans : CM_TITransactionByDateDict;
	posNeg, numOfDays, idx : Integer;
	dates : DateArray;
	aDate : Date;
	shift1, shift2, shift3 : Time;
	_shifts : IntegerArray;
begin
	if _shifts.isEmpty then
		shift1.setTime(7,0,0,0);
		shift2.setTime(15,0,0,0);
		shift3.setTime(23,0,0,0);
	else
		shift1.setTime(_shifts[1].Integer,0,0,0);
		if _shifts.size &gt;= 2 then
			shift2.setTime(_shifts[2].Integer,0,0,0);
		else
			shift2.setTime(15,0,0,0);
			shift3.setTime(23,0,0,0);
		endif;
		
		if _shifts.size = 3 then
			shift3.setTime(_shifts[3].Integer,0,0,0);
		else
			shift3.setTime(23,0,0,0);
		endif;
	endif;
	workShifts.clear;

	create trans transient;
	create dates transient;
	// ### for this jobsheet get all the loads and discharges from the transactions.
	trans.clear;
//	self.allShipReceivals.copy(trans);
//	self.allShipReleases.copy(trans);
	if trans.isEmpty then
		return;
	endif;

	
	// ### get the date range and store away each date that the work covers.
	tsFrom := trans.first.dateTime;
	tsTo := trans.last.dateTime;
	aDate := tsTo.date + 1;
	tsTo.setDate(aDate);
	tsFrom.differenceAsTime(tsTo,posNeg, numOfDays);
	numOfDays := numOfDays + 1;
	aDate := tsFrom.date - 1;
	
	
	foreach idx in 1 to numOfDays do
		dates.add(aDate);
		aDate := aDate + 1;
	endforeach;
	// ### build up an array of shifts over the days
	foreach aDate in dates do
		tsTmp.setDate(aDate);
		// SHIFT 1
		tsTmp.setTime(shift1);
		if not workShifts.includes(tsTmp) then
			workShifts.add(tsTmp);
		endif;
		// SHIFT 2
		tsTmp.setTime(shift2);
		if not workShifts.includes(tsTmp) then
			workShifts.add(tsTmp);
		endif;
		// SHIFT 3
		tsTmp.setTime(shift3);
		if not workShifts.includes(tsTmp) then
			workShifts.add(tsTmp);
		endif;

	endforeach;

epilog
	delete trans;
	delete dates;
end;</source>
        <Parameter name="workShifts" type="TimeStampArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getShiftsFromRange" id="a827aba0-4a8d-41b2-bde4-607d267958ce">
        <source>getShiftsFromRange(_shiftDict : CM_ShiftStartDateCodeDict input);
// ---------------------------------------------------------------------------
// Created:		22 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		Populate the passed in collection with a collection of transient
//				shifts for the receiver voyage
//
// ---------------------------------------------------------------------------
vars
	delay		: CM_Delay;			//cnwmc5 - 9 June 2016 - TFS 2114
	aJS			: CM_VoyageJobSheet;
	fromTS, toTS: TimeStamp;
	fromTS_theor: TimeStamp;
	aTran		: CM_TITransaction;
	tmpDate		: Date;
	tmpTime		: Time;
	
begin
	if _shiftDict = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Shift Dict passed in. Contact Developer.');
		
		return;
	endif;
	if self.myTerminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Voyage " &amp; self.String &amp; " has no Terminal. Contact Developer.');
		return;
	endif;
	tmpTime.setTime(23,59,59,0);
	tmpDate.setDate(31,12,3000);
	fromTS.setTime(tmpTime);
	fromTS.setDate(tmpDate);
	
	fromTS_theor := fromTS;
	
	tmpTime.setTime(0,0,0,0);
	tmpDate.setDate(01,01,2000);
	toTS.setTime(tmpTime);
	toTS.setDate(tmpDate);
	
	if self.allJobSheets.isEmpty then

		if self.arrivedDT.isValid then
			fromTS := self.arrivedDT;
		else
			fromTS := null;
		endif;
		if self.departedDT.isValid then
			toTS := self.departedDT;
		else
			toTS := app.actualTimeServer;
		endif;
		
	else
		
		foreach aJS in self.allJobSheets discreteLock do
		
			// FIRST TRANSACTIONS
			aTran := aJS.allShipReceivals.first;
			
			if aTran &lt;&gt; null then
				if aTran.dateTime &lt; fromTS then
					fromTS := aTran.dateTime;
				endif;
				
				if aTran.dateTime &gt; toTS then
					toTS := aTran.dateTime;
				endif;
			endif;
			aTran := aJS.allShipReleases.first;
			if aTran &lt;&gt; null then
				if aTran.dateTime &lt; fromTS then
					fromTS := aTran.dateTime;
				endif;
				
				if aTran.dateTime &gt; toTS then
					toTS := aTran.dateTime;
				endif;
			endif;
			
			// LAST TRANSACTIONS
			aTran := aJS.allShipReceivals.last;
			
			if aTran &lt;&gt; null then
				if aTran.dateTime &lt; fromTS then
					fromTS := aTran.dateTime;
				endif;
				
				if aTran.dateTime &gt; toTS then
					toTS := aTran.dateTime;
				endif;
			endif;
			aTran := aJS.allShipReleases.last;
			if aTran &lt;&gt; null then
				if aTran.dateTime &lt; fromTS then
					fromTS := aTran.dateTime;
				endif;
				
				if aTran.dateTime &gt; toTS then
					toTS := aTran.dateTime;
				endif;
			endif;
		endforeach;
		
		//cnwmc5 - 9 June 2016 - TFS 2114
		//Need to check if any delays are outside of the job sheet ranges, they also need shifts to display correctly/..
		foreach delay in self.allDelays do
			if delay.startDT &lt; fromTS then
				fromTS := delay.startDT;
			endif;
			if delay.endDT &gt; toTS then
				toTS := delay.endDT;
			endif;
		endforeach;
		
	endif;

	if (fromTS = null) or (fromTS = fromTS_theor) then
		// assume that ship has not arrived so have no idea what shifts to use
		// fromTS = fromTS_theor, when allShipReceivals and allShipRelesases were null
		return;
	endif;
	
	self.myTerminal.getShiftsFromRange(_shiftDict, fromTS, toTS);
end;</source>
        <Parameter name="_shiftDict" type="CM_ShiftStartDateCodeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getShiftsFromRangeForJobSheet" id="0a478d09-9e23-4dc7-a7da-2f354e949a3a">
        <source>getShiftsFromRangeForJobSheet(_shift : CM_ShiftStartDateCodeDict input; _jobSheet : CM_VoyageJobSheet);

/*

Purpose:			Get all the persistent shifts applicable for the passed in job sheet.
					Will create any standard ones that are not already persisted.

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2010	cnwrd1	Initial creation
//cnwrd1 par 22533 6.5.2010 
22 Jun 2010	cnwkpd1	PAR #24609 - Fix performance in Voyage KPI processing

*/

vars
	aJS				: CM_VoyageJobSheet;
	fromTS, toTS	: TimeStamp;
	fromTS_theor	: TimeStamp;
	aTran			: CM_TITransaction;
	tmpDate			: Date;
	tmpTime			: Time;
	pxyShift,
	shift			: CM_Shift;
	realShift 		: CM_ShiftEntity;
	realShifts,
	tmpShifts 		: CM_ShiftStartDateCodeDict;
	
begin
	if _shift = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Shift Dict passed in. Contact Developer.');
		
		return;
	endif;
	if self.myTerminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Voyage " &amp; self.String &amp; " has no Terminal. Contact Developer.');
		return;
	endif;
	tmpTime.setTime(23,59,59,0);
	tmpDate.setDate(31,12,3000);
	fromTS.setTime(tmpTime);
	fromTS.setDate(tmpDate);
	
	fromTS_theor := fromTS;
	
	tmpTime.setTime(0,0,0,0);
	tmpDate.setDate(01,01,2000);
	toTS.setTime(tmpTime);
	toTS.setDate(tmpDate);
	
	if _jobSheet = null then

		if self.arrivedDT.isValid then
			fromTS := self.arrivedDT;
		else
			fromTS := null;
		endif;
		if self.departedDT.isValid then
			toTS := self.departedDT;
		else
			toTS := app.actualTimeServer;
		endif;
		
	else
		aJS := _jobSheet;
		// FIRST TRANSACTIONS
		aTran := aJS.allShipReceivals.first;
		
		if aTran &lt;&gt; null then
			if aTran.dateTime &lt; fromTS then
				fromTS := aTran.dateTime;
			endif;
			
			if aTran.dateTime &gt; toTS then
				toTS := aTran.dateTime;
			endif;
		endif;
		aTran := aJS.allShipReleases.first;
		if aTran &lt;&gt; null then
			if aTran.dateTime &lt; fromTS then
				fromTS := aTran.dateTime;
			endif;
			
			if aTran.dateTime &gt; toTS then
				toTS := aTran.dateTime;
			endif;
		endif;
		
		// LAST TRANSACTIONS
		aTran := aJS.allShipReceivals.last;
		
		if aTran &lt;&gt; null then
			if aTran.dateTime &lt; fromTS then
				fromTS := aTran.dateTime;
			endif;
			
			if aTran.dateTime &gt; toTS then
				toTS := aTran.dateTime;
			endif;
		endif;
		aTran := aJS.allShipReleases.last;
		if aTran &lt;&gt; null then
			if aTran.dateTime &lt; fromTS then
				fromTS := aTran.dateTime;
			endif;
			
			if aTran.dateTime &gt; toTS then
				toTS := aTran.dateTime;
			endif;
		endif;
	endif;

	if (fromTS = null) or (fromTS = fromTS_theor) then
		// assume that ship has not arrived so have no idea what shifts to use
		// fromTS = fromTS_theor, when allShipReceivals and allShipRelesases were null
		return;
	endif;
	
	// Get all the transient shifts for the date range
	create tmpShifts transient;
	self.myTerminal.getShiftsFromRange(tmpShifts, fromTS, toTS);
	
	// And get all the real shifts to compare it to
	create realShifts transient;
	self.myTerminal.getShiftsFromRangeReal(realShifts, fromTS, toTS);
	
	// CCMS 1134 - Now persist any of the shifts that do not already exist
	foreach pxyShift in tmpShifts do
		// Skip any "Ignored" standard shifts
		if not pxyShift.ignore then
			
			if not realShifts.includesKey(pxyShift.startDateTime, pxyShift.code) then
				app.myUtilityCA.utlCreateShiftStd(pxyShift, app.myPassport, realShift);
			endif;
		
		endif;
	endforeach;
	
	// Now get the collection of real shifts again (there may be some new ones
	realShifts.clear();
	self.myTerminal.getShiftsFromRangeReal(realShifts, fromTS, toTS);
	
	// And finally copy the non-ignored ones to the return collection
	_shift.clear;
	foreach shift in realShifts where not shift.ignore do
		_shift.add(shift);
	endforeach;


epilog
	if tmpShifts &lt;&gt; null then
		tmpShifts.purge;
		delete tmpShifts;
	endif;
	delete realShifts;

end;</source>
        <Parameter name="_shift" type="CM_ShiftStartDateCodeDict" usage="input"/>
        <Parameter name="_jobSheet" type="CM_VoyageJobSheet"/>
    </JadeMethod>
