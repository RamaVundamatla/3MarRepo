    <JadeMethod name="countryCode" id="08893703-8e82-45b0-8f47-11acd6ddd7a8">
        <methodInvocation>mapping</methodInvocation>
        <source>countryCode(set: Boolean; _value: String io) mapping;
// -------------------------------------------
// Created 05 April 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	if set then
		// set code here
	else
		if self.myPort.myCountry &lt;&gt; null then
			_value := self.myPort.myCountry.code;
			return;
		endif;
		_value := null;
		// get code here
	endif;



end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doProcessing" id="a7ed2926-0b2d-4a86-bb76-8212307c085c">
        <updating/>
        <source>doProcessing(_root : CM_Root) updating;

// Created by cnwdvb1 on 06 April 2006

vars

	port : CM_Port;

begin

	if global.isValidObject(self.myPort) then
		// Par17405. There is validation for CM_Port to avoid this duplicate key in future
		port := app.myRoot.allPorts[self.fileCountryCode &amp; self.filePortCode];
		if port &lt;&gt; null and port.code &lt;&gt; self.myPort.code then
			app.raiseCMException2(ERR_PortDuplicateLoadCSV, self.myPort.code, port.code, null, null);
		endif;
		
		self.exclusiveLock(self.myPort);
		self.myPort.updateFromImport(self,_root);
		return;
	endif;
	
	create port persistent;
	
	port.updateFromImport(self, _root);
	
	
	
	
end;</source>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="getName" id="2815a45a-69a3-4ead-b2ec-7481a679082b">
        <source>getName(): String;

// Created by cnwdvb1 on 06 April 2006

vars

begin
	return inheritMethod() &amp; ' ' &amp; self.portCode &amp; ' ' &amp; self.countryCode &amp; ' ' &amp; self.filePortCode &amp; ' ' &amp; self.fileCountryCode;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="c3755262-ec53-4486-aac1-65d9380e337a">
        <updating/>
        <source>initialise(_port : CM_Port) updating;
// -------------------------------------------
// Created 05 April 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	self.myPort 	:= _port;
	self.isActive	:= true;

end;</source>
        <Parameter name="_port" type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="portCode" id="f46e861f-0b6b-4097-855a-f880b9af0a5e">
        <methodInvocation>mapping</methodInvocation>
        <source>portCode(set: Boolean; _value: String io) mapping;
// -------------------------------------------
// Created 05 April 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	if set then
		// set code here
	else
		// Want to compare the three letter code against file.
		if self.myPort.portCode &lt;&gt; null then
			_value := self.myPort.portCode;
		else
			// For upgrade need existing port code.
			_value := self.myPort.code;
		endif;
		
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
