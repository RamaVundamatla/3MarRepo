    <JadeMethod name="moveToShip" id="aba29d41-3117-4c81-aebf-3e4433089912">
        <updating/>
        <source>moveToShip(_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     04 January 2006	cnwhjg1
//
// Purpose:     This places the Docket and TI's physically onto the ship. 
//				ship 'prenotes' are real TIs that get placed aboard when created
// ----------   ----------  --------------------------------------------------
// 20/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 30 Jun 2025  navma1 		MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev
vars
	toTgtStr			: String;
	createTrans,
	isOperational   	: Boolean;
	voy 				: CM_Voyage;
	locn 				: CM_LocationsController; 
	foundHeight 		: Integer;
	cmifPreNote			: CMIF_PreNote;
	ti 					: CM_TrackedItem;
	isVoyHOLDSorSHIP	: Boolean;
	portDestCode		: String;
begin
	
	if self.myUserObject = null or not self.myUserObject.isKindOf(CMIF_PreNote) then 
		return;
	else 
		cmifPreNote	:= self.myUserObject.CMIF_PreNote;
	endif;
	
	exclusiveLock(self.myPersistentBOL);
	toTgtStr := cmifPreNote.voyageCode.trimBlanks &amp; " " &amp; cmifPreNote.stowageLocation.trimBlanks;
	self.myTerminal.findLocationFromString(toTgtStr, false, locn, foundHeight);
	if locn = null then 
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_INVALID_LOCN, toTgtStr, null, null);
		return;
	endif;
	voy := self.myTerminal.lookupVoyage(cmifPreNote.voyageCode.trimBlanks, null, false);
	if voy = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_INVALID_VOYAGE, cmifPreNote.voyageCode, null, null);
		return;
	endif;
	//-------------------
	//We only create transactions if a non-worked voyage (This means the Box is actually there!)
	//If its a non-worked voyage then they are putting the box on, and want export stats
	//-------------------
	isVoyHOLDSorSHIP	:= voy.isHOLDSorSHIP();			//30.06.2025 navma1 #MTN-34090
	createTrans 		:= isVoyHOLDSorSHIP;		    //30.06.2025 navma1 #MTN-34090
	
	if createTrans then
	   
		//overwrite depending on what the users are doing. This is passed in from the UI.
		//Basically we need to know if we build transactions (the box was released), or its being
		//simply placed so it can be discharged by the ops process.
		if cmifPreNote.nonWorkedReleaseType = TransactionedMoveType then

			foreach ti in self.myPersistentBOL.allTrackedItems discreteLock do 
				//Set the box as an export.
				isOperational := createTrans;	//We WANT an operational move if its a non-worked voyage
				if not ti.isTranshipItem then					// PAR #23645 CCMS 1116
					ti.setImExStatus(TI_IMEX_STATUS_EXPORT);
				endif;											// PAR #23645 CCMS 1116
			endforeach;
		else
			createTrans   := false;
			isOperational := false;
			//Leave as a transit.
		endif;
	endif;	

	//PAR 1345 AA 29/8/01: Set items for discharge here to be imports. This is because these
	//types of voyage do not have a colour code that resets the status to import, and discharge of
	//transits does not generate the correct charges
	// PAR 33644	if (voy.isNonPlannedVoyage or voy.isNonWorkedVoyage) and
	// PAR 33644	   not isPlannedRORO then	// PAR 21745 CCMS MES 1031 - We treat RORO/Planned voyages as Planned
	if isVoyHOLDSorSHIP then													//30.06.2025 navma1 #MTN-34090	
		portDestCode := self.myTerminal.getConfig(PortDestCode).String;			//30.06.2025 navma1 #MTN-34090
		foreach ti in self.myPersistentBOL.allTrackedItems discreteLock do 		
			if ti.dischargePort = portDestCode  and not ti.isTranshipItem then	// PAR #23645 CCMS 1116
				ti.setImExStatus(TI_IMEX_STATUS_IMPORT);
			endif;
		endforeach;
	endif;	
	
	//---------------------
	//Do the actual move
	//---------------------
	foreach ti in self.myPersistentBOL.allTrackedItems discreteLock do 		
		if ti.isOnShip then //PAR 15206
			continue;//PAR 15206
		endif;
		ti.moveToLocation(locn, null, null, null, REAL_MODE, true, isOperational, false, false, false, false, null, null, null, null, null, _passport);	// TFS 2651
	endforeach;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="stripCarriageReturns" id="07f8ab66-e28a-4bcc-af97-52fa1eeb4cd7">
        <updating/>
        <source>stripCarriageReturns(	_attrName 	: String ;
						_strValue 	: String ) : Boolean updating;
/*

Date		Who		Reason
01 November 2016	cnwer1	Initial creation TFS 2889
// 16 Jan 2016	cnwrs1	TFS 3222 fields without Cr were not being updated
*/

vars
	pos  : Integer;
begin
	if _strValue = null then
		return false;
	endif;
	
	if _attrName = ETRow_LoggingContractor  then
		self.handlingContractor1 := _strValue.removeTabCrLfs().trimBlanks();
		return true;		
	elseif _attrName = ETRow_LoadingContractor then
		self.handlingContractor2 :=  _strValue.removeTabCrLfs().trimBlanks();
		return true;	
	elseif _attrName = ETRow_LoggingGang  then

		self.gangNumber :=  _strValue.removeTabCrLfs().trimBlanks();
		return true;
		
	elseif _attrName = ETRow_Customer  then

		self.customer := _strValue.removeTabCrLfs().trimBlanks();
		return true;
		
	elseif _attrName = ETRow_LoaderNumber  then
	
		self.loaderNumber := _strValue.removeTabCrLfs().trimBlanks();
		return true;
	elseif _attrName = ETRow_TruckNumber  then

		self.truckNumber :=  _strValue.removeTabCrLfs().trimBlanks();
		return true;	
	elseif _attrName = ETRow_TrailerNumber  then
	//epr TFS 2889 1/11/16
		self.trailerNumber := _strValue.removeTabCrLfs().trimBlanks();
		return true;	
	endif;	
	
	return false;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_strValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="032ad77d-3c5b-4f7e-99cd-4a6d11a03cf2">
        <updating/>
        <source>validateForCreate(_passport: CM_Passport input): Boolean updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 20 February 2009
//
// Implemented version:
// Implemented version: 7.7.1
// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
//28/06/2022 navds20 TFS 53760 MTN - DuplicateItem not Translatable
//----------------------------------------------------------------------
begin
	inheritMethod(_passport);
	
	if self.myVoyage &lt;&gt; null then
		if self.myVoyage.doesBOLAlreadyExist(self.bolNumber) &lt;&gt; null then
			//app.raiseCMException2(DuplicateItem, app.getErrorString(BillOfLading) &amp; " (" &amp; self.bolNumber&amp; ")", app.getErrorString(VoyageText) &amp; "(" &amp; self.myVoyage.code &amp; ")", null, null); //28/06/2022 navds20 TFS 53760
			//Bill of Lading %1 already exists for Voyage %2 : Bill_lading_alread_exists_voya
			app.raiseCMException2(Bill_lading_alread_exists_voya,  self.bolNumber, self.myVoyage.code , null, null); //28/06/2022 navds20 TFS 53760
		endif;
	endif;
	
// cnwdad1 08/05/2009 - CCNS 1735.
	if app.isSubTerminalsOn(self.myTerminal) then
		if self.mySubTerminal = null then
		//	app.raiseCMException1(REQUIRED_FIELD, app.getString(SubTerminal_GC), ETRow_MySubTerminal, null);
			app.raiseCMException1(Input_required_field_Required, app.getString(SubTerminal_GC), ETRow_MySubTerminal, null);// cnwdb2	PAR 35364
		endif;
	endif;
	if self.allDocketErrors &lt;&gt; null and not self.allDocketErrors.isEmpty() then
		self.allDocketErrors.first().validateForCreate();
	endif;
epilog
	return _passport.noErrors();
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreateCusCar" id="a28a800d-2d94-43ce-97e8-937ba1468db4">
        <updating/>
        <source>validateForCreateCusCar(_passport : CM_Passport input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     Feb 2006 cmsrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tiUpdCntrl		: CMIF_TIUpdateController;
	subItemError	: Boolean;
	
begin
	self.myBOLType := app.myRoot.allBOLTypes[self.bolType];
	if self.myBOLType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Docket/Bill of Lading Type', 'bolType', self.myUserObject);
		app.raiseCMException(Input_required_field_dockBill, 'bolType', self.myUserObject); // cnwdb2	PAR 35364
		return _passport.noErrors();
	endif;
	
	if self.myProxyBOL &lt;&gt; null then
		self.myProxyBOL.erase(NORMAL_ERASE);
		self.myProxyBOL := null;
	endif;

	//create the proxy from scratch
	self.myProxyBOL := self.myTerminal.createBOL(self.getBOLClass, true);		
	self.myProxyBOL.setPxyFromCMIF_BOL(self, _passport);
	
	self.myProxyBOL.validateForCreateCusCar(self.headerOnly, _passport);

epilog
	if tiUpdCntrl &lt;&gt; null then
		delete tiUpdCntrl;
	endif;
	return _passport.noErrors();
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreateSubClasses" id="40b018c9-9c46-438e-9a0e-d4fac51700c1">
        <updating/>
        <source>validateForCreateSubClasses(_passport : CM_Passport input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tiUpdCntrl		: CMIF_TIUpdateController;
	
begin

/*
	if self.myIntFaceInOutCommon &lt;&gt; null then
		self.myProxyBOL.setProxyReceivalDocketCommon(self.myIntFaceInOutCommon, self);
	endif;
*/
	self.validateSubItems(_passport);
	
	tiUpdCntrl := app.createTIUpdateControl(TI_UPDMODE_RECEIPT, _passport.userCode, self.myUserObject);
	self.myProxyBOL.validateForCreate(tiUpdCntrl, self.headerOnly, _passport);

epilog
	if tiUpdCntrl &lt;&gt; null then
		delete tiUpdCntrl;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="255248fb-2587-4302-bcce-0c935cf4372c">
        <updating/>
        <source>validateForUpdate(_passport: CM_Passport input): Boolean updating;
//----------------------------------------------------------------
//	Created:	11 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	updCntrl	: CMIF_TIUpdateController;
	
begin
	inheritMethod(_passport);

	if self.myProxyBOL = null and
	   self.myPersistentBOL = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'proxy BOL / persistent BOL', null, self.myUserObject);
		app.raiseCMException(Input_required_field_proxBol, null, self.myUserObject); // cnwdb2	PAR 35364
		return _passport.noErrors();
	endif;
	
// cnwdad1 08/05/2009 - CCNS 1735.
	if app.isSubTerminalsOn(self.myTerminal) then
		if self.mySubTerminal = null
		and not self.myTerminal.getConfig(IsSubTerminalAreaDefined).Boolean	//28 Nov 2014	NDL	Par 35295
		then
		//	app.raiseCMException1(REQUIRED_FIELD, app.getString(SubTerminal_GC), ETRow_MySubTerminal, null);
			app.raiseCMException1(Input_required_field_Required, app.getString(SubTerminal_GC), ETRow_MySubTerminal, null); // cnwdb2	PAR 35364
		endif;
	endif;
	
	if self.myProxyBOL = null then
		app.createUpdateProxy(self.myPersistentBOL);
	endif;
	
	//check for a change of cargo type here
	if self.bolType &lt;&gt; self.myProxyBOL.bolType then
		//currently unable to change this - leave it for now
		app.writeStatement(class.name &amp; " " &amp; method.name &amp; " " &amp; "BOL TYPE CHANGED");
		//delete and recreate as new type
		app.writeStatement(class.name &amp; " " &amp; method.name &amp; " " &amp; "");
	endif;
	
	self.myProxyBOL.setPxyFromCMIF_BOL(self, _passport);

	updCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, null, null);
	self.validateSubItemsForUpdate(updCntrl, _passport);
	self.myProxyBOL.validateForUpdate(updCntrl, false, _passport);

	return _passport.noErrors();
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateSubItemsForUpdate" id="ac442626-4b09-4108-b136-d08826de6824">
        <source>validateSubItemsForUpdate(_control	: CMIF_TIUpdateController input; _passport: CM_Passport input) protected;
//----------------------------------------------------------------
//	Created:	07 April 2006	by Jason Chapman  (cnwjc2)
//
//	Copied from ?
//----------------------------------------------------------------
vars
	idx,
	numAttached	: Integer;
	origTIs		: CM_TIArray;
	subItem		: CMIF_TIObject;
	matchFound	: Boolean;
	realTI,
	originalTI,
	pxyTI,
	child		: CM_TrackedItem;
	attach		: CMIF_InOutAttachment;

begin
	create origTIs transient;

//	proxy has refs to reals not pxys
	self.myProxyBOL.allTrackedItems.copy(origTIs);

	// Check if Attachment sub-items have a proxy.  If not then try and match
	// to an existing child on self.myProxyTrackedItem
	foreach subItem in self.allSubItems do
		if (not subItem.isKindOf(CMIF_InOutAttachment)) then
			continue;
		endif;
		attach := subItem.CMIF_InOutAttachment;
		
		//add as we go - they get removed if no longer needed
		//if attach.myProxyTrackedItem &lt;&gt; null then
		//	origTIs.add(attach.myProxyTrackedItem);
		//endif;
		
		// Check to see if the attachment already has a proxy and that the
		// user has not changed the Id and/or type.
		if attach.myProxyTrackedItem &lt;&gt; null then
			if attach.myProxyTrackedItem.id = attach.id
		  	and attach.myProxyTrackedItem.cargoType = attach.cargoType then
		   		originalTI := null;
		   		realTI := attach.myProxyTrackedItem.pxyGetRealObject();
		   		//originalTI := origTIs[attach.myProxyTrackedItem.id];
				foreach originalTI in origTIs do : findMatch
		   			if originalTI = realTI then
			   			break findMatch;
					endif;
				endforeach;
				if originalTI &lt;&gt; null then
				   origTIs.remove(originalTI);
				else
					//detach/delete proxy??
					app.writeStatement(class.name &amp; " " &amp; method.name &amp; " " &amp; "cant find orginal with same id as proxy");
				endif;
		   		continue;
			else
				//
				app.writeStatement(class.name &amp; " " &amp; method.name &amp; " " &amp; "IDs don't match");
			endif;
		else
			app.writeStatement(class.name &amp; " " &amp; method.name &amp; " " &amp; "subitem proxy is null");
		endif;
		
		// Search through proxy children to see if have one with the same id/type
		matchFound := false;
		numAttached := origTIs.size;
		foreach originalTI in origTIs do
			if originalTI.id = attach.id and
			   originalTI.cargoType = attach.cargoType then
			   	// A match has been found
			   	matchFound := true;
			   	if attach.myProxyTrackedItem &lt;&gt; null then
			   		// found a match but for a different proxy so treat as a delete
			   		if (not self.myProxyBOL.allTrackedItems.includes(attach.myProxyTrackedItem)) then
			   			// attachment proxy is not in the list here to be erased so
			   			// delete here.
			   			attach.myProxyTrackedItem.erase(NORMAL_ERASE);
			   		endif;
			   	endif;
			   	// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
			   	// Attach this child to the attachment
			   	//attach.setMyProxyTrackedItem(originalTI);	//not sure how to handle let error for now
			   	//origTIs.remove(originalTI);
			   	break;
			endif;
			
			if (not matchFound) and
		   	   attach.myProxyTrackedItem &lt;&gt; null then
			  	// User has updated id or type so delete proxy
		   		if (not self.myProxyBOL.allTrackedItems.includes(attach.myProxyTrackedItem)) then
		   			// attachment proxy is not in the list here to be erased so
		   			// delete here.
		   			attach.myProxyTrackedItem.erase(NORMAL_ERASE);
			   	endif;
			   	attach.setMyProxyTrackedItem(null);
			endif;
		endforeach;
	endforeach;
	
	// delete any remaining proxies in origTIs
	while origTIs.size &gt; 0 do
		child := origTIs.last;
		self.myProxyBOL.detachTI(child);
		origTIs.remove(child);
		self.myProxyBOL.allTrackedItems.remove(child);
		child.erase(NORMAL_ERASE);
	endwhile;

	//Finally validate the sub-items
	//there should be no old ti proxies only ones to update - cmifs without a proxy will have one created in validate for update
	foreach subItem in self.allSubItems do
		subItem.validateForUpdate(_passport);
		attach := subItem.CMIF_InOutAttachment;
		if attach.myProxyTrackedItem &lt;&gt; null
		and not attach.myProxyTrackedItem.isValid then
			attach.myProxyTrackedItem.validateTrackedItem(_control, _passport);
		endif;
	endforeach;
		
epilog
	delete origTIs;

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
