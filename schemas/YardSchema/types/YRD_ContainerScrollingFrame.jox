    <JadeMethod name="getDrawingFrame" id="c64781b0-55b5-4b09-ba51-8f1b14360503">
        <source>getDrawingFrame() : Frame;
// ---------------------------------------------------------------------------
// Created:		04 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	return self.myDockBar.myDrawingFrame;
end;</source>
        <ReturnType type="Frame"/>
    </JadeMethod>
    <JadeMethod name="handleContextMenuEvent" id="b37649f8-cd71-437c-9ad6-d06d26735b23">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>handleContextMenuEvent(frame: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return self.myDockBar.myDrawingFrame.contextMenu(frame, conwin, mouse, x, y);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleLabelFrameDblClick" id="27f97c54-62d9-4787-a6b2-13039bc8a4da">
        <updating/>
        <source>handleLabelFrameDblClick(frame: CMUI_ScrollableLabelsFrame input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	ydc : YRD_ContainerDrawingController;
begin
	inheritMethod(frame);

	if self.myDockBar.isForGCRacks then
		return;
	endif;

	if  self.myDockBar.isForOverview 
	or self.myDockBar.isForRoRoLanes then // cnwjk3 CCMS 1018 15/01/10
		return;
	endif;

	ydc := self.myDockBar.myDrawingController;
	ydc.handleLabelFrameDblClick(frame);
end;</source>
        <Parameter name="frame" type="CMUI_ScrollableLabelsFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleLabelFrameDragOver" id="684de1ff-ba7a-4d85-acf1-54ed5be5d2e1">
        <updating/>
        <source>handleLabelFrameDragOver(frame: CMUI_ScrollableLabelsFrame input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	ydc : YRD_ContainerDrawingController;
begin
	inheritMethod(frame, win, x, y, state);

	if self.myDockBar.isForGCRacks then
		return;
	endif;
	if  self.myDockBar.isForRoRoLanes then // cnwjk3 CCMS 1018 15/01/10
		return;
	endif;

	ydc := self.myDockBar.myDrawingController;
	ydc.handleLabelFrameDragOver(frame, win, x, y, state);
end;</source>
        <Parameter name="frame" type="CMUI_ScrollableLabelsFrame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleLabelFrameMouseDown" id="34d0949c-476b-412d-b3f7-ce0a3767bd37">
        <updating/>
        <source>handleLabelFrameMouseDown(frame: CMUI_ScrollableLabelsFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	rdc	: YRD_RoRoLaneDrawingController;
	ydc : YRD_ContainerDrawingController;
	tmpTA : CM_TerminalArea;
begin
	inheritMethod(frame, button, shift, x, y);

	if self.myDockBar.isForGCRacks then
		return;
	endif;

	if self.myDockBar.isForRoRoLanes then						// cnwjk3 CCMS 1018 02/02/10
		rdc := self.myDockBar.myRoRoLaneDrawingController;		// cnwjk3 CCMS 1018 02/02/10
		if rdc &lt;&gt; null then										// jlgmd1	TFS#36913 08/02/2018
			rdc.handleLabelFrameMouseDown(frame,button,shift,x,y);	// cnwjk3 CCMS 1018 02/02/10
		endif;													// jlgmd1	TFS#36913 08/02/2018
		return;													// cnwjk3 CCMS 1018 02/02/10
	endif;														// cnwjk3 CCMS 1018 02/02/10
	
	ydc := self.myDockBar.myDrawingController;
	ydc.handleLabelFrameMouseDown(frame,button,shift,x,y);

end;</source>
        <Parameter name="frame" type="CMUI_ScrollableLabelsFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="handleLabelFrameMouseMove" id="2a6f058d-cf4f-425c-9077-52636b7941e3">
        <updating/>
        <source>handleLabelFrameMouseMove(frame: CMUI_ScrollableLabelsFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	ydc : YRD_ContainerDrawingController;
begin
	inheritMethod(frame, button, shift, x, y);

	if self.myDockBar.isForOverview then
		return;
	endif;
	if self.myDockBar.isForGCRacks then
		return;
	endif;

	if self.myDockBar.isForRoRoLanes then																	// cnwjk3 ccms 1018 4/12/09
		if self.myDockBar.myRoRoLaneDrawingController &lt;&gt; null then												// cnwjk3 ccms 1018 4/12/09
			self.myDockBar.myRoRoLaneDrawingController.handleLabelFrameMouseMove(frame, button, shift, x, y);	// cnwjk3 ccms 1018 4/12/09
		endif;																									// cnwjk3 ccms 1018 4/12/09
	else
		ydc := self.myDockBar.myDrawingController;
		ydc.handleLabelFrameMouseMove(frame, button, shift, x, y);
	endif;

end;</source>
        <Parameter name="frame" type="CMUI_ScrollableLabelsFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="handleLabelFrameMouseUp" id="70fd027c-181f-4a26-8d52-7bcb2aea68f7">
        <updating/>
        <source>handleLabelFrameMouseUp(frame: CMUI_ScrollableLabelsFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	ydc : YRD_ContainerDrawingController;
	tmpTA : CM_TerminalArea;
begin
	inheritMethod(frame, button, shift, x, y);

	if self.myDockBar.isForGCRacks then
		return;
	endif;
	if  self.myDockBar.isForRoRoLanes then // cnwjk3 CCMS 1018 15/01/10
		return;
	endif;

	ydc := self.myDockBar.myDrawingController;
	ydc.handleLabelFrameMouseUp(frame,button,shift,x,y);
end;</source>
        <Parameter name="frame" type="CMUI_ScrollableLabelsFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="439e4741-88b7-4417-8142-261a7eccad2f">
        <controlMethod name="Frame::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		14 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	rdc	: YRD_RoRoLaneDrawingController;
	ydc : YRD_ContainerDrawingController;
	tmpTA : CM_TerminalArea;
begin
	inheritMethod(frame, button, shift, x, y);

	if self.myDockBar.isForGCRacks then
		return;
	endif;

	if self.myDockBar.isForRoRoLanes then						// cnwjk3 CCMS 1018 02/02/10
		rdc := self.myDockBar.myRoRoLaneDrawingController;		// cnwjk3 CCMS 1018 02/02/10
		rdc.doDFMouseDown(frame,button,shift,x,y);				// cnwjk3 CCMS 1018 02/02/10
		return;													// cnwjk3 CCMS 1018 02/02/10
	endif;														// cnwjk3 CCMS 1018 02/02/10

	ydc := self.myDockBar.myDrawingController;
	ydc.doDFMouseDown(frame,button,shift,x,y);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="selectBlockOfObjectsFromXYs" id="e7948881-741b-4a7c-be11-136d54f54c86">
        <updating/>
        <source>selectBlockOfObjectsFromXYs( _class : Class; _x1,_y1,_x2,_y2 : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		07 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	self.myDockBar.myDrawingController.selectBlockOfObjectsFromXYs(_class,_x1,_y1,_x2,_y2 );
	
end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="3d364f25-2fbb-4b05-8925-ce37e234f8b1">
        <updating/>
        <source>windowCreated(cntrl: CMUI_ScrollingGridAreaFrame input; persistCntrl: CMUI_ScrollingGridAreaFrame) updating;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	if self.isInPainter then
		return;
	endif;
	
	self.autoRedraw := true;
end;</source>
        <Parameter name="cntrl" type="CMUI_ScrollingGridAreaFrame" usage="input"/>
        <Parameter name="persistCntrl" type="CMUI_ScrollingGridAreaFrame"/>
    </JadeMethod>
