    <JadeMethod name="searchForOnShipTI" id="7abf0c47-3e76-4eac-8f03-bccd92057cb3">
        <source>searchForOnShipTI(tiId : String; matches: Integer output) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:     05 January 2001 by cnwrs2
//
// Purpose:     Call this when you DONT know the TI type, hunts for each type.
//				We only look onship, and for a normal state ti. (speeds up the search)
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------
vars
	ti	: CM_TrackedItem;

begin

	ti := self.lookupNumTIMatchesWithId(tiId, TI_CargoType_Null, TI_STATE_ONSHIP, matches );


	return ti;
end;</source>
        <Parameter name="tiId" type="String"/>
        <Parameter name="matches" type="Integer" usage="output"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="searchForOnsiteOrQueueOnshipTI" id="c6a2a5b1-5367-46a3-8094-5608c699ef63">
        <source>searchForOnsiteOrQueueOnshipTI(_id : String;
							   _matches : Integer output; 
							   _cargoType : Integer;
							   _includeOnSite : Boolean) : CM_TrackedItem;

/*

Purpose:			Find a Tracked Item matching the passed in ID from the pool of onsite TIs and 
					those in voyages currently being worked in the RT queues.

Parameters:			(Partial) container ID, cargo type

Return Value:		Matching Tracked Item (if there is only one match)
					Also _matches is updated with the number of matches
					


Date		Who		Reason
02 Dec 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
30 Mar 2011	NDL		Par 27290	Made the onsite portion of the code optional.
13 Dec 2011	cnwcs5	par 28806 - exclude TIs not marked for discharge when serching onship TIs
*/

vars
	onsiteMatches,
	voyageMatches,
	tiSize			: Integer;
	onsiteTI, ti,						// par 28806
	voyageTI		: CM_TrackedItem;
	masterQ			: CM_MasterQueue;
	voyages			: CM_VoyageArray;
	voyage			: CM_Voyage;
	tiSet			: CM_TISet;
	upperID			: String;
	
begin
	// First search for onsite matches
	if _includeOnSite then
		onsiteTI := self.searchForOnsiteTI(_id, onsiteMatches, _cargoType);
	endif;
	
	// And then search for items in the pool of working voyages (all those with RT queues attached)
	if self.radioTelemetry &lt;&gt; null then
		masterQ := self.radioTelemetry.masterQueue;
		
		if masterQ &lt;&gt; null then

			// Get all the voyage queues
			voyages	:= masterQ.getVoyageQueueVoyages();
			
			if voyages &lt;&gt; null then
				
				// Search for the TI on each voyage
				create tiSet transient;
				upperID := _id.toUpper();
				
				foreach voyage in voyages do
					tiSet.clear();
					if voyage.searchForOnShipTIType(upperID, _cargoType, tiSet) then
						// par 28806 - tiSet may contain TIs that are not marked for discharge so
						// remove thse from the colection
						foreach ti in tiSet do	
							if ti.getFirstAvailableDischargeJob = null then
								// no discharge job
								tiSet.remove (ti);
							endif;
						endforeach;
						
						tiSize := tiSet.size;
						
						// Save off the first matching TI on a voyage, if there is only one
						if tiSize = 1 and voyageTI = null then
							voyageTI := tiSet.first;
						endif;

						voyageMatches := voyageMatches + tiSize;
					endif;
				endforeach;
			endif;
		endif;
	endif;
	
	// Now combine the results to return the appropriate values
	_matches := onsiteMatches + voyageMatches;
	
	// If there is only one match, then return it
	if _matches = 1 then
		if onsiteTI &lt;&gt; null then
			return onsiteTI;
		else
			return voyageTI;
		endif;
	endif;
	
	// Otherwise return null
	return null;
		
	
epilog
	delete voyages;
	delete tiSet;
	
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_matches" type="Integer" usage="output"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_includeOnSite" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="searchForOnsiteTI" id="750cdceb-3f23-4159-8397-f90fd9596f46">
        <source>searchForOnsiteTI(tiId : String; matches: Integer output; _cargoType : Integer) : CM_TrackedItem;
//Call this when you DONT know the TI type, hunts for each type.
//We only look onsite, and for a normal state ti. (speeds up the search)
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// ---------------------------------------------------------------------------
vars
	ti	:	CM_TrackedItem;
begin

	ti := self.lookupNumTIMatchesWithId(tiId, _cargoType, TI_STATE_NORMAL, matches);

	return ti;
end;</source>
        <Parameter name="tiId" type="String"/>
        <Parameter name="matches" type="Integer" usage="output"/>
        <Parameter name="_cargoType" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
