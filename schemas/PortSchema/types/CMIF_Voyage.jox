    <JadeMethod name="validate" id="4d47ceaf-7fff-43e3-ae87-51fdc7b5f579">
        <updating/>
        <source>validate() updating;
/*
------------------------------------------------------------------------
Created:			15 January 2003 by cnwdwq1
Purpose:			Tests that this object has what it takes to do the create.
Parameters:		As above. Special comment:
Returns:			As above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
16/07/2024 		navlw1			ChangeRequest 63839: NSW | OnePort - Uniqueness of Inward and External Code	
26/11/2024		navdap1			MTN-33516 NSW | OnePort - Voyage Already Exists With External Code Error
------------------------------------------------------------------------
*/
vars
	tmpStr		: String;
	tmpVoy		: CM_Voyage;
begin
	//---------------------
	//Clear this no matter what.
	//---------------------
	self.voyageCreated := null;
	if self.code.trimBlanks = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Code', null, null);
		app.raiseCMException(Input_required_field_code, null, null); // cnwdb2	PAR 35364
	endif;
	if self.code.cnContains(' ') then
		app.raiseCMException1(VB_SPACE_IN_AREA_NAME, self.code, null, null);
		return;
	endif;
	//Inward code is optional.
	if self.inwardCode.trimBlanks &lt;&gt; null then
		if self.inwardCode.cnContains(' ') then
			app.raiseCMException1(VB_SPACE_IN_AREA_NAME, self.inwardCode, null, null);
			return;
		endif;
	endif;
	if self.myOperator = null then
		tmpStr := app.getTerminologyAlternate(null, self.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
	//	app.raiseCMException1(REQUIRED_FIELD, tmpStr, ETRow_Operator, null);
		app.raiseCMException1(Input_required_field_Required, tmpStr, ETRow_Operator, null); // cnwdb2	PAR 35364
	endif;
	if self.myShippingLine = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Shipping Line', ETRow_ShippingLine, null);
		app.raiseCMException(Input_required_field_shpLine, ETRow_ShippingLine, null); // cnwdb2	PAR 35364
	endif;
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', ETRow_Terminal, null);
		app.raiseCMException(Input_required_field_terminal, ETRow_Terminal, null); // cnwdb2	PAR 35364
	endif;
	// only raise this one if they have trades on this system
	if self.myTrade = null and app.myRoot.allTradesByDescription.isEmpty = false then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Trade', null, null);
		app.raiseCMException(Input_required_field_trade, null, null); // cnwdb2	PAR 35364
	endif;
	//-------------------------
	//Test to see if we dont already have one of these
	//-------------------------
	tmpVoy := self.myTerminal.lookupVoyage(self.code, self.arrivedDT, false); // navlw1 #63839
	if tmpVoy &lt;&gt; null and self.inwardCode = null then
	//	app.raiseCMException3(ERR_DUPLICATE_KEY,"Voyage",self.code.String,null,null,null);
		app.raiseCMException1(Already_exists_voyage,self.code.String,null,null); //cnwdb2 PAR 35364
	endif;
	
	// start navlw1 #63839
	if self.inwardCode &lt;&gt; null then
		//if self.myTerminal.getDefaultVoyageProcess.isAutomaticProcess then		// MTN-33516
		if self.myTerminal.getConfig(AllowDupVoyageInOutCodes).Boolean then			// MTN-33516
			tmpVoy := self.myTerminal.lookupVoyageAuto(self.inwardCode, self.vesselCode, null, true);
			if tmpVoy &lt;&gt; null then			
				app.raiseCMException1(Already_exist_inward_voyage,self.inwardCode,null,null);
			endif;
		else
			tmpVoy := self.myTerminal.lookupVoyage(self.inwardCode, null, true);
			if tmpVoy &lt;&gt; null then
				//	app.raiseCMException3(ERR_DUPLICATE_KEY,"Inward Voyage",self.inwardCode.String,null,null,null);
				app.raiseCMException1(Already_exist_inward_voyage,self.inwardCode,null,null); //cnwdb2 PAR 35364
			endif;
		endif;
	endif;
	// end navlw1 #63839
	if self.allOperators.isEmpty then
	//	app.raiseCMException1(REQUIRED_FIELD, 'list of voyage operators', null, null);
		app.raiseCMException(Input_required_field_lstVoyOps, null, null); // cnwdb2	PAR 35364
	endif;
end;</source>
    </JadeMethod>
</Class>
