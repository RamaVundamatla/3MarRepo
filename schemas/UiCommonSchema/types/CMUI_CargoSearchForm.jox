    <JadeMethod name="loadCombos" id="a390fbbf-d5c3-4fbd-9c1d-e856fdeb8b5b">
        <source>loadCombos();
//07 September 2009	cnwml2
//
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------
// 23/08/2013	cnwdap1		PAR #32331 Added Colour and Colour Picker
// 10/06/2022	navcs2		ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
// 12/07/2022 	navcs2 		TFS 53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
// 22 Sep 2022 	navhl20 	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
// 12 Jan 2023	navcs2		ChangeRequest 56149: EUP - VAS Cargo Search Screen (Task 56150)
// 03 May 2023 	navhl20		ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
// 11 Aug 2023 	navmv20 	Bug 59697: EUP - Change of Ownership Cargo Review - Able to create COO for Offsite Cargo
// 28 Sep 2023 	navhl20 	ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
// 16 Oct 2023  navlc30     ChangeRequest 58996: EUP | VBS changes MTN - Adding multiple items at once (From Ticket FR 53429)
// 26 Feb 2024	navpw1		TFS: 59411 (61864) - Fixed issue with Cargo Onsite verses on ship fore release work order detail

vars
	termArea : CM_TerminalArea;
	form	 : CM_BaseForm;
begin
	self.cmbSite.clear;
	self.cmbSite.addItem(app.siteEnumToString(TI_SITE_ONSITE));
	self.cmbSite.addItem(app.siteEnumToString(TI_SITE_ONSHIP));
	if not self.myParentForm.isKindOf(CMUI_OwnershipChangeMaint) then //11/08/2023 navmv20 Bug 59697
		self.cmbSite.addItem(app.siteEnumToString(TI_SITE_OFFSITE));//11/08/2023 navmv20 Bug 59697
	endif; //11/08/2023 navmv20 Bug 59697
//	self.cmbSite.addItem(app.siteEnumToString(TI_SITE_ONTRAIN));
	
	self.cmbSite.setForText(app.siteEnumToString(TI_SITE_ONSITE));
	
	// 10/06/2022 navcs2 52351
	if self.myParentForm &lt;&gt; null and (self.myParentForm.name = "YRD_WorkOrder" or self.myParentForm.name = "CMUI_VehicleBookingItemMaint" )then	//16.10.2023 navlc30 #58996
		self.cmbBookings.visible := true;
		self.cmbReleases.visible := true;
		self.cmbBooking.visible := true;
		self.cmbSite.addItem(app.siteEnumToString(SEL_QUERYSITE_NOTIFIED));
		self.buildReleaseRequestsCombo();
		self.buildBookingComboBox();
		if self.myContextSearchObject.isKindOf(CM_WorkOrderTIDtl) then			//28.9.2023 navhl20 #59638
			if self.myContextSearchObject.isKindOf(CM_WodReceive) then
				if self.myContextSearchObject.CM_WodReceive.transport = TI_TRANSMODE_SHIP then
					self.cmbSite.setForText(app.siteEnumToString(TI_SITE_ONSHIP));
				endif;
			elseif self.myContextSearchObject.isKindOf(CM_WodRelease) then
				if self.myContextSearchObject.CM_WodRelease.transport = TI_TRANSMODE_SHIP then
					self.cmbSite.setForText(app.siteEnumToString(TI_SITE_ONSITE));	// ### TFS 59411 (61864) 26Feb2024 NAVPW1
				endif;
			endif;
		endif;
	endif;
	
	// 12/07/2022 navcs2 TFS 53899
	if self.myParentForm.isKindOf(CMUI_VehicleBookingItemMaint) then
		self.cmbSite.addItem(app.siteEnumToString(SEL_QUERYSITE_NOTIFIED));
		if self.myParentForm.CMUI_VehicleBookingItemMaint.optBtnDelivery.value then				//03.5.2023 navhl20 #57402[57471]
			self.cmbSite.setForText(app.siteEnumToString(SEL_QUERYSITE_NOTIFIED));
			self.cmbSite.enabled := false;
		elseif self.myParentForm.CMUI_VehicleBookingItemMaint.optBtnPickUp.value then			//03.5.2023 navhl20 #57402[57471]
			self.cmbSite.setForText(app.siteEnumToString(TI_SITE_ONSITE));
			self.cmbSite.enabled := false;
		endif;
	endif;
	
	//Start 22.09.2022 navhl20 TFS 53900
	if self.myParentForm.isKindOf(CMUI_VehicleBookingEnqForm) then
		self.cmbSite.addItem(app.siteEnumToString(SEL_QUERYSITE_NOTIFIED));
		if self.myParentForm.CMUI_VehicleBookingEnqForm.cmbDirection.getCurrentItemData = DIRECTION_DELIVERY then
			self.cmbSite.setForText(app.siteEnumToString(SEL_QUERYSITE_NOTIFIED));
			self.cmbSite.enabled := false;
		elseif self.myParentForm.CMUI_VehicleBookingEnqForm.cmbDirection.getCurrentItemData = DIRECTION_PICKUP then
			self.cmbSite.setForText(app.siteEnumToString(TI_SITE_ONSITE));
			self.cmbSite.enabled := false;
		endif;
	endif;
	//End 22.09.2022 navhl20 TFS 53900
	
	// ### TFS CR 59614 TASK 59619 15AUG2023 NAVAB1
	if self.myParentForm.isKindOf(CMUI_CustomDocsMaint) then
		self.cmbSite.addItem(app.siteEnumToString(SEL_QUERYSITE_NOTIFIED));
	endif;
	
	//jlier1 JIRA 36572 23/1/26
	if self.myParentForm &lt;&gt; null and self.myParentForm.name = "INV_InvoiceLineUpdate" then
		self.cmbSite.addItem(app.siteEnumToString(SEL_QUERYSITE_NOTIFIED));
	endif;
	
	//+cnwml2 PAR21663
	foreach termArea in self.myTerminal.allTerminalAreas do
		self.txtLocation.addItem(termArea.id);
	endforeach;
	
	if app.isCargoGroupEnabled then
		self.txtCargoGroupID.visible := true;
	else
		self.txtCargoGroupID.visible := false;
	endif;
	
	self.myAssistant.listTableColour(self.lstColourList);				// PAR #32331
	self.loadCmbCommodity();											// 12 Jan 2023	navcs2	#56149 (56150)
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadSelectedTITable" id="b8f1687c-ad07-4c05-82bc-dca2178357c6">
        <source>loadSelectedTITable();
//14 September 2009	cnwml2
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
24 Jul 2025 navhn30 MTN-35315: MTN | Pagination - Work Order Maintenance
*/

vars
	count : Integer;
	ti : CM_TrackedItem;
	iter : Iterator;
	idx : Integer;
begin
	//+cnwml2 PAR21663
	/*iter := self.allSelectedTrackedItems.createIterator;
	while iter.next(ti) do	
		count := count + 1;
		idx := self.tblSelectedItems.updateItemObject(ti, self.colorRow1, self.colorRow2, app.myPassport);
		self.tblSelectedItems.accessRow(idx).itemObject := ti;
		self.tblResults.removeItemObject(ti);
	endwhile;*/
	self.tblSelectedItems.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null,self.allSelectedTrackedItems, true); //24.07.2025	navhn30  MTN-35315
epilog
	delete iter;		// PAR #26678
end;</source>
    </JadeMethod>
