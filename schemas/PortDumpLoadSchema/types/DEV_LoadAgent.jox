        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadVoyageDelayAdd" id="7897ef38-cf16-4766-9837-649992250bb6">
        <source>loadVoyageDelayAdd(_voyageDelayAddProxy:HMS_VoyageDelayAdd io) :Boolean protected;

vars
	realHMSTransaction: HMS_Transaction;
//	realObject, proxyObject: HMS_VoyageDelayAdd;
	error: CM_Error;
	theTerminal: CM_Terminal;
	transController: CMIF_HMS_TransactionController;
	workingVoyageCtrl: CMIF_HMS_WorkingVoyage;
	workingDelayCtrl: CMIF_HMS_VoyageDelay;
//	countError,countOK: Integer;
begin
	if _voyageDelayAddProxy.myHMSVoyageData = null then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyageDelayAddProxy.transactionDT.String&amp;" ERROR: "&amp;"No Voyage.",0);
		return false;
	endif;
	if _voyageDelayAddProxy.myVoyageDelay = null then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyageDelayAddProxy.transactionDT.String&amp;" ERROR: "&amp;"No Voyage Delay.",0);
		return false;
	endif;
	beginTransaction;
	create transController transient;
	create workingVoyageCtrl transient;
	create workingDelayCtrl transient;
	transController.myWorkingVoyage := workingVoyageCtrl;
	transController.myWorkingDelay := workingDelayCtrl;
	theTerminal := app.myPassport.myTerminal;

//	transController.myVoyageMovement := _voyageDelayAddProxy.myPassageeMovement;
	transController.myHMSVoyageData := _voyageDelayAddProxy.myHMSVoyageData;
	transController.myTerminal := app.myPassport.myTerminal;
	transController.myPersistentVoyageDelay := _voyageDelayAddProxy.myVoyageDelay;
	transController.type := TRANS_TYPE_AddVoyageDelay;
	
	realHMSTransaction := transController.createConversionTransaction(app.myPassport);
	if app.myPassport.allErrorWarnings.size = 0 and 
	   realHMSTransaction &lt;&gt; null then
		realHMSTransaction.setPropertyValue("userCode",_voyageDelayAddProxy.userCode);
		realHMSTransaction.setPropertyValue("userName",_voyageDelayAddProxy.userName);
		realHMSTransaction.setPropertyValue("transactionDT",_voyageDelayAddProxy.transactionDT);
		commitTransaction;
		return true;
	else
		abortTransaction;
		foreach error in app.myPassport.allErrors do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_voyageDelayAddProxy.transactionDT.String&amp;" ERROR: "&amp;error.text,0);
		endforeach;
		return false;
	endif;
epilog
	delete transController;
	delete workingVoyageCtrl;
	delete workingDelayCtrl;
end;</source>
        <access>protected</access>
        <Parameter name="_voyageDelayAddProxy" type="HMS_VoyageDelayAdd" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
