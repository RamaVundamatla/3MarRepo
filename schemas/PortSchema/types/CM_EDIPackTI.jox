vars

begin
	return ETDef_EDITIPack;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOperatorCode" id="f4e03120-a280-43be-be8f-0e21a542c073">
        <source>getOperatorCode(): String;
//
//cnwrs1 par 26800 14 Jan 2011
// 
vars
	operator : CM_Operator;	//par 26971 cnwrs1 14 Feb 2011
begin
	operator := app.myRoot.allOperators[self.operatorCode[1:4]];
	if operator &lt;&gt; null then
		return operator.code;
	else
		return null;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOxygen" id="a378d838-5d12-47d5-8cfc-55f0e822e78b">
        <source>getOxygen():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2020	jlgndl1	Initial creation	TFS 47958

*/

vars

begin

	//All Oxygen display fields are limited to Decimal 6,2  so don't returm bigger than that
	if self.oxygen &gt; 999.99 then
		return 999.99;
	endif;

	return self.oxygen;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getValueSpecial" id="d2ba66db-59f2-4798-8191-1c74c6c54b16">
        <source>getValueSpecial(_propName: String; _xlationOperator: CM_Operator): String;
//
// 16 Jan 2012	MSL CCMS 1009 PAR 29024
//
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
// 30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML
//30 Jun 2016	cnwrs1	TFS 2300 Add Fonterra Pack VGM

vars
	foundMatch	: Boolean;
begin
	if _propName =  ETRow_Commodity then //Par 13379 cnwrs1 feb 2007
		if _xlationOperator &lt;&gt; null then
			return _xlationOperator.getXlationForeignCode(self.commodity[1:30], XLATION_TYPE_COMMODITY_BYOP, foundMatch);
		else
			return self.commodity;
		endif;
	elseif _propName = ETRow_Humidity then//non-multiplied
		if self.getHumidity = NULL_HUMIDITY then//i.e. null STRING - NULL_Humidity - other wise '0' is a valid humidity
			return null;
		else
			return self.getHumidity.asStringJMT;
		endif;
	elseif _propName = ETRow_Ventilation or _propName = ETRow_Vent then//non-multiplied
		if self.vent = NULL_VENTILATION then//i.e. null STRING - NULL_VENTILATION - other wise '0' is a valid vent
			return null;
		else
			return vent.String;
		endif;
	elseif _propName = ETRow_CarbonDioxide then
		if self.getCarbonDioxide = NULL_CARBON_DIOXIDE then
			return null;
		else
			return self.getCarbonDioxide.asStringJMT;
		endif;
	elseif _propName = ETRow_Oxygen then
		if self.getOxygen = NULL_OXYGEN then
			return null;
		else
			return self.getOxygen.asStringJMT;
		endif;
	elseif _propName = ETRow_Temperature then
		if self.temperature = NULL_TEMPERATURE then
			return null;
		else
			return self.temperature.asStringJMT();
		endif;
	elseif _propName = ETRow_NetWeight then
		return weightNet.String;
	elseif _propName = ETRow_TareWeight then
		return weightTare.String;
	elseif _propName = ETRow_IsCertifiedWeight then							// TFS #2033
		return self.isWeightCertified.asStringJMT;		// TFS #2033
	else
		return inheritMethod(_propName, _xlationOperator);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
