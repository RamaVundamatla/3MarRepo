    <JadeMethod name="binaryLoad" id="2b789aba-e331-4d19-a0be-7e83a1161e23">
        <updating/>
        <source>binaryLoad(pFileName:String; pFile:File input):Binary updating;
// --------------------------------------------------------------------------------
// Created:		14 February 1999 by cnwdad1
//
// Purpose:		Loads a file from disk into a binary.
//
// Parameters:	pFileName (String) - The name of the file to load.
//				pFile (File) - The file object to load.
// Returns:		Binary - The loaded binary data.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	binary	: Binary;

begin
	pFile.openInput(pFileName);

	if pFile.isAvailable() then
		binary	:=	pFile.readBinary(pFile.fileLength());
	endif;

	pFile.close();
epilog
	return binary;
end;</source>
        <Parameter name="pFileName" type="String"/>
        <Parameter name="pFile" type="File" usage="input"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="classForeColor" id="b8765275-deaa-4475-b662-dd2843f59479">
        <source>classForeColor(pClass:Class; pListBox:ListBox input; pIndex:Integer);
// --------------------------------------------------------------------------------
// Created:		11 July 1999 by cnwdad1
//
// Purpose:		Sets the appropriate fore colour for a class in a listbox control.
//
// Parameters:	pClass (Class) - The class whose fore colour we're setting.
//				pListBox (ListBox) - The listbox containing the class.
//				pIndex (Integer) - The index of the class in the listbox.
// Returns:		Nothing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (pClass.isSystemObject) then
		pListBox.itemForeColor[pIndex]	:=	Red;
	elseif (pClass.schema &lt;&gt; currentSchema) then
		pListBox.itemForeColor[pIndex]	:=	Blue;
	elseif (pClass.abstract) then
		pListBox.itemForeColor[pIndex]	:=	Green;
	else
		pListBox.itemForeColor[pIndex]	:=	Black;
	endif;
end;</source>
        <Parameter name="pClass" type="Class"/>
        <Parameter name="pListBox" type="ListBox" usage="input"/>
        <Parameter name="pIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="classString" id="38efeae8-0956-48b6-9a01-5127fae21d4c">
        <source>classString(pClass:Class):String;
// --------------------------------------------------------------------------------
// Created:		13 February 1999 by cnwdad1
//
// Purpose:		Returns a display of a class name and the number of instances.
//
// Parameters:	pClass (Class) - The class whose display to return.
// Returns:		String - The class display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	classDescription	: String;

begin
	if (pClass = null) then
		classDescription	:=	null;
	else
		classDescription	:=	pClass.Class.name;

		if (pClass.schema &lt;&gt; currentSchema) then
			classDescription	:=	classDescription &amp; '      (of ' &amp; pClass.schema.name &amp; ')';
		endif;

		if (pClass.abstract) then
			classDescription	:=	classDescription &amp; '   (Abstract)';
		else
			classDescription	:=	classDescription &amp; '   (' &amp; pClass.instances.size.String &amp; ')';
		endif;
	endif;
epilog
	return classDescription;
end;</source>
        <Parameter name="pClass" type="Class"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cmdFileGet" id="4acddbcd-4822-4e70-a03a-205a1f5e9dc0">
        <source>cmdFileGet(pMustExist:Boolean):String;
// --------------------------------------------------------------------------------
// Created:		06 February 1999 by cnwdad1
//
// Purpose:		Get the name of an existing disk file.
//
// Parameters:	pMustExist (Boolean) - Indicates whether the file must already exist.
// Returns:		String - The name of the file.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cmdFile		: CMDFileOpen;
	fileName	: String;

begin
	create cmdFile;

	cmdFile.allowMultiSelect	:=	false;
	cmdFile.createPrompt		:=	false;
	cmdFile.defaultExt			:=	".*";
	cmdFile.fileMustExist		:=	pMustExist;
//	cmdFile.filter				:=	"All files|*.*";
//	cmdFile.filterIndex			:=	1;
	cmdFile.cnEcSetFilters(true, 1, null);
	cmdFile.hideReadOnly		:=	false;
//	cmdFile.initDir				:=
	cmdFile.noReadOnlyReturn	:=	true;
	cmdFile.pathMustExist		:=	true;
	cmdFile.readOnly			:=	false;
	cmdFile.resetCurrentPath	:=	true;
	cmdFile.shareAware			:=	true;
	cmdFile.validate			:=	true;

	if (cmdFile.open = 0) then
		fileName	:=	cmdFile.fileName;
	else
		fileName	:=	"";
	endif;

	return fileName;
epilog
	if (cmdFile &lt;&gt; null) then
		delete cmdFile;
	endif;
end;</source>
        <Parameter name="pMustExist" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="confirmAction" id="b33fcab5-dbed-4c7a-9779-91ef22899683">
        <source>confirmAction(pAction:String):Boolean;
// --------------------------------------------------------------------------------
// Created:		11 July 1999 by cnwdad1
//
// Purpose:		Used to ask the User to confirm an action.
//
// Parameters:	pAction (String) - A description of the action to be confirmed.
// Returns:		Boolean - The User's response to the confirmation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	response	: Integer;

begin
	response	:=	app.msgBox(pAction, 'Confirmation Required', MsgBox_Question_Mark_Icon + MsgBox_Yes_No);

	if (response = MsgBox_Return_Yes) then
		return true;
	else
		return false;
	endif;
end;</source>
        <Parameter name="pAction" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="fileGet" id="61fc8b74-50a0-400c-99b2-996b058482c1">
        <source>fileGet(pFileName:String):File;
// --------------------------------------------------------------------------------
// Created:		14 February 1999 by cnwdad1
//
// Purpose:		Gets a disk file.
//
// Parameters:	pFileame (String) - The name of the file to get from disk.
// Returns:		File - The file object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	file	: File;

begin
	create file transient;
	file.kind	:=	File.Kind_Binary;
	file.mode	:=	File.Mode_Input;
epilog
	return file;
end;</source>
        <Parameter name="pFileName" type="String"/>
        <ReturnType type="File"/>
    </JadeMethod>
