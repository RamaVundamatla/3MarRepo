    <JadeMethod name="setExternalReferences" id="c8e3ce1e-8fdf-4886-8d58-0d3d1a29a6d6">
        <source>setExternalReferences(_invoiceLine : CM_InvoiceLine input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/02/2025	navkc1 JIRA Story MTN-33896: NSW | Invoicing Differentiate NSW Hard Coded Functionality

*/

vars
	locnCustomHyphens,
	mainAccountDisplayValue,
	location,
	customer,
	shipmentProfile,
	cargoProfile,
	fcg					: String;
	berth 				: HMS_Berth;
	ti 					: CM_TrackedItem;
	trans,prevRelease 	: CM_TITransaction;
	isoTypeGroup 		: CM_ISOTypeGroup;
	glCode 				: CM_GLCode;
	movement 			: HMS_Movement;
	voyage 				: CM_Voyage;
	theInvoice 			: CM_Invoice;
	wharf 				: HMS_Wharf;
	hmsTrx				: HMS_VTMISTransaction;
	hmsVoyage			: HMS_VoyageData;
	debtor				: CM_Debtor;
	product				: CM_Product;
	transName : String;
	shipRec : CM_TransactionType;
begin
	
	glCode := _invoiceLine.getGLCode();
	
	if glCode &lt;&gt; null then
		mainAccountDisplayValue := glCode.code;
	endif;
	
	hmsTrx := _invoiceLine.myTransactionHMS;
	
	if hmsTrx &lt;&gt; null then
		movement := hmsTrx.myMovement;
		
		if movement &lt;&gt; null then
			berth := movement.getMyBerth();
			
			if berth.isLogicalBerth() then
				berth := null;
			endif;
		endif;
	endif;
	
	if berth = null then
		voyage := _invoiceLine.getMyVoyageObject();
		
		if voyage &lt;&gt; null then
			hmsVoyage := voyage.myHMSVoyageData;
			
			if hmsVoyage &lt;&gt; null then
				berth := hmsVoyage.getMyFirstPhysicalBerth();
			endif;
		endif;
	endif;
	
	if berth &lt;&gt; null then
		location := berth.externalReference1;
	endif;
	
	debtor := _invoiceLine.debtor;
	if debtor &lt;&gt; null then
		customer := debtor.code;
	endif;
	
	ti := _invoiceLine.trackedItem;
	if ti &lt;&gt; null then
		if ti.isExport then
			
			shipmentProfile:="ED";
			
		elseif ti.isImport then
			
			shipmentProfile:="ID";
			
		elseif ti.isTranshipItem then
			
			trans := _invoiceLine.myTransactionTI;
			if trans &lt;&gt; null then
				if trans.state = TI_STATE_ONSHIP  then
					prevRelease := ti.getLastTransOfType(TRANS_TYPE_REL_SHIP);
					
					if prevRelease &lt;&gt; null then
						shipmentProfile:="ET";
					else
						shipmentProfile:="IT";
					endif;
				elseif trans.state = TI_STATE_NORMAL then
					prevRelease := ti.getLastTransOfType(TRANS_TYPE_REC_SHIP);
					
					if prevRelease &lt;&gt; null then
						shipmentProfile:="IT";
					else
						shipmentProfile:="ET";
					endif;
				endif;
			// ### JIRA 34304 11MAR 2025 NAVAB1 Proforma Invoices, no transactions, so use where it is now. The code for this change was deleted
			else // PROFORMA NSW only map receive ship and release ship in their tran map
				 // ### JIRA 34855 12APR2025 NAVAB1 we store the transaction type in this field for proforma
				if _invoiceLine.quantityNoMinMax = TRANS_TYPE_REC_SHIP then 
					shipmentProfile:="IT";
				elseif _invoiceLine.quantityNoMinMax = TRANS_TYPE_REL_SHIP then 
					shipmentProfile:="ET";
				else
					shipmentProfile:="ET";
				endif;
			endif;
		endif;
		
		isoTypeGroup := ti.getISOTypeGroup;
		if isoTypeGroup &lt;&gt; null and ti.isContainer then
			cargoProfile := isoTypeGroup.externalReference1;
			
			fcg := isoTypeGroup.externalReference2;
			
		else
			cargoProfile := ti.myCargoType.externalReference;
			
			product := ti.myProduct;
			
			if product &lt;&gt; null then
				fcg := product.code;
			endif;
		endif;
		
		if ti.isContainer then
			if ti.isEmpty then
				cargoProfile := cargoProfile &amp; "MT";
			else
				cargoProfile := cargoProfile &amp; "FL";
			endif;
		endif;
	endif;
	
	locnCustomHyphens := "----";
	
	_invoiceLine.externalRef4 := mainAccountDisplayValue&amp; "--" &amp; location &amp; locnCustomHyphens &amp; 
								customer &amp; "-" &amp; shipmentProfile &amp; "-" &amp; cargoProfile &amp; "-" &amp; fcg &amp;  "-";
	
	theInvoice := _invoiceLine.invoice;
	if theInvoice &lt;&gt; null then
		if not (theInvoice.isTASInvoice() and theInvoice.isTASCreditNote()) then
			if berth &lt;&gt; null then
				wharf := berth.myWharf;
				
				if wharf &lt;&gt; null then
					_invoiceLine.externalRef1 := wharf.code[1:30];
					_invoiceLine.externalRef2 := wharf.description[1:30];
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_invoiceLine" type="CM_InvoiceLine" usage="input"/>
    </JadeMethod>
</Class>
