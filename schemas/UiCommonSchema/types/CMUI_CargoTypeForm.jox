/* ---------------------------------------------------------------------------
Created:	19 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	cargoType : CM_CargoType;

begin

	if self.cmbProductType.listIndex = -1 then
		cargoType := self.myCurrentObject.CM_CargoType;
		if cargoType = null then
			self.cmbProductType.listIndex := 1;	// go to the first item in the combobox
		else
			self.cmbProductType.listIndex := cargoType.productType + 1;
		endif;
	endif;

end;</source>
