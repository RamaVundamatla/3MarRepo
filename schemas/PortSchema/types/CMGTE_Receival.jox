    <JadeMethod name="setUpdatedSeals" id="98fab59e-76d9-48cc-b5a3-f6d4b6922668">
        <source>setUpdatedSeals( _allUpdatedSeals : CM_SealTIBySealTypeDict );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2017	cnwndl1	Initial creation	TFS 4656

*/

vars

	sealTITrans : CM_SealTI;
	existingSealTi : CM_SealTI;
	sealType : CM_SealType;

begin

	foreach sealTITrans in _allUpdatedSeals do
		sealType := app.myRoot.getSealType( sealTITrans.sealType );
		existingSealTi := self.allSeals.getSealTI( sealType );
		if existingSealTi = null then
			create existingSealTi;
			existingSealTi.setSealType( sealTITrans.sealType );
			self.allSeals.add( existingSealTi );
		endif;
		existingSealTi.allSealNums.clear();
		sealTITrans.allSealNums.copy( existingSealTi.allSealNums );
	endforeach;
	
epilog

end;</source>
        <Parameter name="_allUpdatedSeals" type="CM_SealTIBySealTypeDict"/>
    </JadeMethod>
