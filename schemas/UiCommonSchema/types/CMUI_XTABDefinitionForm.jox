    <JadeMethod name="isCompatibleTypeAndMode" id="1616de63-58a1-4345-b9bf-1cf090f6ca2c">
        <source>isCompatibleTypeAndMode(_type, _mode :Integer):Boolean protected;
// ---------------------------------------------------------------------------
// Created:     12 February 2010 by cnwcs5
// Purpose:     CCMS 1925 / PAR 22295 Release Summaries
// Parameters:  _mode	- the mode to check
// Returns:     true if the mode is valie for the objects in our collection
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/03/2010	cnwcs5		Fixed issue with BOL
// 19/05/2017	cnwma1		TFS #4397*:MSL - Summarise container list from Voyage Side Profile
// 03 Jan 2023	navhl20		ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
// 18 Feb 2023  navmv20     TFS 55649 Task 55689: UI - Selector Query Contracts
// 30 May 2023	navlw1		ChangeRequest 58146: EUP - VBS MTN - [6] - Selector Query and JRW Part 2
// ---------------------------------------------------------------------------

vars
	obj	:Object;
begin
	obj := self.myCollection.first;
	
	//+cnwml2 PAR24559
	if obj.isKindOf(CM_LocationsController) then
		obj := obj.CM_LocationsController.allTrackedItems.first;
	endif;

	if obj = null then
		return true;	// anything OK
	endif;
	
	if self.isSnapshotMode then		
		if _type = CM_QueryDefinition.Snapshot_Query_Type and	
			_mode = CM_QueryDefinition.Snapshot_Query_Mode then
			return true;
		endif;
	elseif obj.isKindOf (CM_BOL) then
		if _type = CM_QueryDefinition.BOL_Query_Type then	// 01/03/2010 cnwcs5
			return true;									// 01/03/2010 cnwcs5
		endif;												// 01/03/2010 cnwcs5
	elseif obj.isKindOf (CM_TrackedItem) then
		if _type &lt;&gt; CM_QueryDefinition.Release_Query_Type and
			_type &lt;&gt; CM_QueryDefinition.BookRef_Query_Type and
			_type &lt;&gt; CM_QueryDefinition.BOL_Query_Type and	// 01/03/2010 cnwcs5
			_type &lt;&gt; CM_QueryDefinition.Transaction_Query_Type and  // 19/05/2017 cnwma1 TFS #4397
			_type &lt;&gt; CM_QueryDefinition.Invoicing_Query_Type and	// 19/05/2017 cnwma1 TFS #4397
			_type &lt;&gt; CM_QueryDefinition.Snapshot_Query_Type then
			return true;
		endif;
	elseif obj.isKindOf (CM_BulkRelease) then
		if _type = CM_QueryDefinition.Release_Query_Type then
			return true;
		endif;
	elseif obj.isKindOf (CM_ReserveDetail) then
		if _type = CM_QueryDefinition.Release_Query_Type and
			_mode = CM_QueryDefinition.ReleaseItem_Query_Mode then
			return true;
		endif;
	elseif obj.isKindOf (CM_BookingRef) then
		if _type = CM_QueryDefinition.BookRef_Query_Type then
			return true;
		endif;
	elseif obj.isKindOf (CM_BookingRefItem) then
		if _type = CM_QueryDefinition.BookRef_Query_Type and
			_mode = CM_QueryDefinition.BookRefItem_Query_Mode then
			return true;
		endif;
	//  CCMS 1262 Feb 2012 transaction enquiry and selector queries		
	elseif obj.isKindOf(CM_TITransaction) then
		if _type = CM_QueryDefinition.Transaction_Query_Type and
			_mode = CM_QueryDefinition.CargoTransaction_Query_Mode then
			return true;
		endif;
	elseif obj.isKindOf(CM_EventTransaction) then
		if _type = CM_QueryDefinition.Transaction_Query_Type and
			_mode = CM_QueryDefinition.EventTransaction_Query_Mode then
			return true;
		endif;
	elseif obj.isKindOf(HMS_VTMISTransaction) then
		if _type = CM_QueryDefinition.Transaction_Query_Type and
			_mode = CM_QueryDefinition.HMSTransaction_Query_Mode then
			return true;
		endif;	
	elseif obj.isKindOf(CM_WOTransaction) then							//03.01.2023 navhl20	#54350:[54269]
		if _type = CM_QueryDefinition.Transaction_Query_Type and
			_mode = CM_QueryDefinition.WorkOrderTrans_Query_Mode then
			return true;
		endif;
	elseif obj.isKindOf(CM_VehicleBookingTimeSlot) then							// 30/05/2023 navlw1 tfs 58146
		if _type = CM_QueryDefinition.VehicleBookingSlot_Query_Type and
			_mode = CM_QueryDefinition.VehicleBookingSlot_Query_Mode then
			return true;
		endif;
	
	//16 May 2014	NDL	Par 34142
	elseif obj.isKindOf(CM_Invoice) then
		if _type = CM_QueryDefinition.Invoicing_Query_Type and
			_mode = CM_QueryDefinition.Invoice_Query_Mode then
			return true;
		endif;
	elseif obj.isKindOf(CM_InvoiceLine) then
		if _type = CM_QueryDefinition.Invoicing_Query_Type and
			_mode = CM_QueryDefinition.InvoiceLine_Query_Mode then
			return true;
		endif;
	elseif obj.isKindOf(CM_CashPayment) then
		if _type = CM_QueryDefinition.Cash_Query_Type and
			_mode = CM_QueryDefinition.CashPayment_Query_Mode then
			return true;
		endif;
	elseif obj.isKindOf(CM_CashReceipt) then
		if _type = CM_QueryDefinition.Cash_Query_Type and
			_mode = CM_QueryDefinition.CashReceipt_Query_Mode then
			return true;
		endif;
	// 18 Feb 2023  navmv20  TFS 55649 Task 55689 - START
	elseif obj.isKindOf(CM_InvoiceContract) then
		if _type = CM_QueryDefinition.Invoicing_Query_Type and
			_mode = CM_QueryDefinition.Contract_Query_Mode then
			return true;
		endif;
	// 18 Feb 2023  navmv20  TFS 55649 Task 55689 - END// 18 Feb 2023  navmv20     TFS 55649 Task 55689: UI - Selector Query Contracts
	endif;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPropertyDerivedFromParent" id="73c47105-bc33-4026-b6c6-0e37750f9092">
        <source>isPropertyDerivedFromParent( _field :CM_XTABField ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwndl1	Initial creation	CCMS 1028

*/

vars

	qDef : CM_QueryDefinition;
	queryProp : CM_QueryProperty;
	niceName : String;
	headerQDef : CM_QueryDefinition;
	headerQueryProp : CM_QueryProperty;
	
begin

	if _field = null then
		return false;
	endif;

	qDef := self.cmbMode.listObject.CM_QueryDefinition;
	if qDef = null then
		return false;
	elseif not qDef.isBookRefItemType then
		return false;
	endif;
	
	// OK our mode is 'Booking Reference Items'
	// so, is this cell one that derives its data from its parent Booking reference?
	// This can only be true if the parent also has a 'CM_QueryProperty' by the same 'nice name'

	queryProp := _field.getQueryProperty;
	if queryProp = null then
		return false;
	else
		return qDef.derivedfromParent(queryProp);
	endif;
	
	
epilog

end;</source>
        <Parameter name="_field" type="CM_XTABField"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
