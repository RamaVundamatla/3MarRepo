    <JadeMethod name="setControlsForAddEdit" id="e2e1e8f3-1cb3-4893-9cae-7d1e00394d53">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	theForm : SOP_TableMaintForm;
	pxyTerminalAreaType		: CM_TerminalAreaType;
begin
	pxyTerminalAreaType := self.myForm.myProxyObject.CM_TerminalAreaType;

  
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;


	if theForm.mode = theForm.Mode_Add then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Should not be able to add!');
		return;
	else
		self.myForm.tblInput1.userInputEnabled := true;
	endif;

	if pxyTerminalAreaType&lt;&gt; null // TFS 39174
	and pxyTerminalAreaType.type = TA_TYPE_HIDE then // TFS 39174
		theForm.tblInput1.enableRowByName(ETRow_Description); // TFS 39174
	else
		theForm.tblInput1.disableRowByName(ETRow_Description);
	endif;
	
	theForm.tblInput1.row := theForm.tblInput1.getRowByName(ETRow_IsNotAvailableForEntry);
	theForm.tblInput1.setFocus;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDefaults" id="7548463f-1700-4890-a552-5d59b5a8f9d3">
        <source>setupThumbnailDefaults();

vars

begin
	inheritMethod();
	self.myForm.allowAdd 	:= false;	
	self.myForm.allowDelete := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="af584910-f195-4f22-bd95-91763ac9fc69">
        <updating/>
        <source>setupThumbnailDetails() updating;

vars
	theForm		: SOP_TableMaintForm;
begin
	theForm := self.myForm;
	inheritMethod();
	self.myForm.initTblInput(self.myForm.tblInput1, ETDef_TerminalAreaType);
	theForm.setTblDataEntRows(ETDef_TerminalAreaType);

	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Description, false);


	theForm.shtTblInput1.caption := 'Details';
	theForm.shtTblInput1.visible := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="b064ef85-6e89-41f3-ba57-409384abda96">
        <updating/>
        <source>showThumbnail(pObj: CM_TerminalAreaType) updating;

vars
	tbl			: CM_EntryTable;
	jCell		: JadeTableCell;
begin
	if pObj = null then
		return;
	endif;
	
	tbl := self.myForm.tblInput1;
	
	tbl.setValueByName(ETRow_Description, pObj.description);
	tbl.setValueByName(ETRow_IsNotAvailableForEntry, pObj.isNotAvailableForEntry);
end;</source>
        <Parameter name="pObj" type="CM_TerminalAreaType"/>
    </JadeMethod>
</Class>
