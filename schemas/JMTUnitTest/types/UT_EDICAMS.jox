    <JadeMethod name="removeElementFromSegment" id="49021ad6-0f62-4d70-b0f1-b976d9ffe61a">
        <source>removeElementFromSegment(_num :Integer; _delim :Character; _str :String):String protected;
/*
Purpose:	Remove _num element from _str

Date		Who		Reason
17 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
8/04/2019 	JLGNS1	ChangeRequest 39725: JMT - CODECO 00B
*/
vars
	first, last	:String;
	int, pos 	:Integer;
begin
	pos := 1;
	
	while pos &gt; 0 and pos &lt; _str.length do
		//pos := _str.pos ('+', pos);
		pos := _str.pos (_delim, pos);
		int := int + 1;
	
		if pos = 0 then
			return null;
		elseif int &lt; _num then
			first := _str [1:pos]; 
		elseif int = _num then
			last := _str[pos:end];
			break;
		endif;
				
		pos := pos + 1;
	endwhile;

	return first &amp; last;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_num" type="Integer"/>
        <Parameter name="_delim" type="Character"/>
        <Parameter name="_str" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="removeStopsAndAddOneKnownStop" id="71d94991-e391-46a8-bc84-7b9e3ebbfee5">
        <source>removeStopsAndAddOneKnownStop(_ti : CM_TrackedItem input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2023	navra1	Initial creation

*/

vars
	stops :CM_StopsByIdDict;
	stop : CM_Stops;
	iter:Iterator;

begin

	create stops transient;		
	_ti.getAllActiveStops(stops);		
	
	iter := stops.createIterator();
		
	while iter.next(stop) do		
		self.deleteStopForTIById(_ti, stop.id);		
	endwhile;
	
	self.addStopById(_ti, 2);		
	
	
epilog
	delete stops;
	delete iter;
	delete stop;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="roadExitNoCheck" id="5bda23a5-7645-4739-b78b-a0b422741b11">
        <source>roadExitNoCheck(_vvr: CM_VehicleVisitRecord input);
//19 August 2009	cnwdw1	
//16 Feb 2024	navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit
vars

	expectErrors : Boolean;

begin
	
	expectErrors := self.opts.bool("ExpectErrors");
	
	//app.myTrxDA.trxRoadExit(_vvr.myRoadJob, app.myPassport);			//16.02.2024 navnk30 #62414
	app.myTrxDA.trxRoadExit(_vvr.myRoadJob, null, app.myPassport);		//16.02.2024 navnk30 #62414
	
	if expectErrors then
		return;
	endif;
	
/*	self.assertNoTrxErrorsOrWarnings();
	if not _vvr.allReceivedTrackedItems.isEmpty() then										// 16/08/2012 cnwmh5
		self.checkTIsForTxnOfType(_vvr.allReceivedTrackedItems, TRANS_TYPE_REC_ROAD);
	endif;
	if not _vvr.allReleasedTrackedItems.isEmpty() then										// 16/08/2012 cnwmh5
		self.checkTIsForTxnOfType(_vvr.allReleasedTrackedItems, TRANS_TYPE_REL_ROAD);
	endif;*/
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
    </JadeMethod>
    <JadeMethod name="sdl_tCoarri_Standard" id="89fc1e26-760f-49b3-8aea-6cd339041592">
        <updating/>
        <source>sdl_tCoarri_Standard() updating;
/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
23 Aug 2017	jlgsl4				Initial creation - copy of tCoarri_Standard()
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/

constants
	VoyageName1				= 'UT_VOYAGE';				
	ForeignVoyageCodeMSK1 	= 'MSK_VOYAGE';
	ForeignVoyageCodeUTOP1 	= 'UTOP_VOYAGE';
	BoatName				= 'UT_VESSEL';
	PortName				= "NZAKL";
	ContainerName1			= 'UTXT000001';
	ContainerName2			= 'UTXT000002';
	ContainerName3			= 'UTXT000003';
	ContainerName4			= 'UTXT000004';
	ContainerName5			= 'UTXT000005';
	BlockStackName			= 'BS26728';
	CamGroup 				= "UT-STD";
	CamProtocol 			= "UT_STD_COARRI";
	CamProtocol2 			= "UT_STD_COARRI2";
	SenderCode 				= "UT_SENDER";
	SenderCodeDepot 		= "UT_SENDERDEPOT";
	ShipperCode 			= "UT_SHIPPER";
	FacilityCode 			= "UT_FACILITY";
	RecipientCode 			= "UT_RECIPIENT";
vars
	runDateTime 		: TimeStamp;
	tempStr				: String;
	idx 				: Integer;
	container1, 
	container2, 
	container3, 
	container4, 
	container5 			: CM_Container;
	operator 			: CM_Operator;
	operatorMSK 		: CM_Operator;
	voyage1 			: CM_Voyage;
	defaultVoyage 		: CM_Voyage;
	passport 			: CM_Passport;
	bs 					: CM_BlockStack;
	startDateTime 		: TimeStamp;
	endDateTime 		: TimeStamp;
	camGroup 			: CM_CamGroup;
	camProtocol 		: CM_CamProtocol;
	camTaskHistory 		: CM_CamTaskHistory;
	operatorDict 		: CM_OperatorByCodeDict;
	freightForwarders 	: CM_ConsigneeConsignorSet;
	port 				: CM_Port;
	theSlot 			: CM_LocationsController;
	strs 				: StringArray;
	crane				: CM_Machine;
	strArray 			: HugeStringArray; //jlgka1 TFS 44020
begin
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	operatorMSK := self.getOperator('MSK');
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	self.deleteEDIInwardXlation(ForeignVoyageCodeUTOP1, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageName1, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIInwardXlation(ForeignVoyageCodeMSK1, XLATION_TYPE_VOYAGETERMINAL, operatorMSK, null);
	self.deleteEDIOutwardXlation(VoyageName1, XLATION_TYPE_VOYAGETERMINAL, operator, null);

	self.deleteVoyage(VoyageName1);
	voyage1 := self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage1);
	voyage1 := self.createVesselVoyage( VoyageName1,BoatName, operatorMSK);

	self.createEDIXlation(ForeignVoyageCodeUTOP1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );	
	self.createEDIXlation(ForeignVoyageCodeUTOP1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);

	self.createEDIXlation(ForeignVoyageCodeMSK1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, true, operatorMSK, null );	
	self.createEDIXlation(ForeignVoyageCodeMSK1, VoyageName1, XLATION_TYPE_VOYAGETERMINAL, false, operatorMSK, null);

//	self.createEDIXlation(ForeignVoyageCodeUTOP, VoyageName, XLATION_TYPE_VOYAGETERMINAL, true, operator, null);
//	self.createEDIXlation(ForeignVoyageCodeMSK, VoyageName, XLATION_TYPE_VOYAGETERMINAL, true, operatorMSK, null);
	
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage1.findLocation(strs, false, theSlot, idx);
	container3 := self.addContainerAtLocnDisch(ContainerName3, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage1);
	self.assertTrueMsg((container3.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container3.setLoadPort ("NZWEL");
	container3.setSealNumCustoms("CUST003");
	container3.setSealNumOperators("OPER003");
	container3.setSealNumShippers("SHIP003");
	container3.setSealNumVent("VENT003");
	commitTransaction;
	create strArray transient;
	strArray.add("USER1003");
	strArray.add("USER2003");
	strArray.add("USER3003");
	self.addSealTI(strArray, container3, "MATSEAL");
	// ### 20 REEFERS
	strs.clear;
	strs.add("030684");
	voyage1.findLocation(strs, false, theSlot, idx);
	container4 := self.addContainerAtLocnDisch(ContainerName4, "2232", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage1);
	self.assertTrueMsg((container4.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container4.setLoadPort ("NZLYT");
	container4.setSealNumCustoms("CUST004");
	container4.setSealNumOperators("OPER004");
	container4.setSealNumShippers("SHIP004");
	container4.setSealNumVent("VENT004");
	commitTransaction;
	strArray.clear;
	strArray.add("USER1004");
	strArray.add("USER2004");
	strArray.add("USER3004");
	self.addSealTI(strArray, container4, "MATSEAL");
	// create on-site cargo
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull(port);

	// ### 20 MT
	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage1);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	beginTransaction;
	container1.setDestinationPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	container2 := self.addContainerAtLocnDisch(ContainerName2, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage1);
	
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage1.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.createVoyageDischargeJobs (voyage1, crane.id);
	self.createVoyageLoadJobs(voyage1, PortName, crane.id);
	self.planLoadItems(voyage1, crane.id);
	self.loadAllJobsToOps(voyage1, true);
	self.planDischargeItems(voyage1, bs, crane.id);
	self.moveAllCargo(voyage1);
	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operatorMSK);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	self.opts.addAssoc("useVoyageOp", true);
	camProtocol	:= self.createCamProtocolCoarri (CamProtocol, camGroup, "STANDARD COARRI SMDG162", "NZCHC", operator.code);
	
	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	self.zCheckOutput (camProtocol, camTaskHistory, self.zCoarri_STANDARD);	// par 29517
	
epilog
	delete operatorDict;
	delete freightForwarders;
	delete strs;
	app.setIsBackGroundApp (false);
	delete strArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="tAATOneStopAperak" id="90c13ea5-e55b-4f78-985a-b7b1e9de7fe2">
        <source>tAATOneStopAperak();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2016	cnwndl1	Initial creation	TFS 2276 / 2565

*/

constants

	CamGroup : String = "UT_OSAP";
	CamProtocol : String = "UT_OneStopAper";
	SenderCode : String = "UT_SENDER";
	SenderCodeDepot : String = "UT_SENDERDEPOT";
	ShipperCode : String = "UT_SHIPPER";
	FacilityCode : String = "UT_FACILITY";
	RecipientCode : String = "UT_RECIPIENT";
	OperatorCode : String = "UTOP";
	VoyageCode1 : String = "UT_TATVOY";
	
vars

	camOneStopAper : CM_CamOneStopAPERAK;
	camGroup : CM_CamGroup;
	operatorDict : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
	camProtocol : CM_CamProtocol;
	operator : CM_Operator;
	camProtocolDesc :CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	registeredCargoTypes : IntegerArray;
	camEventTypes : CM_EventTypeByNameDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camTaskHistory : CM_CamTaskHistory;
	ediFile	:CM_EDIFile;
	filesToDelete : CM_EDIFileSet;
	tiId : String;
	runDateTime : TimeStamp;
begin

	startDateTime := app.actualTimeServer;

	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	create camEditTriggerFields transient;
	create camEventTypes transient;
	camEventTypes.add( app.myRoot.allEventTypesByType [EVT_EDIFileReceived] );
	
	create operatorDict transient;
	create freightForwarders transient;
	create registeredCargoTypes transient;
	create registeredTransactions transient;
	create filesToDelete transient;
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocolDesc := CM_CamOneStopAPERAK.firstInstance;
	camProtocol	:= self.createCamProtocol(CamProtocol, camGroup, "NZCHC", operator.code, camProtocolDesc, false, false, false, registeredTransactions, registeredCargoTypes, camEventTypes, camEditTriggerFields, null );	
	
	ediFile := self.zReceiveAOneStopXMLPrenote(1,tiId,VoyageCode1);
	self.assertTrueMsg( ediFile &lt;&gt; null, app.myPassport.getErrorsAndWarningsAsString.trimBlanks &amp; " - test 1");
	filesToDelete.add( ediFile );
	
	beginTransaction;
	camProtocolDesc.setTransmissionNumber(10);
	camProtocol.setPropertyValue(CM_CamProtocol::specialFileName.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::isSingleTransPerFile.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::fileSuffix.name, "csv");
	commitTransaction;
	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	runDateTime := app.actualTimeServer;
	app.setIsBackGroundApp (true);
	
//	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	self.runCamsNow(startDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

epilog

	delete operatorDict;
	delete freightForwarders;
    delete registeredTransactions;
	delete registeredCargoTypes;
	
	delete camEventTypes;
	app.setIsBackGroundApp (false);
	delete camEditTriggerFields;
	
	//clean up the successfull ones from the EDI Operations Form.... ( cos these ones were from successfull tests )
	foreach ediFile in filesToDelete do
		if ediFile.ediData &lt;&gt; null then
			app.myTrxDA.trxDeleteEDIData(ediFile.ediData, app.myPassport);
		endif;
	endforeach;

	delete filesToDelete;

end;</source>
    </JadeMethod>
    <JadeMethod name="tAATOneStopCamsXML" id="6fdc7084-5b58-448c-8045-bfc41055d549">
        <source>tAATOneStopCamsXML();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/08/2016	cnwndl1	Initial creation	TFS 2277 / 2561
19/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
17/05/2023	jlika1	TFS 56398 EUP - OUT - Overlanded Cargo Handling - Web
*/

constants

	BlockStackId1 : String = "UTOBS1";
	CamGroup : String = "UT_OSCG";
	CamProtocol : String = "UT_OneStopXML";
	SenderCode : String = "UT_SENDER";
	SenderCodeDepot : String = "UT_SENDERDEPOT";
	ShipperCode : String = "UT_SHIPPER";
	FacilityCode : String = "UT_FACILITY";
	RecipientCode : String = "UT_RECIPIENT";
	OperatorCode : String = "UTOP";
	TiId1 : String = "UTOS1234567";
	TiId2 : String = "UTOS1234568";
	TiId3 : String = "UTOS1234569";
	TiId4 : String = "UTOS1234570";
	TiId5 : String = "UTOS1234571";
	TiId6 : String = "UTOSBYQ006";
	TiId7 : String = "UTOS1234572";
	ForeignOperatorCode1 : String = "TRANSOPOUT";
	DelBlockStackId : String = "UTDELBOY";
	BOLid1 : String = "UTBOLOUTTURN";
	BOLid2 : String = "UTBOLOUTTURN2";
	BOLid3 : String = "UTBOLOUTTURN3";
	BOLid4 : String = "UTBOLOUTTURN4";
	BOLid5 : String = "UTBOLOUTTURN5";
	BOLid6 : String = "UTBOLOUTTURN6";
	BOLid7 : String = "UTBOLOUTTURN7";
	TyreId1 : String = "Tyre001";
	TyreId2 : String = "Tyre002";
	TyreId3 : String = "Tyre003";
	TyreId4 : String = "Tyre004";
	TyreId5 : String = "Tyre005";
	TyreId6 : String = "Tyre006";
	TyreId7 : String = "Tyre007";

vars

	camOneStopXML : CM_CamOneStopXML;
	camGroup : CM_CamGroup;
	operatorDict : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
	camProtocol : CM_CamProtocol;
	operator : CM_Operator;
	camProtocolDesc :CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	registeredCargoTypes : IntegerArray;
	camEventTypes : CM_EventTypeByNameDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camTaskHistory : CM_CamTaskHistory;
	index : Integer;
	bs1 : CM_BlockStack;
	ti1 : CM_TrackedItem;
	ti2 : CM_TrackedItem;
	ti3 : CM_TrackedItem;
	ti4 : CM_TrackedItem;
	ti6 : CM_TrackedItem;
	ti7 : CM_TrackedItem;
	voyEvent : CMEVT_VoyageEvent;
	term : CM_Terminal;
	voyage : CM_Voyage;
	eventType : CM_EventType;
	voyEventType : CM_EventType;
	fileOutputAsStr : String;
	xmlDoc  : JadeXMLDocument;
	xmlElement  : JadeXMLElement;
	fileName : String;
	expectedFileName : String;
	cannon : CM_TrackedItem;
	xmlCTElement  : JadeXMLElement;
	foreignVoyageCode : String;
	inForeignCode : String;
	xmlVoyElement : JadeXMLElement;
	runDateTime : TimeStamp;
	camEditTriggerField : CM_CamEditTriggerField;
	xmlCargoElement : JadeXMLElement;							// TFS 4492
	delBS : CM_BlockStack;
	cargoIdStr : String;
	
	baseId : String;
	startAt : Integer;
	endAt : Integer;
	int : Integer;
	findId : String;
	roroLCs : CM_LCArray;
	roroLC : CM_ROROGCController;
	voyageJob : CM_VoyageJob;
	theDeck : CM_DeckVoyage;
	wlesToMove : CM_WLEArray;
	wlesWithWarnings : CM_WLEArray;
	bol1 : CM_BOL;
	bol2 : CM_BOL;
	bol3 : CM_BOL;
	bol4 : CM_BOL;
	bol5 : CM_BOL;
	bol6 : CM_BOL;
	bol7 : CM_BOL;
	tyre : CM_TrackedItem;
	utByQCargoType : CM_CargoType;
	portHere : CM_Port;
	portLoad : CM_Port;
	tis : CM_TIArray;
	tiToSplit : CM_Cargo;
	dummyVoyage : CM_Voyage;
	wasNull : Boolean;
	xmlArray : JadeXMLElementArray;
	cmifEventCtrl : CMIF_VoyageEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin

	create xmlArray transient;

	startDateTime := app.actualTimeServer;

	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	self.deleteTerminalArea(BlockStackId1);
	self.deleteTerminalArea(DelBlockStackId);
	self.deleteBOL( BOLid1, null );	//25 Oct 2017	NDL	TFS 6940
	self.deleteBOL( BOLid2, null );
	self.deleteBOL( BOLid3, null );
	self.deleteBOL( BOLid4, null );
	self.deleteBOL( BOLid5, null );
	self.deleteBOL( BOLid6, null );
	self.deleteBOL( BOLid7, null );
	
	utByQCargoType := getRoot.getCargoTypeFromAbbrevOrDescr( "UTBYQ" );
	self.assertTrueMsg( utByQCargoType &lt;&gt; null, "'UTBYQ' Cargo type not found.");
	
	deleteCargo( TyreId1, TI_CargoType_BreakBulk );
	deleteCargo( TyreId2, TI_CargoType_BreakBulk );
	deleteCargo( TyreId3, TI_CargoType_BreakBulk );
	deleteCargo( TyreId4, TI_CargoType_BreakBulk );
	deleteCargo( TyreId5, TI_CargoType_BreakBulk );
	deleteCargo( TyreId6, TI_CargoType_BreakBulk );
	deleteCargo( TyreId7, TI_CargoType_BreakBulk );
	deleteCargo( TiId6, utByQCargoType.id );
	deleteCargo( TiId7, TI_CargoType_Container );
	
	bs1 := self.addBlockStack(BlockStackId1, 99, null);
	
	//04 Aug 2017	NDL	TFS 5679
	//Set up a logical delete area, make it so it wants to generate logical delete trxs
	delBS := self.addLogicalDelArea(DelBlockStackId, true);
	
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	process.sleep(1000);
	
	ti4 := self.addContainerAtLocation(TiId4, operator, "2200", "MT", TI_IMEX_STATUS_EXPORT, bs1);
	ti3 := self.addContainerAtLocation(TiId3, operator, "2200", "MT", TI_IMEX_STATUS_IMPORT, bs1);
	ti2 := self.addContainerAtLocation(TiId1, operator, "2200", "MT", TI_IMEX_STATUS_STORAGE, bs1);
	ti1 := self.addContainerAtLocation(TiId2, operator, "2200", "MT", TI_IMEX_STATUS_STORAGE, bs1);
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	cannon := self.addCannonAtLocation(TiId3, operator, bs1);
	
	create camEditTriggerFields transient;
	camEditTriggerField := CM_CamUserDefRepDesc.firstInstance.allCamEditTriggerFields['Integer', CM_TrackedItem::imexStatus.name];
	if camEditTriggerField = null then
		beginTransaction;
		create camEditTriggerField;
		camEditTriggerField.set(CM_TrackedItem::imexStatus.name, true, "Integer", CM_TrackedItem.name);
		camEditTriggerField.setNonSystemAttributes("Imex Status", null, null);
		camEditTriggerField.setCamUserDefRepDesc( CM_CamUserDefRepDesc.firstInstance );	
		commitTransaction;
	endif;
	camEditTriggerFields.add( camEditTriggerField );
	
	create operatorDict transient;
	create freightForwarders transient;
	
	create camEventTypes transient;
	//camEventTypes.add( app.myRoot.allEventTypesByType[10383] );  //This is a user defined voyage event  called UT_ET2
	foreach eventType in app.myRoot.allEventTypesByType do
		if eventType.name = "UT_ET2" then
			voyEventType := eventType;
			camEventTypes.add( eventType );
		elseif eventType.type = EVT_VoyBolOutturnReq then
			camEventTypes.add( eventType );
		endif;
	endforeach;
	
	create registeredCargoTypes transient;
	registeredCargoTypes.add(1);
	registeredCargoTypes.add(cannon.cargoType);
	
    create registeredTransactions transient;
	registeredTransactions.add(TRANS_TYPE_RELEASE.asStringJMT);
	registeredTransactions.add(TRANS_TYPE_RECEIVE.asStringJMT);
	registeredTransactions.add(TRANS_TYPE_REC_RAIL.asStringJMT);
	registeredTransactions.add(TRANS_TYPE_REC_ROAD.asStringJMT);
	registeredTransactions.add(TRANS_TYPE_REC_SHIP.asStringJMT);
	registeredTransactions.add(TRANS_TYPE_REC_TRANSHIP.asStringJMT);
	registeredTransactions.add(TRANS_TYPE_RELEASE.asStringJMT);
	registeredTransactions.add(TRANS_TYPE_REL_RAIL.asStringJMT);
	registeredTransactions.add(TRANS_TYPE_REL_ROAD.asStringJMT);
	registeredTransactions.add(TRANS_TYPE_REL_SHIP.asStringJMT);
	registeredTransactions.add(TRANS_TYPE_MOVE.asStringJMT);
	registeredTransactions.add(TRANS_TYPE_MOVE_PICKUP.asStringJMT);
	registeredTransactions.add(TRANS_TYPE_MOVE_SETDOWN.asStringJMT);
	registeredTransactions.add(TRANS_TYPE_CREATED.asStringJMT);
	registeredTransactions.add(TRANS_TYPE_EDIT.asStringJMT);	//28 Jun 2017	NDL	TFS 5170
	registeredTransactions.add(TRANS_TYPE_Logical_Delete.asStringJMT);	//04 Aug 2017	NDL	TFS 5679
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	
	operatorDict.add(operator);
	operatorDict.add( app.myRoot.allOperators["MSK"] );
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	term := self.getTerminal();
	voyage	:= self.getVoyage("UT_TATVOY");
	beginTransaction;
	voyage.setDepartureDT(null);
	
	/* //17/02/2025	navkc1 JIRA Bug MTN-33582
	voyEvent := app.createEvent(voyEventType.type, app.actualTimeServer, term, app.myPassport.userCode, false, false,0).CMEVT_VoyageEvent;
	voyEvent.setMyVoyage(voyage);
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582
	create cmifEventCtrl transient;
	cmifEventCtrl.type := voyEventType.type;
	cmifEventCtrl.dateTime := app.actualTimeServer();
	cmifEventCtrl.myTerminal := term;
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myVoyage := voyage;
	
	voyEvent := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_VoyageEvent;
	//17/02/2025	navkc1 JIRA Bug MTN-33582
	
	ti2.zSetImportVoyage(voyage);
	ti1.zSetImportVoyage(voyage);
	cannon.zSetImportVoyage(voyage);
	ti3.setPropertyValue("myVoyage",voyage);
	ti4.setPropertyValue("myVoyage",voyage);
	ti2.setPropertyValue("myVoyage",voyage);
	ti1.setPropertyValue("myVoyage",voyage);
	cannon.setPropertyValue("myVoyage",voyage);
	ti1.setMyVGMDetails(	"JAMES LAST", "JAMES EARL JONES", "JAMES LAST", 					// TFS 4492
						"SM1", "UTOS1234567-DOC1", null, "JLAST@COUNTBASSIE.COM",			// TFS 4492
						"123 STREET" &amp; Cr &amp; "CITY" &amp; Cr &amp; "COUNTRY", "+64212258133", null, 					// TFS 4492
						"+6433652500", "21/05/2017 14:30".TimeStamp, 						// TFS 4492
						"21/05/2017 09:30".TimeStamp, null	);								// TFS 4492
	commitTransaction;
	
	//add 2 hazards
	self.addTIHazard(ti2, "1.0", false);
	self.addTIHazard(ti2, '1.2', false);
	
	//21 Mar 2017	NDL	TFS 3710 - Voyage translation
	foreignVoyageCode := "1YOVTAT_TU";
	inForeignCode := "2YOVTAT_TU";
	self.deleteEDIInwardXlation(foreignVoyageCode, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(voyage.code, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	
	self.deleteEDIInwardXlation(inForeignCode, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(voyage.inwardCode, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	
	self.deleteEDIInwardXlation (ForeignOperatorCode1, XLATION_TYPE_OPERATOR_BYOP, operator, null);	//12 Jun 2017	NDL	TFS 4751
	self.deleteEDIOutwardXlation (ForeignOperatorCode1, XLATION_TYPE_OPERATOR_BYOP, operator, null);	//12 Jun 2017	NDL	TFS 4751
	
	self.createEDIXlation(foreignVoyageCode, voyage.code, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );	
	
	dummyVoyage := term.lookupVoyage(voyage.inwardCode, null, true);
	self.assertTrueMsg( dummyVoyage &lt;&gt; null, "WTF! 'dummyVoyage' not found from inwardCode AND wasNull = " &amp; wasNull.String);
	
	
	self.createEDIXlation(inForeignCode, voyage.inwardCode, XLATION_TYPE_VOYAGETERMINAL, true, operator, null );	
	self.createEDIXlation(ForeignOperatorCode1, operator.code, XLATION_TYPE_OPERATOR_BYOP, true, operator, null);	//12 Jun 2017	NDL	TFS 4751
			
	camProtocolDesc := CM_CamOneStopXML.firstInstance;
	camProtocol	:= self.createCamProtocol(CamProtocol, camGroup, "NZCHC", operator.code, camProtocolDesc, false, false, false, registeredTransactions, registeredCargoTypes, camEventTypes, camEditTriggerFields,null);	
	
	beginTransaction;
	camProtocolDesc.setTransmissionNumber(10);
	camProtocol.setPropertyValue(CM_CamProtocol::specialFileName.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::isSingleTransPerFile.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::fileSuffix.name, "XML");
	commitTransaction;
	
	self.opts.purge();
	self.opts.addAssoc('IMEXStatus',TI_IMEX_STATUS_EXPORT);
	self.updateTI(ti1);
	
	//04 Aug 2017	NDL	TFS 5679
	//Move an Export to logical delete
	self.move(ti4, delBS);
	// Create and move an Import to logical delete
	self.move(ti3, delBS);
	
	//25 Oct 2017	NDL	TFS 6940
	if not voyage.allBOLInByTypeStatusNumDT.isEmpty then
		bol1 := voyage.allBOLInByTypeStatusNumDT.getFirstWithNumber( BOLid1 );
		bol2 := voyage.allBOLInByTypeStatusNumDT.getFirstWithNumber( BOLid2 );
		bol3 := voyage.allBOLInByTypeStatusNumDT.getFirstWithNumber( BOLid3 );
		bol4 := voyage.allBOLInByTypeStatusNumDT.getFirstWithNumber( BOLid4 );
		bol5 := voyage.allBOLInByTypeStatusNumDT.getFirstWithNumber( BOLid5 );
		bol6 := voyage.allBOLInByTypeStatusNumDT.getFirstWithNumber( BOLid6 );
		bol7 := voyage.allBOLInByTypeStatusNumDT.getFirstWithNumber( BOLid7 );
	endif;
	if bol1 = null then
		bol1 := self.addBOL(BOLid1, voyage, operator, null, term );
	endif;
	if bol2 = null then
		bol2 := self.addBOL(BOLid2, voyage, operator, null, term );
	endif;
	if bol3 = null then
		bol3 := self.addBOL(BOLid3, voyage, operator, null, term );
	endif;
	if bol4 = null then
		bol4 := self.addBOL(BOLid4, voyage, operator, null, term );
	endif;
	if bol5 = null then
		bol5 := self.addBOL(BOLid5, voyage, operator, null, term );
	endif;
	if bol6 = null then
		bol6 := self.addBOL(BOLid6, voyage, operator, null, term );
	endif;
	if bol7 = null then
		bol7 := self.addBOL(BOLid7, voyage, operator, null, term );
	endif;
	
	beginTransaction;
	
	/* //17/02/2025	navkc1 JIRA Bug MTN-33582
	voyEvent := app.createEvent( EVT_VoyBolOutturnReq, app.actualTimeServer, term, app.myPassport.userCode, false, false,0).CMEVT_VoyageEvent;
	voyEvent.setMyVoyage(voyage);
	voyEvent.setMyBol(bol1);
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
	delete cmifEventCtrl;
	create cmifEventCtrl transient;
	cmifEventCtrl.type := EVT_VoyBolOutturnReq;
	cmifEventCtrl.dateTime := app.actualTimeServer();
	cmifEventCtrl.myTerminal := term;
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myVoyage := voyage;
	cmifEventCtrl.myBOL := bol1;
	
	voyEvent := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_VoyageEvent;
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
	
	/* //17/02/2025	navkc1 JIRA Bug MTN-33582
	voyEvent := app.createEvent( EVT_VoyBolOutturnReq, app.actualTimeServer, term, app.myPassport.userCode, false, false,0).CMEVT_VoyageEvent;
	voyEvent.setMyVoyage(voyage);
	voyEvent.setMyBol(bol2);
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
	delete cmifEventCtrl;
	create cmifEventCtrl transient;
	cmifEventCtrl.type := EVT_VoyBolOutturnReq;
	cmifEventCtrl.dateTime := app.actualTimeServer();
	cmifEventCtrl.myTerminal := term;
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myVoyage := voyage;
	cmifEventCtrl.myBOL := bol2;
	
	voyEvent := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_VoyageEvent;
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
	commitTransaction;
	
	
	//07 Aug 2017	TFS 5701
	//Find the first available cannon starting from "CANN1112253" 53-83 They will be Remain On Board
	baseId := "CANN11122";
	startAt := 53;
	endAt := 83;
	foreach int in startAt to endAt do
		findId := baseId &amp; int.String;
		ti1 := voyage.allOnshipTIsByIdCargoType.getAtKeyGeq( findId, null );
		if ti1 &lt;&gt; null and ti1.id = findId then
			//got one, change it to import and bring it ashore
			self.opts.purge();
			self.opts.addAssoc(UTTI_BOL, BOLid1);
			self.opts.addAssoc('IMEXStatus',TI_IMEX_STATUS_IMPORT);
			self.updateTI(ti1);
			
			create roroLCs transient;
			theDeck := voyage.myROROStructure.allDecksByCode[DECK1];
			self.assertTrueMsg( theDeck &lt;&gt; null, "Deck not found");
			roroLC := theDeck.allROROGCControllers.getAtKey(0,"DD1003G"); 
			self.assertTrueMsg( roroLC &lt;&gt; null, "RORO Location not found");
			if roroLC.myRORORequestDischarge = null then
				roroLCs.add( roroLC );
				beginTransaction;
				roroLC.createDefaultDischargeCC(app.myPassport, true);
				commitTransaction;
				voyageJob := self.addVoyageROROJob( voyage, theDeck, "OUTURN", roroLCs, true );
				self.assertTrueMsg( voyageJob &lt;&gt; null, "Deck not found");
			endif;
			
			create wlesToMove transient;
			create wlesWithWarnings transient;
			self.assertTrueMsg( not ti1.allWorklistEntries.isEmpty, "No WLE found for " &amp; ti1.id );
			wlesToMove.add(ti1.allWorklistEntries.first);		
			app.myTrxUA.trxUpdateWLEsDoMove(wlesToMove, wlesWithWarnings, REAL_MODE, false, null, app.myPassport);
			
			if ti1.isOnShip and ti1.isQueued then
				self.moveBreakBulk( ti1, ti1.myPrimaryQueuedLocation, ti1.totalQuantity );
			endif;
			
			//now add a discrepancy
			app.myTrxUA.trxBreakBulkOverage(ti1, self.class.name, ti1.totalQuantity * 3 , ti1.totalWeight * 3, 0, 0, method.qualifiedName, false, false, false, app.myPassport);
		
			//now create an OUTTURN trx
		//	self.createTransaction( ti, global.getTiTxnTypeForClass(CM_Outturn), null );
			
			startAt := int + 1;
			break;
		endif;
		
	endforeach;
	
	//Do the next one to the 2nd BOL
	foreach int in startAt to endAt do
		findId := baseId &amp; int.String;
		ti1 := voyage.allOnshipTIsByIdCargoType.getAtKeyGeq( findId, null );
		if ti1 &lt;&gt; null and ti1.id = findId then
			//got one, change it to import and bring it ashore
			self.opts.purge();
			self.opts.addAssoc(UTTI_BOL, BOLid2);
			self.opts.addAssoc('IMEXStatus',TI_IMEX_STATUS_IMPORT);
			self.updateTI(ti1);
			
			
			wlesToMove.clear();
			wlesWithWarnings.clear();
			self.assertTrueMsg( not ti1.allWorklistEntries.isEmpty, "No WLE found for " &amp; ti1.id );
			wlesToMove.add(ti1.allWorklistEntries.first);		
			app.myTrxUA.trxUpdateWLEsDoMove(wlesToMove, wlesWithWarnings, REAL_MODE, false, null, app.myPassport);
			
			if ti1.isOnShip and ti1.isQueued then
				self.moveBreakBulk( ti1, ti1.myPrimaryQueuedLocation, ti1.totalQuantity );
			endif;
			
			//now add a discrepancy
			app.myTrxUA.trxBreakBulkOverage(ti1, self.class.name, ti1.totalQuantity * 3 , ti1.totalWeight * 3, 0, 0, method.qualifiedName, false, false, false, app.myPassport);
		
			break;
		endif;
		
	endforeach;
	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	
	runDateTime := app.actualTimeServer;
//	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	self.runCamsNow(startDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	
	//16 Feb 2017	NDL	TFS 3454 - New data for 'PlaceOfEvent' and 'SenderID' tag sets.
	fileOutputAsStr := camTaskHistory.getRawDataString();
	create xmlDoc transient;
	xmlDoc.parseString( fileOutputAsStr );
	xmlElement := xmlDoc.getElementByTagName(CM_CamOneStopXML.XMLTag_PlaceOfEvent);
	self.assertTrueMsg( xmlElement &lt;&gt; null, "XML tag 'PlaceOfEvent' not found");
	self.assertTrueMsg( xmlElement.textData = FacilityCode, "Incorrect value for 'PlaceOfEvent'");
	xmlElement := xmlDoc.getElementByTagName(CM_CamOneStopXML.XMLTag_SenderID);
	self.assertTrueMsg( xmlElement &lt;&gt; null, "XML tag 'SenderID' not found");
	self.assertTrueMsg( xmlElement.textData = SenderCode, "Incorrect value for 'SenderID'");
	delete xmlDoc;
	
	//16 Feb 2017	NDL	TFS 3454 - Specific file name formatting.
	index := 0;
	foreach camTaskHistory in camProtocol.taskHistoryByProtocolSeq do
		fileName := camTaskHistory.fileName;
		index := index + 1;
		create xmlDoc transient;
		fileOutputAsStr := camTaskHistory.getRawDataString();
		if fileOutputAsStr &lt;&gt; null then
			xmlDoc.parseString( fileOutputAsStr );
			xmlElement := xmlDoc.getElementByTagName(CM_CamOneStopXML.XMLTag_EventType);
			xmlCTElement := null;
			xmlCTElement := xmlDoc.findElementByTagName(CM_CamOneStopXML.XMLTag_CargoType);
			xmlVoyElement := xmlDoc.findElementByTagName('SOP_VoyageInBound');
			if ( xmlCTElement &lt;&gt; null and xmlCTElement.textData = 'N' ) then
				self.assertTrueMsg( xmlVoyElement.text = inForeignCode, "Voyage failed to translate (" &amp; xmlVoyElement.text &amp; ") " &amp; index.String);
				if index &gt; 9 then
					//only expecting 8 items from this test, but if other users are playing in paralell we can get extra data.
					expectedFileName := "BB_CARGO_" &amp; xmlElement.textData &amp; "_00" &amp; index.String &amp; ".xml";
				else
					expectedFileName := "BB_CARGO_" &amp; xmlElement.textData &amp; "_000" &amp; index.String &amp; ".xml";
				endif;
			else
				if index &gt; 9 then
					//only expecting 8 items from this test, but if other users are playing in paralell we can get extra data.
					expectedFileName := "CARGO_" &amp; xmlElement.textData &amp; "_00" &amp; index.String &amp; ".xml";
				else
					expectedFileName := "CARGO_" &amp; xmlElement.textData &amp; "_000" &amp; index.String &amp; ".xml";
				endif;
				//12 Jun 2017	NDL	TFS 4751
				xmlElement := xmlDoc.getElementByTagName("JMTTransClass");
				if xmlElement &lt;&gt; null and xmlElement.textData = "CMEVT_VoyageEvent" then
					delete xmlDoc;
					continue;
				endif;
				
				//04 Aug 2017	NDL	TFS 5679
				xmlCargoElement := xmlDoc.getElementByTagName("CargoNumber"); 
				cargoIdStr := xmlCargoElement.textData;
				
				xmlElement := xmlDoc.getElementByTagName("LineOperatorCode");
				self.assertTrueMsg( xmlElement &lt;&gt; null, "XML tag 'LineOperatorCode' not found " &amp; cargoIdStr);
				self.assertTrueMsg( xmlElement.textData = ForeignOperatorCode1, "Operator not translated going out. " &amp; cargoIdStr);
				
		//		xmlCargoElement := xmlDoc.getElementByTagName("CargoNumber"); 														// TFS 4492
				if cargoIdStr = TiId1 then	//24 Oct 2019	NDL	TFS 46293
					xmlElement := xmlDoc.getElementByTagName("HazardousInformation");
					self.assertTrueMsg(xmlElement &lt;&gt; null, "XML tag 'HazardousInformation' not found for TiId1 [" &amp; TiId1 &amp; "]");
					xmlArray.clear;
					xmlDoc.getElementsByTagName("HazardousInformation", xmlArray);
					self.assertTrueMsg(xmlArray.size = 2, "Should be 2 'HazardousInformation' tags for TiId1 [" &amp; TiId1 &amp; "]");
					
				elseif cargoIdStr = TiId2 then																			// TFS 4492
					xmlElement := xmlDoc.getElementByTagName("MethodOfWeightCalculation");											// TFS 4492
					self.assertTrueMsg(xmlElement &lt;&gt; null, "XML tag 'MethodOfWeightCalculation' not found");						// TFS 4492
					self.assertTrueMsg(xmlElement.textData = "SM1", "MethodOfWeightCalculation should be SM1");						// TFS 4492
					xmlElement := xmlDoc.getElementByTagName("WeightVerificationDate");												// TFS 4492
					self.assertTrueMsg(xmlElement &lt;&gt; null, "XML tag 'WeightVerificationDate' not found");							// TFS 4492
					self.assertTrueMsg(xmlElement.textData = "20170520213000", "WeightVerificationDate should be 21/05/2017 14:30");// TFS 4492
					xmlElement := xmlDoc.getElementByTagName("Street");																// TFS 4492
					self.assertTrueMsg(xmlElement &lt;&gt; null, "XML tag 'Street' not found");											// TFS 4492
					self.assertTrueMsg(xmlElement.textData = "123 STREET", "Street should be 123 STREET");							// TFS 4492
					xmlElement := xmlDoc.getElementByTagName("City");																// TFS 4492
					self.assertTrueMsg(xmlElement &lt;&gt; null, "XML tag 'City' not found");												// TFS 4492
					self.assertTrueMsg(xmlElement.textData = "CITY", "City should be CITY");										// TFS 4492
					xmlElement := xmlDoc.getElementByTagName("Country");															// TFS 4492
					self.assertTrueMsg(xmlElement &lt;&gt; null, "XML tag 'Country' not found");											// TFS 4492
					self.assertTrueMsg(xmlElement.textData = "COUNTRY", "Country should be COUNTRY");								// TFS 4492
					
					xmlElement := xmlDoc.getElementByTagName("HazardousInformation");
					self.assertTrueMsg(xmlElement &lt;&gt; null, "XML tag 'HazardousInformation' not found for TiId2 [" &amp; TiId2 &amp; "]");
					xmlArray.clear;
					xmlDoc.getElementsByTagName("HazardousInformation", xmlArray);
					self.assertTrueMsg(xmlArray.size = 1, "Should be 1 'HazardousInformation' tags for TiId2 [" &amp; TiId2 &amp; "]");
					
				endif;																												// TFS 4492
				
			endif;
			delete xmlDoc;
			self.assertTrueMsg( fileName = expectedFileName, "Incorrect file name for item " &amp; index.String);
		endif;
	endforeach;
	
	//Do new OUTTURN requirements testing related to TFS 8165 - 09 Jan 2018
	portHere := app.myRoot.allPorts[term.getConfig(PortDestCode).String];
	foreach portLoad in voyage.allPorts do
		if portLoad.code[1:2] &lt;&gt; portHere.code[1:2] then
			//so its been loaded in a different country
			break;
		endif;
	endforeach;
	
	//Add 3 tyres to Bol3 and discharge all 3 - should be no packages, NILL discrepancy
	tyre := self.addCargoForVoyage(voyage, TyreId1);
	self.opts.purge();
	self.opts.addAssoc(UTTI_BOL, BOLid3);
	self.opts.addAssoc('IMEXStatus',TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc('LoadPort', portLoad.code);
	self.updateTI(tyre);
	self.moveBreakBulk( tyre, bs1, tyre.totalQuantity );
	
	tyre := self.addCargoForVoyage(voyage, TyreId2);
	self.opts.purge();
	self.opts.addAssoc(UTTI_BOL, BOLid3);
	self.opts.addAssoc('IMEXStatus',TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc('LoadPort', portLoad.code);
	self.updateTI(tyre);
	self.moveBreakBulk( tyre, bs1, tyre.totalQuantity );
	
	tyre := self.addCargoForVoyage(voyage, TyreId3);
	self.opts.purge();
	self.opts.addAssoc(UTTI_BOL, BOLid3);
	self.opts.addAssoc('IMEXStatus',TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc('LoadPort', portLoad.code);
	self.updateTI(tyre);
	self.moveBreakBulk( tyre, bs1, tyre.totalQuantity );
	
	//Add 2 tyres to Bol4 and discharge only 1 - should be 1 packages, SH discrepancy
	tyre := self.addCargoForVoyage(voyage, TyreId4);
	self.opts.purge();
	self.opts.addAssoc(UTTI_BOL, BOLid4);
	self.opts.addAssoc('IMEXStatus',TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc('LoadPort', portLoad.code);
	self.updateTI(tyre);
	self.moveBreakBulk( tyre, bs1, tyre.totalQuantity );
	
	tyre := self.addCargoForVoyage(voyage, TyreId5);
	self.opts.purge();
	self.opts.addAssoc(UTTI_BOL, BOLid4);
	self.opts.addAssoc('IMEXStatus',TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc('LoadPort', portLoad.code);
	self.updateTI(tyre);
	
	//Add Cargo of 10 to Bol5, discharge then add discrepancy of +3 - should be 3 packages, SU discrepancy
	self.opts.purge();
	self.opts.addAssoc( "CargoType", utByQCargoType.id.Integer );
	self.opts.addAssoc( "TotalQuantity", "10".Integer );
	ti6 := self.addCargoForVoyage(voyage, TiId6);
	
	//Make underbond...  Ports the same country and Tranship, received in port
	self.opts.purge();
	self.opts.addAssoc(UTTI_BOL, BOLid5);
	self.opts.addAssoc('IMEXStatus',TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc('LoadPort', portHere.code);
	self.updateTI(ti6);
	self.moveBreakBulk( ti6, bs1, ti6.totalQuantity );
	
	app.myTrxUA.trxBreakBulkOverage(ti6, self.class.name, (ti6.totalQuantity * 1.3).Integer , ti6.totalWeight * 1.3, 0, 0, method.qualifiedName, false, false, false, app.myPassport);
	
	self.opts.purge();
	self.opts.addAssoc('IMEXStatus',TI_IMEX_STATUS_TRANSHIP);
	self.updateTI(ti6);
	beginTransaction;
	ti6.setPropertyValue("myImportVoyage",voyage);
	commitTransaction;
	
	//Add a container to BOL6 not discharged, should be ignored, Add two tyres, transfer one off to Bol7, should result in Bol6 being SH by 1, and Bol7 being SU by 1
	ti7 := self.addContainerOnShip(TiId7, voyage.myOperator, "2200", "GOLD", null, voyage, portHere.code, voyage.code).CM_Container;
	self.opts.purge();
	self.opts.addAssoc(UTTI_BOL, BOLid6);
	self.opts.addAssoc('IMEXStatus',TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc('LoadPort', portLoad.code);
	self.updateTI(ti7);
	
	tyre := self.addCargoForVoyage(voyage, TyreId6);
	self.opts.purge();
	self.opts.addAssoc(UTTI_BOL, BOLid6);
	self.opts.addAssoc('IMEXStatus',TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc('LoadPort', portLoad.code);
	self.updateTI(tyre);
	self.moveBreakBulk( tyre, bs1, tyre.totalQuantity );
	
	tyre := self.addCargoForVoyage(voyage, TyreId7);
	self.opts.purge();
	self.opts.addAssoc(UTTI_BOL, BOLid6);
	self.opts.addAssoc('IMEXStatus',TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc('LoadPort', portLoad.code);
	self.updateTI(tyre);
	self.moveBreakBulk( tyre, bs1, tyre.totalQuantity );
	
	create tis transient;
	tis.add(tyre);
	app.myTrxUA.trxTransferToBOL(	bol7.CM_BOLIn,	//_newBol : CM_BOLIn;
									tyre.myOperator,	//_newOperator : CM_Operator;
									tyre.myConsignee,	//_newConsignee : CM_ConsigneeConsignor
									tis,	//_tis : CM_TIArray;
									tiToSplit,	//_tiToSplit : CM_Cargo 10;
									null,	//_newId : String;
									0.0,	//_splitWeight : Decimal;
									0,	//_splitQuantity : Integer;
									app.myPassport	//_passport : CM_Passport input
									);
	
	process.sleep(5000);
	startDateTime := app.actualTimeServer;
	
	beginTransaction;
	/* //17/02/2025	navkc1 JIRA Bug MTN-33582
	voyEvent := app.createEvent( EVT_VoyBolOutturnReq, app.actualTimeServer, term, app.myPassport.userCode, false, false,0).CMEVT_VoyageEvent;
	voyEvent.setMyVoyage(voyage);
	voyEvent.setMyBol(bol3);
	*/ 
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
	delete cmifEventCtrl;
	create cmifEventCtrl transient;
	cmifEventCtrl.type := EVT_VoyBolOutturnReq;
	cmifEventCtrl.dateTime := app.actualTimeServer();
	cmifEventCtrl.myTerminal := term;
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myVoyage := voyage;
	cmifEventCtrl.myBOL := bol3;
	
	voyEvent := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_VoyageEvent;
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
	
	/* //17/02/2025	navkc1 JIRA Bug MTN-33582
	voyEvent := app.createEvent( EVT_VoyBolOutturnReq, app.actualTimeServer, term, app.myPassport.userCode, false, false,0).CMEVT_VoyageEvent;
	voyEvent.setMyVoyage(voyage);
	voyEvent.setMyBol(bol4);
	*/
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
	delete cmifEventCtrl;
	create cmifEventCtrl transient;
	cmifEventCtrl.type := EVT_VoyBolOutturnReq;
	cmifEventCtrl.dateTime := app.actualTimeServer();
	cmifEventCtrl.myTerminal := term;
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myVoyage := voyage;
	cmifEventCtrl.myBOL := bol4;
	
	voyEvent := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_VoyageEvent;
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
	
	/* //17/02/2025	navkc1 JIRA Bug MTN-33582
	voyEvent := app.createEvent( EVT_VoyBolOutturnReq, app.actualTimeServer, term, app.myPassport.userCode, false, false,0).CMEVT_VoyageEvent;
	voyEvent.setMyVoyage(voyage);
	voyEvent.setMyBol(bol5);
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
	delete cmifEventCtrl;
	create cmifEventCtrl transient;
	cmifEventCtrl.type := EVT_VoyBolOutturnReq;
	cmifEventCtrl.dateTime := app.actualTimeServer();
	cmifEventCtrl.myTerminal := term;
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myVoyage := voyage;
	cmifEventCtrl.myBOL := bol5;
	
	voyEvent := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_VoyageEvent;
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
	
	/* //17/02/2025	navkc1 JIRA Bug MTN-33582
	voyEvent := app.createEvent( EVT_VoyBolOutturnReq, app.actualTimeServer, term, app.myPassport.userCode, false, false,0).CMEVT_VoyageEvent;
	voyEvent.setMyVoyage(voyage);
	voyEvent.setMyBol(bol6);
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
	delete cmifEventCtrl;
	create cmifEventCtrl transient;
	cmifEventCtrl.type := EVT_VoyBolOutturnReq;
	cmifEventCtrl.dateTime := app.actualTimeServer();
	cmifEventCtrl.myTerminal := term;
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myVoyage := voyage;
	cmifEventCtrl.myBOL := bol6;
	
	voyEvent := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_VoyageEvent;
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
	
	/* //17/02/2025	navkc1 JIRA Bug MTN-33582
	voyEvent := app.createEvent( EVT_VoyBolOutturnReq, app.actualTimeServer, term, app.myPassport.userCode, false, false,0).CMEVT_VoyageEvent;
	voyEvent.setMyVoyage(voyage);
	voyEvent.setMyBol(bol7);
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
	delete cmifEventCtrl;
	create cmifEventCtrl transient;
	cmifEventCtrl.type := EVT_VoyBolOutturnReq;
	cmifEventCtrl.dateTime := app.actualTimeServer();
	cmifEventCtrl.myTerminal := term;
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myVoyage := voyage;
	cmifEventCtrl.myBOL := bol7;
	
	voyEvent := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_VoyageEvent;
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
	commitTransaction;
	
	self.runCamsNow(startDateTime, camProtocol);
	
	index := index + 1;
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.getAtKey( camProtocol, index);	//should be the cam history for BOL3
	self.assertTrueMsg( camTaskHistory &lt;&gt; null, "Cam history for Extra Outturns not found.");
	
	
	fileOutputAsStr := camTaskHistory.getRawDataString();
	create xmlDoc transient;
	xmlDoc.parseString( fileOutputAsStr );
	xmlElement := xmlDoc.getElementByTagName("OceanBill");
	self.assertTrueMsg( xmlElement.textData = BOLid3, "Cam history for BOL3 Wrong &lt;OceanBill&gt; value.");
	xmlElement := xmlDoc.getElementByTagName("Packages");
	self.assertTrueMsg( xmlElement.textData = null, "Cam history for BOL3 &lt;Packages&gt; tag should be empty.");
	xmlElement := xmlDoc.getElementByTagName("OutturnType");
	self.assertTrueMsg( xmlElement.textData = "NIL", "Cam history for BOL3 &lt;OutturnType&gt; tag should be 'NIL'.");
	xmlElement := xmlDoc.getElementByTagName("VesselDischargeIndicator");
	self.assertTrueMsg( xmlElement.textData = "V", "Cam history for BOL3 &lt;VesselDischargeIndicator&gt; tag should be 'V'.");
	delete xmlDoc;
	
	index := index + 1;

	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.getAtKey( camProtocol, index);	//should be the cam history for BOL4
	self.assertTrueMsg( camTaskHistory &lt;&gt; null, "Cam history for BOL4 Outturn not found.");
	
	fileOutputAsStr := camTaskHistory.getRawDataString();
	create xmlDoc transient;
	xmlDoc.parseString( fileOutputAsStr );
	xmlElement := xmlDoc.getElementByTagName("OceanBill");
	self.assertTrueMsg( xmlElement.textData = BOLid4, "Cam history for BOL4 Wrong &lt;OceanBill&gt; value.");
	xmlElement := xmlDoc.getElementByTagName("Packages");
	self.assertTrueMsg( xmlElement.textData = "1", "Cam history for BOL4 &lt;Packages&gt; tag should be 1.");
	xmlElement := xmlDoc.getElementByTagName("OutturnType");
	self.assertTrueMsg( xmlElement.textData = "SH", "Cam history for BOL4 &lt;OutturnType&gt; tag should be 'SH'.");
	xmlElement := xmlDoc.getElementByTagName("VesselDischargeIndicator");
	self.assertTrueMsg( xmlElement.textData = "V", "Cam history for BOL4 &lt;VesselDischargeIndicator&gt; tag should be 'V'.");
	delete xmlDoc;
	
	index := index + 1;
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.getAtKey( camProtocol, index);	//should be the cam history for BOL5
	self.assertTrueMsg( camTaskHistory &lt;&gt; null, "Cam history for BOL5 Outturn not found.");
	fileOutputAsStr := camTaskHistory.getRawDataString();
	create xmlDoc transient;
	xmlDoc.parseString( fileOutputAsStr );
	xmlElement := xmlDoc.getElementByTagName("OceanBill");
	self.assertTrueMsg( xmlElement.textData = BOLid5, "Cam history for BOL5 Wrong &lt;OceanBill&gt; value.");
	xmlElement := xmlDoc.getElementByTagName("Packages");
	self.assertTrueMsg( xmlElement.textData = "3", "Cam history for BOL5 &lt;Packages&gt; tag should be 3.");
	xmlElement := xmlDoc.getElementByTagName("OutturnType");
	self.assertTrueMsg( xmlElement.textData = "SU", "Cam history for BOL5 &lt;OutturnType&gt; tag should be 'SU'.");
	xmlElement := xmlDoc.getElementByTagName("VesselDischargeIndicator");
	self.assertTrueMsg( xmlElement.textData = "U", "Cam history for BOL5 &lt;VesselDischargeIndicator&gt; tag should be 'U'.");
	delete xmlDoc;
	
	index := index + 1;
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.getAtKey( camProtocol, index);	//should be the cam history for BOL6
	self.assertTrueMsg( camTaskHistory &lt;&gt; null, "Cam history for BOL6 Outturn not found.");
	fileOutputAsStr := camTaskHistory.getRawDataString();
	create xmlDoc transient;
	xmlDoc.parseString( fileOutputAsStr );
	xmlElement := xmlDoc.getElementByTagName("OceanBill");
	self.assertTrueMsg( xmlElement.textData = BOLid6, "Cam history for BOL6 Wrong &lt;OceanBill&gt; value.");
	xmlElement := xmlDoc.getElementByTagName("Packages");
	self.assertTrueMsg( xmlElement.textData = "1", "Cam history for BOL6 &lt;Packages&gt; tag should be 1.");
	xmlElement := xmlDoc.getElementByTagName("OutturnType");
	self.assertTrueMsg( xmlElement.textData = "SH", "Cam history for BOL6 &lt;OutturnType&gt; tag should be 'SH'.");
	xmlElement := xmlDoc.getElementByTagName("VesselDischargeIndicator");
	self.assertTrueMsg( xmlElement.textData = "V", "Cam history for BOL6 &lt;VesselDischargeIndicator&gt; tag should be 'V'.");
	delete xmlDoc;
	
	index := index + 1;
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.getAtKey( camProtocol, index);	//should be the cam history for BOL7
	self.assertTrueMsg( camTaskHistory &lt;&gt; null, "Cam history for BOL7 Outturn not found.");
	fileOutputAsStr := camTaskHistory.getRawDataString();
	create xmlDoc transient;
	xmlDoc.parseString( fileOutputAsStr );
	xmlElement := xmlDoc.getElementByTagName("OceanBill");
	self.assertTrueMsg( xmlElement.textData = BOLid7, "Cam history for BOL7 Wrong &lt;OceanBill&gt; value.");
	xmlElement := xmlDoc.getElementByTagName("Packages");
	self.assertTrueMsg( xmlElement.textData = "1", "Cam history for BOL7 &lt;Packages&gt; tag should be 1.");
	xmlElement := xmlDoc.getElementByTagName("OutturnType");
	self.assertTrueMsg( xmlElement.textData = "SU", "Cam history for BOL7 &lt;OutturnType&gt; tag should be 'SU'.");
	xmlElement := xmlDoc.getElementByTagName("VesselDischargeIndicator");
	self.assertTrueMsg( xmlElement.textData = "V", "Cam history for BOL7 &lt;VesselDischargeIndicator&gt; tag should be 'V'.");
	delete xmlDoc;
		
epilog
	self.deleteEDIInwardXlation(foreignVoyageCode,XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIInwardXlation(inForeignCode,XLATION_TYPE_VOYAGETERMINAL, operator, null);
	if voyage &lt;&gt; null then
		self.deleteEDIOutwardXlation(voyage.code,	XLATION_TYPE_VOYAGETERMINAL, operator, null);
		self.deleteEDIOutwardXlation(voyage.inwardCode,	XLATION_TYPE_VOYAGETERMINAL, operator, null);
	endif;
	self.deleteEDIInwardXlation (ForeignOperatorCode1, XLATION_TYPE_OPERATOR_BYOP, operator, null);	//12 Jun 2017	NDL	TFS 4751
	self.deleteEDIOutwardXlation (ForeignOperatorCode1, XLATION_TYPE_OPERATOR_BYOP, operator, null);	//12 Jun 2017	NDL	TFS 4751

	delete operatorDict;
	delete freightForwarders;
    delete registeredTransactions;
	delete registeredCargoTypes;
	delete xmlDoc;
	delete roroLCs;
	delete wlesToMove;
	delete wlesWithWarnings;
	delete xmlArray;
	
	delete camEventTypes;
	app.setIsBackGroundApp (false);
	delete camEditTriggerFields;
	delete tis;
	delete cmifEventCtrl;//17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
    </JadeMethod>
    <JadeMethod name="tAlabamaSteelCoil" id="4806384c-4dcf-451b-b051-bebdeb8aa2cc">
        <updating/>
        <source>tAlabamaSteelCoil() updating;
//
///19 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//30 Apr 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
//
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
// 26 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 21 Jun 2018	jlgrs1	TFS 39298 (TFS 36430) Penn Ship Manifest too many locks
// 27 Feb 2025  navlc30 JIRA 34175_UT_EDICAMS::tAlabamaSteelCoil needs to be fixed
constants
	USER_DEF_NAME : String = "JMTInternalShipManifest";
	VoyageName		= 'UT_VOY1AST';				
	BoatName		= 'UT_VES1AST';
	Cargo_Type = "COILS";
	CamGroup 		= "UT_AST1";
	CamProtocol 	= "UT_ASTCOIL_TST";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
    BlockStackName  = "UT_SUZBSTACK";
	OperatorCode = "UTOP";
vars
	runDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camProtocolDesc :CM_CamProtocolDesc;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
    transactions : StringArray;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	cargoTypeObj : CM_CargoType;
    cargoItems : CM_TISet;
	cargoItem : CM_TrackedItem;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	et : CM_EventTransaction;
//	strArray : HugeStringArray;
	expectedOutput : String;
	bs : CM_BlockStack;
	count : Integer;
	registeredCargoTypes : IntegerArray;
	camTrainEventTypes : CM_EventTypeByNameDict;
	measureType1 : CM_MeasurementType;
	measureType2 : CM_MeasurementType;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	sealType: CM_SealType;
	cmifEventCtrl : CMIF_VoyageEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	self.setTerminalConfig(EdiShipManAllowPartial, true);
	self.setTerminalConfig(CreateBOLForOnshipItems, false);
	create camEditTriggerFields transient;
	measureType1 := app.getDefaultMeasurementForType(Type_Weight);
	if measureType1 &lt;&gt; null and
	   measureType1.shortName &lt;&gt; 'kg' then
		measureType2 := app.myRoot.allMeasurementTypesByShortName['kg'];
		if measureType2 &lt;&gt; null then
			beginTransaction;
			measureType1.setPropertyValue(CM_MeasurementType::isDefault.name, false);
			measureType2.setPropertyValue(CM_MeasurementType::isDefault.name, true);
			measureType2.setPropertyValue(CM_MeasurementType::format.name, '14.3'.Decimal);
			measureType2.setFormatPrecision(3);
			commitTransaction;
		endif;
	endif;
	measureType1 := app.getDefaultMeasurementForType(Type_Linear);
	if measureType1 &lt;&gt; null then
	   if measureType1.shortName &lt;&gt; 'cm' then
			measureType2 := app.myRoot.allMeasurementTypesByShortName['cm'];
			if measureType2 &lt;&gt; null then
				beginTransaction;
				measureType1.setPropertyValue(CM_MeasurementType::isDefault.name, false);
				measureType2.setPropertyValue(CM_MeasurementType::isDefault.name, true);
				measureType2.setPropertyValue(CM_MeasurementType::format.name, '14.0'.Decimal);				//27.02.2025 navlc30 #34175
				measureType2.setFormatPrecision(0);															//27.02.2025 navlc30 #34175
				commitTransaction;
			endif;
		else																								//27.02.2025 navlc30 #34175
			beginTransaction;
			measureType1.setPropertyValue(CM_MeasurementType::format.name, '14.0'.Decimal);
			measureType1.setFormatPrecision(0);
			commitTransaction;
		endif;
	endif;
	startDateTime := app.actualTimeServer;
	self.deleteContainer(VoyageName&amp;'/BOL01/001');
	self.deleteContainer(VoyageName&amp;'/BOL01/002');
	self.deleteContainer(VoyageName&amp;'/BOL01/003');
	self.deleteContainer(VoyageName&amp;'/BOL01/004');
	passportObj	:=	app.myPassport;
	operator := self.getOperator(OperatorCode);
	cargoTypeObj := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	sealType := app.myRoot.allSealTypes["SHIP"];
	if not sealType.allCargoTypes.includes(cargoTypeObj) then
		beginTransaction;
		sealType.allCargoTypes.add(cargoTypeObj);
		commitTransaction;
	endif;
//	self.deleteEDIInwardXlation(VoyageName, XLATION_TYPE_VOYAGETERMINAL, operator);
	self.deleteVoyage(VoyageName);
	voyage	:= self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel	:= self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	vessel := self.addVesselCellular(BoatName, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, "Add vessel failed");
	voyage := self.addVoyageWithContainerStructur(VoyageName, BoatName, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalShipManifest xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalShipManifest.xsd"&gt;
  &lt;AllBOLHeader&gt;
    &lt;BOLHeader&gt;
      &lt;bolType&gt;5003&lt;/bolType&gt;
      &lt;numItems&gt;50&lt;/numItems&gt;
      &lt;id&gt;BOL01&lt;/id&gt;
      &lt;loadPort&gt;GBLIV&lt;/loadPort&gt;
      &lt;messageMode&gt;A&lt;/messageMode&gt;
      &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
      &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
      &lt;AllBOLDetails&gt;
        &lt;BOLDetails&gt;
          &lt;weight&gt;8090.0000&lt;/weight&gt;
          &lt;quantity&gt;1&lt;/quantity&gt;
          &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
          &lt;consignee&gt;UOP Tonawanda / Tonawanda NY&lt;/consignee&gt;
          &lt;consignor&gt;UOP Tonawanda / Tonawanda NY&lt;/consignor&gt;
          &lt;id&gt;BOL01&lt;/id&gt;
          &lt;messageMode&gt;A&lt;/messageMode&gt;
          &lt;remarks&gt;(AM # 36-12) CL 9,UN 3077,PKG III,ENVIRONMENTALLY HAZARDOUS SUBSTANCE, (50 Steel Coils)&lt;/remarks&gt;
        &lt;/BOLDetails&gt;
        &lt;BOLDetails&gt;
          &lt;weight&gt;16960.0000&lt;/weight&gt;
          &lt;quantity&gt;1&lt;/quantity&gt;
          &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
          &lt;consignee&gt;UOP Tonawanda / Tonawanda NY&lt;/consignee&gt;
          &lt;consignor&gt;UOP Tonawanda / Tonawanda NY&lt;/consignor&gt;
          &lt;id&gt;BOL01&lt;/id&gt;
          &lt;messageMode&gt;A&lt;/messageMode&gt;
          &lt;remarks&gt;TRIACETIN (16 IBC)&lt;/remarks&gt;
        &lt;/BOLDetails&gt;
      &lt;/AllBOLDetails&gt;
  &lt;AllCargoOnShip&gt;
    &lt;CargoOnShip&gt;
      &lt;site&gt;3&lt;/site&gt;
      &lt;bol&gt;BOL01&lt;/bol&gt;
      &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
      &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/001&lt;/id&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;sealShipper&gt;CMA-CGM366&lt;/sealShipper&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	  &lt;weight&gt;1090.0000&lt;/weight&gt;
	  &lt;width&gt;100&lt;/width&gt;
	  &lt;height&gt;10&lt;/height&gt;
	  &lt;AllToDoTask/&gt;
	&lt;/CargoOnShip&gt;
	&lt;CargoOnShip&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/002&lt;/id&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;sealShipper&gt;TBE495037&lt;/sealShipper&gt;
      &lt;weight&gt;2090.0000&lt;/weight&gt;
      &lt;width&gt;200&lt;/width&gt;
      &lt;height&gt;20&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	&lt;/CargoOnShip&gt;
	&lt;CargoOnShip&gt;
	  &lt;quantity&gt;50&lt;/quantity&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;commodity&gt;&lt;/commodity&gt;
	  &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
	  &lt;dischargePort&gt;NZPOE&lt;/dischargePort&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/003&lt;/id&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;remarks&gt;(AM # 36-12) CL 9,UN 3077,PKG III,ENVIRONMENTALLY HAZARDOUS SUBSTANCE, (50 Steel Coils)&lt;/remarks&gt;
      &lt;weight&gt;3090.0000&lt;/weight&gt;
      &lt;width&gt;300&lt;/width&gt;
      &lt;height&gt;30&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	&lt;/CargoOnShip&gt;
	&lt;CargoOnShip&gt;
	  &lt;quantity&gt;16&lt;/quantity&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;commodity&gt;&lt;/commodity&gt;
	  &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
	  &lt;dischargePort&gt;NZPOE&lt;/dischargePort&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/004&lt;/id&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;remarks&gt;TRIACETIN (16 IBC)&lt;/remarks&gt;
      &lt;weight&gt;4090.0000&lt;/weight&gt;
      &lt;width&gt;400&lt;/width&gt;
      &lt;height&gt;40&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	&lt;/CargoOnShip&gt;
  &lt;/AllCargoOnShip&gt;
    &lt;/BOLHeader&gt;
  &lt;/AllBOLHeader&gt;
  &lt;AllLayout/&gt;
 &lt;/JMTInternalShipManifest&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);
//return;
	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj	:=	ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						"Load Failed",
						CM_EDIFile.EDI_STATUS_DBLOADED,
						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 9, "incorrect number of EDI trackedItems");
	
	// Create the Receives
    
	// create terminal area
    self.deleteTerminalArea(BlockStackName);
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');
    
    create cargoItems transient;
    voyage.getAllTrackedItems(cargoItems);    
   // Discharge 4 of the items 
    foreach cargoItem in cargoItems do
        count := count + 1;
        self.move(cargoItem, bs);
        if count = 4 then
            break;
        endif;
    endforeach;

	beginTransaction;
    /*
	et := app.createEvent(EVT_VoyageDeparture, app.actualTimeServer, self.getTerminal(), app.myPassport.userCode, false, false,0).CMEVT_VoyageEvent;
    et.CMEVT_VoyageEvent.setMyVoyage(voyage);
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
	create cmifEventCtrl transient;
	cmifEventCtrl.type := EVT_VoyageDeparture;
	cmifEventCtrl.dateTime := app.actualTimeServer();
	cmifEventCtrl.myTerminal := self.getTerminal();
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myVoyage := voyage;
	
	et := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_VoyageEvent;
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
	
	voyage.setPropertyValue(CM_Voyage::status.name, Voyage_Status_Departed);
    commitTransaction;
    
   //Test CAMS Response 
	camGroup := self.getCamGroup(CamGroup);
	if camGroup &lt;&gt; null then
		foreach camProtocol in camGroup.protocols do
			self.deleteCamProtocol(camProtocol.code);
		endforeach;
	endif;
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create registeredCargoTypes transient;
	registeredCargoTypes.add(cargoTypeObj.id);
	create camTrainEventTypes transient;
	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_VoyageDeparture]);
	create operatorDict transient;
	create freightForwarders transient;
    create transactions transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	self.deleteCamProtocol(CamProtocol);
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	
	camProtocolDesc := app.myRoot.allCamProtocolDescs["Alabama Steel Coil"];
	camProtocol	:= self.createCamProtocol(CamProtocol, camGroup, "NZCHC", operator.code, camProtocolDesc, false, false, false, transactions, registeredCargoTypes, camTrainEventTypes, camEditTriggerFields,null);	
	beginTransaction;
	camProtocolDesc.setTransmissionNumber(10);
//	camProtocol.setPropertyValue(CM_CamProtocol::noCrLfInMessage.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::specialFileName.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::singleTransactionPerFile.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::singleTransactionPerFile.name, true);
	camProtocol.setLogExcludedTransactions(true);
	camProtocol.setLogIncludedTransactions(true);
	commitTransaction;
    // RUNS CAMS
	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	// write contents of file
//	write '-------------------------------';
//	write camProtocol.description;
//	write '--------------------------------';
	
	self.zOutput_AST_CoilXML(expectedOutput);
	self.zCheckOutputXML(camProtocol, camTaskHistory, expectedOutput, "vessel");
epilog
//	delete strArray;
	delete operatorDict;
	delete freightForwarders;
    delete cargoItems;
    delete transactions;
	delete camTrainEventTypes;
	delete registeredCargoTypes;
	delete camEditTriggerFields;
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
    </JadeMethod>
    <JadeMethod name="tAlabamaSteelUpdDel" id="b20aab2d-f4bf-4e41-92f2-82fcee140abf">
        <updating/>
        <source>tAlabamaSteelUpdDel() updating;
//
///19 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	Cargo_Type = "Steel Coil";
	Cargo_Subtype = "GVS";
	VoyageName		= 'UT_VOY2AST';				
	BoatName		= 'UT_VES2AST';
	PortName		= "NZAKL";
	ContainerName1	= 'COIL240501';
	ContainerName2	= 'COIL240502';
	ContainerName3	= 'COIL240503';
	ContainerName4	= 'COIL240504';
	ContainerName5	= 'COIL240505';
	BlockStackName	= 'BS26728';
	CamGroup 		= "UT_AST2";
	CamProtocol 	= "UT_ASTUPDDEL";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
vars
	runDateTime : TimeStamp;
	tempStr	: String;
	idx : Integer;
//	container1, container2, container3, container4, container5 : CM_Container;
	cargo1 : CM_TrackedItem;
	cargo2 : CM_TrackedItem;
	cargo3 : CM_TrackedItem;
	cargo4 : CM_TrackedItem;
	cargo5 : CM_TrackedItem;
	operator : CM_Operator;
	defaultOperator : CM_Operator;
	voyage : CM_Voyage;
	defaultVoyage : CM_Voyage;
	passport : CM_Passport;
	bs 	: CM_BlockStack;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camProtocolDesc :CM_CamProtocolDesc;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
    registeredTransactions : StringArray;
	registeredCargoTypes : IntegerArray;
	port : CM_Port;
	theSlot : CM_LocationsController;
	strs : StringArray;
	crane : CM_Machine;
	cargoTypeObj : CM_CargoType;
	cargoSubType : CM_Product;
//	strArray : HugeStringArray;
	expectedOutput : String;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
begin
	create camEditTriggerFields transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	cargoTypeObj := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	cargoSubType := cargoTypeObj.allProducts[operator.code, Cargo_Subtype];

	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	cargo1 := self.getTrackedItem(ContainerName1);
	self.deleteTrackedItem(cargo1, false);
	cargo1 := self.getTrackedItem(ContainerName1);
	self.assertIsDeleted(cargo1);
	
	cargo2 := self.getTrackedItem(ContainerName2);
	self.deleteTrackedItem(cargo2, false);
	cargo2 := self.getTrackedItem(ContainerName2);
	self.assertIsDeleted(cargo2);
	
	cargo3 := self.getTrackedItem(ContainerName3);
	self.deleteTrackedItem(cargo3, false);
	cargo3 := self.getTrackedItem(ContainerName3);
	self.assertIsDeleted(cargo3);
	
	cargo4 := self.getTrackedItem(ContainerName4);
	self.deleteTrackedItem(cargo4, false);
	cargo4 := self.getTrackedItem(ContainerName4);
	self.assertIsDeleted(cargo4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	voyage := self.createVesselVoyage ( VoyageName,BoatName, operator);
	
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo3 := self.addCargoAtLocationDetailed(ContainerName3, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_IMPORT, voyage, operator);
//	container3 := self.addContainerAtLocnDisch(ContainerName3, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((cargo3.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	cargo3.setLoadPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	strs.clear;
	strs.add("030684");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo4 := self.addCargoAtLocationDetailed(ContainerName4, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_IMPORT, voyage, operator);
//	container4 := self.addContainerAtLocnDisch(ContainerName4, "2232", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((cargo4.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	cargo4.setLoadPort ("NZLYT");
    cargo4.setDeliveryRelease("12345678901234567890");
	commitTransaction;
	// create on-site cargo
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull (port);

	// ### 20 MT
	cargo1 := self.addCargoAtLocationDetailed(ContainerName1, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_IMPORT, voyage, operator);
//	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(cargo1, tempStr);
	beginTransaction;
	cargo1.setDestinationPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	cargo2 := self.addCargoAtLocationDetailed(ContainerName2, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_IMPORT, voyage, operator);
//	container2 := self.addContainerAtLocnDisch(ContainerName2, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(cargo2, tempStr);
	
//	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
//	self.assertNoTrxErrorsOrWarnings ();
	
//	self.createVoyageDischargeJobs(voyage, crane.id);
//	self.createVoyageLoadJobs(voyage, PortName, crane.id);
//	self.planLoadItems(voyage, crane.id);
//	self.loadAllJobsToOps(voyage, true);
//	self.planDischargeItems(voyage, bs, crane.id);
//	self.moveAllCargo(voyage);
	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create operatorDict transient;
	create freightForwarders transient;
	create registeredCargoTypes transient;
	registeredCargoTypes.add(cargoTypeObj.id);
    create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_Move).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_Edit).asStringJMT);
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	camProtocolDesc := app.myRoot.allCamProtocolDescs["Alabama Steel Upd Del"];
	camProtocol	:= self.createCamProtocol(CamProtocol, camGroup, "NZCHC", operator.code, camProtocolDesc, false, false, false, registeredTransactions, registeredCargoTypes, null, camEditTriggerFields,null);	
	
	beginTransaction;
	camProtocolDesc.setTransmissionNumber(10);
//	camProtocol.setPropertyValue(CM_CamProtocol::noCrLfInMessage.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::specialFileName.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::singleTransactionPerFile.name, true);
	commitTransaction;
 	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	
//	create strArray transient;
	self.zOutput_AST_UpdDelXML(expectedOutput);
	self.zCheckOutputXML(camProtocol, camTaskHistory, expectedOutput, "warehouse_activity");
epilog
//	delete strArray;
	delete operatorDict;
	delete freightForwarders;
    delete registeredTransactions;
	delete registeredCargoTypes;
	delete strs;
	app.setIsBackGroundApp (false);
	delete camEditTriggerFields;
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;test1aasdfakhsdflkj&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tAlabamaSteelWareXMLEventIBI" id="b381cd88-6955-44c9-baee-a6f17e607260">
        <updating/>
        <source>tAlabamaSteelWareXMLEventIBI() updating;
//
///19 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams Events Only
//
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
// 21 Jun 2018	jlgrs1	TFS 39298 (TFS 36430) Penn Ship Manifest too many locks
constants
	USER_DEF_NAME : String = "JMTInternalShipManifest";
	Cargo_Type = "COILS";
	Cargo_Subtype = "GVS";
	VoyageName		= 'UT_VOY3AST';				
	BoatName		= 'UT_VES3AST';
	PortName		= "NZAKL";
	ContainerName1	= 'COIL240501';
	ContainerName2	= 'COIL240502';
	ContainerName3	= 'COIL240503';
	ContainerName4	= 'COIL240504';
	ContainerName5	= 'COIL240505';
	BlockStackName	= 'BS26728';
	CamGroup 		= "UT_AST3";
	CamProtocol 	= "UT_ASTWAREHOUSE1";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
	OperatorCode = "UTOP";
vars
	runDateTime : TimeStamp;
	tempStr	: String;
	idx : Integer;
//	container1, container2, container3, container4, container5 : CM_Container;
	cargo1 : CM_TrackedItem;
	cargo2 : CM_TrackedItem;
	cargo3 : CM_TrackedItem;
	cargo4 : CM_TrackedItem;
	cargo5 : CM_TrackedItem;
	operator : CM_Operator;
	defaultOperator : CM_Operator;
	voyage : CM_Voyage;
	defaultVoyage : CM_Voyage;
	passport : CM_Passport;
	bs 	: CM_BlockStack;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camProtocolDesc :CM_CamProtocolDesc;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
    registeredTransactions : StringArray;
	registeredCargoTypes : IntegerArray;
	port : CM_Port;
	theSlot : CM_LocationsController;
	strs : StringArray;
	crane : CM_Machine;
	cargoTypeObj : CM_CargoType;
	cargoSubType : CM_Product;
	ediText : String;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	errorMsg : String;
	expectedOutput : String;
	cargoItems : CM_TISet;
	cargoItem : CM_TrackedItem;
	count : Integer;
	et : CM_EventTransaction;
	camTrainEventTypes : CM_EventTypeByNameDict;
	measureType : CM_MeasurementType;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	cmifEventCtrl : CMIF_VoyageEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	self.setTerminalConfig(EdiShipManAllowPartial, true);
	create camEditTriggerFields transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType &lt;&gt; null and
	   measureType.conversionRate &lt;&gt; 1 then
		beginTransaction;
		measureType.setPropertyValue(CM_MeasurementType::isDefault.name, false);
		commitTransaction;
	endif;
	measureType := app.myRoot.allMeasurementTypesByShortName['kg'];
	if measureType &lt;&gt; null then
		if not measureType.isDefault then
			beginTransaction;
			measureType.setPropertyValue(CM_MeasurementType::isDefault.name, true);
			commitTransaction;
		endif;
		if not measureType.format = 14.3 then
			beginTransaction;
			measureType.setPropertyValue(CM_MeasurementType::format.name, '14.3'.Decimal);
			commitTransaction;
		endif;
	endif;
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	cargoTypeObj := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	cargoSubType := cargoTypeObj.allProducts[operator.code, Cargo_Subtype];

	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	cargo1 := self.getTrackedItem(ContainerName1);
	self.deleteTrackedItem(cargo1, false);
	cargo1 := self.getTrackedItem(ContainerName1);
	self.assertIsDeleted(cargo1);
	
	cargo2 := self.getTrackedItem(ContainerName2);
	self.deleteTrackedItem(cargo2, false);
	cargo2 := self.getTrackedItem(ContainerName2);
	self.assertIsDeleted(cargo2);
	
	cargo3 := self.getTrackedItem(ContainerName3);
	self.deleteTrackedItem(cargo3, false);
	cargo3 := self.getTrackedItem(ContainerName3);
	self.assertIsDeleted(cargo3);
	
	cargo4 := self.getTrackedItem(ContainerName4);
	self.deleteTrackedItem(cargo4, false);
	cargo4 := self.getTrackedItem(ContainerName4);
	self.assertIsDeleted(cargo4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	voyage := self.createVesselVoyage (VoyageName,BoatName,  operator);
	
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo3 := self.addCargoAtLocationDetailed(ContainerName3, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_IMPORT, voyage, operator);
//	container3 := self.addContainerAtLocnDisch(ContainerName3, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((cargo3.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	cargo3.setLoadPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	strs.clear;
	strs.add("030684");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo4 := self.addCargoAtLocationDetailed(ContainerName4, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_IMPORT, voyage, operator);
//	container4 := self.addContainerAtLocnDisch(ContainerName4, "2232", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((cargo4.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	cargo4.setLoadPort ("NZLYT");
	commitTransaction;
	// create on-site cargo
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull (port);

	// ### 20 MT
	cargo1 := self.addCargoAtLocationDetailed(ContainerName1, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_IMPORT, voyage, operator);
//	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(cargo1, tempStr);
	beginTransaction;
	cargo1.setDestinationPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	cargo2 := self.addCargoAtLocationDetailed(ContainerName2, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_IMPORT, voyage, operator);
//	container2 := self.addContainerAtLocnDisch(ContainerName2, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(cargo2, tempStr);
	
//	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
//	self.assertNoTrxErrorsOrWarnings ();
	
//	self.createVoyageDischargeJobs(voyage, crane.id);
//	self.createVoyageLoadJobs(voyage, PortName, crane.id);
//	self.planLoadItems(voyage, crane.id);
//	self.loadAllJobsToOps(voyage, true);
//	self.planDischargeItems(voyage, bs, crane.id);
//	self.moveAllCargo(voyage);

	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalShipManifest xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalShipManifest.xsd"&gt;
  &lt;AllBOLHeader&gt;
    &lt;BOLHeader&gt;
      &lt;bolType&gt;5003&lt;/bolType&gt;
      &lt;numItems&gt;50&lt;/numItems&gt;
      &lt;id&gt;BOL01&lt;/id&gt;
      &lt;loadPort&gt;GBLIV&lt;/loadPort&gt;
      &lt;messageMode&gt;A&lt;/messageMode&gt;
      &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
      &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
      &lt;AllBOLDetails&gt;
        &lt;BOLDetails&gt;
          &lt;weight&gt;8090.0000&lt;/weight&gt;
          &lt;quantity&gt;1&lt;/quantity&gt;
          &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
          &lt;consignee&gt;UOP Tonawanda / Tonawanda NY&lt;/consignee&gt;
          &lt;consignor&gt;UOP Tonawanda / Tonawanda NY&lt;/consignor&gt;
          &lt;id&gt;BOL01&lt;/id&gt;
          &lt;messageMode&gt;A&lt;/messageMode&gt;
          &lt;remarks&gt;(AM # 36-12) CL 9,UN 3077,PKG III,ENVIRONMENTALLY HAZARDOUS SUBSTANCE, (50 Steel Coils)&lt;/remarks&gt;
        &lt;/BOLDetails&gt;
        &lt;BOLDetails&gt;
          &lt;weight&gt;16960.0000&lt;/weight&gt;
          &lt;quantity&gt;1&lt;/quantity&gt;
          &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
          &lt;consignee&gt;UOP Tonawanda / Tonawanda NY&lt;/consignee&gt;
          &lt;consignor&gt;UOP Tonawanda / Tonawanda NY&lt;/consignor&gt;
          &lt;id&gt;BOL01&lt;/id&gt;
          &lt;messageMode&gt;A&lt;/messageMode&gt;
          &lt;remarks&gt;TRIACETIN (16 IBC)&lt;/remarks&gt;
        &lt;/BOLDetails&gt;
      &lt;/AllBOLDetails&gt;
    &lt;/BOLHeader&gt;
  &lt;/AllBOLHeader&gt;
  &lt;AllLayout/&gt;
  &lt;AllCargoOnShip&gt;
    &lt;CargoOnShip&gt;
      &lt;site&gt;3&lt;/site&gt;
      &lt;bol&gt;BOL01&lt;/bol&gt;
      &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
      &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/001&lt;/id&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;sealShipper&gt;CMA-CGM366&lt;/sealShipper&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	  &lt;weight&gt;1090.0000&lt;/weight&gt;
	  &lt;width&gt;100&lt;/width&gt;
	  &lt;height&gt;10&lt;/height&gt;
	  &lt;AllToDoTask/&gt;
	&lt;/CargoOnShip&gt;
	&lt;CargoOnShip&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/002&lt;/id&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;sealShipper&gt;TBE495037&lt;/sealShipper&gt;
      &lt;weight&gt;2090.0000&lt;/weight&gt;
      &lt;width&gt;200&lt;/width&gt;
      &lt;height&gt;20&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	&lt;/CargoOnShip&gt;
	&lt;CargoOnShip&gt;
	  &lt;quantity&gt;50&lt;/quantity&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;commodity&gt;&lt;/commodity&gt;
	  &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
	  &lt;dischargePort&gt;NZPOE&lt;/dischargePort&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/003&lt;/id&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;remarks&gt;(AM # 36-12) CL 9,UN 3077,PKG III,ENVIRONMENTALLY HAZARDOUS SUBSTANCE, (50 Steel Coils)&lt;/remarks&gt;
      &lt;weight&gt;3090.0000&lt;/weight&gt;
      &lt;width&gt;300&lt;/width&gt;
      &lt;height&gt;30&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	&lt;/CargoOnShip&gt;
	&lt;CargoOnShip&gt;
	  &lt;quantity&gt;16&lt;/quantity&gt;
	  &lt;site&gt;3&lt;/site&gt;
	  &lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
	  &lt;bol&gt;BOL01&lt;/bol&gt;
	  &lt;cargoTypeDescr&gt;Steel Coils&lt;/cargoTypeDescr&gt;
	  &lt;commodity&gt;&lt;/commodity&gt;
	  &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
	  &lt;dischargePort&gt;NZPOE&lt;/dischargePort&gt;
	  &lt;id&gt;'&amp;VoyageName&amp;'/BOL01/004&lt;/id&gt;
	  &lt;imexStatus&gt;Import&lt;/imexStatus&gt;
	  &lt;messageMode&gt;A&lt;/messageMode&gt;
	  &lt;operatorCode&gt;'&amp;OperatorCode&amp;'&lt;/operatorCode&gt;
	  &lt;remarks&gt;TRIACETIN (16 IBC)&lt;/remarks&gt;
      &lt;weight&gt;4090.0000&lt;/weight&gt;
      &lt;width&gt;400&lt;/width&gt;
      &lt;height&gt;40&lt;/height&gt;
	  &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
	&lt;/CargoOnShip&gt;
  &lt;/AllCargoOnShip&gt;
 &lt;/JMTInternalShipManifest&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);
//return;
	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passport.allErrors.isEmpty(), passport.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passport.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj	:=	ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						"Load Failed",
						CM_EDIFile.EDI_STATUS_DBLOADED,
						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 9, "incorrect number of EDI trackedItems");
	
	// Create the Receives
    
	// create terminal area
    self.deleteTerminalArea(BlockStackName);
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');
    
    create cargoItems transient;
    voyage.getAllTrackedItems(cargoItems);    
   // Discharge 4 of the items 
    foreach cargoItem in cargoItems do
        count := count + 1;
        self.move(cargoItem, bs);
        if count = 4 then
            break;
        endif;
    endforeach;

	beginTransaction;
	/* //17/02/2025	navkc1 JIRA Bug MTN-33582
	et := app.createEvent(EVT_VoyageDeparture, app.actualTimeServer, self.getTerminal(), app.myPassport.userCode, false, false,0).CMEVT_VoyageEvent;
    et.CMEVT_VoyageEvent.setMyVoyage(voyage);
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
	create cmifEventCtrl transient;
	cmifEventCtrl.type := EVT_VoyageDeparture;
	cmifEventCtrl.dateTime := app.actualTimeServer();
	cmifEventCtrl.myTerminal := self.getTerminal();
	cmifEventCtrl.userCode := app.myPassport.userCode;
	cmifEventCtrl.myVoyage := voyage;
	
	et := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_VoyageEvent;
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
	
    commitTransaction;

	
	// DELETE THEN RE-CREATE THE CAM PROTOCOL
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	
	create camTrainEventTypes transient;
	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_VoyageDeparture]);
	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_TrainDepart]);
	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_TruckDeparture]);
	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_WagonConfirmed]);
	camTrainEventTypes.add(app.myRoot.allEventTypesByType[EVT_WagonDeparted]);
	create operatorDict transient;
	create freightForwarders transient;
	create registeredCargoTypes transient;
	registeredCargoTypes.add(cargoTypeObj.id);
    create registeredTransactions transient;
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveShip).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRail).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRoad).asStringJMT);
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseShip).asStringJMT);
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);

	camProtocolDesc := app.myRoot.allCamProtocolDescs["Alabama Steel Warehouse"];
	camProtocol	:= self.createCamProtocol(CamProtocol, camGroup, "NZCHC", operator.code, camProtocolDesc, false, false, false, registeredTransactions, registeredCargoTypes, camTrainEventTypes, camEditTriggerFields,null);	
	
	beginTransaction;
	camProtocolDesc.setTransmissionNumber(10);
//	camProtocol.setPropertyValue(CM_CamProtocol::noCrLfInMessage.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::specialFileName.name, true);
	camProtocol.setPropertyValue(CM_CamProtocol::isSingleTransPerFile.name, true);
	commitTransaction;
 	
	// run cams
	endDateTime := startDateTime.addMinutes(1);
	
	app.setIsBackGroundApp (true);
	
//	runDateTime := app.actualTimeServer;
//	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	self.runCamsNow(startDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	self.zOutput_AST_WareXMLEventIBI(expectedOutput);
	self.zCheckOutputXML(camProtocol, camTaskHistory, expectedOutput, "warehouse_activity");
epilog
	delete operatorDict;
	delete freightForwarders;
    delete registeredTransactions;
	delete registeredCargoTypes;
	delete strs;
	delete cargoItems;
	delete camTrainEventTypes;
	app.setIsBackGroundApp (false);
	delete camEditTriggerFields;
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;test1aasdfakhsdflkj&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tAlabamaSteelWareXMLTranEBITr" id="94bbd808-8950-43aa-877c-9bcb5d6984f6">
        <updating/>
        <source>tAlabamaSteelWareXMLTranEBITr() updating;
//
///19 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams Transactions only Import Tranship to look like Export
//
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
// 21 Jun 2018	jlgrs1	TFS 39298 (TFS 36430) Penn Ship Manifest too many locks
// 10 Sep 2019	cnwrs1	TFS 46030
constants
	USER_DEF_NAME : String = "JMTInternalShipManifest";
	USER_DEF_NAME_TRANSHIP : String = "JMTInternalTranship";
	Cargo_Type = "COILS";
	Cargo_Subtype = "GVS";
	VoyageName		= 'UT_VOY4AST';				
	ExportVoyageName = 'UT_VOY5AST';
	BoatName		= 'UT_VES4AST';
	PortName		= "NZAKL";
	ContainerName1	= 'COIL240501';
	ContainerName2	= 'COIL240502';
	ContainerName3	= 'COIL240503';
	ContainerName4	= 'COIL240504';
	ContainerName5	= 'COIL240505';
	BlockStackName	= 'BS26728';
	CamGroup 		= "UT_AST4";
	CamProtocol 	= "UT_ASTWAREHOUSE2";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
	OperatorCode = "UTOP";
vars
	runDateTime : TimeStamp;
	tempStr	: String;
	idx : Integer;
//	container1, container2, container3, container4, container5 : CM_Container;
	cargo1 : CM_TrackedItem;
	cargo2 : CM_TrackedItem;
	cargo3 : CM_TrackedItem;
	cargo4 : CM_TrackedItem;
	cargo5 : CM_TrackedItem;
	operator : CM_Operator;
	defaultOperator : CM_Operator;
	voyage : CM_Voyage;
	defaultVoyage : CM_Voyage;
	passport : CM_Passport;
	bs 	: CM_BlockStack;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camProtocolDesc :CM_CamProtocolDesc;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
    registeredTransactions : StringArray;
	registeredCargoTypes : IntegerArray;
	port : CM_Port;
	theSlot : CM_LocationsController;
	strs : StringArray;
	crane : CM_Machine;
	cargoTypeObj : CM_CargoType;
	cargoSubType : CM_Product;
	ediText : String;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	errorMsg : String;
	expectedOutput : String;
	cargoItems : CM_TISet;
	cargoItem : CM_TrackedItem;
	count : Integer;
	et : CM_EventTransaction;
	camTrainEventTypes : CM_EventTypeByNameDict;
	measureType : CM_MeasurementType;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	isDoClearanceCheck : Boolean;
	voyageNames : StringArray;
	voyageArray : CM_VoyageArray;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.setTerminalConfig(EdiShipManAllowPartial, true);
	create camEditTriggerFields transient;
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType &lt;&gt; null and
	   measureType.conversionRate &lt;&gt; 1 then
		beginTransaction;
		measureType.setPropertyValue(CM_MeasurementType::isDefault.name, false);
		commitTransaction;
	endif;
	measureType := app.myRoot.allMeasurementTypesByShortName['kg'];
	if measureType &lt;&gt; null then
		if not measureType.isDefault then
			beginTransaction;
			measureType.setPropertyValue(CM_MeasurementType::isDefault.name, true);
			commitTransaction;
		endif;
		if not measureType.format = 14.3 then
			beginTransaction;
			measureType.setPropertyValue(CM_MeasurementType::format.name, '14.3'.Decimal);
			commitTransaction;
		endif;
	endif;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; self.getProfileSetting(UT_Profile.P_OPERATOR).display);
		
	cargoTypeObj := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	cargoSubType := cargoTypeObj.allProducts[operator.code, Cargo_Subtype];

	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	cargo1 := self.getTrackedItem(ContainerName1);
	self.deleteTrackedItem(cargo1, false);
	cargo1 := self.getTrackedItem(ContainerName1);
	self.assertIsDeleted(cargo1);
	
	cargo2 := self.getTrackedItem(ContainerName2);
	self.deleteTrackedItem(cargo2, false);
	cargo2 := self.getTrackedItem(ContainerName2);
	self.assertIsDeleted(cargo2);
	
	cargo3 := self.getTrackedItem(ContainerName3);
	self.deleteTrackedItem(cargo3, false);
	cargo3 := self.getTrackedItem(ContainerName3);
	self.assertIsDeleted(cargo3);
	
	cargo4 := self.getTrackedItem(ContainerName4);
	self.deleteTrackedItem(cargo4, false);
	cargo4 := self.getTrackedItem(ContainerName4);
	self.assertIsDeleted(cargo4);
	
	// delete terminal area cargo is loaded from/discharged to
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);


//	voyage := self.createVesselVoyage(BoatName, ExportVoyageName, operator);
//	voyage := self.createVesselVoyage(BoatName, VoyageName, operator);
	
	create voyageNames transient;
	voyageNames.add(ExportVoyageName);
	voyageNames.add(VoyageName);
	create voyageArray transient;
	self.createVesselVoyages( BoatName, voyageNames, operator, voyageArray );
	voyage := voyageArray[2];
	
	beginTransaction;
	voyage.setPropertyValue(CM_Voyage::externalRef.name, "EXTREF001");
	commitTransaction;
	
	// create terminal area
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');

	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo3 := self.addCargoAtLocationDetailed(ContainerName3, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_IMPORT, voyage, operator);
//	container3 := self.addContainerAtLocnDisch(ContainerName3, "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((cargo3.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	cargo3.setLoadPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	strs.clear;
	strs.add("030684");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo4 := self.addCargoAtLocationDetailed(ContainerName4, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_IMPORT, voyage, operator);
//	container4 := self.addContainerAtLocnDisch(ContainerName4, "2232", "REEF", TI_IMEX_STATUS_IMPORT, theSlot, port, voyage);
	self.assertTrueMsg((cargo4.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	cargo4.setLoadPort ("NZLYT");
	commitTransaction;
	// create on-site cargo
	port := app.myRoot.allPorts[PortName];
	self.assertNotNull (port);

	// ### 20 MT
	cargo1 := self.addCargoAtLocationDetailed(ContainerName1, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_IMPORT, voyage, operator);
//	container1 := self.addContainerAtLocnDisch(ContainerName1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(cargo1, tempStr);
	beginTransaction;
	cargo1.setDestinationPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	cargo2 := self.addCargoAtLocationDetailed(ContainerName2, cargoTypeObj, cargoSubType, bs.myLocationsController, "NZCHC", TI_IMEX_STATUS_IMPORT, voyage, operator);
//	container2 := self.addContainerAtLocnDisch(ContainerName2, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(cargo2, tempStr);
	
//	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
//	self.assertNoTrxErrorsOrWarnings ();
	
//	self.createVoyageDischargeJobs(voyage, crane.id);
//	self.createVoyageLoadJobs(voyage, PortName, crane.id);
//	self.planLoadItems(voyage, crane.id);
//	self.loadAllJobsToOps(voyage, true);
//	self.planDischargeItems(voyage, bs, crane.id);
//	self.moveAllCargo(voyage);

	ediText :=
'
&lt;?xml version="1.0"?&gt;
&lt;JMTInternalShipManifest xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalShipManifest.xsd"&gt;
