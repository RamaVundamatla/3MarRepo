    <JadeMethod name="setupForm" id="edf886ec-226b-465c-8a41-61136f8b5dbc">
        <updating/>
        <source>setupForm() updating;
// --------------------------------------------------------------------------------
// Created:		28 April 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.toolbarStyle	:=	self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:=	true;
	
	inheritMethod();
	
	self.move(self.left, self.top, 452, 525);
	self.ctrlYardAlloc.setDisplayWindow(self);
	self.populateYardAllocations();
	self.setupYA(null);
	self.ctrlYardAlloc.setFocusToCriteria();
end;</source>
    </JadeMethod>
    <JadeMethod name="setupYA" id="901a89a2-abb6-4998-a1cf-c64430608e12">
        <updating/>
        <source>setupYA(pAllocationObj:CM_YardAllocation) updating, protected;
// --------------------------------------------------------------------------------
// Created:		28 April 2005 by cnwdad1
//
// Purpose:		Sets up the Yard Allocation Control with the YA currently selected
//				in the combobox control.
//
// Parameters:	pAllocationObj - A reference to a Yard Allocation to set up.  If
//					this is null, then check whether one is selected in the combobox.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// --------------------------------------------------------------------------------
vars
	yardAllocationObj	: CM_YardAllocation;
	listPointer			: Integer;
	
begin
	if pAllocationObj = null then
		listPointer	:=	self.cmbYardAlloc.listIndex;
		
		if listPointer = CNEC_NULL_INDEX then
			self.cmbYardAlloc.listIndex := self.YA_NEW;
			yardAllocationObj	:=	null;
		elseif self.cmbYardAlloc.itemData[listPointer] = self.YA_NEW then
			yardAllocationObj	:=	null;
		else
			yardAllocationObj	:=	self.cmbYardAlloc.listObject.CM_YardAllocation;
		endif;
	else
		yardAllocationObj	:=	pAllocationObj;
	endif;
	
	beginLoad;
	ctrlYardAlloc.setYardAllocation(yardAllocationObj);
	
epilog
	endLoad;
end;</source>
        <access>protected</access>
        <Parameter name="pAllocationObj" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="08be2050-5b17-4b92-82c5-ad62d6dba12f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008255, locale);
	btnDeleteYA.translateCaption(Xlat_0001188, locale);
	lblYardAlloc.translateCaption(Xlat_0001163, locale);
	mnuGroup.translateCaption(Xlat_0008256, locale);
	mnuGroupAdd.translateCaption(Xlat_0008257, locale);
	mnuGroupDelete.translateCaption(Xlat_0008258, locale);
	mnuGroupUpdate.translateCaption(Xlat_0008259, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="4890d94c-a944-4c72-bad1-f77f3b902d25">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	baseForm : CM_BaseForm;
	
begin
	if not self.aAllCallingForms.isEmpty() then
		foreach baseForm in self.aAllCallingForms do
			baseForm.doYardAllocationFormCancel(self.ctrlYardAlloc.hasCancelled);
			baseForm.doYardAllocationFormUnload();
		endforeach;
	endif;
	
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="yaRefreshAllocation" id="53fa7fd2-0494-4baa-9f96-2a6392f0ffd4">
