    <JadeMethod name="cmbAltUsers_gotFocus" id="bf724698-4345-4891-9ad7-2b924a49669d">
        <controlMethod name="ComboBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbAltUsers_gotFocus(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2012	cnwmc5	Initial creation

*/

vars
	pos : Integer;
begin
	//combobox.text := self.tblUserData.accessCell(self.tblUserData.row, 6).text;
	/*write class.name &amp; '::' &amp; method.name &amp; Tab &amp; "row: " &amp; self.tblUserData.row.String &amp; Tab &amp; 'col: ' &amp; 6.String &amp; Tab &amp; 
		'listIndex: ' &amp; combobox.listIndex.String &amp; Tab &amp; 'find: ' &amp; combobox.findString(1, self.tblUserData.accessCell(self.tblUserData.row, 6).text.String).String &amp; Tab &amp; 
		'cmb text: ' &amp; self.tblUserData.accessCell(self.tblUserData.row, 6).text;*/
		
	pos := combobox.findString(1, self.tblUserData.accessCell(self.tblUserData.row, 8).text.String);
	combobox.listIndex := pos;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createNewUserRow" id="a6a8f72b-1f47-4b49-b8b8-bdd20d8ebb62">
        <updating/>
        <source>createNewUserRow() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
09 October 2012	cnwmc5	Initial creation
16 April 2025	navpw1	JIRA: MTN-34402: Added Control Id as the list reports is a duplicated control

*/

vars
	row			: Integer;
	jadeCell	: JadeTableCell;
	tableRows,
	controlId	: Integer;
	
begin
	tableRows := self.tblUserData.rows;
	row := self.tblUserData.addItem(null);
	
	jadeCell := self.tblUserData.accessCell(tableRows, self.ReportsList_Column);
	//controlId := jadeCell.cellControl.index;
	controlId := self.controlIdxMax;
	controlId += 1;
	
	self.setupNewRow(row, controlId);
	
	self.controlIdxMax := controlId;
end;</source>
    </JadeMethod>
