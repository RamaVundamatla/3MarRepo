    <JadeMethod name="isNotIdleHistory" id="5f5967eb-29be-4c87-bd94-540ec11feefa">
        <source>isNotIdleHistory() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/09/2020	jlgdap1		Initial creation TFS 49316 MTN Machine Idle Time
// 21/10/2022	navdap1		TFS 50083 MTN Machine Delay Idle Time
//
vars

begin
	if self.type = self.Type_LogOff 
	or self.type = self.Type_GoOffline 
	or self.type = self.Type_AcceptMove 
	or self.type = self.Type_PickUp 
	or self.type = self.Type_Info 
	or self.type = self.Type_DelayStart
	or self.type = self.Type_SetdownDelay then		//03-10-2022 navds21 TFS 50083
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSetDownDelayHistory" id="20b8f3d1-b02f-42ce-b292-a86aa245bf36">
        <source>isSetDownDelayHistory(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/10/2022	navds21	TFS 50083 MTN - Machine Delay Idle Time

*/

vars

begin
	if self.type = self.Type_SetdownDelay
	or self.type = self.Type_SetDown then
	return true;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="43e2b9ab-418b-488e-9c77-f018afa1f010">
        <updating/>
        <source>setDetails(_type : Integer; _machine : CM_Machine; _userId : String) updating;
/*

Date		Who		Reason
27 June 2017	cnwer1	Initial creation TFS 4620

*/

vars

begin
	self.type:=_type;
	
	self.userId:=_userId;
	if self.userId = null then
		self.userId :=self.Unknown_Value;
	endif;
	self.appName :=app.name;
	self.machine:=_machine;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_userId" type="String"/>
    </JadeMethod>
    <JadeMethod name="typeString" id="7fa28e39-b5ac-477a-9336-0b76776486e0">
        <methodInvocation>mapping</methodInvocation>
        <source>typeString(set: Boolean; value: String io) mapping;
//Return a nice string of the task Type
// 01/11/2010 	cnwcs5	par 23714/ccms1132 - new type (accept)
//										   - small optimisation using local var instead of self.type
//										   - new type (info)
// 31/03/2011	cnwcs5	ccms 1132 - new types for delays
// 15/09/2020	jlgdap1	TFS 49316 MTN Machine Idle Time
// 21/10/2022	navdap1	TFS 50083 MTN Machine Delay Idle Time
vars
	intType	:Integer;	// 01/11/0201 cnwcs5 par 23714/ccms1132
begin
	value := null;
	
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	// use local variable instead of mutiple self.type (getPropertyCalue calls)
	intType := self.type;				// 01/11/0201 cnwcs5 par 23714/ccms1132
	
	if intType = Type_Unknown then
		value := app.getErrorString(Unknown);
	elseif intType = Type_LogOn then
		value := app.getErrorString(Logged_on);
	elseif intType = Type_LogOff then
		value := app.getErrorString(Logged_off);
	elseif intType = Type_GoOnline then
		value := app.getErrorString(Went_online);
	elseif intType = Type_GoOffline then
		value :=app.getErrorString( Went_offline);
	elseif intType = Type_Move then
		value :=app.getErrorString(Moved);
	elseif intType = Type_PickUp then
		value :=  app.getErrorString(Pickup);
	elseif intType = Type_SetDown then
		value := app.getErrorString(Setdown);
	elseif intType = Type_RejectMove then
		value :=  app.getErrorString(Reject);
	elseif intType = Type_Amendment then //cnwrd1 par 23997 28.4.2010
		value := app.getErrorString(Machine_amendment);		
	elseif intType = Type_AcceptMove then	// 01/11/0201 cnwcs5 par 23714/ccms1132
		value := app.getErrorString(Accept);			// 01/11/0201 cnwcs5 par 23714/ccms1132
	elseif intType = Type_Info then			// 01/11/0201 cnwcs5 par 23714/ccms1132
		value := app.getErrorString(Information);				// 01/11/0201 cnwcs5 par 23714/ccms1132
	elseif intType = Type_DelayStart then	// 31/03/3011 cnwcs5
		value := app.getErrorString(Delay_start);				// 31/03/3011 cnwcs5
	elseif intType = Type_DelayEnd then		// 31/03/3011 cnwcs5
		value := app.getErrorString(Delay_end);				// 31/03/3011 cnwcs5
	elseif intType = Type_Idle then						// TFS 49316
		value := app.getErrorString(Machine_idle);		// TFS 49316
	elseif intType = Type_SetdownDelay then						//03-10-2022 navds21 TFS 50083
		value := app.getErrorString(Machine_setdown_delay);		//03-10-2022 navds21 TFS 50083
	else
		value := app.getErrorString(Unknown);
	endif;
	
//	value := '&lt;unknown&gt;';
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
</Class>
