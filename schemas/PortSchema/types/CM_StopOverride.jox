    <JadeMethod name="getDisplayStringForAttribute" id="547b9355-259f-46a7-9b2e-423113e7ebdd">
        <source>getDisplayStringForAttribute( _attrName : String; _short : Boolean ) : String;

/*
Date			Who		Reason
24 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	returnStr	: String;
	
begin
	if _attrName = ETRow_Details then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			returnStr	:= app.getErrorString( TransType_161 ) &amp; ColonAndSpace &amp; self.stopDescription;
			if self.oldClearanceExpiryDate &lt;&gt; null then
				returnStr	:=	returnStr &amp; Space &amp; Hyphen &amp; Space &amp;
								app.getString( Old ) &amp; Space &amp; app.getString( Clearance_Expiry_Date ) &amp; Space &amp;
								CM_Edit.S_EDIT_THING &amp; Space &amp;
								self.oldClearanceExpiryDate.shortFormatJMT();
			endif;
			if self.myStopOverrideReason &lt;&gt; null then
				returnStr	:=	returnStr &amp; Space &amp; Hyphen &amp; Space &amp;
								app.getString( Stop_Overridden_Reason ) &amp; Space &amp; DoubleQuote &amp;
								self.myStopOverrideReason.description &amp; DoubleQuote;
			endif;
			returnStr	:= returnStr &amp; Period &amp; Space &amp; self.remarks;
			return returnStr;
		endif;
	else
		return inheritMethod( _attrName, _short );
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="3232add6-772a-4f2b-9686-a6c816e68e36">
        <source>getName() : String;

vars
	returnStr	: String;
	
begin
	returnStr	:= 	inheritMethod() &amp; Tab &amp;
					self.stopId.display &amp; Tab &amp;
					self.stopDescription;
	
	if self.myTrackedItem &lt;&gt; null then
		returnStr	:= returnStr &amp; Tab &amp; self.myTrackedItem.id;
	endif;
	
	if self.myStop = null then
		returnStr	:= returnStr &amp; Tab &amp; '************';
	else
		returnStr	:= returnStr &amp; Tab &amp; self.myStop.id.display;
	endif;
	
	if self.myStopOverrideReason &lt;&gt; null then
		returnStr	:= returnStr &amp; Tab &amp; self.myStopOverrideReason.description.display;
	endif;
	
	return returnStr;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOldClearanceExpiryDate" id="9b5220f5-ee2c-4a29-a59c-961b93c78632">
