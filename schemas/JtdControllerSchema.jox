    <Function name="winCreateFontA" id="fe6c2e6e-65ca-44ee-a0ed-b3562f08b1bf">
        <entrypoint>CreateFontA</entrypoint>
        <executionLocation>presentationClient</executionLocation>
        <library name="gdi32"/>
        <source>winCreateFontA
(
	nHeight           : Integer; // height of font
	nWidth            : Integer; // width of font
	nEscapement       : Integer; // angle of escapement
	nOrientation      : Integer; // angle of base-line orientation
	nWeight           : Integer; // font weight
	dwItalic          : Integer; // italic attribute option
	dwUnderline       : Integer; // underline attribute option
	dwStrikeOut       : Integer; // strike-out attribute option
	dwCharSet         : Integer; // character set identifier
	dwOutputPrecision : Integer; // output precision
	dwClipPrecision   : Integer; // clip precision
	dwQuality         : Integer; // output quality
	dwPitchAndFamily  : Integer; // pitch and family
	lpszFace          : String  // null-terminated typeface name; max 32 chars
)
: Integer is CreateFontA in gdi32;</source>
        <Parameter name="nHeight" type="Integer"/>
        <Parameter name="nWidth" type="Integer"/>
        <Parameter name="nEscapement" type="Integer"/>
        <Parameter name="nOrientation" type="Integer"/>
        <Parameter name="nWeight" type="Integer"/>
        <Parameter name="dwItalic" type="Integer"/>
        <Parameter name="dwUnderline" type="Integer"/>
        <Parameter name="dwStrikeOut" type="Integer"/>
        <Parameter name="dwCharSet" type="Integer"/>
        <Parameter name="dwOutputPrecision" type="Integer"/>
        <Parameter name="dwClipPrecision" type="Integer"/>
        <Parameter name="dwQuality" type="Integer"/>
        <Parameter name="dwPitchAndFamily" type="Integer"/>
        <Parameter name="lpszFace" type="String"/>
        <ReturnType type="Integer"/>
    </Function>
    <Function name="winCreateFontW" id="18f158f5-c1d7-415f-9eaf-c96be5fa2870">
        <entrypoint>CreateFontW</entrypoint>
        <executionLocation>presentationClient</executionLocation>
