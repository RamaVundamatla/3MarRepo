begin

	foreach ediTI in _allToDoRemarks do
		ediToDoRemarksTI := ediTI.CM_EDITaskRemarkRelBookTI;
		bookingId := ediToDoRemarksTI.bookingId;
		sequence := ediToDoRemarksTI.bookingItemSeq;
		if _cmifBookingRef &lt;&gt; null then
			foreach cmifItem in _cmifBookingRef.allCMIF_BRItems do
				if cmifItem.sequence = sequence then
					selectedCmifItem := cmifItem;
					break;
				endif;
			endforeach;
		endif;
		if selectedCmifItem = null then
			app.raiseCMException1(Booki_item_with_seque_not_foun, sequence, null, ediTI);
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_allToDoRemarks" type="CM_EDITISet"/>
        <Parameter name="_cmifBookingRef" type="CMIF_BookingRef"/>
    </JadeMethod>
</Class>
