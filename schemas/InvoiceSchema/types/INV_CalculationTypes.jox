end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbMesTypeBuild" id="b11cdda8-91a2-478c-9264-f509c4d2fe34">
        <source>doCmbMesTypeBuild(_calcType : Integer);
/*
Purpose:			
Date		Who		Reason
27 May 2013	cnwab1	Initial creation
*/

vars
	dt1, dt2 : CM_DayType;
	mes : CM_MeasurementType;
begin
	self.cmbMesType.clear();
	
	self.cmbMesType.sorted := true;
	
	
	foreach mes in app.myRoot.allMeasurementTypesByShortName  discreteLock do
		if (_calcType = INV_CALC_TYPE_CARGOLENGTHCONVT and mes.isLinear() )
		or (_calcType = INV_CALC_TYPE_CARGOVOLUMECONVT and mes.isVolume() )
		or (_calcType = INV_CALC_TYPE_CARGOWEIGHTCONVT and mes.isWeight()) 
		or (_calcType = INV_CALC_TYPE_INVENT_WEIGHT and mes.isWeight())  // ### TFS 51219 28MAY2021 NAVAB1
		or (_calcType = INV_CALC_TYPE_INVENT_VOLUME and mes.isVolume())  // ### TFS 51219 28MAY2021 NAVAB1
		then
			self.cmbMesType.addItemObject(mes.name, mes);
		endif;
		
	endforeach;
	
epilog

end;</source>
        <Parameter name="_calcType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doCmbWeightToUseBuild" id="2a429726-74d5-4322-a138-46f4fdb1dbbb">
        <source>doCmbWeightToUseBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2025	navkc1 JIRA 36144 AAT | RotaBox ISO Type and New Attributes - Form

*/

vars

begin
	self.cmbWeightToUse.clear();
	
	self.cmbWeightToUse.addItemWithData(CM_CalculationType.CargoWeightStr, CM_CalculationType.CargoWeight);
	self.cmbWeightToUse.addItemWithData(CM_CalculationType.TotalWeightStr, CM_CalculationType.TotalWeight);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="b11852df-c385-45f2-903f-9af11f074b6c">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theReturn : Integer;
begin
 
	while true do
		app.myTrxDA.trxDeleteCalculationType(self.myCurrentObject.CM_CalculationType, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			return true;
		else
			theReturn := app.showErrorWarningDialog("Calculation Type", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFilterTable" id="972ca305-952d-4e32-bd59-4899db7c30d9">
        <updating/>
        <source>doFilterTable() updating;
/*

Purpose:			Filters the table using the text entered

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
22 September 2021	navpw1	Initial creation TFS: 51912

*/

vars

	filterText		: String;
	rowIdx,
	colIdx,
	start			: Integer;
	cell			: JadeTableCell;
	cellText		: String;
begin

	//filterText := self.txtFilterBox.text.toUpper();
	filterText := self.frmTableFilter.txtFilterBox.text.toUpper(); //25/06/2024	navkc1 CR 64823 Task 64824
	
	if (filterText = "") then
		self.clearFilter();
		return;
	else
		//self.btnClearFilter.enabled := true;
		self.frmTableFilter.btnClearFilter.enabled := true; //25/06/2024	navkc1 CR 64823 Task 64824
	endif;
	/*
	start := self.tblData.fixedRows + 1;
	foreach rowIdx in start to self.tblData.rows do	: rowLoop
		self.tblData.accessRow(rowIdx); // ### TFS 51912 22Sep2021 NAVPW1 Needed as we use accessedRow below. Plus needed for columns of current row
		foreach colIdx in 1 to self.tblData.columns do
			cell := self.tblData.accessCell(rowIdx, colIdx);
			cellText := cell.text.toUpper;
			if cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then
				self.tblData.accessedRow.visible := true;
				continue rowLoop;
			endif;
		endforeach;
		self.tblData.accessedRow.visible := false;
	endforeach;
	*/
end;</source>
    </JadeMethod>
