    <JadeMethod name="getWeightForSummary" id="9aaae569-5e8f-45e0-aa21-7c50f2ff95d5">
        <source>getWeightForSummary(): Decimal;
// ---------------------------------------------------------------------------
// Created:     16 February 2010 by cnwcs5
// Purpose:     CCMS 1925 / PAR 22295 Release Summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti	:CM_TrackedItem;
begin
