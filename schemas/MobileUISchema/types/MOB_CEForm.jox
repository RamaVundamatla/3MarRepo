    <JadeMethod name="adjustFormForDevice" id="2ca34daf-20b8-4fa2-8545-d771ad667187">
        <updating/>
        <source>adjustFormForDevice() updating, protected;
// ---------------------------------------------------------------------------
// Created:	14 August 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
