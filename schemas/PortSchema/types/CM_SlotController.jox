    <JadeMethod name="canTwinLiftWithLocation" id="695f62a2-c6bb-40eb-92c0-f27bd9de7ac0">
        <source>canTwinLiftWithLocation(_nextLocation: CM_LocationsController; 
						_myTrackedItem: CM_TrackedItem; 
						_nextLocationTrackedItem: CM_TrackedItem;
						_mode		: Integer;
						_direction : Integer output;
						_errorString : String io): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 February 2009	cnwer1	Initial creation

*/

vars
	job : CM_VoyageJob;
begin
	if not inheritMethod(_nextLocation,_myTrackedItem,_nextLocationTrackedItem,_mode,_direction,_errorString) then
	
		return false;
	endif;

	_direction:=CM_RTQueueEntry.TWIN_NONE;
	if self = _nextLocation then
	//	write "next loc = self";
		_errorString :=app.getErrorString(Next_voyage_slot_same_self);
		return false;
	endif;
	
	if not _nextLocation.isKindOf(CM_SlotController) then
	//	write "next loc not slot controller";
		_errorString :=app.getErrorString(Next_locatio_voyage_slot);
		return false;
	endif;
	
	
	if self.myBayVoyage = null or _nextLocation.CM_SlotController.myBayVoyage = null then
	//	write "bay voyages null";
		_errorString :=app.getErrorString(Next_voyage_slot_differ_voyage);
		return false;
	endif;
	
	// the bay voyages will differ but the voyage &amp; cellular voyge structure should be the same
	if self.myBayVoyage.myCellularVoyageStructure &lt;&gt; _nextLocation.CM_SlotController.myBayVoyage.myCellularVoyageStructure then
		_errorString :=app.getErrorString(Next_voyage_slot_differ_voyage);
		return false;
	endif;
	
//decided that because straddles will be picking up from crane transfer area just that they are on the same voyage is enough
//i.e. in real life they will just be sitting on the wharf waiting to be collected and the bay plan could of been slightly wrong 
	//check is in the same hold
	
	//epr par 19994 19/6/09
	// we are checking the target location i.e. where the containers are going which in this case will relate to a load job
	if _mode = QUEUE_MODE then
		if self.myBayVoyage.myHold &lt;&gt; _nextLocation.CM_SlotController.myBayVoyage.myHold then
			_errorString :=app.getErrorString(Voyages_holds_differ);
			return false;
		endif;
		
		if self.myBayVoyage = _nextLocation.CM_SlotController.myBayVoyage then
			_errorString :=app.getErrorString(Same);
			return false;
		endif;
		
		//check is in the same cell (column)
		if self.ordinalCell &lt;&gt; _nextLocation.CM_SlotController.ordinalCell then
			_errorString := app.getErrorString(Voyages_cells_differ);
			return false;
		endif;
		
		//check is in the same row
		if self.ordinalDeck &lt;&gt; _nextLocation.CM_SlotController.ordinalDeck then
			_errorString :=app.getErrorString(Voyages_decks_differ);
			return false;
		endif;
		//check is in the same row
		if self.ordinalTier &lt;&gt; _nextLocation.CM_SlotController.ordinalTier then
			_errorString :=app.getErrorString(Voyages_tiers_differ);
			return false;
		endif;
	endif;

	_direction:=CM_RTQueueEntry.TWIN_BOTH;
	return true;
epilog

end;</source>
        <Parameter name="_nextLocation" type="CM_LocationsController"/>
        <Parameter name="_myTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_nextLocationTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_direction" type="Integer" usage="output"/>
        <Parameter name="_errorString" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cellId" id="1ec44560-5c03-416a-9028-878abdd8b8fc">
        <methodInvocation>mapping</methodInvocation>
        <source>cellId(_set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     02 April 2002 by cnwdwq1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

begin
	if _set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	_value := self.mySlotDefnVoyage.cellId;
end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="changeTrackedItemSize" id="ec7ce674-f807-4f96-9399-4438b4218637">
        <updating/>
        <source>changeTrackedItemSize(_moveMode : Integer; _ti : CM_TrackedItem input; 
					_originalHeight, _originalLength : Integer;
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     23 February 2001 by cnwdwq1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	newHeight, newLength: Real;
	control : CMIF_MoveController;
begin
	inheritMethod(_moveMode, _ti, _originalHeight, _originalLength, _passport);
	
	// PAR 16415 CCMS 1029
//	newLength := _ti.getLengthInUnits();
	newLength := _ti.getActualLength();
	newHeight := _ti.getHeightOfTI();
	//----------------------
	// If there is no height or length size change then ...nothing to do...
	//----------------------
	if ( (newHeight = _originalHeight) and (newLength = _originalLength) ) then
		return;
	endif;
	if self.isTIPrimaryLocation(_ti, _moveMode) = false then
		//Not primary location, quit now. They MUST change it from the primary slot
		app.raiseCMException3(Err_BackEndAlteration, _ti.id, 'slot', 'voyage', null, null);
		return;
	endif;
	//------------------
	//We need to create a moveController to do the work
	//------------------
	create control transient;
	control.setMyToPrimaryLocation(self);
	control.setMoveMode(_moveMode);
	control.setMyTrackedItem(_ti);
	control.setMyOriginatingLocation(self);
	control.isSystemMove := true;
	control.isResizing := true;
	//cnwth2a added this to ignore same position warning
	control.isForcedMove := true;
	//------------------------------
	// See if length attribute has changed...
	//------------------------------
	if newLength &lt;&gt; _originalLength then 
		// if extending OR retracting we need to determine how many slots.
		if not self.getSpannedToLCs(control) then
			//Not enough space!
			app.setContinueCMExceptions(false);
			app.raiseCMException1(ERR_MORPH_NOT_40_FRONT, newLength.String, null, null); // PAR 21746
			return;	
		endif;
		//We dont care what happens to the height, at the end of the day you can have as many boxes as you want
	endif;
	//----------------
	//Do the move.	
	//----------------
	control.warningsHaveBeenAcknowledged := true;
	control.executeMove(_passport);
epilog
	//Cleanup
	delete control;
end;</source>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_originalHeight" type="Integer"/>
        <Parameter name="_originalLength" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
