Date		: 29 September 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	self.lastSuccessfullTS := _timeStamp;
end;</source>
        <Parameter name="_timeStamp" type="TimeStamp"/>
    </JadeMethod>
</Class>
