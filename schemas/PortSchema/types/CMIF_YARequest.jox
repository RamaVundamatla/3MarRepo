    <JadeMethod name="isBookingRef_Match" id="e4011f83-808d-4628-8d64-9569de1c9cc9">
        <source>isBookingRef_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 26 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	// Return true because cargo type is not being used.
	if self.myBookingRef = null then
		return true;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	// Do we have a match?
	return _yaData.matches(self.myBookingRef);

end;</source>
