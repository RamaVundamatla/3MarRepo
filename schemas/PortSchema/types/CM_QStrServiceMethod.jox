    <JadeMethod name="setComboValues" id="50b9a7a9-2807-4a74-bbdc-6c217fc57efd">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts

*/

vars
	serviceObjSet : ObjectSet;
	service : CM_Service;
	edition : Integer;
	invalidObj : Boolean;

	terminal : CM_Terminal;
	termCrit			: CM_SelectorCriteriaLine;
	ut					: CM_UserTerminal;
	obj					: Object;
	os					: ObjectSet;
	
	dict				: CM_ServiceByNameDict;
	
begin
	_combo.clear();
	create dict transient;
	
	//We get services in play based on the banks in play.
	create serviceObjSet  transient;
	self.getServicesInPlay( _params, serviceObjSet );
	
	if serviceObjSet.isEmpty then
		//nothing to do
		return;
	endif;
	
	//so populate the services based on the banks found
	foreach obj in serviceObjSet do
		service := obj.CM_Service;
		if dict[service.name] = null then
			dict.add(service);
		endif;
		_combo.itemObject[ _combo.addItem( self.translateToDisplayValue(service).String ) ] := service;
	endforeach;
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := dict[_queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := dict[_queryOperator.CM_QStringLookupNotEqual.selectionValue];
	endif;

epilog
	delete os;
	delete dict;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="60a4df99-6527-474c-b296-55775ef876d2">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts

*/

vars

	serviceObjSet  : ObjectSet;
	obj 		   : Object;
	service        : CM_Service;
	selectionValue : Integer;
	idx 		   : Integer;

begin

	_tbl.clear;
	_tbl.rows := 0;
	_tbl.sortColumn[1] := 2;
	
	//We get services in play based on the banks in play.
	create serviceObjSet  transient;
	self.getServicesInPlay( _params, serviceObjSet );
	
	if serviceObjSet.isEmpty then
		//nothing to do
		return;
	endif;
	
	//so populate the services based on the banks found
	foreach obj in serviceObjSet do
		service := obj.CM_Service;
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.CM_QStringLookupIsOneOf.allSelectionValues.includes(service.name) then
			selectionValue := 1;
		endif;
		idx := _tbl.addItem( selectionValue.String &amp; Tab &amp; self.translateToDisplayValue(service).String );
		_tbl.accessRow(idx).itemObject := service;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;

epilog

	delete serviceObjSet;

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="8863bc5d-1607-4912-8f12-9456c7a2622d">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts

*/

vars
	service : CM_Service;
	str : String;
	numRows, idx : Integer;
	sa : StringArray;

begin
	create sa transient;
	
	numRows := _tbl.rows;
	foreach idx in _tbl.fixedRows + 1 to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			service := _tbl.accessRow(idx).itemObject.CM_Service;
			sa.add(service.name);
		endif;
	endforeach;
	
	_op.setSearchValue(sa);

epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="7e3ed114-37bc-4cf2-8bb6-2dc56ddb77c0">
        <source>translateToDisplayValue(_value: Any): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts

*/

vars

	service : CM_Service;

begin
	if _value.isKindOf(CM_Service) then
		if _value &lt;&gt; null then
			service := _value.CM_Service;
			return service.name &amp; "  [" &amp; service.bank.code &amp; "/" &amp; service.bank.terminal.code &amp; "]";
		else
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="29f80066-0d89-4b47-8644-6866009da313">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars
	invalidObj : Boolean;
	object 	   : CM_Service;
	returnVal  : String;
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then
			return _value;
		endif;
		
		if _value.isKindOf(CM_Service) then
			object := _value.CM_Service;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.name;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
