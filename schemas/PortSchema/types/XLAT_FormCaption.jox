    <JadeMethod name="vControlName" id="59189836-f025-4227-9197-64fd244e210f">
        <methodInvocation>mapping</methodInvocation>
        <source>vControlName(set: Boolean; _value: String io) mapping;

vars
	doc : JadeXMLDocument;
	attr : JadeXMLAttribute;
	invalid : Boolean;
begin
	if self.myGlobalConstant = null then
		_value := null;
		return;
	endif;
	on Exception do app.handleDeletedObject(exception, self.myGlobalConstant, invalid); 
	create doc transient;
	doc.parseString(self.myGlobalConstant.text);
	if invalid then
		_value := null;
		return;
	endif;
	_value := doc.getElementByTagName("ErrorMsg").getAttributeByName("ControlName").value;
epilog
	delete doc;
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vControlProperty" id="6f48d3ac-42ba-41f9-9a68-1a71591f974b">
        <methodInvocation>mapping</methodInvocation>
        <source>vControlProperty(set: Boolean; _value: String io) mapping;

vars
	doc : JadeXMLDocument;
	attr : JadeXMLAttribute;
	 invalidConstant	: Boolean;
begin
	if self.myGlobalConstant = null then
		_value := null;
		return;
	endif;

	create doc transient;
	on Exception do app.handleDeletedObject(exception, self.myGlobalConstant, invalidConstant);
	doc.parseString(self.myGlobalConstant.text);
	if invalidConstant then
		_value := null;
		return;
	endif;
	
	_value := doc.getElementByTagName("ErrorMsg").getAttributeByName("ControlProperty").value;
epilog
	delete doc;
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="vFormClass" id="bde88669-cf07-4c4b-a439-d56b402b4c43">
        <methodInvocation>mapping</methodInvocation>
        <source>vFormClass(set: Boolean; _value: String io) mapping;
// 10/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
vars
	doc : JadeXMLDocument;
	attr : JadeXMLAttribute;
    invalidConstant	: Boolean;
	globalConstant : GlobalConstant;
begin
	globalConstant := self.myGlobalConstant;
	if globalConstant = null then
		_value := null;
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, globalConstant, invalidConstant);
	create doc transient;
	doc.parseString(globalConstant.text);
	if invalidConstant then
		_value := null;
		return;
	endif;
	
	_value := doc.getElementByTagName("ErrorMsg").getAttributeByName("FormClass").value;
epilog
	delete doc;
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
