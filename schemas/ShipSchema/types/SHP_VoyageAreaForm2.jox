    <JadeMethod name="doMnuWorkRemarksBayBuild" id="0b41cf44-9307-4c01-9a77-eec80435e85e">
        <source>doMnuWorkRemarksBayBuild();
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	idx,idex : Integer;
	aVoyage : CM_Voyage;
	theBay : CM_Bay;
	theHold : CM_Hold;
	subMenu, subSubMenu : MenuItem;
begin
	aVoyage := self.myCurrentVoyage;
	if aVoyage = null then
		return;
	endif;
	self.doPurgeSubMenus(self.mnuWorkRemarks2);
	
	foreach theHold in aVoyage.myCellularVoyageStructure.allHolds do
		idx := idx + 1;
		subMenu := self.mnuWorkRemarks2.getMenuItem(idx);
		if subMenu = null then
			subMenu := self.mnuWorkRemarks2.loadSubMenu(idx);
		endif;

		subMenu.caption := "Hold " &amp; theHold.ordinalHold.String.padLeadingZeros(2);
		subMenu.userObject := null;
		foreach theBay in theHold.allBays do
			idx := idx + 1;
			subSubMenu := self.mnuWorkRemarks2.getMenuItem(idx);
			if subSubMenu = null then
				subSubMenu := subMenu.loadSubMenu(idx);
			endif;
	
			subSubMenu.caption := "Bay " &amp; theBay.id;
			subSubMenu.userObject := theBay;
		endforeach;
	endforeach;

end;</source>
    </JadeMethod>
