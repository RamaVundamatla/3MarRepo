    <JadeMethod name="jssGetMemberType" id="80169edb-3b1a-4b68-9df6-14f071b24a3b">
        <source>jssGetMemberType():Type;
// --------------------------------------------------------------------------------
// Created:		15 March 2001 by cnwdad1
//
// Purpose:		Returns the Type of the receiver's membership.
//
// Parameters:	None
//
// Returns:		The Type of the receiver's membership.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return class().CollClass.getMemberType();
end;</source>
        <ReturnType type="Type"/>
    </JadeMethod>
    <JadeMethod name="jssIsNotEmpty" id="860c10b5-9fc1-4f75-891b-0c735ee4f6ae">
        <source>jssIsNotEmpty():Boolean;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		To check whether the receiver has any members.
//
// Parameters:	None
//
// Returns:		True if the receiver has any members, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (not self.isEmpty());
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
