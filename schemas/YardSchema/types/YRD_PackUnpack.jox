    <JadeMethod name="chbFilter_change" id="db0f29d2-af09-406e-8595-7a9f5a3870fc">
        <controlMethod name="CheckBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chbFilter_change(checkbox: CheckBox input) updating;
//  37288 apply filter or clear filtered result
vars
	release		: CM_BulkRelease;
begin
	if self.chbFilter.value then
		release := self.cmbBR.listObject.CM_BulkRelease;
	endif;
	// rebuild the list of containers to pack
	if self.cmbCargoType.listObject &lt;&gt; null then
		self.myAssistant.comboBoxTrackedItemCmbPack(self.cmbTrackedItem, self.cmbCargoType.listObject.CM_CargoType.id, self.myTI, self.cmbBooking.listObject.CM_BookingRef, release);					// PAR #31196
	endif;
	// rebuild the list of cargo to pack
	self.doSearch();
end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkContainerHasBeenEntered" id="62a530ad-e6ea-41aa-840c-6f8b4a17eefc">
        <source>checkContainerHasBeenEntered():Boolean protected;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 28 January 2004
//
//********************************************************************
vars

begin
	if self.cmbTrackedItem.text = null then
		return false;
	endif;
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearTableContainerValues" id="014d9502-334f-450a-b651-31123956cd6c">
        <updating/>
        <source>clearTableContainerValues(_restoreBooking : Boolean)updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 13 November 2003
//
//********************************************************************
/*

Date		Who		Reason
06 Jul 2010	cnwkpd1	PAR #24795 - Tidy up notifications and performance of Pack/Unpack
16 Aug 2023 navma1	Bug 58727: ATD - Pack/Unpack gives Error (1201). Kernel stack overflow
*/

vars
	release				: CM_BulkRelease;		
	booking				: CM_BookingRef;		
	bookingItem			: CM_BookingRefItem;	
	cargoTypeObj		: Object;
begin
	if _restoreBooking then
		release 	:= self.cmbBR.listObject.CM_BulkRelease;					
		booking 	:= self.cmbBooking.listObject.CM_BookingRef;				
		bookingItem := self.cmbBookingItem.listObject.CM_BookingRefItem;	
	endif;
	self.tblContainer.clearValues();
	self.cmbTrackedItem.listIndex := -1;
	self.cmbTrackedItem.text 	  := null;
	self.doRestoreReleaseAndBooking(release, booking, bookingItem);		// PAR #23925
	//restore cargoType to what it was

	cargoTypeObj := self.cmbCargoType.myObject;
	
	if cargoTypeObj &lt;&gt; null then
		self.cmbCargoType.setObject(cargoTypeObj);
		self.tblContainer.setValueByControlName(cmbCargoType.name, cmbCargoType.text);
	else
		//set to the default cargo type
		cargoTypeObj := app.myRoot.allCargoTypesById[self.myTerminal.defaultCargoType];
		if cargoTypeObj &lt;&gt; null and cargoTypeObj.isKindOf(CM_CargoType) then
			if self.myTerminal.allCargoBOLTypes.includes(cargoTypeObj.CM_CargoType) then
				self.cmbCargoType.setObject(cargoTypeObj);
				self.cmbCargoType.lostFocus(self.cmbCargoType);	
			endif;
		endif;
	endif;
	
	// 28474 Mar 2012 restore cargo type and complete transaction combos as for 24046 and 25258 elsewhere

	self.cmbCompTrans.text := app.getString(Default);
	self.tblContainer.setValueByName(ETRow_CompleteTransaction, self.cmbCompTrans.text);
	if self.myTI &lt;&gt; null then							// PAR #24795
		self.disarmNotesForObject(self.myTI);
	endif;
	
	self.myTI := null;
	
	self.disarmNotesForTableObjects(self.tblPacked);	// PAR #24795
	self.tblPacked.rows := self.tblPacked.fixedRows;
	
end;</source>
        <Parameter name="_restoreBooking" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cmbBR_dropDown" id="e4806cd6-bd33-4bd8-bae5-e9c5d59cb199">
