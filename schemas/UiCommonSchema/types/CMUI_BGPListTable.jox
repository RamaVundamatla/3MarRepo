    <JadeMethod name="addSelectedObject" id="7031ed4a-58dc-45fe-994d-876ed3ea032d">
        <updating/>
        <source>addSelectedObject(_obj : Object) updating;
// ---------------------------------------------------------------------------
// Created:     01 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	
begin
	if _obj = null then
		return;
	endif;
	
	if (not self.allSelectedObjects.includes(_obj)) then
		self.allSelectedObjects.add(_obj);
		
		if self.findObjectInRow(_obj, rowPointer) then
			self.accessCell(rowPointer, self.chkBoxColumn).text	:=	TableCheckBox_Selected;
		endif;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="change" id="3fc2c26b-58c1-4a53-94e4-33713921d4c2">
        <updating/>
        <source>change(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rowObject	: Object;
	itemObj		: CM_AutoWarningItem;
	rowPointer	: Integer;
	
begin
	inheritMethod(table);
	rowPointer	:=	table.row;

	if rowPointer &gt; 0 and rowPointer &lt;= table.rows then
		rowObject	:=	table.accessRow(rowPointer).itemObject;
		
		if rowObject.isKindOf(CM_AutoWarningItem) then
			itemObj	:=	rowObject.CM_AutoWarningItem;
			itemObj.set(table.getCellText(rowPointer, 3).Integer,
						table.getCellText(rowPointer, 4).Integer,
						itemObj.className,
						null);
		endif;
		
		if self.rowChecked(table.row) then
			if (not self.allSelectedObjects.includes(rowObject)) then
				self.allSelectedObjects.add(rowObject);
			endif;
		else
			if self.allSelectedObjects.includes(rowObject) then
				self.allSelectedObjects.remove(rowObject);
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkBoxFirst" id="852188ca-5f41-4ce5-9c4d-3d378ceb05b7">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>chkBoxFirst(set: Boolean; _value: Boolean io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if set then
		if _value then
			self.chkBoxColumn 	:=	1;
		else
			self.chkBoxColumn 	:=	self.columns;
		endif;
	else
		_value := (self.chkBoxColumn = 1);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="clear" id="2cdebe39-a066-46c5-80af-747fef08cd82">
        <executionLocation>client</executionLocation>
        <source>clear() clientExecution;
//----------------------------------------------------------------
//	Created:	29 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
begin
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="clearSelected" id="d97a5aac-2ded-4b3a-9aff-0bd060df7eae">
        <updating/>
        <source>clearSelected() updating;

vars
	maxRows		: Integer;
	theFirstRow	: Integer;
	rowPointer	: Integer;
	chkCol		: Integer;
	
begin
	self.allSelectedObjects.clear();
	chkCol		:=	self.chkBoxColumn;
	maxRows		:=	self.rows;
	theFirstRow	:=	self.fixedRows + 1;
	
	foreach rowPointer in theFirstRow to maxRows do
		self.accessCell(rowPointer, chkCol).text	:=	TableCheckBox_NotSelected;
		self.accessRow(rowPointer).selected			:=	false;
	endforeach;

	if maxRows &gt;= theFirstRow then
		self.row	:=	theFirstRow;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="clearTable" id="3e4d8286-2f11-4ec5-8634-70f658b0621e">
        <updating/>
        <source>clearTable() updating;
//--------------------------------------------------
// Created:	25 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.allSelectedObjects.clear();
	self.clear();
	self.rows	:=	0;	
end;</source>
    </JadeMethod>
    <JadeMethod name="click" id="aa960d33-ac58-406a-8205-28cd3d6a450a">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(table: Table input) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		28 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.change(table);
	inheritMethod(table);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="1458ff4f-4c3e-4e7c-a994-6bee35bd40c9">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.rows 			:=	1;
	self.columns 		:=	4;
	self.fixedRows 		:=	1;
	self.fixedColumns	:=	0;
	
	self.selectMode		:=	self.SelectMode_Row;
	self.gridLines		:=	true;
	self.scrollBars		:=	self.ScrollBars_Vertical;
	self.autoSize		:=	self.AutoSize_ColumnMinimum;
	self.chkBoxFirst	:=	true;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="c9c674fc-bd4a-4b21-8301-043c0294ec65">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		01 March 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.purgeTableObjects();
end;</source>
    </JadeMethod>
    <JadeMethod name="findObject" id="32fe2324-88d9-4eb9-8cbd-1f720dfd6b2a">
        <updating/>
        <source>findObject(_obj : Object; _rowIdx : Integer io) : Boolean updating;
//-----------------------------------------
//Created: January 2003 By: cnwgd1
//-----------------------------------------
vars
	rowPointer	: Integer;
	startPos	: Integer;
	numRows		: Integer;
	isFound		: Boolean;
	tableRowObj	: JadeTableRow;
	
begin
	numRows	:=	self.rows;
	
	if _rowIdx &gt; numRows then
		return isFound;
	endif;
	
	startPos	:=	(self.fixedRows + 1).max(_rowIdx);
	
	if startPos &gt; numRows then
		return isFound;
	endif;	 
	
	foreach rowPointer in startPos to numRows do
		tableRowObj	:=	self.accessRow(rowPointer);
		
		if tableRowObj.itemObject = _obj then
			isFound	:=	true;
			_rowIdx	:=	rowPointer;
			break;
		endif;
	endforeach;
epilog
	return isFound;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findObjectInRow" id="0bac5630-b7f9-4fcb-8dbc-384a8d00943e">
        <updating/>
        <source>findObjectInRow(_obj : Object; _rowIdx : Integer io) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     15 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	startPos	: Integer;
	numRows		: Integer;
	isFound		: Boolean;
	
begin
	if _obj = null then
		return isFound;
	endif;
	
	numRows	:=	self.rows;
	
	if _rowIdx &gt; numRows then
		return isFound;
	endif;
	
	startPos	:=	(self.fixedRows + 1).max(_rowIdx);
	
	if startPos &gt; numRows then
		return isFound;
	endif;	 
	
	foreach rowPointer in startPos to numRows do
		if self.accessRow(rowPointer).itemObject = _obj then
			isFound	:=	true;
			_rowIdx	:=	rowPointer;
			break;
		endif;
	endforeach;
epilog
	return isFound;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSelectedAsStringArray" id="d34a419c-780d-44c6-8be8-15e04112d594">
        <updating/>
        <source>getSelectedAsStringArray(_stringArray : StringArray input) updating;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	colPointer	: Integer;
	rowPointer	: Integer;
	totalRows	: Integer;
	
begin
	if _stringArray = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null array');
		return;
	endif;

	totalRows	:=	self.rows;
	
	if totalRows &lt; 1 then
		return;
	endif;

	if self.chkBoxFirst then
		colPointer	:=	self.chkBoxColumn + 1;
	else
		colPointer	:=	self.chkBoxColumn - 1;
	endif;	
	
	foreach rowPointer in 1 to totalRows do
		if self.accessCell(rowPointer, self.chkBoxColumn).text = TableCheckBox_Selected then
			_stringArray.add(self.accessCell(rowPointer, colPointer).text);
		endif;
	endforeach;
end;</source>
        <Parameter name="_stringArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedFromDisplay" id="93429645-b739-4d9e-9015-41aac6342c23">
        <source>getSelectedFromDisplay() : String;
// -------------------------------------------
// Created 26 October 2004 by cnwdvb1
// -------------------------------------------
vars
	displayValue	: String;
	rowPointer		: Integer;
	totalRows		: Integer;
	colPointer		: Integer;
	tableObj		: CMUI_BGPListTable;

begin
	totalRows	:=	self.rows;
	tableObj	:=	self;
	
	if tableObj.chkBoxFirst then
		colPointer	:=	tableObj.chkBoxColumn + 1;
	else
		colPointer	:=	tableObj.chkBoxColumn - 1;
	endif;
	
	foreach rowPointer in 1 to totalRows do
		if self.allSelectedObjects.includes(tableObj.accessRow(rowPointer).itemObject) then
			if displayValue &lt;&gt; null then
				displayValue	:=	displayValue &amp; ', ';
			endif;
			
			displayValue	:=	displayValue &amp; tableObj.accessCell(rowPointer, colPointer).text; 
		endif;
	endforeach;

	return displayValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedString" id="6f328f7b-6a87-441e-a063-5e604ab4ce64">
        <source>getSelectedString(pAttrName : String) : String;
// ---------------------------------------------------------------------------
// Created:     23 March 2001 by cnwrs2
//
// Purpose:     Returns a string of all the selected objects
//
// Parameters:  The attribute name on the object to display (eg. code)
//
// Returns:     The string of all the selected objects.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	selectedObj		: Object;
	returnValue		: String;
	
begin
	if self.allSelectedObjects.size = 0 then
		if self.useAnyStringWhenNonSelected then
			returnValue	:=	Any_String;
		endif;
	else
		foreach selectedObj in self.allSelectedObjects do
			if returnValue &lt;&gt; null then
				returnValue	:=	returnValue &amp; ', ';
			endif;
			
			returnValue	:=	returnValue &amp; selectedObj.getPropertyValue(pAttrName).String.trimBlanks;
		endforeach;
	endif;

	return returnValue;	
end;</source>
        <Parameter name="pAttrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedStringXML" id="636f3661-925a-495f-a96b-a170ac03adfa">
        <source>getSelectedStringXML(_attrName, _tag : String) : String;

// cnwdvb1 20 March 2003 

vars
	selectedObj		: Object;
	tempString		: String;
	xmlString	: String;
	
begin
	if self.allSelectedObjects.size = 0 then
		xmlString	:=	Any_String;
	else
		foreach selectedObj in self.allSelectedObjects do
			if xmlString &lt;&gt; null then
				xmlString	:=	xmlString &amp; ', ';
			endif;
			
			tempString	:=	selectedObj.getPropertyValue(_attrName).String;
			xmlString	:=	xmlString &amp; tempString.cnEcGetTagValueOfName(_tag);
		endforeach;
	endif;
	
	return xmlString;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_tag" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedStrings" id="6e92af62-0073-4d7b-bb84-16f2e1deb0b5">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>getSelectedStrings(_stringArray : CM_StringArray input)updating, clientExecution;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	colPointer	: Integer;
	rowPointer	: Integer;
	totalRows	: Integer;
	rowObject	: Object;
	
begin
	if _stringArray = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null array');
		return;
	endif;

	totalRows	:=	self.rows;
	
	if totalRows &lt; 1 then
		return;
	endif;

	if self.chkBoxFirst then
		colPointer	:=	self.chkBoxColumn + 1;
	else
		colPointer	:=	self.chkBoxColumn - 1;
	endif;	
	
	foreach rowPointer in 1 to totalRows do
		if self.accessCell(rowPointer, self.chkBoxColumn).text = TableCheckBox_Selected then
			rowObject	:=	self.accessRow(rowPointer).itemObject;
			
			if CM_TransactionType.hasInstance(rowObject) then
				_stringArray.add(rowObject.CM_TransactionType.classNameToCreate);
			else
				_stringArray.add(self.accessCell(rowPointer, colPointer).text);
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="_stringArray" type="CM_StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getXMLStringForSelected" id="c1c59cdd-0cd3-4d5a-96e5-0765a0c3ca42">
        <source>getXMLStringForSelected(_attrNames : StringArray) : String;
// -------------------------------------------
// Created 18 February 2004 by cnwdvb1
// -------------------------------------------
vars
	selectedObj	: Object;
	xmlString	: String;
	tempString	: String;
	attrName	: String;

begin
	if not self.allSelectedObjects.isEmpty then
		xmlString	:=	self.formatAsXMLPrefix(XMLTag_ListTable &amp; self.name);
		
		foreach selectedObj in self.allSelectedObjects do
			tempString	:=	null;
			
			foreach attrName in _attrNames do
				if tempString &lt;&gt; null then
					tempString	:=	tempString &amp; ',';
				endif;
				
				tempString	:=	tempString &amp; selectedObj.getPropertyValue(attrName).String;
			endforeach;
			
			xmlString	:=	xmlString &amp;  global.formatAsXML(XMLTag_SelectedValue, tempString);
		endforeach;
		
		xmlString	:=	xmlString &amp; self.formatAsXMLSuffix(XMLTag_ListTable &amp; self.name);
	endif;
	
	return xmlString;
end;</source>
        <Parameter name="_attrNames" type="StringArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="c4b384e5-8378-4bbb-93bf-faf8aa276a21">
        <updating/>
        <source>mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
