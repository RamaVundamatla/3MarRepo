    <JadeMethod name="cnEcXmlImportObjectAttributes" id="b7a267cb-0d18-4fc6-83c5-eb95e7f8b448">
        <updating/>
        <source>cnEcXmlImportObjectAttributes(	pObject:Object input;
								pInput: CnEcXmlStructureInstance;
								pOidTable: CnEcOidTable io;
								pLoadStage : Integer;
								pErrorMsg : String io;
								pFormat : CnEcXmlFormat;
								pMergeDuplicateCheck : Boolean
								):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		10 October 2000 by cnwdad1
//
// Purpose:		Import an object's attributes from an XML structure.
//
// Parameters:	pObject - The object who's attributes to import.
//				pInput - The XML structure containing the attribute details.
//				pOidTable - A container of object OIDs.
//				pLoadStage - One of four data-load stages.  Refer to the CnEcData_Load_Type
//					category of Global Constants for possible stages.
//				pErrorMsg - Returns an error message if the load fails.
//				pFormat - The BaseSchema XML Format which describes how to load the
//					attributes.
//				pMergeDuplicateCheck - If true, then a check for duplicates will be
//					done.
//
// Returns:		True if the attributes were successfully imported.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	inputField			: CnEcXmlStructureInstance; 
	property			: Property;
	object				: Object;
	value				: String;
	isDataCreated		: Boolean;
	oidPair				: CnEcOidPair;
	collection			: Collection;
	smtp 				: CnSmtpConnection;
	binaryData			: Binary;
	allXmlElements		: CnEcXmlStructureInstanceSet;
	allXmlGroups		: CnEcXmlStructureInstance;
	allProperties		: CnEcClassPropertyColls;
	duplicatedObject	: Object;	// the one that already existed 
	objToUpdate			: Object;
	objToDelete			: Object;

begin
	pErrorMsg := "";

	if pLoadStage &lt;&gt; CNEC_DATA_LOAD_ATTRIBUTE then
		pErrorMsg := " LoadStage parameter invalid " &amp; self.getName() &amp; "::" &amp; method.name;
    	return null;	
	endif;

	if pOidTable = null then
		pErrorMsg := " OidTable parameter invalid ";
    	return null;	
	endif;

	if pInput = null then
		pErrorMsg := " HubMsgStructureInstance parameter invalid ";
    	return null;	
	endif;

	if pLoadStage = CNEC_DATA_LOAD_ATTRIBUTE then
		// find the imported oid to populate the dictionary for cross referencing.
		inputField := pInput.findStructure("oid");
		if app.isValidObject(inputField) then
			value := inputField.tagData;
			if value &lt;&gt; "" and pOidTable.allOidPairsByImported.getAtKey(value) = null then
				create oidPair;
				oidPair.intializeMe(pObject.getOidString(), value, pOidTable);
			endif;
		endif;
	else
	endif;
	
	if pMergeDuplicateCheck then
		duplicatedObject := pObject.cnEcGetDuplicate(pFormat,pInput);
	endif;
	
	objToUpdate := pObject;
	
	if duplicatedObject &lt;&gt; null then	
		//found a duplicate already in the database, use that and delete the newly created one.
		pErrorMsg := "Duplicate";
		oidPair.duplicateOf(duplicatedObject);
		objToUpdate := duplicatedObject;
		objToDelete := pObject;
		delete objToDelete;
	endif;
	
	// check to see if we have any data for each property in the collection of properties for this object.
	allProperties := getThePropertyCollection(objToUpdate);
			
	foreach object in allProperties.propertyColl do
		property := object.Property;


		if Reference.hasInstance(property) then
			continue;					
		endif;
		
		inputField := getTheInputField(pFormat, pInput, property, objToUpdate);
					
		if app.isValidObject(inputField) then
			value := inputField.tagData;
			if value = "" then
				continue;
			endif;
		else
			continue;	 
		endif;

		if Attribute.hasInstance(property) then

			if property.getType() = String then 
				objToUpdate.setPropertyValue(property.getName(), value);
				
			elseif property.getType() = Integer then 
				objToUpdate.setPropertyValue(property.getName(), value.Integer);
				
			elseif property.getType() = Real then 
				objToUpdate.setPropertyValue(property.getName(), value.Real);
				
			elseif property.getType() = Decimal then 
				objToUpdate.setPropertyValue(property.getName(), value.Decimal);
				
			elseif property.getType() = Boolean then 
				objToUpdate.setPropertyValue(property.getName(), value.Boolean);
				
			elseif property.getType() = Binary then 
				create smtp transient;
				smtp.emBase64Decode(value, binaryData); 
				objToUpdate.setPropertyValue(property.getName(), binaryData);
				delete smtp;
				
			elseif property.getType() = Character then 
				objToUpdate.setPropertyValue(property.getName(), value.Character);
				
			elseif property.getType() = Date then 
				objToUpdate.setPropertyValue(property.getName(), value.Date);
				
			elseif property.getType() = Point then 
				objToUpdate.setPropertyValue(property.getName(), value.Point);
				
			elseif property.getType() = Time then 
				objToUpdate.setPropertyValue(property.getName(), value.Time);
				
			elseif property.getType() = TimeStamp then 
				objToUpdate.setPropertyValue(property.getName(), value.TimeStamp);
// cnwdad1 29/09/202
//	    		elseif property.getType().isKindOf(CollClass) then	// This is some kind of Array    		
			elseif CollClass.hasInstance(property.getType()) then	// This is some kind of Array    		
				if property.getType() = BinaryArray then
					create smtp transient;
					create allXmlElements transient; 
					inputField.findAllStructures("Binary", allXmlElements);
					collection := objToUpdate.getPropertyValue(property.getName()).Collection;
					foreach allXmlGroups in allXmlElements do
						if app.isValidObject(allXmlGroups) then
							smtp.emBase64Decode(allXmlGroups.tagData, binaryData);
							collection.add(binaryData);
						else
							continue;	 
						endif;
					endforeach;
					delete smtp;  
							
				elseif property.getType() = BooleanArray then
					create allXmlElements transient; 
					inputField.findAllStructures("Boolean", allXmlElements);
					collection := objToUpdate.getPropertyValue(property.getName()).Collection;
					foreach allXmlGroups in allXmlElements do
						if app.isValidObject(allXmlGroups) then
							collection.add(allXmlGroups.tagData.Boolean);
						else
							continue;	 
						endif;
					endforeach; 
										
				elseif property.getType() = CharacterArray then
					create allXmlElements transient; 
					inputField.findAllStructures("Character", allXmlElements);
					collection := objToUpdate.getPropertyValue(property.getName()).Collection;
					foreach allXmlGroups in allXmlElements do
						if app.isValidObject(allXmlGroups) then
							collection.add(allXmlGroups.tagData.Character);
						else
							continue;	 
						endif;
					endforeach; 
										 
				elseif property.getType() = DateArray then
					create allXmlElements transient; 
					inputField.findAllStructures("Date", allXmlElements);
					collection := objToUpdate.getPropertyValue(property.getName()).Collection;
					foreach allXmlGroups in allXmlElements do
						if app.isValidObject(allXmlGroups) then
							collection.add(allXmlGroups.tagData.Date);
						else
							continue;	 
						endif;
					endforeach; 
										 
				elseif property.getType() = DecimalArray then
					create allXmlElements transient; 
					inputField.findAllStructures("Decimal", allXmlElements);
					collection := objToUpdate.getPropertyValue(property.getName()).Collection;
					foreach allXmlGroups in allXmlElements do
						if app.isValidObject(allXmlGroups) then
							collection.add(allXmlGroups.tagData.Decimal);
						else
							continue;	 
						endif;
					endforeach; 
					 
				elseif property.getType() = HugeStringArray then
					create allXmlElements transient; 
					inputField.findAllStructures("HugeString", allXmlElements);
					collection := objToUpdate.getPropertyValue(property.getName()).Collection;
					foreach allXmlGroups in allXmlElements do
						if app.isValidObject(allXmlGroups) then
							collection.add(allXmlGroups.tagData);
						else
							continue;	 
						endif;
					endforeach; 
					 
				elseif property.getType() = IntegerArray then
					create allXmlElements transient; 
					inputField.findAllStructures("Integer", allXmlElements);
					collection := objToUpdate.getPropertyValue(property.getName()).Collection;
					foreach allXmlGroups in allXmlElements do
						if app.isValidObject(allXmlGroups) then
							collection.add(allXmlGroups.tagData.Integer);
						else
							continue;	 
						endif;
					endforeach; 
					 
				elseif property.getType() = PointArray then
					create allXmlElements transient; 
					inputField.findAllStructures("Point", allXmlElements);
					collection := objToUpdate.getPropertyValue(property.getName()).Collection;
					foreach allXmlGroups in allXmlElements do
						if app.isValidObject(allXmlGroups) then
							collection.add(allXmlGroups.tagData.Point);
						else
							continue;	 
						endif;
					endforeach; 
					 
				elseif property.getType() = RealArray then
					create allXmlElements transient; 
					inputField.findAllStructures("Real", allXmlElements);
					collection := objToUpdate.getPropertyValue(property.getName()).Collection;
					foreach allXmlGroups in allXmlElements do
						if app.isValidObject(allXmlGroups) then
							collection.add(allXmlGroups.tagData.Real);
						else
							continue;	 
						endif;
					endforeach; 
					 
				elseif property.getType() = StringArray then
					create allXmlElements transient; 
					inputField.findAllStructures("String", allXmlElements);
					collection := objToUpdate.getPropertyValue(property.getName()).Collection;
					foreach allXmlGroups in allXmlElements do
						if app.isValidObject(allXmlGroups) then
							collection.add(allXmlGroups.tagData);
						else
							continue;	 
						endif;
					endforeach;
								
				elseif property.getType() = TimeArray then
					create allXmlElements transient; 
					inputField.findAllStructures("Time", allXmlElements);
					collection := objToUpdate.getPropertyValue(property.getName()).Collection;
					foreach allXmlGroups in allXmlElements do
						if app.isValidObject(allXmlGroups) then
							collection.add(allXmlGroups.tagData.Time);
						else
							continue;	 
						endif;
					endforeach; 
					 
				elseif property.getType() = TimeStampArray then
					create allXmlElements transient; 
					inputField.findAllStructures("TimeStamp", allXmlElements);
					collection := objToUpdate.getPropertyValue(property.getName()).Collection;
					foreach allXmlGroups in allXmlElements do
						if app.isValidObject(allXmlGroups) then
							collection.add(allXmlGroups.tagData.TimeStamp);
						else
							continue;	 
						endif;
					endforeach; 
					 
				endif;	// for Array get types (CollClass)
							
			endif;	// property get type
			isDataCreated := true and ( pErrorMsg = "Duplicate" );	
		endif; // attribute load

	endforeach;
	
	return isDataCreated;
	
epilog
	delete smtp;
	delete allXmlElements;
end;</source>
        <Parameter name="pObject" type="Object" usage="input"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <Parameter name="pOidTable" type="CnEcOidTable" usage="io"/>
        <Parameter name="pLoadStage" type="Integer"/>
        <Parameter name="pErrorMsg" type="String" usage="io"/>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pMergeDuplicateCheck" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcXmlImportObjectCollections" id="bf48d1d2-31a9-4b4e-aa7c-15263949708d">
        <source>cnEcXmlImportObjectCollections(	pObject:Object input;
								pInput: CnEcXmlStructureInstance;
								pOidTable: CnEcOidTable io;
								pLoadStage : Integer;
								pErrorMsg : String io;
								pFormat : CnEcXmlFormat):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 October 2000 by cnwdad1
//
// Purpose:		Import an object's collections from an XML structure.
//
// Parameters:	pObject - The object who's attributes to import.
//				pInput - The XML structure containing the attribute details.
//				pOidTable - A container of object OIDs.
//				pLoadStage - One of four data-load stages.  Refer to the CnEcData_Load_Type
//					category of Global Constants for possible stages.
//				pErrorMsg - Returns an error message if the load fails.
//				pFormat - The BaseSchema XML Format which describes how to load the
//					attributes.
//
// Returns:		True if the collections were successfully imported.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	inputField			: CnEcXmlStructureInstance;
	inputColl			: CnEcXmlStructureInstance;
	property			: Property;
	object				: Object;
	value				: String;
	extKey				: String;
	isDataCreated		: Boolean;
	collection			: Collection;
	extKeyDict			: ExtKeyDictionary;
	allProperties		: CnEcClassPropertyColls;

begin
	pErrorMsg := "";

	if pLoadStage &lt;&gt; CNEC_DATA_LOAD_COLLECTION  then
		pErrorMsg := " LoadStage parameter invalid " &amp; self.getName() &amp; "::" &amp; method.name;
    	return null;
	endif;

	if pOidTable = null then
		pErrorMsg := " OidTable parameter invalid ";
    	return null;
	endif;

	if pInput = null then
		pErrorMsg := " HubMsgStructureInstance parameter invalid ";
    	return null;
	endif;
	
	// get a coll of each of the properties.

	// check to see if we have any data for each property in the collection of properties for this object.
	allProperties := getThePropertyCollection(pObject);	
    foreach object in allProperties.propertyColl do
    	property := object.Property;

    	if Attribute.hasInstance(property) then
			continue;
     	endif;
        
        inputField := getTheInputField(pFormat, pInput, property, pObject);
		
		if app.isValidObject(inputField) then
			value := inputField.tagData;
			
			if value = "" then
				continue;
			endif;
		else
			continue;
		endif;

     	if Reference.hasInstance(property) then

			if ExplicitInverseRef.hasInstance(property) and  property.ExplicitInverseRef.updateMode.Character.toHex.String = "02" then
     			//do nothing Automatic end of Automatic updating
     			continue;
     		endif;

     		if CollClass.hasInstance(property.getType()) then
				inputColl := pInput.findStructure(property.getName());
				
				if inputColl.isKindOf(CnEcXmlGroupInstance) then //
					// must be several values in the collection. 
					foreach inputField in inputColl.CnEcXmlGroupInstance.allFields do
						value := inputField.tagData;
						object := pOidTable.getObject(value);
						
     					if object &lt;&gt; null then
     						collection := pObject.getPropertyValue(property.getName()).Collection;
     						
     						if collection = null then
     							create collection as currentSchema.getClass(property.getType.name);
								pObject.setPropertyValue(property.getName(), collection);
     						endif;
     						
     						if ExtKeyDictionary.hasInstance(collection) then // its a ExtKeyDictionary
     							extKeyDict := collection.ExtKeyDictionary;
     							extKey := inputField.getTagAttribute("key");
								
     							if not extKeyDict.includesKey(extKey) then
	     							extKeyDict.putAtKey(extKey,object);
	     						endif;
     						else
     							if not collection.includes(object) then
     								collection.add(object);
     							endif;
     						endif;
     					endif;

                		isDataCreated := true;
                	endforeach;
                	
                else
                	// must be only one or zero values in the collection.
                	if app.isValidObject(inputColl) then
                		value := inputColl.tagData;
						object := pOidTable.getObject(value);
     					
     					if object &lt;&gt; null then
     						collection := pObject.getPropertyValue(property.getName()).Collection;
     						
     						if collection = null then
     							create collection as currentSchema.getClass(property.getType.name);
								pObject.setPropertyValue(property.getName(), collection);
     						endif;
     						
     						if ExtKeyDictionary.hasInstance(collection) then // its a ExtKeyDictionary
     							extKeyDict := pObject.getPropertyValue(property.getName()).ExtKeyDictionary;
     							extKey := inputField.getTagAttribute("key");
								
     							if not extKeyDict.includesKey(extKey) then 
     								extKeyDict.putAtKey(extKey,object);
     							endif;
     						else
     							if not collection.includes(object) then
     								collection.add(object);
     							endif;
     						endif;
     					endif;
     					
                		isDataCreated := true;
                	endif;
                endif;
     		else
     			continue;
     		endif;
     	endif; 
	endforeach; 

    return isDataCreated;
epilog

end;</source>
        <Parameter name="pObject" type="Object" usage="input"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <Parameter name="pOidTable" type="CnEcOidTable" usage="io"/>
        <Parameter name="pLoadStage" type="Integer"/>
        <Parameter name="pErrorMsg" type="String" usage="io"/>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcXmlImportObjectEpilog" id="529abbdd-b8ea-407d-892c-0285639cb48e">
        <updating/>
        <source>cnEcXmlImportObjectEpilog(pObject : Object; pFormatName : String; pErrorString : String io):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		10 October 2000 by cnwdad1
//
// Purpose:		This method if re-implemented on each class where required, provides
//				a mechanism for performing additional functionality after the import
//				of data via cnEcImport.
//
// Parameters:	pObject - The object to execute the epilog method against.
//				pFormatName - The name of the XML Format to drive the import.
//				pErrorString (String) - An error message.
//
// Returns:		True if successfull, false if unsuccessfull with an optional error
//				message as an IO parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	retValue		: Boolean;
	format			: CnEcXmlFormat;
	className		: String;
	formatClass 	: CnEcXmlFormatClass;
	epiMethodName	: String;
	epiMethod		: Method;
	
begin
	retValue := true;
	
	if pObject = null then
		return retValue;
	endif;
	
	if pFormatName &lt;&gt; "" then
		format := app.cnEcGetXmlFormat(pFormatName);
		
		if format &lt;&gt; null then
			formatClass := format.getFormatClass(pObject.class().name);
			if formatClass &lt;&gt; null then
				epiMethodName := formatClass.epilogMethodName;
			else
				return retValue;
			endif;
		else
			pErrorString := "Invalid format selected.";
			retValue := false;
		endif;
	else
		pErrorString := "No format selected.";
		retValue := false;
	endif;
	
	if epiMethodName = "" then
		return retValue;
	else
		epiMethod := pObject.class().getMethod(epiMethodName);
		if epiMethod &lt;&gt; null then
			pObject.sendMsg(epiMethodName);
		else
			pErrorString := "'" &amp; epiMethodName &amp; "' method not found.";
			retValue := false;
		endif;
	endif;
epilog
	return retValue;
end;</source>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pFormatName" type="String"/>
        <Parameter name="pErrorString" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcXmlImportObjectNoids" id="eb48a139-2878-4942-b6cf-1e4dbb92178d">
        <source>cnEcXmlImportObjectNoids(	pObject:Object;
							pInput: CnEcXmlStructureInstance;
							pOidTable: CnEcOidTable io;
							pLoadStage : Integer;
							pErrorMsg : String io;
							pFormat : CnEcXmlFormat):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 October 2000 by cnwdad1
//
// Purpose:		Import an Object's Noids from an XML structure.
//
// Parameters:	pObject - The object who's attributes to import.
//				pInput - The XML structure containing the attribute details.
//				pOidTable - A container of object OIDs.
//				pLoadStage - One of four data-load stages.  Refer to the CnEcData_Load_Type
//					category of Global Constants for possible stages.
//				pErrorMsg - Returns an error message if the load fails.
//				pFormat - The BaseSchema XML Format which describes how to load the
//					attributes.
//
// Returns:		True if the Noids were successfully imported.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	inputField			: CnEcXmlStructureInstance;
	value				: String;
	oidPair				: CnEcOidPair;
	isDataCreated		: Boolean;
	
begin
	pErrorMsg := "";

	if pLoadStage &lt;&gt; CNEC_DATA_LOAD_NOID   then
		pErrorMsg := " LoadStage parameter invalid " &amp; self.getName() &amp; "::" &amp; method.name;
    	return null;
	endif;

	if pOidTable = null then
		pErrorMsg := " OidTable parameter invalid ";
    	return null;
	endif;

	if pInput = null then
		pErrorMsg := " HubMsgStructureInstance parameter invalid ";
    	return null;
	endif;

	if pLoadStage = CNEC_DATA_LOAD_NOID then
		// find the imported oid to populate the dictionary for cross referencing its NOID.
		inputField := pInput.findStructure("oid");
		
		if app.isValidObject(inputField) then
			value := inputField.tagData;
			
			if value &lt;&gt; "" then
				create oidPair;
				oidPair.intializeMe(pObject.getOidString(), value, pOidTable);
				isDataCreated := true;
			endif;
		endif;
		return isDataCreated;
	endif;
end;</source>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <Parameter name="pOidTable" type="CnEcOidTable" usage="io"/>
        <Parameter name="pLoadStage" type="Integer"/>
        <Parameter name="pErrorMsg" type="String" usage="io"/>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcXmlImportObjectSingletons" id="50c027e1-efc4-4ff4-8093-f9ea0fa3ea1f">
        <source>cnEcXmlImportObjectSingletons(	pObject:Object input;
								pInput: CnEcXmlStructureInstance;
								pOidTable: CnEcOidTable io;
								pLoadStage : Integer;
								pErrorMsg : String io;
								pFormat : CnEcXmlFormat):Boolean;
// --------------------------------------------------------------------------------
// Created:		10 October 2000 by cnwdad1
//
// Purpose:		Import an Object's singleton references from an XML structure.
//
// Parameters:	pObject - The object who's attributes to import.
//				pInput - The XML structure containing the attribute details.
//				pOidTable - A container of object OIDs.
//				pLoadStage - One of four data-load stages.  Refer to the CnEcData_Load_Type
//					category of Global Constants for possible stages.
//				pErrorMsg - Returns an error message if the load fails.
//				pFormat - The BaseSchema XML Format which describes how to load the
//					attributes.
//
// Returns:		True if the singletons were successfully imported.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	inputField1			: CnEcXmlStructureInstance;
	inputField2			: CnEcXmlStructureInstance;
	property			: Property;
	object				: Object;
	value				: String;
	isDataCreated		: Boolean;
	vClassPropertyColl	: CnEcClassPropertyColls;
	isFormatLoad : Boolean;	//30 Jan 2015	NDL

begin
	pErrorMsg := "";

	if pLoadStage &lt;&gt; CNEC_DATA_LOAD_SINGLETON  then
		pErrorMsg := " LoadStage parameter invalid " &amp; self.getName() &amp; "::" &amp; method.name;
    	return null;
	endif;

	if pOidTable = null then
		pErrorMsg := " OidTable parameter invalid ";
    	return null;
	endif;

	if pInput = null then
		pErrorMsg := " HubMsgStructureInstance parameter invalid ";
    	return null;
	endif;
	
	isFormatLoad := ( pOidTable.hubbleId = CNEC_XML_FormatImport ) and ( pFormat &lt;&gt; null and pFormat.formatName = CNEC_DEFAULT_FULL );	//30 Jan 2015	NDL
	
	// get a coll of each of the properties.

	// check to see if we have any data for each property in the collection of properties for this object.
	vClassPropertyColl := getThePropertyCollection(pObject);
    foreach object in vClassPropertyColl.propertyColl do
    	property := object.Property;
    	
    	if Attribute.hasInstance(property) then
			continue;
     	endif;
        
        inputField1 := getTheInputField(pFormat, pInput, property, pObject);
		
		if app.isValidObject(inputField1) then
			value := inputField1.tagData;
			
			if value = "" then
				continue;
			endif;
		else
			continue;
		endif;

     	if Reference.hasInstance(property) then
     		if CollClass.hasInstance(property.getType()) then
     			continue;
     		endif;

			if ExplicitInverseRef.hasInstance(property) then
				if property.ExplicitInverseRef.updateMode.Character.toHex.String = "02" then
	     			//do nothing Automatic end of Automatic updating
    	 			continue;
				endif;
	 		endif;

			if property.getType().isKindOf(CollClass) then
				continue;
				
			else
				if property.getName() = CnEcXmlFormat::myBaseRoot.name and pObject.class().name = CnEcXmlFormat.name then // allows for the load of XMLFormats by XMLFormatter
					pObject.setPropertyValue(property.getName(), app.myBaseRoot);
    	 			isDataCreated := true;
					
				else
					inputField2 := inputField1.findStructure("OID");
					
					if app.isValidObject(inputField2) then
						value := inputField2.tagData;
						object := pOidTable.getObject(value);
						//30 Jan 2015	NDL
						if object = null and isFormatLoad then
							//No NOID file for Format imports, if its a format being imported, find the format to use
							object := self.findReferencedFormat( pObject, property, inputField1, pFormat, pOidTable );
							//29 May 2015	NDL	Par 36350
							if object = null and value &lt;&gt; null and property &lt;&gt; null and property.type = CnEcXmlFormat then
								//OK just get the default oid format
								object := app.cnEcGetXmlFormat(CNEC_DEFAULT_REF);
							endif;
						endif;
							//set up error message to report in case of failure.
						pErrorMsg := "'pObject.setPropertyValue(property.getName(), object)' failed. ";
						pErrorMsg := pErrorMsg &amp; "pObject = '" &amp; pObject.String &amp; "'.  property.getName() = '" &amp; property.getName() &amp; "'.  object = '" &amp; object.String &amp; ".";
						pObject.setPropertyValue(property.getName(), object);
						isDataCreated := true;
						pErrorMsg := ""; //Reset values
					endif;
				
				endif;
     		endif;
     	endif;
	endforeach;

    return isDataCreated;
	
epilog

end;</source>
        <Parameter name="pObject" type="Object" usage="input"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <Parameter name="pOidTable" type="CnEcOidTable" usage="io"/>
        <Parameter name="pLoadStage" type="Integer"/>
        <Parameter name="pErrorMsg" type="String" usage="io"/>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcXmlTagIt" id="a9b9865c-291e-43e6-93ad-1115e24d3461">
        <source>cnEcXmlTagIt(pTag : String; pData: String; pIsDebug : Boolean) : String;
// --------------------------------------------------------------------------------
// Created:		10 October 2000 by cnwdad1
//
// Purpose:		Generates an XML tag and returns it.
//
// Parameters:	pTag - The name of the XML tag.
//				pData - The contents of the XML tag.
//				pIsDebug - Has no effect.
//
// Returns:		The XML tag.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tagString	: String;
	xmlData		: String;
	
begin
	tagString	:= "";
	xmlData		:= pData;

	if pIsDebug then
		tagString := "&lt;" &amp; pTag &amp; "&gt;" &amp; xmlData &amp; "&lt;/" &amp; pTag &amp; "&gt;" &amp; CrLf;
	elseif pData.length() &gt; 0 then
		tagString := "&lt;" &amp; pTag &amp; "&gt;" &amp; xmlData &amp; "&lt;/" &amp; pTag &amp; "&gt;" &amp; CrLf;
	endif;

	return tagString;
end;</source>
        <Parameter name="pTag" type="String"/>
        <Parameter name="pData" type="String"/>
        <Parameter name="pIsDebug" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="findReferencedFormat" id="3b8dfdc3-ac42-4675-9c1d-705c4e364b16">
        <source>findReferencedFormat( pObject:Object input; property : Property; inputField1 : CnEcXmlStructureInstance; pFormat : CnEcXmlFormat; pOidTable: CnEcOidTable io ):Object;
/*

Purpose:			

Parameters:			There is No NOID file for Format imports, if its a format being imported, find the format to use
					and set up the oid pair

Return Value:		

Date		Who		Reason
02 February 2015	cnwndl1	Initial creation	Par 35619

*/

vars

	object : Object;
	inputField2 : CnEcXmlStructureInstance;
	value : String;
	oidPair : CnEcOidPair;
	
begin

	if pObject.isKindOf(CnEcXmlFormatReference) then
		if property.name = CnEcXmlFormatReference::myFormat.name then
			inputField2 := inputField1.findStructure(CnEcXmlFormat::formatName.name);
			if app.isValidObject(inputField2) then
				value := inputField2.tagData;
				if value &lt;&gt; null then
					object := app.myBaseRoot.getXmlFormat( pFormat.schemaName, value );
					if object &lt;&gt; null then
						//add to the oidTable;
						create oidPair;
						oidPair.intializeMe(object.getOidString(), value, pOidTable);
					endif;
				endif;
			endif;
		endif;
	endif;
	
	return object;
	

epilog

end;</source>
        <Parameter name="pObject" type="Object" usage="input"/>
        <Parameter name="property" type="Property"/>
        <Parameter name="inputField1" type="CnEcXmlStructureInstance"/>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pOidTable" type="CnEcOidTable" usage="io"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getFormatXmlString" id="aa416d74-4ad5-43bb-952d-ae10f5dc9d24">
        <source>getFormatXmlString(	pFormatName:String;	
					pObject:Object;
					pIsDebug:Boolean;
					pMaxObjectCount:Integer io;
					pCurrentObjectCount:Integer io;
					pMaxResponseSize:Integer io ) : String;

// Special version of getXmlString used for exporting formats.

vars
	format		: CnEcXmlFormat;
	xmlString	: String;
	
begin
	//format := app.cnEcGetXmlFormat(pFormatName); // needs to be hard coded to BaseSchema
	if app.isValidObject(app.myBaseRoot) then
		format := app.myBaseRoot.getXmlFormat(BaseSchema.name, pFormatName);
	endif;

	if format &lt;&gt; null then
		xmlString := format.cnEcXmlFormatObjectString(pObject, pIsDebug, pMaxObjectCount, pCurrentObjectCount, pMaxResponseSize);
	else
		CnEcBaseXmlException.raise_(CNEC_X_02801, "No format for [" &amp; pFormatName &amp; "]");
	endif;
epilog
	return xmlString;
end;</source>
        <Parameter name="pFormatName" type="String"/>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pIsDebug" type="Boolean"/>
        <Parameter name="pMaxObjectCount" type="Integer" usage="io"/>
        <Parameter name="pCurrentObjectCount" type="Integer" usage="io"/>
        <Parameter name="pMaxResponseSize" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNoidString" id="6704599a-1164-4469-84ed-691480126fdd">
        <source>getNoidString(pFormat : CnEcXmlFormat ; pObject : Object; pIsDebug : Boolean):String;

vars
	retValue	: String;
	className	: String;
	formatClass : CnEcXmlFormatClass;
	noidProperty : String;
	
begin
	if pObject = null then
		return "";
	endif;

	if pFormat &lt;&gt; null then
		formatClass := pFormat.getFormatClass(pObject.class().name);
		if pObject.isKindOf(CnEcXmlFormat) then	//28 May 2015	NDL	Par 36350
			noidProperty := CnEcXmlFormat::formatName.name; // we are exporting a ref to a format, probably Default-OID
		elseif formatClass &lt;&gt; null then
			noidProperty := formatClass.noidPropertyName;
		else
			noidProperty := "";
		endif;
	else
		noidProperty := "";
	endif;
	
	if noidProperty &lt;&gt; "" then
		retValue := self.cnEcXmlTagIt("DISPLAY_PROPERTY", noidProperty, pIsDebug); 	// the 'property' for this class that will be shown
																				// in CnEcXmlNoidSelect listBox
		retValue := retValue &amp; cnEcXmlTagIt("DISPLAY_VALUE", pObject.getPropertyValue(noidProperty).String, pIsDebug); // the 'value' of the property that will be shown
																					//  for you to match to in the CnEcXmlCnEcNoidSelect textBox
		retValue := cnEcXmlTagIt("NOID", retValue, pIsDebug);
		retValue := retValue &amp; cnEcXmlTagIt("oid", pObject.getOidString(), pIsDebug);
		retValue := cnEcXmlTagIt(pObject.class().name, retValue, pIsDebug);
	else
		if pObject.isKindOf(Class) then
			retValue := cnEcXmlTagIt("DISPLAY_PROPERTY", "name", pIsDebug);
			retValue := retValue &amp; cnEcXmlTagIt("DISPLAY_VALUE", pObject.class().name, pIsDebug);
			retValue := cnEcXmlTagIt("NOID", retValue, pIsDebug);
			retValue := retValue &amp; cnEcXmlTagIt("oid", pObject.getOidString(), pIsDebug);
			retValue := cnEcXmlTagIt(pObject.class().name, retValue, pIsDebug);
		else
		// If nothing implemented then will use the following to display the OID values.
			retValue := cnEcXmlTagIt("DISPLAY_PROPERTY", "getOidString", pIsDebug);
			retValue := retValue &amp; cnEcXmlTagIt("DISPLAY_VALUE",  "Incoming Oid value was = '" &amp; pObject.getOidString() &amp; "'" , pIsDebug);
			retValue := cnEcXmlTagIt("NOID", retValue, pIsDebug);
			retValue := retValue &amp; cnEcXmlTagIt("oid", pObject.getOidString(), pIsDebug);
			retValue := cnEcXmlTagIt(pObject.class().name, retValue, pIsDebug);
		endif;
	endif;
epilog
	return retValue;
end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pIsDebug" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTheInputField" id="80698e34-1114-4d1c-a3cb-db0e2871a3bc">
        <source>getTheInputField(pFormat : CnEcXmlFormat; pInput: CnEcXmlStructureInstance; property : Property; pObject : Object):CnEcXmlStructureInstance;

vars
	formatClass		: CnEcXmlFormatClass;
	formatProperty	: CnEcXmlFormatProperty;
	
begin
	if pFormat = null or pFormat.formatName = CNEC_DEFAULT_FULL then
       	// see if we have a tag the same as the properties name
		return pInput.findStructure(property.getName());
	else
		// see if we have a tag by the name the property is mapped to in the format.
		formatClass := pFormat.getFormatClass(pObject.class().name);
		
		if formatClass &lt;&gt; null then
			formatProperty := formatClass.getFormatProperty(property.getName());
			
			if formatProperty &lt;&gt; null then
				return pInput.findStructure(formatProperty.tagName);
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <Parameter name="property" type="Property"/>
        <Parameter name="pObject" type="Object"/>
        <ReturnType type="CnEcXmlStructureInstance"/>
    </JadeMethod>
    <JadeMethod name="getThePropertyCollection" id="56110a66-d98f-40e4-8803-7825ec15077f">
        <source>getThePropertyCollection(pObject : Object):CnEcClassPropertyColls;

// Reimplemented under CnEcHubble...

begin
	return null;
end;</source>
        <Parameter name="pObject" type="Object"/>
        <ReturnType type="CnEcClassPropertyColls"/>
    </JadeMethod>
    <JadeMethod name="getXmlString" id="22b83436-906f-4c99-ba5a-5da8f8d90ad6">
        <source>getXmlString(	pFormatName:String;	
				pObject:Object;
				pIsDebug:Boolean;
				pMaxObjectCount:Integer io;
				pCurrentObjectCount:Integer io;
				pMaxResponseSize:Integer io ) : String;

vars
	format		: CnEcXmlFormat;
	xmlString	: String;
	
begin
	format := app.cnEcGetXmlFormat(pFormatName);

	if format &lt;&gt; null then
		xmlString := format.cnEcXmlObjectString(pObject, pIsDebug, pMaxObjectCount, pCurrentObjectCount, pMaxResponseSize);
	else
		CnEcBaseXmlException.raise_(CNEC_X_02801, "No format for [" &amp; pFormatName &amp; "]");
	endif;
epilog
	return xmlString;
end;</source>
        <Parameter name="pFormatName" type="String"/>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pIsDebug" type="Boolean"/>
        <Parameter name="pMaxObjectCount" type="Integer" usage="io"/>
        <Parameter name="pCurrentObjectCount" type="Integer" usage="io"/>
        <Parameter name="pMaxResponseSize" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="xcnEcXmlTagItLevel" id="dec73bbb-acbe-4dc5-bd8e-62897745d9c3">
        <source>xcnEcXmlTagItLevel(pTagLevel : Integer; pTag : String; pData: String; pIsDebug : Boolean) : String;

vars
	tagString	: String;
	xmlData		: String;
	
begin
	tagString	:= "";
	xmlData		:= pData;
    xmlData		:= cnEcXmlTagIt("OID", self.getOidString() , pIsDebug) &amp; xmlData;
    xmlData		:= cnEcXmlTagIt("edition", self.edition().String, pIsDebug) &amp; xmlData;
    
	if pIsDebug then
			tagString := "&lt;" &amp; pTag &amp; "&gt;" &amp; xmlData &amp; "&lt;/" &amp; pTag &amp; "&gt;" &amp; CrLf;
	else
		if pData.length &gt; 0 then
			tagString := "&lt;" &amp; pTag &amp; "&gt;" &amp; xmlData &amp; "&lt;/" &amp; pTag &amp; "&gt;" &amp; CrLf;
		endif;
	endif;

	return tagString;
end;</source>
        <Parameter name="pTagLevel" type="Integer"/>
        <Parameter name="pTag" type="String"/>
        <Parameter name="pData" type="String"/>
        <Parameter name="pIsDebug" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
