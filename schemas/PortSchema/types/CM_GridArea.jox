    <JadeMethod name="hasGridAreaDecreased" id="89160caa-3691-4457-b3ab-b2f7b1962aec">
        <source>hasGridAreaDecreased(_proxyTA: CM_GridArea ): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2017	jlgns1	Initial creation
//20 September 2017 jlgns1 TFS 6956 QNS - RT Queue error
*/


vars

begin
	if self.allGridRows.size &gt; _proxyTA.allGridRows.size then
		return true;
	endif;
	
	if self.allGridColumns.size &gt; _proxyTA.allGridColumns.size then
		return true;
	endif;
	
	if self.heightOfStack &gt; _proxyTA.heightOfStack then
		return true;
	endif;
	
	
	return false;
epilog

end;</source>
