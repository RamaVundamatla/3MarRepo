    <JadeMethod name="permissionCheck" id="de031f35-42fe-4f2a-8b1b-e0728d68929f">
        <source>permissionCheck();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	canEdit : Boolean;
begin
	canEdit := self.mode.Boolean;
	if canEdit and app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.txtQuantity.enabled := true;
		self.mskTareWeight.enabled := true;
		self.mskCargoWeight.enabled := true;
		self.mskLostWeight.enabled := true;
		self.mskTotalWeight.enabled := true;
		self.txtReason.enabled := true;
		self.mskDiameter.enabled := true;
		self.mskHeight.enabled := true;
		self.mskVolume.enabled := true;
		self.mskRollingLength.enabled := true;
		self.mskLength.enabled := true;
		self.txtGrammage.enabled := true;
		self.mskWidth.enabled := true;
		self.btnOk.enabled := true;
	
	elseif app.myCurrentUserCan(self.myTerminal, self.permissionView) then
		self.txtQuantity.enabled := false;
		self.mskTareWeight.enabled := false;
		self.mskCargoWeight.enabled := false;
		self.mskLostWeight.enabled := false;
		self.mskTotalWeight.enabled := false;
		self.txtReason.enabled := false;
		self.mskDiameter.enabled := false;
		self.mskHeight.enabled := false;
		self.mskVolume.enabled := false;
		self.mskRollingLength.enabled := false;
		self.mskLength.enabled := false;
		self.txtGrammage.enabled := false;
		self.mskWidth.enabled := false;
		self.btnOk.enabled := false;
		self.btnCancel.enabled := true;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setDimensionsByCargoType" id="6d6aca54-d49c-4e84-8758-2f3e76d793c0">
        <source>setDimensionsByCargoType();
/*
Purpose:			

Date		Who		Reason
28 June 2023	navab1	 // ### TFS BUG 58865 28JUN2023 NAVAB1
17/07/23		navcs2	Bug 59045: FR | 54536 EUP - Repair Data Processing Timing - Old Weights for Repair Messages
26 Sepetember 2023	navcs2	Bug 60170: EUP - Damage | Discrepancy - Label not shown correctly on Repairs Details form
*/

vars
	cargoType: CM_CargoType;
	cargoSubType : CM_Product;
	trackedItem		: CM_TrackedItem;
begin
	if self.myTrackedItem &lt;&gt; null then
		trackedItem := self.myTrackedItem;
	elseif self.pxyTrackedItem &lt;&gt; null then
		trackedItem := self.pxyTrackedItem;
	endif;
	cargoSubType := trackedItem.myProduct;
	if cargoSubType =  null then
		cargoType := trackedItem.myCargoType;
		if cargoType &lt;&gt; null then
			cargoSubType := cargoType.mySystemProductType;
		endif;
	endif;
	if cargoSubType = null then
		return;
	endif;

	self.mskVolume.visible := cargoSubType.isAttributeValidForCargoType(ETRow_MyVolume);
	if self.myCargoType.isBreakBulk and not self.myCargoType.useTareCargoWeight then															// 26 Sepetember 2023	navcs2	Bug 60170
		self.txtQuantity.visible := cargoSubType.isAttributeValidForCargoType(ETRow_MyQuantity);
	endif;																							// 26 Sepetember 2023	navcs2	Bug 60170
	self.mskLength.visible := cargoSubType.isAttributeValidForCargoType(ETRow_MyLength);
	self.mskHeight.visible := cargoSubType.isAttributeValidForCargoType(ETRow_MyHeight);
	self.mskWidth.visible := cargoSubType.isAttributeValidForCargoType(ETRow_MyWidth);

	self.lblVolume.visible := self.mskVolume.visible;
	self.lblQuantityNew.visible := self.txtQuantity.visible;
	self.lblLength.visible := self.mskLength.visible;
	self.lblWidth.visible := self.mskWidth.visible;
	self.lblHeight.visible := self.mskHeight.visible;
epilog

end;</source>
    </JadeMethod>
