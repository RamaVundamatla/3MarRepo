    <JadeMethod name="trxUpdateStopsForBOLsBulk" id="f126b5db-7fea-49b7-970a-d1d5e5e2566d">
        <updating/>
        <source>trxUpdateStopsForBOLsBulk(_bol :CM_BOLIn; _edition :Integer; _bols :CM_BOLSet; _addColl :IntegerArray; _clearColl :CM_StopsTableSet; _passport :CM_Passport input)updating;
// ---------------------------------------------------------------------------
// Created:     15 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	bol			:CM_BOL;
	stopsTable	:CM_StopsTable;
begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;
	
	foreach bol in _bols do
		reserveLock(bol);	//only I can upgrade to exclusive from this point on, but others can get share
		if bol = _bol and
			_passport.noErrors and
			bol.edition &lt;&gt; _edition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString (Docket), null, null);
			return;
		endif;
	endforeach;
	
	// do the adding first
	app.myUtilityCA.utlCreateStopsForBOLs(_bols, _addColl, _passport);
	
	// now do the clear
	foreach stopsTable in _clearColl do
		app.myUtilityDA.utlDeleteStopBOLsBulk(_bols, stopsTable, 'N/A', _passport);
	endforeach;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_bol" type="CM_BOLIn"/>
        <Parameter name="_edition" type="Integer"/>
        <Parameter name="_bols" type="CM_BOLSet"/>
        <Parameter name="_addColl" type="IntegerArray"/>
        <Parameter name="_clearColl" type="CM_StopsTableSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateStopsForTIMasterBulk" id="4c9116cd-b530-46d8-b1ee-5eb3224a4a74">
        <updating/>
        <source>trxUpdateStopsForTIMasterBulk(_master :CM_TIMaster; _edition :Integer;
			_coll :CM_TIMasterSet; _addColl :CM_StopsTableSet; _clearColl :CM_StopsTableSet; _passport :CM_Passport input)updating;
// ---------------------------------------------------------------------------
// Created:     17 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tiMaster	:CM_TIMaster;
	stopsTable	:CM_StopsTable;
	int			:Integer;
begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;
	
	foreach tiMaster in _coll do
		reserveLock(tiMaster);	//only I can upgrade to exclusive from this point on, but others can get share
		
		if tiMaster = _master and
			_passport.noErrors and
			tiMaster.edition &lt;&gt; _edition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString (Item), null, null);
			return;
		endif;
	endforeach;
	
	// do the adding first
	foreach stopsTable in _addColl do
		app.myUtilityCA.utlCreateStopsForTIMasts(_coll, stopsTable, _passport);
	endforeach;
	
	// now do the clear
	foreach stopsTable in _clearColl do
		app.myUtilityDA.utlDeleteStopTIMastsBulk(_coll, stopsTable, _passport);
	endforeach;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_master" type="CM_TIMaster"/>
        <Parameter name="_edition" type="Integer"/>
        <Parameter name="_coll" type="CM_TIMasterSet"/>
        <Parameter name="_addColl" type="CM_StopsTableSet"/>
        <Parameter name="_clearColl" type="CM_StopsTableSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
