    <JadeMethod name="setupThumbnailDefaults" id="c9cb290d-5ced-404c-9d86-6a34cf6ed5d8">
        <source>setupThumbnailDefaults();
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 February 2007	cnwer1	Initial creation - PAR#xxxx
