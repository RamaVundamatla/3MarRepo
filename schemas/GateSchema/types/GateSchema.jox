    <JadeMethod name="doRaiseAlertForKiosk" id="5070bd2c-f53a-44b0-87ba-95bb85a7cdc4">
        <source>doRaiseAlertForKiosk(_details:String; _allExtraDetails:CnEcArray);
// --------------------------------------------------------------------------------
// Created:		17 August 2006 by cnwdad1
//
// Purpose:		Raises a system alert with the details of of what needs to be actioned.
//
// Parameters:	_details - The details of the alert circumstances.
//				_allExtraDetails - A reference to an array of error information.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	alertObj 		: CM_SystemAlert;
	extraInfoObj	: CnEcArrayObject;

begin
	app.writeLog(_details, LogERROR);
	
	create alertObj;
	alertObj.details	:=	_details;
	
	if _allExtraDetails &lt;&gt; null then
		foreach extraInfoObj in _allExtraDetails do
			alertObj.addLogEntry(extraInfoObj.stringValue);
		endforeach;
	endif;
	
	alertObj.setSeverity(SEVERE_WARNING);

	// Tell alert to add itself to the system, then commit it persistently.
	alertObj.add();
	self.alertManager.commitAlert();
end;</source>
        <Parameter name="_details" type="String"/>
        <Parameter name="_allExtraDetails" type="CnEcArray"/>
    </JadeMethod>
    <JadeMethod name="getKioskConnectionInfo" id="99ea842a-a48f-4be9-8c26-6324e85f4b85">
        <source>getKioskConnectionInfo(_terminalId:String io; _userId:String io; _gateName : String io):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		17 August 2006 by cnwdad1
//
// Purpose:		Returns the connection information that is configured within the
//				client's initialization file, such as the default Terminal.
//
// Parameters:	_terminalId - The terminal ID to be used for this session.
//
// Returns:		True if the information is successfully retrieved, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iniFileName : String;
	idValue		: String;
	userName	: String;
//	gateName	: String;		
	errorMsg	: String;
	errorMsg1	: String;
	errorMsg2	: String;
	
begin
	iniFileName 	:=	app.getIniFileName();
	idValue			:=	app.getProfileString(iniFileName, INI_SECT_KIOSK01, INI_KEY_KTERMINAL, null);
	userName		:=	app.getProfileString(iniFileName, INI_SECT_KIOSK01, INI_KEY_KUSER, null);
	//gateName		:=	app.getProfileString(iniFileName, INI_SECT_KIOSK01, INI_KEY_KGATE, null); //cnwrd1 ccms 1862 par 27435 2.5.2011
	
	
	
	if idValue = null then
		errorMsg1	:=	"Initialization file [" &amp; INI_SECT_KIOSK01 &amp; "] section has not been configured correctly" &amp;
						CrLf &amp; CrLf &amp; "[" &amp; INI_SECT_KIOSK01 &amp; "]" &amp; CrLf &amp;
						INI_KEY_KTERMINAL &amp; "= ";
		
		errorMsg	:=	errorMsg1;
	endif;
	
	if userName = null then
		errorMsg2	:=	"Initialization file [" &amp; INI_SECT_KIOSK01 &amp; "] section has not been configured correctly" &amp;
						CrLf &amp; CrLf &amp; "[" &amp; INI_SECT_KIOSK01 &amp; "]" &amp; CrLf &amp;
						INI_KEY_KUSER &amp; "= ";
		
		if errorMsg = null then
			errorMsg	:=	errorMsg2;
		else
			errorMsg	:=	errorMsg &amp; CrLf &amp; CrLf &amp; errorMsg2;
		endif;
	endif;
	
	/*
	if gateName = null then //cnwrd1 ccms 1862 par 27435 2.5.2011
		errorMsg2	:=	"Initialization file [" &amp; INI_SECT_KIOSK01 &amp; "] section has not been configured correctly" &amp;
						CrLf &amp; CrLf &amp; "[" &amp; INI_SECT_KIOSK01 &amp; "]" &amp; CrLf &amp;
						INI_KEY_KGATE &amp; "= ";
		
		if errorMsg = null then
			errorMsg	:=	errorMsg2;
		else
			errorMsg	:=	errorMsg &amp; CrLf &amp; CrLf &amp; errorMsg2;
		endif;
	endif;
	*/
	
	if errorMsg &lt;&gt; null then
		app.msgBox(errorMsg, "Error", MsgBox_Information_Icon + MsgBox_OK_Only);
		
		return false;
	endif;
	
	_terminalId	:=	idValue.toUpper();
	_userId		:=	userName.toUpper();
	//_gateName 	:= 	gateName; //cnwrd1 ccms 1862 par 27435 2.5.2011
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_terminalId" type="String" usage="io"/>
        <Parameter name="_userId" type="String" usage="io"/>
        <Parameter name="_gateName" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFlexiGateApp" id="d66a299f-3aa7-41db-8f41-c54167efce94">
        <updating/>
        <source>initFlexiGateApp() updating;
// ---------------------------------------------------------------------------
// Created:     24 July 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 07 Feb 2012		cnwkpd1			PAR #28381 - Update JSM version info correctly in managed environments
// ---------------------------------------------------------------------------
vars
	tmpTerm	: CM_Terminal;
	
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	app.niceName := "Terminal Gate";
	app.setupAppVersion();				// PAR #28381
	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);

	self.initialize();

	app.passBackAllExceptions := false;	//app.isDevelopmentSystem;
	app.passBackJadeExceptionsOnly := true;

	on Exception do app.generalExceptionHandler(exception) global;
	
	//self.logLevel := LogWARN;	//22 Nov 2019	NDL	TFS 47053 Part of 'initialize'

	if not app.doLogin() then
		terminate;
	endif;
	
	tmpTerm := app.myRoot.allTerminals['DP1'];
	if tmpTerm = null then
		tmpTerm := CM_Terminal.firstInstance;
	endif;
	
	self.myPassport.setMyTerminal(tmpTerm);
	
	// Extra stuff here not in UiCommonSchema
	//app.createMyController(CMUI_Controller);

	app.mainForm := app.loadForm(GTE_FlexiGateForm, GTE_Assistant, false, false, false, app.getMyTerminalDO_NOT_USE(), null);
	
	// hide the menu for demo
	app.mainForm.CM_BaseForm.handleMenusForModalDisplay();
	
	// If user fails security we don't want to show a null form.
	if app.mainForm &lt;&gt; null then
		app.mainForm.show;
	endif;
	
epilog
	app.mousePointer := Window.MousePointer_Default;


end;</source>
    </JadeMethod>
    <JadeMethod name="initGateKiosk01App" id="1fc5df23-db27-4458-8e2e-38d601c4eda8">
        <updating/>
        <source>initGateKiosk01App() updating, protected;
// --------------------------------------------------------------------------------
// Created:		31 July 2006 by cnwdad1
//
// Purpose:		Initialization method for the Kiosk01 application.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	terminalObj		: CM_Terminal;
	userObj			: CM_User;
	allSkinsObj		: ObjectSet;
	skinObj			: Object;
	terminalId		: String;
	userId			: String;
	gateName		: String;
	compName		: String;
	aGate 			: CM_Gate;  
	aKiosk, 
	theKiosk		: CM_Kiosk;
begin
	self.isRunningKiosk	:=	true;
	self.initialize();
	
	on Exception do self.xHandlerKiosk(exception) global;

	// PAR 20553 Sep 2009 - need license to run Kiosk app.
/*	if (not app.myRoot.canDo(PmRoadGateKiosk)) then
		app.raiseCMException1(NotLicensedToPerformAction, "Road Gate Kiosk", null, null);
		return;
	endif;	*/	//07 Oct 2019	NDL	TFS 46169
	
	if self.getKioskConnectionInfo(terminalId, userId, gateName) then
		terminalObj	:=	self.myRoot.allTerminals[terminalId.toUpper()];
		
		if terminalObj = null then
			terminate;
		else
			self.myPassport.setMyTerminal(terminalObj);
		endif;
	else
		terminate;
	endif;
	
	userObj	:=	self.myRoot.allUsers[userId];
	
	if userObj = null then
		app.msgBox("User not found - terminating the Kiosk application.",app.getErrorString(Error), MsgBox_OK_Only );	//27 Mar 2012	NDL	Par 28995
		app.writeStatement( "User not found - terminating the Kiosk application.");
		terminate;
	else
		self.myPassport.setMyUser(userObj);
	endif;
	
	compName := app.computerName;
	
	foreach aKiosk in terminalObj.allKiosksByCode do
		//if aKiosk.machineName.toUpper = compName then
		if aKiosk.machineName.toUpper = compName.toUpper then //cnwrd1 par 35276
			theKiosk := aKiosk;
			break;
		endif;
	endforeach;
	
	if theKiosk = null then
		app.msgBox("Kiosk not found for computer name " &amp; compName &amp; " - terminating the Kiosk application.",app.getErrorString(Error), MsgBox_OK_Only );	//27 Mar 2012	NDL	Par 28995
		app.writeStatement( "Kiosk not found for computer name " &amp; compName &amp; " - terminating the Kiosk application.");
		terminate;
	endif;
	
	aGate := theKiosk.findGate();
	
	if aGate = null then
		app.msgBox("Kiosk gate not found - terminating the Kiosk application.",app.getErrorString(Error), MsgBox_OK_Only );	//27 Mar 2012	NDL	Par 28995
		app.writeStatement( "Kiosk gate not found - terminating the Kiosk application.");
		terminate;
	else
		self.kioskGate := aGate;
	endif;

	
	
	create allSkinsObj transient;
	JadeSkinApplication.instances.copy(allSkinsObj);
	
	foreach skinObj in allSkinsObj where skinObj.JadeSkinApplication.name = "Kiosk012006" do
		app.setApplicationSkin(skinObj.JadeSkinApplication);
		break;
	endforeach;
	

epilog
	delete allSkinsObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="isKioskApp" id="8752a72c-6740-4cc9-80d4-054378c46696">
        <source>isKioskApp(): Boolean;
// --------------------------------------------------------------------------------
// Created:		16 August 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.isRunningKiosk;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xHandlerKiosk" id="8fabf4a5-dc1d-496d-a9d2-fa4937e3761d">
        <source>xHandlerKiosk(_exceptionObj:Exception):Integer protected;
// --------------------------------------------------------------------------------
// Created:		02 August 2006 by cnwdad1
//
// Purpose:		Default exception handler for the Kiosk application.
//
// Parameters:	_exceptionObj - A reference to the exception object.
//
// Returns:		The passback value indicating how the kernal should handle the exception.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allErrorsObj	: CnEcArray;
	errorInfo		: String;
	
	
begin
	create allErrorsObj transient;
	errorInfo	:=	_exceptionObj.cnEcGetDetails();
	errorInfo.cnEcGetArrayOfLines(allErrorsObj);
	
	self.doRaiseAlertForKiosk("Kiosk unhandled error - refer to extra info.", allErrorsObj);
	app.msgBox("A system error has occured - please contact the gate office.", app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
	
	return Ex_Abort_Action;
epilog
	delete allErrorsObj;
end;</source>
        <access>protected</access>
        <Parameter name="_exceptionObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
