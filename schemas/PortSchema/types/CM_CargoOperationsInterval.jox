        <Inverse name="HMS_Movement::allCargoOperationsIntervals"/>
    </ExplicitInverseRef>
    <JadeMethod name="getTableDisplay" id="78a1ed25-f177-42d6-b52f-c7b1e32aa9c0">
        <source>getTableDisplay():String;
/*
Date		Who		Reason
21 September 2011	cnwcs5	Initial creation - CCMS RIO 2041 / par 28220 Start/Stop Times
*/
vars
	startTS, endTS	:TimeStamp;
	str				:String;
begin
	// return tab delimited string for display in table
	startTS	:= self.startDT;
	endTS	:= self.endDT;
	
	if startTS &lt;&gt; null then
		str := startTS.date.asStringJMT;
		str := str &amp; Tab &amp; startTS.time.asStringJMT;
	else
		str := str &amp; Tab;
	endif;
	
	if endTS &lt;&gt; null then
		str := str &amp; Tab &amp; endTS.date.asStringJMT;
		str := str &amp; Tab &amp; endTS.time.asStringJMT;
	endif;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyHMSMovement" id="ea44f4da-517b-42ac-8fba-dda4830f56d9">
        <updating/>
        <source>setMyHMSMovement(_movement :HMS_Movement) updating;
/*
Date		Who		Reason
20 September 2011	cnwcs5	Initial creation - CCMS RIO 2041 / par 28220 Start/Stop Times
*/
vars

begin
	self.myHMSMovement := _movement;
epilog

end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
    </JadeMethod>
</Class>
