    <JadeMethod name="sendWeight" id="f5e837d8-f90b-466c-a645-14ea1bd1862b">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_WeightCallerInterface::sendWeight"/>
            <JadeInterfaceMethod name="IF_TCPWeightCallerInterface::sendWeight"/>
        </interfaceImplements>
        <source>sendWeight(_newWeight : Decimal);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Jun 2010	cnwer1	Initial creation
19 Apr 2016	cnwkpd1	TFS 1870 - Removed addInfoDisplay because this displays a dialog box which 
					would interrupt the driver flow in normal operations
// 17/08/2016 cnwrh7	TFS	2501 iScale
05/02/2018 jlgns1	Bug 36870: PNL - Weigh warning when not required 851.121
*/

vars
	ti 		: CM_TrackedItem;			//Bug 36870
begin
	
	//Copied from doMoveFrameRefresh
	if self.myWeightInterfaceController &lt;&gt; null then																	//Bug 36870
		// Warning if there is no ToDo Task or the weight is not Forced 												//Bug 36870   
		if self.myVMAgent.myMachine.getCurrentTwinTask() = null then    												//Bug 36870
			ti := self.myVMAgent.myMachine.currentQueueTask.ti;															//Bug 36870
			if ti &lt;&gt; null then																							//Bug 36870
				if ti.isKindOf(CM_Container) and ti.weighStatus &lt;&gt; WEIGH_STATUS_FORCED then       						//Bug 36870
					if not ti.CM_Container.hasToDoTasksWithTransClass(TRANS_TYPE_WEIGH, false) then						//Bug 36870
						app.msgBox(app.getErrorString1(Contai_not_marked_weighi_requi,null),"Warnning",MsgBox_OK_Only);	//Bug 36870
					endif;																								//Bug 36870
				endif;																									//Bug 36870		
			endif;																										//Bug 36870
		endif;																											//Bug 36870
	endif;																												//Bug 36870

	
//	self.addInfoDisplay("Loadrite Weight received");
	self.myMoveTableDetails.addDataForEntRowName(ETRow_TotalWeight, _newWeight.asStringJMT);
	if self.myTCPWeightInterfaceController &lt;&gt; null  and _newWeight &lt;&gt; null then													//For IScale device as they use TCPWeightInterfaceController AND got weight figure
		self.btnSaveWeight.visible := true;
	endif;
epilog

end;</source>
        <Parameter name="_newWeight" type="Decimal"/>
    </JadeMethod>
