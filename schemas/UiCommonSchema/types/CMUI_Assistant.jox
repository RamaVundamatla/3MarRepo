    <JadeMethod name="doBookingEnquiry" id="94d2f0b6-0ad7-4fe6-995a-47385ed68f83">
        <source>doBookingEnquiry( _coll : Collection );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2010	cnwrd1	Initial creation

*/



vars

	subSys : CMUI_SubSystem;
	formCls,
	assistCls: Class;
	bookingForm : CM_TableViewForm;
	firstObject : CM_Object;
	collOfBookings : CM_BookingRefSet;
	collOfBookingItems : CM_BookingRefItemSet;
	
begin

	subSys := app.myController.allSubSystems['GateSchema'];
	if subSys &lt;&gt; null then
		subSys.getFormDetails('GTE_BookingRefMultiForm', formCls, assistCls);
	endif;
	if formCls = null or _coll = null or _coll.isEmpty then
		return;
	endif;
	bookingForm := app.loadForm(formCls, 
								assistCls, 
								false, 
								false,
								false, 
								app.myPassport.myTerminal,
								null ).CM_TableViewForm;	
								
	if bookingForm = null then
		return;
	endif;
	
	firstObject := _coll.first.CM_Object;
	if firstObject = null then
		return;
	endif;
	
	if firstObject.isKindOf(CM_BookingRef) then
		create collOfBookings transient;
	//	self.transientsToDelete.add(collOfBookings);	// so the transient gets deleted when the form closes.
		_coll.copy(collOfBookings);
		bookingForm.myCurrentObject := collOfBookings;
	elseif firstObject.isKindOf(CM_BookingRefItem) then
		create collOfBookingItems transient;
		//self.transientsToDelete.add(collOfBookingItems);	// so the transient gets deleted when the form closes.
		_coll.copy(collOfBookingItems);
		bookingForm.myCurrentObject := collOfBookingItems;
	endif;
	
	bookingForm.show;
	
epilog

end;
</source>
        <Parameter name="_coll" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="doBulkMovePdOrQdToBlock" id="1745d075-d91d-4431-a42a-8f97fa3050a6">
        <source>doBulkMovePdOrQdToBlock(	_noChargeMove : Boolean;
							_userAuthorityCode : String;
							_moveMode : Integer;
							_allTrackedItems : CM_TIArray;	// In the order they will be processed.
							_targetLocn : CM_LocationsController; //  PAR 34865 CM_BlockController;
							_targetLocationStr : String;
							_processedMoves : CM_TIArray io
							) :Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2012	cnwndl1	Initial creation	Par 30211 - Copy of doBulkMoveToGridArea with mods to handle single location stuff.

*/

vars

	moveModeTypeStr : String;
	ti : CM_TrackedItem;
	msg : String;
	cargoType : CM_CargoType;
	includesQueued : Boolean;
	includesPlanned : Boolean;
	queuedCount : Integer;
	plannedCount : Integer;
	idStr : String;
	ignoreWarnings : Boolean;
	moveController : CMIF_MoveController;
	moveValidateExcOccurred : Boolean;
	excHandlerMess : String;	
	isWarningOnly : Boolean;
	wle : CM_WorkListEntry;	
	justYardAllocWarnings : Boolean;
	warning : CM_Error;
	result : Integer;
	skippedCargo :CM_TIArray;
	
begin

	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();

	if _moveMode &lt;&gt; QUEUE_MODE and _moveMode &lt;&gt; PLANNING_MODE then
		//i.e. Not valid for QUEUE_PLAN_ON_PICKUP or AUTO_PLAN_MODE or REAL_MODE.
		return false;
	endif;
	moveModeTypeStr := app.moveModeStatusEnumToString(_moveMode);

	// check none of the user selected cargo items are 'off site' or 'bulk cargo' or are already planned/queued.
	create skippedCargo transient;
	foreach ti in _allTrackedItems do
		if ti.isOnShip then	//08 Apr 2016	NDL	TFS 1824
			msg := app.getErrorString1(Onshi_cargo_not_moved_movei_fo, ti.id);
			app.msgBox(msg, app.getErrorString(Multi_move), MsgBox_OK_Only);
			return false;
		endif;
		if ti.isOffSite() then
			msg := app.getErrorString1(Cargo_offsite_cannot_moved, ti.id);
			app.msgBox(msg, app.getErrorString(Multi_move), MsgBox_OK_Only);
			return false;
		endif;
		//if ti.isChild() then
		if ti.isChild() and _moveMode &lt;&gt; PLANNING_MODE then	//14 July 2014	NDL Par 34559
			msg := app.getErrorString3(ERR_Move_Parent_TI, ti.id, ti.getParent().id, ti.getParent().id );
			app.msgBox(msg, app.getErrorString(Multi_move), MsgBox_OK_Only);
			return false;
		endif;
		cargoType := null;
		cargoType := ti.myCargoType;
		if cargoType &lt;&gt; null and cargoType.isBulkProduct then
			msg := app.getErrorString2(Cannot_move_as_multi_cargo, ti.id, cargoType.description);
			app.msgBox(msg, app.getErrorString(Multi_move), MsgBox_OK_Only);
			return false;
		endif;
		if _moveMode = QUEUE_MODE then
			if ti.isQueued then
				includesQueued := true;
				queuedCount := queuedCount + 1;
				skippedCargo.add( ti );
			else
				idStr := idStr &amp; ', ' &amp; ti.id;
			endif;
		endif;
		if _moveMode = PLANNING_MODE then
			if ti.isPlanned(PLANNING_MODE) then
				includesPlanned := true;
				plannedCount := plannedCount + 1;
				skippedCargo.add( ti );
			else
				idStr := idStr &amp; ', ' &amp; ti.id;
			endif;
		endif;
	endforeach; 
	
	//If we are going to ignore some, advise the user
	if includesQueued then
		msg := app.getErrorString1(Includes_Already_Queued, queuedCount.String);
		app.msgBox(msg, app.getErrorString(Multi_move), MsgBox_OK_Only);
		if _allTrackedItems.size = queuedCount then
			return true;
		endif;
	elseif includesPlanned then
		msg := app.getErrorString1(Includes_Already_Planned, plannedCount.String);
		app.msgBox(msg, app.getErrorString(Multi_move), MsgBox_OK_Only);
		if _allTrackedItems.size = plannedCount then
			return true;
		endif;
	endif;
	
	//tell them we are doing a multi move, which items and to where	
	msg := app.getErrorString3(UiMoveTrackedItem, moveModeTypeStr, idStr[3:end], _targetLocationStr);
	if app.msgBox( msg, app.getErrorString(Multi_move), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
		return true;
	endif;	
		
	//check to see if they want to ignore warnings or not.
	msg := app.getErrorString1(Yes_Ignore_Warning_No_Stop,moveModeTypeStr);
	if app.msgBox(msg, app.getErrorString(Multi_move), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
		ignoreWarnings := true;
	endif;		
	
	//rip thru the items in order, finding the locations in the correct decking in order, as best we can.
	foreach ti in _allTrackedItems do
	
		//skip those with existing moves of this type.
		if _moveMode = QUEUE_MODE then
			if ti.isQueued then
				continue;
			endif;
		endif;
		if _moveMode = PLANNING_MODE then
			if ti.isPlanned(PLANNING_MODE) then
				continue;
			endif;
		endif;
	
		delete moveController;
		app.myPassport.clearErrorsWarnings();
		app.setContinueCMExceptions( true );
		moveValidateExcOccurred := false;
		isWarningOnly := false;
		excHandlerMess := null;
		
		//create a fresh move controller and populate as much as we dare.
		create moveController transient;
		moveController.setMyTrackedItem(ti);
		moveController.setMoveMode(_moveMode);
		moveController.isNoChargeMove := _noChargeMove;
		moveController.userAuthorityCode := _userAuthorityCode;
		moveController.validateOnly := true;
		moveController.setMyPassport(app.myPassport);	
		moveController.setMyToPrimaryLocation(_targetLocn);
		
		// arm a local exception handler to override any JMT errors, test the move
		on Exception do self.handleMultiMoveValidation( exception, moveValidateExcOccurred, excHandlerMess, isWarningOnly );		
		moveController.executeMove( app.myPassport );
		if moveValidateExcOccurred then
			if not ignoreWarnings or not isWarningOnly then
				app.myPassport.clearErrorsWarnings();
				continue;
			endif;
		endif;		
		on Exception do null;
	
		isWarningOnly := false;
		excHandlerMess := null;
		
		// Find a wle if you can
		wle := null;
		wle := ti.getWLEforFailedAutoPlan();	// in case this move is to override a failed auto plan
		if wle = null then
		//	wle := ti.getVoyageWLEUnactioned( false );	//Ship discharge job associated with this move
			wle := ti.getVoyageWLEForLCUnactioned( false, _targetLocn );	//23 Jun 2016	NDL	TFS 2172
		endif;
		if wle = null then
			//wle := ti.getWLEForRoadRailMove();	//Rail or Road job associated with this move
			wle := ti.getIncompleteRoadReceiveWle();	//20 Sep 2013	NDL	Par 32497
			if wle = null then
				wle := ti.getIncompleteRailReceiveWle();	//20 Sep 2013	NDL	Par 32497
			endif;
		endif;
		
		if wle &lt;&gt; null then
			//found one so use it. 
			moveController.setMyWorkListEntry(wle);	
			moveController.setJobForMove(wle.job);
		endif;
		
		// OK we are doing it for real
		moveController.validateOnly := false;
		
		while true do
		
			app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
			
			//we unconditionally ignore Yard Allocation Errors.
			justYardAllocWarnings := true;
			if not ignoreWarnings and not app.myPassport.allWarnings.isEmpty and app.myPassport.noErrors then
				foreach warning in app.myPassport.allWarnings do
					if warning.errorCode &lt;&gt; WARN_TI_NOTMATCH_ALLOCATION_AT then // error 82959
						justYardAllocWarnings := false;
					endif;
				endforeach;
			endif;
			
			if app.myPassport.trxCompletedOK then
				_processedMoves.add( ti );
				break;
				
			elseif app.myPassport.noErrors and ( ignoreWarnings or justYardAllocWarnings ) then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
				
			else
				result := app.showErrorWarningDialog(app.getErrorString(Move), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknowledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				break;
				
			endif;
		endwhile;	
		
		if app.myPassport.hasErrors then
			app.showErrorWarningDialog(app.getErrorString(Move), app.myPassport, ErrWarnMode_Add);
			break;
		endif;
		
	endforeach;
	
	msg := app.getErrorString3(	Moves_were_successful, _processedMoves.size.String, moveModeTypeStr, _allTrackedItems.size.String);
	if moveValidateExcOccurred and excHandlerMess &lt;&gt; null then
		if ( not ignoreWarnings and isWarningOnly ) or (not isWarningOnly) then
			// it was just a warning, but they wanted to stop.  or it was a real error
			msg := msg &amp; CrLf &amp; app.getErrorString2( First_fail_move_was, ti.id, excHandlerMess);
		endif;
	endif;
	app.msgBox(msg, app.getErrorString(Multi_move), MsgBox_Question_Mark_Icon + MsgBox_OK_Only);
		
	return true;
	
epilog

	foreach ti in skippedCargo do
		_processedMoves.addExclusive(ti);
	endforeach;

	delete moveController;
	delete skippedCargo;
	
end;</source>
        <Parameter name="_noChargeMove" type="Boolean"/>
        <Parameter name="_userAuthorityCode" type="String"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_allTrackedItems" type="CM_TIArray"/>
        <Parameter name="_targetLocn" type="CM_LocationsController"/>
        <Parameter name="_targetLocationStr" type="String"/>
        <Parameter name="_processedMoves" type="CM_TIArray" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBulkMoveToGridArea" id="5c947bb7-8889-413e-bee4-d08b15b61b1b">
        <source>doBulkMoveToGridArea(	_noChargeMove : Boolean;
						_userAuthorityCode : String;
						_moveMode : Integer;
						_allTrackedItems : CM_TIArray;	// In the order they will be processed.
						_targetLocns : CM_LCArray;
						_targetLocationStr : String;
						_processedMoves : CM_TIArray io
						) :Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

	moveModeTypeStr : String;
	ti : CM_TrackedItem;
	msg : String;
	cargoType : CM_CargoType;
	includesQueued : Boolean;
	includesPlanned : Boolean;
	queuedCount : Integer;
	plannedCount : Integer;
	idStr : String;
	ignoreWarnings : Boolean;
	removeLocns : CM_LCArray;
	targetLocns : CM_LCArray;
	targetLocn : CM_LocationsController;
	size : Integer;
	locnToUse : CM_LocationsController;
	moveController : CMIF_MoveController;
	index : Integer;
	spanProb : Boolean;
	spanLC : CM_LocationsController;
	moveValidateExcOccurred : Boolean;
	excHandlerMess : String;	
	isWarningOnly : Boolean;
	wle : CM_WorkListEntry;	
	justYardAllocWarnings : Boolean;
	warning : CM_Error;
	result : Integer;
	skippedCargo :CM_TIArray;
	
begin

	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();

	if _moveMode &lt;&gt; QUEUE_MODE and _moveMode &lt;&gt; PLANNING_MODE then
		//i.e. Not valid for QUEUE_PLAN_ON_PICKUP or AUTO_PLAN_MODE or REAL_MODE.
		return false;
	endif;
	moveModeTypeStr := app.moveModeStatusEnumToString(_moveMode);

	// check none of the user selected cargo items are 'off site' or 'bulk cargo' or are already planned/queued.
	create skippedCargo transient;
	foreach ti in _allTrackedItems do
		if ti.isOnShip then	//08 Apr 2016	NDL	TFS 1824
			msg := app.getErrorString1(Onshi_cargo_not_moved_movei_fo, ti.id);
			app.msgBox(msg, app.getErrorString(Multi_move), MsgBox_OK_Only);
			return false;
		endif;
		if ti.isOffSite() then
			msg := app.getErrorString1(Cargo_offsite_cannot_moved, ti.id);
			app.msgBox(msg, app.getErrorString(Multi_move), MsgBox_OK_Only);
			return false;
		endif;
		//if ti.isChild() then
		if ti.isChild() and _moveMode &lt;&gt; PLANNING_MODE then//14 July 2014	NDL Par 34559
			msg := app.getErrorString3(ERR_Move_Parent_TI, ti.id, ti.getParent().id, ti.getParent().id );
			app.msgBox(msg, app.getErrorString(Multi_move), MsgBox_OK_Only);
			return false;
		endif;
		cargoType := null;
		cargoType := ti.myCargoType;
		if cargoType &lt;&gt; null and cargoType.isBulkProduct then
			msg := app.getErrorString2(Cannot_move_as_multi_cargo, ti.id, cargoType.description);
			app.msgBox(msg, app.getErrorString(Multi_move), MsgBox_OK_Only);
			return false;
		endif;
		if _moveMode = QUEUE_MODE then
			if ti.isQueued then
				includesQueued := true;
				queuedCount := queuedCount + 1;
				skippedCargo.add( ti );
			else
				idStr := idStr &amp; ', ' &amp; ti.id;
			endif;
		endif;
		if _moveMode = PLANNING_MODE then
			if ti.isPlanned(PLANNING_MODE) then
				includesPlanned := true;
				plannedCount := plannedCount + 1;
				skippedCargo.add( ti );
			else
				idStr := idStr &amp; ', ' &amp; ti.id;
			endif;
		endif;
	endforeach; 
	
	//If we are going to ignore some, advise the user
	if includesQueued then
		msg := app.getErrorString1(Includes_Already_Queued, queuedCount.String);
		app.msgBox(msg, app.getErrorString(Multi_move), MsgBox_OK_Only);
		if _allTrackedItems.size = queuedCount then
			return true;
		endif;
	elseif includesPlanned then
		msg := app.getErrorString1(Includes_Already_Planned, plannedCount.String);
		app.msgBox(msg, app.getErrorString(Multi_move), MsgBox_OK_Only);
		if _allTrackedItems.size = plannedCount then
			return true;
		endif;
	endif;
	
	//tell them we are doing a multi move, which items and to where	
	msg := app.getErrorString3(UiMoveTrackedItem, moveModeTypeStr, idStr[3:end], _targetLocationStr);
	if app.msgBox( msg, app.getErrorString(Multi_move), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
		return true;
	endif;	
		
	//check to see if they want to ignore warnings or not.
	msg := app.getErrorString1(Yes_Ignore_Warning_No_Stop,moveModeTypeStr);
	if app.msgBox(msg, app.getErrorString(Multi_move), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
		ignoreWarnings := true;
	endif;		

	create removeLocns transient;
	create targetLocns transient;
	_targetLocns.copy(targetLocns);
	
	//rip thru the items in order, finding the locations in the correct decking in order, as best we can.
	foreach ti in _allTrackedItems do
	
		//skip those with existing moves of this type.
		if _moveMode = QUEUE_MODE then
			if ti.isQueued then
				continue;
			endif;
		endif;
		if _moveMode = PLANNING_MODE then
			if ti.isPlanned(PLANNING_MODE) then
				continue;
			endif;
		endif;
	
		//clear out any existing data from a previous iteration
		// if there are any locations needing removed from out target set, do it now.
		foreach targetLocn in removeLocns do
			targetLocns.remove(targetLocn);
		endforeach;
		removeLocns.clear();
		
		size := targetLocns.size;
		if size = 0 then
			break;// no locations left break out of everything.
		endif;
		locnToUse := null;
		delete moveController;
		
		//create a fresh move controller and populate as mucha s we dare.
		create moveController transient;
		moveController.setMyTrackedItem(ti);
		moveController.setMoveMode(_moveMode);
		moveController.isNoChargeMove := _noChargeMove;
		moveController.userAuthorityCode := _userAuthorityCode;
		moveController.validateOnly := true;
		moveController.setMyPassport(app.myPassport);	
		
		//Find a location for this ti.
		foreach index in 1 to size do
			targetLocn := targetLocns[index];
			if not targetLocn.isAvailForMultiMove() then
				// someone else has grabbed this one while we have been mucking around, mark it to be removed from our potential targets
				removeLocns.add(targetLocn);
				continue;
			endif;
			
			//clear any existing target location we have tried for this ti, and set teh current one we are trying 
			moveController.setMyToPrimaryLocation(null);
			moveController.setMyToSecondaryLocations(null);
			moveController.setMyToPrimaryLocation(targetLocn);
			
			if not targetLocn.getSpannedToLCs( moveController ) then
				// This target location has no space
				continue;
			endif;
			
			spanProb := false;
			if not moveController.myToSecondaryLocations.isEmpty then
				foreach spanLC in moveController.myToSecondaryLocations do
					if not spanLC.isAvailForMultiMove() then
						// the space is there but not for a mutli move.. q'd or planned items probably.
						spanProb := true;
						break; 
					endif;
				endforeach;
				if spanProb then
					//we had a space problem in one of our spanned locations in the local loop above, now need to head back to get a new target location to try.
					continue;
				endif;
			endif;
			
			// Check to make sure that if there is already an item associated with
			// this primary position in any way that it is the same size...
			if not targetLocn.validateCargoMatchForMultiMove(ti) then
				continue;
			endif;
			
			
			// Ok we have a place where we can fit, better check all the other stuff like hazardous, diff voyage etc.
			app.myPassport.clearErrorsWarnings();
			app.setContinueCMExceptions( true );
			moveValidateExcOccurred := false;
			isWarningOnly := false;
			excHandlerMess := null;
			
			// arm a local exception handler to override any JMT errors,
			on Exception do self.handleMultiMoveValidation( exception, moveValidateExcOccurred, excHandlerMess, isWarningOnly );
			
			moveController.executeMove( app.myPassport );
			if moveValidateExcOccurred then
				if not ignoreWarnings or not isWarningOnly then
					app.myPassport.clearErrorsWarnings();
					continue;
				endif;
			endif;
			
			on Exception do null;
			
			locnToUse := targetLocn;
			break; // got a good target location, break from finding a location
		endforeach;
		
		if locnToUse = null then
			// no locations found to suit this ti.
			break;
		else
			removeLocns.add(locnToUse);  // set up to be removed from the available list
			isWarningOnly := false;
			excHandlerMess := null;
		endif;
		
		// Find a wle if you can
		wle := null;
		wle := ti.getWLEforFailedAutoPlan();	// in case this move is to override a failed auto plan
		if wle = null then
			wle := ti.getVoyageWLEUnactioned( false );	//Ship discharge job associated with this move
		endif;
		if wle = null then
			//wle := ti.getWLEForRoadRailMove();	//Rail or Road job associated with this move
			//20 Sep 2013	NDL	Par 32497
			wle := ti.getIncompleteRoadReceiveWle();
			if wle = null then
				wle := ti.getIncompleteRailReceiveWle();	
			endif;
		endif;
		
		if wle &lt;&gt; null then
			//found one so use it. 
			moveController.setMyWorkListEntry(wle);	
			moveController.setJobForMove(wle.job);
		endif; 
		
		moveController.validateOnly := false;
		
		while true do
			if targetLocn.isWagon() then 
				app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
			else
				app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
			endif;
			
			//we unconditionally ignore Yard Allocation Errors.
			justYardAllocWarnings := true;
			if not ignoreWarnings and not app.myPassport.allWarnings.isEmpty and app.myPassport.noErrors then
				foreach warning in app.myPassport.allWarnings do
					if warning.errorCode &lt;&gt; WARN_TI_NOTMATCH_ALLOCATION_AT then // error 82959
						justYardAllocWarnings := false;
					endif;
				endforeach;
			endif;
			
			if app.myPassport.trxCompletedOK then
				_processedMoves.add( ti );
				break;
				
			elseif app.myPassport.noErrors and ( ignoreWarnings or justYardAllocWarnings ) then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
				
			else
				result := app.showErrorWarningDialog(app.getErrorString(Move), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknowledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				break;
				
			endif;
		endwhile;	
		
		if app.myPassport.hasErrors then
			app.showErrorWarningDialog(app.getErrorString(Move), app.myPassport, ErrWarnMode_Add);
			break;
		endif;
		
	endforeach;
	
	msg := app.getErrorString3(	Moves_were_successful, _processedMoves.size.String, moveModeTypeStr, _allTrackedItems.size.String);
	if moveValidateExcOccurred and excHandlerMess &lt;&gt; null then
		if ( not ignoreWarnings and isWarningOnly ) or (not isWarningOnly) then
			// it was just a warning, but they wanted to stop.  or it was a real error
			msg := msg &amp; CrLf &amp; app.getErrorString2( First_fail_move_was, ti.id, excHandlerMess);
		endif;
	endif;
	app.msgBox(msg, app.getErrorString(Multi_move), MsgBox_Question_Mark_Icon + MsgBox_OK_Only);
		
	return true;
	
epilog

	foreach ti in skippedCargo do
		_processedMoves.addExclusive(ti);
	endforeach;

	delete moveController;
	delete removeLocns;
	delete targetLocns;
	delete skippedCargo;
	
end;</source>
        <Parameter name="_noChargeMove" type="Boolean"/>
        <Parameter name="_userAuthorityCode" type="String"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_allTrackedItems" type="CM_TIArray"/>
        <Parameter name="_targetLocns" type="CM_LCArray"/>
        <Parameter name="_targetLocationStr" type="String"/>
        <Parameter name="_processedMoves" type="CM_TIArray" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
