    <JadeMethod name="btnOk_click" id="c75bedbe-c710-4989-93d3-e49f52acb282">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.statusMsg('Updating Array entries...');

	if self.myArray &lt;&gt; null and self.formValidate() then
		self.formUpdate();
		modalResult	:=	1;
		unloadForm();
	endif;
epilog
	self.statusMsg('');
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="formAdd" id="6dce09f0-9c65-47e9-987c-40522b942156">
        <source>formAdd() protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	index	: Integer;

begin
	index					:=	tblObjects.addItem("");
	tblObjects.row			:=	index;
	tblObjects.column		:=	1;
	tblObjects.backColor	:=	Cn_LightGray;
	tblObjects.column		:=	2;

	if (self.myArray.isKindOf(BooleanArray)) then
		tblObjects.inputType	:=	Table.InputType_CheckBox;
		tblObjects.setCellText(index, 2, "0");

	elseif (self.myArray.isKindOf(CharacterArray)) then
		tblObjects.inputType	:=	Table.InputType_TextBox;

	elseif (self.myArray.isKindOf(DateArray)) then
		tblObjects.inputType	:=	Table.InputType_TextBox;

	elseif (self.myArray.isKindOf(DecimalArray)) then
		tblObjects.inputType	:=	Table.InputType_TextBox;

	elseif (self.myArray.isKindOf(HugeStringArray)) then
		tblObjects.inputType	:=	Table.InputType_TextBox;

	elseif (self.myArray.isKindOf(IntegerArray)) then
		tblObjects.inputType	:=	Table.InputType_TextNumeric;

	elseif (self.myArray.isKindOf(RealArray)) then
		tblObjects.inputType	:=	Table.InputType_TextBox;

	elseif (self.myArray.isKindOf(StringArray)) then
		tblObjects.inputType	:=	Table.InputType_TextBox;

	elseif (self.myArray.isKindOf(TimeArray)) then
		tblObjects.inputType	:=	Table.InputType_TextBox;

	elseif (self.myArray.isKindOf(TimeStampArray)) then
		tblObjects.inputType	:=	Table.InputType_TextBox;

	endif;

	lblEntries.caption	:=	(tblObjects.rows - 1).String;

	if (not btnOk.enabled) then
		btnOk.enabled	:=	true;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="formDelete" id="bd794040-3d23-4759-b16a-b26168276f0a">
        <updating/>
        <source>formDelete() updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (tblObjects.row &gt; 1) and (tblObjects.row &lt;= tblObjects.rows) then
		tblObjects.removeItem(tblObjects.row);
	endif;

	lblEntries.caption	:=	(tblObjects.rows - 1).String;
	tblObjects.clearAllSelected;
	btnDelete.enabled	:=	false;
	btnInsert.enabled	:=	false;

	if (not btnOk.enabled) then
		btnOk.enabled	:=	true;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="formInsert" id="f351eaf5-b5b4-49e1-bd6d-3e7f79487819">
        <source>formInsert();
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	index	: Integer;

begin
	if (tblObjects.row &gt; 1) and (tblObjects.row &lt;= tblObjects.rows) then
		index					:=	tblObjects.row;
		tblObjects.addItemAt("", index);
		tblObjects.row			:=	index;
		tblObjects.column		:=	1;
		tblObjects.backColor	:=	Cn_LightGray;
		tblObjects.column		:=	2;

		if (self.myArray.isKindOf(BooleanArray)) then
			tblObjects.inputType	:=	Table.InputType_CheckBox;
			tblObjects.setCellText(index, 2, "0");

		elseif (self.myArray.isKindOf(CharacterArray)) then
			tblObjects.inputType	:=	Table.InputType_TextBox;

		elseif (self.myArray.isKindOf(DateArray)) then
			tblObjects.inputType	:=	Table.InputType_TextBox;

		elseif (self.myArray.isKindOf(DecimalArray)) then
			tblObjects.inputType	:=	Table.InputType_TextBox;

		elseif (self.myArray.isKindOf(HugeStringArray)) then
			tblObjects.inputType	:=	Table.InputType_TextBox;

		elseif (self.myArray.isKindOf(IntegerArray)) then
			tblObjects.inputType	:=	Table.InputType_TextNumeric;

		elseif (self.myArray.isKindOf(RealArray)) then
			tblObjects.inputType	:=	Table.InputType_TextBox;

		elseif (self.myArray.isKindOf(StringArray)) then
			tblObjects.inputType	:=	Table.InputType_TextBox;

		elseif (self.myArray.isKindOf(TimeArray)) then
			tblObjects.inputType	:=	Table.InputType_TextBox;

		elseif (self.myArray.isKindOf(TimeStampArray)) then
			tblObjects.inputType	:=	Table.InputType_TextBox;

		endif;
	endif;

	lblEntries.caption	:=	(tblObjects.rows - 1).String;

	if (not btnOk.enabled) then
		btnOk.enabled	:=	true;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="formLoad" id="b6e8e3bd-8e07-42bf-a592-ad5557439fb9">
        <updating/>
        <source>formLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		Handles all processing of the Form load event.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.caption			:=	self.caption &amp; ': ' &amp; self.myClass.name &amp; "." &amp; self.arrayName;
	self.canUpdate			:=	self.isEditingAllowed();
	self.viewObjectsByOid	:=	self.getViewObjectsByOid();

	if (self.myClass = null) then
		app.msgBox("The reference to the class null.", "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
		unloadForm();
		return;
	endif;

	if (self.myArray &lt;&gt; null) then
		self.loadArray(self.myClass);
	endif;

	btnDelete.enabled	:=	false;
	btnInsert.enabled	:=	false;
	btnOk.enabled		:=	false;

	if (not self.canUpdate) then
		btnAdd.visible				:=	false;
		btnClearAll.visible			:=	false;
		btnDelete.visible			:=	false;
		btnInsert.visible			:=	false;
		btnOk.visible				:=	false;
		tblObjects.columnVisible[2]	:=	false;
	endif;

	modalResult				:=	0;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="formUpdate" id="ec3f1705-9772-4487-a2a2-670e70e573cc">
        <updating/>
        <source>formUpdate() updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	index		: Integer;
	count		: Integer;
	table		: Table;
	value		: String;
	aPoint		: Point;
	pointX		: String;
	pointY		: String;
	position	: Integer;

begin
	self.myArray.clear();
	table	:=	tblObjects;
	count	:=	table.rows;
	index	:=	2;

	while (index &lt;= count) do
		if (self.myArray.isKindOf(BooleanArray)) then
			self.myArray.add((table.getCellText(index, 2) = "1").Boolean);

		elseif (self.myArray.isKindOf(CharacterArray)) then
			self.myArray.add(table.getCellText(index, 2).Character);

		elseif (self.myArray.isKindOf(DateArray)) then
			self.myArray.add(table.getCellText(index, 2).Date);

		elseif (self.myArray.isKindOf(DecimalArray)) then
			self.myArray.add(table.getCellText(index, 2).Decimal);

		elseif (self.myArray.isKindOf(HugeStringArray)) then
			self.myArray.add(table.getCellText(index, 2).String);

		elseif (self.myArray.isKindOf(IntegerArray)) then
			self.myArray.add(table.getCellText(index, 2).Integer);

		elseif (self.myArray.isKindOf(PointArray)) then
			value	:=	table.getCellText(index, 2).trimBlanks;

			if (value.length = 0) then
				aPoint.set(0, 0);
			else
				position	:=	value.pos(",", 1);

				if (position = 1) then
					pointX	:=	"0";
				else
					pointX	:=	value[1:(position - 1)];
				endif;

				if (position = value.length) then
					pointY	:=	"0";
				else
					pointY	:=	value[(position + 1):end];
				endif;

				aPoint.set(pointX.Integer, pointY.Integer);
			endif;

			self.myArray.add(aPoint);

		elseif (self.myArray.isKindOf(RealArray)) then
			self.myArray.add(table.getCellText(index, 2).Real);

		elseif (self.myArray.isKindOf(StringArray)) then
			self.myArray.add(table.getCellText(index, 2).String);

		elseif (self.myArray.isKindOf(TimeArray)) then
			self.myArray.add(table.getCellText(index, 2).Time);

		elseif (self.myArray.isKindOf(TimeStampArray)) then
			self.myArray.add(table.getCellText(index, 2).TimeStamp);

		endif;

		index	:=	index + 1;
	endwhile;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="formValidate" id="720d398a-5b62-4e1e-8882-e59b7d743d4b">
        <updating/>
        <source>formValidate() : Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	index			: Integer;
	rows			: Integer;
	table			: Table;
	type			: String;
	invalidMsg		: String;
	lengthMsg		: String;
	value			: String;
	valBoolean		: Boolean;
	valCharacter	: Character;
	valDate			: Date;
	valDecimal		: Decimal[23];
	valInteger		: Integer;
	valPoint		: Point;
	valReal			: Real;
	valString		: String;
	valTime			: Time;
	valTimeStamp	: TimeStamp;
	pointX			: String;
	pointY			: String;
	position		: Integer;

begin
	if (tblObjects.rows &lt; 2) then
		app.msgBox("There are no attributes to update.", "Warning", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;

	type	:=	self.myClass.findProperty(arrayName).type.CollClass.memberType.name;
	table	:=	tblObjects;
	rows	:=	table.rows;
	index	:=	2;

	while (index &lt;= rows) do
		value		:=	table.getCellText(index, 2).trimBlanks;
		invalidMsg	:=	"Row " &amp; index.String &amp; " has an invalid " &amp; type &amp; " value: " &amp; value;
		lengthMsg	:=	self.myArray.getName() &amp; " elements have a maximum length of: ";

		if (type = "Boolean") then
			if (value &lt;&gt; "1") and (value &lt;&gt; "0") then
				app.msgBox(invalidMsg, "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
				return false;
			endif;

			valBoolean		:=	(value = "1");

		elseif (type = "Character") then
			if (value.trimBlanks.length &gt; 1) then
				app.msgBox(invalidMsg, "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
				return false;
			endif;

			valCharacter	:=	value.Character;

		elseif (type = "Date") then
			if (value.trimBlanks.length &gt; 0) and (not value.Date.isValid) then
				app.msgBox(invalidMsg, "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
				return false;
			endif;

			valDate			:=	value.Date;

		elseif (type = "Decimal") then
			if (not value.isDecimal) then
				app.msgBox(invalidMsg, "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
				return false;
			endif;

			if (value.pos(".", 1) = 0) then
				if (value.length &gt; 23) then
					app.msgBox(lengthMsg &amp; "23", "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
					return false;
				endif;
			else
				if (value.length &gt; 23 + 1) then		// The decimal point character doesn't count in the length.
					app.msgBox(lengthMsg &amp; "23", "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
					return false;
				endif;
			endif;

			valDecimal		:=	value.Decimal;

		elseif (type = "Integer") then
			if (not value.isInteger) then
				app.msgBox(invalidMsg, "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
				return false;
			endif;

			valInteger		:=	value.Integer;

		elseif (type = "Point") then
			if (value.length &gt; 8) then
				app.msgBox(lengthMsg &amp; "8", "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
				return false;
			endif;

			if (value.length &gt; 0) then
				position	:=	value.pos(",", 1);

				if (position = 0) then
					app.msgBox(invalidMsg, "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
					return false;
				endif;

				if (position = 1) then
					pointX	:=	"0";
				else
					pointX	:=	value[1:(position - 1)];
				endif;

				if (position = value.length) then
					pointY	:=	"0";
				else
					pointY	:=	value[(position + 1):end];
				endif;

				if (not pointX.isInteger) or (not pointY.isInteger) then
					app.msgBox(invalidMsg, "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
					return false;
				endif;

			endif;

		elseif (type = "Real") then
			if (not value.isReal) then
				app.msgBox(invalidMsg, "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
				return false;
			endif;

			valReal			:=	value.Real;

		elseif (type = "String") then
			if (value.length &gt; 62) then
				app.msgBox(lengthMsg &amp; "62", "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
				return false;
			endif;

			valString		:=	value;

		elseif (type = "Time") then
			if (value.trimBlanks.length &gt; 0) and (not value.Time.isValid) then
				app.msgBox(invalidMsg, "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
				return false;
			endif;

			valTime			:=	value.Time;

		elseif (type = "TimeStamp") then
			if (value.trimBlanks.length &gt; 0) and (not value.TimeStamp.isValid) then
				app.msgBox(invalidMsg, "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
				return false;
			endif;

			valTimeStamp	:=	value.TimeStamp;

		endif;

		index	:=	index + 1;
	endwhile;

	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getArrayName" id="cacff096-709e-4a90-aad8-6ce74284b205">
        <source>getArrayName() : String;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return  arrayName;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyArray" id="d0bacf07-0c8a-4d83-985e-b7edbd64f094">
        <source>getMyArray() : Array;
// --------------------------------------------------------------------------------
// Created:		20 January 1999 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return  myArray;
end;</source>
        <ReturnType type="Array"/>
    </JadeMethod>
