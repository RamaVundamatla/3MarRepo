    <JadeMethod name="createProductsForTIs" id="63bb9f1c-4bc3-40c8-8fcb-9d64247949e6">
        <source>createProductsForTIs(tis : CM_ObjectByStringDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 July 2023	jlier1	Initial creation 58840
17 August 2023	navmd1	TFS 59870 fix 4033 error when processing LOADCO messages
03 Apr 2024	jlika1	TFS 63079 EUP | FR 54026 LOADCO LOADNA - Mapping Width Length Height Fields Are Blank
08 Apr 2024	jlika1	TFS 63081 EUP* | FR - 54026 LOADCO LOADNA - Sales Detail Missing from LOADNA
23 Apr 2025	naviv1	MTN-34636 EUP FR | 54026 - LOADCO and LOADNA Message - Incorrect Weight Summary in the LOADCO message
*/

vars
	iter					: Iterator;
	reserveDetailOid,
	prevReserveDetailOid 	: String;
	ti 						: CM_TrackedItem;
	product 				: CMIF_JsonProductEUP;
	reserveDetail 			: CM_ReserveDetail;
	totalWeight 			: Decimal [14,2];
	totalQuantity,
	productSequence			: Integer;
	salesLine 				: CMIF_JsonSalelineEUP;
begin
		
	iter:=tis.createIterator;
	while iter.next(ti) do
		reserveDetailOid:=iter.getCurrentKey(1).String;
		reserveDetail:=reserveDetailOid.asOid.CM_ReserveDetail;
		if prevReserveDetailOid &lt;&gt; reserveDetailOid then
			if product &lt;&gt; null and totalQuantity &lt;&gt; 0 then
				product.colli:=totalQuantity;				
			endif;
			
			if product &lt;&gt; null and totalWeight &lt;&gt; 0 then				
				product.weight:=totalWeight.roundedTo(2);		
			endif;
			
			totalQuantity:=0;
			totalWeight:=0;
			productSequence:=+1;
			create product transient;
			product.setFromReserveDetail(reserveDetail,null);
			product.sequenceNumber:=productSequence;
			self.products.add(product);
		endif;
		
		prevReserveDetailOid:=reserveDetailOid;
		totalWeight:= totalWeight + ti.totalWeight; //JIRA-34636
		totalQuantity:= totalQuantity + ti.totalQuantity; //JIRA-34636
	endwhile;

	if product &lt;&gt; null and totalQuantity &lt;&gt; 0 then
		product.colli:=totalQuantity;		
	endif;
	
	if product &lt;&gt; null and totalQuantity &lt;&gt; 0 then		
		product.weight:=totalWeight.roundedTo(2);
	endif;
	
	create salesLine transient;
	self.sales.add(salesLine);
epilog
	delete iter;
end;</source>
        <Parameter name="tis" type="CM_ObjectByStringDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createProductsForVBS" id="acaf7546-87d4-4d38-938f-309234fa4bd9">
        <source>createProductsForVBS(vbs : CM_ObjectByStringDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2023	jlier1	Initial creation 58839
17 August 2023	navmd1	TFS 59870 fix 4033 error when processing LOADCO messages
03 Apr 2024	jlika1	TFS 63079 EUP | FR 54026 LOADCO LOADNA - Mapping Width Length Height Fields Are Blank
9 Oct 2024 navsaa30 MTN-32063 EUP | FR 54026 - Sales Detail Missing from LOADNA
23 Apr 2025	naviv1	MTN-34636 EUP FR | 54026 - LOADCO and LOADNA Message - Incorrect Weight Summary in the LOADCO message
*/

vars
	iter					: Iterator;
	reserveDetailOid,
	prevReserveDetailOid 	: String;
	vbsItem 				:  CM_VehicleBookingTimeSlotItem;
	product 				: CMIF_JsonProductEUP;
	reserveDetail 			: CM_ReserveDetail;
	totalWeight 			: Decimal [14,2];
	totalQuantity,
	productSequence			: Integer;
	salesLine 				: CMIF_JsonSalelineEUP;
	trailerType				: String;
	trailerTypeFor7002		: Boolean;
begin
		
	iter:=vbs.createIterator;
	while iter.next(vbsItem) do
		if trailerType = null then					//9/10/2024  navsaa30 #54026
			trailerType	:= vbsItem.myVehicleBookingSlot.myTerminal.getConfig(TrailerTypeForLOADNA).String;
		endif;
		reserveDetailOid:=iter.getCurrentKey(1).String;
		reserveDetail:=reserveDetailOid.asOid.CM_ReserveDetail;
		if prevReserveDetailOid &lt;&gt; reserveDetailOid then
			if product &lt;&gt; null and totalQuantity &lt;&gt; 0 then
				product.colli:=totalQuantity;				
			endif;
			if product &lt;&gt; null and totalWeight &lt;&gt; 0 then
				product.weight:=totalWeight.roundedTo(2);		
			endif;
			
			totalQuantity:=0;
			totalWeight:=0;
			productSequence:=+1;
			create product transient;
			product.setFromReserveDetail(reserveDetail,reserveDetail.myCargoGroup);
			product.sequenceNumber:=productSequence;
			self.products.add(product);
		endif;
		
		prevReserveDetailOid:=reserveDetailOid;
		totalWeight:= totalWeight + vbsItem.weight;			//JIRA-34636
		totalQuantity:= totalQuantity + vbsItem.quantity;  //JIRA-34636
		if trailerType &lt;&gt; null and vbsItem.myVehicleBookingSlot.myTILCType &lt;&gt; null then										//9/10/2024  navsaa30 #54026
			if vbsItem.myVehicleBookingSlot.myTILCType.code = trailerType then				
				trailerTypeFor7002	:= true;
			endif;
		endif;
	endwhile;

	if product &lt;&gt; null and totalQuantity &lt;&gt; 0 then
		product.colli:=totalQuantity;		
	endif;	
	if product &lt;&gt; null and totalWeight &lt;&gt; 0 then		
		product.weight:=totalWeight.roundedTo(2);
	endif;
	
	create salesLine transient;
	if trailerTypeFor7002 then						//9/10/2024  navsaa30 #54026
			salesLine.code	:= "7002";
		endif;
	self.sales.add(salesLine);
	
epilog
	delete iter;
end;</source>
        <Parameter name="vbs" type="CM_ObjectByStringDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="delete" id="becad095-6f4c-4288-a302-7e7b8be6171c">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 June 2023	jlier1	Initial creation 58839

*/

vars

begin
	if self.tour &lt;&gt; null then
		delete self.tour;
	endif;
	
	if self.unload &lt;&gt; null then
		delete self.unload;
	endif;
	
	if self.load &lt;&gt; null then
		delete self.load;
	endif;
	
	self.products.purge;
	self.sales.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFromVehicleBooking" id="81ce4588-86be-48be-989c-1dad05dd7751">
        <updating/>
        <source>setFromVehicleBooking(_vehicleBooking : CM_VehicleBookingTimeSlot; _release :CM_BulkRelease; _deliveryParty : CM_DeliveryParty) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Jun 2023	jlier1	Initial creation 58839
08 Apr 2024	jlika1	TFS 63080 EUP* | FR 54026 LOADCO LOADNA - Delivery Instructions Missing from 
12 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
20 Aug 2024 navmd1	TFS 61725 Changed Load Date into TimeStamp so UTC conversion works properly
*/

vars
	
begin

	self.instructions:=_release.code &amp; "-" &amp; _vehicleBooking.id;
	if _release.myInstructions &lt;&gt; null then
		self.goods:=_release.myInstructions.getExternalInstruction;
	endif;
	self.service:="XXXX";
	
	if _vehicleBooking.myTILCType &lt;&gt; null then							// 12 Aug 2024 navcs2	ChangeRequest 63928
		self.transporttype:=_vehicleBooking.myTILCType.code &amp; " OUT"; 	// 12 Aug 2024 navcs2	ChangeRequest 63928
	endif;																// 12 Aug 2024 navcs2	ChangeRequest 63928
	
	create self.tour transient;
	self.tour.tourNumber:=1;
	self.tour.supplierCode:=_vehicleBooking.getCarrierCode;
	
	create self.load transient;
	self.load.number:="0";
	self.load.name:="EUROPORTS TERMINAL LEFTBANK";
	self.load.street:="LAND VAN WAASLAAN";
	self.load.street2:="KAAI 1213";
	self.load.country:="B";
	self.load.zipcode:="9130";
	self.load.city:="KALLO (KIELDRECHT)";
	self.load.date.setDate(_vehicleBooking.bookingTSstart.localToUTCTime.date);
	self.load.reference:=_vehicleBooking.externalReference;
	
	create self.unload transient;
	self.unload.setFromDeliveryParty(_deliveryParty);
	
		
epilog

end;</source>
        <Parameter name="_vehicleBooking" type="CM_VehicleBookingTimeSlot"/>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_deliveryParty" type="CM_DeliveryParty"/>
    </JadeMethod>
</Class>
