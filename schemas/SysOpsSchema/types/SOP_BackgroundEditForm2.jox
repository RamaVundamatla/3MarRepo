    <JadeMethod name="fieldClassList_doAlignCtrls" id="a3b034c7-7142-405d-95e5-c94f04f1f164">
        <controlMethod name="CMUI_FieldGeneric::doAlignCtrls"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fieldClassList_doAlignCtrls(_fieldGeneric: CMUI_FieldGeneric input) updating;
// --------------------------------------------------------------------------------
// Created:		24 February 2006 by cnwdad1
//
// Purpose:		Aligns the receiver's child controls.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlWidth	: Real;
	controlLeft		: Real;
	listboxObj		: CMUI_ListTable;
	
begin
	listboxObj		:=	lstTable;
	controlLeft		:=	_fieldGeneric.myLabel.left + _fieldGeneric.myLabel.width + CMUI_FieldFrame.HORIZONTAL_SPACING;
	controlWidth	:=	_fieldGeneric.clientWidth() - controlLeft;
	listboxObj.move(controlLeft, 0, self.DEFAULT_WIDTH, _fieldGeneric.height);
	listboxObj.move(controlLeft, 0, controlWidth, _fieldGeneric.height);
	listboxObj.visible		:=	true;
	listboxObj.scrollBars	:=	Table.ScrollBars_VertPermanentHorz;
end;</source>
        <Parameter name="_fieldGeneric" type="CMUI_FieldGeneric" usage="input"/>
    </JadeMethod>
