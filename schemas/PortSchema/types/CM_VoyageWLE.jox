    <JadeMethod name="setCompletedDate" id="799dcf04-eb5d-4518-bdbb-5bc19b15e84b">
        <updating/>
        <source>setCompletedDate(_compTS: TimeStamp) updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	voyage	: CM_Voyage;
begin
	if self.status &lt;&gt; WLE_COMPLETED then
		self.completedDate := null;
		return;
	endif;
	self.completedDate := _compTS;
	
	if self.job = null then
		return;
	endif;
	
	//epr par  7/2/2011 25573  set the jobs actual start and end times
	self.job.CM_VoyageJob.updateActualAndEndTs(self.completedDate);
	
	voyage:=self.getVoyage;
	if voyage &lt;&gt; null then
		app.myEventManager.createSingleObjInfoNoteEvt(voyage, EVENT_WLE_COMPLETE, self);
	endif;
	
	// epr par 25573 7/2/2011 refactored code block into below method
	self.setJobSheetAndCompletedRate();
	
	// PAR #26426 remove me from my release request's "being actioned" collection
	self.myRequest.setMyOriginatingBulkRelease(null);

end;</source>
        <Parameter name="_compTS" type="TimeStamp"/>
    </JadeMethod>
