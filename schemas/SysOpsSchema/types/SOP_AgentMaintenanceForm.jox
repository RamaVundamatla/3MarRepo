    <JadeMethod name="doAgentSearch" id="b219fa6f-8cd6-4204-bebd-89a874b98433">
        <updating/>
        <source>doAgentSearch() updating, protected;
/*
Purpose:			From CCMS GLT 2342 copy duty doc Cargo Description search for agents

Parameters:			

Return Value:		

Date		Who		Reason
03/03/2014	cnwjre1	Initial creation
10/06/2019	jlgdap1	TFS 44554 AAT Stevedore Data Access
*/

vars
	existingAgent 	: Object;
	combo		: ComboBox;
	debtorType	: CM_DebtorType;
	consignor : CM_ConsigneeConsignor;
	customsAgent	: CM_CustomsAgent;
	stevedore		: CM_Stevedore;					// TFS 44554
	passport : CM_Passport;
	failedDAC : CM_DataAccessController;
	searchTxt	: String;
	pos, foundPos  : Integer;
	comboText	: String;
begin

	debtorType := self.myAgentType;
	if debtorType = null then
		return;
	endif;
	combo := self.cmbAgent;
	existingAgent := combo.listObject;
	searchTxt := self.txtAgent.text.toUpper().trimRight();
	
	// if a null search string, re-populate the combo
	if searchTxt = null then
		self.populateAgentCombo();
		return;
	endif;
	
	combo.clear;

	//search all agents and filter name/description using the search string
	passport	:= app.myPassport;

	if debtorType.code = "SDT2" or			// consignee
	   debtorType.code = "SDT3" or			// consignor
	   debtorType.code = "SDT7" then		// freight forwarder

		foreach consignor in app.myRoot.allConsigneeConsignors do
			if (not consignor.canUserAccessSelf(null, failedDAC, passport) or consignor.isNotAvailableForEntry) then
				continue;
			endif;
			
			if debtorType.code = "SDT7" and not consignor.isFreightFwdr then
				continue;
			elseif debtorType.code = "SDT2" and not consignor.isConsignee then
				continue;
			elseif debtorType.code = "SDT3" and not consignor.isConsignor then
				continue;
			endif;
		
			pos := 1;
			foundPos := 0;
			foundPos := consignor.description.toUpper.pos(searchTxt, pos);
			if foundPos &gt; 0 then
				comboText := getAgentDescription(consignor);
				combo.itemObject[combo.addItem(comboText)] := consignor;
			endif;
		endforeach;
	elseif debtorType.code = "SDT6" then	// customs agent
		foreach customsAgent in app.myRoot.allCustomsAgents do
			if (not customsAgent.canUserAccessSelf(null, failedDAC, passport) or customsAgent.isNotAvailableForEntry) then
				continue;
			endif;
		
			pos := 1;
			foundPos := 0;
			foundPos := customsAgent.name.toUpper.pos(searchTxt, pos);
			if foundPos &gt; 0 then
				comboText := self.getAgentDescription(customsAgent);
				combo.itemObject[combo.addItem(comboText)] := customsAgent;
			endif;
		endforeach;
		
	// TFS 44554
	elseif debtorType.code = "SDT10" then	// stevedore
		foreach stevedore in app.myRoot.allStevedores discreteLock do
			if not stevedore.canUserAccessSelf(null, failedDAC, passport) or stevedore.notAvailableForEntry then
				continue;
			endif;
			
			pos := 1;
			foundPos := 0;
			foundPos := stevedore.description.toUpper.pos(searchTxt, pos);
			if foundPos &gt; 0 then
				comboText := self.getAgentDescription(stevedore);
				combo.itemObject[combo.addItem(comboText)] := stevedore;
			endif;
		endforeach;
	// TFS 44554
	
	endif;

	combo.showDropDown();
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="51c9ed19-ab69-41e1-a584-1aa074336a9f">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
//	toolbar cancel action - cancel edit, enable buttons, restore table
vars

begin
	inheritMethod();
	
	self.mode := self.Mode_View;
	self.enableToolbarButtons();
	// repopulate the table with the original data
	if self.cmbAgent.listIndex &gt; 0 then
		self.cmbAgent_click(self.cmbAgent);
	endif;
	
	self.tblAgents.userInputEnabled := false;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="628a7f79-98a3-4572-8e23-ab8805f6d675">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// save new or updated agent + debtor
// Changed On	By			Reason
// ----------	--------	-------------------------------------------
// 08/08/2018	jlgdap1		TFS 40092 PEL1 Adding Changes to Debtors
// 25/10/2018	jlgrh7 		TFS #41285	PKT - Unable to edit Customs Agent
// 10/06/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
vars
	theReturn	: Integer;
	index		: Integer;
	description	: String;
	cmif		: CMIF_AgentDebtor;
	realAgent	: CM_Object;
	realDebtor	: CM_Debtor;
	table		: CM_EntryTable;
	
begin
	
	table := self.tblAgents;
	create cmif transient;

	//cmif.agentCode := table.getValueByName(ETRow_Code).String;										//-TFS41285
	if self.myAgentType.code = CM_DebtorType.DT_CUSTOMS_AGENT then							//+TFS41285
		cmif.agentCode := table.getValueByName(ETRow_CustomsAgentCode).String;
	elseif self.myAgentType.code = CM_DebtorType.DT_STEVEDORE_VOYAGE then					// TFS 44554
		cmif.agentCode := table.getValueByName(ETRow_StevedoreCode).String;			// TFS 44554
	else
		cmif.agentCode := table.getValueByName(ETRow_Code).String;								
	endif;
	cmif.agentDescription := table.getValueByName(ETRow_Description).String;
	if table.isRowVisible(ETRow_Debtor) then
		//cmif.debtorName := table.getValueByName(ETRow_Debtor).String;				// TFS 40092
		cmif.debtorName := table.getValueByName(ETRow_Debtor).String[1:100];		// TFS 40092
	else
		cmif.myDebtor := self.cmbDebtor.listObject.CM_Debtor;
	endif;
	cmif.debtorAddress := table.getValueByName(ETRow_Address).String;
	cmif.isCashOnly := table.getValueByName(ETRow_IsCashOnly).Boolean;
	cmif.isConsignor := table.getValueByName(ETRow_IsConsignor).Boolean;
	cmif.isConsignee := table.getValueByName(ETRow_IsConsignee).Boolean;
	cmif.isFreightForwarder := table.getValueByName(ETRow_IsFreightFwdr).Boolean;
	if self.myAgentType.code = CM_DebtorType.DT_CUSTOMS_AGENT then
		cmif.agentType := CUSTOMS_AGENT;
	elseif self.myAgentType.code = CM_DebtorType.DT_STEVEDORE_VOYAGE then			// TFS 44554 //04.11.2020 cnwma1 TFS #50112
		cmif.agentType := STEVEDORE;												// TFS 44554
	endif;
	
	if self.mode = self.Mode_Update then 
		realAgent := self.cmbAgent.listObject.CM_Object;
		if realAgent.isKindOf(CM_ConsigneeConsignor) then
			realDebtor := realAgent.CM_ConsigneeConsignor.debtor;
		elseif realAgent.isKindOf(CM_CustomsAgent) then
			realDebtor := realAgent.CM_CustomsAgent.myDebtor;
		elseif realAgent.isKindOf(CM_Stevedore) then								// TFS 44554
			realDebtor := realAgent.CM_Stevedore.myDebtor;							// TFS 44554
		endif;
	endif;
	
	while true do
		if self.mode = self.Mode_Add then
			app.myTrxCA.trxCreateAgentDebtor(cmif, realAgent, realDebtor, app.myPassport);
		elseif self.mode = self.Mode_Update then
			app.myTrxUA.trxUpdateAgentDebtor(cmif, realAgent, realDebtor, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			global.beep;
			self.enableToolbarButtons();
			if self.mode = self.Mode_Add then
				// add the agent to the combo and position on it
				description := self.getAgentDescription(realAgent);
				index := self.cmbAgent.addItem(description);
				self.cmbAgent.itemObject[index] := realAgent;
				self.cmbAgent.listIndex := index;
			// for an update, should really check if a consignee/or has been updated such that it should no longer be in the current agent combo -
			//	  e.g. agent type of Consignee and the isConsignee option has been reset.  Code should check for this and remove it from the combo?
			//		while leaving it in the table so the user can see that it has updated.
			endif;
			return ;
		else
			theReturn := app.showErrorWarningDialog(self.myAgentType.description &amp; "/Debtor Add", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
			return ;
		endif;
		break;
	endwhile;

epilog
	delete cmif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doChangeDebtor" id="f02cc1dd-de15-4002-b926-2c5728680c1f">
        <updating/>
        <source>doChangeDebtor() updating, protected;
// allow change of debtor rather than changing the name of the existing debtor
//	Toggle showing debtor as a combo of existing debtors, and as a text box to change the existing debtor name.
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------
// 10/06/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
vars
	debtor	: CM_DebtorNode;
	object	: CM_Object;
	table	: CM_EntryTable;
begin
	table := self.tblAgents;
	// if debtor name is showing, replace with combo
	if table.isRowVisible(ETRow_Debtor) then
		table.hideRowByName(ETRow_Debtor, false);		// textbox for debtor name
		table.showRowByName(ETRow_MyDebtor, false);		// combo of existing debtors
		table.disableRowByName(ETRow_Address);			// can't edit address
	
		self.cmbDebtor.clear();
		foreach debtor in app.myRoot.myRootCompany.debtors discreteLock do
			if not debtor.isKindOf( CM_Debtor ) then
				continue;
			endif;
			self.cmbDebtor.itemObject[self.cmbDebtor.addItem(debtor.name)] := debtor;
		endforeach;

		debtor := null;
		if self.mode &lt;&gt; self.Mode_Add then
			object := self.cmbAgent.listObject.CM_Object;
			if object.isKindOf(CM_ConsigneeConsignor) then
				debtor := object.CM_ConsigneeConsignor.debtor;
			elseif object.isKindOf(CM_CustomsAgent) then
				debtor := object.CM_CustomsAgent.myDebtor;
			elseif object.isKindOf(CM_Stevedore) then				// TFS 44554
				debtor := object.CM_Stevedore.myDebtor;				// TFS 44554
			endif;
		endif;
		if debtor &lt;&gt; null then
			self.cmbDebtor.listIndex := self.cmbDebtor.findObject(debtor);
		endif;
	else
	// replace combo with name text - any prior entry is shown here
		table.showRowByName(ETRow_Debtor, false);		// textbox for debtor name
		table.hideRowByName(ETRow_MyDebtor, false);		// combo of existing debtors
		table.enableRowByName(ETRow_Address);
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doClose" id="5ce47669-febc-46eb-bf45-743a1aba8c69">
