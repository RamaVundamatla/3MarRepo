<CollClass name="CM_WorkOrderSet" id="e51b498e-6815-4b3e-9b21-aa4b5d03ca81">
    <loadFactor>98</loadFactor>
    <memberType name="CM_WorkOrder"/>
    <superclass name="ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="workorder"/>
    <JadeMethod name="getWODDetailOfTypeStatus" id="d5cdf58d-3a34-47a7-b713-c957c6f67806">
        <source>getWODDetailOfTypeStatus(_type, _status : Integer) : CM_WorkOrderDtl;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2018	jlger1	Initial creation 41310

*/

vars

	workOrder : CM_WorkOrder;
	workOrderDetail : CM_WorkOrderDtl;
begin
	foreach workOrder in self discreteLock, reversed do
		if workOrder.taskStatus &lt;&gt; _status then
			continue;
		endif;
		workOrderDetail:=workOrder.getWorkOrderDetailOfType(_type);
		if workOrderDetail &lt;&gt; null then
			return workOrderDetail;
		endif;
		
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="getWODPermitForAdditonalCargo" id="f79a775f-1f65-4e46-aafe-d859da3316b0">
        <source>getWODPermitForAdditonalCargo() : CM_WodPermitRequest;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2018	jlger1	Initial creation

*/

vars
workOrder : CM_WorkOrder;
	workOrderDetail : CM_WorkOrderDtl;
begin
	foreach workOrder in self discreteLock do
		if workOrder.taskStatus = WO_STATUS_CANCELLED then
			continue;
		endif;
		foreach workOrderDetail in workOrder.allWoDtls discreteLock do
			if workOrderDetail.detailType = WO_TASK_PERMIT then
				if workOrderDetail.CM_WodPermitRequest.isAdditionalCargo then
					return workOrderDetail.CM_WodPermitRequest;
				endif;
			endif;
		endforeach;
		
	endforeach;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_WodPermitRequest"/>
    </JadeMethod>
    <JadeMethod name="getWODPermitForDetailType" id="48a297a5-b94f-4fd7-8bbd-04451643c7c9">
        <source>getWODPermitForDetailType(	_permitDetailType: Integer;
							_taskStatus : Integer  )
							 : CM_WorkOrderDtl;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/10/2018	jlger1	Initial creation 41310
30/10/2018	jlgdap1	TFS 41676 PEL1 Unable to Create IMSR after Cancellation
*/

vars
	workOrder : CM_WorkOrder;
	workOrderDetail : CM_WorkOrderDtl;
begin
	foreach workOrder in self discreteLock, reversed do
		if _taskStatus &lt;&gt; null and workOrder.taskStatus &lt;&gt; _taskStatus then
			continue;
		endif;
		foreach workOrderDetail in workOrder.allWoDtls discreteLock do
			if workOrderDetail.detailType = WO_TASK_PERMIT then
				if workOrderDetail.CM_WodPermitRequest.permitDetailType = _permitDetailType then
					if _permitDetailType = WO_TASK_EXTENSION or
						_permitDetailType = WO_TASK_SHIFTMOVEMENT or
						_permitDetailType = WO_TASK_MARINEINITIAL then			// TFS 41676
						if workOrderDetail.CM_WodPermitRequest.myPermitWodVoyageDetail &lt;&gt; null then
							continue;
						endif;
					endif;
					return workOrderDetail;
				endif;
			endif;
		endforeach;
		
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_permitDetailType" type="Integer"/>
        <Parameter name="_taskStatus" type="Integer"/>
        <ReturnType type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="getWorkOrderDetailOfType" id="2115677c-059f-4651-98a4-2e321bfcc8fa">
        <source>getWorkOrderDetailOfType(_type : Integer) : CM_WorkOrderDtl;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlger1	Initial creation 39166

*/

vars
	workOrder : CM_WorkOrder;
	workOrderDetail : CM_WorkOrderDtl;
begin
	foreach workOrder in self discreteLock,reversed do
		if workOrder.taskStatus = WO_STATUS_CANCELLED then
			continue;
		endif;
		workOrderDetail:=workOrder.getWorkOrderDetailOfType(_type);
		if workOrderDetail &lt;&gt; null then
			return workOrderDetail;
		endif;
		
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="includesMeOrHasNoneSimilar" id="577555b2-bafa-4d0a-9f52-675579d06a4c">
        <source>includesMeOrHasNoneSimilar( _realWO : CM_WorkOrder; _class : Class ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 June 2018	jlgndl1	Initial creation	TFS 38948

*/

vars

	wo : CM_WorkOrder;
	wod : CM_WorkOrderDtl;
begin

	foreach wo in self do
		foreach wod in wo.allWoDtls do
			if wod.isKindOf( _class ) then
				if _realWO &lt;&gt; null and wo = _realWO then
					return true;
				endif;
				return false;
			endif;
		endforeach;
	endforeach;
	
	return true;

epilog

end;</source>
        <Parameter name="_realWO" type="CM_WorkOrder"/>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
