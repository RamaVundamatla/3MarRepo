    <JadeMethod name="getCriteriaSummary" id="cd37d006-e53d-40ec-abdf-c6c8528c7112">
        <source>getCriteriaSummary(_delim: String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2022	navhl20	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
20 Dec 2022	navak20 Task 55978: EUP - VBS MTN - [1] - VBS Slot Types - Review Changes
*/

vars
	criteria : CM_YACriteria;
	invalidObj : Boolean;
	attrStr : String;
	valueStr : String;
	
	retString : String;

begin

	on Exception do app.handleDeletedObject(exception, criteria, invalidObj);

	foreach criteria in self.allCriteria do
		attrStr := null;
		
		criteria.edition;
		
		if invalidObj then
			invalidObj := false;
			continue;
		endif;
		
		if criteria.myYACriteriaType = null then
			continue;
		endif;
		
		if criteria.myYACriteriaType.type = YACriteriaType_Carrier then
			attrStr := app.getErrorString(Carrier);
		else
			attrStr := criteria.myYACriteriaType.description;
		endif;
		valueStr := criteria.getDisplayForYAMTableColumn;
		// 20.12.2022 navak20 TFS 55978
		if attrStr = null and valueStr = null then
		  continue;
		endif;
		// 20.12.2022 navak20 TFS 55978
		if attrStr &lt;&gt; null and valueStr &lt;&gt; null then
			if retString &lt;&gt; null then
				retString := retString &amp; _delim;
			endif;
			retString := retString &amp; attrStr &amp; "=" &amp; valueStr;
		endif;
	endforeach;
	
	on Exception do null;
	
	return retString;
	
epilog

end;</source>
        <Parameter name="_delim" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableDisplayString" id="6c7c9ea1-97f9-452b-886d-224dbea5ea3e">
        <source>getTableDisplayString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 June 2022	navtnr20	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types

*/

vars

begin
	if self.getCriteriaSummary(", ") = null then
		return app.getErrorString(Criter_not_config_double_click);
	endif;

	return self.getCriteriaSummary(", ").formatWithEllipsis(1, 100, true);

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
