    <JadeMethod name="setForRedraw" id="381f626c-82c2-4f12-9aa5-e69fd2c6297e">
        <updating/>
        <source>setForRedraw(_obj : Object;x1,y1,x2,y2 : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTI : CM_TrackedItem;
begin
	self.x1	:= x1;
	self.y1	:= y1;
	self.x2	:= x2;
	self.y2	:= y2;

end;</source>
