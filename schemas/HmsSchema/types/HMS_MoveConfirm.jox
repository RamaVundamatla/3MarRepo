    <JadeMethod name="acceptConfirmation" id="4504cf01-f297-41c5-af70-6177a195ff52">
        <updating/>
        <source>acceptConfirmation() updating;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	confirmDT	: TimeStamp;
	movPrev,
	movNext		: HMS_VoyageMovement;
	invalidDT	: Boolean;
	time 		: Time;
	tmpStatus 	: Integer;
	tmpHarbour	: HMS_Harbour;
	pxyMovement	: HMS_VoyageMovement;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	// This method sets a new planned or actual date on a movement 
	// as a result of the confirmation process. 

	// Get confirmation DT	
	confirmDT.setDate(self.txtDateMove.text.asDateJMT());
	confirmDT.setTime(self.txtTimeMove.text.asTimeJMT());

	// Check that proposed date does not invalidate the current movement order
	movPrev := self.myVoyageMovement.getVoyageMovementPrevious;
	movNext := myVoyageMovement.getVoyageMovementNext;

	invalidDT:=false;
	if movPrev &lt;&gt; null then
		if movPrev.occursOnDTNEW &gt; confirmDT then
			invalidDT := true;
		endif;
	endif;

	if movNext &lt;&gt; null then
		if movNext.occursOnDTNEW &lt; confirmDT then
			invalidDT := true;
		endif;
	endif;

	if invalidDT then
		// Confirm date outside correct range to preserve movement order - NOTIFY user
		app.msgBox(app.getErrorString(HMS_MoveConfirmDT), app.getErrorString(HMS_Invalid_Confirmation_DT), MsgBox_OK_Only + MsgBox_Stop_Icon);
        // Set Confirm DT back to the occursOnDT
        self.txtDateMove.setDate(self.myVoyageMovement.occursOnDTNEW.date);
 		self.txtTimeMove.setTime(self.myVoyageMovement.occursOnDTNEW.Time);
 		return;	

	else
		// Confirm date within correct range to preserve movement order.		
		if isPlannedConfirmType=true then
			// Confirming planned time
			tmpStatus := MovementStatus_ConfirmedPlan;
		else
			// Confirming actual time
			tmpStatus := MovementStatus_Actual;
		endif;
		
		pxyMovement := self.myVoyageMovement.pxyCreateUpdateProxy();		
		pxyMovement.setProxyForMoveConfirmation(confirmDT, tmpStatus, tbDraftAft.text.asDecimalJMT(), tbDraftFwd.text.asDecimalJMT() ); 	// 01 APR 2010	NDL	Par 23556

	endif;

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateHMSMovement(pxyMovement, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Move Confirmation', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

	// Action: Shut all active confirmation windows for this movement	
	tmpHarbour := self.myVoyageMovement.myHarbour;
 	tmpHarbour.causeEvent(CloseConfirmWindow,true,self.myVoyageMovement);

 
epilog
	delete pxyMovement;
end;</source>
    </JadeMethod>
    <JadeMethod name="addUserToMoveReferences" id="415054f3-58b5-4d4a-9280-d35c586d2c4b">
        <updating/>
        <source>addUserToMoveReferences() updating;

vars
 	c:	Control;
begin
 	// This method adds this user to the perm movement's collection of 
 	// allUsersForConfirmation.

 	if myVoyageMovement.allUserCodesForConfirmation.includes(app.getMyUserCode)=false then
 		// Add user to movement
 		beginTransaction;
 		myVoyageMovement.allUserCodesForConfirmation.add(app.getMyUserCode);
 		commitTransaction;
 	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="btnNo_click" id="95d943ed-3383-4f9b-9b92-c2cf3c0ecbc5">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNo_click(btn: Button input) updating;
//-----------------------------------------
// Created: August 2003 By: cnwgd1
//-----------------------------------------
vars

begin
	self.declineConfirmation();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cancelConfirmation" id="d1297f01-4b9e-41fd-ab31-6254c7b5f53f">
        <updating/>
        <source>cancelConfirmation() updating;

vars

begin
  	// If this user is not the last user with the confirmation window open, unload the form  
  	// and remove this user from the movements.allUsersForConfirmation collection
  	if myVoyageMovement.allUserCodesForConfirmation.size&gt;1 then
  		// ie At least one user with message 
  	else
  		// user is last with this message - cannot cancel
  		// If this is the only user with this window open, disable the cancel button
	 	if myVoyageMovement.allUserCodesForConfirmation.size=1 then
	 		// Disable cancel
	 		//btnClose.enabled:=false;

	 		// Display message box
	 		app.msgBox("A response to this confirmation message must be made by at least one user. 
Please select 'YES' to accept the confirmation or 'NO' to decline it.","Confirmation Required", MsgBox_OK_Only + MsgBox_Stop_Icon);

	 	endif;	
  	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="closeForm" id="b40281e2-6f96-4efd-8c99-7c0abb64bdf1">
        <updating/>
        <source>closeForm() updating;

vars

begin
	// Closes form and removes this user from the movement's.allUsersForConfirmation collection
  	if myVoyageMovement.allUserCodesForConfirmation.includes(app.getMyUserCode)=true then
  		beginTransaction;
  		myVoyageMovement.allUserCodesForConfirmation.remove(app.getMyUserCode);
  		commitTransaction;
  	endif;
	unloadForm;		//AJA 8/11/00: Outside the 'if' for safety

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="59ce2062-fbb1-4860-a1e2-a66cda3a1f61">
        <updating/>
        <source>create() updating;
//--------------------------------------------------------------
//Created: 18 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	// PAR 16389 - PmHMSMovementsView has HMS_VoyageMovementForm from Navigator which
	// has not been updated for Voy Comod Planning so is excluded by license.  This screen
	// only shown from Graphical View so use those permissions
	self.permissionMaint := PmHMSGraphicalMaint;
	self.permissionView := PmHMSGraphicalView;
	
	self.helpFileName := HelpFile_Harbour;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="declineConfirmation" id="c4eff8c7-b16e-4e08-8aaa-b60f6524f3d4">
        <updating/>
        <source>declineConfirmation() updating;

vars

begin
 	// User has declined the confirmation of the proposed planned or actual time
 	// Action: Shut all active confirmation windows for this movement
 	self.myTerminal.myHarbour.causeEvent(CloseConfirmWindow,true,myVoyageMovement);
end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="e2f53180-9eed-4d1b-a959-e0ebd55bbb15">
        <updating/>
        <source>doOK() updating;
//-----------------------------------------
// Created: August 2003 By: cnwgd1
//-----------------------------------------
vars

begin
	self.acceptConfirmation();
end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="49050218-c717-4762-81b7-07ad030cd242">
        <updating/>
        <source>initForm(_parentForm : CM_BaseForm)updating;
//--------------------------------------------------------------
//Created: 22 July 2003 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
05 Jun 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation
	
*/

vars

begin
 	// This method loads the movement confirmation form. This form has two functions
 	// These are:	
 	//		(1) Confirm a planned movement X hrs prior to planned moveDT
 	//		(2) Change a planned time to an actual time for a movement

	self.setFormParent(_parentForm);
	
	if isPlannedConfirmType=true then
		self.caption := "Confirm 'Planned' Movement Time.";	
		lblConfirmType.caption:="Planned";
	else
		self.caption := "Confirm 'Actual' Movement Time.";
		lblConfirmType.caption:="Actual";	
	endif;

	self.helpKeyword := "Confirm Movement Time";		// PAR #34210
	
	// Set confirm DT to movement time 
	txtDateMove.setDate(myVoyageMovement.occursOnDTNEW.date);
 	txtTimeMove.setTime(myVoyageMovement.occursOnDTNEW.Time);

	// Set move Type and vessel name labels
	lblMoveType.caption:=myVoyageMovement.moveType;
	lblVesselName.caption:=myVoyageMovement.getMyVessel().name;

    tbDraftFwd.text := myVoyageMovement.draftFwd.String;	//4.1.1 Draft Enhancements
    tbDraftAft.text := myVoyageMovement.draftAft.String;

end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="18186b5f-676c-4d2f-aa79-c765c1807622">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 August 2018 16:35:00.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022926, locale);
	btnNo.translateCaption(Xlat_0001533, locale);
	lblAtArr.translateCaption(Xlat_0001534, locale);
	lblConfirmTitle.translateCaption(Xlat_0001535, locale);
	lblConfirmType.translateCaption(Xlat_0001536, locale);
	lblConfirmYN.translateCaption(Xlat_0001537, locale);
	lblMoveType.translateCaption(Xlat_0001538, locale);
	lblTimeFor.translateCaption(Xlat_0001539, locale);
	lblTimeFor_1.translateCaption(Xlat_0016576, locale);
	lblVesselName.translateCaption(Xlat_0001541, locale);
	lblis.translateCaption(Xlat_0001542, locale);
	lblis_1.translateCaption(Xlat_0001543, locale);
	lblis_1_1.translateCaption(Xlat_0001544, locale);
	lblofThe.translateCaption(Xlat_0001545, locale);
	lblofThe_1.translateCaption(Xlat_0001546, locale);
	lblofThe_1_1.translateCaption(Xlat_0001547, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unloadForm" id="13afb71d-4276-4b6a-80dc-451a90a73c8b">
        <updating/>
        <source>unloadForm(): Boolean updating;

vars

begin
	self.cancelConfirmation();
	return inheritMethod();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
