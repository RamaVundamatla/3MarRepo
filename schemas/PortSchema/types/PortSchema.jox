    <JadeMethod name="setNextCompactTime" id="7af038b9-ce10-4c21-b1fc-8266a9194b55">
        <updating/>
        <source>setNextCompactTime()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2021	navndl1	Initial creation	TFS 50488
*/

vars
	
	ts : TimeStamp;
	tsInterval : TimeStampInterval;

begin

	// - n = default, i.e. do every time
	// 0 = Off, i.e. no compaction
	// + n = minimum delay in minutes between compactions.

	
	if self.compactTransientIntervalMins &lt; 1 then
		// doing every time, or not doing at all, date not needed.
		
		self.compactAfterTS := null;
		
	else
		//we have a minimum number of minutes between each compactionn, set a the next time stamnp
		
		ts := self.actualTimeAppServer;
		tsInterval.set( 0, self.compactTransientIntervalMins * 60000 );
		
		self.compactAfterTS := ( ts + tsInterval );
	
	endif;

epilog

end;</source>
    </JadeMethod>
