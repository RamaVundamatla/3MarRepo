	str 	: String;

begin
	// get codes from list box, display in text box and disappear the list box
	str := self.lstAllStops.getSelectedString(CM_StopsTable::code.name);
	if str.length &gt; 30 then
		self.txtAllStops.text := str[1:29]&amp; '...';
