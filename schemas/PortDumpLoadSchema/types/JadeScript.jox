    <JadeMethod name="getNextValidContainerId" id="0c74caa2-047d-4342-8481-0671960c2e9e">
        <source>getNextValidContainerId(_prefix : String; _number : Integer io) : String protected;

vars
	tiId : String;
begin
	tiId := _prefix[1:4]&amp;_number.stringWithLeadingZeros(7);
	while not app.checkDigitContainerId(tiId) do
//		write "try "&amp;tiId;
		_number := _number + 1;
		if _number &gt; 9999999 then
			tiId := null;
			return tiId;
		endif;
		tiId := _prefix[1:4]&amp;_number.stringWithLeadingZeros(7);
	endwhile;
//	write "return "&amp;tiId;
	_number := _number + 1;
	return tiId;
end;
</source>
        <access>protected</access>
        <Parameter name="_prefix" type="String"/>
        <Parameter name="_number" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleException" id="2bdb6514-ce36-4b65-8d51-ebe9259b7be8">
        <source>handleException(_exception: Exception):Integer;

vars

begin
//	write('('&amp;_exception.errorCode.String&amp;'). '&amp;_exception.extendedErrorText);
	app.doDumpStack(_exception);
	return Ex_Pass_Back;
end;</source>
        <Parameter name="_exception" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="importData" id="31d72cb2-fddc-4aaa-9e5f-6c0eb48275e6">
        <updating/>
        <source>importData() updating;
// ---------------------------------------------------------------------------
// Created:     18 March 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars
	dirName: String;
	theUser: CM_User;
	result : Boolean;
	deleteAll	: Boolean;
begin
	on Exception do null global;
	dirName := DIR_NAME;
	app.initialize;
	app.myPassport.setMyTerminal(CM_Terminal.firstInstance);
	if theUser = null then
		theUser := CM_Root.firstInstance.allUsers[SUPERUSER_Str];
	endif;
	app.myPassport.setMyUser(theUser);
	app.myPassport.warningsAcknowledged	:= true;
	app.isConverting := true; // ignore warnings
	if dirName = null then
		dirName := 'C:\temp\';
	elseif dirName[dirName.length] &lt;&gt; '\' then
		dirName := dirName &amp; '\';
	endif;
	
	deleteAll	:= false;	// true means choose to delete all existing objects first
// root based
	self.importObjects(CMIF_ConfigRoot, dirName, 0, deleteAll);
	self.importObjects(CM_CommodityGroup, dirName, 0, deleteAll);
	self.importObjects(CM_ConsigneeConsignorGroup, dirName, 0, deleteAll);
	self.importObjects(CM_ISOTypeGroup, dirName, 0, deleteAll);
	self.importObjects(CM_OperatorGroup, dirName, 0, deleteAll);
	self.importObjects(CM_PortGroup, dirName, 0, deleteAll);
	self.importObjects(CM_Carrier, dirName, 0, deleteAll);
	self.importObjects(CM_CargoType, dirName, 1, deleteAll);
	self.importObjects(CM_Country, dirName, 0, deleteAll);
	self.importObjects(CM_ContRange, dirName, 0, deleteAll);
	self.importObjects(CM_DrawingAttribute, dirName, 0, deleteAll);
	self.importObjects(CM_EmailAddress2, dirName, 0, deleteAll);
	self.importObjects(CM_HazardClass, dirName, 0, deleteAll);
	self.importObjects(CM_JobType, dirName, 0, deleteAll);
	self.importObjects(CM_CodeGroupLogSpecs, dirName, 0, deleteAll);
	self.importObjects(CM_LogConditionCode, dirName, 0, deleteAll);
	self.importObjects(CM_LogRegradeCode, dirName, 0, deleteAll);
	self.importObjects(CM_LogRejectCode, dirName, 0, deleteAll);
	self.importObjects(CM_LogSpecies, dirName, 0, deleteAll);
	self.importObjects(CM_LoggingOrganisation, dirName, 0, deleteAll);
	self.importObjects(CM_MachineType, dirName, 0, deleteAll);
	self.importObjects(CM_MachineAvailability, dirName, 0, deleteAll);
	self.importObjects(CM_Machine, dirName, 0, deleteAll);
	self.importObjects(CM_RTDeviceHandHeld, dirName, 0, deleteAll);
	self.importObjects(CM_RTDeviceScanner, dirName, 0, deleteAll);
	self.importObjects(CM_RTDeviceVehicleMount, dirName, 0, deleteAll);
	self.importObjects(CM_MTGrade, dirName, 0, deleteAll);
	self.importObjects(CM_Operator, dirName, 0, deleteAll);
	self.importObjects(CMIF_ConfigOperator, dirName, 0, deleteAll);
	self.importObjects(CM_PredefinedRemark, dirName, 0, deleteAll);
	self.importObjects(CM_PrinterDef, dirName, 0, deleteAll);
	self.importObjects(CM_ShippingAgent, dirName, 0, deleteAll);
	self.importObjects(CM_Product, dirName, 0, deleteAll);
	self.importObjects(CM_ShippingLine, dirName, 0, deleteAll);
	self.importObjects(CM_Stevedore, dirName, 0, deleteAll);
	self.importObjects(CM_StopsTable, dirName, 0, deleteAll);
	self.importObjects(CM_TemperatureConversion, dirName, 0, deleteAll);
	self.importObjects(CM_TempRange, dirName, 0, deleteAll);
	self.importObjects(CM_ToDoTaskDesc, dirName, 0, deleteAll);
	self.importObjects(CM_ToDoTemplate, dirName, 0, deleteAll);
	self.importObjects(CM_Trade, dirName, 0, deleteAll);
	self.importObjects(CM_WagonClass, dirName, 0, deleteAll);
	self.importObjects(CM_WeightRange, dirName, 0, deleteAll);
	self.importObjects(CM_ConsigneeConsignor, dirName, 0, deleteAll);
	self.importObjects(CM_Commodity, dirName, 0, deleteAll);
	self.importObjects(CM_ISOType, dirName, 0, deleteAll);
	self.importObjects(CM_Port, dirName, 0, deleteAll);
	self.importObjects(CM_ShipPortGroup, dirName, 0, deleteAll);

// harbour dependant
	self.importObjects(HMS_Harbour, dirName, 0, deleteAll);
	self.importObjects(CM_EmailGroup, dirName, 0, deleteAll);
	self.importObjects(HMS_HarbourRegion, dirName, 0, deleteAll);
	self.importObjects(HMS_Wharf, dirName, 0, deleteAll);
	self.importObjects(HMS_Pilot, dirName, 0, deleteAll);
	self.importObjects(HMS_PilotLaunch, dirName, 0, deleteAll);
	self.importObjects(HMS_Berth, dirName, 0, deleteAll);
	self.importObjects(HMS_Tug, dirName, 0, deleteAll);
