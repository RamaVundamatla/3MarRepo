    <JadeMethod name="cmbSeqAppliesTo_click" id="0d636ced-e5b9-4f52-8ce2-f1e5ecd81b64">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSeqAppliesTo_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     25 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx			: Integer;
	isEnabled	: Boolean;
begin
	idx := combobox.listIndex;
	if idx &gt; 0 then
		self.seqAppliesToMode := combobox.itemData[idx];
	else
		// set to the default
		self.seqAppliesToMode := self.SeqAppliesTo_Job;
	endif;
	
	isEnabled := (self.seqAppliesToMode &lt;&gt; self.SeqAppliesTo_IndividualSlots);

	self.btnSeqDisP2ST2B.enabled := isEnabled;
	self.btnSeqDisS2PT2B.enabled := isEnabled;
	self.btnSeqDisT2BP2S.enabled := isEnabled;
	self.btnSeqDisT2BS2P.enabled := isEnabled;

	self.btnSeqLoadP2SB2T.enabled := isEnabled;
	self.btnSeqLoadS2PB2T.enabled := isEnabled;
	self.btnSeqLoadB2TP2S.enabled := isEnabled;
	self.btnSeqLoadB2TS2P.enabled := isEnabled;
	
	if self.seqAppliesToMode = self.SeqAppliesTo_Job  or self.seqAppliesToMode = self.SeqAppliesTo_SelectedSlots then
		self.cmbSeqBoth.visible := true;
	else
		self.cmbSeqBoth.visible := false;
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
