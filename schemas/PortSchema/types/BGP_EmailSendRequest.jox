    <JadeMethod name="action" id="74878b18-c661-45dd-8611-75fe4bf40500">
        <updating/>
        <source>action(): Boolean updating;

// cnwdvb1 10 February 2003 
// Basically we have to do a bit of tricky stuff because email can be a bit of 
// a pain at times.
// RULES
// We try to send emails 3 times with a bit of wait in between.
// Receive requests have a special exception handler which creates alerts
// if it fails too many times(based on configuration of email autotask.
// 17 Jun 2013	cnwrs1	ccms 1336 Par 31389 separate BGP EmailRequest to seperate read and send
// 03 Jan 2013	cnwrs1	32983 crash after user deleted.
// 27 Jul 2020	jlgdap1	TFS 49764 MTN Retire Basic Authentication to Exchange Online
// 03 Oct 2022	navmd1	TFS 55020 Auto retry emails that have .net errors (as well as ActiveX)
// 19 Jan 2024	navmd1	TFS 55021 Move Email Architect agent creation up so exception handler has access to better errors
constants
	Email_Retry = 10;
	ActiveX_Invoke_Ex = 14181;
	DotNet_Invoke_Ex = 14576;
vars
	errCode				: Integer;
	errTxt,
	logPath				: String;
	receiveMailIDS		: IDS_Server;
	emailSoftware,
	emailLicense		: Integer; // ### TFS 51526 23Feb2022 NAVPW1
	isIDS				: Boolean;
	msg 				: String;
	controller			: BGP_Controller;
	emailArchitect		: CMIF_EmailArchitect;
	
begin
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDescExt(emailArchitect), errCode, errTxt, true, false);
	on LockException do app.alertLockExceptionHandler(exception);

	create emailArchitect transient;
	
	self.setUser();
	emailSoftware 	:= app.myRoot.getConfig(AutoEmailSoftware).Integer;
	emailLicense	:= app.myRoot.getConfig(EmailLicenseType).Integer;	// ### TFS 51526 10Feb2022 NAVPW1
	
//	if self.isToSend then
		
		// BGP Email Test Mode. PAR 25611	11/11/2010
		if app.myRoot.getConfig(BgpEmailTestMode).Boolean then
			if self.toAddress.isBlank then	// if addresss is blank and BGP Test Mode, an email should be processed and recorded in Activity History.
				msg := BgpEmailTestModeStr &amp;': ' &amp; BgpTestEmailAddresNotSpecified &amp; ' ' &amp; self.getOrigAddressWhenBGPTestMode();
				app.writeLog(msg, LogINFO);	///25 Nov 2019	NDL	TFS 47053
				
				return true;
			else
				if self.sendSubject[1:19] &lt;&gt; "BGP Email Test Mode" then	//cnwrs1	15 Apr 2013	check the test mode when the mail is sent as well as when we setup the email
					beginTransaction;
					self.setEmailRequestForBGPTestMode();
					commitTransaction;
				endif;
				msg := BgpEmailTestModeStr &amp; ': Sending email to ' &amp; self.toAddress &amp; " " &amp; self.getOrigAddressWhenBGPTestMode();
				app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				
			endif;
		endif;
		
		app.sendHeartbeatIfRequired();		// 4/9/17 MAP TFS5551
		
		//if emailSoftware = self.EMAIL_EMAILARCHITECT then
		if emailSoftware = self.EMAIL_EMAILARCHITECT and emailLicense &lt;&gt; EmailLicenseType_3 then					// ### TFS 51526 10Feb2022 NAVPW1
			// We are using the IDSMail control.
			self.sendAOS();
		elseif emailSoftware = BGP_EmailSendRequest.EMAIL_EMAILARCHITECT and emailLicense = EmailLicenseType_3 then // ### TFS 51526 10Feb2022 NAVPW1
			self.sendEATls(emailArchitect);
		elseif emailSoftware = self.EMAIL_IDSMAIL then
			isIDS := true;
			logPath := self.sendIDS();
		elseif emailSoftware = self.EMAIL_EMAILARCHITECTOAUTH then		// TFS 49764
			self.sendOAuth(emailArchitect);								// TFS 49764
		else
			self.sendCardSchema();
		endif;

epilog
	if errCode &lt;&gt; null then
		// This hasn't been any help with diagnostics and crasheds Owens.
		if isIDS and logPath &lt;&gt; null then
			self.copyIDSLog(logPath);
		endif;
		// We have had an error. Pass info through trx to update self.
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, 'Email Error/' &amp; errTxt, app.myPassport);
//		if isToSend then
			// We only resend if we get an ocx error.
			if self.numberOfRetries &lt; Email_Retry + 1 and errCode.isOneOf(ActiveX_Invoke_Ex, DotNet_Invoke_Ex) then
				msg := 'Attempting to send message again';
				app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				
				// May as well have a little break while we are here.
				process.sleep(1000);
				app.myTrxUA.trxUpdateBGPRequest(self, false, 0, null, app.myPassport);
				self.causeEvent(BGP_Object.BGP_ActionRequest, true, null);
			else
				// Because we leave the request sitting there, we need to unlink it from the controller
				controller := self.myProcessingController;
				app.myTrxUA.trxUpdateBGPControllerProcess(controller, process, controller.dateTimeLastStarted, true, app.myPassport);
			endif;
//		endif;
	else
//		if self.isToSend then
			app.createActivityHistory(ActivityHistoryEmail, null, self, null, false, false);
//		endif;
	endif;
	
	delete emailArchitect;
	
	inheritMethod();
	// We tank send emails that have had problems.
	// That is we don't delete them.
	return (errCode = null) or false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addTextToSendMessage" id="ccc4a8ab-cbdf-4da3-9c1f-def72aa4a4e9">
        <updating/>
        <source>addTextToSendMessage(_addText : String) updating;
//--------------------------------------------------
// Created:	20 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.sendMessage := self.sendMessage &amp; CrLf &amp; _addText;
end;</source>
        <Parameter name="_addText" type="String"/>
    </JadeMethod>
    <JadeMethod name="autoReply" id="e5c338a3-515a-4fe3-a5ac-8599ab93bc17">
        <source>autoReply(_to, _sender: String; _subject: String; _message: String) protected;
//----------------------------------------------------------------
//	Created:	01 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
constants
	ReplyPrefix_RE = "RE: ";

vars
	replySender,
	address		: String;
	str			: String;
	retInt,
	pos			: Integer;
	email		: CM_EmailAddress2;
	iter		: Iterator;
	reply		: Boolean;
	msg : String;
begin
	
	str := '&lt;';
	pos := (_sender.pos(str, 1) + str.length);
	if pos &lt; _sender.length then	//cnwrs1 par 27672 3 June 2011
		address := _sender.scanUntil('&gt;', pos);
	endif;
	replySender := _to;
	
	if address = null then
		msg := "Cannot determine address from message.";
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		return;
	endif;

	iter := app.myRoot.allEmailAddressesByAddress.createIterator();
	app.myRoot.allEmailAddressesByAddress.startKeyGeq(address, iter);
	
	reply := false;
	while iter.next(email) do
		if email.emailAddress &lt;&gt; address then
			break;
		endif;
		//we are hitting email addresses with the same address here
		//if one or more wants an auto-reply then reply once
		if email.autoReplyOption &lt;&gt; EmailReplyType_None then
			reply := true;
			break;
		endif;
	endwhile; 
	
	if not reply then
		return;
	endif; 

	if email.autoReplyOption = EmailReplyType_HeaderOnly then
		msg := "Sending auto reply.";
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		retInt := app.myTrxCA.trxCreateEmailSendRequest('EDI',email.emailAddress, replySender, null, null, ReplyPrefix_RE &amp; _subject,
						 						null, null, null, null, null,EmailSource_EDI, null, app.myPassport);

//	elseif email.autoReplyOption = EmailReplyType_EntireMessage then 
	else
			// Don't raise exception will stop receival.
//		app.raiseUnexpectedProgramError(class.name, method.name, 'unexpected auto reply type');
	endif;

epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_to" type="String"/>
        <Parameter name="_sender" type="String"/>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
    <JadeMethod name="copyIDSLog" id="987f1f47-9bac-4518-9e53-6ac757cd115c">
        <source>copyIDSLog(_filePath : String) protected;
// -------------------------------------------
// Created 09 July 2004 by cnwdvb1
// -------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars

	fileName,
	theLine		: String;
	sourceFile	: File;
	msg : String;
begin

	fileName := _filePath &amp; '\POPDUMP.TXT';
	create sourceFile transient;
	sourceFile.mode		:=	File.Mode_Input;
	sourceFile.shareMode:=	File.Share_Read;
	sourceFile.kind		:=	File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	sourceFile.fileName	:= fileName;
	if not sourceFile.tryOpen then
		msg := 'Unable to open file ' &amp; fileName;
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		return;
	endif;
	msg := 'EMAIL ERROR IDS DIAGNOSTIC LOGGING';
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	while not sourceFile.endOfFile() do
		msg := sourceFile.readLine();
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
	endwhile;	
	return;

epilog
	if  sourceFile &lt;&gt; null then
		sourceFile.close();
	endif;
	delete sourceFile;
end;</source>
        <access>protected</access>
        <Parameter name="_filePath" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteFile" id="8e0331d9-5176-418c-add5-6ec06ffbb719">
        <source>deleteFile(_fileName : String) protected;
//
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
//
vars

	file		: File;
	msg : String;
begin
	create file transient;
	file.mode			:=	File.Mode_Input;
	file.shareMode		:=	File.Share_Exclusive;
	file.fileName		:= 	_fileName;
	if file.tryOpen then
		msg := 'Deleting email attachment - ' &amp; file.fileName;
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053

		file.purge();
	endif;
epilog
	delete file;
end;</source>
        <access>protected</access>
        <Parameter name="_fileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="getContentType" id="0fa7afd5-8775-439e-838b-98b95000e82d">
        <source>getContentType(_fileName : String) : String protected;
// -------------------------------------------
// Created 18 November 2003 by cnwdvb1
// -------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	msg : String;
begin
	if _fileName.pos(self.CSV, 1) &lt;&gt; 0 then
		msg := 'File is csv file - ' &amp; _fileName;
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		return CnSmtpConnection.Text_Plain;
	endif;
	msg := _fileName;
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	return null;
end;</source>
        <access>protected</access>
        <Parameter name="_fileName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDetailForDisplay" id="481ed82c-8d0a-4907-bb64-2a39af12ae22">
        <source>getDetailForDisplay(_array: HugeStringArray input): Boolean;
/* ---------------------------------------------------------------------------
Created:     16 September 2008 by cnwrs2

Purpose:     PAR 17925
        
Date		Who		Reason
14 Sep 2012	cnwkpd1	PAR #29274 - Replace Object::getInstanceIdForObjectXX with RootSchema methods
	
*/

vars
	header					: CM_FileDataStorageHeader;

begin
	_array.addTruncated(app.getErrorString(User) &amp; Tab &amp; self.getUserCode);	
	_array.addTruncated(app.getErrorString(Description) &amp; Tab &amp; self.getSourceDescription(self.sourceOfEmail, self.getInstanceIdForObject64(self).Integer));
	_array.addTruncated(app.getErrorString(Destination) &amp; Tab &amp; self.toAddress);
	_array.addTruncated(app.getErrorString(Sender) &amp; Tab &amp; self.fromAddress);
	_array.addTruncated(app.getErrorString(CC) &amp; Tab &amp; self.ccAddresses);
	_array.addTruncated(app.getErrorString(BCC) &amp; Tab &amp; self.bccAddresses);
	_array.addTruncated(app.getErrorString(Subject) &amp; Tab &amp; self.sendSubject);
	_array.addTruncated(app.getErrorString(Message) &amp; Tab &amp; self.sendMessage);

	foreach header in self.allAttachedFiles do
		_array.addTruncated(app.getErrorString(Attachment) &amp; Tab &amp; header.fileName);
	endforeach;	

	return true;

epilog

end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="e6f4c517-ec19-4ca8-9c78-b2c0c3cb3311">
        <source>getDisplay(): String;

// cnwdvb1 17 February 2003 
// 17 Jun 2013		cnwrs1	ccms 1336 Par 31389 separate BGP EmailRequest to seperate read and send

vars

	str, detail : String;

begin

	str := inheritMethod();
//	if self.isToSend then
		detail := 'Sending email to ' &amp; toAddress;
//	else
//		detail := 'Automated email retrieval';
//	endif;
	
	return str &amp; Tab &amp; detail;
	

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getErrorDescExt" id="e75bbf1b-1709-4311-bf60-ecb21dad696d">
        <source>getErrorDescExt(_emailArchitect : CMIF_EmailArchitect input) : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
19 January 2024			navmd1	Initial creation TFS 55021

*/

vars

begin
	if _emailArchitect &lt;&gt; null and _emailArchitect.lastError &lt;&gt; null then
		return self.getErrorDesc() &amp; CrLf &amp; _emailArchitect.lastError;
	endif;

	return self.getErrorDesc();
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_emailArchitect" type="CMIF_EmailArchitect" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getErrorMessage" id="587ec161-abf9-4787-9df4-4527ac8d837f">
        <source>getErrorMessage(_str : String; _receiveMailIDS	: IDS_Server input) : String protected;
//
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
//
vars

	err, mailSystem,
	errDecode,
	errDecodeAPI		: Integer;
	errMessage,
	detail				: String;
	pos					: Integer;
	msg : String;
begin

	// Put know errors in plain english here.
	if _str.pos("-2147214948", 1) &lt;&gt; 0 then
		detail := 'Unable to send email. Error likely due to invalid email address ' &amp; self.alertDescription;
	else
		err := _str[1:15].Integer;
		msg := 'Error message ' &amp; err.String;
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		// It is a communications error with pop server.
		_receiveMailIDS.decodeError( err, mailSystem, errDecode, errDecodeAPI, errMessage);
		if errMessage.length &gt; 0 then
			detail := 'OCX Error Message ' &amp; err.String &amp; ' (' &amp;  errMessage &amp; ') ' &amp; self.alertDescription;
			app.writeLog(detail, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
		else
			detail := self.alertDescription;
		endif;
	endif;
	return detail;

end;</source>
        <access>protected</access>
        <Parameter name="_str" type="String"/>
        <Parameter name="_receiveMailIDS" type="IDS_Server" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOrigAddressWhenBGPTestMode" id="0ce5feed-67a3-441e-97ce-c08fdc9faea6">
        <source>getOrigAddressWhenBGPTestMode(): String protected;
/* ---------------------------------------------------------------------------
Created:	11 November 2010	by cnwvu1

Purpose:	PAR 25611
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	i	: Integer;

begin

	if self.sendMessage.isBlank() then
		return null;
	endif;

	i := 1;
	return self.sendMessage.scanUntil(CrLf, i);
	

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
