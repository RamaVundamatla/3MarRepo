    <JadeMethod name="outputFile" id="cdc2db13-b9ae-46a3-b1dd-1856fe65d71c">
        <updating/>
        <source>outputFile(_protocol: CM_CamProtocol input; _camAgent: CM_CamControllerAgent; _camFile: CM_CamFile input; _runDateTime: TimeStamp; _camTaskHistory: CM_CamTaskHistory input; _unhSeqNumber: Integer io; _seqNumber: Integer; _terminal: CM_Terminal; _contextObj : CM_Object; _transactions : CM_TITransactionSet) updating;
//
//11 Nov 2014	cnwrs1	CCMS 2405 - Alabama Steel Cams
//13 Jan 2015	cnwrs1	Par 35505 dont createv &lt;warehouse activity&gt; for non warehouse
//23 jan 2015	cnwrs1	Par 35535 - AST XML remove extra CrLf
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//09 Jan 2020	jlgdap1	TFS 48016 SNO Deletion CODECO - new _transactions parameter
vars
	camVoyage : CM_CamVoyage;
	camMessage : CM_CamMessage;
	str : String;
	strLine : String;
	theLines : HugeStringArray;
begin
	create theLines transient;
	if _camFile.camVoyages.size &gt; 0 then
		_camFile.incrementMessageCount();
		strLine := strLine &amp; '&lt;?xml version="1.0"?&gt;'&amp;CrLf;
		foreach camVoyage in _camFile.camVoyages do
			foreach camMessage in camVoyage.camMessages do
				foreach str in camMessage.group3 do
					strLine := strLine &amp; str; 
				endforeach;
			endforeach;
		endforeach;
	endif;
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;strLine.length.String&amp;' '&amp;strLine;
	strLine := strLine.replaceString(CrLf, Cr);
	strLine := strLine.replaceString(Lf, Cr);
	strLine.getHugeTokensForDelimiter(Cr, theLines);
	foreach str in theLines do
		self.outputFileMessage(_camTaskHistory, str, null);
	endforeach;
	_camTaskHistory.setRawDataString(strLine);
epilog
	delete theLines;
end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_contextObj" type="CM_Object"/>
        <Parameter name="_transactions" type="CM_TITransactionSet"/>
    </JadeMethod>
    <JadeMethod name="processEvent" id="4d8d4279-2d47-4eb4-b00d-29f98d9caee7">
        <updating/>
        <source>processEvent(_transaction: CM_EventTransaction; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input; _camFile: CM_CamFile input) updating;
//
//11 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//22 Jan 2015	cnwrs1	Par 35539/35540 - AST EDI Formatting 
//01 Apr 2014	cnwrs1	Par 35963 coil not being produced as it is mising transdate and camsDateTime
//
vars
	theTI : CM_TrackedItem;
	voyage: CM_Voyage;
	bolIn : CM_BOLIn;
	firstTI : CM_TrackedItem;
	loopTI : CM_TrackedItem;
	camMessage : CM_CamMessage;
	strMsg : String;
	xmlDoc : JadeXMLDocument;
	rootElem : JadeXMLElement;
	attrib : JadeXMLAttribute;
	element : JadeXMLElement;
	bolElement : JadeXMLElement;
	coilElement : JadeXMLElement;
//	ordersElement : JadeXMLElement;
//	itemsElement : JadeXMLElement;
//	batchesElement : JadeXMLElement;
	posStart, posEnd : Integer;
	strID : String;
	orderNum : Integer;
	count : Integer;
	cargoList : DynaDictionary;
	cargoType : Integer;
	subType : String;
	iter : Iterator;
	seq : Integer;
	measureType : CM_MeasurementType;
	dimStr : String;
    voyOp : CM_Operator;
//	transportID : String;
begin
	_camAgent.writeDebugLog(class.name&amp;'::'&amp;method.name&amp;" process "&amp;_transaction.type.asStringJMT);

//	theTI := _transaction.myTrackedItem;
	if _transaction.type &lt;&gt; EVT_VoyageDeparture then
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, 'Event transaction is not a Voyage Depature');
		endif;
		return;
	endif;
	voyage := _transaction.getVoyage();		// in xmast it is _transaction.CMEVT_VoyageDeparture.myVoyage;
	if voyage = null then
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, 'Event transaction has no voyage');
		endif;
		return;
	endif;
	if voyage.status &lt;&gt; Voyage_Status_Departed then
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, 'Event transaction voyage has not departed');
		endif;
		return;
	endif;
	if voyage.allBOLInByTypeStatusNumDT.size = 0 then
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, 'Event transaction voyage has not bol ins');
		endif;
		return;
	endif;
	camMessage := self.getCamMessage(_camFile, null, null, CODECO_EDIT, _camProtocol.singleContainerPerBGM);
//	seq := theTI.deliveryRelease.asIntegerJMT();
    
	create xmlDoc transient;
	xmlDoc.outputDeclaration := true;
	//encoding
	rootElem := xmlDoc.addElement("vessel");
    element := rootElem.addElement("transmission_number");
	element.addText(self.transmissionNumber.String);
	element := rootElem.addElement("vessel_name");
	element.addText(voyage.vesselName);
	element := rootElem.addElement("vessel_voyage");
	element.addText(voyage.code);
	foreach bolIn in voyage.allBOLInByTypeStatusNumDT do
		bolElement := rootElem.addElement("bill_of_lading");
		element := bolElement.addElement("bill_of_lading_scac");
        voyOp := voyage.myOperator;
        if voyOp &lt;&gt; null then 
            element.addText(voyOp.code ); //cnwgb1 PAR 35584 28.1.2015
        endif;
		element := bolElement.addElement("bill_of_lading_nbr");
		element.addText(bolIn.number);
		foreach theTI in bolIn.allTrackedItems do
			coilElement := bolElement.addElement("coil");
			element := coilElement.addElement("coil_number");
			element.addText(theTI.id);
			element := coilElement.addElement("coil_thickness");
			measureType := app.getDefaultMeasurementForType(Type_Height);
			if measureType = null then
				dimStr := theTI.height.asStringWeightJMT;
			else
				dimStr := app.convertMeasurementForDisplay(measureType.shortName, theTI.height);
			endif;
			element.addText(dimStr);
			element := coilElement.addElement("coil_width");
			measureType := app.getDefaultMeasurementForType(Type_Width);
			if measureType = null then
				dimStr := theTI.width.asStringWeightJMT;
			else
				dimStr := app.convertMeasurementForDisplay(measureType.shortName, theTI.width);
			endif;
			element.addText(dimStr);
			element := coilElement.addElement("coil_gross_weight_kg");
			element.addText(theTI.totalWeight.asStringWeightJMT);
			element := coilElement.addElement("coil_net_weight_kg");
			element.addText(theTI.weight.asStringWeightJMT);
		endforeach;
	endforeach;
	strMsg := xmlDoc.writeToString();
	strMsg := strMsg.replaceString('&lt;?xml version="1.0"?&gt;'&amp;CrLf, '');
	strMsg := strMsg.replaceString('&lt;warehouse_activity&gt;'&amp;CrLf, '');
	strMsg := strMsg.replaceString('&lt;/warehouse_activity&gt;', '');
	self.addMessage(camMessage.group3, strMsg );
   
epilog
	delete iter;
    delete xmlDoc;
    delete cargoList;
end;</source>
        <Parameter name="_transaction" type="CM_EventTransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
