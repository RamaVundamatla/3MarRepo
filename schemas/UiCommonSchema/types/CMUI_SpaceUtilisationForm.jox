    <JadeMethod name="btnLocateTI_click" id="0d42e12b-aab5-40cf-9554-054dff9d3e6a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnLocateTI_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		03 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTable : CM_DataTable;
begin

	if fldMain.topSheet = self.shtHaz then
		theTable := self.tblHaz;
	elseif fldMain.topSheet = self.shtYA then
		theTable := self.tblYA;
	else
		return;
	endif;
	
	self.doBtnLocateClick(theTable);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
