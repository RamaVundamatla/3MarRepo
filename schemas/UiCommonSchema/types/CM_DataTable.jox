    <JadeMethod name="doFindNext" id="81a7abc0-c3b6-4179-b8aa-e57ec2146b88">
        <updating/>
        <source>doFindNext(_searchText : String; _searchColumn : String; _startRow, _startCol : Integer io) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2012	cnwer1	Initial creation PAR 30803

*/

vars
	foundAt,
	intRow,
	intCol,
	startRow,
	startCol,
 	totalCols: Integer;
	findText 	: String;
	theCell 	: JadeTableCell;
begin
	
	startRow:=	_startRow.max(2);
	if startRow  &gt; self.rows then
		return false;
	endif;
	
	findText:=_searchText;
	if _searchColumn &lt;&gt; null then
		startCol:=self.getColumnByHeading(_searchColumn);
		if startCol = null then
			return false;
		endif;
		totalCols:=startCol;
	else	
		startCol:= _startCol.max(1);
		totalCols:=self.columns;
	endif;
	
	foreach intRow in startRow to self.rows do
		foreach intCol in startCol to totalCols do		
			theCell:=self.accessCell(intRow,intCol);
			foundAt	:=	theCell.text.toUpper.pos(findText.toUpper, 1);
			
			if foundAt &gt; 0 then
				self.accessedCell.selected	:=	true;			
				if _searchColumn &lt;&gt; null then
					_startRow:=	intRow+1;
				else
					_startRow	:=	intRow;
				endif;
				_startCol 	:=  intCol + 1;
			
				//make sure cell shows
				if theCell.positionLeft &lt; 0 then
					self.leftColumn:=intCol;
				endif;
				if theCell.positionTop &lt; 0 then
					self.topRow:=intRow;
				endif;
				return true;
			endif;
			
			foundAt	:=	0;
		endforeach;
		if _searchColumn = null then
			startCol:=1;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_searchText" type="String"/>
        <Parameter name="_searchColumn" type="String"/>
        <Parameter name="_startRow" type="Integer" usage="io"/>
        <Parameter name="_startCol" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doHandleMeasurementColumns" id="81e87493-1ec7-4a36-9b61-f99ad7cea7b1">
        <updating/>
        <source>doHandleMeasurementColumns() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	row : EntTableRow;
	proxyRow : EntTableRowProxy;
	measure : CM_MeasurementType;
	idx : Integer;
	controlPrefix, rowName, rowHeading : String;
	allRows, removeRows : EntTableRowArray;
	inserted : Boolean;
	alteredHeaderName : String;

begin
	create removeRows transient;
	create allRows transient;
	self.allTblDataEntRows.copy(allRows);
	foreach row in self.allTblDataEntRows where row.measurementType &lt;&gt; null do
		idx := allRows.indexOf(row);
		inserted := false;
		foreach measure in app.myRoot.allMeasurementTypesByShortName discreteLock where measure.measurementType = row.measurementType do
			if not measure.isDisplay or not measure.isAvailableForEntry then
				continue;
			endif;
			app.getRowHeadingFromMeasure(row, measure, controlPrefix, rowName, rowHeading);
			// 35440 use the cargo type attribute heading
			alteredHeaderName := self.getCargoTypeAttrHeading(row.name);
			if alteredHeaderName &lt;&gt; null then
				rowName := alteredHeaderName &amp; " " &amp; measure.shortName;
			endif;
			create proxyRow transient;
			if measure.isDefault then															//cnwmc5 - 4 September 2014 - PAR 34533
				proxyRow.setBasicDetails(rowHeading, rowName, row.inputType, true);				//cnwmc5 - 4 September 2014 - PAR 34533
			else																				//cnwmc5 - 4 September 2014 - PAR 34533
				proxyRow.setBasicDetails(rowHeading, rowName, self.InputType_None, true);		//cnwmc5 - 4 September 2014 - PAR 34533
			endif;																				//cnwmc5 - 4 September 2014 - PAR 34533
			allRows.insert(idx, proxyRow);
			inserted := true;
		endforeach;
		// and remove this row
		if inserted then
			removeRows.add(row);
		endif;
	endforeach;
	
	foreach row in removeRows do
		allRows.remove(row);
	endforeach;
	
	//self.deleteEntTableRowProxy();
	self.allTblDataEntRows.clear;
	allRows.copy(self.allTblDataEntRows);
epilog
	delete removeRows;
	delete allRows;
end;</source>
    </JadeMethod>
