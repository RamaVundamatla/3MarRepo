    <JadeMethod name="drawSelf" id="2088c50b-e624-4933-87a6-53992f28842d">
        <updating/>
        <source>drawSelf() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theLabel : String;
begin
	if (not self.drawMe) then
		self.myGridAreaFrame.clearGraphics();
		self.totalPointHeight := 0;
		self.totalPointWidth := 0;
		return;
	endif;
	if self.displayMode = ShpDisplayMode_Defn then
		self.allAttributesUsed.purge;
	endif;
	
	if self.myGridAreaForm &lt;&gt; null then 
		if self.isKindOf(SHP_BayAreaAboveDeck) then
			theLabel := "OD";
		else
			theLabel := "UD";
		endif;
		self.myGridAreaForm.modalDialogUpdateInfo("Drawing Bay " &amp; self.bayID &amp; " " &amp; theLabel);	
	endif;
	inheritMethod();

end;</source>
    </JadeMethod>
    <JadeMethod name="drawSpecialAfterBayId" id="b106301b-691f-47ad-964b-3511e354737c">
        <source>drawSpecialAfterBayId(_theX, _theY : Integer; _drawId40 : Boolean);
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aCell : CM_CellDefn;
	aTier : CM_TierDefn;
	offSet, rowOffset : Real;
	numSlotsOD, numSlotsUD,theMiddleX,theSpace : Integer;
	theString : String;
	aColumn : CMUI_GridColumn; 
	theRowHeight,
	theColWidth,theScaleFactor : Real;
	firstPoint, lastPoint : CMUI_GridPoint;
	xOffset1, xOffset2,yOffset1,yOffset2, theX : Integer;
	amPrinting : Boolean;
	theFrame : CMUI_GridAreaFrame;
begin

	amPrinting := self.amPrinting();
	
	if amPrinting and self.isKindOf(SHP_BayAreaAboveDeck) then
		return;
	endif;
	
	theScaleFactor := self.scaleYFactor;
	theFrame := self.myGridAreaFrame;
		
	theString := self.label; 
	xOffset1 := 10;
	xOffset2 := 28;

	if self.amPrinting and theScaleFactor = self.PrintScaleSmall then
		yOffset1 := 2;
		yOffset2 := 22;
	elseif self.amPrinting and theScaleFactor = self.PrintScaleMedium then
		yOffset1 := 0;
		yOffset2 := 20;
	elseif theScaleFactor = 1 then
		yOffset1 := 12;
		yOffset2 := 35;
	else
//		yOffset1 := 0;
		yOffset2 := 23;
	endif;
	
	// ### BAY ID
	if amPrinting then
		theX := _theX;
		if theScaleFactor = self.PrintScaleSmall then
			theX := ((self.totalPointWidth / 2).Integer) + 10;
			xOffset1 := 0;
			xOffset2 := 20;
		endif;
		theFrame.drawFillStyle := Frame.DrawFillStyle_Transparent;
		theFrame.drawEllipse1(theX - 10 ,_theY + yOffset1, theX + 10, _theY + yOffset2,Black);
		theFrame.drawTextAlign := Frame.DrawTextAlign_Center;
		theFrame.drawTextAt(theString,theX,_theY + yOffset1 + 3,Black);
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. " &amp; theString &amp; " " &amp; theX.String &amp; " " &amp; _theY.String &amp; " " &amp;  yOffset1.String);
	else
		theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
		theFrame.drawFillColor := Blue; 
		theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
		theFrame.drawEllipse1(_theX - xOffset1,_theY + yOffset1, _theX - xOffset2, _theY + yOffset2,Blue);
		theFrame.drawTextAt(theString,_theX - xOffset2 + 3,_theY + yOffset1 + 5,White);
	endif;
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	theFrame.drawTextAlign := Frame.DrawTextAlign_Left;

	if not amPrinting and not self.hideHoldID then
		// #### HOLD ID
		if self.displayMode = ShpDisplayMode_Defn then // DEFN does not use XML - yet
			theString := self.myBay.myHold.ordinalHold.String.padLeadingZeros(2);
		elseif self.ordinalHold &lt;&gt; null then
			theString := self.ordinalHold.String.padLeadingZeros(2);
		endif;
		if theString.trimBlanks &lt;&gt; null then
			xOffset1 := 49;
			xOffset2 := 31;
			theFrame.drawFillColor := Green;
			theFrame.drawFilledRectangle(_theX - xOffset1,_theY + yOffset1, _theX - xOffset2, _theY + yOffset2,Green);
			theFrame.drawTextAt(theString,_theX - xOffset1 + 3,_theY + yOffset1 + 5,White);
		endif;
	endif;
	// ##### 40 ID
	if not amPrinting then
		if _drawId40  then
			if self.displayMode = ShpDisplayMode_Defn then
				theString := self.myBay.getFortyFootBayID.trimBlanks;
			else
				theString := self.bayID40;
			endif;
			xOffset1 := 8;
			xOffset2 := 10;
	
			theFrame.drawFillColor := Mauve;
			theFrame.drawEllipse1(_theX - xOffset1,_theY + yOffset1, _theX + xOffset2 ,  _theY + yOffset2,Mauve);
			theFrame.drawTextAt(theString,_theX - xOffset1 + 3,_theY + yOffset1 + 5,White);
		endif;
	endif;
end;</source>
        <Parameter name="_theX" type="Integer"/>
        <Parameter name="_theY" type="Integer"/>
        <Parameter name="_drawId40" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllPointsForJob" id="37d2a747-d3ff-4524-817b-4bcce8acbb64">
        <source>getAllPointsForJob(_theJob : CM_Job;thePoints : CMUI_GridPointSet input) ;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	aPoint : CMUI_GridPoint;
	aBayPoint : SHP_BayPoint;
	aLidPoint : SHP_LidPoint;
	theGridArea : CMUI_GridArea;
	isBayPoint : Boolean;
begin
	if thePoints = null then
		return ;
	endif;
	thePoints.clear;
	
	
	if _theJob.isKindOf(CM_VoyageHatchLidJob) then
		foreach theGridArea in self.mySDF.allGridAreasByRowColumn do
			if not theGridArea.isKindOf(SHP_BayAreaAboveDeck) then
				continue;
			endif;
			
			if theGridArea.allGridRows.isEmpty then
				continue;
			endif;
			foreach aPoint in theGridArea.allGridRows.last.allGridPointsByColumn do
				if aPoint.isKindOf(SHP_LidPoint) then
					aLidPoint := aPoint.SHP_LidPoint;
					if aLidPoint.myHatchLid &lt;&gt; null then
						if aLidPoint.myHatchLid.allVoyageHatchLidJobs.includes(_theJob.CM_VoyageJob) then
							thePoints.add(aPoint);
						endif;
					endif;
				endif;			
			endforeach;
		endforeach;
	
	else
		foreach theGridArea in self.mySDF.allGridAreasByRowColumn do
			foreach aPoint in theGridArea.allGridPoints do
				if aPoint.isKindOf(SHP_BayPoint) then
					aBayPoint := aPoint.SHP_BayPoint;
					
					if self.displayMode = ShpDisplayMode_ColCodeDisch then
						if aBayPoint.colDischMyJob = _theJob then
							thePoints.add(aPoint);
						endif;
					else
						if aBayPoint.colLoadMyJob = _theJob then
							thePoints.add(aPoint);
						endif;
					endif;
				endif;			
			endforeach;
		endforeach;
	endif;
end;</source>
        <Parameter name="_theJob" type="CM_Job"/>
        <Parameter name="thePoints" type="CMUI_GridPointSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCorrespondingPoint" id="6746ecc9-eebe-4a92-ac9c-d610717638bf">
        <source>getCorrespondingPoint(_aPoint : SHP_BayPoint) : SHP_BayPoint;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aPoint : CMUI_GridPoint;
	idx,pointIDX : Integer;
	thePoints,thePointsAlt : CMUI_GridPointSet;
begin
	create thePoints transient;
	create thePointsAlt transient;
	
	self.mySDF.getAllSelectedPoints(thePoints);
	self.mySDF.getAllSelectedPointsALT(thePointsAlt);
	
	foreach aPoint in thePointsAlt do
		idx := idx + 1;
		if _aPoint = aPoint then
			break;
		endif;
	endforeach;
	
	pointIDX := idx;
	idx := 0;
	foreach aPoint in thePoints do
		idx := idx + 1;
		if pointIDX = idx then
			return aPoint.SHP_BayPoint;
		endif;
	endforeach;

epilog
	delete thePoints;
	delete thePointsAlt;
//	app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. _aPoint " &amp; _aPoint.String &amp; " pointIDX " &amp; pointIDX.String &amp; " idx " &amp; idx.String &amp; " aPoint " &amp; aPoint.String);
end;</source>
        <Parameter name="_aPoint" type="SHP_BayPoint"/>
        <ReturnType type="SHP_BayPoint"/>
    </JadeMethod>
    <JadeMethod name="getDrawHeight" id="f6a07f75-6f7c-4939-8d20-b1931d418272">
        <source>getDrawHeight(_scaleFactor : Real): Integer;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		Works out the maximum Height of the frame
//
// ---------------------------------------------------------------------------

vars
	theTotalPointHeight,theRowHeight,theTopMargin,theBotMargin : Integer;
	aBayRow : SHP_BayRow;
begin
	if self.allGridRows.isEmpty then
		return null;
	endif;
	theBotMargin := BottomMargin;
	if self.scaleXFactor = self.PrintScaleSmall and self.isKindOf(SHP_BayAreaBelowDeck) then
	theBotMargin := 30;
	endif;
	theRowHeight := (self.RowHeight * _scaleFactor).Integer;
	theTopMargin := self.getTopMargin();
	aBayRow := self.allGridRows.last.SHP_BayRow;
	
	if self.scaleXFactor = 1 or (self.scaleXFactor = self.PrintScaleSmall and self.isKindOf(SHP_BayAreaAboveDeck)) then
		theTotalPointHeight := 	((aBayRow.row * theRowHeight) + 2).Integer;
	else
		theTotalPointHeight := 	((aBayRow.row * theRowHeight) + theTopMargin  + theBotMargin).Integer;
	endif;


	return theTotalPointHeight;
end;</source>
        <Parameter name="_scaleFactor" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDrawWidth" id="cb57e184-b330-40aa-99aa-c004d7d9c302">
        <source>getDrawWidth(_scaleFactor : Real): Integer;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		Works out the maximum width of the frame
//
// ---------------------------------------------------------------------------

vars
	theTotalPointWidth,theColWidth : Integer;
	aBayCol : SHP_BayColumn;
begin
	if self.allGridColumns.isEmpty then
		return null;
	endif;
	theColWidth := (self.ColWidth * _scaleFactor).Integer;
	
	aBayCol := self.allGridColumns.last.SHP_BayColumn;
	
	if self.scaleXFactor = 1 or self.scaleXFactor = self.PrintScaleSmall then
		theTotalPointWidth := 	((aBayCol.allignment * theColWidth) + 2).Integer;
	else
		theTotalPointWidth := 	((aBayCol.allignment * theColWidth) + LeftMargin  + RightMargin).Integer;
	endif;


	return theTotalPointWidth;
end;</source>
        <Parameter name="_scaleFactor" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRowColumnFromXY" id="b6571e68-8edf-4985-937d-7fa1278fb479">
        <source>getRowColumnFromXY(_x, _y : Real);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 May 2009	cnwer1	Initial creation

*/

vars
	topLeftPoint : CMUI_GridPoint;
	gridRow : CMUI_GridRow;
	gridCol : CMUI_GridColumn;
	iter : Iterator;
begin
	if self.allGridPoints.isEmpty then
		return;
	endif;
	
	//get the first point this is the top left point
	topLeftPoint:=self.allGridPoints.first;
	if _x &lt; topLeftPoint.x1 and _y &gt; topLeftPoint.y1 then
		//this is a row select
		iter:=self.allGridRows.createIterator;
		while iter.next(gridRow) do
			if _y &gt; gridRow.y1 and _y &lt; gridRow.y2 then
					write gridRow.label;
				return;
			endif;
		endwhile;
		
	elseif _y &lt; topLeftPoint.y1 and _x &gt;  topLeftPoint.x1 then
		//this is a column select
		iter:=self.allGridColumns.createIterator;
		while iter.next(gridCol) do
			if _x &gt; gridCol.x1 and _x &lt; gridCol.x2 then
					write gridCol.label;
				return;
			endif;
		endwhile;
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="getSelectedHatchLid" id="c8304095-4530-4d65-9e93-3fb076cc06ff">
        <source>getSelectedHatchLid() : CM_HatchLid;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	bayFrame : CMUI_GridAreaFrame;
	aPoint : CMUI_GridPoint;
	idx, ordinal : Integer;
	aHatchLid : CM_HatchLid; //Vessel;
begin
	// the lid points are part of the on deck bay area
	if self.allSelectedPoints.size = 0 then
		return null;
	endif;
	// only one lid point will be selected, but there is 1 lid point for every cell (column) so get the hatch lid object first
	foreach aPoint in self.allSelectedPoints do
		if aPoint.isKindOf(SHP_LidPoint) then
			if aPoint.SHP_LidPoint.myHatchLid &lt;&gt; null then
				aHatchLid :=  aPoint.SHP_LidPoint.myHatchLid.CM_HatchLid; //Vessel;
				break;
			endif;
		endif;
	endforeach;

	return aHatchLid;
end;</source>
        <ReturnType type="CM_HatchLid"/>
    </JadeMethod>
