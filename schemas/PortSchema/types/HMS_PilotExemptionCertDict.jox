<CollClass name="HMS_PilotExemptionCertDict" id="73eb5457-6373-4fcc-8284-92d67aac221e">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="HMS_PilotExemptionCertificate"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="pilotExempt"/>
    <MemberKey>
        <property name="HMS_PilotExemptionCertificate::certifiedDate"/>
    </MemberKey>
    <JadeMethod name="hasAnotherLikeMe" id="2b75244a-9c5e-4dfb-ae66-7e0e5242c550">
        <source>hasAnotherLikeMe( _pilotExempt : HMS_PilotExemptionCertificate ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

	iter : Iterator;
	pilotExempt : HMS_PilotExemptionCertificate;

begin

	iter := self.createIterator;
	
	while iter.next( pilotExempt ) do
		if pilotExempt &lt;&gt; _pilotExempt then
			//don't check this one, its me...
			continue;
		endif;
		
		if pilotExempt.myVessel &lt;&gt; _pilotExempt.myVessel then
			//different vessel
			continue;
		endif;
		
		if pilotExempt.myHarbour &lt;&gt; _pilotExempt.myHarbour then
			//different harbour
			continue;
		endif;
		
		if pilotExempt.myMaster &lt;&gt; _pilotExempt.myMaster then
			//different master
			continue;
		endif;
		
		return true;
		
	endwhile;
	
	return false;

epilog

	delete iter;

end;</source>
        <Parameter name="_pilotExempt" type="HMS_PilotExemptionCertificate"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
