    </JadeMethod>
    <JadeMethod name="updateTIRemarks" id="15328257-76df-48e1-bf85-d91562747fc9">
        <source>updateTIRemarks(_ti : CM_TrackedItem io; _remarks : String);

/*

Purpose:		Update ti's Remarks

Date			Who		Reason
07/02/2014		cnwmh5	Initial creation

*/

vars

	pxyTI						: CM_TrackedItem;

begin

	if _ti = null then
		return;
	endif;

	beginLoad;
	pxyTI := _ti.pxyCreateUpdateProxy();
	endLoad;
	
	app.myTrxUA.trxUpdateTIRemarks(pxyTI, _remarks, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	delete pxyTI;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_remarks" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateTIRemarksFromLCSet" id="977ccea7-ff09-4ec8-8917-e84f703bfce3">
        <source>updateTIRemarksFromLCSet(_lcSet : CM_LCSet);

/*

Purpose:			

Date			Who		Reason
28 August 2015	cnwmh5	Initial creation

*/

vars

	lc					: CM_LocationsController;
	ti					: CM_TrackedItem;

begin

	// set the remarks
	beginTransaction;
	foreach lc in _lcSet do
		///write method.qualifiedName() &amp; Tab &amp; lc.ident &amp; Tab &amp; _opts.bool("is40").String;
		foreach ti in lc.allTrackedItems discreteLock do
			if not ti.remarks.cnContains(self.createdByUnitTest(null)) then
				ti.setRemarks(self.createdByUnitTest(null) &amp; CrLf, false);
			endif;
		endforeach;
	endforeach;
	commitTransaction;

epilog

end;</source>
        <Parameter name="_lcSet" type="CM_LCSet"/>
    </JadeMethod>
    <JadeMethod name="updateTITransactionDateTime" id="29490320-f487-4f0d-ad55-79f097fcce36">
        <source>updateTITransactionDateTime(_trans : CM_TITransaction io; _dateTime: TimeStamp);

vars
	txnController: CMIF_TITransactionController;
begin

	global.createTxnControllerForType(_trans.type, txnController);
	
	txnController.ammended := _trans.ammended;
	txnController.dateTime := _dateTime;
	txnController.deleted := _trans.deleted;
	txnController.freightForwarderCode := _trans.freightForwarderCode;
	txnController.noCharge := _trans.noCharge;
	txnController.operatorCode := _trans.operatorCode.trimBlanks;
	txnController.superseded := _trans.superseded;
	txnController.type := _trans.type;
	txnController.myToDoTask := _trans.myToDoTask;
	txnController.urNumber := _trans.urNumber;
	txnController.userGenerated := _trans.userGenerated;
	txnController.userId := _trans.userId.trimBlanks;
	txnController.myTerminal := _trans.myTerminal;
	txnController.myTrackedItem := _trans.myTrackedItem;
	
	app.myTrxUA.trxUpdateTITransaction(txnController, _trans, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();


epilog
	delete txnController;
end;</source>
        <Parameter name="_trans" type="CM_TITransaction" usage="io"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="updateTIWeightToDoTask" id="09c6bb92-8aba-4ac8-ba63-e2c781e0eed0">
        <source>updateTIWeightToDoTask(_ti : CM_TrackedItem io; _toDoId : Integer; _weight : Decimal; _certified, _addingToDo : Boolean);

/*

Purpose:		Update the weight of the tracked item

Date			Who		Reason
10/02/2014		cnwmh5	Initial creation

*/

vars

	pxyTI				: CM_TrackedItem;	
	controller			: CMIF_TIUpdateController;
	
begin

	beginLoad;
	pxyTI := _ti.pxyCreateUpdateProxy();
	endLoad;
	
	controller := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.myPassport.userCode, null);
	pxyTI.setTotalWeightAndCertified(_weight, pxyTI.weightCargo, pxyTI.weightTare, _certified, controller, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	app.myTrxUA.trxUpdateTIWeightToDo(pxyTI, _toDoId, _addingToDo, true, null, TI_UPDMODE_NORMAL, null, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	delete pxyTI;
	delete controller;

end;</source>
