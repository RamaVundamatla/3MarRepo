    <JadeMethod name="btnDoSearch_click" id="fba73877-e0ac-4a93-af10-0fd33d79134b">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDoSearch_click(btn: Button input) updating;
// -------------------------------------------
// Created 29 November 2005 by cnwdvb1
// 15/05/2025	navcs2	MTN-34843 Development - Form Changes
// -------------------------------------------
vars
	readonly : Boolean;
begin

	if self.isWagonMaster then	// 06 Jul 2009	NDL	CCMS 1067
		self.displayWagonMasters( null );
	else
		self.displayTiMasters( null );
	endif;
	self.showHideSearcher();

	readonly := false;
	
	// TFS 2198 CNWAB1
	if (self.isTILC or self.isMAFI) and not app.myCurrentUserCan(null, PmAdmTiMasterTrailerUpdate) then				// 15/05/2025	navcs2	MTN-34844
		readonly := true;
	elseif self.isContainer and not app.myCurrentUserCan(null, PmAdmTiMasterContainerUpdate) then
		readonly := true;
	elseif self.isGenerator and not app.myCurrentUserCan(null, PmAdmTiMasterGeneratorUpdate) then
		readonly := true;
	elseif self.isWagonMaster and not app.myCurrentUserCan(null, PmWagonMasterMaint) then
		readonly := true;
	elseif self.isWagonMaster and not app.myCurrentUserCan(null, self.permissionMaint) then
		readonly := true;
	endif;

	if readonly then
		self.btnNew.enabled:= false;
		self.btnDelete.enabled:= false;
		self.btnEdit.enabled:= false;
		self.mnuAdd.enabled:= false;
		self.mnuAddTask.enabled:= false;
		self.mnuEdit.enabled:= false;
		self.mnuStops.enabled:= false;
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnEdit_click" id="660693b3-2338-439a-bbe6-a54f1ef44483">
