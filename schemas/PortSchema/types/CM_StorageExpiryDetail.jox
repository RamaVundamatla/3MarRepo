    <JadeMethod name="setProxy" id="8a8edb7c-c6ae-4b9a-b3ed-b1068e321e9d">
        <updating/>
        <source>setProxy(_additionalStorageDays : Integer; _dateTime : TimeStamp; _freeDays, _freeDaysType : Integer; _freeStorageAdjustment : String; _freeStorageDays, _freeStorageDaysRemaining : Integer;
		_freeStorageExpiry : TimeStamp; _futureStorageAnniversary : TimeStamp; _incoTermsCode : String; _myOwnershipChange : CM_OwnershipChange; _myStorageDetail : CM_StorageDetail;
		_myTrackedItem : CM_TrackedItem;_operatorCode, _operatorForBillingCode, _storageChangeReason : String; _totalQuantity : Integer; _totalVolume, _totalWeight : Decimal;
		_chargedDaysType : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2023 navmv20 CR 58250 Task 58251: Jade - Upgrade script

*/

vars

begin
	self.additionalStorageDays := _additionalStorageDays;
	self.dateTime := _dateTime;
	self.freeDays := _freeDaysType;
	self.freeDaysType := _freeDaysType;
	self.freeStorageAdjustment := _freeStorageAdjustment;
	self.freeStorageDays := _freeStorageDays;
	self.freeStorageDaysRemaining := _freeStorageDaysRemaining;
	self.freeStorageExpiry := _freeStorageExpiry;
	self.futureStorageAnniversary := _futureStorageAnniversary;
	self.incoTermsCode := _incoTermsCode;
	self.myOwnershipChange := _myOwnershipChange;
// ### TFS BUG 64221 21MAY2024 NAVAB1	self.myStorageDetail := _myStorageDetail;
	self.myTrackedItem := _myTrackedItem;
	self.operatorCode := _operatorCode;
	self.operatorForBillingCode := _operatorForBillingCode;
	self.storageChangeReason := _storageChangeReason;
	self.totalQuantity := _totalQuantity;
	self.totalWeight := _totalWeight;
	self.totalVolume := _totalVolume;
	self.chargedDaysType := _chargedDaysType;
epilog

end;
</source>
