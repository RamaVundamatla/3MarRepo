        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateITSInterfaceRequest" id="8c04809f-59c3-4692-a43c-6f4682708969">
        <updating/>
        <source>trxCreateITSInterfaceRequest(_pxyObject : CM_ITSInterfaceRequest; _realObject : CM_ITSInterfaceRequest output; 
							_passport : CM_Passport input) updating;

/*

Purpose:			Record ITS Interface Request.

Parameters:			Proxy for class of request (Request from ITS, internal reset request etc.)

Return Value:		None


Date		Who		Reason
16 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	app.myUtilityCA.utlCreateITSInterfaceRequest(_pxyObject, _realObject, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyObject" type="CM_ITSInterfaceRequest"/>
        <Parameter name="_realObject" type="CM_ITSInterfaceRequest" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateITSInterfaceResponse" id="d8356950-237b-42b8-be12-b76189cbba0c">
        <updating/>
        <source>trxCreateITSInterfaceResponse(	_pxyObject	: CM_ITSInterfaceResponse input;
								_realObject : CM_ITSInterfaceResponse output;
								_request	: CM_ITSInterfaceRequestMessage input;
								_passport	: CM_Passport input) updating;

/*

Purpose:			Create Interface Response that will be sent to ITS.

Parameters:			

Return Value:		None


Date		Who		Reason
24 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	app.myUtilityCA.utlCreateITSInterfaceResponse(_pxyObject, _realObject, _request, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyObject" type="CM_ITSInterfaceResponse" usage="input"/>
        <Parameter name="_realObject" type="CM_ITSInterfaceResponse" usage="output"/>
        <Parameter name="_request" type="CM_ITSInterfaceRequestMessage" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateInOut" id="d6f76f0c-dd1c-4211-8f35-5fd100a0ca24">
        <updating/>
        <source>trxCreateInOut(pIntFaceCommon : CMIF_InOutCommon input; pIntFaceArray : CMIF_TIObjectArray; _passport : CM_Passport input; _allBookingSlots : CMIF_1StopBookingDataArray) updating;
//Creates a road entry transaction using an array of interface objects representing
//pages of the road entry forms
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30May03 		RJS			Removed utl as wanted to do validation prior to
//							going into transaction state or share locks
//							were held unnecessarily
//
// 18/02/2009	cnwdad1		PAR #18925. If the call to create a vehicle for a
//							Road Job raises an exception, the method has failed
//							but the "return" statement would not be called because
//							the callstack would jump to the next statement after
//							the "if" condition - added a check for any errors.
// 14/09/2009	cnwcs5		Move code to move vehicle till after the vehicle visit 
//							record is updated with the TI's
//							Use CM_InterchangeArea instead of CM_YardInterchangeArea
// 17/06/2010	cnwcs5		par 24418 - interchange area handling
//
// 15/12/2014	cnwmc5		Refactored coded to be in a utl
// ---------------------------------------------------------------------------
vars
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	app.myUtilityCA.utlCreateInOutVehicle(pIntFaceCommon, _passport);		//cnwmc5 - 22 Jan 2015 - PAR 35518
	
	if _passport.noErrors then												//cnwmc5 - 22 Jan 2015 - PAR 35518
		app.myUtilityCA.utlCreateInOut(pIntFaceCommon, pIntFaceArray, _passport, _allBookingSlots);	//TFS 53107, AjitM, navam1
	endif;																	//cnwmc5 - 22 Jan 2015 - PAR 35518
	
epilog	
	self.finaliseActivityWithPassport(_passport); 
end;</source>
        <Parameter name="pIntFaceCommon" type="CMIF_InOutCommon" usage="input"/>
        <Parameter name="pIntFaceArray" type="CMIF_TIObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_allBookingSlots" type="CMIF_1StopBookingDataArray"/>
    </JadeMethod>
    <JadeMethod name="trxCreateInOutFlexiGateEntity" id="d9f6b70b-bc2e-4d3c-a746-52c9b5aab3df">
        <updating/>
        <source>trxCreateInOutFlexiGateEntity(_vvr : CM_VehicleVisitRecord input; _pxyGTE : CMGTE_Entity input; _gte: CMGTE_Entity output; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     22 September 2008 by cnwab1
//
// Purpose:     For new flexi gate
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//19/6/2025   jlier1MTN-34221 refactoring validation so is before trx - also removed validation only parameter as never used
// ---------------------------------------------------------------------------
vars
		pxyTIs : CM_ObjectByStringDict;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	//19/6/2025   jlier1 MTN-34221 refactoring validation so is before trx 
	app.setContinueCMExceptions(true);
	create pxyTIs transient;
	app.myValCA.valGateEntity(_vvr,_pxyGTE,pxyTIs,_passport);
	if app.myPassport.hasErrorsIgnored then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	// Start the transaction
	beginTransaction;
	app.myUtilityCA.utlCreateInOutFlexiGateEntity(_vvr, _pxyGTE, _gte, _passport);
		
epilog
	if pxyTIs &lt;&gt; null then
		pxyTIs.purge;
		delete pxyTIs;
	endif;
	self.finaliseActivityWithPassportEW(_passport, true);
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_pxyGTE" type="CMGTE_Entity" usage="input"/>
        <Parameter name="_gte" type="CMGTE_Entity" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateInOutFlexiGateEntitys" id="d6ff93b4-30e1-4e24-9411-31612fa5a224">
        <updating/>
        <source>trxCreateInOutFlexiGateEntitys(	_vvr : CM_VehicleVisitRecord input;
								_pxyGTEArray : CMGTE_EntityArray input; 
								_realGTEArray :CMGTE_EntityArray output;
								_additions : Boolean; 
								_passport : CM_Passport input) updating;
// -----------------------------------------------------------------------------
// Created:		07 September 2009 by consw1
//
// Purpose:		Create multiple Gate Entities for new flexi gate
//
// Parameters:	
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//19/6/2025   jlier1 MTN-34221 refactoring validation so is before trx - validation only never set so removed
//08 Jan 2026 	navlc30 	JIRA 36900 Bug AAT Cannot add a PIN to a truck in the yard 
// -----------------------------------------------------------------------------

vars
	gte, pxyGTE : CMGTE_Entity;
	wle : CM_WorkListEntry;
	arbiter	: CM_RTQueueArbiter;
	req : CM_Request;
	tilcLC : CM_TILCController;
	ti 	: CM_TrackedItem;
	pxyTIs : CM_ObjectByStringDict;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(true);
	
	create pxyTIs transient;
	
	app.myValCA.valGateEntities(_vvr,_pxyGTEArray,pxyTIs,_passport);
	
	if pxyTIs &lt;&gt; null then
		pxyTIs.purge;
		delete pxyTIs;
	endif;
	
	if app.myPassport.hasErrorsIgnored then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	_passport.useTITransactionDeferUpdate := true;	// 05 Jul 2017	NDL	TFS 5238	
	_passport.useTIDictDeferUpdate := true;			// 05 Jul 2017	NDL	TFS 5238
	
	create _realGTEArray transient;
	// Start the transaction
	beginTransaction;
	
	foreach pxyGTE in _pxyGTEArray discreteLock do
		gte := null;
		app.myUtilityCA.utlCreateInOutFlexiGateEntity(_vvr, pxyGTE, gte, _passport);
		if _passport.hasErrors() then
			_passport.clearDeferUpdatesCollections();	// 05 Jul 2017	NDL	TFS 5238
			break;
		endif;
		
		if  gte &lt;&gt; null then
			
			_realGTEArray.add(gte);
		endif;
		//26 May 2011	NDL	Par 27585 - Adding gate entities after the truck is gated in...
		if _additions then
			
		
			app.myUtilityCA.utlCreateActionGateEntity(_vvr, gte, _additions, null, _passport);
			if _passport.hasErrors() then
				_passport.clearDeferUpdatesCollections();	// 05 Jul 2017	NDL	TFS 5238
				break;
			endif;
			
			//jlier1 TFS 60908 if it is a chassis that is Remain on board it automatically creates a relase chasis we need to also action that
			if gte = _vvr.myInCMGTE_Chassis then
				tilcLC:=gte.CMGTE_TILC.myTrackedItem.CM_TILC.getNextFreeLC();	
				if gte.CMGTE_TILC.imexStatus = TI_IMEX_STATUS_REMAINONBOARD  and _vvr.myOutCMGTE_Chassis &lt;&gt; null then
					app.myUtilityCA.utlCreateActionGateEntity(_vvr, _vvr.myOutCMGTE_Chassis, true, null, _passport);
					if _passport.hasErrors() then
						_passport.clearDeferUpdatesCollections();
						break;
					endif;
				endif;
			endif;
			
			//05 Aug 2014	NDL	Par 34675
			if gte.isRelease then
				req := gte.myYardRequest;
				if req &lt;&gt; null then
					wle := req.allWorkListEntries.first;
				endif;
				if wle &lt;&gt; null and wle.isAnyId then
					create arbiter;
					arbiter.job := wle.job;
					wle.enqueueWLE(arbiter);
					arbiter.erase(0);
				endif;
			endif;
		endif;
		
	endforeach;
	
	
	
	//jlier1 TFS 60908 if we just added an inward chassis need to move any receival cargo on to the chassis that is on the truck
	if tilcLC &lt;&gt; null and _vvr.myRoadJob &lt;&gt; null then
		foreach ti in _vvr.allReceivedTrackedItems discreteLock where not ti.isKindOf(CM_TILC) do
			if ti.myPrimaryActualLocation =  _vvr.vehicle.locationsController then
				//move onto the chassis
				ti.moveToLocation( tilcLC, null, null, null,REAL_MODE, false, true, false, false, false,   false,null, null, null, null, _vvr, _passport);	
			endif;
		endforeach;
		_vvr.myRoadJob.rebuildStatus();
	endif;
	_passport.doDeferredUpdates();	// 05 Jul 2017	NDL	TFS 5238
	
epilog
	//arbiter is Already cleared on line#105 calling erase(0)	//08.01.2026 navlc30 #36900
	//delete arbiter;											//08.01.2026 navlc30 #36900
	if pxyTIs &lt;&gt; null then
		pxyTIs.purge;
		delete pxyTIs;
	endif;
	self.finaliseActivityWithPassportEW(_passport, true);
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_pxyGTEArray" type="CMGTE_EntityArray" usage="input"/>
        <Parameter name="_realGTEArray" type="CMGTE_EntityArray" usage="output"/>
        <Parameter name="_additions" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateInOutFlexiJob" id="1a04262a-7d22-4b63-bf4a-fdc32d3e6b96">
        <updating/>
        <source>trxCreateInOutFlexiJob(_pxyVVR 				: CM_VehicleVisitRecord;
						_realVVR 			: CM_VehicleVisitRecord io;
						_allProformaLines 	: ObjectSet input;
						_passport 			: CM_Passport input) updating;
/* ---------------------------------------------------------------------------
// Created:     25 September 2008 by cnwab1
//
// Purpose:     For new flexi gate
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
20 Aug 2012		cnwer1		CCMS 1280 changes for CASH System - added parameter _allProformaLines
11/03/2015		cnwmh5		Transient Leaks
27 Feb 2018		cnwma1  	ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
24/10/2018 		JLGNS1		Bug 40885: PEN - Object not found error
10 Sep 2021		navdap1		TFS 51248 SNO Truck Apointment and Pre-Notes
10 Aug 2022 	navkc1		Bug 54494: CUX - Drivers with multiple vehicles not saved
08 Dec 2022		navsp1 		ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
12 Apr 2023		navdap1		TFS 57362 CUX Changes to Outgoing Message Formats
14/02/2024		navcs2		Bug 62454: FR | 53667 - Inspection App - Resend Message discrepancy
08 Aug 2024 	navcs2		ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
10 Apr 2024 	navma1		Bug 64224: MTN - DeadLocks Caused by Future Actors
19 May 2025	jlier1	MTN-34221 refactoring validation so is before trx 
// ---------------------------------------------------------------------------*/
vars
	item 				: CMGTE_Entity;
	realVVR 			: CM_VehicleVisitRecord;
	tmpEvent			: Integer;
	tmpTerminal			: CM_Terminal;
	pxyTIs				: CM_ObjectByStringDict; 
	gate				: CM_Gate;
	pxyVBTS,
	vbts				: CM_VehicleBookingTimeSlot;
	strArray 			: StringArray;
	ti 					: CM_TrackedItem;
	pxyTi 				: Object;
	pxyGen 				: CM_Generator;
	deliveryIds, 
	pickupIds 			: StringArray;
	gateLaneController 	: CM_YardController;
	driverDetails		: CM_DriverDetails;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	// This will hold a collection of validated TIs.
	create pxyTIs transient;	
	
	tmpTerminal := _passport.myTerminal;

	//app.setContinueCMExceptions(false);
	app.setContinueCMExceptions(true);

	realVVR := _pxyVVR.pxyGetRealObject();
	
	// This validation is repeated in utlCreateVehicleVisitFlexi/Update, but done here
	// as loads objects into cache, and want to do this before calling validateForCreateJobFlexi
	if realVVR = null then
		_pxyVVR.validateForCreate(_passport);
	else
		_pxyVVR.validateForUpdate(_passport);
	endif;
	
	// Do the validataion for the creation of a job.  This should do all validation on
	// the sub-objects as well.
	_pxyVVR.validateForCreateJobFlexi(_passport, pxyTIs, false);

	endLoad;		// to clear any locks that may have been held as part of validation
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	_passport.useTIDictDeferUpdate		  	:= true;
	_passport.useTITransactionDeferUpdate 	:= true;
	_passport.useEventDeferUpdate 		  	:= true;	 // ### TFS CR 63938 TASK 63942 02MAY2024 NAVAB1
	_passport.useOfflineFutureActorDeferUpd	:= true;	 // 10.04.2024 navma1 #64224
	
	// Start the transaction
	beginTransaction;
	
	if realVVR = null then
		app.myUtilityCA.utlCreateVehicleVisitFlexi(_pxyVVR, realVVR, _passport);
	else
		app.myUtilityUA.utlUpdateVehicleVisitFlexi(_pxyVVR,true, _passport);
	endif;
		
	if _passport.noErrorsIgnored() then
		//19 May 2025	jlier1	MTN-34221 removed code called in utlCreateVehicleVisitFlexit and UpdateVehicleVisitFlexi
		app.myUtilityCA.utlCreateInOutFlexiJob(realVVR, _passport, pxyTIs);
	endif;	
		
	
	if _passport.noErrors() then
		// Issue notifications for received containers
		tmpEvent := tmpTerminal.getTerminalEvent(TIEvent_Terminal_Receival);
		foreach item in realVVR.allGateEntities do
			if item.isKindOf(CMGTE_Receival) and item.CMGTE_Receival.myTrackedItem &lt;&gt; null then
				item.CMGTE_Receival.myTrackedItem.causeEvent(tmpEvent, false, null);
			endif;
		endforeach;
	endif;
	
	// create/update the proforma invoice before any more real invoice charges are created
	// i.e. trx invoice/charges are done below in the doDeferredUpdates
	// Feb 37546 this is not needed - creates cash payments with null receipts for nothing
	///if _passport.noErrors() then
	///	app.myUtilityUA.utlUpdateCashPaymentProforma(realVVR,_allProformaLines,_passport);
	///endif;
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();	
	endif;

	//cnwmc5 - 20 Jan 2015 - CCMS 2435
	if app.isWebApp and _passport.noErrors and realVVR &lt;&gt; null  then
		//cnwmc5 - 30 Jan 2015 - CCMS 2435
		//since the webserice completely gates in the cargo, we need to make the realVVR not updatable..
		//this needs to be done here, because the 'create' of the VVR ignores the proxyVVR's 'isUpdatable' flag..
		realVVR.setIsUpdatable(false);
		
		pxyVBTS := _pxyVVR.myVehicleBookingTimeslot;
		
		if pxyVBTS &lt;&gt; null then
			vbts := pxyVBTS.pxyGetRealObject();
		endif;
		
		//jlier1 TFS 59732 6/9/23 
		if vbts &lt;&gt; null then
			create strArray transient;
			create deliveryIds transient;			// TFS 51248
			create pickupIds transient;				// TFS 51248
			foreach ti in realVVR.allReceivedTrackedItems do
				strArray.add( ti.id );
				deliveryIds.add(ti.id);				// TFS 51248
			endforeach;
			foreach ti in realVVR.allReleasedTrackedItems do
				strArray.add( ti.id );
				pickupIds.add(ti.id);				// TFS 51248
			endforeach;
			
			pxyVBTS.setProxy(	vbts.bookingTSstart,	//_scheduleTSstart : TimeStamp;
							vbts.bookingTSend,	//_scheduleTSend : TimeStamp;
							vbts.myVehicleBookingTerminal,	//_myVBTerminal : CM_VehicleBookingTerminal;
							realVVR.getCarrier(),	//vbts.myCarrier,	//_myCarrier : CM_Carrier;
							null,					//_mySubCarrier : CM_Carrier;
							realVVR.myDriverDetails, //vbts.myDriver,	//_myDriver : CM_DriverDetails;
							vbts.myVehicle,	//_myVehicle : CM_Vehicle;
							vbts.remarks,	//_remarks : String;
							not realVVR.allReceivedTrackedItems.isEmpty(),	//_includesDelivery : Boolean;
							not realVVR.allReleasedTrackedItems.isEmpty(),	//_includesPickUp : Boolean;
							strArray,	//_bookedTiIds : StringArray;
							realVVR,	//_myVehicleVisitRecord : CM_VehicleVisitRecord
							vbts.myVBTimeSlotType,	//_myVBTimeslotType : CM_VehicleBookingTimeSlotType
							vbts.id,	//_id : String;
							vbts.allBookingRefs,	//_allBookingRefs : CM_BookingRefSet;
							vbts.allBulkReleases,	//_allBulkReleases : CM_BulkReleaseSet
							null,	//_allVBSTimeSlots : CM_VehicleBookingTSItemSet;
							null,	//_preGateInCheck : Boolean;
							null,	//_preGateOutChck : Boolean;
							null,	//_kioskCheck : Boolean;
							null,	//_externalReference : String
							null	// 08 Aug 2024 navcs2	ChangeRequest 63928
							);
	
			//app.myUtilityUA.utlUpdateVVSBooking(pxyVBTS, _passport);							// TFS 51248
			app.myUtilityUA.utlUpdateVVSBooking(pxyVBTS, deliveryIds, pickupIds, _passport);	// TFS 51248
		endif;
	endif;

	// ### TFS 55215 23Nov2022 NAVPW1
	if _passport.noErrors then
		CMIF_TrxActionTransport@createAction(null, null, realVVR, CMIF_TrxActionTransport.ProcessTruckArrival, _passport);	// TFS 57362		
	endif;
	// ### TFS 55215 23Nov2022 NAVPW1
	
	//08Dec2022 navsp1 TFS 55580
	if _passport.noErrors and realVVR.vehicle.myPrimaryActualLocation &lt;&gt; null then
		if not realVVR.vehicle.myPrimaryActualLocation.CM_YardController.isInsideYard then
			CMIF_TrxActionInspection@createAction(realVVR,_passport);						// 14/02/2024		navcs2		Bug 62454
		endif;
	endif;
epilog
	self.finaliseActivityWithPassportEW(_passport, false);
	if _passport.trxCompletedOK or _realVVR &lt;&gt; null then
		_realVVR:=realVVR;
	endif;
	//27.02.2018 cnwma1 ChangeRequest #36813
	foreach pxyTi in pxyTIs do
		if app.isValidObject(pxyTi) then			//Bug 40885
			if pxyTi.isKindOf(CM_TILC)  then
				pxyGen := pxyTi.CM_TILC.getGenerator;
				if pxyGen&lt;&gt; null  and pxyGen.isTransient then
					delete pxyGen;
				endif;
			endif;
		endif;		
	endforeach;
	//27.02.2018 cnwma1 ChangeRequest #36813
	pxyTIs.purge();
	
	delete pxyTIs;		//+cnwml2 MSL CCMS 1012
	delete strArray;
	delete deliveryIds;		// TFS 51248
	delete pickupIds;		// TFS 51248
end;</source>
        <Parameter name="_pxyVVR" type="CM_VehicleVisitRecord"/>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord" usage="io"/>
        <Parameter name="_allProformaLines" type="ObjectSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateInOutVehicle" id="8e980a2a-bdc3-43f8-8bdb-9161bec656c3">
        <updating/>
        <source>trxCreateInOutVehicle(pIntFaceCommon : CMIF_InOutCommon input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2014	cnwmc5	Initial creation

*/

vars
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	app.myUtilityCA.utlCreateInOutVehicle(pIntFaceCommon, _passport);
	
epilog	
	self.finaliseActivityWithPassport(_passport); 
end;</source>
        <Parameter name="pIntFaceCommon" type="CMIF_InOutCommon" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateInstantMoveHistory" id="1b57e44a-a516-4233-a7ca-128b634da3f2">
        <updating/>
