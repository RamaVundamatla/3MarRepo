    <JadeMethod name="updateConstantDetails" id="db5a8962-f466-4a77-b148-347a344c5930">
        <source>updateConstantDetails();

/*

Purpose:		Update the Constant details	and Constant Objects

Date			Who		Reason
18/04/2012		cnwmh5	Initial creation

*/

vars

	lsConstant		: LSconstant;
	transAgent 		: CM_TranslationAgent;
	sa 				: StringArray;
	
begin

	self.staMain.caption := "Updating Constant Objects.  Please wait...";
	self.doWindowEvents(0);
	
	if self.myLSclass = null then
		return;
	endif;
	
	create transAgent transient;
	create sa transient;
		
	foreach lsConstant in self.myLSclass.allConstants do
		sa.add(lsConstant.name);
	endforeach;

	transAgent.trxLoadSpecificTranslations(sa);
	
epilog

	delete transAgent;
	delete sa;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="updateFormChanges" id="bf205702-01f0-4abe-bc97-bd5f46567059">
        <source>updateFormChanges();

/*

Purpose:		Updates the changes to a form	

Date			Who		Reason
26/01/2012		cnwmh5	Initial creation

*/

vars

	obj					: Object;
	jdo					: JadeDynamicObject;
	form				: Form;
	control				: Control;
	tmpMenu				: MenuItem;
	
	formName			: String;
	controlName			: String;
	text				: String;
	propertyType		: String;
	
	index				: Integer;
	processed			: Boolean;
	
begin

	beginTransaction;

	foreach obj in self.dictFormChanges do
		jdo := obj.JadeDynamicObject;
		
		formName := jdo.getPropertyValue("formName").String;
		controlName :=  jdo.getPropertyValue("controlName").String;
		propertyType := jdo.getPropertyValue("propertyType").String;
		text := jdo.getPropertyValue("formText").String;
		
		
		//write  formName &amp; Tab &amp; controlName &amp; Tab &amp; propertyType &amp; Tab &amp; text;
		
	/*	foreach form in Form.instances do
			if form.name = formName then
				break;
			endif;
		endforeach; */
		
		form := self.allAvailableForms.getAtKey( formName ).Form;	//10 Jun 2021	NDL	TFS 51321
		
		if form = null then
			return;
		endif;
	
		app.reserveLock(form);
		
		// update the form caption
		if formName = controlName then
			app.log("Updating " &amp; form.name &amp; ", " &amp; form.name &amp; ", caption");
			form.setPropertyValue('caption', text);
			continue;
		endif;
		
		// update the control caption / bubbleHelp 
		processed := false;
		foreach index in 1 to form.controlCount do
			control := form.controls(index);
			//write form.name &amp; Tab &amp; control.name;
			if control.name = controlName then
				if propertyType = 'caption' then
					app.log("Updating " &amp; form.name &amp; ", " &amp; control.name &amp; ", caption");
					control.setPropertyValue('caption', text);
					processed := true;
					break;
				elseif propertyType = "bubbleHelp" then
					app.log("Updating " &amp; form.name &amp; ", " &amp; control.name &amp; ", bubbleHelp");
					control.setPropertyValue('bubbleHelp', text);
					processed := true;
					break;
				endif;
			endif;
		endforeach;
	
		if processed then 
			continue;
		endif;
	
		// update the menu caption
		foreach index in 1 to form.menuItemCount do
			tmpMenu := form.menuItems(index);
			if tmpMenu.isSeparatorJMT() or tmpMenu.name = null then
				continue;
			endif;
			//write form.name &amp; Tab &amp; tmpMenu.getPropertyValue('name').String &amp; Tab &amp; "caption";
			if tmpMenu.name = controlName then
				app.log("Updating " &amp; form.name &amp; ", " &amp; tmpMenu.getPropertyValue('name').String &amp; ", caption");
				tmpMenu.setPropertyValue('caption', text);
				break;
			endif;
		endforeach;
	
		form._clearFormBuildData();
		
		app.unlock(form);
		
	endforeach;
	
	commitTransaction;
	
epilog

	if process.isInTransactionState then
		abortTransaction;
	endif;
	
	

end;</source>
    </JadeMethod>
    <JadeMethod name="updateLSconstantsFormFromTable" id="52491ad0-f4cd-4ae8-b884-1078ba0eec94">
        <source>updateLSconstantsFormFromTable();

/*

Purpose:		Read through the table seeing if anything has changed and update accordingly

				Changes to LSconstant will be handled when the method is regenerated.
				Changes to the form will be handled immediately

Date			Who		Reason
26/01/2011		cnwmh5	Initial creation

*/

vars

	jdo							: JadeDynamicObject;
	lsConstant					: LSconstant;

	row 						: Integer;
	constantText				: String;
	constantName				: String;
	commentedOut				: String;

begin

	self.staMain.caption := "Getting translateForm method changes...";
	self.doWindowEvents(0);

	// read through the rows and update lsConstant for non form changes and create dyna dict for form changes
	row := 2;
	self.dictFormChanges.clear();
	while row &lt;= self.tblDetails.rows do
	
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; self.tblDetails.getCellText(row, 1) &amp; Tab &amp; self.tblDetails.getCellText(row, 2) &amp; Tab &amp; 
			self.tblDetails.getCellText(row, 3) &amp; Tab &amp; self.tblDetails.getCellText(row, ColCommentOut).String &amp; Tab &amp; 
			self.tblDetails.getCellText(row, ColConstantName) &amp; Tab &amp; self.tblDetails.getCellText(row, ColFormText) &amp; Tab &amp; 	
			self.tblDetails.getCellText(row, ColConstantText), LogINFO);
		
		lsConstant := self.tblDetails.cnEcGetCellObject(row, ColConstantName).LSconstant;
		if lsConstant &lt;&gt; null then
			
			commentedOut := self.tblDetails.getCellText(row, ColCommentOut).String;
			constantName := self.tblDetails.getCellText(row, ColConstantName);
			constantText := self.tblDetails.getCellText(row, ColConstantText);
		
			if commentedOut &lt;&gt; lsConstant.isCommentedOut.String then
				if commentedOut = "1" then
					lsConstant.isCommentedOut := true;
				else
					lsConstant.isCommentedOut := false;
				endif;
			endif;
			if lsConstant.name = null and constantName &lt;&gt; null then
				lsConstant.name := constantName;
			endif;
			if self.tblDetails.getCellText(row, ColFormText) &lt;&gt; lsConstant.text then
				create jdo transient;
				jdo.addProperty("formName", String);
				jdo.setPropertyValue("formName", self.tblDetails.getCellText(row, 1));
				jdo.addProperty("controlName", String);
				jdo.setPropertyValue("controlName", self.tblDetails.getCellText(row, 2));
				jdo.addProperty("propertyType", String);
				jdo.setPropertyValue("propertyType", self.tblDetails.getCellText(row, 3));
				jdo.addProperty("formText", String);
				jdo.setPropertyValue("formText", self.tblDetails.getCellText(row, ColFormText));
				self.dictFormChanges.putAtKey(self.tblDetails.getCellText(row, 1), self.tblDetails.getCellText(row, 2), 
					self.tblDetails.getCellText(row, 3), jdo);
			endif;
			if self.tblDetails.getCellText(row, ColConstantText) = null then
				lsConstant.text := self.tblDetails.getCellText(row, ColFormText);
			endif;
			if constantText &lt;&gt; null then
				if constantText &lt;&gt; lsConstant.text then
					lsConstant.text := constantText;
				endif;
			endif;
			
		endif;
	
		row := row + 1;
		
	endwhile;

	// read through the changes to the form and update the forms details
	if not self.dictFormChanges.isEmpty() then
		//self.staMain.caption := "Updating control caption / bubbleHelp / constant text.  Please wait...";
		self.staMain.caption := "Updating control caption / bubbleHelp / constant text.  Please wait...";
		self.doWindowEvents(0);
		self.updateFormChanges();
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateTableRowDetails" id="aa23044a-7d28-42ff-8f03-b5aad0b06f94">
        <source>updateTableRowDetails();

/*

Purpose:			

Date			Who		Reason
27 January 2012	cnwmh5	Initial creation

*/

vars

	constantObj					: LSconstant;
	tableRow					: JadeTableRow;
	tableColumn					: JadeTableColumn;

	backGroundColour			: Integer;
	commentedOut				: Boolean;
	formText					: String;
	constantText				: String;

begin

	if self.tblDetails.row = 1 then
		return;
	endif;

	// get the values from the current row
	tableRow := self.tblDetails.accessRow(self.tblDetails.row);
	backGroundColour := tableRow.backColor;
	commentedOut := self.tblDetails.getCellText(tableRow.row, ColCommentOut).Boolean;
	formText := self.tblDetails.getCellText(tableRow.row, ColFormText).String;
	constantText :=  self.tblDetails.getCellText(tableRow.row, ColConstantText).String;
	constantObj := self.tblDetails.cnEcGetCellObject(tableRow.row, ColConstantName).LSconstant;
	
	// check to see if form text has changed and whether still different
	if self.tblDetails.column = ColFormText then
		if constantObj &lt;&gt; null and  constantObj.text &lt;&gt; formText then
			if formText &lt;&gt; constantText then
				backGroundColour := self.RowColourDiffText;
			endif;
		endif;
	endif;
	
	// check to see if constant text has changed and whether still different
	if self.tblDetails.column = ColConstantText then
		if constantObj &lt;&gt; null and  constantObj.text &lt;&gt; constantText then
			if formText &lt;&gt; constantText then
				backGroundColour := self.RowColourDiffText;
			endif;
		endif;
	endif;
	
	// update the background colour
	tableRow.backColor := backGroundColour;
	
epilog

end;</source>
    </JadeMethod>
</GUIClass>
