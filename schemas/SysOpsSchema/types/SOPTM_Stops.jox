    <JadeMethod name="doDelete" id="0ab9697b-aa67-4846-a35b-15a2776bd1bf">
        <updating/>
        <source>doDelete(pObj: CM_Object io) updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	result : Integer;
begin

	while true do
		app.myTrxDA.trxDeleteStopsTable(pObj.CM_StopsTable, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.myForm.clearErrorWarnings();
			break;
		else
			if app.myPassport.noErrors
			and app.myPassport.hasWarnings then
				//only do this if no error and has warnings - other combinations handled by the form - only way to handle warning at the moment
				result := app.showErrorWarningDialog('Delete', app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
					result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			else
				//the form doDelete will handle it
			endif;
		endif;
		break;
	endwhile;

end;</source>
        <Parameter name="pObj" type="CM_Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doEditStopTableTemplate" id="e2821dfe-ddc9-4a2c-9e37-30d473b2406d">
        <source>doEditStopTableTemplate();
//ccms1824 cnwrs1 may 2009

vars
	theForm					: SOP_TableMaintForm;
	stopTableTemplateForm 	: SOP_StopTableTerminalForm;
	obj						: Object;
	terminal 				: CM_Terminal;
	stopsTable				: CM_StopsTable;
	
	selectedTypes 			: CM_CargoBOLTypeArray;		//cnwmc5 - 11 April 2014 - CCMS 2532
begin
	theForm := self.myForm;
	if theForm.myProxyObject = null and		// editing
		theForm.myCurrentObject = null then // selected
		return;
	endif;
	// what do we have selected
	obj := theForm.tblData1.accessRow (theForm.tblData1.row).itemObject;			// par 19830 concms1 june 2009
	if( obj = null) then	 					// par 19830 concms1 june 2009	
		return;									// par 19830 concms1 june 2009
	else										// par 19830 concms1 june 2009
		terminal := obj.CM_Terminal;			// par 19830 concms1 june 2009
	endif;										// par 19830 concms1 june 2009
	
	stopTableTemplateForm := app.loadForm(SOP_StopTableTerminalForm, theForm.myAssistant.class, false, false ,true ,self.myForm.myTerminal, null).SOP_StopTableTerminalForm;
	
	if stopTableTemplateForm = null then
		return;
	endif;
	
	//cnwmc5 - 11 April 2014 - CCMS 2532
	create selectedTypes transient;						//cnwmc5 - 11 April 2014 - CCMS 2532
	theForm.mulSelect1.getSelected(selectedTypes);		//cnwmc5 - 11 April 2014 - CCMS 2532
	
	if theForm.myProxyObject &lt;&gt; null then
		stopsTable := theForm.myProxyObject.CM_StopsTable;
		
		stopTableTemplateForm.init(SOP_StopTableTerminalForm.Mode_Update, stopsTable, terminal, selectedTypes);		//cnwmc5 - 11 April 2014 - CCMS 2532
	else
		stopsTable := theForm.myCurrentObject.CM_StopsTable;
		
		stopTableTemplateForm.init(SOP_StopTableTerminalForm.Mode_View, stopsTable, terminal, selectedTypes);		//cnwmc5 - 11 April 2014 - CCMS 2532
	endif;
	
	stopTableTemplateForm.showModal;
	
	if stopTableTemplateForm.modalResult = IDOK then
		// redisplay stop table terminals sheet
		self.showThumbnail_Terminal (stopsTable);
	endif;
epilog
	//cnwmc5 - 11 April 2014 - CCMS 2532
	delete selectedTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="15ed3609-64bb-47d3-8d6d-b4b1335e7b60">
        <source>doResize();
//
// Aug 2007 cnwrs1 CCMS 1017
//
vars
	theForm : SOP_TableMaintForm;
begin
	inheritMethod();
	theForm 		:= self.myForm;
		
	theForm.tblData1.columnWidth[2] := theForm.tblData1.clientWidth - theForm.tblData1.columnWidth[1];	// par 19830 concms1 june 2009
end;
</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="9462840f-f467-4369-b0ec-5dfb1d326d77">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//ccms1824 cnwrs1 may 2009
// 08/12/2009	cnwrl1		PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Clearance Expiry Date
// 06/11/2023	navkc1 		Bug 61094: FR | EUP VBS Criteria , Stops Criteria , Delivery Party Address
// ---------------------------------------------------------------------------

vars

	proxyStopTable			: CM_StopsTable;
	theForm 				: SOP_TableMaintForm;
	rtnValue				: Boolean;
	selectedTypes 			: CM_CargoBOLTypeSet;
	requiresInfoType		: Integer;
	tmpJadeCode				: String; //ccms 1093
	
begin
	theForm := self.myForm;

	if theForm.mode = theForm.Mode_Add and 
		theForm.myProxyObject = null	// // 06/11/2023	navkc1 Bug 61094 - If the user defined Stop criteria, it would have already created a proxy
			then
		create theForm.myProxyObject as CM_StopsTable transient;
	endif;
	
	proxyStopTable := theForm.myProxyObject.CM_StopsTable;
	
	create selectedTypes transient;
	theForm.mulSelect1.getSelected(selectedTypes);
	if theForm.cmbCustomEntry.listIndex &gt; 0 then
		requiresInfoType := theForm.cmbCustomEntry.itemData[theForm.cmbCustomEntry.listIndex].Integer;
	endif;

	tmpJadeCode := self.jadeCode;
	
	// cnwrl1 08/12/2009 PAR 21889 - start of coding
	proxyStopTable.setProxy(	theForm.tblInput1.getValueByName(ETRow_RequiresInfo).Boolean, 
								theForm.tblInput1.getValueByName(ETRow_Code).String,
								theForm.tblInput1.getValueByName(ETRow_Heading).String,
								theForm.tblInput1.getValueByName(ETRow_ShortHeading).String,
								requiresInfoType,
								theForm.tblInput1.getValueByName(ETRow_Id).Integer,
								selectedTypes,
								theForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean,
								theForm.tblInput1.getValueByName(ETRow_AllowClearanceExpiryDate).Boolean,
								app.myRoot,
								tmpJadeCode,
								app.myPassport.userCode,
								theForm.tblInput1.getValueByName(ETRow_ExcludedForPinGeneration).Boolean	// ### TFS 61382 (61534) 01Dec2023 NAVPW1
								);
	
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateStopsTable(proxyStopTable, theForm.myCurrentObject, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateStopsTable(proxyStopTable, app.myPassport);
		rtnValue := app.myPassport.trxCompletedOK;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return rtnValue;
epilog
	delete selectedTypes;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowObjectCriteriaLineForm" id="7d823ea7-b261-4e26-93a1-d780f5abf2e3">
        <source>doShowObjectCriteriaLineForm(_stop : CM_StopsTable);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
06/11/2023		navkc1 Bug 61094: FR | EUP VBS Criteria , Stops Criteria , Delivery Party Address
*/

vars

	pxyObjMatchCriteria : CM_StopCriteria;
	form : CMUI_ObjectCriteriaLineForm;
	str : String;
	contObj : CM_StopsTable;
	table :CM_EntryTable;
	terminals:	CM_TerminalSet;
	criteria : CM_YACriteria;
begin

	create form;
	
	contObj := self.myForm.myProxyObject.CM_StopsTable;
	
	// 06/11/2023	navkc1 Bug 61094 - In ADD mode, there won't be a Stop proxy object yet, create it now
	if contObj = null then
		create self.myForm.myProxyObject as CM_StopsTable transient;
		contObj := self.myForm.myProxyObject.CM_StopsTable;
	endif;
	
	pxyObjMatchCriteria := contObj.myStopCriteria;
	
	// 06/11/2023	navkc1 Bug 61094 - In ADD mode, there won't be a Stop Criteria proxy object yet, create it now
	if pxyObjMatchCriteria = null then
		create pxyObjMatchCriteria transient;
		pxyObjMatchCriteria.setMyStopTable(contObj);
	endif;
	
	form.setMyTerminal(self.myForm.myTerminal);

	form.setBaseData(	CM_ObjectMatchCriteria.StopCriteriaInt,	//_context : Integer;
						contObj,	//_contextObj : CM_Object;
						pxyObjMatchCriteria,	//_myObjectMatchCriteria : CM_ObjectMatchCriteria;
						null,	//_myListForm : CMUI_ObjectCriteriaListForm
						self.myForm	//_myParentForm: CM_BaseForm
					);
					
	form.showModal();
	
	// 06/11/2023	navkc1 Bug 61094
	//str := self.myForm.tblDataDisplayRow(self.myForm.tblData, self.myForm.myCurrentObject);
	str := self.myForm.tblDataDisplayRow(self.myForm.tblData, contObj);
	self.myForm.tblData.setCellText( self.myForm.tblData.row, 1, str );
	self.myForm.tblInput1.setValueByName(ETRow_SetCriteria, contObj.getStopCritDisp()); // 06/11/2023	navkc1 Bug 61094 - Update the Criteria row

epilog

end;</source>
        <Parameter name="_stop" type="CM_StopsTable"/>
    </JadeMethod>
    <JadeMethod name="doTblData1Click" id="7da593e8-1672-4424-ba6d-761fc28e9bcf">
        <source>doTblData1Click();
// ---------------------------------------------------------------------------
// Created:     05 June 2009 by concms1
// Purpose:     Par 19830 - enable/disable edit button depending on what is selected 
//				in the table
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form		:SOP_TableMaintForm;
	obj			:Object;
	table		:CM_DataTable;
	button		:Button;
	terminal	:CM_Terminal;
begin 
	form	:= self.myForm;
	table	:= form.tblData1;
	button	:= form.btnDT1_Edit;
	
	if table.row &gt; table.fixedRows then
		obj		:= table.accessRow (table.row).itemObject;
	endif;
	
	if obj = null then
		button.enabled	:= false;
		return;
	endif;
	
	if form.mode = form.Mode_Update or form.mode = form.Mode_Add then
		button.enabled := true;
		return;
	endif;
	// we are in view mode - can only view an item that has been setup
	if form.myCurrentObject = null then
		button.enabled := false;
		return;
	endif;
	terminal := obj.CM_Terminal;
	
	if form.myCurrentObject.CM_StopsTable.getTemplateForTerminal(terminal) &lt;&gt; null then
		button.enabled := true;
		return;
	endif;
	
	button.enabled := false;
epilog

end;</source>
    </JadeMethod>
