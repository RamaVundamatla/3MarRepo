    <JadeMethod name="setApplicationSkinByName" id="addde7a4-3d5d-4be8-ba52-24d1ffcbd30d">
        <source>setApplicationSkinByName(pName : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2023	navpw1	Initial creation

*/

vars
	jsr				: JadeSkinRoot;
	jadeSkinsColl	: JadeSkinsColl;
	jsa				: JadeSkinApplication;
	platform		: Integer;
	version			: String;
	architecture	: Integer;
	
begin

	jsr := JadeSkinRoot.firstInstance;
	if jsr = null then
		return;
	endif;
	
	//par13850 Mohammad 10/4/2007
	platform	:=	process.getOSPlatform(version, architecture);
	if platform.bitAnd(Node.OSWindows) &lt;&gt; 0 and platform = Node.OSWindowsHome then
		// Operating System is the Windows 95 or Windows 98
		app.writeLog('Operating system version ' &amp; platform.String &amp; 
				' (Windows ' &amp; version &amp; ') - Skins not set', LogINFO);
		return;
	endif;
	
	jsa := jsr.allApplicationSkins[pName];
	
	if jsa = null then
		// jadeSkin not found
		app.msgBox('skin ' &amp; pName &amp; ' not found ', '', 0);
		return;
	endif;

	app.setApplicationSkin(jsa);
	
end;</source>
        <Parameter name="pName" type="String"/>
    </JadeMethod>
