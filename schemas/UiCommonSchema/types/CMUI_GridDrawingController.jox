<Class name="CMUI_GridDrawingController" id="faf86441-f35b-45f4-b722-a5a3998672e5">
    <superclass name="CMUI_Transient"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>
This is really the "cell" at the intersection of its row and 
column.  The term "cell" is not used because it has special 
(and different) meaning for Bay Defs.</text>
