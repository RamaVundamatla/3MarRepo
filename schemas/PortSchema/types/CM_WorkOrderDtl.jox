    <JadeMethod name="getExtraInfo" id="444d5ac9-61ed-4f14-8480-08043fbbb007">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:		TFS 39718	

Parameters:			

Return Value:		

Date		Who		Reason
13 Jul 2018	jlgab1	Initial creation
16 Mar 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
*/

vars
	block   : CM_DataContainerBlock;
	addStr  : String;
	trans   : CM_WOTransaction;
begin
	
	inheritMethod(_dataContainer);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(self.getDisplayString(true), DC_MoreInfo, 1, self);

	block.addNewItem('Task Id', DC_Label, 1, self);
	block.addNewItem(self.taskID, DC_Data, 1, self);
	
	if app.isSpecial then														//08.02.2023 navma1 #56457:[56458]
		block := _dataContainer.addNewBlock;
		block.addNewItem('Task Status', DC_Label, 1, self);
		block.addNewItem(app.workOrderStatusEnumToString(self.status), DC_Data, 1, self);
		
		foreach trans in self.allWODtlTransactions do
			addStr := addStr &amp; Cr &amp; trans.getTranTypeString();
		endforeach;
		
		if addStr &lt;&gt; null then
			block.addNewItem('Transaction details ', DC_Label, 1, self);
			block.addNewItem(addStr, DC_Data, 1, self);
		endif;
		
	endif;
	if not self.allJobSheets.isEmpty then
		block.addNewItem('Job Sheets', DC_Label, 1, self);
		block.addNewItem(self.allJobSheets.listString(Comma,CM_JobSheet::externalName.name), DC_Data, 1, self);
	endif;
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
