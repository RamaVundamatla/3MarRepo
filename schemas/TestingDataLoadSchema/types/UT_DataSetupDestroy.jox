    <JadeMethod name="processSystemEDIDataXlations" id="b5f92913-1a87-496d-ad1b-fe576d49498b">
        <source>processSystemEDIDataXlations(_ediXlationXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the EDI data translation

Date			Who		Reason
29/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	code					: String;
	foreignDefault			: Boolean;
	xlationTableType		: String;
	operator				: String;
	
begin

	varsStr := 'operator			: CM_Operator;' &amp; CrLf;
	codeStr := CrLf;

	foreach obj in _ediXlationXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		code := self.returnElementText(xmlElement.getElementByTagName('code')).String;
		code.cnReplaceString('"', '');
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		description.cnReplaceString('"', '');
		foreignDefault := self.returnElementText(xmlElement.getElementByTagName('foreignDefault')).Boolean;
		xlationTableType := self.returnElementText(xmlElement.getElementByTagName('xlationTableType')).String;
		xlationTableType.cnReplaceString('"', '');
		//if xlationTableType = null then
		//	xlationTableType := "XLATION_TYPE_OPERATOR";
		//endif;
		//operator := self.returnElementText(xmlElement.getElementByTagName('operator')).String;
		//if operator &lt;&gt; null then
		//	codeStr := codeStr &amp; Tab &amp; 'operator := app.myRoot.allOperators[' &amp; operator &amp; '];' &amp; CrLf &amp; CrLf;
		//endif;
		
		optsElement := xmlElement.getElementByTagName('opts');
		self.setupOptsAssoc(optsElement, codeStr);
		if xlationTableType &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("XlationTableType", ' &amp; xlationTableType &amp; ');' &amp; CrLf;
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addEDIDataTranslation("' &amp; code &amp; '", "' &amp; description &amp; '", ' &amp; foreignDefault.String &amp; ');' &amp; CrLf;
		
	//	self.addEDIDataTranslation(
		
		
		//codeStr := codeStr &amp; Tab &amp; 'self.addEDIXlation("' &amp; code &amp; '", "' &amp; description &amp; '", ' &amp; xlationTableType &amp; Tab &amp; 
		//	', null, operator, false, ' &amp; foreignDefault.String &amp; ');' &amp; CrLf; 
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_ediXlationXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemEDIUpdates" id="32c4bbfa-e90a-4b11-a57f-34032a80b165">
        <source>processSystemEDIUpdates();

/*

Purpose:		Update the EDI file format

Date			Who		Reason
06/12/2011		cnwmh5	Initial creation

*/

vars
	
	fileFormatEDIXML		: CM_FileFormatEDIXML;
	fileFormatEDICSV		: CM_FileFormatEDICSV;
	operator				: CM_Operator;
	ediFileType				: CM_EDIFileType;
	
begin

	beginTransaction;
	foreach fileFormatEDICSV in CM_FileFormatEDICSV.instances do
		if fileFormatEDICSV.operatorCode &lt;&gt; null then
			operator := app.myRoot.allOperators[fileFormatEDICSV.operatorCode];
			fileFormatEDICSV.setPropertyValue("myOperator", operator);
		endif;
	endforeach;
	commitTransaction;
	
	beginTransaction;
	foreach fileFormatEDIXML in CM_FileFormatEDIXML.instances do
		if fileFormatEDIXML.operatorCode &lt;&gt; null then
			operator := app.myRoot.allOperators[fileFormatEDIXML.operatorCode];
			fileFormatEDIXML.setPropertyValue("myOperator", operator);
		endif;
	endforeach;
	commitTransaction;
	
	beginTransaction;
	foreach ediFileType in app.myRoot.allEDIFileTypes do
		if ediFileType.type = EDIFileType_CusRes then
			ediFileType.setPropertyValue('name', 'Customs Response');
			break;
		endif;
	endforeach;
	commitTransaction;	
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="processSystemEmailAddresses" id="5f229cbb-67f1-4e39-ab28-da72b74c692c">
        <source>processSystemEmailAddresses(_emailAddressXMLElement : JadeXMLElement; _methodStr : String io);

