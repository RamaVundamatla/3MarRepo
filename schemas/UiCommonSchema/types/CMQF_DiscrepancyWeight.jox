vars

begin
	inheritMethod(_agent);
	
	if _agent.isRowIncluded(ETRow_IMEXStatuses) then
		_agent.getSelectedIMEXStatuses(self.allIMEXStatusCodes);
	endif;
epilog
end;</source>
