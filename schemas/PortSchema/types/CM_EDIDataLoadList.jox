    <JadeMethod name="setPreNoteInterfaceObject" id="f0f90126-e49b-4c4b-9ab1-a34388bb5452">
        <source>setPreNoteInterfaceObject(_ediTI : CM_EDILoadListTI; _doNotGeneratePin : Boolean) : CMIF_PreNote;
// --------------------------------------------------------------------------------
// Created:		3 August 2009 by cnwjo3
//
// Purpose:		set the interface object for a new prenote.
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
// 18 Jun 2012	cnwrs1	Par 31625 DPH Load list changes
// 06 Jul 2017	jlgrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 30 Aug 2017	jlgrs1	TFS 6797 SNO SpecialStow
// 01 Dec 2022	jlika1	TFS 55586 	HS Code User Defined EDI
//05 April 2023	navpw1	TFS: 56707 (56712) - Added extra critiera for a booking item to match against
//01 Aug 2025   navsp1  JIRA-35530 Solution Implementation - COPRAR Trailer Support
vars
	ifObj			: CMIF_PreNote;
	
	cargoType		: CM_CargoType;
	isoType			: CM_ISOType;
	tmpBookingRef	: CM_BookingRef;
	
//	ff				: CM_ConsigneeConsignor;
	commodityCode 	: String;
	tempCommodity	: CM_Commodity;
	tmpHazards : ObjectArray;
	specialStowObj : CM_SpecialStow;
	reason			: String; //05/04/2024	navkc1 Bug 63509
begin
	create ifObj transient;

	ifObj.setUserDetails(_ediTI);
	
	ifObj.transportMode := TI_TRANSMODE_ROAD_STR;
	
	ifObj.operatorCode := _ediTI.operatorCode;
	ifObj.isEDI := true;
	if _ediTI.imCodes.size &gt; 0 then
//		ifObj.setHazardsFromEDI(_ediTI.imCodes);
		create tmpHazards transient;
		_ediTI.getProxyHazards(_ediTI.imCodes, tmpHazards, false);
		tmpHazards.copy(ifObj.allTIHazards);
	endif;
	
	ifObj.billOfLading := _ediTI.bol;
	ifObj.bookingReference := _ediTI.bookingRef.toUpper();
	tmpBookingRef := self.getMyTerminal.getBookingReferenceLatest(_ediTI.operatorCode, _ediTI.bookingRef); // adm 150908 Par 17936
	if tmpBookingRef &lt;&gt; null then
		if ifObj.myBookingRefItem = null then
			if _ediTI.cargoType &lt;&gt; null then
				cargoType := app.myRoot.allCargoTypesById[_ediTI.cargoType];
			endif;
			if _ediTI.isoType &lt;&gt; null then
				isoType := app.myRoot.allISOTypes[_ediTI.isoType];
			endif;
			ifObj.myBookingRefItem := tmpBookingRef.getMatchingItem(cargoType,commodityCode,isoType,null, null, null, null, null, null, reason); // ### TFS 56707 (56712) 05Apr2023 NAVPW1
		endif;
	endif;	
	
	ifObj.cargoType := _ediTI.cargoType;
	ifObj.carriageTempC := _ediTI.temperature;
	ifObj.commodity := self.findCommodityCode(_ediTI);
	ifObj.consigneeCode := _ediTI.translateConsigneeCode(_ediTI.consignee);
	ifObj.consignorCode := _ediTI.translateConsigneeCode(_ediTI.consignor);

	ifObj.description	:= _ediTI.description;
	ifObj.destinationPort := _ediTI.translatePortCode(_ediTI.destinationPort);
	ifObj.dischargePort := _ediTI.translatePortCode(_ediTI.dischargePort);
	if ifObj.dischargePort = null then
		ifObj.dischargePort := "****";
	endif;
	ifObj.freightForwarderCode := _ediTI.translateConsigneeCode(_ediTI.freightForwarder);
	ifObj.myTranshipToPort	:= app.myRoot.allPorts[_ediTI.translatePortCode(_ediTI.myTranshipToPort)];
	ifObj.height := _ediTI.height;
	ifObj.id := _ediTI.id[1:20];
	ifObj.isoType := _ediTI.isoType;
	ifObj.trailerType := _ediTI.trailerType;    //JIRA-35530
	// 08/10/2012 cnwar2 #30399 - always create loadlist prenotes as export
	/*if _ediTI.fullOrMT = "E" then
		ifObj.imExStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_STORAGE];
		ifObj.statusString := "Storage";
	else*/
	ifObj.imExStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	ifObj.statusString := "Export";
	//endif;
	

	ifObj.length := _ediTI.length;

	ifObj.loadPort := _ediTI.translatePortCode(_ediTI.loadPort);
	ifObj.quantity := 1;
	ifObj.receiptTransportMode := TI_TRANSMODE_ROAD;
	//ifObj.sealNum := _ediTI.sealNum;
	//ifObj.setSealNum(_ediTI.sealNum);	//20 Sep 2010	NDL	Par 25608
	ifObj.setSealNum(_ediTI.sealNum);	//01 Sep 2011	NDL	 moved down Par 28071
	ifObj.setSealNumVent(_ediTI.sealNumberVent);
	ifObj.setSealNumCustoms(_ediTI.sealCustoms);
	ifObj.setSealNumShippers(_ediTI.sealShipper);
	ifObj.setSealNumTerminalOperator(_ediTI.sealTerminalOperator);
	ifObj.setSealNumUnknown(_ediTI.sealUnknown);

	ifObj.voyageCode := _ediTI.myEDIData.CM_EDIDataLoadList.voyageCode;

	ifObj.weightTotal := _ediTI.weight;
	ifObj.width := _ediTI.width;
	ifObj.setHumidity( _ediTI.getHumidity );
	ifObj.ventilation := _ediTI.vent;
	ifObj.setOxygen( _ediTI.getOxygen );
	ifObj.setCarbonDioxide( _ediTI.getCarbonDioxide );
	ifObj.curtainsIn := _ediTI.curtainsIn;
	ifObj.noPinRequired := _doNotGeneratePin;

//	ifObj.sealNumCustoms := _ediTI.sealNum;  //this may be incorrect

	if app.isSubTerminalsOn(self.getMyTerminal) then
		ifObj.mySubTerminal		:=	self.getMyTerminal.allSubTerminals[_ediTI.subTerminalCode];
		ifObj.subTerminalCode	:=	_ediTI.subTerminalCode;
	endif;
	specialStowObj := app.myRoot.allSpecialStows[_ediTI.specialStowage];
	if specialStowObj &lt;&gt; null then
		ifObj.specialStow := specialStowObj.code;
	endif;
	//jlika1 TFS 55586
	ifObj.hsCode := _ediTI.hsCode;
	
	return ifObj;
epilog
	delete tmpHazards;
end;</source>
        <Parameter name="_ediTI" type="CM_EDILoadListTI"/>
        <Parameter name="_doNotGeneratePin" type="Boolean"/>
        <ReturnType type="CMIF_PreNote"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromCMIF" id="877f3d27-d0c8-47da-8c18-6d873ea0b492">
        <updating/>
        <source>setPxyFromCMIF(_params: CMIF_EDIDataDetails) updating;
//----------------------------------------------------------------
//	Created:	22 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(_params);
	self.voyageCode := _params.voyage;
	self.listType := _params.listType;
epilog

end;</source>
        <Parameter name="_params" type="CMIF_EDIDataDetails"/>
    </JadeMethod>
    <JadeMethod name="setTBAInterfaceObject" id="a75425ea-7d6d-4d86-a703-1c0dcdb3bda1">
        <source>setTBAInterfaceObject(_ediTI: CM_EDILoadListTI): CMIF_TBACargo;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2019	jlgmp6	Initial creation	TFS 45590

*/

vars
	tba: CMIF_TBACargo;
	terminal: CM_Terminal;
	voyage: CM_Voyage;
	commodity: CM_Commodity;
	
begin
	if _ediTI = null then
		return null;
	endif;

	create tba transient;

	terminal := self.getMyTerminal();
	voyage := self.getVoyageFromCode(_ediTI.myEDIData.CM_EDIDataLoadList.voyageCode);
	commodity := app.myRoot.allCommodities[_ediTI.commodity];

	tba.cargoType := TI_CargoType_Container;
	tba.transportMode := "Unknown";

	tba.id := _ediTI.id;
	tba.isEDI := true;
	tba.imExStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	tba.statusString := "Export";
	tba.operatorCode := _ediTI.operatorCode;
	tba.myTerminal := terminal;
	if app.isSubTerminalsOn(terminal) then
		tba.mySubTerminal := terminal.allSubTerminals[_ediTI.subTerminalCode];
		tba.subTerminalCode := _ediTI.subTerminalCode;
	endif;
	tba.isoType := _ediTI.isoType;
	tba.height := _ediTI.height.Integer;
	tba.width := _ediTI.width.Integer;
	tba.length := _ediTI.length.Integer;
	tba.weight := _ediTI.weight.Integer;
	tba.weightTotal := _ediTI.weight.Integer;
	tba.destinationPort := _ediTI.translatePortCode(_ediTI.destinationPort);
	tba.dischargePort := _ediTI.translatePortCode(_ediTI.dischargePort);
	tba.voyageCode := _ediTI.myEDIData.CM_EDIDataLoadList.voyageCode;
	tba.commodity := self.findCommodityCode(_ediTI);
	
	
	// TFS 47733 all the following were missed out
	if commodity &lt;&gt; null 
	and commodity.requiresPower then
		tba.setCarbonDioxide( _ediTI.getCarbonDioxide.max(0) ); // Minimum Zero EDI is defaulting to -1!!!?
		tba.setHumidity( _ediTI.getHumidity.max(0) ); // Minimum Zero EDI is defaulting to -1!!!?
		tba.ventilation := _ediTI.vent;
		tba.hasCoolingWaterConnection := _ediTI.isWaterCooled;
		tba.setOxygen( _ediTI.getOxygen.max(0) ); // Minimum Zero EDI is defaulting to -1!!!?
		tba.carriageTempC := _ediTI.temperature;
	
	endif;
	
	tba.bookingReference := _ediTI.bookingRef;
	tba.billOfLading := _ediTI.bol;
	tba.consigneeCode := _ediTI.consignee;
	tba.consignorCode := _ediTI.consignor;
	tba.curtainsIn := _ediTI.curtainsIn;
	tba.freightForwarderCode := _ediTI.freightForwarder;
	tba.isWeightCertified := _ediTI.isWeightCertified;
	tba.loadPort := _ediTI.loadPort;
	tba.overHeight := _ediTI.overHeight.max(0); // Minimum Zero EDI is defaulting to -1!!!?
	tba.overLengthFront := _ediTI.overLengthFront.max(0); // Minimum Zero EDI is defaulting to -1!!!?
	tba.overLengthRear := _ediTI.overLengthBack.max(0); // Minimum Zero EDI is defaulting to -1!!!?
	tba.overWidthLeft := _ediTI.overWidthLeft.max(0); // Minimum Zero EDI is defaulting to -1!!!?
	tba.overWidthRight := _ediTI.overWidthRight.max(0); // Minimum Zero EDI is defaulting to -1!!!?
	tba.shippingReference := _ediTI.shipperDesc;
	tba.specialStow := _ediTI.specialStowage;
	tba.weightCertifiedName := _ediTI.weightCertifiedName;
	tba.weightCertifiedReference := _ediTI.weightCertifiedReference;
	tba.hsCode := _ediTI.hsCode; // jlika1 TFS 8856
	
	return tba;
epilog

end;</source>
        <Parameter name="_ediTI" type="CM_EDILoadListTI"/>
        <ReturnType type="CMIF_TBACargo"/>
    </JadeMethod>
    <JadeMethod name="setVesselName" id="9c729129-6b42-4f53-b444-64f5bc63827c">
        <updating/>
        <source>setVesselName(_strVessel: String) updating;
//----------------------------------------------------------------
//	Created:	24 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.vesselName := _strVessel;
end;</source>
        <Parameter name="_strVessel" type="String"/>
    </JadeMethod>
    <JadeMethod name="setVoyageCode" id="625fff73-5030-4280-970b-18bded9d3ff4">
        <updating/>
        <source>setVoyageCode(_voyCode: String) updating;
//----------------------------------------------------------------
//	Created:	22 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.voyageCode &lt;&gt; _voyCode then
		self.voyageCode := _voyCode;
	endif;
epilog

end;</source>
        <Parameter name="_voyCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIData" id="cd8e4d88-ec07-4d05-85bf-efa95d597934">
        <updating/>
        <source>verifyEDIData(): Integer updating;
//----------------------------------------------------------------
//	Created:	22 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 06/08/2012	cnwcs5	par 30136 - EDI BGP Split
vars
	voyage 		: CM_Voyage;
begin
	
	on Exception do validationExceptionHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	
	//epr par 37090 23/10/15 CCMS 2538 EDI Admin Improvements
	voyage:=self.getVoyageFromCode(self.voyageCode);
	if voyage &lt;&gt; null and voyage.hasDeparted  and  self.getMyTerminal.getConfig(EdiAddVoyageDepartError).Boolean then
		app.raiseCMException1(Voyage_departed,voyageCode,"Voyage Code", self);
	endif;

epilog
	
	return app.myPassport.allErrorWarnings.size;
end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIDataTIs" id="e3a7fc54-69ce-4c7e-90a0-b52fe553b8fc">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
//----------------------------------------------------------------
//	Created:	22 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
05 Jul 2017	jlgrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
19 Jul 2024	navdap1	CR 64619/Task 64654 NSW - EDI Ops Comparison List Type and Choose Voyage
18 Jul 2025 navlc30 JIRA 35294 - 34575.002 - Incorrect Operator Displayed in Warning When Load/Discharge List Loaded After Some Cargo Items Completed
============================================================================*/

vars
	proxyContainer				: CM_TrackedItem;
	ediTI, lastEDI				: CM_EDITrackedItem;
	updCntrl					: CMIF_TIUpdateController;
	errorWarningLimit			: Integer;
	terminal					: CM_Terminal;
	totalTIs, tiCount			: Integer;
	passport					: CM_Passport;
	transhipVoyageCode 			: String;
	progressTS 					: TimeStamp;
	ediLoadList 				: CM_EDILoadListTI;
	allEDISealDetails 			: DynaDictionary;
	loadListTIs 				: CM_EDITIById;
	sealIter 					: Iterator;
	sealObj 					: CM_EDITrackedItem;
	voyage 						: CM_Voyage;									//navra1 - MTN-34830 - 23rd May 2025
	voyageProgress 				: CM_VoyageProgress;							//navra1 - MTN-34830 - 23rd May 2025
	moveType					: String;										//navra1 - MTN-34830 - 23rd May 2025
	moveTypeInteger				: Integer;										//navra1 - MTN-34830 - 23rd May 2025
	voyStage					: CM_VoyageStage;								//navra1 - MTN-34830 - 23rd May 2025
	errMsg 						: String;										//navra1 - MTN-34830 - 23rd May 2025
begin
	create allEDISealDetails transient;
	allEDISealDetails.setMembership(CM_EDISealTI);
	allEDISealDetails.addMemberKey( CM_EDISealTI::id.name, false, true ); 
	allEDISealDetails.endKeys(true);
	create loadListTIs transient;

	passport := _passport;

	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, app.myPassport);
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	terminal := self.getMyTerminal();
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, null, null, null);
	endif;
	
	errorWarningLimit := terminal.getConfig(EDIVerificationErrorLimit).Integer;
	
	app.setContinueCMExceptions(true);
	updCntrl := app.createTIUpdateControl(TI_UPDMODE_LOADLIST, null, null);

	totalTIs := self.allEDITrackedItems.size;
	self.updateProgress(progressTS, "Verifying cargo details", totalTIs, tiCount, true, passport);
	
	foreach ediTI in self.allEDITrackedItems do
		if ediTI.isEDISealDetails then
			allEDISealDetails.add(ediTI);
			continue;
		endif;
		ediLoadList := ediTI.CM_EDILoadListTI;
		if ediLoadList = null then
			continue;
		endif;
		loadListTIs.add(ediLoadList);
	endforeach;

	if not allEDISealDetails.isEmpty then
		sealIter := allEDISealDetails.createIterator;
		while sealIter.next(sealObj) do
			sealObj.CM_EDISealTI.sealEDITypeVerify;
			sealObj.CM_EDISealTI.sealEDINumVerify;
			if sealObj.myParent &lt;&gt; null then
				continue;
			endif;
			ediLoadList := loadListTIs[sealObj.id].CM_EDILoadListTI;
			if ediLoadList = null then
				continue;
			endif;
			app.myTrxUA.trxUpdateEDITIParent(sealObj, ediLoadList, _passport);
		endwhile;
		delete sealIter;
	endif;
	
	//navra1 - MTN-34830 - 23rd May 2025 - start
	if loadListTIs &lt;&gt; null and loadListTIs.size() &gt; 0 then
		if loadListTIs.first().myEDIData &lt;&gt; null then
			voyage := loadListTIs.first().myEDIData.getMyVoyageObject();
			if voyage &lt;&gt; null and voyage.isAutomaticProcess() then
				voyageProgress := voyage.myVoyageProgress;
				moveType := loadListTIs.first().myEDIData.CM_EDIDataLoadList.listType;
			endif;
		endif;
	endif;	
	//navra1 - MTN-34830 - 23rd May 2025 - end

	foreach ediTI in loadListTIs do
		ediLoadList := ediTI.CM_EDILoadListTI;
		tiCount := tiCount + 1;
		self.updateProgress(progressTS, "Verifying cargo details", totalTIs, tiCount, false, passport);
		
		//do our own isotype validation
		self.verifyISOType(ediLoadList);
		
		// TFS 64619 and our own load list type validation
		self.verifyListType(ediLoadList);
		
		//then the rest
		proxyContainer := self.getMyTerminal().createTI(ediLoadList.myCargoType, true);
		ediLoadList.setProxy(proxyContainer);
		updCntrl.setMyUserObject(ediLoadList);
		proxyContainer.validateTrackedItem(updCntrl, passport);
		
		ediLoadList.verifyObjectAvailableForEntry( proxyContainer.myConsignee );	//20 Sep 2021	NDL	TFS 51928
		
		delete proxyContainer;
		transhipVoyageCode := ediLoadList.getTranshipVoyageCode(); //cnwrs1 ccms 1137 16 july 2010 
		if transhipVoyageCode &lt;&gt; null then
			if self.getMyTerminal().lookupVoyage(transhipVoyageCode, null, false) = null then
				app.raiseCMWarning1(Tranship_voyage_code_invalid, transhipVoyageCode, ETRow_TranshipVoyageCode, self, self);
			endif;
		endif;
		if lastEDI &lt;&gt; null and lastEDI.id = ediLoadList.id then
			app.raiseCMException1(ERR_DUPLICATE_KEY, ediLoadList.id, 'id', ediLoadList);
		endif;		
		
		//navra1 - MTN-34830 - 23rd May 2025 - start
		if voyageProgress &lt;&gt; null then
			if moveType &lt;&gt; null then
				if moveType = 'D' then
					moveTypeInteger := CM_VoyageStage.Type_Discharge;
				elseif moveType = 'L' then
					moveTypeInteger := CM_VoyageStage.Type_Load;
				endif;
				
				voyStage := voyageProgress.getStageForOperator(CM_VoyageStage.VoyStage_InvoicePosted, ediLoadList.operatorCode, moveTypeInteger);
				
				if voyStage &lt;&gt; null then
					//errMsg := app.getErrorString3(Operat_already_fully_processed, operatorCode, voyage.code, voyStage.getTypeDescription());						//18.07.2025 navlc30 #35294
					errMsg := app.getErrorString3(Operat_already_fully_processed, ediLoadList.operatorCode, voyage.code, voyStage.getTypeDescription());			//18.07.2025 navlc30 #35294	
					ediLoadList.myEDIData.addWarningMessage(errMsg, ediLoadList, app.myPassport);					
					app.myPassport.addWarningFull(Operat_already_fully_processed, errMsg, null, ediLoadList, null);
				endif;
			endif;			
		endif;
		//navra1 - MTN-34830 - 23rd May 2025 - end
		
		lastEDI := ediLoadList;
	endforeach;
	
	self.updateProgress(progressTS, "Verifying cargo details", totalTIs, tiCount, true, passport);
	
	return passport.allErrorWarnings.size;

epilog
	delete loadListTIs;
	delete allEDISealDetails;
	delete sealIter;
	delete updCntrl;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyISOType" id="35efc639-55b1-461a-832b-4802d2b8ff9b">
        <source>verifyISOType(_ediTI: CM_EDILoadListTI);
//----------------------------------------------------------------
//	Created:	23 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	size		: String;
	type		: String;
	isoTypeCode	: String;
	isoTypeObj	: CM_ISOType;
begin
	isoTypeCode := _ediTI.isoType;
	//th2 CCMS 1547 - make warnings only - these are never turned into tracked items so let the users
	//see this data in load list comparison regardless of file content
	if isoTypeCode.length &lt; 4 then
		//app.raiseCMWarning3(ERR_INVALID_ISOTYPE, isoTypeCode, "EDI tracked item", _ediTI.id, 'isoType', _ediTI, _ediTI);
		// 16/02/2009 cnwar2 #18910 - Warnings no longer necessary
		return;
	endif;
	
	//see if we have it
	isoTypeObj := app.myRoot.allISOTypes[isoTypeCode];
	if isoTypeObj &lt;&gt; null then
		//that's enough 
		return;
	endif;
	
	size := isoTypeCode[1:2];
	type := isoTypeCode[3:2];
	
	if size[1:1] &lt;&gt; "2" and size[1:1] &lt;&gt; "4" then
		app.raiseCMWarning3(ERR_INVALID_ISOTYPE, "size " &amp; size, "EDI tracked item", _ediTI.id, 'isoType', _ediTI, _ediTI);
		return;
	endif;
	
	if type &lt;&gt; FAN_TYPE and
	   type &lt;&gt; FLATRACK_TYPE and
	   type &lt;&gt; GENERAL_TYPE and
	   type &lt;&gt; HIGHCUBE_TYPE and
	   type &lt;&gt; HIGHREEF_TYPE and
	   type &lt;&gt; OPENSIDE_TYPE and
	   type &lt;&gt; OPENTOP_TYPE and
	   type &lt;&gt; PORTHOLE_TYPE and
	   type &lt;&gt; REEFER_TYPE and
	   type &lt;&gt; TANK_TYPE then
			app.raiseCMWarning3(ERR_INVALID_ISOTYPE, "type " &amp; isoTypeCode, "EDI tracked item", _ediTI.id, 'isoType', _ediTI, _ediTI);
		return;
	endif;
			
epilog

end;</source>
        <Parameter name="_ediTI" type="CM_EDILoadListTI"/>
    </JadeMethod>
    <JadeMethod name="verifyListType" id="a7ba53ef-c7a0-499f-8133-ab523d56b778">
        <source>verifyListType(_ediTI : CM_EDILoadListTI);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19 Jul 2024	navdap1		Initial creation CR 64619/Task 64654 NSW - EDI Ops Comparison List Type and Choose Voyage
//							and ChangeRequest 63839: NSW | OnePort - Uniqueness of Inward and External Code
//
vars
	vessel : CM_Vessel;
	terminal : CM_Terminal;
	voyage : CM_Voyage;

begin
	// if we don't have a load list type or a vessel code, nothing to do
	if self.listType = null or self.vesselName = null then
		return;
	endif;
	
	// find the voyage from the raw data voyage code - could be an inward or external code
	if _ediTI.rawDataVoyageCode &lt;&gt; self.voyageCode then
		vessel := app.myRoot.allVessels[self.vesselName];
		if vessel = null then		// No vessel? Nothing we can do here
			return;
		endif;
		terminal := app.myPassport.myTerminal;
		
		// Try inwards codes first
		voyage := terminal.allVoyagesByInwardCodeAuto[_ediTI.rawDataVoyageCode, vessel.code];
		if voyage = null then
			voyage := terminal.allVoyagesByInwardCode[_ediTI.rawDataVoyageCode];
		endif;
		// Found one, so list type should be "D"ischarge - complain if it's not
		if voyage &lt;&gt; null and self.listType &lt;&gt; "D" then
			app.raiseCMException(Load_Discharge_List_Conflict, null, null);
		endif;
		
		// Look for an external code match
		if voyage = null then
			voyage := terminal.allVoyagesByExtCodeAuto[_ediTI.rawDataVoyageCode, vessel.code];
			if voyage = null then
				voyage := terminal.allVoyagesByExternalCode[_ediTI.rawDataVoyageCode];
				
				// Found one? list type should be "L"oad - complain if it isn't
				if voyage &lt;&gt; null and self.listType &lt;&gt; "L" then
					app.raiseCMException(Load_Discharge_List_Conflict, null, null);
				endif;
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_ediTI" type="CM_EDILoadListTI"/>
    </JadeMethod>
    <JadeMethod name="warnOnDBLoad" id="1981c24f-aa53-4025-8523-eae3c4ac4714">
        <source>warnOnDBLoad(_message: String output; _flags: Integer output; _intCancel: Integer output);
//----------------------------------------------------------------
//	Created:	22 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	_message	:= app.getErrorString(ERR_DBLoadList);
	_flags		:= MsgBox_OK_Only + MsgBox_Information_Icon;
	_intCancel	:= MsgBox_Return_OK;
epilog

end;</source>
        <Parameter name="_message" type="String" usage="output"/>
        <Parameter name="_flags" type="Integer" usage="output"/>
        <Parameter name="_intCancel" type="Integer" usage="output"/>
    </JadeMethod>
</Class>
