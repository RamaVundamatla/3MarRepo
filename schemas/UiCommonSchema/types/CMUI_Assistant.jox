begin

	cmb := pCmb;

	cmb.addItem('');
	
	if pTemp &lt;&gt; NULL_TEMPERATURE then
		cmb.text := app.temperatureDisplayString(pTemp); //pTemp.userNumberFormat($CM_Temperature);	
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
