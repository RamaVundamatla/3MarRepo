    <JadeMethod name="addTrainToProcessing" id="f0c3b9b4-4783-4a90-a90a-2ef803b04e86">
        <source>addTrainToProcessing(_train: CM_Train): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

begin

	if not self.allTrainsToProcess.includes(_train) then
		self.allTrainsToProcess.add(_train);
		return true;
	endif;
	
	return false;
	
epilog

end;</source>
        <Parameter name="_train" type="CM_Train"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addVoyageToProcessing" id="eccc0c7b-3f44-4262-91cb-daef9a8fc2e3">
        <source>addVoyageToProcessing(_voyage: CM_Voyage; _originalVoyageCode : String): Boolean;
//----------------------------------------------------------------
//	Created:	15 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	//PAR24219
	//We first want to check whether we already have the voyage in the collection and if so,
	//it's just an update which will means we're not adding it for the first time.
	if self.updateVoyagesToProcess(_voyage, _originalVoyageCode) then 
		return false;
	endif;
	
	self.allVoyagesToProcess.add(_voyage);
		
	return true;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_originalVoyageCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkEDITIVoyageCodeMatches" id="7fcc898d-e804-4bae-baf7-3755d982d485">
        <source>checkEDITIVoyageCodeMatches(_voyageCode, _altVoyageCode : String;
							_excludeDeparted : Boolean)  : Boolean protected;
/*

Date		Who		Reason
16 October 2015	cnwer1	Initial creation PAR 37090

*/

vars
	voyage : CM_Voyage; 
	
begin
	if _altVoyageCode.toUpper[ 1 : _voyageCode.length() ] = _voyageCode then
		if _excludeDeparted then 
			voyage:= self.myTerminal.lookupVoyage(_altVoyageCode,null,false);
			if voyage = null or not voyage.hasDeparted then
				return true;
			endif;
		else
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_altVoyageCode" type="String"/>
        <Parameter name="_excludeDeparted" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllEDIDataForType" id="dafac6cc-b6ea-41ac-9461-2066d85b0d65">
        <source>getAllEDIDataForType(_ediDataType:Integer; _allEDIDatas:CM_EDIDataArray input);
// --------------------------------------------------------------------------------
// Created:		14 June 2010 by cnwdad1
//
// Purpose:		Populates the specified array parameter whith EDI Data objects of
//				the specified type.
//
// Parameters:	_ediDataType - The type of EDI Data objects required.
//				_allEDIDatas - A reference to an array of EDI Data objects.
//
// Returns:		The populated EDI Data array.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	ediDataObj	: CM_EDIData;
	iteratorObj	: Iterator;
	
begin
	iteratorObj	:=	self.allEDIDatasByTypeNumber.createIterator();
	self.allEDIDatasByTypeNumber.startKeyGeq(_ediDataType, 0, iteratorObj);
	
	while iteratorObj.next(ediDataObj) do
		if ediDataObj.ediDataType &lt;&gt; _ediDataType then
			break;
		endif;
		
		_allEDIDatas.add(ediDataObj);
	endwhile;
epilog
	delete iteratorObj;
end;</source>
        <Parameter name="_ediDataType" type="Integer"/>
        <Parameter name="_allEDIDatas" type="CM_EDIDataArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDataTypeFromClass" id="8947516c-b913-4fb8-80dd-17910b094b33">
        <source>getDataTypeFromClass(_class: Class; _types: IntegerArray input);
//----------------------------------------------------------------
//	Created:	24 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//15/9/2008 7.6.3 PAR17931 	cnwsh3 	Removed data classes that were intended for use with U.S changes but they were not required.
// 22/02/2010	cnwrl1		PAR 21735 = CCMS 1068 (CR005) - EDI file load of Consignor/Consignee
//19 Sep 2012	cnwrs1		CCMS SFW 1290 Transaction file
//11 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS EDI
// 13 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 18 Jul 2018	jlgrs1	TFS PLI01
// 08 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
// 29 Mar 2023	jlika1  TFS 57276 POB | QShips - Manual Load of XML EDI file
// 27 Jun 2023	jlizm1	TFS 53901 EUP VBS EDI
// 12 Jul 2023	navdap1	TFS 58923 EUP CallOff EDI Data Type / EDI Load
// 27 Jan 2025	jlier1  TFS 33694
vars
	
begin
	
	if _class = CM_EDIDataCustomStop then
		_types.add(EDIDataType_CustomStop);
		_types.add(EDIDataType_OneStopCust);	//08 Sep 2016	NDL	TFS 2278 / 2670
	elseif _class = CM_EDIDataOperatorStop then
		_types.add(EDIDataType_OperatorStop);
		_types.add(EDIDataType_OneStopEIDO);	//04 Oct 2016	NDL	TFS 2718 / 2536
	elseif _class = CM_EDIDataBayPlan then
		_types.add(EDIDataType_BayPlan);
	elseif _class = CM_EDIDataBookingRef then
		_types.add(EDIDataType_BookingSingleLine);
	elseif _class = CM_EDIDataLoadList then
		_types.add(EDIDataType_LoadList);
	elseif _class = CM_EDIDataPack then	//ccms 1976 01 Dec 2010 cnwrs1
		_types.add(EDIDataType_Pack);	
	elseif _class = CM_EDIDataPrenote then
		_types.add(EDIDataType_Prenote);
		_types.add(EDIDataType_OneStopPre);	//01 Sep 2016	NDL	TFS 2276 / 2565
	elseif _class = CM_EDIDataProduct then
		_types.add(EDIDataType_Product);	
	elseif _class = CM_EDIDataStowAdvice then
		_types.add(EDIDataType_StowAdvice);
	elseif _class = CM_EDIDataOpCarrierAcessByCT then 
		_types.add(EDIDataType_OpCarrierAcessByCT);
	elseif _class = CM_EDIDataOutwardRail then
		_types.add(EDIDataType_OutwardRail);
	elseif _class = CM_EDIDataBOLOutLog then
		_types.add(EDIDataType_BOLOutLog);
	elseif _class = CM_EDIDataGeneric then
		//add these in ascending order
		_types.add(EDIDataType_CSV);
		_types.add(EDIDataType_XML);
	elseif _class = CM_EDIDataTranship then
		_types.add(EDIDataType_Tranship);	
	elseif _class = CM_EDIDataFleet then
		_types.add(EDIDataType_Fleet);
	elseif _class = CM_EDIDataCargo then
		_types.add(EDIDataType_Cargo);
	elseif _class = CM_EDIDataCargoOnSite then
		_types.add(EDIDataType_CargoOnSite);
	elseif _class = CM_EDIDataCargoOnShip then
		_types.add(EDIDataType_CargoOnShip);
	elseif _class = CM_EDIDataBillOfLading then
		_types.add(EDIDataType_CustomsBOL);
	elseif _class = CM_EDIDataUSCustomsMessage then
		_types.add(EDIDataType_CustomsMessage);
	// Classes added for Messina Project one MES 1010 and 1011 September 2009
	elseif _class = CM_EDIDataFleetWagon then	//MES 1010 Interface load jmn
		_types.add(EDIDataType_FleetWagon);		
	elseif _class = CM_EDIDataConsignoree then		// cnwrl1 22/02/2010 PAR 21735
		_types.add( EDIDataType_Consignoree );		// cnwrl1 22/02/2010 PAR 21735
	elseif _class = CM_EDIDataBOL then
		_types.add(EDIDataType_BOL);
	elseif _class = CM_EDIDataStop then
		_types.add(EDIDataType_Stop);
	elseif _class = CM_EDIDataTrain then
		_types.add(EDIDataType_Train);
	elseif _class = CM_EDIDataVoyage then
		_types.add(EDIDataType_Voyage);
	elseif _class = CM_EDIDataVoyageQships then
		_types.add(EDIDataType_Voyage);
	elseif _class = CM_EDIDataWagon then
		_types.add(EDIDataType_Wagon);
	elseif _class = CM_EDIDataTrainConsist then
		_types.add(EDIDataType_TrainConsist);
	elseif _class = CM_EDIDataDeckPlan then
		_types.add(EDIDataType_DeckPlan);
	elseif _class = CM_EDIDataDeckStowageAdvice then //cnwgb1 CCMS 1009 14.10.2011
		_types.add(EDIDataType_DeckStowageAdvice);
	elseif _class = CM_EDIDataShipManifest then
		_types.add(EDIDataType_ShipManifest);
	elseif _class = CM_EDIDataBooking then //par21718 cnwrs1 nov 2009
		_types.add(EDIDataType_BookingMultiLine);
// cnwdad1 11/12/2009 - PAR #21946.
	elseif _class = CM_EDIDataCargoFieldUpdate then
		_types.add(EDIDataType_CargoFieldUpdate);
	elseif _class = CM_EDIDataToDoTask then //cnwgb1 PAR 22022 18.2.2010
		_types.add(EDIDataType_ToDoTask);
	elseif _class = CM_EDIDataTransaction then	//19 Sep 2012	cnwrs1		CCMS SFW 1290 Transaction file
		_types.add(EDIDataType_Transaction);
	elseif _class = CM_EDIDataReleaseRequest then
		_types.add(EDIDataType_ReleaseRequest);
	elseif _class = CM_EDIDataRequestMultiLine then
		_types.add(EDIDataType_RequestMultiLine);
	elseif _class = CM_EDIDataCarrier then //epr par 35304 2/12/14
		_types.add(EDIDataType_Carrier);
	elseif _class = CM_EDIDataCommodity then
		_types.add(EDIDataType_Commodity);
	elseif _class = CM_EDIDataCustomsAgent then //epr par 35304 2/12/14
		_types.add(EDIDataType_CustomsAgent);
	elseif _class = CM_EDIDataDriver then //epr par 35304 2/12/14/
		_types.add(EDIDataType_Driver);
	elseif _class = CM_EDIDataVehicle then///epr par 35304 2/12/14
		_types.add(EDIDataType_Vehicle); 
	elseif _class = CM_EDIDataDebtor then
		_types.add(EDIDataType_Debtor); // epr par 36370 2/6/15
	elseif _class = CM_EDIDataCargoGroupAssign then
		_types.add(EDIDataType_CargoGroupAssign);	//31 Jul 2015	NDL	Par 36608
	elseif _class = CM_EDIDataCargoGroupNotified then
		_types.add(EDIDataType_CargoGroupNotified);	//10 Aug 2015	NDL	Par 36608
	elseif _class = CM_EDIDataMultiMoveGroup then
		_types.add(EDIDataType_MultiMoveGroup);	//16 Sep 2015	NDL	Par 36906
	elseif _class = CM_EDIDataMove then
		_types.add(EDIDataType_QueueMove);		// 16 Sep 2015	JRE	Par 36912
	elseif _class = CM_EDIDataCargoGroup then	//16 Feb 2016	NDL	Par 37544
		_types.add(EDIDataType_CargoGroup);
	elseif _class = CM_EDIDataVBSSlot then	// TFS 53901
		_types.add(EDIDataType_VBSSlot);
	elseif _class = CM_EDIDataVGM then
		_types.add(EDIDataType_VGM);
	elseif _class = CM_EDIDataVoyageEvent then	// TFS 54165 jlizm1 29/07/2022
		_types.add(EDIDataType_VoyageEvent);
	elseif _class = CM_EDIDataGateDoc then
		_types.add(EDIDataType_GateDocument);
	elseif _class = CM_EDIDataWagonRelease then 		//navra1 - 2nd Dec 2022 - TFS 54124
		_types.add(EDIDataType_WagonReleaseAssign);		//navra1 - 2nd Dec 2022 - TFS 54124
	elseif _class = CM_EDIDataTransManifest then		//05.Jun.2023 navsp1 TFS 58054
		_types.add(EDIDataType_TransportManifest);
	elseif _class = CM_EDIDataCallOff then		// TFS 58923
		_types.add(EDIDataType_CallOff);		// TFS 58923
	elseif _class = CM_EDIDataDeliveryParty then //jlier1 33694 27/1/25
		_types.add(EDIDataType_DeliveryParty);
	else
		_types.add(EDIDataType_Unknown);
	endif;	
end;
</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_types" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getEDIDataClassForType" id="f345a8be-2972-4419-b12d-b07d3d838ae1">
        <source>getEDIDataClassForType(_type: Integer): Class;
/*
----------   ----------  --------------------------------------------------
Created:	01 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason

15/9/2008 	PAR17931 7.6.3	cnwsh3 	Removed data classes that were intended for use with U.S changes but they were not required.  	
28/08/2009	cnwrl1		PAR 20320 - MES 1011 New Messina Messages
22/02/2010	cnwrl1		PAR 21735 = CCMS 1068 (CR005) - EDI file load of Consignor/Consignee
19 Sep 2012	cnwrs1		CCMS SFW 1290 Transaction file
11 Dec 2015	cnwrs1		Par 37402 TFS 1192 MultiLine Release Request
05 Apr 2016	cnwrs1		TFS 1600 VERMAS EDI
13 Nov 2017	jlgrs1		TFS 5705 - SNO - EDIDataBooking Prenote release Req
18 Jul 2018	jlgrs1		TFS PLI01
08 Aug 2018	jlgrs1		TFS 39619 PEN - Approved Carriers For Operator
16 Nov 2022	jlika1		TFS 54892 - POB - Vessel, Voyage and Movement EDI Messages
27 Jun 2023	jlizm1		TFS 53901 EUP VBS EDI
12 Jul 2023	navdap1		TFS 58923 EUP CallOff EDI Data Type / EDI Load
27 Jan 2025	jlier1  	TFS 33694
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _type = EDIDataType_BayPlan then
		return  CM_EDIDataBayPlan;
	elseif _type = EDIDataType_BOL then
		return  CM_EDIDataBOL;
	elseif _type = EDIDataType_BOLDtl then
		return  CM_EDIDataBOL;
	elseif _type = EDIDataType_BOLHdr then
		return  CM_EDIDataBOL;
	elseif _type = EDIDataType_BOLOutLog then
		return  CM_EDIDataBOLOutLog;
	elseif _type = EDIDataType_BookingHeader then //par21718 cnwrs1 Nov 2009
		return  CM_EDIDataBooking;
	elseif _type = EDIDataType_BookingItem then //par21718 cnwrs1 Nov 2009
		return  CM_EDIDataBooking;
	elseif _type = EDIDataType_BookingMultiLine then //par21718 cnwrs1 Nov 2009
		return  CM_EDIDataBooking;
	elseif _type = EDIDataType_BookingSingleLine then
		return  CM_EDIDataBookingRef;
	elseif _type = EDIDataType_Cargo then
		return  CM_EDIDataCargo;
	elseif _type = EDIDataType_CargoFieldUpdate then
		return  CM_EDIDataCargoFieldUpdate;
	elseif _type = EDIDataType_CargoOnShip then
		return  CM_EDIDataCargoOnShip;
	elseif _type = EDIDataType_CargoOnSite then
		return  CM_EDIDataCargoOnSite;
	elseif _type = EDIDataType_Consignoree then		// cnwrl1 22/02/2010 PAR 21735
		return CM_EDIDataConsignoree;				// cnwrl1 22/02/2010 PAR 21735
	elseif _type = EDIDataType_CSV then
		return  CM_EDIDataGenCSV;
	elseif _type = EDIDataType_CustomStop then
		return CM_EDIDataCustomStop;
	elseif _type = EDIDataType_CustomsBOL then //Found to be missing when modifying for MES 1011 cnwgb1 7.9.09
		return CM_EDIDataBillOfLading;
	elseif _type = EDIDataType_CustomsMessage then //Found to be missing when modifying for MES 1011 cnwgb1 7.9.09
		return CM_EDIDataUSCustomsMessage;
	elseif _type = EDIDataType_Fleet then
		return  CM_EDIDataFleet;
	elseif _type = EDIDataType_FleetWagon then //MES 1010 Interface load jmn
		return  CM_EDIDataFleetWagon;
	elseif _type = EDIDataType_Generic then
		return  CM_EDIDataGeneric;
	elseif _type = EDIDataType_Layout then
		return  CM_EDIDataDeckPlan;
	elseif _type = EDIDataType_LayoutPoint then
		return  CM_EDIDataDeckPlan;
	elseif _type = EDIDataType_LoadList then
		return  CM_EDIDataLoadList;
	elseif _type = EDIDataType_OpCarrierAcessByCT  then 
		return CM_EDIDataOpCarrierAcessByCT;
	elseif _type = EDIDataType_OperatorStop then
		return CM_EDIDataOperatorStop;
	elseif _type = EDIDataType_OutwardRail then
		return  CM_EDIDataOutwardRail;
	elseif _type = EDIDataType_Pack then	//ccms 1976 01 dec 2010 cnwrs1
		return  CM_EDIDataPack;
	elseif _type = EDIDataType_Port then
		return  CM_EDIDataVoyage;
	elseif _type = EDIDataType_Prenote then
		return  CM_EDIDataPrenote;
	elseif _type = EDIDataType_Product then
		return  CM_EDIDataProduct;
	elseif _type = EDIDataType_ReleaseRequest then
		return CM_EDIDataReleaseRequest;
	elseif _type = EDIDataType_RequestMultiLine then
		return CM_EDIDataRequestMultiLine;
