    <JadeMethod name="createGetDestinationResponse" id="d4973b16-d3bb-4249-bb07-2a65fe271768">
        <source>createGetDestinationResponse(_message : CMIF_InterfaceMsgController input) protected;

/*

Purpose:			Create response for a successful incoming GetDestination message

Parameters:			Incoming message controller

Return Value:		_message updated with response


Date		Who		Reason
22 Sep 2008	consw1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
24 Nov 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
					Change to hook code signature
02 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
11 May 2009	cnwkpd1	PAR #19641 - Rule change - only return twin container ID and location
					if the location is a grid location

*/

vars
	field,
	twinId,
	twinLocationStr	: String;
	twinTargetLoc	: CM_LocationsController;
	response		: CMIF_InterfaceResponse;
	task,
	twinTask		: CM_RTQueueTask;

begin
	task := _message.getTask();
	twinTask := _message.getTwinTask();
	
	// Create response object
	response := _message.createResponseLine();
	
	// Destination String (pass in both tasks)
	field := self.myInterfaceDefinition.getLocationTranslationString(_message.functionName,
																	 task, 
																	 twinTask,
																	 task.ultimateTargetLocation,
																	 false);
	response.allResponseFields.add(field);
	_message.setLocationDestination( field );		// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	
	// Twin task information - rework for PAR #19641
	twinId := null;
	twinLocationStr := null;
	
	// Do we have a twin task with a TI?
	if twinTask &lt;&gt; null and twinTask.ti &lt;&gt; null then
		// Get twin target location
		twinTargetLoc := twinTask.ultimateTargetLocation();
		
		// If this is a grid location, then return Twin Container Id and Destination string
		if twinTargetLoc &lt;&gt; null and twinTargetLoc.isGridLocation() then
			// Twin ID
			twinId := twinTask.ti.id;
			
			// Twin Destination String (pass in just twin task)
			twinLocationStr := self.myInterfaceDefinition.getLocationTranslationString(_message.functionName,
																					   twinTask, 
																					   null,
																					   twinTask.ultimateTargetLocation,
																					   false);
		endif;
	endif;
	response.allResponseFields.add(twinId);
	response.allResponseFields.add(twinLocationStr);
	// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	// do not need to save the twinLocationStr because only report on GetDestinationResponse if there is an error.
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_message" type="CMIF_InterfaceMsgController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createLogonResponse" id="e09586ed-adda-4c65-bef1-f550b59fc210">
        <source>createLogonResponse(_message : CMIF_InterfaceMsgController input) protected;

/*

Purpose:			Create response for a successful incoming Logon message

Parameters:			Incoming message controller

Return Value:		_message updated with response


Date		Who		Reason
23 Sep 2008	consw1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
02 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars
	faultQuestion 	: CM_FaultQuestion;
	response		: CMIF_InterfaceResponse;
	questionNo		: Integer;
	twinLift		: String;
	
begin
	if _message.machineIsTwinLift then
		twinLift := 1.String;
	else
		twinLift := 0.String;
	endif;
	
	foreach faultQuestion in _message.myMediator.allFaultQuestions do
		// Create one response line per fault question
		response := _message.createResponseLine();

		questionNo := questionNo + 1;
		// Unique Id
		response.allResponseFields.add(questionNo.String);
		// Question
		response.allResponseFields.add(faultQuestion.description);
		
		// Lift type
		response.allResponseFields.add(twinLift);		// PAR #18743
	endforeach;

	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_message" type="CMIF_InterfaceMsgController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createNextJobResponse" id="13ac6ba9-4a71-47a0-8812-623d85d2a82c">
        <source>createNextJobResponse(_message : CMIF_InterfaceMsgController input) protected;

/*

Purpose:			Create response for a successful incoming NextJob message

Parameters:			Incoming message controller

Return Value:		_message updated with response


Date		Who		Reason
19 Sep 2008	consw1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
24 Nov 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
					Parameter changes to Location Description hook code
27 Nov 2008	cnwkpd1	PAR #18555 - Correct uniqueness check to last 4 digits
02 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
11 Feb 2009	cnwkpd1	PAR #18888 - Wrong source location being returned to the Voice application

*/

vars
	directedTask	: Boolean;
	field			: String;
//	matches			: Integer;							// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	numberOfMatches	: Integer;							// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	response		: CMIF_InterfaceResponse;
	shortId			: String;
	task,
	twinTask		: CM_RTQueueTask;
	
begin
	task 			:= _message.getTask();
	directedTask	:= task.taskType = TASK_DIRECTOR;

	twinTask 		:= _message.getTwinTask();
	
	// Create response object
	response := _message.createResponseLine();
	
	// Job Type
	field := "Q";
	if directedTask then
		field := "D";
	endif;
	response.allResponseFields.add(field);
	_message.setJobType( field );					// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	
	// Container Id
	field := null;
	if not directedTask and task.ti &lt;&gt; null then
		field := task.ti.id;
	endif;
	response.allResponseFields.add(field);
	_message.setContainerId( field );				// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814

	// Is Unique Id?
	field := null;
/*	if not directedTask and task.ti &lt;&gt; null then
		shortId := task.ti.id;
		if shortId.length &gt; 4 then					
			shortId := shortId[shortId.length-3:end];			// PAR #18555 - take 4, not 5 characters
		endif;
//		app.getMyTerminal().searchForOnsiteTI(shortId, matches, TI_CargoType_Container);	// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
		app.getMyTerminalDO_NOT_USE().searchForOnsiteTI(shortId, numberOfMatches, TI_CargoType_Container);
//		if matches = 1 then									// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
		_message.setNumberOfMatches( numberOfMatches );		// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
		if _message.numberOfMatches = 1 then
			field := "Y";
		else
			field := "N";
		endif;
	endif;*/
	if not directedTask and task.ti &lt;&gt; null then//30 Mar 2011	NDL	Par 27290
		if self.myInterfaceDefinition.getContainerUniqueValue( _message.functionName, task) then
			field := "Y";
		else
			field := "N";
		endif;
	endif;
	response.allResponseFields.add(field);
	_message.setUniqueId( field );					// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814

	// Twin Container Id - PAR #18743
	field := null;
	if not directedTask and twinTask &lt;&gt; null and twinTask.ti &lt;&gt; null then
		field := twinTask.ti.id;
	endif;
	response.allResponseFields.add(field);
	_message.setContainerId2( field );				// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814

	// Is Twin a Unique Id? - PAR #18743
	field := null;
/*	if not directedTask and twinTask &lt;&gt; null and twinTask.ti &lt;&gt; null then
		shortId := twinTask.ti.id;
		if shortId.length &gt; 4 then					
			shortId := shortId[shortId.length-3:end];
		endif;
//		app.getMyTerminal().searchForOnsiteTI(shortId, matches, TI_CargoType_Container);	// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
		app.getMyTerminalDO_NOT_USE().searchForOnsiteTI(shortId, numberOfMatches, TI_CargoType_Container);
//		if matches = 1 then									// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
		_message.setNumberOfMatches( numberOfMatches );		// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
		if _message.numberOfMatches = 1 then
			field := "Y";
		else
			field := "N";
		endif;
	endif; */
	if not directedTask and twinTask &lt;&gt; null and twinTask.ti &lt;&gt; null then//30 Mar 2011	NDL	Par 27290
		if self.myInterfaceDefinition.getContainerUniqueValue( _message.functionName, twinTask) then
			field := "Y";
		else
			field := "N";
		endif;
	endif;
	response.allResponseFields.add(field);
	_message.setUniqueIdTwin( field );				// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	
	// Container attributes
	field := null;
	if not directedTask and task.ti &lt;&gt; null then
		field := self.myInterfaceDefinition.getContainerAttributesString(_message.functionName,
																		 task, 
																		 twinTask);
	endif;
	response.allResponseFields.add(field);
	_message.setContainerAttributes( field );		// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814

	// Source String
	field := self.myInterfaceDefinition.getLocationTranslationString(_message.functionName,
																	 task,
																	 twinTask,
																	 task.getSourceLocation, 		// PAR #18888
																	 true);
	response.allResponseFields.add(field);
	_message.setLocationSource( field );			// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	
	// Destination String
	field := self.myInterfaceDefinition.getLocationTranslationString(_message.functionName,
																	 task, 
																	 twinTask,
																	 task.ultimateTargetLocation, 
																	 false);
	response.allResponseFields.add(field);
	_message.setLocationDestination( field );		// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_message" type="CMIF_InterfaceMsgController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createPickupResponse" id="2ca6ada3-d338-4632-b4f7-732ebf943e08">
        <source>createPickupResponse(_message : CMIF_InterfaceMsgController input) protected;

/*

Purpose:			Create response for a successful incoming Pickup message

Parameters:			Incoming message controller

Return Value:		_message updated with response


Date		Who		Reason
22 Sep 2008	consw1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
24 Nov 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes
					Change of signature for hook code
02 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars
	field			: String;
	response		: CMIF_InterfaceResponse;
	task,
	twinTask		: CM_RTQueueTask;

begin
	task := _message.getTask();
	twinTask := _message.getTwinTask();
	
	// Create response object
	response := _message.createResponseLine();
	
	// Destination String
	field := self.myInterfaceDefinition.getLocationTranslationString(_message.functionName,
																	 task, 
																	 twinTask,
																	 task.ultimateTargetLocation,
																	 false);
	response.allResponseFields.add(field);
	_message.setLocationDestination( field );		// cnwrl1 14/05/2009 PAR 19668 - CCMS 1814
	
epilog
	
end;</source>
