    <JadeMethod name="setupForm" id="df32f6d5-1ed1-4276-883f-5825afda0fc6">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2009	cnwrd1	Initial creation
//22 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	theBR : CM_BulkRelease;
begin
	inheritMethod();
	self.updateMode		:= self.Mode_Add;
	
	self.loadCombos();
	
	self.setGroupButtonsVisible(false);
		
	//depends on type
	self.initFieldsForEntDefName( ETDef_RIMEdit2, true); 
	
	self.isSelectorCapable := true;
	self.setNavigatorHeading(self.caption);
	
	self.hasChanged := false;
	
	self.lblStatus.visible := false;
	
	//22 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	//self.txtRequiredDate2.setValue( app.actualTimeServer().date );
	self.dtRequired.setDate( self.systemToLocalTime(app.actualTimeServer()).date );
	self.cmbPriority.setForText('3');	
	
	self.cmbSourceArea.setComboStyle( ComboBox.Style_DropDownComboList);
	self.cmbTargetArea.setComboStyle( ComboBox.Style_DropDownComboList);

		
	if self.myInitialisingRelease &lt;&gt; null then
			theBR := self.myCurrentObject.CM_BulkRelease;
			self.myInitialisingRelease := theBR;
			self.updateMode		:= self.Mode_Add;
			self.cmbRequestType.enabled := false;
			self.cmbRelease.setForObject(theBR);
			//self.txtJobID.text := theBR.code;
			self.doReleaseChange();
			self.doReleaseItemLostFocus();
	else
		if self.myCurrentObject &lt;&gt; null then
			self.updateMode		:= self.Mode_Update;
			self.initForRequest( self.myCurrentObject );
		else
			self.updateMode		:= self.Mode_Add;
		endif;
	endif;

	self.showHideFieldsForType();
	self.doSetCaption();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showHideFieldsForControllerStr" id="5a2a3e8e-9fc2-4ed9-9ce4-d31182845dde">
        <updating/>
        <source>showHideFieldsForControllerStr() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 March 2011	cnwrd1	Initial creation

*/

vars

begin

/*
	if self.currentEntTableDef &lt;&gt; ETDef_RIMEdit2 then
		self.initFieldsForEntDefName( ETDef_RIMEdit2, true); 
	endif;
	 	
	if self.height &lt;&gt; 565 then
		self.minimumHeight :=  565;
		self.height :=  565;
	endif;

	
	self.txtNumRequested.visible := true;
	self.cmbSourceArea.visible := true;
	self.picSelector.enabled := false;				
	self.chkIsClean.visible := false;
	self.cmbOperator.visible := false;
	self.cmbISOGroup.visible := false;
	self.cmbISOType.visible := false;
	self.lstMTGrades.visible := false; 
	self.chkAddToRTQ.visible := false;
	self.cmbRelease.visible := false;
	self.cmbReleaseItem.visible := false;
	self.cmbRTQueue.visible := false;
	self.cmbTargetSubTerm.visible := false;
				
	self.chkStatusHeld.visible := true;
	self.chkNoChecks.visible := true;
	self.lstTrackedItems.visible := true;
	
	self.btnAdvancedSrc.visible := false;
			
	if self.updateMode = self.Mode_Add then	
		self.picSelector.enabled := true;
	else
		self.picSelector.enabled := false;
	endif;
		

	self.cmbSubTerminal.visible := false; //cnwrd1 par 24961 14.7.2010 only show for delivery requests.
	self.cmbTargetSubTerm.visible := false; 
	
	*/
	
	//cnwrd1 par 29353 30.3.2012
	if self.currentEntTableDef &lt;&gt; ETDef_MoveRequest then
		self.initFieldsForEntDefName( ETDef_MoveRequest, true); 
	endif;
	
	if self.height &lt;&gt; 500 then
		self.minimumHeight :=  500;
		self.height :=  500;
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showHideFieldsForDepotRequest" id="1d2c9ddf-591d-4f6b-9a53-a8b2e95a4a95">
        <updating/>
        <source>showHideFieldsForDepotRequest() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 March 2011	cnwrd1	Initial creation
3 Nov 2022 		navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
*/

vars

begin

	if self.currentEntTableDef &lt;&gt; ETDef_RIMEdit2 then
		self.initFieldsForEntDefName( ETDef_RIMEdit2, true); 
	endif;
	//Start 3 Nov 2022 NAVSKS20 TFS 52721	
	/*if self.height &lt;&gt; 600 then
		self.minimumHeight :=  600;
		self.height :=  600;
	endif; */
	
	self.minimumHeight :=  650;
	self.height :=  650;
	
	if self.myTerminal.getConfig( DelReqChangeSubTerm).Boolean then
		self.cmbUpdateSubTer.visible := true; 
	else 
		self.cmbUpdateSubTer.visible := false; 
	endif;
	//End 3 Nov 2022 NAVSKS20 TFS 52721
	
	self.picSelector.enabled := false;
	self.txtNumRequested.visible := true;
	self.cmbSourceArea.visible := true;
	self.chkIsClean.visible := true;
	self.cmbOperator.visible := true;
	self.cmbISOGroup.visible := true;
	self.cmbISOType.visible := true;
	self.lstMTGrades.visible := true; //cnwrd1 par 26633 17.12.2010
	self.chkAddToRTQ.visible := true;
	self.cmbRelease.visible := true;
	self.cmbReleaseItem.visible := true;
	self.cmbRTQueue.visible := true;
	self.cmbTargetSubTerm.visible := true;
	self.chkStatusHeld.visible := false;
	self.chkNoChecks.visible := false;
	self.lstTrackedItems.visible := false;
	self.btnAdvancedSrc.visible := true;
	
	if self.myTerminal.isAutoPlanUseBestPickDirector then
		self.chkBestPick.visible := false;
	else
		self.chkBestPick.visible := true;
	endif;	

	self.picSelector.enabled := true;		// cnwjre1 May 2011 27097

	if app.isSubTerminalsOn(self.myTerminal) then
		self.cmbSubTerminal.visible := true; //cnwrd1 par 24961 14.7.2010 only show for delivery requests.
		self.cmbTargetSubTerm.visible := true; 
	else
		self.cmbSubTerminal.visible := false;
		self.cmbTargetSubTerm.visible := false;
	endif;
	
epilog

end;</source>
    </JadeMethod>
