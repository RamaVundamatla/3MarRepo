    <JadeMethod name="createInvoiceLineVTMIS" id="aec4bceb-9593-425b-a574-f401b137f726">
        <updating/>
        <source>createInvoiceLineVTMIS(_debtor : CM_Debtor; _invLineType : CM_InvoiceLineDesc; _tran : HMS_VTMISTransaction) : CM_InvoiceLine updating;
//10 Oct 2022 	navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
//23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
vars
	invLine	: CM_InvoiceLine;
	invoice	: CM_Invoice;
	now		: TimeStamp;
	seqNum  : Integer;
	invType : CM_InvoiceDesc;
begin

	invType := self.getInvoiceType(_debtor);
	invoice := bank.getAutoInvoiceVTMIS(invType, _invLineType, _tran, _debtor); 

	create invLine persistent;
	seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE); // PAR 30751
	
	if _tran.transactionDT.isValid then
		now := _tran.transactionDT;	//else use timestamp set in now.
	else
		now := app.serverTimestampAtTrxStart;	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
	invLine.setForCreate(seqNum, false, null, self, invoice, _debtor, bank, 0, now);
	
	invLine.setMyTransactionHMS(_tran);
	invLine.createCharges(); 
	
	invLine.doHookCodeForRemarks();	//27 Dec 2018	NDL	TFS 42119

	app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(invLine);		// 9/5/18 MAP TFS37718

	if app.canLogExtraDetail then										//10.10.2022 navma1 #52967
		app.invLog(method.qualifiedName &amp; " New invoice line " &amp; _invLineType.narration &amp; " = " &amp; // TFS 42084
		invLine.sequenceNum.String &amp; ", invoice " &amp; invLine.invoice.sequenceNum.String &amp; ", debtor " &amp; _debtor.name, LogTRACE.String);
	endif;
	
	// PAR 24423 - now done in createCharges
	//tmpTotal := invLine.lineTotal; // ### VERY IMPORTANT TO LEAVE THIS HERE, as it is virtual. This call sets rate and quantity correctly
	
	return invLine;
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="_tran" type="HMS_VTMISTransaction"/>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
