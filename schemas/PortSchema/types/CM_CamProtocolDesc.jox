    <JadeMethod name="isTransactionToBeProcessed" id="dd06575f-ab55-4cfe-a05a-d66600b52fa8">
        <source>isTransactionToBeProcessed(_camProtocol : CM_CamProtocol; _trans : CM_TITransaction; _camAgent : CM_CamControllerAgent) : Boolean;
//
// ccms 1011 par 21254 cnwrs1 oct 2009
//
//06 Mar 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
vars
	result : Boolean;
	registeredTransactions : IntegerArray;
begin
	//epr TFS 2395 20/7/16 other transactions can be added in getTransactionTypesToProcess so use that method	
	create registeredTransactions transient;
	self.getTransactionTypesToProcess(_camProtocol,registeredTransactions);
	
	result := registeredTransactions.includes(_trans.type);
	if result = false then
		if _camAgent &lt;&gt; null  then
			_camAgent.logReasonForExclusion(_trans, "Transaction is not in registered trans list");
		endif;
	endif;
	return result;
epilog
	delete registeredTransactions;
end;
</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_trans" type="CM_TITransaction"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
