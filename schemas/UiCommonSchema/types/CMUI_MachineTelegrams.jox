    <JadeMethod name="doSysNotify" id="0874dd2b-e39b-4364-8f3d-3d6c5f00c292">
        <updating/>
        <source>doSysNotify(eventType: Integer; theObject: Object; eventTag: Integer) protected, updating;

// Created by cnwdvb1 on 30 June 2006

vars

begin


	if not self.updateObjectInTable(eventType, theObject.CM_RTGTelegram, self.tblTelegrams) then
		self.updateObjectInTable(eventType, theObject.CM_RTGTelegram, self.tblTelegrams);
	endif;
	
	
	
end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
