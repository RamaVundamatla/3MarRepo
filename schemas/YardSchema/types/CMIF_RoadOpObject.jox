    <JadeMethod name="doNotableAdd" id="2c01575a-a037-4810-a64b-465c2055d810">
        <source>doNotableAdd(_ti :CM_TrackedItem) protected;
// ---------------------------------------------------------------------------
// Created:     19 March 2010 by cnwcs5
// Purpose:     par 23193 - notification of changes to tracked items
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	invalid	:Boolean;
	controller : CMIF_RoadOpController; //27/03/2025	navkc1 JIRA Story MTN-34156
	form	: CM_BaseForm; //27/03/2025	navkc1 JIRA Story MTN-34156
	control : Control;
begin
	//27/03/2025	navkc1 JIRA Story MTN-34156 - If Form is not doing notification then don't do it here
	controller := self.myRoadOpController;
	if controller &lt;&gt; null then
		control := controller.myBaseDockBar;
		
		if control &lt;&gt; null and control.form &lt;&gt; null then
			if control.form.isKindOf(CM_BaseForm) then
				form := control.form.CM_BaseForm;
			endif;
		endif;
		
		if form &lt;&gt; null then
			if form.notificationLevel &lt;&gt; form.NoteLevelDoNotes then
				return;
			endif;
		endif;
	endif;
	
	if _ti = null then
		return;
	endif;
	
	if not self.registerForTINotes then
		return;
	endif;
	
	on Exception do app.handleDeletedObject (exception, _ti, invalid);
	
	// this check is not necessary but will force an exception if _ti is invalid
	if _ti.isTransient then
		return;
	endif;
	
	if invalid then
		// we got an exception
		return;
	endif;
	
	if (not self.allNotableTIs.includes(_ti)) then
		self.allNotableTIs.add(_ti);
		self.beginNotification(_ti, Object_Update_Event, Response_Continuous, null);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="f9007710-a9ea-4b24-a93e-5de864e16087">
        <source>doNotableClear() protected;
// ---------------------------------------------------------------------------
// Created:     19 March 2010 by cnwcs5
// Purpose:     par 23193 - notification of changes to tracked items
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti : CM_TrackedItem;
begin
	if not self.registerForTINotes then
		return;
	endif;
	
	foreach ti in self.allNotableTIs do
		self.endNotification(ti, Object_Update_Event);
	endforeach;

	self.allNotableTIs.clear;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doNotableRemove" id="c4f01fc4-3800-4ccb-93a2-bd0ef5d046e3">
        <source>doNotableRemove(_ti :CM_TrackedItem) protected;
// ---------------------------------------------------------------------------
// Created:     19 March 2010 by cnwcs5
// Purpose:     par 23193 - notification of tracked items changes
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	invalid	:Boolean;
begin
	if not self.registerForTINotes then
		return;
	endif;
	
	if _ti = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject (exception, _ti, invalid);
	
	// this check is not necessary but will force an exception if _ti is invalid
	if _ti.isTransient then
		return;
	endif;
	
	if invalid then
		// we got an exception
		return;
	endif;
	
	if  self.allNotableTIs.includes(_ti) then
		self.allNotableTIs.remove(_ti);
		self.endNotification(_ti, Object_Update_Event);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doNotableTIRefresh" id="2ebfdb56-de47-45ba-855c-d1f16eb7c861">
        <source>doNotableTIRefresh(_ti :CM_TrackedItem) protected;
// ---------------------------------------------------------------------------
// Created:     19 March 2010 by cnwcs5
// Purpose:     par 23193 - notification of changes to tracked items
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/03/2010	cnwcs5		par 23368 - exception when ti has CM_YardInternalJob WLEs
// ---------------------------------------------------------------------------
vars
	wle	:CM_WorkListEntry;
	edition : Integer;
	invalid : Boolean;
begin
	if (not self.allNotableTIs.includes(_ti)) then
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, _ti, invalid );
		
	foreach wle in _ti.allWorklistEntries do
		if CM_YardWLE.hasInstance(wle) and
			wle.job.isRoadJob then	// par 23368
			self.updateDataTableObject (wle);
		endif;
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doSetupGateLaneOption" id="784c379d-e369-44a6-9ca2-deadce0f67ad">
        <source>doSetupGateLaneOption(_obj :Object; _menu :MenuItem input) protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - road ops form changes
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	area	:CM_GateArea;
	vehicle	:CM_Vehicle;
	lc		:CM_LocationsController;
begin
    if app.myPassport.myUser.canDo( app.myPassport.myTerminal, PmAdmGateLaneMaint ) 
    or app.myPassport.myUser.canDo( app.myPassport.myTerminal, PmAdmGateLaneMaint ) then // TFS 2198
		if CM_GateArea.hasInstance (_obj) then
			area := _obj.CM_GateArea;
			
		elseif CM_GateAreaLaneController.hasInstance (_obj) then
			area := _obj.CM_GateAreaLaneController.myTerminalArea.CM_GateArea;
			
		elseif CM_Vehicle.hasInstance (_obj) then
			vehicle := _obj.CM_Vehicle;
			
			lc := vehicle.myPrimaryActualLocation;
			
			if lc &lt;&gt; null and CM_GateAreaLaneController.hasInstance (lc) then
				area := lc.myTerminalArea.CM_GateArea;
			endif;
		endif;
	
		if area = null or area.laneCount = 0 then
			// nothing to do
			_menu.visible 	:= false;
			return;
		endif;
	
		_menu.userObject	:= area;
		_menu.caption 	:= app.getErrorString (MaintainLanes);
		_menu.visible 	:= true;
	else
		_menu.visible 	:= false;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_menu" type="MenuItem" usage="input"/>
    </JadeMethod>
