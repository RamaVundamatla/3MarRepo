    <JadeMethod name="setDateComboBoxsFromText" id="9617cf71-98fe-4e71-a230-5fd3e6d0d818">
        <source>setDateComboBoxsFromText(_name : String constant; _cmb : CMUI_ComboBox);
// ---------------------------------------------------------------------------
// Created:     27 April 2005	cnwhjg1
//
// Purpose:     to populate HMS combos in template from what was entered from form 
// 19 June 2018    jlgrh7 TFS #39280 LNX - Cannot select default value for ETA and ETD in Report Maintenance     
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting       
// ----------   ----------  --------------------------------------------------
vars

	reportAgent : CMUI_ReportAgent;
	qryReport : CM_QryReport;
	filterObject : CMQF_FilterReports;
	str : String;
	idx, row : Integer;
	combo : CMUI_ComboBox;
begin

	combo := _cmb;

	// find row in table so can replace with combo. 
	row := self.tblParameter.getRowByName(_name);

	if row &gt; 0 then // if no row then exit

	reportAgent := self.myReportAgent;
		
		if reportAgent &lt;&gt; null then 
			qryReport := reportAgent.myQryReport;
		else
			return;
		endif;
		
		if qryReport &lt;&gt; null then 
			filterObject := qryReport.myFilterObject; 
			//need this filter object as is the one that has the proper data. 
		else
			return;
		endif;
				
		// find which combo to populate
		if combo = self.cmbArriveDFrom then 
			str := filterObject.getDisplayStringForAttribute(ETRow_ArrivalsDateFrom, false);
			
		elseif combo = self.cmbArriveDTo then 
			str := filterObject.getDisplayStringForAttribute(ETRow_ArrivalsDateTo, false);
													
		elseif combo = self.cmbDepartDFrom then 
			str := filterObject.getDisplayStringForAttribute(ETRow_DepartedDateFrom, false);
										
		elseif combo = self.cmbDepartDTo then 
			str := filterObject.getDisplayStringForAttribute(ETRow_DepartedDateTo, false);
										
		elseif combo = self.cmbInPortDFrom then 
			str := filterObject.getDisplayStringForAttribute(ETRow_InPortDateFrom, false);
										
		elseif combo = self.cmbInPortDTo then 
			str := filterObject.getDisplayStringForAttribute(ETRow_InPortDateTo, false);	
			
		elseif combo = self.cmbExpArrDFrom then																																	//+TFS39308
			str :=filterObject.getDisplayStringForAttribute(ETRow_ExpectedArrivalDateFrom, false);	
			
		elseif combo = self.cmbExpArrDTo then
			str :=filterObject.getDisplayStringForAttribute(ETRow_ExpectedArrivalDateTo, false);		
			
		elseif combo = self.cmbExpDepDFrom then
			str :=filterObject.getDisplayStringForAttribute(ETRow_ExpectedDepartDateFrom, false);	
			
		elseif combo = self.cmbExpDepDTo then
			str :=filterObject.getDisplayStringForAttribute(ETRow_ExpectedDepartDateTo, false);		
		
		// 20/04/2023	navkc1	CR 55654 Task 55670 --&gt;
		elseif combo = self.cmbContractFromStartDate then
			str := filterObject.getDisplayStringForAttribute(ETRow_ContractFromStartDate, false);
		elseif combo = self.cmbContractToStartDate then
			str := filterObject.getDisplayStringForAttribute(ETRow_ContractToStartDate, false);
		elseif combo = self.cmbDetailFromStartDate then
			str := filterObject.getDisplayStringForAttribute(ETRow_DetailFromStartDate, false);
		elseif combo = self.cmbDetailToStartDate then
			str := filterObject.getDisplayStringForAttribute(ETRow_DetailToStartDate, false);
		elseif combo = self.cmbRateFromStartDate then
			str := filterObject.getDisplayStringForAttribute(ETRow_RateFromStartDate, false);
		elseif combo = self.cmbRateToStartDate then
			str := filterObject.getDisplayStringForAttribute(ETRow_RateToStartDate, false);
		elseif combo = self.cmbContractFromEndDate then
			str := filterObject.getDisplayStringForAttribute(ETRow_ContractFromEndDate, false);
		elseif combo = self.cmbContractToEndDate then
			str := filterObject.getDisplayStringForAttribute(ETRow_ContractToEndDate, false);
		elseif combo = self.cmbDetailFromEndDate then
			str := filterObject.getDisplayStringForAttribute(ETRow_DetailFromEndDate, false);
		elseif combo = self.cmbDetailToEndDate then
			str := filterObject.getDisplayStringForAttribute(ETRow_DetailToEndDate, false);
		elseif combo = self.cmbRateFromEndDate then
			str := filterObject.getDisplayStringForAttribute(ETRow_RateFromEndDate, false);
		elseif combo = self.cmbRateToEndDate then
			str := filterObject.getDisplayStringForAttribute(ETRow_RateToEndDate, false);
		// 20/04/2023	navkc1	CR 55654 Task 55670 &lt;--
		
		else 
			return;
		endif;

		combo.text := str;
		
		tblParameter.setControl(row, combo);
		tblParameter.setValue(row, combo.text);		

	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_cmb" type="CMUI_ComboBox"/>
    </JadeMethod>
    <JadeMethod name="setDateFieldsCmbProcessClick" id="0e7e19db-3d45-4088-9018-dc609568971c">
        <updating/>
        <source>setDateFieldsCmbProcessClick() updating;
// ---------------------------------------------------------------------------
// Created:     10 March 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	jrwReport		: JadeReportWriterReport;
	row				: Integer;
	tbl				: CM_EntryTable;
	entTableDef		: EntTableDef;
	qryReport		: CM_QryReport;
	templateRpt		: BGP_ReportRequest;
	menuEntity		: CM_MenuEntity;
	filterObject	: CMQF_FilterReports;
	entView			: EntTableView;
	entRow			: EntTableRow;
	rowName			: String;
	defaultValue	: String;
	viewRows		: StringArray;
	selectorCriteriaToDisplay	: CM_QueryCriteriaHolderArray;
	bgpRequest		: BGP_ReportRequest;
begin
	tbl := self.tblParameter;
	
	qryReport := self.myReportAgent.myQryReport;
	if qryReport = null then
		return;
	endif;
	menuEntity := self.myMenuEntity;
	if menuEntity = null then
		return;
	endif;

	entTableDef := self.myReportAgent.myEntTableDef;
	jrwReport := self.myReportAgent.myJRWReport;
	
	if jrwReport &lt;&gt; null then
		self.setPrintOptionsView();
	endif;
	
	tbl.optimiseHeadingColumn();
	self.createReportController();
	
	if menuEntity &lt;&gt; null and CM_MenuUserReport.hasInstance(menuEntity) then
		//PAR22361 - cnwsh3 - 18/02/2010 - Remove references to CM_MenuUserReport.myReportRequest 
		//mapped method.  Now using getBGPReportRequest method
		//if menuEntity.CM_MenuUserReport.myReportRequest &lt;&gt; null and
		//   menuEntity.CM_MenuUserReport.myReportRequest.myFilter &lt;&gt; null then
		bgpRequest := menuEntity.CM_MenuUserReport.getBGPReportRequest();
		if bgpRequest &lt;&gt; null and
		   bgpRequest.myFilter &lt;&gt; null then
			filterObject := bgpRequest.myFilter;
		endif;
	else
		if qryReport.myFilterObject &lt;&gt; null then
			filterObject := qryReport.myFilterObject;
		endif;	
	endif;
	
	if CM_QryReportSystem.hasInstance(qryReport) then
		entView := entTableDef.allEntTableViews[qryReport.tableDefViewName];
		if entView = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Failed to get an EntTableView for system report');
			return;
		endif;
		foreach entRow in entView.allEntTableRows do
			
			if entRow.inputType = CM_EntryTable.InputType_Date then  
				// only overwrite the date controls. others should stay the same. 
				self.myReportAgent.loadParameterByName(null, entRow, entRow.name, defaultValue);
			endif;
		endforeach;
		
	elseif CM_QryReportUser.hasInstance(qryReport) then
		viewRows := qryReport.CM_QryReportUser.viewRows;
		entTableDef:=qryReport.getETDef;
		foreach rowName in viewRows do
		//	load as per normal?????
			row:=entTableDef.getRowByName(rowName);
			if row = 0 then
				continue;
			endif;
			entRow:=entTableDef.allEntTableRows[row];
			self.myReportAgent.loadParameterByName(filterObject, entRow, entRow.name, defaultValue);
		endforeach;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'QryReport passed through is of invalid class type');
		return;
	endif;


	////////////////////////////////////////////////////////
	//Ugly piece of code specifically for the ship log list
	if (qryReport.getIdPrefix = '_rpt') and (qryReport.menuId = qryReport.getIdPrefix &amp; CM_RepShipLogList.String)  then	
		row := tbl.setValueByName(ETRow_ExtraDetail, '-- Dbl Click to Add/Update --');
		tbl.accessCell(row, CM_EntryTable.ColumnValue).inputType := Table.InputType_None; 
	endif;
	///////////////////////////////////////////////////////
	
	self.lblRepName.visible := true;
	if (not qryReport.isFormBasedReport) then
		self.lblRepName.caption := 'JRW Report : ' &amp; qryReport.getJRWFileNames();
	else
		self.lblRepName.caption := 'Non JRW report';
	endif;
	
	if qryReport.mySelectorQuery &lt;&gt; null then
//		self.lblRepName.caption := self.lblRepName.caption &amp; CrLf &amp; 'Selector query : ' &amp; qryReport.mySelectorQuery.heading;	// cnwrl1 11/11/2009 PAR 19951 - what it was
		self.lblRepName.caption := app.getString( Selector_Query, self.lblRepName.caption, qryReport.mySelectorQuery.heading );
		
		//if it's a template then show the query stuff saved on the static request object
		if templateRpt &lt;&gt; null then
			if templateRpt.myFilter &lt;&gt; null then
				selectorCriteriaToDisplay := templateRpt.myFilter.allQueryCriteriaHolders;
			endif;
		else
			selectorCriteriaToDisplay := qryReport.mySelectorQuery.allCriteriaLineHolders;
		endif;
		self.myReportAgent.showTableForSelectorReport(selectorCriteriaToDisplay);
		
	endif;
	
	self.myReportAgent.loadJRWParams();
	
	tbl.optimiseHeadingColumn();
	tbl.moveFirst();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setFormatOption" id="5d3c8543-f527-41a9-b0b5-612b64326324">
        <updating/>
        <source>setFormatOption(_request : BGP_ReportRequest)protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 January 2026	navsp1	Initial creation MTN-36668

*/

vars

begin
    if _request &lt;&gt; null then
		if _request.outputDestination = JadeReportWriterReport.CSV then
			self.cmbFormat.text := self.myReportAgent.FORMAT_OPTION_CSV;
			self.tblPrintOptions.setValueByName(ETRow_FormatOption, self.myReportAgent.FORMAT_OPTION_CSV);
			return;
		elseif _request.outputDestination = JadeReportWriterReport.XML then
			self.cmbFormat.text := self.myReportAgent.FORMAT_OPTION_XML;
			self.tblPrintOptions.setValueByName(ETRow_FormatOption, self.myReportAgent.FORMAT_OPTION_XML);
			return;
        elseif _request.outputDestination  = CM_QryReport.PDF_Format then 
            self.cmbFormat.text := self.myReportAgent.FORMAT_OPTION_PDF;
			self.tblPrintOptions.setValueByName(ETRow_FormatOption, self.myReportAgent.FORMAT_OPTION_PDF);
            return;
		endif;
        
        self.cmbFormat.text := self.myReportAgent.FORMAT_OPTION_STANDARD;
		self.tblPrintOptions.setValueByName(ETRow_FormatOption, self.myReportAgent.FORMAT_OPTION_STANDARD);
        return;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_request" type="BGP_ReportRequest"/>
    </JadeMethod>
    <JadeMethod name="setFromQuickFind" id="b95b5b43-a68a-45ae-803c-d8478ba21786">
        <updating/>
        <source>setFromQuickFind(_obj: CM_Object; _text: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2014	cnwndl1	Initial creation

*/

vars

begin
	
	if _text &lt;&gt; null then
		
		
		self.doReportSearch();
		self.txtSearchReport.text := _text;
		self.btnFindTV_click(self.btnFindTV);
		if self.lbReportTree.listIndex &gt; 0 then
			self.lbReportTree_click(self.lbReportTree);
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
    <JadeMethod name="setOutputType" id="f90a13a7-51ab-4441-8dbf-1cca43de95f0">
        <updating/>
        <source>setOutputType(_request : BGP_ReportRequest) protected, updating;

// cnwdvb1 24 April 2003 

vars

begin

	if _request &lt;&gt; null then
		if _request.outputType = BGP_ReportRequest.Print then
			self.cmbDestination.text := self.DESTINATION_PRINT;
			self.tblPrintOptions.setValueByName(ETRow_DestinationOption, self.DESTINATION_PRINT);
			return;
		elseif _request.outputType = BGP_ReportRequest.SaveAndPrint then
			self.cmbDestination.text := self.DESTINATION_PRINTANDSAVE;
			self.tblPrintOptions.setValueByName(ETRow_DestinationOption, self.DESTINATION_PRINTANDSAVE);
			return;
        elseif _request.outputType  = BGP_ReportRequest.FTP_SFTP then                               //MTN-36668
            self.cmbDestination.text := self.DESTINATION_SFTP;                                  //MTN-36668
			self.tblPrintOptions.setValueByName(ETRow_DestinationOption, self.DESTINATION_SFTP);//MTN-36668
            return;                                                                                 //MTN-36668
		endif;
	endif;
	
	self.cmbDestination.text := self.DESTINATION_SAVE;
	self.tblPrintOptions.setValueByName(ETRow_DestinationOption, self.DESTINATION_SAVE);
	
end;</source>
        <access>protected</access>
        <Parameter name="_request" type="BGP_ReportRequest"/>
    </JadeMethod>
    <JadeMethod name="setPrintOptionsView" id="93bd6d7e-dd95-44df-ab67-9b030561e29a">
        <updating/>
        <source>setPrintOptionsView() protected, updating;
// ---------------------------------------------------------------------------
// Created:     02 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	formatOption 			: Integer;
	processOption			: String;
	viewName				: String;
	entView					: EntTableView;
	entDef					: EntTableDef;
	doEmail,
	doNoData,
	isPDF					: Boolean;
	printer					: CM_PrinterDef;
    destinationOption       : String;           //MTN-36668
begin
	doNoData := true;
	entDef := app.myController.getEntTableDef(ETDef_ReportOptions);

	self.shtTemplate.visible := false;
	self.setTemplateControlsEnabled(false);

	if self.cmbFormat.listIndex &gt; 0 then
		formatOption := self.cmbFormat.itemData[self.cmbFormat.listIndex];
	else
		formatOption := JadeReportWriterReport.PRINTER;
	endif;
	
	processOption := self.tblPrintOptions.getValueByName(ETRow_ProcessOption).String;
	printer := self.cmbPrinter.listObject.CM_PrinterDef;
	if printer &lt;&gt; null then
		isPDF := printer.printerIsPDF;
	endif;
	//if we are viewing the BGP reports table
	if self.myReportAgent.state = self.myReportAgent.STATE_BGR_RUN then
		if global.isValidObject(self.myBGPReport) then
			doEmail := (self.myBGPReport.myEmailTemplate &lt;&gt; null);
			doNoData := self.myBGPReport.emailNoDataRpt();
			if self.myBGPReport.allMenuCSVFileData.size &gt; 0 then
				// This view is for current menu reports that have a file to dump down to disk.
				viewName := 'BGRCSVRun';
			else
				viewName := 'BGRRun';
			endif;
		endif;
	
	elseif self.myReportAgent.state = self.myReportAgent.STATE_TEMPLATE_VIEW then
		self.shtTemplate.visible := true;
		doEmail := (self.myMenuEntity.CM_MenuUserReport.myEmailTemplate &lt;&gt; null);
		doNoData := self.myMenuEntity.CM_MenuUserReport.emailNoDataRpt();
		//if self.myMenuEntity.CM_MenuUserReport.myReportRequest.outputDestination = JadeReportWriterReport.PRINTER then
		//PAR22361 - cnwsh3 - 18/02/2010 - Remove references to CM_MenuUserReport.myReportRequest 
		//mapped method.  Now using getBGPReportRequest method
		if self.myMenuEntity.CM_MenuUserReport.getBGPReportRequest().outputDestination = JadeReportWriterReport.PRINTER then
			if isPDF then	//and app.getMyUser.canDo(app.getMyTerminalDO_NOT_USE, PmPDFBackground) then
				// This view is for viewing a pre existing pdf template.
				viewName := 'templateStandardViewPDF';
			else
				// This view is for viewing a standard Jade report template.
				viewName := 'templateStandardView';
			endif;
		else
			// This view is for file format templates.
			viewName := 'templateCSVView';
		endif;
	
	elseif self.myReportAgent.state = self.myReportAgent.STATE_TEMPLATE_EDIT then
		self.shtTemplate.visible := true;
		self.setTemplateControlsEnabled(true);
		doEmail := (self.myMenuEntity.CM_MenuUserReport.myEmailTemplate &lt;&gt; null);
		doNoData := self.myMenuEntity.CM_MenuUserReport.emailNoDataRpt();
	//	if isPDF and app.getMyUser.canDo(app.getMyTerminalDO_NOT_USE, PmPDFBackground) and
		if isPDF and	//07 Oct 2019	NDL	TFS 46169
		   formatOption = JadeReportWriterReport.PRINTER then
		   	// This view is for editing a pdf template.
			viewName := 'editTemplatePDF';
		elseif formatOption &lt;&gt; JadeReportWriterReport.PRINTER then
			// This view is for editing file templates.
			viewName := 'editTemplateCSV';
		else
			// This view is for editing a standard Jade report template.
			viewName := 'editTemplateStandard';
		endif;
		
	elseif formatOption = JadeReportWriterReport.PRINTER then
		if processOption = self.PROCESS_FOREGROUND then
			// This view is for running a standard Jade report in the foreground.
			viewName := 'standard';
		elseif processOption = self.PROCESS_BACKGROUND then
		//	if isPDF and app.getMyUser.canDo(app.getMyTerminalDO_NOT_USE, PmPDFBackground)then
			if isPDF then	//07 Oct 2019	NDL	TFS 46169
				// This view is for running a standard pdf report in the background.
				viewName := 'standardBGPPDF';
			else
				viewName := 'standardBGP';
			endif;
		elseif processOption = self.PROCESS_TEMPLATE then
			self.shtTemplate.visible := true;
			self.setTemplateControlsForNew();
			self.setTemplateControlsEnabled(true);
		//	if isPDF and app.getMyUser.canDo(app.getMyTerminalDO_NOT_USE, PmPDFBackground) then
			if isPDF then	//07 Oct 2019	NDL	TFS 46169
				viewName := 'standardTemplatePDF';
			else
				viewName := 'standardTemplate';
			endif;
		endif;
		
	else
		if processOption = self.PROCESS_FOREGROUND then
			// This view is for running a file basef report in the foreground.
			viewName := 'CSV';
		elseif processOption = self.PROCESS_BACKGROUND then
			// This view is for running a file based report format in the background.
			viewName := 'CSVBGP';
		elseif processOption = self.PROCESS_TEMPLATE then
			self.shtTemplate.visible := true;
			self.setTemplateControlsForNew();
			self.setTemplateControlsEnabled(true);
			// This view is for creating a file format template.
			viewName := 'CSVTemplate';
		endif;
	endif;
	
	if viewName &lt;&gt; null then
		entView := entDef.allEntTableViews[viewName];
		self.tblPrintOptions.showHideRowsByView(entView, CM_EntryTable.ShowHideRows, false);
		self.tblPrintOptions.setValueByName(ETRow_DoEmail, doEmail);
		if not app.myRoot.getConfig(RunReportWhenNoData).Boolean then
			self.tblPrintOptions.hideRowByName(ETRow_EmailNoDataRpt, false);
		else
			self.tblPrintOptions.setValueByName(ETRow_EmailNoDataRpt, doNoData);
		endif;
		
		self.tblPrintOptions.adjustHeight(150);
//		self.tblPrintOptions.cnAdjustColumnWidths();
        
        destinationOption := self.cmbDestination.text;                      //MTN-36668
        if destinationOption &lt;&gt; self.DESTINATION_SFTP then              //MTN-36668
            self.tblPrintOptions.hideRowByName(ETRow_FTPEntity, false);     //MTN-36668
        endif;                                                              //MTN-36668
	endif;
    
   	self.handlePrintBackgroundOptions();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setReportTemplateProxy" id="e9017d07-8753-4e90-bf8c-4d73407906e0">
        <source>setReportTemplateProxy(	_pxyReportTemplate	: CM_ReportTemplate input;
						_filter				: CMQF_FilterReports;
						_extraDetail		: CM_ExtraDetail;
						_emailTemplate		: CM_EmailTemplate input;
						_destination		: Integer;
						_profName,
						_printerName		: String;
                        _ftpEntity          : CM_FTPEntity) protected;
// -------------------------------------------
// Created 10 December 2004 by cnwdvb1
// -------------------------------------------
vars

	allUsersToGetOutput,
	allUsersWhoCanEdit		: CM_UserSet;
	networkFilepath			: String;
	stopEmailWhenNoDataRpt	: Boolean;



begin

	networkFilepath := self.tblPrintOptions.getValueByNameIfVisible(ETRow_ServerFilePath).String;
	create allUsersToGetOutput transient;
	create allUsersWhoCanEdit transient;
	
	self.multiGrpEdit.getSelected(allUsersWhoCanEdit);
	self.multiGrpOutput.getSelected(allUsersToGetOutput);
	
	stopEmailWhenNoDataRpt := not self.tblPrintOptions.getValueByNameIfVisible(ETRow_EmailNoDataRpt).Boolean;
	
	_pxyReportTemplate.setForProxy(	self.tblPrintOptions.getValueByName(ETRow_TemplateName).String,
									self.tblPrintOptions.getValueByName(ETRow_TemplateDescription).String,
									_profName,
									_printerName,
									networkFilepath,
									_destination,
									self.getOutputType(),
									stopEmailWhenNoDataRpt,
									_filter,
									self.myReportAgent.myQryReport,
									_extraDetail,
									_emailTemplate,
									self.cmbUserRunAs.listObject.CM_User,
									allUsersToGetOutput,
									allUsersWhoCanEdit,
                                    _ftpEntity,                 //MTN-36668
									app.myPassport);
									
epilog	

	delete allUsersToGetOutput;
	delete allUsersWhoCanEdit;
end;</source>
        <access>protected</access>
        <Parameter name="_pxyReportTemplate" type="CM_ReportTemplate" usage="input"/>
        <Parameter name="_filter" type="CMQF_FilterReports"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <Parameter name="_emailTemplate" type="CM_EmailTemplate" usage="input"/>
        <Parameter name="_destination" type="Integer"/>
        <Parameter name="_profName" type="String"/>
        <Parameter name="_printerName" type="String"/>
        <Parameter name="_ftpEntity" type="CM_FTPEntity"/>
    </JadeMethod>
    <JadeMethod name="setStateFromReportAgent" id="2de26bb5-6273-422e-93c7-98f6dd95905d">
        <updating/>
        <source>setStateFromReportAgent(_state : String) updating;
// ---------------------------------------------------------------------------
// Created:     17 December 2002		cnwth2	
//
// Purpose:     As the form is quite complex, this method handles the visibility and enabling
//				of controls. *Class constant passed in
//
//			 	IMPORTANT - THIS SHOULD ONLY BE CALLED FROM THE METHOD
//					CMUI_ReportAgentStd.setState(..)
// ----------   ----------  --------------------------------------------------
// 16/11/2010	cnwdad1		PAR #25218.
// 22/11/2010	cnwdad1		PAR #25218.
// 19 June 2018	jlgrh7 		TFS #39308 LNX - Include Debtor Maintenance in Audit Enquiry
// 20 June 2018 jlgrh7		LNX - Cannot set Rundate for ETA and ETD for report templates
// 3/11/2019	jlgns1		TFS 3827 XLAT_FormCaptions need to be sorted out
// 20/05/2021	navmd1		TFS 51190 Handle crap data a bit better
// 10/02/2022	jlizm1		TFS 52643 SNO Error creating report template
// 16 March 2023 navhl20 	Defect 57144: Send to Report showing Error
// 24/04/2023	navkc1		CR 55654 Task 55670: Jade - Contract reporting
// 24 Oct 2025	navec1		MTN-36160: NSWP | Implement Date String Parsing and Conversion Logic

vars
	
	desc	: String;

begin

	if self.myReportAgent.myQryReport &lt;&gt; null then
		desc := self.myReportAgent.myQryReport.reportDescription;
	endif;
	
	self.lbReportTree.enabled 		:= true;
	self.btnDeleteBGR.enabled 		:= false;
	self.btnPrint.enabled 			:= false;
	self.tblBGPReports.visible		:= false;
	self.tblBGPEnt.visible			:= false;
	self.tblParameter.visible 		:= false;
	self.lblRepName.visible 		:= false;	
	self.tblTerminals.enabled 		:= false;
	self.btnEdit.enabled 			:= false;
    self.grpOutputOptions.visible   := true;        //MTN-36668

	// cnwrl1 01/12/2009 PAR 19950 - start of coding
	// Revert the button captions to the original values,
	// this is because some of the options eg STATE_BGR_EDIT change them.
	self.btnPrint.translateCaption( Xlat_0000800, null );
	self.btnDeleteBGR.translateCaption( Xlat_0000796, null );
	// cnwrl1 01/12/2009 PAR 19950 - end of coding
	
	self.tblPrintOptions.userInputEnabled := true;
	self.tblPrintOptions.enableRowByName(ETRow_FormatOption);
	self.tblPrintOptions.enableRowByName(ETRow_ProcessOption);

	if _state = self.myReportAgent.STATE_QRYREPORT then
		self.lblRepName.visible 		:= true;	
		self.btnPrint.enabled 			:= true;
		self.tblParameter.visible 		:= true;
		self.tblTerminals.enabled 		:= true;

		self.switchDateBoxComboBox(false, ETRow_BaseDate, self.cmbBaseDate);
		self.switchDateBoxComboBox(false, ETRow_CloseDate, self.cmbCloseDate);
		self.switchDateBoxComboBox(false, ETRow_PackByDate, self.cmbPackByDate);
		self.switchDateBoxComboBox(false, ETRow_MatchDateEnd, self.cmbMatchEnd);
		self.switchDateBoxComboBox(false, ETRow_MatchDateStart, self.cmbMatchStart);
		self.switchDateBoxComboBox(false, ETRow_OnDate, self.cmbOnDate);
		self.switchDateBoxComboBox(false, ETRow_OpenDate, self.cmbOpenDate);
		self.switchDateBoxComboBox(false, ETRow_ProcessDate, self.cmbProcDate);	//16 Nov 2009	NDL	Par 21519
		
		self.switchDateBoxComboBox(false, ETRow_StartDate, self.cmbOpenDate);
		self.switchDateBoxComboBox(false, ETRow_EndDate, self.cmbCloseDate);
		
		self.switchDateBoxComboBox(false, ETRow_EffectiveDate, self.cmbOnDate);	 	//cnwrd1 par 23583 11.8.2010
		self.switchDateBoxComboBox(false, ETRow_ExpiryDateFrom, self.cmbOpenDate);	//cnwrd1 par 23583 11.8.2010
		self.switchDateBoxComboBox(false, ETRow_ExpiryDateTo, self.cmbCloseDate);	//cnwrd1 par 23583 11.8.2010
		
		self.switchDateBoxComboBox(false, ETRow_LastConnectDT, self.cmbOnDate);	
		
		// HMS
		self.switchDateBoxComboBox(false, ETRow_ArrivalsDateFrom, self.cmbArriveDFrom);
		self.switchDateBoxComboBox(false, ETRow_ArrivalsDateTo, self.cmbArriveDTo);
		self.switchDateBoxComboBox(false, ETRow_DepartedDateFrom, self.cmbDepartDFrom);
		self.switchDateBoxComboBox(false, ETRow_DepartedDateTo, self.cmbDepartDTo);
		self.switchDateBoxComboBox(false, ETRow_InPortDateFrom, self.cmbInPortDFrom);
		self.switchDateBoxComboBox(false, ETRow_InPortDateTo, self.cmbInPortDTo);
		
		// 20/04/2023	navkc1	CR 55654 Task 55670 --&gt;
		self.switchDateBoxComboBox(false, ETRow_ContractFromStartDate, self.cmbContractFromStartDate);
		self.switchDateBoxComboBox(false, ETRow_ContractToStartDate, self.cmbContractToStartDate);
		self.switchDateBoxComboBox(false, ETRow_DetailFromStartDate, self.cmbDetailFromStartDate);
		self.switchDateBoxComboBox(false, ETRow_DetailToStartDate, self.cmbDetailToStartDate);
		self.switchDateBoxComboBox(false, ETRow_RateFromStartDate, self.cmbRateFromStartDate);
		self.switchDateBoxComboBox(false, ETRow_RateToStartDate, self.cmbRateToStartDate);
		
		self.switchDateBoxComboBox(false, ETRow_ContractFromEndDate, self.cmbContractFromEndDate);
		self.switchDateBoxComboBox(false, ETRow_ContractToEndDate, self.cmbContractToEndDate);
		self.switchDateBoxComboBox(false, ETRow_DetailFromEndDate, self.cmbDetailFromEndDate);
		self.switchDateBoxComboBox(false, ETRow_DetailToEndDate, self.cmbDetailToEndDate);
		self.switchDateBoxComboBox(false, ETRow_RateFromEndDate, self.cmbRateFromEndDate);
		self.switchDateBoxComboBox(false, ETRow_RateToEndDate, self.cmbRateToEndDate);
		// 20/04/2023	navkc1	CR 55654 Task 55670 &lt;--
		
		self.switchDateBoxComboBox(false, ETRow_MovementDateFrom, self.cmbArriveDFrom);
		self.switchDateBoxComboBox(false, ETRow_MovementDateTo, self.cmbArriveDTo);
		
		self.switchDateBoxComboBox(false, ETRow_FromPackByDate, self.cmbOpenDate);		// cnwdad1 19/11/2010 - PAR #25218.
		self.switchDateBoxComboBox(false, ETRow_ToPackByDate, self.cmbCloseDate);		// cnwdad1 19/11/2010 - PAR #25218.
		
		//30 Dec 2010	NDL	Par 26650
		self.switchDateBoxComboBox(false, ETRow_FromEstReqDate, self.cmbOpenDate);
		self.switchDateBoxComboBox(false, ETRow_ToEstReqDate, self.cmbCloseDate);
		self.switchDateBoxComboBox(false, ETRow_ReportDate, self.cmbBaseDate);	//14 Sep 2012	EPR PAR 30364
		
		//12 Jul 2016	NDL	TFS 2234
		self.switchDateBoxComboBox(false, ETRow_FromDate, self.cmbOpenDate);
		self.switchDateBoxComboBox(false, ETRow_ToDate, self.cmbCloseDate);
		
