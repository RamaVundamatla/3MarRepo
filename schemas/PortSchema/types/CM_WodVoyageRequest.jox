    <JadeMethod name="getDisplayString" id="7be14ce4-48f9-457f-9d1e-b69bfcdc42a4">
        <source>getDisplayString(_useShortDesc: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jun 2018	jlger1	Initial creation
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars
	displayString : String;
	typeDesc      : String;
begin
	typeDesc := self.getTypeDescription();							   //29.09.2021 navma1 #51925
	
	if _useShortDesc then
		displayString := typeDesc;
	else
		displayString := self.getLongDescription(typeDesc,null);		//29.09.2021 navma1 #51925
	endif;
	
	return displayString;
epilog

end;</source>
        <Parameter name="_useShortDesc" type="Boolean"/>
