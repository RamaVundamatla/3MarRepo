    </JadeMethod>
    <JadeMethod name="setTiReceivedTransportMode" id="e9c2de47-4c12-401f-a748-b5b76577e7ac">
        <source>setTiReceivedTransportMode(_ti: CM_TrackedItem input);
// ---------------------------------------------------------------------------
// Created:     24 May 2004 by cnwrs1
//
// Purpose:     PAR8243     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	_ti.setReceiptTransportMode(TI_TRANSMODE_RAIL);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="a2bf7247-a8ef-4647-9ad5-9e54dcabc369">
        <updating/>
        <source>updateTI(_passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     27 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 26/09/2008	concms1	par 16130 - new parameter for clearPIN method
vars
	ti	: CM_TrackedItem;
	trainCode	: String;
begin
	inheritMethod(_passport);
	
	ti := self.myTrackedItem;
	if ti &lt;&gt; null then	
		ti.removePIN(true, false); // cnwrd1 par 22624 3.5.2010
	/*
		// 18/05/2009 cnwar2 CCMS1723/#???
		if ti.myTerminal.getConfig(PinEmbargoDays).Integer &lt;&gt; 0 then
			ti.embargoPIN(true);
		else
			ti.clearPIN(true);	// par 16130
		endif;
	*/
		// 25618 selector query by receival train, save in allExtraData
		trainCode := ti.findReceiveTrainCode();
		if trainCode &lt;&gt; null then
			self.setExtraData(TrnsExtraDataReceiveTrain, trainCode);
		endif;
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
