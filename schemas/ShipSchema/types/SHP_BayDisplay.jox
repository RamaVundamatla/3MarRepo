    <JadeMethod name="initSelectBayCombo" id="b08e65f6-a7d4-4b43-9d88-fbc017bc648a">
        <source>initSelectBayCombo(_combo : CMUI_ComboBox input);

vars

	aBay : CM_Bay; //Defn;
	idx : Integer;
	bayColl : Collection;
	obj : Object;
	iter : Iterator;
begin
	
	_combo.clear;

	bayColl :=self.getBaysCollection;
	if bayColl = null then
		return;
	endif;
	iter:=bayColl.createIterator;
	
	idx := _combo.addItem(null);
	while iter.next(obj) do
		aBay := obj.CM_Bay;
		idx := _combo.addItemObject(aBay.id.trimBlanks,aBay);
		if aBay = self.myBay then
			_combo.listIndex := idx;
		endif;
		if aBay.myHold &lt;&gt; null then
			if aBay.myHold.ordinalHold mod 2 = 0 then
				_combo.itemBackColor[idx] := CM_BaseForm.ColourYellowDark;
			else
				_combo.itemBackColor[idx] := PaleYellow;
			endif;
		endif;
	endwhile;
	
epilog
	
	delete iter;
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
