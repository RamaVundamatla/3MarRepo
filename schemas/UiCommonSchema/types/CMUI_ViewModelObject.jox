    <JadeMethod name="displayEntryListbox" id="6462737d-1fc7-4bc5-8283-ff3f74eb8d62">
        <source>displayEntryListbox() : String;
// -----------------------------------------------------------------------------
// Created:		12 February 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	obj			: CM_Object;
	invalidObj	: Boolean;

begin

	on Exception do app.handleDeletedObject( exception, obj, invalidObj );	// when deleted by another user, it can be not null but invalid. CCMS 1105, PAR 21535 Nov 2009

	obj := self.myObject;
	if obj = null or invalidObj then
		return null;
	endif;
	
	return obj.displayEntryListbox;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="d81bc341-5709-4330-a235-1b189055ff09">
        <updating/>
        <source>initializeMe(_object : CM_Object; _index : Integer; _parent : SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		12 February 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	myObject := _object;
	index 	 := _index;
	myParent := _parent;
end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="setExpanded" id="2fc2cc1a-be2e-4031-98a5-4263bcbe1a06">
