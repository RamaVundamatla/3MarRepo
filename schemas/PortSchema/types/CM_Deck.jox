    <JadeMethod name="exportAsXMLInverseRef" id="bd8e08fb-795d-465a-bbea-7dede8283f42">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 April 2011	cnwer1	Initial creation

*/

vars

begin
	if _property = CM_Deck::allDeckItems then
		return NoExport;
	elseif _property = CM_Deck::allLifts then
		return ExportAsParent;
	elseif _property = CM_Deck::allMachinery then
		return ExportAsParent;
	elseif _property = CM_Deck::allGeneralItems then
		return ExportAsParent;
	elseif _property = CM_Deck::allROROLaneDefnByOrdinal then
		return NoExport;
	elseif _property = CM_Deck::allROROLocnDefnByOrdinal then
		return NoExport;
	elseif _property = CM_Deck::allRamps then
		return ExportAsParent;	
	elseif _property = CM_Deck::allSlotDefnByOrdinal then 
	// will be export as part of the CM_RORLocnDefnVessel::allROROSlotDefnByOridnal collection
		return NoExport;
	elseif _property = CM_Deck::myDeckLayout then
		return ExportAsParent;
	endif;

	return inheritMethod(_property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="4f5960e6-7593-447f-9329-83d7198f3dcc">
        <source>findLocation(_strs: StringArray; _noException : Boolean; _foundLC: CM_LocationsController io; _foundHeight: Integer io);
//--------------------------------------------------
// Created:	03 April 2006 By: cnwgd1
//--------------------------------------------------
vars
	locn : CM_ROROLocnDefnVoyage;
	lane : CM_ROROLaneDefnVoyage;
	slot : CM_ROROSlotDefn;
	locnID : String;
begin
	if _foundLC &lt;&gt; null then
		return;
	endif;

	locnID := _strs[1];
	
	slot := self.allSlotDefnByCode[locnID].CM_ROROSlotDefnVoyage;
	if slot &lt;&gt; null then
		_foundLC := slot.CM_ROROSlotDefnVoyage.mySlotController;
	endif;
	
	if _foundLC &lt;&gt; null then
		return;
	endif;
	
	locn := self.allROROLocnDefnByCode[locnID].CM_ROROLocnDefnVoyage;
	if locn &lt;&gt; null then
		foreach slot in locn.allROROSlotDefnByOrdinal discreteLock do
			if slot.CM_ROROSlotDefnVoyage.mySlotController.allTrackedItems.isEmpty() then
				_foundLC := slot.CM_ROROSlotDefnVoyage.mySlotController;
				break;
			endif;
		endforeach;
	endif;
	
	if _foundLC &lt;&gt; null then
		return;
	endif;

	lane := self.allROROLaneDefnByCode[locnID].CM_ROROLaneDefnVoyage;
	if lane &lt;&gt; null then
		_foundLC := lane.myLaneController;
	endif;
	
	if _foundLC &lt;&gt; null then
		return;
	endif;
	
	
	
	
	
end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="generateDeckImage" id="77b58f3d-e73f-4373-968c-0513fbd89c66">
        <source>generateDeckImage();
/*

Purpose:	generate a deck binary image  that is 70 pixels high		

Parameters:			

Return Value:		


Date		Who		Reason
24 June 2011	cnwer1	Initial creation CCMS MES 1116

*/
constants
	Margin = 10;
vars
	x1, y1, x2, y2   :Integer;
	 thePageHeight : Integer;
	 scale : Decimal[12,2];
//	printFrame : CMUI_PointDrawingFrame; ///arggh print is done on the frame which of course is in UiCommonSchema
//	viewPort	: CMUI_Frame;
	layerLayout : CM_DeckLayerLayout;
	deckItemLayout : CM_DeckItemLayout;
	offsetLeft	, offsetTop	: Real;
	pageHeight : Real;
begin

	thePageHeight:=70;
	//no layout no graphics
	if self.myDeckLayout = null then
		return;
	endif;
	
	self.myDeckLayout.getExtremePoints(x1, y1, x2, y2 );
	
	scale:=(thePageHeight-Margin)/(y2-y1);
epilog

end;</source>
    </JadeMethod>
