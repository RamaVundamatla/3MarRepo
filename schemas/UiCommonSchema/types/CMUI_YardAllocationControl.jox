    <JadeMethod name="userNotify" id="7a31e83a-20ff-450c-b714-16ad99d04bfa">
        <controlMethod name="BaseControl::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>userNotify(cntrl: BaseControl input; eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		23 March 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, eventType, theObject, eventTag, userInfo);
	
	if eventType = EVENT_YA_CP_CREATE then
		
	elseif eventType = EVENT_YA_CP_DELETE then
		
	elseif eventType = EVENT_YA_CP_UPDATE then
		if userInfo.Process = process then
			return;
		endif;
		
		app.msgBox(	"The information you are viewing has been changed by another user or process.  " &amp;
					"When you click 'OK', the form will be refreshed.",
					"Warning",
					MsgBox_Information_Icon + MsgBox_OK_Only);
		
//		beginLoad;
		
		self.doRefreshCPCollection();
		self.yaRefreshCriteriaPriority(null);
		
//		endLoad;
	endif;
end;</source>
        <Parameter name="cntrl" type="BaseControl" usage="input"/>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="06b95307-549e-485f-a2a5-16223637eb91">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		28 February 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	terminalObj	: CM_Terminal;
	passportObj	: CM_Passport;
	userObj		: CM_User;
	
begin
	inheritMethod(cntrl, persistCntrl);
	
	self.transparent			:=	true;
	self.isFirstLocationLoad	:=	true;
	
	if not self.isInPainter() then
		self.isBlockGroupsUsed		:=	app.myPassport.myTerminal.isAutoPlanYAGroupedBlocks();   //SFW1030 04/08/2008
	endif;
	
	self.setupChildControls();
	
	if not self.isInPainter() then
		self.enableDeckingOptionsButtons(false);
		self.populateFillOptionCombos(myCmbOptionIn);
		self.populateFillOptionCombos(myCmbOptionOut);
		self.populateOverlapFlagCombobox();
		self.populateNoLocationFlagCombobox();
	endif;
	
	self.myCtrlCriteria.hideCriteriaCode();
	
	if not self.isInPainter() then
		terminalObj	:=	app.getMyTerminalDO_NOT_USE();
		
		if terminalObj = null then
			if app.isDevelopmentSystem() then
				terminalObj	:=	CM_Terminal.firstInstance();
			else
				// Raise an exception, since a Terminal should always be found at run-time.
				app.raiseCMException1(ERR_NO_OBJECT, "Terminal", "No Terminal was found.", null);
			endif;
		endif;
		
		self.populateOverstowRulesCombobox(terminalObj);
		passportObj	:=	app.myPassport;
		
		if passportObj &lt;&gt; null then
			userObj	:=	passportObj.myUser;
			
			if userObj = null then
				self.myTxtPriorityAdj.visible	:=	false;
			else
				self.myTxtPriorityAdj.visible	:=	userObj.canDo(terminalObj, PmYAMaintPriorityValue);
			endif;
			
			self.myLblPriorityAdj.visible	:=	self.myTxtPriorityAdj.visible;
		endif;
		
		self.beginNotification(terminalObj, terminalObj.getTerminalEvent(EVENT_YA_CP_CREATE), Response_Continuous, null);	
		self.beginNotification(terminalObj, terminalObj.getTerminalEvent(EVENT_YA_CP_DELETE), Response_Continuous, null);	
		self.beginNotification(terminalObj, terminalObj.getTerminalEvent(EVENT_YA_CP_UPDATE), Response_Continuous, null);	
	endif;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
    <JadeMethod name="yaGetCriteriaPriority" id="21838471-930b-410f-b5af-bf9c6b4ff0db">
        <source>yaGetCriteriaPriority():CMIF_YACriteriaPriority;
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Purpose:		Returns a reference to the Criteria currently selected in the table.
//
// Parameters:	None
//
// Returns:		A reference to a Criteria object, otherwise null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myLstCriteria.listIndex = CNEC_NULL_INDEX then
		return null;
	else
		return self.myLstCriteria.listObject.CMIF_YACriteriaPriority;
	endif;
end;</source>
        <ReturnType type="CMIF_YACriteriaPriority"/>
    </JadeMethod>
    <JadeMethod name="yaRefreshCriteriaPriority" id="4d22fc31-5716-454a-b4ce-a81fe5e1dabe">
        <source>yaRefreshCriteriaPriority(_obj : Object);
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Purpose:		Refreshes the display of the Yard Allocation Criteria list.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listboxObj		: CMUI_ListBox;
	currentObj		: Object;
	yaColorVoyage	: Integer;
	
begin

	listboxObj	:=	self.myLstCriteria;
	
	if _obj = null then
		currentObj := listboxObj.listObject.CMIF_YACriteriaPriority;
	else
		currentObj := _obj;
	endif;

	listboxObj.clear();
	listboxObj.listCollection(	self.myCtrlCriteria.allSelectedCPs,
								false,
								Collection.CNEC_DISPLAY_ORDER_COLLECTION);
	
	if currentObj = null then
		currentObj := self.myCtrlCriteria.allSelectedCPs.first.CMIF_YACriteriaPriority;
	endif;
	
	if currentObj &lt;&gt; null then
		listboxObj.selectObject(currentObj);
		listboxObj.click(listboxObj);
		
	endif;
	
	// ### Default description for NEW allocations
	if self.myProxyYA.pxyGetRealObject = null then // PAR 10442
		self.myTxtDescription.text := self.getDefaultDescription();
	endif;
	
	yaColorVoyage	:= self.getVoyageColour(self.myCtrlCriteria.allSelectedCPs);
	
	if yaColorVoyage &lt;&gt; 0 then
		self.myLblColorPicker.backColor := yaColorVoyage;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="yaSetCriteriaPriority" id="deefe914-f160-4369-b162-c79b1488ee76">
        <updating/>
        <source>yaSetCriteriaPriority(_yaCriteriaPriority: CMIF_YACriteriaPriority) updating;
// ---------------------------------------------------------------------------
// Created:     20 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.myLstCriteria = null then
		// We have not been setup yet.
		return;
	endif;
	
	if self.myLstCriteria.findObject(_yaCriteriaPriority) = CNEC_NULL_INDEX then
		self.myLstCriteria.listIndex	:=	CNEC_NULL_INDEX;
	else
		self.setSelectedCP(_yaCriteriaPriority.myCriteriaPriority);
		self.myLstCriteria.selectObject(_yaCriteriaPriority);
	endif;
end;</source>
        <Parameter name="_yaCriteriaPriority" type="CMIF_YACriteriaPriority"/>
    </JadeMethod>
