    <JadeMethod name="getCalculationType" id="cdf1d0ba-11c5-406d-b748-249ba78465af">
        <source>getCalculationType() : CM_CalculationType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/01/2025	navkc1 JIRA Bug MTN-33760: EUP | FR 14673 - Invoice Contract Enquiry screen results for Rates 

*/

vars
	contractDetails : CM_InvoiceContractDetails;
	
begin
	contractDetails := self.getInvoiceContractDetails();
	
	if contractDetails &lt;&gt; null then
		return contractDetails.myCalculationType;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_CalculationType"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="af4c09c0-801f-421e-84b2-72d5c7ba51b8">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes
15 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results

*/

vars
	invoiceContractDetails : CM_InvoiceContractDetails;
	contract : CM_InvoiceContract;
	service  : CM_Service;
	calculationType : CM_CalculationType;
	rateEntry	: CM_InvoiceContractRateEntry;
begin
	if _attrName = ETRow_FromTS then
		return self.systemToLocalTime(self.fromTS).asStringJMT();
	elseif _attrName = ETRow_ToTS then
		return self.systemToLocalTime(self.toTS).asStringJMT();
	elseif _attrName = ETRow_Criteria then															//15.10.2024 navlc30 #19508
		invoiceContractDetails := self.getInvoiceContractDetails();
		if invoiceContractDetails &lt;&gt; null and invoiceContractDetails.myInvoiceContractCriteria &lt;&gt; null then
			return invoiceContractDetails.myInvoiceContractCriteria.getCriteriaSummary(",");
		endif;
		return null;
	elseif _attrName = ETRow_InvoiceLineType then													//15.10.2024 navlc30 #19508
		invoiceContractDetails := self.getInvoiceContractDetails();
		if invoiceContractDetails &lt;&gt; null and invoiceContractDetails.myInvoiceLineType &lt;&gt; null then
			return invoiceContractDetails.myInvoiceLineType.narration;
		endif;
		return null;
	elseif _attrName = ETRow_ContractId then														//16.10.2024 navlc30 #19508
		invoiceContractDetails := self.getInvoiceContractDetails();
		if invoiceContractDetails &lt;&gt; null then
			contract := invoiceContractDetails.myInvoiceContract;
			if contract &lt;&gt; null then
				return contract.contractId;
			endif;	
		endif;
		return null;
	elseif _attrName = ETRow_DebtorName then														//16.10.2024 navlc30 #19508
		invoiceContractDetails := self.getInvoiceContractDetails();
		if invoiceContractDetails &lt;&gt; null then
			contract := invoiceContractDetails.myInvoiceContract;
			if contract &lt;&gt; null and contract.myDebtor &lt;&gt; null then
				return contract.myDebtor.name;
			endif;	
		endif;
		return null;
	elseif _attrName = ETRow_Service then															//16.10.2024 navlc30 #19508

		service := self.getInvoiceContractService;
		if service &lt;&gt; null then
			return service.name;
		endif;
		return null;
	elseif _attrName = ETRow_CalculationType then //24/01/2025	navkc1 JIRA Bug MTN-33760
		
		calculationType := self.getCalculationType();
		
		if calculationType &lt;&gt; null then
			return calculationType.description;
		endif;
		
		return null;
	elseif _attrName = ETRow_Rate then //24/01/2025	navkc1 JIRA Bug MTN-33760
		rateEntry := self.allInvoiceContractRateEntries.first();
		
		if rateEntry &lt;&gt; null then
			return rateEntry.costPerUnit.asStringJMTWithPrecision(4, true);
		endif;
		
		return null;
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="5ce3151b-4657-477c-84f6-f341aab30451">
        <source>getExtraInfo(_dataContainer: CM_DataContainer) ;
/*
Purpose - 	
Who - NAVAB1
Date - 29NOV2023
ADO -  CR 61268
*/

vars
	maxLen,
	first,
	int,
	count	: Integer;
	cpu : Real;
	caption : String;
	aCT : CM_CalculationType;
	calcType : Integer;
	rateEntry : CM_InvoiceContractRateEntry;
	qtyRange  : CM_QuantityRange;
	block : CM_DataContainerBlock;
	dpl : Integer;
	rate : CM_InvoiceContractRate;
begin
	
	foreach rateEntry in self.allInvoiceContractRateEntries do
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Rate), DC_MoreInfo, 1, rateEntry);

		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(From), DC_Label, 1, rateEntry);
		block.addNewItem(rateEntry.fromAmount.asStringJMTWithPrecision(2,true), DC_Data, 1, rateEntry);

		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(To), DC_Label, 1, rateEntry);
		block.addNewItem(rateEntry.toAmount.asStringJMTWithPrecision(2,true), DC_Data, 1, rateEntry);

		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Rate), DC_Label, 1, rateEntry);
		block.addNewItem(rateEntry.costPerUnit.asStringJMTWithPrecision(4,true), DC_Data, 1, rateEntry);

		// ### TFS CR 61579 TASK 62453 12FEB2024 NAVAB1
		if rate = null then
			rate := rateEntry.myInvoiceContractRate;
		endif;
	endforeach;
	
	if rate &lt;&gt; null 
	and rate.myCalculationType &lt;&gt; null then

		block := _dataContainer.insertNewBlock(1);
		block.addNewItem("Calculation Type", DC_Label, 1, rateEntry);
		block.addNewItem(rate.myCalculationType.description, DC_Data, 1, rateEntry);
	
		block := _dataContainer.insertNewBlock(1);
		block.addNewItem("Derive Quantity From", DC_MoreInfo, 1, rateEntry);
		
	endif;
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceContractDetails" id="dc5f93ba-da31-4ba8-b2be-6fe899b36bb9">
        <source>getInvoiceContractDetails() : CM_InvoiceContractDetails;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 October 2024	navlc30	Initial creation
15 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results
*/

vars
	invoiceContractDetails : CM_InvoiceContractDetails;
	rateEntry : CM_InvoiceContractRateEntry;
	rate : CM_InvoiceContractRate;	
begin
	
epilog

	foreach rateEntry in self.allInvoiceContractRateEntries do
		rate := rateEntry.myInvoiceContractRate;
		if rate &lt;&gt; null then
			invoiceContractDetails := rate.myInvoiceContractDetail;
			break;
		endif;		
	endforeach;

	return invoiceContractDetails;
end;</source>
        <ReturnType type="CM_InvoiceContractDetails"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceContractService" id="743295d1-779c-4709-92dc-69a5e7bc4610">
        <source>getInvoiceContractService() : CM_Service;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results
*/

vars
	service : CM_Service;
	rateEntry : CM_InvoiceContractRateEntry;
	rate : CM_InvoiceContractRate;	
begin
	
epilog

	foreach rateEntry in self.allInvoiceContractRateEntries do
		rate := rateEntry.myInvoiceContractRate;
		if rate &lt;&gt; null then
			service := rate.myService;
			break;
		endif;		
	endforeach;

	return service;
end;</source>
        <ReturnType type="CM_Service"/>
    </JadeMethod>
