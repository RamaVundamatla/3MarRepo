    <JadeMethod name="getAccessValue" id="68511829-3cdf-45c3-8fb9-676237388318">
        <updating/>
        <source>getAccessValue(_badFeature : Boolean output) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2010	conkc1:2	Initial creation
11 Nov 2019	jlgmd1	TFS 47391 - Allow identification of features that don't actually exist (ie, typos)

*/
vars
	class     : Class;
	className : String;
	tmpSchema : Schema;
	property  : Property;
	amethod   : Method;

begin

	if self.featureName = "edition" then
		return false;
	endif;

	if self.featureName.toUpper() = "OIDBIN" then
		return false;
	endif;
	
	if self.subClassName &lt;&gt; null then
		className := self.subClassName;
	else
		className := self.className;
	endif;
	
	tmpSchema := rootSchema.getSchema(PortSchemaName);
	class     := tmpSchema.getClass(className);

	property := class.getPropertyInHTree(self.featureName);
	if property = null then
		
		amethod := class.getMethodInHTree(self.featureName);
		if amethod = null then
			app.writeStatement("Error - " &amp; className &amp; " " &amp; self.featureName);
			_badFeature := true;
			return false;
		endif;
	endif;

	if property &lt;&gt; null then
		return property.access = #'2';
	endif;
	
	if amethod &lt;&gt; null then
		return amethod.access = #'2';
	endif;
epilog

end;</source>
        <Parameter name="_badFeature" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getReturnType" id="bdf34b68-521d-4d31-b835-f3cf09fec930">
        <source>getReturnType() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2010	conkc1	Initial creation

*/

vars
	class     : Class;
	classname : String;
	tmpSchema : Schema;
	property  : Property;
	amethod   : Method;
	type      : Type;
begin

	if self.featureName = "oidBin" then
		return true;
	endif;

	if self.subClassName &lt;&gt; null then
		classname := self.subClassName;
	else
		classname := self.className;
	endif;
	
	tmpSchema := rootSchema.getSchema(PortSchemaName);
	class     := tmpSchema.getClass(classname);

	property := class.getPropertyInHTree(self.featureName);
	if property = null then
		amethod := class.getMethodInHTree(self.featureName);
	endif;

	if property &lt;&gt; null then
		if property.isKindOf(Reference) then
			return true;
		endif;
	endif;
	
	if amethod &lt;&gt; null then
		if amethod.isKindOf(JadeMethod) then
			type := amethod.JadeMethod.getType;
			if type.isKindOf(PrimType) then
				return false;
			else
				return true;
			endif;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupAndBuildSet" id="b1ffc96f-d309-47cd-bd58-f10f0bbae487">
        <updating/>
        <source>setupAndBuildSet(_featureName : String; _className : String; _featureNiceName : String; 
				 _subClassName : String; _set : CMIF_ExternalDBFeatureSet input) updating;
//21 June 2012	cnwrs1		Par 29826 - doesn't work with blanks in field name
//23 Nov 2017	jlgdap1		TFS 7511 LNX Raise an exception if we're trying to add a duplicate on _featureName and _className
//11 Nov 2019	jlgmd1		TFS 47391 - Raise an exception if what we're adding doesn't actually exist
vars
	existing : CMIF_ExternalDBFeature;		// TFS 7511
	badFeature : Boolean;

begin
	if _featureNiceName.containsOneOf('/ ') then //par 29826 //cnwgb1 PAR 31664 11.6.2013 Add slash
		app.raiseUnexpectedProgramError(class.name, method.name, 'The Nice Feature Name '&amp;_featureNiceName&amp;' for feature '&amp;_featureName&amp;'::'&amp;_className&amp;' can not contain blanks or slashes, please correct');
		return;
	endif;
	self.featureName           := _featureName;
	self.className             := _className;
	self.subClassName          := _subClassName;
	
	if _featureNiceName &lt;&gt; null then
		self.featureNiceName       := _featureNiceName;
	else
		self.featureNiceName       := _featureName;
	endif;
	
	self.returnValueIsAnObject := self.getReturnType;
	self.isProtected           := self.getAccessValue(badFeature);
	
	// TFS 47391 Fail the unit test check if the defined feature doesn't exist on the given class/subclass
	if badFeature then
		app.raiseUnexpectedProgramError(class.name, method.name, "The feature " &amp; _featureName &amp; " does not exist for class/subclass " &amp; _className &amp; "/" &amp; _subClassName);
		return;
	endif;
	
	// TFS 7511 Check that we don't already have an entry for this feature name, class name and subclass name
	// E.G. myJob on CM_ReleaseShip and CM_ReceiveShip is allowed, but not the same attribute on teh same subclass
	if app.isDevelopmentSystemMain then
		foreach existing in _set do
			if existing.featureName	= self.featureName and existing.className = self.className and existing.subClassName = self.subClassName then
				app.raiseUnexpectedProgramError(class.name, method.name, "The feature " &amp; _featureName &amp; " has been used twice in class/subclass " &amp; _className &amp; "/" &amp; _subClassName);
				write existing.featureName &amp; Tab &amp; existing.className &amp; Tab &amp; existing.subClassName &amp; Tab &amp; self.subClassName;
				return;
			endif;
		endforeach;
	endif;
	// TFS 7511 end
	
	_set.add(self);
end;
</source>
        <Parameter name="_featureName" type="String"/>
        <Parameter name="_className" type="String"/>
        <Parameter name="_featureNiceName" type="String"/>
        <Parameter name="_subClassName" type="String"/>
        <Parameter name="_set" type="CMIF_ExternalDBFeatureSet" usage="input"/>
    </JadeMethod>
</Class>
