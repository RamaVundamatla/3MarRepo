    </JadeMethod>
    <JadeMethod name="notFinished" id="2c514b0c-94e6-4da8-b7f4-22e2c7451338">
        <source>notFinished() : Boolean;
vars
	machine: Object;
begin
	foreach machine in allMachines do
		if machine.SIM_Machine.hasWorkToDo then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
