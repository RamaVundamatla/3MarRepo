    <JadeMethod name="loadCmbConsign" id="df2066d0-0bd0-435b-8bba-d44614a4e546">
        <source>loadCmbConsign() protected;
// ---------------------------------------------------------------------------
// Created:     27 May 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On	Changed By	Reason
// ----------   ----------  --------------------------------------------------
// 29/06/2022	navdap1		TFS 53362 EUP Master Data Interface Customers Between TOS and ERP
vars
	consignDict		: CM_ConsignByCodeDict;
	consign			: CM_ConsigneeConsignor;
	tmpCmbEe,
	tmpCmbOr,
	tmpCmbFrightFwdr	: ComboBox;
	failedDAC	: CM_DataAccessController;
	consByName : Boolean;			// TFS 53362
	conStr : String;				// TFS 53362
	
begin
	consignDict := app.myRoot.allConsigneeConsignors;
	consByName := app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean;		// TFS 53362
	if consByName then																// TFS 53362
		self.cmbFiltConsignee.sorted := true;										// TFS 53362
		self.cmbFiltConsignor.sorted := true;										// TFS 53362
	endif;																			// TFS 53362

	tmpCmbEe := self.cmbFiltConsignee;
	tmpCmbOr := self.cmbFiltConsignor;
	tmpCmbFrightFwdr := self.cmbFiltFrghtFwdr;
	
	tmpCmbEe.clear();
	tmpCmbOr.clear();
	tmpCmbFrightFwdr.clear();
	
	tmpCmbEe.addItem(Any_String);
	tmpCmbOr.addItem(Any_String);
	tmpCmbFrightFwdr.addItem(Any_String);
	
	foreach consign in consignDict do
	
		if (not consign.canUserAccessSelf(null, failedDAC, app.myPassport)) then
			continue;
		endif;
		
		conStr := consign.code &amp; '  ' &amp; consign.description;			// TFS 53362
		if consByName then												// TFS 53362
			conStr := consign.description &amp; '  ' &amp; consign.code;		// TFS 53362
		endif;															// TFS 53362
		
		if not consign.isConsignee and not consign.isConsignor and not consign.isFreightFwdr then
			//tmpCmbEe.itemObject[tmpCmbEe.addItem(consign.code &amp; '  ' &amp; consign.description)] := consign;	// TFS 53362
			//tmpCmbOr.itemObject[tmpCmbOr.addItem(consign.code &amp; '  ' &amp; consign.description)] := consign;	// TFS 53362
			tmpCmbEe.itemObject[tmpCmbEe.addItem(conStr)] := consign;										// TFS 53362
			tmpCmbOr.itemObject[tmpCmbOr.addItem(conStr)] := consign;										// TFS 53362
			tmpCmbFrightFwdr.itemObject[tmpCmbFrightFwdr.addItem(consign.code &amp; '  ' &amp; consign.description)] := consign;
		endif;
	
		if consign.isConsignee then 
			//tmpCmbEe.itemObject[tmpCmbEe.addItem(consign.code &amp; '  ' &amp; consign.description)] := consign;	// TFS 53362
			tmpCmbEe.itemObject[tmpCmbEe.addItem(conStr)] := consign;										// TFS 53362
		endif;
		
		if consign.isConsignor then
			//tmpCmbOr.itemObject[tmpCmbOr.addItem(consign.code &amp; '  ' &amp; consign.description)] := consign;	// TFS 53362
			tmpCmbOr.itemObject[tmpCmbOr.addItem(conStr)] := consign;										// TFS 53362
		endif;
		
		if consign.isFreightFwdr then
			tmpCmbFrightFwdr.itemObject[tmpCmbFrightFwdr.addItem(consign.code &amp; '  ' &amp; consign.description)] := consign;
		endif;
	endforeach;
	
	self.tblSearch.setValueByName(ETRow_FilterConsignee, Any_String);
	self.tblSearch.setValueByName(ETRow_FiltConsignor, Any_String);
//	self.tblSearch.setValueByName(ETRow_FiltFreightForwarderCode, Any_String);
	tmpCmbEe.text := Any_String;
	tmpCmbOr.text := Any_String;
	tmpCmbFrightFwdr.text :=  Any_String;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadCmbCountryOfOrigin" id="34fb2bae-5c35-4ca4-82d2-dd0887a2092a">
        <source>loadCmbCountryOfOrigin();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Aug 2022 navtnr20 ChangeRequest 54441: EUP - Additional Field - Country of Origin
*/

vars
	cmb				 : ComboBox;
	countryDict : CM_CountryByCodeDict;
	country     : CM_Country;
			

begin
	cmb := self.cmbCountryOfOrigin;
	cmb.clear();

	countryDict := app.myRoot.allCountries;
	
	cmb.addItem(Any_String);
	

	foreach country in countryDict do
		if country.isNotAvailableForEntry then
			continue;
		endif;																							
	cmb.itemObject[cmb.addItem(country.code &amp; '  ' &amp; country.description)] := country;																					
	endforeach;
	
	self.tblSearch.setValueByName(ETRow_CountryOfOrigin, Any_String);
	cmb.text := Any_String;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadCmbShippingLine" id="7606817d-9c6c-4e58-9983-68c9a4e69d82">
        <source>loadCmbShippingLine();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2022	navak20	53204: EUP - GEN/REP/INB - Additional Cargo Field - Shipping Line - UI
20 Jun 2022	navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP
*/

vars
	cmb				 : ComboBox;
	shippingLineDict : CM_ShippingLineByCodeDict;
	shippingLine     : CM_ShippingLine;
	byDesc			 : Boolean;				// TFS 53362

begin
	cmb := self.cmbShippingLine;
	cmb.clear();

	shippingLineDict := app.myRoot.allShippingLines;
	
	cmb.addItem(Any_String);
	
	if self.myTerminal &lt;&gt; null then										// TFS 53362
		byDesc := self.myTerminal.getConfig(ComboByNameLine).Boolean;	// TFS 53362
	endif;																// TFS 53362
	foreach shippingLine in shippingLineDict do
		if shippingLine.isNotAvailableForEntry then
			continue;
		endif;
		
		if byDesc then																							// TFS 53362
			cmb.itemObject[cmb.addItem(shippingLine.description &amp; '  ' &amp; shippingLine.code)] := shippingLine;	// TFS 53362
		else																									// TFS 53362
			cmb.itemObject[cmb.addItem(shippingLine.code &amp; '  ' &amp; shippingLine.description)] := shippingLine;
		endif;																									// TFS 53362
	endforeach;
	
	self.tblSearch.setValueByName(ETRow_ShippingLine, Any_String);
	cmb.text := Any_String;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadComboStevedore" id="1d8e7571-9318-4926-b25b-4d3bf2194a5e">
        <source>loadComboStevedore();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Oct 2020 cnwma1	ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	cmbSteve	 : ComboBox;
	steveDict	 : CM_StevedoreByCodeDict;
	stevedore    : CM_Stevedore;
	failedDAC	: CM_DataAccessController;
begin
	cmbSteve := self.cmbStevedore;
	cmbSteve.clear();
	
	steveDict := app.myRoot.allStevedores;
	
	
	
	cmbSteve.addItem(Any_String);
	
	foreach stevedore in steveDict do
		if stevedore.notAvailableForEntry then
			continue;
		endif;
		
		if not stevedore.canUserAccessSelf(null, failedDAC, app.myPassport) then
			continue;
		endif;
		
		cmbSteve.itemObject[cmbSteve.addItem(stevedore.code &amp; '  ' &amp; stevedore.description)] := stevedore;
		
	endforeach;
	
	
	self.tblSearch.setValueByName(ETRow_Stevedore, Any_String);
	cmbSteve.text := Any_String;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="9ff8f690-a6bd-459e-9bdc-e326b10e9c00">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      30 May 2003 by cnwsgp1
// 04 Nov 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
// 23 May 2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// 17 Aug 2022 navtnr20 ChangeRequest 54441: EUP - Additional Field - Country of Origin
// ---------------------------------------------------------------------------
begin
	self.setFilterDefaults();
	inheritMethod();
	
	self.loadCmbConsign();
	loadComboStevedore();    //02.10.2020 cnwma1 TFS #50112
	self.loadCmbShippingLine();		// 23.05.2022 navak20 TFS 53204
	self.loadCmbCountryOfOrigin(); 	//17.08.2022 navtnr20 54441
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstStops_displayRow" id="84690258-07e1-4886-8168-00634742cd61">
        <updating/>
        <source>lstStops_displayRow(table: Table input; theSheet: Integer; obj: CM_StopsTable; theRow: Integer; bcontinue: Boolean io):String updating;
//----------------------------------------------------------------
//	Created:	16 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	selected		: Boolean;
begin
	
	selected := self.lstStops.allSelectedObjects.includes(obj);
	if selected then
		return TableCheckBox_Selected  &amp; Tab &amp; obj.heading;
	else
		// DVB CCMS 1235
		if not (obj.isNotAvailableForEntry) then
			return  TableCheckBox_NotSelected &amp; Tab &amp; obj.heading;
		else
			return null;
		endif;
	endif;


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="CM_StopsTable"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
