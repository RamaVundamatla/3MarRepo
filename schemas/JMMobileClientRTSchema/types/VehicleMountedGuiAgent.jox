    <JadeMethod name="userNotification" id="c66757fc-b9de-439c-98be-3c57e76f352d">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	dto	: DTO_VehicleMountedInfo;
	newUserInfo : Any;
begin
	
	if eventType = MobileHandHeldThin::VehicleMountedAgent.Event_Server_Note and theObject = self.myVehicleMountedAgent then
		dto := userInfo.DTO_VehicleMountedInfo;
		if dto.eventObject &lt;&gt; null then
			newUserInfo:=dto.eventObject;
		else
			newUserInfo:=dto.eventMessage;
		endif;
		self.writeLog(newUserInfo.String);
		self.myNotesObj.causeEvent(dto.event, true, newUserInfo);
	endif;

epilog
	delete dto;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
