// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/04/2018	jlgdap1		Initial creation TFS 37858 PEL1 Invocie Status Advancement
//
vars

begin
	self.myInvoice := _invoice;
	self.myParentObject := _invoice;
	self.myRoot := app.myRoot;
epilog

end;</source>
