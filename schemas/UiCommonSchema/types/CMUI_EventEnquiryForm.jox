    <JadeMethod name="lstEventGroups_click" id="d2ab8158-9d4e-4bdb-8f8b-481100a3b1bd">
        <controlMethod name="CMUI_ListTable::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstEventGroups_click(table: Table input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	12 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	eventTypeGroup			: CM_EventTypeGroup;
	objSet					: ObjectSet;
	eventType				: CM_EventType;
begin
	if table.row = null then
		return;
	endif;
	eventTypeGroup := table.accessRow(table.row).itemObject.CM_EventTypeGroup;
	if eventTypeGroup = null then
		return;
	endif;
	create objSet transient;
	self.lstEventTypes.allSelectedObjects.copy(objSet);
	app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-');
	if table.getCellText(table.row, 1).Boolean then
		//select all the event types in the selected group
		foreach eventType in eventTypeGroup.allEventTypes do
			if (not objSet.includes(eventType)) then
				app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-adding eventType:' &amp; eventType.name);
				objSet.add(eventType);
			endif;
		endforeach;
	else
		foreach eventType in eventTypeGroup.allEventTypes do
			if objSet.includes(eventType) then
				app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-removing eventType:' &amp; eventType.name);
				objSet.remove(eventType);
			endif;
		endforeach;
	endif;
	
	self.lstEventTypes.clearSelected();
	self.lstEventTypes.setSelected(objSet);
	
end;

</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
