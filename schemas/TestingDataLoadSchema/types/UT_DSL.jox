    <JadeMethod name="loadTranMap" id="73e19b8d-d559-4439-9890-488f6b7b9371">
        <source>loadTranMap(_fileContent, _fileName, _mapName : String) : CM_TranMap;

/*

Purpose:		Load a Transaction Map

Date			Who		Reason
20/03/2013		cnwmh5	Initial creation

*/

vars

	bank		: CM_Bank;
	cargoMap	: CM_TranMap;

begin

	self.transactionMapLoad(_fileContent, _fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[_mapName];
	self.assertNotNullMsg(cargoMap, "cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return cargoMap;

epilog

end;</source>
        <Parameter name="_fileContent" type="String"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_mapName" type="String"/>
        <ReturnType type="CM_TranMap"/>
    </JadeMethod>
    <JadeMethod name="loadVoyJobToOps" id="40b8b7de-63b3-4be7-86a9-ecb67dec3b21">
        <source>loadVoyJobToOps(_job: CM_VoyageJob; _load : Boolean; _ignoreWarnings : Boolean );
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	theProxyJob : CM_Job;
	loadState : Boolean;
begin
	if _job.CM_VoyageJob.isHatchLidJob() then
		return;
	endif;
	
	if _job.isLoadedToOperations = _load then // it is already what we want it to be
		return;
	endif;
	
	app.cmsBeginLoad(loadState);
	theProxyJob := _job.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);

	if not _ignoreWarnings then
		app.myTrxUA.trxUpdateVoyageJobLoadUnload(theProxyJob.CM_VoyageJob, _load, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	else
		
		while true do
			app.myTrxUA.trxUpdateVoyageJobLoadUnload(theProxyJob.CM_VoyageJob, _load, app.myPassport);
			if app.myPassport.trxCompletedOK then
				break;
			else
				if app.myPassport.noErrors then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
		
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsAndWarnsFullAsStr());
		
	endif;
epilog
	app.cmsEndLoad(loadState);			// 08/04/2011 cnwmh5 #27347
	delete theProxyJob;
end;</source>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_load" type="Boolean"/>
        <Parameter name="_ignoreWarnings" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="machineAcceptSpecifiedTandTask" id="80e24895-a205-444b-9d8d-bdc21a1c71f9">
        <source>machineAcceptSpecifiedTandTask(_machine: CM_Machine input; _task, _taskTwin: CM_RTQueueEntry input) protected;

/*

Purpose:			

Parameters:			

Return Value:		

Date			Name	TFS#		Description
============================================================================
12 July 2011	cnwrd1	Initial creation
20 January 2020	jlgka1 TFS 47394 - Tandem Movement Enhancement. Revert code back before the Tandem Movement changes.
============================================================================*/
vars
	task,
	twinTask : CM_RTQueueTask;
begin
	
	if _taskTwin &lt;&gt; null then
		twinTask:=_taskTwin.allTasks.first;
	endif;
	
	app.myTrxUA.trxMachineAcceptTask(_machine,_task.allTasks.first,
									 twinTask,								   
									 null ,									   
									 app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
end;</source>
