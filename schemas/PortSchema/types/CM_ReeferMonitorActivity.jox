<Class name="CM_ReeferMonitorActivity" id="4fc5e807-3186-4445-8139-8d942254db4b">
    <superclass name="CM_YardActivity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardActivity"/>
    <JadeMethod name="addReeferExtraInfoForTrx" id="0cd5229b-75d8-42f5-a180-c633e94752a2">
        <source>addReeferExtraInfoForTrx( _information: StringArray512 input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	newTimeStamp : TimeStamp;
	criteria : CM_ReeferJobCriteria;
	newMonitorJob : CM_YardActivity;

begin
		
	//find the matching criteria and if there is one, get the next time to monitor, and add the next monitor job.
	criteria := self.myTrackedItem.getMatchingReeferCriteria();
	
	if criteria &lt;&gt; null and criteria.monitor and not criteria.allTimes.isEmpty then
		newTimeStamp := criteria.getNextReeferMonitorTS();	
		if newTimeStamp.date.isValid then
			newMonitorJob := self.myTrackedItem.createReeferJob( CM_ReeferMonitorActivity, newTimeStamp, app.myPassport );
		endif;
	endif;
	
	if newMonitorJob &lt;&gt; null then
		_information.addTruncated("Reefer Monitor Job created for "  &amp; newTimeStamp.asStringJMT );
		_information.addTruncated("Used Criteria - " &amp; criteria.getCriteriaSummary(",") );
	endif;
		
epilog

end;</source>
        <Parameter name="_information" type="StringArray512" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addReeferInfoTransaction" id="70f883ec-d9c1-4f1f-aee1-f4437f60b892">
        <source>addReeferInfoTransaction();
/*
Purpose:			

Date		Who		Reason
09JUL2021	NAVAB1	TFS 51455
*/


vars
	
	information : StringArray512;
	info : CM_Information;
	invalid : Boolean;

begin

	if self.myTrackedItem &lt;&gt; null then
	
		on Exception do app.handleDeletedObject( exception, self.myTrackedItem, invalid );
		
		create information transient;
		information.addTruncated(self.getTypeString &amp; " - Actioned");
		information.addTruncated("Reefer = " &amp; self.myTrackedItem.id);
		
		self.addReeferExtraInfoForTrx( information );
		
		info := self.myTrackedItem.createInfomationTransaction( "Reefer Job - Actioned", information, null, app.myPassport );
		
	endif;

epilog

	delete information;

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="4c70cc73-9964-4ecc-99f6-038b50730f6b">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

begin

	self.type := self.ReeferMonitor;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doAction" id="340a9e87-5834-46fd-9155-6b6b101ecc0e">
        <updating/>
        <source>doAction() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars
	alarmJob : CM_YardActivity;

begin
	self.status := CM_YardActivity.Status_Actioned;  // ### TFS 51455 09JUL2021 NAVAB1
	
	self.addReeferInfoTransaction();
	
	// TFS 51455 this method is called because a temperature has been recorded for a reefer
	if self.myTrackedItem &lt;&gt; null then
		alarmJob := self.myTrackedItem.getCurrentReeferAlarmJob();
		
		if alarmJob &lt;&gt; null then
			alarmJob.doAction();  // ### TFS 51455 09JUL2021 NAVAB1 -  delete the alarm job
		
		endif;
	endif;
		
epilog

	delete self;

end;</source>
    </JadeMethod>
