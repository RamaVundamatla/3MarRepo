        <updating/>
        <source>setForUpdate( _proxy : CM_DebtorSurchargeRate ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2018	jlgndl1	Initial creation	TFS 37818

*/

vars

begin

	self.mySurchargeInvoiceLineType := _proxy.getSurchargeInvoiceLineType;
	self.surchargeRate := _proxy.surchargeRate;
	self.myDebtor := _proxy.myDebtor;
	self.mySurchargeAndExemptions := _proxy.mySurchargeAndExemptions;


epilog

end;</source>
        <Parameter name="_proxy" type="CM_DebtorSurchargeRate"/>
