    <JadeMethod name="xROROStowageAdvice_31192" id="c038fb86-6194-411e-965a-9b856dccf002">
        <source>xROROStowageAdvice_31192(_voyageName : String; _shipName : String; _testOperator : String) : String;

/*

Purpose:		Setup the Stowage Adivce for Hazards	

Date			Who		Reason
25/02/2013		cnwmh5	Initial creation #31192

*/

vars

	ediText : String;
	
begin
	
	ediText := 
'V,A,'&amp;_voyageName&amp;','&amp;_shipName&amp;'
S,LOA,Book124,ISO Container,,MT,,USPOE,NZAKL,1.1,,ANNEA111179,,2200,,NZPOE,,,Stowage Remark AUTOLOCN22,,AUTOLOCN22,,,'&amp;_voyageName&amp;',14888
