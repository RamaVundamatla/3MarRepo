    <JadeMethod name="doUpdateEmailDefaults" id="21b8b3c1-aee8-4401-ae3e-c855dfc1b9a4">
        <source>doUpdateEmailDefaults(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2018	jlgndl1	Initial creation

*/

vars

	sa : StringArray;
	real : CM_UserPasswordDefaultEmail;
	result : Integer;
	form : CMUI_UserPasswordEmailForm;
	
begin

	real := self.myProxy.pxyGetRealObject();

	create sa transient;
	self.mulSelectFields.getSelectedDisplayEntries(sa);	
	
	self.myProxy.setProxy(	self.txtSubject.text,
												self.txtMessage.text,
												sa,
												true,
												self.myProxy.copyTo,
												false,
												false
												);
	
	self.myProxy.setAddressees( self.txtBccAddress.text.trimBlanks, self.txtCcAddress.text.trimBlanks );
	
	form := self;
	
	while true do
		app.myTrxUA.trxUpdateUserPwDefEmail(self.myProxy, real, app.myPassport);
		if app.myPassport.trxCompletedOK() then
			self.clearErrorWarnings();
			form.myReal := real;
			form.modalResult := IDOK;
			return true;
			
		else
			result := app.showErrorWarningDialog('User Password Email Template', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors()
			and result = IDOK
			then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
		endif;
		
		form.modalResult := IDCANCEL;
		return false;
		
	endwhile;
	
epilog

	delete sa;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setUserPasswordDefaultEmail" id="169ebe9b-1daf-44e8-806c-993b15204f22">
