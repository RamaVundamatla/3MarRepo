	app.extractNewXLATFormConstants();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhTranslateFixUp" id="ecb85ab6-88c4-405b-a197-fe195409f0e8">
        <source>mdhTranslateFixUp();

/*

Purpose:		Fixup constants with wrong source (id)

Date			Who		Reason
08/02/2012		cnwmh5	Initial creation
24/04/2013		cnwcs5		par 30652 - remove resynch/resynchObject method calls

*/

vars

	file						: File;
	constant					: Constant;
	schema						: Schema;
	category					: ConstantCategory;
	xlat						: XLAT_TranslatableText;
	file2						: File;
	
	transAgent 					: CM_TranslationAgent;
	sa 							: StringArray;
	origArray					: StringArray;
	
	int 						: Integer;
	
	
	line						: String;
	constantName				: String;
	constantId					: Integer;
	constantNumber				: Integer;

begin

	app.initialize();
	
	create file transient;
	file.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	file.fileName := "C:\localDev\FixUp\Original Details.txt";
	
	create file2 transient;
	file2.mode := File.Mode_Output;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	file2.fileName := "C:\localDev\FixUp\Changed Details.txt";
	
	schema := rootSchema.getSchema(PortSchema.name);
	if schema = null then
		return;
	endif;

	create transAgent transient;
	create sa transient;
	
	create origArray transient;
	
	// get the original details
	while not file.endOfFile do
		line := file.readLine();
		origArray.add(line);
	endwhile;
	file.close;
	
	// get the next available constant number
	foreach constant in rootSchema.getSchema(PortSchemaName).getCategory("XLAT_FormCaptions").getConstants discreteLock do
		constantNumber := constantNumber.max(constant.getPropertyValue("source").Integer);
	endforeach;
	
	// read through the constants and if not in origArray update to next constantNumber and generate new constant object
	category := schema.getConstantCategory("XLAT_FormCaptions");
	
	foreach constant in category.getConstants() do
	
		// check to see if in array
		if origArray.includes(constant.name &amp; Tab &amp; constant.getSource().String) then
			continue;
		endif;
	
	//if constant.name &lt;&gt; "SOP_GateConfigF_CchkPrintConfi" then
	//		continue;
	///	endif;
	
		constantNumber := constantNumber + 1;
		
		write constant.name &amp; Tab &amp; constant.getSource().String &amp; Tab &amp; constantNumber.String;
		
		file2.writeLine(constant.getSource());
		
		beginTransaction;
		constant.setPropertyValue('source', constantNumber.String);
		commitTransaction;
		
		int := constant.getSource().Integer;
		sa.clear();
		sa.add(constant.name);
		
		transAgent.trxLoadSpecificTranslations(sa);
	
	endforeach;
	file.close();
	file2.close();
	
epilog

	delete file;
	delete file2;
	delete transAgent;
	delete sa;
	delete origArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="mdhTranslateFixUpWrongId" id="37ffa7e4-413b-4785-8062-0ab07a946a1c">
        <source>mdhTranslateFixUpWrongId();

/*

Purpose:		Fixup constants with wrong source (id)

Date			Who		Reason
08/02/2012		cnwmh5	Initial creation
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

*/

vars

	file						: File;
	constant					: Constant;
	schema						: Schema;
	file2						: File;
	xlat						: XLAT_TranslatableText;
	
	transAgent 					: CM_TranslationAgent;
	sa 							: StringArray;
	int 						: Integer;
	changedArray				: IntegerArray;
	
	line						: String;
	constantName				: String;
	constantId					: Integer;
	constantPrevChanged			: Boolean;
	nameDiff					: Boolean;

begin

	app.initialize();
	
	create file transient;
	file.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	file.fileName := "C:\localDev\FixUp\Original Details.txt";
	
	create file2 transient;
	file2.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	file2.fileName := "C:\localDev\FixUp\Changed Details.txt";
	
	schema := rootSchema.getSchema(PortSchema.name);
	if schema = null then
		return;
	endif;

	create changedArray transient;
	while not file2.endOfFile do
		changedArray.add(file2.readLine().Integer);
	endwhile;
	file2.close();
	
	create transAgent transient;
	create sa transient;
	
	while not file.endOfFile do
	
		line := file.readLine();
		
		constantName := line[1:line.pos(Tab, 1) - 1];
		constantId := line[line.pos(Tab, 1) + 1:end].Integer;
		
		constant := schema.getConstant(constantName);
		if constant = null then
			continue;
		endif;
		
		//if constantName = "SOP_GateConfigF_CchkPrintConfi" then
		//	write 'found';
		//endif;
		
	//	if constant.getSource().Integer &lt;&gt; 11586 then
	//		continue;
	///	endif;
		
		constantPrevChanged := false;
		if changedArray.includes(constant.getSource().Integer) then
			constantPrevChanged := true;
		endif;
		
		nameDiff := false;
		xlat := app.myRoot.allXLAT_TranslatableText["XLAT_FormCaptions", constantId];
		if xlat &lt;&gt; null and xlat.vConstantName &lt;&gt; constantName then
			nameDiff := true;
		endif;		
		
		if constant.getSource().Integer = constantId and not constantPrevChanged and not nameDiff then
			continue;
		endif;
		
		write constant.String &amp; Tab &amp; constant.name &amp; Tab &amp; constant.getSource().String &amp; Tab &amp; constantName &amp; Tab &amp; constantId.String &amp; Tab &amp; 
			(constant.getSource().Integer &lt;&gt; constantId).String;
		
		if not constantPrevChanged then
			beginTransaction;
			constant.setPropertyValue('source', constantId.String);
			commitTransaction;
		endif;
		
		int := constant.getSource().Integer;
		sa.clear();
		sa.add(constantName);
	
		transAgent.trxLoadSpecificTranslations(sa);
				
	endwhile;
	file.close;
	file2.close;
	
epilog

	delete file;
	delete file2;
	delete transAgent;
	delete sa;
	delete changedArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="mes50458" id="5b572e9d-b654-4f66-b800-f3af41767550">
        <source>mes50458();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 December 2020	jlgma1	Initial creation

*/

vars
 req : CM_TIRequest;
 gte : CMGTE_Release;
begin

	req := "2330.1576431".asOid.CM_TIRequest;
	gte := "4456.477845".asOid.CMGTE_Release;
	
	beginTransaction;
	if req &lt;&gt;null then
		req.setPropertyValue("trackedItem",null);
	endif;
	
	if gte &lt;&gt; null then
		gte.setMyTrackedItem(null);
	endif;
	commitTransaction;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mes7378" id="27d86489-18d6-474e-9d77-2e3cda12c62b">
        <source>mes7378();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 October 2017	jlgma1	Initial creation
*/
vars
	int : Integer;
	precisionError : Boolean;
	c : Integer;
	kpi : CM_KPIVoyageMoveDtl_GC;
	lFile        : File;
	vol : Decimal[16,4];
begin	
	// Used for testing the Problem
	/*	on Exception do app.handlePrecisionError(exception, precisionError);
		vol := 6562500000.0000;
		int := volume.rounded();
	if precisionError then
		int := 2147483647;
	endif;
	*/
	/* Used to Fix 3 instances  with the following oids
	5933.6269
	5933.21734
	5933.21736
	*/
	vol := 2147483647.0000;
	create lFile transient;
	lFile.fileName := "C:\TEMP\MES1810.csv";
	lFile.open;
	foreach kpi in CM_KPIVoyageMoveDtl_GC.instances do
		if kpi.volume&gt; 2147483647 then
			lFile.writeLine( kpi.volume.String  &amp;"," &amp; kpi.getOidAsString);
			c := c+1;
			beginTransaction;
				kpi.setPropertyValue("volume",vol);
			commitTransaction;
		endif;
	endforeach;
	lFile.close;
	delete lFile;
	app.msgBox(c.String,"",0);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mh5CheckBeginEndLoads" id="ead237b5-4690-462a-b8ef-d4b5cb86ba52">
        <source>mh5CheckBeginEndLoads();

/*

Purpose:			Find all methods off PortSchema that have cmsBeginLoad, cmsEndLoad, beginLoad or endLoad in them, and check whethter 
					epilog has cmsEndLoad or endLoad

Parameters:			

Return Value:		


Date		Who		Reason
06 April 2011	cnwmh5	Initial creation

*/

vars

	schema		: Schema;
	file		: File;
	class		: Class;

	schemas		: SchemaColl;
	classes		: ClassColl;
	
	alreadyProcessed	: StringArray;

begin

	// initial setup
	create schemas transient;
	
	// setup the output file
	create file transient;
	file.mode := File.Mode_Output;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	//file.fileName := "C:\temp\JM Terminal_27347\cmsBeginLoadcmsEndLoadbeginLoadendLoadAfterChange.txt";
	file.fileName := "C:\temp\cmsBeginLoadcmsEndLoadbeginLoadendLoadWithMsgBox.txt";
	if file.isAvailable then
		file.purge;
	endif;
	file.writeLine('key' &amp; Tab &amp; 'schemaName' &amp; Tab &amp; 'className' &amp; Tab &amp; 'methodName' &amp; Tab &amp; 'cmsBeginLoad' &amp; Tab &amp; 
		'cmsEndLoad' &amp; Tab &amp; 'vars' &amp; Tab &amp; 'beginLoad' &amp; Tab &amp; 'endLoad' &amp; Tab &amp; 'isInEpilog' &amp; Tab &amp; 'OK');
	
	// get all the schemas we need to check
	schemas.add(currentSchema);
	currentSchema.allSubschemas(schemas);
	///schemas.add(currentSchema.getSubschema("PortDumpLoadSchema"));
	
	// check to see if cmsBeginLoad, cmsEndLoad, beginLoad, or endLoad exist in methods
	foreach schema in schemas do
				
		write '++++++++++++++++++++++++SCHEMA: ' &amp; schema.name &amp; ' ++++++++++++++++++++++++++++++++';
				
		// get the classes for the specific schema
		delete classes;
		classes := schema.getAllClasses(true);
		if classes.isEmpty() then
			continue;
		endif;
		
		// check to see if the class has cmsBeginLoad, cmsEndLoad, beginLoad, or endLoad in it's methods
		foreach class in classes where class.schema = schema do
			self.findBeginLoadEndLoadMethods(file, class);
		endforeach;		
		
	endforeach;
	
	write '===================================================FINISHED===================================================';
	
	file.close;
	
epilog

	delete file;

	delete classes;
	delete schemas;

end;</source>
    </JadeMethod>
    <JadeMethod name="mhCompareOldNewCodeForDiffs" id="e9f5932c-c0d3-4ec5-8a75-4429f25df890">
        <source>mhCompareOldNewCodeForDiffs();

/*

Purpose:		Compare the old and the new code for any differences	

Date			Who		Reason
10/02/2012		cnwmh5	Initial creation

*/

vars


	file						: File;
	obj							: Object;
	newFile						: File;
	diffFile					: File;
	fileNodeObj					: FileNode;
	fileFolder1					: FileFolder;
	fileFolder2					: FileFolder;
	
	jdo							: JadeDynamicObject;
	jdoTest						: JadeDynamicObject;
	
	dictOld  					: DynaDictionary;
	dictNew  					: DynaDictionary;
	
	allFilesOld					: FileNodeArray;
	allFilesNew					: FileNodeArray;
	
	currentClassName			: String;
	currentMethodName			: String;
	attribute					: String;
	text						: String;
	propertyType				: String;
	fileName					: String;
	
	isCommentedOut				: Boolean;
	differenceFound				: Boolean;
	diffFileCreated				: Boolean;
	newFieldFileCreated			: Boolean;

begin
	
	// get the files in the specified directory
	create allFilesOld transient;
	create allFilesNew transient;
		
	// load the details from *Schema-NEW.txt
	delete fileFolder1;
	create fileFolder1 transient;
	fileFolder1.fileName := "c:\translate22092012";
	fileFolder1.mask := "*Schema-ToBeCompared.txt";
	if not fileFolder1.isValidPathName(fileFolder1.fileName) or not fileFolder1.isAvailable() then
		app.log('Unable to find ' &amp; "c:\translate22092012");
		return;
	endif;
	allFilesOld := fileFolder1.files();

	foreach fileNodeObj in allFilesOld do
	
		if fileNodeObj.fileName.cnContains("PortSchema") then
			continue;
		endif;
	
		if dictOld &lt;&gt; null then
			dictOld.purge;
		endif;
		delete dictOld;
		create dictOld transient;
		dictOld.setMembership(JadeDynamicObject);
		dictOld.addExternalKey(String, 35, false, true);					// class name
		dictOld.addExternalKey(String, 35, false, true);					// method name
		dictOld.addExternalKey(String, 35, false, false);					// attribute
		dictOld.addExternalKey(String, 35, false, true);					// type   e.g. caption or bubbleHelp
		dictOld.endKeys(false);
		
		self.createJDOForComparisonMethod(fileNodeObj.File, dictOld);
		
		// load the details from *-FormCaptions-partial-NEW.txt
		allFilesNew.clear();
		delete file;
		create file transient;
		fileName := app.getFileName(fileNodeObj.fileName);
		file.fileName := "c:\translate22092012" &amp; "\" &amp; fileName[1:fileName.length - 17] &amp; "-FormCaptions-partial-CNWMH5A-ToBeCompared.txt";
		write file.fileName;
		if not file.isAvailable then
			app.log("Unable to find file " &amp; file.fileName);
			return;
		endif;
		allFilesNew.add(file);
		
		if dictNew &lt;&gt; null then
			dictNew.purge;
		endif;
		delete dictNew;
		create dictNew transient;
		dictNew.setMembership(JadeDynamicObject);
		dictNew.addExternalKey(String, 35, false, true);					// class name
		dictNew.addExternalKey(String, 35, false, true);					// method name
		dictNew.addExternalKey(String, 35, false, false);					// attribute
		dictNew.addExternalKey(String, 35, false, true);					// type   e.g. caption or bubbleHelp
		dictNew.endKeys(false);
		
		self.createJDOForComparisonMethod(file, dictNew);
	
		// Create the *-FIELDS-NEW file
		//create newFile transient;
		//newFile.fileName := _directory &amp; "\" &amp; fileName[1:fileName.length - 17] &amp; "-NEW-FIELDS.txt";
		//if newFile.isAvailable then
		//	newFile.purge;
		//endif;
		//newFile.writeLine("class" &amp; Tab &amp; "method" &amp; Tab &amp; "commented" &amp; Tab &amp; "attribute" &amp; Tab &amp; "text");
		
		// Create the *-DIFF-NEW file
		delete diffFile;
		create diffFile transient;
		diffFile.mode := File.Mode_Output;	// 29/2/16 cnwmp6 PAR 36286 unicode version
		diffFile.fileName := "c:\translate22092012" &amp; "\" &amp; fileName[1:fileName.length - 17] &amp; "-DIFFS.txt";
		if diffFile.isAvailable then
			diffFile.purge;
		endif;
		diffFile.writeLine("class" &amp; Tab &amp; "method" &amp; Tab &amp; "commented" &amp; Tab &amp; "attribute" &amp; Tab &amp; "old text" &amp; Tab &amp; "new text");
	
		diffFileCreated := false;
		newFieldFileCreated := false;
		
		foreach obj in dictOld do
			jdo := obj.JadeDynamicObject;
			currentClassName := jdo.getPropertyValue("className").String;
			currentMethodName := jdo.getPropertyValue("methodName").String;
			attribute := jdo.getPropertyValue("attribute").String; 
			propertyType := jdo.getPropertyValue("propertyType").String;
			text := jdo.getPropertyValue("text").String;
			
			jdoTest := dictNew[currentClassName, currentMethodName, attribute, propertyType].JadeDynamicObject;
			if jdoTest = null then
			//	newFile.writeLine(currentClassName &amp; Tab &amp; currentMethodName &amp; Tab &amp; isCommentedOut.String &amp; Tab &amp; 
			//		propertyType &amp; Tab &amp; attribute &amp; Tab &amp; text);
			//	newFieldFileCreated := true;
			else
				if jdoTest.getPropertyValue("text").String.trimBlanks() &lt;&gt; text.trimBlanks() then
					diffFile.writeLine(currentClassName &amp; Tab &amp; currentMethodName &amp; Tab &amp; isCommentedOut.String &amp; Tab &amp; 
						propertyType &amp; Tab &amp; attribute &amp; Tab &amp; text &amp; Tab &amp; jdoTest.getPropertyValue("text").String);
					diffFileCreated := true;
				endif;
			endif;
						
		endforeach;
		
		//if not newFieldFileCreated then
		//	newFile.purge;
		//endif;
		
		if not diffFileCreated then
			diffFile.purge;
		else
			differenceFound := true;
		endif;
				
	endforeach;
	
epilog

	if dictOld &lt;&gt; null then
		dictOld.purge;
	endif;
	delete dictOld;
	
	if dictNew &lt;&gt; null then
		dictNew.purge;
	endif;
	delete dictNew;

	delete file;
	delete newFile;
	delete diffFile;
	delete fileFolder1;
	delete fileFolder2;

end;
</source>
    </JadeMethod>
    <JadeMethod name="mhConvertFilesSoCanProgCompare" id="4ce97fd0-0328-42eb-bfe2-43e3e1c120d5">
        <source>mhConvertFilesSoCanProgCompare();

vars
	
	
	schema					: Schema;
	klass					: Class;
	obj						: Object;
	
	file					: File;
	outputFile				: File;
	
	fileFolder1				: FileFolder;
	fileFolder2				: FileFolder;
	fileNodeObj				: FileNode;
	
	allFiles				: FileNodeArray;
	filesPartial			: FileNodeArray;
	filesSource				: FileNodeArray;
	
	returnOK				: Boolean;
	
begin
	
	
	schema := rootSchema.getSchema("SchemaComparisonUtility");
	if schema = null then
		app.log("Unable to find SchemaComparisonUtility");
		return;
	endif;
	
	klass := schema.getClass("SchemaComparisonUtility");
	if klass = null then
		app.log("Unable to find JadeScript");
		return;
	endif;
	
	create obj as klass transient;
		
	// get the files in the specified directory
	create allFiles transient;
	
	delete fileFolder1;
	create fileFolder1 transient;
	fileFolder1.fileName := "c:\translate22092012";
	if not fileFolder1.isValidPathName(fileFolder1.fileName) or not fileFolder1.isAvailable() then
		app.log('Unable to find ' &amp; fileFolder1.fileName);
		return;
	endif;
	
	create filesSource transient;
	fileFolder1.mask := "*Schema.scm";
	filesSource := fileFolder1.files();
	filesSource.copy(allFiles);
	
	delete fileFolder2;
	create fileFolder2 transient;
	fileFolder2.fileName := "c:\translate22092012";
	if not fileFolder2.isValidPathName(fileFolder2.fileName) or not fileFolder2.isAvailable() then
		app.log('Unable to find ' &amp; fileFolder2.fileName);
		return;
	endif;
	
	create filesPartial transient;
	fileFolder2.mask := "*-FormCaptions-partial-CNWMH5A.scm";
	filesPartial := fileFolder2.files();
	filesPartial.copy(allFiles);	
	
	foreach fileNodeObj in allFiles do
	
		if fileNodeObj.fileName.cnContains("PortSchema") then
			continue;
		endif;
	
		delete file;
		create file transient;
		file.fileName := fileNodeObj.fileName;
		
		delete outputFile;
		create outputFile transient;
		outputFile.fileName := "c:\translate22092012" &amp; "\" &amp; app.getFileName(file.fileName);
		outputFile.fileName := outputFile.fileName[1:outputFile.fileName.length - 4] &amp; "-ToBeCompared.txt";
		if outputFile.isAvailable then
			outputFile.purge;
		endif;
		write outputFile.fileName &amp; Tab &amp; file.fileName;
	
		obj.sendMsgWithIOParams('sortSCMByClassMethodWithParams', file, outputFile);
	
	endforeach;
	
epilog
	
	delete file;
	delete outputFile;
	
	delete obj;
	
	delete allFiles;
		
end;
</source>
    </JadeMethod>
