____________________________________________________________________________</text>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="jssDecimal" id="0fb51da0-4204-48ed-91a6-61ebb91bf691">
        <source>jssDecimal():Decimal;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the text value of the receiver's caption as a Decimal value.
//
// Parameters:	None
//
// Returns:		Decimal - the trimmed caption cast to a Decimal value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.caption.trimBlanks.jssRemoveSubstring(",").Decimal;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

