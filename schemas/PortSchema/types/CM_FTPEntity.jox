    <JadeMethod name="getDisplayStringForAttribute" id="30d57681-bef1-4ab7-90a2-52176d9b1ee1">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
//20 Aug 2015	cnwrs1	Par 36795 enable a file to be read and deleted in one session
//24 Aug 2015	cnwrs1	Par 36815 enable FTP get to continue after a failed file delete by saving off the fileNames
//
vars

begin
	if _attrName = ETRow_SingleFileCopy then
		return getSingleFileCopy().String;
	elseif _attrName = ETRow_SaveUndeletedFilesList then
		return getSaveUndeletedFilesList().String;
	else
		return inheritMethod(_attrName, _short);
	endif;
end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPortNumberForConnect" id="3cfae072-bfdb-4f72-8788-1fa2b82c1681">
        <source>getPortNumberForConnect() : Integer;
/*

Purpose:			Get the optional port number for the FTP connect, which may optionally
					be specified after a ":" in the serverName

Parameters:			None

Return Value:		Port number, or null if there isn't one specified

Date		Who		Reason
15 Nov 2017	jlgkpd1	Initial creation

*/

constants
	PortDelimiter	= ":";

vars
	pos,
	portNumber		: Integer;
	portString		: String;
	
begin
	pos := self.serverName.reversePos(PortDelimiter);
	if pos &lt;&gt; 0 and pos &lt; self.serverName.length() then
		portString := self.serverName[pos+1:end];
		if portString.isInteger then
			portNumber := portString.Integer;
		endif;
	endif;
	
	return portNumber;
		
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPwForUse" id="c11cf8e9-66d3-4b48-a8df-d857d9187422">
