        <length>6</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="mt20Imp" id="7c1ae0ef-066b-4d56-ab2f-6a984155cd95">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="mt40Imp" id="2746c8c7-4772-4254-931e-24a76c84bbaf">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="otherDlrTra" id="bd7417c1-49d6-4ba3-bb19-f09848fc5602">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="otherImp" id="d95bf410-c764-47a5-8bda-7219da914291">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="otherSobTra" id="3a546bd0-63a4-4011-869a-e488745299e2">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="reef20Imp" id="ac4c240d-fbd8-43ea-9c8d-62de0690958a">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="reef40Imp" id="11b0db9b-2c1c-486f-bfcb-c29cca28fb7e">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="sob20Tra" id="b6f17ef1-0b3a-4b2c-996c-984a5d18b23e">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="sob40Tra" id="ca892d00-fa05-4a62-b3a8-edcb4e626c18">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="setFromSR" id="6fd29789-55ff-4fd9-a89b-c2b8b7315c75">
        <updating/>
        <source>setFromSR(_slotRequest: CM_SlotRequest) updating;
//----------------------------------------------------------------
//	Created:	12 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	other	: Boolean;
	sob		: Boolean;
	dlr		: Boolean;
	reef	: Boolean;
	forty	: Boolean;
	empty	: Boolean;
	dry		: Boolean;
begin

	// PAR 21746 if _slotRequest.fortyBack 
	// PAR 21746 or _slotRequest.isBackend then // PAR 19945
	if _slotRequest.getAttrIsBackend() then
		//dont count
		return;
	endif;
	
	if _slotRequest.isLoad and _slotRequest.isSOB then
		//dont count sobs for load cc's (only once on the discharge)
		return;
	endif;
	
	//basic stuff
	self.dischargePort	:= _slotRequest.dischargePort;
	self.bayID := _slotRequest.myBay.id;

	if _slotRequest.cargoType &lt;&gt; TI_CargoType_Container then
		other := true;
	else
		//container only stuff
		if _slotRequest.getAttrIs40() then
			forty := true;
			self.bayID := _slotRequest.myBay.idBay40;	//overwrite bay id
		endif;
		
		if _slotRequest.getAttrEmpty() then
			empty := true;
		else
			//full container stuff
			if _slotRequest.getAttrPowerRequired() then // PAR7496 AKB2004FEB	or _slotRequest.reefer then
				reef := true;
			else
				dry := true;
			endif;
			
		endif;
	endif;
	
	if _slotRequest.isSOB then
		sob := true;
	endif;
	
	if _slotRequest.isRehandle then
		dlr := true;
	endif;
	

	//dlr
	self.dlr20Tra		:= (dlr and (not forty) and (not other)).Integer;
	self.dlr40Tra		:= (dlr and forty and (not other)).Integer;
	self.otherDlrTra	:= (dlr and other).Integer;
	
	//sob
	self.sob20Tra		:= (sob and (not forty) and (not other)).Integer;
	self.sob40Tra		:= (sob and forty and (not other)).Integer;
	self.otherSobTra	:= (sob and other).Integer;
	
	//imex
	//non-containers
	self.otherImp		:= (other and (not dlr) and (not sob)).Integer;
	//mt
	self.mt20Imp		:= (empty and (not forty)).Integer;
	self.mt40Imp		:= (empty and forty).Integer;
	//reef
	self.reef20Imp		:= (reef and (not forty)).Integer;
	self.reef40Imp		:= (reef and forty).Integer;
	
	//dry
	self.gen20Imp		:= (dry and (not forty)).Integer;
	self.gen40Imp		:= (dry and forty).Integer;
	
	
end;</source>
        <Parameter name="_slotRequest" type="CM_SlotRequest"/>
    </JadeMethod>
</Class>
