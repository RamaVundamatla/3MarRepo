    <JadeMethod name="takeOutItem" id="293d1740-a37b-4728-b32f-9ef29d3c4365">
        <updating/>
        <source>takeOutItem(_listBox : CM_MultiSelectListBox input; _theObject : Object) updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	idx : Integer;
	
begin
	// add into the selected list box
	idx := _listBox.findObject(_theObject);
	
	if idx &lt;&gt; CNEC_NULL_INDEX then
		_listBox.removeItem(idx);
	endif;
end;</source>
        <Parameter name="_listBox" type="CM_MultiSelectListBox" usage="input"/>
