    <JadeMethod name="rel822_par33305" id="24c4fbe2-af1c-45f1-95d2-6fd66795a144">
        <source>rel822_par33305();
//
//14 Jan 2014	cnwrs1	Par 33305 - info.clear is missing for user defined Reports
//
vars
	infoSent : CM_InfoEDISent;
	idx : Integer;
	str : String;
	infoLines : StringArray512;
	infoData : StringArray512;
	ignore : Boolean;
	deleted : Boolean;
	xml	: String;
	cnt : Integer;
begin
	create infoLines transient;
	create infoData transient;
	foreach infoSent in CM_InfoEDISent.instances do
//		cnt := cnt + 1;
//		if cnt &gt; 100 then
//			break;
//		endif;
		infoLines.clear;
		infoData.clear;
		ignore := false;
		deleted := false;
		infoSent.getInformationLines(infoLines);
		idx := 0;
		foreach str in infoLines do
			idx := idx + 1;
			if idx = 3 then 
				if str[1:8] = "Deleted:" then
					deleted := true;
				endif;
			endif;
			if (deleted and idx = 4) or 
			   (not deleted and idx = 3) then
//				write str[1:16];
				if str[1:16] &lt;&gt; "JRW Design Name:" then
					ignore := true;
					break;
				endif;
			endif;
			if str[1:9] = "Protocol:" then
				infoData.clear;
			endif;
			infoData.add(str);
		endforeach;
		if ignore then
			continue;
		endif;
		write infoData[1]&amp;' '&amp;idx.String&amp;' '&amp;infoData.size.String;
		if infoData.size &lt; idx then
			xml := infoData.asXmlString(CM_InfoEDISent.InfoHeaderTag, CM_InfoEDISent.InfoDetailTag);
			beginTransaction;
			infoSent.setXmlInfo(xml);
			commitTransaction;
//			write "";
//			foreach str in infoData do
//				write str&amp;' : '&amp;infoSent.myTrackedItem.String;
//			endforeach;
		endif;
	endforeach;
end;
</source>
    </JadeMethod>
