    <JadeMethod name="getSelectorVisibleColumns" id="fd245d1f-8178-4e6a-a3e2-593d6837a93b">
        <source>getSelectorVisibleColumns(_sa : StringArray input);
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries - hard-coded list equivalent to CM_CargoBOLType allSelectorVisibleColumns
vars
	qProp	: CM_QueryProperty;
begin
	_sa.clear();

	qProp := self.allQueryProperties[CM_TITransaction::getTransactionType.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CM_TITransaction::dateTime.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CM_TITransaction::id.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CM_TITransaction::myTerminal.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CM_TITransaction::getDetails.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;

end;
</source>
        <Parameter name="_sa" type="StringArray" usage="input"/>
    </JadeMethod>
</Class>
