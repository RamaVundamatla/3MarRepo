    <JadeMethod name="validateForUpdate" id="c678dd6e-837b-4c31-ad89-9ca041a32752">
        <source>validateForUpdate();
// -------------------------------------------
// Created 03 August 2004 by cnwdvb1
// -------------------------------------------
// 08/12/2014   cnwdb2		PAR #35364

vars

	restrict,
	original : CM_LabourRestriction;

begin
	inheritMethod();
	
	original := self.pxyGetRealObject();
	restrict := self.myTerminalArea.allRestrictionsLabour[self.id];
	if restrict &lt;&gt; null and restrict &lt;&gt; original then
	//	app.raiseCMException3(ERR_DUPLICATE_KEY,"Labour Restriction", self.id, null,null, null);
		app.raiseCMException1(Already_exists_labRestrict,self.id,null, null); // cnwdb2 PAR 35364

	endif;
	
end;</source>
