    <JadeMethod name="setForUpdate" id="a329665f-2aa1-4d47-8a2a-71766ad7692d">
        <updating/>
        <source>setForUpdate(_proxy: CM_ReleaseByTypeCriteria) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	realReserve : CM_ReserveSelection;

begin

	if not self.isTransient then
		if _proxy.myReserveSelection &lt;&gt; null and _proxy.myReserveSelection.isTransient then
			realReserve := _proxy.myReserveSelection.pxyGetRealObject();
		endif;
		if realReserve = null then
			if not _proxy.myReserveSelection.isTransient then
				realReserve := _proxy.myReserveSelection;
			endif;
		endif;
		self.myReserveSelection := realReserve;
	else
		self.myReserveSelection := _proxy.myReserveSelection;
	endif;
	
	inheritMethod(_proxy);

epilog

end;</source>
        <Parameter name="_proxy" type="CM_ReleaseByTypeCriteria"/>
    </JadeMethod>
