    <JadeMethod name="doApproveEstimation" id="19fa0131-8488-496d-bacd-5cab529f16e6">
        <updating/>
        <source>doApproveEstimation( _approve : Boolean; _totDays : Decimal )updating;
/*

Purpose:			NOT REFERENCED

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2018	jlgndl1	Initial creation	TFS 39197
*/

vars

	voyage : CM_Voyage;
	movement : HMS_Movement;
begin

	voyage := self.getMyVoyageObject();
	
	if voyage = null or self.myParent = null or not self.myParent.isVoyageWorkOrder then
		return;
	endif;
	
	//31 July 2018	NDL	TFS 39930
	movement := voyage.getMovementArrival;
	if movement &lt;&gt; null then
		if self.myBerth &lt;&gt; null then
			movement.setMyBerth(self.myBerth);
		endif;
		
		if  self.requiredByDT.isValid then
			movement.setOccursOnDT(self.requiredByDT);
		endif;
		
		voyage.myHMSVoyageData.validateMe( app.myPassport);
		if app.myPassport.hasErrors then
			return;
		endif;
	endif;
	
//	if voyage.myVoyageProcess.isInaPortNetProcess
//	or voyage.myVoyageProcess.isPelindo1Process
//	then
	if not voyage.myVoyageProcess.isDefaultProcessJMT then	//23 July 2018	NDL	TFS 39882
		if _approve then
			//	self.myParent.CM_WorkOrderVoyage.setApproved( app.myPassport.myUser.code, null, app.myPassport );
			self.myParent.CM_WorkOrderVoyage.setTaskStatus( WO_STATUS_APPROVED );
		endif;
		self.myParent.CM_WorkOrderVoyage.setLengthOfTime( _totDays );
	endif;

epilog

end;</source>
        <Parameter name="_approve" type="Boolean"/>
        <Parameter name="_totDays" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="doRejectEstimation" id="fe48ea92-31fa-48c5-9aaa-0ad51ce3a00b">
        <updating/>
        <source>doRejectEstimation( _remarks : String; _lengthOfTime : Decimal )updating;
/*

Purpose:			NOT REFERENCED

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2018	jlgndl1	Initial creation	TFS 39197

*/

vars

	voyage : CM_Voyage;

begin

	voyage := self.getMyVoyageObject();
	
	if voyage = null or self.myParent = null or not self.myParent.isVoyageWorkOrder then
		return;
	endif;
	
//	if voyage.myVoyageProcess.isInaPortNetProcess
//	or voyage.myVoyageProcess.isPelindo1Process
//	then
	if not voyage.myVoyageProcess.isDefaultProcessJMT then	//23 July 2018	NDL	TFS 39882
		self.myParent.CM_WorkOrderVoyage.setNotApproved( app.myPassport.myUser.code, _remarks, _lengthOfTime );
	endif;

epilog

end;</source>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_lengthOfTime" type="Decimal"/>
    </JadeMethod>
