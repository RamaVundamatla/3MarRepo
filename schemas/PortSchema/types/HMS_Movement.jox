    <JadeMethod name="initializeForActivity" id="2433521e-6657-457b-9254-fef2368c833a">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*
Purpose:			

Date		Who		Reason
04 May 2022	navab1	TFS 53569
*/

vars
	details : CMIF_VslVesselBerthings;
	voyage : CM_Voyage;
	berth : HMS_Berth;
begin
	voyage := self.getMyVoyage(); // ### TFS 53569 06MAY2022 NAVAB1

	if _opsViewTable.isKindOf(CMIF_VslVesselBerthings) then
		details := _opsViewTable.CMIF_VslVesselBerthings;
		
		details.tableName		    := details.Vsl_vessel_berthings;
		
		details.gkey := details.generateFullGKey(self, "");
		details.vvd_gkey := details.generateFullGKey(voyage, "");
		details.ata := self.occursOnDTNEW.asEpochFormat();
		details.atd := voyage.departedDT.asEpochFormat();
		berth := self.getMyBerth();
		if berth &lt;&gt; null then
			details.quay := details.generateFullGKey(berth, "");
		endif;
		details.seq:= details.n4MoveSeq(self.HMS_VoyageMovement);
		
		details.ship_side_to := details.n4BerthOrientation(self.HMS_VoyageMovement.sideTo);
	endif;
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
    <JadeMethod name="isArrivalDirectFromOtherHarbor" id="06daaa53-a8b0-47c8-81f0-87d3f5968152">
        <source>isArrivalDirectFromOtherHarbor() : Boolean;
// ---------------------------------------------------------------------------
// Created:     21 February 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	prevMove	: HMS_Movement;
begin
	if (not self.moveType = HMSMovementTypeArrival) then
		return false;
	endif;
	
	prevMove	:= self.myPreviousMovement;
	if prevMove = null then
		return false;
	endif;
	
	return (prevMove.moveType = HMSMovementTypeDeparture and
		   prevMove.getMyBerth = self.getMyBerth);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCancelled" id="5877ad3a-8477-40ae-a8ec-bddbdd9cd2c4">
        <source>isCancelled():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 November 2018	jlgndl1	Initial creation	TFS 42043

*/

vars

begin

	if self.moveType.isOneOf( HMSMovementTypeCanceledArrival, HMSMovementTypeCanceledShift, HMSMovementTypeCanceledDepart ) then
		return true;
	endif;

	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForTerminal" id="bbe7d0e2-ce26-44b5-bbb4-94f6bb146f66">
        <source>isForTerminal():Boolean;
// --------------------------------------------------------------------------------
// Created:		24 October 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is actually
//				sailing from a Terminal.
//
// Parameters:	None
//
// Returns:		True if the receiver is sailing from a Terminal, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	harbourRegionObj	: HMS_HarbourRegion;
	terminalObj			: CM_Terminal;
	
begin
	if self.getMyBerth() &lt;&gt; null then
		harbourRegionObj	:=	self.getMyBerth().myHarbourRegion;
	endif;
	
	if harbourRegionObj &lt;&gt; null then
		return harbourRegionObj.isTerminal();
		
		//terminalObj			:=	harbourRegionObj.getTerminalForScenario();
		
		//if terminalObj &lt;&gt; null then
		//	return true;
		//endif;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
