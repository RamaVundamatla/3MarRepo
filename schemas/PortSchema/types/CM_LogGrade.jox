    <JadeMethod name="setForCreate" id="eb1707c1-c53b-486e-9ce9-3b4c8fc1d72c">
        <updating/>
        <source>setForCreate(pProxyLogGrade : CM_LogGrade) updating;
//--------------------------------------------------------------
//Created: 08 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	inheritMethod(pProxyLogGrade);
	
	self.myLogSpecies := pProxyLogGrade.myLogSpecies;

end;</source>
