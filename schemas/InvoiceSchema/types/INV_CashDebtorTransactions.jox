        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnExportCSV_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	if self.tblCash.rows &lt;= self.tblCash.fixedRows then
		app.raiseCMException(ERR_NoDataToExtract, 'Table Data', self.tblCash);
		return;
	endif;
	
	self.tblCash.outputAsCSV(null);

epilog

end;</source>
