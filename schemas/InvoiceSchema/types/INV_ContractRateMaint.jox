    <JadeMethod name="doCmbUOMBuild" id="90e9c6be-c46c-4714-bb7d-4b3dcc743b3a">
        <source>doCmbUOMBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 TTask 55665: UI - Contract Details

*/
vars
	invUOM : CM_InvoiceUnitOfMeasure;
begin
	self.cmbUnitOfMeasure.clear;
	
	foreach invUOM in app.myRoot.allInvoiceUnitOfMeasure  do
		self.cmbUnitOfMeasure.addItem(invUOM.description);
		self.cmbUnitOfMeasure.itemObject[self.cmbUnitOfMeasure.newIndex] := invUOM;
	endforeach;
	invUOM := self.myInvLineDescription.myUOM;
	if invUOM &lt;&gt; null then
		self.cmbUnitOfMeasure.listObject := invUOM; // ### TFS BUG 59913 313AUG2023 NAVAB1
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doHandleNotification" id="18c6c83e-729c-43d3-bf23-887ff0203050">
        <updating/>
        <source>doHandleNotification( eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes

*/

vars
	dataLine	: String;
	invContractRateEntry : CM_InvoiceContractRateEntry;
	event : Integer;
	idx : Integer;
	theDataLine : String;
	rate : CM_InvoiceContractRate;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if userInfo.isKindOf(CM_InvoiceContractRateEntry) then
		invContractRateEntry := userInfo.CM_InvoiceContractRateEntry;
	elseif theObject.isKindOf(CM_InvoiceContractRateEntry) then
		invContractRateEntry := theObject.CM_InvoiceContractRateEntry;
	elseif userInfo.isKindOf(CM_InvoiceContractRate) then
		rate := userInfo.CM_InvoiceContractRate;
	elseif theObject.isKindOf(CM_InvoiceContractRate) then
		rate := theObject.CM_InvoiceContractRate;
	endif;
	
	if event = Event_InvContractRateEntCreate or event = Event_InvContractRateCreate then
		if invContractRateEntry &lt;&gt; null then			
			self.tblDisplayRow();
		elseif rate.myService &lt;&gt; null then
			if self.cmbService.listObject = rate.myService then
				self.handleService();
			endif;
		endif;
	elseif event = Event_InvContractRateEntUpdate then
		if invContractRateEntry &lt;&gt; null then
			//25/10/2023 navmv20 CR 60503 Task 60505 - start
			self.tblDisplayRow();
			
				/*self.tblData.findObjectInRow(invContractRateEntry,idx);
				self.tblData.refreshRowObjects();
				if idx &gt; self.tblData.fixedRows then
					theDataLine := invContractRateEntry.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
					self.tblData.accessCell(idx, 1).text := theDataLine;
				endif;*/
			//25/10/2023 navmv20 CR 60503 Task 60505 - end
		endif;
		
	elseif event = Event_InvContractRateEntDelete then
		self.tblData.removeItemObject(invContractRateEntry);
		self.doNotableClear();
		self.tblDisplayRow();//5/10/2023 navmv20 CR 60503 Task 60505
	elseif event = Event_InvContractRateDelete then
 // ### TFS BUG 56879 02MAR2023 NAVAB1		self.tblData.refreshRowObjects(); - this removes and re adds the objects in the table
		self.tblData.rows := self.tblData.fixedRows; // ### TFS BUG 56879 02MAR2023 NAVAB1
		self.cmbService.listIndex := -1; // ### TFS BUG 56879 02MAR2023 NAVAB1
	endif;
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
