    <JadeMethod name="manuallySelectAFDebtor" id="02f5cd22-cfa7-46ee-bb6b-b8bc68bacf7c">
        <source>manuallySelectAFDebtor() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
05 April 2018	jlgndl1	Initial creation
06 March 2023	navmk20	Task 56140: EUP Inv Config - Surcharge Logging
18 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels

*/
	
vars

	rangeStart : Real;
	rangeEnd : Real;
	dr : CM_Debtor;
	currentHighest : CM_InvTypeAdditionalCharges;

begin

	rangeStart := self.txtAFRangeStart.text.asRealJMT();
	rangeEnd := self.txtAFRangeEnd.text.asRealJMT();
	if rangeEnd &gt; CM_InvoiceTypeSurchargeExempt.HighValue_15_2 then	//24 Apr 2018	NDL	TFS 37819 rework, and again 24 Jul 2019	NDL TFS 45509
		rangeEnd := CM_InvoiceTypeSurchargeExempt.HighValue_15_2;
	endif;
	dr := self.cmbAFDebtor.listObject.CM_Debtor;
	
	if self.myCurrentInvTypeSurExempt = null then
		return;
	endif;
	if rangeStart = 0 and rangeEnd = 0 and dr &lt;&gt; null then
		//default to the next start value for this debtor
		// 1.3.2023 navmk20 TFS 56140
		app.invLog("To get current highest additional charges", LogINFO.String);
		currentHighest := self.myCurrentInvTypeSurExempt.getHighestRangeAddChgFor( dr );
		if currentHighest = null then
			self.txtAFRangeStart.text := "0.00".Decimal.asStringJMT;
			self.txtAFRangeEnd.text := CM_InvoiceTypeSurchargeExempt.HighValue_15_2.asStringJMT;
		elseif currentHighest.rangeEnd &lt; CM_InvoiceTypeSurchargeExempt.HighValue_15_2 then
			self.txtAFRangeStart.text := ( currentHighest.rangeEnd + 0.01 ).asStringJMT;
			self.txtAFRangeEnd.text := CM_InvoiceTypeSurchargeExempt.HighValue_15_2.asStringJMT;
		else
			//do nothing
		endif;
		
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="manuallySelectETDebtor" id="113eb97a-a7bf-428d-a1bb-225df2bc4446">
        <source>manuallySelectETDebtor() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
05 April 2018	jlgndl1	Initial creation
06 March 2023	navmk20	Task 56140: EUP Inv Config - Surcharge Logging
18 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels
*/
	
vars

	rangeStart : Real;
	rangeEnd : Real;
	dr : CM_Debtor;
	currentHighest : CM_InvoiceTypeExternalTax;

begin

	rangeStart := self.txtETRangeStart.text.asRealJMT();
	rangeEnd := self.txtETRangeEnd.text.asRealJMT();
	if rangeEnd &gt; CM_InvoiceTypeSurchargeExempt.HighValue_15_2 then	//24 Apr 2018	NDL	TFS 37819 rework, and again 24 Jul 2019	NDL TFS 45509
		rangeEnd := CM_InvoiceTypeSurchargeExempt.HighValue_15_2;
	endif;
	dr := self.cmbETDebtor.listObject.CM_Debtor;
	
	if self.myCurrentInvTypeSurExempt = null then
		return;
	endif;
	if rangeStart = 0 and rangeEnd = 0 and dr &lt;&gt; null then
		//default to the next start value for this debtor
		// 1.3.2023 navmk20 TFS 56140
		app.invLog("To get current highest additional charges", LogINFO.String);
		currentHighest := self.myCurrentInvTypeSurExempt.getHighestRangeTaxFor( dr );
		if currentHighest = null then
			self.txtETRangeStart.text := "0.00".Decimal.asStringJMT;
			self.txtETRangeEnd.text := CM_InvoiceTypeSurchargeExempt.HighValue_15_2.asStringJMT;
		elseif currentHighest.rangeEnd &lt; CM_InvoiceTypeSurchargeExempt.HighValue_15_2 then
			self.txtETRangeStart.text := ( currentHighest.rangeEnd + 0.01 ).asStringJMT;
			self.txtETRangeEnd.text := CM_InvoiceTypeSurchargeExempt.HighValue_15_2.asStringJMT;
		else
			//do nothing
		endif;
		
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
