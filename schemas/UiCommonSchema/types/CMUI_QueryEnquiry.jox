    <JadeMethod name="setupForm" id="058f1985-4d6d-42e9-9ffa-91f3b5f1029a">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	
	self.splMain.top := self.frmToolbar.height - 4;
	self.frmQuery.zOrder(1); //+ cnwmd1 29/07/2009 - The zOrder has been changed in painter.
	
	if self.usesQueryFrame then
		self.positionQueryFrame();
		self.initQueryFrame();
	else
		self.frmQuery.visible := false;
	endif;
	
	if self.xmlMacro then
		self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
	else
		self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
	endif;
    self.mnuContextHide_click(self.mnuContextHide); // this reverses the lines above and sets things correctly

//	self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
	self.btnCancelBase.caption := '&amp;Close';
	
	self.fldQuery.useSheetBackColors := true;
	self.fldQuery.setDefaultSheetBackColors();
	self.fldQuery.initSheetBackColors();
	
	self.mnuSendToReport.visible := false;											// 26/11/2012 cnwmh5 #30756
	self.mnuSendReportMain.visible := false;										// 26/11/2012 cnwmh5 #30756
	
	//epr par 19271 3/4/09
	self.tblInfo.visible:=self.useTableInfo; 
	if not self.useTableInfo then
		self.splMain.hideRightControl(true);
	endif;
	self.mnuContextHide.visible:=self.useTableInfo;
	
	//25/06/2024	navkc1 CR 64823 Task 64824
	//self.txtFilterBox.width := self.frmFilterBox.clientWidth - 5;
	
	self.frmTblFilter.setupControl(self.tblData, null); //05/06/2024	navkc1 CR 63736 Task 63770
end;</source>
    </JadeMethod>
    <JadeMethod name="shouldIShow" id="85098ec0-bf89-42d9-ba1e-2518a8030f45">
        <source>shouldIShow() : Boolean;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return true;
	if app.isDevelopmentSystem then
		return true;
	else
		app.msgBox("This screen is unavailable as it is still in development.","Invoice Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showColourLegend" id="1735614b-330b-41ad-84d2-6bc591680ef9">
        <source>showColourLegend();
//--------------------------------------------------------------
//Created: 07 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	colLegend	: CMUI_ColourLegend;
	
begin
	// Update the navigator
	create colLegend;

	colLegend.centreWindow;
	colLegend.addLegendItem("Job Unactioned",					Black,				White,				"picJobWLEs", false);
	colLegend.addLegendItem("Job Returned",						Red,				White,				"picJobWLEs", false);
	colLegend.addLegendItem("Job Part Complete",				Black,				White,				"picJobPartComp", false);
	colLegend.addLegendItem("Job Complete",						Black,				White,				"picJobComp", false);
	colLegend.addLegendItem("Unactioned Receipt Job",			CM_Job.Colour_ReceiptUnactioned,		White,				null, false);
	colLegend.addLegendItem("Unactioned Release Job",			CM_Job.Colour_ReleaseUnactioned,				White,				null, false);
	colLegend.addLegendItem("Partially Worked Receipt Job",		CM_Job.Colour_ReceiptPartComplete, White, null, false);
	colLegend.addLegendItem("Partially Worked Release Job",		CM_Job.Colour_ReleasePartComplete,			White,				null, false);
	colLegend.addLegendItem("Completed Receipt Job",			White,				CM_Job.Colour_ReceiptComplete,				null, false);
	colLegend.addLegendItem("Completed Release Job",			White,				CM_Job.Colour_ReleaseComplete, null, false);
	colLegend.addLegendItem("Completed Hatch Lid Job",			Black,				CM_VoyageHatchLidJob.Colour_HatchLidComplete, null, false);
	colLegend.addLegendItem("Matched up to a TBA Contaner",		Black,				 LightGreen,		null, false);
	colLegend.addLegendItem("Returned Job",						Black,				Red,				null, false);
	colLegend.addLegendItem("Voyage Job Unassigned",			Black,				ColourYellowDark,	null, false);
	colLegend.addLegendItem("Voyage Job Unassigned",			Black,				ColourYellowLight,	null, false);
	colLegend.addLegendItem("Voyage Job Loaded to Operations - Not Fully Planned",	Black,				CM_VoyageJob.Colour_JobLoaded, null, false);
	colLegend.addLegendItem("Voyage Job Loaded to Operations - Fully Planned",	Black,		CM_VoyageJob.Colour_JobLoadedPlanned, null, false);
	colLegend.addLegendItem("Voyage Job Not Loaded to Operations", Black,			CM_VoyageJob.Colour_JobNotLoaded, null, false);
	colLegend.addLegendItem("Ship nonPlan/nonWork Cargo and Log Dockets", Black,	self.colorRow1,		null, false);
	colLegend.addLegendItem("Ship nonPlan/nonWork Cargo and Log Dockets", Black,	self.colorRow2,		null, false);
	colLegend.addLegendItem("Other",							White,				Mauve,				null, false);

	colLegend.showModal;


epilog
	delete colLegend;


end;</source>
    </JadeMethod>
