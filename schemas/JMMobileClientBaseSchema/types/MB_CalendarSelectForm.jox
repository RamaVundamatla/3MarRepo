        <updating/>
        <source>calCalendar_click(cntrl: MB_Calendar input) updating;
// --------------------------------------------------------------------------------
// Created:		01 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	txtDate.text	:=	cntrl.date.shortFormatJMT();
end;</source>
