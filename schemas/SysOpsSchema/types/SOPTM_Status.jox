    <JadeMethod name="setupThumbnailDefaults" id="9e6c5d14-e1a6-4fcb-a1cb-1bf8cc2be611">
        <source>setupThumbnailDefaults();
// ---------------------------------------------------------------------------
// Created:     22 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	
	self.myForm.allowAdd 	:= false;
