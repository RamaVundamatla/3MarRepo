    <JadeMethod name="setNominatedTA" id="08140d52-2ef2-429c-9076-c33ab0fd3fc8">
        <updating/>
        <source>setNominatedTA(_areaId : String; _ta : CM_TerminalArea ; _gridObj : CM_GridObject) updating;
// 10/02/2010	cnwjre1	CCMS 1101
// only store one terminal area in allTerminalAreas at present - is a collection to allow for multiple areas in future

// ==========================================================
// RJS July 2010 - Above comment is incorrect!  From Road Gate can enter more then one terminal area
// refer PAR 25012
// ==========================================================

vars
	ta,
	oldTa	: CM_TerminalArea;
begin

	if _ta = null then
		ta := self.myTerminal.lookupTerminalArea(_areaId);
	else
		ta := _ta;
	endif;
	if ta &lt;&gt; null then
		if self.allTerminalAreas.isEmpty then
			self.allTerminalAreas.add(ta);
			self.allTerminalAreaGridObj.add(_gridObj);
		else
			self.allTerminalAreaGridObj.clear();
			self.allTerminalAreas.clear; //(oldTa);
			self.allTerminalAreas.add(ta);
			self.allTerminalAreaGridObj.add(_gridObj);
		endif;
	endif;

end;
</source>
        <Parameter name="_areaId" type="String"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_gridObj" type="CM_GridObject"/>
    </JadeMethod>
    <JadeMethod name="setNominatedTAs" id="79343d76-d48d-4658-8ee0-6194bb6de732">
        <updating/>
        <source>setNominatedTAs( _taList : CM_TerminalAreaArray; _alTAGridObjects : CM_GridObjectArray) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwrd1	Initial creation

*/

vars

begin

	if _taList &lt;&gt; null then //cnwrd1 par 24169  3.6.2010
		// clear and copy _taList 
		self.allTerminalAreas.clear();
		_taList.copy(self.allTerminalAreas);
		self.allTerminalAreaGridObj.clear(); //cnwrd1 2098
		if _alTAGridObjects &lt;&gt; null then
			_alTAGridObjects.copy(self.allTerminalAreaGridObj);
		endif;
	endif;	
	
epilog

end;</source>
        <Parameter name="_taList" type="CM_TerminalAreaArray"/>
        <Parameter name="_alTAGridObjects" type="CM_GridObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setProxyAdditionalInfo" id="f6531876-81b2-4023-bef9-ca3aee60c795">
        <updating/>
        <source>setProxyAdditionalInfo(_needGen, _needCOU, _doorsFrwd, _heavyRated : Boolean;
						_mask : String; _aveGrades : IntegerArray) updating;
//--------------------------------------------------------------
//Created: 05 February 2003 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
23 Nov 2011	cnwkpd1	PAR #28731 - fix transient leaks
	
*/

vars
	idArray : StringArray;
begin

	self.raiseExceptionIfNotTransient(method);
	
	self.needGenerator 	:= _needGen;
	self.needCOU		:= _needCOU;
	self.doorsForward	:= _doorsFrwd;
	self.heavyRated		:= _heavyRated;
	
	self.allAvailabilityGrades.clear();
	_aveGrades.copy(self.allAvailabilityGrades);
	
		// Set The Mask IDs
//	create idArray transient;		// PAR #28731 
	idArray := self.getIDsFromString(_mask);
	self.setIds(idArray);

epilog
	delete idArray;

end;</source>
        <Parameter name="_needGen" type="Boolean"/>
        <Parameter name="_needCOU" type="Boolean"/>
        <Parameter name="_doorsFrwd" type="Boolean"/>
        <Parameter name="_heavyRated" type="Boolean"/>
        <Parameter name="_mask" type="String"/>
        <Parameter name="_aveGrades" type="IntegerArray"/>
    </JadeMethod>
