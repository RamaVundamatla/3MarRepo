        <source>setProxy(_root : CM_Root)updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.myRoot := _root;
end;</source>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="validate" id="5302b917-0750-434b-9f69-8e047a2ffa2b">
        <source>validate(_conflictManager : CMIF_HMS_ConflictsManager output; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 11 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.validateMe(_passport);
	self.validateCurrentChanges(_conflictManager, _passport);		
end;</source>
        <Parameter name="_conflictManager" type="CMIF_HMS_ConflictsManager" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateCurrentChanges" id="28f4cfff-af32-4300-a22f-a385598b97d1">
        <source>validateCurrentChanges(_conflictManager : CMIF_HMS_ConflictsManager output; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 11 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	changeFound	: Boolean;
	realClass		: HMS_TidalClass;
	count			: Integer;
	tmpDec,
	maxCurrent		: Decimal[5,1];
begin
	if (not self.isTransient) then
		return;
	endif;
	
	realClass := self.pxyGetRealObject();
	if realClass = null then
		return;
	endif;

	foreach maxCurrent in self.allMaximumCurrents do
		count := count+1;
		tmpDec := realClass.allMaximumCurrents[count];
		if maxCurrent &lt;&gt; tmpDec then
			// Tidal class current values have been changed
			// Run validation on tidal class current changes
			changeFound := true;
			break;
		endif;
	endforeach;

	if changeFound then
		create _conflictManager transient;
		_conflictManager.allValidationTypes.add(ValidateTidalClass);
		_conflictManager.myChangedTidalClass := realClass;
		// Build a collection of movements to validate
		app.myRoot.validateVoyageConflicts(_conflictManager);	
		if (not _conflictManager.allCMIFConflicts.isEmpty) then
			app.raiseCMException(HMSMovementConflict, null, null);
		else
			delete _conflictManager;
			_conflictManager := null;			
		endif;
	endif;
	
end;</source>
        <Parameter name="_conflictManager" type="CMIF_HMS_ConflictsManager" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="05168753-b8b4-4124-997b-f3789a26f887">
        <source>validateForDelete(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	17 December 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_passport);
	if (not self.allHMSVesselData.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, self.getDisplayString(), "Vessel Data", null, null);	
	endif;	
	if (not self.allHMSVoyageData.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, self.getDisplayString(), "HMS Voyage Data", null, null);	
	endif;	
	if (not self.allMovements.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, self.getDisplayString(), "Voyage Movements", null, null);	
	endif;					

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMaxCurrents" id="263759f3-e4f0-4cdb-86ca-1cd7f13b92ad">
        <source>validateMaxCurrents(_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 11 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	str : String;
	count : Integer;
  	dec	: Decimal[6,3]; //par19665 cnwrs1 apr 2009
begin

	// Check for error in data or blank fields
	foreach dec in self.allMaximumCurrents do
		count := count+1;
		if count = 1 then
			str := ETRow_MaxFloodTideArrival;
		elseif count = 2 then
			str := ETRow_MaxEbbTideArrival;
		elseif count = 3 then
			str := ETRow_MaxFloodTideDept;
		elseif count = 4 then
			str := ETRow_MaxEbbTideDept;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Count exceeds limit of 4.');											
		endif;		
		// Check that current values are between 0 and 50
		if dec &lt;= 0 or dec &gt; 50 then
			app.raiseCMException1(TidalOutOfRange, str, null, null);
		endif;	
	endforeach;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="63a8890d-77b8-42a6-805e-937ea9948538">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//--------------------------------------------------------------
vars
	tmpTidalClass : HMS_TidalClass;
begin
	inheritMethod(_passport);
	
	if self.code = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Code', ETRow_Code, null);
		app.raiseCMException(Input_required_field_code, ETRow_Code, null); // cnwdb2	PAR 35364


	endif;
	if self.description = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Description', ETRow_Description,  null);
		app.raiseCMException(Input_required_field_desc, ETRow_Description,  null); // cnwdb2	PAR 35364
	endif;

	if self.myRoot = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Harbour Root', null,  null);
		app.raiseCMException(Input_required_field_harbRoot, null,  null); // cnwdb2	PAR 35364
	endif;

	if _passport.hasErrors then
		return;
	endif;

	tmpTidalClass := self.myRoot.allTidalClasses.getAtKey(self.code);
	if tmpTidalClass &lt;&gt; null then
		if self.isTransient and tmpTidalClass &lt;&gt; self.pxyGetRealObject() then
			//app.raiseCMException2(DuplicateItem, 'TidalClass', self.code, ETRow_Code, null); //14.06.2022 navds20 53760
			// TidalClass already exists for %1 : Tidalclass_already_exists
			app.raiseCMException1(Tidalclass_already_exists, self.code, ETRow_Code, null); //14.06.2022 navds20 53760
		endif;
	endif;

	self.validateMaxCurrents(_passport);	

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
