<Class name="WsdlApplication" id="08c2070a-2ca8-47f1-8c56-f395e0cad85f">
    <superclass name="Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This class represents a web service application.

This is the root class of the various Wsdl classes.
Each .wsdl file corresponds to exactly one WsdlApplication.
Each application can contain one or more endpoints (in Jade an endpoint is a JadeWebService
Provider or Consumer subclass. In a Wsdl file an endpoint is a Url, eg:
'http://host/dir/jadehttp.dll?Provider&amp;serviceName=CitiesProvider';

ExposedWsdlTypes are the Classes defined in the wsdl file (ie those classes used or referenced
by the webservice provider)

wsdlName is the name of this application as it is defined in the wsdl file.
jadeName is the name of this application given by the user when imported into Jade, this may or may
not be the same name as what it originally had in the wsdl file.

</text>
    <DbClassMap file="richinternettoolset"/>
    <ExplicitInverseRef name="endpoints" id="a5193e84-dfe5-433e-8eab-799736c60ee7">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <type name="WEndpointArray"/>
        <Inverse name="WsdlEndpoint::myApplication"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="exposedWsdlTypes" id="37de9265-7f6e-4f86-84c6-a378d8fb9d92">
        <memberTypeInverse/>
        <type name="WTypeArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="jadeName" id="80277baa-b792-4629-b1cc-9d27e9781e99">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="wsdlName" id="16e91870-0e0a-45e8-a023-20f41dc5e0e9">
        <type name="String"/>
    </PrimAttribute>
</Class>
