    </JadeMethod>
    <JadeMethod name="dphTFS42853" id="c23df3cf-b50b-4e5a-96ac-0d6833a34cfe">
        <source>dphTFS42853();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2017	cnwma1	Initial creation
05 Oct 2022  navma1		Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
21 June 2023 navmv20 CR 58373 Task 58381: Jade - Future Storage Additional Days
*/

vars
	ti : CM_TrackedItem;
	count :Integer;
	ts : TimeStamp;
	date: Date;
	time :Time;
	lFile :File;
	storageDetail : CM_StorageDetail;
begin

	date := "01/01/2000".Date;
	time := "00:00:00.000".Time;
	
	ts.setDate(date);
	ts.setTime(time);
	create lFile transient;
	lFile.fileName := "C:\TEMP\dph1752.csv";
	lFile.open;
	lFile.writeLine("ID" &amp;","&amp; "Cargo Type" &amp;","&amp; "AnniversaryDate"&amp;","&amp;  "InvoiceLines");
	foreach ti in CM_BreakBulkGeneric.instances where ti.isOnSite and  ti.plannedDT &lt;&gt; null and ti.plannedDT &lt; ts do
		
	lFile.writeLine(ti.id &amp;","&amp; ti.cargoTypeDescr &amp;","&amp; ti.plannedDT.asStringJMT &amp;","&amp;  ti.invoiceLines.size.asStringJMT &amp;","&amp;ti.getOidString );
	//ti.setFutureStorageAnniversary(null,storageDetail);	//05.10.2022 navma1 #52967 //21/06/2023 navmv20 CR 58373 Task 58381
	ti.setFutureStorageAnniversary(null,storageDetail,false); //21/06/2023 navmv20 CR 58373 Task 58381
	count := count +1;
	endforeach;
	lFile.close;
	delete lFile;
epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="dumpTranslationsAfter" id="dcaea6b0-1227-4131-bf98-8a39c821997e">
        <source>dumpTranslationsAfter();
/*
Date		Who		Reason
23 April 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	cmd				:CMDFileSave;
	file			:File;
	xlationTable	:CM_XlationTable;
	str1, str2		:String;
	type			:Integer;
	xlation			:CM_Xlation;
begin
	app.initialize;
	
	create cmd transient;
	
	if cmd.open &lt;&gt;  0 then
		return;
	endif;
	
	create file transient;
	
	file.mode := File.Mode_Output;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	file.fileName := cmd.fileName;
	
	file.writeLine (Tab &amp; 'Type' &amp; Tab &amp; 'Operator' &amp; Tab &amp; 'Terminal' &amp; Tab &amp; Tab &amp;'Foreign Code' &amp; Tab &amp; 'F/Default' &amp; Tab &amp; 'System Code' &amp; Tab &amp; 'S/Default');
	foreach xlationTable in CM_XlationTable.instances do
		// oid, type, operator, terminal, 
		str1 := xlationTable.asStringJMT &amp; Tab;
		
		type := xlationTable.type;
	
		if type = XLATION_TYPE_PORT_BYOP then
			str1 := str1 &amp; 'Ports';
		elseif type = XLATION_TYPE_COMMODITY_BYOP then
			str1 := str1 &amp; 'Commodities';
		elseif type = XLATION_TYPE_CARRIER_BYOP then
			str1 := str1 &amp; 'Carriers';			
		elseif type = XLATION_TYPE_CONSIGNEE_BYOP then
			str1 := str1 &amp; 'Consignees/consignors';
		elseif type = XLATION_TYPE_VESSEL_BYOP then
			str1 := str1 &amp; 'Vessels';
		elseif type = XLATION_TYPE_ISOTYPE_BYOP then
			str1 := str1 &amp; 'ISO types';			
		elseif type = XLATION_TYPE_OPERATOR_BYOP then  
			str1 := str1 &amp; 'Operators';		
		elseif type = XLATION_TYPE_TERMINAL_BYOP then
			str1 := str1 &amp; 'Terminals';			
		elseif type = XLATION_TYPE_MTGRADE_BYOP then
			str1 := str1 &amp; 'MT Grades';
		elseif type = XLATION_TYPE_VOYAGETERMINAL then
			str1 := str1 &amp; 'Voyages';
		elseif 	type = XLATION_TYPE_OPERATOR then
			str1 := str1 &amp; 'System - Operators';		
		elseif type = XLATION_TYPE_CUSTOMSAGENT then
			str1 := str1 &amp; 'System - Customs Agents';			
		elseif type = XLATION_TYPE_SHIPPINGLINE then
			str1 := str1 &amp; 'System - Shipping lines';			
		elseif type = XLATION_TYPE_VESSEL then
			str1 := str1 &amp; 'System - Vessels';
		endif;
	
		str1 := str1 &amp; Tab;
		
		if xlationTable.myOperator &lt;&gt; null then
			str1 := str1 &amp; xlationTable.myOperator.code &amp; Tab &amp; Tab;
			
		elseif xlationTable.myOperatorTerminal &lt;&gt; null then
			if xlationTable.myOperatorTerminal.myOperator &lt;&gt; null then
				str1 := str1  &amp; xlationTable.myOperatorTerminal.myOperator.code &amp; Tab;
			else
				str1 := str1 &amp; Tab;
			endif;
			if xlationTable.myOperatorTerminal.myTerminal &lt;&gt; null then
				str1 := str1  &amp; xlationTable.myOperatorTerminal.myTerminal.code &amp; Tab;
			else
				str1 := str1 &amp; Tab;
			endif;
		else
			str1 := str1 &amp; Tab &amp; Tab;
		endif;
		
		// foreignCode, foreign Default, systemCode, systemDefault
		foreach xlation in xlationTable.allInwardTranslations do
			str2 := xlation.foreignCode &amp; Tab &amp; 'In' &amp; Tab &amp; xlation.systemCode &amp; Tab &amp; null.String;
		endforeach;
		
		write str1 &amp; Tab &amp; str2;

		file.writeLine (str1 &amp; Tab &amp; str2);
		
		foreach xlation in xlationTable.allOutwardTranslations do
			str2 := xlation.foreignCode &amp; Tab &amp; '' &amp; Tab &amp; xlation.systemCode &amp; Tab &amp; "Out";
		endforeach;
		
		write str1 &amp; Tab &amp; str2;

		file.writeLine (str1 &amp; Tab &amp; str2);
	endforeach;
	
	file.close;
epilog
	delete cmd;
	delete file;
end;</source>
    </JadeMethod>
