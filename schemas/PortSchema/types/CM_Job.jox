    <JadeMethod name="getExtraInfo" id="c0b763f8-257c-4dde-8f7f-3202b78ed7a3">
        <source>getExtraInfo(_dataContainer : CM_DataContainer) ;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14/06/2022 	navcs2 		ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
// 06 Mar 2025 navma1 		MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
// 09 Sep 2025	naviv1		MTN-35754 | Release Request ID is displayed on the Booking field on the additional information section of the Gate Lanes In table
// ---------------------------------------------------------------------------

vars
	block 		: CM_DataContainerBlock;
	req			: CM_Request;
	wle			: CM_WorkListEntry;
	bol 		: CM_BOL;
	pieceCount 	: Integer;
	str,
	addStr		: String;	
	firstYOPass,
	invalidObj	: Boolean;
	ti			: CM_TrackedItem;
	releaseNum : String;

begin
	firstYOPass	:= true;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_ID), DC_Label, 1, self);
	block.addNewItem(self.jobId, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Status), DC_Label, 1, self);
	block.addNewItem(self.statusString, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Dwell_Time), DC_Label, 1, self);
	block.addNewItem(self.dwellTime.String, DC_Data, 1, self);




	foreach req in self.allRequests discreteLock do		//06.03.2025 navma1 #MTN-34179
		if req.isKindOf(CM_YardRequest) then		
			releaseNum := req.CM_YardRequest.deliveryNumber;
		endif;
		
		if firstYOPass then
			req.getExtraInfo(_dataContainer); //cnwrd1 ccms 1075 yard ops form test...
			firstYOPass := false;
		endif;
		
		if releaseNum &lt;&gt; "" then		
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Release_request), DC_Label, 1, null); //09-Sep-2025 naviv1 #MTN-35754
			block.addNewItem(releaseNum, DC_Data, 1, null);
			break;
		endif;
		
	endforeach;

	if self.workListEntries.isNotEmpty then						//06.03.2025 navma1 #MTN-34179
		block := _dataContainer.addNewBlock;
		block.addNewItem("Cargo", DC_MoreInfo, 1, null);
		foreach wle in self.workListEntries discreteLock do		//06.03.2025 navma1 #MTN-34179
		// 14/06/2022 navcs2 TFS 53038
			if wle.isKindOf(CM_WOToDoWLE) then
				continue;		//Otherwise we get the same info twice
			endif;
			if wle.myBOL &lt;&gt; null then
				bol := wle.myBOL;
				str := str &amp; wle.myBOL.number &amp; '; ';
				if str.length &lt;= 35 then
					addStr := str;
				else
					break;
				endif;
				pieceCount := pieceCount + bol.numItems;
			elseif wle.myTrackedItem &lt;&gt; null then
				block := _dataContainer.addNewBlock;
				block.addNewItem("Cargo", DC_Label, 1, wle.myTrackedItem);
				block.addNewItem(wle.myTrackedItem.id, DC_Data, 1, wle.myTrackedItem);
			endif;
		endforeach;
		if addStr &lt;&gt; null then

			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(BillOfLading), DC_Label, 1, null);
			block.addNewItem(addStr, DC_Data, 1, null);

			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(CM_Total_Piece_Count), DC_Label, 1, null);
			block.addNewItem(pieceCount.String, DC_Data, 1, null);
		endif;
	endif;

	// 22/02/2013 cnwar2 #28979
	if self.isKindOf(CM_YardInternalJob)
	and self.CM_YardInternalJob.selectedTIs.size &gt; 0 then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Selected Cargo", DC_MoreInfo, 1, null);
		on Exception do app.handleDeletedObject(exception, ti, invalidObj); 	// TFS 2198 (TESTING)
		
		foreach ti in self.CM_YardInternalJob.selectedTIs discreteLock do		//06.03.2025 navma1 #MTN-34179
			block := _dataContainer.addNewBlock;
			block.addNewItem("Cargo", DC_Label, 1, ti);
			block.addNewItem(ti.id, DC_Data, 1, ti);
		endforeach;
	endif;
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getFirstInstFromTIs" id="9437d760-410d-445c-9c81-3754d6fb2b97">
        <source>getFirstInstFromTIs():CM_InstructionsIssued;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Apr 2025	navbs1	Bug MTN-34396: EUP | Additional Operational Instructions - more issues (part 2)

*/

vars
	wle : CM_WorkListEntry;
	trackedItem : CM_TrackedItem;
	instruction : CM_InstructionsIssued;
begin
    foreach wle in workListEntries discreteLock do 					//08.04.2025 navbs1 #34396
		trackedItem := wle.myTrackedItem;
		if trackedItem &lt;&gt; null then
			instruction := trackedItem.getInstructions();
		endif;
		if instruction &lt;&gt; null then	 
			 return instruction;
		endif;		
	endforeach;
	return null;
end;
</source>
        <ReturnType type="CM_InstructionsIssued"/>
    </JadeMethod>
    <JadeMethod name="getFirstInstFromWODtl" id="a4d16c44-1950-42aa-82b2-2c96b82846d3">
        <source>getFirstInstFromWODtl(wod : CM_WorkOrderDtl io) : CM_InstructionsIssued;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Apr 2025	navbs1	Bug MTN-34396: EUP | Additional Operational Instructions - more issues (part 2)

*/

vars
	workorder : CM_WorkOrder;
	instruction : CM_InstructionsIssued;
begin
    wod := self.getMyWorkOrderDtl();				//08.04.2025 navbs1 #34396
	
	if wod &lt;&gt; null then
		workorder := wod.myParent;
	endif;
	
	if workorder &lt;&gt; null then
		instruction := workorder.getInstructions();
		if instruction &lt;&gt; null then
			 return instruction;
		endif;
	endif;
		
	
	if wod &lt;&gt; null then
		instruction := wod.getInstructions();
		if instruction &lt;&gt; null then
			  return instruction;
		endif;
	endif;
	
	return null;
end;
</source>
        <Parameter name="wod" type="CM_WorkOrderDtl" usage="io"/>
        <ReturnType type="CM_InstructionsIssued"/>
    </JadeMethod>
