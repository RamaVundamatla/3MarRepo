    <JadeMethod name="hasMinChargeCollected" id="02e1918b-3367-408a-a291-a67075904174">
        <source>hasMinChargeCollected(_origInvLine : CM_InvoiceLine):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 Jan 2020 cnwma1	Bug 48298: ADP - FW: Ticket 48149 - Minimum Charge Line remove in UAT - ##336278##

*/

vars
	ti 		: CM_TrackedItem;
	cashPay : CM_CashPayment;
begin
	
	ti := _origInvLine.trackedItem;
	
	if ti = null then
		return false;
	endif;
	
	if ti.allCashPayments.isEmpty then
		return false;
	endif;
	
	foreach cashPay in ti.allCashPayments discreteLock do 
		if cashPay.isTaxPayment then 
			continue;
		endif;
		
		if not cashPay.isMinimumCharge then
			continue;
		endif;
		
		if cashPay.myInvoiceLine &lt;&gt; null then
			if cashPay.myInvoiceLine.invoiceLineDesc = self.minimumChargeInvoiceLineType and 
			   cashPay.myTrackedItem = _origInvLine.trackedItem then
				return true;
			endif;
		
		endif;
	endforeach;
	return false;
	
epilog

end;</source>
        <Parameter name="_origInvLine" type="CM_InvoiceLine"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasMinimumChargeGroup" id="edeb9039-8240-4fd6-8d53-c2b243a41fd2">
        <source>hasMinimumChargeGroup() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2018	jlgns1	Initial creation

*/

vars

begin
	if self.group &lt;&gt; null and self.group.myMinimumChargeInvoiceLineType &lt;&gt; null then
		return  true;
	else
		return false;
	endif;
		
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="healthCheckIsValid" id="079f3fde-fca0-4d1e-97ae-2f4be9f52269">
        <source>healthCheckIsValid(_agent : CMIF_InvoiceHealthAgent) : Boolean;
/*
Purpose:			
Date		Who		Reason
13 September 2016	cnwab1	Initial creation
*/

vars
	message : String;
	resultType : Integer;
	detail : CMIF_InvoiceHealthAgentDetail;
	term : CM_Terminal;
	bu : CM_Bank;
begin

	if self.isVoid then
		return true;
	endif;
	
	bu := self.getBank();
	if bu = null then
		return true;
	endif;
	if not _agent.allBusinessUnits.includes(bu) then
		return true;
	endif;
	
//	term := self.getMyTerminal();
//	if term = null then
//		return true;
//	endif;
//	if not _agent.allTerminals.includes(term) then
//		return true;
//	endif;

	// ### Business Unit
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_Bank)
	and not self.healthCheckObject(self.bank, resultType) then
		create detail transient;
		detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_Bank, self.narration, CMIF_InvoiceHealthAgent.ItemType_InvoiceLineType, self.getMyTerminal(), resultType, self);
		return false;
	endif;
	// ### Calculation Type
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_CalcType)
	and not self.healthCheckObject(self.myCalculationType, resultType) then
		create detail transient;
		detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_CalcType, self.narration, CMIF_InvoiceHealthAgent.ItemType_InvoiceLineType, self.getMyTerminal(), resultType, self);
		return false;
	endif;
	// ### Invoice Type
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_InvoiceType)
	and not self.healthCheckObject(self.invoiceType, resultType) then
		create detail transient;
		detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_InvoiceType, self.narration, CMIF_InvoiceHealthAgent.ItemType_InvoiceLineType, self.getMyTerminal(), resultType, self);
		return false;
	endif;
	// ### Min Charge Line
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_MinCharge)
	and self.healthCheckObject(self.minimumChargeInvoiceLineType, resultType) and resultType = CMIF_InvoiceHealthAgent.ResultType_Valid then
		create detail transient;
		detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_MinCharge, self.narration, CMIF_InvoiceHealthAgent.ItemType_InvoiceLineType, self.getMyTerminal(), resultType, self);
		return false;
	endif;
	// ### Services
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_Service)
	and not self.healthCheckCollection(self.services, resultType) then
		create detail transient;
		detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_Service, self.narration, CMIF_InvoiceHealthAgent.ItemType_InvoiceLineType, self.getMyTerminal(), resultType, self);
		return false;
	endif;
	return true;
	
epilog
end;</source>
        <Parameter name="_agent" type="CMIF_InvoiceHealthAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isBerthageCalcType" id="56a1441b-d78e-49c0-b023-c2878d0e6c2d">
        <source>isBerthageCalcType() : Boolean;
/*

Purpose:		TFS 43694	

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2019	jlgab1	Initial creation

*/

vars
	calcType : CM_CalculationType;
begin
	calcType := self.myCalculationType;
	
	if calcType = null then
		return false;
	endif;
			
	
	if calcType.calculationType = INV_CALC_TYPE_TIMEBLCK_HRS 
	or calcType.calculationType = INV_CALC_TYPE_TIMEBLCK_HRS_ONE 
	or calcType.calculationType = INV_CALC_TYPE_TIMEBLCK_HRS_UNT then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
