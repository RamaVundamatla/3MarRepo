    <JadeMethod name="setProxy" id="9fc2ddeb-8955-496c-99e1-17dfb3a21fe2">
        <updating/>
        <source>setProxy(pCode:String; pDescription:String; pIsNotAvailableForEntry:Boolean; pTerminalObj:CM_Terminal) updating;
// --------------------------------------------------------------------------------
// Created:		10 March 2005 by cnwdad1:2
//
// Purpose:		Sets the receiver's proxy property values.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.setSuperClassDetailsForProxy(pCode, pDescription, pIsNotAvailableForEntry, null);
	self.myTerminal	:=	pTerminalObj;
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pIsNotAvailableForEntry" type="Boolean"/>
        <Parameter name="pTerminalObj" type="CM_Terminal"/>
    </JadeMethod>
</Class>
