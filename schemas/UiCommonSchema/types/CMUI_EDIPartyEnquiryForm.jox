    <JadeMethod name="addToolbarControls" id="8bc119dd-2d49-4f36-a4bd-1ab6cc8582cb">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*
Date		Who		Reason
17 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	toolbar			: CMUI_Toolbar;
begin	
	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExportCSVQE, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	
	inheritMethod();

	if app.getMyUser.canDo (self.myTerminal, PmAdmEDIPartyMaint) then
		toolbar.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);	
	endif;
	
	// if they don't have update access they can view the delay
	toolbar.addButton(self.btnEditItem, CMUI_Toolbar.Control_Alignment_Left);	
	
	if app.getMyUser.canDo (self.myTerminal, PmAdmEDIPartyMaint) then	
		toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);	
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
