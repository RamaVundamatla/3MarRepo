    <DbClassMap file="jsscore_transient"/>
    <PrimAttribute name="isCaseSensitive" id="72a3650c-ba2f-44a1-ac08-adf63a20954b">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="isIncludeFolders" id="fab1db0e-b9e0-4d07-bfd8-50db9db7d490">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="isSearchSubfolders" id="2ab6888d-140d-427d-a8fb-bcf3760eba3c">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="isWildcard" id="58d222eb-6718-4f20-bb8d-0a6dc23b9e12">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myWildcardSearch" id="327fca40-f2f4-465c-bd90-1214ca2fd9b7">
        <embedded/>
        <type name="JSSWildcardSearch"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <PrimAttribute name="searchString" id="a10698cc-7f35-4d75-9680-1c466d9e8468">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="20a529f9-1cf0-4910-8c47-3d390385d236">
        <updating/>
        <source>create() updating;
// -----------------------------------------------------------------------------
// Created:		22 January 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if self.isTransient() then
		create self.myWildcardSearch transient;
	else
		create self.myWildcardSearch;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="4671e326-9ecb-4009-b9c0-0ca3c43b1838">
        <updating/>
        <source>delete() updating;
// -----------------------------------------------------------------------------
// Created:		22 January 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	delete self.myWildcardSearch;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSearch" id="17985add-69b7-4b22-af86-ea72d7a4ff4d">
        <updating/>
        <source>doSearch(pAllNodes:FileNodeArray io):Boolean updating;
// -----------------------------------------------------------------------------
// Created:		22 January 2002 by cnwdad1
//
// Purpose:		Initiates the directory (FileFolder) search.
//
// Parameters:	pAllNodes - The FileNodeArray to contain the search results.
//
// Returns:		True if any FileNodes were found, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	fileNodeObj	: FileNode;
	
begin
	pAllNodes.purge();
	
	if self.isWildcard then
		self.myWildcardSearch.parseWildcards(self.searchString, self.isCaseSensitive);
		
		self.jssFindWildcardName(	self.myWildcardSearch,
									self.isSearchSubfolders,
									self.isIncludeFolders,
									pAllNodes);
	else
		self.jssFindExactName(		self.searchString,
									self.isSearchSubfolders,
									self.isIncludeFolders,
									self.isCaseSensitive,
									pAllNodes);
	endif;
epilog
	return pAllNodes.size() &gt; 0;
end;</source>
        <Parameter name="pAllNodes" type="FileNodeArray" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssFindExactName" id="18054ac6-02e4-46a3-9c45-fa4b171164a0">
        <updating/>
        <source>jssFindExactName(	pNodeName:String;
					pIsSearchSubfolders:Boolean;
					pIsIncludeFolders:Boolean;
					pIsCaseSensitive:Boolean;
					pAllNodes:FileNodeArray io) updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 January 2002 by cnwdad1
//
// Purpose:		Searches the receiver for a file node within its path.
//
// Parameters:	pNodeName - The name of the node to search for.
//				pIsSearchSubfolders - If true, subdirectories will also be scanned.
//				pIsIncludeFolders - If true, directory nodes will be included in the search results.
//				pIsCaseSensitive - Determines whether the name matching is case-sensitive.
//				pAllNodes (io) - The FileNodeArray of found nodes.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fileNodeObj		: FileNode;
	allFiles		: FileNodeArray;
	findName		: String;
	fileNodeName	: String;
	
begin
	findName	:=	pNodeName;
	allFiles	:=	self.files();
	
	foreach fileNodeObj in allFiles do
		if pIsCaseSensitive then
			fileNodeName	:=	fileNodeObj.name;
		else
			fileNodeName	:=	fileNodeObj.name.toUpper();
		endif;
		
		if fileNodeName = findName then
			if fileNodeObj.jssIsFile()
			or pIsIncludeFolders
			then
				pAllNodes.add(fileNodeObj);
			endif;
		endif;
			
		if fileNodeObj.jssIsFolder() then
			if pIsSearchSubfolders then
				fileNodeObj.jssFindExactName(	pNodeName,
												pIsSearchSubfolders,
												pIsIncludeFolders,
												pIsCaseSensitive,
												pAllNodes);
			endif;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pNodeName" type="String"/>
        <Parameter name="pIsSearchSubfolders" type="Boolean"/>
        <Parameter name="pIsIncludeFolders" type="Boolean"/>
        <Parameter name="pIsCaseSensitive" type="Boolean"/>
        <Parameter name="pAllNodes" type="FileNodeArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="jssFindWildcardName" id="7a0a4bdf-fa41-4291-a16f-338defdf38a4">
        <updating/>
        <source>jssFindWildcardName(	pWildcardSearchObj:JSSWildcardSearch;
						pIsSearchSubfolders:Boolean;
						pIsIncludeFolders:Boolean;
						pAllNodes:FileNodeArray io) updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 January 2002 by cnwdad1
//
// Purpose:		Searches the receiver for a file node within its path.
//
// Parameters:	pWildcardSearchObj - The wildcard search object.
//				pIsSearchSubfolders - If true, subdirectories will also be scanned.
//				pIsIncludeFolders - If true, directory nodes will be included in the search results.
//				pAllNodes (io) - The FileNodeArray of found nodes.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	fileNodeObj		: FileNode;
	allFiles		: FileNodeArray;
	fileNodeName	: String;
	
begin
	allFiles	:=	self.files();
	
	foreach fileNodeObj in allFiles do
		if pWildcardSearchObj.isCaseSensitive then
			fileNodeName	:=	fileNodeObj.name;
		else
			fileNodeName	:=	fileNodeObj.name.toUpper();
		endif;
		
		if pWildcardSearchObj.doSearch(fileNodeName) then
			if fileNodeObj.jssIsFile()
			or pIsIncludeFolders
			then
				pAllNodes.add(fileNodeObj);
			endif;
		endif;
			
		if fileNodeObj.jssIsFolder() then
			if pIsSearchSubfolders then
				fileNodeObj.jssFindWildcardName(pWildcardSearchObj,
												pIsSearchSubfolders,
												pIsIncludeFolders,
												pAllNodes);
			endif;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pWildcardSearchObj" type="JSSWildcardSearch"/>
        <Parameter name="pIsSearchSubfolders" type="Boolean"/>
        <Parameter name="pIsIncludeFolders" type="Boolean"/>
        <Parameter name="pAllNodes" type="FileNodeArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setSearchCriteria" id="bb3c8e82-e01b-48a8-8e51-045a706a7f2d">
        <updating/>
        <source>setSearchCriteria(	pSearchString:String;
					pIsWildcard:Boolean;
					pIsCaseSensitive:Boolean;
					pIsSearchSubfolders:Boolean;
					pIsIncludeFolders:Boolean) updating;
// -----------------------------------------------------------------------------
// Created:		22 January 2002 by cnwdad1
//
// Purpose:		Updates the criteria for the search.
//
// Parameters:	pSearchString - Either a literal or wildcard string to search for.
//				pIsWildcard - if true, the search string will be treated as wildcard
//					tokens, othrwise it'll be treated as a literal value.
//				pIsCaseSensitive - Determines whether name matching is case-sensitive.
//				pIsSearchSubfolders - If true, subdirectories will also be scanned.
//				pIsIncludeFolders - If true, directories will be included in the
//					search results array (FileNodeArray).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.isWildcard			:=	pIsWildcard;
	self.isCaseSensitive	:=	pIsCaseSensitive;
	self.isSearchSubfolders	:=	pIsSearchSubfolders;
	self.isIncludeFolders	:=	pIsIncludeFolders;
	
	if self.isCaseSensitive then
		self.searchString		:=	pSearchString;
	else
		self.searchString		:=	pSearchString.toUpper();
	endif;
end;</source>
        <Parameter name="pSearchString" type="String"/>
        <Parameter name="pIsWildcard" type="Boolean"/>
        <Parameter name="pIsCaseSensitive" type="Boolean"/>
        <Parameter name="pIsSearchSubfolders" type="Boolean"/>
        <Parameter name="pIsIncludeFolders" type="Boolean"/>
    </JadeMethod>
</Class>
