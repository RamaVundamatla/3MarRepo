    <JadeMethod name="isPallet" id="aafbde58-e2c5-4b22-9a02-321bfc91f02f">
        <source>isPallet(): Boolean;
// ---------------------------------------------------------------------------
// Created:		27 July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
// 28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
// ---------------------------------------------------------------------------
vars
	cargoType : CM_CargoType;
begin
	cargoType := self.myCargoType;		//28.05.2024 navma1 #64224
	
	if cargoType &lt;&gt; null and cargoType.myDefaultHandlingType &lt;&gt; null then
		return cargoType.myDefaultHandlingType.id = 1;
	endif;

	return false;
end;</source>
        <ReturnType type="Boolean"/>
