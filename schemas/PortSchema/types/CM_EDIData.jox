    <JadeMethod name="validationExceptionHandler" id="0d133c76-789a-430b-9834-eaa13dc66aaf">
        <source>validationExceptionHandler(_exObj: Exception; _passport : CM_Passport input): Integer protected;
// --------------------------------------------------------------------------------
// Method:		agtExceptionHandler
//
// Purpose:		Base exception handler for TransactionAgents.
//              It simply aborts the current transaction before inheriting the
//              behaviour of its superclass method.
//
// Parameters:	The exception object
// --------------------------------------------------------------------------------
vars

begin

	if _exObj.isKindOf(CM_Exception) and _exObj.CM_Exception.isWarning then
		// code for CCMS-1660
		//if _passport.allWarningsToIgnore.includes(_exObj.errorCode) then
		//	return Ex_Continue;
		//endif;
		app.addWarningFullPassport(_exObj.errorCode, _exObj.extendedErrorText, _exObj.CM_Exception.userString, _exObj.CM_Exception.myUserObject, _passport);
		return Ex_Continue;
	endif;
	if _exObj.isKindOf(CM_Exception) then
		// Only add the error to the passport if we are continuing, otherwise the Transaction Agent handler will do this for us on Pass_Back
		//app.addErrorFullPassport(_exObj.errorCode, _exObj.extendedErrorText, _exObj.CM_Exception.userString, _exObj.CM_Exception.myUserObject, _passport);	// TFS 49971 jlgmd1
		if _exObj.continuable then
			app.addErrorFullPassport(_exObj.errorCode, _exObj.extendedErrorText, _exObj.CM_Exception.userString, _exObj.CM_Exception.myUserObject, _passport);
			return Ex_Continue;
		endif;
	endif;
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyAll" id="a34c9ba2-e338-4654-ad4a-58c944e675bf">
        <updating/>
        <source>verifyAll() updating;
// 26/06/2012	cnwcs5	par 29747:2 - check status is changing before setting it
//09 Mar 2015	cnwrs1	Par 35827 - for error 88612 set the status to skip processing
//07 Apr 2015	cnwrs1	Par 35994 - put verifying status back in
// 27 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 4
vars
	numInError	: Integer;
	tmpStr      : String;
	newStatus 	: Integer;
begin
	app.myTrxUA.trxSetEDIDataStatus(self, CM_EDIFile.EDI_STATUS_VERIFYING); //ccms1845

	app.myPassport.clearErrorsWarnings();
	numInError := self.verifyEDIData();
	
	if numInError = 0 then
		tmpStr := self.class.name &amp; " " &amp; method.qualifiedName;
		
//		self.cnStartTransaction(tmpStr[1:50]);
		
		numInError := self.verifyEDIDataTIs(app.myPassport);
	endif;
	
	newStatus := self.getStatusAfterVerifyOrDBLoad (true, app.myPassport);	// par 29747:2 June 2012
	
	if self.status &lt;&gt; newStatus then										// par 29747:2 June 2012
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, newStatus);		// par 27392 cnwrs1 14 Apr 2011
	endif;
epilog
	if tmpStr &lt;&gt; null then
//		self.cnEndTransaction();
	endif;
end;</source>
    </JadeMethod>
