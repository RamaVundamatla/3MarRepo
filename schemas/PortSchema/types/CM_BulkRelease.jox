    <JadeMethod name="getVBSDetails" id="24a5a4b3-2437-4d33-beb3-cf8926fe0468">
        <source>getVBSDetails(_vbsId : String output; _vbsStartTime : TimeStamp output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Sep 2025 navlc30 JIRA 35531 - Address the Error to allow Processing multiple Release Requests on a single VBS Slot at the Gate

*/

vars
	vbts	: CM_VehicleBookingTimeSlot;
begin
	if self.allVBTimeslotsById.size = 1 then
		vbts := self.allVBTimeslotsById.first;
		_vbsId := vbts.id;
		_vbsStartTime := vbts.bookingTSstart;
	endif;
epilog

end;</source>
