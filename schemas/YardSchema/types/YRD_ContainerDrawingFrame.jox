	/*
	if self.myDockBar.isForRows then
		return self.myDockBar.myDrawingController.YRD_CargoRowDrawingController.myYardGridEnqForm;
	elseif self.myDockBar.isForTrailers then
		return self.myDockBar.myTrailerDrawingController.myTrailerForm;
	elseif self.myDockBar.isForOverview  then
		return self.myDockBar.myDrawingController.YRD_GridOViewDrawingController.myGridOverviewForm;
	elseif  self.myDockBar.isForEndView then
		return self.myDockBar.myDrawingController.YRD_CargoBayDrawingController.myGridOverviewForm;
	else
		return self.myDockBar.myDrawingController.myYardGridAreaForm;
	endif;
	*/
end;</source>
