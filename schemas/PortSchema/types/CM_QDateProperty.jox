    <JadeMethod name="setTextValues" id="493f3a9f-8890-43bc-83ce-c368044e1292">
        <source>setTextValues(_txt: TextBox input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 Oct 2008	cnwkpd1	PAR #18078 - Correct Selector Query reports using Date Day operators

*/

vars

begin
	if _txt = null or (self.getControlTypeForOperator(_operator) &lt;&gt; QueryControl_TextBox) then
		return;
	endif;
	
	_txt.text := _operator.getSearchValue.String;

	
epilog

end;</source>
        <Parameter name="_txt" type="TextBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="6eb463d7-8a9e-466d-8ab4-a87e2f2258b0">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     July 2008		cnwvu1	
// 17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
// ---------------------------------------------------------------------------
vars
	dte : Date;
	str : String;
begin
	
	if _value.isKindOf(Date) then	//  cnwrd1 14.7.2008 par #17511 	
		return _value.Date.asStringJMT() ; //  cnwrd1 14.7.2008 par #17511     	
	elseif _value.isKindOf(DateArray) then // ### TFS CR 55626 TASK 55688 20FEB2023 NAVAB1
		foreach dte in _value.DateArray do // ### TFS CR 55626 TASK 55688 20FEB2023 NAVAB1
			if str = null then // ### TFS CR 55626  // ### TFS CR 55626 TASK 55688 20FEB2023 NAVAB1TASK 55688 20FEB2023 NAVAB1
				str := dte.asStringJMT();
			else // ### TFS CR 55626 TASK 55688 20FEB2023 NAVAB1
				str := str &amp; ", " &amp; dte.asStringJMT(); // ### TFS CR 55626 TASK 55688 20FEB2023 NAVAB1
			endif; // ### TFS CR 55626 TASK 55688 20FEB2023 NAVAB1
		endforeach; // ### TFS CR 55626 TASK 55688 20FEB2023 NAVAB1
		
		return str;
	else  // ### TFS CR 55626 TASK 55688 20FEB2023 NAVAB1 : this is never going to work &gt;&gt;&gt;
		return _value.Date.asStringJMT()  &amp;' '&amp; _value.Time.asStringJMT();	// Par 17266, removed seconds for query's result. 03 July 2008, cnwvu1 
	endif;
                                                                                                                                              


end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="acd9bf7c-62da-4f49-8ef4-1cc205be1c6e">
        <source>translateToSearchValueForWeb(_value: Any; _sending: Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/01/2020	jlgdap1		Initial creation TFS 47456 SNO Web portal report issue 2 - ensure dates go out to web portal as dd/mm/yyyy
//
vars

begin
	if _sending then
		if _value.Date.isValid then
			return _value.Date.format('dd/MM/yyy');
		endif;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
