<Class name="CMIF_TAMTSummary" id="dbf7cc22-ccb3-481e-8825-26d2811183d9">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="balance" id="25c88133-dfbf-4a15-bd5e-59bd6ea61c37">
        <embedded/>
        <virtual/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="numInArea" id="5d676b8e-6f83-490c-96b3-2f5b3b89cd01">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="numRequired" id="48c86f7a-b314-4f68-968c-ed21c270500a">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="packAreaId" id="776ba796-d9b8-404c-8cc4-c92db5156afc">
