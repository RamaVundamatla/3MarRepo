    <DbClassMap file="unitTest"/>
    <JadeMethod name="tCheckTrailerTotWeight" id="1489da7b-626f-4488-a7eb-abc4f42766fe">
        <source>tCheckTrailerTotWeight();
/*

Purpose:			This unit test make sure the Total Weight of a trailer is same as when they've entered during gate in
					The total weight shouldn't be derived from the cargo on board + tareweight
					Pre condition - Trailer type has allowUpdateTotalWeight = true;

Parameters:			

Return Value:		

Date		Who		Reason
//21/10/2025	navkc1 JIRA 36056 CUX | Total Weight Specification for Trailers - Unit Tests

*/

constants
	UTTRAILCARGO	= 'UTTRWGT';
	UTCONTCARGO		= 'UTTRWGT-1';
	UTCARGOTYPE 	= 'UTWGTTRAIL';
	UTTRAILTYPE 	= "UTTOTWGT";
	UTTRUCKID 		= 'UTTOTWGT';
	UTTAREA			= 'UTTATOT';
vars
	cTypeTrailer 	: CM_CargoType;
	trailerType		: CM_TILCType;
	term			: CM_Terminal;
	root			: CM_Root;
	operator		: CM_Operator;
	ta				: CM_TerminalArea;
	gcArea			: CM_IrregularBlockArea;
	vvr				: CM_VehicleVisitRecord;
	cont			: CM_Container;
	trail			: CM_TILC;
	actualTotWeight : Decimal[14,4];
begin
	
	term := self.getMyTerminal();
	root := app.getMyRoot();
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// Get Terminal Area
		gcArea := self.addGeneralCargoArea(UTTAREA, null, 5, 5, 10, null, null);
	
	// Get Cargo Type Trailer 
		self.opts.purge();
		self.opts.addAssoc('TrackAs', ProductType_Trailer);
		cTypeTrailer := self.addCargoType(UTCARGOTYPE, true);
	
	// Get Trailer Type
		self.opts.purge();
		self.opts.addAssoc('allowUpdateTotalWeight', true);
		trailerType := self.addTrailerType(UTTRAILTYPE, UTTRAILTYPE, cTypeTrailer, null, 1, null, 50000, 1000, null, null, null);
	
	// Delete Vehicle
		self.deleteVehicle(UTTRUCKID);
	
	// Delete existing cargo
		cont := self.getTrackedItem(UTCONTCARGO).CM_Container;
		self.deleteTrackedItem(cont, true);
		
		trail := self.getTrackedItem(UTTRAILCARGO).CM_TILC;
		self.deleteTrackedItem(trail, true);
	
	// Gate in Trailer
		self.opts.purge();
		self.opts.addAssoc('totalWeight', 10000); // Total weight of the trailer
		vvr := self.gateInTrailerAndContainer(UTTRUCKID, UTTRAILCARGO, UTCONTCARGO, UTTRAILTYPE, "2200", operator.code, "MT", self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString));
		
	// Work vehicle
		self.workVehicle(vvr);
	
	// Get Container and Trailer
		cont := self.getTrackedItem(UTCONTCARGO).CM_Container;
		trail := self.getTrackedItem(UTTRAILCARGO).CM_TILC;
		
		self.assertNotNullMsg(cont, "Failed to get the container");
		self.assertNotNullMsg(trail, "Failed to get the trailer");
		
		self.moveCargo(cont, null, trail.allLCs.first, app.myPassport);
	
	/*====================================
	Test - Total Weight of the trailer must be the same as what we've entered, i.e. 10000
	====================================*/
		actualTotWeight := trail.totalWeight;
		self.assertEqualMsg(actualTotWeight.String, "10000.0000", "Total weight is not as expected."); // Total weight of the trailer
	
	// Update Trailer Type allowUpdateTotalWeight to false
		self.opts.purge();
		self.opts.addAssoc("allowUpdateTotalWeight", false);
		self.updateTrailerType(trailerType);
	
	/*====================================
	Test - Total Weight of the trailer must be weight of cargo onboard + tareweight, as the option has changed
	====================================*/
		actualTotWeight := trail.totalWeight;
		self.assertEqualMsg(actualTotWeight.String, "3000.0000", "Total weight is not as expected."); // Total weight of the trailer
	
epilog
	self.deleteTrailerType(trailerType);
	self.deleteCargoType(UTCARGOTYPE);
	self.deleteTerminalArea(UTTAREA);
	
	self.deleteTrackedItem(cont, true);
	self.deleteTrackedItem(trail, true);
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckTrailerTotWeight2" id="7f90d8d9-6563-448e-ae38-4ba27064c6c1">
        <source>tCheckTrailerTotWeight2();
/*

Purpose:			This unit test make sure the Total Weight of a trailer is derived from the cargo on board + tareweight
					Pre condition - Trailer type has allowUpdateTotalWeight = false;

Parameters:			

Return Value:		

Date		Who		Reason
//21/10/2025	navkc1 JIRA 36056 CUX | Total Weight Specification for Trailers - Unit Tests

*/

constants
	UTTRAILCARGO	= 'UTTRWGT';
	UTCONTCARGO		= 'UTTRWGT-1';
	UTCARGOTYPE 	= 'UTWGTTRAIL';
	UTTRAILTYPE 	= "UTTOTWGT";
	UTTRUCKID 		= 'UTTOTWGT';
	UTTAREA			= 'UTTATOT';
vars
	cTypeTrailer 	: CM_CargoType;
	trailerType		: CM_TILCType;
	term			: CM_Terminal;
	root			: CM_Root;
	operator		: CM_Operator;
	ta				: CM_TerminalArea;
	gcArea			: CM_IrregularBlockArea;
	vvr				: CM_VehicleVisitRecord;
	cont			: CM_Container;
	trail			: CM_TILC;
	actualTotWeight : Decimal[14,4];
begin
	
	term := self.getMyTerminal();
	root := app.getMyRoot();
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// Get Terminal Area
		gcArea := self.addGeneralCargoArea(UTTAREA, null, 5, 5, 10, null, null);
	
	// Get Cargo Type Trailer 
		self.opts.purge();
		self.opts.addAssoc('TrackAs', ProductType_Trailer);
		cTypeTrailer := self.addCargoType(UTCARGOTYPE, true);
	
	// Get Trailer Type
		self.opts.purge();
		self.opts.addAssoc('allowUpdateTotalWeight', false);
		trailerType := self.addTrailerType(UTTRAILTYPE, UTTRAILTYPE, cTypeTrailer, null, 1, null, 50000, 1000, null, null, null);
	
	/*====================================
	Setup scenario for gating trailer when the trailer type allowUpdateTotalWeight is false
	====================================*/
	
	// Delete Vehicle
		self.deleteVehicle(UTTRUCKID);
	
	// Delete existing cargo
		cont := self.getTrackedItem(UTCONTCARGO).CM_Container;
		self.deleteTrackedItem(cont, true);
		trail := self.getTrackedItem(UTTRAILCARGO).CM_TILC;
		self.deleteTrackedItem(trail, true);
	
	// Gate in Trailer
		self.opts.purge();
		self.opts.addAssoc('totalWeight', 10000); // Total weight of the trailer
		vvr := self.gateInTrailerAndContainer(UTTRUCKID, UTTRAILCARGO, UTCONTCARGO, UTTRAILTYPE, "2200", operator.code, "MT", self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString));
		
	// Work vehicle
		self.workVehicle(vvr);
	
	// Get Container and Trailer
		cont := self.getTrackedItem(UTCONTCARGO).CM_Container;
		trail := self.getTrackedItem(UTTRAILCARGO).CM_TILC;
		
		self.assertNotNullMsg(cont, "Failed to get the container 2");
		self.assertNotNullMsg(trail, "Failed to get the trailer 2");
		
		self.moveCargo(cont, null, trail.allLCs.first, app.myPassport);
	
	/*====================================
	Test - Total Weight of the trailer must be derived from Cargo On board + tare weight = 2000 + 1000 = 3000
	====================================*/
		actualTotWeight := trail.totalWeight;
		self.assertEqualMsg(actualTotWeight.String, "3000.0000", "Total weight is not as expected."); // Total weight of the trailer

epilog
	self.deleteTrailerType(trailerType);
	self.deleteCargoType(UTCARGOTYPE);
	self.deleteTerminalArea(UTTAREA);
	
	self.deleteTrackedItem(cont, true);
	self.deleteTrackedItem(trail, true);
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckTrailerTotWeight3" id="5cc65af7-f260-46e9-b54a-f92a75827e92">
        <source>tCheckTrailerTotWeight3();
/*

Purpose:			This unit test check a warning message is displayed when updating a trailer's total weight to 0
					When the trailer type allowUpdateTotalWeigth is true

Parameters:			

Return Value:		

Date		Who		Reason
21/10/2025	navkc1 JIRA 36056 CUX | Total Weight Specification for Trailers - Unit Tests

*/

constants
	UTTRAILCARGO	= 'UTTRWGT';
	UTCONTCARGO		= 'UTTRWGT-1';
	UTCARGOTYPE 	= 'UTWGTTRAIL';
	UTTRAILTYPE 	= "UTTOTWGT";
	UTTRUCKID 		= 'UTTOTWGT';
	UTTAREA			= 'UTTATOT';
vars
	cTypeTrailer 	: CM_CargoType;
	trailerType		: CM_TILCType;
	term			: CM_Terminal;
	root			: CM_Root;
	operator		: CM_Operator;
	ta				: CM_TerminalArea;
	gcArea			: CM_IrregularBlockArea;
	vvr				: CM_VehicleVisitRecord;
	cont			: CM_Container;
	trail			: CM_TILC;
	actualTotWeight : Decimal[14,4];
begin
	
	term := self.getMyTerminal();
	root := app.getMyRoot();
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// Get Terminal Area
		gcArea := self.addGeneralCargoArea(UTTAREA, null, 5, 5, 10, null, null);
	
	// Get Cargo Type Trailer 
		self.opts.purge();
		self.opts.addAssoc('TrackAs', ProductType_Trailer);
		cTypeTrailer := self.addCargoType(UTCARGOTYPE, true);
	
	// Get Trailer Type
		self.opts.purge();
		self.opts.addAssoc('allowUpdateTotalWeight', true);
		trailerType := self.addTrailerType(UTTRAILTYPE, UTTRAILTYPE, cTypeTrailer, null, 1, null, 50000, 1000, null, null, null);
	
	// Delete Vehicle
		self.deleteVehicle(UTTRUCKID);
	
	// Delete existing cargo
		cont := self.getTrackedItem(UTCONTCARGO).CM_Container;
		self.deleteTrackedItem(cont, true);
		
		trail := self.getTrackedItem(UTTRAILCARGO).CM_TILC;
		self.deleteTrackedItem(trail, true);
	
	// Gate in Trailer
		self.opts.purge();
		self.opts.addAssoc('totalWeight', 10000); // Total weight of the trailer
		vvr := self.gateInTrailerAndContainer(UTTRUCKID, UTTRAILCARGO, UTCONTCARGO, UTTRAILTYPE, "2200", operator.code, "MT", self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString));
		
	// Work vehicle
		self.workVehicle(vvr);
	
	// Get Container and Trailer
		cont := self.getTrackedItem(UTCONTCARGO).CM_Container;
		trail := self.getTrackedItem(UTTRAILCARGO).CM_TILC;
		
		self.assertNotNullMsg(cont, "Failed to get the container");
		self.assertNotNullMsg(trail, "Failed to get the trailer");
		
		self.moveCargo(cont, null, trail.allLCs.first, app.myPassport);
	
	/*====================================
	Test - Total Weight of the trailer must be the same as what we've entered, i.e. 10000
	====================================*/
		actualTotWeight := trail.totalWeight;
		self.assertEqualMsg(actualTotWeight.String, "10000.0000", "Total weight is not as expected."); // Total weight of the trailer
	
	/*====================================
	Test - Update trailer total weight to be 0, expects a warning message
	====================================*/
	
		self.opts.purge();
		self.opts.addAssoc("TotalWeight", "0");
		self.opts.addAssoc("ExpectErrorWarning", true);
		self.expectedTrxErrors.clear();
		self.expectedTrxErrors.add(TrailerTotalWeightZero);
		self.updateTrackedItem(trail);
		
		self.assertTrxWarningMsg(TrailerTotalWeightZero, "Warning message not shown");
epilog
	self.deleteTrailerType(trailerType);
	self.deleteCargoType(UTCARGOTYPE);
	self.deleteTerminalArea(UTTAREA);
	
	self.deleteTrackedItem(cont, true);
	self.deleteTrackedItem(trail, true);
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckTrailerTotWeight4" id="73c34a14-3ae5-4cb7-a5bc-12447a2cf494">
        <source>tCheckTrailerTotWeight4();
/*

Purpose:			This unit test check an error message is displayed when updating a trailer's total weight to be less than tare weight
					When the trailer type allowUpdateTotalWeigth is true

Parameters:			

Return Value:		

Date		Who		Reason
21/10/2025	navkc1 JIRA 36056 CUX | Total Weight Specification for Trailers - Unit Tests

*/

constants
	UTTRAILCARGO	= 'UTTRWGT';
	UTCONTCARGO		= 'UTTRWGT-1';
	UTCARGOTYPE 	= 'UTWGTTRAIL';
	UTTRAILTYPE 	= "UTTOTWGT";
	UTTRUCKID 		= 'UTTOTWGT';
	UTTAREA			= 'UTTATOT';
vars
	cTypeTrailer 	: CM_CargoType;
	trailerType		: CM_TILCType;
	term			: CM_Terminal;
	root			: CM_Root;
	operator		: CM_Operator;
	ta				: CM_TerminalArea;
	gcArea			: CM_IrregularBlockArea;
	vvr				: CM_VehicleVisitRecord;
	cont			: CM_Container;
	trail			: CM_TILC;
	actualTotWeight : Decimal[14,4];
begin
	
	term := self.getMyTerminal();
	root := app.getMyRoot();
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// Get Terminal Area
		gcArea := self.addGeneralCargoArea(UTTAREA, null, 5, 5, 10, null, null);
	
	// Get Cargo Type Trailer 
		self.opts.purge();
		self.opts.addAssoc('TrackAs', ProductType_Trailer);
		cTypeTrailer := self.addCargoType(UTCARGOTYPE, true);
	
	// Get Trailer Type
		self.opts.purge();
		self.opts.addAssoc('allowUpdateTotalWeight', true);
		trailerType := self.addTrailerType(UTTRAILTYPE, UTTRAILTYPE, cTypeTrailer, null, 1, null, 50000, 1000, null, null, null);
	
	// Delete Vehicle
		self.deleteVehicle(UTTRUCKID);
	
	// Delete existing cargo
		cont := self.getTrackedItem(UTCONTCARGO).CM_Container;
		self.deleteTrackedItem(cont, true);
		
		trail := self.getTrackedItem(UTTRAILCARGO).CM_TILC;
		self.deleteTrackedItem(trail, true);
	
	// Gate in Trailer
		self.opts.purge();
		self.opts.addAssoc('totalWeight', 10000); // Total weight of the trailer
		vvr := self.gateInTrailerAndContainer(UTTRUCKID, UTTRAILCARGO, UTCONTCARGO, UTTRAILTYPE, "2200", operator.code, "MT", self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString));
		
	// Work vehicle
		self.workVehicle(vvr);
	
	// Get Container and Trailer
		cont := self.getTrackedItem(UTCONTCARGO).CM_Container;
		trail := self.getTrackedItem(UTTRAILCARGO).CM_TILC;
		
		self.assertNotNullMsg(cont, "Failed to get the container");
		self.assertNotNullMsg(trail, "Failed to get the trailer");
		
		self.moveCargo(cont, null, trail.allLCs.first, app.myPassport);
	
	/*====================================
	Test - Total Weight of the trailer must be the same as what we've entered, i.e. 10000
	====================================*/
		actualTotWeight := trail.totalWeight;
		self.assertEqualMsg(actualTotWeight.String, "10000.0000", "Total weight is not as expected."); // Total weight of the trailer
	
	/*====================================
	Test - Update trailer total weight to be 10 (less than tare weight of 1000), expects an error message
	====================================*/
	
		self.opts.purge();
		self.opts.addAssoc("TotalWeight", "10.0");
		self.opts.addAssoc("ExpectErrorWarning", true);
		self.expectedTrxErrors.clear();
		self.expectedTrxErrors.add(TrailerTotalWgtLessTypeTareWgt);
		self.updateTrackedItem(trail);
		
		self.assertTrxErrorMsg(TrailerTotalWgtLessTypeTareWgt, "Error message not shown");
epilog
	self.deleteTrailerType(trailerType);
	self.deleteCargoType(UTCARGOTYPE);
	self.deleteTerminalArea(UTTAREA);
	
	self.deleteTrackedItem(cont, true);
	self.deleteTrackedItem(trail, true);
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckTrailerTotWeight5" id="2caced26-5951-47da-8527-7cecdeba6693">
        <source>tCheckTrailerTotWeight5();
/*

Purpose:			This unit test check an a warning message is displayed when the total weight is greater than the max weight defined in trailer type
					When the trailer type allowUpdateTotalWeigth is true

Parameters:			

Return Value:		

Date		Who		Reason
// 17/11/2025	navkc1	MTN JIRA 36651

*/

constants
	UTTRAILCARGO	= 'UTTRWGT';
	UTCONTCARGO		= 'UTTRWGT-1';
	UTCARGOTYPE 	= 'UTWGTTRAIL';
	UTTRAILTYPE 	= "UTTOTWGT";
	UTTRUCKID 		= 'UTTOTWGT';
	UTTAREA			= 'UTTATOT';
vars
	cTypeTrailer 	: CM_CargoType;
	trailerType		: CM_TILCType;
	term			: CM_Terminal;
	root			: CM_Root;
	operator		: CM_Operator;
	ta				: CM_TerminalArea;
	gcArea			: CM_IrregularBlockArea;
	vvr				: CM_VehicleVisitRecord;
	cont			: CM_Container;
	trail			: CM_TILC;
	actualTotWeight : Decimal[14,4];
begin
	
	term := self.getMyTerminal();
	root := app.getMyRoot();
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// Get Terminal Area
		gcArea := self.addGeneralCargoArea(UTTAREA, null, 5, 5, 10, null, null);
	
	// Get Cargo Type Trailer 
		self.opts.purge();
		self.opts.addAssoc('TrackAs', ProductType_Trailer);
		cTypeTrailer := self.addCargoType(UTCARGOTYPE, true);
	
	// Get Trailer Type
		self.opts.purge();
		self.opts.addAssoc('allowUpdateTotalWeight', true);
		trailerType := self.addTrailerType(UTTRAILTYPE, UTTRAILTYPE, cTypeTrailer, null, 1, null, 50000, 1000, null, null, null);
	
	// Delete Vehicle
		self.deleteVehicle(UTTRUCKID);
	
	// Delete existing cargo
		cont := self.getTrackedItem(UTCONTCARGO).CM_Container;
		self.deleteTrackedItem(cont, true);
		
		trail := self.getTrackedItem(UTTRAILCARGO).CM_TILC;
		self.deleteTrackedItem(trail, true);
	
	// Gate in Trailer
		self.opts.purge();
		self.opts.addAssoc('totalWeight', 10000); // Total weight of the trailer
		vvr := self.gateInTrailerAndContainer(UTTRUCKID, UTTRAILCARGO, UTCONTCARGO, UTTRAILTYPE, "2200", operator.code, "MT", self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString));
		
	// Work vehicle
		self.workVehicle(vvr);
	
	// Get Container and Trailer
		cont := self.getTrackedItem(UTCONTCARGO).CM_Container;
		trail := self.getTrackedItem(UTTRAILCARGO).CM_TILC;
		
		self.assertNotNullMsg(cont, "Failed to get the container");
		self.assertNotNullMsg(trail, "Failed to get the trailer");
		
		self.moveCargo(cont, null, trail.allLCs.first, app.myPassport);
	
	/*====================================
	Test - Total Weight of the trailer must be the same as what we've entered, i.e. 10000
	====================================*/
		actualTotWeight := trail.totalWeight;
		self.assertEqualMsg(actualTotWeight.String, "10000.0000", "Total weight is not as expected."); // Total weight of the trailer
	
	/*====================================
	Test - Update trailer total weight to be 10 (less than tare weight of 1000), expects an error message
	====================================*/
	
		self.opts.purge();
		self.opts.addAssoc("TotalWeight", "60000.0");
		self.opts.addAssoc("ExpectErrorWarning", true);
		self.expectedTrxErrors.clear();
		self.expectedTrxErrors.add(TotalWeightExceedTypeMax);
		self.updateTrackedItem(trail);
		
		self.assertTrxWarningMsg(TotalWeightExceedTypeMax, "Warning message not shown");
epilog
	self.deleteTrailerType(trailerType);
	self.deleteCargoType(UTCARGOTYPE);
	self.deleteTerminalArea(UTTAREA);
	
	self.deleteTrackedItem(cont, true);
	self.deleteTrackedItem(trail, true);
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateTrailerType" id="c3abe79c-c337-4850-ae43-e9ab13d83055">
        <source>tCreateTrailerType();
/*

Date		Who		Reason
08/07/2013	cnwer1	Initial creation CCMS DPH 2274
29/04/2014  cnwma1	Add Update Trailer Type   
10/03/2023	jlika1	Add width to Trailer Type
*/
constants
	Cargo_Type = "UTCHAS";
	TrailerType ="UTTT20";
vars
	ct : CM_CargoType;
	tt	: CM_TILCType;
begin
	
	ct	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	if ct &lt;&gt; null then
		self.deleteCargoType(Cargo_Type);
	endif;
	
	self.opts.purge;
	self.opts.addAssoc("TrackAs",ProductType_Trailer);
	ct:=self.addCargoType(Cargo_Type, false);
	
	self.assertNotNull(ct);
	self.assertEqual(ct.productType,ProductType_Trailer);
	self.assertEqual(ct.myClassToCreate, CM_TILC);
	
	tt:=self.addTrailerType(TrailerType,TrailerType,ct,500,1,50,30000,13000,null,null,500);
	self.assertNotNull(tt);
	self.assertEqual(tt.numControllers,1);
	self.assertEqual(tt.width.asStringJMT,"500.0000");	
	
	self.opts.addAssoc("TrailerLenght",650);
	self.updateTrailerType(tt);
	self.assertEqual(tt.length.asStringJMT,"650.0000");	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tGateInOutInspectionAppCheck" id="e3fb7fe8-054e-4319-a0e8-53da7897b6a2">
        <source>tGateInOutInspectionAppCheck();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2022	navsp1	Initial creation TFS - ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
10 March 2023		jlika1	Add width to trailer.
24 May 2023 		navhl20 Defect 58041: MTN - Unable to copy the slots with the status "Booked - Current"
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot

*/


constants
	
	REF 			: String = "28595";//"55580";
	CARRIERCODE 	: String = REF &amp; "CAR";
	SUBCARRIERCODE 	: String = REF &amp; "SUB";
	DRIVERID    	: String = REF &amp; "DRIVER";
	VEHICLEID   	: String = REF &amp; "VEHICLE";
	ID				: String = "IDUT" &amp; REF;
	TRAILERID 		: String = REF &amp; "TRAILER";
	SOURCE_CARGO 	: Integer= 2;
	TrailerType 	: String = REF &amp; "TT20";
	Cargo_Type 		: String = "UTCHAS";
	Trailer 		: String = REF &amp; "UTTRAILER";
	ContainerID		: String = "CNTU" &amp; REF;
vars
	realVbsTimeSlot,
	proxyVbsTimeSlot,vbs	: CM_VehicleBookingTimeSlot;
	vbsSlotType				: CM_VehicleBookingTimeSlotType;
	date					: Date;
	startTime,
	endTime					: TimeStamp;
	vbsTimeSlotItem			: CM_VehicleBookingTimeSlotItem;
	trackedItem				: CM_TrackedItem;
	tiStringArray			: StringArray;
	vehicleBookingTerminal	: CM_VehicleBookingTerminal;
	carrier					: CM_Carrier;
	subCarrier				: CM_Carrier;
	driver					: CM_DriverDetails;
	vehicle					: CM_Vehicle;
	allCarriers 			: CM_CarrierByCodeDict;	
	allVehicleMachines 		: CM_VehicleSet; 
	email					: CM_EmailEntityByTypeNameDict;
	bs1 					: CM_BlockStack;
	vvr,pxyVVR				: CM_VehicleVisitRecord;
	trailer 				: CM_TILC;
	tt						: CM_TILCType;
	ct 						: CM_CargoType;

	direction,		
	quantity, 
	sequence,
	sourceType				: Integer;
	pin						: CM_GateArea;
	dualGate 				: CM_Gate;
	carrierCode 			: String;
	truck 					: CM_Vehicle;
	objectArray				: ObjectArray;
	terminal 				: CM_Terminal;
	vbsProcess				: CM_VBSProcess;
	ti : CM_TrackedItem;
begin	
	terminal := self.getMyTerminal;
	
	self.deleteVbsTimeSlotAdv(ID);
	self.deleteVbsTimeslotType(REF);
	
	
	//Set the vbs process to Slot Type Validation
	beginTransaction;
		terminal.setMyVBSProcess(app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE]);//getMyVBSProcess();
	commitTransaction;
	
	/*Add location*/
	bs1:=self.addBlockStack("BS"&amp;REF,999,null);
	
	/*add cargo type*/
	app.myPassport.ignoreErrors();
	self.opts.purge;
	self.opts.addAssoc("TrackAs",ProductType_Trailer);
	self.opts.addAssoc("AllowDuplicateId", true);
	ct := self.getCargoType(Cargo_Type);
	if ct = null then
		ct:=self.addCargoType(Cargo_Type, false);
	endif;
	self.assertNotNull(ct);
	self.assertEqual(ct.productType,ProductType_Trailer);
	self.assertEqual(ct.myClassToCreate, CM_TILC);
	
	/*Add trailer type*/
	tt:=self.addTrailerType(TrailerType,TrailerType,ct,500,1,50,30000,13000,null,null,500);
	self.assertNotNull(tt);
	self.assertEqual(tt.numControllers,1);	
	self.assertEqual(tt.width.asStringJMT,"500.0000");
	
	self.deleteVehicle(VEHICLEID);
	self.deleteDriverDetails(DRIVERID);
	
	/*VBS Timeslot - Booking*/
	vehicleBookingTerminal := self.getMyTerminal.myVehicleBookingTerminal;
	vbsSlotType 		   := self.addVbsTimeslotType(REF, "Slot Type Create" &amp; REF); 	
	create proxyVbsTimeSlot transient;	
	direction  := DIRECTION_DELIVERY;
	quantity   := 0;
	sequence   := 0;
	sourceType := SOURCE_CARGO;
	self.deleteContainer(ContainerID);
	
	create vbsTimeSlotItem transient;
	
	vbsTimeSlotItem.setProxy(direction,
							null,
							null,
							null,
							null,
							trackedItem,
							proxyVbsTimeSlot,
							quantity,
							sequence,
							sourceType,
							0,
							null,
							null);	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
							
	
	/* get tracked item*/
	
	create tiStringArray transient;
	
	/* create carrier and subcarrier*/
	create email transient;
	self.deleteCarrier(SUBCARRIERCODE);
	carrierCode := self.getProfileStr(UT_Profile.P_CARRIER);
	carrier := app.myRoot.allCarriers[carrierCode];
	subCarrier := self.addCarrier(SUBCARRIERCODE, SUBCARRIERCODE, email, false, true, true, null);

	/* create vehicle*/
	vehicle := self.addVehicle( VEHICLEID, carrier, self.getTerminal());
	self.assertNotNull(vehicle);
	
	/* create driver details*/
	create allCarriers transient;
	allCarriers.add(carrier);
	create allVehicleMachines transient;
	allVehicleMachines.add(vehicle);
	driver := self.createDriverDetails(DRIVERID, allCarriers, allVehicleMachines);
	
	/*Gate*/
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	
	/*Create vehicle booking with both pre-check and post-check enabled.*/
	startTime.setTime(vbsSlotType.startTime);
	startTime.setDate(date.cnEcAddDays(1));
	
	endTime.setTime(vbsSlotType.startTime.addMinutes(vbsSlotType.duration));
	endTime.setDate(date.cnEcAddDays(1));	
	
	proxyVbsTimeSlot.setProxy(startTime, endTime, vehicleBookingTerminal, carrier, subCarrier, driver, vehicle, null, true, false, tiStringArray, vvr, vbsSlotType, ID, null, null, null, true, true, vbsSlotType.kioskCheck, null, null); // 08 Aug 2024 navcs2	ChangeRequest 63928
	app.myTrxCA.trxCreateVehicleBookingAdv(proxyVbsTimeSlot, realVbsTimeSlot,false, app.myPassport);			//24.5.2023 navhl20 #58041

	/*Create VVR*/
	self.opts.purge;
	self.opts.addAssoc("Location", bs1.myLocationsController.getFullId);
	self.opts.addAssoc("VehicleBookingTS",realVbsTimeSlot);	
	vvr:=self.gateInTrailerAndContainer(VEHICLEID,Trailer,ContainerID,tt.code,"2200",self.getProfileSetting(UT_Profile.P_OPERATOR).asString,"MT",dualGate);
	self.assertNotNull(vvr);
	
	ti := vvr.allReceivedTrackedItems.first; // NAVAB1 RTQ Task has invalid source location
	
	
	truck:=self.getTerminal.vehicles[VEHICLEID,null];
	self.assertNotNull(truck);
	
	/*Trailer*/
	trailer:=vvr.myInCMGTE_Chassis.myTrackedItem.CM_TILC;
	self.assertNotNull(trailer);
	self.assertEqual(trailer.myPrimaryActualLocation,truck.locationsController); 	
	self.assertEqual(trailer.width.asStringJMT,"500.0000");
	
	/*-------------------------------------Gate IN-------------------------------------------*/ 
	pin 		:= self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString);	
	self.assertNotNull(pin);
	
	/*Move vehicle to lane*/
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
	assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pin, 1));
		
	/*Move vehicle to yard*/
	self.expectedTrxErrors.add(Vehicle_cannot_move_to_yard);
	self.moveVehicleToYard(vvr.vehicle);
	self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode(Vehicle_cannot_move_to_yard), " Should include error " &amp; Vehicle_cannot_move_to_yard.String &amp; " Vehicle cannot move to yard");
	assertTrueMsg(vvr.gateInCheckStatus = vvr.InspectionPending,"Vehicle inspection pending");
	
	//28.Mar.2023  navsp1 TFS 57268 -- &gt;&gt;&gt;&gt;
	/*Update gate in inspection status to failed*/
	pxyVVR := app.createUpdateProxy(vvr).CM_VehicleVisitRecord;
	pxyVVR.updateGateCheckDetails(true,vvr.InspectionFailed,app.actualTimeServer);	
	app.myTrxUA.trxUpdateVehicleVisitFlexi(pxyVVR,app.myPassport);
	assertTrueMsg(vvr.gateInCheckStatus = vvr.InspectionFailed,"Vehicle inspection failed");
	delete pxyVVR;
	
	/*Move vehicle to yard*/
	self.expectedTrxErrors.add(Vehicle_cannot_move_to_yard);
	self.moveVehicleToYard(vvr.vehicle);
	self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode(Vehicle_cannot_move_to_yard), " Should include error " &amp; Vehicle_cannot_move_to_yard.String &amp; " Vehicle cannot move to yard");
	assertTrueMsg(vvr.gateInCheckStatus = vvr.InspectionFailed,"Vehicle inspection failed");
	//28.Mar.2023  navsp1 TFS 57268 -- &lt;&lt;&lt;&lt;
	
	/*Update gate in inspection status*/
	pxyVVR := app.createUpdateProxy(vvr).CM_VehicleVisitRecord;
	pxyVVR.updateGateCheckDetails(true,vvr.InspectionCompleted,app.actualTimeServer);	
	app.myTrxUA.trxUpdateVehicleVisitFlexi(pxyVVR,app.myPassport);
	assertTrueMsg(vvr.gateInCheckStatus = vvr.InspectionCompleted,"Vehicle inspection completed");
	delete pxyVVR;
	
	/*Move vehicle to yard*/
	self.moveVehicleToYard(vvr.vehicle);	
	self.moveQueuedCargo(vvr.myInCMGTE_Chassis.myYardRequest.allWorkListEntries.first);
	self.assertEqual(trailer.myPrimaryActualLocation,bs1.myLocationsController); 

	/*--------------------------Gate OUT -----------------------------------------*/
	/*Road exit with errors*/
	self.expectedTrxErrors.clear();
	self.expectedTrxErrors.add(Vehicle_cannot_road_exit);
	self.opts.purge();
	self.opts.addAssoc("ExpectErrors",true);
	self.roadExit(vvr);
	self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode(Vehicle_cannot_road_exit), " Should include error " &amp; Vehicle_cannot_road_exit.String &amp; " Vehicle cannot road exit");
	self.assertEqual(trailer.state, TI_STATE_NORMAL);
	
	//28.Mar.2023  navsp1 TFS 57268 -- &gt;&gt;&gt;&gt;
	/*Update gate out inspection status failed*/
	pxyVVR := app.createUpdateProxy(vvr).CM_VehicleVisitRecord;
	pxyVVR.updateGateCheckDetails(false,vvr.InspectionFailed,app.actualTimeServer);	
	app.myTrxUA.trxUpdateVehicleVisitFlexi(pxyVVR,app.myPassport);
	assertTrueMsg(vvr.gateOutCheckStatus = vvr.InspectionFailed,"Vehicle inspection failed");
	delete pxyVVR;
	
	/*Road exit with errors*/
	self.expectedTrxErrors.clear();
	self.expectedTrxErrors.add(Vehicle_cannot_road_exit);
	self.opts.purge();
	self.opts.addAssoc("ExpectErrors",true);
	self.roadExit(vvr);
	self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode(Vehicle_cannot_road_exit), " Should include error " &amp; Vehicle_cannot_road_exit.String &amp; " Vehicle cannot road exit");
	self.assertEqual(trailer.state, TI_STATE_NORMAL);
	self.assertEqual(vvr.gateOutCheckStatus, vvr.InspectionFailed);
	//28.Mar.2023  navsp1 TFS 57268 -- &lt;&lt;&lt;&lt;	
	
	/*Update gate out inspection status*/
	pxyVVR := app.createUpdateProxy(vvr).CM_VehicleVisitRecord;
	pxyVVR.updateGateCheckDetails(false,vvr.InspectionCompleted,app.actualTimeServer);	
	app.myTrxUA.trxUpdateVehicleVisitFlexi(pxyVVR,app.myPassport);
	assertTrueMsg(vvr.gateOutCheckStatus = vvr.InspectionCompleted,"Vehicle inspection completed");
	delete pxyVVR;
	
	/*Road exit*/
	self.opts.purge();
	self.expectedTrxErrors.clear();
	self.roadExit(vvr);	
	
	// Delete the VBS Timeslot Type and any vehicle booking slots							//07.Mar.2025 navsp1 UT fixes
	if realVbsTimeSlot &lt;&gt; null and realVbsTimeSlot.myVehicleVisitRecord &lt;&gt; null then
		self.deleteVVR(realVbsTimeSlot.myVehicleVisitRecord);
	endif;
	if vbsSlotType &lt;&gt; null then
		foreach vbs in vbsSlotType.myTerminal.myVehicleBookingTerminal.allVBTimeslotsById do
			if vbs.myVBTimeSlotType = vbsSlotType then
				self.deleteVbsTimeSlotAdv(vbs.id);
			endif;
		endforeach;
		self.deleteVbsTimeslotType(REF);
	endif;
epilog
	beginTransaction;
		terminal.setMyVBSProcess(app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_STANDARD_CODE]);
	commitTransaction;
	
	self.unqueueTI(ti); // NAVAB1 RTQ Task has invalid source location
	
	delete tiStringArray;
	delete allCarriers;
	delete email;
	delete allVehicleMachines;
	delete proxyVbsTimeSlot;
	delete objectArray;
	delete pxyVVR;
end;</source>
    </JadeMethod>
    <JadeMethod name="tGateInTrailer" id="bde2fbe3-037e-4fe4-83b2-35cc1637e698">
        <source>tGateInTrailer();
/*

Date		Who		Reason
08 July 2013	cnwer1	Initial creation CCMS DPH 2274
10 March 2023	jlika1	Add width to trailer.
*/

constants
	Cargo_Type = "UTCHAS";
	TrailerType ="UTTT20";
	TruckID = "UTCHAS";
	TrailerID = "CHAS1234";
	CargoID = "UTCHAS1234";
vars
	ct : CM_CargoType;
	tt	: CM_TILCType;
	truck : CM_Vehicle;
	trailer : CM_TILC;
	vvr  : CM_VehicleVisitRecord;
	tiTrans : CM_TITransaction;
	bs1 : CM_BlockStack;
begin
	
	self.deleteAllCargo(TrailerID,ct);
	bs1:=self.addBlockStack("BSCHAS",999,null);
	
	self.opts.purge;
	self.opts.addAssoc("TrackAs",ProductType_Trailer);
	ct:=self.addCargoType(Cargo_Type, false);
	
	self.assertNotNull(ct);
	self.assertEqual(ct.productType,ProductType_Trailer);
	self.assertEqual(ct.myClassToCreate, CM_TILC);
	
	tt:=self.addTrailerType(TrailerType,TrailerType,ct,500,1,50,30000,13000,null,null,500);
	self.assertNotNull(tt);
	self.assertEqual(tt.numControllers,1);
	self.assertEqual(tt.width.asStringJMT,"500.0000");	
	
	self.deleteVehicle(TruckID);
	
	self.opts.purge;
	self.opts.addAssoc("Location", bs1.myLocationsController.getFullId);
	vvr:=self.gateInTrailerAndContainer(TruckID,TrailerID,null,tt.code,null,"PON",null,dualGate);
	self.assertNotNull(vvr);
	
	truck:=self.getTerminal.vehicles[TruckID,null];
	self.assertNotNull(truck);
	
		
	trailer:=truck.locationsController.allTrackedItemsById[TrailerID,ct.id].CM_TILC;
	self.assertNotNull(trailer);
	self.assertEqual(trailer.width.asStringJMT,"500.0000");	
	
	trailer:=vvr.myInCMGTE_Chassis.myTrackedItem.CM_TILC;
	self.assertNotNull(trailer);
	self.assertEqual(trailer.myPrimaryActualLocation,truck.locationsController); 
	tiTrans:=trailer.getLastTransOfType(TRANS_TYPE_REC_ROAD);
	self.assertNotNull(tiTrans);
	
	
	self.moveVehicleToLane(vvr.vehicle, self.pin, 1);
	assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.pin, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
	
	self.moveQueuedCargo(vvr.myInCMGTE_Chassis.myYardRequest.allWorkListEntries.first);
	self.assertEqual(trailer.myPrimaryActualLocation,bs1.myLocationsController); 
	
	self.roadExit(vvr);
	self.assertEqual(trailer.state, TI_STATE_NORMAL);

	
end;</source>
    </JadeMethod>
    <JadeMethod name="tGateInTrailerCargo" id="8568e3bb-b2de-41f0-8bf8-787de05042c2">
