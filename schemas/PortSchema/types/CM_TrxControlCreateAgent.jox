    <JadeMethod name="trxCreateRouteTemplate" id="a1c3f0f3-d468-4db7-90d5-be3fc6f7ccd7">
        <updating/>
        <source>trxCreateRouteTemplate(_pxyRouteTemplate : HMS_RouteTemplate; _realRouteTemplate : HMS_RouteTemplate output; 
		_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     11 November 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	_pxyRouteTemplate.validateForCreate(_passport);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	create _realRouteTemplate persistent;
	_realRouteTemplate.setForCreate(_pxyRouteTemplate, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyRouteTemplate" type="HMS_RouteTemplate"/>
        <Parameter name="_realRouteTemplate" type="HMS_RouteTemplate" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateSAPRequest" id="7b88843f-ca65-48c2-9434-3b3fc7188b46">
        <updating/>
        <source>trxCreateSAPRequest(_workOrder : CM_WorkOrder input;_isFinRecheck : Boolean; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2018	jlger1	Initial creation
14 Nov       2018   cnwma1  Bug 41993: PEL1 - IMSR Cash receipt
11/06/2025	navcs2	MTN-34987  MTN -  Disable SAP Integration

*/


vars
	cashReceipt : CM_CashReceipt;
begin
	/*
	
	No longer using SAP		11/06/2025	navcs2	MTN-34987  MTN -  Disable SAP Integration
	
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	if _workOrder = null then
		return;
	endif;
	
	if not _workOrder.myTerminal.isSapFinancialEnabled then
		return;
	endif;
	
	if _workOrder.allCashReceipts.isEmpty then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	if _isFinRecheck then
		//this is a cancel request
		if _workOrder.taskStatus = WO_STATUS_CANCELLED then
			//lets check if there are any cash receipts at not CREDIT_CANCEL_APPROVED
			foreach cashReceipt in _workOrder.allCashReceipts do
				_workOrder.createSAPRequest(cashReceipt,true);	
			endforeach;
			
		elseif _workOrder.taskStatus = WO_STATUS_REJECTED_FIN or
				_workOrder.taskStatus = WO_STATUS_PENDING_FIN then
			//resend the request 
			foreach cashReceipt in _workOrder.allCashReceipts do
				_workOrder.createSAPRequest(cashReceipt,false);
			endforeach;	
		endif;
	else
	*/
	/*
	 14.11.2018 cnwma1 Bug #41993
	 This will be used to send SAP Request if there is configuation error and the user click on create cash Receipt on the work order screen
	*/
	/*
		if _workOrder.isVoyageWorkOrder then
			if _workOrder.isWorkOrderForIMSR then
				foreach cashReceipt in _workOrder.allCashReceipts do
					_workOrder.createSAPRequest(cashReceipt,false);
				endforeach;	
			endif;
		endif;	
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
	*/
end;

</source>
        <Parameter name="_workOrder" type="CM_WorkOrder" usage="input"/>
        <Parameter name="_isFinRecheck" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
