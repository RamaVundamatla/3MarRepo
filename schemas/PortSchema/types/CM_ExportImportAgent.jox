    <JadeMethod name="getExportImportProperty" id="3e988a7a-7dc0-4168-b1da-84a8776848f7">
        <source>getExportImportProperty(_exportClass: CM_ExportImportClass; _tagName: String): CM_ExportImportProperty protected;
/*

Purpose:			
	* Finds a property configuration by its XML tag name
	 * 
	 * @param _exportClass Class configuration to search
	 * @param _tagName XML tag name (with spaces removed)
	 * @return Property configuration or null if not found
Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation Initial creation MTN-36788 - JADE Core Framework - Export Engine - XML Generation

*/

vars
    keyProp: CM_ExportImportProperty;
begin
    foreach keyProp in _exportClass.allProperties do
        if self.removeSpaces(keyProp.displayName) = _tagName then
            return keyProp;
        endif;
    endforeach;
    
    return null;
end;</source>
        <access>protected</access>
        <Parameter name="_exportClass" type="CM_ExportImportClass"/>
        <Parameter name="_tagName" type="String"/>
        <ReturnType type="CM_ExportImportProperty"/>
    </JadeMethod>
    <JadeMethod name="removeSpaces" id="e882fbc3-33c7-45be-b315-3ff83667aabd">
        <source>removeSpaces(_text: String): String;
/*

Purpose:			
	 * Removes spaces from text for XML tag names
	* Example: "Commodity Code" ? "CommodityCode"
Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation Initial creation MTN-36788 - JADE Core Framework - Export Engine - XML Generation

*/

vars
    result: String;
begin
    if _text = null or _text = "" then
        return _text;
    endif;
    
    result := _text.replace(" ",'');
    
    return result;
end;</source>
        <Parameter name="_text" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="saveXmlToFile" id="76fe2014-0cf5-46a1-9675-f23baa16d175">
        <updating/>
        <source>saveXmlToFile(_filePath: String): Boolean updating;
/**
 * Saves the generated XML to a file
 * @param _filePath: Full path to output file
 * @return: true if successful, false otherwise
 
 Date		Who		Reason
06 January 2026	naviv1	Initial creation Initial creation MTN-36788 - JADE Core Framework - Export Engine - XML Generation
 */
vars
    file: File;
    fullXml: String;
begin
    create file;
    file.fileName := _filePath;
    
	file.openOutput(file.fileName);
    if not file.isAvailable()  then
       // self.writeLog("ERROR: Cannot create file: " &amp; _filePath);
        delete file;
        return false;
    endif;
    
    // Add XML declaration and root element
    fullXml := '&lt;?xml version="1.0" encoding="utf-8"?&gt;' &amp; CrLf;
    fullXml := fullXml &amp; "&lt;ExportData&gt;" &amp; CrLf;
    fullXml := fullXml &amp; self.xmlStr;
    fullXml := fullXml &amp; "&lt;/ExportData&gt;";
    
    file.writeString(fullXml);
    file.close();
    
   // self.writeLog("XML saved to: " &amp; _filePath);
    
epilog
    delete file;
    return true;
end;</source>
        <Parameter name="_filePath" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
