<Class name="CM_QInvContTypeLookupMethod" id="f849a7a5-cdc6-4115-a116-7acaaa55ad1a">
    <superclass name="CM_QIntegerLookupMethod"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="3550c194-5a9f-4084-9af3-9deb4c79c4b6">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
	
	self.allAllowedOperators.clear;
	
	create oper as CM_QIntArrayLookupEqual persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntArrayLookupNotEqual persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntegerArrIsOneOf persistent;
	self.allAllowedOperators.add(oper);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="a641cb6f-50d9-49a9-9485-0b066872afbb">
        <source>getKeyLengthForXTABDictionary(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/

vars
	length	:Integer;
begin

	length := INV_CONTRACT_TYPE_VOLBASED_STR.length;
	length := length.max(INV_CONTRACT_TYPE_STANDARD_STR.length);
	
	return length;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
