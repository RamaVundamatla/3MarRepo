    <JadeMethod name="utlCreateStopTableTemplate" id="e9ffd9df-7283-4c05-b093-4ee5aac6c9be">
        <source>utlCreateStopTableTemplate(_proxyStopTableTemplate : CM_StopTableTemplate; _newStopTableTemplate : CM_StopTableTemplate output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		Aug 2007 cnwrs1 CCMS1017
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
//	app.myValCA.valStopTableTemplate(_proxyStopTableTemplate);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	create _newStopTableTemplate persistent;
	_newStopTableTemplate.setForCreate(_proxyStopTableTemplate);
	
	if _passport.noErrors then
