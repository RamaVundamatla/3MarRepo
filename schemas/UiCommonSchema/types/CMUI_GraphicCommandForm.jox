    <JadeMethod name="tblDim_click" id="688a5b5e-5d1a-465d-8594-0daffe85996a">
        <controlMethod name="CM_EntryTable::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDim_click(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		1 Janurary 2009 by cnwjo3
//
// Purpose:		
//
// Parameters:	
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	r : Integer;
	line : String;
begin
	return;
	foreach r in 1 to tblDim.rows do
		line := (r-1).String &amp; Tab &amp; tblDim.accessCell(r,2).text;
		line := line &amp; Tab &amp; tblDim.accessCell(r,3).backColor.String;
		line := line &amp; Tab &amp; tblDim.accessCell(r,4).backColor.String;
		line := line &amp; Tab &amp; tblDim.accessCell(r,5).text;
		line := line &amp; Tab &amp; tblDim.accessCell(r,6).text;
		line := line &amp; Tab &amp; tblDim.accessCell(r,7).text;
		line := line &amp; Tab &amp; tblDim.accessCell(r,8).text;
		line := line &amp; Tab &amp; tblDim.accessCell(r,9).text;
		line := line &amp; Tab &amp; tblDim.accessCell(r,10).text;
		line := line &amp; Tab &amp; tblDim.accessCell(r,11).text;
		line := line &amp; Tab &amp; tblDim.accessCell(r,12).text;
		line := line &amp; Tab &amp; tblDim.accessCell(r,13).text;
		write line;
	endforeach;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
