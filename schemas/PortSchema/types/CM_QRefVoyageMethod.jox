    <JadeMethod name="setComboValues" id="a3258b63-a9f3-4363-a57f-172741c68cbd">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
// re-use the code in CM_QStrVoyageProperty to avoid copying it and keeping in step
vars
	voyProp		: CM_QStrVoyageProperty;
begin
	create voyProp transient;
	voyProp.setComboValues(_combo, _params, _queryOperator, _passport);
epilog
	delete voyProp;
end;
</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="992f090f-278b-43f6-bb00-ecb5900380c3">
        <source>translateToDisplayValue(_value: Any): String;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
vars

begin
	if _value = null then
		return null;
	endif;
	return _value.CM_Voyage.code &amp; '   ' &amp; _value.CM_Voyage.description;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="48c0ad46-7fe5-4e6b-b42d-035ffa9c6d80">
        <source>translateToSearchValue(_value: Any): Any;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
vars

begin
	if _value &lt;&gt; null then
		if _value.isKindOf (Collection) then
			return _value;
		endif;
		
		if _value.isKindOf (CM_Voyage) then
			return _value.CM_Voyage;
		endif;
	endif;
	
	return null;

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="ec366a4b-5aec-457e-aedf-91c916bbabf7">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	term : CM_Terminal;
	voyage : CM_Voyage;

begin
	if _value.isKindOf(String) then
		term := app.myPassport.myTerminal;
		if term &lt;&gt; null then
			voyage := term.allVoyagesByCode.getAtKeyGeq(_value.String, null);
			if voyage &lt;&gt; null and voyage.code = _value.String then
				return voyage;
			endif;
		endif;
		
	elseif _value.isKindOf(CM_Voyage) then
		return _value.CM_Voyage.code;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
