    <JadeMethod name="expandItem" id="4b065d40-89a2-4de4-a07f-57a2e5642b1f">
        <updating/>
        <source>expandItem(idx : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpRows,
	expandTo,
	tmpIdx,
	startLevel,
	tmpLevel	: Integer;
	tmpValue	: Boolean;
begin

	if self.itemHasSubItems(idx) then
		tmpValue := (not self.itemExpanded[idx]);
		self.itemExpanded[idx] := tmpValue;
		if tmpValue then
			tmpRows := self.listCount;
			tmpIdx := idx + 1;
			startLevel := self.itemLevel[idx];
			while tmpIdx &lt; tmpRows do
				tmpIdx := tmpIdx + 1;
				tmpLevel := self.itemLevel[tmpIdx];
				if tmpLevel = startLevel then
					expandTo := tmpIdx;
					break;
				endif;
			endwhile;
		endif;
	endif;

end;</source>
        <Parameter name="idx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="expandParentsUntilVisible" id="31b58d20-a67f-4ef0-95de-2f85784541dc">
        <updating/>
        <source>expandParentsUntilVisible( rowIndex : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2016	cnwndl1	Initial creation	TFS 3123

*/

vars

	parentIndex : Integer;

begin

	parentIndex := self.getParentRow( rowIndex );
	if parentIndex &gt; 0 and parentIndex &lt; self.listCount then
		if not self.itemVisible( parentIndex ) then
			self.expandParentsUntilVisible( parentIndex );
		endif;
		self.expandItem( parentIndex );
	endif;

epilog

end;</source>
        <Parameter name="rowIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllSelectedObjects" id="69ece9ee-3cb8-4ec1-aab0-9aa9dfeb7f18">
        <source>getAllSelectedObjects() : ObjectArray;
/*
Purpose:			
Date		Who		Reason
10 February 2015	cnwab1	Initial creation
*/

vars

	count	: Integer;
	idx		: Integer;
	objs : ObjectArray;
begin
	count := self.listCount;
	
	create objs transient;
	
	foreach idx in 1 to count where self.itemSelected[idx] = true do
		if self.itemObject[idx] &lt;&gt; null then
			objs.add( self.itemObject[idx]);
		endif;
	endforeach;

	return objs;
epilog

end;</source>
        <ReturnType type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getCurrentSelections" id="aada538c-4283-42ee-a2a2-eb106e492e1a">
        <source>getCurrentSelections(selectedEntries : StringArray input);

// R Barr 6/11/2006 Comalco -- get currently selected entries; then use restoreSelectedEntries()

vars
	count	: Integer;
	idx		: Integer;
begin
	count := listCount;
	selectedEntries. clear;
	foreach idx in 1 to count where itemSelected[idx] = true do
		selectedEntries.add(itemText[idx]);
	endforeach;
end;
</source>
        <Parameter name="selectedEntries" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFirstSelectedObject" id="64182c1b-b135-4ccf-bc38-1c0a8418c9ec">
        <source>getFirstSelectedObject():Object;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwndl1	Initial creation

*/

vars
	count	: Integer;
	idx		: Integer;
begin
	count := self.listCount;
	foreach idx in 1 to count where self.itemSelected[idx] = true do
		if self.itemObject[idx] &lt;&gt; null then
			return self.itemObject[idx];
		endif;
	endforeach;
end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getParentRow" id="dc987a81-c679-4924-8bff-cadf6e2c4ebc">
        <source>getParentRow(_startRow : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:     25 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx,
	lvl,
	rtnValue	: Integer;
	
begin

	rtnValue := -1;

	if _startRow &gt; self.listCount then
		return rtnValue;
	endif;

	lvl := self.itemLevel[_startRow] - 1;
	
	if lvl &lt;= 0 then
		// this must already by at level 1
		return rtnValue;
	endif;

	foreach idx in (_startRow -1) to 1 step -1 do
		if self.itemLevel[idx] = lvl then
			rtnValue := idx;
			break; // ### AKB2004AGUST Added
		endif;
	endforeach;
	
	return rtnValue;

end;</source>
        <Parameter name="_startRow" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSelectedEntries" id="b686cc91-4827-4218-9111-10157d08ebcf">
        <source>getSelectedEntries(_coll :CM_IntegerArray input);
// ---------------------------------------------------------------------------
// Created:     17 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	count	: Integer;
	idx		: Integer;
begin
	count := listCount;
	
	_coll.clear;
	
	foreach idx in 1 to count where itemSelected[idx] = true do
		_coll.add(idx);
	endforeach;
epilog

end;</source>
        <Parameter name="_coll" type="CM_IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getXMLStringForSelected" id="2981d140-6d7e-47ec-8f22-f34bdc6846fd">
        <source>getXMLStringForSelected() : String;
/*

Date		Who		Reason
15 October 2015	cnwer1	Initial creation PAR

*/

vars

	count	: Integer;
	idx		: Integer;
	hasSelected : Boolean;
	str : String;
begin
	count := listCount;
		
	foreach idx in 1 to count where itemSelected[idx] = true do	
		if not hasSelected then
			str := self.formatAsXMLPrefix(XMLTag_ListBox &amp; self.name);
			hasSelected:=true;
		endif;
		str := str &amp;  global.formatAsXML(XMLTag_Selected, itemText[idx]);	
	endforeach;
		
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="removeSelectedObjects" id="ad7466c2-6558-4510-ad00-0cac03e03055">
        <source>removeSelectedObjects();
//--------------------------------------------------
// Created:	24 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	cnt,
	lstCnt : Integer;
	theTime : String;
begin
	lstCnt := self.listCount();
	while cnt &lt; lstCnt do
		cnt := cnt+1;			
		if self.itemSelected[cnt] = true then
			self.removeItem(cnt);
			lstCnt := lstCnt-1;
			cnt := cnt -1;
		endif;	
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="26044256-f0ab-4862-b01e-c7fbe372e4a9">
        <updating/>
        <source>repositionAfterResize() updating;

vars
   	newLeft, newTop, newWidth, newHeight	: Real;
   	parentWidth,
   	parentHeight	: Real;

begin
	newLeft 	:= self.left;
	newTop 		:= self.top;
	newWidth 	:= self.width;
	newHeight 	:= self.height;

	if self.parent.isKindOf(Form) then
		parentWidth  := self.parent.Form.clientWidth;
		parentHeight := self.parent.Form.clientHeight;
	elseif self.parent.isKindOf(Control) then
		parentWidth  := self.parent.Control.clientWidth;
		parentHeight := self.parent.Control.clientHeight;
	else
		parentWidth  := self.parent.width;
		parentHeight := self.parent.height;
	endif;

	if lockRight then
		newLeft := (parentWidth - newWidth - self.distanceFromRight).max(0);
	endif;
	if lockBottom then
		newTop := (parentHeight - newHeight - self.distanceFromBottom).max(0);
	endif;
	if stretchWidth then
		newWidth := (parentWidth - newLeft - self.distanceFromRight).max(0);
	endif;
	if stretchHeight then
		newHeight := (parentHeight - newTop - self.distanceFromBottom).max(0);
	endif;

	if newLeft &lt;&gt; self.left or newTop &lt;&gt; self.top or newWidth &lt;&gt; self.width or newHeight &lt;&gt; self.height then
		self.move(newLeft, newTop, newWidth, newHeight);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="restoreSelectedEntries" id="4f6aaf74-07ae-4e96-811b-d7a058602172">
        <source>restoreSelectedEntries(selectedEntries : StringArray);

// R Barr 6/11/2006 Comalco -- use getCurrentSelections(), then call this method to restore selected entries

vars
	entry	: String;
	idx		: Integer;
begin
	if listCount &lt; 1 then
		return;
	endif;
	
	foreach entry in selectedEntries do
		idx := findStringExact(1, entry);
		if idx &gt; 1 then
			itemSelected[idx] := true;
		endif;
	endforeach;
end;
</source>
        <Parameter name="selectedEntries" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="selectObject" id="ca66edbb-f160-4fe5-a012-326d7c6195bb">
        <updating/>
        <source>selectObject(_obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	i		: Integer;
	numItems : Integer;
begin
	if _obj = null then
		return;
	endif;
	
	numItems := self.listCount;
	
	foreach i in 1 to numItems do
		if self.itemObject[i] = _obj then
			self.listIndex := i;
			self.itemSelected[i] := true;
			break;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setOriginals" id="d2bf59f6-6485-4ee4-8a82-6918dc793317">
        <updating/>
        <source>setOriginals(_x,_y, _index : Integer; _object : Object) updating;
// ---------------------------------------------------------------------------
// Created:		05 April 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.origIndex := _index;
	self.origXPos := _x;
	self.origYPos := _y;
	self.myDragObject := _object;
end;</source>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="02aa8419-fef8-4cd0-9dad-4fd33d8e901a">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2013	cnwmc5	Initial creation	PAR 31051

*/

vars

begin
	inheritMethod(cntrl, persistCntrl);
	if not self.isInPainter then
		if app.isUsingSkin() then
			self.hasTreeLines := false;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
