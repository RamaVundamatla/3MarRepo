    <JadeMethod name="showEDIEmailOptions" id="547d934a-03e8-489a-9446-23d9e30429a1">
        <source>showEDIEmailOptions(_emailTemplate : CM_EmailTemplate; _sending: Boolean) : Integer;
/*
Purpose - 	
Who - NAVAB1
Date - 08JUL2024
ADO -  CR 64617 TASK 64638
*/

vars
	form			: CMUI_EDIEmailForm;
	canView			: Boolean;
	canMaintain		: Boolean;
	limitedUpdate	: Boolean;

begin
	canView := app.myPassport.myUser.canDo(self.myTerminal, PmEDIEmailTemplateView);
	canMaintain := app.myPassport.myUser.canDo(self.myTerminal, PmEDIEmailTemplateMaint);
	
	if not (canView or canMaintain) then
		//just return OK - send default email
		app.msgBox("You do not have the permissions required for viewing or modifying the email defaults.","E-mail Options",null);
		return IDOK;
	endif;

	if _emailTemplate = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'email defaults is null from form');
		return IDCANCEL;
	endif;

	if canMaintain then
		limitedUpdate := false;
	else
		limitedUpdate := true;
	endif;
	
	create form;
	form.setAssistantAndTerminalRefs(self, self.myTerminal);
	form.setTemplate(_emailTemplate);
	form.centreWindow;
	form.showModal();
	
	return form.modalResult;

epilog

end;</source>
        <Parameter name="_emailTemplate" type="CM_EmailTemplate"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
