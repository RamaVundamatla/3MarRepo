    <JadeMethod name="validateForCreate" id="3d242f53-0c6a-4798-ab65-887e773a7c9e">
        <updating/>
        <source>validateForCreate(_passport : CM_Passport input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tiUpdCntrl		: CMIF_TIUpdateController;
	subItemError	: Boolean;
	
begin
	inheritMethod(_passport);
	self.myBOLType := app.myRoot.allBOLTypes[self.bolType];
	if self.myBOLType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Docket/Bill of Lading Type', 'bolType', self.myUserObject);
		app.raiseCMException(Input_required_field_dockBill, 'bolType', self.myUserObject); // cnwdb2	PAR 35364
		return _passport.noErrors();
	endif;
	
	if self.myProxyBOL &lt;&gt; null then
		if self.hasDocketErrors then
			self.myProxyBOL.allDocketErrors.first().setMyBol(null);
		endif;
		self.myProxyBOL.erase(NORMAL_ERASE);
		self.myProxyBOL := null;
	endif;

	if self.myIntFaceInOutCommon &lt;&gt; null then
		self.carrierCode 	:= self.myIntFaceInOutCommon.carrierCode;
		self.regNumber 		:= self.myIntFaceInOutCommon.regNumber;
	endif;

	//create the proxy from scratch
	self.myProxyBOL := self.myTerminal.createBOL(self.getBOLClass, true);		
	self.myProxyBOL.setPxyFromCMIF_BOL(self, _passport);

	self.validateForCreateSubClasses(_passport);

epilog
	if tiUpdCntrl &lt;&gt; null then
		delete tiUpdCntrl;
	endif;
	return _passport.noErrors();
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
