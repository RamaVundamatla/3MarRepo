end;</source>
    </JadeMethod>
    <JadeMethod name="showUserColourFrame" id="e3e895fd-96da-414f-a573-09c2aee7c942">
        <source>showUserColourFrame();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 03/02/2015	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars

begin
