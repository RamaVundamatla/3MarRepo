    <JadeMethod name="populateMultiObjArray" id="375ea12f-7668-4ae2-8c0a-853fec8041f2">
        <updating/>
        <source>populateMultiObjArray( _objArray : ObjectArray ) updating, protected;

/*

Purpose:			

Parameters:			creates TI arrays that represent multi cargo items.
						
					TI arrays are attached to special on truck buttons so 'like' cargo can be bulk unloaded.
					The arrays are deleted when the form is deleted or this method is called again..

Return Value:		


Date		Who		Reason
28 Sep 2011	cnwndl1	Initial creation
09 Feb 2012	cnwkpd1	PAR #28731 - fix transient leaks

*/

vars

	dynaDict : DynaDictionary;
	obj : Object;
	tiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	prevTi : CM_TrackedItem;

begin

	self.doCleanUpTiArraysOnBtns();  // deletes any existing TI Arrays.

	if _objArray.size &lt; 2 then
		// nothing to do.
		return;
	endif;

	create dynaDict transient;
	dynaDict.setMembership(CM_TrackedItem);
	dynaDict.addMemberKey("id",false,false);
	dynaDict.endKeys(true);
	
	foreach obj in _objArray do
		if obj.isKindOf(CM_TrackedItem) then
			dynaDict.add(obj);
		endif;
	endforeach;
	
	if dynaDict.size &lt; 2 then
		// nothing to do.
		return;
	endif;
	
	iter := dynaDict.createIterator;
	while iter.next( obj ) do
		ti := obj.CM_TrackedItem;
		if prevTi &lt;&gt; null then		
			if self.tisAreSimilar( prevTi, ti) then
				if tiArray = null then	// no current array, create it, add the prev ti, and add the array to the multobjarray
					create tiArray transient;
					multiObjArray.add(tiArray);
					tiArray.add(prevTi);
				endif;
				tiArray.add(ti); // add current similar ti
			else
				// reset the current array
				tiArray := null;
			endif;
		endif;
		prevTi := ti;
	endwhile;
	
epilog
	delete iter;
	delete dynaDict;

end;</source>
        <access>protected</access>
        <Parameter name="_objArray" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="returnFromDocAction" id="410bfbf2-c36a-4c0b-9ce1-69a6f6500b83">
