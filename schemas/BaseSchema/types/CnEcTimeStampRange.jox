    <DbClassMap file="basedvr"/>
    <ImplicitInverseRef name="myTimestampFrom" id="409cd9a9-609c-4936-8786-473af95ce4b5">
        <embedded/>
        <type name="CnEcTimestamp"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTimestampTo" id="0bd3fc20-2a8e-46e0-9f96-9bb9130ea9f5">
        <embedded/>
        <type name="CnEcTimestamp"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="getTimestampFrom" id="bd235e83-6d54-4ad8-9423-d993c360874f">
        <source>getTimestampFrom():TimeStamp;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Get the timestamp from value.
//
// Parameters:	None
//
// Returns:		The timestamp from value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myTimestampFrom.timestampClient;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getTimestampTo" id="560f4050-7388-4986-a22c-121cf0c8faf9">
        <source>getTimestampTo():TimeStamp;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		The timestamp to value.
//
// Parameters:	None
//
// Returns:		The timestamp to value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myTimestampTo.timestampClient;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setTimestampFrom" id="5802783c-cb52-4ec0-8cb1-3d0767ff71ee">
        <updating/>
        <source>setTimestampFrom(pTimestampFromObj:CnEcTimestamp) updating;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Set the timestamp from value object.
//
// Parameters:	pTimestampFromObj - The timestamp from object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateRange(pTimestampFromObj.timestampClient, self.myTimestampTo.timestampClient) then
		self.myTimestampFrom	:=	pTimestampFromObj;
	endif;
end;</source>
        <Parameter name="pTimestampFromObj" type="CnEcTimestamp"/>
    </JadeMethod>
    <JadeMethod name="setTimestampTo" id="1f4d6c8f-be2c-43c5-9f13-10560d0d2a9f">
        <updating/>
        <source>setTimestampTo(pTimestampToObj:CnEcTimestamp) updating;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Set the timestamp to value object.
//
// Parameters:	pTimestampToObj - The timestamp to object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateRange(self.myTimestampFrom.timestampClient, pTimestampToObj.timestampClient) then
		self.myTimestampTo	:=	pTimestampToObj;
	endif;
end;</source>
        <Parameter name="pTimestampToObj" type="CnEcTimestamp"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="cf99de54-269f-4403-afdd-7dff2a27f8fb">
        <updating/>
        <source>updateMe(pTimestampFrom:TimeStamp; pTimestampTo:TimeStamp) updating;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Update the receiver's timestamp range.
//
// Parameters:	pTimestampFrom - The timestamp from value.
//				pTimestampTo - The timestamp to value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateRange(pTimestampFrom, pTimestampTo) then
		self.myTimestampFrom.updateMe(pTimestampFrom);
		self.myTimestampTo.updateMe(pTimestampTo);
	endif;
end;</source>
        <Parameter name="pTimestampFrom" type="TimeStamp"/>
        <Parameter name="pTimestampTo" type="TimeStamp"/>
    </JadeMethod>
</Class>
