	idx, 
	currentRow,
	theReturn : Integer;
	toDelete : CM_TimeSlotEntity;
begin
/*	currentRow := self.tblTimeSlot.row;
	while true do
		foreach idx in 2 to self.tblTimeSlot.columns do
			toDelete := self.tblTimeSlot.accessCell(currentRow, idx).itemObject.CM_TimeSlotEntity;
			
			app.myTrxDA.trxDeleteTimeSlot(toDelete, app.myPassport);
			if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				continue;
			else
				theReturn := app.showErrorWarningDialog('Worker Shift Deletion', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
