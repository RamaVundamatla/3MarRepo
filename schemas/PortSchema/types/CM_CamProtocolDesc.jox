    <JadeMethod name="includeTransaction" id="16a7a376-dd11-4311-8f35-656a9ef43da5">
        <source>includeTransaction(_transaction 	: CM_Transaction; 
					_camsTS			: TimeStamp;
					_startTS		: TimeStamp;
					_endTS 			: TimeStamp;
					_camProtocol	: CM_CamProtocol; 
					_camGroup 		: CM_CamGroup; 
					_camAgent 		: CM_CamControllerAgent; 
					_logExcluded 	: Boolean;
					_event 			: CM_EventTransaction) : Boolean;
/*
Note: _transaction must be of type CM_TITransaction.  The parameter type is just so we can re-implenent for 
	  event transactions
	  
/****Changes

Date		Name	TFS#			Description
============================================================================
25/06/2012	cnwcs5	Par 29601. 		Initial creation. Log excluded transactions
18/07/2012	cnwrs1	CCMS 1269 		CAMS Remove CM_CamTask
07/02/2013	cnwcs5	CCMS 1294
					/PAR 30855
24/04/2013	cnwcs5	Par 30652 		Remove resynch/resynchObject method calls
15/05/2014	cnwrs1	Par 34159  		Include Chassis in Codeco
05/06/2018	jlgsl4	TFS 38884  		SNO - no CAMS output for TIs in Logical Delete areas
07/12/2018	jlgka1	TFS 37102		STWR - CAMS UN/EDIFACT CODECO for Released-Ship/Received-Ship for inland barges.
8/04/2019 	JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B
24/04/2019 	jlgka1	TFS 43785		STWR - CAMS STANDARD CODECO for Non-Structure Voyage.
11/03/2020	jlgdap1	TFS 48785 		SNO COARRI Issue. If we're using Voyage Operator, and the "Include Tranship 
													Imports for Voyage Operator" option is ticked, check the
													import voyage for any tranships to see if the operators match
============================================================================*/
vars
	ti			: CM_TrackedItem;
	isInvalid	: Boolean;
	voyageToUse : CM_Voyage;				// TFS 48785
begin
	// we know the transaction will be within the cams start/end interval
	
	on Exception do app.handleDeletedObject(exception, ti, isInvalid);
	on Exception do app.handleDeletedObject(exception, ti.myVoyage, isInvalid);
			
	ti := _transaction.CM_TITransaction.myTrackedItem;
	
	if ti = null then
		_camAgent.logReasonForExclusion (_transaction, 'Transaction does not have a cargo item');
		return false;
	endif;

	if ti.isDeleted then // TFS 38884
		_camAgent.logReasonForExclusion (_transaction, 'Transaction is for deleted cargo item'); // TFS 38884
		return false; // TFS 38884
	endif; // TFS 38884

	if not _camProtocol.includeCargoType(ti.cargoType, _transaction, _camAgent, _logExcluded) then
		return false;
	endif;
	
	if isInvalid then
		_camAgent.logReasonForExclusion (_transaction, 'Transaction has an invalid cargo item');
	
		return false;
	endif;
	
	// TFS 48785 if we're processing a Voyage Departed event, and the CAMS protocol is configured to 
	// check tranship import voyages, then do so
	voyageToUse := ti.myVoyage;
	if _event &lt;&gt; null and _event.type = EVT_VoyageDeparture and ti.isTranshipItem and _camProtocol.getTranshipImportsVoyageOp() and _camProtocol.useVoyageOperator then
		voyageToUse := ti.myVoyageTranshipImport;
	endif;
	// TFS 48785
	//if ti.myVoyage = null then				// TFS 48785
	if voyageToUse = null then					// TFS 48785
		_camAgent.logReasonForExclusion (_transaction, 'Transaction does not have a voyage');	
		return false;
	endif;
	// jlgka1 TFS 37102 --&gt;
	//if ti.myVoyage.isBarge then				// TFS 48785
	if voyageToUse.isBarge then					// TFS 48785
		if not (_camAgent.myCurrentCamProtocol.protocolDesc.isKindOf(CM_CamStandardCODECODesc)
		    or _camAgent.myCurrentCamProtocol.protocolDesc.isKindOf(CM_CamStandardCODECOSMDG213) ) 
			 or _camAgent.myCurrentCamProtocol.protocolDesc.isKindOf(CM_CamCOARRIDesc) then
			_camAgent.logReasonForExclusion (_transaction, 'Transaction voyage is a barge not valid for ' &amp; _camAgent.myCurrentCamProtocol.protocolDesc.name &amp; ' protocol');	
			return false;		
		endif;
	endif;	
	//if not ti.myVoyage.isBarge and (_transaction.CM_TITransaction.isCamsShipReleaseType() or _transaction.CM_TITransaction.isCamsShipReceiveType()) then	// TFS 48785
	if not voyageToUse.isBarge and (_transaction.CM_TITransaction.isCamsShipReleaseType() or _transaction.CM_TITransaction.isCamsShipReceiveType()) then	// TFS 48785
		if _camAgent.myCurrentCamProtocol.protocolDesc.isKindOf(CM_CamStandardCODECODesc) 
		or _camAgent.myCurrentCamProtocol.protocolDesc.isKindOf(CM_CamStandardCODECOSMDG213) then
			_camAgent.logReasonForExclusion (_transaction, 'Transaction voyage is not a barge not valid for ' &amp; _camAgent.myCurrentCamProtocol.protocolDesc.name &amp; ' protocol' );	
			return false;		
		endif;
	endif;
	// jlgka1 TFS 37102 &lt;--
	
	// jlgka1 TFS 43785  added the outer if statement to use config before checking--&gt;
	if not _camProtocol.useCodecoForNonStrucVoyage then
		//if not self.includeVoyage (_camProtocol, ti.myVoyage, _transaction, _camAgent, _logExcluded) then	// TFS 48785
		if not self.includeVoyage (_camProtocol, voyageToUse, _transaction, _camAgent, _logExcluded) then	// TFS 48785
			return false;
		endif;
	endif;
	// jlgka1 TFS 43785 --&gt;
	
	if isInvalid then
		_camAgent.logReasonForExclusion (_transaction, 'Transaction has an invalid voyage');
		return false;
	endif;
	
	if not _camProtocol.isCAMGroupMatch (_transaction.CM_TITransaction, _camAgent, _logExcluded) then
		return false;
	endif;
	
	//epr TFS 2395 21/7/16
	if _transaction.isKindOf(CM_Edit) and 
		_camProtocol.allEditTriggerFields.size &gt; 0 and 
		not _transaction.CM_Edit.hasCamProtocolTrigger (_camProtocol.allEditTriggerFields) then
		// an edit trx for a field we are NOT interested in
		
		_camAgent.logReasonForExclusion (_transaction, 'Edit Transaction does not match any CAM protocol trigger fields');
		
		return false;		
	endif;
	
	return true;
end;</source>
        <Parameter name="_transaction" type="CM_Transaction"/>
        <Parameter name="_camsTS" type="TimeStamp"/>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camGroup" type="CM_CamGroup"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_logExcluded" type="Boolean"/>
        <Parameter name="_event" type="CM_EventTransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeVoyage" id="da40586c-2337-46a0-92de-0fea9af4a90b">
        <source>includeVoyage(_camProtocol: CM_CamProtocol; _voyage :CM_Voyage; _trx :CM_Transaction; _camAgent : CM_CamControllerAgent; _logExcluded :Boolean):Boolean protected;
/*
Date		Who		Reason
27/06/2012	cnwcs5	Initial creation - par 29601
*/
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
vars
	result	:Boolean;
begin
	result := _voyage.isCellularVoyage;
	
	if not result and _logExcluded then
		_camAgent.logReasonForExclusion (_trx, 'Voyage ' &amp; _voyage.code &amp; ' is not cellular');
	endif;
	
	return result;
epilog

end;</source>
        <access>protected</access>
