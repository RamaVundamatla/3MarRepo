    <JadeMethod name="setSlotIds" id="43de93e5-17e9-4df3-903b-ed2fb2e5b097">
        <updating/>
        <source>setSlotIds() updating;
/*
 ------------------------------------------------------------------------
Created:			13 November 2002 by cnwdwq1
Purpose:			Rips through all slot controllers and sets their ID. This only gets called
							when the bayCellTier numbering convention changes on the voyage/defn.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	sc : CM_SlotController;
	useBayCTNumbering : Boolean;
begin
	useBayCTNumbering := self.myCellularVoyageStructure.useBayCellTierNumbering;
	foreach sc in self.allSlotControllersByOrdinal do
		sc.setIdent(useBayCTNumbering);
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="unplanAll" id="f1e9dd2b-cc22-43f7-a026-217dc553bbee">
        <updating/>
        <source>unplanAll(_moveMode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aSlotController : CM_SlotController;
begin
	foreach aSlotController in self.allSlotControllersByOrdinal do
		aSlotController.unplanAllTrackedItems(_moveMode);
	endforeach;
end;</source>
        <Parameter name="_moveMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateSlotLinks" id="9843372b-fcd0-4968-be98-64f1610c3405">
        <updating/>
        <source>updateSlotLinks() updating;
// ---------------------------------------------------------------------------
// Created:     14 October 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	objs : ObjectSet;
	slot : CM_SlotController;

begin
	inheritMethod();

	if not self.isTransient then
	// PAR 26042 if a tier or cell is different from the voyage defn, then slot defn objects are deleted, but orphaned slot controllers are left behind.
	// because the parent child inverse is from slot controller to slot defn have to remove orphaned slot controllers like this.
	create objs transient;
	foreach slot in self.allSlotControllersByOrdinal discreteLock do
		if slot.mySlotDefnVoyage = null then
				objs.add(slot);
		endif;
	endforeach;
	objs.purge();
	endif;
epilog
	delete objs;



end;</source>
    </JadeMethod>
    <JadeMethod name="useCellTierNumbering" id="f61819cd-acf4-4c46-b4b1-de6ceb73ecfd">
        <source>useCellTierNumbering(): Boolean;
