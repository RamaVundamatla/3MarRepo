    <JadeMethod name="doResizeControls" id="24441a60-06cf-48d3-8365-2945b8dd6419">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	top : Real;
	stdWidth : Real;
	
	specialLiftsCount : Integer;
	rowHeight : Real;
	height : Real;
	fullListHeight : Real;
	
	specialLift : CM_SpecialLift;
	stdHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	self.lblSelect.move(top,
						top,
						stdWidth,
						stdHeight ); 
					 
	top := lblSelect.top + lblSelect.height + self.resizedMargin;
	height := self.clientHeight - top - self.getCMDButtonsHeight();
	if self.chkToDo.visible then
		height := height - stdHeight - self.resizedMargin;
	endif;
	
	specialLiftsCount := app.myRoot.allSpecialLifts.size;
	rowHeight := self.lstSpecialLifts.accessRow(1).height;
	fullListHeight := ( rowHeight * specialLiftsCount ) + self.resizedMargin;
	if height &gt; fullListHeight then
		height := fullListHeight;
	endif;
	
	self.lstSpecialLifts.move(	self.resizedMargin,
								top,
								stdWidth - self.resizedMargin,
								height ); 
								
	top := lstSpecialLifts.top + lstSpecialLifts.height + self.resizedMargin;
	
	self.chkToDo.move(	self.resizedMargin,
						top,
						((stdWidth * 2) / 3),
						stdHeight ); 

	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="352019cf-be46-4b18-8490-0aca8b1eba07">
        <source>doSave():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

	proxyTi : CM_TrackedItem;
	realTi : CM_TrackedItem;
	sessionAgent : CM_MobileAgent;
	errors : String;
	toDoTaskDesc : CM_ToDoTaskDesc;
	//addingToDo : Boolean;
	specialLift : CM_SpecialLift;
	specialLifts : CM_SpecialLiftByCodeDict;
	index : Integer;
	updateRequired : Boolean;
	addCompRemTodo	: Integer;	// 1 = add, 2 = complete, 3 = remove 16 Mar 2016	NDL TFS 1673

begin

	app.mousePointer := self.MousePointer_HourGlass;
	
	sessionAgent := self.getSessionAgent;
	proxyTi := sessionAgent.getMyProxyObject.CM_TrackedItem;
	if proxyTi = null then
		return false;
	endif;
	realTi := proxyTi.pxyGetRealObject().CM_TrackedItem;
	
	//16 Mar 2016	NDL TFS 1673
	if self.chkToDo.value then
		addCompRemTodo := 1;
	else
		addCompRemTodo := 3;
	endif;
	
	if self.myCargoCheckItem &lt;&gt; null then			
		toDoTaskDesc := self.myCargoCheckItem.myToDoTaskDesc;
	elseif self.myToDoTaskDesc &lt;&gt; null then		// 37244
		toDoTaskDesc := self.myToDoTaskDesc;
		addCompRemTodo := 2;	//16 Mar 2016	NDL TFS 1673
	endif;
	
	create specialLifts transient;
	foreach index in 1 to lstSpecialLifts.rows do
		if lstSpecialLifts.rowChecked(index) then
			specialLift := lstSpecialLifts.accessRow(index).itemObject.CM_SpecialLift;
			if specialLift &lt;&gt; null and not specialLifts.includes(specialLift) then
				specialLifts.add(specialLift);
			endif;
		endif;
	endforeach;
	
	if realTi = null then
		updateRequired := true;
	else
		if addCompRemTodo = 1 then
			if toDoTaskDesc &lt;&gt; null and not realTi.allToDoTasksToDo.includesToDoDesc(toDoTaskDesc.code) then
				// its not there and we want it added.
				updateRequired := true;
			endif;
		else
			if toDoTaskDesc &lt;&gt; null and realTi.allToDoTasksToDo.includesToDoDesc(toDoTaskDesc.code) then
				// it is there and we no longer want it.
				updateRequired := true;
			endif;
		endif;
		if not updateRequired then
			if specialLifts.size &lt;&gt; realTi.allSpecialLifts.size then
				updateRequired := true;
			endif;
		endif;
		if not updateRequired then
			foreach specialLift in specialLifts do
				if not realTi.allSpecialLifts.includes(specialLift) then
					updateRequired := true;
					break;
				endif;
			endforeach;
		endif;
		if not updateRequired then
			foreach specialLift in realTi.allSpecialLifts do
				if not specialLifts.includes(specialLift) then
					updateRequired := true;
					break;
				endif;
			endforeach;
		endif;
	endif;
	
	if not updateRequired then
		// no updating to do.
		return true;
	endif;
	
	if sessionAgent.updateSpecialLifts(	specialLifts,	//_specialLifts : CM_SpecialLiftByCodeDict;
										toDoTaskDesc,	//_toDoTask : CM_ToDoTaskDesc;
										addCompRemTodo	//_addingToDo : Boolean
										) then
		
		return true;
	else
		//errors := app.myPassport.getErrorsAsString.trimBlanks;
		errors := app.myPassport.getAllErrorsWarningsAsString.trimBlanks;	// 10 Aug 2012	NDL	Par 29885
		if errors &lt;&gt; null then
			self.msgBox(errors,app.getErrorString(Error),MsgBox_OK_Only, true);
		endif;
		return false;
	endif;
	
epilog

	delete specialLifts;
	app.mousePointer := self.MousePointer_Default;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="2914ea12-91b8-46c9-bed0-6660104a13c5">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

begin
	
	if self.doSave() then
		if self.myToDoTaskDesc &lt;&gt; null then
			self.getSessionAgent().setMyProxy( null ); // delete the proxy TI
			self.unloadForm();
		else
			self.doBackButtonClick();
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="9472750d-fa98-4017-8fea-7672a6a00c8d">
        <updating/>
        <source>handleBtnTwo() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

begin
	
	// 37244 handle coming from to do task complete
	if self.myToDoTaskDesc = null then
		self.doBackButtonClick();
	else
		self.getSessionAgent().setMyProxy( null ); // delete any proxy TI
		self.unloadForm();
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstSpecialLifts_displayRow" id="b28fbe52-7ea4-42c5-b310-6ee3e1886698">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSpecialLifts_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

	selected	: Boolean;
	specialLift : CM_SpecialLift;
	str : String;
	
begin

	specialLift := obj.CM_SpecialLift;
	if specialLift = null then
		return null;
	endif;
	selected := lstSpecialLifts.allMySelectedObjects.includes(obj);
	
	
	str := specialLift.description;
	if selected then
		return TableCheckBox_Selected &amp; Tab &amp; str;
	else
		return TableCheckBox_NotSelected &amp; Tab &amp; str;
	endif;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="688f730e-275c-453e-8427-bbf0dcfba0cd">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

begin

	self.lblSelect.visible := true;

	self.lstSpecialLifts.displayCollection(app.myRoot.allSpecialLifts, false, Table.DisplayCollection_Forward, null);
	self.lstSpecialLifts.clearSelected;
	
	self.lstSpecialLifts.visible := true;
								
	if self.myTrackedItem &lt;&gt; null then
		self.lstSpecialLifts.setSelected(self.myTrackedItem.allSpecialLifts);
	endif;
						
	self.doResizeControls(true);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e6df8321-4b5c-4feb-8775-986c774d5475">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

begin

	// 37244 from to do task completion
	if self.myTrackedItem = null then
		self.myTrackedItem := self.myMobileGenericAgent.myNextTiToAction;
	endif;
	app.myMobileAgent.setMyProxy( self.myTrackedItem );
	app.myMobileAgent.setMySelectedTI(self.myTrackedItem);
	
	inheritMethod();
	
	// 37244 from to do task completion
	if self.myToDoTaskDesc = null then
		self.setupCmdButtons( 2, app.getErrorString(Save), BACK_BUTTON, null, null, null );
	else
		self.setupCmdButtons( 2, app.getErrorString(Save), app.getErrorString(Back), null, null, null );
		if self.myTrackedItem &lt;&gt; null then
			self.caption := self.caption &amp; " " &amp; self.myTrackedItem.id;
		endif;
	endif;
	self.setupControls();
	self.setupInputs();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupInputs" id="dc5edf4a-3fd3-4676-8d47-677aa24075c2">
        <updating/>
        <source>setupInputs() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars

	cargoCheck	: CM_CargoCheck;
	item 		: CM_CargoCheckItem;
	toDo		: CM_ToDoTask;

begin

	self.chkToDo.visible := false;
	cargoCheck := self.myMobileGenericAgent.getEquipCheckContextFromState();
	
	if cargoCheck &lt;&gt; null then
		foreach item in cargoCheck.allCargoCheckItems discreteLock where item.requiredExtraInfo = EXTRA_INFO_SPECIAL_LIFT do	//31 May 2012	NDL Par 29038
			if item.myToDoTaskDesc &lt;&gt; null then
				self.myCargoCheckItem := item;
				self.chkToDo.visible := true;
				self.chkToDo.caption := item.myToDoTaskDesc.description;
				if self.myTrackedItem &lt;&gt; null then
					foreach toDo in self.myTrackedItem.allToDoTasksToDo where toDo.toDoTaskDescCode = item.myToDoTaskDesc.code do
						self.chkToDo.value := true;
						break;
					endforeach;
				endif;
			endif;
		endforeach;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="8f01fb36-d46e-4561-851b-85f9a00c810b">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014813, locale);
	chkToDo.translateCaption(Xlat_0014814, locale);
	lblSelect.translateCaption(Xlat_0014815, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
