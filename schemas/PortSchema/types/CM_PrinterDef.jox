    <JadeMethod name="cnEcGetDuplicate" id="6f30098d-cf76-45c8-a424-0439ad2683e7">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	logicalPrinterName : String;
	printer : CM_PrinterDef;

begin

	logicalPrinterName := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "logicalPrinterName" ).String; 
	
	if logicalPrinterName &lt;&gt; null then
		printer := app.myRoot.allPrinterDefsByLogicalName.getAtKey( logicalPrinterName );
	endif;

epilog

	return printer;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
