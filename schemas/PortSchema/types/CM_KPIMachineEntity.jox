    <JadeMethod name="jrwGetSumOfAllDelays" id="d36f0125-4a33-497f-8940-36a71862000a">
        <source>jrwGetSumOfAllDelays():Integer;
// ---------------------------------------------------------------------------
// Created:     16 December 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Total delay duration that occurred in this period in seconds
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	result, seconds	:Integer;
	delay			:CM_Delay;
	startTS, endTS, 
	ts1, ts2		:TimeStamp;
begin
	startTS	:= self.getStartTS;
	endTS	:= self.getEndTS;

	foreach delay in self.allDelays do 
		// every time reset start &amp; end
		ts1 := startTS;
		ts2 := endTS;
		if delay.startDT &gt; ts1 then
			ts1 := delay.startDT;
		endif;
		
		if delay.endDT &lt;&gt; null and delay.endDT &lt; ts2 then
			ts2 := delay.endDT;
		endif;
		seconds := ts1.getDifferenceInSeconds (ts2).rounded;
		result	:= result + seconds;
	endforeach;
	
	return result;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jrwGetSumOfGrossMoveDurations" id="3532aa7f-1a11-43dc-8e1e-d3596d743351">
        <source>jrwGetSumOfGrossMoveDurations():Integer;
// ---------------------------------------------------------------------------
// Created:     09 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Duration in seconds
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	kpiMove :CM_KPIMachineMoveDtl;
	result	:Integer;
begin
	foreach kpiMove in self.allKPIMachineMoves do
		result := result + kpiMove.grossDuration;
	endforeach;
	
	return result;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jrwGetSumOfMoveDurations" id="c6dc87f7-01c5-460d-a8fa-e4832732822f">
        <source>jrwGetSumOfMoveDurations():Integer;
// ---------------------------------------------------------------------------
// Created:     09 November 2010 by cnwcs5 par 23714/ccms 1132
