<GUIClass name="HMS_ScrollableGraphicalFrame" id="455c41df-a769-4e13-a59b-87ca0991f5d5">
    <superclass name="CMUI_ScrollableFrame"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="getVerticalHeight" id="36ef78be-5b98-417e-9ace-334b13b1335d">
        <source>getVerticalHeight(): Real;
// ---------------------------------------------------------------------------
// Created:     04 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	// as we do not resize the height of the scrollingFrame
	// return the vLabels height as this is resized
	return self.myVLabels.height;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="resetScrollHeight" id="6ef82c8e-2ff7-48a0-8249-a6051a3705b0">
        <updating/>
        <source>resetScrollHeight(_newHeight : Real) updating;
// ---------------------------------------------------------------------------
// Created:     04 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.myVLabels.height := _newHeight;

	self.repositionScrollBars();

end;</source>
        <Parameter name="_newHeight" type="Real"/>
    </JadeMethod>
    <JadeMethod name="resizeScrollingFrame" id="a525c799-8f99-4f6f-aebe-87ff75a1f8a6">
        <source>resizeScrollingFrame(pWidth: Real; pHeight: Real);
// ---------------------------------------------------------------------------
// Created:     19 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(pWidth, pHeight);
	
	//self.lblTimeNowLine.width := pWidth;

end;</source>
        <Parameter name="pWidth" type="Real"/>
        <Parameter name="pHeight" type="Real"/>
    </JadeMethod>
    <JadeMethod name="scrollControl" id="765a19a8-d1b6-421a-b73f-5a345c6e4525">
        <source>scrollControl(pDirection: Integer; pValue: Integer);
// ---------------------------------------------------------------------------
// Created:     04 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpForm	: HMS_GraphicalViewX;
	tmpReal	: Real;
begin
	if pDirection = ScrollBar_Horizontal then
		inheritMethod(pDirection, pValue);
		return;
	endif;
	
	tmpForm := self.form.HMS_GraphicalViewX;
	
	tmpForm.scrollControls(pDirection, pValue);

	if self.myVLabels &lt;&gt; null then
		tmpReal := self.myVLabels.top;
		self.myVLabels.top := -(pValue);
	endif;

end;</source>
        <Parameter name="pDirection" type="Integer"/>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
