    <JadeMethod name="resetData_43931" id="bc8cb491-9678-4e85-85a1-70d23e365828">
        <source>resetData_43931();
/*

Purpose:			Reset 43931

Parameters:			

Return Value:		

Date		Who		Reason
04/04/2019	jlgmh5	Initial creation

*/

vars

	terminal				: CM_Terminal;
	//dsl						: UT_DSL;
	ti						: Object;
	bs						: CM_BlockStack;
	operator				: CM_Operator;
	cont					: CM_TrackedItem;
	txn						: CM_TITransaction;
	voyage					: CM_Voyage;
	
	tisToDelete				: StringArray;
	tiSet					: CM_TISet;
	
	trackedItemId			: String;
		
begin	

	//app.initialize();
		
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	app.myPassport.setMyTerminal(terminal);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	// get the voyage
	voyage := self.getVoyage("MSCK000002");
	if voyage = null then
		app.writeLog("Unable to find Voyage - MSCK000002.  Exiting JadeScript...", LogINFO);
		write "Unable to find Voyage - MSCK000002.  Exiting JadeScript...";
		return;
	endif;
	
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("JLG43931013");
	tisToDelete.add("JLG4393101");
	tisToDelete.add("JLG43931");
	tisToDelete.add("JLGG4393101");
	
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			self.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;
	
	// Create cargo on site
	bs := self.getTerminalArea("MKBS01").CM_BlockStack;
	if bs = null then
		app.writeLog("Unable to find Block Stack - MKBS03.  Exiting JadeScript...", LogINFO);
		write "Unable to find Block Stack - MKBS03.  Exiting JadeScript...";
		return;
	endif;
	
	operator := app.myRoot.allOperators["O439"];
	if operator = null then
		app.writeLog("Unable to find Operator - O439.  Exiting JadeScript...", LogINFO);
		write "Unable to find Operator - O439.  Exiting JadeScript...";
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc(UTTI_VoyageCode, voyage.code);
	self.opts.addAssoc(UTTI_TotalWeight, 2500.0000.Decimal);
	self.opts.addAssoc("ReceivedDate", "02/04/2019 00:10:00");
	self.opts.addAssoc("RecTransportMode", 3);
	self.opts.addAssoc("CamsDate", "02/04/2019 00:10:00");
	cont := self.addContainerAtLocation("JLG43931013", operator, "FLTP", "GEN", 1, bs);
	self.createTransaction(cont, global.getTiTxnTypeForClass(CM_ReleaseShip), "02/04/2019 00:50:00".TimeStamp);
	
	foreach txn in cont.allTransactions discreteLock do
	
		if not txn.isKindOf(CM_ReceiveShip) then
			continue;
		endif;
		
		beginTransaction;
		txn.setCAMSTimeStamp("02/04/2019 00:10:00".TimeStamp);
		txn.setPropertyValue("dateTime", "02/04/2019 00:10:00".TimeStamp);
		commitTransaction;
	
	endforeach;
	
	
	self.opts.purge();
	self.opts.addAssoc(UTTI_VoyageCode, voyage.code);
	self.opts.addAssoc(UTTI_TotalWeight, 2500.0000.Decimal);
	self.opts.addAssoc("ReceivedDate", "02/04/2019 01:10:00");
	self.opts.addAssoc("RecTransportMode", 3);
	self.opts.addAssoc("CamsDate", "02/04/2019 01:10:00");
	
	cont := self.addContainerAtLocation("JLG4393101", operator, "FLTP", "GEN", 1, bs);
	self.createTransaction(cont, global.getTiTxnTypeForClass(CM_ReleaseShip), "02/04/2019 01:50:00".TimeStamp);
	
	foreach txn in cont.allTransactions discreteLock do
	
		if not txn.isKindOf(CM_ReceiveShip) then
			continue;
		endif;
		
		beginTransaction;
		txn.setCAMSTimeStamp("02/04/2019 01:10:00".TimeStamp);
		txn.setPropertyValue("dateTime", "02/04/2019 01:10:00".TimeStamp);
		commitTransaction;
	
	endforeach;
	
	self.opts.purge();
	self.opts.addAssoc(UTTI_VoyageCode, voyage.code);
	self.opts.addAssoc(UTTI_TotalWeight, 2500.0000.Decimal);
	self.opts.addAssoc("ReceivedDate", "02/04/2019 02:10:00");
	self.opts.addAssoc("RecTransportMode", 3);
	self.opts.addAssoc("CamsDate", "02/04/2019 02:10:00");
	cont := self.addContainerAtLocation("JLG43931", operator, "TRAI", "GEN", 1, bs);
	self.createTransaction(cont, global.getTiTxnTypeForClass(CM_ReleaseShip), "02/04/2019 02:50:00".TimeStamp);
	
	foreach txn in cont.allTransactions discreteLock do
	
		if not txn.isKindOf(CM_ReceiveShip) then
			continue;
		endif;
		
		beginTransaction;
		txn.setCAMSTimeStamp("02/04/2019 02:10:00".TimeStamp);
		txn.setPropertyValue("dateTime", "02/04/2019 02:10:00".TimeStamp);
		commitTransaction;
	
	endforeach;
	
	self.opts.purge();
	self.opts.addAssoc(UTTI_VoyageCode, voyage.code);
	self.opts.addAssoc(UTTI_TotalWeight, 2500.0000.Decimal);
	self.opts.addAssoc("ReceivedDate", "02/04/2019 03:10:00");
	self.opts.addAssoc("RecTransportMode", 3);
	self.opts.addAssoc("CamsDate", "02/04/2019 03:10:00");
	cont := self.addContainerAtLocation("JLGG4393101", operator, "2200", "GEN", 1, bs);
	self.createTransaction(cont, global.getTiTxnTypeForClass(CM_ReleaseShip), "02/04/2019 03:50:00".TimeStamp);
	
	foreach txn in cont.allTransactions discreteLock do
	
		if not txn.isKindOf(CM_ReceiveShip) then
			continue;
		endif;
		
		beginTransaction;
		txn.setCAMSTimeStamp("02/04/2019 03:10:00".TimeStamp);
		txn.setPropertyValue("dateTime", "02/04/2019 03:10:00".TimeStamp);
		commitTransaction;
	
	endforeach;
	
	

epilog

	delete tisToDelete;
	delete tiSet;
	
end;</source>
    </JadeMethod>
