    <JadeMethod name="utlUpdateInterTerminalConfig" id="abdb8fa4-7b0b-4393-ade9-92cf46e81b20">
        <source>utlUpdateInterTerminalConfig(pInterTerminalConfig : CM_InterTerminalConfig; _passport : CM_Passport input);
/*
Date				Who		Reason
08 February 2010	conkc1	Initial creation CCMS Otago 1867
*/
vars
	realInterTerminalConfig : CM_InterTerminalConfig;
	expectedEdition         : Integer;
	
begin

	self.initialiseActivity();

	pInterTerminalConfig.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pInterTerminalConfig.pxyGetRealObjectAndEdition(realInterTerminalConfig, expectedEdition);
	
	if realInterTerminalConfig = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_InterTerminalConfig.name, null, null);
		return;
	endif;

	app.myValUA.valInterTerminalConfig(realInterTerminalConfig, pInterTerminalConfig);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realInterTerminalConfig);
	exclusiveLock(realInterTerminalConfig.myRelease);

	realInterTerminalConfig.myRelease.updateFromProxy(pInterTerminalConfig.myRelease);

	if _passport.noErrors and realInterTerminalConfig.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'InterTerminalConfig', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInterTerminalConfig, true);
	endif;
	
	if _passport.noErrors then
		realInterTerminalConfig.setForUpdate(pInterTerminalConfig);
	endif;

	if _passport.noErrors then
		realInterTerminalConfig.updateTargetTerminalInfo(pInterTerminalConfig);
	endif;

	if _passport.noErrors then
		realInterTerminalConfig.updateSelectedTerminalAreas(pInterTerminalConfig);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInterTerminalConfig, false);
	endif;

epilog

end;</source>
        <Parameter name="pInterTerminalConfig" type="CM_InterTerminalConfig"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
