    <JadeMethod name="calAssignedAmount" id="08a39056-51bb-4f7e-b3f1-976259f3b9aa">
        <source>calAssignedAmount(_uom : String): Real;
//--------------------------------------------------------------
//Created: 19 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	rtnAmount : Real;
	bolExt : CM_BOLExtLogOut;
begin
	
	foreach bolExt in self.allBOLExtLogOuts do
		if _uom = BOL_UOM_VOLUME then
			rtnAmount := rtnAmount + bolExt.jasVolume;
		elseif _uom = BOL_UOM_WEIGHT then
			rtnAmount := rtnAmount + bolExt.myBOL.getTotalTIWeight;		
		else
			rtnAmount := rtnAmount + bolExt.myBOL.numTIs;		
		endif;
	endforeach;
	return rtnAmount;
end;</source>
        <Parameter name="_uom" type="String"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="checkCanBeDelete" id="a781491f-5d6c-49ff-9252-d90488a9b3f7">
        <source>checkCanBeDelete() : Boolean;
//--------------------------------------------------------------
//Created: 22 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	exclusiveLock(self);
	if (not self.allLogStockOrderLines.isEmpty) then
		return false;
	endif;
	if (not self.allBOLExtLogOuts.isEmpty) then
		return false;
	endif;
	if (not self.allLocationsByHatchPlace.isEmpty) then
		return false;
	endif;
	
	return true;
			
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkProductOrdered" id="f6b42881-74bc-4be4-aa03-fd14c479208a">
        <source>checkProductOrdered(_product : CM_Product) : Boolean;
//--------------------------------------------------------------
//Created: 12 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	order : CM_LogStockOrderLine;
begin
	if _product = null then
		return false;
	endif;
	
	foreach order in self.allLogStockOrderLines do
		if order.myProduct = _product then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_product" type="CM_Product"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="erase" id="27349740-b0d5-41f6-8a3b-6873a69c1a58">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//--------------------------------------------------------------
//Created: 20 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if (not self.isTransient) then
//		global.causeEvent(self.myLogVoyage.myTerminal.getTerminalEvent(LogLot_Delete_Event), false, self);		
		global.causeEvent(self.myLogVoyageStructure.myVoyage.myTerminal.getTerminalEvent(LogLot_Delete_Event), false, self);		
	endif;
	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllOperators" id="ba1301da-7fb5-45a7-88b0-1d73ba12a54d">
        <source>getAllOperators(_allOperators : CM_OperatorSet input);

vars

	logVoyageController : CM_LogVoyageController;
	iter				: Iterator;

	

begin

	iter := self.allLocationsByHatchPlace.createIterator;
	while iter.next(logVoyageController) do
		logVoyageController.getAllOperators(_allOperators);
	endwhile;

epilog
	delete iter;
end;</source>
        <Parameter name="_allOperators" type="CM_OperatorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllocatedLogRows" id="3e3deff3-bd66-49e3-8a10-7a6847025ea1">
        <source>getAllocatedLogRows(_locnSet : CM_LCSet input);
//--------------------------------------------------------------
//Created: 19 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	order : CM_LogStockOrderLine;
begin
	foreach order in self.allLogStockOrderLines do
		order.getAllocatedLocations(_locnSet);
	endforeach;
end;</source>
        <Parameter name="_locnSet" type="CM_LCSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="e26fa3a5-24aa-457d-ad92-3cd6e879be9b">
        <source>getMyTerminal():CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2014	cnwndl1	Initial creation	Par 33264

*/

vars

	error : Boolean;

begin

	on Exception do app.handleDeletedObject( exception, self.myLogVoyageStructure.myVoyage, error );

	if self.myLogVoyageStructure.myVoyage &lt;&gt; null then
		if self.myLogVoyageStructure.myVoyage.myTerminal &lt;&gt; null then
			return self.myLogVoyageStructure.myVoyage.myTerminal;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getOperatorsForLot" id="f8b5d781-0ea3-44bb-b3ac-e7b4b01384c8">
        <source>getOperatorsForLot(_operatorSet : CM_OperatorSet input);
//--------------------------------------------------------------
//Created: 19 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	order : CM_LogStockOrderLine;
	voyOper : CM_VoyageOperator;
begin
	foreach order in self.allLogStockOrderLines do
		voyOper := order.getMyVoyageOperator();
		if voyOper &lt;&gt; null then
			if (not _operatorSet.includes(voyOper.myOperator)) then
				_operatorSet.add(voyOper.myOperator);
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="_operatorSet" type="CM_OperatorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSpecsForOperator" id="d637e623-a9d5-4657-8fe6-04320d8d535f">
        <source>getSpecsForOperator(	_operator 	: CM_Operator;
						_allSpecies,
						_allGrades : CM_CodeSet input);

vars

	iter 				: Iterator;
	logVoyageController	: CM_LogVoyageController;

begin

	iter := self.allLocationsByHatchPlace.createIterator;
	while iter.next(logVoyageController) do
		logVoyageController.getSpecsForOperator(_operator,_allSpecies,  _allGrades);
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_allSpecies" type="CM_CodeSet" usage="input"/>
        <Parameter name="_allGrades" type="CM_CodeSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getStevedoresForLot" id="111601d3-b9f1-47ac-8b0c-58946bbeedbd">
        <source>getStevedoresForLot(_stevedoreDict : CM_StevedoreByCodeDict input);
//--------------------------------------------------------------
//Created: 19 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	order : CM_LogStockOrderLine;
	voyOper : CM_VoyageOperator;
	tmpStevedore : CM_Stevedore;
begin
	foreach order in self.allLogStockOrderLines do
		voyOper := order.getMyVoyageOperator();
		if voyOper &lt;&gt; null then
			tmpStevedore := app.myRoot.allStevedores[voyOper.stevedoreCode1];
			if tmpStevedore &lt;&gt; null then
				if (not _stevedoreDict.includes(tmpStevedore)) then
					_stevedoreDict.add(tmpStevedore);
				endif;
			endif;
			tmpStevedore := app.myRoot.allStevedores[voyOper.stevedoreCode2];
			if tmpStevedore &lt;&gt; null then
				if (not _stevedoreDict.includes(tmpStevedore)) then
					_stevedoreDict.add(tmpStevedore);
				endif;
			endif;			
		endif;
	endforeach;
end;</source>
        <Parameter name="_stevedoreDict" type="CM_StevedoreByCodeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="myConsignee" id="84c82d98-adb4-4223-87c0-547f19d5e9cb">
        <methodInvocation>mapping</methodInvocation>
        <source>myConsignee(set: Boolean; _value: CM_ConsigneeConsignor io) mapping;
//--------------------------------------------------------------
//Created: 19 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	order : CM_LogStockOrderLine;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.allLogStockOrderLines.size &gt; 0 then
		order := self.allLogStockOrderLines.first;
		_value := order.myConsignee;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_ConsigneeConsignor" usage="io"/>
    </JadeMethod>
