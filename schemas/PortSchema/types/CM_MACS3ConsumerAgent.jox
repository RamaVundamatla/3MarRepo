    <JadeMethod name="doSendCheckCreditReq" id="96dbcaac-6a80-4c9f-922a-ecc9d40f4884">
        <updating/>
        <source>doSendCheckCreditReq(_remainingCredits: Decimal output): Boolean updating;
//
// Purpose:			Gets the remaining credits a customer has left on their account.
//					As this API doesn't seem stable, this is just a best effort call.
//
// Parameters:			
//
// Return Value:	false if the call fails for any reason
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/03/2021	navmd1		Initial creation TFS 49052 MACS3 Vessel Library API
//
vars
	httpHeader,
	jsonResponse	: String;
	resultCode		: Integer;
	
	parser			: JadeJson;
	parsingError	: Boolean;
	transObjs		: ObjectArray;
	response		: CMIF_MACS3BillingResponse;
begin
	// Don't log these requests
	self.createActivityHistory := false;
	
	jsonResponse := self.doSendHTTPRequest(	self.BillingEndpoint,
											"GET",
											CM_MACS3ConsumerAgent.HTTPHeader &amp; self.apiKey,
											null,
											resultCode	);
	
	if resultCode &lt;&gt; HttpResponseOK then
		app.writeLog(method.qualifiedName &amp; "Error - Result Code: " &amp; resultCode.String, LogWARN);
		return false;
	endif;
	
	create parser transient;
	create transObjs transient;
	
	on Exception do self.handleJSONException(exception, parsingError);
	
	response := parser.parse(jsonResponse, CMIF_MACS3BillingResponse, transObjs).CMIF_MACS3BillingResponse;
	if response = null or parsingError then
		app.writeLog(method.qualifiedName &amp; "Error - Unable to parse Billing response", LogWARN);
		return false;
	endif;
	
	_remainingCredits := response.availableCredits;
	
	// This technically doesn't need to be INFO, but the other sendHTTP messages are, so this makes sense to be too
	app.writeLog(method.qualifiedName &amp; " Credits Remaining: " &amp; _remainingCredits.String, LogINFO);
	
	return true;
epilog
	delete parser;
	if transObjs &lt;&gt; null then
		transObjs.purge();
	endif;
	delete transObjs;	// found by unit tests
	
	// Turn logging back on
	self.createActivityHistory := true;
end;</source>
        <Parameter name="_remainingCredits" type="Decimal" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSendHTTPRequest" id="29150e61-11c8-406a-909e-75ada216bb69">
        <updating/>
        <source>doSendHTTPRequest(_url: String; _verb: String; _additionalHeaders: String; _putPostData: String; _resultCode: Integer output): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
03 February 2021	jlgmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

vars
	headers		: String;
begin
	if self.feedId &lt;&gt; null then
		headers := _additionalHeaders &amp; CrLf &amp; CM_MACS3ConsumerAgent.TargetFeedHeader &amp; self.feedId;
	endif;

	app.writeLog(method.qualifiedName &amp; Tab &amp; "Sending HTTP Request to MACS3", LogINFO);
	app.writeLog(method.qualifiedName &amp; Tab &amp; "url is " &amp; _verb &amp; " '" &amp; _url &amp; "'", LogINFO);
	app.writeLog(method.qualifiedName &amp; Tab &amp; "timeout (seconds) is '" &amp; self.timeoutSeconds.String &amp; "'", LogINFO);
	app.writeLog(method.qualifiedName &amp; Tab &amp; "additional header is '" &amp; headers &amp; "'", LogDEBUG);
	
	return inheritMethod(_url, _verb, headers, _putPostData, _resultCode);

epilog

end;</source>
        <Parameter name="_url" type="String"/>
        <Parameter name="_verb" type="String"/>
        <Parameter name="_additionalHeaders" type="String"/>
        <Parameter name="_putPostData" type="String"/>
        <Parameter name="_resultCode" type="Integer" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doSendProdMetaReq" id="f616f0a1-2d40-4a6d-ad9a-d89fe70840d0">
        <updating/>
        <source>doSendProdMetaReq(): String updating;
//
// Purpose:			A quick call to check the MACS3 API contains vessel information for our given IMO.
//					It also indicates whether a JSON files exists, and what version that file is.
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/03/2021	navmd1		Initial Creation TFS 49052 MACS3 Vessel Library API
//
vars
	url,
	httpHeader,
	jsonResponse	: String;
	resultCode		: Integer;
begin
	if self.myVessel = null then
		app.raiseUnexpectedProgramError(class.name, method.name, " vessel is null");
		return null;
	endif;

	url := self.baseEndpoint &amp; "v1/vessels/" &amp; self.myVessel.lloydsNumber &amp; "/" &amp; CM_MACS3ConsumerAgent.MethodProdMetaData;
	jsonResponse := self.doSendHTTPRequest(	url,
											"GET",
											CM_MACS3ConsumerAgent.HTTPHeader &amp; self.apiKey,
											null,
											resultCode	);
	
	if resultCode &lt;&gt; HttpResponseOK then
		self.handleBadResponse(resultCode);
		return null;
	endif;
		
	// success
	self.updateActivityHistory(true);

	return jsonResponse;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doSendVesselProfileReq" id="7d49d5cc-ebc8-4de7-a4aa-b3f9a749ae6f">
        <updating/>
        <source>doSendVesselProfileReq(): String updating;
//
// Purpose:			The original call to get vessel information from the MACS3 API.
//					This seems to be superseded by the v2 Vessel Versions call instead.
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/04/2020	jlgdap1		Initial creation TFS 49003 MYN API Inline Agent
// 02/03/2021	navmd1		TFS 49052 MACS3 Vessel Library API
//
vars
	url,
	httpHeader,
	jsonResponse	: String;
	resultCode		: Integer;
begin
	if self.myVessel = null then
		app.raiseUnexpectedProgramError(class.name, method.name, " vessel is null");
		return null;
	endif;

	url := self.baseEndpoint &amp; "v1/vessels/" &amp; self.myVessel.lloydsNumber &amp; "/" &amp; CM_MACS3ConsumerAgent.MethodVesselProfiles &amp;
			"/" &amp; self.myVessel.myCellularVesselStructure.definitionVersion.String &amp; "/json";
	jsonResponse := self.doSendHTTPRequest(	url,
											"GET",
											CM_MACS3ConsumerAgent.HTTPHeader &amp; self.apiKey,
											null,
											resultCode	);
	
	if resultCode &lt;&gt; HttpResponseOK then
		self.handleBadResponse(resultCode);
		return null;
	endif;
		
	// success
	self.updateActivityHistory(true);
	
	return jsonResponse;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doSendVesselVersionsReq" id="04845d96-4432-43da-b632-c5d7a7726c66">
        <updating/>
        <source>doSendVesselVersionsReq(): String updating;
//
// Purpose:			Gets the json file for the specified version/imo.
//					Also correctly logs/uses customer credits.
//					As we can now specify 'latest' as the version string, we probably don't really need to call productive-metadata anymore either.
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/03/2021	navmd1		Initial creation TFS 49052 MACS3 Vessel Library API
//
vars
	url,
	httpHeader,
	jsonResponse	: String;
	resultCode		: Integer;
begin
	if self.myVessel = null then
		app.raiseUnexpectedProgramError(class.name, method.name, " vessel is null");
		return null;
	endif;

	url := self.baseEndpoint &amp; "v2/vessels/" &amp; self.myVessel.lloydsNumber &amp; "/" &amp; CM_MACS3ConsumerAgent.MethodVesselVersions &amp;
			"/" &amp; self.myVessel.myCellularVesselStructure.definitionVersion.String &amp; "/json";
	jsonResponse := self.doSendHTTPRequest(	url,
											"GET",
											CM_MACS3ConsumerAgent.HTTPHeader &amp; self.apiKey,
											null,
											resultCode	);
	
	if resultCode &lt;&gt; HttpResponseOK then
		self.handleBadResponse(resultCode);
		return null;
	endif;
		
	// success
	self.updateActivityHistory(true);
	
	return jsonResponse;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleBadResponse" id="3df80e99-bd6b-4273-8f47-aecd8ad82d44">
        <source>handleBadResponse(_resultCode : Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
03 February 2021	jlgmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

vars

begin
	if _resultCode = null then
	
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Web Service MACS3 timed out", LogERROR);
		app.raiseCMException1(MACS3_BAD_RESPONSE, "Web Service MACS3 timed out", null, null);
	
	elseif _resultCode = HttpResponseNotFound then
	
		app.writeLog(method.qualifiedName &amp; Tab &amp; "resultCode is 404 " &amp; app.getErrorString(MACS3_UNKNOWN_IMO), LogINFO);
		app.raiseCMException1(MACS3_BAD_RESPONSE, app.getErrorString1(MACS3_UNKNOWN_IMO, self.myVessel.lloydsNumber), CM_Vessel::lloydsNumber.name, self.myVessel);
	
	elseif _resultCode = HttpResponseForbidden then
		
		app.writeLog(method.qualifiedName &amp; Tab &amp; "resultCode is 403 - Authorisation Error", LogERROR);
		app.raiseCMException1(MACS3_BAD_RESPONSE, "Authorisation Error - Check API Key", null, null);
	
	else
	
		app.writeLog(method.qualifiedName &amp; Tab &amp; "resultCode is " &amp; _resultCode.String, LogERROR);
		app.raiseCMException1(MACS3_BAD_RESPONSE, _resultCode.String, null, null);
	
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_resultCode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupFromWebServiceDefinition" id="14e607e7-61d4-42e9-a9a2-de770319ff86">
        <updating/>
        <source>setupFromWebServiceDefinition(_definition: CM_ExternalWebServiceDef) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 February 2021	jlgmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

vars

begin
	inheritMethod(_definition);

	// Force the endpoint to end in a forward slash
	if self.baseEndpoint[self.baseEndpoint.length:end] &lt;&gt; "/" then
		self.baseEndpoint := self.baseEndpoint &amp; "/";
	endif;
	
	self.apiKey 			:= _definition.CM_NavisMACS3Service.apiKey;
	self.feedId 			:= _definition.CM_NavisMACS3Service.feedId;
epilog

end;</source>
        <Parameter name="_definition" type="CM_ExternalWebServiceDef"/>
    </JadeMethod>
</Class>
