<Class name="SOPTM_DataAccessConsignee" id="84e73976-f2c7-48c6-a401-8d26968102fc">
    <superclass name="SOPTM_DataAccess"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="sysops"/>
    <JadeMethod name="create" id="dc3a7348-d0c8-431f-a4f3-c741c60aa665">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     17 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.name := SOP_TableMaintForm.Table_DataAccessConsignees;
	self.permissionView	 := PmCmpDAConsigneeOrTableView;
	self.permissionMaint := PmCmpDAConsigneeOrTableMaint;

end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayHeading" id="f7bec2a2-d851-477f-8ecc-ec006e783626">
        <source>getDisplayHeading(): String;
// ---------------------------------------------------------------------------
// Created:     11 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	return 	 app.getTerminologyAlternate(null, null, 'Consignee', CM_TermExpressionPlural, 'Consignees') &amp; '/' &amp;
			app.getTerminologyAlternate(null, null, CM_TerminologyConsignor, CM_TermExpressionPlural, 'Consignors') &amp; ' Data Access Groups';
			
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="18db9468-9200-4f8e-b760-96b1c971fcff">
        <source>setupThumbnailDetails();

vars
	theForm : SOP_TableMaintForm;

begin
  
    theForm := self.myForm;
// par 10009
//	theForm.setupForDataAccessController('Consignees/Consignors', 'displayEntryConsignee', CM_ConsigneeConsignor);
	theForm.setupForDataAccessController(app.getTerminologyAlternate(null, null, 'Consignee', CM_TermExpressionPlural, 'Consignees') &amp; '/' &amp; 
								app.getTerminologyAlternate(null, null, CM_TerminologyConsignor, CM_TermExpressionPlural, 'Consignors'), 
								'displayEntryConsignee', CM_ConsigneeConsignor);

	
	theForm.mulSelect1.setAvailable(app.myRoot.allConsigneeConsignors, true);

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="1a710caf-d149-45fe-bf61-5ab956d07f60">
        <updating/>
        <source>showThumbnail(pDataAccess : CM_DataAccessController) updating;

vars

	theForm : SOP_TableMaintForm;

begin
   
    theForm := self.myForm;

  	theForm.chkIncludeNotSet.visible := true; // AKB2004SEP
 //	theForm.shtMultiSelect1.caption := "Consignee/or";
	theForm.chkIncludeNotSet.value := pDataAccess.includeIfNull;

	theForm.txtName.text := pDataAccess.name;
	theForm.optAllow.value	:= (not pDataAccess.mustNotBeIncluded);
	theForm.optDisallow.value := pDataAccess.mustNotBeIncluded;
	theForm.setMSHeadingsForDataAccess();
	theForm.mulSelect1.setSelected(pDataAccess.allObjects);
	self.disableMulSelect1Contents();
end;</source>
        <Parameter name="pDataAccess" type="CM_DataAccessController"/>
    </JadeMethod>
    <JadeMethod name="tblDataDisplayRow" id="39da557a-e4a6-491d-a796-fd9bbb58297b">
        <source>tblDataDisplayRow(table: Table input; obj: Object): String;

vars

begin
	
	if obj.CM_DataAccessController.classContainedName = CM_ConsigneeConsignor.name then //7.3.09 cnwgb1 PAR 19041
		return inheritMethod(table, obj);
	else
		return null;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
