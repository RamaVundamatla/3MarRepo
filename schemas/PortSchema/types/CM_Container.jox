    <JadeMethod name="getConvertedLengthIn" id="5d57dccf-58e5-44b5-8913-bef0b046f5de">
        <source>getConvertedLengthIn(_shortName: String): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
