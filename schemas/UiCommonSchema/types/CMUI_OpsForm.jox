    <JadeMethod name="displayAllWLEsForObj" id="d065c71e-5442-4272-a291-3473b6b20794">
        <updating/>
        <source>displayAllWLEsForObj(pObject : CM_Object)updating;
//-----------------------------------------
//Created: March 2003 By: cnwgd1
//-----------------------------------------
vars
	saveObj		: Object;
	idx			: Integer;
	wleArray	: CM_WLEArray;
begin

	saveObj := lstJobs.listObject;
	
	create wleArray transient;

	if pObject &lt;&gt; null then	
		pObject.getAllWLEs(wleArray);
	endif;
	
	self.displayWLEs(wleArray);

	if saveObj &lt;&gt; null then
		idx := self.lstJobs.findObject(saveObj);
		if idx &gt; 0 then
			lstJobs.listIndex := idx;
			lstJobs.listObject := saveObj;
			// sgp 15 July 2003 : Don't expand when item selected.
			// Only expand when click the +/- or picture.  This is
			// consistent with the voyage ops form.
//			lstJobs.itemExpanded[idx] := true;
			return;
		endif;
	endif;

	if lstJobs.listCount &gt; 0 then
		lstJobs.listIndex := 1;
		lstJobs.listObject := lstJobs.itemObject[1];
	endif;

epilog
	delete wleArray;
end;</source>
        <Parameter name="pObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="displayExtraInfoForObj" id="c75eb716-2531-4535-87e3-4b46cf830ff1">
        <source>displayExtraInfoForObj(_obj : CM_Object);
//--------------------------------------------------------------
//Created: 18 March 2003 By: cnwgd1
//
// Changed On   Changed By  Reason
// ----------   ----------  ------------------------------------
// 25/05/2009	consw1		PAR 19710 - SFW1067 Rail Simplifications
//--------------------------------------------------------------
vars
	wle 		: CM_WorkListEntry;
	dataContainer : CM_DataContainer;
begin

	self.tblInfo.clear();
	self.tblInfo.rows := 0;

	self.tblInfoSmall.clear();
	self.tblInfoSmall.rows := 0;
	
	if (not CM_Object.hasInstance(_obj)) then
		return;
	endif;
	

	create dataContainer transient;
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;
			
	if _obj &lt;&gt; null and _obj.isKindOf(CM_Object) then
		self.getExtraInfoForObj(_obj.CM_Object, dataContainer);
		self.showExtraInformation(dataContainer, self.tblInfo, true, false, 4, 1, 1, 1, 1);
		self.doResizeColumnWidths(self.tblInfo, true);
		self.showExtraInformation(dataContainer, self.tblInfoSmall, true, false, 4, 1, 1, 1, 1);
		self.doResizeColumnWidths(self.tblInfoSmall, true);
	endif;
	

	
epilog
	if dataContainer &lt;&gt; null then
		delete dataContainer;
	endif;

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="displayInfoFromArray" id="21f57462-fa2c-4356-9d20-e90926cb1b98">
        <source>displayInfoFromArray(pExtraInfo : HugeStringArray);
// ---------------------------------------------------------------------------
// Created:		November  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	str	: String;
	tmpWidth : Real;
	row1,
	row2,
	idx	: Integer;
begin
	if pExtraInfo = null or pExtraInfo.isEmpty then
		return;
	endif;
	foreach idx in 1 to pExtraInfo.size do
		str := pExtraInfo[idx];
		str.replaceChar(Cr," ");
		str.replaceChar(Lf," ");
		if str &lt;&gt; "" then
			if str.cnContains('WARNING') then
				row1 := 1;
				row2 := 1;
				self.tblInfo.addItemAt(str, row1);
				self.tblInfoSmall.addItemAt(str, row2);
				self.tblInfo.accessRow(row1).backColor := Red;				
				self.tblInfoSmall.accessRow(row2).backColor := Red;				
				self.tblInfo.accessRow(row1).fontBold := true;				
				self.tblInfoSmall.accessRow(row2).fontBold := true;							
				self.tblInfo.accessRow(row1).foreColor := White;				
				self.tblInfoSmall.accessRow(row2).foreColor := White;											
			else
				row1 := self.tblInfo.addItem(str);
				row2 := self.tblInfoSmall.addItem(str);			
				self.tblInfo.accessRow(row1).backColor := colorControlBack;			
				self.tblInfoSmall.accessRow(row2).backColor := colorControlBack;						
			endif;
		endif;
	endforeach;

	self.tblInfo.accessColumn(1).width := 150;
	
	tmpWidth := self.tblInfo.width - 150 - app.getVerticalScrollbarWidth - 2;
	if tmpWidth &gt; 300 then
		self.tblInfo.accessColumn(2).width := tmpWidth.Integer;
	endif;	
end;</source>
        <Parameter name="pExtraInfo" type="HugeStringArray"/>
    </JadeMethod>
