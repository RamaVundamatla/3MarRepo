    <JadeMethod name="addObjectsToTable" id="b5c39dfe-b534-44d3-b24b-45b69031853b">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aInvoiceTermsOfTrade : CM_InvoiceTermsOfTrade;
	theInvoiceTermsOfTrades :	CM_InvTermsOfTradeByCode;
	tmpPassport	: CM_Passport;
	breakOut	: Boolean;
begin

	self.setMyDataClass();
	beginClassNotification(CM_InvoiceTermsOfTrade, false, Object_Create_Event, Response_Continuous, 0); 

	theInvoiceTermsOfTrades := app.myRoot.myRootCompany.allInvoiceTermsOfTrade;
	tmpPassport := app.myPassport;
	
	foreach aInvoiceTermsOfTrade in theInvoiceTermsOfTrades do
		if self.includeObject(aInvoiceTermsOfTrade, tmpPassport) then
			self.addObjectToTable(aInvoiceTermsOfTrade, _numItems, breakOut);
		endif;
		if breakOut then
			break;
		endif;
	endforeach;

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
