    <JadeMethod name="makeMessages" id="0f7cc037-8d34-4cf1-bfc5-fbc65d2bbf42">
        <source>makeMessages(_trackedItem: CM_TrackedItem; _transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camMessage: CM_CamMessage input; _xlVoyageId: String; _terminal: CM_Terminal; _secondTrx : CM_TITransaction);
// ---------------------------------------------------------------------------
// Created:     21 March 2011 by cnwcs5 CCMS PNL 2057 / PAR 27231
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/05/2011	cnwcs5		par 27553 - mandatory TDT+1 &amp; LOC+7 in group 7
// 10 May 2011	cnwcs5		CCMS SCT 2058/par 27460 - user defined special characters
// 30/05/2016	cnwdap1		TFS #2061 COPARN/CODECO/COARRI/EDI VGM Updates
// 07/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
// 23/08/2017	cnwma1  TFS #5834-PNL - EDI Translation - ISO Code foreign out
// 19 Sep 2017	jlgrs1	TFS 6957 Codeco/Coarri VGM extra details
// 25 Sep 2018 	jlggb1	TFS 40947 Correction to TFS 36713
// 21 Jun 2022	jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
// ---------------------------------------------------------------------------
vars
	fCode, code, pCode 	: String;
	temp, carrierCode	: String;
	ti 					: CM_TrackedItem;
	exportVoyage, callSign, lloydsNumber, vesselName : String;	// par 27553
	contentsStatus : String;
	isoCode,fIsoCode : String;
	includeVGM : Boolean;
begin
// MOT
	ti := _transaction.myTrackedItem;
	if _camProtocol.useVGM and 
	   _camProtocol.getIncludeExtraVGM and
	   ti &lt;&gt; null and 
	   ti.isWeightCertified and 
	   not ti.isEmpty then		// TFS #2061
		includeVGM := true;
	endif;
	contentsStatus := self.contentsStatusToString(_transaction.contentsStatus,_camMessage.activity, _transaction.type);

	// EQD segment
	//self.makeEQDSegment (_camProtocol, _camMessage.group3, "CN", ti.id.trimRight, ti.CM_Container.isoType, '102', '5', null, self.imExStatusToString(ti),  //23/08/2017 cnwma1 TFS #5834
	//					 contentsStatus); // par 27460 09/05/2011 cnwcs5 	
	isoCode := ti.CM_Container.isoType;
	fIsoCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, isoCode, XLATION_TYPE_ISOTYPE_BYOP, _terminal);
	self.makeEQDSegment (_camProtocol, _camMessage.group3, "CN", ti.id.trimRight,fIsoCode, '102', '5', null, self.imExStatusToString(ti),  //23/08/2017 cnwma1 TFS #5834
						 contentsStatus); //23/08/2017 cnwma1 TFS #5834
	_camMessage.eqdCount := _camMessage.eqdCount + 1;

	// RFF+BN
	self.makeMessageRFF_BN (_camProtocol, _camMessage.group3,  ti);	// par 27460 cnwcs5

	// RFF+CN
	self.makeMessageRFF_CN (_camProtocol, _camMessage.group3, ti);	// par 27460 cnwcs

	// RFF+ABT
	self.makeMessageRFF_ABT (_camProtocol, _camMessage.group3,  _camMessage.activity, ti);	// par 27460 cnwcs5	

	// DTM - transaction date/time
	self.makeDTMSegment(_camProtocol, _camMessage.group3, self.getDTMFormatQualifier(_camProtocol), _transaction.dateTime, "203"); // TFS 53754
	if includeVGM then
		self.makeMessageDTM_VGM(_camProtocol, _camMessage.group3, ti);					// TFS 4492
	endif;
	
	// LOC segments
	self.makeMessageLOC (_camProtocol, _camMessage.group3, _camMessage.activity, ti);	// par 27460 cnwcs5

	// MEA - weight
	self.makeMEASegmentForTotalWeight(_camProtocol, _camMessage.group3,ti,null); //epr par 37551 TFS 1429 16/2/16

	// DIM+ segment
	self.makeMessageDimensionsData (_camProtocol, _camMessage.group3, ti);		// par 27460 09/05/2011 cnwcs5

	// TMP Segment
	self.makeTMPSegment (_camProtocol, _camMessage.group3, 2, ti.getTemperature, "CEL");	// par 27460 09/05/2011 cnwcs5 				

	//the SEL for the seal number
	self.makeMessageSealsData( ti, _camMessage, _camMessage.group3, _camProtocol, contentsStatus);	

	// FTX+AAA+++&lt;goods description&gt;
	temp := ti.getCommodityDesc;
	
	if temp &lt;&gt; null then
		self.makeFTXSegment (_camProtocol, _camMessage.group3, "AAA", null, null, temp);	// par 27460 cmwcs5
	endif;
	
	// Dangerous Goods
	self.makeMessageHazardsData (ti, _camProtocol, _camMessage.group3);	// par 27460 09/05/2011 cnwcs5 	
	
	// EQA - the only attached equipment is a reefer generator
	self.makeEQASegment (_camProtocol, _camMessage.group3, 'RG', ti);	// par 27460 09/05/2011 cnwcs5
	
	// ECN/MOT requirement PIA+5+&lt;goods description&gt;:ZZZ
	code 	:= ti.commodity.trimRight;
	fCode 	:= self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_COMMODITY_BYOP, _terminal);
	
	if fCode = null then
		fCode := code.trimRight;
	endif;
	
	if fCode &lt;&gt; null then
		self.makePIASegment (_camProtocol, _camMessage.group3, 5, fCode, "ZZZ");	// par 27460 cmwcs5
	endif;

	// ECN/MOT Requirement - TDT+30 (on carriage transport in segment 5)
	// par 27553 - mandatory TDT+30 in group 5
	if ti.isTranshipItem and ti.myExportVoyage &lt;&gt; null and _transaction.getMyVoyage &lt;&gt; ti.myExportVoyage then
		// only has values if tranship
		exportVoyage 	:= ti.myExportVoyage.code;						
		callSign		:= ti.myExportVoyage.callSign.trimRight;
		lloydsNumber	:= ti.myExportVoyage.lloydsNumber;
		vesselName		:= ti.myExportVoyage.vesselName.trimRight.toUpper;
	
		if ti.myExportVoyage.myOperator &lt;&gt; null then	
			code 	:= ti.myExportVoyage.myOperator.code;
			fCode 	:= self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_CARRIER_BYOP, _terminal);
					
			if fCode = null then
				fCode := code;
			endif;
			
			carrierCode := fCode;
		endif;
		if _camProtocol.camGroup.useCallSign then
			self.makeTDT30Segment (_camProtocol, _camMessage.group3, exportVoyage, '1', null, carrierCode, '172', '20', null, null, callSign, '103', null, vesselName); // 25/9/2018 jlggb1 40947		
		else
			self.makeTDT30Segment (_camProtocol, _camMessage.group3, exportVoyage, '1', null, carrierCode, '172', '20', null, null, lloydsNumber, '146', null, vesselName); // 25/9/2018 jlggb1 40947		
		endif;
	else
		// par 27553 - mandatory TDT+30 in group 5
		self.makeTDT30Segment (_camProtocol, _camMessage.group3, null, null,null, null, null, null, null, null, null, null, null, null);	// par 27460 cnwcs5
	endif;
	
	// ECN/MOT Requirement - LOC+7+&lt;place of delivery&gt;
	if _camMessage.activity = COARRI_SHIPLOAD then
		code := ti.loadPort.trimRight;
	elseif _camMessage.activity = COARRI_SHIPDISCHARGE then
		code := ti.dischargePort.trimRight;
	endif;

	fCode 	:= self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, _terminal);
	
	if fCode = null then
		fCode := code.trimRight;
	endif;

	// par 27553 - mandatory TDT+30 in group 5
	self.makeLOCSegment (_camProtocol, _camMessage.group3, '7', fCode, '139', '6', null, null, null);	// par 27460 cnwcs5
	
	// NAD+CF
	self.makeMessageNAD_CF (_camProtocol, _camMessage.group3, ti);	// par 27460 cnwcs5	
	
	// TFS #2061 NDA for VGM																			// TFS #2061
	if includeVGM then				// TFS #2061
		self.makeMessageNAD_VGM(_camProtocol, _camMessage.group3, ti);									// TFS #2061
	endif;																								// TFS #2061
end;
</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_xlVoyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_secondTrx" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_DTM_ArriveDepart" id="90c09950-a8e8-4edf-bee9-713194b981cb">
        <updating/>
        <source>outputHeader_DTM_ArriveDepart(_camTaskHistory :CM_CamTaskHistory input; _protocol :CM_CamProtocol; _camVoyage :CM_CamVoyage; _count :Integer io; _coll :HugeStringArray input) : String updating, protected;
/*
Purpose: 	Refactored code	

Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//04 Jul 2022	jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
vars
	voyage	:CM_Voyage;
	strDT	:String;
	strLine : String;
begin
	voyage := _camVoyage.voyageOid;
	
	if voyage = null then
		return null;	
	endif;
	
	//DTM header for arrival and departue date/times
	// 132 = arival, 133 = departure
	if voyage.departedDT.date.isValid then
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeDTMSegment (_protocol, null, '133', voyage.departedDT, '203'), _coll);
		_count := _count + 1;
	endif;
	
	if voyage.arrivedDT.date.isValid then
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeDTMSegment (_protocol, null, '132', voyage.arrivedDT, '203'), _coll);
		_count := _count + 1;
	endif;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camVoyage" type="CM_CamVoyage"/>
        <Parameter name="_count" type="Integer" usage="io"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_LOC" id="a4ab95d9-8859-46ca-86ce-f83d29391128">
        <updating/>
        <source>outputHeader_LOC(_camTaskHistory :CM_CamTaskHistory input; _protocol :CM_CamProtocol; _activity :Integer;_count :Integer io; _coll :HugeStringArray input) : String updating, protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	terminal	:CM_Terminal;
	code, fCode	:String;
	strLine : String;
begin
	terminal	:= _protocol.terminal;
	
	code 		:= terminal.getConfig(PortDestCode).String;
	fCode 		:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal).trimRight;

	if _activity = COARRI_SHIPLOAD then
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeLOCSegment (_protocol, null, '9',  fCode, '139', '6', _protocol.camGroup.facilityCode, "TER", "ZZZ"), _coll);
		_count := _count + 1;
	else
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeLOCSegment (_protocol, null, '11',  fCode, '139', '6', _protocol.camGroup.facilityCode, "TER", "ZZZ"), _coll);
		_count := _count + 1;
	endif;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_count" type="Integer" usage="io"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_NAD" id="21b25e7f-6468-4f38-955e-56e5a0fbd447">
        <updating/>
        <source>outputHeader_NAD(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _camMessage :CM_CamMessage input; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	code, fCode	:String;
	strLine : String;
begin
	// ECN/MOT Requirement - NAD+CF+&lt;Carrier&gt;
	code 	:= _camMessage.camVoyage.getVoyageOperatorCode;
	fCode 	:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_CARRIER_BYOP, _protocol.terminal);
	
	if fCode = null then
		fCode := code;
	endif;
	
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeNADSegment (_protocol, null, "CF", fCode, '160', '20'), _coll);
	
	_camMessage.segmentCount := _camMessage.segmentCount + 1;
	
	// ECN/MOT Requirement - NAD+MS+&lt;Document Sender&gt;
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeNADSegment (_protocol, null, "MS", _protocol.getSenderCode_NAD_MS, null, null), _coll);
	
	_camMessage.segmentCount := _camMessage.segmentCount + 1;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_RFF" id="dc6c7704-77f0-47f0-a5b8-4bbf83fd41c6">
        <updating/>
        <source>outputHeader_RFF(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _camMessage :CM_CamMessage input; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	strLine : String;
begin
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeRFFSegment (_protocol, null, "VON",  _camMessage.camVoyage.getSanitisedVoyageCode()), _coll);
	_camMessage.segmentCount := _camMessage.segmentCount + 1;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_TDT" id="9324ee1b-f69c-4358-b9a4-6465ff444fa0">
        <updating/>
        <source>outputHeader_TDT(_camTaskHistory :CM_CamTaskHistory input; _protocol :CM_CamProtocol; _camVoyage :CM_CamVoyage; _count :Integer io; _coll :HugeStringArray input) : String updating, protected;
/*
Purpose:		Output TDT+20 segment for voyage			

Date		Who		Reason
17 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
19 Dec 2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	voyage				:CM_Voyage;
	code, fCode, msg	:String;
	strLine : String;
begin
	voyage	:= _camVoyage.voyageOid;
	// work out carrier code - 
	code 	:= _camVoyage.getVoyageOperatorCode;
	fCode 	:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_CARRIER_BYOP, _protocol.terminal);
				
	if fCode = null then
		fCode := code;
	endif;
				
	if _protocol.camGroup.useCallSign then
		msg := self.makeTDT20Segment (_protocol, _camVoyage.getSanitisedVoyageCode(), "1", 
									null, fCode, "172", "20", null, null, voyage.callSign.trimRight, '103', null, voyage.vesselName.trimRight.toUpper);
	else
		msg := self.makeTDT20Segment (_protocol, _camVoyage.getSanitisedVoyageCode(), "1", 
									null, fCode , "172", "20", null, null, voyage.lloydsNumber, '146', null, voyage.vesselName.trimRight.toUpper);
	endif;
			
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, msg, _coll);	
	
	_count := _count + 1;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camVoyage" type="CM_CamVoyage"/>
        <Parameter name="_count" type="Integer" usage="io"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNA" id="a460a447-3144-4ba3-86d8-ff30824c82bc">
        <updating/>
        <source>outputHeader_UNA(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
vars

begin
	return self.outputFileMessage(_camTaskHistory, self.makeUNASegment (_protocol), null);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNB" id="2dd249a3-3d83-466a-a321-205a13c7b6d4">
        <updating/>
        <source>outputHeader_UNB(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _seqNumber :Integer; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
vars
	
begin
	if _protocol.camGroup.code.trimBlanks = "COL" and _protocol.terminal.getConfig(PortDestCode).String = "POE" then
		return self.outputFileMessage (_camTaskHistory, 
								self.makeUNBSegment (_protocol, "UNOA", 2, "POTOTAGO", "ZZ", _protocol.camGroup.recipient.trimBlanks, "ZZ", _seqNumber, null, true, _camTaskHistory.runDateTime),
								_coll);	
	else
		return self.outputFileMessage (_camTaskHistory, 
								self.makeUNBSegment (_protocol, "UNOA", 2, _protocol.getSenderCode_NAD_MS, "ZZZ", _protocol.camGroup.recipient.trimBlanks, "ZZZ", _seqNumber, null, false, _camTaskHistory.runDateTime),
								_coll);	
	endif;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNH_BGM" id="9700ddef-7c8f-418d-a292-fef6c3af6160">
        <updating/>
        <source>outputHeader_UNH_BGM(_camFile :CM_CamFile input; _camTaskHistory :CM_CamTaskHistory input; _activity :Integer; 
						_unhSeq, _segmentCount :Integer io; _coll :HugeStringArray input) : String updating, protected;
/*
Purpose:	Refactored code	

Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
constants
	COARRI = "COARRI";
	LOAD = "270";
	DISCHARGE = "98";
vars
	strLine : String;
begin
	if _activity = COARRI_SHIPLOAD then
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeq, LOAD, COARRI, _coll);
		
		_segmentCount := _segmentCount + 2;
		
	elseif _activity = COARRI_SHIPDISCHARGE then
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeq, DISCHARGE, COARRI, _coll);
		
		_segmentCount := _segmentCount + 2;
	endif;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_unhSeq" type="Integer" usage="io"/>
        <Parameter name="_segmentCount" type="Integer" usage="io"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
