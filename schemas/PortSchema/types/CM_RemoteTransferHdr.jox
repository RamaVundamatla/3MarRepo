    <JadeMethod name="processExternal" id="22654de8-e07a-4fee-b576-016d253eb9de">
        <updating/>
        <source>processExternal(_parseAgent : CM_RemoteParseAgent io) : String updating;

vars

	logTransferDtl	: CM_RemoteTransferDtl;
	response		: String;
	err				: Integer;
	errText			: String;
	realRemoteHdr	: CM_RemoteDataHdr;
	headerCast		: CM_RemoteDataHdr;

	
begin

	response := inheritMethod(_parseAgent);
	if response = null then
		if _parseAgent.createTransferDetail(self) then
			app.myTrxCA.trxCreateRemoteData(self, realRemoteHdr, true, app.myPassport);
			if app.myPassport.trxCompletedOK then
				return self.doBuildMessage(self.xmlResponse(err, errText));
			endif;
		endif;	
		response := app.getErrorString1(Err_XML, 'transfer');
		return self.doBuildMessage(self.xmlResponse(Err_XML , response));
	endif;
	headerCast := self;
	return self.doBuildMessage(self.xmlDefaultResponse(headerCast, Err_XML , response));
	
end;</source>
        <Parameter name="_parseAgent" type="CM_RemoteParseAgent" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processInternal" id="037c7948-ed28-4f8d-b661-73a79b65492a">
        <updating/>
        <source>processInternal(_cmif : CMIF_Remote; _passport : CM_Passport input) : Boolean updating;

vars
	realRemoteHdr	: CM_RemoteDataHdr;
	remoteDetail	: CM_RemoteTransferDtl;

begin

	inheritMethod(_cmif, _passport);
	create remoteDetail transient;
	remoteDetail.setProxyForTransfer(self, _cmif.terminalAreaTo, null, _cmif.transferTo, null, 'class="LOG"', _cmif.allTis.asCSV(true));
	
	app.myTrxCA.trxCreateRemoteData(self, realRemoteHdr, true, _passport);

	return _passport.trxCompletedOK;

end;</source>
        <Parameter name="_cmif" type="CMIF_Remote"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="runProcess" id="c8c82ebc-a2ab-42e0-9f74-656c108525c5">
        <source>runProcess(_errorSet : CM_ErrorSet input; _isBackGround : Boolean) : Boolean;

vars

	transferDetail				: CM_RemoteDataDtl;

begin

	//PAR 21218  23/02/2010. This par touches BGP Internal mode only, when the Background button is turned on in the LOG_TransfersMaintForm and a user presses the Save button.
	if _isBackGround and (self.messageId = self.MessageIdInternal) then	// It means, if there are some validation warnings, a system allert is created to show this warnings and logs are not processed.
		app.myPassport.setIsBackgroundWarningsIgnored(false);	// For example, to stop moving logs, when Inspected/Fumigated status to be changed on a log row or on the logs.
	endif;
	
	foreach transferDetail in self.allRemoteDataDtl where not transferDetail.isProcessed do
		transferDetail.CM_RemoteTransferDtl.doTransfer(_errorSet);
	endforeach;
	return inheritMethod(_errorSet, _isBackGround);

end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_isBackGround" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="8aec5261-def5-4f76-94be-d5287d39ca63">
