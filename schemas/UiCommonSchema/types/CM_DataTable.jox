    <JadeMethod name="mouseMoveAutoScroll" id="1ab8a879-70ed-4772-8a63-d0f84c8291bc">
        <updating/>
        <source>mouseMoveAutoScroll(_up : Boolean; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		24 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	startTime, endTime : Time;
	object : Object;
	scrollGap, theRow : Integer;

begin
	startTime := app.actualTimeServer.time;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	if not shift.isControlKeyPressed then
		self.doAutoScroll := false;
		return;
	endif;
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " #######################. ");
	// ### START AUTO SCROLL DOWN
	self.doAutoScroll := true;
	while true do
		endTime := app.actualTimeServer.time;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. Row " &amp; self.row.String);
		if  endTime &gt;= (startTime + 250) then
			process.sleep(250);
			if (not _up	and	self.topRow &lt; self.rows) 
			or (_up and self.topRow &gt; 1) then
				if _up then
					// ### SCROLL UP
					self.topRow := self.topRow - 1;
				else
					// ### SCROLL DOWN
					self.topRow := self.topRow + 1;
				endif;
				//####
				self.mouseMoveSelectForScroll(button, shift,x,y);
				app.doWindowEvents(0);
				//####

//			else

//				self.doAutoScroll := false;
//				break;
			endif;
		endif;

//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. doAutoScroll " &amp; self.doAutoScroll.String &amp; " self.row " &amp; self.row.String &amp; " self.rows " &amp; self.rows.String);
		if self.doAutoScroll = false 
		or self.row = self.rows 
		or self.row &lt;= self.fixedRows + 1 then
			// the user has moved the mouse away from the bottom of the table so stop autoscrolling
			break;
		endif;

	endwhile;

end;</source>
        <Parameter name="_up" type="Boolean"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseMoveForDragSelect" id="d0ded205-60d5-4433-8861-0529dab6834c">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseMoveForDragSelect(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     11 October 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	startTime, endTime : Time;
	object : Object;
	scrollGap, theRow : Integer;
begin
	// ### CONTROL ONLY
	if shift.isControlKeyPressed()
	and not shift.isShiftKeyPressed()
	and not shift.isAltKeyPressed() then
		if self.allowDragSelect then
			// ### STOP AUTO SCROLL
			// ### NOTE. this stop will be part of an additional mouse move event, seperate from the one that is stuck in the do while loop in mouseMoveAutoScroll.
			if self.doAutoScroll then
				scrollGap :=  (self.clientHeight - y).Integer;
				if scrollGap &gt; 50 then
					self.doAutoScroll := false;
				elseif y &gt; 50 then
					self.doAutoScroll := false;
				endif;
			endif;
			
			if button = Window.MouseButton_Left then
			
				// ### SCROLL 1 ROW
				scrollGap := self.mouseMoveSelectForScroll(button, shift, x, y);
				// AUTO SCROLL DOWN. We are within 25 pixels of the bottom of the table
				if scrollGap &lt;= 25 then
					self.mouseMoveAutoScroll(false,button,shift,x,y);
				// AUTO SCROLL UP. We are within 50 pixels of the top of the table
				elseif (y &lt;=30 and y &gt; 15) then
					self.mouseMoveAutoScroll(true,button,shift,x,y);
				endif;
			
			endif;
		endif;
		
		return;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseMoveSelectForScroll" id="4211bd6b-6091-427a-b48a-c803e8526729">
        <updating/>
        <source>mouseMoveSelectForScroll(button: Integer; shift: Integer; x: Real; y: Real) : Integer updating;
// ---------------------------------------------------------------------------
// Created:		24 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	lastRow, scrollGap, theRow, stRow, endRow : Integer;

begin
	theRow := self.getRowFromY(y);
	if theRow &lt;= 0 then
		return 0;
	endif;

	stRow := theRow;
	endRow := theRow;
	
	if not self.allSelectedObjects.isEmpty then
		if self.findObjectInRow(self.allSelectedObjects.last,lastRow) then
			if lastRow &gt; 0 and lastRow &lt;&gt; theRow then
				if lastRow &lt; theRow then
					stRow := lastRow;
					endRow := theRow;
				else
					stRow := theRow;
					endRow := lastRow;
				endif;
			endif;
		endif;
	endif;

	foreach theRow in stRow to endRow do
		//epr par 23089 15/3/10
		self.selectRow(theRow,false);
			
	endforeach;		

	scrollGap :=  (self.clientHeight - y).Integer;

	return scrollGap;
end;</source>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="1be8cf0f-5470-4534-8f9b-1f187f0e3198">
        <updating/>
        <source>mouseUp(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars

	startTime, endTime : Time;
	 option, timeRemaining : Integer;
begin
	self.doAutoScroll := false;
	if isPossibleDrag then
		self.clearAllSelected();
		self.allSelectedRows.clear;
		self.selectRow(table.row,false);
	endif;
	
	// check for a long click
	startTime := self.longStart;
	endTime := app.actualTimeServer.time;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	if not self.longDidDBLClick then
		if  endTime &gt;= (startTime + 650) then
			if button = Button.MouseButton_Left then
				self.longLeftClick := true;
			elseif button = Button.MouseButton_Right then
				self.longRightClick := true;
			endif;
		endif;
	endif;

	if self.allowDragSelect then
		if self.allSelectedObjects.size &gt; 1 then
			self.longLeftClick := false;
		endif;
	endif;
	
	
	// 10 Sept 2024	navab1	CR 66065 : MTN - Generate quick list of selected column data
	if shift.isAltKeyPressed then
		self.helpKeyword := self.helpKeyword &amp; self.column.String &amp; "|";
		self.accessCell(1, self.column).fontBold := true;
		
		if self.getTimerStatus(self.Timer_CTRL_SHFT_G, option, timeRemaining) then
			self.endTimer(self.Timer_CTRL_SHFT_G);
		endif;
		
		self.beginTimer(5000, Timer_OneShot,self.Timer_CTRL_SHFT_G);
		
	else
		self.helpKeyword := "";

	endif;
	

	inheritMethod(table, button, shift, x, y);

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="outputCSVToFile" id="4c923b9c-6cdc-4b99-94cf-99d22fef7fe3">
        <updating/>
        <source>outputCSVToFile(_file: File input; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Apr 2025	navnk30	JIRA 34687: Extend the export functionality to work with TableViewForms that implement Pagination on their DataTables

*/

vars
	colourColumn,
	numDone,
	col,
	firstDataRowId,
	numRows				: Integer;
	cellText,
	rowLine				: String;
	cmifMonitor			: CMIF_Monitor;
	lastUpdated			: Decimal[20];
	hiddenFirstColumn	: Boolean;
	tblObj				: CM_Object;
	tblColl				: Collection;
	etRow				: EntTableRow;
begin
	/**
	 * Handles exporting of data rows for paginated data tables.
	 * The existing export flow remains unchanged for fixed rows in all tables 
	 * and for all rows in non-paginated tables, and other processing.
	 */

	inheritMethod(_file, _passport);
	if not self.isPaginated() then
		return;
	endif;
	
	tblColl := self.getCollection();
	colourColumn := self.getColourColumnNumber();
	numRows := tblColl.size();
	firstDataRowId := self.fixedRows + 1;
	
	foreach tblObj in tblColl as CM_Object do
		numDone += 1;
		
		if cmifMonitor &lt;&gt; null and (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then
			cmifMonitor.updateProgress(cmifMonitor.message, cmifMonitor.partsInJob, numDone);
			lastUpdated := app.relativeMachineTime;
		endif;
		
		foreach col in 1 to self.allTblDataEntRows.size() do
			etRow := self.allTblDataEntRows[col];
			if col = colourColumn then
				cellText := self.accessCell(firstDataRowId, col).backColor.display;
			else
				cellText := tblObj.getDisplayStringForAttribute(etRow.name, true);
			endif;
			
			if (not cellText.isReal()) then
				cellText := cellText.csvFormat();
			endif;
			
			if col = 1 or hiddenFirstColumn then
				rowLine := cellText;
				hiddenFirstColumn := false;
			else
				rowLine := rowLine &amp; ',' &amp; cellText;
			endif;
		endforeach;
		
		_file.writeLine(rowLine);
		rowLine := null;
	endforeach;
epilog

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="printTable" id="256986c2-e278-4fca-9a3f-4c5e7494c962">
        <updating/>
        <source>printTable(_caption : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2011	cnwer1	Initial creation CCMS 1031
						refactored code from various sources moved to table
*/

vars

	tiReport	: CM_TIEnquiryOutput;
	progress	: CMS_Progress;
	now			: TimeStamp;
	tmpReport	: JadeReport;
	tp			: CM_GenericTablePrint;
begin

	app.mousePointer := MP_HOURGLASS;
	now := self.systemToLocalTime(app.actualTimeServer());	// 10/6/16 cnwmp6 TFS 488 - Multi timezone support
	create tmpReport transient;
	app.printer.close;
	app.printer.suppressDialog := true;
	app.printer.setMargins(Print_Landscape,5,5,10,10);
	app.printer.topOfPage := 1;
	app.printer.bottomOfPage := 1;
	app.printer.setReport(tmpReport);	//Capture for print preview.

	create tiReport transient;
	tiReport.initReport;
	tiReport.initReportForLandscape();
	app.printer.setHeader(tiReport.frHeader);
	
	tmpReport.description := _caption[1:60];
	tiReport.picLogo.picture := app.getPicLogoPort; // The bitmap called rptlogo.bmp in reports/formats
	tiReport.lblCargoType.caption := _caption;
	tiReport.lblCargoTypeLbl.visible := false;
	tiReport.lblTIIDlbl.visible := false;
	tiReport.lblTIID.visible := false;
	tiReport.lblPrintedBylbl.visible:=false;
	tiReport.lblPrintedBy.visible:=false;
	
	create tp transient;
	
	tp.frFooter.width := app.printer.pageWidth;
	tp.lblTheUser.caption := app.getMyUserCode;
	tp.lblTheDatePrinted.caption := now.asStringJMT;
	app.printer.setFooter(tp.frFooter);
	
	create progress transient;
	tp.printTable(self, true, progress);
		
	app.printer.close;
	app.printPreview(tmpReport, true);
	
epilog
	delete progress;
	delete tp;
	delete tiReport;
	app.mousePointer := MP_DEFAULT;

end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="queryRowColChg" id="611f4c0f-1b12-4fdc-89c5-864c2adee765">
