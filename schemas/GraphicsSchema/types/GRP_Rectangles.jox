        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	self.frameOne.autoRedraw := true;
//	self.frame2_1.transparencyPercent := 50;
	self.frame2_1.transparent := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="makePicture" id="db8a2a0d-ff5a-4afd-87b9-2b42f31db192">
        <source>makePicture() : Binary;
// ---------------------------------------------------------------------------
// Created:     04 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	frame2.autoRedraw := true;
	frame2.drawFilledRectangle(10,10,30,30,Red);
	return frame2.createPictureAsType(false, false, 8, Window.PictureType_Icon);
epilog

end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
