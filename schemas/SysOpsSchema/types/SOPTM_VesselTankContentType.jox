    <JadeMethod name="setControlsForAddEdit" id="db84d62d-2011-4f1c-a734-dc2bbd940585">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 April 2011	cnwer1	Initial creation

*/

vars

theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;

	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
	
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_VesselTankContentsType);
	
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="a6919eb3-95de-4c06-a404-16f66704c2ca">
