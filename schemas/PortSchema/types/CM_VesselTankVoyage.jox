<Class name="CM_VesselTankVoyage" id="84f2cc38-2509-4437-9ff0-f84eff321f61">
    <superclass name="CM_VesselTank"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="vesselStructures"/>
    <PrimAttribute name="actualWeight" id="959dfe98-0ea7-4ea0-985e-cb2c9dbbad82">
        <precision>12</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myVoyageStructuralElement" id="3c040b2c-be16-46e6-a5e2-c2952f9fa2a2">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_VoyageStructuralElements"/>
        <access>readonly</access>
        <Inverse name="CM_VoyageStructuralElements::allTanks"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myVoyageStructure" id="dd96cd3b-149c-4514-8990-65b41280255d">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_VoyageStructure"/>
        <access>readonly</access>
        <Inverse name="CM_VoyageStructure::allTanks"/>
    </ExplicitInverseRef>
    <JadeMethod name="cloneMySelf" id="4297bfd6-15cf-45d0-b484-eb17d61c57b4">
        <updating/>
        <source>cloneMySelf(_newVoyage : CM_VoyageStructuralElements) : CM_VesselTankVoyage updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	newMe : SelfType;
begin
	newMe := self.cloneSelf(false);
	//newMe.myVoyageStructure := _newVoyage;
	newMe.myVoyageStructuralElement := _newVoyage;
	newMe.myVesselTankType := self.myVesselTankType;
		
	return newMe;

epilog

end;</source>
        <Parameter name="_newVoyage" type="CM_VoyageStructuralElements"/>
        <ReturnType type="CM_VesselTankVoyage"/>
    </JadeMethod>
    <JadeMethod name="delete" id="ba519c53-da06-44c9-8d0a-d6837c4a0997">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	if self.isTransient then
		return;
	endif;
	
	self.myVoyageStructuralElement.causeEvent(EVENT_TANK_DELETE,false,self);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditParent" id="2350abd5-177b-446d-84d0-b61888de11e9">
        <source>getAuditParent(): CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	if self.myVoyageStructuralElement = null then
		return null;
	endif;
	
	return self.myVoyageStructuralElement.myVoyage;

epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getStructure" id="f041ce76-0b12-4746-8884-eb90e7d2e1dc">
        <source>getStructure(): CM_VoyageStructuralElements;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	return self.myVoyageStructuralElement;

epilog

end;</source>
        <ReturnType type="CM_VoyageStructuralElements"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="f9c9929c-c5d2-472c-b75f-6715277017be">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	pxySelf : SelfType;
	completedOK		: Boolean;
begin
	pxySelf:= inheritMethod();
	
	pxySelf.myVoyageStructuralElement:=self.myVoyageStructuralElement;
	
	completedOK := true;			
	return pxySelf;

epilog
	if not completedOK then			
		delete pxySelf;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0400d710-6099-4bc4-9fa2-9bf5a1868484">
        <updating/>
        <source>setForCreate(_proxyVoyageTank: CM_VesselTankVoyage) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	
begin
	
	if _proxyVoyageTank.myVoyageStructuralElement.isTransient then
		self.myVoyageStructuralElement:=_proxyVoyageTank.myVoyageStructuralElement.pxyGetRealObject();
	else
		self.myVoyageStructuralElement:=_proxyVoyageTank.myVoyageStructuralElement;
	endif;

	
	
	inheritMethod(_proxyVoyageTank);

epilog

end;</source>
        <Parameter name="_proxyVoyageTank" type="CM_VesselTankVoyage"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5a3ccef0-5b9e-4092-b16c-70165c5e70e6">
        <updating/>
        <source>setForUpdate(_proxyVoyageTank: CM_VesselTankVoyage) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116
22 June 2011	cnwer1  added auditing
*/

vars
	voyage : CM_Voyage;
	beforeAuditText,
	afterAuditText	: String;
begin
	if  self.myVoyageStructuralElement &lt;&gt; null then
		beforeAuditText:=self.myVoyageStructuralElement.getAuditText;
	endif;
	
	inheritMethod(_proxyVoyageTank);
	
	self.actualWeight := _proxyVoyageTank.actualWeight;
	
	if self.myVoyageStructuralElement &lt;&gt; null then
	
		voyage:= self.myVoyageStructuralElement.myVoyage;
		afterAuditText:=self.myVoyageStructuralElement.getAuditText;
		app.myAA.auditUpdateTrx(voyage,beforeAuditText, afterAuditText);
	
		if _proxyVoyageTank.pxyGetRealObject =null then
			self.myVoyageStructuralElement.causeEvent(EVENT_TANK_CREATE,false,self);
		else
			self.myVoyageStructuralElement.causeEvent(EVENT_TANK_UPDATE,false,self);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_proxyVoyageTank" type="CM_VesselTankVoyage"/>
    </JadeMethod>
    <JadeMethod name="setMyActualWeight" id="c1aaad94-fb34-4cf8-bb24-f465a9095a21">
        <updating/>
        <source>setMyActualWeight(_weight : Decimal) updating;
/*
Date		    Who			Reason
19 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin
	self.actualWeight := _weight;
epilog

end;</source>
        <Parameter name="_weight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyageStructure" id="7c5ea2a7-22b0-4728-8bc5-8b13b667f19a">
        <updating/>
        <source>setMyVoyageStructure(_voyageStructure : CM_VoyageStructuralElements) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin

	self.myVoyageStructuralElement:=_voyageStructure;
epilog

end;</source>
        <Parameter name="_voyageStructure" type="CM_VoyageStructuralElements"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="307069b8-7b61-4405-8e43-082563719f77">
        <source>validateCreate(_passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	if self.myVoyageStructuralElement = null then
	// 	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Voyage) &amp; " " &amp; app.getErrorString(Structure), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Voyage) &amp; " " &amp; app.getErrorString(Structure), null, null); // cnwdb2	PAR 35364
		return;
	endif;

	 if self.myVoyageStructuralElement.allTanks[self.code] &lt;&gt; null then
		 app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	 endif;

	
	inheritMethod(_passport);

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
