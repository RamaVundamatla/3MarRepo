    <JadeMethod name="setDayListArray" id="9ff9407d-6257-4e6c-b938-a43fec9c10e3">
        <source>setDayListArray( monday : Date );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 November 2010	cnwndl1	Initial creation

*/

vars

	date : Date;
	pos : Integer;
	
begin

	date := monday;
	self.dayListArray.clear();
	foreach pos in 1 to 7 do
		self.dayListArray.add( date.format("dddd") );
		date := date + 1;
	endforeach;

epilog

end;</source>
        <Parameter name="monday" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setFilterMacroInfo" id="7d42d820-a638-41fe-9445-0fb15ec996b6">
        <source>setFilterMacroInfo();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2010	cnwndl1	Initial creation

*/

vars
	text : String;
	dayType : CM_DayType;
	outputString : String;
	calendar : CM_Calendar;
begin

	text := null;
	if self.allSelectedCalendars.isEmpty then
		if self.myTerminal &lt;&gt; null then
			outputString := outputString &amp; app.getErrorString1(Includes_calendars_for, self.myTerminal.name) &amp; CrLf;
		else
			outputString := outputString &amp; app.getErrorString(Includes_calendars) &amp; CrLf;
		endif;
	else
		foreach calendar in self.allSelectedCalendars do
			if text = null then
				text := calendar.description;
			else
			//	text := text &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp; calendar.description;
				text := text &amp; ", " &amp; calendar.description;
			endif;
		endforeach;
		outputString := outputString &amp; app.getErrorString(Includes_calendars_colon) &amp; Tab &amp; text &amp; CrLf;
	endif;
	
	
	
	text := null;
	if self.allSelectedDayTypes.isEmpty then
		outputString := outputString &amp; app.getErrorString(Includes_all_day_types);
	else
		foreach dayType in self.allSelectedDayTypes do
			if text = null then
				text := dayType.description;
			else
			//	text := text &amp; CrLf &amp; Tab &amp; Tab &amp; Tab &amp; dayType.description;
				text := text &amp; ", " &amp; dayType.description;
			endif;
		endforeach;
		outputString := outputString &amp; app.getErrorString(Includes_day_types_of) &amp; Tab &amp; text;
	endif;
	
	
	
	txtFilterSummary.text := outputString;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setHeadingForDayColumnDisplay" id="893bd2a6-f378-438a-9d93-06fc0d81800e">
        <source>setHeadingForDayColumnDisplay( _date : Date; _baseCellHeight : Integer ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 October 2010	cnwndl1	Initial creation

*/

vars

	checkDayType : Boolean;
	checkCalendar : Boolean;
	term : CM_Terminal;
	calendar : CM_Calendar;
	calendarDate : CM_CalendarDate;
	allCalendarDates : CM_CalendarDatesByDateTimedict;
	returnStr : String;
	count : Integer;
	tableRow : JadeTableRow;

begin

	checkDayType := not self.allSelectedDayTypes.isEmpty;
	checkCalendar := not self.allSelectedCalendars.isEmpty;
	term := self.myTerminal;
	create allCalendarDates transient;

	foreach calendar in app.myRoot.allCalendars do
			
		if term = null then
			// show everything, have been called from Sys ops
		else
			if not calendar.allTerminals.includes(term) then
				continue;
			endif;
		endif;
		
		if checkDayType and not self.allSelectedDayTypes.includes( calendar.myDayType ) then
			continue;
		endif;

		if checkCalendar and not self.allSelectedCalendars.includes( calendar ) then
			continue;
		endif;
		
		
		
		calendar.getAllCalendarDatesForDay( _date, allCalendarDates);
		
		foreach calendarDate in allCalendarDates do
			if calendarDate.getTimeDisplay.trimBlanks &lt;&gt; null then
				continue;
			endif;
			if returnStr = null then
				returnStr := calendarDate.description;
			else
				returnStr := returnStr &amp; CrLf &amp;  calendarDate.description;
			endif;
			self.allCalendarDatesDisplayed.addNoDuplicates(calendarDate, false);
			count := count + 1;
		endforeach;
		
		
		
	endforeach;
	
	tableRow := self.tblCalendar.accessRow(1);
	if count &gt; 1 then
		tableRow.height := ( _baseCellHeight * count );
	else
		tableRow.height := ( _baseCellHeight + 2 );
	endif;
	
	self.tblCalendar.setCellText(1,2,returnStr );

epilog

	delete allCalendarDates;

end;</source>
        <access>protected</access>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_baseCellHeight" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1c405cd1-7dc9-4e31-a726-c185506b37b2">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 October 2010	cnwndl1	Initial creation
//21 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	date : Date;
	
begin
	
	//21 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	date := app.actualTimeServer().date();
	
	self.refreshToolbar();
	self.frmUserColours.visible := false;
	
	self.setColours();
	
	self.beginClassNotification(CM_CalendarDate, false, Object_Create_Event, Response_Continuous, null);
	self.beginClassNotification(CM_CalendarDate, false, Object_Update_Event, Response_Continuous, null);
	self.beginClassNotification(CM_CalendarDate, false, Object_Delete_Event, Response_Continuous, null);
	
	self.beginClassNotification(CM_Calendar, false, Object_Create_Event, Response_Continuous, null);
	self.beginClassNotification(CM_Calendar, false, Object_Update_Event, Response_Continuous, null);
	self.beginClassNotification(CM_Calendar, false, Object_Delete_Event, Response_Continuous, null);
	
	self.beginClassNotification(CM_DayType, false, Object_Create_Event, Response_Continuous, null);
	self.beginClassNotification(CM_DayType, false, Object_Update_Event, Response_Continuous, null);
	self.beginClassNotification(CM_DayType, false, Object_Delete_Event, Response_Continuous, null);

	inheritMethod();
	
	self.minimumWidth := 635;
	self.minimumHeight := 380;
	
	// default values
	self.day := date.day;
	self.month := date.month;
	self.year := date.year;
	
	self.doRefreshCalendar( true );
	
	self.cmbPeriod.setFocus();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showFilter" id="3da59639-3dcd-436b-b1ab-69c159b344d2">
        <source>showFilter();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2010	cnwndl1	Initial creation

*/

vars

	theFrame : CMUI_MoveableFrame;
	
begin

	app.mousePointer := Window.MousePointer_HourGlass;
	theFrame := self.frmFilter;
	
	if theFrame.visible then 
		theFrame.visible := false;
		return;
	endif;

	
	theFrame.centreHorizontallyInParent();
	theFrame.top := 100;
	
	theFrame.zOrder(1);

	theFrame.visible := true;
	
epilog

	app.mousePointer := Window.MousePointer_Default;
	
end;</source>
    </JadeMethod>
