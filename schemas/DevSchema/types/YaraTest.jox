    <JadeMethod name="testException" id="4a5107ae-bfd4-402e-8d62-7319c04cc962">
        <source>testException();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 September 2025	navsaa30	Initial creation

*/

vars
	error : CM_Error;
begin
app.initialize;
app.raiseCMException1( ERR_ORDER_CREATE_UPDATE,"Cargo Type " &amp; " not found.", null,null );

	app.myPassport.addErrorFull(ERR_ORDER_CREATE_UPDATE, app.getErrorString(ERR_ORDER_CREATE_UPDATE), null, null, null);
foreach error in CM_Error.instances do
	if error.errorCode = 96945 then
		write "yes";
	endif;
endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="testOrderCreate" id="29fad579-f9d0-4256-a119-63da14d30988">
        <source>testOrderCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2025	navsaa30	Initial creation

*/


constants
	//XML_File_Name = "C:\Users\navnk30\yara\xml_files\OrderCreate-3.xml";
	XML_File_Name= "C:\Users\navsaa30\ordercreate.xml";
vars
	file		: File;
	bgpReq		: BGP_AgGatewayWSRequest;
	incomingXML	: String;
	ramTerminal	: CM_Terminal;
begin
	app.initialize();
	app.myPassport.setMyUserFromCode("NAVNK30");
	ramTerminal := "2351.1561".asOid().CM_Terminal;
	app.myPassport.setMyTerminal(ramTerminal);
	create file transient;
	file.fileName := XML_File_Name;
	while not file.endOfFile do
		incomingXML &amp;= file.readLine();
	endwhile;
	
	create bgpReq transient;
	bgpReq.setDetails(incomingXML, ramTerminal, "navnk30", "Nithish");
	bgpReq.action();
	
	
epilog
	delete file;
end;</source>
    </JadeMethod>
