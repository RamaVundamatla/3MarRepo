    <JadeMethod name="clickChkBoxFormatUNL" id="2502049f-c642-41b1-b68c-e11dbcfc5cba">
        <updating/>
        <source>clickChkBoxFormatUNL() updating;
// ----------------------------------------------------------------------------
//	Created by cnwvu1	09 April 2008
// ----------------------------------------------------------------------------

vars
	par	: String;
	rt	: RootHotFixes;
	ptch: Patch;
	
begin

	if self.mode &lt;&gt; self.MODE_EMPTY then

		rt := app.myRootHotFix;
		par := self.txt_parNo.text;
		ptch := rt.allPatches[ par ];
		self.setTextForNotepad( ptch );
		
	endif;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="convertToUNLFormat" id="88a3716a-7764-4999-a60c-5fcaab5e4504">
        <updating/>
        <source>convertToUNLFormat(_str : String io; _scm : SchemaInPatch io; _patch : Patch; _validate : Boolean; _isFirst : Boolean io) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 February 2014	cnwmc5	Initial creation	PAR 32864

*/

vars
	tokens 		: HugeStringArray;
	
	schema 		: String;
	klass		: String;
	meth		: String;
	strUNL		: String;
	
begin
	create tokens transient;
	//_str.getTokensForDelimiter("::", tokens);
	self.getTokensForDoubleColon(_str, tokens);
	
	if tokens.size &lt; 2 then
		return true;
	endif;
	
	if tokens.size = 2 then
		klass := tokens[1];
		meth := tokens[2];
	else
		schema := tokens[1];
		klass := tokens[2];
		meth := tokens[3];
		
		strUNL := "Schema " &amp; schema;
		
		if _isFirst then
			_isFirst := false;
			
			if not self.validateUNLSchema( _validate, strUNL, _patch, _scm ) then
				return false;
			endif;
		endif;
		
		if not _validate then
			if _scm = null 
			or _scm.name &lt;&gt; schema then
				self.validateUNLSchema(false, strUNL, _patch, _scm);
			endif;
		endif;
	endif;
	
	_str := "Method " &amp; klass &amp; " " &amp; meth;
	
	return true;
epilog
	delete tokens;
end;</source>
        <Parameter name="_str" type="String" usage="io"/>
        <Parameter name="_scm" type="SchemaInPatch" usage="io"/>
        <Parameter name="_patch" type="Patch"/>
        <Parameter name="_validate" type="Boolean"/>
        <Parameter name="_isFirst" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCancel" id="8c71f658-02c5-4df5-a1d7-461afd334792">
        <updating/>
        <source>doCancel() updating;
/*--------------------------------------------------------------------
Created:	08 April 2007 By cnwvu1
Purpose:	
----------------------------------------------------------------------
*/
vars
	patch 		: Patch;
	normalMode	: Integer;		// TFS 38497 jlgmd1 12/10/2018
	
begin


	if self.mode = self.MODE_INSERT then
		self.txt_notepad.text 		:= '';
		//self.txt_ParTopic.text		:= '';
		self.txt_ParDescr.text		:= '';
		self.txt_CloseDetail.text	:= '';
		self.txt_AreasAffect.text	:= '';
	    self.cmb_Customer.text  	:= '';
		self.cmb_Topic.text  		:= '';
		self.txt_tag.text			:= '';		// TFS 38497 jlgmd1 12/10/2018
		self.opt_PriorityA.value  	:= false;
		self.opt_PriorityB.value  	:= false;
		self.lbl_PAR00000.caption 	:= "TFS-00000";
		self.setMode( self.MODE_EMPTY);
		
	elseif self.mode = self.MODE_EDIT or self.mode = self.MODE_EDIT_TFS then		// TFS 38497 jlgmd1 12/10/2018
		// we have real patch because there is EDIT mode
		
		// TFS 38497 jlgmd1 12/10/2018
		if self.inTFSMode then
			// try and get a 'tfs' version of the patch first
			patch := app.myRootHotFix.allPatches[ app.myRootHotFix.TFS_NUMBER_MASK &amp; self.txt_parNo.text ];
			normalMode := self.MODE_NORMAL_TFS;
		endif;
		
		if patch = null then
			patch := app.myRootHotFix.allPatches[ self.txt_parNo.text ];		
			if patch.isTFSPatch then										// TFS 38497 jlgmd1 12/10/2018
				normalMode := self.MODE_NORMAL_TFS;							// TFS 38497 jlgmd1 12/10/2018
			else															// TFS 38497 jlgmd1 12/10/2018
				normalMode := self.MODE_NORMAL;
			endif;															// TFS 38497 jlgmd1 12/10/2018
		endif;
		
		if patch &lt;&gt; null then
			self.setTextForNotepad( patch );
			self.setMode( normalMode );		// TFS 38497 jlgmd1 12/10/2018
		else
			app.msgBox('Patch ' &amp; self.txt_parNo.text &amp; ' is deleted.', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
			self.setMode( self.MODE_EMPTY );
		endif;
		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid data mode for doCancel');
		
	endif;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doCheckAutoPatchNo" id="6d56d3c1-0049-4316-bf5e-7633ae16ea83">
        <updating/>
        <source>doCheckAutoPatchNo() updating;

vars

begin

	if not self.chk_autoPatchNo.value then
		if not self.mode = self.MODE_EMPTY then
			self.txt_patch.enabled := true;
		endif;
	else
		self.txt_patch.enabled := false;
	endif;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doCreateFiles" id="9fc72896-085a-4308-9260-6218f501fa4e">
        <updating/>
        <source>doCreateFiles() updating;
/*--------  ----------  --------------------------------------------------
Created:	08 April 2007 By cnwvu1
Purpose:
----------  ----------  --------------------------------------------------
*/
vars
	rtH				: RootHotFixes;
	patch,patchDbl	: Patch;
	listOfPars		: FileNodeArray;
	newPatchNo		: String;
	// Parameters from the Form
	findNewPatchNo	: Boolean;
	newPatchNo_forced	: String;
//	strReadme		: String;
	errStr			: String;
	dirPart			: String;		// TFS 38497 jlgmd1 12/10/2018
	parNo			: String;		// TFS 38497 jlgmd1 12/10/2018
	tag				: String;		// TFS 38497 jlgmd1 12/10/2018

begin

	if not self.validateNewPatchBeforeFiles() then
		return;
	endif;

	findNewPatchNo		:= chk_autoPatchNo.value;
	newPatchNo_forced	:= self.txt_patch.text;
//	strReadme			:= self.txt_readme.text;

	rtH   := app.myRootHotFix;
	patch := rtH.allPatches[ self.txt_parNo.text ];
	
	// TFS 38497 jlgmd1 12/10/2018
	if self.inTFSMode and not patch.isTFSPatch then
		patch := rtH.allPatches[ app.myRootHotFix.TFS_NUMBER_MASK &amp; self.txt_parNo.text ];
	endif;
	
	// TFS 38497 jlgmd1 12/10/2018
	if patch.isTFSPatch then
		dirPart	:= rtH.DIR_PART_TFS;
		parNo	:= patch.parNo;
		if parNo[1:1] = app.myRootHotFix.TFS_NUMBER_MASK then
			parNo	:= parNo[2:end];
		endif;
	else
		dirPart	:= rtH.DIR_PART_PAR;
		parNo	:= patch.parNo;
	endif;
	
	// TFS 38497 jlgmd1 12/10/2018
	if patch.tag &lt;&gt; null then
		tag := "_" &amp; patch.tag;
	endif;
	
	app.writeLogMessage('');
	app.writeLogMessage('');
	app.writeLogMessage(' __________________ Creating Patch __________________');
			
	if not patch.validate(self.chk_webPatch.value) then
		return;
	endif;
	
	create listOfPars transient;
	
	beginTransaction;

	rtH.set( self.txtDirSetup.text, self.txtReleaseNo.text );	// RootHotfixes will have edited Setup directory if it was edited.
	
// ______________________ getting the new Patch number __________________________
	if not findNewPatchNo then
		newPatchNo := newPatchNo_forced;
	else
		if not rtH.getPatchNoForNewPar( newPatchNo, self.txtReleaseNo.text ) then
			abortTransaction;
			app.msgBox('The Patch failed. More details in Jade Interpreter Output.', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
			return;
		endif;
	endif;

	patch.setPatchNo( newPatchNo, app.myRootHotFix.releaseVersionNo );
	
	//before saving patchNo and ReleaseNo we should check rt.allPatchesByReleasePatch
	// this dictionary allows duplicates, so we should check manually
	patchDbl := app.myRootHotFix.allPatchesByReleaseNoPatchNo[ self.txtReleaseNo.text, newPatchNo ];
	if (patchDbl &lt;&gt; null) and (patchDbl &lt;&gt; patch) then
		abortTransaction;
		app.msgBox('Cannot create the patch ' &amp; newPatchNo &amp; '. It exists already... The Patch ' &amp; patchDbl.patchNo &amp;'_'&amp; patchDbl.parNo &amp; ' Release ' &amp; patch.releaseVersionNoForPatch, self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
// ______________________ create all directories for the new Patch __________________________
	if not rtH.createDirsForHotFix( 1, newPatchNo &amp; dirPart &amp; parNo &amp; tag, '', newPatchNo, self.chk_webPatch.value, self.opt_PriorityA.value ) then
		abortTransaction;
		app.msgBox('The Patch failed. More details in Jade Interpreter Output.', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
// ______________________ creating all files for the new Patch _____________________________
	if not patch.createFilesForPatch( newPatchNo, patch.singleUser, self.chk_thinClient.value, self.chk_webPatch.value ) then
		abortTransaction;
		app.writeLogMessage('');
		app.writeLogMessage('The Patch failed...');
		app.writeLogMessage('');
		app.msgBox('The Patch failed. More details in Jade Interpreter Output.', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	commitTransaction;	
	self.txt_patch.text	:= patch.patchNo;
	
	app.writeLogMessage('');
	app.writeLogMessage(' The Patch ' &amp; patch.patchNo &amp;'_'&amp; parNo &amp; ' has been created on a disk.');
	app.writeLogMessage('');
	app.msgBox(' The Patch ' &amp; patch.patchNo &amp;'_'&amp; parNo &amp; ' has been created on a disk.', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
	
epilog
	if listOfPars &lt;&gt; null then 
		delete listOfPars;
	endif;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="a7d4e748-a6b4-4bf7-b99f-4148706c35d6">
        <updating/>
        <source>doDelete() updating;
/*--------------------------------------------------------------------
Created:	09 April 2007 By cnwvu1
Purpose:	
----------------------------------------------------------------------
*/

vars
	n		: Integer;
	ptch	: Patch;
	type	: String;
begin

	if self.txt_parNo.text = '' then
		app.msgBox('Program error. Par number is empty...', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
	endif;

	// jlgmd1 28/08/2019 missed from TFS 38497
	ptch := app.myRootHotFix.allPatches[ self.txt_parNo.text ];
	type := "PAR";
	if ptch &lt;&gt; null and ptch.isTFSPatch then
		type := "TFS";
	endif;
	
	n := app.msgBox("Delete patch " &amp; type &amp; " " &amp; self.txt_parNo.text &amp; " ?", "Deletion Confirmation", MsgBox_Yes_No);
	if n = MsgBox_Return_No then 
		return;
	endif;
	
	if ptch &lt;&gt; null then
		beginTransaction;
		ptch.deletePatch( true );
		commitTransaction;
	endif;
	
	self.txt_parNo.text			:= '';
	self.txt_notepad.text		:= '';
	//self.txt_ParTopic.text		:= '';
	self.txt_ParDescr.text 		:= '';
	self.txt_CloseDetail.text	:= '';
	self.txt_AreasAffect.text	:= '';
	self.txt_tag.text			:= '';		// TFS 38497 jlgmd1 12/10/2018
	self.cmb_Customer.text  	:= '';
	self.cmb_Topic.text  		:= '';
	self.opt_PriorityA.value  	:= false;
	self.opt_PriorityB.value  	:= false;

	self.setMode( self.MODE_EMPTY );	
	
end;

</source>
    </JadeMethod>
    <JadeMethod name="doEdit" id="a93b0b8f-97ea-4410-9172-4ab99963fe29">
        <updating/>
        <source>doEdit() updating;
/*--------------------------------------------------------------------
Created:	08 April 2007 By cnwvu1
Purpose:	
----------------------------------------------------------------------
*/
vars

begin

	if (self.txt_parNo.text.trimRight = '') then
//		app.msgBox('Error. PAR cannot be empty...', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;

	if (self.txt_parNo.text.trimRight &lt;&gt; '') and (self.txt_notepad.text.trimRight = '') then
		app.msgBox('PAR not found. Please press Insert.', self.class.name &amp;'.'&amp; method.name, MsgBox_OK_Only + MsgBox_Information_Icon);
		self.setMode( self.MODE_EMPTY );
		return;
	endif;
	
	if self.mode = self.MODE_NORMAL_TFS then
		self.setMode( self.MODE_EDIT_TFS );		// TFS 38497 jlgmd1 12/10/2018
	else
		self.setMode( self.MODE_EDIT );
	endif;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doInsert" id="89f3903a-c138-4ba9-9b2c-4e4fce011605">
        <updating/>
        <source>doInsert() updating;
/*--------------------------------------------------------------------
Created:	07 April 2007 By cnwvu1
Purpose:	create new par
----------------------------------------------------------------------
*/

vars
	newPar	: String;
	rt		: RootHotFixes;
	patch	: Patch;
	n		: Integer;
	
begin

	rt := app.myRootHotFix;
	newPar := self.txt_parNo.text;
	
	if not rt.isValidParNo( newPar ) then
		return;
	endif;

	patch := rt.allPatches[ newPar ];
	self.setTextForNotepad( patch );
	self.lbl_PAR00000.caption := "TFS-" &amp; newPar;
	self.lbl_parNo.caption := "TFS No";		// TFS 38497 jlgmd1 12/10/2018
	
	if patch = null then

		self.setMode(self.MODE_INSERT);
	
	else
		// TFS 38497 jlgmd1 12/10/2018
		if not patch.isTFSPatch then
			self.lbl_PAR00000.caption := "PAR-" &amp; newPar;
			self.lbl_parNo.caption := "PAR No";
		endif;
		
		n := app.msgBox("The patch " &amp; patch.parNo &amp; " exists already. Do you want to edit it?", "Edition Confirmation", MsgBox_Yes_No);
		if n = MsgBox_Return_Yes then
			// TFS 38497 jlgmd1 12/10/2018
			if patch.isTFSPatch then
				self.lbl_PAR00000.caption := "TFS-" &amp; newPar;
				self.lbl_parNo.caption := "TFS No";
				self.setMode(self.MODE_EDIT_TFS);
			else
				self.setMode(self.MODE_EDIT);
			endif;
		else
		// TFS 38497 jlgmd1 12/10/2018 START
			if not patch.isTFSPatch then
				self.setMode(self.MODE_NORMAL);
				self.lbl_PAR00000.caption := "PAR-" &amp; newPar;
				self.lbl_parNo.caption := "PAR No";
				// See if we have a TFS version instead
				patch := rt.allPatches[ app.myRootHotFix.TFS_NUMBER_MASK &amp; newPar ];
				if patch &lt;&gt; null then
					self.setTextForNotepad(patch);
					self.setMode(self.MODE_NORMAL_TFS);
					self.lbl_PAR00000.caption := "TFS-" &amp; newPar;
					self.lbl_parNo.caption := "TFS No";
					n := app.msgBox("Do you want to edit the TFS version of this patch?", "TFS Patch", MsgBox_Yes_No);
					if n = MsgBox_Return_Yes then
						self.setMode(self.MODE_EDIT_TFS);
					endif;
				else
					n := app.msgBox("Do you wish to create a new patch with the same number for TFS?", "TFS Patch", MsgBox_Yes_No);
					if n = MsgBox_Return_Yes then
						self.setTextForNotepad(patch);
						self.setMode(self.MODE_INSERT);
						self.lbl_PAR00000.caption := "TFS-" &amp; newPar;
						self.lbl_parNo.caption := "TFS No";
					endif;
				endif;
			else
				self.setMode(self.MODE_NORMAL_TFS);
			endif;
		// TFS 38497 jlgmd1 12/10/2018 END
		endif;
	endif;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="36c32762-9662-464c-9eba-d61f78de35d1">
        <source>doResize();

vars

begin

	//self.txt_ParTopic.width	:= self.frm_patchReadme.width - self.txt_ParTopic.left - 12;
	//self.txt_ParDescr.width	:= self.txt_ParTopic.width;
	self.txt_ParDescr.width		:= self.frm_patchReadme.width - self.txt_ParDescr.left - 12;
	
	self.txt_CloseDetail.width	:= self.txt_ParDescr.width;
	self.txt_AreasAffect.width	:= self.txt_ParDescr.width;
	self.frm_notepad.height	:= self.frm_workArea.height - 2;
//	self.frm_notepad.width		:= self.frm_workArea.width * 2 / 5;
	self.frm_notepad.width	:= self.frm_workArea.width;
	self.frm_development.width	:= self.frm_workArea.width;
	self.frm_development.height	:= self.frm_workArea.height - 2;
	self.frm_development.width	:= self.frm_workArea.width - self.frm_notepad.width;
	self.frm_development.left	:= self.frm_notepad.width;

end;
</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="beff6719-df6e-4c00-8f0d-f7ccef5d315c">
        <updating/>
        <source>doSave() updating;
/*--------------------------------------------------------------------
Created:	08 April 2007 By cnwvu1
Purpose:	
----------------------------------------------------------------------
*/
vars
	ptch: Patch;
	scm	: SchemaInPatch;
	cls	: ClassInSchema;
	mtd	: MethodInClass;
	appl: AppInSchema;
	topicString, priorityString : String;
	ticketType, patchNo : String;		// TFS 38497 jlgmd1 12/10/2018
	
begin

	if self.chk_webPatch.value then
		if not self.validateWeb(true, ptch) then
			return;
		endif;
	elseif self.chk_formatUNL.value then	// UNL format
		if not self.validateUNL( true, ptch ) then
			return;
		endif;
	else	// Tree format
		if not self.validateNotepad( true, ptch, scm, cls, mtd, appl ) then
			return;
		endif;
	endif;
	
	if self.opt_PriorityA.value then
		priorityString := ", Priority A";
	else
		priorityString := ", Priority B";
	endif;
	
	// TFS 38497 jlgmd1 12/10/2018
	if self.inTFSMode then
		ticketType := Patch.Readme_TFS;
	else
		ticketType := Patch.Readme_PAR;
	endif;
	
	topicString := self.cmb_Topic.text &amp; priorityString &amp; CrLf &amp; ticketType &amp; '-' &amp; self.txt_parNo.text &amp; ", Advised by : " &amp; self.cmb_Customer.text;

// save data
	beginTransaction;
	
	patchNo := self.txt_parNo.text;	
	ptch := app.myRootHotFix.allPatches[ patchNo ];
	
	// TFS 38497 jlgmd1 12/10/2018
	// If we are creating a TFS patch, but our existing patch is not a TFS one, then we really want to be editing the TFS one instead!
	if ptch &lt;&gt; null then
		if self.inTFSMode and not ptch.isTFSPatch then
			patchNo := app.myRootHotFix.TFS_NUMBER_MASK &amp; patchNo;
			ptch := app.myRootHotFix.allPatches[ patchNo ];
		endif;
	endif;
	
	if ptch = null then
		create ptch;
		//ptch.setForCreate( self.txt_parNo.text, self.chk_SCMDDB.value, self.chk_singleuser.value, topicString, self.txt_ParDescr.text, self.txt_CloseDetail.text, self.txt_AreasAffect.text );
		ptch.setForCreate( patchNo, self.chk_SCMDDB.value, self.chk_singleuser.value, self.inTFSMode, topicString, self.txt_ParDescr.text, self.txt_CloseDetail.text, self.txt_AreasAffect.text, self.txt_tag.text );	// TFS 38497 jlgmd1 12/10/2018
	else
		ptch.deletePatch( false );	// deletes all childs: scemas, classes and methods of the Par
		//ptch.set( self.txt_parNo.text, self.chk_SCMDDB.value, self.chk_singleuser.value, topicString, self.txt_ParDescr.text, self.txt_CloseDetail.text, self.txt_AreasAffect.text );
		ptch.set( patchNo, self.chk_SCMDDB.value, self.chk_singleuser.value, self.inTFSMode, topicString, self.txt_ParDescr.text, self.txt_CloseDetail.text, self.txt_AreasAffect.text, self.txt_tag.text );	// TFS 38497 jlgmd1 12/10/2018
	endif;
	
	if self.chk_webPatch.value then
		if not self.validateWeb(false, ptch) then
			abortTransaction;
			return;
		endif;
	elseif self.chk_formatUNL.value then	// UNL format
		if not self.validateUNL( false, ptch ) then
			abortTransaction;
			return;
		endif;
	else	// Tree format
		if not self.validateNotepad( false, ptch, scm, cls, mtd, appl ) then
			abortTransaction;
			return;
		endif;
	endif;
	
	commitTransaction;
	
	if ptch.isTFSPatch then
		self.setMode( self.MODE_NORMAL_TFS );	// TFS 38497 jlgmd1 12/10/2018
	else
		self.setMode( self.MODE_NORMAL );
	endif;
	
	//cnwmc5 - 25 Feb 2014 - PAR 32864
	self.setTextForNotepad( ptch );

epilog
	abortTransaction;
end;
</source>
    </JadeMethod>
    <JadeMethod name="getNextLineFromNotepad" id="115b16df-4e6a-4950-b064-a492a23d70ee">
        <source>getNextLineFromNotepad( _text: String; _nStart,_nPos : Integer io ) : String;
/*--------------------------------------------------------------------
Created:	08 April 2007 By cnwvu1
Purpose:	get next line up to next CrLf
----------------------------------------------------------------------
*/

vars
	s : String;
	k : Integer;
	
begin

	_nPos := _text.pos( CrLf, _nStart );
	if _nPos = 0 then
		return '';
	endif;
	
	s := '';
	k := _nStart;
	while k &lt;= _nPos-1 do
		s := s &amp; _text[k];
		k := k + 1;
	endwhile;
	//	s := _text[ _nStart : _nPos-1 ]; - this works in the wrong way
	
	return s.trimRight;
	
end;
</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_nStart" type="Integer" usage="io"/>
        <Parameter name="_nPos" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTokensForDoubleColon" id="c6a3ecd7-230f-475d-b07d-dd3743218d5a">
        <source>getTokensForDoubleColon(_str : String; _tokens : HugeStringArray input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2014	cnwmc5	Initial creation	PAR 32864

*/

vars
	theToken	: String;
	pos			: Integer;

begin

	if _str = null then
		return;
	endif;

	pos := 1;
	while (pos &gt; 0) do
		theToken := _str.scanUntil(":", pos);  // Outputs this
		if _str[pos+1] = ":" 
		or pos = 0 then
			_tokens.add(theToken);
		endif;
		if pos = 0 then
			break;
		endif;
		pos := pos + 2;
	endwhile;
	
epilog

end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_tokens" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="inTFSMode" id="a2581019-4a8f-42ed-94c9-3cc565a68d41">
        <source>inTFSMode() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 October 2018	jlgmd1	Initial creation TFS 38497

*/

vars

begin

	return self.mode = self.MODE_EDIT_TFS or self.mode = self.MODE_NORMAL_TFS or self.mode = self.MODE_INSERT;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="installPatchOnS11" id="cec1e6b5-e761-4d43-9a02-4059ca3639db">
        <updating/>
        <source>installPatchOnS11() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 January 2014	cnwmc5	Initial creation

*/

vars
	batchFile	: String;
	result		: Integer;
	
	file		: File;
	patch		: Patch;
begin
	executeWhen JMTDevelopmentEnvironment;
		app.msgBox("Unable to install patches/hotfixes from a DEVELOPMENT environment", "Hotfix/Patch Create", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endExecuteWhen;

	self.mousePointer := Window.MousePointer_HourGlass;
	
	//batchFile:= '\\cnwchcm24\cnwpod$\Releases\' &amp; self.txtReleaseNo.text &amp; '\Hotfixes-pending\' &amp; self.txt_patch.text &amp; '_Par' &amp; self.txt_parNo.text &amp; '\autoinstall.bat';
	patch := app.myRootHotFix.allPatches[ self.txt_parNo.text ];
	
	// TFS 38497 jlgmd1 12/10/2018 START
	if self.inTFSMode and patch = null or not patch.isTFSPatch then
		patch := app.myRootHotFix.allPatches[ app.myRootHotFix.TFS_NUMBER_MASK &amp; self.txt_parNo.text ];
	endif;
	
	if patch = null then
		write "Patch " &amp; self.txt_parNo.text &amp; " not found";
		return;
	endif;
	
	batchFile := patch.getPatchDirectory &amp; 'autoinstall.bat';			// Grab the local patch dir
	batchFile := app.myRootHotFix.DIR_FILE_SHARE &amp; batchFile[3:end];	// And then convert it to the UNC path
	// TFS 38497 jlgmd1 12/10/2018 END
	
	create file transient;
	file.fileName := batchFile;
	if not file.isAvailable then
		self.doCreateFiles();
		
		// And grab the file again now we actually have a patch number
		batchFile := patch.getPatchDirectory &amp; 'autoinstall.bat';			// Grab the local patch dir
		batchFile := app.myRootHotFix.DIR_FILE_SHARE &amp; batchFile[3:end];	// And then convert it to the UNC path
	endif;
	
	node.createExternalProcess(null, batchFile, null, null, true, true, result);
epilog
	self.mousePointer := Window.MousePointer_Default;
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="isExportSubClasses" id="bec45a57-6e14-4adb-9463-4dc7f4e11b2b">
        <source>isExportSubClasses( _notepadStr : String ) : Boolean;
/* ---------------------------------------------------------------------------
Created:	26 February 2010	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	return _notepadStr[_notepadStr.length - 2 : end] = app.myRootHotFix.EXTRACT_SUBCLASSES_STR;

end;</source>
