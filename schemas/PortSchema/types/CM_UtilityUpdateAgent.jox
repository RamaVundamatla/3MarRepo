    <JadeMethod name="utlRenameTerminalAreaView" id="6dcaf114-b020-4fe8-b0ea-837778022e30">
        <updating/>
        <source>utlRenameTerminalAreaView(_terminalAreaView : CM_TerminalAreaView input; _newName : String;_passport : CM_Passport ) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 November 2010	cnwer1	Initial creation

*/

vars
	terminal : CM_Terminal;
	taView : CM_TerminalAreaView;
begin
	if _terminalAreaView = null then
		return;
	endif;
	
	
	if _terminalAreaView.name = _newName then
		return;
	endif;
	
	terminal := _terminalAreaView.myTerminal;
	if terminal &lt;&gt; null then
		if terminal.allTerminalAreaViews[null,_newName] &lt;&gt; null then
			//raise exception 
			app.raiseCMException2(Duplicate_ID_For,_newName,"Terminal Area View", null,null);
			return;
		endif;
	endif;
	
	_terminalAreaView.setName(_newName);
	_terminalAreaView.causeEvent(_passport.myTerminal.getTerminalEvent(Event_TAView_Update),false,_passport.myUser);
epilog

end;</source>
        <Parameter name="_terminalAreaView" type="CM_TerminalAreaView" usage="input"/>
        <Parameter name="_newName" type="String"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlReplaceTMInvoiceLineType" id="e654f967-1714-4bac-9ead-99f27e3406ef">
        <updating/>
        <source>utlReplaceTMInvoiceLineType(_topLevel : CM_FinancialObject;  _fromILD : CM_InvoiceLineDesc; _toILD : CM_InvoiceLineDesc; _passport : CM_Passport input) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     Sept 2013	cnwjre1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	count			: Integer;
	serviceMap		: CM_TIServiceMap;
	productGroupMap	: CM_ProductGroupMap;
	productMap		: CM_ProductMap;
	imexMap			: CM_ImexServiceMap;
	contentsMap		: CM_ContentsMap;
	commodityMap	: CM_CommodityMap;
	broker			: CM_TransServiceBroker;
	debtorMap		: CM_DebtorMap;
begin

	self.initialiseActivity();
	
	// do validation
	if _fromILD = null or 
	   _toILD = null then
		return 0;
	endif;
	if _fromILD = _toILD then
		return 0;
	endif;

	if _passport.noErrors then
		if _topLevel.isKindOf(CM_TIServiceMap) then
			serviceMap := _topLevel.CM_TIServiceMap;
			count := serviceMap.replaceInvoiceLineTypes(_fromILD, _toILD);
		elseif _topLevel.isKindOf(CM_ProductGroupMap) then
			productGroupMap := _topLevel.CM_ProductGroupMap;
			count := productGroupMap.replaceInvoiceLineTypes(_fromILD, _toILD);
		elseif _topLevel.isKindOf(CM_ProductMap) then
			productMap := _topLevel.CM_ProductMap;
			count := productMap.replaceInvoiceLineTypes(_fromILD, _toILD);
		elseif _topLevel.isKindOf(CM_ImexServiceMap) then
			imexMap := _topLevel.CM_ImexServiceMap;
			count := imexMap.replaceInvoiceLineTypes(_fromILD, _toILD);
		elseif _topLevel.isKindOf(CM_ContentsMap) then
			contentsMap := _topLevel.CM_ContentsMap;
			count := contentsMap.replaceInvoiceLineTypes(_fromILD, _toILD);
		elseif _topLevel.isKindOf(CM_CommodityMap) then
			commodityMap := _topLevel.CM_CommodityMap;
			count := commodityMap.replaceInvoiceLineTypes(_fromILD, _toILD);
		elseif _topLevel.isKindOf(CM_TransServiceBroker) then
			broker := _topLevel.CM_TransServiceBroker;
			count := broker.replaceInvoiceLineTypes(_fromILD, _toILD);
		elseif _topLevel.isKindOf(CM_DebtorMap) then
			debtorMap := _topLevel.CM_DebtorMap;
			count := debtorMap.replaceInvoiceLineTypes(_fromILD, _toILD);
		endif;
	endif;

	return count;

end;</source>
        <Parameter name="_topLevel" type="CM_FinancialObject"/>
        <Parameter name="_fromILD" type="CM_InvoiceLineDesc"/>
        <Parameter name="_toILD" type="CM_InvoiceLineDesc"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
