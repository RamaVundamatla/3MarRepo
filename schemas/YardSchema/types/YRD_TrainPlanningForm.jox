    <JadeMethod name="makeFrameRake" id="e360ad84-0731-4b92-8d63-1bd01512f98a">
        <updating/>
        <source>makeFrameRake() updating;
// ---------------------------------------------------------------------------
// Created:     June 2009
//
// Purpose:     Make another scrolling grid area
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	newGridArea : YRD_RailDockBar;
	newSDF : CMUI_ScrollableDrawingFrame;
	newDragSelect : CMUI_GridAreaDrawingFrame;

begin
	newGridArea := self.dkbGridArea.loadControl(self.maxGridAreas).YRD_RailDockBar;
	newSDF := self.mySDF.loadControl(self.maxGridAreas).CMUI_ScrollableDrawingFrame;
	newDragSelect := self.frmDragSelect.loadControl(self.maxGridAreas).CMUI_GridAreaDrawingFrame;

	newSDF.top := 0;
	newSDF.scrollBars := self.mySDF.scrollBars;
	newSDF.labels := self.mySDF.labels;
	newSDF.setHLabelDetails(self.mySDF.myHLabels.height);
	newSDF.setVLabelDetails(self.mySDF.myVLabels.width);
	newSDF.labels := self.mySDF.labels;
	newSDF.displayMode := self.mySDF.displayMode;
	newSDF.moveMode := self.mySDF.moveMode;
	newSDF.viewMode := self.mySDF.viewMode;
	newSDF.scaleFactor :=self.mySDF.scaleFactor;
	newSDF.caption := null;
	newSDF.myTerminal := self.myTerminal;
	newSDF.setupFrame();

	newSDF.picture1 := self.mySDF.picture1;
	newSDF.picture2 := self.mySDF.picture2;
	newSDF.picture3 := self.mySDF.picture3;
	newSDF.picture4 := self.mySDF.picture4;
	newSDF.myParentForm := self;
	
	newGridArea.setCreate( newSDF, newDragSelect );
	self.allGridAreaDockBars.add(newGridArea);
	
	self.maxGridAreas := self.maxGridAreas + 1;

epilog

end;</source>
    </JadeMethod>
