    <JadeMethod name="loadForm" id="e58f5cde-f128-401f-a560-8f784efefe2e">
        <updating/>
        <source>loadForm()updating;

/*****************************************************
	Written by	:	cnwgrp1		04 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	myDA.allOpenForms.add(self);
	myDataDA.setMyForm(self);
	centreWindow;
	if currentStep &lt; 2 then
		btnBack.enabled := false;
	endif;
	lblWizHeader.caption:= myDA.associatedObjectType &amp; " - " &amp;myDA.associatedObjectName ;
	
	if currentStep = 1 then
		lblStep1.fontBold := true;
		lblStep1.left := 10;
	elseif currentStep = 2 then
		lblStep2.fontBold := true;
		lblStep2.left := 10;
	elseif currentStep = 3 then
		lblStep3.fontBold := true;
		lblStep3.left := 10;
	elseif currentStep = 4 then
		lblStep4.fontBold := true;
		lblStep4.left := 10;
	elseif currentStep = 5 then
		lblStep5.fontBold := true;
		lblStep5.left := 10;
	elseif currentStep = 6 then
		lblStep6.fontBold := true;
		lblStep6.left := 10;
	endif;
	
	blnError := false;
epilog
	app.statusBusy(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="queryUnload" id="675d7c1e-f791-4a59-b812-42c622bf7be5">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;

/*****************************************************
	Written by	:	cnwpra1		16 July 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	error	: Boolean;

begin
	on UserInterfaceException do handleUserInterfaceException(exception, error);
	
	myDA.checkExcel;
	
	if error then
		cancel := 1;
	endif;
	
	
epilog

end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setBlnError" id="52450615-9db7-48f1-afd1-3b6926135a32">
