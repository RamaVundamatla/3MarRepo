    <JadeMethod name="delete" id="638c4bb8-19a0-4415-907b-c76aa117d7a8">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 Apr 2009	cnwer1	Initial creation
25 May 2009	cnwkpd1	PAR #19764 - Don't try to do collection maintenance if the receiver is a transient (proxy)
					This was causing a 1308 exception during the upgrade

*/

vars

begin
	/*	Because self.myVoyage.allPorts is an uninversed collection when this is deleted remove it from voyage 
		won't matter when user deletes the port rotation but if they ever delete a port this obj gets auto deleted because its a child
		then we can remove the port from the voyage */
	if not self.isTransient() and self.myVoyage &lt;&gt; null then
		if self.myVoyage.allPorts.includes(self.myPort) then
			self.myVoyage.allPorts.remove(self.myPort);
		endif;
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="includesPort" id="ef550634-134c-494f-b197-3ff280744f5c">
        <source>includesPort(_port : CM_Port) : Boolean;
/* ---------------------------------------------------------------------------
Created:     29 May 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	return self.myPort = _port or self.allTranshipPorts.includes(_port);

epilog

end;</source>
        <Parameter name="_port" type="CM_Port"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="5142171c-a6d6-49ad-91ae-61a4afab7b4f">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Date			Who		Reason
24 April 2009	cnwer1	Initial creation
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars

	pxyPortRotation: CM_PortRotation;
	completedOK		: Boolean;

begin
	pxyPortRotation := inheritMethod();
	pxyPortRotation.myPort := self.myPort;
	self.allTranshipPorts.copy(pxyPortRotation.allTranshipPorts);
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyPortRotation;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyPortRotation;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="7ad4b38c-6fb6-47ff-975c-fbdd8ffa0214">
        <updating/>
        <source>setForCreate(_pxyPortRotation : CM_PortRotation;
				_parent : CM_Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 April 2009	cnwer1	Initial creation

*/

vars

begin
	if _parent = null then
		return;
	endif;
	
	if _parent.isKindOf(CM_Trade) then
		self.myTrade:=_parent.CM_Trade;
	elseif _parent.isKindOf(CM_Voyage) then
		self.myVoyage:=_parent.CM_Voyage;
	endif;


	self.setForUpdate(_pxyPortRotation);

epilog

end;</source>
        <Parameter name="_pxyPortRotation" type="CM_PortRotation"/>
        <Parameter name="_parent" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="3f5c82aa-2c9c-440c-8099-3b3462995869">
        <updating/>
        <source>setForUpdate(_pxyPortRotation : CM_PortRotation) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 April 2009	cnwer1	Initial creation
31/8/17		MAP		Don't clear/recreate tranship ports unless they have changed TFS5551

*/

vars
	port : CM_Port;
	addedPorts : CM_PortSet;
	
begin
	self.myPort := _pxyPortRotation.myPort;
	
	if not self.allTranshipPorts.membersSame(_pxyPortRotation.allTranshipPorts) then
		self.allTranshipPorts.clear;
		create addedPorts transient;
		foreach port in _pxyPortRotation.allTranshipPorts discreteLock do
			if not addedPorts.includes(port) then // PAR 344038
				self.allTranshipPorts.add(port);
				addedPorts.add(port);
			endif;
		endforeach;
	endif;
	
epilog
	delete addedPorts;
	
end;</source>
        <Parameter name="_pxyPortRotation" type="CM_PortRotation"/>
    </JadeMethod>
    <JadeMethod name="setMyTrade" id="95a8c83b-db9f-44cf-9514-fbbd7767d3b1">
        <updating/>
        <source>setMyTrade(_trade : CM_Trade) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2017	jlgkpd1	Initial creation

*/

vars

begin
	if self.myTrade &lt;&gt; _trade then
		self.myTrade := _trade;
	endif;
	
epilog

end;</source>
        <Parameter name="_trade" type="CM_Trade"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyage" id="f3451f41-2d70-4adb-b7d8-8fcb18ac433d">
        <updating/>
        <source>setMyVoyage(_voyage : CM_Voyage) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2017	jlgkpd1	Initial creation

*/

vars

begin
	if self.myVoyage &lt;&gt; _voyage then
		self.myVoyage := _voyage;
	endif;
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="375954f8-e2ac-4281-ad73-95ec7a78eb5d">
        <updating/>
        <source>setProxy(_port : CM_Port;
			_parent : CM_Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 April 2009	cnwer1	Initial creation
//16 Apr 2018	jlgrs1	TFS 38147 fixup PortRotation addition (error if not transient)
*/

vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.myPort := _port;
	
	if _parent.isKindOf(CM_Trade) then
		self.myTrade := _parent.CM_Trade;
	elseif _parent.isKindOf(CM_Voyage) then
		self.myVoyage := _parent.CM_Voyage;
	endif;

epilog

end;</source>
        <Parameter name="_port" type="CM_Port"/>
        <Parameter name="_parent" type="CM_Object"/>
    </JadeMethod>
</Class>
