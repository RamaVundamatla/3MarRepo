        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAll_click(btn: Button input) updating;
// -------------------------------------------
// Created 29 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.currentButton := BTN_ALL; 
	self.btnSystem.value 	:= true;
	self.btnTerminal.value	:= true;
	self.setDisplaySystem();
	self.displayAllHistory();


end;</source>
