    <JadeMethod name="updateAllDetails" id="2b662660-6b2e-4ee5-b089-a3e575ba07d1">
        <source>updateAllDetails();

vars
	index					: Integer;
	object					: Object;
	helpForm				: CnEcHelpFormDetail;
	f1, f2					: Boolean;
	newKeyword, newHelpFile	: String;
	newContextID			: Integer;
	project					: String;
	time					: Real;
	date					: TimeStamp;
	error					: String;

begin
	table.accessMode := Table.AccessMode_Cell;

	foreach index in 2 to table.rows do
		table.row := index;

		// get helpForm

		table.column := 1;
		object := table.itemObject;
		helpForm := object.CnEcHelpFormDetail;

		table.column := 2;
		newKeyword := table.text.trimBlanks;

		table.column := 3;
		newContextID := table.text.trimBlanks.Integer;

		table.column := 4;
		newHelpFile := table.text.trimBlanks;

		if newKeyword &lt;&gt; helpForm.helpTopic or newContextID &lt;&gt; helpForm.helpContextID or newHelpFile &lt;&gt; helpForm.helpFile then
			beginTransaction;
			error := helpForm.update(date, helpForm.description, newKeyword, newContextID, newHelpFile);

			if error.length &gt; 0 then
				abortTransaction;
				app.msgBox(error, "Error on line " &amp; index.String, 0); 
			else
				commitTransaction;
			endif;
		endif;

		if error.length &gt; 0 then
			continue;
		endif;

		// time recording

		table.column := 5;
		project := table.text.trimBlanks();

		if project.length &gt; 0 then
			table.column := 6;
			time := table.text.trimBlanks().Real;
		endif;

		if time &gt; 0 then
			error := self.aMyHelp.addTime(project, date, 0, time);
		endif;

		// get Flags

		table.column := 7;
		f1 := (table.text.length &gt; 0 and table.text[1] &lt;&gt; "0");
		table.column := 8;
		f2 := (table.text.length &gt; 0 and table.text[1] &lt;&gt; "0");

		if f1 &lt;&gt; helpForm.flag1 or f2 &lt;&gt; helpForm.flag2 then	// only update if change
			beginTransaction;
			helpForm.updateFlags(f1, f2);
			commitTransaction;
		endif;
		
//		write( index.String &amp; Tab &amp; helpForm.form.name &amp; Tab &amp; f1.String &amp; Tab &amp; f2.String );
	endforeach;

	self.populateAllDetails();
end;</source>
    </JadeMethod>
    <JadeMethod name="updateChangedForm" id="deed9944-8fcb-4e00-9479-e5551845bdd4">
        <source>updateChangedForm();

vars
	cnEcHelpFormDetail	: CnEcHelpFormDetail;
	error				: String;
	form				: Form;
	myIndex				: Integer;
	cnEcHelpTime		: CnEcHelpTime;
begin
//	myIndex := lbChangedForms.listIndex;
	form := lstForms_change.listObject.Form;
	
	if form = null then
		form := lstForms_included.listObject.Form;
	else
		aAllChangedForms.remove(form);
		lstForms_change.listCollection(aAllChangedForms, false, 0);
	endif;
	cnEcHelpFormDetail := aMyHelp.getHelpForm(form);

	beginTransaction;
	error := cnEcHelpFormDetail.update(txtDateModified.text.TimeStamp, txtDescription.text, txtHelpKeyword.text, txtContextID.text.Integer, txtHelpFile.text);

	if error.length = 0 and chkTimeRecording.value then
		cnEcHelpTime := lstStored_list.listObject.CnEcHelpTime;
		if cnEcHelpTime &lt;&gt; null then
			error := aMyHelp.addTime(cnEcHelpTime.project, txtDateModified.text.TimeStamp, 0, txtTime.text.Real);	// 0 = keep current estimate
		endif;
	endif;

	if error.length = 0 then
		commitTransaction;
		self.populateProjects();
	else
		abortTransaction;
		app.msgBox(error, "Update Error", 0);
	endif;

	self.resetStoredDetail();
end;</source>
    </JadeMethod>
</GUIClass>
