    <JadeMethod name="createSystemQuickAccessObjects" id="2e31b1a4-1967-4218-a6c9-bf47c43f32b8">
        <source>createSystemQuickAccessObjects();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2014	cnwndl1	Initial creation
05/0302015	cnwmh5	Transient Leaks
*/

vars

	quickAccess : CM_QuickAccess;
	userQuickAccess : CM_QuickAccessUser;
	accessesToDelete : ObjectArray;
	iter : Iterator;
	
begin

	//Quick Accesses to remove  8.4.1
	create accessesToDelete transient;
	quickAccess := app.myRoot.allSystemQuickAccess.getAtKey("NPNW");  // replaced by new "VOPS", "Voyage Operations"
	if quickAccess &lt;&gt; null then
		iter := CM_QuickAccessUser.instances.createIterator;
		while iter.next(userQuickAccess) do
			if userQuickAccess.permissionInteger = PmShipOperationsView then
				accessesToDelete.add( userQuickAccess );
			endif;
		endwhile;
		if not accessesToDelete.isEmpty then
			beginTransaction;
			accessesToDelete.purge();
			delete quickAccess;
			commitTransaction;
		endif;
	endif;

	//any changes here need to be reflected in UiCommonSchema::CMUI_QuickFind::buildQuickAccessFormsHelp
	//and if anything special is required possibly UiCommonSchema::CMUI_QuickFind::openForm too.
	
	app.myRoot.createSystemQuickAccess( "BOL", PmShipGCOperationsView, "Voyage Cargo", true, false );
	app.myRoot.createSystemQuickAccess( "BOOK", PmGteBookingRefView, "Booking Enquiry", true, false );
	app.myRoot.createSystemQuickAccess( "BULK", PmGteMTReleaseView, "Bulk Release Enquiry", true, false );
	app.myRoot.createSystemQuickAccess( "CARGO", PmAdmCargoEnquiryView, "Cargo Enquiry", true, false );
	app.myRoot.createSystemQuickAccess( "CR", PmYardCargoReviewView, "Cargo Review", true, false ); // 10 Sept 2024	navab1	CR 66065
	app.myRoot.createSystemQuickAccess( "CD", PmAdmCustDocEnqView, "Custom Documents", true, false ); // 10 Sept 2024	navab1	CR 66065
	app.myRoot.createSystemQuickAccess( "EDI", PmAdmEdiopersView, "EDI Operations", true, false );
	app.myRoot.createSystemQuickAccess( "GATE", PmGteInOutFastView, "Road Gate", true, false );
	app.myRoot.createSystemQuickAccess( "IL", PmAdmInvoicelistView, "Invoice List", true, false ); // 10 Sept 2024	navab1	CR 66065
	app.myRoot.createSystemQuickAccess( "ILL", PmAdmInvoicelinesView, "Invoice Line List", true, false ); // 10 Sept 2024	navab1	CR 66065
	app.myRoot.createSystemQuickAccess( "IC", PmInvContractEnqView, "Invoice Contracts", true, false ); // 10 Sept 2024	navab1	CR 66065
	app.myRoot.createSystemQuickAccess( "JOB", PmShipJobOperationsMaint, "Voyage Job Operations", true, false );
	app.myRoot.createSystemQuickAccess( "LOLO", PmVoyagePlanningView, "LOLO Planning", true, false );
	//app.myRoot.createSystemQuickAccess( "NPNW", PmShipOperationsView, "Non-Planned Non-Worked", true, false );	// removed
	app.myRoot.createSystemQuickAccess( "OOW", PmAdmOrdworkView, "Order Of Works", true, false );
	app.myRoot.createSystemQuickAccess( "PACK", PmAdmLclpackView, "Pack/Unpack", true, false );
	app.myRoot.createSystemQuickAccess( "PRE", PmGtePreNoteView, "Pre-Notification Enquiry", true, false );
	app.myRoot.createSystemQuickAccess( "RAIL", PmAdmRailopsView, "Rail Operations", true, false );
	app.myRoot.createSystemQuickAccess( "ROAD", PmAdmRoadopsdualView, "Road Operations", true, false );
	app.myRoot.createSystemQuickAccess( "RORO", PmVoyageROROPlanningView, "RORO Planning", true, false );
	app.myRoot.createSystemQuickAccess( "RTQ", PmAdmQueueView, "Radio Telemetry Queue", true, false );
	app.myRoot.createSystemQuickAccess( "SAT", PmAdmSatelliteView, "Satellite View", true, false );
	app.myRoot.createSystemQuickAccess( "SEL", PmAdmSelectorView, "Selector Query", true, false );
	app.myRoot.createSystemQuickAccess( "S", PmAdmSystemTableView, "System Admin", true, true );
	app.myRoot.createSystemQuickAccess( "T", PmAdmTabledefineView, "Terminal Admin", true, true );
	app.myRoot.createSystemQuickAccess( "TA", PmAdmTermareadefView, "Terminal Area Definition", true, false );		// TFS 48992
	app.myRoot.createSystemQuickAccess( "VBS", PmGteVehSchView, "Vehicle Bookings", true, false );
	app.myRoot.createSystemQuickAccess( "VOPS", PmShipOperationsView, "Voyage Operations", true, false );
	app.myRoot.createSystemQuickAccess( "VOY", PmShipVoyageEnquiryView, "Voyage Enquiry", true, false );
	app.myRoot.createSystemQuickAccess( "VV", PmGteVisitRecordView, "Vehicle Visit Enquiry", true, false );
	app.myRoot.createSystemQuickAccess( "WO", PmAdmWorkOrderEnquiry, "Work Order Enquiry", true, false ); // 10 Sept 2024	navab1	CR 66065
	app.myRoot.createSystemQuickAccess( "WOP", PmAdmWorkOrderOperations, "Work Order Operations", true, false ); // 10 Sept 2024	navab1	CR 66065
	 
	app.myRoot.createSystemQuickAccess( "HH", PmAdmHandHeldLogonAs, "Hand Held Apps", false, false );		
	app.myRoot.createSystemQuickAccess( "VM", PmAdmVehicleRTLogonAs, "Vehicle Mounted App", false, true ); 
	

epilog

	delete accessesToDelete;
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createSystemSealCheckTypes" id="5254f863-ae68-4011-8894-eb612c53350b">
        <source>createSystemSealCheckTypes();
//
// 19 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 20/12/2017	jlgdap1	TFS 36347 STWR System Seals should only be updated / created if they don't exist already
//
vars
	sealType : CM_SealType;
	pxySealType : CM_SealType;
	entTableRowHdr : EntTableRowHeader;
	entTableRow : EntTableRow;
	description : String;
	allCargoTypes : CM_CargoTypeSet;
	converting : Boolean;
begin
	
	converting := app.isConverting;
	app.isConverting := true;
	create allCargoTypes transient;
	allCargoTypes.add( app.myRoot.allCargoTypesById.getAtKey(TI_CargoType_Container) );
	
	// Create the system Operators seal type if it doesn't exist.
	sealType := app.myRoot.getSealType(SealType_Operator);
	if sealType = null then
		description := null;
		entTableRowHdr := app.myRoot.myEntTableDataRoot.allEntTableRowHeadersByName[ETRow_SealNum];
		if entTableRowHdr &lt;&gt; null then
			entTableRow := entTableRowHdr.allEntTableRows.first;
			if entTableRow &lt;&gt; null then
				description := entTableRow.getHeading(null, null, app.myCurrentLocale);
			endif;
		endif;
		if description = null then
			description := "Operator Seal";
		endif;
		create pxySealType transient;
		pxySealType.setProxy(	SealType_Operator,	//_sealType: String;
								description,	//_description: String;
								allCargoTypes,	//_allCargoTypes: CM_CargoTypeSet;
								true,	//_allowMultipleSealNums: Boolean;
								false,	//_notAvailableForEntry: Boolean;
								true,	//_showSealOnCheck: Boolean;
								true,	//_savePrevSeal : Boolean
								false	//_useForTrucks : Boolean;
								);
		pxySealType.setIsInUse(true);						
		app.myTrxCA.trxCreateSealType(pxySealType, sealType, app.myPassport);	
	
		delete pxySealType;
	endif;

	// Create the system customs seal type if it doesn't exist.
	sealType := app.myRoot.getSealType(SealType_Customs);
	if sealType = null then
		description := null;
		entTableRowHdr := app.myRoot.myEntTableDataRoot.allEntTableRowHeadersByName[ETRow_SealNumCustoms];
		if entTableRowHdr &lt;&gt; null then
			entTableRow := entTableRowHdr.allEntTableRows.first;
			if entTableRow &lt;&gt; null then
				description := entTableRow.getHeading(null, null, app.myCurrentLocale);
			endif;
		endif;
		if description = null then
			description := "MAF/Customs Seal";
		endif;
		create pxySealType transient;
		pxySealType.setProxy(	SealType_Customs,	//_sealType: String;
								description,	//_description: String;
								allCargoTypes,	//_allCargoTypes: CM_CargoTypeSet;
								true,	//_allowMultipleSealNums: Boolean;
								false,	//_notAvailableForEntry: Boolean;
								true,	//_showSealOnCheck: Boolean;
								false,	//_savePrevSeal : Boolean
								false	//_useForTrucks : Boolean;
								);
		pxySealType.setIsInUse(true);						
		app.myTrxCA.trxCreateSealType(pxySealType, sealType, app.myPassport);	
	
		delete pxySealType;
	endif;
	
	// Create the system Shippers seal type if it doesn't exist.
	sealType := app.myRoot.getSealType(SealType_Shipper	);
	if sealType = null then
		description := null;
		entTableRowHdr := app.myRoot.myEntTableDataRoot.allEntTableRowHeadersByName[ETRow_SealNumShippers];
		if entTableRowHdr &lt;&gt; null then
			entTableRow := entTableRowHdr.allEntTableRows.first;
			if entTableRow &lt;&gt; null then
				description := entTableRow.getHeading(null, null, app.myCurrentLocale);
			endif;
		endif;
		if description = null then
			description := "Shippers Seal";
		endif;
		create pxySealType transient;
		pxySealType.setProxy(	SealType_Shipper,	//_sealType: String;
								description,	//_description: String;
								allCargoTypes,	//_allCargoTypes: CM_CargoTypeSet;
								true,	//_allowMultipleSealNums: Boolean;
								false,	//_notAvailableForEntry: Boolean;
								true,	//_showSealOnCheck: Boolean;
								false,	//_savePrevSeal : Boolean
								false	//_useForTrucks : Boolean;
								);
		pxySealType.setIsInUse(true);						
		app.myTrxCA.trxCreateSealType(pxySealType, sealType, app.myPassport);	
	
		delete pxySealType;
	endif;
	
	// Create the system vent seal type if it doesn't exist.
	sealType := app.myRoot.getSealType(SealType_Vent);
	if sealType = null then
		description := null;
		entTableRowHdr := app.myRoot.myEntTableDataRoot.allEntTableRowHeadersByName[ETRow_SealNumVent];
		if entTableRowHdr &lt;&gt; null then
			entTableRow := entTableRowHdr.allEntTableRows.first;
			if entTableRow &lt;&gt; null then
				description := entTableRow.getHeading(null, null, app.myCurrentLocale);
			endif;
		endif;
		if description = null then
			description := "Vent Seal";
		endif;
		create pxySealType transient;
		pxySealType.setProxy(	SealType_Vent,	//_sealType: String;
								description,	//_description: String;
								allCargoTypes,	//_allCargoTypes: CM_CargoTypeSet;
								true,	//_allowMultipleSealNums: Boolean;
								false,	//_notAvailableForEntry: Boolean;
								true,	//_showSealOnCheck: Boolean;
								false,	//_savePrevSeal : Boolean
								false	//_useForTrucks : Boolean;
								);
		pxySealType.setIsInUse(true);						
		app.myTrxCA.trxCreateSealType(pxySealType, sealType, app.myPassport);	
	
		delete pxySealType;
	endif;
	
	// Create the system Terminal Operator seal type if it doesn't exist.
	sealType := app.myRoot.getSealType(SealType_TerminalOperator);
	if sealType = null then
		description := null;
		entTableRowHdr := app.myRoot.myEntTableDataRoot.allEntTableRowHeadersByName[ETRow_SealNumTerminalOperator];
		if entTableRowHdr &lt;&gt; null then
			entTableRow := entTableRowHdr.allEntTableRows.first;
			if entTableRow &lt;&gt; null then
				description := entTableRow.getHeading(null, null, app.myCurrentLocale);
			endif;
		endif;
		if description = null then
			description := "Terminal Operator Seal";
		endif;
		create pxySealType transient;
		pxySealType.setProxy(	SealType_TerminalOperator,	//_sealType: String;
								description,	//_description: String;
								allCargoTypes,	//_allCargoTypes: CM_CargoTypeSet;
								true,	//_allowMultipleSealNums: Boolean;
								false,	//_notAvailableForEntry: Boolean;
								true,	//_showSealOnCheck: Boolean;
								false,	//_savePrevSeal : Boolean
								false	//_useForTrucks : Boolean;
								);
		pxySealType.setIsInUse(true);						
		app.myTrxCA.trxCreateSealType(pxySealType, sealType, app.myPassport);	
		
		delete pxySealType;
	endif;

	// Create the system Unknown seal type if it doesn't exist.
	sealType := app.myRoot.getSealType(SealType_Unknown);
	if sealType = null then
		description := null;
		entTableRowHdr := app.myRoot.myEntTableDataRoot.allEntTableRowHeadersByName[ETRow_SealNumUnknown];
		if entTableRowHdr &lt;&gt; null then
			entTableRow := entTableRowHdr.allEntTableRows.first;
			if entTableRow &lt;&gt; null then
				description := entTableRow.getHeading(null, null, app.myCurrentLocale);
			endif;
		endif;
		if description = null then
			description := "Unknown Seal";
		endif;
		create pxySealType transient;
		pxySealType.setProxy(	SealType_Unknown,	//_sealType: String;
								description,	//_description: String;
								allCargoTypes,	//_allCargoTypes: CM_CargoTypeSet;
								true,	//_allowMultipleSealNums: Boolean;
								false,	//_notAvailableForEntry: Boolean;
								true,	//_showSealOnCheck: Boolean;
								false,	//_savePrevSeal : Boolean
								false	//_useForTrucks : Boolean;
								);
		pxySealType.setIsInUse(true);						
		app.myTrxCA.trxCreateSealType(pxySealType, sealType, app.myPassport);	
		
		delete pxySealType;
	endif;
epilog
	delete pxySealType;
	delete allCargoTypes;
	app.isConverting := converting;
end;</source>
    </JadeMethod>
    <JadeMethod name="createTransMapInvLineGroupType" id="0e655945-50bb-46fe-94c6-82b1c3b424dd">
        <source>createTransMapInvLineGroupType();

/*

Purpose:		Create Transaction Map Invoice Line Group Types

Date			Who		Reason
21/01/2014		cnwmh5	Initial creation

*/

vars
	
	root	: CM_Root;
	mapType	: CM_TranMapInvoiceLineGroupType;
	
begin
	
	root := app.myRoot;
	
	// ### TFS CR 56446 TASK 56447 13FEB2023 NAVAB1
	// ### TFS CR 56446 TASK 56447 13FEB2023 NAVAB1
	beginTransaction;
	if root.allTMInvLineGrpTypes[TranMapInvLineGroupTypeAll] = null then
		create mapType persistent;
		mapType.update("All", TranMapInvLineGroupTypeAll, root);
	endif;
	
	if root.allTMInvLineGrpTypes[TranMapInvLineGroupTypeLow] = null then
		create mapType persistent;
		mapType.update("Lowest", TranMapInvLineGroupTypeLow, root);
	endif;
	
	if root.allTMInvLineGrpTypes[TranMapInvLineGroupTypeLowDef] = null then
		create mapType persistent;
		mapType.update("Lowest Default", TranMapInvLineGroupTypeLowDef, root);
	endif;
	
	mapType:= root.allTMInvLineGrpTypes[TranMapInvLineGroupTypeHigh];
	if mapType = null then
		create mapType persistent;
		mapType.update("Highest 1", TranMapInvLineGroupTypeHigh, root);
	else
		mapType.update("Highest 1", TranMapInvLineGroupTypeHigh, root);
	endif;
	
	if root.allTMInvLineGrpTypes[TranMapInvLineGroupTypeHigh2] = null then
		create mapType persistent;
		mapType.update("Highest 2", TranMapInvLineGroupTypeHigh2, root);
	endif;
	
	if root.allTMInvLineGrpTypes[TranMapInvLineGroupTypeHigh3] = null then
		create mapType persistent;
		mapType.update("Highest 3", TranMapInvLineGroupTypeHigh3, root);
	endif;
	
	if root.allTMInvLineGrpTypes[TranMapInvLineGroupTypeHigh4] = null then
		create mapType persistent;
		mapType.update("Highest 4", TranMapInvLineGroupTypeHigh4, root);
	endif;
	
	if root.allTMInvLineGrpTypes[TranMapInvLineGroupTypeHigh5] = null then
		create mapType persistent;
		mapType.update("Highest 5", TranMapInvLineGroupTypeHigh5, root);
	endif;
	
	mapType:= root.allTMInvLineGrpTypes[TranMapInvLineGroupTypeHighDef];
	if mapType = null then
		create mapType persistent;
		mapType.update("Highest 1 Default", TranMapInvLineGroupTypeHighDef, root);
	else
		mapType.update("Highest 1 Default", TranMapInvLineGroupTypeHighDef, root);
	endif;
	
	if root.allTMInvLineGrpTypes[TranMapInvLineGroupTypeHigh2Df] = null then
		create mapType persistent;
		mapType.update("Highest 2 Default", TranMapInvLineGroupTypeHigh2Df, root);
	endif;
	
	if root.allTMInvLineGrpTypes[TranMapInvLineGroupTypeHigh3Df] = null then
		create mapType persistent;
		mapType.update("Highest 3 Default", TranMapInvLineGroupTypeHigh3Df, root);
	endif;
	
	if root.allTMInvLineGrpTypes[TranMapInvLineGroupTypeHigh4Df] = null then
		create mapType persistent;
		mapType.update("Highest 4 Default", TranMapInvLineGroupTypeHigh4Df, root);
	endif;
	
	if root.allTMInvLineGrpTypes[TranMapInvLineGroupTypeHigh5Df] = null then
		create mapType persistent;
		mapType.update("Highest 5 Default", TranMapInvLineGroupTypeHigh5Df, root);
	endif;
	
	commitTransaction;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createVbsProcesses" id="a31a3151-0647-47d4-a31f-f267229ac8a3">
        <source>createVbsProcesses(_releaseController: CnEcReleaseController);
/*

Purpose:			Creates VBS Processes

Parameters:			_releaseController	CnEcReleaseController	Used for logging things and other functions

Return Value:		NONE

Date		Who		Reason
10 February 2023	navpw1	Initial creation TFS: 53697 (55830)

*/

vars
	vbsProcessStandard : CM_VBSProcessStandard;
	vbsProcessSlotVal : CM_VBSProcessSlotValidation;
begin
	if  app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_STANDARD_CODE] &lt;&gt; null and 
		app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE] &lt;&gt; null
	then
		_releaseController.logEntry("No processes need creating");
		return;
	endif;
	
	//Create standard vbs process
	if app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_STANDARD_CODE] = null then
		beginTransaction;
		//Create Standard VBS Process
		create vbsProcessStandard persistent;
		vbsProcessStandard.setProxy(CM_VBSProcess.VBS_STANDARD_CODE, CM_VBSProcess.VBS_STANDARD_DESC);
		vbsProcessStandard.setPropertyValue(CM_VBSProcessSlotValidation::myRoot.name, app.myRoot);
		commitTransaction;
		vbsProcessStandard := app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_STANDARD_CODE].CM_VBSProcessStandard;
		if vbsProcessStandard = null then
			_releaseController.logEntry("Error occurred vbs standard process not created");
		endif;
	endif;
	
	//Create Slot Type Validation VBS Process
	if app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE] = null then
		beginTransaction;
		create vbsProcessSlotVal persistent;
		vbsProcessSlotVal.setProxy(CM_VBSProcess.VBS_SLVALIDATION_CODE, CM_VBSProcess.VBS_SLVALIDATION_DESC);
		vbsProcessSlotVal.setPropertyValue(CM_VBSProcessSlotValidation::myRoot.name, app.myRoot);
		commitTransaction;
		vbsProcessSlotVal := app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE].CM_VBSProcessSlotValidation;
		if vbsProcessSlotVal = null then
			_releaseController.logEntry("Error occurred vbs slot type validation process not created");
		endif;
	endif;
	
	_releaseController.logEntry("Completed creating VBS Processes");
	
epilog
	abortTransaction;
end;</source>
        <Parameter name="_releaseController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="createYATypesStandard" id="07911658-ac99-4eff-a699-dec911871042">
        <source>createYATypesStandard();
// -------------------------------------------
// Created 20 September 2005 by cnwdvb1
/*

Date		Who		Reason
10/09/2009	cnwkpd1	PAR #19112 - New IsAvailable YA Criteria
31/05/2010	cnwdap1	CCMS 1116 new VoyageInbound and VoyageOutbound YA Criteria
15/07/2010	cnwdap1	PAR #24691 Correct Voyage Outbound description - it had "Special lift", not "Voyage Outbound"
27/10/2010	cnwjre1 PAR 21800 CCMS 1043 add contents status as YA and Inv Alloc criteria
07/02/2011	cnwdap1	PAR #26861 CCMS POL 2031 added destination terminal
05/07/2011	cnwmh5		#27807 - Add containerLength back after removed for 7.6.3
20/09/2012	cnwjre1	CCMS 1295 add IsEmpty
22/01/2013	cnwjre1 CCMS 1295 add isReefer
17/09/2013	cnwdap1	PAR #32215 CCMS DMP 2290 Add Vehicle Make, Model, Type, Year, isNew
28/04/2015	cnwdap1	PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements - added required temperature
16 Mar 2016	cnwrs1	TFS 1455 Add Freight Tons
26/04/2016  cnwma1  PAR #36914 TFS1768 Communicating/NonCommunciating Reefer Yard Allocation Criteria
02/06/2016	cnwdap1	TFS #1949 VGM Process Requirements - Allocations
20/12/2016	cnwdap1	TFS 3040 SNO Empty Container Pool Management
13/02/2017	cnwjre1	TFS 3285 AAT  Invoicing Tranship Cargo Based on the Operators of both the Inbound and Outbound Voyage
05/04/2017  cnwma1	TFS #3890:STWO - Add 'in transit' to Cargo allocations
24/07/2017	cnwma1	TFS #5513:STWO - Direct Delivery Invoicing Set-up
17/04/2017	jlgsl4	TFS 43798 - AAT - IsChild cargo invoice allocation
04/11/2019	jlgdap1	TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
04/11/2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
03/06/2022	jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
02JUN2022 	NAVSRK20	ChangeRequest 53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
25Oct2022	navhl20	TFS 53862 EUP - WMS - Damage Recording Extra Details
10/01/2023	jlika1	TFS 55588 - HS Code Yard Allocation criteria and Invoice Allocation
03 Mar 2023	navmv20 TFS 56216 Task 56217: Jade - New YA Criteria
08 Mar 2023 navsp1  TFS ChangeRequest 56795: PRP - Suzano EDI - Release Order
02/08/2023	navkc1	CR 59594  Task 59584: Jade - CustDocs New YA Criteria
18/08/2023	navkc1	CR 59603 Task 59604: UI - CustDocs More Stop Criteria
20/11/2023	jlika1	TFS 61133 61013 CUX | Cargo Priority - Yard Allocations
25/01/2023	jlika1	TFS 62138 62141 CUX | Add new YA Criteria
02 Feb 2023 navhl20 ChangeRequest 61960: FR | 57937 - [TKT: 61898] - Kiosk - US.080 'c' - Coded Instructions Missing from Additional question Criteria 
05 Apr 2024 navlc30 Bug 56071: PEN- VVR Package not sent
22 Jan 2025 navhn30 Story MTN-33826: CUX | MAFI Fields Missing from Yard Allocations - Jade changes and testing
27 May 2025	navdap1	MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
*/

vars
	proxyObj, realObj			: CM_YACriteriaType;
	avGradeObj					: CM_YATypeAvGrade;
	bookingRefObj				: CM_YATypeBookingRef;
	cargoTypeObj				: CM_YATypeCargoType;
	carrierObj					: CM_YATypeCarrier;
	cleanObj					: CM_YATypeClean;
	commReeferObj				: CM_YATypeCommReefer;
	commodityObj				: CM_YATypeCommodity;
	commodityGroupObj			: CM_YATypeCommodityGroup;
	consigneeObj				: CM_YATypeConsignee;
	consignorObj				: CM_YATypeConsignor;
	contentsObj					: CM_YATypeContentsStatus;						// par 21800
	containerLengthObj			: CM_YATypeContainerLength;
	destinationPortObj			: CM_YATypeDestinationPort;
	dischargePortObj			: CM_YATypeDischargePort;
	transhipToPortObj			: CM_YATypeTranshipToPort;						//cnwas3 ccms 1028
	freightForwarderObj 		: CM_YATypeFreightForwarder;
	freightTonsObj				: CM_YATypeFreightTons;
	hazardousObj				: CM_YATypeHazardous;
	heavyDutyObj				: CM_YATypeHeavyDuty;
	isIntendedRelMode   		: CM_YATypeIntendedRelMode;
	isoObj						: CM_YATypeISO;
