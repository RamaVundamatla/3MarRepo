    <JadeMethod name="getPositionAsPercentage" id="247c7caa-e0ba-4fb3-8b50-a8aeb8c08c4d">
        <source>getPositionAsPercentage(_x, _y : Integer; _xPercent, _yPercent : Real output);
// ---------------------------------------------------------------------------
// Created:     14 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	maxVal	: Real;
begin

	if self.myScrollingFrame = null then
		return;
	endif;

	maxVal := self.myScrollingFrame.clientWidth;
	if maxVal = 0 then
		_xPercent := 0;
	else
		_xPercent := (_x / maxVal) * 100;
	endif;
	
	maxVal := self.myScrollingFrame.clientHeight;
	if maxVal = 0 then
		_yPercent := 0;
	else
		_yPercent := (_y / maxVal) * 100;
	endif;

end;</source>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_xPercent" type="Real" usage="output"/>
        <Parameter name="_yPercent" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getScrollValues" id="b5dfd584-3f97-4d1c-808e-62a242be476f">
        <source>getScrollValues(_hScroll, _vScroll : Integer output);
//--------------------------------------------------
// Created:	25 May 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	_hScroll := self.myHScroll.value;
	_vScroll := self.myVScroll.value;
end;</source>
        <Parameter name="_hScroll" type="Integer" usage="output"/>
        <Parameter name="_vScroll" type="Integer" usage="output"/>
    </JadeMethod>
