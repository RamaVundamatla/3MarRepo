    <JadeMethod name="setLoggedOn" id="9583da92-df8e-4d7c-b616-f49a15003fd2">
        <updating/>
        <source>setLoggedOn(_value : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2009	cnwer1	Initial creation

*/

vars

begin
	if self.loggedOn &lt;&gt; _value then
		self.loggedOn:=_value;
		//ccms 1076 
		self.checkMachineCoverage(self.myPrimaryQueue); 
		//epr TFS 995 22/5/17
		if self.loggedOn then
			self.resetFaultQuestions();
		endif;
	endif;
	
	if self.loggedOn then
		self.setLastGetMessageTS;
	endif;
		
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
