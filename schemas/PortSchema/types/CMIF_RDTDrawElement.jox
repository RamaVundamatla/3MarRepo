    <JadeMethod name="drawGridTopColumnHeaderTopDown" id="6aaec1c4-118a-45fb-86df-234c45c75ccf">
        <source>drawGridTopColumnHeaderTopDown(_x1, _y1, _x2, _y2 : Real; _frame : Frame input; _scaleFactor : Real;  _isLandScape, _flipH, _flipV : Boolean; _mode : Integer; _isGapCol : Boolean)protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21/06/2011 cnwdz2	27732
29 May 2012 cnwer1	PAR 29588
*/
vars
	lc 				: CM_LocationsController;
	gridLc			: CM_GridController;
	headerX, headerY,
	noAccessDrawY,
	widthPixels	: Real;
	topLabel,
	label 	: String;
	labelTextHeight : Real;
	forkLiftStack : CM_ForkLiftStack;
	tmpTA	: CM_GridArea;
begin	
	if _frame = null then
		return;
	endif;
	
	lc := self.getLocationController();
	if lc = null or not lc.isKindOf(CM_GridController) then
		return;
	endif;
	gridLc := lc.CM_GridController;
	
	tmpTA := gridLc.getMyTerminalArea.CM_GridArea;
	//17/06/2011 cnwdz2 27732
	if tmpTA.isKindOf(CM_ForkLiftStack) then
		forkLiftStack := tmpTA.CM_ForkLiftStack;
	endif;
	
	if _isLandScape then
		widthPixels := self.getSizeInPixels(self.heightFt, _scaleFactor);
		label := gridLc.getColumnLabel(true);
	else
		widthPixels := self.getSizeInPixels(self.widthFt, _scaleFactor);
		label := gridLc.getRowLabel();
	endif;
	
	//08/10/2010 cnwdz2 par25671
	if lc.isGap() then
		if _isGapCol then
			widthPixels := lc.getGapWidthPixels(widthPixels);
		endif;
	endif;
	
	if _flipH then 
		headerX := _x2 - widthPixels/2;
	else
		headerX := _x1 + widthPixels/2;		
	endif;

	labelTextHeight := _frame.drawTextHeight(label);

	if _flipV then
		headerY := _y2 + (_y2-_y1)/2 - labelTextHeight/2;
	else
		headerY := _y1 + (_y2-_y1)/2 - labelTextHeight/2;
	endif;
	
	//17/06/2011 cnwdz2 27732
	if _isLandScape then
		if _mode = self.MODE_FACE then				
			
			if forkLiftStack &lt;&gt; null and not self.lookForkLiftStackFromBottom then
				topLabel := tmpTA.topLabel;
			else
				topLabel := tmpTA.bottomLabel;
			endif;
		
			if topLabel &lt;&gt; null then	
				if (_flipH and gridLc.myGridColumn.column = tmpTA.allGridColumns.size) or 
				   (not _flipH and gridLc.myGridColumn.column = 1) then						
					_frame.drawTextAt(topLabel, headerX+1, 1, Red);						
				endif;									
				headerY := headerY + 5;
			endif;
		else
			if _flipV and tmpTA.bottomLabel &lt;&gt; null then
				if (_flipH and gridLc.myGridColumn.column = tmpTA.allGridColumns.size) or 
				   (not _flipH and gridLc.myGridColumn.column = 1) then						
					_frame.drawTextAt(tmpTA.bottomLabel, headerX+1, 1, Red);						
				endif;	
				headerY := headerY + 5;
			endif;
			
			if not _flipV and tmpTA.topLabel &lt;&gt; null then	
				if (_flipH and gridLc.myGridColumn.column = tmpTA.allGridColumns.size) or 
				   (not _flipH and gridLc.myGridColumn.column = 1) then						
					_frame.drawTextAt(tmpTA.topLabel, headerX+1, 1, Red);						
				endif;	
				headerY := headerY + 5;
			endif;					
		endif;
		
		//17/06/2011 cnwdz2 27732
		if forkLiftStack &lt;&gt; null and 
			((not forkLiftStack.accessFront and gridLc.myGridRow.row = tmpTA.allGridRows.size) or
			(not forkLiftStack.accessBack and gridLc.myGridRow.row = 1)) then			   
			_frame.drawWidth := 3;
			if _flipV then
				noAccessDrawY := (_y2-_y1) - 2;
			else
				noAccessDrawY := _y2 - 2;
			endif;
			_frame.drawLine(_x1,noAccessDrawY,_x2,noAccessDrawY,Red);					
		endif;
	else
		if _flipV and tmpTA.rightLabel &lt;&gt; null then
			if (_flipH and gridLc.myGridRow.row = tmpTA.allGridRows.size) or 
			   (not _flipH and gridLc.myGridRow.row = 1) then						
				_frame.drawTextAt(tmpTA.rightLabel, headerX+1, 1, Red);						
			endif;	
			headerY := headerY + 5;
		endif;
		
		if not _flipV and tmpTA.leftLabel &lt;&gt; null then	
			if (_flipH and gridLc.myGridRow.row = tmpTA.allGridRows.size) or 
			   (not _flipH and gridLc.myGridRow.row = 1) then						
				_frame.drawTextAt(tmpTA.leftLabel, headerX+1, 1, Red);						
			endif;	
			headerY := headerY + 5;
		endif;					
	endif;
	_frame.drawTextAlign := Frame.DrawTextAlign_Center;
	_frame.drawTextAt(label, headerX, headerY, Black);
	
			

	
end;</source>
