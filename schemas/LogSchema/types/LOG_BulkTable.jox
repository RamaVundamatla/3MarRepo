    <JadeMethod name="cnEcResizeContents" id="9f8ffe45-160e-43b7-9b59-e694547292b4">
        <updating/>
        <source>cnEcResizeContents() updating;
//--------------------------------------------------------------
//Created: August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	numRows,
	numColumns,
	r, c 		: Integer;
	inputText, 
	outputText 	: String;
	cellInputType,
	newRowHeight, 
	cellWidth, 
	cellHeight 	: Integer;
	idx			: Integer;

begin

	if (not self.visible) then
		return;
	endif;

	numRows := self.rows;
	numColumns := self.columns;
	newRowHeight := (self.height/numRows).Integer;	
	cellWidth := (self.width/numColumns).Integer;	

	foreach r in 1 to numRows do
		self.rowHeight[r] := newRowHeight;
		foreach c in 1 to numColumns where self.columnVisible[c] do
			cellInputType := self.accessCell(r, c).inputType;
			if cellInputType &lt;&gt; InputType_None and
			   cellInputType &lt;&gt; InputType_TextBox then
				continue;
			endif;
			inputText := self.getCellText(r, c);
			if inputText &lt;&gt; null then
				self.fitTextToCell(inputText, outputText, cellWidth, cellHeight);
				if outputText &lt;&gt; inputText then
					self.setCellText(r, c, outputText);
				endif;
			endif;
		endforeach;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="5ab7fba8-f3cb-4fbc-a8eb-cc90e3de1d6d">
        <updating/>
        <source>gotFocus(table: Table input) updating;
//--------------------------------------------------------------
//Created: 12 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.tabKey := J_key_Tab;

	inheritMethod(table);

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleFormTab" id="10c4e785-0d57-4f43-aa90-36afdfb4b02f">
        <updating/>
        <source>handleFormTab(keyCode: Integer io; shift: Integer; pPrev, pNext : Control) updating;
//--------------------------------------------------------------
//Created: 25 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	entTable	: LOG_BulkTable;
	lastRowControl,
	prevControl,
	nextControl,
	theActiveControl,
	tmpControl	: Control;

	idx			: Integer;
	max			: Integer;	

begin

	if keyCode &lt;&gt; J_key_Tab then
		// Tab has not been pressed so no need to handle
		return;
	endif;

	theActiveControl := app.activeControl;

	if theActiveControl.parent.isKindOf(LOG_BulkTable) then
		theActiveControl := theActiveControl.parent.Control;
	endif;

	prevControl := pPrev;
	nextControl := pNext;
	
	if shift = 0 and theActiveControl = prevControl then
		// moving forward into table
		if prevControl.isKindOf(LOG_BulkTable) then
			entTable := prevControl.LOG_BulkTable;
			if entTable.accessSheet(entTable.topSheet).row = entTable.rows then
				// on last row of previous table so move to first row of this table
				self.accessSheet(self.topSheet).row := self.fixedRows + 1;
			endif;
		else
			self.accessSheet(self.topSheet).row := self.fixedRows + 1;
		endif;
		
	elseif shift = 1 and theActiveControl = nextControl then
		// moving back into table
		
		if nextControl.isKindOf(LOG_BulkTable) then
			entTable := nextControl.LOG_BulkTable;
			if entTable.accessSheet(entTable.topSheet).row = entTable.fixedRows + 1 then
				// on top row of next table so move to last row of this table
				self.accessSheet(self.topSheet).row := self.rows;
			endif;
		else
			self.accessSheet(self.topSheet).row := self.rows;
		endif;
	endif;

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="pPrev" type="Control"/>
        <Parameter name="pNext" type="Control"/>
    </JadeMethod>
    <JadeMethod name="handleTableTab" id="01934fa7-e957-4ab6-a141-b214a568636d">
        <updating/>
        <source>handleTableTab(shift : Integer) updating;
//--------------------------------------------------------------
//Created: 25 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpRow	: Integer;

begin
	tmpRow := self.rowForTopSheet;
	
	if tmpRow = self.rows and 
	   self.column = self.columns and shift = 0 then
		self.tabKey := 0;
		self.form.tabNext();
		self.selected := false;

	elseif tmpRow = (self.fixedRows + 1) and 
	   self.column = self.columns and shift = 1 then
		self.tabKey := 0;
		self.form.tabPrior();
		self.selected := false;
	else
	endif;

end;</source>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="2f941e49-8052-49eb-959d-d8b311a3b1e7">
