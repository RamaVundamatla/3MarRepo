    <JadeMethod name="getMenuHdrSystem" id="74627b4a-1f2d-4a0b-ba6a-00f9ffb36c52">
        <source>getMenuHdrSystem(_id: String): CM_MenuHdrSystem;
// ---------------------------------------------------------------------------
// Created:     16 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.allMenuItems[MenuType_HeaderSystem, _id].CM_MenuHdrSystem;

end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_MenuHdrSystem"/>
    </JadeMethod>
    <JadeMethod name="getMenuItemsDict" id="73a5dcd0-ad8c-4934-85d0-d0a373071c9f">
        <source>getMenuItemsDict(): CM_MenuItemByTypeMenuIdDict;
// ---------------------------------------------------------------------------
// Created:     16 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.allMenuItems;

end;</source>
        <ReturnType type="CM_MenuItemByTypeMenuIdDict"/>
    </JadeMethod>
    <JadeMethod name="getReportByConstantValue" id="abc042d4-7c59-4e38-90ae-acbeccfc9cb0">
        <source>getReportByConstantValue(_constantValue : Integer) : CM_QryReport;
// ---------------------------------------------------------------------------
// Created:     28 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuItem			: CM_MenuEntity;

begin
	
	foreach menuItem in self.allMenuItems do
		if menuItem.isKindOf(CM_QryReport) then
			if menuItem.CM_QryReport.menuId = '_rpt' &amp; _constantValue.String then
				return menuItem.CM_QryReport;
			endif;
		endif;
	endforeach;

end;</source>
        <Parameter name="_constantValue" type="Integer"/>
        <ReturnType type="CM_QryReport"/>
    </JadeMethod>
</Class>
