    </JadeMethod>
    <JadeMethod name="doMenuHeightsUndo" id="e7af2a5c-e008-4ab6-bfc1-4f5ce8164a05">
        <source>doMenuHeightsUndo();
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		We allow the user to paint power good, power bad, locations avail or unavail
//				Plus height restrictions. We store each of these as a seperate set of updates to the location controller
//				When they click the height save button we pass the array of CMIF objects to the TRX
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aPoint : CMUI_GridPoint;
	rtnValue : Boolean;
	aController : CM_LocationsController;
	anInterfaceObject : CMIF_GridTARegion;
	theFrame : CMUI_GridAreaFrame;
	anObject : Object;
begin
	theFrame := self.frmGridArea;

	foreach anObject  in self.allInterfaceObjects reversed do
		anInterfaceObject := anObject.CMIF_GridTARegion;
		foreach aController in anInterfaceObject.allLocationControllers do

			aPoint := self.mySDF.getPointFromLC(aController);
			if aPoint &lt;&gt; null then
				if anInterfaceObject.updateMode &lt;&gt; CMIF_GridTARegion.UpdateMode_PowerGood
				and anInterfaceObject.updateMode &lt;&gt; CMIF_GridTARegion.UpdateMode_PowerDamaged then
					aPoint.YRD_PadPoint.availability := anInterfaceObject.oldAvailability;
				endif;
				if anInterfaceObject.updateMode = CMIF_GridTARegion.UpdateMode_PowerGood then
					aPoint.YRD_PadPoint.powerDamaged := anInterfaceObject.oldPowerDamaged;
				endif;
				if anInterfaceObject.updateMode = CMIF_GridTARegion.UpdateMode_PowerDamaged then
					aPoint.YRD_PadPoint.powerDamaged := anInterfaceObject.oldPowerDamaged;
				endif;
				aPoint.drawSelf(theFrame);
			endif;
		endforeach;
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableNotification" id="9d1a7201-c496-4998-ba62-afcf3a83ca22">
        <updating/>
        <source>doNotableNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 06/11/2012	cnwcs5	par 30475 - removed references to location restrictions
// 22/11/2016	cnwdap1	TFS 2844 STWR Hazardous Details Enhancements
// 18/05/2021	navdap1	TFS 49899 MTN Labour on Block for New GC Areas
vars
	listbox			: CMUI_ListBox;
	event, theIndex	: Integer;
	anObject		: Object;
	aLabRest		: CM_LabourRestriction;
	aSBS 			: CM_SubBlockStack;
	aTA				: CM_TerminalArea;
	aTermSubArea	: CM_TerminalSubArea;
	aDoorRule		: CM_DoorDirectionRule;
	aHazardDetail	: CM_TerminalAreaHazDetails;				// TFS 2844
	theLCS			: CM_LCArray;
	theDoorLCs		: CM_LCArray;
	theDoorLC		: CM_DoorDirectionLocation;
	i 				: Integer;
begin

	event 		:= self.myTerminal.getEventFromTerminalEvent(eventType);
	anObject 	:= userInfo.Object;
	listbox		:= self.lstRestrictions;
	
	if global.isValidObject(anObject) then
		if anObject.isKindOf(CM_LabourRestriction) then
			aLabRest := anObject.CM_LabourRestriction;
		
		elseif anObject.isKindOf(CM_SubBlockStack) then
			aSBS := anObject.CM_SubBlockStack;
		
		elseif anObject.isKindOf(CM_TerminalArea) then
			aTA := anObject.CM_TerminalArea;
		
		elseif anObject.isKindOf(CM_TerminalSubArea) then
			aTermSubArea := anObject.CM_TerminalSubArea;
		
		elseif anObject.isKindOf(CM_DoorDirectionRule) then
			aDoorRule := anObject.CM_DoorDirectionRule;
			
		elseif anObject.isKindOf(CM_TerminalAreaHazDetails) then			// TFS 2844
			aHazardDetail := anObject.CM_TerminalAreaHazDetails;			// TFS 2844
			
		endif;
	endif;

	if event = Event_TALocation_Create then
		if aLabRest &lt;&gt; null then
			//self.displayListBoxAdd(aLabRest.id,aLabRest,YRD_PadArea.AreaMode_Labour,3);			// TFS 49899
			self.displayListBoxFindUpdate(aLabRest.id,aLabRest,YRD_PadArea.AreaMode_Labour,3);		// TFS 49899
		
		elseif aSBS &lt;&gt; null then
			self.displayListBoxAdd(aSBS.id,aSBS,YRD_PadArea.AreaMode_SubBlock,3);
		
		elseif aTermSubArea &lt;&gt; null then 
			self.displayListBoxAdd(aTermSubArea.id,aTermSubArea,YRD_PadArea.AreaMode_TermSubArea,3);		
		
		elseif aDoorRule &lt;&gt; null then
			self.displayListBoxAdd(aDoorRule.description,aDoorRule,YRD_PadArea.AreaMode_DoorDirection,3);
			
		elseif aHazardDetail &lt;&gt; null then																		// TFS 2844
	//		self.displayListBoxAdd(aHazardDetail.id, aHazardDetail, YRD_PadArea.AreaMode_Hazardous, 3);			// TFS 2844
			self.displayListBoxFindUpdate(aHazardDetail.id, aHazardDetail, YRD_PadArea.AreaMode_Hazardous, 3);	//24 May 2017	NDL	TFS 4332
			
		endif;
		
	elseif event = Event_TALocation_Update then
		if aLabRest &lt;&gt; null then
			self.displayListBoxFindUpdate(aLabRest.id,aLabRest,YRD_PadArea.AreaMode_Labour,3);
		
		elseif aSBS &lt;&gt; null then
			self.displayListBoxFindUpdate(aSBS.id,aSBS,YRD_PadArea.AreaMode_SubBlock,3);
		
		elseif aTermSubArea &lt;&gt; null then
			self.displayListBoxFindUpdate(aTermSubArea.id,aTermSubArea,YRD_PadArea.AreaMode_TermSubArea,3);
		
		elseif aDoorRule &lt;&gt; null then
			self.displayListBoxFindUpdate(aDoorRule.description,aDoorRule,YRD_PadArea.AreaMode_DoorDirection,3);
			
		elseif aHazardDetail &lt;&gt; null then																		// TFS 2844
			self.displayListBoxFindUpdate(aHazardDetail.id, aHazardDetail, YRD_PadArea.AreaMode_Hazardous, 3);	// TFS 2844
		
		endif;
		
	elseif event = Event_TALocation_Delete then
		if anObject &lt;&gt; null then
			theIndex := listbox.findObject(anObject);
			
			if theIndex &gt; 0 then
				listbox.removeItem(theIndex);
				//avoid error 4s
				if anObject = self.myCurrentObject then
					self.myCurrentObject:=null;
					self.btnEditTV.enabled 		:= false;
					self.btnNewTV.enabled 		:= false;
					self.btnDeleteTV.enabled	:= false;			
				endif;
				if self.frmGridArea.myGridArea &lt;&gt; null then	//ccms1752 cnwvu1 - we have to refresh grid area after deletion as well.
					self.doDrawGridArea();	
					self.sptThumbEditShowLeftControll( self.frmGridArea.myGridArea.YRD_PadArea );
				endif;
				//epr par 37377 18/1/16
				self.doSheetRedraw(self.theAreaMode);
			endif;
		endif;
	endif;	

	if not self.myCurrentTerminalArea.isRestrictionBlockStack() then // theObject will = myCurrentTerminalArea
		create theLCS transient;
		// ONLY update the graphic if this screen if looking at the same thing as the note.
		if aLabRest &lt;&gt; null then
			aLabRest.allLocationControllers.copy(theLCS);
			self.doUpdateGridAreaNote(aLabRest,theLCS);
		
		elseif aSBS &lt;&gt; null then
			aSBS.allByPassedControllers.copy(theLCS);
			self.doUpdateGridAreaNote(aSBS,theLCS);
		
		elseif aTA &lt;&gt; null then
			aTA.allLocationsControllers.copy(theLCS);
			self.doUpdateGridAreaNote(aTA,theLCS);
		
		elseif aTermSubArea &lt;&gt; null then 
			aTermSubArea.allYardControllers.copy(theLCS);
			self.doUpdateGridAreaNote(aTermSubArea,theLCS);		
		
		elseif aDoorRule &lt;&gt; null /*or anObject.isKindOf(CM_DoorDirectionRule)*/ then	// ccms 1572	cnwvu1
			create theDoorLCs transient;
			foreach theDoorLC in aDoorRule.allDoorDirectionLocations do
				theDoorLCs.add( theDoorLC.myLocationsController );
			endforeach;
			theDoorLCs.copy( theLCS );
			self.doUpdateGridAreaNote(aDoorRule,theLCS);
			
		elseif aHazardDetail &lt;&gt; null then																		// TFS 2844
			aHazardDetail.allLocationsControllers.copy(theLCS);													// TFS 2844
			self.doUpdateGridAreaNote(aHazardDetail, theLCS);													// TFS 2844
			
		endif;
	endif;

	//cnwjo3 ccms 1018.  Refreshing issue.  RoRoLaneAreas dont update correctly.  Not the best code
	if self.myCurrentTerminalArea &lt;&gt; null then
		if self.myCurrentTerminalArea.isKindOf(CM_RoRoLaneArea) then
		
			self.doDrawGridArea();  
			
			foreach i in 1 to listbox.listCount do			
				if listbox.itemLevel[i] = 2 and listbox.itemData[i] = YRD_PadArea.AreaMode_Labour then // par 30475
					listbox.listIndex := i;
					
					self.doLstRestrictionsClick(listbox);
					break;
				endif;
			endforeach;
		endif;
	endif;
epilog
	delete theLCS;
	endLoad;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="d409f56b-187f-4b7c-b660-385c30458707">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	self.mySDF.repositionScrollBars();
	
	if self.grpNotifyEmails.visible then
		//08 July 2015	NDL	Par 36588		
		self.grpNotifyEmails.top := self.tblOther.top + self.tblOther.height + 2;
		self.grpNotifyEmails.height := self.tblOther.height;
		self.grpNotifyEmails.width := self.tblOther.width;
		self.mulNotifyEmails.cnEcResizeContents; 
	endif;
	
	self.frmDetailsBottom.clipControls := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="0e9b6980-0253-49d7-96e5-7d6e4564bd5b">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 06/11/2012	cnwcs5 par 30475 - removed references to location restrcitions
// 23/11/2016	cnwdap1	TFS 2844 STWR Hazardous Details Enhancements
vars
	areaMode : Integer;
begin
	areaMode :=  self.theAreaMode;
	
	if areaMode = YRD_PadArea.AreaMode_SubBlock then
		self.doBtnSubSave();
	
	elseif areaMode = YRD_PadArea.AreaMode_Height then
		self.doBtnHeightSave();
	
	elseif areaMode = YRD_PadArea.AreaMode_Labour then
		self.doBtnLabourSave();
	
	elseif areaMode = YRD_PadArea.AreaMode_TermSubArea then 
		self.doBtnTermSubAreaSave();
	
	elseif areaMode = YRD_PadArea.AreaMode_DoorDirection then 
		self.doBtnDoorDirectionRuleSave();
		
	elseif areaMode = YRD_PadArea.AreaMode_Hazardous then			// TFS 2844
		self.doBtnHazardsSave();									// TFS 2844
		
	endif;
	
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSheetRedraw" id="818c70c9-af21-40fe-accd-5a9ad7624f39">
        <updating/>
        <source>doSheetRedraw(_areaMode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02/06/2010	cnwdad1		CCMS 1947 - for ignoreLights flag on Labour Restrictions.
// 06/11/2012	cnwcs5		par 30475 - remove references to location restrictions/tidy up translations
// 22/11/2016	cnwdap1		TFS 2844 STWR hazardous Details Enhancements
// ---------------------------------------------------------------------------
vars
	table		: CM_EntryTable;
	sheet		: CMUI_Sheet;
	xlation		: String;
	ta			: CM_TerminalArea;
	gridArea	: CMUI_GridArea;
begin
	table 		:= self.tblOther;
	sheet 		:= self.shtRestrictData;
	ta			:= self.myCurrentTerminalArea;
	gridArea	:= self.frmGridArea.myGridArea;
	
	table.clearValues();
	self.btnEditTV.enabled:= true; // TFS 2198
	sheet.visible 			:= false;
	sheet.enabled 			:= false;
	sheet.caption 			:= null;
	self.mnuHeights.visible	:= false;
	
	self.grpNotifyEmails.visible := false;	//07 July 2015	NDL	Par 36588
	
	table.hideRowByName(ETRow_AutoRestrictionsEnabled, false);
	table.hideRowByName(ETRow_StockControlled, false);
	table.hideRowByName(ETRow_IgnoreLights, false);		// cnwdad1 02/06/2010 - CCMS 1947.
	
	if not ta.isRestrictionBlockStack() then
		if gridArea &lt;&gt; null then
			gridArea.YRD_PadArea.clearAllSelectedItems(); // added this in because of click on labour table
		endif;
	endif;
	// ### HEIGHTS
	if _areaMode = YRD_PadArea.AreaMode_Height then
		self.doBuildMenuHeights();
		self.sptThumbEdit.hideLeftControl(true);
		
		if gridArea &lt;&gt; null then
			gridArea.YRD_PadArea.areaMode := YRD_PadArea.AreaMode_Height;
		endif;
		
		self.setNavigatorHeading(ta.id &amp; " "  &amp; app.getErrorString (Pad_Edit));	// par 30475
		
		// TFS 2198
		if not app.myCurrentUserCan(self.myTerminal,PmAdmPadeditMaint) then 
			self.shtRestrictData.disableAllChildren();
			self.btnEditTV.enabled:= false;
		endif;
		
	// ### LABOUR
	elseif _areaMode = YRD_PadArea.AreaMode_Labour then
		self.sptThumbEdit.showLeftControl(65, true);
		
		xlation			:= app.getErrorString (Labour_restrictions);	// par 30475
		sheet.caption 	:= xlation;										// par 30475
		sheet.visible 	:= true;
		sheet.enabled 	:= true;
		
		sheet.setFocus();
		
		table.hideRowByName(ETRow_HideFromOverView, false);
		table.hideRowByName(ETRow_Washed, false);
		table.hideRowByName(ETRow_TestISOTypeGroup, false);
		table.hideRowByName(ETRow_HeavyLift, false);					
		table.hideRowByName(ETRow_WaterCooled, false);
		table.hideRowByName(ETRow_ImportsOnly, false);
		table.hideRowByName(ETRow_ExportsOnly, false);
		table.hideRowByName(ETRow_StockControlled, false);
		table.hideRowByName(ETRow_RehandlesOnly, false);
		table.hideRowByName(ETRow_AllStops, false);
		table.showRowByName(ETRow_Id, false);
		table.showRowByName(ETRow_Colour, false);
		table.showRowByName(ETRow_Comment, false);
		table.showRowByName(ETRow_Organisation, false);
		table.showRowByName(ETRow_DurationHours, false);
		table.showRowByName(ETRow_DurationDays, false);
		table.showRowByName(ETRow_Reason, false);
		table.showRowByName(ETRow_NotifyOnExpiry, false);
		table.showRowByName(ETRow_Expiry, false);
		table.hideRowByName(ETRow_Description, false);
		table.hideRowByName(ETRow_DoorDirectionRuleWording, false);
		table.hideRowByName(ETRow_IsoTypeGroup, false);
		table.hideRowByName(ETRow_MaxCapacity, false);   //par18840 cnwjo3
		table.hideRowByName(ETRow_HazardClass, false);								// TFS 2844
		table.hideRowByName(ETRow_Flashpoint, false);								// TFS 2844
		table.hideRowByName(ETRow_PackingGroup, false);								// TFS 2844
		table.hideRowByName(ETRow_AcidsBases, false);								// TFS 2844
		table.hideRowByName(ETRow_AllowNonHazardous, false);						// TFS 2844
		table.hideRowByName(ETRow_ShowError, false);								// TFS 2844
		
		// cnwdad1 02/06/2010 - CCMS 1947.
		if ta.isOtagoStraddleAreaAorC() then
			table.showRowByName(ETRow_IgnoreLights, false);
		endif;
		
		//08 July 2015	NDL	Par 36588
		table.hideRowByName(ETRow_NotifyOnExpiry, false);
		self.grpNotifyEmails.visible := true;
		self.mulNotifyEmails.setSelected( null );
		self.doResize;
		
		
	//	sheet.cnEcResizeContents();
		
		if not ta.isRestrictionBlockStack()	then 
			if gridArea &lt;&gt; null then
				gridArea.YRD_PadArea.areaMode := YRD_PadArea.AreaMode_Labour;
			endif;
		endif;
		
		self.setNavigatorHeading(ta.id &amp; " "  &amp; xlation);	// par 30475
		
		// TFS 2198
		if not app.myCurrentUserCan(self.myTerminal,PmAdmLabrestrMaint) then
			self.shtRestrictData.disableAllChildren();
			self.btnEditTV.enabled:= false;
		endif;
				
	// ### SUB BLOCK STACKS
	elseif _areaMode = YRD_PadArea.AreaMode_SubBlock then
		self.sptThumbEdit.showLeftControl(35, true);

		xlation			:= app.getErrorString (Sub_Block_stacks);	// par 30475
		sheet.caption 	:= xlation;									// par 30475
		sheet.visible 	:= true;
		sheet.enabled	:= true;
		
		sheet.setFocus();
		
		table.hideRowByName(ETRow_Washed, false);
		table.hideRowByName(ETRow_TestISOTypeGroup, false);
		table.hideRowByName(ETRow_HeavyLift, false);							
		table.hideRowByName(ETRow_WaterCooled, false);
		table.hideRowByName(ETRow_ImportsOnly, false);
		table.hideRowByName(ETRow_ExportsOnly, false);
		table.hideRowByName(ETRow_RehandlesOnly, false);
		table.hideRowByName(ETRow_AllStops, false);
		table.hideRowByName(ETRow_Comment, false);
		table.hideRowByName(ETRow_Organisation, false);
		table.hideRowByName(ETRow_DurationHours, false);
		table.hideRowByName(ETRow_DurationDays, false);
		table.hideRowByName(ETRow_Reason, false);
		table.hideRowByName(ETRow_NotifyOnExpiry, false);
		table.hideRowByName(ETRow_Expiry, false);
		table.showRowByName(ETRow_AutoRestrictionsEnabled, false);
		table.showRowByName(ETRow_Id, false);
		table.showRowByName(ETRow_Colour, false);
		table.showRowByName(ETRow_HideFromOverView, false);
		table.showRowByName(ETRow_StockControlled, false);
		table.hideRowByName(ETRow_Description, false);
		table.hideRowByName(ETRow_DoorDirectionRuleWording, false);
		table.hideRowByName(ETRow_IsoTypeGroup, false);
		table.showRowByName(ETRow_MaxCapacity, false); //par18840 cnwjo3
		table.hideRowByName(ETRow_HazardClass, false);								// TFS 2844
		table.hideRowByName(ETRow_Flashpoint, false);								// TFS 2844
		table.hideRowByName(ETRow_PackingGroup, false);								// TFS 2844
		table.hideRowByName(ETRow_AcidsBases, false);								// TFS 2844
		table.hideRowByName(ETRow_AllowNonHazardous, false);						// TFS 2844
		table.hideRowByName(ETRow_ShowError, false);								// TFS 2844
		
		sheet.cnEcResizeContents();
		
		if gridArea &lt;&gt; null then
			gridArea.YRD_PadArea.areaMode := YRD_PadArea.AreaMode_SubBlock;
		endif;
		
		self.myMasterMenuAction.setHeading(ta.id &amp; " " &amp; xlation); 	// par 30475
		
		// TFS 2198
		if not app.myCurrentUserCan(self.myTerminal,PmAdmBlockstackMaint) then
			self.shtRestrictData.disableAllChildren();
			self.btnEditTV.enabled:= false;
		endif;
				

	// ### TERM SUB AREA
	elseif _areaMode = YRD_PadArea.AreaMode_TermSubArea then
		self.sptThumbEdit.showLeftControl(20, true);
		
		xlation 		:= app.getErrorString (Sub_Areas);	// par 30475
		
		sheet.caption 	:= xlation;							// par 30475
		sheet.visible 	:= true;
		sheet.enabled 	:= true;
		
		sheet.setFocus();
		table.hideRowByName(ETRow_HideFromOverView, false);
		table.hideRowByName(ETRow_Washed, false);
		table.hideRowByName(ETRow_TestISOTypeGroup, false);
		table.hideRowByName(ETRow_HeavyLift, false);					
		table.hideRowByName(ETRow_WaterCooled, false);
		table.hideRowByName(ETRow_ImportsOnly, false);
		table.hideRowByName(ETRow_ExportsOnly, false);
		table.hideRowByName(ETRow_RehandlesOnly, false);
		table.hideRowByName(ETRow_AllStops, false);
		table.showRowByName(ETRow_Id, false);
		table.showRowByName(ETRow_Colour, false);
		table.hideRowByName(ETRow_Comment, false);
		table.hideRowByName(ETRow_Organisation, false);
		table.hideRowByName(ETRow_DurationHours, false);
		table.hideRowByName(ETRow_DurationDays, false);
		table.hideRowByName(ETRow_Reason, false);
		table.hideRowByName(ETRow_NotifyOnExpiry, false);
		table.hideRowByName(ETRow_Expiry, false);
		table.hideRowByName(ETRow_Description, false);
		table.hideRowByName(ETRow_DoorDirectionRuleWording, false);
		table.hideRowByName(ETRow_IsoTypeGroup, false);
		table.hideRowByName(ETRow_MaxCapacity, false); //par18840 cnwjo3
		table.hideRowByName(ETRow_HazardClass, false);								// TFS 2844
		table.hideRowByName(ETRow_Flashpoint, false);								// TFS 2844
		table.hideRowByName(ETRow_PackingGroup, false);								// TFS 2844
		table.hideRowByName(ETRow_AcidsBases, false);								// TFS 2844
		table.hideRowByName(ETRow_AllowNonHazardous, false);						// TFS 2844
		table.hideRowByName(ETRow_ShowError, false);								// TFS 2844
		sheet.cnEcResizeContents();
		
		if not ta.isRestrictionBlockStack()	then 
			if gridArea &lt;&gt; null then
				gridArea.YRD_PadArea.areaMode := YRD_PadArea.AreaMode_TermSubArea;
			endif;
		endif;
		
		self.setNavigatorHeading(ta.id &amp; " "  &amp; xlation); 	// par 30475
		
		// TFS 2198
		if not app.myCurrentUserCan(self.myTerminal,PmAdmLabrestrMaint) then
			self.shtRestrictData.disableAllChildren();
			self.btnEditTV.enabled:= false;

		endif;

	// ### DOOR DIRECTION RULE	ccmc1752
	elseif _areaMode = YRD_PadArea.AreaMode_DoorDirection then
		self.sptThumbEdit.showLeftControl(25, true);
		
		xlation			:= app.getErrorString (XLAT_LU_DoorDirRules);	// par 30475
		sheet.caption 	:= xlation;	// par 30475
		sheet.visible 	:= true;
		sheet.enabled 	:= true;
		
		sheet.setFocus();
		
		table.hideRowByName(ETRow_HideFromOverView, false);
		table.hideRowByName(ETRow_Washed, false);
		table.hideRowByName(ETRow_TestISOTypeGroup, false);
		table.hideRowByName(ETRow_HeavyLift, false);					
		table.hideRowByName(ETRow_WaterCooled, false);
		table.hideRowByName(ETRow_ImportsOnly, false);
