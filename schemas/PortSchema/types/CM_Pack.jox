    <JadeMethod name="getLocationTA" id="8c422040-03ad-48c7-aeef-8e8f10de8910">
        <source>getLocationTA() : CM_TerminalArea;
//
// cnwrs1 May 2007 Find SourceTerminal area for cams
//
vars
	tmpFoundLC : CM_LocationsController;
	tmpFoundHeight : Integer;
begin
	self.myTerminal.findLocationFromString(self.location, true, tmpFoundLC, tmpFoundHeight);
	if tmpFoundLC &lt;&gt; null then
		return tmpFoundLC.myTerminalArea;
	else
		return null;
	endif;
end;

</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="getOtherTrackedItem" id="8a9e9acd-d927-4f85-a016-dfed8f3a8965">
        <source>getOtherTrackedItem(): CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwdwq1
// Purpose: 
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	mar 2006	cnwrs1		can be expected to be invalid 
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	invalidTI		: Boolean;
	id				: String;
	othTrackedItem	: CM_TrackedItem;
begin
	othTrackedItem := self.otherTrackedItem;
	if othTrackedItem &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, othTrackedItem, invalidTI);
		// Dereference TI to check it is valid
		id := othTrackedItem.id;
	endif;
	
	if invalidTI then
		return null;
	endif;

	return othTrackedItem;
	
end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getPackAmount" id="1c38a412-a255-4cbb-af10-107d0b60a733">
        <source>getPackAmount() : String;
/*

Date		Who		Reason
01 July 2014	cnwer1	Initial creation PAR
08 Dec  2014    cnwma1  PAR #35350 Error 1090 on Transaction Enquiry
*/

vars
ct : CM_CargoType;
	product : CM_Product;
	ti	: CM_TrackedItem;
	density  	: Decimal[14,4];
	invalidObj : Boolean;
begin
	
	on Exception do app.handleDeletedObject(exception,self.otherTrackedItem,invalidObj);
	
	if self.action = ACTION_PACK_CHILD then
		if self.otherTrackedItem &lt;&gt; null then	//08/12/2014 cnwma1 PAR #35350
			ct:= self.otherTrackedItem.myCargoType;
			if not invalidObj then
				density:=self.otherTrackedItem.getDensity;
			endif;
		endif;
	
	else
		ct:= self.myTrackedItem.myCargoType;
		density:=self.myTrackedItem.getDensity;
	endif;
	if ct = null then
		return null;
	endif;

	if ct.isBreakBulkMulti then
		return self.totalQuantity.asStringJMT ;	
	elseif ct.isBulkMulti then
			
		return ct.getBulkTrackByDisplayForWeight( self.totalWeight,density,true) ;	
	else
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
