    <JadeMethod name="addObjectsToTable" id="2dd86467-0baa-4273-ab02-582fb3f0891d">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14/07/2006	cnwdad1		PAR #12098.  The "All" didn't work when searching.
// 23/12/2015	cnwma1      PAR #36707.  Editing Cargo Subtype Groups
// --------------------------------------------------------------------------------
vars
	cargoTypeObj		: CM_CargoType;
	productGroupObj		: CM_ProductGroup;
	passportObj			: CM_Passport;
	iteratorObj			: Iterator;
	isBreakOut			: Boolean;
	dynaDict 			: DynaDictionary;
	obj                 : Object;
	
begin
	self.setMyDataClass();
	beginClassNotification(CM_ProductGroup, false, Object_Create_Event, Response_Continuous, 0); 
	
	
	if self.cmbFiltCargoType.listIndex = CNEC_NULL_INDEX then
		return;
	else
		create dynaDict transient;         			 				     //23/12/2015 cnwma1 PAR #36707
		dynaDict.setMembership(CM_ProductGroup);
		dynaDict.addMemberKey("code", false, true);// Code
		dynaDict.endKeys(true);		

		if self.cmbFiltCargoType.itemData[self.cmbFiltCargoType.listIndex] = self.LIST_ENTRY_ALL then
			iteratorObj		:=	app.myRoot.allCargoTypesById.createIterator();
			//create allProductGroupObjs transient;      					 //23/12/2015 cnwma1 PAR #36707
			while iteratorObj.next(cargoTypeObj) do
				//cargoTypeObj.allProductGroups.copy(allProductGroupObjs);	//23/12/2015 cnwma1 PAR #36707
				cargoTypeObj.allProductGroups.copy(dynaDict);               //23/12/2015 cnwma1 PAR #36707
			endwhile;
		else
			//allProductGroupObjs	:=	self.aMyCurrentCargoType.allProductGroups;   //23/12/2015 cnwma1 PAR #36707
			self.aMyCurrentCargoType.allProductGroups.copy(dynaDict); 
		endif;
	endif;
	
	passportObj			:=	app.myPassport;
	

	if not  dynaDict.isEmpty then
		foreach obj in dynaDict do                                               //23/12/2015 cnwma1 PAR #36707
			productGroupObj :=obj.CM_ProductGroup; 
			if self.includeObject(productGroupObj, passportObj) then
				self.addObjectToTable(productGroupObj, _numItems, isBreakOut);
			endif;
			
			if isBreakOut then
				break;
			endif;
			
		endforeach;
	endif;
epilog
	delete iteratorObj;
	

	delete dynaDict;

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cmbCargoType_lostFocus" id="a5b27328-fdec-455e-8e0f-85d77ffe9578">
