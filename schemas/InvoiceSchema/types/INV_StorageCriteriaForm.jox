    <JadeMethod name="displayCalendarView" id="a62ab7ce-909b-4ca6-ae77-602822d858d7">
        <source>displayCalendarView(_theObject : CM_Calendar) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//30/05/2023	navkc1	CR 58013 Task 58014: UI - Storage Config - Storage Detail – Free Storage

*/

vars
	
begin

	if _theObject = null then
		return null;
	else
		return _theObject.description;
	endif;
	
epilog

end;</source>
        <Parameter name="_theObject" type="CM_Calendar"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doApply" id="55c56a1b-180e-458d-bc99-43cd9b22fb0c">
        <updating/>
        <source>doApply() updating;
/*

Purpose:		Apply the storage details options to all on-site cargo,
				with confirmation and cancellable status display		

Parameters:			

Return Value:		

Date		Who		Reason
08/06/2023	navkc1	CR 58007 Task 58008: JADE - Storage Config - Audits

*/

vars
	partsInJob,
	partsDone	: Integer;
	count		: Integer;
	monitor		: CMIF_Monitor;
	ti			: CM_TrackedItem;
begin
	if self.myStorageDetail = null then
		return;
	endif;
	if app.msgBox('Do you want to do update the free storage days on all on-site cargo that matches this storage detail?' ,'Confirm Apply',
				MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return; 
	endif;
	create monitor transient;
	monitor.myParent := self;
	app.myPassport.setMyCMIFMonitor(monitor);
	
	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null, 'Cancel' , null, null, 'Updating Free Storage',  'Please Wait....');
	self.pbProgressBar.visible := true;

	partsInJob :=  self.myTerminal.allOnsiteTIsByCargoTypeId.size;
	monitor.partsInJob := partsInJob;
	app.myTrxUA.trxUpdateCargoFreeStorageDays(self.myTerminal, self.myStorageDetail, app.myPassport);
epilog
	app.myPassport.setMyCMIFMonitor(null);
	delete monitor;
	self.frmModalDialog.visible := false;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doCancel" id="68f6fb7d-b830-4afd-b9cc-a0647bc999b7">
        <updating/>
        <source>doCancel() updating;

vars

begin
	if self.isFormChanged then
		if self.confirmCancel(app.getErrorString(The_Current_Item)) then
			self.unloadForm();
		else
			return;
		endif;
	else	
		self.unloadForm();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="c4c22f6b-2e0b-4ce0-a6ac-7ea53f457de5">
        <updating/>
        <source>doOK(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2012	cnwer1	Initial creation SFW 1295

*/

vars
	pxyStorageDetail, newStorageDetail : CM_StorageDetail;
	isNew		: Boolean;
	theReturn	: Integer;
begin	
	
	if self.myStorageDetail = null then
		create pxyStorageDetail transient;
		isNew := true;
	else
		beginLoad;
		pxyStorageDetail := self.myStorageDetail.pxyCreateUpdateProxy();
		endLoad;
	endif;
	self.doSaveProxy(pxyStorageDetail);
	
	while true do
		if self.myStorageDetail = null then
			app.myTrxCA.trxCreateStorageDetail(pxyStorageDetail, null, newStorageDetail, app.myPassport );
		else
			app.myTrxUA.trxUpdateStorageDetail(pxyStorageDetail, app.myPassport );
		endif;
		if not app.myPassport.trxCompletedOK then
			theReturn := app.showErrorWarningDialog(app.getErrorString(Errors), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
	endwhile;
	self.resetFirstChangeFlag();
	
	// taken out for TFS 2570
	// new and Future Storage Mapping selected, go to the form	// TFS 2570
	//if isNew and												// TFS 2570
	//  self.chkUseFS.value then								// TFS 2570
	//	self.myStorageDetail := newStorageDetail;				// TFS 2570
	//	self.showMappingForm();									// TFS 2570
	//endif;													// TFS 2570
		
	return true;
epilog
	endLoad;
	delete pxyStorageDetail;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="6f42550f-8a7b-4904-b578-5487befbd299">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/05/2023	navkc1	CR 58013 Task 58014: UI - Storage Config - Storage Detail – Free Storage

*/

vars

begin
	inheritMethod();
	self.btnOK.left := self.btnCancel.left - 65;
	self.btnNext.left := btnOK.left - 65;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveProxy" id="31de7773-85f0-4a4a-b368-245c56aa299f">
        <source>doSaveProxy(_pxy : CM_StorageDetail input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2012	cnwer1	Initial creation SFW 1295
21 Jul 2017			cnwma1	TFS #5409:STWO - Storage Slab Auto Commercial Hold
30/05/2023	navkc1	CR 58013 Task 58014: UI - Storage Config - Storage Detail – Free Storage
16/06/2023	navkc1	CR 58221 Task 58222: UI - Ownership Change Free Days
*/

vars
	receivalRule,
	chargedDays,
	freeDays,
	stopFreeDays	: Integer;
	index : Integer;
	criteriaFrame : CMUI_YACriteriaCntl;
	criteriaType : CM_YACriteriaType;
	proxyCriteria: CM_YACriteria;
	itemCode : String;
	value : Any;
	futureStorageStop : CM_StopsTable;
	roadReceival,
	shipReceival,
	railReceival,
	unpackReceival: Integer; // 29/05/2023	navkc1	CR 58011 Task 58012
	combo		: CMUI_ComboBox; // 29/05/2023	navkc1	CR 58011 Task 58012
	allAdditionalCalendars	: CM_CalendarByCodeDict; // 30/05/2023	navkc1	CR 58013 Task 58014
	cooFreeDays,
	cooFreeDaysType	: Integer; //16/06/2023	navkc1	CR 58221 Task 58222
	includeFirstDay,
	includeLastDay : Boolean; //29/02/2023	navkc1 CR 61899 Task 61904
begin
	create allAdditionalCalendars transient; // 30/05/2023	navkc1	CR 58013 Task 58014
	
	// 30/05/2023	navkc1	CR 58013 Task 58014 Changed from Radio button to Combobox
	// If the storage details if for Future Storage, take the value from Future Release Combo instead
	if self.myStorageDetail &lt;&gt; null and self.myStorageDetail.allFutureStorageMappings.isNotEmpty() then
		combo := self.cmbFutureStoChrgPeriod;
	else
		combo := self.cmbRelStoChrgPeriod;
	endif;
	if combo.listIndex &gt; 0 then
		chargedDays := combo.itemData[combo.listIndex];
	endif;
	
	// 30/05/2023	navkc1	CR 58013 Task 58014 Changed from Radio button to Combobox
	combo := self.cmbFreeStoPeriod;
	if combo.listIndex &gt; 0 then
		freeDays := combo.itemData[combo.listIndex];
	endif;
	
	if self.optFirstTerminal.value then
		receivalRule := CM_StorageDetail.RecievalDateRuleFirstByTerm;
	elseif self.optFirstLocation.value then
		receivalRule := CM_StorageDetail.RecievalDateRuleFirstByLocn;
	elseif self.optLastTerminal.value then	
		receivalRule := CM_StorageDetail.RecievalDateRuleLastByTerm;
	elseif self.optLastLocation.value then
		receivalRule := CM_StorageDetail.RecievalDateRuleLastByLocn;
	endif;
	// 24/08/2016 cnwjre1 new parameter for TFS 2570
	stopFreeDays := self.txtStopFreeDays.text.Integer;
	
	//21.07.2017 cnwma1 TFS #5409
	if self.cmbStop.listObject &lt;&gt; null then
		futureStorageStop := self.cmbStop.listObject.CM_StopsTable;
	endif;
	
	// 29/05/2023	navkc1	CR 58011 Task 58012
	combo := self.cmbTruckReceival;
	if combo.listIndex &gt; 0 then
		roadReceival := combo.itemData[combo.listIndex];
	endif;
	// 29/05/2023	navkc1	CR 58011 Task 58012
	combo := self.cmbShipReceival;
	if combo.listIndex &gt; 0 then
		shipReceival := combo.itemData[combo.listIndex];
	endif;
	// 29/05/2023	navkc1	CR 58011 Task 58012
	combo := self.cmbWagonReceival;
	if combo.listIndex &gt; 0 then
		railReceival := combo.itemData[combo.listIndex];
	endif;
	// 29/05/2023	navkc1	CR 58011 Task 58012
	combo := self.cmbChildReceival;
	if combo.listIndex &gt; 0 then
		unpackReceival := combo.itemData[combo.listIndex];
	endif;
	
	// 30/05/2023	navkc1	CR 58013 Task 58014
	self.msgFreeStoExcCalendar.getSelected(allAdditionalCalendars);
	
	//16/06/2023	navkc1	CR 58221 Task 58222
	cooFreeDays := self.txtCooFreeDays.text.Integer;
	combo := self.cmbCooFreeDaysType;
	if combo.listIndex &gt; 0 then
		cooFreeDaysType := combo.itemData[combo.listIndex];
	endif;
	
	//29/02/2023	navkc1 CR 61899 Task 61905
	includeFirstDay := self.chkIncFirstDay.value;
	includeLastDay := self.chkIncLastDay.value; 
	
	_pxy.setValues(chargedDays, freeDays, self.txtFreeDays.text.Integer, self.myTerminal.myStorageConfig, self.txtChargeDays.text.Integer, 0, stopFreeDays, receivalRule, self.chkNoStorageReceived.value,futureStorageStop, 
					self.txtDesc.text, roadReceival, shipReceival, railReceival, unpackReceival, allAdditionalCalendars, cooFreeDays, cooFreeDaysType, includeFirstDay, includeLastDay); // PAR 36275  //21.07.2017 cnwma1 TFS #5409

	foreach index in 1 to self.myTerminal.myStorageConfig.allYACriteriaTypes.size do
		criteriaFrame := self.frmCriteria.getControl(index).CMUI_YACriteriaCntl;
		criteriaType := criteriaFrame.getCriteriaType();
		if criteriaType &lt;&gt; null and criteriaFrame.hasValue() then
			create proxyCriteria transient;
			itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
			//epr TFS 1822 28/4/16
			value := criteriaFrame.getValue();
			
			proxyCriteria.setProxy(criteriaType, value, itemCode);
			proxyCriteria.setYardAllocation(_pxy);

		endif;
	endforeach;
epilog
	delete allAdditionalCalendars;
end;</source>
        <access>protected</access>
        <Parameter name="_pxy" type="CM_StorageDetail" usage="input"/>
    </JadeMethod>
