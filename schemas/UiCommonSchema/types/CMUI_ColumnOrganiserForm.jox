    <JadeMethod name="delete" id="0436c6af-9569-4974-9e97-30d4469aec72">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
/*

Date		Who		Reason
03 April 2014	cnwer1	Initial creation PAR

*/

vars
	entTableRow : EntTableRow;
begin 
	
	if self.modalResult = IDOK then
		//epr par 33900 3/4/14 leaking transients;
		//if saved allTblDataRows will be the saved selected rows remove any that are saved
		foreach entTableRow in self.allTblDataEntRows discreteLock do
			if self.allAvailableMeasurementRows.includes(entTableRow) then
				self.allAvailableMeasurementRows.remove(entTableRow);
			endif;
		endforeach;
	endif;
	
	self.allAvailableMeasurementRows.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayMultiSelectAvailable" id="50b6feb9-030e-49bd-9dec-816b41f623bf">
        <source>displayMultiSelectAvailable(_obj : Object) : String protected;
//--------------------------------------------------
// Created:	08 September 2005 By: cnwgd1
//--------------------------------------------------
//call back method used by multi select sheet
vars
	entRow : EntTableRow;
	rtnString : String;
begin
	if myDataTable = null and myTextTable = null then
		return null;
	endif;
	if EntTableRow.hasInstance(_obj) then
		entRow := _obj.EntTableRow;
		if myDataTable &lt;&gt; null then
			rtnString := entRow.getHeading(self.myDataTable.myTerminologyCargoBOLType, self.myDataTable.myTerminologyTerminal, app.myCurrentLocale);
		else
			rtnString := entRow.getHeading(self.myTextTable.myTerminologyCargoBOLType, self.myTextTable.myTerminologyTerminal, app.myCurrentLocale);
		endif;
	endif;
	return rtnString;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayMultiSelectSorted" id="8be08806-5ac0-417b-b9d4-a1d034ab8910">
        <source>displayMultiSelectSorted(_obj : Object) : String protected;
//--------------------------------------------------
// Created:	08 September 2005 By: cnwgd1
//--------------------------------------------------
//call back method used by multi select sheet
vars
	idx : Integer;
	entRow : EntTableRow;
	rtnString : String;
	ascend : Boolean;
begin
	if myDataTable = null then
		return null;
	endif;
	if self.mulColumnSorter.mySelectedListBox.listCount &gt;= self.maxSortingColumns then
		// reached max limit allowed
		return null;
	
	elseif EntTableRow.hasInstance(_obj) then
		entRow := _obj.EntTableRow;
		rtnString := entRow.getHeading(self.myDataTable.myTerminologyCargoBOLType, self.myDataTable.myTerminologyTerminal, app.myCurrentLocale);
		idx := self.myDataTable.allTblDataSortColumns.indexOf(entRow.name);
		if idx &gt; 0 then
			if self.myDataTable.allTblDataSortDescending[idx] then
				rtnString := rtnString &amp; ' - ' &amp; Descending;			
			else
				rtnString := rtnString &amp; ' - ' &amp; Ascending;
			endif;
		else
			rtnString := rtnString &amp; ' - ' &amp; Ascending;
		endif;

		return rtnString;			
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
