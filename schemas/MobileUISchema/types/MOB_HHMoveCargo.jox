    <JadeMethod name="cmbYardLocation_displayEntry" id="89ef0c1e-c02b-42e8-b415-1a592b66f43a">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbYardLocation_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
// ---------------------------------------------------------------------------
// Created:	13 January 2009 By Graeme Black cnwgb1
// Purpose:	Display the location controller (Called from Jadeinfrastructure)
//			Note the format of locations depends on the kind of place it is in
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars
begin
	//Only display places where we can put things
	if obj.isKindOf(CM_RTGLaneController) or obj.isKindOf(CM_GapController) then
		return null;
	endif;
	
	return self.getSessionAgent().displayEntryLC(obj.CM_LocationsController);
epilog
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="contextMenu" id="9ee8cb7d-ae43-4070-b5d2-9417e3d8a004">
        <controlMethod name="Form::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>contextMenu(conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwndl1	Initial creation	Par 27277

*/

vars

begin

	if not self.wasCalledViaContext(false) then
		return false;
	endif;

	// we only want to show these contexts if we started at the enquiry form.

	return buildContextMenu(null, conwin, mouse, x, y);

epilog

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayCurrentLocation" id="737e4f78-c49a-4c55-b18e-d0dca1430b11">
        <source>displayCurrentLocation() protected;
// ---------------------------------------------------------------------------
// Created:	14 January 2009 By Graeme Black cnwgb1
// Purpose:	Show the current location on the form (Blue Text)
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars
	
begin

	self.lblCurLocValue.caption := null;
	if self.myTrackedItem &lt;&gt; null then
		self.lblCurLocValue.caption := self.myTrackedItem.locationId;
	endif;
	
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
