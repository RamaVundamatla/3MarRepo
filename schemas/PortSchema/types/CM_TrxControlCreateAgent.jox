    <JadeMethod name="trxCreateEmailSendRequest" id="152dda41-beef-4ae5-970b-473b407a01bd">
        <updating/>
        <source>trxCreateEmailSendRequest(	_alertDescription,
							_toAddress,
							_fromAddress,
							_ccAddresses,
							_bccAddresses,
							_sendSubject,
							_sendMessage			: String;
							_allAttachedFilePaths	: HugeStringArray;
							_allFileData			: CM_FileDataStorageHdrSet input;
							_blob					: Binary;
							_blobFileName			: String;
							_sourceOfEmail			: Integer;
							_updateCallbackObj		: Object;
							_passport				: CM_Passport input) : Integer updating;

// cnwdvb1 10 February 2003 
//16 Nov 2012	cnwrs1		Par 30728 - may be called from trx exception hander in cams if directory/file is now invalid
//15 Feb 2021	NDL			TFS 49493 - moved the nasty ' process.isInTransactionState' and 'setTransState' up to where they should be if we are going to do this.
vars
	setTransState : Boolean;
begin

	if not process.isInTransactionState then
		
		// Always initialize the activity first
		self.initialiseActivityWithPassport(_passport, method);
		setTransState := true;
	
		// Arm our base exception handlers
		on Exception do agtPassportExHandler(exception, _passport);
		on LockException do agtPassportLockExHandler(exception, _passport);
	
		app.setContinueCMExceptions(false);
	// Start the transaction
	//if not process.isInTransactionState then
		beginTransaction;
	//	setTransState := true;
	endif;
	
	// Perform the operation
	return app.myUtilityCA.utlCreateEmailSendRequest(true, _alertDescription, _toAddress, _fromAddress, _ccAddresses, _bccAddresses, _sendSubject, _sendMessage, _allAttachedFilePaths, _allFileData, _blob, _blobFileName, _sourceOfEmail, _updateCallbackObj, _passport);
	
epilog
	if setTransState then
		self.finaliseActivityWithPassport(_passport);
	endif;
end;</source>
        <Parameter name="_alertDescription" type="String"/>
        <Parameter name="_toAddress" type="String"/>
        <Parameter name="_fromAddress" type="String"/>
        <Parameter name="_ccAddresses" type="String"/>
        <Parameter name="_bccAddresses" type="String"/>
        <Parameter name="_sendSubject" type="String"/>
        <Parameter name="_sendMessage" type="String"/>
        <Parameter name="_allAttachedFilePaths" type="HugeStringArray"/>
        <Parameter name="_allFileData" type="CM_FileDataStorageHdrSet" usage="input"/>
        <Parameter name="_blob" type="Binary"/>
        <Parameter name="_blobFileName" type="String"/>
        <Parameter name="_sourceOfEmail" type="Integer"/>
        <Parameter name="_updateCallbackObj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
