        <updating/>
        <source>cmbConsignor_lostFocus(combobox: ComboBox input) updating;

/*
Date			Who		Reason
21 March 2013	cnwar2	#26014

*/
vars

begin
	tblMain.setValueByControlName(combobox.name, combobox.text);
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
