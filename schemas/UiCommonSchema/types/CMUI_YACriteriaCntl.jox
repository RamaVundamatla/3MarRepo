    <JadeMethod name="setTabIndex" id="073fe6ad-6852-46fd-a05a-7f3a28959b5b">
        <updating/>
        <source>setTabIndex(_tabIndex : Integer io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
06 August 2008	consw1	Initial creation

*/

vars
	cntlOptYes, cntlOptNo, cntlOptEither : CMUI_OptionButton;

begin
	_tabIndex := _tabIndex + 1;
	self.cmbCriteriaType.tabIndex	:= _tabIndex;
	
	_tabIndex := _tabIndex + 1;
	self.txtCriteriaValue.tabIndex	:= _tabIndex;

	_tabIndex := _tabIndex + 1;
	self.chkCriteriaValue.tabIndex	:= _tabIndex;

	self.getYesNoOptionButtons( cntlOptYes, cntlOptNo, cntlOptEither );
	_tabIndex := _tabIndex + 1;
	if cntlOptYes &lt;&gt; null then
		cntlOptYes.tabIndex	:= _tabIndex;
	endif;
	_tabIndex := _tabIndex + 1;
	if cntlOptNo &lt;&gt; null then
		cntlOptNo.tabIndex	:= _tabIndex;
	endif;
	_tabIndex := _tabIndex + 1;
	if cntlOptEither &lt;&gt; null then
		cntlOptEither.tabIndex	:= _tabIndex;
	endif;
	
	_tabIndex := _tabIndex + 1;
	self.btnValuePicker.tabIndex	:= _tabIndex;

epilog

end;</source>
