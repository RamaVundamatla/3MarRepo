    <ExplicitInverseRef name="myToolbarButton" id="99c93c08-cc4b-41ad-85fa-3b3eeb13ea30">
        <embedded/>
        <type name="CMUI_ToolbarButton"/>
        <access>readonly</access>
        <Inverse name="CMUI_ToolbarButton::myButtonForToolbar"/>
    </ExplicitInverseRef>
    <JadeMethod name="bubbleHelp" id="83939a20-f14b-4642-a6c0-a76fb60e9019">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>bubbleHelp(set: Boolean; value: String io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     25 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(set, value);

	if set and self.myToolbarButton &lt;&gt; null then
		self.myToolbarButton.bubbleHelp := value;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="caption" id="ee69cc8d-d503-4a47-8120-dd15f4012f42">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>caption(set: Boolean; val: String io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     25 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod(set, val);
	
	if set and self.myToolbarButton &lt;&gt; null then
		self.myToolbarButton.setCaption(val, true);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="val" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="enabled" id="5ef8e2f6-dbf6-4ca8-9a9c-a6e83324ba61">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>enabled(set: Boolean; value: Boolean io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     25 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	btn	: CMUI_ToolbarButton;

begin
    
	inheritMethod(set, value);
	
	
	btn := self.myToolbarButton;

	if set and btn &lt;&gt; null then
		if btn.enabled &lt;&gt; value then
			btn.enabled := value;
			if (not value) then
				btn.clearGraphics();
			endif;
			if self.fontCharacter &lt;&gt; null then
					// need to force a redraw of the character
					btn.drawCharacter(self.fontName, self.fontCharacter.Character, self.fontColour);
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isAddedToToolbar" id="bde1a915-3be8-40e8-af50-72854be19d8b">
        <source>isAddedToToolbar(): Boolean;
//----------------------------------------------------------------
//	Created:	24 November 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	return self.myToolbarButton &lt;&gt; null;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFontFromDrawingAttr" id="9b82ff26-4fb5-439e-aa8b-9c9ffff57f2d">
        <updating/>
        <source>setFontFromDrawingAttr(_drawAttr : CM_DrawingAttribute) updating;
// ---------------------------------------------------------------------------
// Created:     12 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _drawAttr = null then
		self.fontCharacter	:= null;
		self.fontColour		:= 0;
		return;
	endif;
	
	self.fontCharacter	:= _drawAttr.fontCharacter;
	self.fontColour		:= _drawAttr.colour;
	self.fontName		:= _drawAttr.fontName;
	self.drawTextAlign := Button.DrawTextAlign_Center;  // ### TFS 50421 27OCT2021 NAVAB1
end;</source>
        <Parameter name="_drawAttr" type="CM_DrawingAttribute"/>
    </JadeMethod>
    <JadeMethod name="style" id="003f1ebe-ca4c-44da-93f0-54944bcd57ea">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>style(set: Boolean; val: Integer io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     11 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(set, val);
	
	if set and self.myToolbarButton &lt;&gt; null then
		self.myToolbarButton.style := val;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="val" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="value" id="3454317b-4d84-4374-972c-41cc5aae8223">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>value(set: Boolean; val: Boolean io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     11 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	btn	:CMUI_ToolbarButton;
begin
	inheritMethod(set, val);
	
	if set then
		btn := self.myToolbarButton;
		
		if btn &lt;&gt; null then
			btn.resetButtonState(val);
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="val" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="visible" id="85621fac-32ad-4814-9065-f3d88ac98984">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
