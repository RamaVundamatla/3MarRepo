    <JadeMethod name="set" id="52190439-776c-48f4-a436-5b8b20bbd55d">
        <updating/>
        <source>set( _parNo: String; /*_patchNo : String;*/ _extractOptionDDB, _singleUser, _tfsPatch : Boolean; _readmeParTopic, _readmeParDescription, _readmeCloseDetail, _readmeAreasAffected, _patchTag : String ) updating;
// created by cnwvu1 on 10/03/2007

vars
	s : String;
begin

	self.parNo				:= _parNo;
//	self.patchNo			:= _patchNo;	// should be after creating files physicaly
	self.tag				:= _patchTag;		// TFS 38497 jlgmd1 12/10/2018
	self.extractOptionDDB	:= _extractOptionDDB;
	self.singleUser			:= _singleUser;
	self.isTFSPatch			:= _tfsPatch;		// TFS 38497 jlgmd1 12/10/2018
	self.dateOfLastEdition	:= app.actualTimeServer();
	self.userCode			:= app.getUserCode();
	
	self.readme_parTopic		:= _readmeParTopic;
	self.readme_parDescription	:= _readmeParDescription;
	self.readme_closeDetail		:= _readmeCloseDetail;
	self.readme_areasAffected	:= _readmeAreasAffected;
	
end;</source>
        <Parameter name="_parNo" type="String"/>
        <Parameter name="_extractOptionDDB" type="Boolean"/>
        <Parameter name="_singleUser" type="Boolean"/>
        <Parameter name="_tfsPatch" type="Boolean"/>
        <Parameter name="_readmeParTopic" type="String"/>
        <Parameter name="_readmeParDescription" type="String"/>
        <Parameter name="_readmeCloseDetail" type="String"/>
        <Parameter name="_readmeAreasAffected" type="String"/>
        <Parameter name="_patchTag" type="String"/>
    </JadeMethod>
