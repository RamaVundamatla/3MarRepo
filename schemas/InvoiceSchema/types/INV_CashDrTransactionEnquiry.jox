    <JadeMethod name="btnExport2File_click" id="111a6cb1-8549-4aa8-a68c-291763674e36">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnExport2File_click(btn: Button input) updating;
// TFS 985
vars
	row : Integer;
	cash : CM_Cash;

begin

	//09 Apr 2018	NDL	TFS 37365 - Allow multi select
	foreach row in 1 to  self.tblCash.rows do
		if self.tblCash.accessRow(row).selected then
			cash :=  self.tblCash.accessRow(row).itemObject.CM_Cash;
			if cash = null then
				continue;
			endif;
			self.doExport(cash, true);
			self.doRefreshExportCell(row);
		endif;
	endforeach;

	/*
	row := self.tblCash.row;
	if row &lt;= self.tblCash.fixedRows then
		return;
	endif;
	if row &gt; self.tblCash.rows then
		return;
	endif;

	cash :=  self.tblCash.accessRow(row).itemObject.CM_Cash;
	if cash = null then
		return;
	endif;
	
	self.doExport(cash, true);
	//epr tfs 1754 1/4/16
	self.doRefreshExportCell(row);
	*/

end;
</source>
