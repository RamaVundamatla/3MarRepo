    <JadeMethod name="showHideWagonColumn" id="6e6c6bf8-e317-41a1-b63a-c3726861db31">
        <updating/>
        <source>showHideWagonColumn() updating;
//
// Changed on	By			Reason
// ----------	----------	----------------------------------------------------------
// 11/08/2011	cnwdap1		PAR #27972 Bulk release type no longer translatable, replaced by string constants
vars

begin
	//if self.viewTransportMode = app.getErrorString(BR_TYPE_DESCR_ROAD) or 		// cnwrd1 par 18519 6.3.09	// PAR #27972
	//   self.viewTransportMode = app.getErrorString(BR_TYPE_DESCR_SHIP) 		// cnwrd1 par 18519 6.3.09		// PAR #27972
	if self.viewTransportMode = BR_TYPE_ROAD_STR or 		// cnwrd1 par 18519 6.3.09							// PAR #27972
	   self.viewTransportMode = BR_TYPE_SHIP_STR 		// cnwrd1 par 18519 6.3.09								// PAR #27972

	   or  self.viewTransportMode = app.getErrorString(View_Additions) 
	   or  self.viewTransportMode = app.getErrorString(Road_rail) then
		tblData.hideColumnByColName(ETRow_Wagon);
		tblData.hideColumnByColName(ETRow_WagonTrain);	//04 Nov 2009	NDL Par 21519
		tblData.hideColumnByColName(ETRow_Train); // PAR 19710
		tblSearch.hideRowByName(ETRow_FilterTrain, false); // PAR 19710
	else
		tblData.showColumnByColName(ETRow_Wagon);
		tblData.showColumnByColName(ETRow_WagonTrain);	//04 Nov 2009	NDL Par 21519
		tblData.showColumnByColName(ETRow_Train);
		tblSearch.showRowByName(ETRow_FilterTrain, false);
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="showMandatoryFields" id="9d2ed920-d185-465f-ac66-062d56c06b8d">
        <source>showMandatoryFields();
// ---------------------------------------------------------------------------
// Created:     14 August 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	numRows,
	idx		: Integer;
	entRow	: EntTableRowTransient;
begin

	numRows := self.tblMain.rows;
	foreach idx in 1 to numRows do
		entRow := self.tblMain.accessRow(idx).itemObject.EntTableRowTransient;
		if entRow = null then
			continue;
		endif;
		if entRow.name = ETRow_CargoType or
		   entRow.name = ETRow_IdTextBox or
		   entRow.name = ETRow_IsoType or
		   entRow.name = ETRow_StatusString or
		   entRow.name = ETRow_ReceiptTransportMode 
		   then
			self.tblMain.accessCell(idx, 1).text := self.tblMain.accessCell(idx, 1).text &amp; MandatoryFieldIndicator; 
		endif;
	endforeach;

	numRows := self.tblExtra.rows;
	foreach idx in 1 to numRows do
		entRow := self.tblExtra.accessRow(idx).itemObject.EntTableRowTransient;
		if entRow = null then
			continue;
		endif;
		if entRow.name = ETRow_VoyageCode or
		   entRow.name = ETRow_OperatorCode or
		   entRow.name = ETRow_DischargePort or
		   entRow.name = ETRow_Commodity or
		   entRow.name = ETRow_WeightTotal or
		   entRow.name = ETRow_MySubTerminal
		   then
			self.tblExtra.accessCell(idx, 1).text := self.tblExtra.accessCell(idx, 1).text &amp; MandatoryFieldIndicator; 			
		endif;
	endforeach;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="showReeferFields" id="7fc9e68f-9f56-4398-b812-f7f367f13baf">
        <source>showReeferFields();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 June 2010	cnwmd1	Initial creation

*/

vars
	cargoType : CM_CargoType;
	isoType : CM_ISOType;
	operator : CM_Operator;
	tmpCombo : ComboBox;
	theRow : Integer;
	opCode : String;
begin
	theRow := tblMain.getRow(ETRow_CargoType);
	if theRow &lt;&gt; 0 then
		tmpCombo := tblMain.accessCell(theRow, tblMain.ColumnValue).cellControl.ComboBox;
		//if tmpCombo &lt;&gt; null and tmpCombo.name = GTE_PreNoteForm::cmbTiType.name then
		if tmpCombo &lt;&gt; null and tmpCombo.name = GTE_PreNoteForm::cmbTiType.name and tmpCombo.listObject.isKindOf(CM_CargoType) then   // 13/09/2010 cnwmh5 #25727
			cargoType := tmpCombo.listObject.CM_CargoType;
		endif;
	endif;
	
	if cargoType = null then
		return;
	endif;
	
	theRow := tblMain.getRow(ETRow_ISOType);
	if theRow &lt;&gt; 0 then
		tmpCombo := tblMain.accessCell(theRow, tblMain.ColumnValue).cellControl.ComboBox;
		if tmpCombo &lt;&gt; null and tmpCombo.name = GTE_PreNoteForm::cmbISOType.name then
			isoType := tmpCombo.listObject.CM_ISOType;
		endif;
	endif;
	
//	theRow := tblExtra.getRow(ETRow_Operator);
	theRow := tblExtra.getRow(ETRow_OperatorCode);	//08 June 2011	NDL	Par 27682
	if theRow &lt;&gt; 0 then
		tmpCombo := tblExtra.accessCell(theRow, tblExtra.ColumnValue).cellControl.ComboBox;
		if tmpCombo &lt;&gt; null and tmpCombo.name = GTE_PreNoteForm::cmbOperator.name then
			operator := tmpCombo.listObject.CM_Operator;
		endif;
	endif;
	
	if operator &lt;&gt; null then
		opCode := operator.code;
	endif;
	
	self.myAssistant.GTE_Assistant.showHideTemperatureFields(cargoType.id, isoType, opCode, self.tblExtra, self.myTerminal);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="239a3f83-376e-4e67-873d-a0dab0690a1d">
        <updating/>
        <source>showThumbnailData( _ti : CM_TrackedItem ) updating;
// ---------------------------------------------------------------------------
// Created:     01 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 03 Jun 2009	concms1	par 19807 - changed to hide sub-terminals in tblThumb if not being used
// 04 Nov 2009	cnwdap1 CCMS 1017 show/hide overdimensions as appropriate
// 11 Nov 2009	cnwdap1	PAR #21583 Revert to "old" ent table def for thumbnail for now
//							(to be reviewed as part of CCMS 1019)
// 26/02/2010	cnwmh5	PAR 22517 - Change app.myPassport.myTerminal to self.myTerminal
// 04/04/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements - display deg C or deg F depending on Operator setting
// 07/11/2025	navdap1	MTN-36554 MTN | Cargo Type for Contents field missing on Prenote Enquiry and Road Operations screens
vars

	tmpStop		: CM_Stops;
	toDoTask	: CM_ToDoTask;
	allStops	: CM_StopsByIdDict;
	entTableDef	: EntTableDef;
	
begin
	if _ti = null then
		return;
	endif;

	self.setNavigatorHeading(self.viewTransportMode &amp; ' (' &amp; _ti.CM_TrackedItem.id &amp; ')');

	self.tblThumb.rows := 0;
	entTableDef := app.myController.getEntTableDef(ETDef_PreNoteThumb);				//+cnwml2 PAR23668
	self.showThumbnailForDef(ETDef_PreNoteThumb, _ti);			// PAR #21582
	
	// show the field "Booking Reference Item" in the thumbnail only if the flag is checked.
	if not self.myTerminal.getConfig(AllowMultiBookingRef).Boolean then
		self.tblThumb.hideRowFromHeading(self.tblMain.getHeadingByName(ETRow_MyBookingRefItem));
	endif;

	//+cnwml2 PAR23668
	if self.myTerminal.getConfig(NoPINs).Boolean then
		self.tblThumb.hideRowFromHeading(entTableDef.getEntTableRow(ETRow_PinNo).getHeading(null, null, app.myCurrentLocale));
		self.tblData.hideColumnByColName(ETRow_PinNo);
	else
		self.tblThumb.showRowFromHeading(entTableDef.getEntTableRow(ETRow_PinNo).getHeading(null, null, app.myCurrentLocale));
		self.tblData.showColumnByColName(ETRow_PinNo);
	endif;

	
	self.lstStops.clearSelected();
	create allStops transient;
	_ti.getAllActiveStops( allStops );
	foreach tmpStop in allStops do
		self.lstStops.addSelectedObject(tmpStop.myStopsTable);
	endforeach;
	
	self.lstToDo.clearSelected();
	foreach toDoTask in _ti.allToDoTasksToDo do
		self.lstToDo.addSelectedObject(toDoTask.toDoTaskDesc);
	endforeach;
	
	if _ti.receiptTransportMode = TI_TRANSMODE_ROAD then
		self.btnResendCarrier.enabled := true;
	else
		self.btnResendCarrier.enabled := false;
	endif;
	
	//26 Aug 2009	NDL	CCMS 1609 Par 20521
	self.btnBookingRefDis.enabled := true;
	
	if app.isDevelopmentSystem then
		tblThumb.addItem(_ti.String);
	endif;

	//15/04/2009 cnwdz2 ccms1735
	if app.isSubTerminalsOn(self.myTerminal) then
		self.cmbSubTerminal.automaticCellControl	:=	true;
	else
		self.tblData.hideColumnByColName(ETRow_MySubTerminal);
		// there are 2 tables that have sub-terminal - need to hide in both
		self.tblThumb.hideRowFromHeading(self.tblExtra.getHeadingByName(ETRow_MySubTerminal));	// par 19807
		self.tblExtra.hideRowByName(ETRow_MySubTerminal, false); 
	endif;
	//self.loadBookingRefItems();
	
	// CCMS 1017 hide over dimensions fields if not a container or not overdimensions
	if not _ti.isContainer or not _ti.isOverDimensions then
		self.tblThumb.hideRowsFromHeading(self.tblExtra.getHeadingByName(ETRow_OverLengthFront));
		self.tblThumb.hideRowsFromHeading(self.tblExtra.getHeadingByName(ETRow_OverLengthBack));
		self.tblThumb.hideRowsFromHeading(self.tblExtra.getHeadingByName(ETRow_OverWidthLeft));
		self.tblThumb.hideRowsFromHeading(self.tblExtra.getHeadingByName(ETRow_OverWidthRight));
		self.tblThumb.hideRowsFromHeading(self.tblExtra.getHeadingByName(ETRow_OverHeight));
		self.tblExtra.hideRowByName(ETRow_OverHeight, false);
		self.tblExtra.hideRowByName(ETRow_OverLengthFront, false);
		self.tblExtra.hideRowByName(ETRow_OverLengthBack, false);
		self.tblExtra.hideRowByName(ETRow_OverWidthLeft, false);
		self.tblExtra.hideRowByName(ETRow_OverWidthRight, false);
	endif;
	
	//if not _ti.isExport or not app.myPassport.myTerminal.getConfig(ShowPortOfCallTranship).Boolean then
	if not _ti.isExport or not self.myTerminal.getConfig(ShowPortOfCallTranship).Boolean then  // 26/02/2010 cnwmh5 #22517
		self.tblExtra.hideRowByName(ETRow_MyTranshipToPort, false);
		self.tblThumb.hideRowFromHeading(self.tblExtra.getHeadingByName(ETRow_MyTranshipToPort));
		self.tblData.hideColumnByColName(ETRow_MyTranshipToPort);
	else
		self.tblExtra.showRowByName(ETRow_MyTranshipToPort, false);
		self.tblThumb.showRowFromHeading(self.tblExtra.getHeadingByName(ETRow_MyTranshipToPort));
		self.tblData.showColumnByColName(ETRow_MyTranshipToPort);
	endif;
	
	
	//31695 epr 12/6/13
	if _ti.canMergeBreakBulk then
		self.tblThumb.showRowFromHeading(entTableDef.getEntTableRow(ETRow_TotalQuantity).getHeading(null, null, app.myCurrentLocale));
	else
		self.tblThumb.hideRowFromHeading(entTableDef.getEntTableRow(ETRow_TotalQuantity).getHeading(null, null, app.myCurrentLocale));
	endif;
	
	// PAR #31155 display temperature in Fahrenheit if set on operator 
	if _ti.myOperator &lt;&gt; null then																	// PAR #31155
		if _ti.myOperator.displayTempFahrenheit then												// PAR #31155
			self.tblThumb.hideRowFromHeading(self.tblExtra.getHeadingByName(ETRow_CarriageTempC));	// PAR #31155
			self.tblThumb.showRowFromHeading(self.tblExtra.getHeadingByName(ETRow_CarriageTempF));	// PAR #31155
		else																						// PAR #31155
			self.tblThumb.showRowFromHeading(self.tblExtra.getHeadingByName(ETRow_CarriageTempC));	// PAR #31155
			self.tblThumb.hideRowFromHeading(self.tblExtra.getHeadingByName(ETRow_CarriageTempF));	// PAR #31155
		endif;																						// PAR #31155
	else																							// PAR #31155
		self.tblThumb.showRowFromHeading(self.tblExtra.getHeadingByName(ETRow_CarriageTempC));		// PAR #31155
		self.tblThumb.hideRowFromHeading(self.tblExtra.getHeadingByName(ETRow_CarriageTempF));		// PAR #31155
	endif;																							// PAR #31155
	
	// MTN-36554 Show Cargo Type For Contents if we have a rotatable container
	if _ti.isRotatableContainer then
		self.tblThumb.showRowFromHeading(self.tblExtra.getHeadingByName(ETRow_CargoTypeCodeForCntnt));
	else
		self.tblThumb.hideRowFromHeading(self.tblExtra.getHeadingByName(ETRow_CargoTypeCodeForCntnt));
	endif;
	
epilog
	delete allStops;
	
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a5ca78c7-bdb9-4566-8801-f1feef3cad32">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:46:02.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005448, locale);
	btnBookingRefDis.translateBubbleHelp(Xlat_0014359, locale);
	btnBookingRefDis.translateCaption(Xlat_0011448, locale);
	btnResendCarrier.translateCaption(Xlat_0001349, locale);
	btnSummariseAll.translateBubbleHelp(Xlat_0009578, locale);
	btnSummariseAll.translateCaption(Xlat_0009579, locale);
	lblTransportMode.translateCaption(Xlat_0001350, locale);
	mnuBookRefDiscrep.translateCaption(Xlat_0014360, locale);
	mnuContextExtras.translateCaption(Xlat_0005449, locale);
	mnuContextReceive.translateCaption(Xlat_0005450, locale);
	mnuSetReceiveType.translateCaption(Xlat_0018139, locale);
	mnuSummarise.translateCaption(Xlat_0009580, locale);
	mnuSummariseAll.translateCaption(Xlat_0009581, locale);
	mnuSummariseSelected.translateCaption(Xlat_0009582, locale);
	mnuTestAP.translateCaption(Xlat_0005451, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtBookingRefGotFocus" id="b35e75c0-1ec7-4f81-8684-7de705ae9bbc">
        <updating/>
        <source>txtBookingRefGotFocus(textbox: TextBox input) updating;
// ---------------------------------------------------------------------------
// Created:     01 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
