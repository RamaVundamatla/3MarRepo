<Class name="CM_EDIDataGeneric" id="88be7ce8-bae6-4114-9872-d273dfb18d53">
    <superclass name="CM_EDIData"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="edi"/>
    <JadeMethod name="getMyTIDisplayDefNames" id="4a2c635b-1e62-46d3-8eb3-597926c6e704">
        <source>getMyTIDisplayDefNames(_names: StringArray input);
/*

Purpose: PAR 29143 This is required to return the default list of columns
         The parent version of this method requires an EDIData with concrete 
         EDITrackedItem

Parameters:			

Return Value:		

Date		Who		Reason
22 February 2012	cnwgb1	Initial creation

*/

vars

begin
    _names.add(self.getMyTIDisplayDefName());

epilog

end;</source>
        <Parameter name="_names" type="StringArray" usage="input"/>
    </JadeMethod>
</Class>
