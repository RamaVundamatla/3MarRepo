        <updating/>
        <source>lstColour_lostFocus(table: Table input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/08/2013	cnwdap1		Initial creation PAR #32331
//
vars
	tbl		: CM_EntryTable;
begin
