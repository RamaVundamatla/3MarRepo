    <JadeMethod name="setFormTitle" id="380643a7-00ca-4c52-b871-a9896012e776">
        <source>setFormTitle();
/*
Purpose:			
Date		Who		Reason
03/02/2017	cnwab1	Initial creation
29/05/2017	cnwdap1	TFS 4248 LNX Voyagwe Event Allocation
*/

vars
	title : String;
    shift : CM_Shift;
	jobSheet : CM_VoyageJobSheet;				// TFS 4248
begin

epilog
	self.lblTitle.caption := "";
	
	if self.myCurrentVoyage &lt;&gt; null then
		title := app.getErrorString(Voyage) &amp; " - " &amp; self.myCurrentVoyage.code &amp; CrLf;
	endif;
	shift := self.myCurrentShift;
	
	if shift= null then
		shift := self.myTerminal.allShiftsDay.last;
	endif;	
	if shift &lt;&gt; null then
		//title := title &amp; shift.getNiceName();									// TFS 4248
		title := title &amp; shift.getNiceName() &amp; CrLf;							// TFS 4248
	endif;
		
	jobSheet := self.myCurrentJobSheet;											// TFS 4248
	if jobSheet &lt;&gt; null then													// TFS 4248
		title := title &amp; jobSheet.crane;										// TFS 4248
		if self.myCurrentJob &lt;&gt; null then										// TFS 4248
			title := title &amp; Space &amp; Hyphen &amp; Space &amp; self.myCurrentJob.id;		// TFS 4248
		endif;																	// TFS 4248
	endif;																		// TFS 4248
	
	self.lblTitle.caption := title;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="71d25c24-1728-4bf0-980c-b2dbaeb98e58">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			
Date		Who		Reason
03/02/2017	cnwab1	Initial creation
29/05/2017	cnwdap1	TFS 4248 LNX Voyage Event Allocation
*/

vars

begin



	inheritMethod();
	if self.myCurrentJob &lt;&gt; null then
		self.myCurrentShift := self.myCurrentJob.myShift;
		self.myCurrentJobSheet := self.myCurrentJob.myJobSheet.CM_VoyageJobSheet;		// TFS 4248
	endif;
	
	self.initTable();
	self.displayEvents();
	

	self.setFormTitle();
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSave.enabled:= false;
		self.txtAmount.enabled:= false;
		self.txtDate.enabled:= false;
		self.txtEndDate.enabled:= false;
		self.txtEndTime.enabled:= false;
		self.txtRemarks.enabled:= false;
		self.txtTime.enabled:= false;
		self.txtEventType.enabled:= false;
		self.tblData.userInputEnabled := false;
	endif;	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="89bb045b-5fff-4106-b2bd-f69e600becd9">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
/*
Purpose:			
Date		Who		Reason
03 February 2017	cnwab1	Initial creation
*/

vars
	event : CMEVT_VoyageEvent;
	idx : Integer;
begin
	
	if eventType = Object_Create_Event then
		if theObject.isKindOf(CMEVT_VoyageEvent) then
			event := theObject.CMEVT_VoyageEvent;
			if event.myVoyage = self.myCurrentVoyage then
				self.displayEvents();
				self.tblData.selectObject(event, true);
				self.doSelectEvent(event);
				
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblData_click" id="2faa4ee6-ea67-4c1c-985a-c99ead02285f">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_click(table: Table input) updating;
/*
Purpose:			
Date		Who		Reason
03 February 2017	cnwab1	Initial creation
*/

vars

	event : CM_EventTransaction;
	eventType : CM_EventType;
	obj : Object;
	
begin

/*	
	if table.row &gt; table.fixedRows then
		self.mnuInspectObject.userObject := table.accessRow(table.row).itemObject;	
	else
		self.mnuInspectObject.userObject := null;
	endif;
	*/
//	self.mnuColumnOrganiser.userObject := table;

	obj := table.accessRow(table.row).itemObject;
	if obj.isKindOf(CM_EventTransaction) then
		event := obj.CM_EventTransaction;
		self.doSelectEvent(event);
	elseif obj.isKindOf(CM_EventType) then
		eventType := obj.CM_EventType;
		self.doUnselectEvent(eventType);
	endif;


epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblData_contextMenu" id="c9003947-b26e-4b8a-8e18-dc0fa79814d4">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*
Purpose:			
Date		Who		Reason
08 February 2017	cnwab1	Initial creation
*/

vars
	xLeft 	: Real;
	yTop	: Real;
begin

	xLeft := x;
	yTop := y;

	self.mnuContext.visible := app.isAllowedToInspect();
	self.mnuInspectObj.visible := app.isAllowedToInspect();
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form

	self.popupMenu(self.mnuContext, xLeft.Integer, yTop.Integer);

	return false;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="04aba944-8ed4-48c2-9012-5cd84a419c9c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 February 2017 09:18:43.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021877, locale);
	btnCancel.translateCaption(Xlat_0021878, locale);
	btnSave.translateCaption(Xlat_0021879, locale);
	chkComplete.translateCaption(Xlat_0021880, locale);
	lblAmount.translateCaption(Xlat_0021881, locale);
	lblDate.translateCaption(Xlat_0021882, locale);
	lblEndDate.translateCaption(Xlat_0021883, locale);
	lblEndTime.translateCaption(Xlat_0021884, locale);
	lblEventType.translateCaption(Xlat_0021885, locale);
	lblRemarks.translateCaption(Xlat_0021886, locale);
	lblTime.translateCaption(Xlat_0021887, locale);
	lblTitle.translateCaption(Xlat_0021888, locale);
	mnuContext.translateCaption(Xlat_0021889, locale);
	mnuInspectObj.translateCaption(Xlat_0021890, locale);
end;</source>
    </JadeMethod>
