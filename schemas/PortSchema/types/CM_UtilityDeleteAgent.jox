        <source>utlDeleteDefinedText(_definedText: CM_DefinedText io; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 October 2022 navvt20  ChangeRequest 53424: MTN - MOB - Input Remarks - Jade

*/

vars

begin
	if not self.exclusiveLockObjectToDelete(_definedText) then
	    return;
	endif;
	_definedText.validateForDelete();
	
	if not _passport.noErrors then
		return;
	endif;
	
	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_definedText);
	endif;
	
	_definedText.erase(NORMAL_ERASE);
epilog

end;</source>
