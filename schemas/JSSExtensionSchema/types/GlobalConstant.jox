<Class name="GlobalConstant">
    <JadeMethod name="jssGetCategory" id="d76f6493-ea61-402d-9329-1753d7db6b42">
        <source>jssGetCategory():ConstantCategory;
// --------------------------------------------------------------------------------
// Created:		08 July 2001 by cnwdad1
//
// Purpose:		Returns the receivers global constant category.
//
// Parameters:	None
//
// Returns:		The ConstantCategory object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.category;
end;</source>
        <ReturnType type="ConstantCategory"/>
    </JadeMethod>
</Class>
