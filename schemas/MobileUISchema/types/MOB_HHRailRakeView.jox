    <JadeMethod name="clickBtnTrain" id="d9279135-d1cb-4ef4-ac4e-1d052fee9a2d">
        <updating/>
        <source>clickBtnTrain() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

begin

	app.mousePointer :=	Busy;

	self.myMobileGenericAgent.setMyCurrentWagon(null);
	self.gotoForm( MOB_HHRailPlaceTrainForm, false );	// going back to a previous menu form so set to true

epilog

	app.mousePointer :=	Idle;

end;</source>
    </JadeMethod>
    <JadeMethod name="clickBtnWagonInsert" id="d298e1c3-ca4e-4b21-aca6-2ee284e16c6d">
        <updating/>
        <source>clickBtnWagonInsert() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	currentIndex : Integer;
	currentWagon : CM_Wagon;
	index : Integer;
	currentRakePos : Integer;
	mess : String;
	railLine : CM_RailLine;
	wagon : CM_Wagon;
	afterFreePos : Integer;
	beforeFreePos : Integer;
	wagonArray : CM_WagonArray;
	wagonList : String;
	wagonList2 : String;
	success : Boolean;
	
begin

	app.mousePointer :=	Busy;

	currentIndex := self.lstRakeWagons.listIndex;
	if currentIndex &lt; 1 or currentIndex &gt; self.lstRakeWagons.listCount then
		app.mousePointer :=	Idle;
		mess := app.getErrorString(Please_select_positionPOP);
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return;
	endif;
	
	currentRakePos := self.lstRakeWagons.itemData[currentIndex];
	currentWagon := lstRakeWagons.itemObject[currentIndex].CM_Wagon;
	if currentRakePos &gt; 0 and currentWagon = null then	// we have an empty position, this is the easy one, the insert is just an update of this position
						// just take the user there, to do his thing...
		self.myMobileGenericAgent.setMyCurrentWagon(null);
		self.myMobileGenericAgent.setCurrentRakePosition(currentRakePos);
		if self.myMobileGenericAgent.inward then
			self.gotoForm( MOB_HHRailPlaceWagonIn, false );	
		else
			self.gotoForm( MOB_HHRailPlaceWagonOut, false );
		endif;
		return;
	endif;
	
	
	// OK to do an insert here, there has to be an empty space before or after this position, so we can move the other wagons along
	// and free this space.
	railLine := self.myMobileGenericAgent.myCurrentRailLine;
	currentRakePos := railLine.allWagons.indexOf(currentWagon);
	
	// try after first.
	if currentRakePos &lt; railLine.maximumWagons then
		foreach index in currentRakePos to railLine.maximumWagons do
			wagon := railLine.getWagonAtPosition(index);
			if wagon = null then
				afterFreePos := index;
				break;
			endif;
		endforeach;
	endif;
	
	if afterFreePos = 0 then
		if currentRakePos &gt; 1 then
			foreach index in 1 to currentRakePos reversed do
				wagon := railLine.getWagonAtPosition(index);
				if wagon = null then
					beforeFreePos := index;
					break;
				endif;
			endforeach;
		endif;
	endif;
	
	
	if afterFreePos = 0 and beforeFreePos = 0 then
		// no space available.
		app.mousePointer :=	Idle;
		mess := app.getErrorString(No_available_space_insert);
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return;
	endif;
	
	
	// build the array of the wagons we want to move.
	create wagonArray transient;
	if afterFreePos &lt;&gt; 0 then		// try this first  - insert implies move this one back a position.
		// we have a position after 
		foreach index in currentRakePos to afterFreePos - 1 reversed do
			wagon := railLine.getWagonAtPosition(index);
			wagonArray.add(wagon);
			if wagonList = null then
				wagonList := wagon.id;
			else
				wagonList := wagonList &amp; ", " &amp; wagon.id;
			endif;
		endforeach;
	
	elseif beforeFreePos &lt;&gt; 0 then
		// we only have a position before 
		foreach index in beforeFreePos + 1 to currentRakePos do
			wagon := railLine.getWagonAtPosition(index);
			wagonArray.add(wagon);
			if wagonList = null then
				wagonList := wagon.id;
			else
				wagonList := wagonList &amp; ", " &amp; wagon.id;
			endif;
		endforeach;
	
	endif;
	
	// check that none of these are confirmed. - we are not allowed to move confirmed wagons.
	foreach wagon in wagonArray do
		if wagon.confirmed then
			if wagonList2 = null then
				wagonList2 := wagon.id;
			else
				wagonList2 := wagonList2 &amp; ", " &amp; wagon.id;
			endif;
		endif;
	endforeach;
	if wagonList2 &lt;&gt; null then
		app.mousePointer :=	Idle;
		mess := app.getErrorString1(ERR_WAGON_CONFIRMED, wagonList2);
		self.msgBox( mess, app.getErrorString(DoYouWantToContinue), MsgBox_OK_Only, true);
		return;
	endif;
	
	
	// in theory we should be able to move these.
	if afterFreePos &lt;&gt; 0 then	
		app.mousePointer :=	Idle;
		mess := app.getErrorString1(Insert_move_wagons_back, wagonList);
		if self.msgBox( mess, app.getErrorString(DoYouWantToContinue), MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;
	
	elseif beforeFreePos &lt;&gt; 0 then
		app.mousePointer :=	Idle;
		mess := app.getErrorString1(Insert_move_wagons_forward, wagonList);
		if self.msgBox( mess, app.getErrorString(DoYouWantToContinue), MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;
	
	endif;
	
	app.mousePointer :=	Busy;
	
	// move the other wagons out of the way.
	if afterFreePos &lt;&gt; 0 then
		success := self.incrementWagonPositions( wagonArray, 1 );
	else
		success := self.incrementWagonPositions( wagonArray, -1 );
	endif;
	
	
	if success then
		self.myMobileGenericAgent.setMyCurrentWagon(null);
		self.myMobileGenericAgent.setCurrentRakePosition(currentRakePos);
		if self.myMobileGenericAgent.inward then
			self.gotoForm( MOB_HHRailPlaceWagonIn, false );	
		else
			self.gotoForm( MOB_HHRailPlaceWagonOut, false );
		endif;
	endif;
	
epilog

	delete wagonArray;
	app.mousePointer :=	Idle;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="clickBtnWagonUpdate" id="7ad434df-ae03-40a0-9279-e45d9dba9285">
        <updating/>
        <source>clickBtnWagonUpdate() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	index : Integer;
	pos : Integer;
	mess : String;
	object : Object;
	
begin

	app.mousePointer :=	Busy;

	index := lstRakeWagons.listIndex;
	if index &lt; 1 or index &gt; lstRakeWagons.listCount then
		app.mousePointer :=	Idle;
		mess := app.getErrorString(Please_select_positionPOP);
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return;
	endif;
	
	object := lstRakeWagons.itemObject[index];
	if object &lt;&gt; null then	//we have a line associated with a wagon.
		if object.isKindOf( CM_Wagon ) then
			self.myMobileGenericAgent.setMyCurrentWagon(object.CM_Wagon);
			if self.myMobileGenericAgent.inward then
				self.gotoForm( MOB_HHRailPlaceWagonIn, false );	
			else
				self.gotoForm( MOB_HHRailPlaceWagonOut, false );
			endif;
			return;
		endif;
	endif;
	
	pos := lstRakeWagons.itemData[index];
	if pos &gt; 0 then	// we have an empty position.
		self.myMobileGenericAgent.setMyCurrentWagon(null);
		self.myMobileGenericAgent.setCurrentRakePosition(pos);
		if self.myMobileGenericAgent.inward then
			self.gotoForm( MOB_HHRailPlaceWagonIn, false );
		else
			self.gotoForm( MOB_HHRailPlaceWagonOut, false );
		endif;
		return;
	
	endif;
	
	

epilog

	app.mousePointer :=	Idle;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="215e5b6c-079d-4147-9924-45a9db6d2e14">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	stdLeft : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	width : Real;
	left : Real;
	lstHeight : Real;
	rake : CM_RailLine;
	rakeName : String;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdLeft :=  self.resizedMargin;
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin - 8 ;
	stdHeight := self.getStdControlHeight;
	
	if _initialSetup then
		self.lblRakeWagons.setAndIncrementTabIndex( tabIndex );
		self.lblRakeWagons.visible := true;
	endif;
	self.lblRakeWagons.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
	if _initialSetup then
		if self.myMobileGenericAgent.myCurrentRailLine &lt;&gt; null then
			rakeName := self.myMobileGenericAgent.myCurrentRailLine.getDisplayDetails(false);							
			self.lblRakeWagons.caption := app.getErrorString1(Wagons_for,rakeName);
		endif;
	endif;
	
	
	top := self.lblRakeWagons.top + self.lblRakeWagons.height + self.resizedMargin;
	// total form height - height of button area at bottom - room for rake btn - room for to opt buttons below - some spare room + offset.
	//lstHeight := self.height - self.getCMDHeight() - top - ( stdHeight * 1.5 )  - stdHeight +  self.getSessionAgent().deviceHeightOffset;
	lstHeight := self.clientHeight - self.getCMDHeight() - top - ( stdHeight * 1.5 )  - stdHeight;
	if _initialSetup then
		self.lstRakeWagons.setAndIncrementTabIndex( tabIndex );
		self.lstRakeWagons.visible := true;
	endif;
	self.lstRakeWagons.move(	stdLeft,
								top,
								stdWidth,
								lstHeight );
							
	width := btnWagonUpdate.width;
	left := stdLeft;
	top := self.lstRakeWagons.top + self.lstRakeWagons.height + ( stdHeight / 2 );
	if _initialSetup then
		self.btnWagonUpdate.setAndIncrementTabIndex( tabIndex );
		self.btnWagonUpdate.visible := true;
	endif;
	self.btnWagonUpdate.move(	left,
							top,
							width,
							stdHeight );
	
	left := self.lstRakeWagons.width + self.lstRakeWagons.left - width;
	if _initialSetup then
		self.btnWagonInsert.setAndIncrementTabIndex( tabIndex );
		self.btnWagonInsert.visible := true;
	endif;
	self.btnWagonInsert.move(	left,
							top,
							width,
							stdHeight );
							
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getHelpDescr" id="9c773f53-7153-426a-8f1a-b329db19f190">
        <source>getHelpDescr(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2010	cnwndl1	Initial creation		Par 25215

*/

vars

begin

	return app.getErrorString(RAILHHHELP_RAK001) &amp; CrLf  &amp; CrLf &amp;
			//This shows all the wagons that are on the rake being worked.
			app.getErrorString(RAILHHHELP_RAK002) &amp; CrLf  &amp; CrLf &amp;
			//Green - indicates that the item is on the train being worked and has been confirmed.
			app.getErrorString(RAILHHHELP_RAK003) &amp; CrLf  &amp; CrLf &amp;
			//Red - indicates that the item is a wagon or cargo that is either on the train being worked, ( or the default train ) and has not yet been confirmed.
			app.getErrorString(RAILHHHELP_RAK004) &amp; CrLf  &amp; CrLf &amp;
			//Black - indicates that the wagon belongs to different train than the one being worked.
 

			app.getErrorString(RAILHHHELP_WAG004);
			//Press Train to go back to the Train and Rake selection form.

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
