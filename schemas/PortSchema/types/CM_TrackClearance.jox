    <JadeMethod name="setForCreate" id="4c7a6262-86b6-4e5b-b146-ddf102c748a0">
        <updating/>
        <source>setForCreate(_proxyTrackClearance:CM_TrackClearance) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 June 2009	cnwndl1	Initial creation

*/

vars

begin

	setForUpdate(_proxyTrackClearance);
	setMyRoot();
	
epilog

end;</source>
        <Parameter name="_proxyTrackClearance" type="CM_TrackClearance"/>
