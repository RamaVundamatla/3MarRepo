    <JadeMethod name="getFirstCargoPlacedTime" id="6345e538-dd94-420d-8d22-76db1920efa3">
        <source>getFirstCargoPlacedTime():TimeStamp;
/*
Returns: Time of first carog placement

Date		Who		Reason
04 Dec 2012	cnwcs5	Initial creation - par 30413
*/
vars
	result	:TimeStamp;
	vvrd	:CM_VehicleVisitRecordDetail;
begin
	result	:= null;
	
	foreach vvrd in self.allVehicleVisitRecordDetails do
		if vvrd.recordType = VisitRecord_CargoPlaced then
			result	:= vvrd.timeStart;
			break;
		endif;
	endforeach;


	return result;
epilog

end;</source>
