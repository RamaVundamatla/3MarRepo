    <JadeMethod name="addDamageRow" id="a9fe7057-e47a-45c5-bd2f-983287cc75cc">
        <updating/>
        <source>addDamageRow(_damageInstance : CM_DamageInstance) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	25 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	row		: Integer;
begin
	//row := self.addItem(app.myHandHeldGuiAgent.getDamageDescrForLoc(_damageInstance.damageLocation) &amp; Tab &amp; 
	row := self.addItem(_damageInstance.myDamagePosition.code &amp; Tab &amp; 
				_damageInstance.myDamageDefinition.code &amp; Tab &amp;
				// TFS 54862 _damageInstance.severity.String &amp; Tab &amp; 
				_damageInstance.myDamageSeverity.code.String &amp; Tab &amp; // TFS 54862 
				_damageInstance.isNewDamage.String &amp; Tab &amp; 
				_damageInstance.quantity.String);
	self.accessCell(row,1).cellControl := self.myCmbPosition;
	self.accessCell(row,2).cellControl := self.myCmbCode;
	self.accessCell(row,3).cellControl := self.myCmbSeverity;
	self.accessCell(row,4).inputType := self.InputType_CheckBox;
	self.accessCell(row,5).inputType := self.InputType_SignedNumeric;
end;


</source>
        <access>protected</access>
        <Parameter name="_damageInstance" type="MobileHandHeldThin::CM_DamageInstance"/>
    </JadeMethod>
    <JadeMethod name="addNewRow" id="2391cc23-82d5-4e88-8865-77b929fa5b46">
        <updating/>
        <source>addNewRow() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	25 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	row	 : Integer;
begin
	row := self.addItem(null);
	self.accessCell(row,1).cellControl := self.myCmbPosition;
	self.accessCell(row,2).cellControl := self.myCmbCode;
	self.accessCell(row,3).cellControl := self.myCmbSeverity;
	self.accessCell(row,4).inputType := self.InputType_CheckBox;
	self.accessCell(row,5).inputType := self.InputType_SignedNumeric;

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cellInputReady" id="136c3642-f51b-4ac2-936e-67067376bf28">
        <controlMethod name="Table::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>cellInputReady(table: Table input; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating, clientExecution;
/*
----------   ----------  --------------------------------------------------
Created:	25 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	theHeight			: Real;
begin
	inheritMethod(table, inputControl, cleft, ctop, cwidth, cheight);

	if table.row = table.rows and table.column = 5 then
		self.addNewRow();
	endif;
	
		
end;


</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMinimumHeight" id="760231e7-5ef7-4103-b1fa-7b39c24a65f8">
        <source>getMinimumHeight() : Real;
/*
----------   ----------  --------------------------------------------------
Created:	22 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return self.rows * self.rowHeight[1] + 5;

end;


</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="5bfc3cd1-8a73-4206-ad36-e4205bc99891">
