<Class name="WS_AutoGateOutRequest" id="3e1d25e2-a2f4-4ed1-97c7-e0d84602659e">
    <superclass name="WS_Request"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allCargoIdentifiers" id="aa910b62-9ed0-4182-850f-0a3f2c6cddc8">
        <memberTypeInverse/>
        <type name="WS_OnsiteCargoIdentifierArray"/>
        <access>readonly</access>
        <text>Identifies the cargo items (including trailers and other equipment) being gated out with the truck.</text>
    </ImplicitInverseRef>
    <PrimAttribute name="batNumber" id="31377f10-13b0-437f-b8ad-133da5be71dc">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>The 'BAT number' or 'RFID Tag number' that would uniquely identify
the on-site truck, if the truck registration is not provided.</text>
    </PrimAttribute>
    <PrimAttribute name="gate" id="cc097fa8-a192-43b0-bfc2-4b5fa459ede3">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>The name of the Gate being used.
If left blank will use the 'Default' gate for the Terminal.</text>
    </PrimAttribute>
    <PrimAttribute name="truckRegistration" id="0b0faa29-e15b-43e3-9dd7-29d79c7de7b3">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>The truck registration that uniquely identifies
the on-site truck.</text>
    </PrimAttribute>
    <PrimAttribute name="truckState" id="a7364bc8-0cf6-4376-8d0f-14ec644d1b88">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>The 'State' associated with the truck registration that uniquely identifies
the truck. (In systems that are using 'State' as part of the truck identification)</text>
    </PrimAttribute>
    <JadeMethod name="addRealTI" id="ec0fcb68-e15b-458d-a0a4-3825c5516486">
        <source>addRealTI( _ti : CM_TrackedItem );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 September 2015	cnwndl1	Initial creation	Par 36951

*/

vars

	ws_Id : WS_OnsiteCargoIdentifier;

begin
	
	create ws_Id transient;
	ws_Id.setProxyFromObject( _ti );
	
	self.allCargoIdentifiers.add( ws_Id );

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="delete" id="c2d7827e-cc62-4074-aca3-c99c73f173fd">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Sep 2015	cnwndl1	Initial creation
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars

begin

	self.allCargoIdentifiers.purge();	//08.01.2026 navma1 #MTN-36897

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAndValidateTisToRelease" id="4394eb83-5a3b-4c96-9b25-769932976e24">
        <source>getAndValidateTisToRelease( _terminal : CM_Terminal; _vehicle : CM_Vehicle; toBeReleasedTis : CM_TIArray input ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 September 2015	cnwndl1	Initial creation	Par 36951

*/

vars

	vvr : CM_VehicleVisitRecord;
	ws_Id : WS_OnsiteCargoIdentifier;
	ti : CM_TrackedItem;
	localTis : CM_TIArray;
	cmgte : CMGTE_Entity;
	cmgteRel : CMGTE_Release;
	br : CM_BulkRelease;

begin

	vvr := _vehicle.getCurrentVisit();
	
	if vvr = null then
		app.raiseCMException(	Invalid_vehicle_visit_record,
								null, 
								null);
		return false;
	endif;
	
	if self.allCargoIdentifiers.isEmpty then
		// Not trying to take anything out.
		return true;
	endif;
	
	create localTis transient;
	foreach ws_Id in self.allCargoIdentifiers do
		ti := ws_Id.findMatchingCargoItem( _terminal );
		if ti = null then
			//couldn't find the thing.
			app.raiseCMException1(	Cargo_item_not_found_site,
									ws_Id.cargoId,
									null, 
									null);
			return false;
		endif;
		localTis.addExclusive( ti );
	endforeach;
	
	//check that the cargo items are in a release that we are working from.
	foreach cmgte in vvr.allGateEntities do
		if cmgte.isKindOf( CMGTE_Release ) then
			cmgteRel := cmgte.CMGTE_Release;
			if not cmgteRel.getIsAnyId() then
				continue;
			endif;
			br := cmgteRel.myBulkRelease;
			if br = null then
				continue;
			endif;
			foreach ti in localTis do
				if br.allTrackedItemsAssigned.includes( ti ) then
					toBeReleasedTis.addExclusive( ti );
				endif;
			endforeach;
		endif;
	endforeach;
	
	foreach ti in localTis do
		if not toBeReleasedTis.includes( ti ) then
			app.raiseCMException1(	Suitable_release,
									ti.id,
									null, 
									null);
		endif;
	endforeach;
	
	
	return true;

epilog

	delete localTis;
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="toBeReleasedTis" type="CM_TIArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getValidatedGate" id="bfd7ae79-ac06-441f-805d-3f7da58fa4dd">
        <source>getValidatedGate( _terminal : CM_Terminal; _gate : CM_Gate output):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 September 2015	cnwndl1	Initial creation	Par 36951

*/

vars

begin

	if gate.trimBlanks &lt;&gt; null then
		_gate := _terminal.getGate( gate );
		if _gate = null then
			app.raiseCMException1(	Gate_not_known,
									gate,
									null, 
									null);
			return false;
		endif;
	else
		_gate := _terminal.getDefaultGate_OUT;
		if _gate = null then
			app.raiseCMException1(	NO_Default_gate,
									_terminal.name,
									null, 
									null);
			return false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_gate" type="CM_Gate" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getValidatedVehicle" id="0124bc09-28af-49bd-a632-84349144725f">
        <source>getValidatedVehicle( _terminal : CM_Terminal ):CM_Vehicle;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 September 2015	cnwndl1	Initial creation	Par 36951

*/

vars

	registration : String;
	state : String;
	vehicle : CM_Vehicle;
	bat : String;
	vvr : CM_VehicleVisitRecord;

begin

	registration := self.truckRegistration;
	state := self.truckState;
	bat := self.batNumber;

	if registration = null and bat = null then
		app.raiseCMException(	Input_required_field_VehRegNum,
								null, 
								null);
		return null;
	else
		if registration &lt;&gt; null then
			vehicle := _terminal.vehicles[registration.toUpper, state];
			if vehicle = null then
				if state &lt;&gt; null then
					app.raiseCMException2(Err_Unknown_Truck_Rego_State,
										  registration,
										  state,
										  null, 
										  null);
				else
					app.raiseCMException2(ERR_Truck_Unknown,
										  registration,
										  null,
										  null, 
										  null);
				endif;
				return null;
			endif;
			
		elseif bat &lt;&gt; null then
			vvr := _terminal.getVehicleVisitForBatNumber( bat );
			if vvr &lt;&gt; null then
				vehicle := vvr.vehicle;
			else
				app.raiseCMException(Number_no_current_truck,
									  null, 
									  null);
			endif;
		endif;
		
		if not vehicle.isOnsite then
			app.raiseCMException1(Vehicle_not_site,
									  registration,
									  null, 
									  null);
			return null;
		endif;
	endif;
	
	return vehicle;

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
</Class>
