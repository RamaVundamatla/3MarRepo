    <JadeMethod name="canTwinLiftWithLocation" id="9dc122d6-8a3f-4060-8863-d0b1a4649811">
        <source>canTwinLiftWithLocation(_nextLocation: CM_LocationsController; 
						_myTrackedItem: CM_TrackedItem; 
						_nextLocationTrackedItem: CM_TrackedItem;
						_mode		: Integer;
						_direction : Integer output;
						_errorString : String io): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 February 2009	cnwer1	Initial creation

*/

vars

begin
	if not inheritMethod(_nextLocation,_myTrackedItem,_nextLocationTrackedItem,_mode,_direction,_errorString) then
		return false;
	endif;
	
	_direction:=CM_RTQueueEntry.TWIN_NONE;
	if not self = _nextLocation then
		_errorString:=app.getErrorString(Next_locatio_this_vehicle);
		return false;
	endif;

	_direction:=CM_RTQueueEntry.TWIN_BOTH ;
	return true;

epilog

end;</source>
        <Parameter name="_nextLocation" type="CM_LocationsController"/>
        <Parameter name="_myTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_nextLocationTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_direction" type="Integer" usage="output"/>
        <Parameter name="_errorString" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="ccms1061_conversion" id="8dac6ef3-25bf-4cdf-8b2f-799324714017">
        <updating/>
        <source>ccms1061_conversion(_terminalArea :CM_VehicleTransferArea)updating;
// ---------------------------------------------------------------------------
// Created:     15 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// this is a BIG kludge to remove CM_VehicleController instances from the
	// CM_TerminalArea::allLocationsControllers collection when CM_VehicleController::myTerminalArea
	// is null. 
	if self.vehicle.myPrimaryActualLocation = null then
		self.myTerminalArea	:= _terminalArea;	// force inverse maintenance
		self.myTerminalArea := null;			// force inverse maintenance
	endif;
epilog

end;</source>
        <Parameter name="_terminalArea" type="CM_VehicleTransferArea"/>
    </JadeMethod>
    <JadeMethod name="executeDisplayNotesForMove" id="20d3c5db-1592-4a61-839f-306ddb0953b6">
        <source>executeDisplayNotesForMove(_controller : CMIF_MoveController);
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theVoyage 	: CM_Voyage;	
	theTerminal : CM_Terminal;
	theTI		: CM_TrackedItem;
	termArea	: CM_TerminalArea;
begin

	theTerminal := self.myTerminal;
	theTI 		:= _controller.myTrackedItem;
	termArea    := self.myTerminalArea;
	
	// Par 11095 Terminal Area Enquiry Screen not Refreshing
	if self &lt;&gt; null and termArea &lt;&gt; null then
		app.myEventManager.createSingleObjInfoNoteEvt(termArea,	theTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),self);
	endif;
	// Par 11095 end
	
	if self &lt;&gt; null and termArea &lt;&gt; null then
		
		// PAR 10328
		if  self = _controller.myOriginatingLocation then
			app.myEventManager.createSingleObjInfoNoteEvt(termArea, theTerminal.getTerminalEvent(EVENT_TI_MOVE_FROM_LOCATION),theTI);
		elseif self = _controller.myToPrimaryLocation then
			app.myEventManager.createSingleObjInfoNoteEvt(termArea, theTerminal.getTerminalEvent(EVENT_TI_MOVE_TO_LOCATION),theTI);
		endif;
		app.myEventManager.createSingleObjInfoNoteEvt(termArea, theTerminal.getTerminalEvent(EVENT_TI_MOVE),self);
	endif;

	
	
	// update the load list
	if termArea &lt;&gt; null then
		if not _controller.isUndoMove and _controller.moveMode = PLANNING_MODE then
			// this is used in the load list
			app.myEventManager.createSingleObjInfoNoteEvt(termArea,theTerminal.getTerminalEvent(EVENT_PLANNING_TI_PLANNED),
				theTI);
		endif;
		
		// calling this event whether unplanning or not means that the TI is added to the load list as it arrives in the yard
		// this is used in the load list
		theVoyage := theTI.myVoyage;
		if theVoyage &lt;&gt; null then
			if theVoyage.isHOLDSorSHIP() then
				app.myEventManager.createSingleObjInfoNoteEvt(theVoyage,theTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),
						theVoyage);								
			elseif (_controller.isUndoMove 
					// ### Just arrived by road/rail.
					or (_controller.isSystemMove and _controller.isForcedMove and _controller.myOriginatingLocation = null ) ) then 
				app.myEventManager.createSingleObjInfoNoteEvt(theVoyage,theTerminal.getTerminalEvent(EVENT_PLANNING_TI_UNPLANNED),theTI);
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_controller" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="executePostMoveForToLocation" id="6fdda1b9-8e64-4bb6-b674-48f258516f52">
        <source>executePostMoveForToLocation(_control: CMIF_MoveController; _passport: CM_Passport input);
//----------------------------------------------------------------
//	Created:	18 February 2004	by Jason Chapman  (cnwjc2)
//
// 04 Dec 2025 navma1 	MTN-36742 AAT- Webb Dock West (WDCT) experiencing slowness 
//----------------------------------------------------------------
vars
	ti 				 : CM_TrackedItem;
	job			     : CM_Job;
	wle 			 : CM_WorkListEntry;
	nextAnyAmountWle : CM_YardWLE;
	vvr 			 : CM_VehicleVisitRecord;
	arbiter			 : CM_RTQueueArbiter;
begin


	ti := _control.myTrackedItem;

	if _control.myWorkListEntry &lt;&gt; null and _control.moveMode = REAL_MODE then
	
		//21 Mar 2017	NDL	TFS 3813 - 
		wle := _control.myWorkListEntry;
		
		if wle.isAnyAmount() then	//13 Mar 2018	NDL	TFS 37408 - moved up
			//epr TFS 36605 22/1/18 lets set the actual amount that was moved onto the truck
			wle.setQuantity(_control.quantity);
			wle.setWeight(_control.weight);
		
		
			if wle.anyIdCargoAvailableCount &gt; 0 then
				//Any Amount (Any Id) Release, and we have at least one left, so create the wle
				create nextAnyAmountWle as wle.class;
				nextAnyAmountWle.setForCreate( wle.job , wle.myRequest );	
			endif;
		endif;
		
		job := _control.myWorkListEntry.job;
		
		if job = null then
			return;
		endif;
		
		//10 Feb 2021	NDL	TFS 50666
		if nextAnyAmountWle &lt;&gt; null then
			create arbiter;
			arbiter.job := job;
			nextAnyAmountWle.enqueueWLE( arbiter );
			
			if not _passport.noErrors then
				return;
			endif;
		endif;
	
		if job.isKindOf(CM_RoadJob) and not _control.myWorkListEntry.isReceipt then
			vvr:=job.CM_RoadJob.myVehicleVisit;
			
			//epr par 34523 31/7/14 
			if ti.jobRoadRelease &lt;&gt; null then
				ti.jobRoadRelease.allReleaseTrackedItems.remove(ti);
			endif;
			
		
			job.CM_RoadJob.allReleaseTrackedItems.tryAdd(ti);			//04.12.2025 navma1 #MTN-36742

			//epr TFS 40248 29/8/18
			if vvr &lt;&gt; null and not ti.hasBeenMerged then				//04.12.2025 navma1 #MTN-36742
				vvr.allReleasedTrackedItems.tryAdd(ti);
			endif;
		endif;

		if _control.myWorkListEntry &lt;&gt; null	and _control.myWorkListEntry.isReleaseByTypeBulkRelease() then
			ti.validateCustDocTransportMove(_control, app.myPassport); // release by type, add here after the TI has been moved so we know what is now on the transport
		endif;
	endif;
	
epilog
	if arbiter &lt;&gt; null then
		arbiter.erase(0);
	endif;

end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFullId" id="7e7c93af-9569-481a-864a-d55fca4a2fb1">
        <source>getFullId(): String;

// Changed On	Changed By	Reason
// ----------	----------	--------------------------------------------------
// 15 Mar 2010	consw1		PAR #23020 - Allow for vehicle that is defined with a state
// ---------------------------------------------------------------------------
vars
	str	: String;
	
begin

	if self.vehicle = null then
		str := '&lt;' &amp; app.getErrorString(Unknown) &amp; '&gt;';
	else
		str := vehicle.regNumber;
		if vehicle.state &lt;&gt; null then
			str := str &amp; " (" &amp; vehicle.state &amp; ")";
		endif;
	endif;
	
	return str &amp; " " &amp; app.getErrorString(Road);
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
