    <JadeMethod name="setForUpdate" id="e25625bb-0a13-4c80-9448-f071b4090e73">
        <updating/>
        <source>setForUpdate(_proxyPackage: CM_PackageInvoice) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 February 2024	navra1	Initial creation for CR 61910/Task 62303 - EUP | API Create default package to run on invoice

*/

vars

begin
	self.sendToDebtorEmail 				:= _proxyPackage.sendToDebtorEmail;
	self.attachExtAttOfInv 				:= _proxyPackage.attachExtAttOfInv;
	self.prefixEmailSubWithInvNumber 	:= _proxyPackage.prefixEmailSubWithInvNumber;
	
	inheritMethod(_proxyPackage);

epilog

end;</source>
        <Parameter name="_proxyPackage" type="CM_PackageInvoice"/>
    </JadeMethod>
</Class>
