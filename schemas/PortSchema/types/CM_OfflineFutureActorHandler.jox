    <JadeMethod name="actionExceptionHandler" id="36a3aea6-ec0c-4cf8-b45c-b1fcff2a08a8">
        <source>actionExceptionHandler(exc : Exception; actor : CM_OfflineFutureActor) : Integer protected;

/*

Purpose:			Catch-all exception handler for the processing of a single 
					OfflineFutureActor instance, to allow any specific processing in the 
					exception to occur prior to passing back for a stack dump and
					alerts, etc


Return Value:


Date		Who		Reason

*/

vars
	returnVal		: Integer;
	msg				: String;
	
begin
	returnVal := Ex_Pass_Back;
	
	msg := exc.class.name &amp; " " &amp; exc.errorCode.String;

	// Set CardSchema dump/reporting info as appropriate
	//app.myCnCntrl.setLogMiniStackDump(not app.sysParamValue(SYSPARAM_DIAG_STACKDUMP).Boolean);
	//app.myCnCntrl.setReportExceptions(app.isReportableException(exc));
	
	if app.isValidObject(actor) then
		msg := msg &amp; " processing " &amp; actor.longDisplay;
		msg := msg &amp; ", adding to non-processing list";
		self.allNonProcessableActors.addNoDuplicates(actor, false);

		actor.processActionException(exc);
	endif;

	msg := msg &amp; ", returning Ex_Pass_Back and firing timer for queue reprocessing";
	self.logErrorMessage(msg);
	
	self.startOneShotTimer(0);

epilog
	return returnVal;
	
end;</source>
        <access>protected</access>
        <Parameter name="exc" type="Exception"/>
        <Parameter name="actor" type="CM_OfflineFutureActor"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="calculateDelayAndStartTimer" id="3f44ab2f-643b-4d13-b370-557eefc8a411">
        <source>calculateDelayAndStartTimer() : Boolean protected;

/*

Purpose:			Calculate the delay required until the next OfflineFutureActor is ready
					to be processed, and if it is less than the time remaining until the
					next continuous timerEvent, then fire off a one shot timer to ensure
					we wake up at the right time
					

Return Value:		True if a new timer was started. false otherwise


Date		Who		Reason
*/

vars
	actor			: CM_OfflineFutureActor;
	iter			: Iterator;
	now,
	nextTimerReqd,
	nextLockRetry	: TimeStamp;
	option,
	timeRemaining	: Integer;
	needATimer		: Boolean;
	newTimerDelay	: Integer;
				
begin
	// If running as a test, just do one timer event and stop
	if self.startTime &lt;&gt; null and
	   self.endTime &lt;&gt; null then
		return false;
	endif;
	// First get the status of the continuous timer, and calculate the time it will fire
	if not self.getTimerStatus(EVENT_TIMER_OFFLINEFUTURE_CONT, option, timeRemaining) then
		self.logErrorMessage("Timer " &amp; EVENT_TIMER_OFFLINEFUTURE_CONT.String &amp; " not running, restarting");
		self.startContinuousTimer();
		timeRemaining := Standard_Timer_Delay;
	endif;

	nextTimerReqd := app.actualTimeServer + timeRemaining.Time;
	
	iter := app.myRoot.allOfflineFutureActors.createIterator;
	while iter.next(actor) do
		// Have read past any due for action before next timer, so bail out
		if actor.actionTimeStamp &gt;= nextTimerReqd then
			break;
		endif;
		
		// If this actor caused an exception (other than a lock) in the current 
		// instantiation of the application, then skip it
		if self.allNonProcessableActors.includes(actor) then
			continue;
		endif;
		
		// If this actor hasn't had a lock exception, then use its action timestamp
		if actor.lockExceptionTimeStamp = null then
			nextTimerReqd := actor.actionTimeStamp;
			needATimer := true;
			break;
		endif;
		
		// Otherwise, need to calculate the reprocessing time of this previously locked 
		// actor, and possibly use this time, if it precedes the nextTimerReqd time
		nextLockRetry := actor.lockExceptionTimeStamp + Lock_Exception_Process_Delay.Time;
		if nextLockRetry &lt; nextTimerReqd then
			nextTimerReqd := nextLockRetry;
			needATimer := true;
		endif;

	endwhile;
	
	// If a new timer is required, then start it here
	if needATimer then
		self.logDiagMessage(method.qualifiedName &amp; " new timerEvent required at " &amp; nextTimerReqd.String);
		// handle old overdue actors without risking 1406 exceptions
		now := app.actualTimeServer;
		if nextTimerReqd &lt; now then
			newTimerDelay := 0;
		else
			newTimerDelay := nextTimerReqd.milliSecondsDiff(now).Integer.max(0);
		endif;
		self.startOneShotTimer(newTimerDelay);
		return true;
	endif;
	
	return false;

epilog
	delete iter;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getNextActorToProcessNow" id="4a3702f9-486d-4b5e-af47-94bfe1184ed5">
        <source>getNextActorToProcessNow() : CM_OfflineFutureActor protected;

/*

Purpose:			Get the next CM_OfflineFutureActor that's ready to be processed.  This
					will be any one for which we have passed the action time, and was not 
					too recently the cause of a lock exception.
					self.startTime and endTime are for testing only, not the regular usage.


Return Value:		CM_OfflineFutureActor to be processed, or null if there are none


Date		Who		Reason

*/

vars
	returnVal,
	actor			: CM_OfflineFutureActor;
	iter			: Iterator;
	now				: TimeStamp;
	msg				: String;
	
begin
	on LockException do getNextLockExceptionHandler(exception);
	on DeadlockException do getNextLockExceptionHandler(exception);
	
	now := app.actualTimeServer;
	
	iter := app.myRoot.allOfflineFutureActors.createIterator;
	if self.startTime &lt;&gt; null then
		app.myRoot.allOfflineFutureActors.startKeyGeq(self.startTime, iter);
	endif;
	while iter.next(actor) do
		// Exit if reading past nominated end time, for testing
		if self.endTime &lt;&gt; null and
		   actor.actionTimeStamp &gt; self.endTime then
			returnVal := null;
			return returnVal;
		endif;
			
		// Have read past any due for action, so bail out.
		// For testing do everything in the time range.
		if actor.actionTimeStamp &gt; now then
			if self.endTime = null then
				returnVal := null;
				return returnVal;
			endif;
		endif;
		
		// If this actor caused an exception (other than a lock) in the current 
		// instantiation of the application, then skip it
		if self.allNonProcessableActors.includes(actor) then
			logMessage(actor.longDisplay &amp; " previously marked as non-processable, skipping");
			continue;
		endif;
		
		// If this actor hasn't caused any previous locks, then it's OK to process now
		if actor.lockExceptionTimeStamp = null then
			returnVal := actor;
			
			return returnVal;
		endif;
		
		// If enough time has elapsed since the last lock exception for this actor,
		// this it's OK to process now
		if now.milliSecondsDiff(actor.lockExceptionTimeStamp) &gt; Lock_Exception_Process_Delay then
			returnVal := actor;
			return returnVal;
		endif;
	
		// Otherwise, read the next actor in the collection	
	
	endwhile;
	
	// Got here, then there is no valid one to process, so return null
	returnVal := null;
	return returnVal;


epilog
	delete iter;

	// Diagnostic log of returned value
	msg := method.qualifiedName;
	if returnVal = null then
		msg := msg &amp; " - no OfflineFutureActors to process";
	else
		msg := msg &amp; " - returning " &amp; returnVal.longDisplay;
	endif;
	self.logDiagMessage(msg);
	
end;</source>
        <access>protected</access>
        <ReturnType type="CM_OfflineFutureActor"/>
    </JadeMethod>
    <JadeMethod name="getNextLockExceptionHandler" id="4c975c49-82d5-4c6b-8d59-ffe16f95e22d">
        <source>getNextLockExceptionHandler(exc : Exception) : Integer protected;

/*

Purpose:			Handler for Lock and Deadlock exceptions during getNextActor processing.  Will
					abort action after starting a timer for reprocessing


Return Value:


Date		Who		Reason

*/

vars
	returnVal		: Integer;
	msg				: String;
	
begin
	returnVal := Ex_Pass_Back;
	
	msg := method.qualifiedName &amp; " " &amp; exc.class.name &amp; " " &amp; exc.errorCode.String;
	msg := msg &amp; ", aborting action and firing timer for reprocessing";
	self.logMessage(msg);
	
	app.cmsAbortTransaction();
	
	// Fire off a timer to retry after an appropriate wait for the locks to clear
	self.startOneShotTimer(Lock_Exception_Process_Delay);
	
	returnVal := Ex_Abort_Action;
	
epilog
	return returnVal;
	
end;</source>
        <access>protected</access>
        <Parameter name="exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lockExceptionHandler" id="20d1092e-697e-4d39-a892-aefa187144cc">
        <source>lockExceptionHandler(exc : Exception; actor : CM_OfflineFutureActor input) : Integer protected;

/*

Purpose:			Handler for Lock and Deadlock exceptions, to allow for re-queuing
					of OfflineFutureActor object for processing


Return Value:


Date		Who		Reason

*/

vars
	msg				: String;
	
begin
	msg := exc.class.name &amp; " " &amp; exc.errorCode.String &amp; " processing " &amp; actor.longDisplay;
	msg := msg &amp; ", aborting current attempted transaction, and updating OfflineFutureActor lockExceptionTimeStamp";

	app.doDumpStack(exc);

	// We have encountered a lock or deadlock, so abort the current transaction
	app.cmsAbortTransaction();
	
	// Now we need to re-enter transaction state, and update the lockExceptionTimeStamp.
	beginTransaction;
	actor.setLockExceptionTimeStamp(app.actualTimeServer);
	
	// Return to the arming method, which will do the commit
	return Ex_Resume_Next;

	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="exc" type="Exception"/>
        <Parameter name="actor" type="CM_OfflineFutureActor" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
