    <JadeMethod name="trxCreateVoyageCargoRequest" id="f11c47b4-5fc8-46a5-a3ff-9130b57706ea">
        <updating/>
        <source>trxCreateVoyageCargoRequest( _voyage : CM_Voyage input;
							 _voyageExternalCode : String;	
							_allPxyWorkOrdersDtls : ObjectArray input;
							_allDocuments	: ObjectArray input;
							_nextStatus : CM_VoyageStatus;	//24 May 2018	NDL	TFS 38135
							_berth : HMS_Berth;
							_requiredByDT : TimeStamp;
							_allPxyHMSResourcesUsed : HMS_ResourceUsedSet; // TFS 40127
							_setVoyageRequestOperators : Boolean; //TFS 42220
							_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Mar 2018	jlger1	Initial creation 37664
05 Aug 2018 jlger1	tfs 40032 - now just creates the cargo requests - on approving the cargo request the cargo  and jobs are created
14 Aug 2018 jlgam15 TFS 40266 WebPortal - RequiredByDT is not being saved properly on the cargo request
19 Sep 2018	jlgdap1	TFS 40842 PEL1 Hook code not being invoked when cargo request is submitted via web portal
01 Oct 2021	jlier1	TFS 51963 - changes to voyage process
09 Mar 2022	jlizm1	TFS 52834 SAL file attachments filter by work order
21 Feb 2024	navsck1	ChangeRequest 62237 [62238]: MTN | Manage Work Order Documents in Web Portal
*/

vars
	checkStatus,
	nextStatus	: CM_VoyageStatus;
	workOrderDtl : CM_WorkOrderDtl;
	pxyWorkOrderDtl : CM_WodVoyageCargoRequest;
	berth : HMS_Berth;
	realWorkOrder  : CM_WorkOrder; 
	pxyWorkOrder : CM_WorkOrderVoyage;
	allWorkOrderDetailsToDelete : ObjectSet;
	terminal : CM_Terminal;
	hookBank : CM_Bank;									// TFS 40842
	cargoRequest : CM_WodCargoRequest;
	cargoOperator : CM_Operator;
	voyageRequest : CM_WodVoyageRequest;
	pxyDocuments : CM_FileDataSet;
	documentsToDelete : CM_FileDataSet;
	obj : Object;
	newDocuments : ObjectArray;
	filesToCreate : Boolean;
	filesToUpdate : Boolean;
	realFile : CM_FileData;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	
	if _voyage = null and _voyageExternalCode = null then
		//raise Exception 
		return;
	endif;
	
	
		
	if _voyage &lt;&gt; null then
		//epr TFS 41523 1/11/18 
		if _voyage.myVoyageProcess &lt;&gt; null then
			if _voyage.myVoyageProcess.isMTNWOProcess then //jlier1 TFS 51963 1/10/21
				checkStatus:=app.myRoot.allVoyageStatuses[Voyage_Status_CargoRequested];
			endif;
			if checkStatus = null or not checkStatus.userCanSet(app.myPassport.myTerminal) then
				app.raiseCMException2(Cannot_Set_Voyage_Status, app.myPassport.myTerminal.code, checkStatus.description, "status", null);	// TFS 37445
				return;
			endif;
		endif;
		
		terminal:=_voyage.myTerminal;
		if _voyage.status = Voyage_Status_CargoRequested  or
			 _voyage.status = Voyage_Status_CargoReqRejected then
		else
		
			if _voyage.status &lt;&gt; Voyage_Status_CargoReqPending  then			
				//new error
				app.raiseCMException1(Voyage_status_create_cargo,_voyage.statusDescription,null,null);	
			endif;
		endif;	
		
		workOrderDtl:= _voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_CARGOINITIAL);
	endif;

	beginTransaction;
	
	
	
	berth:=_berth;
	
	if berth = null and _voyage &lt;&gt; null and _voyage.myHMSVoyageData &lt;&gt; null then															// TFS 39964
		//berth := _voyage.myHMSVoyageData.getBerthForDateTime(_voyageJob.myShift.startDateTime);		// TFS 39964
		
		if berth= null and _voyage.getMovementArrival &lt;&gt; null then // TFS 39349
			berth := _voyage.getMovementArrival.getMyBerth;		// TFS 39349 use arrival
		endif;
	endif;	
	if workOrderDtl &lt;&gt; null then
		realWorkOrder := workOrderDtl.myParent;
	endif;
	
	create allWorkOrderDetailsToDelete transient;
	
	if realWorkOrder &lt;&gt; null then	
		if realWorkOrder.taskStatus &lt;&gt; WO_STATUS_PENDING and
			realWorkOrder.taskStatus &lt;&gt; WO_STATUS_NOTAPPROVED and 
			realWorkOrder.taskStatus &lt;&gt; WO_STATUS_USERENTRY  then
			//raise exception
			app.raiseCMException1(Not_updat_initi_cargo_reque_st,realWorkOrder.getStatusString,null,null);
			return;
		endif;
		
		pxyWorkOrder := realWorkOrder.pxyCreateUpdateProxy.CM_WorkOrderVoyage;		
		workOrderDtl.CM_WodVoyageCargoRequest.allCargoDetails.copy(allWorkOrderDetailsToDelete);
		pxyWorkOrderDtl:=workOrderDtl.pxyGetProxyObject.CM_WodVoyageCargoRequest;	
		pxyWorkOrderDtl.setMarineDetsFromResourceUsed(_allPxyHMSResourcesUsed); // TFS 40127
		
	else
		create pxyWorkOrder transient;
		pxyWorkOrder.setProxy(null,null,false,app.actualTimeAppServer,app.myPassport.myUser,null,null,terminal,null,null,null, WO_STATUS_PENDING);
		pxyWorkOrder.setMyVoyage(_voyage);
		pxyWorkOrder.setVoyageExternalCode(_voyageExternalCode);
		
		create pxyWorkOrderDtl transient;
		pxyWorkOrderDtl.setParent(pxyWorkOrder);		
		pxyWorkOrderDtl.setMarineDetsFromResourceUsed(_allPxyHMSResourcesUsed); // TFS 40127
	endif;
	
	if pxyWorkOrderDtl.myBerth = null then
		pxyWorkOrderDtl.setMyBerth(berth);
	endif;
	if _requiredByDT &lt;&gt; null then
		pxyWorkOrder.setRequiredByDT(_requiredByDT);
		// TFS 41538 -  OccursOnDT not necessary any more on an initial cargo request
		// TFS 41538 pxyWorkOrderDtl.setRequiredByDT(_requiredByDT);
	else
		if pxyWorkOrderDtl.requiredByDT = null then
			if _voyage &lt;&gt; null and _voyage.arrivedDT &gt; app.actualTimeAppServer then
				// TFS 41538 pxyWorkOrderDtl.setRequiredByDT(_voyage.arrivedDT);// TFS 39964	
				pxyWorkOrder.setRequiredByDT(_voyage.arrivedDT);
			else
				// TFS 41538 pxyWorkOrderDtl.setRequiredByDT(app.actualTimeAppServer);// TFS 39964
				pxyWorkOrder.setRequiredByDT(app.actualTimeAppServer);
			endif;
		endif;
	endif;
	
	pxyWorkOrderDtl.allCargoDetails.purge;
	_allPxyWorkOrdersDtls.copy(	pxyWorkOrderDtl.allCargoDetails);
	
	if realWorkOrder = null then
	
		app.myUtilityCA.utlCreateWorkOrder(pxyWorkOrder, realWorkOrder, app.myPassport);
	else
		app.myUtilityUA.utlUpdateWorkOrder(pxyWorkOrder,true,app.myPassport);
	endif;
	
	if  _passport.hasErrors then
		return;
	endif;
	
	allWorkOrderDetailsToDelete.purge;
	
	if _voyage = null then
		return;
	endif;
	
	if  realWorkOrder &lt;&gt; null and _allDocuments &lt;&gt; null then								// 21.02.2024 navsck1 #62237
		create pxyDocuments transient;
		create newDocuments transient;
		create documentsToDelete transient;
		realWorkOrder.allFiles.copy(documentsToDelete);
		foreach obj in _allDocuments do
			if obj.isKindOf(CM_FileData) and obj.CM_FileData.pxyIsProxy then
				// document is for update
				pxyDocuments.add(obj.CM_FileData);
				filesToUpdate := true;
				realFile := obj.CM_FileData.pxyGetRealObject();
				if documentsToDelete.includes(realFile) then
					documentsToDelete.remove(realFile);
				endif;
			else
				// document is to be created
				newDocuments.add(obj);
				filesToCreate := true;
			endif;
		endforeach;

		if filesToCreate then
			app.myUtilityCA.utlCreateFiles(realWorkOrder, newDocuments, _passport);
		endif;
		if filesToUpdate then
			app.myUtilityUA.utlUpdateFiles(pxyDocuments, _passport);
		endif;
		if documentsToDelete.size() &gt; 0 then
			// any documents that are on the exisitng voyage cargo request, 
			// but aren't in the list to update, will get deletetd
			app.myUtilityDA.utlDeleteFiles(documentsToDelete, _passport);
		endif;
	endif;																					// 21.02.2024 navsck1 #62237
	
	if  _passport.hasErrors then
		return;
	endif;
	
	
	//24 May 2018	NDL	TFS 38135
	if _nextStatus &lt;&gt; null then
		nextStatus := _nextStatus;
	else
		
		if _voyage.myVoyageProcess.isMTNWOProcess then //jlier1 TFS 51963 1/10/21
			nextStatus:=_voyage.myVoyageProcess.allStatusesById[Voyage_Status_CargoRequested]; // TFS 41539	
		endif;
		
	endif;
	
	if nextStatus &lt;&gt; null then
		_voyage.setStatusFromObject(nextStatus);
	endif;	
	
	hookBank := app.myRoot.getVoyageBusUnit(_voyage.myTerminal, _voyage).CM_Bank;		// TFS 40842
	if _voyage.myDischargeCompany &lt;&gt; hookBank then										// TFS 40842
		_voyage.setMyDischargeCompany(hookBank);										// TFS 40842
	endif;																				// TFS 40842
	//epr TFS 42220 26/11/18
	if _setVoyageRequestOperators and realWorkOrder &lt;&gt; null then
		cargoRequest:=realWorkOrder.allWoDtls.first.CM_WodVoyageCargoRequest.allCargoDetails.first;
		if cargoRequest &lt;&gt; null then		
			cargoOperator:=app.myRoot.allOperators[cargoRequest.getOperatorCode];
			if cargoOperator &lt;&gt; null then
				voyageRequest:=_voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_NEWVOYAGE).CM_WodVoyageRequest;
				if voyageRequest &lt;&gt; null then
					voyageRequest.setOperatorsForWS(null,cargoOperator,cargoOperator);
				endif;
			endif;
		endif;
	endif;
	
epilog
	delete pxyWorkOrder;
	delete allWorkOrderDetailsToDelete;
	if pxyDocuments &lt;&gt; null then				// 28.02.2024 navsck1 #62237
		pxyDocuments.purge();
		delete pxyDocuments;
	endif;
	if newDocuments &lt;&gt; null then
		newDocuments.purge();
		delete newDocuments;
	endif;
	if documentsToDelete &lt;&gt; null then
		documentsToDelete.purge();
		delete documentsToDelete;
	endif;										// 28.02.2024 navsck1 #62237
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_voyageExternalCode" type="String"/>
        <Parameter name="_allPxyWorkOrdersDtls" type="ObjectArray" usage="input"/>
        <Parameter name="_allDocuments" type="ObjectArray" usage="input"/>
        <Parameter name="_nextStatus" type="CM_VoyageStatus"/>
        <Parameter name="_berth" type="HMS_Berth"/>
        <Parameter name="_requiredByDT" type="TimeStamp"/>
        <Parameter name="_allPxyHMSResourcesUsed" type="HMS_ResourceUsedSet"/>
        <Parameter name="_setVoyageRequestOperators" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
