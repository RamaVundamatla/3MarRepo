<Class name="CM_QCargoTypeLookupProperty" id="48f94a25-d7cb-4e37-b8d0-4880b670bcdc">
    <superclass name="CM_QIntegerLookupProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="94e40a02-56d8-4975-ad87-42b5361e7077">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     04 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
		
	create oper as CM_QIntegerLookupEqual persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntegerLookupNotEqual persistent;
	self.allAllowedOperators.add(oper);

	create oper as CM_QIntegerIsOneOf persistent;
	self.allAllowedOperators.add(oper);
end;</source>
    </JadeMethod>
    <JadeMethod name="getControlNameForOperator" id="9223fc61-74b6-4cfe-8fca-6c695a94a836">
        <source>getControlNameForOperator(_operator: CM_QueryOperator): String;
// ---------------------------------------------------------------------------
// Created:     19 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if CM_QIntegerLookupEqual.hasInstance(_operator) or
	   CM_QIntegerLookupNotEqual.hasInstance(_operator) then
		return 'cmbCargoType';
	endif;


end;</source>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <ReturnType type="String"/>
    </JadeMethod>
