    <JadeMethod name="handleSystemNotification" id="72c7a998-62fe-47b2-a9f4-092956760673">
        <updating/>
        <source>handleSystemNotification(eventType: Integer; theObject: CM_Object; eventTag: Integer) updating, protected;
//--------------------------------------------------
// Created:	05 May 2005 By: RBarr
//--------------------------------------------------
vars
	translatableText 	: XLAT_TranslatableText;
	xlatErrorMessage	: XLAT_TextMessage;	
	xlatFormCaption		: XLAT_FormCaption;	
	xlatPermission		: XLAT_Permission;	
	xlatReportName		: XLAT_ReportName;	
	xlatEntityTableText	: XLAT_EntityTableText;
	
	translation			: XLAT_Translation;
	locale				: CM_Locale;
	table				: CM_TextTranslationTable;
begin

	if CM_Locale.hasInstance(theObject) then
		locale := theObject.CM_Locale;
		
		if eventType &lt;&gt; Object_Delete_Event then
			// nothing to change at this stage afaik
		else
			// could be trouble!
		endif;
		return;
	endif;

	table := zGetTopTable;


	if XLAT_Translation.hasInstance(theObject) then
		translation := theObject.XLAT_Translation;
		if eventType &lt;&gt; Object_Delete_Event then
			if translation.myTranslatableText = self.myTranslatableText then
				if self.mode = self.Mode_View then
					self.displayTranslations();
				else
				// do nothing - rely on version check
				endif;
			else
				// not interested
			endif;
		else
		 	if 	app.isValidObject(self.myTranslatableText)
			and self.zGetTranslatableTextEdition(table) &lt;&gt; self.myTranslatableText.edition
			then
				// included in search results
				//if agent.isIncludedInSearchResults(self.myTranslatableText) = null then
					self.displayTranslations();
				//endif;	
			else
				// we've just deleted it
			endif;
		endif;
		return;
	endif;

    
	if XLAT_TextMessage.hasInstance(theObject) then
		translatableText := theObject.XLAT_TextMessage;
		table := tblMessages;
	endif;
	if XLAT_FormCaption.hasInstance(theObject) then
		translatableText := theObject.XLAT_FormCaption;
		table := tblFormCaptions;
	endif;
	if XLAT_Menu.hasInstance(theObject) then
		translatableText := theObject.XLAT_Menu;
		table := tblMenuEntities;
	endif;
	if XLAT_Permission.hasInstance(theObject) then
		translatableText := theObject.XLAT_Permission;
		table := tblPermissions;
	endif;
	if XLAT_ReportName.hasInstance(theObject) then
		translatableText := theObject.XLAT_ReportName;
		table := tblReportNames;
	endif;
	if XLAT_EntityTableText.hasInstance(theObject) then
		translatableText := theObject.XLAT_EntityTableText;
		table := tblTableEnts;
	endif;

	// included in search results?
	if app.isValidObject(translatableText) and self.myAgent.isIncludedInSearchResults(translatableText) = null then
		return;
	endif;

	
	if eventType = Object_Delete_Event then
		table.removeDeletedObject(translatableText);
		
		if theObject = self.myTranslatableText and self.zGetTranslatableTextEdition(table) &lt;&gt; self.myTranslatableText.edition then
			self.displayTranslations();
		endif;
	endif;

	if eventType = Object_Update_Event then
		if theObject = self.myTranslatableText
		and self.zGetTranslatableTextEdition(table) &lt;&gt; self.myTranslatableText.edition
		then
			// do nothing - rely on version check
		else
			table.updateItemObject(theObject, colorRow1, colorRow2, app.myPassport);
		endif;
	endif;
	
	if eventType = Object_Create_Event then
		table.updateItemObject(theObject, colorRow1, colorRow2, app.myPassport);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="CM_Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleUserNotification" id="5e56e192-406c-4316-ba4c-9be2e25f3623">
        <updating/>
        <source>handleUserNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2019	jlgab1	Initial creation

*/

vars

begin

	//	JLGAB1 JUN19	
	if eventType = EVENT_SPECIAL_USER then
		self.isDeveloperMode := app.isDevelopmentSystemMain() and app.isSpecial();
		
		if self.isDeveloperMode and not self.btnNew.visible then
	
			lMode.caption := ' Developer - ' &amp; lMode.caption;
			// developer mode functions
			self.btnNew.enabled 		:= true;
			self.btnDelete.enabled 	:= true;
			self.btnNew.visible 		:= true;
			self.btnDelete.visible 	:= true;
			self.doResize();
		endif;
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="cdb0ef8c-e4a4-4fce-b6eb-491f03294ae6">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------
// Created:	19 April 2005 By: RBarr
//--------------------------------------------------
constants
	CTRL = 2;
	
begin
	if keyCode = CMUI_Key_F3 then
		self.showHideSearcher();
	elseif keyCode = J_key_Enter then
		if self.frmSearch.visible then
			self.doSearch();
		endif;		

	elseif keyCode = J_key_E and shift.bitAnd(CTRL) = CTRL and self.mode = self.Mode_View then	// edit mode
		mode := Mode_Update;
	
	elseif keyCode = J_key_S and shift.bitAnd(CTRL) = CTRL and self.mode = self.Mode_Update then	// save
		doSave;

	elseif keyCode = J_key_X and shift.bitAnd(CTRL) = CTRL then
		if self.mode = self.Mode_View then
			self.unloadForm();	// close (view mode)
		 else				
			self.doBaseFormCancel();	// cancel (edit mode)
		endif;

	else	
		inheritMethod(keyCode, shift);
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
