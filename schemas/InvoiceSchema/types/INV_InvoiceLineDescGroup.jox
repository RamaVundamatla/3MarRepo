    <JadeMethod name="addObjectToTable" id="8584866c-70ab-4a86-853c-eb8939825ed8">
        <updating/>
        <source>addObjectToTable(_obj: Object; _numItems: Integer io; _breakOut: Boolean io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2015	cnwmc5	Initial creation	PAR 35858

*/

vars

begin
	if not _obj.isKindOf(CM_InvoiceLineDescGroup) then
		return;
	endif;
	
	if _obj.CM_InvoiceLineDescGroup.bank &lt;&gt; null
	and not _obj.CM_InvoiceLineDescGroup.bank.terminal = self.myTerminal then
		return;
	endif;
	
	inheritMethod(_obj, _numItems, _breakOut);

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_numItems" type="Integer" usage="io"/>
        <Parameter name="_breakOut" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addObjectsToTable" id="f6ff6d00-929a-44e3-adca-ce678336b165">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		This is the query on change of business unit
//
// ---------------------------------------------------------------------------

vars
	aInvoiceLineDesc : CM_InvoiceLineDescGroup;
	theInvoiceLineDescs :	CM_InvLineDescGrpByDescDict;
	tmpPassport	: CM_Passport;
	breakOut	: Boolean;
begin

	self.setMyDataClass();
	// 35872 do change of business unit
	self.setMyCurrentBank( self.cmbBank.listObject.CM_Bank);

	if self.myCurrentBank = null then
		return;
	endif;
	
	
//	TFS 2682	self.caption := self.myCurrentBank.code &amp; " Invoice Line Group";
	self.setCaption("Invoice Line Group " &amp; self.myCurrentBank.code);

	theInvoiceLineDescs := self.myCurrentBank.invLineDescGroups;
	tmpPassport := app.myPassport;
	
	foreach aInvoiceLineDesc in theInvoiceLineDescs do
		if self.includeObject(aInvoiceLineDesc, tmpPassport) then
			self.addObjectToTable(aInvoiceLineDesc, _numItems, breakOut);
		endif;
		if breakOut then
			break;
		endif;
	endforeach;

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
