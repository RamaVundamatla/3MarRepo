    <JadeMethod name="isStorageDetailMatch" id="37cbe61b-d086-4d32-b57e-0526169029f0">
        <source>isStorageDetailMatch(_criteria: CM_YACriteria; _ti: CM_TrackedItem; _tiTrx: CM_TITransaction): Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 15 August 2023
TFS#		: 58429
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	if _tiTrx &lt;&gt; null and _tiTrx.myTrackedItem &lt;&gt; null then	
		return _criteria.myYAData.CM_YADataBoolean.doesValueMatch(_tiTrx.myTrackedItem.itemised);	
	else
		return _criteria.myYAData.CM_YADataBoolean.doesValueMatch( _ti.itemised);
	endif;
end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
