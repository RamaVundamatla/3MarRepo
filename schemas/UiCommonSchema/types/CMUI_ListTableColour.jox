<GUIClass name="CMUI_ListTableColour" id="3ca2a0df-20e9-494d-9798-3a01e3b5af53">
    <superclass name="CMUI_ListTable"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="click" id="f6e6970b-45a3-4ba4-85ff-6406e7a1817e">
        <controlMethod name="CMUI_ListTable::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>click(table: Table input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/08/2013	cnwdap1		Initial creation PAR #32123
//
vars

begin
	if table.row &gt; 1 or not app.myCurrentUserCan(app.getMyTerminalDO_NOT_USE, PmAdmVehicleColourMaint) then
		inheritMethod(table);
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dblClick" id="b49f1d53-4b83-4b4e-b5a2-24197779bd1a">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dblClick(table: Table input) updating, clientExecution;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/08/2013	cnwdap1		Initial creation PAR #32123
//
vars
	form : CMUI_NewColourForm;

begin
	if self.row &gt; 1 or not app.myCurrentUserCan(app.getMyTerminalDO_NOT_USE, PmAdmVehicleColourMaint) then
		return;
	endif;
	create form;
	form.centreWindow;
	form.setParentForm(self.form.CM_BaseForm);
	form.createMyAssistant(CMUI_Assistant);	
	form.showModal;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedString" id="579c0d63-2077-4aa1-84bc-4242b76371fc">
        <source>getSelectedString(pAttrName: String): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/08/2013	cnwdap1		Initial creation PAR #32123
//
vars
	str 	: String;

begin
	str := inheritMethod(pAttrName);
	return str.removeCommas();

epilog

end;</source>
        <Parameter name="pAttrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
