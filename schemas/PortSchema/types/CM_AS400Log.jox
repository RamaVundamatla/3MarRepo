<Class name="CM_AS400Log" id="d2fce58b-95c2-49b0-9ea9-5fba17b45d59">
    <superclass name="CM_AS400TransferObject"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="as400Transfer"/>
    <PrimAttribute name="block" id="b106444d-6e7b-4985-a171-5d23b45d08b1">
        <length>3</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="conditionCode" id="09c978c8-6232-40bf-95ca-d1bc826df832">
        <length>3</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="docket" id="7c76aae1-7ea4-4f75-87c8-722f74bf7f65">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="logNumber" id="c84e3cc3-a493-4389-b4cd-b42e018873ab">
        <length>21</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="maximumSED" id="33841efd-b122-4fed-a129-cc8cfa5c7e90">
        <precision>4</precision>
        <scaleFactor>1</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="minimumSED" id="f4dccc43-9264-4b92-a7d9-f56057175e9a">
        <precision>4</precision>
        <scaleFactor>1</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myAS400FileLoad" id="3b64fdc3-bc39-45c8-a790-01cc0a5e0765">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_AS400FileLoad"/>
        <access>readonly</access>
        <Inverse name="CM_AS400FileLoad::allLogs"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myDocket" id="67a3a3b3-589f-4c73-9814-1d6453b01cd1">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_AS400Docket"/>
        <access>readonly</access>
        <Inverse name="CM_AS400Docket::allLogs"/>
    </ExplicitInverseRef>
    <PrimAttribute name="row" id="aed2e142-db94-4529-b852-d781448fec43">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="subRow" id="aac7c1f7-8d4f-47a8-b3a2-2e4121c248f1">
        <length>3</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="supplier" id="8fa6ac3f-d72b-4b58-bc50-facfa9c382ff">
        <length>7</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="setForCreate" id="2025807d-a938-4feb-8693-45496922f685">
        <updating/>
        <source>setForCreate(_array : HugeStringArray; _fileLoad : CM_AS400FileLoad) updating;

begin


	self.myAS400FileLoad		:= _fileLoad;
	self.docket					:= _array[1].trimBlanks;
	self.supplier				:= _array[2].trimBlanks;
	self.logNumber				:= _array[3].trimBlanks;
	self.minimumSED				:= _array[4].Decimal;
	self.maximumSED				:= _array[5].Decimal;
	self.conditionCode			:= _array[6].trimBlanks;
	self.block					:= _array[7].trimBlanks;
	self.row					:= _array[8];
	self.subRow					:= _array[9].trimBlanks;
	self.myDocket				:= _fileLoad.allDockets[self.docket];


end;</source>
        <Parameter name="_array" type="HugeStringArray"/>
        <Parameter name="_fileLoad" type="CM_AS400FileLoad"/>
    </JadeMethod>
</Class>
