    <JadeMethod name="getCriteriaLineDefinitionForRT" id="29756c56-4074-4ec7-9c34-02c4ba8f3103">
        <source>getCriteriaLineDefinitionForRT( _prop : CM_QueryProperty;
								_searchValueA, _searchValueB : String output; _searchValueBoolean : Boolean output;
								_isStringProperty, _isStringBetweenProperty, _isBooleanProperty : Boolean output);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 8 November 2018
TFS#		: 40670
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	app.raiseCMException1( ERR_QueryForRTMustUseEqualTo, '"'&amp; self.description &amp;'"', null, null);
end;
</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <Parameter name="_searchValueA" type="String" usage="output"/>
        <Parameter name="_searchValueB" type="String" usage="output"/>
        <Parameter name="_searchValueBoolean" type="Boolean" usage="output"/>
        <Parameter name="_isStringProperty" type="Boolean" usage="output"/>
        <Parameter name="_isStringBetweenProperty" type="Boolean" usage="output"/>
        <Parameter name="_isBooleanProperty" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getSearchValue" id="c0bfdf2d-bf06-4ef2-a586-6eafe60edfe2">
        <source>getSearchValue(): Any;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 8 November 2018
TFS#		: 40670
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	return self.allSelectionValues;
end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueAsStringArray" id="991efcd8-1e60-453f-991e-4c4a3809e20b">
        <source>getSearchValueAsStringArray(_arr: StringArray input);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 8 November 2018
TFS#		: 40670
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	self.allSelectionValues.copy(_arr);
end;</source>
        <Parameter name="_arr" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueStr" id="1c78328f-1c90-4a18-944e-8b04d7df54b9">
        <source>getSearchValueStr(_prop : CM_QueryProperty) : String;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 8 November 2018
TFS#		: 40670
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	displayStr,
	str				: String;
begin
	foreach str in self.allSelectionValues do
		if displayStr = null then
			displayStr := _prop.translateToDisplayValue(str);
		else
			displayStr := displayStr &amp; ', ' &amp; _prop.translateToDisplayValue(str);
		endif;
	endforeach;
	
	return displayStr;
end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidForRT" id="1accb227-c6bd-425f-b017-241a91249562">
