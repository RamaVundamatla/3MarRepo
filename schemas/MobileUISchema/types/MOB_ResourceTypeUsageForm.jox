    <JadeMethod name="handleBtnOne" id="34775408-2d60-4d94-bd91-48a5d605f81e">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 February 2010	#cnwdz2	 

*/

vars
	pxyTI : CM_TrackedItem;
	pxyTiSet : CM_TISet;
	templateUsage : CM_ResourceTypeUsage;
begin
	//01 Oct 2015	NDL	Par 36993
	if templateOnly and  self.myCallingForm &lt;&gt; null then
		if myCallingForm.isKindOf(MOB_HHMultiCargoToDoComplete)
		or myCallingForm.isKindOf(MOB_HHCargoTasksCurrent)
		or myCallingForm.isKindOf(MOB_HHDocumentActions)	//21 Sep 2016	NDL	TFS 2647 / 2001
		then
			if myCallingForm.isKindOf(MOB_HHDocumentActions) then	//21 Sep 2016	NDL	TFS 2647 / 2001
				foreach templateUsage in self.allNewProxyResourceTypeUsages do
					self.myCallingForm.MOB_HHDocumentActions.allNewProxyResourceTypeUsages.add( templateUsage );
				endforeach;
			elseif myCallingForm.isKindOf(MOB_HHMultiCargoToDoComplete) then
				foreach templateUsage in self.allNewProxyResourceTypeUsages do
					self.myCallingForm.MOB_HHMultiCargoToDoComplete.allNewProxyResourceTypeUsages.add( templateUsage );
				endforeach;
			elseif myCallingForm.isKindOf(MOB_HHCargoTasksCurrent) then	//05 Oct 2015	NDL	Par 37011
				foreach templateUsage in self.allNewProxyResourceTypeUsages do
					self.myCallingForm.MOB_HHCargoTasksCurrent.allNewProxyResourceTypeUsages.add( templateUsage );
				endforeach;
			endif;
			self.allNewProxyResourceTypeUsages.clear();
			self.unloadForm();
			self.modalResult := IDOK;
			return;
		endif;
	endif;
	
	create pxyTiSet transient;
	pxyTI := app.createUpdateProxy(self.myTrackedItem).CM_TrackedItem;
	pxyTiSet.add(pxyTI);
	
	if self.getSessionAgent.updateTIToDoTaskCmpltBulk(self.myToDoTask, pxyTiSet, self.allNewProxyResourceTypeUsages) then
		self.unloadForm();
		self.modalResult := IDOK;	//07 Mar 2014	NDL Par 33611
	else
		self.msgBox(app.myPassport.getErrorsAndWarningsAsString,app.getErrorString(Error),MsgBox_OK_Only, false);
		self.modalResult := IDCANCEL;	//07 Mar 2014	NDL Par 33611
	endif;

epilog
	if pxyTiSet &lt;&gt; null then
		pxyTiSet.purge();
	endif;
	delete pxyTiSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="04906024-d01d-4e52-a5e9-c26c1fce9777">
