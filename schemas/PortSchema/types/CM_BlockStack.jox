    <JadeMethod name="getTextHeader" id="07dfc822-b88e-4905-95d9-7b357e05025e">
        <source>getTextHeader(): String;
//--------------------------------------------------
// Created:	22 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	bsHeader	: String;
begin
	if self.autoRelease then
		bsHeader := CrLf &amp;  app.getErrorString(This_area_auto_relea_cargo_act) &amp; CrLf;
	endif;
	bsHeader := bsHeader &amp;  inheritMethod();

	if not self.myLocationsController.allTrackedItems.isEmpty() then
		if self.isOverlapped then
			bsHeader := bsHeader &amp; '[Cargo is OVERLAPPING];  ';
		endif;
	
		if self.isFull then
			bsHeader := bsHeader &amp; 'Area marked as FULL;  ';
		endif;
	endif;
epilog
	return bsHeader;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
