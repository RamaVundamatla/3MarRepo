    <JadeMethod name="convertBaseCurrencyToMe" id="958254d9-bcc7-4a4b-9c6d-85b5571b86da">
        <source>convertBaseCurrencyToMe( _baseCurrencyAmount : Decimal; _roundedTo : Integer ):Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2018	jlgndl1	Initial creation	TFS 42218

*/

vars

	myCurrencyAmount : Decimal[23,6];

begin

	if _baseCurrencyAmount = 0 then
		return 0.0;
	endif;

	myCurrencyAmount := ( _baseCurrencyAmount / self.rate ).roundedTo( _roundedTo );
	
	return myCurrencyAmount;

epilog

end;</source>
        <Parameter name="_baseCurrencyAmount" type="Decimal"/>
        <Parameter name="_roundedTo" type="Integer"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
