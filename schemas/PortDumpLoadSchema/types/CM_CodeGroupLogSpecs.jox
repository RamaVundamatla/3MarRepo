<Class name="CM_CodeGroupLogSpecs">
    <JadeMethod name="exportPDXMLMyCollections" id="cda0daad-11eb-43f6-94ae-017c9395039c">
        <source>exportPDXMLMyCollections(_file: File; _objArray: ObjectArray io; _property: Property; _object: Object);

vars
	obj: Object;
begin
	if _property.name = CM_CodeGroupLogSpecs::allLogLengths.name then
		_file.writeLine('&lt;'&amp;CM_CodeGroupLogSpecs::allLogLengths.name&amp;'&gt;');
		foreach obj in self.allLogLengths do
			_file.writeLine('&lt;class&gt;' &amp; obj.class.name &amp; '&lt;/class&gt;');
			_file.writeLine('&lt;theKey&gt;' &amp; obj.theKey &amp; '&lt;/theKey&gt;');
		endforeach;
		_file.writeLine('&lt;/'&amp;CM_CodeGroupLogSpecs::allLogLengths.name&amp;'&gt;');

	elseif _property.name = CM_CodeGroupLogSpecs::allLogTreatments.name then
		_file.writeLine('&lt;'&amp;CM_CodeGroupLogSpecs::allLogTreatments.name&amp;'&gt;');
		foreach obj in self.allLogTreatments do
			_file.writeLine('&lt;class&gt;' &amp; obj.class.name &amp; '&lt;/class&gt;');
			_file.writeLine('&lt;theKey&gt;' &amp; obj.theKey &amp; '&lt;/theKey&gt;');
		endforeach;
		_file.writeLine('&lt;/'&amp;CM_CodeGroupLogSpecs::allLogTreatments.name&amp;'&gt;');

	elseif _property.name = CM_CodeGroupLogSpecs::allLogTypes.name then
		_file.writeLine('&lt;'&amp;CM_CodeGroupLogSpecs::allLogTypes.name&amp;'&gt;');
		foreach obj in self.allLogTypes do
			_file.writeLine('&lt;class&gt;' &amp; obj.class.name &amp; '&lt;/class&gt;');
			_file.writeLine('&lt;theKey&gt;' &amp; obj.theKey &amp; '&lt;/theKey&gt;');
		endforeach;
		_file.writeLine('&lt;/'&amp;CM_CodeGroupLogSpecs::allLogTypes.name&amp;'&gt;');
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLCollections" id="a259a43e-fafe-453c-84bb-e6a7feda2d44">
        <source>importPLXMLCollections(_name: String; _collectionsBlock: String);

vars

begin
	inheritMethod(_name, _collectionsBlock);
end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
</Class>
