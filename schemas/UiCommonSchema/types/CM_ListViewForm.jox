        <source>copyCollectionToDynaDict() updating, serverExecution;
// ---------------------------------------------------------------------------
// Created:     01 December 2000 by cnwrs2
//
// Purpose:     Copy the collection to display into the dynaDict for sorting.
//				This should be reimplemented, refer sample code below.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if app.isDevelopmentSystem then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  WARNING - you need to reimplement this method in your own form.');
	endif;
/*
Sample code for reimplementation
	app.thisTerminal.bulkReleases.copy(self.myDynaDict);

*/
end;</source>
