    <JadeMethod name="buildInitialiseDateTime" id="b388d4e2-fb4a-4951-adee-bf5639886b2e">
        <updating/>
        <source>buildInitialiseDateTime(_bulkDump : Boolean) : String updating;
/*
Purpose:			Used to initialise Date, Time and TimeStamp local variables to Null
					as Jade initialises them to now.
					This is required when a sub class exposes one of these. Code does this unconditionally

Parameters:			

Return Value:		

Date			Who		Reason
21 May 2010		conkc1	Initial creation

PAR 24641
*/
vars

	assignmentString : String;
	sqlColumn        : CM_DataDumpSQLColumn;
	type             : String;
	length           : Integer;
	scaleFactor      : Integer;
	maxLength        : Boolean;

begin

	foreach sqlColumn in self.allDataDumpSQLColumns do
	
		type := sqlColumn.myDataDumpFeature.getFeatureType(self.myDataDumpExtractDef.oidFormat, length, scaleFactor, maxLength);
		//29/06/2010 cnwdz2 24829
		if self.myDataDumpExtractDef.sqlServerVersion &lt;&gt; CM_DataDumpExtractDef.SQLVersion2008 and _bulkDump = false then
			if type = "Date" or type = "Time" or type = "TimeStamp" then
				assignmentString := assignmentString &amp; CrLf &amp; Tab &amp; sqlColumn.myDataDumpFeature.featureName &amp; ":= NullTimeStamp;";
			endif;
		else
			if type = "Date" then
				assignmentString := assignmentString &amp; CrLf &amp; Tab &amp; sqlColumn.myDataDumpFeature.featureName &amp; ":= NullDate;";
			elseif type = "Time" then
				assignmentString := assignmentString &amp; CrLf &amp; Tab &amp; sqlColumn.myDataDumpFeature.featureName &amp; ":= NullTime;";
			elseif type = "TimeStamp" then
				assignmentString := assignmentString &amp; CrLf &amp; Tab &amp; sqlColumn.myDataDumpFeature.featureName &amp; ":= NullTimeStamp;";
			endif;
		endif;
	endforeach;	

	assignmentString := assignmentString &amp; CrLf;
	return assignmentString;

epilog

end;</source>
        <Parameter name="_bulkDump" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="classAlias" id="28d0833b-7880-4deb-bcb0-af9179907f2a">
        <methodInvocation>mapping</methodInvocation>
        <source>classAlias(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     28 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		if self.sqlTableName &lt;&gt; null then
			_value := self.sqlTableName;
		else
			_value := self.myDataDumpClass.classAlias;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="className" id="d381457e-bd79-4b13-8082-606f800f5396">
        <methodInvocation>mapping</methodInvocation>
        <source>className(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     28 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := self.myDataDumpClass.className;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="erase" id="ca12ce9a-0670-4b4b-a227-344b11575682">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2010	#cnwdz2	 

*/

vars

begin
	if not self.isTransient() then
		self.allDataDumpSQLColumns.purge();
	endif;
	
	inheritMethod(_eraseLevel);

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getName" id="411e51f3-4dfb-4517-906a-2ea25394c28a">
        <source>getName(): String;
// -------------------------------------------
// Created 31 December 2003 by cnwdvb1
// -------------------------------------------
vars

begin
	return inheritMethod() &amp; ' ' &amp; self.classAlias &amp; "::" &amp; self.className;


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="86d6adfd-9171-4ca1-b29f-628b46e37c7b">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     30 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyExtractClass : CM_DataDumpExtractClass;
	completedOK		: Boolean;
	
begin
	pxyExtractClass := inheritMethod;
	
	pxyExtractClass.myDataDumpClass := self.myDataDumpClass;
	
	self.allDataDumpFeatures.copy(pxyExtractClass.allDataDumpFeatures);
	self.allDataDumpSQLColumns.copy(pxyExtractClass.allDataDumpSQLColumns);
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyExtractClass;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyExtractClass;
	endif;	
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setDataDumpClass" id="d39db573-f31a-4a3d-b284-7c9a24ea06f9">
        <updating/>
        <source>setDataDumpClass(_dataDumpClass : CM_DataDumpClass) updating;
// ---------------------------------------------------------------------------
// Created:     24 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myDataDumpClass := _dataDumpClass;

end;</source>
        <Parameter name="_dataDumpClass" type="CM_DataDumpClass"/>
    </JadeMethod>
    <JadeMethod name="setExtractUpToCreateHistory" id="53634215-2332-4896-aa67-f48b017c9ce4">
        <updating/>
        <source>setExtractUpToCreateHistory(_updateExtractedUpTo: Boolean;
		_extractedFromDateTime, _extractedUpTo, _startTs, _finishTs: TimeStamp;
		_numCreates, _numUpdates, _numDeletes: Integer;
		_systemAlertCreated: Boolean; _userCode, _userName: String; _deleteOids, _addOids, _updateOids : StringArray) updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2003 by cnwsb1
//
// Purpose:		Used during normal extract runs.  Flags the extract up to
//				timestamp, so that the next extract will start from that
//				point.  Also creates a history object.
// ---------------------------------------------------------------------------
begin
	self.raiseExceptionIfTransient(method);
	
	if _updateExtractedUpTo then
		if _extractedUpTo &lt;&gt; null and not _extractedUpTo.isValid then
			app.raiseCMException1(ERR_INVALID_TIMESTAMP, null,  null, null);
		endif;
		
		self.extractedUpToDateTime := _extractedUpTo;
	endif;
	
	self.myDataDumpExtractDef.createExtractHistory(
			self, _extractedFromDateTime, _extractedUpTo, _startTs, _finishTs, _numCreates,
			_numUpdates, _numDeletes, _systemAlertCreated, _userCode, _userName, _deleteOids, _addOids, _updateOids);
end;</source>
        <Parameter name="_updateExtractedUpTo" type="Boolean"/>
        <Parameter name="_extractedFromDateTime" type="TimeStamp"/>
        <Parameter name="_extractedUpTo" type="TimeStamp"/>
        <Parameter name="_startTs" type="TimeStamp"/>
        <Parameter name="_finishTs" type="TimeStamp"/>
        <Parameter name="_numCreates" type="Integer"/>
        <Parameter name="_numUpdates" type="Integer"/>
        <Parameter name="_numDeletes" type="Integer"/>
        <Parameter name="_systemAlertCreated" type="Boolean"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_userName" type="String"/>
        <Parameter name="_deleteOids" type="StringArray"/>
        <Parameter name="_addOids" type="StringArray"/>
        <Parameter name="_updateOids" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setExtractedUpTo" id="a970d5c8-6462-4d94-a44a-5939bedd3fe3">
        <updating/>
        <source>setExtractedUpTo(_extractedUpTo: TimeStamp) updating;
// ---------------------------------------------------------------------------
// Created:     18 July 2003 by cnwsb1
//
// Purpose:		Used for bulk updating of class Extratced Up To Timestamps,
//				which is necessary after a failed extract, for initial
//				setup, and for testing.
// ---------------------------------------------------------------------------
begin
	self.raiseExceptionIfTransient(method);
	
	if _extractedUpTo &lt;&gt; null and not _extractedUpTo.isValid then
		app.raiseCMException1(ERR_INVALID_TIMESTAMP, null,  null, null);
	endif;
	
	self.extractedUpToDateTime := _extractedUpTo;
end;</source>
        <Parameter name="_extractedUpTo" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="8acde65d-25a9-4778-ac3b-727a3ce9a337">
        <updating/>
        <source>setForCreate(_proxyClass: CM_DataDumpExtractClass) updating;
// ---------------------------------------------------------------------------
// Created:     26 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	setupCommon(_proxyClass);

	self.myDataDumpClass := _proxyClass.myDataDumpClass;
	_proxyClass.allDataDumpFeatures.copy(self.allDataDumpFeatures);
	//_proxyClass.allDataDumpSQLColumns.copy(self.allDataDumpSQLColumns); //3/5/2010 cnwdz2

end;</source>
        <Parameter name="_proxyClass" type="CM_DataDumpExtractClass"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="6a11822a-682f-4052-b01e-8e19c485bf2c">
        <updating/>
        <source>setForUpdate(_proxyClass: CM_DataDumpExtractClass) updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	// Lock self before comparing values.
	exclusiveLock(self);
	
	setupCommon(_proxyClass);

	self.myDataDumpClass := _proxyClass.myDataDumpClass;
	self.allDataDumpFeatures.updateSameAsArray(_proxyClass.allDataDumpFeatures);
	self.updateSQLColumnsSameAsDict(_proxyClass.allDataDumpSQLColumns);
end;</source>
        <Parameter name="_proxyClass" type="CM_DataDumpExtractClass"/>
    </JadeMethod>
