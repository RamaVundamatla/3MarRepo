    <JadeMethod name="dumpStackExHandler" id="76de7d78-9086-4ffe-b637-6d844e6725ec">
        <source>dumpStackExHandler(_exObj : Exception): Integer protected;
/*

Purpose:			In the event of a JADE exception during login (eg, 1090) dump the stack so we have something to go off
					Then continue passing the exception up the chain.
					
					This should be placed above agtPassportExHandler so when it passes the exception back, we get it

Parameters:			

Return Value:		

Date				Who		Reason
28 September 2022	navmd1	Initial creation TFS 54959

*/

vars

begin
	app.doDumpStack(_exObj);
epilog
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="exclusiveLockObjToDelExHandler" id="3c4c1cb9-5064-4e5a-a1d9-16f4eade1a81">
        <source>exclusiveLockObjToDelExHandler(exObj        : Exception;
                               objToDelete  : Object;
                               objDescription : String;
                               gotException : Boolean output) : Integer protected;
constants
	ObjectNotFound = 4;

begin
	gotException := true;
	
	if exObj.errorCode = ObjectNotFound and 
	   exObj.errorObject = objToDelete then
   		app.raiseCMException1(ERR_DEL_NOTFOUND, objDescription, null, null); 
		return Ex_Resume_Next;
	endif;

	abortTransaction;
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="objToDelete" type="Object"/>
        <Parameter name="objDescription" type="String"/>
        <Parameter name="gotException" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="exclusiveLockObjectToDelete" id="a0f3aa45-a5ca-4b37-922a-11e1e1ce9cb2">
        <source>exclusiveLockObjectToDelete(objToDelete : Object) : Boolean protected;

vars
	gotException : Boolean;
	
begin
	gotException := false;
	
	if objToDelete = null then
		return false;
	endif;

	on Exception do self.exclusiveLockObjToDelExHandler(exception, objToDelete, '', gotException);

	// lock will be released at commit/abort transaction
	exclusiveLock(objToDelete);
	
	// if the lock gets an error 4, our handler will resume to here
	if gotException then
		return false;
	endif;
	
	// if we get to here, the object exists and we've got the lock
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="objToDelete" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="fileExceptionHandler" id="33f5e44f-c3f2-4ae6-b9c9-0e9a187d0664">
        <source>fileExceptionHandler(exObj: Exception): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 February 2024	navra1	Initial creation for 61803 - EUP |  API - Save a printout of the invoice and its attachments in the directory specified 

*/

vars
	errorText: String;
begin
	errorText := "Opening file: '" &amp; exObj.FileException.file.fileName &amp; "' caused error";
	errorText := errorText &amp; Lf &amp; exObj.text &amp; Lf &amp; "    Aborting Export Operation!";
	
	if not process.isInTransactionState then		
		app.writeLog(errorText, LogERROR);
		app.msgBox(errorText, "File Open Error",
			MsgBox_OK_Only  + MsgBox_System_Modal + MsgBox_Exclamation_Mark_Icon);
	else				
		app.writeLog(errorText, LogERROR);
		app.cmsAbortTransaction;
	endif;	

	return Ex_Abort_Action;
end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="ecc7eee7-5592-4fa1-8bf3-fa00cb7cca19">
        <source>getMyTerminal(): CM_Terminal;
//
// 29 Oct 2019	cnwrs1	TFS 47281
//
vars

begin
	executeWhen JMTDevelopmentEnvironment;
	app.raiseUnexpectedProgramError(class.name, method.name, 'getMyterminal has been called on Object. This needs be reimplemented in your class.');
	endExecuteWhen;
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="raiseExceptionIfNotInTranState" id="81403ef4-229d-4668-88ca-9cf04eff1f4f">
        <source>raiseExceptionIfNotInTranState(callingMethod : Method) protected;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/02/2009	cnwdad1		PAR #18878 - Log the call stack so that developers
//							can more easily find the cause of the problem.
// ---------------------------------------------------------------------------
vars
	mthName : String;
	
begin

	if process.isInTransactionState or
	   app.isSDSSecondaryDB() then	//cnwrs1 par24679 July 2010 make JMTTerminal work on SDSsecondary			
		return;
	endif;

	if callingMethod &lt;&gt; null then
		mthName := callingMethod.name;
	else
		mthName := "unknown method";
	endif;
	
	app.writeLogProcessStack();		// PAR #18878
	app.setContinueCMExceptions(false);
	app.raiseCMException2(ERR_TRANS_STATE, mthName, self.class.String, null, null);
end;</source>
        <access>protected</access>
        <Parameter name="callingMethod" type="Method"/>
    </JadeMethod>
    <JadeMethod name="raiseExceptionIfNull" id="048d53e3-8dc9-4d2e-97b2-5c59613ef707">
        <source>raiseExceptionIfNull(pObject : Object; pErrStr : String) protected;
// ---------------------------------------------------------------------------
// Created:     20 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pObject = null then
		app.setContinueCMExceptions(false);
	//	app.raiseCMException1(REQUIRED_FIELD, pErrStr, null, null);
		app.raiseCMException1(Input_required_field_Required, pErrStr, null, null); // cnwdb2	PAR 35364
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pErrStr" type="String"/>
    </JadeMethod>
</Class>
