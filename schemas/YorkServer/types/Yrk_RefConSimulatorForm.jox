    <JadeMethod name="processReeferMonitorRequest" id="ba36722b-87ea-4be2-b28c-31b3bb90b1a5">
        <source>processReeferMonitorRequest(_buf:Binary) protected;

vars
	ti			: Yrk_Container;
	message		: Binary;
	id			: String;
begin
	write class.name&amp;"::"&amp;method.name&amp;" Server ";
	self.staMain.caption := "Processed Reefer Monitor Request message";
	

	id := _buf[25:4].String&amp;_buf[30:7].String;
	write class.name&amp;"::"&amp;method.name&amp;" id from buffer " &amp; id;
	exclusiveLock(self.config);

	ti := self.config.allRfcContainers[id];
//	foreach ti in Yrk_Container.instances do
	//	count := count + 1;
	if ti = null then
		self.logReport("Conntainer not known. " &amp; id);
		return;
	endif;
	
	self.logReport("Sent Reefer Monitor message. " &amp; ti.id);
	message := self.reeferMonitorTelegram(ti);
	self.sendTelegram(message);
	//	self.logMonitor('Sending message for ' &amp; ti.id &amp; ' Count - ' &amp; count.String);
	//	self.sentImAlive := false;
//		app.doWindowEvents(0);
//		process.sleep(300);
//	endforeach;
epilog
	unlock(self.config);
end;</source>
        <access>protected</access>
        <Parameter name="_buf" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="recallReeferDataTelegram" id="231a74c5-9641-4fa9-a206-788cc56da98f">
        <source>recallReeferDataTelegram():Binary;

vars
	message,data: Binary;
	header: Binary;
	length: Integer;
	bin: Binary;
begin
	header := self.messageHeader(Recall_Reefer_Data);
	data := self.messageData(Recall_Reefer_Data,null);
	length := header.length + data.length;
	bin := length.Binary;
	header[1:1] := bin[2:1];
	header[2:1] := bin[1:1];
	
	message := header&amp;data;
	return message;
end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
