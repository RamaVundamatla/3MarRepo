    <JadeMethod name="getDischargePort" id="3e275a35-fe83-4bda-b7c0-89f8449af830">
        <source>getDischargePort(_destinationCode : String) : CM_Port;
// get the discharge ports for the input destination for this operator shipping line
// cnwrs1 jume 2006 ccms 1031

vars
	destination : CM_Port;
	port : CM_Port;
	ddp : CM_DestinationToDischargePort;
	dischargePorts : CM_PortByCodeDict;
begin
	destination := app.myRoot.allPorts[_destinationCode];
	if destination = null then
		return null;
	endif;
	create dischargePorts transient;
	self.getDischargePorts(dischargePorts);
	if dischargePorts.includes(destination) then
		return destination;
	else
		ddp := self.allDestinationDischargePorts[destination];
		if ddp &lt;&gt; null then
			return ddp.dischargePort;
		endif;
	endif;
epilog
	delete dischargePorts;	
end;</source>
        <Parameter name="_destinationCode" type="String"/>
        <ReturnType type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="getDischargePorts" id="3e9c93da-2893-4856-8f37-a296f34c7640">
        <source>getDischargePorts(_dischargePorts : CM_PortByCodeDict io);
// get a list of the valid discharge ports for this shipping line(operator independant)
// cnwrs1 jume 2006 ccms 1031
vars
	shipPortGroup: CM_ShipPortGroup;
	shipPort: CM_ShipPort;
begin
	if _dischargePorts = null then
		return;
	endif;
	foreach shipPortGroup in myShippingLine.shipPortGroups do
		foreach shipPort in shipPortGroup.shipPorts do
			if not _dischargePorts.includes(shipPort.port) then
				_dischargePorts.add(shipPort.port);
			endif;
		endforeach;
	endforeach;
end;</source>
        <Parameter name="_dischargePorts" type="CM_PortByCodeDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b2211093-6ec8-4ed2-883e-dc1a7f7ffc11">
        <updating/>
        <source>setForCreate(_proxy : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:     June 2006 cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	//always do in set for create
	self.setForUpdate(_proxy);
	self.myRoot := app.myRoot;

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="fb908db1-9e2a-49af-9a79-e3cd42e30142">
        <updating/>
        <source>setForUpdate(_proxy : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:     June 2006
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.myOperator	:= _proxy.myOperator;
	self.myShippingLine := _proxy.myShippingLine;
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="cca2d507-cd90-4d43-a167-7b1617d34002">
        <updating/>
        <source>setProxy(_operator: CM_Operator; _shippingLine: CM_ShippingLine) updating;

vars

begin
	self.myOperator := _operator;
	self.myShippingLine := _shippingLine;
	self.myRoot := app.myRoot;
end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_shippingLine" type="CM_ShippingLine"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="f61dcf12-bff9-4e53-85e0-1cbdf877d421">
        <source>validateForCreate();

vars

begin
	if self.myOperator = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Operator', null, null);
		app.raiseCMException(Input_required_field_operator, null, null); // cnwdb2	PAR 35364


	endif;
	if self.myShippingLine = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Shipping Line', null, null);
		app.raiseCMException(Input_required_field_shipLine, null, null); // cnwdb2	PAR 35364


	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="6d941286-7042-4c16-93cd-5caf081178e8">
        <source>validateForDelete();

vars

begin
	if self.allDestinationDischargePorts.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.myOperator.code&amp;' '&amp;self.myShippingLine.code, "ports", null, null);
	endif;

end;</source>
    </JadeMethod>
</Class>
