    <JadeMethod name="setPackedDetails" id="bb7397ad-1099-41bf-88bf-74a5fa97b622">
        <updating/>
        <source>setPackedDetails(pPackDate: Date; pPackTime : Time; pPackTempC: Real; pPackTempF: Real) updating;
/*
Date		Who		Reason
28 November 2009	cnwdap1	Initial creation
*/
vars

begin
	if self.packTempDetails = null then
		if self.isTransient then
			create self.packTempDetails transient;
		else
			create self.packTempDetails persistent;
		endif;
	endif;

	if pPackDate.isValid and pPackTime.isValid then	
		self.packTempDetails.dateTime.setDate(pPackDate);
		self.packTempDetails.dateTime.setTime(pPackTime);
	else
		self.packTempDetails.dateTime := null;
	endif;

	//Take one value and convert the other depending if the operator wants F or C temps
	if self.myParent &lt;&gt; null // TFS 45590
	and self.myParent.CM_TrackedItem.myOperator &lt;&gt; null and self.myParent.CM_TrackedItem.myOperator.displayTempFahrenheit /*and pPackTempC &lt;&gt; NULL_TEMPERATURE*/ then  //cnwas3 par 24626
		self.packTempDetails.tempF := pPackTempF;
		self.packTempDetails.tempC := app.myRoot.convFahrenheitToCelsius(pPackTempF);	
	else
		self.packTempDetails.tempC := pPackTempC;
		self.packTempDetails.tempF := app.myRoot.convCelsiusToFahrenheit(pPackTempC);
	endif;
epilog

end;</source>
        <Parameter name="pPackDate" type="Date"/>
        <Parameter name="pPackTime" type="Time"/>
