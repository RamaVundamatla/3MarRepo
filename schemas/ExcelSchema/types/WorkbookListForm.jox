    <JadeMethod name="activate" id="753452a8-33a3-48b9-ab84-0f8bba63f335">
        <controlMethod name="Form::activate"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>activate() updating;

constants
	Option_Load_Form = 1;
	Option_Activate_Form = 2;
	
vars

begin
	myDA.myControllingAppsDA.invokeMethod(myDA.myControllingAppsContext, myDA.myControllingAppsShowMethod, self, Option_Activate_Form);
end;</source>
    </JadeMethod>
    <JadeMethod name="btnCancel_click" id="f6ccf043-787c-4631-89e0-cce68f37fea3">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;

vars

begin
	app.statusBusy(true);
	unloadForm;
epilog
	app.statusBusy(false);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOpenWorkbook_click" id="25c9cc6e-61ed-4fb0-b07c-b43a70c4e7db">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOpenWorkbook_click(btn: Button input) updating;

/*****************************************************
	Written by	:	cnwpra1		21 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	app.statusBusy(true);
	openWorkbook;
	
	unloadForm;
epilog
	app.statusBusy(false);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="dbb51ad2-111b-41cd-8d9c-1460dbdf8e8d">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*****************************************************
	Written by	:	cnwpra1		24 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	loadForm;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadForm" id="a9a3ca06-db26-4a36-bf6f-59227916e1f1">
        <updating/>
        <source>loadForm() updating;

/*****************************************************
	Written by	:	cnwpra1		21 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	str 	: String;
	obj		: Object;
	wb		: WorkbookDefinition;
	row		: Integer;

begin
	centreWindow;
	
	tblListWorkbooks.defaultRowHeight := 16;
	tblListWorkbooks.columns := 1;
	tblListWorkbooks.rows := 1;
	tblListWorkbooks.row := 1;
	tblListWorkbooks.column := 1;
	str := 'Workbook Description';
	tblListWorkbooks.text := str;
	
	if myWBArray = null then
		app.msgBox('Array Error', 'Error', MsgBox_OK_Only);
		unloadForm;
		return;
	endif;
	foreach obj in myWBArray do
		wb := obj.WorkbookDefinition;
		self.caption := 'Workbooks for ' &amp; wb.associatedObjectName; 
		row := tblListWorkbooks.addItem(wb.workbookDescription);
		tblListWorkbooks.accessRow(row).itemObject := wb;
	endforeach;
	
	tblListWorkbooks.height := tblListWorkbooks.rows * tblListWorkbooks.defaultRowHeight;
	self.height 			:= tblListWorkbooks.top + tblListWorkbooks.height + 110;
	grpSelWorkbook.height 	:= tblListWorkbooks.height + 55;
	btnOpenWorkbook.top 	:= grpSelWorkbook.height - 30;
	btnCancel.top 			:= self.height - 58;
	btnOpenWorkbook.enabled	:= false;
	app.statusBusy(false);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="openWorkbook" id="c3defb75-24eb-4ed0-9940-0494f1b43bbf">
        <updating/>
        <source>openWorkbook() updating;

/*****************************************************
	Written by	:	cnwpra1		21 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	mySelectedWorkbookDefn := tblListWorkbooks.accessRow(tblListWorkbooks.row).itemObject.WorkbookDefinition;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyDA" id="cae5e5cf-6062-4250-81e5-2ff24bfa9c8f">
        <updating/>
        <source>setMyDA(value: ExcelWorkbookUseDA) updating;

vars

begin
	if myDA &lt;&gt; value then 
		myDA := value;
	endif;

end;
</source>
        <Parameter name="value" type="ExcelWorkbookUseDA"/>
    </JadeMethod>
    <JadeMethod name="setMyWBArray" id="e6f5f92d-9991-4fcf-83b1-c5c344afbe8e">
        <updating/>
        <source>setMyWBArray(value: ObjectArray) updating;

/*****************************************************
	Written by	:	cnwpra1		21 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	if myWBArray &lt;&gt; value then 
		myWBArray := value;
	endif;


epilog

end;</source>
        <Parameter name="value" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="tblListWorkbooks_click" id="5848e8f6-5a46-47f3-8dc3-5ae32d56e611">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblListWorkbooks_click(table: Table input) updating;

/*****************************************************
	Written by	:	cnwpra1		21 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	if tblListWorkbooks.row &gt; tblListWorkbooks.fixedRows then
		tblListWorkbooks.clearAllSelected;
		tblListWorkbooks.accessRow(tblListWorkbooks.row).selected := true;
		btnOpenWorkbook.enabled := true;
	else
		btnOpenWorkbook.enabled := false;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblListWorkbooks_dblClick" id="2c604f2b-a846-4dd7-b51e-c45be77eac7b">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblListWorkbooks_dblClick(table: Table input) updating;

/*****************************************************
	Written by	:	cnwpra1		21 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	btnOpenWorkbook_click(btnOpenWorkbook);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
</GUIClass>
