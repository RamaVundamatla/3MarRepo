        <source>getSOHLevelsNoProduct(_closingLevel 	: Boolean; 
					_totQty				: Integer io;
					_totVol				: Decimal io;
					_totWeight 			: Decimal io);
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lc	: CM_LocationsController;
	
begin

	if (not self.isStockControlled) then
		return;
	endif;

	foreach lc in self.allLocationsControllers do
		lc.getSOHLevelsNoProduct(_closingLevel, _totQty, _totVol, _totWeight);
	endforeach;

	// PAR 18081
	foreach lc in self.allLCsArchived do
		lc.getSOHLevelsNoProduct(_closingLevel, _totQty, _totVol, _totWeight);
