    <JadeMethod name="addGroupProperty" id="ccd545a2-aff2-487d-885e-9f370c0eb7dd">
        <source>addGroupProperty(_propName: String; _dataType: Type);
//----------------------------------------------------------------
//	Created:	09 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.allGroupPropertyNames.add(_propName);
	self.allGroupPropertyTypes.add(_dataType.name);
	
end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_dataType" type="Type"/>
    </JadeMethod>
    <JadeMethod name="addObject" id="7787831c-a397-4ce5-9af3-d7382aabefec">
        <source>addObject(_obj: Object);
//----------------------------------------------------------------
//	Created:	21 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.groupObject(_obj);

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="addTableTotal" id="3b47393c-ae3f-4814-b51a-147b20727ac3">
        <source>addTableTotal(_table : Table );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2009	cnwndl1	Initial creation

*/

vars
	idx	 : Integer;
	tbl : Table;
	grpSum : CMIF_Object;
	grpFDesc : String;
begin
	tbl := _table;
	if self.allTopLevelGroupsInPrintOrder.last = null then
		return;
	endif;
	idx := tbl.addItem(self.allTopLevelGroupsInPrintOrder.last.getTableSortKey);	//spacing
	tbl.accessRow(idx).height := 4;
	tbl.accessRow(idx).backColor := LightYellow;
	tbl.accessCell(idx,2).mergeCells := Table.MergeCells_Merge;
	
	//summary row here
	create grpSum as self.summaryClass transient;
	self.saveTransient(grpSum);
	
	//group footer
	grpFDesc := "Grand Totals" &amp; Tab;
	idx := _table.addItem(self.allTopLevelGroupsInPrintOrder.last.getTableSortKey &amp; CM_ReportGroup.GroupKeyEnd &amp; Tab &amp; grpFDesc &amp; Tab &amp; grpSum.getGrpSumDisplay(self.allGroupedObjects));
	tbl.accessRow(idx).itemObject := grpSum;
	tbl.accessRow(idx).backColor := Grey;
	tbl.accessedRow.fontBold := true;
	
	idx := tbl.addItem(self.allTopLevelGroupsInPrintOrder.last.getTableSortKey);	//spacing
	tbl.accessRow(idx).height := 4;
	tbl.accessRow(idx).backColor := LightYellow;
	tbl.accessCell(idx,2).mergeCells := Table.MergeCells_Merge;
	
epilog

end;</source>
        <Parameter name="_table" type="Table"/>
    </JadeMethod>
    <JadeMethod name="groupLevel" id="c16f7767-aea8-480e-ac3d-fd622011a7e5">
        <methodInvocation>mapping</methodInvocation>
        <source>groupLevel(set: Boolean; _value: Integer io) mapping;
//----------------------------------------------------------------
//	Created:	09 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if set then
		return;
	else
		_value := 1;	//root always 1
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="groupObject" id="eac427d5-915c-4c0b-9344-4117bc124548">
        <source>groupObject(_obj: Object);
//----------------------------------------------------------------
//	Created:	09 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	keyPropValue	: Any;
	propName		: String;
	repGroup		: CM_ReportGroup;
begin

	//everything goes in here at root level
	self.allGroupedObjects.add(_obj);
	
	propName := self.allGroupPropertyNames[self.groupLevel];
	
	keyPropValue := _obj.getPropertyValue(propName);
	
	if keyPropValue.isKindOf(Integer) then
		//if integer then value is treated as the sort order
		repGroup := self.allTopLevelGroupsInPrintOrder[keyPropValue.Integer];	
	elseif keyPropValue.isKindOf(String) then
		repGroup := self.allTopLevelGroupsByKey[keyPropValue.String];
	else
		app.writeStatement('CNWSH3 ' &amp; class.name &amp; " " &amp; method.name &amp;  " unsupported property type - add type");
	endif;
	
	
	if repGroup = null then
		create repGroup transient;
		repGroup.setForCreateGroup(null, propName, keyPropValue, _obj);
		repGroup.setGroupRoot(self);
	endif;
	
	repGroup.allGroupedObjects.add(_obj);
	
	//we have a top level group now.  do sub grouping...
	
	if self.allGroupPropertyNames.size &gt; self.groupLevel then
		//if there are n group property names then there should be n levels
		//if the number of property names is greater than the current level then keep grouping
		repGroup.groupObject(_obj);
	endif;
	
	
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="populateTable" id="36202830-c207-457c-8657-54c3267e31d9">
        <source>populateTable(_tbl: Table);
//----------------------------------------------------------------
//	Created:	15 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tbl 				: Table;
	reportGroup			: CM_ReportGroup;
	int					: Integer;
begin

	tbl := _tbl;
	tbl.accessColumn(1).visible := false;
	tbl.accessColumn(2).alignment := Table.Alignment_Left;
	
	//add rows
	foreach reportGroup in self.allTopLevelGroupsInPrintOrder do
		reportGroup.addToTable(tbl, self);
	endforeach;
end;</source>
        <Parameter name="_tbl" type="Table"/>
    </JadeMethod>
    <JadeMethod name="refreshTable" id="270a6e8e-35e4-4594-bb4d-49e3e4c1af50">
        <source>refreshTable(_tbl: Table);
//----------------------------------------------------------------
//	Created:	15 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tbl 				: Table;
	reportGroup			: CM_ReportGroup;
begin

	tbl := _tbl;
	tbl.accessColumn(1).visible := false;
	tbl.accessColumn(2).alignment := Table.Alignment_Left;
	
	//add rows
	foreach reportGroup in self.allTopLevelGroupsInPrintOrder do
		reportGroup.updateTable(tbl, self);
	endforeach;

end;</source>
        <Parameter name="_tbl" type="Table"/>
    </JadeMethod>
    <JadeMethod name="removeObject" id="b92be5be-bc8a-4995-bdf0-a6fe843b36d2">
        <source>removeObject(_obj: Object);
//----------------------------------------------------------------
//	Created:	21 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	keyPropValue	: Any;
	propName		: String;
	repGroup		: CM_ReportGroup;
begin

	self.allGroupedObjects.remove(_obj);
	
	propName := self.allGroupPropertyNames[self.groupLevel];
	
	keyPropValue := _obj.getPropertyValue(propName);
	
	if keyPropValue.isKindOf(Integer) then
		repGroup := self.allTopLevelGroupsInPrintOrder[keyPropValue.Integer];	
	elseif keyPropValue.isKindOf(String) then
		repGroup := self.allTopLevelGroupsByKey[keyPropValue.String];
	else
		app.writeStatement('CNWSH32 ' &amp; class.name &amp; " " &amp; method.name &amp;  " unsupported property type - add type");
	endif;
	
	
	if repGroup = null then
		//can't find it
		return;
	endif;
	
	repGroup.allGroupedObjects.remove(_obj);
	
	//remove from sub groups...
	
	if self.allGroupPropertyNames.size &gt; self.groupLevel then
		//if there are n group property names then there should be n levels
		//if the number of property names is greater than the current level then keep grouping
		repGroup.removeObject(_obj);
	endif;
	
	
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="reset" id="60245969-189b-4763-a364-8b96436004b5">
        <source>reset();
//----------------------------------------------------------------
//	Created:	15 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.allGroupedObjects.purge;
	self.allGroupPropertyNames.clear;
	self.allGroupPropertyTypes.clear;
	self.allTopLevelGroupsByKey.purge;
	self.allTopLevelGroupsInPrintOrder.purge;
	self.allCMIFTransients.purge;
end;</source>
    </JadeMethod>
    <JadeMethod name="saveTransient" id="b7a21e75-71da-4867-bfd5-d3c5670a5844">
        <source>saveTransient(_cmif: CMIF_Object);
//----------------------------------------------------------------
//	Created:	30 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.allCMIFTransients.add(_cmif);

end;</source>
        <Parameter name="_cmif" type="CMIF_Object"/>
    </JadeMethod>
    <JadeMethod name="setSummaryClass" id="5722f21c-8d31-4de7-abd4-3f6671bf71d6">
        <updating/>
        <source>setSummaryClass(_cls: Class) updating;
//----------------------------------------------------------------
//	Created:	30 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.summaryClass := _cls;
end;</source>
        <Parameter name="_cls" type="Class"/>
