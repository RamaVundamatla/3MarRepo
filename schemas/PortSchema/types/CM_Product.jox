	self.myLengthString.setForUpdate(_proxy.myLengthString);

	self.myWidth.setForUpdate(_proxy.myWidth);
	self.myHeight.setForUpdate(_proxy.myHeight);
	self.myLength.setForUpdate(_proxy.myLength);
	
	self.myQuantity.setForUpdate(_proxy.myQuantity);
	self.myVolume.setForUpdate(_proxy.myVolume);
	self.myDensityDec.setForUpdate(_proxy.myDensityDec);		// ### TFS 52193 22Nov2021 NAVPW1
	self.myWeight.setForUpdate(_proxy.myWeight);

	self.myType.setForUpdate(_proxy.myType);
	self.myStowageFactor.setForUpdate(_proxy.myStowageFactor);
end;</source>
