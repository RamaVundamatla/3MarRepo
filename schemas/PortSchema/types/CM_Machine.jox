    <JadeMethod name="addAcceptMoveHistory" id="3fa03f3c-7a38-4704-bd11-9955acda1220">
        <updating/>
        <source>addAcceptMoveHistory(_task :CM_RTQueueTask; _target : String) : CM_MachineMoveHistory updating;
// ---------------------------------------------------------------------------
// Created:     01 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     Record Accept in machine history
// Parameters:  _task		- task being accepted
//				_target		- target location id
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	history		: CM_MachineMoveHistory;	
	entry		: CM_RTQueueEntry;
	firstTask	: CM_RTQueueTask;
	instanceId	: Decimal[12, 0];
begin
	// if the pickup task is one that has been created for a director task then we do not need to accept it.
	if _task.machine = self and _task.taskType = TASK_PICKUP then 
		firstTask := _task.myEntry.allTasks.first;
		
	elseif self.isIMV and _task.machine &lt;&gt; self and _task.taskType = TASK_SETDOWN then 
		// accept is for setdown to imv
//		firstTask	:= _task.myEntry.getNextEntryFirstTask;
		firstTask	:= _task.myEntry.getNextEntryFirstDirectorTask; //cnwrd1 par 26797 21.1.2011
		
	elseif self.isIMV and _task.taskType = TASK_MOVE then 
		firstTask := _task.myEntry.allTasks.first;
	endif;

	if firstTask &lt;&gt; null and firstTask.taskType = TASK_DIRECTOR then  
		history := self.findPriorMoveHistoryForTask (CM_MachineHistory.Type_AcceptMove, firstTask);
		// find accept for the director task - if it there we don't need to accept again
		if history &lt;&gt; null then 
			return history;
		endif;
	endif;	

	create history persistent;
	
	history.acceptMove(_task, _target);

	return history; 
end;</source>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <Parameter name="_target" type="String"/>
        <ReturnType type="CM_MachineMoveHistory"/>
    </JadeMethod>
    <JadeMethod name="addAmendMoveHistory" id="ae40b94d-cce9-422a-b463-99eee3f316da">
        <updating/>
        <source>addAmendMoveHistory(_sourceLocationId, _targetLocationId : String; _ti : CM_TrackedItem) : CM_MachineMoveHistory updating;

/*

Purpose:	Add an amended move history line for an IMV swap fixup		

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2010	cnwrd1	Initial creation
//cnwrd1 par 23997 28.4.2010
*/

vars
	histEntry	: CM_MachineMoveHistory;
	userCode	: String;
	
begin
	create histEntry persistent;
	
	if self.user &lt;&gt; null then
		userCode := self.user.code;
	else
		userCode := CM_MachineHistory.Unknown_Value;	//Par 32542
	endif;
	
	//histEntry.amendMove(_sourceLocationId, _targetLocationId, _ti, self.user.code, self);
	histEntry.amendMove(_sourceLocationId, _targetLocationId, _ti, userCode, self);		// 14/03/2013 cnwar2 #30579

	return histEntry; 
end;</source>
        <Parameter name="_sourceLocationId" type="String"/>
        <Parameter name="_targetLocationId" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_MachineMoveHistory"/>
    </JadeMethod>
