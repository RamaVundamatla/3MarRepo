vars

begin

	self.myErrorWarningForm.setCurrentForm(pForm);
	// cnwsb1 14 May 2003 - CM_BaseForm::showModal() now sets isModal:
	// self.myErrorWarningForm.isModal := true;
	self.myErrorWarningForm.show;
	
end;</source>
