    <JadeMethod name="getKeyLengthForXTABDictionary" id="064c0eae-4563-4037-9259-fe9f4320bb76">
        <source>getKeyLengthForXTABDictionary(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 September 2019	jlgzm1	Initial creation TFS 46703 Direct Release Selector Query

*/

vars
	length	:Integer;
begin
	// just incase the global constant values change !!!
	length := TI_TRANSMODE_SHIP_STR.length;
	length := length.max (TI_TRANSMODE_ROAD_STR.length);
	length := length.max (TI_TRANSMODE_RAIL_STR.length);
	
	return length;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
