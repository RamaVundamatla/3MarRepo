    <JadeMethod name="hasHMSResourcesUsed" id="184a6de9-d601-4765-827f-322c9c5f539f">
        <source>hasHMSResourcesUsed() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 June 2018	jlger1	Initial creation 38561

*/

vars
	movement : HMS_VoyageMovement;
begin
	foreach movement in self.allVoyageMovements discreteLock do
		if movement.allResourceUsed.size &gt; 0 then
			return true;
		endif;	
	endforeach;
	
	
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasPilotsJRW" id="5df63eee-32fd-4f9c-b371-415f8675dda7">
        <source>hasPilotsJRW() :String;
// method used for display in Report
//23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

vars
	pilotsUsed : String;
	movement : HMS_VoyageMovement;
begin
	pilotsUsed := "N";
	foreach movement in self.allVoyageMovements do
		// Check to see if selected pilot is used for any of the voyages movements
		if movement.getUnConvertedMyPilotRef &lt;&gt; null or not movement.allMovementPilotDetails.isEmpty then //allPilots.isEmpty then // TFS 44438
			pilotsUsed	:= "Y";
			break;
		endif;
	endforeach;
	return pilotsUsed;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
