    <DbClassMap file="jssxs_array"/>
    <PrimAttribute name="substringPosition" id="05afe346-8509-4ab8-84c8-4922c1070080">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="setPosition" id="47d821de-ba0f-4407-97a8-ff411941bb63">
        <updating/>
        <source>setPosition(pPosition:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		29 June 2001 by cnwdad1
//
// Purpose:		Sets the substring's starting position in the originating string value.
//
// Parameters:	pPosition - The starting position of the substring.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if substringPosition &lt;&gt; pPosition then 
		substringPosition	:=	pPosition;
	endif;
end;</source>
        <Parameter name="pPosition" type="Integer"/>
    </JadeMethod>
</Class>
