    <JadeMethod name="addErrorFullPassport" id="58f071fd-1c56-4384-b3f7-066d5025466f">
        <updating/>
        <source>addErrorFullPassport(pErrorCode : Integer; pText, pField : String; pObject : Object; pPassport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
