    <JadeMethod name="hkLoadLatestHotfixForVersion" id="e4315fb9-b109-4b6c-8b04-220f3cb325d5">
        <source>hkLoadLatestHotfixForVersion(stem:String):String;

vars
	ff:FileFolder;
	fn:FileNode;
	num,encoding,baseBuild:String;
	pos: Integer;
	latest:TimeStamp;
begin
	pos:=1;
	num:= stem.scanUntil("AU",pos);
	encoding:= stem[pos:1];

	create ff;
	ff.usePresentationFileSystem := false;
	ff.fileName:= DailyBuildParentFolder &amp; "DailyResults";
	ff.mask:= "jade" &amp; num &amp; ".*";
	latest.setDate("01/01/1957".Date);
	foreach fn in ff.files where fn.isKindOf(FileFolder) do
		if fn.lastModifiedTime &gt; latest then
			baseBuild:=fn.fileName;
			latest := fn.lastModifiedTime;
		endif;
	endforeach;
	
	if encoding = "A" then 
		baseBuild:= baseBuild &amp; "\x64-msoft-win64\Release_Ansi";
	elseif encoding = "U" then
		baseBuild:= baseBuild &amp; "\x64-msoft-win64\Release_Unicode";
	endif;
		
	return baseBuild;
epilog
	delete ff;
end;
</source>
        <Parameter name="stem" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
