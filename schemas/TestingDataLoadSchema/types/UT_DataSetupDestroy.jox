    <JadeMethod name="processUpdateTrackedItems" id="9f34e055-c646-4659-9c76-14ecf40e1e8a">
        <source>processUpdateTrackedItems(_tiXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Update tracked items

Date			Who		Reason
14/05/2018		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	element					: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;
	
begin

	varsStr := "ti				: CM_TrackedItem;" &amp; CrLf &amp; CrLf;

	foreach obj in _tiXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		// setup any opts
		self.setupOptsAssoc(xmlElement.getElementByTagName('opts'), codeStr);
		
		element := xmlElement.getElementByTagName('id');
		if element &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'ti := self.getTrackedItem(' &amp; self.returnElementText(element).String &amp; ');' &amp; CrLf;
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'self.updateTI(ti);' &amp; CrLf &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	
end;
</source>
        <Parameter name="_tiXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processUserWindowsForOpen" id="3f521b14-c005-4757-8950-13e6d47b0584">
        <source>processUserWindowsForOpen(_userWindowsForOpenXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the defaults for users whend certain windows are open

Date			Who		Reason
12/02/2018		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	user					: CM_User;
	
	cargoTypesArray			: StringArray;
	usersArray				: ObjectArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	length					: Integer;
	noCargoPositions		: Integer;
	height					: Integer;
	weight					: Integer;
	tareWeight				: Integer;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'user			: CM_User;' &amp; CrLf &amp; 
		Tab &amp; 'obj						: Object;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'usersArray				: ObjectArray;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'xmlInfo					: String;' &amp; CrLf &amp; CrLf;
	
	codeStr := codeStr &amp; Tab &amp; 'create usersArray transient;' &amp; CrLf &amp;
	Tab &amp; 'foreach user in app.myRoot.allUsers do' &amp; CrLf &amp;
	Tab &amp; '	if user.code &lt;&gt; "JLGMH5" then' &amp; CrLf &amp;
	Tab &amp; '		usersArray.add(user);' &amp; CrLf &amp;
	Tab &amp; '	endif;' &amp; CrLf &amp;
	Tab &amp; 'endforeach;' &amp; CrLf &amp; CrLf;
	
	epilogStr := epilogStr &amp; 'delete usersArray;' &amp; CrLf;
	
	foreach obj in _userWindowsForOpenXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		codeStr := codeStr &amp; Tab &amp; 'foreach obj in usersArray do' &amp; CrLf &amp;
		Tab &amp; "    xmlInfo := '" &amp; xmlElement.getElementByTagName("xmlInfo").childNodes.first.JadeXMLCDATA.data &amp; "';" &amp; CrLf &amp;
		Tab &amp; "    xmlInfo.cnReplaceString('"&amp; DoubleQuote &amp; "', " &amp; '"' &amp; SingleQuote &amp; '");' &amp; CrLf &amp;
		Tab &amp; '    self.updateUserWindowForOpen(obj.CM_User, "' &amp; xmlElement.tagName &amp; '", ' &amp; CrLf &amp;
		Tab &amp; '    xmlInfo, ' &amp; CrLf &amp;
		Tab &amp; self.returnElementText(xmlElement.getElementByTagName("top")).String &amp; ', ' &amp; CrLf &amp;
		Tab &amp; self.returnElementText(xmlElement.getElementByTagName("left")).String &amp; ',' &amp; CrLf &amp;
		Tab &amp; self.returnElementText(xmlElement.getElementByTagName("width")).String &amp; ',' &amp; CrLf &amp;
		Tab &amp; self.returnElementText(xmlElement.getElementByTagName("height")).String &amp; ',' &amp; CrLf &amp;
		Tab &amp; self.returnElementText(xmlElement.getElementByTagName("state")).String &amp; ');' &amp; CrLf &amp;
		Tab &amp; 'endforeach;'&amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	delete usersArray;
end;

</source>
        <Parameter name="_userWindowsForOpenXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processUsers" id="bac55b38-7f9a-49d6-be37-b3f3d74b0116">
        <source>processUsers(_userXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required users	

Date			Who		Reason
22/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	xmlElement2				: JadeXMLElement;
	xmlElement3				: JadeXMLElement;
	terminalsElement		: JadeXMLElement;
	obj						: Object;
	
	secRoleTerm   			: CM_SecurityRoleTerminal;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	password				: String;
	
begin

	varsStr := varsStr &amp; Tab &amp; 'user				: CM_User;' &amp; CrLf &amp;
		Tab &amp; 'pxyUser				: CM_User;' &amp; CrLf &amp;
		Tab &amp; 'terminal				: CM_Terminal;' &amp; CrLf &amp; 
		Tab &amp; 'userTerm 			: CM_UserTerminal;' &amp; CrLf &amp;
		Tab &amp; 'obj					: Object;' &amp; CrLf &amp;
		Tab &amp; 'secRoleTerm   		: CM_SecurityRoleTerminal;' &amp; CrLf &amp;
		Tab &amp; 'sysSecurityRole		: CM_SecurityRoleSystem;' &amp; CrLf &amp;
		Tab &amp; 'cargoType			: CM_CargoType;' &amp; CrLf &amp;
		Tab &amp; 'bolType				: CM_BOLType;' &amp; CrLf &amp;
		Tab &amp; 'cargoBOLType			: CM_CargoBOLType;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'objArray			: ObjectArray;' &amp; CrLf &amp; CrLf;
		
	epilogStr := epilogStr &amp; Tab &amp; 'delete userTerm;' &amp; CrLf &amp;
		Tab &amp; 'pxyUser.allSubSystemStateObjects.removeInvalidObjects();' &amp; CrLf &amp;
		Tab &amp; 'create objArray transient;' &amp; CrLf &amp;
		Tab &amp; 'pxyUser.allSubSystemStateObjects.copy(objArray);' &amp; CrLf &amp;
		Tab &amp; 'foreach obj in objArray do' &amp; CrLf &amp;
		Tab &amp; '	delete obj;' &amp; CrLf &amp;
		Tab &amp; 'endforeach;' &amp; CrLf &amp;
		Tab &amp; 'delete objArray;' &amp; CrLf &amp;
		Tab &amp; 'delete pxyUser;' &amp; CrLf;
			
	foreach obj in _userXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		self.setupOptsAssoc(xmlElement.getElementByTagName('opts'), codeStr);
		
		// get the password 
		password := '"p@s5word1"';
		xmlElement2 := xmlElement.getElementByTagName("UserPassword");
		if xmlElement2 &lt;&gt; null then
			password := self.returnElementText(xmlElement2).String;
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("UserPassword", ' &amp; password &amp; ');' &amp; CrLf;
		endif;
		
		// get the system security role
		xmlElement2 := xmlElement.getElementByTagName("SysSecurityRole");
		if xmlElement2 &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'sysSecurityRole := app.myRoot.allRoles[' &amp;self.returnElementText(xmlElement2).String &amp; '].CM_SecurityRoleSystem;' &amp; CrLf &amp;
				Tab &amp; 'self.opts.addAssoc("SysSecurityRole", sysSecurityRole);' &amp; CrLf;
		endif;
		
		// get the status
		xmlElement2 := xmlElement.getElementByTagName("Status");
		if xmlElement2 &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Status", "' &amp; self.returnElementText(xmlElement2).String &amp; '");' &amp; CrLf;
		endif;
		
		// get password never expires
		xmlElement2 := xmlElement.getElementByTagName("PasswordNeverExpires");
		if xmlElement2 &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("PasswordNeverExpires", ' &amp; self.returnElementText(xmlElement2).String &amp; ');' &amp; CrLf;
		endif;
		
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		
		codeStr := codeStr &amp; Tab &amp; 'user := self.addUser(' &amp; description &amp; ',"' &amp; xmlElement.tagName &amp; '");' &amp; CrLf &amp; CrLf;
		
		// add the required terminals to the user
		terminalsElement := xmlElement.getElementByTagName("TerminalsToAdd");
		if terminalsElement &lt;&gt; null then
			foreach obj in terminalsElement.childNodes do
				xmlElement2 := obj.JadeXMLElement;
			
				// get the terminal
				codeStr := codeStr &amp; Tab &amp; 'terminal := app.myRoot.allTerminals["' &amp; xmlElement2.tagName &amp; '"].CM_Terminal;' &amp; CrLf &amp;
					Tab &amp; 'self.assertNotNull(terminal);' &amp; CrLf &amp;
					Tab &amp; 'app.myPassport.setMyTerminal(terminal);' &amp; CrLf;
				
				// create the pxyuser to update
				codeStr := codeStr &amp;  Tab &amp; 'delete userTerm;' &amp; CrLf &amp;
					Tab &amp; 'delete pxyUser;' &amp; CrLf &amp;
					Tab &amp; 'pxyUser := app.createUpdateProxy(user).CM_User;' &amp; CrLf;
				
				// get the security role
				secRoleTerm := CM_SecurityRoleTerminalRoot.firstInstance;
				xmlElement3 := xmlElement2.getElementByTagName("TermSecurityRole");
				if xmlElement3 &lt;&gt; null then
					codeStr := codeStr &amp; Tab &amp; 'secRoleTerm := app.myRoot.allRoles[' &amp; self.returnElementText(xmlElement3).String &amp; '].CM_SecurityRoleTerminal;' &amp; CrLf;
				endif;
				
				// create user term
				codeStr := codeStr &amp; Tab &amp; 'create userTerm transient;' &amp; CrLf &amp;
					Tab &amp; 'userTerm.setForProxy(terminal, pxyUser, secRoleTerm, cargoType,	bolType, cargoBOLType);' &amp; CrLf &amp;
					Tab &amp; 'app.myTrxUA.trxUpdateUser(pxyUser, ' &amp; password &amp; ', app.myPassport);' &amp; CrLf &amp; CrLf;
				
			endforeach;		
		endif;
		
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_userXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processVesselDetails" id="be9dc832-a805-4ff5-acac-5485bc734865">
        <updating/>
        <source>processVesselDetails(_vesselXMLElement : JadeXMLElement) updating;

/*

Purpose:		Create the Vessel Details	

Date			Who		Reason
22/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement		: JadeXMLElement;
	vesselElement	: JadeXMLElement;
	layoutElement	: JadeXMLElement;
	
	obj				: Object;
	
	methodStr		: String;
	description		: String;
	layout			: String;
	operator		: String;
	
begin

	foreach obj in _vesselXMLElement.childNodes do
		vesselElement := obj.JadeXMLElement;
		
		methodStr := self.MethodString;
		
		methodStr.cnReplaceString("&lt;^%For^%&gt;", "Create" &amp; vesselElement.tagName);
		self.processVessels(vesselElement, methodStr);
					
		write methodStr &amp; CrLf &amp; CrLf;
			
		// execute the transient method
		self.executeMethod(methodStr);
			
	endforeach;


end;
</source>
        <Parameter name="_vesselXMLElement" type="JadeXMLElement"/>
    </JadeMethod>
    <JadeMethod name="processVessels" id="1914c946-25b1-4cd1-8e93-ad45154b00a9">
        <source>processVessels(_vesselXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required Vessel

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	vesselElement			: JadeXMLElement;
	layoutElement			: JadeXMLElement;
	roroVesselStructure		: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;
	operator				: String;
	theXML					: String;
	value					: String;
	
	
begin
	
	varsStr := 'operator			: CM_Operator;' &amp; CrLf &amp; 
		Tab &amp; 'vessel				: CM_Vessel;' &amp; CrLf &amp;
		Tab &amp; 'allStateData 		: CM_StateDataDict;' &amp; CrLf &amp;
		Tab &amp; 'theXML			: String;' &amp; CrLf;
	
	description := self.returnElementText(_vesselXMLElement.getElementByTagName('description')).String;
	operator := self.returnElementText(_vesselXMLElement.getElementByTagName('operator')).String;
	operator.cnReplaceString('"', '');
	if operator = null then
		operator := "UTOP";
	endif;
	
	codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.expectedTrxErrors.clear();' &amp; CrLf &amp; 
		Tab &amp; 'self.expectTrxError(UNEXPECTED_PROGRAM_ERROR);' &amp; CrLf &amp;
		Tab &amp; 'self.deleteVessel("' &amp; _vesselXMLElement.tagName &amp; '");' &amp; CrLf;
	
	layoutElement := _vesselXMLElement.getElementByTagName('layout');
	roroVesselStructure := _vesselXMLElement.getElementByTagName('ROROVesselStructure');
	
	codeStr := codeStr &amp; Tab &amp; 'operator := app.myRoot.allOperators["' &amp; operator &amp; '"];' &amp; CrLf;
	if layoutElement &lt;&gt; null then
		codeStr  := codeStr &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf;
		if roroVesselStructure &lt;&gt; null then  
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("ROROVesselStructure", "");' &amp; CrLf;
		endif;
		codeStr := codeStr &amp; Tab &amp; 'theXML := "' &amp; layoutElement.childNodes.first.JadeXMLCDATA.data &amp; '";' &amp; CrLf;
		codeStr := codeStr &amp; Tab &amp; 'vessel := self.createVesselFromXML("' &amp; _vesselXMLElement.tagName &amp; '", theXML);' &amp; CrLf;
	else
		codeStr := codeStr &amp; Tab &amp; 'vessel := self.addVesselCellular("' &amp; _vesselXMLElement.tagName &amp; '", operator, null);' &amp; CrLf;
	endif;
		
	vesselElement :=  _vesselXMLElement.getElementByTagName('ROROConfig');
	if vesselElement &lt;&gt; null then
		codeStr := codeStr &amp; Tab &amp; 'if vessel &lt;&gt; null then' &amp; CrLf &amp; 
			Tab &amp; Tab &amp; 'allStateData := vessel.allStateData;' &amp; CrLf &amp;
			Tab &amp; Tab &amp; 'beginTransaction;' &amp; CrLf;
		foreach obj in vesselElement.childNodes do
			xmlElement := obj.JadeXMLElement;
			value := self.returnElementText(vesselElement.getElementByTagName(xmlElement.tagName)).String;
			if value.isAlpha() and value &lt;&gt; 'true' and value &lt;&gt; 'false' then
				value := '"' &amp; value &amp; '"';
			endif;
			codeStr := codeStr &amp; Tab &amp; Tab &amp; 'global.setExtraData(allStateData, vessel, ' &amp; xmlElement.tagName &amp; ', ' &amp; value &amp; ');' &amp; CrLf;
		endforeach;
		codeStr := codeStr &amp; Tab &amp; Tab &amp; 'commitTransaction;' &amp; CrLf &amp;
			Tab &amp; 'endif;' &amp; CrLf;
	
	endif;
		
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_vesselXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processVesselsFromFile" id="3ca4b96c-cc8b-4dbb-a8bc-665691373287">
        <source>processVesselsFromFile(_methodStr : String io);

/*

Purpose:		Create / Add required Vessel

Date			Who		Reason
05/10/2017		cnwmh5	Initial creation

*/
vars
	
	fileFolder						: FileFolder;
	fileNode						: FileNode;
	theRealVessel					: CM_Vessel;
	pxyVessel						: CM_Vessel;
	conflictManager					: CMIF_HMS_ConflictsManager;
	xmlElement						: JadeXMLElement;
	
	fileXML : CMDFileOpen;
	theFileName : String;
	xmlDocumentParser : JadeXMLDocumentParser;
	xmlDocument : JadeXMLDocument;
	rootElement, childElement : JadeXMLElement;
	xmlAttribute : JadeXMLAttribute;
	classToCreate : Class;
	pxyObject 	: CM_Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;

	loloStructure				: Boolean;
	roroStructure				: Boolean;
	vesselCode					: String;
	pos 						: Integer;

begin

	on FileException do app.fileExceptionHandler(exception);
	
	varsStr := 'xmlDocumentParser			: JadeXMLDocumentParser;' &amp; CrLf &amp; 
		Tab &amp; 'xmlDocument				: JadeXMLDocument;' &amp; CrLf &amp;
		Tab &amp; 'rootElement 		: JadeXMLElement;' &amp; CrLf &amp;
		Tab &amp; 'pxyVessel			: CM_Vessel;' &amp; CrLf &amp;
		Tab &amp; 'theRealVessel 		: CM_Vessel;' &amp; CrLf &amp;
		Tab &amp; 'conflictManager 		: CMIF_HMS_ConflictsManager;' &amp; CrLf;

	create fileFolder transient;
	fileFolder.fileName := DataLoadedCopyFromVessels &amp; "\";
	fileFolder.usePresentationFileSystem := true;
	fileFolder.mask := "*.xml";
	
	
	foreach fileNode in fileFolder.files do
	
		pos := fileNode.name.length;
		pos := fileNode.name.reversePosIndex('.', pos);
		vesselCode := fileNode.name[1:pos - 1];
		vesselCode := vesselCode.replaceString('"', '');
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.deleteVessel("' &amp; vesselCode &amp; '");' &amp; CrLf;
	
		//parse xml into doc
		codeStr  := codeStr &amp; Tab &amp; 'delete xmlDocumentParser;' &amp; CrLf &amp;
			Tab &amp; 'create xmlDocumentParser transient;' &amp; CrLf &amp;
			Tab &amp; 'delete xmlDocument;' &amp; CrLf &amp;
			Tab &amp; 'create xmlDocument transient;' &amp; CrLf &amp;
			Tab &amp; 'xmlDocumentParser.parseDocumentFile(xmlDocument, "' &amp; fileNode.fileName &amp; '");' &amp; CrLf &amp;
			Tab &amp; 'rootElement:=xmlDocument.rootElement;' &amp; CrLf &amp; CrLf;
			
		codeStr  := codeStr &amp; Tab &amp; 'delete pxyVessel;' &amp; CrLf &amp;
			Tab &amp; 'create pxyVessel as CM_Vessel transient;' &amp; CrLf &amp;	
			Tab &amp; 'pxyVessel.importFromXMLDoc(rootElement);' &amp; CrLf &amp; CrLf;
			
		codeStr := codeStr &amp; Tab &amp; 'pxyVessel.setPropertyValue("code", "' &amp; vesselCode &amp; '");' &amp; CrLf &amp; 
			Tab &amp; 'pxyVessel.myHMSVesselData.setPropertyValue("myRoot", app.myRoot);' &amp; CrLf &amp; CrLf;
		
		codeStr := codeStr &amp; Tab &amp; 'app.myTrxCA.trxCreateVessel(pxyVessel, theRealVessel, conflictManager, app.myPassport);' &amp; CrLf &amp; CrLf;
		
		
	endforeach;
	
	epilogStr := Tab &amp; 'delete xmlDocumentParser;' &amp; CrLf &amp;
		Tab &amp; 'delete xmlDocument;' &amp; CrLf &amp; CrLf;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);

epilog

	//delete xmlDocumentParser;
	//delete xmlDocument;

end;
</source>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processVoyageDelays" id="3b47956f-5ef3-4f0a-b998-81591e79bc4f">
        <source>processVoyageDelays(_voyageDelayXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the voyage delays

Date			Who		Reason
15/03/2018		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	xmlElement2				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	terminalAttribute		: JadeXMLAttribute;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	startTS					: String;
	endTS					: String;
	estEndTS				: String;
	delayCode				: String;
	
begin

	varsStr := "voyage					: CM_Voyage;" &amp; CrLf &amp; 
		Tab &amp; "terminal					: CM_Terminal;" &amp; CrLf &amp; CrLf;
				
	foreach obj in _voyageDelayXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		optsElement := xmlElement.getElementByTagName('opts');
		self.setupOptsAssoc(optsElement, codeStr);
		
		terminalAttribute := xmlElement.getAttributeByName("Terminal");
		codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttribute.value &amp; '");' &amp; CrLf &amp; CrLf;
		
		startTS := self.returnElementText(xmlElement.getElementByTagName("startTS")).String;
		endTS := self.returnElementText(xmlElement.getElementByTagName("endTS")).String;
		estEndTS := self.returnElementText(xmlElement.getElementByTagName("estEndTS")).String;
		delayCode := self.returnElementText(xmlElement.getElementByTagName("delayCode")).String;
		
		// get the voyage
		codeStr := codeStr &amp; Tab &amp; 'terminal := app.myRoot.allTerminals["' &amp; terminalAttribute.value &amp; '"];' &amp; CrLf &amp;
			Tab &amp; 'voyage := self.getVoyage(' &amp; self.returnElementText(xmlElement.getElementByTagName("voyage")).String &amp; ');' &amp; CrLf &amp; 
			Tab &amp; 'self.assertNotNull(voyage);' &amp; CrLf &amp; CrLf;
				
		codeStr := codeStr &amp; Tab &amp; 'self.createVoyageDelay(' &amp; startTS &amp; '.TimeStamp, ' &amp; endTS &amp; '.TimeStamp, ' &amp; 
			estEndTS &amp; '.TimeStamp, voyage, ' &amp; delayCode &amp; ');' &amp; CrLf &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_voyageDelayXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processVoyages" id="350e2bac-3b4f-4704-89d5-4adeec677960">
        <source>processVoyages(_voyageElements : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required Voyages
Date			Who		Reason
18/10/2017		jlgmh5	Initial creation

*/

vars

	voyageElement			: JadeXMLElement;
	terminalAttribute		: JadeXMLAttribute;
	typeAttribute			: JadeXMLAttribute;
	optsElement				: JadeXMLElement;
	isNonPlannedElement		: JadeXMLElement;
	isNonWorkedElement		: JadeXMLElement;
		
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
begin

	varsStr := varsStr &amp; 'terminal					: CM_Terminal;' &amp; CrLf &amp; CrLf;
	
	epilogStr := epilogStr &amp; 'app.myPassport.setMyTerminal(terminal);' &amp; CrLf &amp; CrLf;

	foreach obj in _voyageElements.childNodes do
		voyageElement := obj.JadeXMLElement;
		app.writeLog("Creating Voyage " &amp; voyageElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Creating Voyage " &amp; voyageElement.tagName &amp; ".  Please wait...";
		
		terminalAttribute := voyageElement.getAttributeByName("Terminal");
		typeAttribute := voyageElement.getAttributeByName("Type");
		isNonPlannedElement := voyageElement.getElementByTagName("isNonPlanned");
		isNonWorkedElement := voyageElement.getElementByTagName("isNonWorked");
		
		optsElement := voyageElement.getElementByTagName("opts");
		if optsElement &lt;&gt; null then
			self.setupOptsAssoc(voyageElement.getElementByTagName('opts'), codeStr);
		else
			codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf;
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; terminalAttribute.value &amp; '");' &amp; CrLf &amp; CrLf;
		
		codeStr := codeStr &amp; Tab &amp; 'terminal := app.myPassport.myTerminal;' &amp; CrLf &amp;
			Tab &amp; 'app.myPassport.setMyTerminal(app.myRoot.allTerminals["' &amp; terminalAttribute.value &amp; '"]);' &amp; CrLf &amp; CrLf;
		
		if typeAttribute &lt;&gt; null then
		
			if typeAttribute.value.toUpper() = "ConRORO".toUpper() then
				codeStr := codeStr &amp; Tab &amp; 'self.addVoyageWithConRORO("' &amp; voyageElement.tagName &amp; '", ' &amp;
					self.returnElementText(voyageElement.getElementByTagName('vesselCode')).String &amp; ', ' &amp;
					self.returnElementText(voyageElement.getElementByTagName('operatorName')).String &amp; ', ' &amp;
					self.returnElementText(voyageElement.getElementByTagName('shippingLine')).String &amp; ', ' &amp;
					self.returnElementText(voyageElement.getElementByTagName('trade')).String &amp; ', ' &amp;
					self.returnElementText(voyageElement.getElementByTagName('numberOfHatches')).String &amp; ', ' &amp; 
					(isNonPlannedElement &lt;&gt; null).String &amp; ', ' &amp; (isNonWorkedElement &lt;&gt; null).String &amp; ');' &amp; CrLf &amp; CrLf;
			elseif typeAttribute.value.toUpper() = "Con".toUpper() then
				codeStr := codeStr &amp; Tab &amp; 'self.addVoyageWithContainerStructur("' &amp; voyageElement.tagName &amp; '", ' &amp;
					self.returnElementText(voyageElement.getElementByTagName('vesselCode')).String &amp; ', ' &amp;
					self.returnElementText(voyageElement.getElementByTagName('operatorName')).String &amp; ', ' &amp;
					self.returnElementText(voyageElement.getElementByTagName('shippingLine')).String &amp; ');' &amp; CrLf &amp; CrLf;
			elseif typeAttribute.value.toUpper() = "Holds".toUpper() then
				codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Trade", ' &amp; self.returnElementText(voyageElement.getElementByTagName('trade')).String &amp; ');' &amp; CrLf;
				codeStr := codeStr &amp; Tab &amp; 'self.addVoyageWithGeneralCargoStruc("' &amp; voyageElement.tagName &amp; '", ' &amp;
					self.returnElementText(voyageElement.getElementByTagName('vesselCode')).String &amp; ', ' &amp;
					self.returnElementText(voyageElement.getElementByTagName('operatorName')).String &amp; ', ' &amp;
					self.returnElementText(voyageElement.getElementByTagName('shippingLine')).String &amp; ', ' &amp;
					self.returnElementText(voyageElement.getElementByTagName('numberOfHatches')).String &amp; ');' &amp; CrLf &amp; CrLf;
			endif;
		
		endif;
		
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_voyageElements" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processWagonClasses" id="f9b09359-bf93-47e4-a85b-e8b854913e98">
        <source>processWagonClasses(_wagonClassXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the wagon class

Date			Who		Reason
01/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	maxPosWeight 			: Decimal[14,2];
	maxPosHeight 			: Decimal[14,2];
	deckHeight				: Decimal[14,2];
	tareWeight 				: Decimal[14,2];
	maxLoadWeight 			: Integer;
	carrier					: String;
	
begin

	varsStr := 'wagonClass				: CM_WagonClass;' &amp; CrLf;
	
	foreach obj in _wagonClassXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		maxPosWeight := self.returnElementText(xmlElement.getElementByTagName('maxPosWeight')).Decimal;
		maxPosHeight := self.returnElementText(xmlElement.getElementByTagName('maxPosHeight')).Decimal;
		deckHeight := self.returnElementText(xmlElement.getElementByTagName('deckHeight')).Decimal;
		tareWeight := self.returnElementText(xmlElement.getElementByTagName('tareWeight')).Decimal;
		maxLoadWeight := self.returnElementText(xmlElement.getElementByTagName('maxLoadWeight')).Integer;
			
		optsElement := xmlElement.getElementByTagName('opts');
		self.setupOptsAssoc(optsElement, codeStr);
		
		carrier := self.returnElementText(xmlElement.getElementByTagName('carrier')).String;	
		if carrier &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'opts.addAssoc("Carrier", app.myRoot.allCarriers[' &amp; carrier &amp; ']);' &amp; CrLf;
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'wagonClass := app.myRoot.allWagonClasses.getAtKey("' &amp; xmlElement.tagName &amp; '");' &amp; CrLf &amp; CrLf &amp; 
			Tab &amp; 'self.deleteWagonClassAndWagons(wagonClass);' &amp; CrLf &amp;
			Tab &amp; 'self.addWagonClass("' &amp; xmlElement.tagName &amp; '");' &amp; CrLf;
			
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	
end;
</source>
        <Parameter name="_wagonClassXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processWorkPoints" id="7d2ff5db-b82b-49d2-a026-8f442196a423">
        <source>processWorkPoints(_workpointXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the carrier details

Date			Who		Reason
23/04/2018		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	attribute				: JadeXMLAttribute;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	
begin

	varsStr := CrLf &amp; Tab &amp; 'pinEmailAddresses	: CM_EmailEntityByTypeNameDict;';

	epilogStr := CrLf &amp; Tab &amp; 'delete pinEmailAddresses;' &amp; CrLf;
	
	codeStr := CrLf &amp; Tab &amp; 'create pinEmailAddresses transient;' &amp; CrLf &amp; CrLf;
			
	foreach obj in _workpointXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		optsElement := xmlElement.getElementByTagName('opts');
		self.setupOptsAssoc(optsElement, codeStr);
		
		attribute := xmlElement.getAttributeByName("Terminal");
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; attribute.value &amp; '");' &amp; CrLf;
				
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addWorkPoint("' &amp; xmlElement.tagName &amp; '", true);' &amp; CrLf;
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_workpointXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processXMLDocument" id="f553ec2c-98fc-4bfa-9479-a28bc9226765">
        <updating/>
        <source>processXMLDocument() updating;

/*

Purpose:		Process the XML Document

Date			Who		Reason
22/02/2012		cnwmh5	Initial creation

*/
constants
	DataToLoad					: String = "DataToLoad";
vars

	openFile					: CMDFileOpen;
	obj							: Object;
	terminal					: CM_Terminal;

	xmlDoc						: JadeXMLDocument;
	xmlElement					: JadeXMLElement;
	elementDataToLoad			: JadeXMLElement;

begin

	//on FileException do fileExceptionHandler(exception, "Import");
	on Exception do handleFormatException(exception, "Import");
	
	create openFile transient;
	openFile.filter := "XML Definition (*.xml)|*.xml";
	if openFile.open() &lt;&gt; 0 then
		return;
	endif;

	create xmlDoc transient;
	xmlDoc.parseFile(openFile.fileName);
	
	elementDataToLoad := xmlDoc.getElementByTagName(DataToLoad);
	if elementDataToLoad = null then
		return;
	endif;
	
	foreach obj in elementDataToLoad.childNodes do
		xmlElement := obj.JadeXMLElement;
	
		if xmlElement.tagName.toUpper() = "System".toUpper() then
			self.processSystem(xmlElement);
		elseif xmlElement.tagName.toUpper() = "Vessel".toUpper() then
			self.processVesselDetails(xmlElement);
		elseif xmlElement.tagName.toUpper() = "Harbour".toUpper() then
			self.processHarbourDetails(xmlElement);
		elseif xmlElement.tagName.toUpper() = "Terminal".toUpper() then
			self.processTerminalDetails(xmlElement);
		endif;
	endforeach;
	
	
	// setup DefAvailabilityGrade for all terminals.  Required so can delete availability grade
	beginTransaction;
	foreach terminal in app.myRoot.allTerminals do
		terminal.setConfig(DefAvailabilityGrade, "0");
	endforeach;
	commitTransaction;
	
	self.processRootMisc();
	
epilog

	delete xmlDoc;
	delete openFile;

end;
</source>
    </JadeMethod>
    <JadeMethod name="processYardAllocations" id="e78fe3c9-c24a-4f79-a6f2-2529a0b47443">
        <source>processYardAllocations(_yardAllocationElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add yard allocations

Date			Who		Reason
17/10/2017		jlgmh5	Initial creation

*/

vars

	yaElement				: JadeXMLElement;
	attribute				: JadeXMLAttribute;
	element					: JadeXMLElement;
	element2				: JadeXMLElement;
	obj						: Object;
	terminalArea			: CM_TerminalArea;
	
	rows					: StringArray;
	cols					: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
begin
	
	varsStr := varsStr &amp; CrLf &amp; Tab &amp; 'terminalArea			: CM_TerminalArea;' &amp; CrLf &amp; 
		Tab &amp; 'tempTerminal				: CM_Terminal;' &amp; CrLf &amp;
		Tab &amp; 'controller				: CM_StackController;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'pxyYACriteria			: CMIF_Array;' &amp; CrLf &amp;
		Tab &amp; 'locations				: CM_LCArray;' &amp; CrLf &amp; 
		Tab &amp; 'rows					: StringArray;' &amp; CrLf &amp; 
		Tab &amp; 'cols					: StringArray;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'iter : Iterator;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'rowCount				: Integer;' &amp; CrLf &amp;
		Tab &amp; 'colCount				: Integer;' &amp; CrLf &amp;
		Tab &amp; 'row						: String;' &amp; CrLf &amp;
		Tab &amp; 'col						: String;' &amp; CrLf;
		
	codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'create pxyYACriteria transient;' &amp; CrLf &amp;
		Tab &amp; 'create locations transient;' &amp; CrLf &amp; 
		Tab &amp; 'create rows transient;' &amp; CrLf &amp;
		Tab &amp; 'create cols transient;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'tempTerminal := app.myPassport.myTerminal;' &amp; CrLf &amp; CrLf;
	create rows transient;
	create cols transient;
	
	epilogStr := epilogStr &amp; CrLf &amp; Tab &amp; 'delete pxyYACriteria;' &amp; CrLf &amp;
		Tab &amp; 'delete locations;' &amp; CrLf &amp;
		Tab &amp; 'delete rows;' &amp; CrLf &amp;
		Tab &amp; 'delete cols;' &amp; CrLf &amp; CrLf;
	
	foreach obj in _yardAllocationElement.childNodes do
		yaElement := obj.JadeXMLElement;
		app.writeLog("Creating Yard Allocation " &amp; yaElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Creating Yard Allocation " &amp; yaElement.tagName &amp; ".  Please wait...";
		
		// get the terminal and set where required
		attribute := yaElement.getAttributeByName("Terminal");
		codeStr := codeStr &amp; Tab &amp; 'app.myPassport.setMyTerminal(tempTerminal);' &amp; CrLf &amp;
			Tab &amp; 'tempTerminal := app.myPassport.myTerminal;' &amp; CrLf &amp;
			Tab &amp; 'app.myPassport.setMyTerminal(app.myRoot.allTerminals["' &amp; attribute.value &amp; '"]);' &amp; CrLf;
		
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf &amp;
			Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; attribute.value &amp; '");' &amp; CrLf &amp; CrLf;
		
		codeStr := codeStr &amp; Tab &amp; 'pxyYACriteria.clear();' &amp; CrLf;
		
		// create the criteria
		element := yaElement.getElementByTagName("criterias");
		foreach obj in element.childNodes do
			element2 := obj.JadeXMLElement;
			codeStr := codeStr &amp; Tab &amp; 'pxyYACriteria.add(self.createYACriteria(' &amp; self.returnElementText(element2.getElementByTagName('criterial')).String &amp; 
				', ' &amp; self.returnElementText(element2.getElementByTagName('value')).String &amp; '));' &amp; CrLf;
		endforeach;
		
		// create the locations details
		codeStr := codeStr &amp; Tab &amp; 'locations.clear();' &amp; CrLf;
		element := yaElement.getElementByTagName("locations");
		foreach obj in element.childNodes do
			element2 := obj.JadeXMLElement;
			
			codeStr := codeStr &amp; Tab &amp; 'terminalArea := self.getTerminalArea("' &amp; element2.tagName &amp; '");' &amp; CrLf;
			self.opts.purge();
			self.opts.addAssoc("Terminal", attribute.value);
			terminalArea := self.getTerminalArea(element2.tagName);
			
			codeStr := codeStr &amp; Tab &amp; 'locations.add(terminalArea.allLocationsControllers.first);' &amp; CrLf &amp; CrLf;
			
		endforeach;
	
		// create the yard allocation
		codeStr := codeStr &amp; Tab &amp; 'self.addYA(' &amp; self.returnElementText(yaElement.getElementByTagName('name')).String &amp; ', pxyYACriteria, locations);' &amp; CrLf;
	
	endforeach;
	
	codeStr := codeStr &amp; Tab &amp; 'app.myPassport.setMyTerminal(tempTerminal);' &amp; CrLf;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_yardAllocationElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="returnArrayDetails" id="ffd2b979-5d29-458a-9505-0a7fea68a902">
        <source>returnArrayDetails(_xmlElement : JadeXMLElement; _collectionName, _collectionType : String; _codeStr : String io);

/*

Purpose:		Returns the details for the array back in the codeStr


Date			Who		Reason
02/03/2012		cnwmh5	Initial creation

*/

vars

	contentsArray			: StringArray;
	
	arrayStr 				: String;
	str 					: String;
	type					: String;

begin

	arrayStr := self.returnElementText(_xmlElement).String;
	arrayStr.cnReplaceString('"', '');
	create contentsArray transient;
	arrayStr.getTokensForDelimiter(';', contentsArray);
	foreach str in contentsArray do
		type := 'app.myRoot';
		if _collectionType.toUpper() &lt;&gt; "ROOT".toUpper() then
			type := _collectionType;
		endif;
		_codeStr := _codeStr &amp; Tab &amp; _xmlElement.tagName &amp; '.add(' &amp; type &amp; '.' &amp; _collectionName &amp; '["' &amp; str &amp; '"]);' &amp; CrLf;		
	endforeach;
	
epilog
	delete contentsArray;
end;
</source>
        <Parameter name="_xmlElement" type="JadeXMLElement"/>
        <Parameter name="_collectionName" type="String"/>
        <Parameter name="_collectionType" type="String"/>
        <Parameter name="_codeStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="returnElementText" id="c384eb9f-b53b-49fb-b3cc-be135516c205">
        <source>returnElementText(_xmlElement : JadeXMLElement) : Any;

/*

Purpose:		Return the text for the xml element		


Date			Who		Reason
22/02/2012		cnwmh5	Initial creation

*/

vars

	returnValue 				: Any;
	attribute					: JadeXMLAttribute;

begin

	returnValue := '';
	
	if _xmlElement &lt;&gt; null then
		returnValue := _xmlElement.text;
		// Can return false here as we don't include stuff we don't setup 
		if returnValue = null then
			returnValue := true;
		else
			attribute := _xmlElement.getAttributeByName("DontFormat");
			if returnValue.String.isAlpha() then
				if _xmlElement.tagName.toUpper &lt;&gt; "TRACKAS" and _xmlElement.tagName.toUpper &lt;&gt; "HANDLINGTYPE" and returnValue.String &lt;&gt; 'null'  and 
						attribute = null then
					returnValue := '"' &amp; returnValue.String &amp; '"';
				endif;
			elseif not returnValue.String.cnIsNumeric() and attribute = null then
				returnValue := '"' &amp; returnValue.String &amp; '"';
			endif;
		endif;
		
	endif;
	
	if returnValue.String.cnContains('""') then
			returnValue := returnValue.String.replaceString('""', '"');
		endif;

	if returnValue.String.length = 0 then
		returnValue := '""';
	endif;
	
	return returnValue;

epilog

end;
</source>
        <Parameter name="_xmlElement" type="JadeXMLElement"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setupOptsAssoc" id="73cb6616-e7fe-4973-bd6c-6f4a96cc7f1b">
        <source>setupOptsAssoc(_optsXMLElement : JadeXMLElement; _codeStr : String io);

/*

Purpose:		Add the opts details to the relevent strings		


Date			Who		Reason
22/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement					: JadeXMLElement;
	attribute					: JadeXMLAttribute;
	obj							: Object;

begin
	
	_codeStr := _codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf;
	
	if _optsXMLElement = null then
		return;
	endif;
	
	foreach obj in _optsXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		attribute := xmlElement.getAttributeByName("Type");
		if attribute = null then
			_codeStr := _codeStr &amp; Tab &amp; 'self.opts.addAssoc("' &amp; xmlElement.tagName &amp; '", ' &amp; 
				self.returnElementText(xmlElement).String &amp; ');' &amp; CrLf;	
		elseif attribute.value &lt;&gt; 'Object' then
			_codeStr := _codeStr &amp; Tab &amp; 'self.opts.addAssoc("' &amp; xmlElement.tagName &amp; '", ' &amp; 
				self.returnElementText(xmlElement).String &amp; '.' &amp; attribute.value &amp; ');' &amp; CrLf;
		endif;
	endforeach;
	
epilog

end;
</source>
        <Parameter name="_optsXMLElement" type="JadeXMLElement"/>
        <Parameter name="_codeStr" type="String" usage="io"/>
    </JadeMethod>
