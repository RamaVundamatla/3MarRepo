//
// Purpose:     Returns the proxy object for the passed in object.
//				This method entable the creation of the proxy to
//				be remimplemneted if required.
// ---------------------------------------------------------------------------
vars

begin
	return app.createUpdateProxy(_realObj);
end;</source>
