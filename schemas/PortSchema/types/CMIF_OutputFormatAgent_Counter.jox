epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getContainerLength" id="b98c308f-70a9-4de0-83d3-98899c11f215">
        <source>getContainerLength(_ti :CM_Container):Integer protected;
/*
Date		Who		Reason
05 Sep 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
03 Sep 2012	cnwcs5	par 30290
*/
constants
	NotIncluded	 	= 0;
	IncludeOther 	= 2;
vars
	length, int	:Integer;
begin
	if _ti.is45() then 
		length := 45;
		
		int := self.is45Included;		// par 30290 Sep 2012
		
		if int = NotIncluded then		// par 30290 Sep 2012
			length := -1;				// par 30290 Sep 2012
			
		elseif int = IncludeOther then	// par 30290 Sep 2012
			length := Max_Integer;		// par 30290 Sep 2012
		endif;							// par 30290 Sep 2012
		
	elseif _ti.is40 then
		length := 40;
	elseif _ti.is30() then 
		length := 30;
		
		int := self.is30Included;		// par 30290 Sep 2012
		
		if int = NotIncluded then		// par 30290 Sep 2012
			length := -1;				// par 30290 Sep 2012
			
		elseif int = IncludeOther then	// par 30290 Sep 2012
			length := Max_Integer;		// par 30290 Sep 2012
		endif;							// par 30290 Sep 2012
		
	elseif _ti.is53() then 
		length := 53;
		
		int := self.is53Included;		// par 30290 Sep 2012
		
		if int = NotIncluded then		// par 30290 Sep 2012
			length := -1;				// par 30290 Sep 2012
			
		elseif int = IncludeOther then	// par 30290 Sep 2012
			length := Max_Integer;		// par 30290 Sep 2012
		endif;							// par 30290 Sep 2012
	else
		length := 20;
	endif;
	
	
	return length;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_Container"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getIndexForRequest" id="b1d7207d-55ad-4612-afb8-62e96de22c1b">
        <source>getIndexForRequest(_request	:CM_Request; _ti :CM_TrackedItem):Integer protected;
/*
Date		Who		Reason
05 September 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	index :Integer;
begin
	if (_request.isKindOf (CM_SlotRequest) and _request.CM_SlotRequest.isBackend) or
		(_request.isKindOf (CM_VoyageRequest) and _request.CM_VoyageRequest.isBackEndRequest) then
		index := null;
		
	elseif ((_request.isKindOf (CM_VoyageRequest) and _request.CM_VoyageRequest.isSoB)) or 
		((_request.isKindOf (CM_SlotRequest) and _request.CM_SlotRequest.isSOB)) then
		index		:= self.Index_SOB;
		
	elseif (_request.isKindOf (CM_VoyageRequest) and _request.CM_VoyageRequest.isRehandle) or
		(_request.isKindOf (CM_SlotRequest) and _request.CM_SlotRequest.isRehandle) then
		index		:= self.Index_DLR;
		
	elseif (_request.isKindOf (CM_VoyageRequest) and _request.CM_VoyageRequest.isLoad) or
		(_request.isKindOf (CM_SlotRequest) and _request.CM_SlotRequest.isLoad) then 
		
		if _ti.isTranshipItem then
			index		:= self.Index_LoadTS;
		else
			index		:= self.Index_Load;
		endif;
	elseif (_request.isKindOf (CM_VoyageRequest) and _request.CM_VoyageRequest.isDischarge) or
		(_request.isKindOf (CM_SlotRequest) and _request.CM_SlotRequest.isDischarge) then
		
		if _ti.isTranshipItem then
			index		:= self.Index_DischargeTS;
		else
			index		:= self.Index_Discharge;
		endif;
	else
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid move type');
	endif;

	return index;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_request" type="CM_Request"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getIndexForTrackedItem" id="05a13ad2-3853-4c20-8a0d-ed2dec87a70e">
        <source>getIndexForTrackedItem(_ti :CM_TrackedItem; _lc :CM_VoyageController):Integer protected;
/*
Date		Who		Reason
08 September 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
06/01/2015	cnwdap1	PAR #35397 CCMS SFW 1394 Voyage Rationalisation - cater for onsite/offsite/prenoted cargo
*/
vars
	index, imex			:Integer;
	dischargeRequest	:CM_Request;
	id : String;
begin
	imex := _ti.getImExStatus;
	id := _ti.id;
	
	if imex = TI_IMEX_STATUS_REMAINONBOARD then
		if _ti.getTransitStatus =  TI_TransitStatusSOB then
			index := self.Index_SOB;
		elseif _ti.getTransitStatus =  TI_TransitStatusDLR then
			index := self.Index_DLR;
		else
			// staying on board
			index := self.Index_ROB;
		endif;
	elseif imex = TI_IMEX_STATUS_IMPORT then
		index := self.Index_Discharge;
		
	elseif imex = TI_IMEX_STATUS_EXPORT then
		index := self.Index_Load;
		
	elseif imex = TI_IMEX_STATUS_TRANSHIP then
		// it is Discharge TS if there is an incomplete discharge request
		// it is Load TS if there is a complete discharge request
		if _lc = null then									// PAR #35397
			if _ti.isOnSite or _ti.isOffSite then			// PAR #35397
				if self.myVoyage = _ti.myVoyageTranshipExport then //	TFS 7721
					index := self.Index_LoadTS; //	TFS 7721
				else
					index := self.Index_DischargeTS; //	TFS 7721
				endif;
				return index; //	TFS 7721
//	TFS 7721			index := self.Index_LoadTS;					// PAR #35397
			else											// PAR #35397
				index := self.Index_DischargeTS;			// PAR #35397
			endif;											// PAR #35397
		//if _lc.isKindOf (CM_SlotController) then			// PAR #35397
		elseif _lc.isKindOf (CM_SlotController) then		// PAR #35397
			dischargeRequest 	:= _lc.CM_SlotController.mySlotRequestDischarge;
		elseif _lc.isKindOf (CM_VoyageROROController) then
			dischargeRequest 	:= _lc.CM_VoyageROROController.myRORORequestDischarge;
		elseif _lc.isKindOf (CM_GeneralCargoController) then //	TFS 7721
			if _lc.myVoyage = _ti.myVoyageTranshipExport then //	TFS 7721
				index := self.Index_LoadTS; //	TFS 7721
			else
				index := self.Index_DischargeTS; //	TFS 7721
			endif;
			return index; //	TFS 7721
		endif;
/*		If the tranship item is on the export voyage the TI will have 2 WLES, t/s load &amp; t/s discharge
		both of which will be complete.
		If the tranship item is on the import voyage the TI will have 2 WLEs, t/s load &amp; t/s discharge, neither
		of which will be complete */
		if dischargeRequest &lt;&gt; null and dischargeRequest.getTrackedItem = _ti then
			if dischargeRequest.isComplete then
				// complete - we must be on export voyage. Show as a Load.
				index := self.Index_LoadTS;
			else
				// not complete - still on import voyage. It is going to be discharged
				index := self.Index_DischargeTS;
			endif;
		// Or, if the tranship item has NO WLEs, it will be an unplanned tranship on the Import voyage	// PAR #35397
		elseif dischargeRequest = null and _lc &lt;&gt; null then												// PAR #35397
			index := self.Index_DischargeTS;															// PAR #35397
		endif;
		
	endif;

	return index;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_lc" type="CM_VoyageController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
