    <JadeMethod name="rowHasKPIMoves" id="e3aba4e1-c101-4c96-b267-912144dfaa6c">
        <source>rowHasKPIMoves() : Boolean;
/*
Purpose:			
Parameters:			
Return Value:		

Date			Who		Reason
16 March 2009	cnwrd1	Initial creation par 18246
02/08/2011		cnwcs5	Tidy up when removing old KPI classes
17/08/2011		cnwcs5	CCMS MES 1033
*/

vars
	sheet	: Sheet;
	table	: CM_DataTable;
	row,col	: Integer;
	kpi 	: CM_KPIVoyageEntity;
	obj		: Object;
	result	: Boolean;
begin
	sheet := self.fldMain.topSheet;
	
	if sheet = self.shtMoves then
		table 	:= self.tblStats;
		row		:= table.row;
		
		if row &gt; table.fixedRows then 
			obj := table.accessRow (row).itemObject;
			
			if obj.isKindOf(CM_KPIVoyageEntity) then
				kpi := obj.CM_KPIVoyageEntity;
	
				if kpi &lt;&gt; null then
					if not kpi.allTrackedItems.isEmpty then
						result := true;
					endif;
				endif;
			endif;
		endif;
	else
		if sheet = self.shtROROMoves then
			table := self.tblROROMoves;
			
			return self.myROROMoveOutputAgent.tableHasTrackedItems (table, table.row, table.column);

		elseif sheet = self.shtRORODecks then
			table := self.tblRORODecks;
			
			return self.myRORODecKOutputAgent.tableHasTrackedItems (table, table.row, table.column);
		endif;		
	endif;
	
	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCaption" id="6e354b2c-13d7-4788-ab43-af44fc0bb40b">
        <updating/>
        <source>setCaption(_caption: String) updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 08/11/2012	cnwcs5	par 30519 - tidy up translations
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	voyage					: CM_Voyage;
	strMode, strCaption,
 	voyageCode				: String;
	intMode					: Integer;
begin
	voyage := self.myCurrentVoyage;
	
	if voyage &lt;&gt; null then 
		intMode := self.sdf01.viewMode;
		
		if intMode &lt;&gt; 1 then		// voyage mode
			strMode := app.getViewModeString(intMode);
		else
			strMode := app.getErrorString(No_Colours);
		endif;

		voyageCode := voyage.code.trimBlanks;
		strCaption := app.getErrorString2 (VoyageSideProfile, voyageCode, strMode);

		inheritMethod(strCaption); // adds on Terminal ID
		
		self.setNavigatorHeading(voyageCode); // NAVIGATOR
	else 
		// just use standard form caption
		self.translateCaption(Xlat_0017652, app.myCurrentLocale); 
		
		inheritMethod(self.caption); // adds on Terminal ID
		
		self.setNavigatorHeading (self.caption);
	endif;
epilog
	
end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="setCurrentVoyage" id="f6536ae5-456d-46fc-95d2-3063c1c4244e">
        <updating/>
        <source>setCurrentVoyage(_voyage : CM_Voyage) updating;
// ---------------------------------------------------------------------------
// Created:     24 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.myCurrentVoyage := _voyage;
	
	//epr par 24538 26/5/11 
	if self.myCurrentVoyage = null then
		return;
	endif;
	
	if self.myVoyageStats = null then
		create self.myVoyageStats transient;
	endif;
	self.myVoyageStats.init(_voyage);
	self.myVoyageStats.getStats(true);


end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
