    <JadeMethod name="setProxyWodCargoRequest" id="2b93c79c-8f53-4992-900d-f11f4e969a34">
        <source>setProxyWodCargoRequest(_voyage : CM_Voyage; _pxyCargoRequest : CM_WodCargoRequest input) :HMS_Berth;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 August 2018	jlger1	Initial creation

*/

vars
	cmifRKBM : CMIF_IPNRKBMDetailItem;
begin
	
	create cmifRKBM transient;
	self.setCMIF_ExternalWSProxy(cmifRKBM);
	
	_pxyCargoRequest.setProxyForInaportnet(cmifRKBM,_voyage);
	
	return cmifRKBM.getBerth;
epilog
	delete cmifRKBM;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_pxyCargoRequest" type="CM_WodCargoRequest" usage="input"/>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="validateDetails" id="c5047b4d-b66b-4058-a546-64159747cfaf">
        <source>validateDetails() ;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/04/2018	jlgdap1		Initial creation TFS 38135 PEL1 Inaportnet Integration (Web Service Provider)
//
vars
	cmifRKBM : CMIF_IPNRKBMDetailItem;
begin
	
	create cmifRKBM transient;
	self.setCMIF_ExternalWSProxy(cmifRKBM);
	
	cmifRKBM.validateDetails;
epilog
	delete cmifRKBM;
	

end;</source>
    </JadeMethod>
