    <JadeMethod name="isInThisTerminal" id="3f0fe9ab-6660-4bd8-90bf-6245e4ca288b">
        <source>isInThisTerminal(_terminalObj: CM_Terminal): Boolean;
// --------------------------------------------------------------------------------
// Created:		21 October 2009 by cnwdad1
//
// Purpose:		Refer to implementation on Object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.myTerminal = _terminalObj);
end;</source>
