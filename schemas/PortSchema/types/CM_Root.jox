        <updating/>
        <source>setupVoyStatusEmailDefaults() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
// 20/03/2018	jlgdap1		TFS 37540 PEL1 Voyage Statuses Pelindo 1
// 22/03/2018	jlgdap1		TFS 37544 PEL1 Voyage Statuses InaPortNet
// 28/11/2018	jlgdap1		TFS 37544 PEL1 Add missing INAPORTNET statuses and refactor
// 07/10/2021	jlizm1		TFS 51963 SAL Voyage Request Changes
// 06/09/2022	jlizm1		TFS 54298 EUP - Simplified Voyage Work Order Process
//
vars
	entTableDef		: EntTableDef;
	entTableRow 	: EntTableRow;
	sa				: StringArray;

begin
	create sa transient;
	entTableDef := self.myEntTableDataRoot.allEntTableDefs[ETDef_VoyageStatusEmail];
	foreach entTableRow in entTableDef.allEntTableRows do
		if entTableRow.name.isOneOf(ETRow_Code, ETRow_VesselCode, ETRow_Arrives, ETRow_Departs, ETRow_Status) then
			sa.add(entTableRow.getHeading(null, null, app.myCurrentLocale));
