    <JadeMethod name="zzGetOperator" id="09461212-2b37-4031-8b81-6774c07ec558">
        <source>zzGetOperator() : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2023	navpw1	Initial creation TFS: 60965

*/

vars
	currentTrackedItem	: CM_TrackedItem;
	operator			: CM_Operator;
	invalidObject		: Boolean;
	
begin
	// 11/11/2009 cnwmh5 PAR21548 - Start
	currentTrackedItem := self.trackedItem;
	
	if currentTrackedItem &lt;&gt; null then
		operator := currentTrackedItem.myOperator;
		if operator &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, operator, invalidObject);
			operator.edition;
			on Exception do null;
			
			if invalidObject then
				return null;
			endif;
			
			return operator.description;
			
		endif;
	endif;
	
	return null;
	
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="zzGetRate" id="26e8f703-8584-4c59-9da6-41b592d089a4">
        <source>zzGetRate() : Real protected;
/*
Purpose - 	
Who - NAVAB1
Date - 08APR2024
ADO -  CR 63369 TASK 63371 
*/

vars
	totalChargeRate : Real;
	allCharges		: CM_ChargeBySeqNumDict;
	charge			: CM_Charge;
	chargeRate 		: Real;
	
begin
	if self.quantity = 0 then
		return 0;
	else
		if self.isVolumeBased()then // ### TFS BUG 57729 28APR2023 NAVAB1
			totalChargeRate := self.getRate(); // ### TFS BUG 57729 28APR2023 NAVAB1 - this just does a sum lineTotal / quantity, for volume based charges the single CM_Charge might have create multiple other CM_Charges so a sum in this way is correct.
		else// ### TFS BUG 57729 28APR2023 NAVAB1
			//+TFS40454 Starts getting all total rates in all Invoice Lines adding up
			allCharges := self.charges;
			if allCharges.isNotEmpty then
				foreach charge in allCharges do
					chargeRate := charge.getRate();
					totalChargeRate := totalChargeRate + chargeRate;
				endforeach;
			endif;
		endif;
		
		if totalChargeRate &lt;&gt; null then
			return totalChargeRate;
		endif;
		
	endif;
	
	return 0;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="zzGetRateStr" id="e34f2dc3-d4be-47a5-bacb-ae7467c8dab1">
        <source>zzGetRateStr() : String protected;
/*
Purpose - 	
Who - NAVAB1
Date - 08APR2024
ADO -  CR 63369 TASK 63371 
*/

vars

begin
	return self.zzGetRate.asStringJMTWithPrecision(self.getRateEntryDecimalPlaces, true);
end;</source>
