        <Parameter name="_iconDownString" type="String"/>
        <Parameter name="_iconLocationString" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="90b94a24-f2e5-4021-841d-bd2ac7f51b3f">
        <source>validateForDelete(_passport: CM_Passport input);
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//
//----------------------------------------------------------

vars

begin
	inheritMethod(_passport);
	if (not self.allResources.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, self.description, "Resources", null, null);	
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="321e0b7f-3bd7-4831-becc-085e6d029440">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//----------------------------------------------------------

vars
	tmpResourceType	:	HMS_ResourceType;
	
begin
	inheritMethod(_passport);
	
	if self.code = null then
	//	app.raiseCMException1( REQUIRED_FIELD, 'Code', ETRow_Code, null );
		app.raiseCMException( Input_required_field_code, ETRow_Code, null ); // cnwdb2	PAR 35364
	endif;
	
	if self.description = null then
//		app.raiseCMException1( REQUIRED_FIELD, 'Description', ETRow_Description, null );
		app.raiseCMException( Input_required_field_Desc, ETRow_Description, null ); // cnwdb2	PAR 35364
	endif;
	
	if self.myRoot = null then
//		app.raiseCMException1( REQUIRED_FIELD , 'Harbour Root', null, null );
		app.raiseCMException( Input_required_field_harbRoot, null, null ); // cnwdb2	PAR 35364
	endif;
	
	
	if _passport.hasErrors then
		return;
	endif;
	
	
	tmpResourceType := self.myRoot.allResourceTypes.getAtKey(self.code);
	if tmpResourceType &lt;&gt; null then
		if self.isTransient and tmpResourceType &lt;&gt; self.pxyGetRealObject() then
			//app.raiseCMException2(DuplicateItem, 'Resource Type', self.code, ETRow_Code, null); //14.06.2022 navds20 53760
			// Resource Type already exists for %1 : Resourc_type_already_exists
			app.raiseCMException1(Resourc_type_already_exists, self.code, ETRow_Code, null);  //14.06.2022 navds20 53760
		endif;
	endif;

epilog


end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
