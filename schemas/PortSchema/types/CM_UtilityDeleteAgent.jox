    <JadeMethod name="utlDeleteTrade" id="5dc28d64-4bea-426f-bea5-4e722dd53f97">
        <source>utlDeleteTrade(pTrade : CM_Trade io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     12 May 2003 by cnwsgp1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
// ---------------------------------------------------------------------------
vars
	yaType : CM_YATypeVoyageTrade;

begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valTrade(pTrade);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(pTrade);
	endif;

	if _passport.noErrors then
		yaType := CM_YATypeVoyageTrade.firstInstance;
		if yaType &lt;&gt; null then
			yaType.removeMyDataObject(pTrade);
		endif;
		
		//21.09.2020 cnwma1 TFS #49906
		if _passport.isOpsViewEnabled(null) then
			pTrade.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_DELETE,
								 BGP_OpsViewWSRequest.OPS_TYPE_TRADE,
								 pTrade);
		endif;
		//21.09.2020 cnwma1 TFS #49906
		pTrade.erase(NORMAL_ERASE);
	endif;
end;</source>
        <Parameter name="pTrade" type="CM_Trade" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteTrain" id="fe6ea581-9a44-41a6-8745-a4ddea99218b">
        <source>utlDeleteTrain(	_train : CM_Train io;
				_allWagonsToDelete : CM_WagonSet;
				_isTrainConsist : Boolean;
				_isValidate : Boolean;
				_isInitialise : Boolean;
				_passport : CM_Passport input);
/*
----------  ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
	
----------  ----------  --------------------------------------------------
19/02/2010	cnwdad1		PAR #21330 - Added _allWagonsToDelete and _isTrainConsist
						parameters for EDI Train Consist.

28/07/2010	cnwdad1		PAR #25120, added parameter for calling "initialiseActivity".
*/
vars
	yaType : CM_YATypeTrain;
	
begin
	if _isInitialise then
		self.initialiseActivity();
	endif;
	
	app.setContinueCMExceptions(true);
	app.myValDA.valTrain(_train, _isTrainConsist, _allWagonsToDelete);
	
	if (not self.checkValidationWithPassport(_passport)) or _isValidate then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	if _passport.noErrors() then //+ cnwmd1, CCMS 1067, Par 19919
		self.myDeleteAuditAgent.audDeleteGeneric(_train);
	endif;

	if _passport.noErrors() then //+ cnwmd1, CCMS 1067, Par 19919
		yaType := CM_YATypeTrain.firstInstance();
		
		if yaType &lt;&gt; null then
			yaType.removeMyDataObject(_train);
		endif;
	endif;
	
	delete _train;
//	_train.erase(NORMAL_ERASE);
end;</source>
        <Parameter name="_train" type="CM_Train" usage="io"/>
        <Parameter name="_allWagonsToDelete" type="CM_WagonSet"/>
        <Parameter name="_isTrainConsist" type="Boolean"/>
        <Parameter name="_isValidate" type="Boolean"/>
        <Parameter name="_isInitialise" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
