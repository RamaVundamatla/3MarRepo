    <JadeMethod name="outputAsCSV" id="82f16dff-34e9-4adb-9890-97e005dfddc9">
        <source>outputAsCSV(_header : Boolean) : String;
/* ---------------------------------------------------------------------------
Created:     03 March 2009 by cnwrs2

Purpose:     Quick export so can load into another database
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
constants
	Seperator	= ',';
	
vars
	str		: String;
	
begin

	if _header then
		return 'Code'.csvFormat() &amp; Seperator &amp;
			   'Description'.csvFormat() &amp; Seperator &amp;
			   'AlternateCode'.csvFormat() &amp; Seperator &amp;
			   'Color'.asStringJMT.csvFormat();
	endif;
	
	return self.code.csvFormat() &amp; Seperator &amp;
		   self.description.csvFormat() &amp; Seperator &amp;
		   self.alternateCode.csvFormat() &amp; Seperator &amp;
		   self.colour.asStringJMT.csvFormat();
		   
epilog

end;</source>
        <Parameter name="_header" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="fbfc3db9-0c88-48a9-8bd0-f558f252db38">
        <source>pxyCreateUpdateProxy(): SelfType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 12/05/2015	cnwdap1		Initial creation PAR #36206 TFS 324/334 Graphical Representation of Hazard Class
//
vars
	pxyHazardClass : CM_HazardClass;
	completedOK : Boolean;

begin
	pxyHazardClass := inheritMethod();
	
	if self.myDrawingAttribute &lt;&gt; null then
		pxyHazardClass.myDrawingAttribute := self.myDrawingAttribute.pxyCreateUpdateProxy();
	endif;
	
	completedOK := true;
	return pxyHazardClass;

epilog
	if not completedOK then
		delete pxyHazardClass;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="refreshHazardMoveDetails" id="ed2194b3-5312-4814-92c8-d559d3d9e6f5">
        <source>refreshHazardMoveDetails(_ruleType : Integer; _terminal : CM_Terminal);
/*
----------   ----------  --------------------------------------------------
Created:	28 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	hazardMoveDetail		: CM_HazardMoveDetail;
	segRule					: CM_SegregationRule;
	segRuleDict				: CM_SegRuleByTypeEntity1Entity2;
	iter					: Iterator;
	ruleTypeKey				: Integer;
	entity1Key,
	entity2Key				: CM_Object;
begin
	hazardMoveDetail := self.allHazardMoveDetails[_ruleType];
	delete hazardMoveDetail;
	
	segRuleDict := _terminal.allSegRulesByEntity1Entity2;
	iter := segRuleDict.createIterator;
	segRuleDict.startKeyGeq(_ruleType, self, null, iter);
	
	while iter.next(segRule) do
		segRuleDict.getIteratorKeys(ruleTypeKey, entity1Key, entity2Key, iter);
		if ruleTypeKey &lt;&gt; _ruleType or entity1Key &lt;&gt; self then
			break;
		endif;
		
		if hazardMoveDetail = null then
			create hazardMoveDetail persistent;
			hazardMoveDetail.setRuleType(_ruleType);
		endif;
		
		hazardMoveDetail.updateFromCondition(segRule.mySegregationCondition, self);
	endwhile;
	
epilog
	delete iter;
end;


</source>
        <Parameter name="_ruleType" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
