<Class name="CnEcHelpTime" id="84ec1d49-7375-4a46-84e8-89df4ef00b8c">
    <superclass name="CnEcHelpEntity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
