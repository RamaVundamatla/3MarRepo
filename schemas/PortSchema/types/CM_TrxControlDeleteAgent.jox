    <JadeMethod name="trxDeletePackage" id="85fcbe4c-2129-4f2b-b2f2-f7b1d7f3339d">
        <updating/>
        <source>trxDeletePackage(_package : CM_Package io; _passport : CM_Passport input) updating;
// Nov 2011 CPL CCMS 2120
vars
	autoTask : CM_AutoTask;
	autoSchedule : CM_AutoSchedule;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	if _package.isKindOf(CM_PackageInvoice) then
		foreach autoTask in _package.allTasks do
			foreach autoSchedule in autoTask.allAutoSchedules do
				app.myUtilityDA.utlDeleteAutoSchedule(autoSchedule, _passport);
			endforeach;
			app.myUtilityDA.utlDeleteAutoTask(autoTask, _passport);
		endforeach;
	endif;
	app.myUtilityDA.utlDeletePackage(_package, _passport);
epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_package" type="CM_Package" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
