    <JadeMethod name="cnEcUnqualName" id="8189043b-5a6a-43dc-9e78-baaeeff5df28">
        <source>cnEcUnqualName() :String;
// Return only the unqualified filename (after the FINAL "\").
vars
	charIndex	: Integer;
	lastCharPos	: Integer;

begin
	charIndex	:=	1;

	while charIndex &lt;&gt; 0 do
		lastCharPos	:=	charIndex;
		charIndex	:=	fileName.pos(global.cnEcGetFileSeparator(), (lastCharPos + 1));
	endwhile;

	return fileName[(lastCharPos + 1):end];	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
