    <JadeMethod name="validateReport" id="1405b860-7d52-4d5e-ab7a-f1e7c89648dc">
        <source>validateReport(_reportName : String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2010	cnwas3	Initial creation

*/
vars
	jrwManager	: JadeReportWriterManager;
	jrwReport	: JadeReportWriterReport;
	
begin
	if _reportName = null then
		return;
	endif;

	jrwManager := app.createReportWriterManager();
	
	jrwReport  := jrwManager.getReport(_reportName);
	
	if jrwReport = null then
		app.raiseCMException1(Report_not_found_letter_case, _reportName, null, null);
	endif;
	
epilog
	delete jrwReport;
	delete jrwManager;
end;</source>
        <Parameter name="_reportName" type="String"/>
    </JadeMethod>
</Class>
