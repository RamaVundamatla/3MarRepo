    <JadeMethod name="canBeDBLoaded" id="29d1bee9-148f-4cce-87c3-f8521a8f74c9">
        <source>canBeDBLoaded(): Boolean;
//
// 18 Jan 2018	cnwrs1	TFS 36357 STW process asynch web server files 
//
// 09 Apr 2018	jlgrs1	TFS 37990 POE Processing pack on Full containers
vars
	result 	:Boolean;
begin
	result := inheritMethod();
//	if not result then
//		result := self.status = CM_EDIFile.EDI_STATUS_LOADED;
//	endif;
	return result;
epilog

