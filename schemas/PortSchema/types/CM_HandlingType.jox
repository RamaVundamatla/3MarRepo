    <JadeMethod name="validateForCreate" id="2c40e45e-a381-4e12-b003-cf3d4ee3c793">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     01 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	
begin
	if app.myRoot.allHandlingTypes[self.id] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.id.String, null, null);
	endif;
	
	self.validateForUpdate;	

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="e5a93f65-1f4e-4238-9ed0-bc7e41185c70">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     01 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if not self.allProducts.isEmpty then
		app.raiseCMException2(ObjectStillHasEntries, self.id.String &amp; '  ' &amp; self.description, 
								self.allProducts.size.String, 
								"Products", 
								null);
	
	
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="68a4bbec-5abf-4108-82d6-44a9cf5f5b77">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     01 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	
	realObjForProxy	: CM_HandlingType;
	realObjFound	: CM_HandlingType;

begin
	self.raiseExceptionIfNotTransient(method);
	
	if self.id = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'id', 'id', null);
		app.raiseCMException(Input_required_field_Id, 'id', null);
	else
		realObjFound	:= app.myRoot.allHandlingTypes[self.id];
		realObjForProxy	:= self.pxyGetRealObject;
		if realObjFound &lt;&gt; null and realObjFound &lt;&gt; realObjForProxy then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.id.String, null, null);
		endif;
	endif;
	
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'description', 'description', null);
		app.raiseCMException(Input_required_field_Desc, 'description', null); // cnwdb2	PAR 35364
	endif;
/*	
	//the is the automatic end, so don't expect a myRoot
	if self.myRoot = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Root', 'Root', null);
		return;
	endif;
*/	

end;</source>
    </JadeMethod>
</Class>
