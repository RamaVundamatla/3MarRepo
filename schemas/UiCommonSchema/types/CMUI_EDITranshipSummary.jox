    <JadeMethod name="clearTable" id="504dde06-3ab7-4479-997a-67fc8f0d6a05">
        <source>clearTable(_table : CM_DataTable);

vars
	row : Integer;
	table : CM_DataTable;
begin
	table := _table;
	row := table.rows;
	while row &gt; 1 do
		table.deleteRow(row); // Remove empty rows.
		row := row - 1;
	endwhile;	
end;
</source>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="create" id="0367df61-5a38-4e4a-8172-eaedafa9daf1">
