    <JadeMethod name="getInterchangeAreaForPosition" id="3706c211-53e0-4f59-a164-5e23cdc88dfa">
        <source>getInterchangeAreaForPosition(_position : Integer) : CM_GantryInterchangeArea;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 July 2009	cnwer1	Initial creation

*/

vars	
	interchangeArea : CM_InterchangeArea;
begin
	foreach interchangeArea in self.allAssociatedInterchangeAreas discreteLock do
		if interchangeArea.isKindOf(CM_GantryInterchangeArea) and interchangeArea.CM_GantryInterchangeArea.interchangePosition = _position then
			return interchangeArea.CM_GantryInterchangeArea;
		endif;
	
	endforeach;

epilog

end;</source>
        <Parameter name="_position" type="Integer"/>
        <ReturnType type="CM_GantryInterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="getMaxRowLabel" id="1e58ef08-df72-4809-aa02-459028f43942">
        <source>getMaxRowLabel(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 Feb 2009	cnwjk3	SFW1030
03 Nov 2010 cnwer1	par 26189 - removed ref to rtgrow.isLane
*/

vars
	iter		: Iterator;
	row			: CM_RTGRow;
	maxLabel,	
	label		: String;
begin
	iter := self.allGridRows.createIterator();
	while iter.next(row) do
		if not row.hasGap then
			label := row.getLabel();
			if label = null then
				continue;
			endif;
			maxLabel := label;
		endif;
	endwhile;	
	return maxLabel;
epilog
	delete iter;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMinRowLabel" id="059e4614-ae72-4b8c-a0a2-ad6810894e3b">
        <source>getMinRowLabel(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 February 2009	cnwjk3	SFW1030
03 Nov 2010 cnwer1	par 26189 - removed ref to rtgrow.isLane
*/

vars
	iter		: Iterator;
	row			: CM_RTGRow;
	minLabel,	
	label		: String;
begin
	iter := self.allGridRows.createIterator();
	while iter.next(row) do
		if not row.hasGap then
			label := row.getLabel();
			if label = null then
				continue;
			endif;
			minLabel := label;
			break;
		endif;
	endwhile;	
	return minLabel;
epilog
	delete iter;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextRTGAreaInRTGLane" id="8fd4b1f0-1f21-4fec-8144-17a1ba669bd2">
        <source>getNextRTGAreaInRTGLane(): CM_RTGArea;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2009	cnwer1	Initial creation

*/

vars
	rtgLane : CM_RTGLane;
	ta	 : CM_TerminalArea;
	iter : Iterator;
begin
	rtgLane:=self.getRTGLane;
	if rtgLane = null then
		return null;
	endif;
	
	iter:=rtgLane.allTAsByTypeId.createIterator;
	iter.startAtObject(self);
	iter.next(ta);
	iter.next(ta);
	if ta = null then
		return null;
	endif;
	
	return ta.CM_RTGArea;
epilog
	delete iter;

end;</source>
        <ReturnType type="CM_RTGArea"/>
    </JadeMethod>
    <JadeMethod name="getPreviousRTGAreaInRTGLane" id="dadab561-57fc-4921-a9cb-223508c9a733">
        <source>getPreviousRTGAreaInRTGLane(): CM_RTGArea;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2009	cnwer1	Initial creation

*/

vars

	rtgLane : CM_RTGLane;
	ta	 : CM_TerminalArea;
	iter : Iterator;
begin
	rtgLane:=self.getRTGLane;
	if rtgLane = null then
		return null;
	endif;
	
	iter:=rtgLane.allTAsByTypeId.createIterator;
	iter.startAtObject(self);
	iter.back(ta);
	iter.back(ta);
	if ta = null then
		return null;
	endif;
	
	return ta.CM_RTGArea;
epilog
	delete iter;


end;</source>
        <ReturnType type="CM_RTGArea"/>
    </JadeMethod>
    <JadeMethod name="getRTGLane" id="7da4e12c-04f0-457d-bba6-59706ac6d4df">
        <source>getRTGLane(): CM_RTGLane;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2009	cnwer1	Initial creation

*/

vars
	taGroup : CM_TerminalAreaGroup;
begin
	//make an assumption are can only ever be in one rtg lane
	
	foreach taGroup in self.allTerminalAreaGroups do
		if taGroup.isKindOf(CM_RTGLane) then
			return taGroup.CM_RTGLane;
		endif;
	endforeach;
epilog

end;</source>
        <ReturnType type="CM_RTGLane"/>
    </JadeMethod>
    <JadeMethod name="getRowForLabel" id="7053cdb9-c546-483b-867e-023002aa216b">
        <source>getRowForLabel(pLabel : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     11 June 2009 by cnwjo3
//
// Purpose:     get the row number from label
//
// Returns:     row number
vars
	rtgRow	: CM_RTGRow;
begin
	rtgRow	:= self.allGridRowsByLabel[pLabel].CM_RTGRow;
	if rtgRow = null then
		return 0;
	endif;
	
	return rtgRow.row;
end;</source>
        <Parameter name="pLabel" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSideInterchangeAreaPosition" id="7a682c49-07c6-42dc-b661-f294a171f764">
        <source>getSideInterchangeAreaPosition():Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2009	cnwer1	Initial creation

*/

vars
	icPos : Integer;
	icArea : CM_InterchangeArea;
	gantryICArea : CM_GantryInterchangeArea;
begin
	icPos := self.ICPosition_NoSides;
	
	foreach icArea in self.allAssociatedInterchangeAreas do
		if not icArea.isKindOf(CM_GantryInterchangeArea) then
			continue;
		endif;
		gantryICArea:=icArea.CM_GantryInterchangeArea;
		if gantryICArea.interchangePosition = self.ICPosition_BeforeRow1 then
			if icPos = self.ICPosition_AfterLastRow then
				icPos:=self.ICPosition_BothSides;
				break;
			else
				icPos:=self.ICPosition_BeforeRow1;
			endif;
		elseif gantryICArea.interchangePosition =  self.ICPosition_AfterLastRow then
			if icPos = self.ICPosition_BeforeRow1 then
				icPos:=self.ICPosition_BothSides;
				break;
			else
				icPos:=self.ICPosition_AfterLastRow;
			endif;
		endif;
	endforeach;
	
	return icPos;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTypeCode" id="b606fdc7-0087-4b38-88af-d74400536e04">
