    <JadeMethod name="setOppositeOrientation" id="89f3f5d2-2dab-4d78-bc90-255a44cbb0e8">
        <updating/>
        <source>setOppositeOrientation() updating;
/*
Purpose:			
Date		Who		Reason
30 September 2011	cnwab1	Initial creation
*/

vars

begin
	if self.orientation = ROROLocn_OOTL_AF then
		self.orientation := ROROLocn_OOTL_PS;
	elseif self.orientation = ROROLocn_OOTL_PS then
		self.orientation := ROROLocn_OOTL_AF;
	elseif self.orientation = ROROLocn_PortStarboard then
		self.orientation := ROROLocn_AftForward;
	elseif self.orientation = ROROLocn_AftForward then
		self.orientation := ROROLocn_PortStarboard;
	else
		self.orientation := ROROLocn_AftForward;
	endif;
epilog

end;</source>
    </JadeMethod>
