    <JadeMethod name="showHidePostConfMnu" id="a085463c-0649-48c9-b2c3-0a1533417752">
        <source>showHidePostConfMnu();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 June 2023	navcs2	ChangeRequest 58433: [58454]: EUP | TAS Invoicing - Invoice Posting Confirmation Message

*/

vars
	extDef			: CM_ExternalWebServiceDef;
begin
	extDef := app.myRoot.getFirstActiveEWSForEndpoint(ETRow_PostConfirmInvoice);
	
	if extDef &lt;&gt; null then
		self.mnuInvoicePostConf.visible := true;
	else
		self.mnuInvoicePostConf.visible := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showInvoiceLinesForm" id="da59afdc-5305-45ec-82be-38cf8816b155">
        <source>showInvoiceLinesForm(_obj : CM_Object);
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	invoiceForm 	: Form; 
	menuAction 		: CMUI_MenuAction;
begin
	if _obj = null then
		app.msgBox("Please select an invoice/invoice line.","Show invoice items error",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	menuAction := app.myController.createMenuAction(PmAdmInvoicelinesView, null, self.myMasterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	invoiceForm := menuAction.goToObject(null, null, false, null); 
	if invoiceForm = null then
		return;
	endif;
	if _obj.isKindOf(CM_Invoice) then
		invoiceForm.INV_ListLines.myCurrentInvoice := _obj.CM_Invoice;
	else
		invoiceForm.INV_ListLines.myCurrentInvoiceLine := _obj.CM_InvoiceLine;
	
	endif;
	invoiceForm.show();

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="showInvoiceNotesForm" id="f96ad12b-baef-4946-9132-11b200f894f5">
        <source>showInvoiceNotesForm(_obj:CM_Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
09 Feb 2022	navtnr20	Initial creation	52771.020
14 Mar 2022 navma1		Bug 53073: MTN - Invoice Notes Form Modality (in conjunction with Audits)
*/

vars
	frm : INV_InvoiceNote;
begin

	app.mousePointer := MP_HOURGLASS;

	create frm;
	frm.myCurrentInvoice  := _obj.CM_Invoice;
	frm.myCurrentNote 	  := _obj.CM_Invoice.myInvoiceNote; 
	frm.myTerminal 		  := self.myTerminal;
	
	frm.createMyAssistant(INV_Assistant);
	
	frm.show;

epilog
	app.mousePointer := MP_DEFAULT;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="showInvoicePropFrame" id="d5b3cbcb-614a-437e-a921-60f023628635">
        <updating/>
        <source>showInvoicePropFrame(_entTableView : String) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
// ---------------------------------------------------------------------------
// 01 Apr 2022	jlier1	TFS 53286
vars
	obj	: Object;
	theTable : CM_EntryTable;
	theFrame, theTableFrame : Frame;
	isMultiPost	: Boolean;
	count	  : Integer;
	message	  : String;
	entTableDef	: EntTableDef;
	entTableView : EntTableView;
	finIO:   CM_ExtFinanceIO;
begin
	if _entTableView = null then
		return;
	endif;

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		// TFS 39618 PATCH 1 if app.myCurrentUserCan(self.myTerminal, PmAdmInvoiceStatusVoid) and _entTableView = ETView_InvListInvPropVoid then
		// TFS 39618 PATCH 1 elseif app.myCurrentUserCan(self.myTerminal, PmAdmInvoiceStatusPost) and _entTableView = ETView_InvListInvPropPost then
		
		if self.myCurrentBank.userCanSet(CM_Invoice.INVOICE_VOID) and _entTableView = ETView_InvListInvPropVoid then  // TFS 39618 PATCH 1 
		elseif self.myCurrentBank.userCanSet(CM_Invoice.INVOICE_POSTED) and _entTableView = ETView_InvListInvPropPost then  // TFS 39618 PATCH 1 
		
		else
			return;
		endif;
	endif;

	self.currentView := _entTableView;
	
	
	if self.myCurrentInvoice = null 
	and self.currentView &lt;&gt; ETView_InvListInvPropNew then
		app.msgBox(app.getErrorString(INV_Please_Select_An_Invoice),app.getErrorString(INV_Invoice_Update_Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	theFrame := self.frmInvProperties;
	theTableFrame := self.frmInvPropParent;
	theTable := self.tblInvProperties;
	theTable.clearValues();
	//epr par 36958 29/9/15
	entTableDef:= theTable.myEntTableDef;
	entTableView:=entTableDef.allEntTableViews[self.currentView];
	theTable.setEntTableFromView(entTableDef,entTableView,null,null);
	
	finIO := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;	
	if finIO &lt;&gt; null and finIO.isKindOf(CM_SALInterface) then
		theTable.hideRowByName(ETRow_Export,false);
	elseif finIO &lt;&gt; null and finIO.isKindOf(CM_POBFinanceOneInterface) then //jlier1 TFS 56856 31/3/23
		theTable.hideRowByName(ETRow_Export,false);
	elseif finIO &lt;&gt; null and finIO.isKindOf(CM_InvoiceAPI) then 										//navra1 - TFS 54090 CR - 61386/Task - 61564 - 4th Dec 2023
		theTable.showRowByName(ETRow_InvoiceDate,false);												//navra1 - TFS 54090 CR - 61386/Task - 61564 - 21st Dec 2023
		if self.myCurrentInvoice.status = CM_Invoice.INVOICE_POSTED_PENDING then						//navra1 - TFS 54090 CR - 61386/Task - 61564 - 4th Dec 2023
			theTable.setValueByName(ETRow_Export, false);												//navra1 - TFS 54090 CR - 61386/Task - 61564 - 4th Dec 2023
			theTable.disableRowByName(ETRow_Export);													//navra1 - TFS 54090 CR - 61386/Task - 61564 - 4th Dec 2023
		else																							//navra1 - TFS 54090 CR - 61386/Task - 61564 - 4th Dec 2023
			theTable.setValueByName(ETRow_Export, true);												//navra1 - TFS 54090 CR - 61386/Task - 61564 - 4th Dec 2023
			theTable.disableRowByName(ETRow_Export);													//navra1 - TFS 54090 CR - 61386/Task - 61564 - 4th Dec 2023
			if app.myCurrentUserCan(self.myTerminal, PmInvoiceAdmin) then								//navra1 - TFS 54090 CR - 61386/Task - 61564 - 4th Dec 2023
				theTable.enableRowByName(ETRow_Export);													//navra1 - TFS 54090 CR - 61386/Task - 61564 - 4th Dec 2023
			endif;																						//navra1 - TFS 54090 CR - 61386/Task - 61564 - 4th Dec 2023
		endif;																							//navra1 - TFS 54090 CR - 61386/Task - 61564 - 4th Dec 2023
	endif;
	
	// Par 23341 multi-select posting
	if  (self.currentView = ETView_InvListInvPropPost or 
		 self.currentView = ETView_InvListInvPropPostASPA) and //22.07.2019 cnwma1 TFS #45577
	   self.tblData.allSelectedObjects.size &gt; 1 then
		isMultiPost := true;
		self.displayPostTable();
	else
		self.displayInvoice();
	endif;
	
	// 23341 multi-select posting
	if isMultiPost then
		self.lblMulti.top := self.frmInvToolbar.height + 5;
		self.lblMulti.width := theTableFrame.width - 5;
		foreach obj in self.tblData.allSelectedObjects do
			count := count + 1;
		endforeach;
		//message := "You have selected " &amp; count.asStringJMT &amp; " invoices to be posted.  The following data will be updated to all selected invoices.";
		message := app.getErrorString1(Selected_Invoices_To_Post, count.asStringJMT);
		self.lblMulti.caption := message;
		self.lblMulti.visible := true;
		theTableFrame.top := self.frmInvToolbar.clientHeight + self.lblMulti.top + 30;
	else
		self.lblMulti.visible := false;
		theTableFrame.top := self.frmInvToolbar.clientHeight + 5;
	endif;
	// end 23341

	self.resizeInvPropFrame();
	
	theFrame.visible := true;
	self.frmToolbar.enabled := false;
	theTable.setFocus();
	theTable.moveFirst();
	
	
epilog
	// TFS 2198 CNWAB1
	if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		//epr par 37356 14/1/16
		if self.currentView &lt;&gt; ETView_InvListInvPropUpdate then
			self.tblData.enabled:=false;
		endif;

	endif;

	self.btnQuery.enabled := false;
end;</source>
        <Parameter name="_entTableView" type="String"/>
    </JadeMethod>
    <JadeMethod name="showPermissionValues" id="928b0fa2-85d3-4a26-ac60-ec6f59ff8824">
        <source>showPermissionValues();
/*

Purpose:

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2019	jlgab1	Initial creation

*/

vars
	permsArray	: IntegerArray;
	permAgent	: CM_PermissionAgent;
	theCaption	: String;
begin

	create permsArray transient;
	permsArray.add(self.permissionView);
	if self.permissionView &lt;&gt; self.permissionMaint then
		permsArray.add(self.permissionMaint);
	endif;
	
	self.getExtraPermissions(permsArray);
	
	theCaption := self.caption;
	if app.isSpecial then
		theCaption := self.class.name &amp; ': ' &amp; self.caption;
	endif;
	create permAgent transient;
	
	permAgent.setInvoiceStatuses(self.myTerminal);
	
	permAgent.showPermDetails(theCaption, permsArray, app.getMyUser, self.myTerminal);
	
epilog
	delete permsArray;
	delete permAgent;

end;</source>
    </JadeMethod>
    <JadeMethod name="showRatesORFrame" id="68076caa-7bce-4639-9423-40a75880e4df">
        <source>showRatesORFrame();
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 11 Apr 2017	cnwma1	TFS 3852 ADP - Negative Invoice Rate Lines
// ---------------------------------------------------------------------------

vars
	theTable : CM_DataTable;
	theFrame, theTableFrame : Frame;
	theHeight : Integer;
begin
	self.txtRateOR.text := null;
	self.txtRateOR.dataType := TextBox.DataType_SignedNumeric;  //11/04/2017 cnwma1 TFS #3852
	self.txtRateOR.bubbleHelp := "New Overriding Rate";
	theFrame := self.frmRatesOR;
	theTableFrame := self.frmRateTableFrm;
	theTable := self.tblRatesOR;
	theTable.rows := theTable.fixedRows;
	
	if self.myCurrentInvoice = null then
		app.msgBox(app.getErrorString(INV_Please_Select_An_Invoice),app.getErrorString(INV_Invoice_Update_Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.displayRates();
	
	theHeight := (theTable.rows * 16);
	
	if theHeight &lt; 100 then
		theHeight := 100;
	endif;
	if theHeight &gt; 500 then
		theHeight := 500;
	endif;
	theTable.height := theHeight;

	theTableFrame.height := theHeight;
//	self.frmInvPropParent.bevelInnerWidth := 2;
	theTableFrame.width := theFrame.clientWidth - 10;
	theTableFrame.left := 5;	
	theTableFrame.top := self.frmRatesToolbar.clientHeight + 5;


	theTable.width := theTableFrame.clientWidth;
	theTable.left := 0;
	theTable.top := 0;

	theFrame.height := self.frmRatesToolbar.height + theHeight + 30;
	theFrame.zOrder(1);
	theFrame.centreWindow();
	self.txtRateOR.setFocus;
	theFrame.visible := true;
	self.frmToolbar.enabled := false;
end;</source>
    </JadeMethod>
