    <JadeMethod name="setupForm" id="7b7e9f9e-2454-4dfe-829a-665b0d335b3e">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin

	inheritMethod();
	
	self.optPortrait.value:=true;
	self.optNormalSize.value:=true;
	self.showPrinterName();
	self.borderStyle:=Form.BorderStyle_Single;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showPrinterName" id="ae1c10a8-011c-4e75-89b1-fbbf69809a98">
        <source>showPrinterName() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2011	cnwer1	Initial creation CCMS 1025

*/

vars

begin
	self.picPrinter.bubbleHelp := app.getErrorString1(PRINT_MESS_PT1, app.printer.getPrinterName() ) &amp; Cr &amp;  app.getErrorString(PRINT_MESS_PT2);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7f80741d-9ea5-4977-ae35-15b663070a82">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 02 August 2018 09:47:37.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022874, locale);
	chkPrintPreview.translateCaption(Xlat_0017086, locale);
	grpOrientation.translateCaption(Xlat_0017087, locale);
	grpReport.translateCaption(Xlat_0017088, locale);
	grpScaling.translateCaption(Xlat_0017089, locale);
	optFitToPage.translateCaption(Xlat_0017090, locale);
	optLandscape.translateCaption(Xlat_0017091, locale);
	optNormalSize.translateCaption(Xlat_0017092, locale);
	optPortrait.translateCaption(Xlat_0017093, locale);
end;</source>
    </JadeMethod>
</GUIClass>
