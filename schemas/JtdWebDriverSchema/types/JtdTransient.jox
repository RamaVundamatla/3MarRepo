    <DbClassMap file="Jtd"/>
    <JadeMethod name="create" id="a8813e0a-d7e6-4df5-8c92-b61465c9c78f">
        <updating/>
        <source>create() updating;

begin
	if not self.isTransient then
		app.jtdMyContext.jtdRaiseJtdException(JtdExCannotCreatePersistent);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="jtdResumeNextExHandler" id="6f6dc405-67b3-49f0-814d-239cf4e3fb33">
        <source>jtdResumeNextExHandler(exObj : Exception; errNo : Integer output) : Integer protected;

begin
	errNo := exObj.errorCode;
	return Ex_Resume_Next;
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="errNo" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
