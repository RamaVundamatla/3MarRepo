    <JadeMethod name="hmsSetMovementsToActual" id="da0339b9-b297-4eb5-a00b-2a360d89e8f6">
        <source>hmsSetMovementsToActual(_voyage : CM_Voyage);
/*
Purpose:			
Date		Who		Reason
05 January 2015	NAVAB1	Initial creation
*/

vars
	movement : HMS_Movement;
begin
	// set the move status so invoicing will take place
	beginTransaction;
	foreach movement in _voyage.myHMSVoyageData.allVoyageMovements do
		movement.setPropertyValue("moveStatusNEW", MovementStatus_Actual);
	endforeach;
	commitTransaction;

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="instantMove" id="6a2e58e7-6599-40df-8d5b-56910d523ad7">
        <source>instantMove(_ti : CM_TrackedItem; _targetLocn : CM_LocationsController);
//	based on SHP_VoyageOpsForm doDischarge/doLoad - if to ship the target location is the ship block stack otherwise is a yard location
//
vars
	moveController : CMIF_MoveController;
begin

	create moveController transient;
	
	//08/12/2023	navkc1 ChangeRequest 58261 Task 61101 - Option to backdate
	if self.opts.includesKey("effectiveTS") then
		moveController.setEffectiveTimeStampOverride(self.opts.timestamp("effectiveTS"));
	endif;
	
	moveController.setMyTrackedItem(_ti);	
	moveController.setMyOriginatingLocation(_ti.myPrimaryActualLocation);
	moveController.setMoveMode(0);			// instant
	moveController.setMyToPrimaryLocation(_targetLocn);
	moveController.transferType := VESSEL_TYPE_LOLO; // NAVAB1 MAY17 0; TFS 4435
	moveController.isNonCraneVoyageMove := true;
	moveController.nonWorkedInstantPreMove();

	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete moveController;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_targetLocn" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="invoiceLineReevaluate" id="dfebce29-9b33-41de-989b-645a047ec18c">
        <source>invoiceLineReevaluate(_lines : ObjectArray);
// pass in an array of CM_InvoiceLines to be re-evaluated
vars
	invs 		: CM_InvoiceLineBySeqNumDict;
	invLine     : CM_InvoiceLine;
	controller  : CMIF_InvoiceLineReeval;

begin
	if _lines = null then
		return;
	endif;

	create invs transient;
	_lines.copy(invs);
	create controller transient;
	controller.reEvaluate := true; //16.09.2024 namva1

	foreach invLine in invs where invLine.status = CM_InvoiceLine.STATUS_NORMAL do
		controller.allInvoiceLines.add(invLine);
	endforeach;
	
	app.myTrxUA.trxUpdateInvoiceLineReeval(controller, app.myPassport);
epilog
	delete controller;	 
	delete invs;
end;
</source>
        <Parameter name="_lines" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="isDeleted" id="852eea0d-51e6-43a6-ad41-ddf32fc3a2a3">
        <source>isDeleted( _obj : Object ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2019	jlgndl1	Initial creation	TFS 44774

*/

vars

	isDeleted : Boolean;
	edition : Integer;

begin

	if _obj &lt;&gt; null then

		on Exception do app.handleDeletedObject( exception, _obj, isDeleted );
		edition := _obj.edition;
	
	endif;

epilog

	return isDeleted;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTransNeedReSync" id="9a26f409-18a0-471e-80aa-548d261cdf2d">
        <source>isTransNeedReSync(_transaction : CM_TITransaction):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 August 2017	jlgma1	TFS #5725 QNS - System Performance issues

*/
vars
	aSBController : CMIF_ServiceBroker;
	bank : CM_Bank;
begin

	bank := _transaction.getBusinessUnitObject();
	
	if bank = null then
		return false;
	endif;

	create aSBController transient;
	aSBController.myTransaction := _transaction;
	aSBController.myBank := bank;
	
	if bank.terminal.getConfig(InvUseInvoiceCargoAlloc).Boolean then 
		aSBController.isInvoiceCargoAllocation := true;
		bank.getInvoiceLineDescForTIAlloc(aSBController);
		
		if aSBController.allInvoiceLineTypes.isEmpty() then // nothing for allocations so try transaction map
			aSBController.isInvoiceCargoAllocation := false;
			bank.getInvoiceLineDescForCargo(aSBController);
		endif;
	else
		bank.getInvoiceLineDescForCargo(aSBController);
	endif;
	
	if aSBController.allInvoiceLineTypes.size &gt;1 then
		return true;
	
	elseif aSBController.allInvoiceLineTypes.size = 1 then
		if aSBController.allInvoiceLineTypes.first.CM_InvoiceLineDesc.isVoid then
			return false;
		else
			return true;
		endif;
	endif;
	
	return false;
	
epilog
	delete aSBController;
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="landerLoad" id="9e82a2a6-6e6d-4ce0-bc48-3cfd2d2b2670">
        <source>landerLoad(_ti: CM_TrackedItem; _destination: CM_LocationsController);
//02 September 2008	cnwdw1	
// Instant move the ti to _destinmation, and unqueue any future moves
vars
	moveController	: CMIF_MoveController;
	wle : CM_WorkListEntry; 
	rtQueEntry : CM_RTQueueEntry;
	futureMove : CM_FutureMove;
begin

	create moveController transient;
	moveController.setMyTrackedItem(_ti);
	moveController.setMyToPrimaryLocation(_destination);
	moveController.setMoveMode(REAL_MODE);
	if _ti.allWorklistEntries.size &gt; 0 then
		wle := _ti.allWorklistEntries.first;
		moveController.setMyWorkListEntry(wle);
		if not wle.allRTQueueEntries.isEmpty then
			rtQueEntry := wle.allRTQueueEntries.last;
		endif;
		if rtQueEntry &lt;&gt; null then
			moveController.isRTMultiMove := true;
			moveController.myRTQueueEntry := rtQueEntry;
			moveController.isRTPickupTask := false;
			moveController.setJobForMove(wle.job);
			moveController.isRadioTelemetryMove := true;
			futureMove := wle.myFutureMove;
		endif; 
	endif;
		
	app.myTrxUA.trxMoveTrackedItemAndUnQueue(moveController, futureMove, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;

epilog
	delete moveController;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_destination" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="loadAllJobsToOps" id="aa2b947a-1a5f-43e3-947e-89bd08e038b1">
        <source>loadAllJobsToOps(_voyage: CM_Voyage; _load : Boolean);
vars
	theProxyJob, job : CM_Job;
	loadState : Boolean;
begin
	foreach job in _voyage.allVoyageJobs  discreteLock do
		if job.CM_VoyageJob.isHatchLidJob() then
			continue;
		endif;
		
		self.loadVoyJobToOps(job.CM_VoyageJob, _load, false);
		/*
		app.cmsBeginLoad(loadState);
		theProxyJob := job.pxyCreateUpdateProxy();
		app.cmsEndLoad(loadState);

		app.myTrxUA.trxUpdateVoyageJobLoadUnload(theProxyJob.CM_VoyageJob, _load, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		*/
	endforeach;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_load" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadTranMap" id="22596200-eb13-4acc-a13c-4a2367fb6eca">
        <source>loadTranMap(_fileContent, _fileName, _mapName : String) : CM_TranMap;

/*

Purpose:		Load a Transaction Map

Date			Who		Reason
20/03/2013		cnwmh5	Initial creation

*/

vars

	bank		: CM_Bank;
	cargoMap	: CM_TranMap;

begin

	self.transactionMapLoad(_fileContent, _fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[_mapName];
	self.assertNotNullMsg(cargoMap, "cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return cargoMap;

epilog

end;</source>
        <Parameter name="_fileContent" type="String"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_mapName" type="String"/>
        <ReturnType type="CM_TranMap"/>
    </JadeMethod>
    <JadeMethod name="loadVoyJobToOps" id="26151420-7019-4e54-8404-21b948dfe4f3">
        <source>loadVoyJobToOps(_job: CM_VoyageJob; _load : Boolean; _ignoreWarnings : Boolean );
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	theProxyJob : CM_Job;
	loadState : Boolean;
begin
	if _job.CM_VoyageJob.isHatchLidJob() then
		return;
	endif;
	
	if _job.isLoadedToOperations = _load then // it is already what we want it to be
		return;
	endif;
	
	app.cmsBeginLoad(loadState);
	theProxyJob := _job.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);

	if not _ignoreWarnings then
		app.myTrxUA.trxUpdateVoyageJobLoadUnload(theProxyJob.CM_VoyageJob, _load, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	else
		
		while true do
			app.myTrxUA.trxUpdateVoyageJobLoadUnload(theProxyJob.CM_VoyageJob, _load, app.myPassport);
			if app.myPassport.trxCompletedOK then
				break;
			else
				if app.myPassport.noErrors then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
		
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsAndWarnsFullAsStr());
		
	endif;
epilog
	app.cmsEndLoad(loadState);			// 08/04/2011 cnwmh5 #27347
	delete theProxyJob;
end;</source>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_load" type="Boolean"/>
        <Parameter name="_ignoreWarnings" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="machineAcceptSpecifiedTask" id="946d0bbe-bf9b-4531-a04d-7599ff90c5a7">
        <source>machineAcceptSpecifiedTask(_machine: CM_Machine input; _task: CM_RTQueueEntry input) protected;
//07 January 2009	cnwdw1	
/* Changes

Date		Name	TFS#		Description
============================================================================
20 January 2020	jlgka1 TFS 47394 - Tandem Movement Enhancement. Revert code back before the Tandem Movement changes.
============================================================================*/
vars

begin

	

	app.myTrxUA.trxMachineAcceptTask(_machine,_task.allTasks.first,
									null,					   
								   null ,									   
								   app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_task" type="CM_RTQueueEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="machineAcceptSpecifiedTwinTask" id="151b9134-8dea-4a53-8a0f-e517540290e6">
        <source>machineAcceptSpecifiedTwinTask(_machine: CM_Machine input; _task, _taskTwin: CM_RTQueueEntry input) protected;
//07 January 2009	cnwdw1	
/* Changes

Date		Name	TFS#		Description
============================================================================
20 January 2020	jlgka1 TFS 47394 - Tandem Movement Enhancement. Revert code back before the Tandem Movement changes.
============================================================================*/

vars
	task,
	twinTask : CM_RTQueueTask;
begin
	
	if _taskTwin &lt;&gt; null then
		twinTask:=_taskTwin.allTasks.first;
	endif;
	
	app.myTrxUA.trxMachineAcceptTask(_machine,_task.allTasks.first,
									twinTask,								   
								   null ,									   
								   app.myPassport);
	
	
	self.assertNoTrxErrorsOrWarnings();
epilog
end;</source>
