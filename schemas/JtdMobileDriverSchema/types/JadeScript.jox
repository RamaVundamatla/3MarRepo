    <JadeMethod name="jhpPfm" id="53f3669f-052f-4e3c-8aa6-c64040bfd3bd">
        <updating/>
        <source>jhpPfm() updating;
vars
	oldWay:Boolean;
	dts,dte,dt3:Decimal[19];
	s,t,u,v,tempString1:String;  i,j,k,l,base,reps,mag:Integer;
	gh:JmtGenerationHelper; sa:StringArray;
begin
	write CrLf&amp;"Starting...";
	reps:=1000;
	app.initialize;
	create gh;
	create sa transient;
	sa[4000]:="a";

	oldWay:=true;
	dts:=app.relativeMachineTime;
	foreach i in 1 to reps do
		if oldWay then
//			gh.repeatable:=true;  s:=gh.repeatable.String;
			//s:=sa.size.String;
			//foreach j in 1 to 10 do
			foreach j in 3990 to 4000 do
				s:=sa[j];
			endforeach;
		else
//			gh.setPropertyValue("repeatable",true);  s:=gh.getPropertyValue("repeatable").String;
		endif;
	endforeach;
	dte:=app.relativeMachineTime;
	write "&lt;"&amp;s&amp;"&gt;"&amp;"&lt;"&amp;t&amp;"&gt;";
	write ((dte-dts)/reps).roundedTo(3).String&amp;" ms/rep";

/*
			s:=t; s:=s&amp;u; s:=s&amp;v; s:=s&amp;w; s:=s&amp;x;
			s:=t&amp;u&amp;v&amp;w&amp;x;
	d2:=12345.60;
			d:=d2 mod 100;
			d:=d2 mod 100;
			d:=d2 mod 100;
			d:=d2 mod 10^2;
			d:=d2 mod 10^2;
			d:=d2 mod 10^2;
	r:R_Dhout;
	create r transient;
	r.a_diexm_thsbrnchno:=1234;
	r.a_diexm_thsaccntno:=12345678;
			tempString1:=r.sd_hash.pad(11,0);
			glb.complexMove(r.a_diexm_thsbrnchno.pad(4), 1, 4, 4, tempString1, 1, 11);
			r.sd_hash:=tempString1.Decimal;
			tempString1:=r.sd_hash.pad(11,0);
			glb.complexMove(r.a_diexm_thsaccntno.pad(8), 2, 7, 8, tempString1, 5, 11);
			r.sd_hash:=tempString1.Decimal;
			r.sd_hash:=r.a_diexm_thsbrnchno*10000000.0+r.a_diexm_thsaccntno mod 10000000;  // jhp 010215 pfm
	write r.sd_hash;
//			glb.setDcDate(s, 0, "CCYYMMDD", null, false);
//			k := glb.dc_daynum;
			glb.setDcDate(k.String, 0, "DAYNUM", null, false);
			s := glb.dc_yymmdd.pad(6);

//			dd.setDate(s[7:2].Integer,s[5:2].Integer,s[1:4].Integer);
//			k:=dd-glb.baseDate;
			dd:=glb.baseDate+k;
			s:=dd.format("yyMMdd");

			glb.gd_cdvstr:="123456789012345678";
			s:=glb.gd_cdvstr;
	write "&lt;"&amp;glb.gd_dgt1.String&amp;glb.gd_dgt2.String&amp;glb.gd_dgt3.String&amp;glb.gd_dgt4.String&amp;glb.gd_dgt5.String&amp;glb.gd_dgt6
	.String&amp;glb.gd_dgt7.String&amp;glb.gd_dgt8.String&amp;glb.gd_dgt9.String&amp;glb.gd_dgt10.String&amp;glb.gd_dgt11.String&amp;glb.gd_dgt12
	.String&amp;glb.gd_dgt13.String&amp;glb.gd_dgt14.String&amp;glb.gd_dgt15.String&amp;glb.gd_dgt16.String&amp;glb.gd_dgt17.String&amp;glb.gd_dgt18.String&amp;"&gt;&lt;&gt;";
	write glb.gd_four;
	write glb.gd_eight;


	ASBLincScreen.profStart and profReport:

	process.profilerStart;
	process.profilerReport(process.persistentApp.name
							&amp;"_"&amp;app.activeForm.name[3:end]
							&amp;"_"&amp;app.actualTimeAppServer.date.format("yyMMdd")
							&amp;"_"&amp;app.actualTimeAppServer.time.format("HHmmss")&amp;".log");
*/
epilog
	delete gh;
	delete sa;
	write "Finished";
end;</source>
    </JadeMethod>
    <JadeMethod name="jhpRunRTApp" id="4db1448d-0fe9-4de0-ae46-562d3980242c">
        <source>jhpRunRTApp();

vars
	i,j:Integer; s,t:String;
	tran:JmtTransactionGenerator;
begin
	app.atcgRunningAtcg:=true;
	app.controlLockAcquire;
	app.controlLockRelease;
	app.initialize;
	//app.profileName:="IMV";
	app.profileName:="RTG";
	//app.profileName:="ShipLander";
	app.profileSequenceId:=1;
	create tran;
	tran.startup;
	//tran.stop;
	//app.finalize; /* */
//	process.traceMethodsOfExecution(true);
//	process.traceMethodsOfExecution(false);
epilog
	delete tran;
end;</source>
    </JadeMethod>
    <JadeMethod name="jtdGenClassFile" id="e946a4f4-85c0-46fb-8387-cf15fc7d73ba">
        <updating/>
        <source>jtdGenClassFile() updating;

vars
	rr:AtcgControl;
begin
	create rr transient;
	app.atcgLogMessage("generating class file");
	//rr.inFile.fileName:=app.atcgLog.getActualFileName;  //.atcgReplace("msg31", "msg30");
	rr.inFile.fileName:="Y:\jjmt6216\logs\rrmsg41.log";
	rr.className:="GateDock1";
	rr.methodNamePrefix:="gd";
	rr.outFolderName:=rr.inFile.fileName.atcgWithoutFileName&amp;"/";
	rr.outFile.fileName:=rr.outFolderName&amp;rr.className&amp;".cls";
	rr.genJadeVersion:="6.2.15";
	rr.genSchema:="JtdMobileDriverSchema";
	rr.genSuperSchema:="JtdMobileCommonSchema";
	rr.genSuperClass:="JmtTransactionGenerator";
	rr.logMessageMethod:="app.logMessage";
	rr.generatingValidationCommented:=false;
	rr.parseInputFile;
	rr.genClassFile;
	rr.loadClassFile;
epilog
	delete rr;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jtdGenClassFileSave" id="2c2eeb9c-60f1-4796-9eb1-61d71b4e6713">
