	self.isInspected 		:= _cmif.isInspected;	// 10/09/2009 cnwar2 CCMS-1107/#20627
	self.isFumigated 		:= _cmif.isFumigated;	// 10/09/2009 cnwar2 CCMS-1107/#20627
	self.isExternallyVisible := _cmif.isExternallyVisible; //cnwrd1 ccms 1134 par 35101
