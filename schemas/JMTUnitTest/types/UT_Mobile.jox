    <JadeMethod name="tCreateChildCargo" id="8f3da2a0-4422-4576-99cd-b406be6fe0e7">
        <source>tCreateChildCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 October 2016	cnwma1	Initial creation
26 May 2023		jlika1	TFS 56398 - EUP - OUT - Overlanded Cargo Handling - Web
08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
*/

vars
	controller : CMIF_MobileGenericAgent;
	newTi,
	unPackTi : CM_TrackedItem;
	cargotype : CM_CargoType;
	location : CM_BlockStack;
	product : CM_Product;
	ti : CM_TrackedItem;
begin


	cargotype :=app.myRoot.getCargoTypeFromAbbrev("VI");
	create controller transient;
	controller.setDoNotShowMsgBox(true);
	
	controller.setMyTerminal(self.getTerminal);
	
	self.deleteContainer("PACK141116");
	self.deleteCargo("VV141116",cargotype);
	unPackTi  := self.addContainerOpts("PACK141116", "2200", "GENL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	//location := self.get
	location := self.getTerminal.allTerminalAreas["BS01"].CM_BlockStack;
	controller.setUnPackContainerDetails(unPackTi,location.allLocationsControllers.first);
	newTi:=controller.createNewTrackedItem(unPackTi,cargotype,"VV141116",null,null,null,null,null,1555,null,null,5,product,null,null,null,null,null,null,null,"2016",null,null,null,null,null,null, null,null,null,null,null,null,false); //TFS 53923
	self.assertNoTrxErrors;
	self.assertNotNull(newTi);
			
	
epilog

	delete controller;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTruckCreateNewCargo" id="ae271e8d-341b-427c-9690-669144b032f1">
        <source>tTruckCreateNewCargo();
/*

Date		Who		Reason
21 April 2017	cnwer1	Initial creation TFS 3760

*/

vars
tiOut,
	ti: CM_TrackedItem;
	truck: CM_Vehicle;
	vvr: CM_VehicleVisitRecord;
	mt: CM_Container;
	mobileAgent : CMIF_MobileGenericAgent;
	bs : CM_BlockStack;
	dualGate : CM_Gate;
		flexiController 		: CMIF_FlexiGateController;
		cargoType				: CM_CargoType;
			pxyGateEntity 			: CMGTE_Receival;
begin
	deleteContainer("UUT12345678");
	deleteContainer("UUT22222222");
	deleteVehicle("UTTRUCK");
	self.deleteTerminalArea("UTBSM1");
	bs := self.addBlockStack("UTBSM1", 100, null);

	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	
	
	mt := self.addContainer("UUT12345678", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE).CM_Container;
	self.move(mt, bs.myLocationsController);
	vvr := gateOutContainer("UTTRUCK", "", "UTDRIVER", mt, true, dualGate, null);
	self.assertNotNull(vvr);
	assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, mt);

	create mobileAgent transient;
	mobileAgent.setMyTerminal( self.getTerminal);
	mobileAgent.setTruck(vvr.vehicle);
	mobileAgent.setDoNotShowMsgBox(true);
	create flexiController transient;
	
	
	flexiController.id :="UUT22222222";
	flexiController.myTerminal := self.getTerminal;
	flexiController.myVehicle := vvr.vehicle;
	flexiController.myVehicleVisitRecord :=vvr;
	flexiController.cargoType:= TI_CargoType_Container;
	flexiController.commodity := "MT";
	flexiController.jobType := CMGTE_Entity.JobType_EmptyIN; 
	flexiController.isoTypeCode :="2200";
	flexiController.operatorCode:="MSK";
	flexiController.weightTotal:=6000;
	cargoType :=app.myRoot.allCargoTypesById[TI_CargoType_Container];
	pxyGateEntity := flexiController.createCMGTE_ReceivalProxy(cargoType);
	pxyGateEntity.setMoveToTruckOnly(true);
	self.assertNotNull(pxyGateEntity);
	app.myPassport.setWarningsIgnored(true);
	mobileAgent.doRealTrackedItemCreate(pxyGateEntity,null,tiOut);
	self.assertNoTrxErrors;
	self.assertNotNull(tiOut);
	

epilog
	delete flexiController;
	delete pxyGateEntity;
	delete mobileAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="uGateChecker" id="e8de2c12-f485-493e-af11-96d79bb87111">
        <source>uGateChecker();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2016	cnwma1	Initial creation
08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
*/

vars
	gateCheckerController : CMIF_MobileGenericAgent;
	terminal : CM_Terminal;
	errMsg : String;
		truck :        CM_Vehicle;
	gate : CM_Gate;
	lc : CM_LocationsController;
	found : Boolean;
	he : Integer;
	ta : CM_TerminalArea;
	subCargo,
	ti : CM_TrackedItem;
	context : Integer;
begin
	terminal :=app.myRoot.allTerminals["MA"];
	truck := terminal.vehicles["MA444", null];
	gate := terminal.allGates["INGATE"];
	context :=1;


	
	create gateCheckerController transient;
	gateCheckerController.setMyTerminal(terminal);
		ta := gateCheckerController.myTerminal.getTAFromClassString("PRECHK Lane 1" ,he,CM_GateArea);
	gateCheckerController.setGate(gate);
	gateCheckerController.setInward( true );
	gateCheckerController.setDoNotShowMsgBox(true);
	
	//ta := terminal.getTAFromClassString("PRECHK Lane 1" ,he,CM_GateArea);
	
	foreach  lc in ta.allLocationsControllers do
	 if lc.isKindOf(CM_GateAreaLaneController) then
		if lc.getNiceName = "PRECHK Lane 1" then
			gateCheckerController.setGateAreaLaneController(lc.CM_GateAreaLaneController,false);
			break;
		endif;
	 endif;
	endforeach;
	
	if lc = null then
		app.raiseCMException1(Lane_not_found, "PRECHK Lane 1", null, null);
		
	endif;
	
	/*if not gateCheckerController.checkFindAndAssignTrailer("ZA888") then
	
		app.raiseCMException1(Lane_not_found, "PRECHK Lane 1", null, null);
		
	endif;*/
	
	//truck := gateCheckerController.findTruck(errMsg,"ZA888",true);
	
	if truck = null then
	app.raiseCMException1(Error, errMsg, null, null);
		
	endif;
	
	
	gateCheckerController.setTruck(truck);
	
	
	if context &lt;&gt; 0 then
		foreach ti in gateCheckerController.allTruckTis do
	/*	gateCheckerController.createCargoCheckForTI(EXTRA_INFO_ALTERNATIVE_ID,context,ti,"1");
		gateCheckerController.createCargoCheckForTI(EXTRA_INFO_IS_OD ,context,ti,"1");
		gateCheckerController.createCargoCheckForTI(EXTRA_INFO_DIMENSION ,context,ti,"1");*/
		gateCheckerController.createCargoCheckForTI(EXTRA_INFO_DAMAGE ,context,ti,"1");
		/*gateCheckerController.createCargoCheckForTI(EXTRA_INFO_HAZARD_SYMBOLS,context,ti,"1");
		gateCheckerController.createCargoCheckForTI(EXTRA_INFO_PHOTO ,context,ti,"1");
		gateCheckerController.createCargoCheckForTI(EXTRA_INFO_SEALS ,context,ti,"1");
		gateCheckerController.createCargoCheckForTI(EXTRA_INFO_SPECIAL_LIFT ,context,ti,"1");
		gateCheckerController.createCargoCheckForTI(EXTRA_INFO_TEMPERATURE ,context,ti,"1");
		gateCheckerController.createCargoCheckForTI(EXTRA_INFO_WEIGHT ,context,ti,"1");*/
		endforeach;
	endif;
	
	foreach ti in gateCheckerController.allTruckTis do
	
		errMsg :=  gateCheckerController.isWaitingOnRequiredChecks(CARGO_CHECK_CONTEXT_GATE_REC , ti, subCargo);
		if errMsg &lt;&gt; "" then 
			app.raiseCMException2(Cargo_check_required,"'" &amp; errMsg &amp; "'",ti.id, null,null); // TFS 1490 added ID
			
		endif;
	endforeach;
	//gateCheckerController.moveTruckToYard(errMsg);
	write errMsg;
epilog
	delete gateCheckerController;
end;</source>
    </JadeMethod>
    <JadeMethod name="uVoyageJobDischargeFind" id="91bb7259-6eba-49f1-b7d9-bf23ff42da34">
        <source>uVoyageJobDischargeFind();
/*
Purpose:			
Date		Who		Reason
26 June 2015	NAVAB1	Initial creation
*/
constants
	CargoID = "GENL4577334";
vars
	mobileAgent : CMIF_MobileGenericAgent;
	terminal		: CM_Terminal;
	ti : CM_TrackedItem;
	allTIs : CM_TIArray;
	targetLocation : CM_LocationsController;
begin
	terminal := self.getTerminal();
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setDoNotShowMsgBox(true);
	mobileAgent.setMyVoyage(terminal.allVoyagesByCode.getAtKeyGeq("UTBISH1",null));
	mobileAgent.setChecksState( CMIF_MobileGenericAgent.ShipDischargeCargo) ;
	
	create allTIs transient;
	mobileAgent.findLanderCargo(CargoID, allTIs);
	
	assertTrueMsg(allTIs.size = 1,"Should find 1 item (" &amp; CargoID &amp;"), found " &amp; allTIs.size.String) ;
	
	targetLocation:=mobileAgent.findLanderLocation("UTBISHW 010001");
	assertTrueMsg(targetLocation &lt;&gt; null, "Location not found - '" &amp; "UTBISHW 010001" &amp; "'");
	


epilog
	delete allTIs;
	delete mobileAgent;

end;</source>
    </JadeMethod>
    <JadeMethod name="uVoyageJobLoadFind" id="17066062-7767-4a60-98bd-4740777b1dcf">
        <updating/>
        <source>uVoyageJobLoadFind() updating;
/*
Purpose:			
Date		Who		Reason
26 June 2015	NAVAB1	Initial creation
*/
constants
	CargoID = "GENL2077310";
vars
	mobileAgent : CMIF_MobileGenericAgent;
	terminal		: CM_Terminal;
	theTI,
	ti : CM_TrackedItem;
	slots, altSlots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
	voyageJob : CM_VoyageJob;
	realAlloc : CM_VoyageAllocation;
	theEditions : CM_ObjectByOidEditionDict;
	moveController : CMIF_MoveController;
	theTIs : CM_TIArray;
	lcs : CM_LCArray;
	locn : CM_SlotController;
	slotreq : CM_SlotRequest;
	alloc : CM_VoyageAllocation;
	locationTarget : String;
	location : CM_LocationsController;
begin
	terminal := self.getTerminal();
	
	create slots transient;
	create altSlots transient;
	create theEditions transient;
	create theTIs transient;
	create lcs transient;
	
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setDoNotShowMsgBox(true);
	mobileAgent.setMyVoyage(terminal.allVoyagesByCode.getAtKeyGeq("UTBISH1",null));
	mobileAgent.setChecksState( CMIF_MobileGenericAgent.ShipLoadCargo);
	

	mobileAgent.findLanderCargo(CargoID, theTIs);
	
	assertTrueMsg(theTIs.size = 1,"Should find 1 item (" &amp; CargoID &amp;"), found " &amp; theTIs.size.String) ;
	

	theTI:=theTIs.first;

	
	app.myTrxUA.trxUpdateTIsReadyToShip(theTIs,true,app.myPassport);

	slots.clear;
	self.getJobSlotControllers("UTBISH1","07",DeckOnDeck,6,1,1,slots);
		create moveController transient;
	
	if theTI &lt;&gt; null and theTI.myPrimaryPlannedLocation &lt;&gt; null then
		// ### UNPLAN LOAD ITEM
	
		moveController.isRehandleMove := false;
		moveController.mySlotRequest := slots.first.mySlotRequestLoad;
		moveController.setMoveMode(PLANNING_MODE);
		moveController.isSystemMove := true;
		moveController.isForcedMove := true;
		moveController.setMyTrackedItem(theTI);
		
		app.myTrxUA.trxUpdateMoveTIUndo(moveController,app.myPassport);
	
	endif;
	
	locn := slots.first();
	if locn &lt;&gt; null then
	// ### ERASE JOB and COLOUR CODING
		slotreq := locn.CM_SlotController.allSlotRequestsLoad.first;
		if slotreq &lt;&gt; null then
			if slotreq.myJob &lt;&gt; null then
				app.myTrxDA.trxDeleteVoyageJob(slotreq.myJob.CM_VoyageJob,app.myPassport);
				self.assertNoTrxErrorsOrWarnings();
				
			endif;
			alloc := slotreq.allAllocations.first().CM_VoyageAllocation;
			if alloc &lt;&gt; null then
				app.myPassport.setWarningsIgnored(true);
				app.myTrxDA.trxDeleteVoyageAllocation(alloc,app.myPassport);
				self.assertNoTrxErrorsOrWarnings();
			endif;
		endif;
		

	endif;

	
	// ### CREATE COLOUR CODING
	realAlloc := self.addVoyageAllocation(mobileAgent.myVoyage, "NZWLG", "U20G", "GENL", TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);
	slots.copyNoDuplicates(theEditions);
	app.myTrxUA.trxUpdateSlotRequestAttribute(slots, altSlots, true, theEditions, null, null, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings();
	
	// ### CREATE JOB
	voyageJob:=self.addVoyageJob(mobileAgent.myVoyage,"CRN2",slots, false);
	assertTrue(voyageJob &lt;&gt; null);
	
	// ### PLAN LOAD
	slots.copyNoDuplicates(lcs);
	moveController.isRehandleMove := false;
	moveController.mySlotRequest := slots.first.mySlotRequestLoad;
	moveController.setMoveMode(PLANNING_MODE);
	moveController.isSystemMove := true;
	moveController.isForcedMove := true;
	moveController.setMyTrackedItem(theTI);
	moveController.setMyToPrimaryLocation(slots.first());
	
	app.myPassport.setWarningsIgnored(true);

	// ### BULK LOAD PLAN
	app.myTrxUA.trxMoveTIsAUTOAssignToJob(theTIs, lcs, moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(theTI.myPrimaryPlannedLocation &lt;&gt; null, theTI.id &amp; " did not load plan, run the test again, it works next time.");
	
	locationTarget:= mobileAgent.getLanderCargoTargetLocation(theTI);
		
	
	self.assertTrueMsg(locationTarget = "070582","Expect target location of 070582, got " &amp; locationTarget);
	// ### LOCATION
	location:= mobileAgent.findLanderLocation(locationTarget);
	
	assertTrueMsg(location &lt;&gt; null, "Location not found - '" &amp; locationTarget &amp; "'");

epilog
	delete moveController;
	delete slots;
	delete altSlots;
	delete tmpLoadCC;
	delete theEditions;
	delete theTIs;
	delete lcs;
	delete mobileAgent;

end;</source>
    </JadeMethod>
    <JadeMethod name="uVoyageJobSOBFind" id="a69bf059-4681-4b22-b319-e0414aa881ad">
        <updating/>
        <source>uVoyageJobSOBFind() updating;
/*
Purpose:			
Date		Who		Reason
26 June 2015	NAVAB1	Initial creation
*/
constants
	CargoID = "SOBB2022452";
vars

	terminal		: CM_Terminal;
	ti : CM_TrackedItem;
	slots, altSlots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
	voyageJob : CM_VoyageJob;
	realAlloc : CM_VoyageAllocation;
	theEditions : CM_ObjectByOidEditionDict;
	moveController : CMIF_MoveController;
	lcs, altlcs : CM_LCArray;
	locn : CM_SlotController;
	slotreq : CM_SlotRequest;
	alloc : CM_VoyageAllocation;
	mobileAgent : CMIF_MobileGenericAgent;
	allTIs : CM_TIArray;
	targetLocation : CM_LocationsController;
begin
	terminal := self.getTerminal();
	
	create slots transient;
	create altSlots transient;
	create theEditions transient;
	create lcs transient;
	create altlcs transient;
	
	create mobileAgent transient;
	mobileAgent.setMyTerminal(terminal);
	mobileAgent.setDoNotShowMsgBox(true);
	mobileAgent.setMyVoyage(terminal.allVoyagesByCode.getAtKeyGeq("UTBISH1",null));
	mobileAgent.setChecksState( CMIF_MobileGenericAgent.ShiftOnBoard);
	
	create allTIs transient;
	mobileAgent.findLanderCargo(CargoID, allTIs);
	
	assertTrueMsg(allTIs.size = 1,"Should find 1 item (" &amp; CargoID &amp;"), found " &amp; allTIs.size.String) ;
	
	ti:=allTIs.first;

	slots.clear;
	self.getJobSlotControllers("UTBISH1","09",DeckOnDeck,2,1,1,slots);
	altSlots.clear;
	self.getJobSlotControllers("UTBISH1","09",DeckOnDeck,6,1,1,altSlots);
	create moveController transient;
	
	if ti &lt;&gt; null and ti.myPrimaryPlannedLocation &lt;&gt; null then
		// ### UNPLAN LOAD ITEM
	
		moveController.isRehandleMove := false;
		moveController.mySlotRequest := slots.first.mySlotRequestLoad;
		moveController.setMoveMode(PLANNING_MODE);
		moveController.isSystemMove := true;
		moveController.isForcedMove := true;
		moveController.setMyTrackedItem(ti);
		
		app.myTrxUA.trxUpdateMoveTIUndo(moveController,app.myPassport);
	
	endif;
	
	locn := slots.first();
	if locn &lt;&gt; null then
	// ### ERASE JOB and COLOUR CODING
		slotreq := locn.CM_SlotController.allSlotRequestsDischarge.first;
		if slotreq &lt;&gt; null then
			if slotreq.myJob &lt;&gt; null then
				app.myTrxDA.trxDeleteVoyageJob(slotreq.myJob.CM_VoyageJob,app.myPassport);
				self.assertNoTrxErrorsOrWarnings();
				
			endif;
			alloc := slotreq.allAllocations.first().CM_VoyageAllocation;
			if alloc &lt;&gt; null then
				app.myPassport.setWarningsIgnored(true);
				app.myTrxDA.trxDeleteVoyageAllocation(alloc,app.myPassport);
				self.assertNoTrxErrorsOrWarnings();
			endif;
		endif;
		

	endif;
	altSlots.copyNoDuplicates(altlcs);
	slots.copyNoDuplicates(lcs);
	slots.copyNoDuplicates(theEditions);
	altSlots.copyNoDuplicates(theEditions);

	// ### CREATE COLOUR CODING
	app.myTrxUA.doRORORequestDLRSoB(lcs, altlcs, false,SOB_MOVETYPE, theEditions, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings();

	// ### CREATE JOB
	voyageJob:=self.addVoyageJob(mobileAgent.myVoyage,"CRN2",slots, true);
	assertTrue(voyageJob &lt;&gt; null);
	
	targetLocation:=mobileAgent.findLanderLocation("090582");
	
	
	assertTrueMsg(targetLocation &lt;&gt; null, "Location not found - '" &amp; "090582" &amp; "'");

epilog
	delete moveController;
	delete slots;
	delete altSlots;
	delete tmpLoadCC;
	delete theEditions;
	
	delete lcs;
	delete altlcs;
	delete allTIs;
	delete mobileAgent;
end;</source>
    </JadeMethod>
</Class>
