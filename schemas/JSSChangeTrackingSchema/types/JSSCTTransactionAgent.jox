    <JadeMethod name="xHandler" id="ce177314-3ce7-4cf7-80ee-45298bb4d9fd">
        <source>xHandler(pTheException:Exception):Integer protected;
/*
Changed On	By			Reason
----------	--------	-------------------------------------------------------------
06/07/2015	cnwdap1		PAR #36403 Added logging of exception details, rejig message creation 
*/
vars
	ts: TimeStamp;
	notifier: JSSCTNotificationObject;
	lMessage: String;
	dumpCallStack: Boolean;
	processOidString: String;
begin
	processOidString := process.getOidString;
	if pTheException.currentMethodDesc &lt;&gt; null and pTheException.reportingMethodDesc &lt;&gt; null then
		lMessage := app.name &amp; "." &amp; self.class.getName() &amp; "::" &amp; method.name &amp; " " &amp;	pTheException.errorCode.String &amp; " - " &amp; pTheException.text &amp; " occurred in " &amp;
					pTheException.reportingMethodDesc.class.getName()&amp;'::'&amp;pTheException.currentMethodDesc.method.name &amp; " at position " &amp;
					pTheException.currentMethodDesc.position.String;
	elseif pTheException.currentMethodDesc &lt;&gt; null then
		lMessage := app.name &amp; "." &amp; self.class.getName() &amp; "::" &amp; method.name &amp; " " &amp;	pTheException.errorCode.String &amp; " - " &amp; pTheException.text &amp; " occurred in " &amp;	
					pTheException.currentMethodDesc.method.name &amp; " at position " &amp; pTheException.currentMethodDesc.position.String;
	elseif pTheException.reportingMethodDesc &lt;&gt; null then
		lMessage := app.name &amp; "." &amp; self.class.getName() &amp; "::" &amp; method.name &amp; " " &amp;	pTheException.errorCode.String &amp; " - " &amp; pTheException.text &amp; " reported by " &amp;
					pTheException.reportingMethodDesc.class.getName()&amp;'::'&amp;pTheException.reportingMethodDesc.method.name &amp; " at position " &amp;
					pTheException.reportingMethodDesc.position.String;
	else
		lMessage := app.name &amp; "." &amp; self.class.getName() &amp; "::" &amp; method.name &amp; " " &amp;	pTheException.errorCode.String &amp; " - " &amp; pTheException.text &amp; " occurred.";
	endif;
	//if pTheException.reportingMethodDesc = null then
	//else
	//	lMessage := app.name &amp; "." &amp; self.class.getName() &amp; "::" &amp; method.name &amp; " " &amp;	pTheException.errorCode.String &amp; " - " &amp; pTheException.text &amp; " reported by " &amp;
	//				pTheException.reportingMethodDesc.class.getName()&amp;'::'&amp;pTheException.reportingMethodDesc.method.name &amp; " at position " &amp;
	//				pTheException.reportingMethodDesc.position.String;
	//endif;
	//if pTheException.currentMethodDesc = null then
	//	lMessage := app.name &amp; "." &amp; self.class.getName() &amp; "::" &amp; method.name &amp; " " &amp;	pTheException.errorCode.String &amp; " - " &amp; pTheException.text &amp; " occurred.";
	//elseif pTheException.reportingMethodDesc = null then
	//	lMessage := app.name &amp; "." &amp; self.class.getName() &amp; "::" &amp; method.name &amp; " " &amp;	pTheException.errorCode.String &amp; " - " &amp; pTheException.text &amp; " occurred in " &amp;
	//				pTheException.currentMethodDesc.method.name &amp; " at position " &amp; pTheException.currentMethodDesc.position.String;
	//else
	//	lMessage := app.name &amp; "." &amp; self.class.getName() &amp; "::" &amp; method.name &amp; " " &amp;	pTheException.errorCode.String &amp; " - " &amp; pTheException.text &amp; " occurred in " &amp;
	//				pTheException.reportingMethodDesc.class.getName()&amp;'::'&amp;pTheException.currentMethodDesc.method.name &amp; " at position " &amp;
	//				pTheException.currentMethodDesc.position.String;
	//endif;
	notifier := JSSCTNotificationObject.firstInstance;
	notifier.causeEvent(JSSCT_Monitor_Note, true,
						ts.date.format("ddMMMyy ") &amp;
						ts.Time.String &amp; "." &amp; (ts.Time.milliSecond + 1000).String[2:3] &amp; " " &amp;
//						process.number.String &amp; " | " &amp;
						processOidString[processOidString.pos(".",1)+1:end] &amp; " | " &amp;
						lMessage);

	dumpCallStack := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "DumpCallStack", 'false').toLower = 'true';
	if pTheException.errorCode = 1266 or dumpCallStack then
		self.dumpCallStack(self.class.getName());
	endif;
	
	app.writeLog(lMessage, true);				// PAR #36403
	
	// Abort the transaction (does nothing if not in transaction state).
	abortTransaction;

	// Abort the operation.
	return Ex_Abort_Action;
end;</source>
        <access>protected</access>
        <Parameter name="pTheException" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xHandlerDeadlock" id="d80b4495-379d-4735-bac0-8c37e033c1e3">
        <source>xHandlerDeadlock(pTheException:DeadlockException):Integer protected;
/*
*/
vars
	ts: TimeStamp;
	notifier: JSSCTNotificationObject;
	lMessage: String;
	dumpCallStack: Boolean;
	processOidString: String;
begin
	processOidString := process.getOidString;
	if pTheException.reportingMethodDesc = null then
	else
		lMessage := app.name &amp; "." &amp; self.class.getName() &amp; "::" &amp; method.name &amp; " " &amp;	pTheException.errorCode.String &amp; " - " &amp; pTheException.text &amp; " reported by " &amp;
					pTheException.reportingMethodDesc.method.name &amp; " at position " &amp;
					pTheException.reportingMethodDesc.position.String;
	endif;
	if pTheException.currentMethodDesc = null then
		lMessage := app.name &amp; "." &amp; self.class.getName() &amp; "::" &amp; method.name &amp; " " &amp;	pTheException.errorCode.String &amp; " - " &amp; pTheException.text &amp; " occurred.";
	else
		lMessage := app.name &amp; "." &amp; self.class.getName() &amp; "::" &amp; method.name &amp; " " &amp;	pTheException.errorCode.String &amp; " - " &amp; pTheException.text &amp; " occurred in " &amp;
					pTheException.currentMethodDesc.method.name &amp; " at position " &amp;
					pTheException.currentMethodDesc.position.String;
	endif;
	notifier := JSSCTNotificationObject.firstInstance;
	notifier.causeEvent(JSSCT_Monitor_Note, true,
						ts.date.format("ddMMMyy ") &amp;
						ts.Time.String &amp; "." &amp; (ts.Time.milliSecond + 1000).String[2:3] &amp; " " &amp;
//						process.number.String &amp; " | " &amp;
						processOidString[processOidString.pos(".",1)+1:end] &amp; " | " &amp;
						lMessage);

	dumpCallStack := app.getProfileStringAppServer(app.getIniFileNameAppServer(), "JSSChangeTracker", "DumpCallStack", 'false').toLower = 'true';
	if dumpCallStack then
		self.dumpCallStack(self.class.getName());
	endif;
	// Abort the transaction (does nothing if not in transaction state).
	abortTransaction;

	// Abort the operation.
	return Ex_Abort_Action;
end;</source>
        <access>protected</access>
        <Parameter name="pTheException" type="DeadlockException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xHandlerGeneral" id="09f94d77-dcb3-4755-b053-d9374eb444a9">
        <source>xHandlerGeneral(pTheException:Exception):Integer protected;
/*
*/
vars
	ts: TimeStamp;
	notifier: JSSCTNotificationObject;
