    <JadeMethod name="createComponent" id="dff8938d-5c28-482a-93a8-9dbfa9eb45d1">
        <source>createComponent(pComponentId:Integer; pComponentDescription:String):JSSLKComponent;
// --------------------------------------------------------------------------------
// Created:		15 January 2003 by cnwdad1
//
// Purpose:		Creates a Component for the receiver.
//
// Parameters:	pComponentId - he unique identifier number of the Component.
//				[ComponentDescription - A description of the Component.
//
// Returns:		A reference to the newly created Component object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theComponent	: JSSLKComponent;
	
begin
	create theComponent;
	theComponent.updateMe(pComponentId, pComponentDescription, self);
	
	return theComponent;
end;</source>
        <Parameter name="pComponentId" type="Integer"/>
        <Parameter name="pComponentDescription" type="String"/>
        <ReturnType type="JSSLKComponent"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="4051f3c2-4073-436a-a3de-d67cd19aacf1">
        <source>getDisplay():String;
// --------------------------------------------------------------------------------
// Created:		01 April 2003 by cnwdad1
//
// Purpose:		Returns a display string of the receiver's details.
//
// Parameters:	None
//
// Returns:		The display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnValue		: String;
	
begin
	returnValue	:=	self.productName &amp; " " &amp; self.productVersion;
	
	return returnValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHighestComponentId" id="6ee38938-3b9b-44d2-8160-c071515e539d">
        <executionLocation>server</executionLocation>
        <source>getHighestComponentId():Integer serverExecution;
// --------------------------------------------------------------------------------
// Created:		27 January 2003 by cnwdad1
//
// Purpose:		Returns the highest Component ID number that the Product has.
//
// Parameters:	None
//
// Returns:		The highest Component ID number.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theComponent	: JSSLKComponent;
	
begin
	theComponent	:=	self.allComponents.last();
	
	if theComponent = null then
		return 0;
	else
		return theComponent.componentId;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="6011bf8e-b85e-444c-a7f2-185d9d7f6a3f">
        <updating/>
        <source>updateMe(pProductName:String; pProductCode:String; pProductVersion:String; pProductLogo:Binary; pTheRoot:JSSLKProductRoot) updating;
// --------------------------------------------------------------------------------
// Created:		15 January 2003 by cnwdad1
//
// Purpose:		Updates the receiver's properties.
//
// Parameters:	pProductName - The name of the Product.
//				pProductCode - The unique product code.
//				pProductVersion - The release version of the product.
//				pProductLogo - A logo image for the receiver.
//				pTheRoot - The root owner of the receiver.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.validateMe(pProductName, pProductCode, pProductVersion, pProductLogo, pTheRoot) then
		// Update general properties and references.
		
		if self.productCode &lt;&gt; pProductCode then
			self.productCode	:=	pProductCode;
		endif;
		
		if productVersion &lt;&gt; pProductVersion then
			self.productVersion	:=	pProductVersion;
		endif;
		
		if self.productLogo &lt;&gt; pProductLogo then
			self.productLogo	:=	pProductLogo;
		endif;
		
		// Update any key properties.
		
		if self.productName &lt;&gt; pProductName then
			self.productName	:=	pProductName;
		endif;
		
		// Update inverse references.
		
		if self.myRoot &lt;&gt; pTheRoot then
			self.myRoot	:=	pTheRoot;
		endif;
	endif;
end;</source>
        <Parameter name="pProductName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <Parameter name="pProductVersion" type="String"/>
        <Parameter name="pProductLogo" type="Binary"/>
        <Parameter name="pTheRoot" type="JSSLKProductRoot"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="bddf5756-8a66-40ea-ad81-7b7109fb10aa">
        <source>validateMe(pProductName:String; pProductCode:String; pProductVersion:String; pProductLogo:Binary; pTheRoot:JSSLKProductRoot):Boolean;
// --------------------------------------------------------------------------------
// Created:		15 January 2003 by cnwdad1
//
// Purpose:		Validates the receiver's properties.
//
// Parameters:	pProductName - The name of the Product.
//				pProductCode - The unique product code.
//				pProductVersion - The release version of the product.
//				pProductLogo - A logo image for the receiver.
//				pTheRoot - The root owner of the receiver.
//
// Returns:		True if the data is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pProductName = null then
		JSSLKException.raise_(99999, $PRODUCT_NAME_BLANK);
		return false;
	endif;
	
	if pProductCode = null then
		JSSLKException.raise_(99999, $PRODUCT_CODE_BLANK);
		return false;
	endif;
	
	if pProductVersion = null then
		JSSLKException.raise_(99999, $PRODUCT_VERSION_BLANK);
		return false;
	endif;
	
	if pTheRoot = null then
		JSSLKException.raise_(99999, $NULL_ROOT);
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="pProductName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <Parameter name="pProductVersion" type="String"/>
        <Parameter name="pProductLogo" type="Binary"/>
        <Parameter name="pTheRoot" type="JSSLKProductRoot"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
