    <JadeMethod name="createBulkRelease" id="40c01bbf-8452-49e2-88eb-ebfe9d3ccc9c">
        <updating/>
        <source>createBulkRelease(_passport: CM_Passport input) : CM_BulkRelease updating, protected;
//------------------------------------------------
// Created: 19 April 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	return null;
end;</source>
