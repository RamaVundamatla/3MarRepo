    <JadeMethod name="doRegrading" id="d3a625f3-bd70-4242-8b35-f1951cca9d13">
        <source>doRegrading(_errorSet : CM_ErrorSet input);

// cnwdvb1 21 November 2002 

vars
	logRegrade		: CMIF_LogRegrade;
	theLocation		: CM_LocationsController;
	theOperator		: CM_Operator;
	myTerminal		: CM_Terminal;
	myTerminalArea	: CM_TerminalArea;
	tiSet, validSet	: CM_TISet;
	remoteDtl		: CM_RemoteDataDtl;			
	ti				: CM_TrackedItem;
	ls				: Boolean;
	
begin

	myTerminal := app.myPassport.myTerminal;

	if myTerminal = null then
		app.raiseCMException1(Err_InvalidTerminal, self.myRemoteDataHdr.terminal, null, null);
	endif;
		
	myTerminalArea := myTerminal.allTerminalAreas[self.terminalArea];
	if myTerminalArea &lt;&gt; null then
		theLocation := myTerminalArea.getLocationsControllerFromId(self.location);
	endif;
	
	theOperator := app.myRoot.allOperators[self.operator];
	if theOperator = null then
		app.raiseCMException1(Err_InvalidSupplier, self.operator, null, null);
	endif;
	if theLocation &lt;&gt; null and self.isMove then
		tiSet := self.getTis(myTerminal, _errorSet, self.allTis);
		create validSet transient;
		app.cmsBeginLoad(ls);
		foreach ti in tiSet do
			self.sharedLock(ti);
			if not theLocation.allTrackedItems.includes(ti) then
				validSet.add(ti);	
			endif;
		endforeach;
	else
		validSet := self.getTis(myTerminal, _errorSet, self.allTis);
	endif;
	
	create logRegrade transient;
	logRegrade.init(theOperator, self.species,self.grade,self.treatment,self.type,self.length,self.sedMin,
					self.sedMax,self.isLogId,self.myRegradeCode, validSet);	
	
	app.myTrxUA.trxRegradeLog(logRegrade, self.myRemoteDataHdr.myUser.code, theLocation, self.isMove, app.myPassport);
	if (not app.myPassport.trxCompletedOK) then
		_errorSet.copyErrors(app.myPassport.allErrorWarnings);
	else
		//_errorSet.copyErrors(app.myPassport.allWarnings);	//We don't need any warnings, when transaction finishes ok. PAR 24189 10/05/2010
		remoteDtl := self;
		app.myTrxUA.trxUpdateRemoteDataIsProcessed(remoteDtl,true, app.myPassport);
	endif;
	
epilog
	app.cmsEndLoad(ls);
	delete validSet;
	delete logRegrade;
	delete tiSet;
end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
    </JadeMethod>
