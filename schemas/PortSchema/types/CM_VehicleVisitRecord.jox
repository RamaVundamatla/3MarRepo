    <JadeMethod name="getOutLane" id="2340546f-2797-42dd-9dde-9f2932fe5a3f">
        <source>getOutLane():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2017	jlgma1	TFS #7610 PKT - REQUIRED FIELD FOR REPORTING

*/

vars
	laneId : String;
	vVVRD : CM_VehicleVisitRecordDetail ;
	extraInfo : CM_Object;
begin
	foreach vVVRD in self.allVehicleVisitRecordDetails reversed do 
		if vVVRD.recordType= VisitRecord_Arrive_PGate_Out then
			break;
		else
			vVVRD := null;
		endif;
	endforeach;
	if vVVRD &lt;&gt; null then
		if vVVRD.getExtraInfoObject&lt;&gt; null then
			extraInfo := vVVRD.getExtraInfoObject;
			if extraInfo.isKindOf(CM_GateAreaLaneController) then
				laneId := extraInfo.CM_LaneController.getLaneNumber.String;
			endif;
		
		endif;
	endif;
	return laneId;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOutwardScaleWeight" id="60c4ba08-605c-469e-a3f3-14dc101359b2">
        <source>getOutwardScaleWeight() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 January 2017	cnwns1	Initial creation

*/

vars
	vvrd : CM_VehicleVisitRecordDetail;
	departureWeight : Decimal[16,4];
	measure : CM_MeasurementType;
begin

	vvrd := self.getBulkGateOut();
	if vvrd &lt;&gt; null then
		departureWeight := vvrd.getExtraInfo_BulkGateInOrOut;
		measure := app.getDefaultMeasurementForType(Type_Weight);
		return	app.convertMeasurementForDisplay(measure.shortName, departureWeight) &amp; Space &amp; measure.shortName;
	endif;
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOutwardScaleWeights" id="7026951e-8818-45ee-bf77-75d7958040d4">
        <source>getOutwardScaleWeights():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2019	jlgndl1	Initial creation	TFS 46849

*/

vars

	vvrd : CM_VehicleVisitRecordDetail;
	selectedVVRD : CM_VehicleVisitRecordDetail;
	scaleOutWeight : Decimal[16,4];
	adjustedOutWeight : Decimal[16,4];
	measure : CM_MeasurementType;
	vvrdString : String;
	adjusted: Boolean;

begin

	//Just get teh first one.  (If there are two, the first one is the one with both weights on it)
	foreach vvrd in self.allVehicleVisitRecordDetails do
		if vvrd.recordType = VisitRecord_Bulk_Out then
			selectedVVRD := vvrd;
			break;
		endif;
	endforeach;
	
	if selectedVVRD = null then
		//nothing doing.
		return null;
	endif;
	
	measure := app.getDefaultMeasurementForType(Type_Weight);
	
	selectedVVRD.getExtraInfo_BulkGateOutWts( scaleOutWeight, adjustedOutWeight, adjusted );
	
	//write the original scale weight and user / computer name
	vvrdString := vvrdString &amp; app.convertMeasurementForDisplay(measure.shortName, scaleOutWeight) &amp; Space &amp; measure.shortName;
	vvrdString := vvrdString &amp; " [" &amp; vvrd.userCode &amp; "] " &amp; vvrd.computerName;
		
	if adjusted then
		
		//add in the user adjusted weight and user / computer name
		vvrdString := vvrdString &amp; " ==&gt; ";	
		vvrdString := vvrdString &amp; app.convertMeasurementForDisplay(measure.shortName, adjustedOutWeight) &amp; Space &amp; measure.shortName;
		vvrdString := vvrdString &amp; " [" &amp; vvrd.userCode &amp; "] " &amp; vvrd.computerName;
	
	endif;
	
	return vvrdString;
	
epilog

	

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
