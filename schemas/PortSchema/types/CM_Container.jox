    <JadeMethod name="getLastPackedTI" id="50ad30d8-d6ad-4758-96bb-865de418244a">
        <source>getLastPackedTI() :String;
// ---------------------------------------------------------------------------
// Created:		07 February 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//Reports: returns ID of cargo packed into this container 
/*

Date		Who		Reason
22 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	trans			:	CM_TITransaction;
	iterator		:	Iterator;
	packedID		:	String;
begin
	packedID := null;	
	iterator := self.allTransactions.createIterator();
	// find the last unpack type transaction
	while iterator.back(trans) do
		if trans.isKindOf(CM_Pack) then
			packedID := trans.CM_Pack.otherTrackedItemId;
			break;
		endif;
	endwhile;
	
	return packedID;

epilog
	delete iterator;		// PAR #26678
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLastPackedTIObject" id="b08a89c3-5ddd-4e4a-a0b6-3ab22d64705c">
        <source>getLastPackedTIObject() :CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:		23 March 2012  by cnwsh3
// ---------------------------------------------------------------------------
//Reports: returns the last cargo packed into this container 
//Date		Who		Reason
//23/03/2012	cnwsh3	Created PAR 29343

vars
	trans			:	CM_TITransaction;
	iterator		:	Iterator;
	ti				: 	CM_TrackedItem;
begin
	iterator := self.allTransactions.createIterator();
	// find the last pack type transaction
	while iterator.back(trans) do
		if trans.isKindOf(CM_Pack) then
			ti := trans.CM_Pack.getOtherTrackedItem();
			break;
		endif;
	endwhile;
	
	return ti;

epilog
	delete iterator;		
	
end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
