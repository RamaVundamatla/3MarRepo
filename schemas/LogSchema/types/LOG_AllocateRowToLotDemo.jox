    <JadeMethod name="doOptTicketClick" id="cf44b1df-aedd-453b-b587-f9b0930f2979">
        <source>doOptTicketClick();
// ---------------------------------------------------------------------------
// Created:     01 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
