    <JadeMethod name="setProxy" id="2ed778dc-41f4-4d29-95a2-66689c67d277">
        <updating/>
        <source>setProxy(	_code,
			_description 				: String;
			_coarriExportPorts 			: CM_PortByCodeDict;
			pCamGroup 					: CM_CamGroup;
			pCamISOPortDesc 			: String;
			pEmailAddress 				: CM_EmailEntity;
			pEmailCopy 					: Boolean;
			pEmailCopyAddresses 		: CM_EmailEntityByTypeNameDict;
			pEmailFileImbedded 			: Boolean;
			pEmailMessage,
			pEmailSubject 				: String;
			pFirstRunDateTime,
			pLastRunDateTime 			: TimeStamp;
			pSpecialFileName			: Boolean;
			pFilePrefix ,
			pFileSuffix 				: String;
			pOperatorXlationCode 		: String;
			pPackOperators 				: CM_OperatorByCodeDict;
			pPackExportConsignees 		: CM_ConsignByCodeDict;
			pPackConsignor 				: String;
			pProtocolDesc 				: CM_CamProtocolDesc;
			pRegisteredTransactions 	: StringArray;
			pSendMtFiles 				: Boolean;
			pSendType 					: Integer;
			pUseVoyageOp				: Boolean;
			pScheduleTimes 				: TimeArray;
			_x12UseClientRefAsBooking,
			_spare1,
			_gateInForNullVoyageChange,
			_gateInForNullOperatorChange : Boolean;
			_spare2,
			_spare3,
			_special_MSCForNZPOE,
			_daysToLookBack 			: Boolean;
			_tempLeadingZerosNoDecimal,
			_supressSealNumbers,
			_singleContainerPerBGM,
			_singleTransactionPerFile 	: Boolean;
			_reprocessOnIdChange,
			_sendCancellationMsg,
			_sendUpdateMsg,
			_debug 						: Boolean;
			_useContainerOperator_NAD_CF,
			_sendCarrier_RFF_CN,
			_useCarrierForBooking 		: Boolean;
			_includeChild				: Boolean;	// cnwdad1 26/01/2010 - PAR #22199.
			pIsEmailEnabled,
			pIsSingleTransPerFile,
			pIsFileTransferEnabled,
			pAnyEditTriggerField		: Boolean;
			pOutputFileRollOver,
			pOutputFileSeqLength,
			pOutputFileStartSeq,
			pLastSequenceNumberUsed 	:Integer;// adm 290709 CCMS 1011
			pOutputFileFormat,
			pDestinationFilePath,
			pJRWReportName 				: String;
			pCamEditTriggerFields 		: CM_CamEditTriggerFieldDict;
			pCamTrainEventTypes 		: CM_EventTypeByNameDict;	// PAR 21905 CCMS MES 1008 - PHB
			pQFCamTransaction 			: CMQF_CamTransactionTemplate;
			pNoCrLf						: Boolean;
			pStatus 					: Integer;
			pTerminal 					: CM_Terminal;
			pTerminalActivity,
			pDepotActivity,
			pUseSubTerminals			: Boolean;
			pPackGateInFull,
			pPackGateOutMT,
			pUnpackGateInMT,
			pUnpackGateOutFull,
			pPrcNullVoyageTransaction,
			_useTiOperator 				: Boolean;
			pAllPackAreas 				: CM_TAByIdDict;
			pMyConsignee 				: CM_ConsigneeConsignor;
			_myFTPEntity 				: CM_FTPEntity;
			_decimalCharacter,
			_elementSeperator,
			_escapeCharacter,
			_segmentTerminator,
			_subElementSeperator		: Character;
			_allRegisteredCargoTypes 	: IntegerArray;
			_selectorQuery 				: CM_MenuUserQuery;
			_delayMinutes 				: Integer;					//08 Sep 2015	NDL	Par 36876
			_coarriBGM 					: Boolean;					//cnwmc5 - 4 Feb 2016 - PAR 37503
			_coarriBGM4446				: Boolean;					//27Jan2023 navsp1 TFS 56282;
			_useVGM 					: Boolean;					//epr par 37551 TFS 1429
			_useRelaxedIdChecking		: Boolean;					// jlgka1 TFS 41641
			_useCodecoForNonStrucVoy	: Boolean;					// jlgka1 TFS 43785
			_dgsDetailsInGroup14		: Boolean
			) updating;	
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwdf1
//
/* Changes

Date		Name	TFS#		Description
============================================================================
18/05/2011	cnwcs5	CCMS SCT 2058 
					/ par 27460 User defined special charac	ters
20/09/2012	cnwcs5				REmove unused special fields from CM_CamProtocol
15 Nov 2012	cnwrs1	Par 30739 - all DTM 203 should call transDateTime 
15 May 2014	cnwrs1	Par 34159 - include Chassis in Codeco
19 Nov 2014	cnwrs1	CCMS 2405 - Alabama Steel Cams
12 Mar 2019 jlgka1	TFS 41641 - Add relaxedIDCheck field to trigger 
								not strict ID checking.
24 Apr 2019 jlgka1	TFS 43785 - Add useCodecoForNonStrucVoy field to bypass validation
								for cellular voyage.
============================================================================*/
begin	
	self.code 					:= _code[1:30];
	self.description 			:= _description;
	self.camGroup				:= pCamGroup;
	self.camISOPortDesc	 		:= pCamISOPortDesc;
	self.myEmailEntity 			:= pEmailAddress;
	self.emailCopy 				:= pEmailCopy;
	self.emailFileImbedded 		:= pEmailFileImbedded;
	//9/11/2009 cnwdz2 par20867
	self.emailMessage 			:= app.shortenStringLength(pEmailMessage,self.emailMessage.maxLength);
	self.emailSubject			:= pEmailSubject;
	self.firstRunDateTime 		:= pFirstRunDateTime;
	self.lastRunDateTime 		:= pLastRunDateTime;
	self.filePrefix 			:= pFilePrefix;
	self.fileSuffix 			:= pFileSuffix;
	self.operatorXlationCode 	:= pOperatorXlationCode;
	self.packConsignor 			:= pPackConsignor;
	self.protocolDesc 			:= pProtocolDesc;
	self.sendMtFiles 			:= pSendMtFiles;
	self.sendType				:= self.EMAIL;
	self.useVoyageOperator 		:= pUseVoyageOp;
	self.useTiOperator 			:= _useTiOperator;

 	self.x12UseClientRefAsBooking := _x12UseClientRefAsBooking; //cnwrd1 par 35207
// AKB	self.includeNonWorkedVoyage 	:= _includeNonWorkedVoyage;
	self.gateInForNullVoyageChange 	:= _gateInForNullVoyageChange;
	self.gateInForNullOperatorChange   	:= _gateInForNullOperatorChange;
//	self.noSNTOnPackTrans 			:= _noSNTOnPackTrans;
//	self.noRCVOnUnpackTrans 		:= _noRCVOnUnpackTrans;
	self.special_MSCForNZPOE 		:= _special_MSCForNZPOE;
	self.daysToLookBack 			:= _daysToLookBack;
	self.tempLeadingZerosNoDecimal 	:= _tempLeadingZerosNoDecimal;
	self.supressSealNumbers 		:= _supressSealNumbers;
	self.singleContainerPerBGM 		:= _singleContainerPerBGM;
	self.singleTransactionPerFile 	:= _singleTransactionPerFile;
	self.reprocessOnIdChange 		:= _reprocessOnIdChange;
	self.sendCancellationMessage 	:= _sendCancellationMsg;
	self.sendUpdateMessage 			:= _sendUpdateMsg;
	self.debug 						:= _debug;
	self.useContainerOperator_NAD_CF 	:= _useContainerOperator_NAD_CF; //par19423 cnwrs1 May 2009
	self.sendCarrier_RFF_CN 		:= _sendCarrier_RFF_CN;
	self.useCarrierForBooking 		:= _useCarrierForBooking;
	self.isIncludeChild				:= _includeChild;	// cnwdad1 26/01/2010 - PAR #22199.

	self.specialFileName 			:= pSpecialFileName;
	self.noCrLfInMessage 			:= pNoCrLf;
	self.status 					:= pStatus;
	
	//ccmc1535
	self.terminalActivity 			:= pTerminalActivity;
	self.depotActivity 				:= pDepotActivity;
	self.useSubTerminals 			:=	pUseSubTerminals;
	self.packGateInFull 			:= pPackGateInFull;
	self.packGateOutMT 				:= pPackGateOutMT;
	self.unpackGateInMT 			:= pUnpackGateInMT;
	self.unpackGateOutFull 			:= pUnpackGateOutFull;
	self.myConsignee 				:= pMyConsignee;
	self.prcNullVoyageTransaction 	:= pPrcNullVoyageTransaction;
	
	//ccms 1011
	self.isEmailEnabled				:= pIsEmailEnabled;
	self.isSingleTransPerFile		:= pIsSingleTransPerFile;
	self.isFileTransferEnabled		:= pIsFileTransferEnabled;
	self.anyEditTriggerField		:= pAnyEditTriggerField;
	self.transferFileFormat			:= pOutputFileFormat;
	self.transferFileRollOver		:= pOutputFileRollOver;
	self.transferFileSeqLength		:= pOutputFileSeqLength;
	self.transferFileStartSeq		:= pOutputFileStartSeq;
	self.lastSequenceNumberUsed		:= pLastSequenceNumberUsed;
	self.destinationFilePath		:= pDestinationFilePath;
	self.jrwReportName				:= pJRWReportName;
	self.myQFCamTransactionTemplate	:= pQFCamTransaction;
	
	self.decimalCharacter			:= _decimalCharacter;	// par 27460 cnwcs5
	self.elementSeparator			:= _elementSeperator;	// par 27460 cnwcs5
	self.escapeCharacter			:= _escapeCharacter;	// par 27460 cnwcs5
	self.segmentTerminator			:= _segmentTerminator;	// par 27460 cnwcs5
	self.subElementSeparator		:= _subElementSeperator;	// par 27460 cnwcs5
	
	self.delayMinutes  				:= _delayMinutes;	//08 Sep 2015	NDL	Par 36876
	self.useRelaxedIdChecking 		:= _useRelaxedIdChecking; // jlgka1 TFS 41641
	
	self.useCodecoForNonStrucVoyage := _useCodecoForNonStrucVoy; // jlgka1 TFS 43785
	self.dgsDetailsInGroup14		:= _dgsDetailsInGroup14;	//JIRA-20814
	
	self.allPackAreas.clear;
	self.allCoarriExportPorts.clear;
	self.packOperators.clear;
	self.packExportConsignees.clear;
	self.registeredTransactions.clear;
	self.allRegisteredCargoTypes.clear;
	self.scheduleTimes.clear;

	_coarriExportPorts.copy(self.allCoarriExportPorts);
	self.allCopyEmailEntities.clear();
	pEmailCopyAddresses.copy(self.allCopyEmailEntities);
	pAllPackAreas.copy (self.allPackAreas);
	pPackOperators.copy(self.packOperators);
	pPackExportConsignees.copy(self.packExportConsignees);
	pRegisteredTransactions.copy(self.registeredTransactions);
	_allRegisteredCargoTypes.copy(self.allRegisteredCargoTypes);
	pScheduleTimes.copy(self.scheduleTimes);

	self.allEditTriggerFields.clear;
	pCamEditTriggerFields.copy(self.allEditTriggerFields);
	
	if pCamTrainEventTypes &lt;&gt; null then
		self.allTrainEventTypes.clear;						// PAR 21905 CCMS MES 1008 - PHB
		pCamTrainEventTypes.copy(self.allTrainEventTypes);	// PAR 21905 CCMS MES 1008 - PHB
	endif;
	self.terminal := pTerminal;
	self.myFTPEntity := _myFTPEntity;	// CCMS 1143 cnwrs1 10 Aug 2010
	self.mySelector:=_selectorQuery;
	
	self.changeCOARRIBGM := _coarriBGM;			//cnwmc5 - 10 Feb 2016 - PAR 37503
	self.changeCOARRIBGM4446 := _coarriBGM4446; //27Jan2023 navsp1 TFS 56282
	self.useVGM := _useVGM; //epr 16/2/16 TFS 1429 par 37551	
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_coarriExportPorts" type="CM_PortByCodeDict"/>
        <Parameter name="pCamGroup" type="CM_CamGroup"/>
