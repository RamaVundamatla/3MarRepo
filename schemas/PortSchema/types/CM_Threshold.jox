    <JadeMethod name="getAuditTextForProperty" id="420da319-3a5d-4f5e-ac84-51ebc20c85d3">
        <source>getAuditTextForProperty(_property: Property): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	propName : String;
	
begin

	propName := _property.name;

	if propName = CM_Threshold::myOperator.name then
	//	return self.getDisplayStringForAttribute(ETRow_MyOperator, false);
		return self.formatAuditText(propName, self.getDisplayStringForAttribute(ETRow_MyOperator, false));
	
	elseif propName = CM_Threshold::myISOTypeGroup.name then
	//	return self.getDisplayStringForAttribute(ETRow_MyISOGroup, false);
		return self.formatAuditText(propName, self.getDisplayStringForAttribute(ETRow_MyISOGroup, false));
	
	else	
		return inheritMethod(_property);
		
	endif;

epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="aeef9304-145b-4f2f-8bc5-84e6d6c80c49">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2011	cnwndl1	Initial creation
//03 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin

	
	if _attrName = ETRow_IsActive then
		return self.isActive.getYesNo;
		
	elseif _attrName = ETRow_LastNotified then
		if self.lastNotified.Date.isValid then
			return self.systemToLocalTime(lastNotified).asStringJMT;//03 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_MaxLevel then
		return self.maxThresholdLevel.String;
		
	elseif _attrName = ETRow_MinLevel then
		return self.minThresholdLevel.String;
		
	elseif _attrName = ETRow_MyISOTypeGroup or _attrName = ETRow_MyISOGroup then
		if self.myISOTypeGroup &lt;&gt; null then
			return self.myISOTypeGroup.description;
		else
			return app.getErrorString(AnyString);
		endif;
		
	elseif _attrName = ETRow_MyOperator then
		if self.myOperator &lt;&gt; null then
			return self.myOperator.description;
		else
			return app.getErrorString(AnyString);
		endif;
		
	elseif _attrName = ETRow_Priority then
		return self.processingPriority.String;
		
	elseif _attrName = ETRow_ReNotifyMins then
		return self.reNotificationMinutes.String;
		
	elseif _attrName = ETRow_Terminal then	// 16 Nov 2011	NDL	Par 28697
		if self.myTerminal = null then
			return null;
		endif;
		return self.myTerminal.code;
		
	endif;
	
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="1a1c4e0b-c28f-4dca-adbf-015d2f6308bd">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	block : CM_DataContainerBlock;

begin

	inheritMethod(_dataContainer);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Is_Active), DC_Label, 1, self);
	block.addNewItem(getDisplayStringForAttribute(ETRow_IsActive, false), DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Last_notified), DC_Label, 1, self);
	block.addNewItem(getDisplayStringForAttribute(ETRow_LastNotified, false), DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Max_Level), DC_Label, 1, self);
	block.addNewItem(getDisplayStringForAttribute(ETRow_MaxLevel, false), DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Min_Level), DC_Label, 1, self);
	block.addNewItem(getDisplayStringForAttribute(ETRow_MinLevel, false), DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(ISO_Group), DC_Label, 1, self);
	block.addNewItem(getDisplayStringForAttribute(ETRow_MyISOGroup, false), DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Operator_GC), DC_Label, 1, self);
	block.addNewItem(getDisplayStringForAttribute(ETRow_MyOperator, false), DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Processing_priority), DC_Label, 1, self);
	block.addNewItem(getDisplayStringForAttribute(ETRow_Priority, false), DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Re_Notify_minutes), DC_Label, 1, self);
	block.addNewItem(getDisplayStringForAttribute(ETRow_ReNotifyMins, false), DC_Data, 1, self);

epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="efc4df15-43c0-4b3c-98ef-af30b47d1db3">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2011	cnwndl1	Initial creation

*/

vars

	pxyThreshold : CM_Threshold;

begin

	pxyThreshold := inheritMethod();
	
	pxyThreshold.myISOTypeGroup := self.myISOTypeGroup;
	pxyThreshold.myOperator := self.myOperator;
	pxyThreshold.myTerminal := self.myTerminal;
	
	return pxyThreshold;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="resetLastNotifiedIfExpiredAt" id="659e9b26-6b70-4e95-8bcb-62094c13cbec">
        <updating/>
        <source>resetLastNotifiedIfExpiredAt( _ts : TimeStamp ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

begin

	if self.lastNotified.Date.isValid then
		if _ts &gt; self.lastNotified.cnEcAddMinutes( self.reNotificationMinutes ) then
			self.setLastNotified( null ); 
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="0741b701-fc9c-420e-87fe-7871b92b6281">
        <updating/>
        <source>setForUpdate( pxyThreshold : CM_Threshold ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

begin

	self.isActive := pxyThreshold.isActive;
	self.lastNotified := pxyThreshold.lastNotified;
	self.maxThresholdLevel := pxyThreshold.maxThresholdLevel;
	self.minThresholdLevel := pxyThreshold.minThresholdLevel;
	self.myISOTypeGroup := pxyThreshold.myISOTypeGroup;
	self.myOperator := pxyThreshold.myOperator;
	self.processingPriority := pxyThreshold.processingPriority;
	self.reNotificationMinutes := pxyThreshold.reNotificationMinutes;
	
	self.myTerminal := pxyThreshold.myTerminal;

epilog

end;</source>
        <Parameter name="pxyThreshold" type="CM_Threshold"/>
    </JadeMethod>
