    <JadeMethod name="buildMoveCollForDateRange" id="00e530ff-0ba9-4aab-a9ed-f828f60a37a2">
        <source>buildMoveCollForDateRange(_movementsColl : Collection input; _fromDT, _endDT : TimeStamp);

vars
	iter : Iterator;
	preMove,
	permMove,
	nextMove : HMS_VoyageMovement;
begin
	// This method builds a collection of permanent movements that could potentially require validation
	_movementsColl.clear;

	iter := self.allVoyageMovements.createIterator;
	self.allVoyageMovements.startKeyGeq(_fromDT,iter);
	while iter.next(permMove) do
		if permMove.occursOnDT &gt;= _fromDT then
			// Add permMove to the collection of movesToValidate
			if permMove.moveType &lt;&gt; HMSMovementTypeDeparture then
				// we need the previous move for departures
				_movementsColl.add(permMove);
			endif;
			// get previous movement
			preMove := permMove.getVoyageMovementPrevious();
			if preMove &lt;&gt; null then
				if (not _movementsColl.includes(preMove)) then
					_movementsColl.add(preMove);
				endif;
			endif;
		endif;
		if _endDT.isValid then
			if permMove.occursOnDT &gt; _endDT then
				break;
			endif;
		endif;
	endwhile;			

epilog
	delete iter;

end;</source>
        <Parameter name="_movementsColl" type="Collection" usage="input"/>
        <Parameter name="_fromDT" type="TimeStamp"/>
        <Parameter name="_endDT" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="buildMoveCollToValidate" id="0faa5a36-27b7-4d37-981c-d25d0579a49e">
        <source>buildMoveCollToValidate(_movementDict : HMS_VoyageMovementByDateDict input; _fromDT, _endDT : TimeStamp);

vars
	iter : Iterator;
	preMove,
	permMove,
	nextMove : HMS_VoyageMovement;
begin
	// This method builds a collection of permanent movements that could potentially require validation
	_movementDict.clear;

	iter := self.allVoyageMovements.createIterator;

	while iter.next(permMove) do
		if permMove.occursOnDTNEW &gt;= _fromDT then
			// Add permMove to the collection of movesToValidate
			if permMove.moveType &lt;&gt; HMSMovementTypeDeparture then
				// we need the previous move for departures
				if (not _movementDict.includes(permMove)) then
					_movementDict.add(permMove);
				endif;
			endif;
			// get previous movement
			preMove := permMove.getVoyageMovementPrevious();
			if preMove &lt;&gt; null then
				if (not _movementDict.includes(preMove)) then
					_movementDict.add(preMove);
				endif;
			endif;
		else
			nextMove := permMove.getVoyageMovementNext();
			if nextMove &lt;&gt; null then
				if nextMove.occursOnDTNEW &gt;= _fromDT then
					// Add permMove to the collection of movesToValidate
					if (not _movementDict.includes(permMove)) then
						_movementDict.add(permMove);
					endif;
				endif;
			endif;
		endif;
		if _endDT.isValid then
			if permMove.occursOnDTNEW &gt; _endDT then
				break;
			endif;
		endif;
	endwhile;			

epilog
	delete iter;
end;</source>
        <Parameter name="_movementDict" type="HMS_VoyageMovementByDateDict" usage="input"/>
        <Parameter name="_fromDT" type="TimeStamp"/>
        <Parameter name="_endDT" type="TimeStamp"/>
    </JadeMethod>
