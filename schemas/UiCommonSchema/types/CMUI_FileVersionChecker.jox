    <JadeMethod name="updateProgress" id="04b9f726-e4cb-41d6-b125-ddbd8daff64c">
        <updating/>
        <source>updateProgress(_cmifMonitor: CMIF_Monitor input) updating;
// ---------------------------------------------------------------------------
// Created:     26 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.pbProgressBar.partsInJob := _cmifMonitor.partsInJob;	
	self.pbProgressBar.partsDone := _cmifMonitor.partsDone;
	self.lblModalInfo.caption := 'Progress: ' &amp; _cmifMonitor.partsDone.String &amp; ' KB of ' &amp; _cmifMonitor.partsInJob.String &amp; ' KB';
	self.lblModalMessage.caption :=_cmifMonitor.message;
	
	self.frmModalDialog.refreshNow();
	self.frmModalDialog.doWindowEvents(0);
	self.btnModalDefault.doWindowEvents(0);
	
	if self.modalDialogReturnValue &lt;&gt; ModalDialogReturn_Null then
		_cmifMonitor.monitorReturnValue := _cmifMonitor.MonitorReturnValue_Cancel;
	endif;


end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
</GUIClass>
