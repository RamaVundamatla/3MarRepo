        <source>utlUpdateVehicle(pProxyVehicle:CM_Vehicle; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cancelSave:Boolean;
	realVehicle:CM_Vehicle;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	pProxyVehicle.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyVehicle.pxyGetRealObjectAndEdition(realVehicle, expectedEdition);
	
	if realVehicle = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Vehicle.name, null, null);
		return;
	endif;

	app.myValUA.valVehicle(realVehicle, pProxyVehicle);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realVehicle);

	if _passport.noErrors and realVehicle.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Vehicle', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVehicle, true);
	endif;
	
	if _passport.noErrors then
		realVehicle.setForUpdate(pProxyVehicle);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVehicle, false);
	endif;

epilog
	
	
end;</source>
