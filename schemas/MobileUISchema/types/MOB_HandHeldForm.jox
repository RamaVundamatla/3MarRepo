    <JadeMethod name="doToDoReqdExtraInfo" id="45ac06da-b529-4e03-8ea2-7d7aeef0f5a9">
        <source>doToDoReqdExtraInfo( toDoTaskDesc : CM_ToDoTaskDesc input; _ti :CM_TrackedItem input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 February 2016	cnwndl1	Initial creation	Par 37513

*/

vars

	weighTaskForm : MOB_WeighTaskForm;
	sealsTaskForm : MOB_SealTaskForm;
	specialLiftForm	: MOB_HandHeldSpecialLiftForm;
	contDimensionsForm	: MOB_HHContainerOverDimForm;
	cargoDimensionsForm	: MOB_HHCargoOverDimForm;
	damageForm		: MOB_HHDamageForm;

begin

	if _ti = null then
		return;
	endif;
	if toDoTaskDesc = null then
		return;
	endif;
	if toDoTaskDesc.requiredExtraInfo = null then
		return;
	endif;

	if toDoTaskDesc.requiredExtraInfo = EXTRA_INFO_WEIGHT then
		create weighTaskForm transient;
		weighTaskForm.myTrackedItem := _ti;
		weighTaskForm.myToDoTask := toDoTaskDesc;
		weighTaskForm.doNotCentreWindow := true; //12 Mar 2015	NDL	Par 35828
		weighTaskForm.move(self.left, self.top, self.width, self.height );	//12 Mar 2015	NDL	Par 35828
		weighTaskForm.showModal();
		
	elseif toDoTaskDesc.requiredExtraInfo = EXTRA_INFO_SEALS then  //cnwrd1 par 29028 9.2.12
		create sealsTaskForm transient;
		sealsTaskForm.myToDoTask := toDoTaskDesc;
		sealsTaskForm.myTrackedItem := _ti;
		sealsTaskForm.doNotCentreWindow := true; //12 Mar 2015	NDL	Par 35828
		sealsTaskForm.move(self.left, self.top, self.width, self.height );	//12 Mar 2015	NDL	Par 35828
		sealsTaskForm.showModal();
			
	elseif toDoTaskDesc.requiredExtraInfo = EXTRA_INFO_SPECIAL_LIFT then  // cnwjre1 37244 Dec 2015 handle special lift
		create specialLiftForm transient;
		specialLiftForm.myToDoTaskDesc := toDoTaskDesc;
		specialLiftForm.myTrackedItem := _ti;
		specialLiftForm.doNotCentreWindow := true;
		specialLiftForm.move(self.left, self.top, self.width, self.height );
		specialLiftForm.showModal();
		
	elseif toDoTaskDesc.requiredExtraInfo = EXTRA_INFO_DIMENSION then  // cnwjre1 37244 Dec 2015 handle dimensions
		if _ti.isContainer then
		// display container dimensions form
			create contDimensionsForm transient;
			contDimensionsForm.myToDoTaskDesc := toDoTaskDesc;
			contDimensionsForm.setTrackedItem(_ti);
			contDimensionsForm.doNotCentreWindow := true;
			contDimensionsForm.move(self.left, self.top, self.width, self.height );
			contDimensionsForm.showModal();
			
		else
		// display general cargo dimensions form
			create cargoDimensionsForm transient;
			cargoDimensionsForm.myToDoTaskDesc := toDoTaskDesc;
			cargoDimensionsForm.setTrackedItem(_ti);
			cargoDimensionsForm.doNotCentreWindow := true;
			cargoDimensionsForm.move(self.left, self.top, self.width, self.height );
			cargoDimensionsForm.showModal();
			
		endif;
		
	elseif toDoTaskDesc.requiredExtraInfo = EXTRA_INFO_DAMAGE then  // cnwjre1 37244 Dec 2015 handle damage
		create damageForm transient;
		damageForm.myToDoTaskDesc := toDoTaskDesc;
		app.myMobileAgent.setMySelectedTI( _ti );
		damageForm.setTrackedItem(_ti);
		damageForm.doNotCentreWindow := true;
		damageForm.move(self.left, self.top, self.width, self.height );
		damageForm.showModal();
		
	endif;

epilog

	delete weighTaskForm;
	delete sealsTaskForm;
	delete specialLiftForm;
	delete contDimensionsForm;
	delete cargoDimensionsForm;
	delete damageForm;

end;</source>
        <Parameter name="toDoTaskDesc" type="CM_ToDoTaskDesc" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dumpTableRow" id="2affe1a5-82a8-4c20-97b7-5709edc0b544">
        <source>dumpTableRow( _tbl : Table input; _row : Integer);
// ---------------------------------------------------------------------------
// Created:	23 January 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
	index : Integer;
begin
	executeWhen JMTDevelopmentEnvironment;
		write "Row " &amp; _row.String;
		foreach index in 1 to _tbl.columns do
				write  "Column " &amp; index.String &amp; _tbl.accessCell( _row, index ).text;
		endforeach;
	endExecuteWhen;
epilog
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
