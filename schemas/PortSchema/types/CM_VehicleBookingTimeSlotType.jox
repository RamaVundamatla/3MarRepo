    <JadeMethod name="getAuditText" id="32a2a5b1-75fc-4710-a2d3-85162f57cfb9">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 October 2022	navhl20	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types

*/

vars
	txt,
	tmpStr: String;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();

	tmpStr := null;
	tmpStr := self.getVBSString(self.outsideSlotTimeAction);
	txt := txt &amp; 'Outside Slot TimeAction' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

	tmpStr := null ;
	if self.myVBSSlotTypeCriteria &lt;&gt; null then
		tmpStr := self.getVBSCriteriaDisplay;
		txt := txt &amp; 'VBSSlot Type Criteria' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="52ac3736-2db8-4bd4-b514-f7627606463e">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Ju 2022	navtnr20ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
25 Nov 2024	navhl20 CR MTN-33483: TPT | Vehicle Truck Booking Auto Associate with Release Request
*/

vars

begin
	if _attrName = ETRow_VbsProcess then
		if self.myVBSProcess &lt;&gt; null then	
			return self.myVBSProcess.description;
		endif;		
		return null;
	elseif _attrName = ETRow_OutsideSlotTimeAction then
		return app.vbsEnumToString(outsideSlotTimeAction);
	elseif _attrName = ETRow_ExternalRefUpdateAllowed then
		return self.isExternelRefUpdateAllowed.asStringJMT;
	elseif _attrName = ETRow_DefineMatchingCriteria then
		return self.getVBSCriteriaDisplay();
	elseif _attrName = ETRow_AutoAssociateRR then					//25.11.2024 navhl20 #33483
		return self.autoAssociateRR.getYesNo();
	endif;
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSlotTypeYACriteria" id="e53dba92-a2e7-4af7-a912-7db9fafac33e">
        <source>getSlotTypeYACriteria(_hasCarrier,
					  _hasOperator,
					  _hasCargoType,
					  _hasProduct,
					  _hasCommodity 	: Boolean output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Aug 2023	navma1	Bug 59793: FR | EUP 53429 - EDI upload - Criteria validation, VBS ID, Verification stage, External Ref number duplication.
*/

vars
	vbsSlotTypeCriteria : CM_VBSSlotTypeCriteria;
	criteria 			: CM_YACriteria;
begin
	
	vbsSlotTypeCriteria := self.myVBSSlotTypeCriteria;
	
	if vbsSlotTypeCriteria = null then
		return;
	endif;
	
	if vbsSlotTypeCriteria.allCriteria.isEmpty then
		return;
	endif;
	
	foreach criteria in vbsSlotTypeCriteria.allCriteria do
		if criteria.myYACriteriaType.isYATypeCarrier then				//Carrier
			_hasCarrier := true;
		elseif  criteria.myYACriteriaType.isYATypeCargoType then		//CargoType
			_hasCargoType := true;
		elseif  criteria.myYACriteriaType.isYATypeProduct then			//Product
			_hasProduct := true;
		elseif  criteria.myYACriteriaType.isYATypeCommodity then		//Commodity
			_hasCommodity := true;
		elseif  criteria.myYACriteriaType.isYATypeOperatorItem then		//Operator
			_hasOperator := true;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_hasCarrier" type="Boolean" usage="output"/>
        <Parameter name="_hasOperator" type="Boolean" usage="output"/>
        <Parameter name="_hasCargoType" type="Boolean" usage="output"/>
        <Parameter name="_hasProduct" type="Boolean" usage="output"/>
        <Parameter name="_hasCommodity" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getVBSCriteriaDisplay" id="9664568b-24a6-453d-ae10-e4703355e7ac">
        <source>getVBSCriteriaDisplay():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2022	navhl20	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types

*/

vars

begin
	if self.myVBSSlotTypeCriteria = null or self.myVBSSlotTypeCriteria.getCriteriaSummary(", ") = null then
		return app.getErrorString(Criter_not_config_double_click);
	endif;

	return self.myVBSSlotTypeCriteria.getCriteriaSummary(", ").formatWithEllipsis(1, 100, true);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVBSString" id="9131a192-1922-48d9-bbe5-f8dc3bed1b5c">
        <source>getVBSString(_timeSlot : Integer): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 October 2022	navhl20	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types

*/

vars

begin
	if _timeSlot = self.VBS_ENTRY_ERROR then
		return self.VBS_ENTRY_ERROR_DESC;
	elseif _timeSlot = self.VBS_ENTRY_NOACTION then
		return self.VBS_ENTRY_NOACTION_DESC;
	elseif _timeSlot = self.VBS_ENTRY_WARN then
		return self.VBS_ENTRY_WARN_DESC;
	endif;
epilog

end;</source>
        <Parameter name="_timeSlot" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="154f9010-8ccc-4ae3-a651-e225806fda58">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 June 2022	navsrk20	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types

*/

vars
	pxy				 : CM_VehicleBookingTimeSlotType;
	pxyRelByTypeCrit : CM_VBSSlotTypeCriteria;
	completedOK		 : Boolean;
begin
	pxy				 := inheritMethod();
	pxy.myVBSProcess := self.myVBSProcess;
	pxy.myTerminal	 := self.myTerminal;
	
	//06.07.2022 navhl20 #53697
	if self.myVBSSlotTypeCriteria &lt;&gt; null then
		pxyRelByTypeCrit := self.myVBSSlotTypeCriteria.pxyCreateUpdateProxy();
		pxyRelByTypeCrit.setProxyBaseData( pxy );
	endif;
	
	completedOK 	:= true;
	return pxy;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="389dddcb-76af-4339-b934-def50e7a6148">
        <updating/>
        <source>setForCreate( pProxy: CM_VehicleBookingTimeSlotType ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Oct 2014	cnwndl1	Initial creation	Par 35008
21 Jun 2022 navma1 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
*/

vars

begin
	inheritMethod(pProxy);
	
	//self.myRoot	:= app.myRoot;			//21.06.2022 navma1 #53697
	self.myTerminal := pProxy.myTerminal;	//21.06.2022 navma1 #53697
epilog

end;</source>
        <Parameter name="pProxy" type="CM_VehicleBookingTimeSlotType"/>
    </JadeMethod>
    <JadeMethod name="setForProxy" id="37b7ec6a-5976-4a74-978c-d3b8ccfb1f98">
        <updating/>
        <source>setForProxy(_code 				  : String;
			_description 		  : String;
			_notAvailableForEntry : Boolean;
			_term				  : CM_Terminal;
			_startTime		   	  : Time;
			_duration			  : Integer;
			_gracePeriod		  : Integer;
			_entryOutsideSlotTime : Integer;
			_pregateInCheck		  : Boolean;
			_pregateOutCheck	  : Boolean;
			_kioskCheck			  : Boolean;
			_externelReference	  : Boolean;
			_autoAssociateRR	  : Boolean
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Oct 2014	cnwndl1	 Initial creation	Par 35008
21 Jun 2022 navma1	 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
05 Jul 2022 navtnr20 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
23 May 2023 navma1   ChangeRequest 54049: EUP - VBS MTN - [9] - Linking Multiple Slots to Vehicle visit
25 Nov 2024	navhl20 CR MTN-33483: TPT | Vehicle Truck Booking Auto Associate with Release Request
*/

vars

begin

	self.code 				  		:= _code[1:10];				//23.05.2023 navma1 #54049
	self.description		 		:= _description;
	self.notAvailableForEntry		:= _notAvailableForEntry;
	self.myTerminal			  		:= _term;						//21.06.2022 navma1 #53697
	self.startTime				    := _startTime;		
	self.duration				    := _duration;
	self.gracePeriod			    := _gracePeriod;
	self.outsideSlotTimeAction      := _entryOutsideSlotTime;
	self.preGateInCheck 		    := _pregateInCheck;
	self.preGateOutCheck		    := _pregateOutCheck;
	self.kioskCheck 			    := _kioskCheck;
	self.myVBSProcess 			    := _term.myVBSProcess;
	self.isExternelRefUpdateAllowed := _externelReference;
	self.autoAssociateRR			:= _autoAssociateRR;			//25.11.2024 navhl20 #33483
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_startTime" type="Time"/>
        <Parameter name="_duration" type="Integer"/>
        <Parameter name="_gracePeriod" type="Integer"/>
        <Parameter name="_entryOutsideSlotTime" type="Integer"/>
        <Parameter name="_pregateInCheck" type="Boolean"/>
        <Parameter name="_pregateOutCheck" type="Boolean"/>
        <Parameter name="_kioskCheck" type="Boolean"/>
        <Parameter name="_externelReference" type="Boolean"/>
        <Parameter name="_autoAssociateRR" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="50955a8e-cb64-4b1e-8d20-b779436ba1fc">
        <updating/>
        <source>setForUpdate( _proxy: CM_VehicleBookingTimeSlotType ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Oct 2014	cnwndl1	Initial creation
21 Jun 2022 navma1 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
5 July 2022 navtnr20 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
25 Nov 2024	navhl20 CR MTN-33483: TPT | Vehicle Truck Booking Auto Associate with Release Request
*/

vars
	criteria : CM_VBSSlotTypeCriteria;
begin
	inheritMethod(_proxy);
	
	//self.myRoot			   		:= _proxy.myRoot;				//21.06.2022 navma1 #53697
	self.myTerminal 		   	 := _proxy.myTerminal;				//21.06.2022 navma1 #53697
	self.startTime 					:= _proxy.startTime; 
	self.duration					:= _proxy.duration;
	self.gracePeriod				:= _proxy.gracePeriod;
	self.outsideSlotTimeAction		:= _proxy.outsideSlotTimeAction;
	self.preGateInCheck				:= _proxy.preGateInCheck;
	self.preGateOutCheck			:= _proxy.preGateOutCheck;
	self.kioskCheck					:= _proxy.kioskCheck;
	self.myVBSProcess				:=_proxy.myVBSProcess;
	self.isExternelRefUpdateAllowed := _proxy.isExternelRefUpdateAllowed;
	self.autoAssociateRR			:= _proxy.autoAssociateRR;			//25.11.2024 navhl20 #33483
	
	if _proxy.myVBSSlotTypeCriteria &lt;&gt; null and _proxy.myVBSSlotTypeCriteria.allCriteria.isNotEmpty then
		if self.myVBSSlotTypeCriteria = null then
			create criteria persistent;
			criteria.setProxyBaseData(self);
			criteria.setForCreate(_proxy.myVBSSlotTypeCriteria);
		else
			self.myVBSSlotTypeCriteria.setForUpdate(_proxy.myVBSSlotTypeCriteria);
		endif;
	else
		criteria := self.myVBSSlotTypeCriteria;
		delete criteria;
	endif;
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_VehicleBookingTimeSlotType"/>
    </JadeMethod>
    <JadeMethod name="setVbsProcess" id="7c1652c0-cf80-47ed-ac17-919e5db77683">
        <updating/>
        <source>setVbsProcess(_vbsProcess : CM_VBSProcess)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jun 2022 navma1 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types

*/

vars

begin
	self.myVBSProcess := _vbsProcess;
epilog

end;</source>
        <Parameter name="_vbsProcess" type="CM_VBSProcess"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="458d0d03-2e79-4680-91fb-5d3624a56564">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 October 2022	navhl20	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types

*/

vars
	propName	: String;
begin

	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if propName  = CM_VehicleBookingTimeSlotType::outsideSlotTimeAction.name or
	   propName = CM_VehicleBookingTimeSlotType::myVBSSlotTypeCriteria.name	then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateDelete" id="e0583d62-be63-44b1-afb4-215be87c5e15">
        <source>validateDelete(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Oct 2014	cnwndl1	Initial creation
17 May 2023 navma1 	Bug 57887: MTN - Deleting Vehicle Booking Time Slot Type is not validating if the slot type used by a template
*/

vars

	iter     			   : Iterator;
	vbts     			   : CM_VehicleBookingTimeSlot;
	vbsTemplate 		   : CM_VehicleBookingDayTemplate;
	vbsTimeTemplate 	   : CM_VehicleBookingTimeTemplate;
	vehicleBookingTerminal : CM_VehicleBookingTerminal;
begin

	vehicleBookingTerminal := self.myTerminal.myVehicleBookingTerminal;						//17.05.2023 navma1 #57887
	
	//iter := CM_VehicleBookingTimeSlot.instances.createIterator;
	iter   := vehicleBookingTerminal.allVBTimeslotsById.createIterator;						//17.05.2023 navma1 #57887
	while iter.next( vbts ) do
		if vbts.myVBTimeSlotType = self then
			app.raiseCMException2(ObjectStillHasEntries, self.code, ' related Vehicle Booking Timeslot', null, null);
			break;
		endif;
	endwhile;

	
	
	foreach  vbsTemplate in vehicleBookingTerminal.allVehicleBookingDayTemplates do			//17.05.2023 navma1 #57887
		foreach vbsTimeTemplate in vbsTemplate.allTimeTemplates do
			if vbsTimeTemplate.myVBTimeslotType = self then
				app.raiseCMException2(ObjectStillHasEntries, self.code, ' related Vehicle Booking Time Slot Template', null, null);
			break;
			endif;
		endforeach;
	endforeach;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="c0be6a41-ad47-40ff-9514-85fb337b23d7">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Oct 2014	cnwndl1	Initial creation	Par 35008
21 Jun 2022 navma1 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
*/

vars
	type	: CM_VehicleBookingTimeSlotType;	
begin
	inheritMethod();
	
	//type := app.myRoot.allVehicleBookingTSTypes[self.code];               //21.06.2022 navma1 #53697
	type   := self.myTerminal.allTerminalVBSSlotTypes[self.code];			//21.06.2022 navma1 #53697
	if type &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, 'code', null);
	endif;
	
end;</source>
    </JadeMethod>
</Class>
