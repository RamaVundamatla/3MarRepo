    <JadeMethod name="doCmbLocaleBuild" id="9e792a84-7a71-41a1-97ff-0a599ae4c21b">
        <source>doCmbLocaleBuild(_debtor: CM_Debtor);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items

*/

vars
	
	locale,
	debtorLocale	: CM_Locale;
	
begin
	
	self.cmbLocale.clear();
	
	if app.myRoot.allLocales.isEmpty() then
		self.tblInvProperties.hideRowByName(ETRow_Locale, false);
		return;
	endif;
	
	foreach locale in app.myRoot.allLocales discreteLock do
		self.cmbLocale.addItemObject(locale.localeDescription, locale);
	endforeach;

	if _debtor &lt;&gt; null then
		locale := self.myCurrentInvoice.myLocale;
		debtorLocale := _debtor.getDebtorLocale();
		
		if _debtor = self.myCurrentInvoice.debtor then
			if locale &lt;&gt; null then
				self.cmbLocale.listObject := locale;
				self.cmbLocale.listIndex := self.cmbLocale.findObject(locale);
			endif;
		elseif debtorLocale &lt;&gt; null then
			self.cmbLocale.listObject := debtorLocale;
			self.cmbLocale.listIndex := self.cmbLocale.findObject(debtorLocale);
		endif;
	endif;
	
	self.tblInvProperties.setValueByControlName(self.cmbLocale.name, self.cmbLocale.text);
epilog

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
