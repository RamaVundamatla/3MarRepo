	// Yard invoice type, ILT10 and ILT11 invoice line type, used in storage, charged to customs agent, calc type Days Since Receival
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX10", "CCT06", "UT_ILT10", null, invType);
	self.addIfNewServiceILD("UT_ServiceX11", "CCT06", "UT_ILT11", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT10"];
	invLineType2 := self.myBank.invoiceLineDescriptors["UT_ILT11"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	invLineType2.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX10"];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 20.00);
	service := self.myBank.services["UT_ServiceX11"];		// for double storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 40.00);
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 100.00);
	
	debtor := operator.debtor;
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 5.00);
	
	self.myVoyage := self.createVesselVoyageCash("JMT STAR", "JSTAR001", operator.code);
	self.assertTrueMsg(self.myVoyage &lt;&gt; null, "Voyage '" &amp; CashVoyageCode &amp; "' not created...");

	self.tranMapLoadMultipleReceipts();
	
	// one receipt, 2 cargo items with negative extras 
	cargoId1 := cargoIds[1];
	cargoId2 := cargoIds[2];
	self.cashTestExtras(cargoId1, cargoId2, drTerm1, 0);
	
epilog
	if currentFinClass &lt;&gt; null then
		self.setInvoiceFinancialClass(currentFinClass.class, null);
	endif;

	delete costs;
	delete debtorRate;
	delete cargoIds;
	self.resetDefaultTranMap();
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashOnShipReleaseDate" id="36ef1c65-d951-409b-8f23-ec71118f878f">
        <updating/>
        <source>tCashOnShipReleaseDate() updating;
/*
Date			Who		Reason
// cnwma1
// cnwjre1
24 Feb 2025		navtr3	MTN-34078: Unit test UT_Cash::tCashOnShipReleaseDate needs to be fixed
*/
vars
	count		: Integer;
	found		: Boolean;
	now			: TimeStamp;
	operator	: CM_Operator;
	customsAgent	: CM_CustomsAgent;
	debtor 		: CM_DebtorNode;
	ti			: CM_TrackedItem;
	invType		: CM_InvoiceDesc;
	ild			: CM_InvoiceLineDesc;
	invLine		: CM_InvoiceLine;
	voyage : CM_Voyage;
	debtorType	: CM_DebtorType;
	agent	: CM_CashInvoiceProformaAgent;
	allTIs 		: CM_TISet;
	allAgents	: ObjectArray;

	tran : CM_TITransaction;
	tranTS : TimeStamp;
	releaseDate	: Date;	
	releaseDate2	: Date; //navtr3 #34078 25th Feb 2025
	tranDate : Date;
begin


	operator := self.getOperator("PON");
	voyage := self.createTargetVesselVoyage(self.getTerminal(), "UMT CASH", "UCASH001", operator);
	
	self.opts.addAssoc("Operator", operator);
	self.createCashTestCargoOnShip(voyage);
	
	// check for invoice type and line type used in tran map
	foreach invType in CM_InvoiceDesc.instances discreteLock do 
		if invType.description = "UT_InvTypeStore" then
			found := true;
			break;
		endif;
	endforeach;
	if not found then
		invType := self.createInvoiceType("UT_InvTypeStore", InvoiceTypeStorage);
	endif;
	found := false;
	foreach ild in CM_InvoiceLineDesc.instances do
		if ild.narration = "UT_LineTypeStore1" then
			found := true;
			break;
		endif;
	endforeach;
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	// invoice line type debtor type can be changed and invoice type deleted by prior tests
	if found then
		if ild.myDebtorType &lt;&gt; debtorType then
			beginTransaction;
			ild.setPropertyValue("myDebtorType", debtorType);
			commitTransaction;
		endif;
		if ild.invoiceType = null then
			beginTransaction;
			ild.zSetInvoiceType(invType);
			commitTransaction;
		endif;
	endif;

	self.deleteInvoiceTransactionMap(1, 'UT_Storage');
	self.tranMapLoadSimpleStorage();
	
	create allAgents transient;
	create allTIs transient;
	foreach ti in voyage.allImportTIs do
		allTIs.add(ti);
	endforeach;
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	self.applyAgentToCargo(allTIs, debtorType, customsAgent);

	// first TI storage  10 days, ship release date in 5 days time, should be 5 days storage
	ti := voyage.allImportTIs.first;
	tranDate := tranDate + 5;
	releaseDate := tranDate;
	tranDate := tranDate + 5;
	now.setDate(tranDate);

	agent := self.createProformaAgent2(now, releaseDate, ti);
	allAgents.add(agent);
	foreach invLine in agent.allProformaInvLines do
		self.assertEqualMsg(invLine.quantity, 5.Real, "First agent storage quantity");
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 1, "First agent pro forma invoice lines");

	// second TI storage at 10 days, no ship release date, should be 10 days storage
	ti := voyage.allImportTIs.last;

	//agent := self.createProformaAgent(now, ti); 
	agent := self.createProformaAgent2(now, releaseDate2, ti); //navtr3 #34078 25th Feb 2025
	allAgents.add(agent);
	count := 0;
	foreach invLine in agent.allProformaInvLines do
		self.assertEqualMsg(invLine.quantity, 10.Real, "Second agent storage quantity");
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 1, "Second agent pro forma invoice lines");

epilog
	self.resetDefaultTranMap();
	delete allTIs;
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCashOverPay1" id="6eef2672-8c9b-4f41-bdb9-81f29fa9e87a">
        <updating/>
        <source>tCashOverPay1() updating;
// cnwma1

/*

Purpose:		Cash module testing of partial payments, splitting over invoice lines.

Parameters:			

Return Value:		


Date		Who		Reason
29/04/2014	cnwjre1	After par 33885
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
02/07/2019	jlgmh5	TFS 44275 is changing the way Cash Works if this fails with a 88618 error then probably
					issue in CM_CashInvoiceProformaAgent::getCurrentInvLines and showParentWithChild being set
// 10 Sep 2019	cnwrs1	TFS 46030
*/

constants

vars
/*
	isDutyDoc	: Boolean;
	multiTax	: Boolean;
	noImportStops	: Boolean;
	allowUnderpay	: Boolean;
	cargoId		: String;
	debtorName	: String;
	cargoIds	: StringArray;
	
	drTerm1 : CM_DebtorTerminal;
	drTerm2 : CM_DebtorTerminal;
	currentFinClass	: CM_ExtFinanceIO;
	
	costs : DecimalArray;
	service : CM_Service;
	debtorRate : CM_DebtorRate;

	endDate : Date;
	
	carrier : CM_Carrier;
	
	truckOut : CM_Vehicle;
	vvrOut : CM_VehicleVisitRecord;
	
	debtor		: CM_Debtor;
	proxyDebtor		: CM_Debtor;
	debtorNode	: CM_DebtorNode;
	debtorNodeController	: CMIF_DebtorNode;
	debtorType, deriveDebtorFrom	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	voyage			: CM_Voyage;
	showParentWithChild 	: Boolean;
	isDoClearanceCheck : Boolean;
	storageConfig : CM_StorageConfig;
	triggers		: CM_StorageTriggerByType;
	calendar		: CM_Calendar;
	defaultVoyageProcess : CM_VoyageProcess;
	*/
begin



	// TFS 45953 - It is no longer possible to over pay for cash so this unit test is no longer relevant.
	
	return;






/*






	// TFS 45953 PEL voyage process means no road exit cash validation and not moving invoice lines to cash invoice
	defaultVoyageProcess := CM_VoyageProcessDefault.firstInstance;
	beginTransaction;
	self.myTerminal.setConfig(DefaultVoyageProcess, defaultVoyageProcess.code);
	commitTransaction;

	// TFS 45953 - set the free storage period to be 12 days
	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	calendar := self.setupCalendar();
	create triggers transient;
	self.getAllStorageTriggers(triggers);
	storageConfig := self.setupStorageConfig10Days(calendar, false, false, 0, 0, false, false, deriveDebtorFrom, triggers, true);

	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	cashInvType := self.getInvoiceType("UT_InvType");		// cash receipt invoice type

	// turn off duty docs to get all the latest code; turn off terminal multi tax to avoid tax
	isDutyDoc := self.myTerminal.getConfig(DutyDocumentationEnabled).Boolean;
	multiTax := self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean;
	noImportStops := self.myTerminal.getConfig(NoImportStops).Boolean;
	allowUnderpay := self.myTerminal.getConfig(CashCollectAllowUnderpay).Boolean;
	showParentWithChild := true; // TFS 45953  self.myTerminal.getConfig(CashShowParentAndChildItems).Boolean;
	// set Oracle financials to get their external cash receipt number
	currentFinClass := getInvoiceFinancialClass();
	self.setInvoiceFinancialClass(CM_OracleFinancials, null);
	self.setTerminalConfig(DutyDocumentationEnabled, false);
	self.setDefaultBankCashInvoiceType(cashInvType);
	self.setTerminalConfig(InvoiceMultiTaxRates, false);
	self.setTerminalConfig(NoImportStops, true);
	self.setTerminalConfig(CashCollectAllowUnderpay, true);
	self.setTerminalConfig(CashInvoiceEveryReceipt, false); // TFS 45953
	//self.setTerminalConfig(CashShowParentAndChildItems, false);

	create cargoIds transient;
	// ids with valid check digits
	self.getCargoIds(cargoIds);
	foreach cargoId in cargoIds do
		self.deleteContainer(cargoId);
	endforeach;
	
	self.setTaxOnBank( false );
	
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	debtorName := "UT_Debtor1";
	debtor := app.myRoot.myRootCompany.debtorNodes[debtorName].CM_Debtor;
	if debtor = null then
		create debtorNodeController transient;
		create proxyDebtor transient;
		self.setDebtorNodeController1(debtorName, debtorNodeController, proxyDebtor);
		app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		debtor := debtorNode.CM_Debtor;
	endif;

	beginTransaction;
		operator.setPropertyValue(CM_Operator::debtor.name, debtor);
	commitTransaction;
	self.myOperator := operator;
	
	endDate := app.actualTimeServer.Date + 10;	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support

	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );
	
	//set up criteria permitted for this Bank in this terminal on pro forma allocation
	self.setBankAvailAllocCriteria();
	
	//set up Bank pro forma allocation
	self.setBankProFormaAllocations();
	
	//create Method of payment if needed
	self.myPaymentMethod :=  app.myRoot.allPaymentMethods.getAtKey(PayMethName);
	if self.myPaymentMethod = null then
		self.myPaymentMethod := self.createPaymentMethod(PayMethName);
	endif;
	self.assertTrueMsg(self.myPaymentMethod &lt;&gt; null, "Payment Method not created...");
	
	//create cash only debtors.
	self.myDebtor1 := app.myRoot.myRootCompany.debtors[DrNameOne];
	if self.myDebtor1 = null then
		self.myDebtor1 := self.addCashOnlyDebtor( DrNameOne );
	endif;
	self.assertTrueMsg(self.myDebtor1 &lt;&gt; null, "Cash only Debtor not created...");
	drTerm1 := self.myDebtor1.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	
	self.myDebtor2 := app.myRoot.myRootCompany.debtors[DrNameTwo];
	if self.myDebtor2 = null then
		self.myDebtor2 := self.addCashOnlyDebtor( DrNameTwo );
	endif;
	drTerm2 := self.myDebtor2.allDebtorTerminals.getAtKey( self.myTerminal );

	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;

	// Voyage invoice type, ILT8 invoice line type, used in ship receive, charged to shipping operator, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Voyage");
	self.addIfNewServiceILD("UT_ServiceX8", "CCT01", "UT_ILT8", null, invType);
	// set service rate
	service := self.myBank.services["UT_ServiceX8"];		// for receive ship
	self.setServiceRate(service, debtor, "01/01/2013".Date, 100.00);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT8"];
	debtorType := app.myRoot.allDebtorTypes["SDT4"];	// cargo operator
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;

	// Yard invoice type, ILT9 invoice line type, used in yard and road release, charged to customs agent, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX9", "CCT01", "UT_ILT9", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT9"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX9"];		// for move and road release
	self.setServiceRate(service, debtor, "01/01/2013".Date, 20.00);
	
	// Yard invoice type, ILT10 and ILT11 invoice line type, used in storage, charged to customs agent, calc type Days Since Receival
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX10", "CCT06", "UT_ILT10", null, invType);
	self.addIfNewServiceILD("UT_ServiceX11", "CCT06", "UT_ILT11", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT10"];
	invLineType2 := self.myBank.invoiceLineDescriptors["UT_ILT11"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	invLineType2.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX10"];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 20.00);
	service := self.myBank.services["UT_ServiceX11"];		// for double storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 40.00);
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 100.00);
	
	debtor := operator.debtor;
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 5.00);
	
	self.myVoyage := self.createVesselVoyageCash("JMT STAR", "JSTAR001", operator.code);
	self.assertTrueMsg(self.myVoyage &lt;&gt; null, "Voyage '" &amp; CashVoyageCode &amp; "' not created...");
	// create carrier and truck
	self.deleteVehicle(VehicleNumOut);
	carrier := self.addCarrier(CarrierName, CarrierName, self.allEmails, false, true, true, self.myDebtor1);
	self.assertNotNull(carrier);
	truckOut := self.addVehicle(VehicleNumOut, carrier, self.myTerminal);
	self.assertTrueMsg(truckOut &lt;&gt; null, "Truck not created...");
	
	self.tranMapLoadDoubleStorage();
	
	//Now create onsite cargo that will be gated out by truck.
	cargoId := "UTTU0010192";
	self.cashTestOverPay1(cargoId, drTerm1, truckOut);
	*/
epilog
/*
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	// TFS 45953 self.setTerminalConfig(CashShowParentAndChildItems, showParentWithChild);
	
	if currentFinClass &lt;&gt; null then
		self.setInvoiceFinancialClass(currentFinClass.class, null);
	endif;

	delete triggers;
	delete costs;
	delete debtorRate;
	delete cargoIds;
	//self.epilogCleanup();
	self.resetDefaultTranMap();
	*/
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCashPrenoteChildCargo" id="45eb4b0e-eb27-4097-8067-15bd960f8dd4">
        <updating/>
        <source>tCashPrenoteChildCargo() updating;
// cnwma1

/*

Purpose:		Cash module testing with child cargo and parent container from prenote, being paid while still
				prenoted then received and unpacked, for TFS 1616 (par 37542)

Parameters:			

Return Value:		


Date		Who		Reason
21/03/2016	cnwjre1	Test prenote payments for container and child, and status of payments after subsequent unpack
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
*/

constants

vars
	isDutyDoc	: Boolean;
	multiTax	: Boolean;
	noImportStops	: Boolean;
	cargoId		: String;
	debtorName	: String;
	cargoIds	: StringArray;
	
	drTerm1 : CM_DebtorTerminal;
	drTerm2 : CM_DebtorTerminal;
	currentFinClass	: CM_ExtFinanceIO;
	
	costs : DecimalArray;
	service : CM_Service;
	debtorRate : CM_DebtorRate;

	endDate : Date;
	
	carrier : CM_Carrier;
	truckOut : CM_Vehicle;
	
	debtor		: CM_Debtor;
	proxyDebtor		: CM_Debtor;
	debtorNode	: CM_DebtorNode;
	debtorNodeController	: CMIF_DebtorNode;
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1  	: CM_InvoiceLineDesc;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
begin

	cashInvType := self.getInvoiceType("UT_InvType");		// cash receipt invoice type

	// turn off duty docs to get all the latest code; turn off terminal multi tax to avoid tax
	isDutyDoc := self.myTerminal.getConfig(DutyDocumentationEnabled).Boolean;
	multiTax := self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean;
	noImportStops := self.myTerminal.getConfig(NoImportStops).Boolean;
	// set Oracle financials to get their external cash receipt number
	currentFinClass := getInvoiceFinancialClass();
	self.setInvoiceFinancialClass(CM_OracleFinancials, null);
	self.setTerminalConfig(DutyDocumentationEnabled, false);
	self.setDefaultBankCashInvoiceType(cashInvType);
	self.setTerminalConfig(InvoiceMultiTaxRates, false);
	self.setTerminalConfig(NoImportStops, true);


	create cargoIds transient;
	self.deleteContainer("UTTU0010191");
	
	self.setTaxOnBank( false );
	
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	debtorName := "UT_Debtor1";
	debtor := app.myRoot.myRootCompany.debtorNodes[debtorName].CM_Debtor;
	if debtor = null then
		create debtorNodeController transient;
		create proxyDebtor transient;
		self.setDebtorNodeController1(debtorName, debtorNodeController, proxyDebtor);
		app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		debtor := debtorNode.CM_Debtor;
	endif;

	beginTransaction;
		operator.setPropertyValue(CM_Operator::debtor.name, debtor);
	commitTransaction;
	self.myOperator := operator;
	
	endDate := app.actualTimeServer.Date + 10;	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support

	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );
	
	//set up criteria permitted for this Bank in this terminal on pro forma allocation
	self.setBankAvailAllocCriteria();
	
	//set up Bank pro forma allocation
	self.setBankProFormaAllocations();
	
	//create Method of payment if needed
	self.myPaymentMethod :=  app.myRoot.allPaymentMethods.getAtKey(PayMethName);
	if self.myPaymentMethod = null then
		self.myPaymentMethod := self.createPaymentMethod(PayMethName);
	endif;
	self.assertTrueMsg(self.myPaymentMethod &lt;&gt; null, "Payment Method not created...");
	
	//create cash only debtor.
	self.myDebtor1 := app.myRoot.myRootCompany.debtors[DrNameOne];
	if self.myDebtor1 = null then
		self.myDebtor1 := self.addCashOnlyDebtor( DrNameOne );
	endif;
	self.assertTrueMsg(self.myDebtor1 &lt;&gt; null, "Cash only Debtor not created...");
	drTerm1 := self.myDebtor1.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;

	// Voyage invoice type, ILT8 invoice line type, used in ship receive, charged to shipping operator, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Voyage");
	self.addIfNewServiceILD("UT_ServiceX8", "CCT01", "UT_ILT8", null, invType);
	// set service rate
	service := self.myBank.services["UT_ServiceX8"];		// for receive ship
	self.setServiceRate(service, debtor, "01/01/2013".Date, 100.00);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT8"];
	debtorType := app.myRoot.allDebtorTypes["SDT4"];	// cargo operator
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;

	// Yard invoice type, ILT9 invoice line type, used in yard and road release, charged to customs agent, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX9", "CCT01", "UT_ILT9", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT9"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX9"];		// for move and road release
	self.setServiceRate(service, debtor, "01/01/2013".Date, 20.00);
	
	// Yard invoice type, ILT10 invoice line type, used in storage, charged to customs agent, calc type Days Since Receival
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX10", "CCT06", "UT_ILT10", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT10"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX10"];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 10.00);
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 5.00);
	
	debtor := operator.debtor;
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 5.00);
	
	self.myVoyage := self.createVesselVoyageCash("JMT STAR", "JSTAR001", operator.code);
	self.assertTrueMsg(self.myVoyage &lt;&gt; null, "Voyage '" &amp; CashVoyageCode &amp; "' not created...");
	// create carrier and truck
	self.deleteVehicle(VehicleNumOut);
	carrier := self.addCarrier(CarrierName, CarrierName, self.allEmails, false, true, true, self.myDebtor1);
	self.assertNotNull(carrier);
	truckOut := self.addVehicle(VehicleNumOut, carrier, self.myTerminal);
	self.assertTrueMsg(truckOut &lt;&gt; null, "Truck not created...");
	
	self.tranMapLoadCashUnpack();
	
	//Now create onsite cargo that will be gated out by truck.
	cargoId := "UTTU0010191";
	self.cashTestPrenoteChildCargo(cargoId, drTerm1, truckOut);

epilog
	if currentFinClass &lt;&gt; null then
		self.setInvoiceFinancialClass(currentFinClass.class, null);
	endif;

	delete costs;
	delete debtorRate;
	delete cargoIds;
	
	self.resetDefaultTranMap();
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashReceiptJMTChangeStatus1" id="8d1cc079-8899-42b4-a02d-5de494abbf4c">
        <updating/>
        <source>tCashReceiptJMTChangeStatus1() updating;
/*

Purpose:			API Draft &gt; API Hold &gt; JMT Draft &gt; Gate out 

Parameters:			

Return Value:		

Date		Who		Reason
06/06/2025	navkc1 JIRA MTN 34779 MTN | Cash Status Change for Special Users.

*/
constants
	CEN = "UTCEN";
	CEN2 = "UTCEN2";
	VOYCODE = "CASHAPIVOY";
	VESSCODE = "CASHAPIVESS";
	CARGOID = "33930-1";
	TRANMAP = "CASHAPI";
	EXTUSER1 = "USER1";
	EXTUSER2 = "USER2";
	INVLINEDESC1 = "UT33930-1";
	INVLINEDESC2 = "UT33930-2";
	TODOTASKDESC = "33930TDT";
	TRUCKID = "33930T";
	CARRIERID = "33930C";
vars
	err,
	fileContext,				
	itemCode,
	cargoId,
	voyCode,
	agentId					: String;
	
	today,
	effectiveDate 			: Date;
	
	ts						: TimeStamp;
	receiptNumber			: Integer;
	
	vvr						: CM_VehicleVisitRecord;
	tm						: CM_TranMap;
	voyage					: CM_Voyage;
	operator				: CM_Operator;
	ti,	ti1					: CM_TrackedItem;
	debtorType				: CM_DebtorType;
	customagent				: CM_CustomsAgent;
	terminal				: CM_Terminal;
	debtorNode				: CM_DebtorNode;
	debtor					: CM_Debtor;
	debtorTerminal			: CM_DebtorTerminal;
	bank					: CM_Bank;
	proxyCriteria			: CM_YACriteria;
	proxyProCrit 			: CM_ProformaTransactionCriteria;
	realProCrit 			: CM_ProformaTransactionCriteria;
	value 					: Any;
	criterias				: CMIF_Array;
	cmifCriteria 			: CMIF_YACriteriaPriority;
	selectedTrxTypes		: CM_TransactionTypeByType;
	critType 				: CM_YACriteriaType;
	pxyTransService 		: CM_TransServiceBroker;
	pxyCashReceipt,
	cashReceipt,
	cashReceiptForBoth		: CM_CashReceipt;
	invLineDesc1,
	invLineDesc2 			: CM_InvoiceLineDesc;
	services				: CM_ServiceByNameDict;
	cmifCashAgent			: CMIF_CashInvoiceProformaCtrl;
	tiSet					: CM_TISet;
	toDoTaskDesc			: CM_ToDoTaskDesc;
	ta1						: CM_TerminalArea;
	tiTrans					: CM_TITransaction;
	actualMess, expectedMess1 : String;
	offlineActor			: CM_OfflineFutureActor;
begin
	//return;
	create services transient;
	create cmifCashAgent transient;
	create tiSet transient; 
	// Terminal Area
	ta1 := self.addBlockStack("UTPHT1",9999999,null);
	self.assertNotNullMsg(ta1, "Failed to create TA1");
	
	// Terminal
	terminal := self.getMyTerminal();
	
	// Operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// Custom Agent
	customagent := self.addCustomsAgent("APIAGENT", "UTCASHAPI");
	self.assertNotNullMsg(customagent, "Failed to create customs agent");
	
	// Delete Truck
	self.deleteVehicle(TRUCKID);
	self.deleteCarrier(CARRIERID);
	
	// Create To Do Task Desc
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[TODOTASKDESC];
	if toDoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc);
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("CargoType", app.myRoot.allCargoTypesById[TI_CargoType_BreakBulk]);
	toDoTaskDesc := self.createToDoTaskDesc(TODOTASKDESC);
	self.assertNotNullMsg(toDoTaskDesc, "Failed to create to do task desc");
	
	// Debtor
	debtor := self.getDebtor("APIDEBT");
	if debtor = null then
		debtorNode := self.addDebtor("APIDEBT", PaymentType_None);
		debtor := debtorNode.CM_Debtor;
	endif;
	beginTransaction;
		customagent.setDebtor(debtor);
	commitTransaction;
	debtorTerminal := debtor.allDebtorTerminals[terminal];
	self.setDebtorCashOnly(debtor, terminal, true);
	
	// Set terminal to Cash config
	self.enableCashOnlyTerminal(terminal, true);
	self.setTerminalConfig(UseCashStatusAdvBGP, true);
	self.setTerminalConfig(CashRoadExitChkServices, true);
	self.setTerminalConfig(CashOnlyInDebtOption, 1);
	
	// Get Invoice Line Type
	invLineDesc1 := self.getInvoiceLineType(INVLINEDESC1); // Days Since receival
	self.assertNotNullMsg(invLineDesc1, "Failed to get invoice line type 1");
	invLineDesc2 := self.getInvoiceLineType(INVLINEDESC2); // Cargo Value of 1
	self.assertNotNullMsg(invLineDesc1, "Failed to get invoice line type 2");
	
	// Setup transaction mapping
	tm := self.getTransactionMap(TRANMAP);
	if tm = null then
		tm := self.createTransactionMap(TRANMAP);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;	
	self.assertNotNullMsg(tm, "Failed to create transaction mapping");
	app.myTrxUA.trxUpdateBankTMActive(tm, app.myPassport);
	
	fileContext := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) †,(Default),,,**Any**,All,VOID
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Released - Road,,(Default),(Default) †,(Default),,,**Any**,All,UT33930-1
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Todo Task Added,,(Default),(Default) ›,(Default),,,**Any**,All,UT33930-2';

	self.transactionMapLoad(fileContext, null);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	
	// Setup cash config
	debtorType := app.myRoot.allDebtorTypes["SDT6"];
	self.assertNotNullMsg(debtorType, "Failed to get cash debtor type");
	self.setTerminalConfig(CashDebtorType, debtorType);
	
	bank := terminal.getDefaultCompanyBank();
	
	create criterias transient;
	critType := app.myRoot.allYACriteriaTypes.getAtKey(19);	//Operator
	create proxyCriteria transient;
	itemCode := critType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	value := operator.code;
	proxyCriteria.setProxy(critType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	criterias.add(cmifCriteria);
	
	create selectedTrxTypes transient;
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[32] ); // Receive Ship
	
	create proxyProCrit transient;
	proxyProCrit.setProxy( criterias, selectedTrxTypes, 2, bank, null, null, null, null, null,null );
	app.myTrxCA.trxCreateProformaCriteria(proxyProCrit, realProCrit, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Pro Forma allocation create failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete proxyProCrit;
	
	// Setup storage config
	self.deleteStorageConfig(true);
	
	// Create voyage
	self.opts.purge();
	self.opts.addAssoc("dateArrival", today.addDays(-30));
	voyage := self.createVesselVoyage(VOYCODE, VESSCODE, operator);
	self.assertNotNullMsg(voyage, "Failed to create voyage");
	
	// Create cargo 1
	self.opts.purge();
	cargoId := CARGOID&amp;today.asStringJMT();
	
	ti1 := self.getTrackedItem(cargoId);
	if ti1 &lt;&gt; null then
		self.deleteTrackedItem(ti1, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	ti1 := self.addCargoForVoyage(voyage, cargoId);
	self.assertNotNullMsg(ti1, "Failed to creatt TI1");
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_IMPORT, true);
	
	// Set Customs Agent and Customs Entry Number
	beginTransaction;
	ti1.setCustomsAgent(customagent);
	ti1.setCustomsEntryNumber(CEN);
	commitTransaction;
	
	tiSet.clear();
	tiSet.add(ti1);
	
	// Discharge cargo
	self.moveCargo(ti1, tiSet, ta1.allLocationsControllers.first(), app.myPassport);
	// Set transaction date to 30 days ago
	beginTransaction;
		foreach ti in tiSet do
			tiTrans := ti.getLastTransOfType(TRANS_TYPE_REC_SHIP); // Received Ship transaction
			ts.setDate(today.addDays(-30));
			tiTrans.setPropertyValue("dateTime", ts);
			ti.setPropertyValue("receivedDT", ts);
		endforeach;
	commitTransaction;
	
	self.opts.purge();
	self.opts.addAssoc("CENum", CEN);
	
	// Delete stops
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	tiSet.clear();
	
	
	/*
	===================================
	Create Draft receipt
	===================================
	*/
	
	// Init details for Cash CMIF
		voyCode := voyage.code;
		today := app.actualTimeServer().date();
		effectiveDate := today;
		agentId := customagent.code;
		
		// Initialize CMIF	
		delete cmifCashAgent;
		create cmifCashAgent transient;
		cmifCashAgent.initialize(voyCode, null, CEN, cargoId, effectiveDate, voyage.arrivedDT.date(), terminal, agentId, false, true);
		cmifCashAgent.setExternalFields(null, null, null, null, "USER1", null);
		cmifCashAgent.doValidateCashCalculate(err);
		self.assertNullMsg(err, "TI1 - CMIF agent validation failed - " &amp; err &amp; ", " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
		// Do calulate cash amout
		cmifCashAgent.doCalculate();
		
		// Get Cash receipt
		cashReceipt := cmifCashAgent.myNewCashReceipt;
		self.assertNotNullMsg(cashReceipt, "TI1 - Failed to create cash receipt");
		
	/*========================================	
	Change Cash Receipt status to HOLD using API
	========================================	*/
		receiptNumber := cashReceipt.sequenceNum;
		delete cmifCashAgent;
		create cmifCashAgent transient;
		
		cmifCashAgent.initializeForProformaStatus(agentId, CEN, receiptNumber, null, null, null, null, null, null, CM_CashReceipt.API_RECEIPT_HOLD, terminal);
		cmifCashAgent.setExternalFields(null, null, null, null, "USER1", null);
		cmifCashAgent.doChangeProformaStatusFromAPI();
		self.assertTrueMsg(cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "TI - Cash Receipt status update to HOLD failed - " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
	/*========================================	
	Change Cash Receipt status to DRAFT from JMT Cash Receipt Enq
	========================================	*/
		delete pxyCashReceipt;
		beginLoad;
		pxyCashReceipt := cashReceipt.pxyCreateUpdateProxy();
		endLoad;
		
		app.myTrxUA.trxCashReceiptJMTUpdateStatus(pxyCashReceipt, CM_CashReceipt.API_RECEIPT_DRAFT, app.myPassport);
	
	/*========================================	
	Check scenarios
	========================================	*/
		// No errors
		self.assertTrueMsg(app.myPassport.noErrors(), app.myPassport.getErrorsAsString());
		// Payment status is changed to Draft
		self.assertEqualMsg(cashReceipt.paymentStatus, CM_CashReceipt.API_RECEIPT_DRAFT, "Cash receipt status is " &amp; app.paymentStatusCashEnumToString(cashReceipt.paymentStatus));
		// Check BGP is created
		offlineActor := app.myRoot.getFutureActor(cashReceipt, CM_CashStatusAdvanceProcess);
		self.assertNotNullMsg(offlineActor, "BGP not created for the draft receipt");
		// Check gate out is returning error
		self.deleteStops(ti);
		self.deleteVehicle(TRUCKID);
		vvr := self.gateOutGC(TRUCKID, null, "UTDRIVER", ti, self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString()), null);
		self.assertNotNullMsg(vvr, "TI - Failed to create VVR");
		self.clearExpectedTrxErrors();
		self.expectedTrxErrors.add(Cash_cargo_not_paid);
		app.myValUA.valCashCollectionForVVR(vvr,true,true,null,app.myPassport);
		self.assertTrxErrorMsg(Cash_cargo_not_paid, "Error not raised 001");
		/*actualMess := app.myPassport.getErrorsAsString();
		expectedMess1 := "for cash-only debtor APIDEBT is not fully paid for

Cash Total Required = 4629.900000
Cash Paid So Far = 0.000000
Cash Outstanding = 4629.900000";
		self.assertTrueMsg(actualMess.pos(expectedMess1, 1) &gt; 0, "Error not raised 001 - " &amp; actualMess);*/
epilog
	self.deleteVehicle(TRUCKID);
	self.resetDefaultTranMap();
	self.deleteVoyage(VOYCODE);
	self.deleteTrackedItem(ti1, true);
	self.deleteVessel(VESSCODE);
	if criterias &lt;&gt; null then
		criterias.purge();
	endif;
	delete criterias;
	delete selectedTrxTypes;
	delete proxyProCrit;
	delete pxyCashReceipt;
	if realProCrit &lt;&gt; null then
		app.myTrxDA.trxDeleteProformaCriteria(realProCrit, app.myPassport);
	endif;
	if cashReceipt &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt);
	endif;
	if cashReceiptForBoth &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceiptForBoth);
	endif;
	delete pxyTransService;
	delete services;
	delete cmifCashAgent;
	delete tiSet;
	if vvr &lt;&gt; null and app.isValidObject(vvr) then
		self.deleteVVR(vvr);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashReceiptJMTChangeStatus2" id="4d82d4ef-bb17-4033-8e55-8fcdec1b2c48">
        <updating/>
        <source>tCashReceiptJMTChangeStatus2() updating;
/*

Purpose:			API Draft &gt; API Hold &gt; JMT Draft &gt; API Hold &gt; Check gate out

Parameters:			

Return Value:		

Date		Who		Reason
06/06/2025	navkc1 JIRA MTN 34779 MTN | Cash Status Change for Special Users.

*/
constants
	CEN = "UTCEN";
	CEN2 = "UTCEN2";
	VOYCODE = "CASHAPIVOY";
	VESSCODE = "CASHAPIVESS";
	CARGOID = "33930-1";
	TRANMAP = "CASHAPI";
	EXTUSER1 = "USER1";
	EXTUSER2 = "USER2";
	INVLINEDESC1 = "UT33930-1";
	INVLINEDESC2 = "UT33930-2";
	TODOTASKDESC = "33930TDT";
	TRUCKID = "33930T";
	CARRIERID = "33930C";
vars
	err,
	fileContext,				
	itemCode,
	cargoId,
	voyCode,
	agentId					: String;
	
	today,
	effectiveDate 			: Date;
	
	ts						: TimeStamp;
	receiptNumber			: Integer;
	
	vvr						: CM_VehicleVisitRecord;
	tm						: CM_TranMap;
	voyage					: CM_Voyage;
	operator				: CM_Operator;
	ti,	ti1					: CM_TrackedItem;
	debtorType				: CM_DebtorType;
	customagent				: CM_CustomsAgent;
	terminal				: CM_Terminal;
	debtorNode				: CM_DebtorNode;
	debtor					: CM_Debtor;
	debtorTerminal			: CM_DebtorTerminal;
	bank					: CM_Bank;
	proxyCriteria			: CM_YACriteria;
	proxyProCrit 			: CM_ProformaTransactionCriteria;
	realProCrit 			: CM_ProformaTransactionCriteria;
	value 					: Any;
	criterias				: CMIF_Array;
	cmifCriteria 			: CMIF_YACriteriaPriority;
	selectedTrxTypes		: CM_TransactionTypeByType;
	critType 				: CM_YACriteriaType;
	pxyTransService 		: CM_TransServiceBroker;
	pxyCashReceipt,
	cashReceipt,
	cashReceiptForBoth		: CM_CashReceipt;
	invLineDesc1,
	invLineDesc2 			: CM_InvoiceLineDesc;
	services				: CM_ServiceByNameDict;
	cmifCashAgent			: CMIF_CashInvoiceProformaCtrl;
	tiSet					: CM_TISet;
	toDoTaskDesc			: CM_ToDoTaskDesc;
	ta1						: CM_TerminalArea;
	tiTrans					: CM_TITransaction;
	actualMess, expectedMess1 : String;
	offlineActor			: CM_OfflineFutureActor;
begin
	//return;
	create services transient;
	create cmifCashAgent transient;
	create tiSet transient; 
	// Terminal Area
	ta1 := self.addBlockStack("UTPHT1",9999999,null);
	self.assertNotNullMsg(ta1, "Failed to create TA1");
	
	// Terminal
	terminal := self.getMyTerminal();
	
	// Operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// Custom Agent
	customagent := self.addCustomsAgent("APIAGENT", "UTCASHAPI");
	self.assertNotNullMsg(customagent, "Failed to create customs agent");
	
	// Delete Truck
	self.deleteVehicle(TRUCKID);
	self.deleteCarrier(CARRIERID);
	
	// Create To Do Task Desc
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[TODOTASKDESC];
	if toDoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc);
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("CargoType", app.myRoot.allCargoTypesById[TI_CargoType_BreakBulk]);
	toDoTaskDesc := self.createToDoTaskDesc(TODOTASKDESC);
	self.assertNotNullMsg(toDoTaskDesc, "Failed to create to do task desc");
	
	// Debtor
	debtor := self.getDebtor("APIDEBT");
	if debtor = null then
		debtorNode := self.addDebtor("APIDEBT", PaymentType_None);
		debtor := debtorNode.CM_Debtor;
	endif;
	beginTransaction;
		customagent.setDebtor(debtor);
	commitTransaction;
	debtorTerminal := debtor.allDebtorTerminals[terminal];
	self.setDebtorCashOnly(debtor, terminal, true);
	
	// Set terminal to Cash config
	self.enableCashOnlyTerminal(terminal, true);
	self.setTerminalConfig(UseCashStatusAdvBGP, true);
	self.setTerminalConfig(CashRoadExitChkServices, true);
	self.setTerminalConfig(CashOnlyInDebtOption, 1);
	
	// Get Invoice Line Type
	invLineDesc1 := self.getInvoiceLineType(INVLINEDESC1); // Days Since receival
	self.assertNotNullMsg(invLineDesc1, "Failed to get invoice line type 1");
	invLineDesc2 := self.getInvoiceLineType(INVLINEDESC2); // Cargo Value of 1
	self.assertNotNullMsg(invLineDesc1, "Failed to get invoice line type 2");
	
	// Setup transaction mapping
	tm := self.getTransactionMap(TRANMAP);
	if tm = null then
		tm := self.createTransactionMap(TRANMAP);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;	
	self.assertNotNullMsg(tm, "Failed to create transaction mapping");
	app.myTrxUA.trxUpdateBankTMActive(tm, app.myPassport);
	
	fileContext := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) †,(Default),,,**Any**,All,VOID
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Released - Road,,(Default),(Default) †,(Default),,,**Any**,All,UT33930-1
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Todo Task Added,,(Default),(Default) ›,(Default),,,**Any**,All,UT33930-2';

	self.transactionMapLoad(fileContext, null);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	
	// Setup cash config
	debtorType := app.myRoot.allDebtorTypes["SDT6"];
	self.assertNotNullMsg(debtorType, "Failed to get cash debtor type");
	self.setTerminalConfig(CashDebtorType, debtorType);
	
	bank := terminal.getDefaultCompanyBank();
	
	create criterias transient;
	critType := app.myRoot.allYACriteriaTypes.getAtKey(19);	//Operator
	create proxyCriteria transient;
	itemCode := critType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	value := operator.code;
	proxyCriteria.setProxy(critType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	criterias.add(cmifCriteria);
	
	create selectedTrxTypes transient;
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[32] ); // Receive Ship
	
	create proxyProCrit transient;
	proxyProCrit.setProxy( criterias, selectedTrxTypes, 2, bank, null, null, null, null, null,null );
	app.myTrxCA.trxCreateProformaCriteria(proxyProCrit, realProCrit, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Pro Forma allocation create failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete proxyProCrit;
	
	// Setup storage config
	self.deleteStorageConfig(true);
	
	// Create voyage
	self.opts.purge();
	self.opts.addAssoc("dateArrival", today.addDays(-30));
	voyage := self.createVesselVoyage(VOYCODE, VESSCODE, operator);
	self.assertNotNullMsg(voyage, "Failed to create voyage");
	
	// Create cargo 1
	self.opts.purge();
	cargoId := CARGOID&amp;today.asStringJMT();
	
	ti1 := self.getTrackedItem(cargoId);
	if ti1 &lt;&gt; null then
		self.deleteTrackedItem(ti1, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	ti1 := self.addCargoForVoyage(voyage, cargoId);
	self.assertNotNullMsg(ti1, "Failed to creatt TI1");
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_IMPORT, true);
	
	// Set Customs Agent and Customs Entry Number
	beginTransaction;
	ti1.setCustomsAgent(customagent);
	ti1.setCustomsEntryNumber(CEN);
	commitTransaction;
	
	tiSet.clear();
	tiSet.add(ti1);
	
	// Discharge cargo
	self.moveCargo(ti1, tiSet, ta1.allLocationsControllers.first(), app.myPassport);
	// Set transaction date to 30 days ago
	beginTransaction;
		foreach ti in tiSet do
			tiTrans := ti.getLastTransOfType(TRANS_TYPE_REC_SHIP); // Received Ship transaction
			ts.setDate(today.addDays(-30));
			tiTrans.setPropertyValue("dateTime", ts);
			ti.setPropertyValue("receivedDT", ts);
		endforeach;
	commitTransaction;
	
	self.opts.purge();
	self.opts.addAssoc("CENum", CEN);
	
	// Delete stops
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	tiSet.clear();
	
	
	/*
	===================================
	Create Draft receipt
	===================================
	*/
	
	// Init details for Cash CMIF
		voyCode := voyage.code;
		today := app.actualTimeServer().date();
		effectiveDate := today;
		agentId := customagent.code;
		
		// Initialize CMIF	
		delete cmifCashAgent;
		create cmifCashAgent transient;
		cmifCashAgent.initialize(voyCode, null, CEN, cargoId, effectiveDate, voyage.arrivedDT.date(), terminal, agentId, false, true);
		cmifCashAgent.setExternalFields(null, null, null, null, "USER1", null);
		cmifCashAgent.doValidateCashCalculate(err);
		self.assertNullMsg(err, "TI1 - CMIF agent validation failed - " &amp; err &amp; ", " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
		// Do calulate cash amout
		cmifCashAgent.doCalculate();
		
		// Get Cash receipt
		cashReceipt := cmifCashAgent.myNewCashReceipt;
		self.assertNotNullMsg(cashReceipt, "TI1 - Failed to create cash receipt");
		
	/*========================================	
	Change Cash Receipt status to HOLD using API
	========================================	*/
		receiptNumber := cashReceipt.sequenceNum;
		delete cmifCashAgent;
		create cmifCashAgent transient;
		
		cmifCashAgent.initializeForProformaStatus(agentId, CEN, receiptNumber, null, null, null, null, null, null, CM_CashReceipt.API_RECEIPT_HOLD, terminal);
		cmifCashAgent.setExternalFields(null, null, null, null, "USER1", null);
		cmifCashAgent.doChangeProformaStatusFromAPI();
		self.assertTrueMsg(cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "TI - Cash Receipt status update to HOLD failed - " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
	/*========================================	
	Change Cash Receipt status to DRAFT from JMT Cash Receipt Enq
	========================================	*/
		delete pxyCashReceipt;
		beginLoad;
		pxyCashReceipt := cashReceipt.pxyCreateUpdateProxy();
		endLoad;
		
		app.myTrxUA.trxCashReceiptJMTUpdateStatus(pxyCashReceipt, CM_CashReceipt.API_RECEIPT_DRAFT, app.myPassport);
		delete pxyCashReceipt;
	/*========================================	
	Check scenarios
	========================================	*/
		// No errors
		self.assertTrueMsg(app.myPassport.noErrors(), app.myPassport.getErrorsAsString());
		// Payment status is changed to Draft
		self.assertEqualMsg(cashReceipt.paymentStatus, CM_CashReceipt.API_RECEIPT_DRAFT, "Cash receipt status is " &amp; app.paymentStatusCashEnumToString(cashReceipt.paymentStatus));
		// Check BGP is created
		offlineActor := app.myRoot.getFutureActor(cashReceipt, CM_CashStatusAdvanceProcess);
		self.assertNotNullMsg(offlineActor, "BGP not created for the draft receipt");
		
	/*===================================
	Change cash receipt status to HOLD using API
	===================================*/
		receiptNumber := cashReceipt.sequenceNum;
		delete cmifCashAgent;
		create cmifCashAgent transient;
		
		cmifCashAgent.initializeForProformaStatus(agentId, CEN, receiptNumber, null, null, null, null, null, null, CM_CashReceipt.API_RECEIPT_HOLD, terminal);
		cmifCashAgent.setExternalFields(null, null, null, null, "USER1", null);
		cmifCashAgent.doChangeProformaStatusFromAPI();
		self.assertTrueMsg(cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "TI - Cash Receipt status update to HOLD failed - " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
	// Check gate out is returning error
		self.deleteStops(ti);
		self.deleteVehicle(TRUCKID);
		vvr := self.gateOutGC(TRUCKID, null, "UTDRIVER", ti, self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString()), null);
		self.assertNotNullMsg(vvr, "TI - Failed to create VVR");
		self.clearExpectedTrxErrors();
		self.expectedTrxErrors.add(Cash_cargo_not_paid);
		app.myValUA.valCashCollectionForVVR(vvr,true,true,null,app.myPassport);
		self.assertTrxErrorMsg(Cash_cargo_not_paid, "Error not raised 001");
		/*actualMess := app.myPassport.getErrorsAsString();
		expectedMess1 := "for cash-only debtor APIDEBT is not fully paid for

Cash Total Required = 4629.900000
Cash Paid So Far = 0.000000
Cash Outstanding = 4629.900000";
		self.assertTrueMsg(actualMess.pos(expectedMess1, 1) &gt; 0, "Error not raised 001");*/
epilog
	self.deleteVehicle(TRUCKID);
	self.resetDefaultTranMap();
	self.deleteVoyage(VOYCODE);
	self.deleteTrackedItem(ti1, true);
	self.deleteVessel(VESSCODE);
	if criterias &lt;&gt; null then
		criterias.purge();
	endif;
	delete criterias;
	delete selectedTrxTypes;
	delete proxyProCrit;
	delete pxyCashReceipt;
	if realProCrit &lt;&gt; null then
		app.myTrxDA.trxDeleteProformaCriteria(realProCrit, app.myPassport);
	endif;
	if cashReceipt &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt);
	endif;
	if cashReceiptForBoth &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceiptForBoth);
	endif;
	delete pxyTransService;
	delete services;
	delete cmifCashAgent;
	delete tiSet;
	if vvr &lt;&gt; null and app.isValidObject(vvr) then
		self.deleteVVR(vvr);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashReceiptJMTChangeStatus3" id="55e4ec20-e35e-461f-be53-f43f03400e71">
        <updating/>
        <source>tCashReceiptJMTChangeStatus3() updating;
/*

Purpose:			API Draft &gt; API Hold &gt; JMT Draft &gt; API Hold &gt; API Paid &gt; Check Gate out

Parameters:			

Return Value:		

Date		Who		Reason
06/06/2025	navkc1 JIRA MTN 34779 MTN | Cash Status Change for Special Users.

*/
constants
	CEN = "UTCEN";
	CEN2 = "UTCEN2";
	VOYCODE = "CASHAPIVOY";
	VESSCODE = "CASHAPIVESS";
	CARGOID = "33930-1";
	TRANMAP = "CASHAPI";
	EXTUSER1 = "USER1";
	EXTUSER2 = "USER2";
	INVLINEDESC1 = "UT33930-1";
	INVLINEDESC2 = "UT33930-2";
	TODOTASKDESC = "33930TDT";
	TRUCKID = "33930T";
	CARRIERID = "33930C";
vars
	err,
	fileContext,				
	itemCode,
	cargoId,
	voyCode,
	agentId					: String;
	
	today,
	effectiveDate 			: Date;
	
	ts						: TimeStamp;
	receiptNumber			: Integer;
	
	vvr						: CM_VehicleVisitRecord;
	tm						: CM_TranMap;
	voyage					: CM_Voyage;
	operator				: CM_Operator;
	ti,	ti1					: CM_TrackedItem;
	debtorType				: CM_DebtorType;
	customagent				: CM_CustomsAgent;
	terminal				: CM_Terminal;
	debtorNode				: CM_DebtorNode;
	debtor					: CM_Debtor;
	debtorTerminal			: CM_DebtorTerminal;
	bank					: CM_Bank;
	proxyCriteria			: CM_YACriteria;
	proxyProCrit 			: CM_ProformaTransactionCriteria;
	realProCrit 			: CM_ProformaTransactionCriteria;
	value 					: Any;
	criterias				: CMIF_Array;
	cmifCriteria 			: CMIF_YACriteriaPriority;
	selectedTrxTypes		: CM_TransactionTypeByType;
	critType 				: CM_YACriteriaType;
	pxyTransService 		: CM_TransServiceBroker;
	pxyCashReceipt,
	cashReceipt,
	cashReceiptForBoth		: CM_CashReceipt;
	invLineDesc1,
	invLineDesc2 			: CM_InvoiceLineDesc;
	services				: CM_ServiceByNameDict;
	cmifCashAgent			: CMIF_CashInvoiceProformaCtrl;
	tiSet					: CM_TISet;
	toDoTaskDesc			: CM_ToDoTaskDesc;
	ta1						: CM_TerminalArea;
	tiTrans					: CM_TITransaction;
	offlineActor			: CM_OfflineFutureActor;
begin
	//return;
	create services transient;
	create cmifCashAgent transient;
	create tiSet transient; 
	// Terminal Area
	ta1 := self.addBlockStack("UTPHT1",9999999,null);
	self.assertNotNullMsg(ta1, "Failed to create TA1");
	
	// Terminal
	terminal := self.getMyTerminal();
	
	// Operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// Custom Agent
	customagent := self.addCustomsAgent("APIAGENT", "UTCASHAPI");
	self.assertNotNullMsg(customagent, "Failed to create customs agent");
	
	// Delete Truck
	self.deleteVehicle(TRUCKID);
	self.deleteCarrier(CARRIERID);
	
	// Create To Do Task Desc
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[TODOTASKDESC];
	if toDoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc);
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("CargoType", app.myRoot.allCargoTypesById[TI_CargoType_BreakBulk]);
	toDoTaskDesc := self.createToDoTaskDesc(TODOTASKDESC);
	self.assertNotNullMsg(toDoTaskDesc, "Failed to create to do task desc");
	
	// Debtor
	debtor := self.getDebtor("APIDEBT");
	if debtor = null then
		debtorNode := self.addDebtor("APIDEBT", PaymentType_None);
		debtor := debtorNode.CM_Debtor;
	endif;
	beginTransaction;
		customagent.setDebtor(debtor);
	commitTransaction;
	debtorTerminal := debtor.allDebtorTerminals[terminal];
	self.setDebtorCashOnly(debtor, terminal, true);
	
	// Set terminal to Cash config
	self.enableCashOnlyTerminal(terminal, true);
	self.setTerminalConfig(UseCashStatusAdvBGP, true);
	self.setTerminalConfig(CashRoadExitChkServices, true);
	self.setTerminalConfig(CashOnlyInDebtOption, 1);
	
	// Get Invoice Line Type
	invLineDesc1 := self.getInvoiceLineType(INVLINEDESC1); // Days Since receival
	self.assertNotNullMsg(invLineDesc1, "Failed to get invoice line type 1");
	invLineDesc2 := self.getInvoiceLineType(INVLINEDESC2); // Cargo Value of 1
	self.assertNotNullMsg(invLineDesc1, "Failed to get invoice line type 2");
	
	// Setup transaction mapping
	tm := self.getTransactionMap(TRANMAP);
	if tm = null then
		tm := self.createTransactionMap(TRANMAP);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;	
	self.assertNotNullMsg(tm, "Failed to create transaction mapping");
	app.myTrxUA.trxUpdateBankTMActive(tm, app.myPassport);
	
	fileContext := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) †,(Default),,,**Any**,All,VOID
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Released - Road,,(Default),(Default) †,(Default),,,**Any**,All,UT33930-1
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Todo Task Added,,(Default),(Default) ›,(Default),,,**Any**,All,UT33930-2';

	self.transactionMapLoad(fileContext, null);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	
	// Setup cash config
	debtorType := app.myRoot.allDebtorTypes["SDT6"];
	self.assertNotNullMsg(debtorType, "Failed to get cash debtor type");
	self.setTerminalConfig(CashDebtorType, debtorType);
	
	bank := terminal.getDefaultCompanyBank();
	
	create criterias transient;
	critType := app.myRoot.allYACriteriaTypes.getAtKey(19);	//Operator
	create proxyCriteria transient;
	itemCode := critType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	value := operator.code;
	proxyCriteria.setProxy(critType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	criterias.add(cmifCriteria);
	
	create selectedTrxTypes transient;
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[32] ); // Receive Ship
	
	create proxyProCrit transient;
	proxyProCrit.setProxy( criterias, selectedTrxTypes, 2, bank, null, null, null, null, null,null );
	app.myTrxCA.trxCreateProformaCriteria(proxyProCrit, realProCrit, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Pro Forma allocation create failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete proxyProCrit;
	
	// Setup storage config
	self.deleteStorageConfig(true);
	
	// Create voyage
	self.opts.purge();
	self.opts.addAssoc("dateArrival", today.addDays(-30));
	voyage := self.createVesselVoyage(VOYCODE, VESSCODE, operator);
	self.assertNotNullMsg(voyage, "Failed to create voyage");
	
	// Create cargo 1
	self.opts.purge();
	cargoId := CARGOID&amp;today.asStringJMT();
	
	ti1 := self.getTrackedItem(cargoId);
	if ti1 &lt;&gt; null then
		self.deleteTrackedItem(ti1, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	ti1 := self.addCargoForVoyage(voyage, cargoId);
	self.assertNotNullMsg(ti1, "Failed to creatt TI1");
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_IMPORT, true);
	
	// Set Customs Agent and Customs Entry Number
	beginTransaction;
	ti1.setCustomsAgent(customagent);
	ti1.setCustomsEntryNumber(CEN);
	commitTransaction;
	
	tiSet.clear();
	tiSet.add(ti1);
	
	// Discharge cargo
	self.moveCargo(ti1, tiSet, ta1.allLocationsControllers.first(), app.myPassport);
	// Set transaction date to 30 days ago
	beginTransaction;
		foreach ti in tiSet do
			tiTrans := ti.getLastTransOfType(TRANS_TYPE_REC_SHIP); // Received Ship transaction
			ts.setDate(today.addDays(-30));
			tiTrans.setPropertyValue("dateTime", ts);
			ti.setPropertyValue("receivedDT", ts);
		endforeach;
	commitTransaction;
	
	self.opts.purge();
	self.opts.addAssoc("CENum", CEN);
	
	// Delete stops
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	tiSet.clear();
	
	
	/*
	===================================
	Create Draft receipt
	===================================
	*/
	
	// Init details for Cash CMIF
		voyCode := voyage.code;
		today := app.actualTimeServer().date();
		effectiveDate := today;
		agentId := customagent.code;
		
		// Initialize CMIF	
		delete cmifCashAgent;
		create cmifCashAgent transient;
		cmifCashAgent.initialize(voyCode, null, CEN, cargoId, effectiveDate, voyage.arrivedDT.date(), terminal, agentId, false, true);
		cmifCashAgent.setExternalFields(null, null, null, null, "USER1", null);
		cmifCashAgent.doValidateCashCalculate(err);
		self.assertNullMsg(err, "TI1 - CMIF agent validation failed - " &amp; err &amp; ", " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
		// Do calulate cash amout
		cmifCashAgent.doCalculate();
		
		// Get Cash receipt
		cashReceipt := cmifCashAgent.myNewCashReceipt;
		self.assertNotNullMsg(cashReceipt, "TI1 - Failed to create cash receipt");
		
	/*========================================	
	Change Cash Receipt status to HOLD using API
	========================================	*/
		receiptNumber := cashReceipt.sequenceNum;
		delete cmifCashAgent;
		create cmifCashAgent transient;
		
		cmifCashAgent.initializeForProformaStatus(agentId, CEN, receiptNumber, null, null, null, null, null, null, CM_CashReceipt.API_RECEIPT_HOLD, terminal);
		cmifCashAgent.setExternalFields(null, null, null, null, "USER1", null);
		cmifCashAgent.doChangeProformaStatusFromAPI();
		self.assertTrueMsg(cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "TI - Cash Receipt status update to HOLD failed - " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
	/*========================================	
	Change Cash Receipt status to DRAFT from JMT Cash Receipt Enq
	========================================	*/
		delete pxyCashReceipt;
		beginLoad;
		pxyCashReceipt := cashReceipt.pxyCreateUpdateProxy();
		endLoad;
		
		app.myTrxUA.trxCashReceiptJMTUpdateStatus(pxyCashReceipt, CM_CashReceipt.API_RECEIPT_DRAFT, app.myPassport);
		delete pxyCashReceipt;
	/*========================================	
	Check scenarios
	========================================	*/
		// No errors
		self.assertTrueMsg(app.myPassport.noErrors(), app.myPassport.getErrorsAsString());
		// Payment status is changed to Draft
		self.assertEqualMsg(cashReceipt.paymentStatus, CM_CashReceipt.API_RECEIPT_DRAFT, "Cash receipt status is " &amp; app.paymentStatusCashEnumToString(cashReceipt.paymentStatus));
		// Check BGP is created
		offlineActor := app.myRoot.getFutureActor(cashReceipt, CM_CashStatusAdvanceProcess);
		self.assertNotNullMsg(offlineActor, "BGP not created for the draft receipt");
		
	/*===================================
	Change cash receipt status to HOLD using API
	===================================*/
		receiptNumber := cashReceipt.sequenceNum;
		delete cmifCashAgent;
		create cmifCashAgent transient;
		
		cmifCashAgent.initializeForProformaStatus(agentId, CEN, receiptNumber, null, null, null, null, null, null, CM_CashReceipt.API_RECEIPT_HOLD, terminal);
		cmifCashAgent.setExternalFields(null, null, null, null, "USER1", null);
		cmifCashAgent.doChangeProformaStatusFromAPI();
		self.assertTrueMsg(cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "TI - Cash Receipt status update to HOLD failed - " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	/*===================================
	Change cash receipt status to PAID &gt; FINAL using API
	===================================*/
		receiptNumber := cashReceipt.sequenceNum;
		delete cmifCashAgent;
		create cmifCashAgent transient;
		
		cmifCashAgent.initializeForProformaStatus(agentId, CEN, receiptNumber, null, null, null, null, null, null, CM_CashReceipt.API_RECEIPT_PAID, terminal);
		cmifCashAgent.setExternalFields(null, null, null, null, "USER1", null);
		cmifCashAgent.doChangeProformaStatusFromAPI();
		self.assertTrueMsg(cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_FINAL, "TI - Cash Receipt status update to Paid (auto to Final) failed - " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	// Check gate out is not returning error
		self.deleteStops(ti);
		self.deleteVehicle(TRUCKID);
		vvr := self.gateOutGC(TRUCKID, null, "UTDRIVER", ti, self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString()), null);
		self.assertNotNullMsg(vvr, "TI - Failed to create VVR");
		app.myValUA.valCashCollectionForVVR(vvr,true,true,null,app.myPassport);
		self.assertTrueMsg(app.myPassport.noErrors(), "Everything paid, should not get errors");
		
epilog
	self.deleteVehicle(TRUCKID);
	self.resetDefaultTranMap();
	self.deleteVoyage(VOYCODE);
	self.deleteTrackedItem(ti1, true);
	self.deleteVessel(VESSCODE);
	if criterias &lt;&gt; null then
		criterias.purge();
	endif;
	delete criterias;
	delete selectedTrxTypes;
	delete proxyProCrit;
	delete pxyCashReceipt;
	if realProCrit &lt;&gt; null then
		app.myTrxDA.trxDeleteProformaCriteria(realProCrit, app.myPassport);
	endif;
	if cashReceipt &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt);
	endif;
	if cashReceiptForBoth &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceiptForBoth);
	endif;
	delete pxyTransService;
	delete services;
	delete cmifCashAgent;
	delete tiSet;
	if vvr &lt;&gt; null and app.isValidObject(vvr) then
		self.deleteVVR(vvr);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashReceiptJMTChangeStatus4" id="94b12e92-5f75-4800-bb8b-938d00f64c56">
        <updating/>
        <source>tCashReceiptJMTChangeStatus4() updating;
/*

Purpose:			API Draft &gt; API Hold &gt; JMT Draft &gt; API Hold &gt; API Cancelled &gt; Check Gate out

Parameters:			

Return Value:		

Date		Who		Reason
06/06/2025	navkc1 JIRA MTN 34779 MTN | Cash Status Change for Special Users.

*/
constants
	CEN = "UTCEN";
	CEN2 = "UTCEN2";
	VOYCODE = "CASHAPIVOY";
	VESSCODE = "CASHAPIVESS";
	CARGOID = "33930-1";
	TRANMAP = "CASHAPI";
	EXTUSER1 = "USER1";
	EXTUSER2 = "USER2";
	INVLINEDESC1 = "UT33930-1";
	INVLINEDESC2 = "UT33930-2";
	TODOTASKDESC = "33930TDT";
	TRUCKID = "33930T";
	CARRIERID = "33930C";
vars
	err,
	fileContext,				
	itemCode,
	cargoId,
	voyCode,
	agentId					: String;
	
	today,
	effectiveDate 			: Date;
	
	ts						: TimeStamp;
	receiptNumber			: Integer;
	
	vvr						: CM_VehicleVisitRecord;
	tm						: CM_TranMap;
	voyage					: CM_Voyage;
	operator				: CM_Operator;
	ti,	ti1					: CM_TrackedItem;
	debtorType				: CM_DebtorType;
	customagent				: CM_CustomsAgent;
	terminal				: CM_Terminal;
	debtorNode				: CM_DebtorNode;
	debtor					: CM_Debtor;
	debtorTerminal			: CM_DebtorTerminal;
	bank					: CM_Bank;
	proxyCriteria			: CM_YACriteria;
	proxyProCrit 			: CM_ProformaTransactionCriteria;
	realProCrit 			: CM_ProformaTransactionCriteria;
	value 					: Any;
	criterias				: CMIF_Array;
	cmifCriteria 			: CMIF_YACriteriaPriority;
	selectedTrxTypes		: CM_TransactionTypeByType;
	critType 				: CM_YACriteriaType;
	pxyTransService 		: CM_TransServiceBroker;
	pxyCashReceipt,
	cashReceipt,
	cashReceiptForBoth		: CM_CashReceipt;
	invLineDesc1,
	invLineDesc2 			: CM_InvoiceLineDesc;
	services				: CM_ServiceByNameDict;
	cmifCashAgent			: CMIF_CashInvoiceProformaCtrl;
	tiSet					: CM_TISet;
	toDoTaskDesc			: CM_ToDoTaskDesc;
	ta1						: CM_TerminalArea;
	tiTrans					: CM_TITransaction;
	actualMess, expectedMess1 : String;
	offlineActor			: CM_OfflineFutureActor;
begin
	//return;
	create services transient;
	create cmifCashAgent transient;
	create tiSet transient; 
	// Terminal Area
	ta1 := self.addBlockStack("UTPHT1",9999999,null);
	self.assertNotNullMsg(ta1, "Failed to create TA1");
	
	// Terminal
	terminal := self.getMyTerminal();
	
	// Operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// Custom Agent
	customagent := self.addCustomsAgent("APIAGENT", "UTCASHAPI");
	self.assertNotNullMsg(customagent, "Failed to create customs agent");
	
	// Delete Truck
	self.deleteVehicle(TRUCKID);
	self.deleteCarrier(CARRIERID);
	
	// Create To Do Task Desc
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[TODOTASKDESC];
	if toDoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc);
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("CargoType", app.myRoot.allCargoTypesById[TI_CargoType_BreakBulk]);
	toDoTaskDesc := self.createToDoTaskDesc(TODOTASKDESC);
	self.assertNotNullMsg(toDoTaskDesc, "Failed to create to do task desc");
	
	// Debtor
	debtor := self.getDebtor("APIDEBT");
	if debtor = null then
		debtorNode := self.addDebtor("APIDEBT", PaymentType_None);
		debtor := debtorNode.CM_Debtor;
	endif;
	beginTransaction;
		customagent.setDebtor(debtor);
	commitTransaction;
	debtorTerminal := debtor.allDebtorTerminals[terminal];
	self.setDebtorCashOnly(debtor, terminal, true);
	
	// Set terminal to Cash config
	self.enableCashOnlyTerminal(terminal, true);
	self.setTerminalConfig(UseCashStatusAdvBGP, true);
	self.setTerminalConfig(CashRoadExitChkServices, true);
	self.setTerminalConfig(CashOnlyInDebtOption, 1);
	
	// Get Invoice Line Type
	invLineDesc1 := self.getInvoiceLineType(INVLINEDESC1); // Days Since receival
	self.assertNotNullMsg(invLineDesc1, "Failed to get invoice line type 1");
	invLineDesc2 := self.getInvoiceLineType(INVLINEDESC2); // Cargo Value of 1
	self.assertNotNullMsg(invLineDesc1, "Failed to get invoice line type 2");
	
	// Setup transaction mapping
	tm := self.getTransactionMap(TRANMAP);
	if tm = null then
		tm := self.createTransactionMap(TRANMAP);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;	
	self.assertNotNullMsg(tm, "Failed to create transaction mapping");
	app.myTrxUA.trxUpdateBankTMActive(tm, app.myPassport);
	
	fileContext := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) †,(Default),,,**Any**,All,VOID
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Released - Road,,(Default),(Default) †,(Default),,,**Any**,All,UT33930-1
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Todo Task Added,,(Default),(Default) ›,(Default),,,**Any**,All,UT33930-2';

	self.transactionMapLoad(fileContext, null);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	
	// Setup cash config
	debtorType := app.myRoot.allDebtorTypes["SDT6"];
	self.assertNotNullMsg(debtorType, "Failed to get cash debtor type");
	self.setTerminalConfig(CashDebtorType, debtorType);
	
	bank := terminal.getDefaultCompanyBank();
	
	create criterias transient;
	critType := app.myRoot.allYACriteriaTypes.getAtKey(19);	//Operator
	create proxyCriteria transient;
	itemCode := critType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	value := operator.code;
	proxyCriteria.setProxy(critType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	criterias.add(cmifCriteria);
	
	create selectedTrxTypes transient;
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[32] ); // Receive Ship
	
	create proxyProCrit transient;
	proxyProCrit.setProxy( criterias, selectedTrxTypes, 2, bank, null, null, null, null, null,null );
	app.myTrxCA.trxCreateProformaCriteria(proxyProCrit, realProCrit, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Pro Forma allocation create failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete proxyProCrit;
	
	// Setup storage config
	self.deleteStorageConfig(true);
	
	// Create voyage
	self.opts.purge();
	self.opts.addAssoc("dateArrival", today.addDays(-30));
	voyage := self.createVesselVoyage(VOYCODE, VESSCODE, operator);
	self.assertNotNullMsg(voyage, "Failed to create voyage");
	
	// Create cargo 1
	self.opts.purge();
	cargoId := CARGOID&amp;today.asStringJMT();
	
	ti1 := self.getTrackedItem(cargoId);
	if ti1 &lt;&gt; null then
		self.deleteTrackedItem(ti1, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	ti1 := self.addCargoForVoyage(voyage, cargoId);
	self.assertNotNullMsg(ti1, "Failed to creatt TI1");
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_IMPORT, true);
	
	// Set Customs Agent and Customs Entry Number
	beginTransaction;
	ti1.setCustomsAgent(customagent);
	ti1.setCustomsEntryNumber(CEN);
	commitTransaction;
	
	tiSet.clear();
	tiSet.add(ti1);
	
	// Discharge cargo
	self.moveCargo(ti1, tiSet, ta1.allLocationsControllers.first(), app.myPassport);
	// Set transaction date to 30 days ago
	beginTransaction;
		foreach ti in tiSet do
			tiTrans := ti.getLastTransOfType(TRANS_TYPE_REC_SHIP); // Received Ship transaction
			ts.setDate(today.addDays(-30));
			tiTrans.setPropertyValue("dateTime", ts);
			ti.setPropertyValue("receivedDT", ts);
		endforeach;
	commitTransaction;
	
	self.opts.purge();
	self.opts.addAssoc("CENum", CEN);
	
	// Delete stops
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	tiSet.clear();
	
	
	/*
	===================================
	Create Draft receipt
	===================================
	*/
	
	// Init details for Cash CMIF
		voyCode := voyage.code;
		today := app.actualTimeServer().date();
		effectiveDate := today;
		agentId := customagent.code;
		
		// Initialize CMIF	
		delete cmifCashAgent;
		create cmifCashAgent transient;
		cmifCashAgent.initialize(voyCode, null, CEN, cargoId, effectiveDate, voyage.arrivedDT.date(), terminal, agentId, false, true);
		cmifCashAgent.setExternalFields(null, null, null, null, "USER1", null);
		cmifCashAgent.doValidateCashCalculate(err);
		self.assertNullMsg(err, "TI1 - CMIF agent validation failed - " &amp; err &amp; ", " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
		// Do calulate cash amout
		cmifCashAgent.doCalculate();
		
		// Get Cash receipt
		cashReceipt := cmifCashAgent.myNewCashReceipt;
		self.assertNotNullMsg(cashReceipt, "TI1 - Failed to create cash receipt");
		
	/*========================================	
	Change Cash Receipt status to HOLD using API
	========================================	*/
		receiptNumber := cashReceipt.sequenceNum;
		delete cmifCashAgent;
		create cmifCashAgent transient;
		
		cmifCashAgent.initializeForProformaStatus(agentId, CEN, receiptNumber, null, null, null, null, null, null, CM_CashReceipt.API_RECEIPT_HOLD, terminal);
		cmifCashAgent.setExternalFields(null, null, null, null, "USER1", null);
		cmifCashAgent.doChangeProformaStatusFromAPI();
		self.assertTrueMsg(cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "TI - Cash Receipt status update to HOLD failed - " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
	/*========================================	
	Change Cash Receipt status to DRAFT from JMT Cash Receipt Enq
	========================================	*/
		delete pxyCashReceipt;
		beginLoad;
		pxyCashReceipt := cashReceipt.pxyCreateUpdateProxy();
		endLoad;
		
		app.myTrxUA.trxCashReceiptJMTUpdateStatus(pxyCashReceipt, CM_CashReceipt.API_RECEIPT_DRAFT, app.myPassport);
		delete pxyCashReceipt;
	/*========================================	
	Check scenarios
	========================================	*/
		// No errors
		self.assertTrueMsg(app.myPassport.noErrors(), app.myPassport.getErrorsAsString());
		// Payment status is changed to Draft
		self.assertEqualMsg(cashReceipt.paymentStatus, CM_CashReceipt.API_RECEIPT_DRAFT, "Cash receipt status is " &amp; app.paymentStatusCashEnumToString(cashReceipt.paymentStatus));
		// Check BGP is created
		offlineActor := app.myRoot.getFutureActor(cashReceipt, CM_CashStatusAdvanceProcess);
		self.assertNotNullMsg(offlineActor, "BGP not created for the draft receipt");
		
	/*===================================
	Change cash receipt status to HOLD using API
	===================================*/
		receiptNumber := cashReceipt.sequenceNum;
		delete cmifCashAgent;
		create cmifCashAgent transient;
		
		cmifCashAgent.initializeForProformaStatus(agentId, CEN, receiptNumber, null, null, null, null, null, null, CM_CashReceipt.API_RECEIPT_HOLD, terminal);
		cmifCashAgent.setExternalFields(null, null, null, null, "USER1", null);
		cmifCashAgent.doChangeProformaStatusFromAPI();
		self.assertTrueMsg(cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "TI - Cash Receipt status update to HOLD failed - " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	/*===================================
	Change cash receipt status to PAID &gt; FINAL using API
	===================================*/
		receiptNumber := cashReceipt.sequenceNum;
		delete cmifCashAgent;
		create cmifCashAgent transient;
		
		cmifCashAgent.initializeForProformaStatus(agentId, CEN, receiptNumber, null, null, null, null, null, null, CM_CashReceipt.API_RECEIPT_CANCELLED, terminal);
		cmifCashAgent.setExternalFields(null, null, null, null, "USER1", null);
		cmifCashAgent.doChangeProformaStatusFromAPI();
		self.assertTrueMsg(cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_CANCELLED, "TI - Cash Receipt status update to CANCELLED failed - " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
	// Check gate out is returning error
		self.deleteStops(ti);
		self.deleteVehicle(TRUCKID);
		vvr := self.gateOutGC(TRUCKID, null, "UTDRIVER", ti, self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString()), null);
		self.assertNotNullMsg(vvr, "TI - Failed to create VVR");
		self.clearExpectedTrxErrors();
		self.expectedTrxErrors.add(Cash_cargo_not_paid);
		app.myValUA.valCashCollectionForVVR(vvr,true,true,null,app.myPassport);
		self.assertTrxErrorMsg(Cash_cargo_not_paid, "Error not raised 001");
		/*actualMess := app.myPassport.getErrorsAsString();
		expectedMess1 := "for cash-only debtor APIDEBT is not fully paid for

Cash Total Required = 4629.900000
Cash Paid So Far = 0.000000
Cash Outstanding = 4629.900000";
		self.assertTrueMsg(actualMess.pos(expectedMess1, 1) &gt; 0, "Error not raised 001 " &amp; actualMess);*/
		
epilog
	self.deleteVehicle(TRUCKID);
	self.resetDefaultTranMap();
	self.deleteVoyage(VOYCODE);
	self.deleteTrackedItem(ti1, true);
	self.deleteVessel(VESSCODE);
	if criterias &lt;&gt; null then
		criterias.purge();
	endif;
	delete criterias;
	delete selectedTrxTypes;
	delete proxyProCrit;
	delete pxyCashReceipt;
	if realProCrit &lt;&gt; null then
		app.myTrxDA.trxDeleteProformaCriteria(realProCrit, app.myPassport);
	endif;
	if cashReceipt &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt);
	endif;
	if cashReceiptForBoth &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceiptForBoth);
	endif;
	delete pxyTransService;
	delete services;
	delete cmifCashAgent;
	delete tiSet;
	if vvr &lt;&gt; null and app.isValidObject(vvr) then
		self.deleteVVR(vvr);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashReceiptJMTChangeStatus5" id="d8cbfe9c-3c28-4acf-8229-4a6cda7c00fe">
        <updating/>
        <source>tCashReceiptJMTChangeStatus5() updating;
/*

Purpose:			API Draft &gt; API Hold &gt; JMT Cancelled &gt; Check Gate out

Parameters:			

Return Value:		

Date		Who		Reason
06/06/2025	navkc1 JIRA MTN 34779 MTN | Cash Status Change for Special Users.

*/
constants
	CEN = "UTCEN";
	CEN2 = "UTCEN2";
	VOYCODE = "CASHAPIVOY";
	VESSCODE = "CASHAPIVESS";
	CARGOID = "33930-1";
	TRANMAP = "CASHAPI";
	EXTUSER1 = "USER1";
	EXTUSER2 = "USER2";
	INVLINEDESC1 = "UT33930-1";
	INVLINEDESC2 = "UT33930-2";
	TODOTASKDESC = "33930TDT";
	TRUCKID = "33930T";
	CARRIERID = "33930C";
vars
	err,
	fileContext,				
	itemCode,
	cargoId,
	voyCode,
	agentId					: String;
	
	today,
	effectiveDate 			: Date;
	
	ts						: TimeStamp;
	receiptNumber			: Integer;
	
	vvr						: CM_VehicleVisitRecord;
	tm						: CM_TranMap;
	voyage					: CM_Voyage;
	operator				: CM_Operator;
	ti,	ti1					: CM_TrackedItem;
	debtorType				: CM_DebtorType;
	customagent				: CM_CustomsAgent;
	terminal				: CM_Terminal;
	debtorNode				: CM_DebtorNode;
	debtor					: CM_Debtor;
	debtorTerminal			: CM_DebtorTerminal;
	bank					: CM_Bank;
	proxyCriteria			: CM_YACriteria;
	proxyProCrit 			: CM_ProformaTransactionCriteria;
	realProCrit 			: CM_ProformaTransactionCriteria;
	value 					: Any;
	criterias				: CMIF_Array;
	cmifCriteria 			: CMIF_YACriteriaPriority;
	selectedTrxTypes		: CM_TransactionTypeByType;
	critType 				: CM_YACriteriaType;
	pxyTransService 		: CM_TransServiceBroker;
	pxyCashReceipt,
	cashReceipt,
	cashReceiptForBoth		: CM_CashReceipt;
	invLineDesc1,
	invLineDesc2 			: CM_InvoiceLineDesc;
	services				: CM_ServiceByNameDict;
	cmifCashAgent			: CMIF_CashInvoiceProformaCtrl;
	tiSet					: CM_TISet;
	toDoTaskDesc			: CM_ToDoTaskDesc;
	ta1						: CM_TerminalArea;
	tiTrans					: CM_TITransaction;
	actualMess, expectedMess1 : String;
begin
	//return;
	create services transient;
	create cmifCashAgent transient;
	create tiSet transient; 
	// Terminal Area
	ta1 := self.addBlockStack("UTPHT1",9999999,null);
	self.assertNotNullMsg(ta1, "Failed to create TA1");
	
	// Terminal
	terminal := self.getMyTerminal();
	
	// Operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// Custom Agent
	customagent := self.addCustomsAgent("APIAGENT", "UTCASHAPI");
	self.assertNotNullMsg(customagent, "Failed to create customs agent");
	
	// Delete Truck
	self.deleteVehicle(TRUCKID);
	self.deleteCarrier(CARRIERID);
	
	// Create To Do Task Desc
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[TODOTASKDESC];
	if toDoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc);
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("CargoType", app.myRoot.allCargoTypesById[TI_CargoType_BreakBulk]);
	toDoTaskDesc := self.createToDoTaskDesc(TODOTASKDESC);
	self.assertNotNullMsg(toDoTaskDesc, "Failed to create to do task desc");
	
	// Debtor
	debtor := self.getDebtor("APIDEBT");
	if debtor = null then
		debtorNode := self.addDebtor("APIDEBT", PaymentType_None);
		debtor := debtorNode.CM_Debtor;
	endif;
	beginTransaction;
		customagent.setDebtor(debtor);
	commitTransaction;
	debtorTerminal := debtor.allDebtorTerminals[terminal];
	self.setDebtorCashOnly(debtor, terminal, true);
	
	// Set terminal to Cash config
	self.enableCashOnlyTerminal(terminal, true);
	self.setTerminalConfig(UseCashStatusAdvBGP, true);
	self.setTerminalConfig(CashRoadExitChkServices, true);
	self.setTerminalConfig(CashOnlyInDebtOption, 1);
	
	// Get Invoice Line Type
	invLineDesc1 := self.getInvoiceLineType(INVLINEDESC1); // Days Since receival
	self.assertNotNullMsg(invLineDesc1, "Failed to get invoice line type 1");
	invLineDesc2 := self.getInvoiceLineType(INVLINEDESC2); // Cargo Value of 1
	self.assertNotNullMsg(invLineDesc1, "Failed to get invoice line type 2");
	
	// Setup transaction mapping
	tm := self.getTransactionMap(TRANMAP);
	if tm = null then
		tm := self.createTransactionMap(TRANMAP);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;	
	self.assertNotNullMsg(tm, "Failed to create transaction mapping");
	app.myTrxUA.trxUpdateBankTMActive(tm, app.myPassport);
	
	fileContext := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) †,(Default),,,**Any**,All,VOID
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Released - Road,,(Default),(Default) †,(Default),,,**Any**,All,UT33930-1
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Todo Task Added,,(Default),(Default) ›,(Default),,,**Any**,All,UT33930-2';

	self.transactionMapLoad(fileContext, null);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	
	// Setup cash config
	debtorType := app.myRoot.allDebtorTypes["SDT6"];
	self.assertNotNullMsg(debtorType, "Failed to get cash debtor type");
	self.setTerminalConfig(CashDebtorType, debtorType);
	
	bank := terminal.getDefaultCompanyBank();
	
	create criterias transient;
	critType := app.myRoot.allYACriteriaTypes.getAtKey(19);	//Operator
	create proxyCriteria transient;
	itemCode := critType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	value := operator.code;
	proxyCriteria.setProxy(critType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	criterias.add(cmifCriteria);
	
	create selectedTrxTypes transient;
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[32] ); // Receive Ship
	
	create proxyProCrit transient;
	proxyProCrit.setProxy( criterias, selectedTrxTypes, 2, bank, null, null, null, null, null,null );
	app.myTrxCA.trxCreateProformaCriteria(proxyProCrit, realProCrit, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Pro Forma allocation create failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete proxyProCrit;
	
	// Setup storage config
	self.deleteStorageConfig(true);
	
	// Create voyage
	self.opts.purge();
	self.opts.addAssoc("dateArrival", today.addDays(-30));
	voyage := self.createVesselVoyage(VOYCODE, VESSCODE, operator);
	self.assertNotNullMsg(voyage, "Failed to create voyage");
	
	// Create cargo 1
	self.opts.purge();
	cargoId := CARGOID&amp;today.asStringJMT();
	
	ti1 := self.getTrackedItem(cargoId);
	if ti1 &lt;&gt; null then
		self.deleteTrackedItem(ti1, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	ti1 := self.addCargoForVoyage(voyage, cargoId);
	self.assertNotNullMsg(ti1, "Failed to creatt TI1");
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_IMPORT, true);
	
	// Set Customs Agent and Customs Entry Number
	beginTransaction;
	ti1.setCustomsAgent(customagent);
	ti1.setCustomsEntryNumber(CEN);
	commitTransaction;
	
	tiSet.clear();
	tiSet.add(ti1);
	
	// Discharge cargo
	self.moveCargo(ti1, tiSet, ta1.allLocationsControllers.first(), app.myPassport);
	// Set transaction date to 30 days ago
	beginTransaction;
		foreach ti in tiSet do
			tiTrans := ti.getLastTransOfType(TRANS_TYPE_REC_SHIP); // Received Ship transaction
			ts.setDate(today.addDays(-30));
			tiTrans.setPropertyValue("dateTime", ts);
			ti.setPropertyValue("receivedDT", ts);
		endforeach;
	commitTransaction;
	
	self.opts.purge();
	self.opts.addAssoc("CENum", CEN);
	
	// Delete stops
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	tiSet.clear();
	
	
	/*
	===================================
	Create Draft receipt
	===================================
	*/
	
	// Init details for Cash CMIF
		voyCode := voyage.code;
		today := app.actualTimeServer().date();
		effectiveDate := today;
		agentId := customagent.code;
		
		// Initialize CMIF	
		delete cmifCashAgent;
		create cmifCashAgent transient;
		cmifCashAgent.initialize(voyCode, null, CEN, cargoId, effectiveDate, voyage.arrivedDT.date(), terminal, agentId, false, true);
		cmifCashAgent.setExternalFields(null, null, null, null, "USER1", null);
		cmifCashAgent.doValidateCashCalculate(err);
		self.assertNullMsg(err, "TI1 - CMIF agent validation failed - " &amp; err &amp; ", " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
		// Do calulate cash amout
		cmifCashAgent.doCalculate();
		
		// Get Cash receipt
		cashReceipt := cmifCashAgent.myNewCashReceipt;
		self.assertNotNullMsg(cashReceipt, "TI1 - Failed to create cash receipt");
		
	/*========================================	
	Change Cash Receipt status to HOLD using API
	========================================	*/
		receiptNumber := cashReceipt.sequenceNum;
		delete cmifCashAgent;
		create cmifCashAgent transient;
		
		cmifCashAgent.initializeForProformaStatus(agentId, CEN, receiptNumber, null, null, null, null, null, null, CM_CashReceipt.API_RECEIPT_HOLD, terminal);
		cmifCashAgent.setExternalFields(null, null, null, null, "USER1", null);
		cmifCashAgent.doChangeProformaStatusFromAPI();
		self.assertTrueMsg(cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "TI - Cash Receipt status update to HOLD failed - " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
	/*========================================	
	Change Cash Receipt status to CANCELLED from JMT Cash Receipt Enq
	========================================	*/
		delete pxyCashReceipt;
		beginLoad;
		pxyCashReceipt := cashReceipt.pxyCreateUpdateProxy();
		endLoad;
		
		app.myTrxUA.trxCashReceiptJMTUpdateStatus(pxyCashReceipt, CM_CashReceipt.API_RECEIPT_CANCELLED, app.myPassport);
		delete pxyCashReceipt;
	/*========================================	
	Check scenarios
	========================================	*/
		// No errors
		self.assertTrueMsg(app.myPassport.noErrors(), app.myPassport.getErrorsAsString());
		// Payment status is changed to Draft
		self.assertEqualMsg(cashReceipt.paymentStatus, CM_CashReceipt.API_RECEIPT_CANCELLED, "Cash receipt status is " &amp; app.paymentStatusCashEnumToString(cashReceipt.paymentStatus));
		
	
	// Check gate out is returning error
		self.deleteStops(ti);
		self.deleteVehicle(TRUCKID);
		vvr := self.gateOutGC(TRUCKID, null, "UTDRIVER", ti, self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString()), null);
		self.assertNotNullMsg(vvr, "TI - Failed to create VVR");
		self.clearExpectedTrxErrors();
		self.expectedTrxErrors.add(Cash_cargo_not_paid);
		app.myValUA.valCashCollectionForVVR(vvr,true,true,null,app.myPassport);
		self.assertTrxErrorMsg(Cash_cargo_not_paid, "Error not raised 001");
		/*actualMess := app.myPassport.getErrorsAsString();
		expectedMess1 := "for cash-only debtor APIDEBT is not fully paid for

Cash Total Required = 4629.900000
Cash Paid So Far = 0.000000
Cash Outstanding = 4629.900000";
		self.assertTrueMsg(actualMess.pos(expectedMess1, 1) &gt; 0, "Error not raised 001 " &amp; actualMess);*/
		
epilog
	self.deleteVehicle(TRUCKID);
	self.resetDefaultTranMap();
	self.deleteVoyage(VOYCODE);
	self.deleteTrackedItem(ti1, true);
	self.deleteVessel(VESSCODE);
	if criterias &lt;&gt; null then
		criterias.purge();
	endif;
	delete criterias;
	delete selectedTrxTypes;
	delete proxyProCrit;
	delete pxyCashReceipt;
	if realProCrit &lt;&gt; null then
		app.myTrxDA.trxDeleteProformaCriteria(realProCrit, app.myPassport);
	endif;
	if cashReceipt &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt);
	endif;
	if cashReceiptForBoth &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceiptForBoth);
	endif;
	delete pxyTransService;
	delete services;
	delete cmifCashAgent;
	delete tiSet;
	if vvr &lt;&gt; null and app.isValidObject(vvr) then
		self.deleteVVR(vvr);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashReceiptJMTChangeStatus6" id="2542073c-1c85-4c2a-87a3-95027252f514">
        <updating/>
        <source>tCashReceiptJMTChangeStatus6() updating;
/*

Purpose:			API Draft &gt; API Hold &gt; JMT Final &gt; Check Gate out

Parameters:			

Return Value:		

Date		Who		Reason
06/06/2025	navkc1 JIRA MTN 34779 MTN | Cash Status Change for Special Users.

*/
constants
	CEN = "UTCEN";
	CEN2 = "UTCEN2";
	VOYCODE = "CASHAPIVOY";
	VESSCODE = "CASHAPIVESS";
	CARGOID = "33930-1";
	TRANMAP = "CASHAPI";
	EXTUSER1 = "USER1";
	EXTUSER2 = "USER2";
	INVLINEDESC1 = "UT33930-1";
	INVLINEDESC2 = "UT33930-2";
	TODOTASKDESC = "33930TDT";
	TRUCKID = "33930T";
	CARRIERID = "33930C";
vars
	err,
	fileContext,				
	itemCode,
	cargoId,
	voyCode,
	agentId					: String;
	
	today,
	effectiveDate 			: Date;
	
	ts						: TimeStamp;
	receiptNumber			: Integer;
	
	vvr						: CM_VehicleVisitRecord;
	tm						: CM_TranMap;
	voyage					: CM_Voyage;
	operator				: CM_Operator;
	ti,	ti1					: CM_TrackedItem;
	debtorType				: CM_DebtorType;
	customagent				: CM_CustomsAgent;
	terminal				: CM_Terminal;
	debtorNode				: CM_DebtorNode;
	debtor					: CM_Debtor;
	debtorTerminal			: CM_DebtorTerminal;
	bank					: CM_Bank;
	proxyCriteria			: CM_YACriteria;
	proxyProCrit 			: CM_ProformaTransactionCriteria;
	realProCrit 			: CM_ProformaTransactionCriteria;
	value 					: Any;
	criterias				: CMIF_Array;
	cmifCriteria 			: CMIF_YACriteriaPriority;
	selectedTrxTypes		: CM_TransactionTypeByType;
	critType 				: CM_YACriteriaType;
	pxyTransService 		: CM_TransServiceBroker;
	pxyCashReceipt,
	cashReceipt,
	cashReceiptForBoth		: CM_CashReceipt;
	invLineDesc1,
	invLineDesc2 			: CM_InvoiceLineDesc;
	services				: CM_ServiceByNameDict;
	cmifCashAgent			: CMIF_CashInvoiceProformaCtrl;
	tiSet					: CM_TISet;
	toDoTaskDesc			: CM_ToDoTaskDesc;
	ta1						: CM_TerminalArea;
	tiTrans					: CM_TITransaction;
begin
	//return;
	create services transient;
	create cmifCashAgent transient;
	create tiSet transient; 
	// Terminal Area
	ta1 := self.addBlockStack("UTPHT1",9999999,null);
	self.assertNotNullMsg(ta1, "Failed to create TA1");
	
	// Terminal
	terminal := self.getMyTerminal();
	
	// Operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// Custom Agent
	customagent := self.addCustomsAgent("APIAGENT", "UTCASHAPI");
	self.assertNotNullMsg(customagent, "Failed to create customs agent");
	
	// Delete Truck
	self.deleteVehicle(TRUCKID);
	self.deleteCarrier(CARRIERID);
	
	// Create To Do Task Desc
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[TODOTASKDESC];
	if toDoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc);
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("CargoType", app.myRoot.allCargoTypesById[TI_CargoType_BreakBulk]);
	toDoTaskDesc := self.createToDoTaskDesc(TODOTASKDESC);
	self.assertNotNullMsg(toDoTaskDesc, "Failed to create to do task desc");
	
	// Debtor
	debtor := self.getDebtor("APIDEBT");
	if debtor = null then
		debtorNode := self.addDebtor("APIDEBT", PaymentType_None);
		debtor := debtorNode.CM_Debtor;
	endif;
	beginTransaction;
		customagent.setDebtor(debtor);
	commitTransaction;
	debtorTerminal := debtor.allDebtorTerminals[terminal];
	self.setDebtorCashOnly(debtor, terminal, true);
	
	// Set terminal to Cash config
	self.enableCashOnlyTerminal(terminal, true);
	self.setTerminalConfig(UseCashStatusAdvBGP, true);
	self.setTerminalConfig(CashRoadExitChkServices, true);
	self.setTerminalConfig(CashOnlyInDebtOption, 1);
	
	// Get Invoice Line Type
	invLineDesc1 := self.getInvoiceLineType(INVLINEDESC1); // Days Since receival
	self.assertNotNullMsg(invLineDesc1, "Failed to get invoice line type 1");
	invLineDesc2 := self.getInvoiceLineType(INVLINEDESC2); // Cargo Value of 1
	self.assertNotNullMsg(invLineDesc1, "Failed to get invoice line type 2");
	
	// Setup transaction mapping
	tm := self.getTransactionMap(TRANMAP);
	if tm = null then
		tm := self.createTransactionMap(TRANMAP);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;	
	self.assertNotNullMsg(tm, "Failed to create transaction mapping");
	app.myTrxUA.trxUpdateBankTMActive(tm, app.myPassport);
	
	fileContext := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) †,(Default),,,**Any**,All,VOID
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Released - Road,,(Default),(Default) †,(Default),,,**Any**,All,UT33930-1
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Todo Task Added,,(Default),(Default) ›,(Default),,,**Any**,All,UT33930-2';

	self.transactionMapLoad(fileContext, null);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	
	// Setup cash config
	debtorType := app.myRoot.allDebtorTypes["SDT6"];
	self.assertNotNullMsg(debtorType, "Failed to get cash debtor type");
	self.setTerminalConfig(CashDebtorType, debtorType);
	
	bank := terminal.getDefaultCompanyBank();
	
	create criterias transient;
	critType := app.myRoot.allYACriteriaTypes.getAtKey(19);	//Operator
	create proxyCriteria transient;
	itemCode := critType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	value := operator.code;
	proxyCriteria.setProxy(critType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	criterias.add(cmifCriteria);
	
	create selectedTrxTypes transient;
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[32] ); // Receive Ship
	
	create proxyProCrit transient;
	proxyProCrit.setProxy( criterias, selectedTrxTypes, 2, bank, null, null, null, null, null,null );
	app.myTrxCA.trxCreateProformaCriteria(proxyProCrit, realProCrit, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Pro Forma allocation create failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete proxyProCrit;
	
	// Setup storage config
	self.deleteStorageConfig(true);
	
	// Create voyage
	self.opts.purge();
	self.opts.addAssoc("dateArrival", today.addDays(-30));
	voyage := self.createVesselVoyage(VOYCODE, VESSCODE, operator);
	self.assertNotNullMsg(voyage, "Failed to create voyage");
	
	// Create cargo 1
	self.opts.purge();
	cargoId := CARGOID&amp;today.asStringJMT();
	
	ti1 := self.getTrackedItem(cargoId);
	if ti1 &lt;&gt; null then
		self.deleteTrackedItem(ti1, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	ti1 := self.addCargoForVoyage(voyage, cargoId);
	self.assertNotNullMsg(ti1, "Failed to creatt TI1");
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_IMPORT, true);
	
	// Set Customs Agent and Customs Entry Number
	beginTransaction;
	ti1.setCustomsAgent(customagent);
	ti1.setCustomsEntryNumber(CEN);
	commitTransaction;
	
	tiSet.clear();
	tiSet.add(ti1);
	
	// Discharge cargo
	self.moveCargo(ti1, tiSet, ta1.allLocationsControllers.first(), app.myPassport);
	// Set transaction date to 30 days ago
	beginTransaction;
		foreach ti in tiSet do
			tiTrans := ti.getLastTransOfType(TRANS_TYPE_REC_SHIP); // Received Ship transaction
			ts.setDate(today.addDays(-30));
			tiTrans.setPropertyValue("dateTime", ts);
			ti.setPropertyValue("receivedDT", ts);
		endforeach;
	commitTransaction;
	
	self.opts.purge();
	self.opts.addAssoc("CENum", CEN);
	
	// Delete stops
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	tiSet.clear();
	
	
	/*
	===================================
	Create Draft receipt
	===================================
	*/
	
	// Init details for Cash CMIF
		voyCode := voyage.code;
		today := app.actualTimeServer().date();
		effectiveDate := today;
		agentId := customagent.code;
		
		// Initialize CMIF	
		delete cmifCashAgent;
		create cmifCashAgent transient;
		cmifCashAgent.initialize(voyCode, null, CEN, cargoId, effectiveDate, voyage.arrivedDT.date(), terminal, agentId, false, true);
		cmifCashAgent.setExternalFields(null, null, null, null, "USER1", null);
		cmifCashAgent.doValidateCashCalculate(err);
		self.assertNullMsg(err, "TI1 - CMIF agent validation failed - " &amp; err &amp; ", " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
		// Do calulate cash amout
		cmifCashAgent.doCalculate();
		
		// Get Cash receipt
		cashReceipt := cmifCashAgent.myNewCashReceipt;
		self.assertNotNullMsg(cashReceipt, "TI1 - Failed to create cash receipt");
		
	/*========================================	
	Change Cash Receipt status to HOLD using API
	========================================	*/
		receiptNumber := cashReceipt.sequenceNum;
		delete cmifCashAgent;
		create cmifCashAgent transient;
		
		cmifCashAgent.initializeForProformaStatus(agentId, CEN, receiptNumber, null, null, null, null, null, null, CM_CashReceipt.API_RECEIPT_HOLD, terminal);
		cmifCashAgent.setExternalFields(null, null, null, null, "USER1", null);
		cmifCashAgent.doChangeProformaStatusFromAPI();
		self.assertTrueMsg(cashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD, "TI - Cash Receipt status update to HOLD failed - " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
	/*========================================	
	Change Cash Receipt status to CANCELLED from JMT Cash Receipt Enq
	========================================	*/
		delete pxyCashReceipt;
		beginLoad;
		pxyCashReceipt := cashReceipt.pxyCreateUpdateProxy();
		endLoad;
		
		app.myTrxUA.trxCashReceiptJMTUpdateStatus(pxyCashReceipt, CM_CashReceipt.API_RECEIPT_FINAL, app.myPassport);
		delete pxyCashReceipt;
	/*========================================	
	Check scenarios
	========================================	*/
		// No errors
		self.assertTrueMsg(app.myPassport.noErrors(), app.myPassport.getErrorsAsString());
		// Payment status is changed to Draft
		self.assertEqualMsg(cashReceipt.paymentStatus, CM_CashReceipt.API_RECEIPT_FINAL, "Cash receipt status is " &amp; app.paymentStatusCashEnumToString(cashReceipt.paymentStatus));
		
	
	// Check gate out is OK
		self.deleteStops(ti);
		self.deleteVehicle(TRUCKID);
		vvr := self.gateOutGC(TRUCKID, null, "UTDRIVER", ti, self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString()), null);
		self.assertNotNullMsg(vvr, "TI - Failed to create VVR");
		app.myValUA.valCashCollectionForVVR(vvr,true,true,null,app.myPassport);
		self.assertTrueMsg(app.myPassport.noErrors(), "Everything is paid, should not get errors");
		
epilog
	self.deleteVehicle(TRUCKID);
	self.resetDefaultTranMap();
	self.deleteVoyage(VOYCODE);
	self.deleteTrackedItem(ti1, true);
	self.deleteVessel(VESSCODE);
	if criterias &lt;&gt; null then
		criterias.purge();
	endif;
	delete criterias;
	delete selectedTrxTypes;
	delete proxyProCrit;
	delete pxyCashReceipt;
	if realProCrit &lt;&gt; null then
		app.myTrxDA.trxDeleteProformaCriteria(realProCrit, app.myPassport);
	endif;
	if cashReceipt &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt);
	endif;
	if cashReceiptForBoth &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceiptForBoth);
	endif;
	delete pxyTransService;
	delete services;
	delete cmifCashAgent;
	delete tiSet;
	if vvr &lt;&gt; null and app.isValidObject(vvr) then
		self.deleteVVR(vvr);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashReleaseBBlkByQty" id="605c032f-8e91-4b9c-87ff-9ace7303fcf9">
        <updating/>
        <source>tCashReleaseBBlkByQty() updating;
/*
Purpose - 	Test pay cash for receive whilst still on ship (TI1). Then test split sand merges and road exits.

				Create cargo on ship (break bulk splittable)
				Receive ship matched ti invoice line calc type Cargo_Quantity.
				
				Pay cash for cargo on ship.
				Then discharge part  (TI2) and release, should release no errors.
				Then discharge part (TI3). Then move part of TI3 to a different location (TI4).
				Release TI4, should release no errors.
				Then discharge part merging into what is left of TI3.
				Release TI3, should release no errors.

				Who - NAVAB1
Date - 02MAY2025
ADO - JIRA 34760
*/

constants
	CGTYPE = "UTCGTYPE";
vars
	isDutyDoc	: Boolean;
	multiTax	: Boolean;
	noImportStops	: Boolean;
	cargoId1,
	cargoId2	: String;
	debtorName	: String;
	cargoIds	: StringArray;
	
	drTerm1 : CM_DebtorTerminal;

	currentFinClass	: CM_ExtFinanceIO;
	
	costs : DecimalArray;
	service : CM_Service;
	debtorRate : CM_DebtorRate;

	endDate : Date;
	
	debtor		: CM_Debtor;
	proxyDebtor		: CM_Debtor;
	debtorNode	: CM_DebtorNode;
	debtorNodeController	: CMIF_DebtorNode;
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	ct : CM_CargoType;
begin

	cashInvType := self.getInvoiceType("UT_InvType");		// cash receipt invoice type

	// turn off duty docs to get all the latest code; turn off terminal multi tax to avoid tax
	isDutyDoc := self.myTerminal.getConfig(DutyDocumentationEnabled).Boolean;
	multiTax := self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean;
	noImportStops := self.myTerminal.getConfig(NoImportStops).Boolean;
	// set default financial to get their external cash receipt number
	currentFinClass := getInvoiceFinancialClass();
	self.setInvoiceFinancialClass(CM_ADPInterface, null);
	self.setTerminalConfig(DutyDocumentationEnabled, false);
	self.setDefaultBankCashInvoiceType(cashInvType);
	self.setTerminalConfig(InvoiceMultiTaxRates, false);
	self.setTerminalConfig(NoImportStops, true);
	self.setTerminalConfig(CashInvoiceEveryReceipt, true);
	
	self.opts.purge();
	self.opts.addAssoc("TrackAs", ProductType_BreakBulk);
	self.opts.addAssoc("AllowDuplicateId", true);
	ct := self.addCargoType(CGTYPE, false);
	self.assertNotNullMsg(ct, "Failed to create cargo type " &amp; CGTYPE);
	
	create cargoIds transient;
	// ids with valid check digits
	cargoIds.add("CATTLE250502-100");
	foreach cargoId1 in cargoIds do
		self.deleteCargo(cargoId1, ct.id);
	endforeach;
	
	self.setTaxOnBank( false );
	
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	debtorName := "UT_Debtor1";
	debtor := app.myRoot.myRootCompany.debtorNodes[debtorName].CM_Debtor;
	if debtor = null then
		create debtorNodeController transient;
		create proxyDebtor transient;
		self.setDebtorNodeController1(debtorName, debtorNodeController, proxyDebtor);
		app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		debtor := debtorNode.CM_Debtor;
	endif;

	beginTransaction;
		operator.setPropertyValue(CM_Operator::debtor.name, debtor);
	commitTransaction;
	self.myOperator := operator;
	
	endDate := app.actualTimeServer.Date + 10;	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support

	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );
	
	//set up criteria permitted for this Bank in this terminal on pro forma allocation
	self.setBankAvailAllocCriteria();
	
	//set up Bank pro forma allocation
	self.opts.purge();
	self.opts.addAssoc("CargoType", ct);
	self.setBankProFormaAllocBBlk();
	
	//create Method of payment if needed
	self.myPaymentMethod :=  app.myRoot.allPaymentMethods.getAtKey(PayMethName);
	if self.myPaymentMethod = null then
		self.myPaymentMethod := self.createPaymentMethod(PayMethName);
	endif;
	self.assertTrueMsg(self.myPaymentMethod &lt;&gt; null, "Payment Method not created...");
	
	//create cash only debtors.
	self.myDebtor1 := app.myRoot.myRootCompany.debtors[DrNameOne];
	if self.myDebtor1 = null then
		self.myDebtor1 := self.addCashOnlyDebtor( DrNameOne );
	endif;
	self.assertTrueMsg(self.myDebtor1 &lt;&gt; null, "Cash only Debtor not created...");
	drTerm1 := self.myDebtor1.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	// clear any credits etc from prior tests such as tCashCredit
	self.zPurgeCashDebtor(drTerm1);
	
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	drTerm1 := debtor.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	// clear any credits etc from prior tests such as tCashCredit
	self.zPurgeCashDebtor(drTerm1);

	// Yard invoice type, ILT10 and ILT11 invoice line type, used in storage, charged to customs agent, calc type Days Since Receival
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX81", "CCT01", "UT_ILT81", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT81"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX81"];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date,10);

	debtor := operator.debtor;
	
	self.myVoyage := self.createVesselVoyageCash("JMT STAR", "JSTAR001", operator.code);
	self.assertTrueMsg(self.myVoyage &lt;&gt; null, "Voyage '" &amp; CashVoyageCode &amp; "' not created...");

	self.opts.purge();
	self.opts.addAssoc("CargoType", ct);
	self.tranMapLoadBBlkRecShip();
	
	// two receipts, each should have its own cash invoice, post the first one before releasing the cargo
	cargoId1 := cargoIds[1];
	self.opts.purge();
	self.opts.addAssoc("CargoType", ct);
	self.cashTestMultipleReceipts4(cargoId1, cargoId2, drTerm1, 1);
	
epilog
	if currentFinClass &lt;&gt; null then
		self.setInvoiceFinancialClass(currentFinClass.class, null);
	endif;
	self.opts.purge();
	delete costs;
	delete debtorRate;
	delete cargoIds;
	self.resetDefaultTranMap();
	self.deleteTranMapTI("UT_BBlkRecShip");	  // ### JIRA 35068 16JUN2025 NAVAB1
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashReleaseSplit01" id="6fa7d940-8b7a-48aa-b1f4-1ae34224c64a">
        <updating/>
        <source>tCashReleaseSplit01() updating;
/*
Purpose - 	Test pay cash for receive whilst still on ship (TI1). Then test split sand merges and road exits.

				Create cargo on ship (break bulk splittable)
				Receive ship matched ti invoice line calc type Cargo_Quantity.
				
				Pay cash for cargo on ship.
				Then discharge part  (TI2) and release, should release no errors.
				Then discharge part (TI3). Then move part of TI3 to a different location (TI4).
				Release TI4, should release no errors.
				Then discharge part merging into what is left of TI3.
				Release TI3, should release no errors.

				Who - NAVAB1
Date - 16MAY2025
ADO - JIRA 34909
*/

constants
	ServName = "UT_SrvSplitCsh";
	LineName =  "UT_LneSplitCsh";
	CGTYPE = "UTCGTYPE";
vars
	isDutyDoc	: Boolean;
	multiTax	: Boolean;
	noImportStops	: Boolean;
	cargoId1,
	cargoId2	: String;
	debtorName	: String;
	cargoIds	: StringArray;
	
	drTerm1 : CM_DebtorTerminal;

	currentFinClass	: CM_ExtFinanceIO;
	
	costs : DecimalArray;
	service : CM_Service;
	debtorRate : CM_DebtorRate;

	endDate : Date;
	
	debtor		: CM_Debtor;
	proxyDebtor		: CM_Debtor;
	debtorNode	: CM_DebtorNode;
	debtorNodeController	: CMIF_DebtorNode;
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	taxCode : CM_TaxCode;
	bank : CM_Bank;
	terminal : CM_Terminal;
	ct : CM_CargoType;
begin

	cashInvType := self.getInvoiceType("UT_InvType");		// cash receipt invoice type

	// turn off duty docs to get all the latest code; turn off terminal multi tax to avoid tax
	isDutyDoc := self.myTerminal.getConfig(DutyDocumentationEnabled).Boolean;
	multiTax := self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean;
	noImportStops := self.myTerminal.getConfig(NoImportStops).Boolean;
	// set default financial to get their external cash receipt number
	currentFinClass := getInvoiceFinancialClass();
	self.setInvoiceFinancialClass(CM_ADPInterface, null);
	self.setTerminalConfig(DutyDocumentationEnabled, false);
	self.setDefaultBankCashInvoiceType(cashInvType);
	self.setTerminalConfig(InvoiceMultiTaxRates, false);
	self.setTerminalConfig(NoImportStops, true);
	self.setTerminalConfig(CashInvoiceEveryReceipt, true);
	self.setTerminalConfig(InvoiceRoundLineTotal, 2); // 2decimal places
	
	self.opts.purge();
	self.opts.addAssoc("TrackAs", ProductType_BreakBulk);
	self.opts.addAssoc("AllowDuplicateId", true);
	ct := self.addCargoType(CGTYPE, false);
	self.assertNotNullMsg(ct, "Failed to create cargo type " &amp; CGTYPE);
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	taxCode := bank.allTaxCodes["UT_TAX_1"];
	if taxCode = null then
		taxCode:=self.addTaxCode("UT_TAX_1","UT_TAX_1", null);
	endif;
	self.assertEqual(taxCode.code, "UT_TAX_1");

	create cargoIds transient;
	// ids with valid check digits
	cargoIds.add("CATTLE250502-100");
	foreach cargoId1 in cargoIds do
		self.deleteCargo(cargoId1, ct.id);
	endforeach;
	
	self.setTaxOnBank( false );
	
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	debtorName := "UT_Cash1";
	debtor := app.myRoot.myRootCompany.debtorNodes[debtorName].CM_Debtor;
	if debtor = null then
		create debtorNodeController transient;
		create proxyDebtor transient;
		self.setDebtorNodeController1(debtorName, debtorNodeController, proxyDebtor);
		app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		debtor := debtorNode.CM_Debtor;
	endif;

	beginTransaction;
		operator.setPropertyValue(CM_Operator::debtor.name, debtor);
	commitTransaction;
	self.myOperator := operator;
	
	endDate := app.actualTimeServer.Date + 10;	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support

	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );
	
	//set up criteria permitted for this Bank in this terminal on pro forma allocation
	self.setBankAvailAllocCriteria();
	
	//set up Bank pro forma allocation
	self.opts.purge();
	self.opts.addAssoc("CargoType", ct);
	self.setBankProFormaAllocBBlk();
	
	//create Method of payment if needed
	self.myPaymentMethod :=  app.myRoot.allPaymentMethods.getAtKey(PayMethName);
	if self.myPaymentMethod = null then
		self.myPaymentMethod := self.createPaymentMethod(PayMethName);
	endif;
	self.assertTrueMsg(self.myPaymentMethod &lt;&gt; null, "Payment Method not created...");
	
	//create cash only debtors.
	self.myDebtor1 := debtor; // app.myRoot.myRootCompany.debtors[DrNameOne];
	self.assertTrueMsg(self.myDebtor1 &lt;&gt; null, "Cash only Debtor not created...");
	drTerm1 := self.myDebtor1.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	// clear any credits etc from prior tests such as tCashCredit
	self.zPurgeCashDebtor(drTerm1);
	
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	drTerm1 := debtor.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	// clear any credits etc from prior tests such as tCashCredit
	self.zPurgeCashDebtor(drTerm1);

	// Yard invoice type, ILT10 and ILT11 invoice line type, used in storage, charged to customs agent, calc type Days Since Receival
	self.deleteService(ServName);
	self.deleteInvoiceLineType(LineName,0);
	
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.opts.addAssoc(UTTI_TaxCode,taxCode);
	self.addIfNewServiceILD(ServName, "CCT05", LineName, null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors[LineName];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services[ServName];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date,28.8);

//	debtor := operator.debtor;
	
	self.myVoyage := self.createVesselVoyageCash("JMT STAR", "JSTAR001", operator.code);
	self.assertTrueMsg(self.myVoyage &lt;&gt; null, "Voyage '" &amp; CashVoyageCode &amp; "' not created...");

	self.opts.purge();
	self.opts.addAssoc("CargoType", ct);
	self.tranMapLoadBBlkSplit();
	
	// two receipts, each should have its own cash invoice, post the first one before releasing the cargo
	cargoId1 := cargoIds[1];
	self.opts.purge();
	self.opts.addAssoc("CargoType", ct);
	self.cashTestMultipleReceipts5(cargoId1, cargoId2, drTerm1, 1);
	
epilog
	self.deleteService(ServName);
	self.deleteInvoiceLineType(LineName,0);
	if currentFinClass &lt;&gt; null then
		self.setInvoiceFinancialClass(currentFinClass.class, null);
	endif;
	self.opts.purge();
	delete costs;
	delete debtorRate;
	delete cargoIds;
	self.resetDefaultTranMap();
	self.deleteTranMapTI("UT_BBlkSplit");	  // ### JIRA 35068 16JUN2025 NAVAB1
end;</source>
