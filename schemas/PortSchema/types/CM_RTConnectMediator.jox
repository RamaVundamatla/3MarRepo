    <JadeMethod name="buildUserPermissions" id="49844cc2-48c4-4303-9079-8367ab61ce8b">
        <source>buildUserPermissions(user : CM_User; _terminal : CM_Terminal);
// ---------------------------------------------------------------------------
// Created:			19 April 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	role : CM_SecurityRole;
	numPermissions,
	i : Integer;
	userTerminal:CM_UserTerminal;	
begin
	self.currentUserPermissions.clear;

	if user = null then
		return;
	endif;


	userTerminal := user.getUserTerminal(_terminal);
	
//	foreach role in userTerminal.allSecurityRoles do
	if userTerminal.mySecurityRole &lt;&gt; null then
		numPermissions := role.permissions.size;
		foreach i in 1 to numPermissions do
			if role.permissions[i] then
				self.currentUserPermissions[i] := true;
			endif;
		endforeach;
	endif;
//	endforeach;

end;</source>
        <Parameter name="user" type="CM_User"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="canBeAllocatedMixedTasks" id="0aa5557b-8970-4430-b758-6d318824dac9">
        <source>canBeAllocatedMixedTasks() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2013	cnwrd1	Initial creation
//cnwrd1 32293
*/

vars
	result : Boolean;
begin

	if self.machine &lt;&gt; null then
		result := self.machine.canBeAllocatedMixedTasks;
	else
		result := false;
	endif;

	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAlertDetails" id="52dbcb97-76e6-4323-a4e2-509b0262474e">
        <source>getAlertDetails() : String;
/*
 ------------------------------------------------------------------------
Created:			27 June 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if self.machine &lt;&gt; null then
		return "Exception Error reported from machine " &amp; self.machine.id.trimRight;
	elseif self.user &lt;&gt; null then
		return "Exception Error reported from user " &amp; self.getUserId();
	else
		return "Exception Error reported from Device PhysId: " &amp; self.device.id;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUserId" id="83224f30-7710-4700-9185-d5fb4fe14b21">
        <source>getUserId() : String;
/*
 ------------------------------------------------------------------------
Created:			01 May 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if self.user = null then
		return app.getErrorString(UnknownUser);
	endif;
	return self.user.code.trimRight;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="init" id="a6d982c8-1cf6-47d5-be09-8af9a0e552d6">
        <updating/>
        <source>init(_terminalCode : String) updating;
// ---------------------------------------------------------------------------
// Created:     09 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
16 Mar 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars

begin
	self.terminalCode 	:= _terminalCode;
	self.setTwinTasks(false);
	self.setCanBeAllocatedMixedTasks(false); //cnwrd1 32293
end;</source>
        <Parameter name="_terminalCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="logMessage" id="292bf3b1-0ee0-4d29-842a-4e65da0b3a5e">
        <updating/>
        <source>logMessage(pClass: Class; pMethod: Method; msgToLog : String) updating;

vars
begin

	app.writeLog(pClass.name &amp; "::" &amp; pMethod.name &amp; " Process=" &amp; process.String &amp; " Mediator=" &amp; self.String &amp; "Dev=" &amp; self.device.id &amp; " " &amp; msgToLog, LogINFO);
	if self.logFile = null then	
		return;
	endif;
	if not self.doTrace then
		return;
	endif;

	logFile.logMessage(pClass.name &amp; "::" &amp; pMethod.name &amp; " Process=" &amp; process.String &amp; " Mediator=" &amp; self.String &amp; "Dev=" &amp; self.device.id &amp; " " &amp; msgToLog);

end;</source>
        <Parameter name="pClass" type="Class"/>
        <Parameter name="pMethod" type="Method"/>
        <Parameter name="msgToLog" type="String"/>
    </JadeMethod>
    <JadeMethod name="myCurrentUserCan" id="be84a8a7-5fa8-47d4-abcd-084751b884c7">
        <source>myCurrentUserCan(doWhat : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:			19 April 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if app.isSpecial() then
		return true;
	endif;
	if self.currentUserPermissions.size = 0 then
		//No permissions yet! Must be no user
		return true;
	endif;
	if self.currentUserPermissions.size &lt; doWhat then
		return false;
	endif;
	return self.currentUserPermissions[doWhat];
end;</source>
        <Parameter name="doWhat" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
