    <JadeMethod name="comboBoxShippingLine" id="b057e068-a856-4a9a-9003-889490b3a017">
        <source>comboBoxShippingLine(_cmb : ComboBox input; _shippingLine : CM_ShippingLine);
//--------------------------------------------------------------
//Created: March 2002 By: cnwgd1
// Changed BY Reason
// 19 May 2022	navgm20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
//--------------------------------------------------------------
vars

begin

//************YOU SHOULD USE THE NEW OBJECT COMBO CMUI_ComboShippingLine AS IT DOES SORTING BY NAME**************

	_cmb.listCollection(app.myRoot.allShippingLines, true, 0);
	
	if _shippingLine &lt;&gt; null then
