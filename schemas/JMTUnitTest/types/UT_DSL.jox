    <JadeMethod name="zapQueueEntry" id="92a5c54f-83ed-465d-aeaf-c45491f3d73b">
        <source>zapQueueEntry(_queueEntry: CM_RTQueueEntry);
//20 September 2010	cnwdw1	
//  Very yucky - It would be good is someone get work out how to do this properly
vars
	obj: Object;
begin
	if _queueEntry &lt;&gt; null then
		beginTransaction;
			obj := _queueEntry;
			delete obj;
		commitTransaction;
	endif;
end;</source>
        <Parameter name="_queueEntry" type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="zapQueueTask" id="60305783-ed9d-463d-b281-823c37392966">
        <source>zapQueueTask(_queueTask: CM_RTQueueTask);
//20 September 2010	cnwdw1	
//  Very yucky - It would be good is someone get work out how to do this properly
vars
	obj: Object;
begin
	if _queueTask &lt;&gt; null then
		self.zapQueueEntry(_queueTask.myEntry);
	endif;
end;</source>
