    <JadeMethod name="tblJobSheet_contextMenu" id="4291a60f-b626-4e21-b8f5-f95f405c30ec">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblJobSheet_contextMenu(table: CM_DataTable input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2023	navhl20	ChangeRequest 57766:[57767] EUP - Delivery Dispatch – Define Job Sheet

*/

vars

begin
	return self.doMnuFormContextMenu(table, mouse, x, y);
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
