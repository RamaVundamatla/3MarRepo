    <JadeMethod name="isSuitableForTI" id="239a222f-6f05-43e1-b1d4-f7897804ba59">
        <source>isSuitableForTI(control: CMIF_MoveController): Boolean;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	if self.width &gt; 0 then
		return false;
	else
		return true;
	endif;
end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
        <ReturnType type="Boolean"/>
