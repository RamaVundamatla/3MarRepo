    <JadeMethod name="allPortDisplayCodesChecker" id="635600c4-ce2d-4e13-849d-b72cf47717d4">
        <source>allPortDisplayCodesChecker(_port : CM_Port);

// Created by cnwdvb1 on 10 April 2006
// Updated by cnwjo3 on 28/6/2010.
vars
	invalid : Boolean;
begin
	//if not global.isValidObject(_port) then
	//	return;
	//endif;
	
	if _port = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _port, invalid);
	
	_port.creationTime;  //cause exception
	
	if invalid then
		return;
	endif;
	
	if not self.allPortCodeDisplay.includes(_port) then
		self.allPortCodeDisplay.add(_port);
	endif;
	
end;</source>
        <Parameter name="_port" type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="allPortDisplayCodesGetObject" id="3e808003-7adc-44dc-b3e4-4e49e991727c">
        <source>allPortDisplayCodesGetObject(_portCode : String) : CM_Port;

// Created by cnwdvb1 on 10 April 2006

vars

	port	: CM_Port;

begin

	port := app.myRoot.allPorts[_portCode];
	
	return port;

end;</source>
        <Parameter name="_portCode" type="String"/>
        <ReturnType type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="allPortDisplayCodesInitialize" id="840c95a6-f99d-47a4-9801-84537e954856">
        <updating/>
        <source>allPortDisplayCodesInitialize() updating;

// Created by cnwdvb1 on 10 April 2006

vars

	obj	: CM_Port;
	dict			: CM_PortByCodeDict;
begin

	if self.isPortCodeDisplayInitialized then
		return;
	endif;
	
	self.allPortCodeDisplay.clear();
	dict := app.myRoot.allActiveDestinations;
	// Need to screen for dupes because of ordering of method calls
	foreach obj in dict discreteLock do
		//if not self.allPortCodeDisplay.includes(obj) then
			self.allPortCodeDisplay.add(obj);
		//endif;
	endforeach;
	
	self.isPortCodeDisplayInitialized := true;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="allPortsForVoyageInitialize" id="d942477f-1b78-4b20-aa9c-882ac330bc50">
        <updating/>
        <source>allPortsForVoyageInitialize(_voyage : CM_Voyage) updating;
// Created by cnwdvb1 on 10 April 2006
/*

Date		Who		Reason
14 Mar 2011	cnwkpd1	PAR #27142 - Correct handleDeletedObject exception arming

*/

vars
	port: CM_Port;
	invalidPort: Boolean;
begin
	if _voyage = null then
		return;
	endif;
	
	self.allPortsVoyCodeDisplay.clear();
	
	on Exception do app.handleDeletedObject(exception, port, invalidPort);

	// Need to screen for dupes because of ordering of method calls
	foreach port in _voyage.allPorts discreteLock do
		if port = null then	// PAR 23692 19/04/2010
			continue;
		endif;
		invalidPort := false;
		
		if port.isActivePort then
			if not self.allPortsVoyCodeDisplay.includes(port) then
				self.allPortsVoyCodeDisplay.add(port);
			endif;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="allTranshipPortsForDischPort" id="3c37384e-e40a-47d7-b76e-dd6a6ace27be">
        <source>allTranshipPortsForDischPort(_port : CM_Port; _voyage : CM_Voyage; _coll : Collection io);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2009	cnwas3	Initial creation

*/

vars
	
	transhipPort 	: CM_Port;
	portRotation 	: CM_PortRotation;
	
begin
	_coll.clear();
	foreach portRotation in _voyage.allPortRotations where (portRotation.allTranshipPorts.size() &gt; 0 and portRotation.myPort = _port) do
		foreach transhipPort in portRotation.allTranshipPorts do
			if not _coll.includes(transhipPort) then //cnwrd1 par 23033 10.3.2010
				_coll.add(transhipPort);
			endif;
		endforeach;
	endforeach;
epilog
	
end;</source>
        <Parameter name="_port" type="CM_Port"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_coll" type="Collection" usage="io"/>
    </JadeMethod>
    <JadeMethod name="allTranshipPortsForVoyage" id="81fb86ac-0689-4ce0-a559-7544b364f870">
        <source>allTranshipPortsForVoyage(_voyage : CM_Voyage; _coll : Collection io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2009	cnwas3	Initial creation

*/

vars
	
	transhipPort 	: CM_Port;
	portRotation : CM_PortRotation;
	
begin
	
	
	_coll.clear();
	
	if _voyage = null then 
		return;
	endif;
	
	foreach portRotation in _voyage.allPortRotations where portRotation.allTranshipPorts.size() &gt; 0 do
		foreach transhipPort in portRotation.allTranshipPorts do
			if not _coll.includes(transhipPort) then //cnwrd1 par 23033 10.3.2010
				_coll.add(transhipPort);
			endif;
		endforeach;
	endforeach;

epilog
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_coll" type="Collection" usage="io"/>
    </JadeMethod>
    <JadeMethod name="autoCalcVolume" id="b32ca4b6-1304-4472-8504-0294d83bb989">
        <source>autoCalcVolume(_length, _width, _height: Decimal): Decimal;
/*
----------   ----------  --------------------------------------------------
Created:	15 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
18/11/2010	cnwvu1		#25592. Separated UI from business logic. 
						Now, all screens either having tables or having textboxes can use this method.
						P.S. Measurements are in cm
27/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements changed Integer parameters to Decimal
*/
vars
	/*length,	
	width,
	height		: Integer;*/
	volume 		: Real;
	
begin
	//length			:= table.getValueByNameIfVisible(ETRow_MyLength).Integer;
	//width			:= table.getValueByNameIfVisible(ETRow_MyWidth).Integer;
	//height			:= table.getValueByNameIfVisible(ETRow_MyHeight).Integer;
	
	volume := (_length/100 * _width/100 * _height/100);
	
	//table.setValueByName(ETRow_MyVolume, volume);
	return volume;
	

end;</source>
        <Parameter name="_length" type="Decimal"/>
        <Parameter name="_width" type="Decimal"/>
        <Parameter name="_height" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="autoCalcVolumeWhenNotNull" id="3fd9b8ae-0979-4daf-9ae3-800ddd88fa4b">
        <source>autoCalcVolumeWhenNotNull(_length, _width, _height: Decimal; _vol: Decimal): Decimal;
/* ---------------------------------------------------------------------------
Created:	21 December 2010	by cnwvu1

Purpose:	#26654. _vol - existing current volume on the UI screen.
   
Change Date		Who			Reason
-----------		--------	--------------------------------------------------
27/03/2013		cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements 
							Changed Integer _length _width _height to Decimal
------------------------------------------------------------------------------*/
vars

begin

	if (_length = 0) or (_width = 0) or (_height = 0) then	//#26654 21/12/2010
		return _vol;	// if any of these are null, don't touch volume. Maybe, it has some value, for example, timber for Port Nelson has volume and length.
	endif;

	return self.autoCalcVolume(_length, _width, _height);

end;</source>
        <Parameter name="_length" type="Decimal"/>
        <Parameter name="_width" type="Decimal"/>
        <Parameter name="_height" type="Decimal"/>
        <Parameter name="_vol" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="autoPlanForDischarge" id="92da5c87-5fe3-4434-8ce1-d7e7c79fd2a9">
        <source>autoPlanForDischarge(_terminal : CM_Terminal; _voy : CM_Voyage);

// Created by cnwdvb1 on 01 May 2006

vars

	form	: CMUI_AutoPlanDischargeForm;

begin

	if _voy = null then
		return;
	endif;
	
	if app.msgBox('Do you wish to auto plan all discharge jobs for voyage ' &amp; _voy.code, 'Auto Discharge', MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;

		
	form	:=	app.loadForm(CMUI_AutoPlanDischargeForm, self.class, false, false, false, self.myTerminal, null).CMUI_AutoPlanDischargeForm;
	form.myVoyage := _voy;
				
	if form = null then
		return;
	endif;
		
	form.show();

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_voy" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="buildMnuGridDischargePlan" id="13d92a7f-06a3-48c3-9674-5480cf3b3544">
        <source>buildMnuGridDischargePlan(_menu : MenuItem input;_locationsController : CM_LocationsController);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 May 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	thePlanMove			: CM_FutureMove;
begin
	if app.myMoveController &lt;&gt; null then
			// DISCHARGE
			if app.myDraggedTrackedItem &lt;&gt; null then
				thePlanMove := app.myDraggedTrackedItem.getFutureMoveOfType(PLANNING_MODE, TI_FutureMoveDLRDischarge);
				if thePlanMove = null then
					thePlanMove := app.myDraggedTrackedItem.getFutureMoveOfType(PLANNING_MODE, TI_FutureMovePlanned);
				endif;
				if thePlanMove &lt;&gt; null then
					_menu.userObject := null;
					_menu.visible := false;
				else
					if app.myMoveController.mySlotRequest &lt;&gt; null and 
					   app.myMoveController.mySlotRequest.myJob &lt;&gt; null then
						// YES!
						if app.myMoveController.mySlotRequest.isDischarge  then
							_menu.caption := "Plan Discharge " &amp; app.myDraggedTrackedItem.id;
							_menu.userObject := _locationsController;
							_menu.visible := true;
						endif;
					elseif app.myMoveController.myVoyageRequest &lt;&gt; null and 
					   app.myMoveController.myVoyageRequest.myJob &lt;&gt; null then
						// YES!
						if app.myMoveController.myVoyageRequest.isDischarge  then
							_menu.caption := "Plan Discharge " &amp; app.myDraggedTrackedItem.id;
							_menu.userObject := _locationsController;
							_menu.visible := true;
						endif;
					endif;
				endif;
			endif;
		endif;
epilog

end;</source>
        <Parameter name="_menu" type="MenuItem" usage="input"/>
        <Parameter name="_locationsController" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="buildMnuGridLoadPlan" id="1903be35-b6da-4851-afdc-e6da43f75114">
        <source>buildMnuGridLoadPlan(_menu : MenuItem input;
				_ti : CM_TrackedItem;
				_gridController		: CM_LocationsController;
				_allTIs 			: Collection input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 May 2012	cnwer1	Initial creation CCMS MES 1035
16/05/2017 	cnwrh7  TFS4142 #PNL - Can't plan prenoted cargo

*/

vars
	
	anLC				: CM_LocationsController;
	locnString			: String;
	thePlanMove			: CM_FutureMove;
	gridController		: CM_LocationsController;
begin
	gridController:=_gridController;
	_menu.visible := false;
	if _ti = null or app.myMoveController = null then
		return;
	endif;
	// #####################
		// PLANNING FROM SHIP?
		// #####################

	if not app.myMoveController.isForShipLoadPlanning() then
		return;
	endif;
	
	
	// if it is planned DLR discharge and a 40 they may have right clicked on the back end.
	// we must have the primary location of teh 40 so that the screen draws correctly
	if  _ti.isAttributeTrue(TI_Attrib_IsForty) then
		if _ti.isRehandle then
			thePlanMove := _ti.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveDLRDischarge);
			if thePlanMove &lt;&gt; null then
				anLC := thePlanMove.CM_FutureMovePlanned.allLocationsControllers.first;
				if anLC &lt;&gt; null and anLC.isKindOf(CM_YardController) then
					gridController := anLC.CM_YardController;
				endif;
			endif;
		else
			// if a plain export load then we need the primary actual location
			anLC := _ti.myPrimaryActualLocation;
			if anLC &lt;&gt; null and anLC.isKindOf(CM_YardController) then
				gridController := anLC.CM_YardController;
			endif;
		endif;
	endif;									

	if gridController = null then
		gridController:=_ti.myPrimaryActualLocation;
	endif;
	/*if gridController = null or not gridController.isYardLocation then						//-TFS4142
		return;
	endif;
	*/
	app.myMoveController.setMyTrackedItem(_ti);
	app.myMoveController.setMyOriginatingLocation(gridController);
	locnString:= app.myMoveController.getStowageDisplay();

	if _allTIs &lt;&gt; null and _allTIs.size &gt; 1 then
		_menu.caption := "Plan Load Selected Cargo";
		_menu.userObject:=null; //epr par 37386 20/1/16
	else
		_menu.caption := app.getErrorString(SHP_Plan_Load_To) &amp; locnString;
		_menu.userObject := gridController;
	endif;
	_menu.visible := true;

	
epilog

end;</source>
        <Parameter name="_menu" type="MenuItem" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_gridController" type="CM_LocationsController"/>
        <Parameter name="_allTIs" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildMnuTasksAdd" id="ffe19699-2bc8-41c4-b108-685740253fd4">
        <source>buildMnuTasksAdd(_menuMaster, _mnuTaskAddSub : MenuItem input; _theTI : CM_TrackedItem input);
// ---------------------------------------------------------------------------
// Created:     20 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 18/03/2010	cnwmh5		PAR22887 - Fix issue with itemEnabled not working correctly
// 24 Oct 2017	jlgrh7 TFS7151 STWO - RE: Ticket 4034 - System fault / bug - To Do tasks
// ---------------------------------------------------------------------------
vars
	dynaDict		: DynaDictionary;
	obj				: Object;
	task			: CM_ToDoTask;
	taskDesc		: CM_ToDoTaskDesc;
	mnuChild		: MenuItem;
	itemEnabled		: Boolean;
	idx 			: Integer;
	taskDict		: CM_ToDoTaskDescByCode;

begin
	// ##############################################
	// Build up menu of ToDo Tasks that can be set
	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForTerm(self.myTerminal, taskDict);
	
	if taskDict.isEmpty then
		_menuMaster.visible := false;
		return;
	endif;

	_menuMaster.visible := true;
	_menuMaster.enabled := true;
	_mnuTaskAddSub.visible:=taskDict.isEmpty;
	//epr TFS 7151 18/10/17													To delete menu item
	idx :=_mnuTaskAddSub.description.Integer;
	if idx &gt; 0 then
		while idx &gt; 0  do
				mnuChild := _mnuTaskAddSub.getMenuItem(idx);
				if mnuChild &lt;&gt; null then
					delete mnuChild;
				endif;	
				idx:= idx - 1;
		endwhile;
	endif;
	
	
	idx := 1;
	// 36868 sort menu items by sortKey then description, so that if there is no sort key or it is not unique then the description becomes the main sort field
	create dynaDict transient;
	dynaDict.setMembership(CM_ToDoTaskDesc);
	dynaDict.addMemberKey("sortKey", false, true);
	dynaDict.addMemberKey("description", false, true);
	dynaDict.endKeys(true);
	
	foreach taskDesc in taskDict do
		dynaDict.add(taskDesc);
	endforeach;

	foreach obj in dynaDict reversed do
		taskDesc := obj.CM_ToDoTaskDesc;
		idx := idx+1;
		itemEnabled := true;
		
		foreach task in _theTI.allToDoTasksToDo do
			if task.toDoTaskDesc = taskDesc then
				itemEnabled := false;
			endif;
		endforeach;

		if taskDesc.description = null then 
			itemEnabled := false;
		endif;
		
		// DVB added to screen for cargo type.
		if itemEnabled and not taskDesc.isAvailableForCargoType(_theTI.cargoType) then
			continue;
		endif;
		
		// Par 17775. ccms1045. APM - Yard Ops, new generator Types. August 2008
		if itemEnabled and not taskDesc.isValidForGenSet( _theTI ) then
			continue;
		endif;

		//keep cloning until all tasks represented
		
		mnuChild := _mnuTaskAddSub.getMenuItem(idx);
		if mnuChild = null then
			mnuChild := _mnuTaskAddSub.loadMenu(idx); // Clone menu								
			mnuChild.caption := taskDesc.description;
			mnuChild.visible := true;
			mnuChild.helpKeyword := taskDesc.description;
			mnuChild.userObject := taskDesc;
		endif;
		mnuChild.enabled := itemEnabled;					// + 18/03/2010 cnmwh5 #22887		
	endforeach;
	
	//epr TFS 7151 18/10/17
	_mnuTaskAddSub.description:=idx.String;
	
epilog
	delete taskDict;
	delete dynaDict;
end;</source>
        <Parameter name="_menuMaster" type="MenuItem" usage="input"/>
        <Parameter name="_mnuTaskAddSub" type="MenuItem" usage="input"/>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildMnuTasksComplete" id="7de517f0-5a79-418e-b4cd-1699c574d76c">
        <source>buildMnuTasksComplete(_menuMaster, _mnuTaskCompleteSub : MenuItem input; _theTI : CM_TrackedItem input);
// ---------------------------------------------------------------------------
// Created:     20 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 18/03/2010	cnwmh5		PAR22887 - Fix issue with itemEnabled not working correctly
// 24 Oct 2017	jlgrh7 TFS7151 STWO - RE: Ticket 4034 - System fault / bug - To Do tasks
// ---------------------------------------------------------------------------
vars
	task			: CM_ToDoTask;
	taskDesc		: CM_ToDoTaskDesc;
	mnuChild		: MenuItem;
	subMenuAdded,
	itemEnabled		: Boolean;
	idx : Integer;
	taskDict		: CM_ToDoTaskDescByCode;
	
begin
	// ##############################################
	// Build up menu of ToDo Tasks that have been set, but are uncomplete
	taskDict := app.myPassport.myUser.getToDoTasksCompleteForTerm(self.myTerminal);
	
	if taskDict.isEmpty then
		_menuMaster.visible := false;
		return;
	endif;

	_menuMaster.visible := true;
	_menuMaster.enabled := true;
	_mnuTaskCompleteSub.visible := taskDict.isEmpty;	

	
	//epr TFS 7151 18/10/17																												To delete menu item
	idx :=_mnuTaskCompleteSub.description.Integer;
	if idx &gt; 0 then
		while idx &gt; 0  do
				mnuChild := _mnuTaskCompleteSub.getMenuItem(idx);
				if mnuChild &lt;&gt; null then
					delete mnuChild;
				endif;	
				idx:= idx - 1;
		endwhile;
	endif;
	
	idx := 1;
	//show todos that can be completed
	foreach taskDesc in taskDict do
		idx := idx + 1;		
		itemEnabled := false;

		if taskDesc.isForGenSetAttachDetach() then	// Attach/Detach generator task
			itemEnabled := false;	 //Par17775. ccms1045. Attach/Detach generator tasks cannot be completed manually and should be disabled
			if not _theTI.canHaveGeneratorAttached() then	// Par 18227, the menu item should be visible for reefers and trailers. Dec 2008
				continue;
			endif;
			
		else
			foreach task in _theTI.allToDoTasksToDo do
				if task.toDoTaskDesc = taskDesc then
					itemEnabled := true;
					break;
				endif;
			endforeach;
		endif;
		
		if not itemEnabled then
			continue;
		endif;
		//keep cloning until all tasks represented
		mnuChild := _mnuTaskCompleteSub.getMenuItem(idx);
		if mnuChild = null then
			mnuChild := _mnuTaskCompleteSub.loadMenu(idx); // Clone menu										
			mnuChild.caption := taskDesc.description;
			mnuChild.visible := itemEnabled;
			mnuChild.helpKeyword := taskDesc.description;
			mnuChild.userObject := taskDesc;
		endif;

		if itemEnabled then
			subMenuAdded := true;
		endif;
	endforeach;
	//epr TFS 7151 18/10/17
	if not subMenuAdded then
		_menuMaster.visible := false;		
	endif;
	_mnuTaskCompleteSub.description:=idx.String;
end;</source>
        <Parameter name="_menuMaster" type="MenuItem" usage="input"/>
        <Parameter name="_mnuTaskCompleteSub" type="MenuItem" usage="input"/>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildMnuTasksRemove" id="b1ca4e79-6e0a-4f0a-b188-978aa36ab0d5">
        <source>buildMnuTasksRemove(_menuMaster, _mnuTaskRemoveSub : MenuItem input; _theTI : CM_TrackedItem input);
// ---------------------------------------------------------------------------
// Created:     20 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 18/03/2010	cnwmh5		PAR22887 - Fix issue with itemEnabled not working correctly
// 24 Oct 2017	jlgrh7 TFS7151 STWO - RE: Ticket 4034 - System fault / bug - To Do tasks
// ---------------------------------------------------------------------------
vars
	task				: CM_ToDoTask;
	taskDesc			: CM_ToDoTaskDesc;
	mnuChild	: MenuItem;
	subMenuAdded,
	itemEnabled			: Boolean;
	idx : Integer;
	taskDict		: CM_ToDoTaskDescByCode;

begin

	// ##############################################
	// Build up menu of ToDo Tasks that have been set, but are uncomplete
	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForTerm(self.myTerminal, taskDict);
	
	if taskDict.isEmpty then
		_menuMaster.visible := false;
		return;
	endif;

	_menuMaster.visible := true;
	_menuMaster.enabled := true;
	_mnuTaskRemoveSub.visible:= taskDict.isEmpty;
	
	//epr TFS 7151 18/10/17																			To delete menu item
	idx :=_mnuTaskRemoveSub.description.Integer;
	if idx &gt; 0 then
		while idx &gt; 0  do
				mnuChild := _mnuTaskRemoveSub.getMenuItem(idx);
				if mnuChild &lt;&gt; null then
					delete mnuChild;
				endif;	
				idx:= idx - 1;
		endwhile;
	endif;
	
	idx := 1;

	//show todos that can be completed
	foreach taskDesc in taskDict do
		idx := idx + 1;		
		itemEnabled := false;
		
		if taskDesc.isForGenSetAttachDetach() and not _theTI.canHaveGeneratorAttached() then	//Par18227. Attach/Detach GenSet should be visible only for reefers and trailers
			continue;	// hide the menu item

		else
			foreach task in _theTI.allToDoTasksToDo do
				if task.toDoTaskDesc = taskDesc then
					itemEnabled := true;
					break;
				endif;
			endforeach;
		
		endif;
		
		if not itemEnabled then
			continue;
		endif;
		
		//keep cloning until all tasks represented
		mnuChild := _mnuTaskRemoveSub.getMenuItem(idx);
		if mnuChild = null then
			mnuChild := _mnuTaskRemoveSub.loadMenu(idx); // Clone menu												
			mnuChild.caption := taskDesc.description;
			mnuChild.visible := itemEnabled;

			mnuChild.helpKeyword := taskDesc.description;
			mnuChild.userObject := taskDesc;
		endif;
		
		if itemEnabled then
			subMenuAdded :=true;				
		endif;
	endforeach;
	_mnuTaskRemoveSub.description:=idx.String;
	//epr TFS 7151 18/10/17
	if not subMenuAdded then
		_menuMaster.visible := false;		
	endif;
epilog
	delete taskDict;
end;</source>
        <Parameter name="_menuMaster" type="MenuItem" usage="input"/>
        <Parameter name="_mnuTaskRemoveSub" type="MenuItem" usage="input"/>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="clearCurrentGateScanRecord" id="6ae37e88-cf34-40f5-8382-ec642f60dcce">
        <updating/>
        <source>clearCurrentGateScanRecord() updating;
/*

Purpose:			Sets/Clears the current Gate Scan Record used by the Gate forms

Parameters:			

Return Value:		

Date			Who		Reason
14 July 2022	navmd1	Initial creation TFS 52777 Tidy up/review code

*/

vars

begin
	self.myCurrentGateScanRecord := null;
	self.allRemainingGSRCargo.clear();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="combBoxTargetArea" id="1f909a18-d1b3-4dfd-878e-ea2e30fd5f3e">
        <source>combBoxTargetArea(_combo : CMUI_ComboBox input; _terminalArea : CM_TerminalArea );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Aug 2009	cnwmd1	Initial creation
08 Sep 2022	jlika1	TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
*/

vars
	aTerminalArea, aBlockStack : CM_TerminalArea;
	idx : Integer;
	theFilter		: CMQF_TerminalAreas;
	theQryReport	: CM_QryReport;
begin
	_combo.clear;
	theQryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(CM_RepTerminalArea);
	
	create theFilter transient;
	theFilter.allTerminals.add(self.myTerminal);
	theFilter.terminalAreaTypes.add(TA_TYPE_CRANE_TRANS);
	theFilter.terminalAreaTypes.add(TA_TYPE_DEPOT_LCL);
	theFilter.terminalAreaTypes.add(TA_TYPE_BLOCK_STACK);
	theFilter.terminalAreaTypes.add(TA_TYPE_SUBBLOCK_STACK);	
	theFilter.terminalAreaTypes.add(TA_TYPE_WASH_AREA);			
	theFilter.terminalAreaTypes.add(TA_TYPE_PTI);				
	theFilter.terminalAreaTypes.add(TA_TYPE_REPAIR);				
	theFilter.terminalAreaTypes.add(TA_TYPE_RECTRANS);				
	theFilter.terminalAreaTypes.add(TA_TYPE_RELTRANS);				
	theFilter.terminalAreaTypes.add(TA_TYPE_DAIRY);			
	theFilter.terminalAreaTypes.add(TA_TYPE_FORK_LIFT_STACK);									
	theFilter.terminalAreaTypes.add(TA_TYPE_STRADDLE_STACK);				
	theFilter.terminalAreaTypes.add(TA_TYPE_RTG);				
	theFilter.terminalAreaTypes.add(TA_TYPE_RMG);
	theFilter.terminalAreaTypes.add(TA_TYPE_RAIL_TRANS);	 //cnwrd1 6.8.2010 par 25315
	theFilter.terminalAreaTypes.add(TA_TYPE_RORO_LANE_AREA);	//29 May 2012	NDL	Par 29642
	theFilter.terminalAreaTypes.add(TA_TYPE_HIDE);	
	theFilter.terminalAreaTypes.add(TA_TYPE_MAFI);	
	
	// Does not handle straddle stacks, only single controller areas
	// Straddles are handled by a string entry into the cmb edit text field (e.g. C 2601).
	theQryReport.doFilter(theFilter, app.myPassport);
	
	idx := _combo.addItem('');
	_combo.itemObject[idx] := null;
	foreach aTerminalArea in theFilter.allQryTerminalAreas do
		idx := _combo.addItem(aTerminalArea.id);
		_combo.itemObject[idx] := aTerminalArea;
	endforeach;
	
	if _terminalArea &lt;&gt; null then
		_combo.cnEcSetObjectIndex(_terminalArea);
	endif;

epilog
	delete theFilter;
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="combBoxUnPackLocation" id="6527798e-0060-4789-95db-68e568a8e783">
        <source>combBoxUnPackLocation(_combo : CMUI_ComboBox input; _terminalArea : CM_TerminalArea);
/*

Purpose:			
	This method will be used by work orders to set the unpack location
Parameters:			

Return Value:		

Date		Who		Reason
21 Mar 2023 navma1	Defect 57205: MTN - WO - Unexpected Program error when adding cargo items to Unpack work order

*/

vars
	aTerminalArea 	: CM_TerminalArea;
	idx 			: Integer;
	theFilter		: CMQF_TerminalAreas;
	theQryReport	: CM_QryReport;
begin
	_combo.clear;
	theQryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(CM_RepTerminalArea);
	
	create theFilter transient;
	theFilter.allTerminals.add(self.myTerminal);
	theFilter.terminalAreaTypes.add(TA_TYPE_BLOCK_STACK);
	theFilter.terminalAreaTypes.add(TA_TYPE_BULK);
	theFilter.terminalAreaTypes.add(TA_TYPE_HIDE);
	theFilter.terminalAreaTypes.add(TA_TYPE_DEPOT_LCL);
	
	theQryReport.doFilter(theFilter, app.myPassport);
	
	idx 					:= _combo.addItem('');
	_combo.itemObject[idx]  := null;

	foreach aTerminalArea in theFilter.allQryTerminalAreas do
		idx 					:= _combo.addItem(aTerminalArea.id);
		_combo.itemObject[idx]  := aTerminalArea;
	endforeach;
	
	if _terminalArea &lt;&gt; null then
		_combo.cnEcSetObjectIndex(_terminalArea);
	endif;

epilog
	delete theFilter;
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="comboBoxAMSDispositionCodes" id="3ba8a05b-66f2-49b2-8402-63c70b57c991">
        <source>comboBoxAMSDispositionCodes(_cmb : ComboBox input; _ediAction : CM_EDIAction);
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 17 February 2009
//
// Implemented version: 7.7.1
// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
//----------------------------------------------------------------------

vars
	ediAction		: CM_EDIAction;
begin

	_cmb.sorted := true;
	_cmb.clear();
	
	foreach ediAction in app.myRoot.allEDIActions where ediAction.myEDIFileType.type = EDIFileTypeX12_350_4010 do
			_cmb.itemObject[_cmb.addItem(ediAction.keyword &amp; Tab &amp; ediAction.description)] := ediAction;
	endforeach;

	if _ediAction &lt;&gt; null then
		_cmb.text := self.displayEntryCustomsStatMessage(_ediAction);
		_cmb.listObject := _ediAction;
	endif;

end;
</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_ediAction" type="CM_EDIAction"/>
    </JadeMethod>
    <JadeMethod name="comboBoxAddCode" id="4f2b34ab-35bf-438a-8c4c-ac376a117fe9">
        <source>comboBoxAddCode(_cmb : ComboBox input; col : Collection; _selectedObj : CM_Code; _allowNull : Boolean);
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj		: Object;
	iter	: Iterator;
	idx 	: Integer; 
	found,
	ls		: Boolean;

begin

	_cmb.clear;
	
	if _allowNull then
		idx := _cmb.addItem(null);
		_cmb.itemObject[idx] := null;
	endif;

	if col = null then
		return;
	endif;

	app.cmsBeginLoad(ls);
	
	iter := col.createIterator;
	while iter.next(obj) do
		if obj.CM_Code.notAvailableForEntry then
			continue;
		endif;
		
		idx := _cmb.addItem(obj.CM_Code.code &amp; Tab &amp; obj.CM_Code.description);
		_cmb.itemObject[idx] := obj.CM_Code;
		
		if _selectedObj &lt;&gt; null and _selectedObj = obj then
			found := true;
		endif;
	endwhile;
	
	if _selectedObj &lt;&gt; null then
		if (not found) then
			idx := _cmb.addItem(_selectedObj.CM_Code.code &amp; Tab &amp; _selectedObj.CM_Code.description);
			_cmb.itemObject[idx] := _selectedObj.CM_Code;
		endif;
		_cmb.listObject := _selectedObj;
	endif;

epilog
	app.cmsEndLoad(ls);
	delete iter;

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="col" type="Collection"/>
        <Parameter name="_selectedObj" type="CM_Code"/>
        <Parameter name="_allowNull" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxAddLocationsWithNull" id="74369d90-ed84-46fd-ba1d-9cc0b6dcdd9f">
        <source>comboBoxAddLocationsWithNull(_cmb : ComboBox input; _lcs : Collection);
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj		: Any;
	iter	: Iterator;
	idx 	: Integer; 
	str		: String;

begin

	_cmb.sorted := false;

	_cmb.clear;
	_cmb.addItem(null);

	iter := _lcs.createIterator;
	foreach obj in _lcs do
		str := self.displayEntryLocationController(obj.CM_LogController);
		if str = null then
			continue;
		endif;
		idx := _cmb.addItem(str);
		_cmb.itemObject[idx] := obj.Object;
	endforeach;
		
epilog
	delete iter;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_lcs" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="comboBoxAddOperator" id="a4975360-7e2c-4c03-aa7c-ce3c0592a6a4">
        <source>comboBoxAddOperator(_cmb : ComboBox input; col : Collection);
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	obj		: Object;
	iter	: Iterator;
	count 	: Integer; 

begin

	_cmb.clear;
	_cmb.addItem(' ');
	_cmb.listObject := null;
	iter := col.createIterator;
	count := 1;
	while iter.next(obj) do
		count := count + 1;
		_cmb.addItem(obj.CM_Operator.code &amp; Tab &amp; obj.CM_Operator.description);
		_cmb.listIndex := count;
		_cmb.itemObject[count] := obj.CM_Operator;
	endwhile;
	_cmb.listIndex := -1;

epilog
	delete iter;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="col" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="comboBoxAllCommodity" id="7b979a1a-1cb2-4c8e-857f-68f61a7e854c">
        <source>comboBoxAllCommodity(_combo : CMUI_ComboBox input; _commodity : CM_Commodity);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/04/2025	navrv30	MTN 34319 EUP | Creating a Release Request from Cargo Review - Validation

*/


vars
	commodity		: CM_Commodity;
	terminal		: CM_Terminal;
	
begin
	terminal := self.myTerminal;
	_combo.clear();
	foreach commodity in app.myRoot.allCommodities discreteLock do  //cargo type based
		if commodity.isNotAvailableForEntry then
			continue;
		endif;
		_combo.addItemObject(commodity.code, commodity);
	endforeach;
epilog

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_commodity" type="CM_Commodity"/>
    </JadeMethod>
    <JadeMethod name="comboBoxAutoReply" id="eba1c150-cb37-49a5-9f5e-4a72394623a1">
        <source>comboBoxAutoReply(_cmb: CMUI_ComboBox input);
/*
----------   ----------  --------------------------------------------------
Created:	05 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	idx		: Integer;
begin
	
	if _cmb = null then
		return;
	endif;
	_cmb.clear;
	
	idx := _cmb.addItem(EmailReplyTypeStr_None);
	_cmb.itemData[idx] := EmailReplyType_None;
	
	idx := _cmb.addItem(EmailReplyTypeStr_HeaderOnly);
	_cmb.itemData[idx] := EmailReplyType_HeaderOnly;
	
	_cmb.text := EmailReplyTypeStr_None;
	
end;
</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxAutoTDTDesc" id="0652026d-f945-47cb-a1bf-e8982ee17a01">
        <updating/>
        <source>comboBoxAutoTDTDesc(_cmb:ComboBox input; _toDoTaskDesc:CM_ToDoTaskDesc) updating;
// ---------------------------------------------------------------------------
// Created:     09 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   25/09/06 by cnwth2 - was well busted by Dan Foo - see history!
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	toDoTaskDesc		: CM_ToDoTaskDesc;
	toDoDict			: CM_ToDoTaskDescByCode;
	
begin
	_cmb.clear();
	_cmb.sorted := false;
	
	toDoDict := app.myRoot.allToDoTaskDescriptions;
	foreach toDoTaskDesc in toDoDict 
		where toDoTaskDesc.type = TODO_TYPE_GROUP_TI do // ### TFS  #56634[54259] 22NOV2022 NAVAB1

		if (not toDoTaskDesc.trxTypeOnCompletion = TRANS_TYPE_WASH) then
			continue;
		endif;
		
		_cmb.itemObject[_cmb.addItem(self.displayEntryToDoTaskDesc(toDoTaskDesc))] := toDoTaskDesc;
	endforeach;
	

	if _cmb.findObject(_toDoTaskDesc) &gt; 0 then
		_cmb.listObject := _toDoTaskDesc;
	endif;
	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="comboBoxAutoTimerInterval" id="9acb30a0-4f45-481a-8e51-4c16ffc868b4">
        <source>comboBoxAutoTimerInterval(_cmb : ComboBox input ; pTimerInterval : Integer);
// ---------------------------------------------------------------------------
// Created:     09 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	int,count: Integer;
begin
    _cmb.clear;
    _cmb.sorted := false;
	loadAutoTimerCombos(_cmb,1,1);
	count := count + 1;
	loadAutoTimerCombos(_cmb,2,1);
	count := count + 1;
	loadAutoTimerCombos(_cmb,3,1);
	count := count + 1;
	loadAutoTimerCombos(_cmb,4,1);
	count := count + 1;
	loadAutoTimerCombos(_cmb,5,1);
	count := count + 1;
	loadAutoTimerCombos(_cmb,10,1);
	count := count + 1;
	loadAutoTimerCombos(_cmb,15,1);
	count := count + 1;
	loadAutoTimerCombos(_cmb,20,1);
	count := count + 1;
	loadAutoTimerCombos(_cmb,30,1);
	count := count + 1;
	loadAutoTimerCombos(_cmb,45,1);
	count := count + 1;
	loadAutoTimerCombos(_cmb,1,60);
	count := count + 1;
	loadAutoTimerCombos(_cmb,2,60);
	count := count + 1;
	loadAutoTimerCombos(_cmb,3,60);
	count := count + 1;
	loadAutoTimerCombos(_cmb,4,60);
	count := count + 1;
	loadAutoTimerCombos(_cmb,5,60);
	count := count + 1;
	loadAutoTimerCombos(_cmb,10,60);
	count := count + 1;
	loadAutoTimerCombos(_cmb,15,60);
	count := count + 1;
	loadAutoTimerCombos(_cmb,20,60);
	count := count + 1;
	loadAutoTimerCombos(_cmb,30,60);
	count := count + 1;
	loadAutoTimerCombos(_cmb,45,60);
	count := count + 1;
	loadAutoTimerCombos(_cmb,1,3600);
	count := count + 1;
	foreach int in 1 to count do
		if _cmb.itemData[int] = pTimerInterval then
			_cmb.listIndex := int;
			_cmb.text := pTimerInterval.String;
			break;
		endif;
	endforeach;

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="pTimerInterval" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxAvailabilityGrade" id="73ff3351-7bf9-4182-b81c-853fb7bcfaf7">
        <source>comboBoxAvailabilityGrade(_cmb : ComboBox input; _grade : CM_MTGrade);
//-----------------------------------------
// Created: February 2004 By: cnwgd1
//-----------------------------------------
vars
	mtGrade			: CM_MTGrade;
	mtGradeDict		: CM_MTGradeByCodeDict;
	str				: String;
begin
	_cmb.clear();
	_cmb.addItem(null);
	// CCMS 1235
//	mtGradeDict := app.myRoot.allAvailabilityGrades;
	mtGradeDict := app.myRoot.allAvailableAvailabilityGrades;

	foreach mtGrade in mtGradeDict do
		_cmb.itemObject[_cmb.addItem(self.displayEntryMTGrade(mtGrade))] := mtGrade;
	endforeach;
	
	if _grade &lt;&gt; null then
		str := self.displayEntryMTGrade(_grade);
		if not mtGradeDict.includes(_grade) then
			_cmb.itemObject[_cmb.addItem(str)] := _grade;
		endif;
		_cmb.text := str;//setting the text sets the listObject
	endif;
	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_grade" type="CM_MTGrade"/>
    </JadeMethod>
    <JadeMethod name="comboBoxBOLInsForVoyage" id="806f9e8c-dd90-4da6-adc7-89fa3c059f22">
        <source>comboBoxBOLInsForVoyage(_cmb: ComboBox input; _voy: CM_Voyage; _bolIn : CM_BOLIn);
/* ---------------------------------------------------------------------------
Created:	03 June 2010	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if _voy = null then
		_cmb.clear;
		return;
	endif;
	
	//_cmb.listCollection(_voy.allBOLInByTypeStatusNumDT[BOLType_GeneralBillOfLading, BOL_STATUS_NORMAL], true, 0);
	_cmb.listCollection(_voy.allBOLInByTypeStatusNumDT, true, 0);

	if _bolIn &lt;&gt; null and _voy.allBOLInByTypeStatusNumDT.includes(_bolIn) then
		_cmb.text := _bolIn.number;
		_cmb.listObject := _bolIn;
	else
		_cmb.listIndex := -1;
		_cmb.text := null;
	endif;
	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_voy" type="CM_Voyage"/>
        <Parameter name="_bolIn" type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="comboBoxBOLStatus" id="c116f016-02e8-4da6-a552-0b6a499b14d1">
        <source>comboBoxBOLStatus(_cmb : CMUI_ComboBox input; _status : Integer);
// ---------------------------------------------------------------------------
// Created:     01 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	_cmb.clear();
	_cmb.sorted := false;
	_cmb.addItem(Any_String);
	_cmb.itemData[_cmb.addItem(app.bolStatusEnumToString(BOL_STATUS_NORMAL))] := BOL_STATUS_NORMAL;
	_cmb.itemData[_cmb.addItem(app.bolStatusEnumToString(BOL_STATUS_ARCHIVED))] := BOL_STATUS_ARCHIVED;
	
	if _status = null then
		_cmb.text := Any_String;
	else
		_cmb.text := app.bolStatusEnumToString(_status);
	endif;
	
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
