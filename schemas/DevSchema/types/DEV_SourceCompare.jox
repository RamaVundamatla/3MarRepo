    <JadeMethod name="notificationReceieved" id="de939482-161e-4464-9b02-11fd76d74a2c">
        <source>notificationReceieved(_eventType: Integer; _theObject: Object; _eventTag: Integer) protected;
/*

Purpose:			Notification event receieved

Parameters:			_eventType:	The event type we are processing
					_theObject:	The object we are processing
					_eventTag:	The event tag we have received from the event

Return Value:		

Date		Who		Reason
28 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	write "Event Type: " &amp; _eventType.asStringJMT() &amp; " | " &amp; "Object: " &amp; _theObject.String.asStringJMT() &amp; " | " &amp; "Event Tag: " &amp; _eventTag.asStringJMT();

end;</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="98e93e57-1c9d-4dd2-9f04-425264f520c3">
        <updating/>
        <source>setupForm() protected, updating;
/*

Purpose:			Sets up our form controls

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	if not app.defaultMdi then
		self.centreWindow;
	else
		mnuExit.caption := "&amp;Close";
		//self.controlBox := false;
	endif;
	
	self.txtDMastSrcDir.text 	:= "C:\JMT_Source\dmast";
	self.txtDMastDestDir.text 	:= "C:\temp\dmast";
	self.txtWMastSrcDir.text 	:= "C:\JMT_Source\wmast";
	self.txtWMastDestDir.text 	:= "C:\temp\wmast";
	self.txtConsole.text 		:= "";
	self.updateStatusLine("", "");
	self.pbFileProgress.visible := false;
	self.shouldCleanFiles 		:= mnuCleanFiles.checked;
	self.chbExtractCleaned.value:= mnuCleanFiles.checked;
	self.shouldExtractFiles 	:= mnuExtractFiles.checked;
	self.chbExtractReorg.value:= mnuExtractFiles.checked;
	
	//self.beginClassNotification(DEV_SourceCompare, false, DevSourceCompareUpdateStatus, Response_Continuous, 0);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="4341054c-9eb9-43bc-a717-18f269675d79">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(_eventType: Integer; _theObject: Object; _eventTag: Integer) updating;
/*

Purpose:			Notification event

Parameters:			_eventType:	The event type we are processing
					_theObject:	The object we are processing
					_eventTag:	The event tag we have received from the event

Return Value:		

Date		Who		Reason
28 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	self.notificationReceieved(_eventType, _theObject, _eventTag);

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="toggleFormControls" id="a71c4843-b422-4e0f-976f-30e8acf8f7e3">
        <source>toggleFormControls(_enabled : Boolean) protected;
/*

Purpose:			Toggles the form controls (Used if the form is busy)

Parameters:			_enabled:	Boolean		Whether we are enabling or disabling our controls

Return Value:		

Date		Who		Reason
28 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	//Set whether our controls are enabled or not
	self.btnStart.enabled			:= _enabled;
	self.btnDMastDestDir.enabled	:= _enabled;
	self.btnDMastSrcDir.enabled		:= _enabled;
	self.btnWMastDestDir.enabled	:= _enabled;
	self.btnWMastSrcDir.enabled		:= _enabled;
	self.txtDMastDestDir.enabled	:= _enabled;
	self.txtDMastSrcDir.enabled		:= _enabled;
	self.txtWMastDestDir.enabled	:= _enabled;
	self.txtWMastSrcDir.enabled		:= _enabled;

	//Refresh our controls
	self.btnStart.refreshNow();
	self.btnDMastDestDir.refreshNow();
	self.btnDMastSrcDir.refreshNow();
	self.btnWMastDestDir.refreshNow();
	self.btnWMastSrcDir.refreshNow();
	self.txtDMastDestDir.refreshNow();
	self.txtDMastSrcDir.refreshNow();
	self.txtWMastDestDir.refreshNow();
	self.txtWMastSrcDir.refreshNow();
	
end;</source>
        <access>protected</access>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
