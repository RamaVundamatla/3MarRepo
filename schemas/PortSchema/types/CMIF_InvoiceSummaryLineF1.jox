    <JadeMethod name="getTsVessVoyString" id="c6971b08-e639-4156-b6e8-e80b7c3341f6">
        <source>getTsVessVoyString( _ti : CM_TrackedItem; _tiTrx : CM_TITransaction ):String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2017	jlgndl1	Initial creation	TFS 5799

*/

vars

	imex : Integer;
	recVoyageStr : String;
	releaseVoyage : CM_Voyage;
	relVoyageStr : String;
	invVoyageStr : String;

begin
	
	if _tiTrx &lt;&gt; null then
		imex := _tiTrx.imExStatus;
	else
		imex := _ti.getImExStatus;
	endif;
	
	if imex = TI_IMEX_STATUS_TRANSHIP then
		recVoyageStr := _ti.receiveVoyageCode;
		releaseVoyage := _ti.releaseVoyage;
		if releaseVoyage = null then
			releaseVoyage := _ti.myExportVoyage;
		endif;
		if releaseVoyage &lt;&gt; null then
			relVoyageStr := releaseVoyage.code;
		endif;
		invVoyageStr := self.myInvoice.voyageCode;
		if recVoyageStr = invVoyageStr then
			//the invoice line is relative to the import voyage, so output the export voayage 
			return relVoyageStr;
		elseif relVoyageStr = invVoyageStr then
			//the invoice line is relative to the export voyage, so output the import voayage 
			return recVoyageStr;
		endif;
		
	endif;
	
	//not a tranship, or voyages don't match...
	return null;

epilog

end;</source>
