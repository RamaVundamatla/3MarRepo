vars
	//wagonForm	: YRD_WagonForm;
begin

	// Update the navigator
//	self.myMasterMenuAction.setHeading(_railLine.CM_RailLine.id.trimBlanks &amp; " Wagon Maintenance"); 
	self.showWagonMaintForm(_railLine, Mode_Add, _position);		
/*	create wagonForm;
	self.allWagonForms.add(wagonForm);
	wagonForm.centreWindow;
	wagonForm.mode := Mode_Add;
	wagonForm.myCurrentRailLine := _railLine.CM_RailLine;
