    <JadeMethod name="mpdTestJSMTransIdLength" id="3acd19f1-132d-4eed-85b3-2bb9616d7816">
        <source>mpdTestJSMTransIdLength();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 June 2024		navmd1	Initial creation

*/

vars
	kc		: CnKarmaCntrl;
	str 	: String;
	isOk	: Boolean;
begin
	create kc transient;
	
	str := "MasonsTestOfTransactionIdLengthInJSMThisIs50Charas";
	self.cnStartTransaction(str[1:CN_TRANSACTION_ID_MAXLENGTH]);
	process.sleep(app.randomRange(1000, 5000));	// Wait some time
	self.cnEndTransaction();
	
	str := "MasonsTestOfTransactionIdLengthInJSMThisIs60CharactersLongA";
	self.cnStartTransaction(str[1:CN_TRANSACTION_ID_MAXLENGTH]);
	process.sleep(app.randomRange(1000, 5000));	// Wait some time
	self.cnEndTransaction();
	
	str := "MasonsTestOfTransactionIdLengthInJSMThisIs70CharactersLongAAAAAAAAAAAA";
	self.cnStartTransaction(str[1:CN_TRANSACTION_ID_MAXLENGTH]);
	process.sleep(app.randomRange(1000, 5000));	// Wait some time
	self.cnEndTransaction();
	
	str := "MasonsTestOfTransactionIdLengthInJSMThisIs80CharactersLongAAAAAAAAAAAABBBBBBBBBB";
	self.cnStartTransaction(str[1:CN_TRANSACTION_ID_MAXLENGTH]);
	process.sleep(app.randomRange(1000, 5000));	// Wait some time
	self.cnEndTransaction();
	
	str := "MasonsTestOfTransactionIdLengthInJSMThisIsMAXLENGTHCharactersLongAAAAAAAAAAAABBBBBBBBBBCCCCCCCCCCDDDDDDDDDDEEEMasonsTestOfTransactionIdLengthInJSMThisIsMAXLENGTHCharactersLongAAAAAAAAAAAABBBBBBBBBBCCCCC!!!!";	// 206, expecting to not see !!!!
	self.cnStartTransaction(str[1:CN_TRANSACTION_ID_MAXLENGTH]);
	process.sleep(app.randomRange(1000, 5000));	// Wait some time
	self.cnEndTransaction();
	
	isOk := true;
	
epilog
	if not isOk then
		self.cnEndTransaction();
	endif;
	delete kc;
end;</source>
    </JadeMethod>
