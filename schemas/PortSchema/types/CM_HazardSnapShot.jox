    <JadeMethod name="getDisplayStringForAttribute" id="69231d78-df23-474c-a158-843ce961f65d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:	TFS 40336		
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/

vars

begin
	if _attrName = ETRow_Limited then
		return self.limitedQuantity.getYesNo();
	elseif _attrName = ETRow_Flashpoint then
		return self.flashpointTemperature.String;
	elseif _attrName = ETRow_HazardClass then
		return self.code;
	elseif _attrName = ETRow_HazardCode then
		return self.undgCodes;
	elseif _attrName = ETRow_IsMarinePollutant then
	
			return app.isMarinePollutantEnumToString(self.isMarinePollutant);
	endif;
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
