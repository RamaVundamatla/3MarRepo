    <JadeMethod name="mnuGridLayout_click" id="c825315f-b50b-43f7-870e-07d56291f183">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuGridLayout_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     27 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	needToShow	: Boolean;
begin
	if app.isAltKeyDown()
	or app.isControlKeyDown()
	or app.isShiftKeyDown()
	then
		return;
	endif;
	
	needToShow := (menuItem.caption = app.getErrorString(ShowLayoutOverview)); 
	self.showHideLayout(needToShow);
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
