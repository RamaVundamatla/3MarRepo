    <JadeMethod name="loadSchema" id="ecd61053-0fbb-4b6d-9552-7c728a401d32">
        <source>loadSchema();
/*

Purpose:		Loads a schema file for comparison with current environment	

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2021	navpw1	Initial creation TFS: 52202

*/

vars
	targetDir, 
	appLogTmpDir				: String;
	currentSchemaData 			: Schema;
	currentClass 				: Class;
	currentMethod 				: Method;
	loadedSchemaFile 			: DEV_Schema;
	loadedSchemaClassesSection 	: DEV_SchemaClassesSection;
	loadedClass					: DEV_Class;
	loadedMethod				: DEV_Method;
	matches 					: JadeRegexMatch;
	devClass 					: DEV_Class;
	devMethod 					: DEV_Method;
	
begin
	self.toggleForm(false);
	self.qlbMissingClasses.clear();
	self.qlbMissingMethods.clear();
	self.qlbSelectClass.clear();
	self.qlbSelectMethod.clear();
	
	self.qlbMissingClasses.refreshNow();
	self.qlbMissingMethods.refreshNow();
	self.qlbSelectClass.refreshNow();
	self.qlbSelectMethod.refreshNow();
	
	if self.differentClasses.size() &gt; 0 then
		self.differentClasses.purge();
	endif;
	
	//Load the selected schema file
	appLogTmpDir := app.getAppServerLogDir() &amp; '\tmpFiles';
	
	targetDir := app.copyFileToAppServer(self.txtSourceFile.text);
	
	self.devSourceCompareAgent.doLoadSchemaFile(targetDir, self.txtSourceFile.tag.replace(".scm", ""));
	
	loadedSchemaFile := self.devSourceCompareAgent.mySchemaFile.mySchema;
	
	/*
	**	Run class and method comparison between the 2
	*/
	
	//Get Loaded Schema Data
	if(loadedSchemaFile.allSections.getAtKey("typeSources") &lt;&gt; null) then
		loadedSchemaClassesSection := loadedSchemaFile.allSections.getAtKey("typeSources").DEV_SchemaClassesSection;
	else
		//throw exception
	endif;
	
	//Process each class in schema and check if current schema has the same class
	
	currentSchemaData := rootSchema.getSchema(loadedSchemaFile.name);
	if (currentSchemaData &lt;&gt; null) then
		foreach loadedClass in loadedSchemaClassesSection.allClasses do
			//Load the currentClass into a variable
			currentClass := currentSchemaData.getClass(loadedClass.name);
			
			//Ignoring JadeScript, Primitives and Interfaces
			if currentClass &lt;&gt; null and currentClass.name = "JadeScript" then
				continue;
			elseif currentClass = null and currentSchemaData.getPrimitive(loadedClass.name) &lt;&gt; null then
				continue;
			elseif currentClass = null and currentSchemaData.getJadeInterface(loadedClass.name) &lt;&gt; null then
				continue;
			endif;
			
			if(currentClass &lt;&gt; null) then
				if currentClass.name = "JadeScript" then
					continue;
				endif;
			
				//Process method comparison for class
				foreach loadedMethod in loadedClass.allMethods do
					//Load the currentMethod into a variable
					currentMethod := currentClass.getMethod(loadedMethod.name);
					if currentMethod &lt;&gt; null then
						//Compare method source as string
						//If different store class name and method name in string array
						if currentMethod.getSource() &lt;&gt; loadedMethod.desc then
							if devClass &lt;&gt; null and devClass.name = loadedClass.name then
								devMethod := create DEV_Method(loadedMethod.name, loadedMethod.desc, loadedMethod.methodSource, -1, devClass) transient;
							else
								devClass := create DEV_Class(loadedClass.name, loadedClass.documentationTextData, loadedClass.isInterface, -1, null, null) transient;
								devMethod := create DEV_Method(loadedMethod.name, loadedMethod.desc, loadedMethod.methodSource, -1, devClass) transient;
								self.differentClasses.add(devClass);
							endif;
						endif;
					else
						//Add Method to listbox as it is different/not in the other schema
						self.qlbMissingMethods.addItem(loadedClass.name &amp; "::" &amp; loadedMethod.name);
						self.qlbMissingMethods.itemObject[self.qlbMissingMethods.newIndex] := loadedMethod;
						self.qlbMissingMethods.itemLevel[self.qlbMissingMethods.newIndex] := 1;
						self.qlbMissingMethods.itemExpanded[self.qlbMissingMethods.newIndex] := true;
					endif;
				endforeach;
			else
				//Add Class to listbox as it is different/not in the other schema
				self.qlbMissingClasses.addItem(loadedClass.name);
				self.qlbMissingClasses.itemObject[self.qlbMissingClasses.newIndex] := loadedClass;
				self.qlbMissingClasses.itemLevel[self.qlbMissingClasses.newIndex] := 1;
				self.qlbMissingClasses.itemExpanded[self.qlbMissingClasses.newIndex] := true;
			endif;
			
		endforeach;
		
		foreach loadedClass in self.differentClasses do
			//Load the currentClass into a variable
			currentClass := currentSchemaData.getClass(loadedClass.name);
			if(currentClass &lt;&gt; null) then
				//Process method comparison for class
				self.qlbSelectClass.addItem(loadedClass.name);
				self.qlbSelectClass.itemObject[self.qlbSelectClass.newIndex] := loadedClass;
				self.qlbSelectClass.itemLevel[self.qlbSelectClass.newIndex] := 1;
				self.qlbSelectClass.itemExpanded[self.qlbSelectClass.newIndex] := true;
			endif;
		endforeach;
	else
		write "Schema not found | " &amp; loadedSchemaFile.name;
	endif;

epilog
	self.toggleForm(true);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="qlbSelectClass_click" id="48a2b332-4195-45fd-acee-700c910ebf43">
        <controlMethod name="CMUI_ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>qlbSelectClass_click(listbox: ListBox input) updating;
/*

Purpose:			Select class event

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2021	navpw1	Initial creation TFS: 52202

*/

vars
	currentClass	: DEV_Class;
	currentMethod	: DEV_Method;
	
begin
	if listbox.text &lt;&gt; null then
		qlbSelectMethod.clear();
		
		foreach currentClass in self.differentClasses do
			if currentClass.name = listbox.text then
				foreach currentMethod in currentClass.allMethods do
					qlbSelectMethod.addItem(currentMethod.name);
					qlbSelectMethod.itemObject[self.qlbSelectMethod.newIndex] := currentMethod;
				endforeach;
				
				break;
			endif;
			
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="qlbSelectMethod_click" id="3c70a651-88a8-4b21-9cea-b1b7d73ffab8">
        <controlMethod name="CMUI_ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>qlbSelectMethod_click(listbox: ListBox input) updating;
/*

Purpose:			Select method event

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2021	navpw1	Initial creation TFS: 52202

*/

vars
	currentClass 				: DEV_Class;
	currentMethod 				: DEV_Method;
	loadedSchemaClassesSection 	: DEV_SchemaClassesSection;
	currentSchemaFile 			: DEV_Schema;
	
begin
	currentSchemaFile := self.devSourceCompareAgent.mySchemaFile.mySchema;
	
	if listbox.text &lt;&gt; null then
		if(currentSchemaFile.allSections.getAtKey("typeSources") &lt;&gt; null) then
			loadedSchemaClassesSection := currentSchemaFile.allSections.getAtKey("typeSources").DEV_SchemaClassesSection;
		else
			//throw exception
		endif;
		foreach currentClass in loadedSchemaClassesSection.allClasses do
			if currentClass.name = self.qlbSelectClass.text then
				foreach currentMethod in currentClass.allMethods do
					if currentMethod.name = listbox.text then
						self.jeLoaded.text := currentMethod.desc;
						break;
					endif;
				endforeach;
				break;
			endif;
			
		endforeach;
	endif;

	if rootSchema.getSchema(currentSchemaFile.name) = null then
		write "Could not find schema";
	elseif rootSchema.getSchema(currentSchemaFile.name).getClass(self.qlbSelectClass.text) =  null then
		write "Could not find class";
	elseif rootSchema.getSchema(currentSchemaFile.name).getClass(self.qlbSelectClass.text).getMethod(listbox.text) = null then
		write "Could not find method";
	else
		self.jeCurrent.text := rootSchema.getSchema(currentSchemaFile.name).getClass(self.qlbSelectClass.text).getMethod(listbox.text).getSource();
	endif;
	
epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
