    <JadeMethod name="getMyVoyageObject" id="8e637fc2-934f-4d31-95d2-3c9c746d683e">
        <source>getMyVoyageObject(): CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2025	navra1	Initial creation for //navra1 - MTN-34830 - 23rd May 2025

*/

vars
	
	
	voyage : CM_Voyage;
	terminal : CM_Terminal;
begin		
	terminal := self.getMyTerminal();
	if self.voyageCode &lt;&gt; null and terminal &lt;&gt; null then
		return terminal.lookupVoyage(self.voyageCode, null, false);
	endif;
	
	return null;
	
epilog
	
end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getReceiptTransportMode" id="6d4ea28e-5193-472e-910b-6e7a8a9997a3">
        <source>getReceiptTransportMode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
26 Oct 2022 navvt20 ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars
	ediTi: CM_EDITrackedItem;
begin
	foreach ediTi in self.allEDITrackedItems do
		if ediTi.isKindOf(CM_EDICargoTI) then
			//return ediTi.CM_EDICargoTI.receiptTransportMode.String; // 26 Oct 2022 navvt20 TFS 55084
			return app.transportModeENumToString(ediTi.CM_EDICargoTI.receiptTransportMode); // 26 Oct 2022 navvt20 TFS 55084
		endif;
	endforeach;
	return null;
epilog

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
