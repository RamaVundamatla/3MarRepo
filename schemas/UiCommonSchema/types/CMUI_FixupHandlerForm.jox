    <JadeMethod name="clickCmbMethod" id="25940a61-9d94-4391-be76-6c20e98d338b">
        <source>clickCmbMethod();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 May 2011	cnwndl1	Initial creation

*/

vars

begin

	//clear the paramters amnd the output and click run to show the help detail.
	
	self.txtParams.text := null;
	self.txtOutput.text := null;
	if cmbMethods.listIndex &gt; 0 then
		if cmbMethods.itemObject[cmbMethods.listIndex] &lt;&gt; null then
			self.clickRun();
		endif;
	endif;
	self.setButtons();

end;
</source>
    </JadeMethod>
    <JadeMethod name="clickFile" id="02487c34-9dba-4338-a9fc-18f412b8566a">
        <source>clickFile();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2011	cnwndl1	Initial creation	Par 27438

*/

vars

	outputText : String;
	line : String;
	outFile : File;
	fileLine : String;
	openDialog : CMDFileOpen;
	
	pos : Integer;

begin

	create openDialog transient;
	openDialog.filter := 'All Files|*.txt';
	openDialog.filterIndex := 1;
	
	if openDialog.open() = 0 then
		
		create outFile transient;
		outFile.mode := File.Mode_Output;
		outFile.allowCreate := true;
		outFile.openOutput(openDialog.fileName);
		
		app.mousePointer := MP_HOURGLASS;
		
		outFile.writeLine( self.cmbMethods.text );
		outFile.writeLine( " " );
		
		outputText := self.txtOutput.text;
		
		pos := outputText.pos(CrLf,1);
		while pos &gt; 0 do
			line := outputText[1:pos - 1];			
			outFile.writeLine( line );
			outputText := outputText[pos + 2:end];
			pos := outputText.pos(CrLf,1);
			if outputText = CrLf then
				break;
			endif;
			if outputText.length &lt; 2 then
				break;
			endif;
		endwhile;
		
		line := outputText;
		outFile.writeLine( line );
		
		outFile.close;
		
		app.msgBox("File '" &amp; outFile.fileName &amp; "' created",app.getErrorString(Complete),MsgBox_OK_Only);
	endif;
	
	app.mousePointer := MP_DEFAULT;

epilog

	delete outFile;

end;</source>
    </JadeMethod>
    <JadeMethod name="clickPrint" id="0fe6c54a-7bd4-4218-aee9-91dbb079e1ba">
        <source>clickPrint();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	cnwndl1	Initial creation	Par 27438

*/

vars

	outputText : String;
	pos : Integer;
	line : String;
	longestLine : Integer;
	printerName : String;

begin
	
	app.mousePointer := MP_HOURGLASS;
	
	self.tblPrint.columns := 1;
	self.tblPrint.rows := 2;
	self.tblPrint.fixedRows := 2;
	
	self.tblPrint.setCellText(1,1,"Special Method:  " &amp; self.cmbMethods.text);
	self.tblPrint.accessCell(1,1).alignment := Table.Alignment_Center_Middle;
	
	self.tblPrint.setCellText(2,1,"Parameters:  " &amp; self.txtParams.text);
	self.tblPrint.accessCell(2,1).alignment := Table.Alignment_Center_Middle;
	
	self.tblPrint.addItem(" ");
	
	outputText := self.txtOutput.text;
	
	pos := outputText.pos(CrLf,1);
	while pos &gt; 0 do
		line := outputText[1:pos - 1];
		if line.length &gt; longestLine then
			longestLine := line.length;
		endif;
		self.tblPrint.addItem(line);
		outputText := outputText[pos + 2:end];
		pos := outputText.pos(CrLf,1);
		if outputText = CrLf then
			break;
		endif;
		if outputText.length &lt; 2 then
			break;
		endif;
	endwhile;
	
	line := outputText;
	if line.length &gt; longestLine then
		longestLine := line.length;
	endif;
	self.tblPrint.addItem(line);
		
	app.printer.setPrinter(printerName);
	self.doPrintOutTable(self.tblPrint, self.caption[1:100], true, true, true, longestLine &lt; 120);
	
epilog

	app.printer.close;
	app.mousePointer := MP_DEFAULT;

end;</source>
    </JadeMethod>
    <JadeMethod name="clickRun" id="485afbb2-dfcc-4eed-aaa4-5d9ceb664a66">
        <source>clickRun();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	cnwndl1	Initial creation	Par 27438
June 2015	cnwjre1	For 36385 agent parameetrArray changed to HugeStringArray and getHugeTokensForDelimiter(space) used instead of getTokens
					to allow for file path as a parameter.
// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	
	hsa	: HugeStringArray;
	meth : Method;
	logStr : String;
	workString : String;

begin

	// get the user entered parameters and set them on the agent.
	create hsa transient;
	self.myFixupHandlerAgent.parameterArray.clear();
	//strArray := txtParams.text.getTokens();			// 36385 delimit by just space to allow for file paths
	txtParams.text.trimBlanks().getHugeTokensForDelimiter(Space.Character, hsa);
	if not hsa.isEmpty then
		hsa.copy( self.myFixupHandlerAgent.parameterArray );
	endif;
	
	//clear the local output from the form.
	txtOutput.text := null;

	//find the method we are supposed to run on teh agent.
	meth := self.cmbMethods.itemObject[self.cmbMethods.listIndex].Method;	
	if meth = null then
		return;
	endif;
	
	//get the start time and parameter value(s) to store away with the logging of the run.
	if self.txtParams.text.trimBlanks &lt;&gt; null then
		workString := "Initiated by " &amp; app.getMyUserCode &amp; " " &amp;app.actualTimeServer.asStringJMT;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.addOutput( "Special Method " &amp; workString &amp; CrLf );
		logStr := meth.qualifiedName &amp; " " &amp; workString &amp; "; ";
		
		workString := "Parameter(s) = '" &amp; self.txtParams.text &amp; "'";
		self.addOutput( workString &amp; CrLf &amp; CrLf );
		logStr := logStr &amp; workString &amp; "; ";
	endif;
	
	//run the method on the agent
	self.myFixupHandlerAgent.sendMsg(meth.name);
	
	//reset the buttons as required.
	self.setButtons();
	
epilog

	if meth &lt;&gt; null and self.txtParams.text.trimBlanks &lt;&gt; null then
		//add the completion time to our log comments.
		workString := "Completed " &amp; app.actualTimeServer.asStringJMT;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.addOutput( CrLf &amp; CrLf &amp; "Special Method " &amp; workString );
		logStr := logStr &amp; workString &amp; "; ";
	
		self.logTheOutcome( logStr, self.txtOutput.text );
	endif;
	
	delete hsa;
	app.mousePointer := MP_DEFAULT;

end;</source>
    </JadeMethod>
