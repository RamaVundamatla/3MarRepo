    <JadeMethod name="canUserAccessSelf" id="ecd2176b-dd75-404b-874d-817ea7a8b70a">
        <source>canUserAccessSelf(_user: CM_User; _failedDAC: CM_DataAccessController output; _passport: CM_Passport): Boolean;
// ---------------------------------------------------------------------------
// Created:     19 May 2009 by concms1
// Purpose:     Par 19715 - Vehicle Visit Record Detail Changes
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti	:CM_TrackedItem;
begin
	if not self.myVehicleVisitRecord.canUserAccessSelf (_user, _failedDAC, _passport) then
		return false;
	endif;
	
	if self.isCargoMove then
		ti := self.getExtraInfo_TrackedItem;
		
		if ti &lt;&gt; null then
			return ti.canUserAccessSelf (_user, _failedDAC, _passport);
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
