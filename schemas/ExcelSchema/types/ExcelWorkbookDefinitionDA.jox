    <JadeMethod name="doWizardStep3Processing" id="bec6a33d-8647-4a45-acde-098346d3eda0">
        <source>doWizardStep3Processing();

/*****************************************************
	Written by	:	cnwgrp1		11 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	extractOptions		: Object;

begin
	if blnSaveWorkbookDefn then
		/*I need to save both the workbook definition (in this package)
		  and the data extract option (in the host schema)*/
		myExcelDataDA.save;
	else
		if myWorkbookDefinition = null then
			extractOptions := null;
		else
			extractOptions := myWorkbookDefinition.myApplicationExtractOptions;
		endif;
		
		if myWorkbookDefinition &lt;&gt; null then
			myExcelDataDA.setValues(myWorkbookDefinition.workbookName,
								myWorkbookDefinition.workbookDescription,
								myWorkbookDefinition.dataWorksheet,
								myWorkbookDefinition.hideDataWorksheet,
								myWorkbookDefinition.topWorksheet);
		else
			myExcelDataDA.clearValues;
		endif;
		
		myControllingAppsDA.invokeMethod(myControllingAppsContext, myControllingAppsStoreMeth, extractOptions, false);
	endif;
		

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doWizardStep3ProcessingBack" id="21b93bf9-77c7-4017-bffb-e50416c78438">
