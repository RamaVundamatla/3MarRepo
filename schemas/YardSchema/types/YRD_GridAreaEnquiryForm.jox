    <JadeMethod name="setColorsFromController" id="faad632b-4222-4f9b-b01b-5262108cd830">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	tmpBackColor	: Integer;

begin
	inheritMethod(_colorControl);

	tmpBackColor := self.backColor;

	self.frmPopupInfo.backColor := tmpBackColor;
	self.frmDeckingOrder.backColor := tmpBackColor;
	self.frmPreferences.backColor := tmpBackColor;
	self.msgSelectAreas.backColor := self.backColor;
	self.frmSelectAreas.backColor := self.backColor;

	self.setColorsForEntryTable(self.tblPreferences);

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setDisplayMode" id="0f657216-9c36-4a86-b883-2bfcc3e8cd5a">
        <updating/>
        <source>setDisplayMode(_mode: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	newMode,
	theIndex : Integer;
	cdc : YRD_ContainerDrawingController;
	anObj : Object;
begin
	
	if _mode = DISPLAY_MODE_ACTUAL then
	elseif _mode = DISPLAY_MODE_PLAN then
	elseif _mode = DISPLAY_MODE_QUEUE then
	else
		return;
	endif;

	cdc := self.myCurrentDrawingController;
	if cdc = null then
		return;
	endif;
	
	cdc.setDisplayMode(_mode);
	cdc.drawSelf(true);

	self.frmStatusLine.displayMode := _mode;

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFromSelectorPanel" id="3d95fdd7-c381-430c-b559-8a3e0226b6c9">
        <updating/>
        <source>setFromSelectorPanel( 	_enqController : CM_EnquiryController;
						_viewMode : Integer;
						_clearSelection : Boolean;
						_didCreateEnq : Boolean
						) updating;

/*

Purpose:			
		called by frmSelectorPane::clickBtnRun
Parameters:			

Return Value:		


Date		Who		Reason
27 July 2011	cnwndl1	Initial creation	Par 27890
12 Oct 2012		cnwer1 par 30571
*/

vars
	enqObj : Object;
begin

	if _clearSelection then
	
		//colour up everything again.
		self.mnuGridSelectorClear.click(self.mnuGridSelectorClear);
	
	else
	
		// colour up the selection from the selector panel enquiry
		if _didCreateEnq then
			self.mySelectorEnquiryController := _enqController;
		endif;
		self.onlySelectSelectorTIs := true;
		
		self.allTIs .clear();
		if self.myCurrentDrawingController &lt;&gt; null then
			self.myCurrentDrawingController.allSelectorTIs.clear();
		endif;
		
		
		foreach enqObj in  _enqController.allObjects.CM_ObjectSet do
			if enqObj.isKindOf(CM_TrackedItem) then
				self.allTIs.add(enqObj.CM_TrackedItem);
				self.myCurrentDrawingController.allSelectorTIs.add(enqObj.CM_TrackedItem);
			elseif enqObj.isKindOf(CM_TITransaction) then
				if enqObj.CM_TITransaction.myTrackedItem &lt;&gt; null then
					self.allTIs.add(enqObj.CM_TITransaction.myTrackedItem);
					self.myCurrentDrawingController.allSelectorTIs.add(enqObj.CM_TITransaction.myTrackedItem);
				endif;
			endif;
		endforeach;
		
		/*if not _enqController.allObjects.isEmpty then
			_enqController.allObjects.copy( self.allTIs );
			if self.myCurrentDrawingController &lt;&gt; null then
				_enqController.allObjects.copy( self.myCurrentDrawingController.allSelectorTIs );
			endif;
		endif;*/
		
		self.doQuery( _viewMode );
		
		if _didCreateEnq then
			self.clearupSelectorQuery := true;
		endif;
		
	endif;
	
	return;
	
	// not called because of the return above, just here to give a reference
	// so some clown doesn't delete the high level one.
	inheritMethod( _enqController, _viewMode, _clearSelection, _didCreateEnq );

epilog

end;</source>
        <Parameter name="_enqController" type="CM_EnquiryController"/>
        <Parameter name="_viewMode" type="Integer"/>
        <Parameter name="_clearSelection" type="Boolean"/>
        <Parameter name="_didCreateEnq" type="Boolean"/>
    </JadeMethod>
