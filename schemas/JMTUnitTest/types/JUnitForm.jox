    <JadeMethod name="txtResultDetails_keyDown" id="015702d4-ae1d-46d8-8476-ef95760332ea">
        <controlMethod name="JadeRichText::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtResultDetails_keyDown(textbox: JadeRichText input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
13 December 2023		navmd1	Initial creation

*/
constants
	CMUI_Key_F11 = 122;
vars
	obj : Object;
begin
	if keyCode = CMUI_Key_F11
		and app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
	then
		if textbox.selText = null then
			return;
		endif;
		
		obj := textbox.selText.asOid;
		if obj = null then
			obj := (textbox.selText &amp; " (t)").asOid;
			if obj = null then
				return;
			endif;
		endif;
		
		obj.inspect;
		
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="JadeRichText" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
