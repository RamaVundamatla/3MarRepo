end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasUnsavedChanges" id="54de9bfd-5f02-4c4b-96bc-d87169641bce">
        <source>hasUnsavedChanges():Boolean;
/*
	Created on 20 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if cmb_CargoType.text &lt;&gt; null
	or cmb_Operator.text &lt;&gt; null
	or cmb_Product.text &lt;&gt; null
	or txt_CargoID.text &lt;&gt; null
	or txt_Mark.text &lt;&gt; null
	or txt_Location.text &lt;&gt; null
	or txt_Weight.text &lt;&gt; null then
		return true;
	endif;
	return inheritMethod();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
