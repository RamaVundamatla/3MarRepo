<Class name="CMIF_SummarySlotRequest" id="4ffbd02c-3b26-4794-a0bd-3d16ff7af673">
    <superclass name="CMIF_ReportExtraDetail"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="bayID" id="21d59875-1766-4ac3-a6a0-1898b0a71ed4">
        <length>6</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="dischargePort" id="390fb386-bad4-4ba4-b72c-727dec30c3a7">
        <length>6</length>
        <embedded/>
