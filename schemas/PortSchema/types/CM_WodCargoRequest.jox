    <JadeMethod name="getExtraInfo" id="a8f6f79a-2ae7-47d3-a0ee-7102fb1497ce">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:		TFS 39718	

Parameters:			

Return Value:		

Date		Who		Reason
11 Jul 2018	jlgab1	Initial creation
19 Dec 2018	NDL		TFS Protect against deleted Workpoint object
27 Jan 2021 navma1	Bug 52681: SAL - Display of Total Weight in Kgs in macro information - Cargo/Permit request
*/

vars
	block 		: CM_DataContainerBlock;
	transtype 	: CM_VoyageJobTransferType;
	wodres 		: CM_WodMarineServiceDetail;
	specialStow : CM_SpecialStow;
	value		: String;
begin
	inheritMethod(_dataContainer);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Imex_status), DC_Label, 1, null);
	block.addNewItem(app.getIMEXStringFromIMEXStatus(self.imexStatus), DC_Data, 1, null);
	
	// TFS 42221 19DEC18 taskID now has the cargo ID in it. This is set when the cargo is created.
	if self.taskID &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Cargo_ID), DC_Label, 1, null);
		block.addNewItem(self.taskID, DC_Data, 1, null);
	endif;
	
	if self.myCargoType &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CargoType), DC_Label, 1, self.myCargoType);
		block.addNewItem(self.myCargoType.description, DC_Data, 1, self.myCargoType);
	endif;
	
	if self.myCargoSubType &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(SubCargoType), DC_Label, 1, null);
		block.addNewItem(self.myCargoSubType.description, DC_Data, 1, null);
	endif;
	
	if self.myCommodity &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Commodity), DC_Label, 1, self.myCommodity);
		block.addNewItem(self.myCommodity.description, DC_Data, 1, self.myCommodity);
	endif;
	
	if self.totalQuantity &gt; 0 then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Total_Quantity), DC_Label, 1, null);
		block.addNewItem(self.totalQuantity.String, DC_Data, 1, null);
	endif;
	
	if self.totalVolume &gt; 0 then
		//27.01.2021 navma1 #52681
		value := self.getMesurementTypeValues(Type_Volume,self.totalWeight);
		
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Total_Volume), DC_Label, 1, null);
		block.addNewItem(value, DC_Data, 1, null);
	endif;
	
	if self.totalWeight &gt; 0 then
		//27.01.2021 navma1 #52681
		value := self.getMesurementTypeValues(Type_Weight,self.totalWeight);
		
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Total_Weight), DC_Label, 1, null);
		block.addNewItem(value, DC_Data, 1, null);
	endif;
	
	// TFS 42221
	if self.myConsignee &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Consignee), DC_Label, 1, self.myConsignee);
		block.addNewItem(self.myConsignee.code, DC_Data, 1, self.myConsignee);
	endif;
	
	if self.myConsignor &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Consignor), DC_Label, 1, self.myConsignor);
		block.addNewItem(self.myConsignor.code, DC_Data, 1, self.myConsignor);
	endif;
	
	if self.myFreightForwarder &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(FreightForwarder), DC_Label, 1, self.myFreightForwarder);
		block.addNewItem(self.myFreightForwarder.code, DC_Data, 1, self.myFreightForwarder);
	endif;
	
	if self.myOperator &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Operator), DC_Label, 1, self.myOperator);
		block.addNewItem(self.myOperator.code, DC_Data, 1, self.myOperator);
	endif;
		
	if self.getMyWorkPoint &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Work_point), DC_Label, 1, self.getMyWorkPoint);
		if self.getMyWorkPoint.description.trimBlanks() &lt;&gt; null then
			block.addNewItem(self.getMyWorkPoint.description, DC_Data, 1, self.getMyWorkPoint);
		else
			block.addNewItem(self.getMyWorkPoint.code, DC_Data, 1, self.getMyWorkPoint);
		endif;
	endif;
	
	if self.transferType &gt; 0 then
		transtype := app.myRoot.allVoyageJobTransferTypes[self.transferType];
		if transtype&lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Transfer_type), DC_Label, 1, null);
			block.addNewItem(transtype.description, DC_Data, 1, null);
		endif;
	endif;
	
	if self.rkbmNumber &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem("RKBM Number", DC_Label, 1, null);
		block.addNewItem(self.rkbmNumber, DC_Data, 1, null);
	endif;

	//20 Jul 2018	NDL	TFS 39837
	if self.dischargePort &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(DischargePort), DC_Label, 1, null);
		block.addNewItem(self.dischargePort, DC_Data, 1, null);
	endif;
	
	if self.loadPort &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Load_Port), DC_Label, 1, null);
		block.addNewItem(self.loadPort, DC_Data, 1, null);
	endif; 
	
	if self.bolNumber &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(BOLNumber), DC_Label, 1, null);
		block.addNewItem(self.bolNumber, DC_Data, 1, null);
	endif;
	
	if self.estimatedStartTS.date.isValid then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Estimated_start), DC_Label, 1, null);
		block.addNewItem(self.estimatedStartTS.asStringJMT, DC_Data, 1, null);
	endif;
	
	if self.estimatedEndTS .date.isValid then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Estimated_end), DC_Label, 1, null);
		block.addNewItem(self.estimatedEndTS .asStringJMT, DC_Data, 1, null);
	endif;
	
	//10 Sep 2018	NDL	TFS 40699
	specialStow := self.getSpecialStowObject();
	if specialStow &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(SpecialStow), DC_Label, 1, null);
		block.addNewItem(specialStow.description, DC_Data, 1, null);
	endif;
	
	//17 Aug 2018	NDL	TFS 40127
	foreach wodres in self.allMarineServiceDetails do
		wodres.getExtraInfo(_dataContainer);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
