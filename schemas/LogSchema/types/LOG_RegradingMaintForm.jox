        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbGrade_displayEntry(combobox: ComboBox input; obj: CM_LogGrade; lstIndex: Integer):String updating;
// ---------------------------------------------------------------------------
// Created:     19 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	grade : CM_LogGrade;
begin
/*
	grade := obj.CM_LogGrade;

	if grade =  null then
		return null;
	elseif grade.notAvailableForEntry then 
	app.writeStatement(class.name &amp; '::' &amp; method.name &amp; " - not  ");
		return null;
	else
app.writeStatement(class.name &amp; '::' &amp; method.name &amp; " - can  ");
		return grade.code.String &amp; Tab &amp; grade.description;
	endif;
*/		
	return self.myAssistant.displayEntryLogGrade(obj.CM_LogGrade);

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="CM_LogGrade"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
