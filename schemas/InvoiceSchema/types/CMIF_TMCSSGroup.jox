<Class name="CMIF_TMCSSGroup" id="92c6211c-fdf3-4a5d-97cd-99f5336b44d8">
    <superclass name="CMIF_TMCGroup"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <ImplicitInverseRef name="mySnapShotBroker" id="3f7a7369-caa0-4d8e-b43e-c006607a3a38">
        <embedded/>
        <type name="CM_SnapShotServiceBroker"/>
    </ImplicitInverseRef>
    <JadeMethod name="exportCargoCSV" id="e40e10b4-ff57-4ca7-bb79-51058b5aa068">
        <updating/>
        <source>exportCargoCSV(_file: File input; _line: String) updating;
// 33095 Jan 2014 put quotes around String fields
vars
	description,
	recordHeader,
	tmpString	: String;
	debtorType	: String;
	attr		: Integer;
	str,
	range	: String;
	allGroupProps : CM_QueryPropertyArray;
	ild			: CM_InvoiceLineDesc;
	queryProp	: CM_QueryProperty;
	qm			: CM_QuantityMap;
	qrm			: CM_QuantityRangeMap;
	ya			: CM_YardAllocation;
	yac			: CM_YACriteria;
	invAlloc	: CM_InvoiceAllocation;
	obj			: Object;
	selected,
 	selectedSorted	: ObjectArray;
	sa			: CnStringArray;		// membership size 260
	mapping : CM_TranMapInvoiceLineMapping;
begin
	self.setControllerCurrent();

	recordHeader := "Snapshot Summary," &amp; self.myGroup.extractName.csvEncode() &amp; "," &amp; self.extractName.csvEncode() &amp; ",";
	tmpString := recordHeader;
	if self.mySnapShotBroker.myDebtorType &lt;&gt; null then
		description := self.mySnapShotBroker.myDebtorType.description.removeTabCrLfs();	// 36400 drop CrLf
		debtorType := self.mySnapShotBroker.myDebtorType.code &amp; " (" &amp; description &amp; ")";
	endif;

	create allGroupProps transient;
	self.mySnapShotBroker.mySnapShotDefinition.getGroupingProperties( allGroupProps );
	create selected transient;
	foreach queryProp in allGroupProps where queryProp.allocationAttribute &lt;&gt; 0 do
		if self.mySnapShotBroker.allYACriteriaTypes.includes(queryProp.allocationAttribute) then
			selected.add(queryProp);
		endif;
	endforeach;
	create selectedSorted transient;
	foreach attr in self.mySnapShotBroker.allYACriteriaTypes do
		foreach obj in selected do
			queryProp := obj.CM_QueryProperty;
			if queryProp.allocationAttribute = attr then
				selectedSorted.add(obj);
				break;
			endif;
		endforeach;
	endforeach;

	create sa transient;

	// file header
	tmpString := "TranMap Type,TranMap Name,Invoice Map,";
	foreach obj in selectedSorted do
		queryProp := obj.CM_QueryProperty;
		tmpString := tmpString &amp; queryProp.niceName.csvEncode() &amp; ",";	// or yac.myYACriteriaType.description??
	endforeach;
	tmpString := tmpString &amp; "Debtor Type,Quantity Attribute,Default,Range,Invoice Line";
	_file.writeLine(tmpString);
	
	// each detail line
	tmpString := recordHeader;
	foreach ya in self.mySnapShotBroker.allInvoiceAllocationsByPriory do
		invAlloc := ya.CM_InvoiceAllocation;
		sa.clear;
		foreach yac in invAlloc.allCriteria do
			sa.add(yac.getRawDescription);
		endforeach;
		qm := invAlloc.myQuantityMap;
		foreach qrm in qm.allQuantityRanges do
			range := qrm.rangeStart.Integer.String &amp; " to " &amp; qrm.rangeEnd.Integer.String;
			// TFS 40620 foreach ild in qrm.allInvoiceLinesUsed do
			foreach mapping in qrm.allTMInvoiceLineMappings do // TFS 40620
				ild := mapping.myTMInvoiceLineDesc; // TFS 40620
			
			
			
			
			
				foreach str in sa do
					tmpString := tmpString &amp; '"' &amp; str &amp; '",';
				endforeach;
				tmpString := tmpString &amp; debtorType.csvEncode() &amp; "," &amp; qm.mySnapShotQuantityType.heading.csvEncode() &amp; "," &amp; invAlloc.default.String &amp; "," &amp; range &amp; "," &amp; ild.narration.csvEncode();
				_file.writeLine(tmpString);
				tmpString := recordHeader;
			endforeach;
		endforeach;
	endforeach;
	
epilog
	delete allGroupProps;
	delete selected;
	delete selectedSorted;
	delete sa;
end;



</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_line" type="String"/>
    </JadeMethod>
    <JadeMethod name="getPicture" id="1b18c5b5-d7db-4322-b483-a876ebbe5631">
        <source>getPicture(form: INV_TransactionMap): Picture;

vars

begin
	if self.hidePictures then
		return null;
	endif;
	return form.picTrans;
end;
</source>
        <Parameter name="form" type="INV_TransactionMap"/>
        <ReturnType type="Picture"/>
    </JadeMethod>
    <JadeMethod name="getRealMapObject" id="94dae28d-efc8-44b5-909d-5467beb0a5e8">
        <source>getRealMapObject(): Object;

vars

begin
	return self.mySnapShotBroker;
end;
</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="48e49ae2-9d6f-4889-9d62-642b4a67f9b3">
        <updating/>
        <source>initialise(_groupCount : Integer io) updating;
// don't create children
vars

begin
	inheritMethod(_groupCount);
end;
</source>
        <Parameter name="_groupCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setControllerCurrent" id="21efdec2-7d73-4e35-b2da-2aea835bf9d3">
        <source>setControllerCurrent() ;
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
vars

begin
	inheritMethod();
	
	myTMCController.myCurrentMapTMSS := self.mySnapShotBroker.myTransactionMap;
	myTMCController.myCurrentMapServiceBroker := self.mySnapShotBroker;

end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="503d146b-1f3c-4d90-947b-b5fd01e86acb">
        <source>setEnableObjects(form: INV_TransactionMap io);

vars

begin
	inheritMethod(form);

	form.menuSItemNew.visible := false;
	form.modePropertyNew := INV_TransactionMap.ModeProperty_TransMap;
	form.modePropertyUpdate := INV_TransactionMap.ModeProperty_SnapShot;
	form.modePropertyDelete := INV_TransactionMap.ModeProperty_SnapShot;

	form.btnProperties.enabled := true;
	form.menuSItemProperties.visible := true;
	form.menuSItemProperties.userObject := self.mySnapShotBroker;
	//form.mnuSItemUpdate.visible := true; //05 Feb 2019	NDL	TFS 43153 - Only need one update. I.e. (menuSItemProperties)
	
	form.menuSItemDelete.visible := true;
	form.btnDelete.enabled := true;

end;
</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrent" id="86f5ca1f-18a8-4a3d-aeae-bb75c18ce402">
        <updating/>
        <source>setMyCurrent(form: INV_TransactionMap io) updating;

vars

begin
	inheritMethod(form);
	
	form.myCurrentMapTMSS := self.mySnapShotBroker.myTransactionMap;
	form.myCurrentMapServiceBroker := self.mySnapShotBroker;

end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
