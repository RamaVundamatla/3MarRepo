    <JadeMethod name="doAllowAllPermissions" id="567585bc-2567-4d9a-b33f-16a48b652f82">
        <updating/>
        <source>doAllowAllPermissions(allow : Boolean) protected, updating;
// ---------------------------------------------------------------------------
// Created:     27 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	permObj 	: CM_PermissionObject;
	r, 
	saveRow, 
	saveCol 	: Integer;
	
begin
	mousePointer := Window.MousePointer_HourGlass;
	
	saveRow := tblPermissions.row;
	saveCol := tblPermissions.column;

	if tblPermissions.rows &lt; 2 then
		return;
	endif;

	tblPermissions.column := 1;

	foreach r in 2 to tblPermissions.rows do
		tblPermissions.row := r;
		permObj := tblPermissions.itemObject.CM_PermissionObject;
		if permObj.isInternal and (not self.isInternalOnly) then
			permObj.permValue := false;
			tblPermissions.text := null;
		else
			permObj.permValue := allow;
			if allow then
				tblPermissions.text := "1";
			else
				tblPermissions.text := "0";
			endif;
		endif;
	endforeach;

epilog
	tblPermissions.row := saveRow;
	tblPermissions.column := saveCol;
	if tblPermUsers.rows &gt;= saveRow then // dh 9/11/2007 par 14781
		tblPermUsers.row	:= saveRow;
	endif;								// dh 9/11/2007 par 14781
	tblPermUsers.column:= saveCol;
	mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="allow" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doChangeMode" id="eacb2075-7cb3-40f5-a9c5-bfaa073a9d3b">
        <updating/>
        <source>doChangeMode(_mode : String) updating;
// ---------------------------------------------------------------------------
// Created:     19 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21/03/2018	jlgdap1		TFS 37445 PEL1 Voyage Status Security
// 23/09/2022   navds20     ChangeRequest 54253: EUP - VAS Work Orders
// ---------------------------------------------------------------------------
vars
	categories	: StringArray;
	
begin

	self.viewMode := _mode;
	
	if self.viewMode = ViewSystem then
		self.shtStopsMaint.visible 	:= false;
		self.shtStopsCancel.visible := false;		// cnwdad1 03/06/2010 - CCMS 1129.
		self.shtStopsView.visible 	:= false;
		self.shtToDoTasks.visible 	:= false;
		self.shtReports.visible		:= false;
		self.shtTransactions.visible:= false;		
		self.shtStatus.visible 		:= false;			// TFS 37445
		self.shtInvoiceStatus.visible := false; // TFS 39618	
		self.shtworkOrderStatus.visible := false; //23/09/2022 navds20 TFS 54253
		self.shtVolDiscReasons.visible := false;		// 29/4/19 MAP TFS41707
		self.shtEventTypes.visible	:= false;	//09 Mar 2020	NDL	TFS 48784
		categories := self.myPermissionAgent.allSystemCategories;
	else
		self.shtStopsMaint.visible 	:= true;
		self.shtStopsCancel.visible := true;		// cnwdad1 03/06/2010 - CCMS 1129.
		self.shtStopsView.visible 	:= true;
		self.shtToDoTasks.visible 	:= true;	
		self.shtReports.visible		:= true;
		self.shtTransactions.visible:= true;		
		self.shtStatus.visible 		:= true;			// TFS 37445
		self.shtInvoiceStatus.visible := true; // TFS 39618		
		self.shtworkOrderStatus.visible := true; //23/09/2022 navds20 TFS 54253	
		self.shtVolDiscReasons.visible := true;			// 29/4/19 MAP TFS41707
		self.shtEventTypes.visible	:= true;	//09 Mar 2020	NDL	TFS 48784
		categories := self.myPermissionAgent.allTerminalCategories;
	endif;
	
	self.zLstDataShow();

	self.fldPermissions.topSheet := self.shtRoleDefn;
	self.doPermissionsSheetChange(self.shtRoleDefn);
	
end;</source>
        <Parameter name="_mode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="f1c96ec8-36fc-455e-ba75-268932e26c41">
        <updating/>
        <source>doDelete(): Boolean updating;

//	implemented in response to POT142, Xpose 1181 24&amp;25/7/01 RDD

vars
	result	: Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin
	// remove role: removing a role that has users removes the role correctly from users
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteSecurityRole(self.myCurrentObject.CM_SecurityRole, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Security role delete', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;

	self.lstData.removeItem(self.lstData.listIndex);  //par 19318
	self.showLstData();  //par 19318
	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPermissionsSheetChange" id="8e89c733-d4c9-46fb-bcdb-eea6f02117f9">
        <updating/>
        <source>doPermissionsSheetChange(sheet : Sheet input) protected, updating;
// ---------------------------------------------------------------------------
// Created:     29 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21/03/2018	jlgdap1		TFS 37445 PEL1 Voyage Status Security
// 23/09/2022   navds20     ChangeRequest 54253: EUP - VAS Work Orders
// ---------------------------------------------------------------------------
vars
	proxyUserWindow	: CM_UserWindowForOpen;

begin
	if sheet = null
	or sheet = shtRoleDefn
	or sheet = shtToDoTasks
	or sheet = shtReports
	or sheet = shtStopsView
	or sheet = shtTransactions
	or sheet = shtStopsMaint
	or sheet = shtStopsCancel		// cnwdad1 03/06/2010 - CCMS 1129.
	or sheet = self.shtMaintRoles // 13 Feb 2018	NDL	TFS 36947
	or sheet = self.shtStatus			// TFS 37445
	or sheet = self.shtInvoiceStatus // TFS 39618
	or sheet = self.shtworkOrderStatus  //23/09/2022 navds20 TFS 54253
	or sheet = self.shtVolDiscReasons	// 29/4/19 MAP TFS41707
	or sheet = self.shtEventTypes	//09 Mar 2020	NDL	TFS 48784
	then
		tblPermissions.visible 	:= false;
		tblPermUsers.visible 	:= false;
		btnSelectAll.enabled 	:= false;
		btnSelectAll.visible 	:= false;
		btnUnselectAll.enabled 	:= false;
		btnUnselectAll.visible 	:= false;
		sheet.cnEcResizeContents();
		return;
	endif;

	if sheet = shtUsers then
		self.loadDataTableForUsers(self.tblPermUsers);
	else
		self.fillTableForCategory(sheet.caption);
	endif;

	if app.myCurrentUserCan(self.myTerminal, PmAdmSecurityRoleMaint) = false then
		self.tblPermissions.parent	:= sheet;
		self.tblPermUsers.parent	:= sheet;
		if sheet = shtUsers then
			tblPermissions.visible	:= false;
			tblPermUsers.visible	:= true;
		else
			tblPermissions.visible	:= true;
			tblPermUsers.visible	:= false;
		endif;
		btnSelectAll.parent := sheet;
		btnSelectAll.enabled := false;
		btnSelectAll.visible := true;
		btnUnselectAll.parent := sheet;
		btnUnselectAll.enabled := false;
		btnUnselectAll.visible := true;
	else
		self.tblPermissions.parent	:= sheet;
		self.tblPermUsers.parent	:= sheet;
		if sheet = shtUsers then
			tblPermissions.visible	:= false;
			tblPermUsers.visible	:= true;
		else
			tblPermissions.visible	:= true;
			tblPermUsers.visible	:= false;
		endif;
		btnSelectAll.parent := sheet;
		btnSelectAll.visible := true;
		btnUnselectAll.parent := sheet;
		btnUnselectAll.visible := true;
		
		if self.mode = Mode_Add or self.mode = Mode_Update then
			btnSelectAll.enabled := true;
			btnUnselectAll.enabled := true;
		else
			btnSelectAll.enabled := false;
			btnUnselectAll.enabled := false;
		endif;
	endif;
	
	if self.mode = self.Mode_Add or self.mode = self.Mode_Update then
		self.btnSelectAll.enabled := true;
		self.btnUnselectAll.enabled := true;
	endif;

	if sheet = shtUsers then
		btnSelectAll.enabled 	:= false;
		btnSelectAll.visible 	:= false;
		btnUnselectAll.enabled 	:= false;
		btnUnselectAll.visible 	:= false;
	endif;
	
	sheet.cnEcResizeContents();
end;</source>
        <access>protected</access>
        <Parameter name="sheet" type="Sheet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doPicClick" id="6d8e6a9c-6096-43c8-8e0a-2e0184a764fd">
        <updating/>
        <source>doPicClick(_index: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     20 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theObject	: Object;

begin
	inheritMethod(_index);

	lstData.itemExpanded[_index] := (not self.lstData.itemExpanded[_index]);
	lstData.listIndex := _index;

	if _index &lt;&gt; -1 then
		theObject := lstData.itemObject[_index];
	endif;

	if theObject &lt;&gt; null then
		self.zShowThumbnailData(theObject);
	else
		self.zClearThumbnailData();
	endif;

end;</source>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doResetRoot" id="915e1e4d-7603-4c4a-b67c-83538178ce4b">
        <updating/>
        <source>doResetRoot() updating;
// ---------------------------------------------------------------------------
// Created:     24 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	if self.mode &lt;&gt; Mode_View then
		app.msgBox('You can not reset unless you are in view mode', 'Error', MsgBox_OK_Only);
		return;
	endif;
	if app.msgBox('Are you sure that you want to reset root?' &amp; Cr &amp; 'It can be a lengthy process.', 'Warning', MsgBox_Yes_No+MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	app.mousePointer := MousePointer_HourGlass;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxResetRootSecurityRoles(app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Reset Root Security Roles', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

	self.zLstDataShow();
	self.zLstDataSelectObject(null);

epilog
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="3c342421-bb87-4f04-b9bd-fee129dc8348">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     29 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 22/03/2018	jlgdap1		TFS 37445 PEL1 Voyage Status Security
// 02/11/2022 	navds20 	ChangeRequest 54253: EUP - VAS Work Orders
vars
	pxyRole,
	realRole,
	tmpParent 		: CM_SecurityRole;
	rtnValue		: Boolean;
	errObj			: CM_Error;
	expectedEdition	: Integer;
	tmpName			: String;
	availToShip		: Boolean;
	permissions 	: BooleanArray;
	toDoTasksAdd,
	toDoTasksComplete	: CM_ToDoTaskDescArray;
	stopTablesView 		: CM_StopsTableByIdDict;
	stopTablesMaint 	: CM_StopsTableByIdDict;
	stopTablesDelete 	: CM_StopsTableByIdDict;		// cnwdad1 CCMS 1129.
	result			: Integer;
	rptDict			: CM_QryReportDict;
	tranTypeDict	: CM_TransactionTypeByType;
	maintRoles		: CM_SecurityRoleSet;	//13 Feb 2018	NDL	TFS 36947
	maintRole		: CM_SecurityRole;	//13 Feb 2018	NDL	TFS 36947
	rowIndex 		: Integer;	//13 Feb 2018	NDL	TFS 36947
	statuses		: CM_VoyageStatusById;			// TFS 37445
	invoiceStatuses : CM_InvoiceStatusById; //TFS 39618	
	volDescReasons	: CM_VolumeDiscrepReasonsByCode;
	eventTypes	: CM_EventTypeByTypeDict;	//09 Mar 2020	NDL	TFS 48784
	statusAgent : CMIF_WOStatusAgent;	//02/11/2022 navds20 TFS 54253
begin
	if self.mode = Mode_Add then
		if self.viewMode = ViewSystem then
			create self.myProxyObject as CM_SecurityRoleSystem transient;
		else
			create self.myProxyObject as CM_SecurityRoleTerminal transient;
		endif;
	else
		self.myProxyObject.CM_SecurityRole.pxyGetRealObjectAndEdition(realRole, expectedEdition);
	endif;
	
	pxyRole := self.myProxyObject.CM_SecurityRole;
	
	tmpName := tblInput.getValueByName(ETRow_Name).String;
	
	if self.isTopLevel then
		tmpParent := self.myParentRole;
	else
		tmpParent := cmbParentRole.listObject.CM_SecurityRole;
	endif;

	availToShip := tblInput.getValueByName('availableToShippingCompany').Boolean;

	create permissions transient;
	self.myPermissionAgent.getPermissionValues(permissions, (self.viewMode = ViewSystem), self.isInternalOnly);
	self.amendPermissions(permissions); // CCMS 1350

	create toDoTasksAdd transient;
	self.mulToDoTasksAdd.getSelected(toDoTasksAdd);

	create toDoTasksComplete transient;
	self.mulToDoTasksComp.getSelected(toDoTasksComplete);

	create stopTablesView transient;
	self.mulStopsView.getSelected(stopTablesView);

	create stopTablesMaint transient;
	self.mulStopsMaint.getSelected(stopTablesMaint);
	
// cnwdad1 03/06/2010 - CCMS 1129.
	create stopTablesDelete transient;
	self.mulStopsDelete.getSelected(stopTablesDelete);
	
	create rptDict transient;
	self.mulReports.getSelected(rptDict);

	create tranTypeDict transient;
	self.mulTransType.getSelected(tranTypeDict);	
	
	create statusAgent transient;	//02/11/2022 navds20 TFS 54253
	self.mulWorkOrderStatus.getSelected(statusAgent.allWoStatusItems);	//02/11/2022 navds20 TFS 54253
	
	//13 Feb 2018	NDL	TFS 36947
	create maintRoles transient;
	if self.tblMaintRoles.rows &gt; 0 then
		foreach rowIndex in 1 to self.tblMaintRoles.rows do
			if self.tblMaintRoles.getCellText( rowIndex, self.SelectColumn ) = 1.String then
				//its selected
				maintRole := self.tblMaintRoles.accessRow(rowIndex).itemObject.CM_SecurityRole;
				if maintRole &lt;&gt; null then
					maintRoles.add( maintRole );
				endif;
			endif;
		endforeach;
	endif;
	
	create statuses transient;						// TFS 37445
	self.mulStatusMaint.getSelected(statuses);		// TFS 37445

	create invoiceStatuses transient; // TFS 39618
	self.mulInvoiceStatus.getSelected(invoiceStatuses); // TFS 39618

	create volDescReasons transient;		// 2/5/19 MAP TFS41707
	self.mulVolDescReasons.getSelected(volDescReasons);
	
	//09 Mar 2020	NDl	TFS 48784
	create eventTypes transient;
	self.mulEventTypes.getSelected(eventTypes);

	pxyRole.setProxy(	tmpName,
						tmpParent,
						permissions,
						availToShip,
						app.myRoot,
						toDoTasksAdd,
						toDoTasksComplete,
						stopTablesView,
						stopTablesMaint,
						stopTablesDelete,
						rptDict,
						tranTypeDict,
						statuses,				// TFS 37445 // TFS 39618
						invoiceStatuses, // TFS 39618
						volDescReasons,
						eventTypes,//09 Mar 2020	NDL	TFS 48784
						statusAgent	//02/11/2022 navds20 TFS 54253
						);
						
	pxyRole.setChildMaintRoles( maintRoles );	//13 Feb 2018	NDL	TFS 36947
	
	while true do
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateSecurityRole(pxyRole, self.myPermissionAgent, self.myCurrentObject, app.myPassport);
		elseif self.mode = Mode_Update then
			app.myTrxUA.trxUpdateSecurityRole(pxyRole, self.myPermissionAgent, app.myPassport);
		endif;

		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		endif;

		result := app.showErrorWarningDialog('Security Role Form', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
		if app.myPassport.noErrors and
		   result = IDOK then
			// there must have just been warnings that the user has acknoledged so ..
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		return false;
	endwhile;
	
	return true;
epilog
	delete permissions;
	delete toDoTasksAdd;
	delete toDoTasksComplete;
	delete stopTablesView;
	delete stopTablesMaint;
	delete stopTablesDelete;
	delete rptDict;
	delete tranTypeDict;
	delete statuses;					// TFS 37445
	delete invoiceStatuses; // TFS 39618	
	delete volDescReasons;
	delete eventTypes;	//09 Mar 2020	NDL	TFS 48784
	statusAgent.allWoStatusItems.purge();	//02/11/2022 navds20 TFS 54253
	delete statusAgent;	//02/11/2022 navds20 TFS 54253
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowFilter" id="33369d21-6e83-456f-a670-0fb841811d07">
        <updating/>
        <source>doShowFilter( _mode : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2018	jlger1	Initial creation tfs 36402

*/

vars

	form : SOP_PermissionFilter;
	result : Integer;
	sht : Integer;
	sheet : Sheet;
	tmpCntrl : Control;
begin
	create form transient;
	form.setMyPermissionAgent(self.myPermissionAgent);
	form.setMode( _mode );
	result:=form.showModal();
	if result = IDOK then
		
		if form.cmbHandHeldApp.text &lt;&gt; null then
			self.filterKeyword :=form.cmbHandHeldApp.text;
			self.filterContext :=CM_PermissionAgent.FilterHandHeld;
		elseif form.cmbMobileApp.text &lt;&gt; null then
			self.filterKeyword := form.cmbMobileApp.text;
			self.filterContext :=CM_PermissionAgent.FilterMobileApps;
		elseif form.cmbWebservices.text &lt;&gt; null then
			self.filterKeyword := form.cmbWebservices.text;
			self.filterContext :=CM_PermissionAgent.FilterWebservices;
		elseif form.txtSearchText.text.trimBlanks &lt;&gt; null then	//05 Feb 2021	NDL - TFS 50757
			self.filterKeyword := form.txtSearchText.text.trimBlanks;
			self.filterContext :=CM_PermissionAgent.FilterText;
		else
			self.setIsFiltering(false);
			return;
		endif;
		self.setIsFiltering(true);	
	else
		self.setIsFiltering(false);
	endif;
epilog

end;</source>
        <Parameter name="_mode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doUserEdit" id="92a3023c-26f8-433d-b693-9accdcff61b8">
        <source>doUserEdit( _table: Table input );
// created by cnwvu1 on 26/01/2007
vars
	tbl			: CM_DataTable;
	theUser		: CM_User;
	selected	: Boolean;
	menuAction	: CMUI_MenuAction;
	viewForm	: SOP_TableMaintForm;
	
begin

	tbl:= self.tblPermUsers;
	
	if tbl.row &gt; 0 then
		theUser:= tbl.accessRow(tbl.row).itemObject.CM_User;
		selected := tbl.accessCell(tbl.row, 1).selected;
	endif;

	if theUser = null or not selected then
		return;
	endif;
	
	self.myAssistant.showTableMaintForm(tbl.accessRow(tbl.row).itemObject.CM_Object, self.myMasterMenuAction, true, false);

end;
</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="fillTableForCategory" id="daac91d3-d819-44b2-964a-d01ca1eedb8e">
        <source>fillTableForCategory(categoryName : String) protected;
// ---------------------------------------------------------------------------
// Created:     27 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19/11/2009	cnwdad1		PAR #21640. Hide Sub-Terminals if no St license.
// 28/02/2024	navdap1		TFS 62642 Add user permission for mobile app - todo
// ---------------------------------------------------------------------------
vars
	permObj			: CM_PermissionObject;
	iter 			: Iterator;
	str				: String;
	isSpecialApp	: Boolean;
	tmpNewRow		: Integer;
	isSubTermLic	: Boolean;		// cnwdad1 19/11/2009 - PAR #21640.
begin
	if app.isSpecial() then
		isSpecialApp := true;
		tblPermissions.columns := 4;
		tblPermissions.accessCell(1,4).text := 'Constant Name';
		tblPermissions.columns := 5;
		tblPermissions.accessCell(1,5).text := 'Modules';
	else
		tblPermissions.columns := 3;
	endif;
	
	isSubTermLic			:=	app.isSubTerminalsLicensed;			// cnwdad1 19/11/2009 - PAR #21640.
	tblPermissions.rows 	:= 1;
	tblPermissions.row 		:= 1;
	tblPermissions.column 	:= 1;
	tblPermissions.accessColumn(1).alignment := Table.Alignment_Center_Middle;
	tblPermissions.accessColumn(1).inputType := Table.InputType_CheckBox;
	tblPermissions.text 	:= "Allowed" &amp; Tab &amp; "Permission" &amp; Tab &amp; 'Explanation';
	tblPermissions.columnWidth[1] := 48;	

	//epr TFS 36402 1/2/18
	if self.isFiltering then		
		iter := self.allFilteredPermissions.createIterator;	
		self.allFilteredPermissions.startKeyGeq(categoryName, null, null, iter);
	else
	
		iter := self.myPermissionAgent.allPermsByCategoryDescrName.createIterator();
		self.myPermissionAgent.allPermsByCategoryDescrName.startKeyGeq(categoryName, null, null, iter);
	endif;
	
	while iter.next(permObj) do		
		if permObj.category &lt;&gt; categoryName then
			break;
		endif;
		
		if self.myParentRole &lt;&gt; null then
			if (not self.myParentRole.canDo(permObj.constValue)) then			
				// only display the permissions that the parent has access to
				app.writeLog(self.myParentRole.name &amp; " cannot do " &amp; permObj.constValue.String, LogINFO);
				if self.isFiltering then
					if not self.allInvalidFilterPermission.includes(permObj.description &amp; " is not allowed on the parent role") then					
						self.allInvalidFilterPermission.add(permObj.description &amp; " is not allowed on the parent role");
					endif;
				endif;	
				continue;		
			endif;
		endif;
		if self.isTopLevel then
			if (not permObj.permValue) then
				app.writeLog(permObj.constValue.String &amp; " top level and permValue = " &amp; permObj.permValue.String &amp; " cannot set", LogINFO);
				continue;
			endif;
		endif;
		
		//25 Jan 2019	NDL	TFS 39618 - hide for now, replaced by Invoice statuses.
		if permObj.constValue = PmAdmInvoiceStatusDisputed
		or permObj.constValue = PmAdmInvListStatusClose
		or permObj.constValue = PmAdmInvoiceStatusPost
		or permObj.constValue = PmAdmInvoiceStatusPrepend
		or permObj.constValue = PmAdmInvListStatusReturn
		or permObj.constValue = PmAdmInvoiceStatusVoid
		then
			continue;
		endif;
		
// cnwdad1 19/11/2009 - PAR #21640.
		if (not isSubTermLic) then
			if permObj.constValue = PmAdmSubTerminalMaint
			or permObj.constValue = PmAdmSubTerminalView
			or permObj.constValue = PmCmpDASubTerminalTableMaint
			or permObj.constValue = PmCmpDASubTerminalTableView
			then
				continue;
			endif;
		endif;
		
		//09 May 2013	- Spoke to Doug, hide at teh momemt
		// until they are removed - DCT Gdansk only, except currently used in JBL run...
		if permObj.constValue = PmAdmHHGate1
		or permObj.constValue = PmAdmHHShip1
		then
			
			continue;
		endif;
				
		// TFS 62642 hide the Todo App permission no VAS Work Order subscription
		if permObj.constValue = PmHHTodoApp and not app.getMyUser.canDo(null, Sub_VASWorkOrder) then
			continue;
		endif;
		
		if permObj.isInternal then
			// RBarr 1/9/2006 Localisation changes - translate the permisisons description
			//str := permObj.description &amp; " (Port only)" &amp; Tab &amp;
			str := permObj.getTranslatedDescription() &amp; " (Port only)" &amp; Tab &amp;
					permObj.explanation;
			if (not self.isInternalOnly) then
				permObj.permValue := false; // make sure permission is off
			endif;
		else
//			str := permObj.description &amp; Tab &amp;
			str := permObj.getTranslatedDescription() &amp; Tab &amp;
				   permObj.explanation;
		endif;
		
		if isSpecialApp then
			str := str &amp; Tab &amp; permObj.constName &amp; Tab &amp; permObj.getModulesList();
		endif;
		
		tmpNewRow := tblPermissions.addItem(Tab &amp; str);
		tblPermissions.accessCell(tmpNewRow, 1).inputType := Table.InputType_CheckBox;
		tblPermissions.accessedCell.itemObject := permObj;
		tblPermissions.accessedCell.text := permObj.permValue.Integer.String;
		
	endwhile;
	
	if isFiltering and tblPermissions.rows = 1 then
		
		self.fldPermissions.topSheet.visible:=false;
	endif;
	
epilog
	
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="categoryName" type="String"/>
    </JadeMethod>
