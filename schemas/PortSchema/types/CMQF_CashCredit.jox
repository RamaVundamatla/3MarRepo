    <JadeMethod name="cloneReferences" id="32035d86-0324-4e3b-805d-705bf2776967">
        <updating/>
        <source>cloneReferences(_obj: CMQF_CashCredit; _transient: Boolean) updating;
// from TFS 985
vars

begin
	inheritMethod(_obj, _transient);
	
	self.allDebtors.clear();
	_obj.allDebtors.copy(self.allDebtors);
	
	self.setMyVoyage( _obj.getMyVoyage );
	
end;
</source>
        <Parameter name="_obj" type="CMQF_CashCredit"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterDebtorTerminal" id="5333fab6-233b-489f-8a6a-c4795496a672">
        <updating/>
        <source>filterDebtorTerminal(_drTerm : CM_DebtorTerminal; _collection : Collection input; _passport : CM_Passport; _breakOut : Boolean output) updating, protected;
//	TFS 985 cash credit reporting
vars

	doFromDateCheck	: Boolean;
	doToDateCheck	: Boolean;
	breakOut		: Boolean;
	
	iter : Iterator;
	
	cash : CM_Cash;
	credit : CM_CashCredit;

begin

	if _drTerm = null then
		return;
	endif;
	
	doFromDateCheck := self.startDate.isValid;
	doToDateCheck := self.endDate.isValid;
	
	iter := _drTerm.allCashCredits.createIterator;
	while iter.next( credit ) do
		if doFromDateCheck and credit.dateTime.Date &lt; self.startDate then
			continue;
		elseif doToDateCheck and credit.dateTime.Date &gt; self.endDate then
			break;
		else
			if self.checkStatusIncludesObject(credit, _passport, breakOut) then
				if not _collection.includes(credit) then
					_collection.add(credit);
				endif;
			endif;
			if breakOut then
				break;
			endif;
		endif;
	endwhile;
	delete iter;
	
	_breakOut := breakOut;
	
epilog

	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_drTerm" type="CM_DebtorTerminal"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="a6097582-c347-473f-9451-645a5c8df985">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
// Feb 2016 TFS 985 cash credit reporting
vars

	iter : Iterator;
	drTerm : CM_DebtorTerminal;
	breakOut : Boolean;
	debtor : CM_Debtor;
	term : CM_Terminal;

begin
	// financial selector reports
	if (not self.allQueryCriteriaHolders.isEmpty) then
		self.filterSelectorQuery(_collection, _passport);
		return;
	endif;
	
	if self.allTerminals.isEmpty and self.allDebtors.isEmpty then
		// no selection, the user wants them all 
		iter := CM_DebtorTerminal.instances.createIterator;
		while iter.next( drTerm ) do
			self.filterDebtorTerminal(drTerm, _collection, _passport, breakOut);
			if breakOut then
				break;
			endif;
		endwhile;
	
	elseif self.allTerminals.isEmpty then
		// debtor selection only, the user wants all terminals for these debtors 
		foreach debtor in self.allDebtors discreteLock do
			iter := debtor.allDebtorTerminals.createIterator;
			while iter.next( drTerm ) do
				self.filterDebtorTerminal(drTerm, _collection, _passport, breakOut);
				if breakOut then
					break;
				endif;
			endwhile;
			delete iter;
		endforeach;
	
	elseif self.allDebtors.isEmpty then
		// terminal selection only, the user wants all debtors for these terminals 
		foreach term in self.allTerminals discreteLock do
			iter := term.allDebtorTerminals.createIterator;
			while iter.next( drTerm ) do
				self.filterDebtorTerminal(drTerm, _collection, _passport, breakOut);
				if breakOut then
					break;
				endif;
			endwhile;
			delete iter;
		endforeach;
	
	else
		// debtor and terminal selection, the user only wants specific debtor / terminal combinations.
		foreach debtor in self.allDebtors discreteLock do
			iter := debtor.allDebtorTerminals.createIterator;
			while iter.next( drTerm ) do
				if not self.allTerminals.includes( drTerm.myTerminal ) then
					continue;
				endif;
				self.filterDebtorTerminal(drTerm, _collection, _passport, breakOut);
				if breakOut then
					break;
				endif;
			endwhile;
			delete iter;
		endforeach;
		
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterSelectorQuery" id="81d85d56-3ba8-4a1d-878e-c7d1850f0809">
        <source>filterSelectorQuery(_collection  : Collection input;
					_passport : CM_Passport) protected;
//	TFS 985 cash credit reporting
vars
	criteriaHolder 		: CM_QueryCriteriaLineHolder;
	qDef				: CM_QueryDefinition;
	enqController		: CM_EnquiryController;
	queryAgent			: CM_QueryAgentFilter;

begin

	// Special one because we need the copy
	on CM_BreakOutException do app.myQAFilter.xHandlerBreakOut(exception);
	
	queryAgent := app.myQAFilter;
	if queryAgent = null then
		return;
	endif;
	
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.Cash_Query_Type, self.selectorMode];
	queryAgent.createEnqControllerForMode(self.selectorMode, CM_QueryDefinition.Cash_Query_Type, enqController);
	delete enqController.allObjects;
	create enqController.allObjects as _collection.class transient;
	
	foreach criteriaHolder in self.allQueryCriteriaHolders discreteLock do
		enqController.myCriteriaLineHolder := criteriaHolder;
		enqController.doQuery(qDef);
	endforeach;

	enqController.allObjects.copy(_collection);
	
epilog
	if enqController &lt;&gt; null then
		delete enqController.allObjects;
	endif;
	delete enqController;
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyage" id="d9ca0294-449a-4e78-9ec1-f573382b813d">
        <source>getMyVoyage():CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	voyage : CM_Voyage;
	edition : Integer;
	invalidObj : Boolean;

begin

	voyage := self.myVoyage;

	if voyage = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, voyage, invalidObj );
	edition := voyage.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return voyage;

epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="a0e5543d-6720-4d8b-b7db-6da84755aba1">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid: String output): String;
//	TFS 985 cash credit reporting
vars

	runDate		: Date;

begin
	runDate := app.actualTimeServer().Date;	// 28/4/16 cnwmp6 TFS 488 - Multi timezone support
	
	if _attrName = ETRow_FromDate then
	   	if _getCalculatedDate then
			return self.setDateFromTemplate(self.startDateTplType, self.startDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.startDateTplType, self.startDateTplFactor);
		endif;
		
	elseif _attrName = ETRow_ToDate then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.endDateTplType, self.endDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.endDateTplType, self.endDateTplFactor);
		endif;
		
	elseif _attrName = ETRow_BillOfLading then
		return self.billOfLading;
	elseif _attrName = ETRow_CargoId then
		return self.cargoId;
	elseif _attrName = ETRow_Number then
		return self.cashReceiptNumber;
	elseif _attrName = ETRow_CustomsEntryNumber then
		return self.customsEntryNumber;
	elseif _attrName = ETRow_Voyage then
		if self.getMyVoyage &lt;&gt; null then
			_oid := self.getMyVoyage.getOidAsString(); 
			return self.getMyVoyage.code;
		endif;
		
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="84f5ca41-4ab6-4b9c-992f-1f89a46fde82">
        <updating/>
        <source>includesObject(_cashCredit: CM_Cash; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//	TFS 985 cash credit reporting
vars
	voyageCode	: String;
	querySelf : CMQF_CashCredit;	

begin

	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;
	
	if self.getMyVoyage &lt;&gt; null then
		voyageCode := self.getMyVoyage.code;
	endif;
	// data attribute filtering
	if _cashCredit.matches(voyageCode, self.billOfLading, self.customsEntryNumber, self.cashReceiptNumber, self.cargoId) then
		querySelf.numFound := querySelf.numFound + 1;
		return true;
	endif;

	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cashCredit" type="CM_Cash"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromTemplate" id="de652c0f-05d9-4a7c-bfa6-5300d095b58d">
        <updating/>
        <source>setFromTemplate(_obj: CMQF_FilterReports; _runDate: Date; _allEventData: CM_EventDataByTypeDict) updating;
// copy of method in CMQF_CashReceipt
//	TFS 985 cash credit reporting
vars
	eventData : CM_EventDataVoyage;

begin
	inheritMethod(_obj, _runDate, _allEventData);
	
	// This code sets the voyage for event driven schedules.
	// Have to do this for each appropriate class because they have different myVoyage references.
	eventData := _allEventData[EventDataVoyage].CM_EventDataVoyage;
	if eventData &lt;&gt; null and eventData.myVoyage &lt;&gt; null then
		self.setMyVoyage( eventData.myVoyage );
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="CMQF_FilterReports"/>
        <Parameter name="_runDate" type="Date"/>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyage" id="8a91f6b0-429c-41b9-835c-94203ab4f29e">
        <updating/>
        <source>setMyVoyage( _voyage : CM_Voyage ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

begin

	self.myVoyage := _voyage;

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
</Class>
