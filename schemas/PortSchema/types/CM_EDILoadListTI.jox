    </JadeMethod>
    <JadeMethod name="isWaterCooled" id="715e3c53-a025-49a3-9b26-cec0f6527c8c">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>isWaterCooled(set: Boolean; _value: Boolean io) updating, mapping;
//----------------------------------------------------------------
//	Created:	10 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	
begin
	if set then
		//ccms 1501 cnwrs1 Nov 2006 a special patch to get MSK auto loadlist working
		// we dont have the temperature at this stage so must set it regardless
		if _value = true then
			self.cooledType := ContainerWaterCooled;
		endif;
		return;
	else
		_value := (self.cooledType = ContainerWaterCooled);	
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadPort" id="43adba18-927b-4af7-987f-776453c57f3e">
        <methodInvocation>mapping</methodInvocation>
        <source>loadPort(set: Boolean; _value: String io) mapping;
// cnwrs1 June 2006 protected the old 3 digit codes
vars
	port : CM_Port;
begin
	if not set then
		if self.loadPort.length = 3 then
			port := app.myRoot.allLocodesByShortCode.getAtKeyGeq(self.loadPort, null);
			if port &lt;&gt; null and port.portCode = self.loadPort then
				_value := port.code;
			else
				_value := self.loadPort;
			endif;
		else
			_value := self.loadPort;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
