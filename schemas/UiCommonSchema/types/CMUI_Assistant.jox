    <JadeMethod name="comboBoxEmailGroups" id="f476fc99-e30f-4ccf-b6fa-724551f66cc4">
        <source>comboBoxEmailGroups(_combo : CMUI_ComboBox input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2022	jlier1	Initial creation 53286

*/

vars
	iter 	: Iterator;
	entity	: CM_EmailEntity;

begin
	if _combo = null then
		return;
	endif;
	
	_combo.clear;
	
	iter := app.myRoot.allEmailEntities.createIterator();
	while iter.next(entity) do
		if entity.type = Email_Group then
			_combo.addItemObject(entity.name, entity);
		endif;
	endwhile;
	
epilog
	delete iter;
end;
</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxEventRequestStatus" id="8c839682-59fd-45a0-93aa-3534345ccb11">
        <source>comboBoxEventRequestStatus(pTbl : CM_EntryTable input; pAttrName : String);
//-----------------------------------------
// Created: 6 May 2005 By: cnwgd1
//-----------------------------------------
// 14/12/2010	cnwcs5	ccms mes 1112 / par 24464
vars
	row : Integer;
	str	: String;
begin
	
	row := pTbl.getRow(pAttrName);

	if (not pTbl.isValidRow(row)) then
		return;
	endif;
			
	str := EventRequestAnyStr &amp; Tab &amp; 
			EventRequestPendingStr &amp; Tab &amp; 
			EventRequestMatchedStr &amp; Tab &amp; 
			EventRequestActionedStr &amp; Tab &amp; 
			EventRequestEmailedStr &amp; Tab &amp;	// 14/12/2010	cnwcs5	ccms mes 1112 / par 24464
			EventRequestCargoDeletedStr;		// 14/12/2010	cnwcs5	ccms mes 1112 / par 24464

	pTbl.setComboValues(row, str);
	pTbl.setValue(row, EventRequestAnyStr);

end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxEventTypeAction" id="f729cd04-2072-4d21-90fa-33ea8a99e963">
        <source>comboBoxEventTypeAction(_cmb : CMUI_ComboBox input; _category : Integer; _value : Integer);
/*

Date		Who		Reason
04 Dec 2014	cnwer1	Initial creation PAR
02 Nov 2022 navma1  ChangeRequest 56636[54258]: EUP - Adding New Event Type for VAS TodoTask Description
*/

vars
	baseScm 	  : Schema;
	category 	  : ConstantCategory;
	const 		  : Constant;
	constDict	  : ConstantNDict;
	theClass,
	text,
	name		  : String;
	eventType 	  : Integer;
	eventCategory : Integer;
begin
	_cmb.clear;
	
	if _category = CM_EventType.WARNING_EVENT then
		return;
	endif;
	
	baseScm   := rootSchema.getSchema(PortSchemaName);
	category  := baseScm.getCategory('EventTypes');
	constDict := category.getConstants();
	
	foreach const in constDict do
		eventType:=const.getSource.Integer;
		if eventType &gt;= EVT_MAX_JMT then
			continue;
		endif;
		if app.myRoot.allEventTypesByType[eventType] &lt;&gt; null then
			continue;
		endif;
		text 		:= const.text;
		name 	  	:= text.cnEcGetTagValueOfName('Name');
		
		if name = null then
			continue;
		endif;
		if _category = null then
			_cmb.addItemWithData( name,eventType);
		else
			theClass	:= text.cnEcGetTagValueOfName('Class');
			if  theClass = CMEVT_TrainTransaction.name then
				eventCategory:=CM_EventType.TRAIN_EVENT;
			elseif theClass = CMEVT_TruckEvent.name then
				eventCategory:=CM_EventType.TRUCK_EVENT;
			elseif theClass = CMEVT_VoyageEvent.name then
				eventCategory:=CM_EventType.VOYAGE_EVENT;
			elseif theClass = CMEVT_WagonTransaction.name then
				eventCategory:=CM_EventType.WAGON_EVENT;
			elseif theClass = CMEVT_LocationActivity.name then			//14 Apr 2021	NDL	TFS 50906
				eventCategory:=CM_EventType.LOCATION_EVENT;
			elseif theClass = CMEVT_VehicleBookingEvent.name then		//31.10.2022 navma1 #56636[54258]
				eventCategory:=CM_EventType.VBS_EVENT;
			elseif theClass = CMEVT_NonOperationalEvent.name then		//31.10.2022 navma1 #56636[54258]
				eventCategory:=CM_EventType.NONOPS_EVENT;
			else
				eventCategory:=CM_EventType.SYSTEM_EVENT;
			endif;
			
			if _category = eventCategory then
				_cmb.addItemWithData( name,eventType);
			endif;
		endif;	
	endforeach;
epilog

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_category" type="Integer"/>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxEventTypeCategory" id="7f1b5a4b-1005-474f-bcb1-8e7f5e5ec1db">
        <source>comboBoxEventTypeCategory(_cmb : CMUI_ComboBox input; _value : Integer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 Oct 2009	cnwndl1	Initial creation	Par 21519
04 Dec 2014 cnwer1  CCMS 1405 can now create system events not all created automatically
31 Oct 2022 navma1  ChangeRequest 56636[54258]: EUP - Adding New Event Type for VAS TodoTask Description
*/

vars
	index : Integer;
begin
	_cmb.clear;
		
	index:= _cmb.addItem( app.getErrorString(Warning_error_event) );	//CM_EventType.WARNING_EVENT = 2
	_cmb.itemData[index] := CM_EventType.WARNING_EVENT;
	
	index := _cmb.addItem( app.getErrorString(Train_event) );			//CM_EventType.TRAIN_EVENT = 3
	_cmb.itemData[index] := CM_EventType.TRAIN_EVENT;
	
	index := _cmb.addItem( app.getErrorString(Voyage_event) );			//CM_EventType.VOYAGE_EVENT = 4
	_cmb.itemData[index] := CM_EventType.VOYAGE_EVENT;
	
	index := _cmb.addItem( app.getErrorString(Truck_event) );			//CM_EventType.TRUCK_EVENT = 6
	_cmb.itemData[index] := CM_EventType.TRUCK_EVENT;
	
	index := _cmb.addItem( app.getErrorString(Wagon_event) );			//CM_EventType.WAGON_EVENT = 5
	_cmb.itemData[index] := CM_EventType.WAGON_EVENT;
	
	index := _cmb.addItem( app.getErrorString(Vbs_event) );				//CM_EventType.VBS_EVENT = 8		//31.10.2022 navma1 #56636[54258]
	_cmb.itemData[index] := CM_EventType.VBS_EVENT;	
	
	index := _cmb.addItem( app.getErrorString(Nonops_event) );			//CM_EventType.NONOPS_EVENT = 9		//31.10.2022 navma1 #56636[54258]
	_cmb.itemData[index] := CM_EventType.NONOPS_EVENT;
	
	if _value &gt;= 1 then
		foreach index in 1 to	_cmb.listCount do
			if _value = _cmb.itemData[index] then
				_cmb.listIndex := index;
				break;
			endif;
		endforeach;
	else
		_cmb.listIndex := -1;
	endif;
	
epilog

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxEventTypeUser" id="a76ff73e-8e76-486f-b311-72b5ac515d4e">
        <source>comboBoxEventTypeUser(_cmb : CMUI_ComboBox input; _category : Integer; _terminal : CM_Terminal );
/*

Date		Who		Reason
10 December 2014	cnwer1	Initial creation PAR

*/

vars
	iter : Iterator;
	eventType : CM_EventType; 
begin

	_cmb.clear();	//02 Jun 2021	NDL		TFS 51245

	iter := app.myRoot.allEventTypesByCategory.createIterator;
	app.myRoot.allEventTypesByCategory.startKeyGeq(_category,null,iter);

	while iter.next(eventType) do
		if eventType.category &lt;&gt; _category then
			break;
		endif;
		
		if not eventType.canUserAdd( _terminal ) then	//09 Mar 2020	NDL	TFS 48784
			continue;
		endif;
		
		 _cmb.addItemObject(eventType.name,eventType);
	endwhile;
epilog
	delete iter;
end;	</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_category" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
