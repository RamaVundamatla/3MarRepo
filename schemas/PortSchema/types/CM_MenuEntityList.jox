vars

begin
	self.setupForm();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTable" id="f1786edb-56ea-44ef-a314-1f137bff3910">
        <source>populateTable();
/*
Purpose:			

Date		Who		Reason
18 October 2021	navab1	TFS 51853
*/

vars

	iter01 : Iterator;
	men : CM_MenuEntity;
	oArray : ObjectArray; 
	idx, count : Integer;
	xml : String;
	root : CM_Root;
	pic : Binary;
	
	linecolr : Integer;
	classs : Class;
begin
	root := CM_Root.firstInstance;
	
	app.mousePointer := Form.MousePointer_HourGlass;

	self.tblMain.rows := 1;
	
	create oArray transient;
	CM_MenuEntity.allInstances(oArray,0,true);
	iter01 := oArray.createIterator;
	idx := 1;
	linecolr := LightYellow;
	
	while iter01.next(men) do
		if men.isKindOf(CM_QryReportSystem) // NO ICON
		or  men.isKindOf(CM_QryReportUser) // NO ICON
//		or  men.isKindOf(CM_MenuRootForRoot) // Have Icons, but these are all 'SYSTEM ITEMS' 
//		or  men.isKindOf(CM_MenuRootForUser) // Have Icons, but these are all 'SYSTEM ITEMS' icon is either a light house or a PC
		or  men.isKindOf(CM_MenuRootQuery) // NO ICONS only 1 instance
		or  men.isKindOf(CM_MenuRootReportForRoot) // NO ICON
		or  men.isKindOf(CM_MenuRootReportUserTerminal) // NO ICON
		or  men.isKindOf(CM_MenuRootToolbar) // NO ICON
		or  men.isKindOf(CM_MenuRootUserBackgroundReps) // NO ICON
		or  men.isKindOf(CM_MenuRootUserTemplates) // NO ICON
		or  men.isKindOf(CM_MenuRootUserTerminal) // NO ICON
		or  men.isKindOf(CM_MenuUserToolbarRoot) // NO ICON
		or  men.isKindOf(CM_MenuUserReport) // NO ICON
//		or  men.isKindOf(CM_MenuUserDtl) // 30,000 plus, all with icons
//		or  men.isKindOf(CM_MenuUserHdr) // 20,000 plus, all with pictures, no icon
//		or  men.isKindOf(CM_MenuUserQuery) // all the same question mark icon , no pictures
		
		then
			continue;
		endif;
	
//		if men.getHeading() &lt;&gt; "EDI Data Translations" then
//		if men.getHeading() &lt;&gt; "Snapshot Summary" then
//		if men.getHeading() &lt;&gt; "Harbour" then
//		if men.getHeading() &lt;&gt; "Currency Type Maintenance" then
//		if men.getHeading() &lt;&gt; "Invoice Types" then
//		if men.getHeading() &lt;&gt; "Activity History" then
//		if men.getHeading() &lt;&gt; "Cash Consolidation" then
//		if men.getHeading() &lt;&gt; "Load Out Reconciliation" then
//		if men.getHeading() &lt;&gt; "Location Enquiry" then
//		if men.getHeading() &lt;&gt; "TBA List" then
//		if men.getHeading() &lt;&gt; "Location Inventory Enquiry" then
		if men.getHeading() &lt;&gt; "Text Translation" then
		
		
			continue;
		endif;
		
		// ICON
		pic := null;
		pic := root.getConfig(men.pictureStringIcon.trimBlanks()).Binary;
		if pic &lt;&gt; null then
//			continue;
		endif;
		
		
		if men.pictureStringButton = PicToolBarSpaceSmall then // seperator
			continue;
		endif;
	
	
	// ### the objects for these classes have images on them
		// CM_MenuDtlSystem - 225 items (master copy of all navigator items?)
		// CM_MenuHdrSystem - 50 items , no icon (master copy of all navigator headers?)
		// CM_MenuToolbar - 225 items
		// CM_MenuUserDtl - 30000 items (navigator items)
		// CM_MenuUserHdr - 20000 items (navigator headers)
		// CM_MenuUserToolbar - 9000 items (main toolbar)

		count := count + 1;

		if classs &lt;&gt; null 
		and classs &lt;&gt; men.class then
			count := 1;
			if linecolr = LightYellow then
				linecolr := LightBlue;
			else	
				linecolr:= LightYellow;
			endif;
		
		endif;
		
		classs := men.class;
		
		idx := self.tblMain.addItem(count.String &amp; Tab &amp; 
										men.String &amp; Tab &amp; 
										men.getHeading() &amp; Tab &amp; 
										men.pictureStringIcon &amp; Tab &amp; 
										men.pictureStringButton &amp; Tab &amp; 
										men.pictureStringButtonDown);
		self.tblMain.accessRow(idx).backColor := linecolr;
		
		if idx = 32000 then
			break;
		endif;
		
		
		// ICON
//		pic := root.getConfig(men.pictureStringIcon).Binary;
		pic := men.pictureIcon;
		
		self.tblMain.accessCell(idx,7).picture := pic;
		self.tblMain.accessedCell.alignment := Table.Alignment_Center_Top;
		self.tblMain.accessRow(idx).height := 33;
		
		
		// UP
//		pic := root.getConfig(men.pictureStringButton).Binary;
		pic := men.pictureButton;
		
		self.tblMain.accessCell(idx,8).picture := pic;
		self.tblMain.accessedCell.alignment := Table.Alignment_Center_Top;
		
		// DOWN
//		pic := root.getConfig(men.pictureStringButtonDown).Binary;
		pic := men.pictureButtonDown;
		
		self.tblMain.accessCell(idx,9).picture := pic;
		self.tblMain.accessedCell.alignment := Table.Alignment_Center_Top;
		
		
	endwhile;

epilog
	delete oArray;
	
	app.mousePointer := Form.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="5eca6fcf-aea7-48eb-985b-44934e1ab4f9">
        <source>setupForm();
/*
Purpose:			

Date		Who		Reason
18 October 2021	navab1	TFS 51853
*/

vars

begin
	self.initialiseTable();
	
	self.populateTable();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblMain_dblClick" id="4cebad69-4a70-4a25-bcc1-db3bf53691c8">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMain_dblClick(table: Table input) updating;
/*
Purpose:			

Date		Who		Reason
19 October 2021	navab1	TFS 51853
*/

vars

begin
	if table.row &gt; table.fixedRows then
		return;
	endif;
	
	table.sortColumn[1] := table.column;
	table.sortAsc[1] := not table.sortAsc[1] ;
	table.resort;
	

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
</GUIClass>
