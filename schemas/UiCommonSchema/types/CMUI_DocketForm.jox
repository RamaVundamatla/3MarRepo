    <JadeMethod name="setDefaults" id="888a5ea9-e725-4a0e-a907-8b52622fb45d">
        <updating/>
        <source>setDefaults() updating, protected;
//--------------------------------------------------------------
//Created: 22 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	theDocket		: CM_BOL;
	defCarrier		: CM_Carrier;
	defDestPort		: CM_Port;
	tmpConsignor	: CM_ConsigneeConsignor;
begin

	if self.mode = Mode_Add then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to add a docket release - this is not permitted');
		return;
	endif;
	theDocket := self.myProxyObject.CM_BOL;
	
	defCarrier := app.myRoot.allCarriers[theDocket.carrierCode];
	// DVB CCMS 1235
	self.cmbCarrier.setObject(defCarrier);
	if defCarrier &lt;&gt; null then
		tblMain.setValueByName(ETRow_CarrierCode, defCarrier.code);	
	endif;
	tmpConsignor := app.myRoot.allConsigneeConsignors[theDocket.consignor];
	
	// HJG changed 13/12/04 CCMS 1235
	self.myAssistant.comboBoxConsignor(self.cmbConsignor, tmpConsignor, CONSIGNOR);
	//self.cmbConsignor.setObject(tmpConsignor);
	tblMain.setValueByName(ETRow_Consignor, cmbConsignor.text);
	
	
	//defDestPort := app.myRoot.allPorts[theDocket.destinationPort];
	defDestPort := app.myRoot.allPorts[theDocket.destinationPort];

// 	lorcan 11/4/2006 Changed port combobox
//	self.myAssistant.comboBoxDestination(cmbDestination, defDestPort);	
	self.cmbDestination.myTerminal := self.myTerminal;// so text for port is displayed in correct order from config
	self.cmbDestination.myAssistant := self.myAssistant;
	self.cmbDestination.showAllDestinations := true;
	if defDestPort &lt;&gt; null then 
		self.cmbDestination.setObject(defDestPort);
	endif;

	tblMain.setValueByName(ETRow_DestinationPort, cmbDestination.text);
	tblMain.setValueByName(ETRow_DocketNumber, theDocket.number);
	tblMain.setValueByName(ETRow_RegNumber, theDocket.vehicle);
	tblMain.setValueByName(ETRow_TruckNumber, theDocket.truckNumber);
	tblMain.setValueByName(ETRow_TrailerNumber, theDocket.trailerNumber);
	tblMain.setValueByName(ETRow_WeightTotal, theDocket.weightTotal);	
	tblMain.setValueByName(ETRow_Remarks, theDocket.remarks);
	tblMain.setValueByName(ETRow_AddAttachment, '-- Dbl Click to Add/Update --');		

	self.setDefaultsByDocketType(theDocket);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDefaultsByDocketType" id="e6523559-5684-4aa2-b897-9282e76bfab7">
        <updating/>
        <source>setDefaultsByDocketType(_docket : CM_BOL) updating, protected;
//--------------------------------------------------------------
//Created: 24 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	logDocket : CM_BOLIn;
	ext			: CM_BOLExtLogIn;
	idx			: Integer;
	tmpLCSearch	: CMIF_SearchTypes;
	tmpConsignor	: CM_ConsigneeConsignor;
	scalerStr 	: String;
	forest 		: CM_SourceLocation;
	compartment : CM_SourceSubLocation;
	stand 		: CM_SourceSubSubLocation;
	tmpCodeGroup : CM_CodesByCodeDict;
	
	
begin
	if _docket.bolType = BOLType_Log then
		logDocket := _docket.CM_BOLIn;
		ext := _docket.myExtension.CM_BOLExtLogIn;
		
		self.setControlsForSupplier(logDocket.myOperator);
		self.cmbSupplier.setObject(logDocket.myOperator);
//		cmbSupplier.listObject := logDocket.myOperator;		
		self.setControlsForSpecies(logDocket.myLogSpecies);
		self.setControlsForGrade(logDocket.myLogGrade, 
								 logDocket.myLogType,
								 logDocket.myLogTreatment,
								 logDocket.myLogLength);
		create tmpLCSearch transient;
		tmpLCSearch.myOperator 	:= logDocket.myOperator;	
		tmpLCSearch.mySpecies 	:= logDocket.myLogSpecies;
		tmpLCSearch.myGrade 	:= logDocket.myLogGrade;
		tmpLCSearch.myType 		:= logDocket.myLogType;
		tmpLCSearch.myTreatment	:= logDocket.myLogTreatment;
		tmpLCSearch.myLength	:= logDocket.myLogLength;
		self.myTerminal.availableLocationsForType(tmpLCSearch, self.allLogLocations, TA_TYPE_LOGAREA);
/*		self.myAssistant.getLogLocationsForSpec(logDocket.myLogGrade, 
												logDocket.myLogType, 
												logDocket.myLogTreatment,
												logDocket.myLogLength,
												self.allLogLocations);*/
	
		if logDocket.myPlannedLocation &lt;&gt; null then
			if not self.allLogLocations.includes(logDocket.myPlannedLocation) then
				self.allLogLocations.add(logDocket.myPlannedLocation);
			endif;
		endif;
				
		if logDocket.allDocketErrors &lt;&gt; null and not logDocket.allDocketErrors.isEmpty() then				//ccms 1110
			self.myAssistant.comboBoxLogDocketError(self.cmbDocketError,logDocket.allDocketErrors.first().myDocketErrorType);			
			tblMain.setValueByName(ETRow_DocketError, logDocket.getLogDocketErrorDescription());
		else
			self.myAssistant.comboBoxLogDocketError(self.cmbDocketError,null);
		endif;
	
		if ext.hasPieceCountError() then	// #23894	21/05/2010
			tblMain.setValueByName(ETRow_PieceCountError, true);
			tblMain.setValueByName(ETRow_DriversPieceCount,logDocket.getDriversPieceCount());
			tblMain.showRowByName(ETRow_DriversPieceCount,false);
		endif;
	
		self.myAssistant.comboBoxLocationControllers(self.cmbLogLocation,  self.allLogLocations, true);

		tblMain.setValueByName(ETRow_JasScaled, ext.jasScaled);
		tblMain.setValueByName(ETRow_PercentScaled, ext.percentScaled);
		tblMain.setValueByName(ETRow_TicketedAll, ext.ticketedAll);
		tblMain.setValueByName(ETRow_Supplier, logDocket.getOperatorCode());
		tblMain.setValueByName(ETRow_LogSpeciesCode, ext.logSpeciesCode);
		tblMain.setValueByName(ETRow_LogGradeCode, ext.logGradeCode);
		tblMain.setValueByName(ETRow_LogTypeCode, ext.logTypeCode);
		tblMain.setValueByName(ETRow_LogTreatmentCode, ext.logTreatmentCode);
		tblMain.setValueByName(ETRow_LengthRandom, ext.lengthCode);
		tblMain.setValueByName(ETRow_NumItems, logDocket.numItems);
		tblMain.setValueByName(ETRow_LogLocation, logDocket.getLocationDescription());
		tblMain.setValueByName(ETRow_TicketSequence, app.getErrorString(Dbl_Click_To_Add_Update));
		tblMain.setValueByName(ETRow_FellDate, ext.fellDate);
//		self.txtFellDate.setDate(ext.fellDate);

		if logDocket.myOperator &lt;&gt; null then
			tmpCodeGroup := logDocket.myOperator.getAllSrcLocn();
		endif;
		if tmpCodeGroup &lt;&gt; null then
			forest := tmpCodeGroup[logDocket.sourceLocation].CM_SourceLocation;
		endif;	

		if forest = null then
			// as forect object my have been deleted
			self.cmbSrcLocn.setTextForDisplayCollection(logDocket.sourceLocation);
		else
			self.cmbSrcLocn.setObject(forest);
		endif;
		tblMain.setValueByName(ETRow_Forest, self.cmbSrcLocn.text);
		
		self.setControlsForCompartment(forest);	//self.cmbSrcLocn.myObject.CM_SourceLocation);
	
		if forest &lt;&gt; null then 
			compartment := 	forest.allSubLocations[logDocket.sourceSubLocation].CM_SourceSubLocation;
		endif;
		
		if compartment = null then
			// as forect object my have been deleted
			self.cmbSrcSubLocn.setTextForDisplayCollection(logDocket.sourceSubLocation);
		else
			self.cmbSrcSubLocn.setObject(compartment);
		endif;
		tblMain.setValueByName(ETRow_Compartment, self.cmbSrcSubLocn.text);
		
		self.setControlsForStand(compartment);

		if compartment &lt;&gt; null then 
			stand := 	compartment.allSubSubLocations[logDocket.sourceSubSubLocation].CM_SourceSubSubLocation;
		endif;
		if stand = null then
			// as forect object my have been deleted
			self.cmbSrcSubSubLocn.setTextForDisplayCollection(logDocket.sourceSubSubLocation);
		else
			self.cmbSrcSubSubLocn.setObject(stand);
		endif;
		tblMain.setValueByName(ETRow_Stand, self.cmbSrcSubSubLocn.text);
		
		self.tblMain.setValueByName(ETRow_IsFSC, ext.isFSC);	// CCMS JML 1105, PAR 21535 Nov 2009
		
		//tblMain.setValueByName(ETRow_LoggingOrganisation, logDocket.loggingOrganisation); //#cnwdz2	 CCMS 1108 par22177 
		tblMain.setValueByName(ETRow_LoggingOrganisation, logDocket.getLoggingOrganisation());
//		self.myAssistant.comboBoxLoggingOrg(self.cmbLoggingOrg, logDocket.loggingOrganisation);
		//self.cmbLoggingOrg.setObject(app.myRoot.allLoggingOrganisations[logDocket.loggingOrganisation]);//#cnwdz2	 CCMS 1108 par22177 
		self.cmbLoggingOrg.setObject(app.myRoot.allLoggingOrganisations[logDocket.getLoggingOrganisation()]);
		
		tblMain.setValueByName(ETRow_LoggingOperation, logDocket.loggingOperation);		
		if logDocket.loggingOperation &lt;&gt; null then 
			self.myAssistant.comboBoxLogOperation(self.cmbLogOperation);
			self.cmbLogOperation.listIndex := self.cmbLogOperation.findString(1,logDocket.loggingOperation);
		endif;
		
		tblMain.setValueByName(ETRow_LoggingContractor, logDocket.handlingContractor1Code);
		tblMain.setValueByName(ETRow_LoggingGang, ext.gangNumber);
		tblMain.setValueByName(ETRow_LoadingContractor, logDocket.handlingContractor2Code);
		tblMain.setValueByName(ETRow_Customer, ext.customer);
		tblMain.setValueByName(ETRow_LoaderNumber, ext.loaderNumber);
		tblMain.setValueByName(ETRow_WeightGrossTonnes, logDocket.weightGrossTonnes);
		tblMain.setValueByName(ETRow_WeightTareTonnes, logDocket.weightTareTonnes);
		tblMain.setValueByName(ETRow_WeightNetTonnes, logDocket.weightNetTonnes);
		scalerStr := ext.allScalerCodes.asCSV(false);
		tblMain.setValueByName(ETRow_ScalerCode, scalerStr);
		tblMain.setValueByName(ETRow_PickupPoint, ext.pickupPoint);
		tblMain.setValueByName(ETRow_Activity, ext.activity);
		tblMain.setValueByName(ETRow_Nightshift, ext.nightshift);
		tblMain.setValueByName(ETRow_Backload, ext.backload);
		tblMain.setValueByName(ETRow_Weighbridge, ext.weighbridge);
		tblMain.setValueByName(ETRow_ChhSupplier, ext.chhSupplier);
		tblMain.setValueByName(ETRow_Opid, ext.getOPID);		
		tblMain.setValueByName(ETRow_UnloadPoint, logDocket.unloadPoint);		

		cmbLogLocation.listObject 	:= logDocket.myPlannedLocation;
//		cmbLogSpecies.listObject 	:= logDocket.myLogSpecies;
		self.cmbLogSpecies.setObjectAndOperator(logDocket.myLogSpecies, logDocket.myOperator);
//		cmbLogGrade.listObject 		:= logDocket.myLogGrade;
		self.cmbLogGrade.setObjectAndSpecies(logDocket.myLogGrade,logDocket.myLogSpecies);
//		cmbTreatment.listObject 	:= logDocket.myLogTreatment;
		self.cmbTreatment.setObjectAndGrade(logDocket.myLogTreatment,logDocket.myLogGrade);
//		cmbLogType.listObject 		:= logDocket.myLogType;
		self.cmbLogType.setObjectAndGrade(logDocket.myLogType,logDocket.myLogGrade);
//		cmbLogLength.listObject 	:= logDocket.myLogLength;
		self.cmbLogLength.setObjectAndGrade(logDocket.myLogLength,logDocket.myLogGrade);
					
		self.restrictEntryForLogDocket(logDocket);
		if ext.allScalerCodes.size &gt; 1 then
			// if more then 1 scaler then have to edit scaler on the log
			tblMain.hideRowByName(ETRow_ScalerCode, false);
		else 
			tblMain.showRowByName(ETRow_ScalerCode, false);
			self.cmbScaler.setObject(app.myRoot.allUsers[scalerStr]);
		endif;
	else
		tblMain.setValueByName(ETRow_BolNumber, _docket.number);
		tblMain.setValueByName(ETRow_Supplier, _docket.getOperatorCode());
	endif;
	
// cnwdad1 21/04/2009 - CCMS 1735.
	if app.isSubTerminalsOn(self.myTerminal) then
		if _docket.isInward and _docket.mySubTerminal &lt;&gt; null then
			tblMain.setValueByName(ETRow_MySubTerminal, _docket.mySubTerminal.code);
		endif;
	else
		tblMain.hideRowByName(ETRow_MySubTerminal, false);		// cnwdad1 19/11/2009 - PAR #21640.
	endif;
epilog	
	
	delete tmpLCSearch;
end;</source>
        <access>protected</access>
        <Parameter name="_docket" type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="setFilterDefaults" id="a42ee8f3-ad43-4a93-a67b-eab86f70774d">
        <updating/>
        <source>setFilterDefaults() updating;
//--------------------------------------------------------------
//Created: 22 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpCombo : ComboBox;
begin
	self.filterDocketNumber			:= null;
	self.filterOperatorCode			:= null;	
	self.filterConsignCode			:= null;
	self.filterVoyage				:= null;					//+cnwml2 SFW CCMS 1071
	self.filterStatus				:= null;					//+cnwml2 SFW CCMS 1071
	self.filterReconciled			:= null;					//+cnwml2 SFW CCMS 1071
	self.filterDocketType			:= self.myBOLType.id;		//+cnwml2 SFW CCMS 1071
	self.myFilterConsign			:= null;
	self.cmbFiltConsignee.listObject:= null;
	self.cmbOperator.setObject(null);
	self.myFilterOperator			:= null;
	self.myFilterVoyage				:= null;					//+cnwml2 SFW CCMS 1071

//	self.cmbDocketType.listObject 	:= null;

	tmpCombo := cmbDocketType;
	
	self.setFilterDocketCmb();	
	//self.myAssistant.comboBoxDocketType(tmpCombo, BOLType_Log);
	tblSearch.setValueByName(ETRow_CargoType, tmpCombo.text);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFilterDocketCmb" id="6a1161a9-8aa0-47d2-afca-b07dac2f26fa">
        <source>setFilterDocketCmb();
//22 January 2010	cnwml2


vars
	coll : CM_BOLTypesByIdDict;

begin
	create coll transient;
	
	if self.myBOLType.id = BOLType_Log then
		coll.add(app.myRoot.allBOLTypes[BOLType_Log]);
		coll.add(app.myRoot.allBOLTypes[BOLType_GeneralDocket]);
		self.cmbDocketType.listCollection(coll, false, 0);
		self.cmbDocketType.text := self.myAssistant.displayEntryDocketType(app.myRoot.allBOLTypes[BOLType_Log]);
		self.cmbDocketType.listObject := app.myRoot.allBOLTypes[BOLType_Log];
	elseif self.myBOLType.id = BOLType_GeneralBillOfLading then
		coll.add(app.myRoot.allBOLTypes[BOLType_GeneralBillOfLading]);
		self.cmbDocketType.listCollection(coll, false, 0);
		self.cmbDocketType.text := self.myAssistant.displayEntryDocketType(app.myRoot.allBOLTypes[BOLType_GeneralBillOfLading]);
		self.cmbDocketType.listObject := app.myRoot.allBOLTypes[BOLType_GeneralBillOfLading];
	endif;
epilog
	delete coll;
end;</source>
    </JadeMethod>
    <JadeMethod name="setFilterValues" id="a8dfc209-a7ff-4aed-84fc-ab735a108552">
        <updating/>
        <source>setFilterValues() updating;
//--------------------------------------------------------------
//Created: 22 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpDocketType	: CM_BOLType;
	
begin

	self.filterDocketNumber	:= tblSearch.getValueByName('filterDocketNumber').String;
	self.myFilterConsign	:= cmbFiltConsignee.listObject.CM_ConsigneeConsignor;
	self.myFilterOperator	:= cmbOperator.listObject.CM_Operator;		
	self.myFilterVoyage		:= self.cmbFiltVoyage.listObject.CM_Voyage;					//+cnwml2 MSL CCMS 1071
	
	//+cnwml2 PAR26136
	if self.tblSearch.getValueByName(ETRow_FilterStatus).String = Any_String then
		self.filterStatus := null;
	else
		self.filterStatus := self.tblSearch.getValueByName(ETRow_FilterStatus).String;		//+cnwml2 MSL CCMS 1071
	endif;
	
	self.filterReconciled := self.tblSearch.getValueByName(ETRow_FilterReconciled).String;	//+cnwml2 MSL CCMS 1071
	
	tmpDocketType := cmbDocketType.listObject.CM_BOLType;
	if tmpDocketType &lt;&gt; null then
		filterDocketType := tmpDocketType.id;
	else
		filterDocketType := TI_CargoType_Null;
	endif;
	
	if self.myFilterConsign &lt;&gt; null then
		self.filterConsignCode := self.myFilterConsign.code.trimRight;
	else
		self.filterConsignCode := null;
	endif;
	
	if self.myFilterOperator &lt;&gt; null then
		self.filterOperatorCode := self.myFilterOperator.code.trimRight;
	else
		self.filterOperatorCode := null;
	endif;	

	//+cnwml2 MSL CCMS 1071
	if self.myFilterVoyage &lt;&gt; null then
		self.filterVoyage := self.myFilterVoyage.code.trimRight;
	else
		self.filterVoyage := null;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setFilterVoyageCmb" id="5d68c871-a229-416c-8e18-b0318e689961">
        <source>setFilterVoyageCmb();
//19 November 2010	cnwml2
//+cnwml2 PAR26136
vars
	voy : CM_Voyage;
begin
	self.cmbFiltVoyage.clear();
	foreach voy in self.myTerminal.allVoyagesByCode do
		if voy.allImportTIs.size &gt; 0 then
			self.cmbFiltVoyage.addItemObject(voy.code &amp; " " &amp; voy.description, voy);
		endif;
	endforeach;
		
epilog

end;</source>
    </JadeMethod>
