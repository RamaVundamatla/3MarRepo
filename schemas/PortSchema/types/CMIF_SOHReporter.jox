    <JadeMethod name="setFromSOHLocation" id="e2c505e9-790f-4e71-8c27-da679dc2082b">
        <updating/>
        <source>setFromSOHLocation(_sohLoc : CM_SOHLocation) updating;
// ---------------------------------------------------------------------------
// Created:     19 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _sohLoc = null then
		return;
	endif;
	
	self.mySOHLocation := _sohLoc;
	self.myProduct := _sohLoc.myProduct;
	self.mySupplier := _sohLoc.myOperator;

end;</source>
        <Parameter name="_sohLoc" type="CM_SOHLocation"/>
    </JadeMethod>
