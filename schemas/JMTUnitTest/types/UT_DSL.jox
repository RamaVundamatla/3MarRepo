    <JadeMethod name="machineAssignToQueue" id="b97db1eb-8c10-4fde-950a-2d20a01e09b4">
        <source>machineAssignToQueue(_machine: CM_Machine; _queue: CM_RadioTelemetryQueue input);
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	pxyMachine: CM_Machine;
	loadStateSet : Boolean;
begin
	app.cmsBeginLoad(loadStateSet);
	pxyMachine := _machine.pxyCreateUpdateProxy;
	app.cmsEndLoad(loadStateSet);
	app.myTrxUA.trxUpdateMachineQueue(pxyMachine, _queue, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	app.cmsEndLoad(loadStateSet);			// 08/04/2011 cnwmh5 #27347
	delete pxyMachine;
end;
</source>
