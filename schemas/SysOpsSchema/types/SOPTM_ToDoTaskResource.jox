    <JadeMethod name="populateTodoTask" id="eec05c1c-3630-430d-a352-8ce44f96efb3">
        <source>populateTodoTask(_type : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2022	navhl20	ChangeRequest 56634[54259]: EUP - Todo Task Description Maintenance

*/

vars
	allTodoTasks		: CM_ToDoTaskDescByCode;
	todoTask			: CM_ToDoTaskDesc;
begin
	create allTodoTasks transient;
	
	// ### TFS BUG 60696 27SEP2023 NAVAB1 'ALL' was not seeing anything, becasue we do not have ALL for to do task type
	if _type = TODO_TYPE_GROUP_ALL then
		foreach todoTask in app.myRoot.allToDoTaskDescriptions do
			allTodoTasks.add(todoTask);
		endforeach;
	
	else
		foreach todoTask in app.myRoot.allToDoTaskDescriptions where todoTask.type = _type do
			allTodoTasks.add(todoTask);
		endforeach;
	endif;
	
	self.setupMultiSelect1(app.getErrorString(To_Do_Tasks),allTodoTasks, SOP_TableMaintForm::displayToDoTaskDesc.name);
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="f5c92e39-a033-48db-a4d7-dcbb1b35da39">
        <updating/>
        <source>setControlsForAddEdit() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		          Who		Reason
18 December 2009	cnwndl1  	Initial creation	CCMS MES 1006
19 Sept 2022        navds21     Bug 54861: Place holder text missing and mismatch
22/12/2022   		navcs2		ChangeRequest 56006: EUP - New VAS Workorder Subscription (task 56008)
23 December 2022    navds21     ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
13th March 2024 	navra1		BUG 62783 - FR - System Admin / To Do Task Description and Resources Type Edits
*/
vars

	theForm : SOP_TableMaintForm;
	iter : Iterator;
	obj : Object;
	toDoColl : CM_ToDoTaskDescBySortKey;

begin
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := true;
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_UnitDescription);
		theForm.tblInput1.enableRowByName(ETRow_NumDecimals);
		theForm.tblInput1.enableRowByName(ETRow_IsAvailable);
		theForm.tblInput1.enableRowByName(ETRow_IsMandatory);   //23.12.2022 navds21 TFS #54349[54262]
		theForm.tblInput1.disableRowByName(ETRow_HasBeenUsed);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.mulSelect1.setSelected(null);
		theForm.mulSelect2.setSelected(null);
		theForm.mulSelect3.setSelected(null);
		theForm.mulSelect41.setSelected(null);
		theForm.mulSelect42.setSelected(null);
		theForm.tblInput1.setValueByName(ETRow_HookCode,'Dbl-Click to add'); //  19/09/2022 navds21 TFS 54861
		
		// 22/12/2022 navcs2 ChangeRequest 56006 (task 56008)
		if not app.myPassport.isVASEnabled then
			theForm.tblInput1.setValueByName(ETRow_Type,app.getToDoTaskIntToString(TODO_TYPE_GROUP_TI));
			theForm.tblInput1.disableRowByName(ETRow_Type);
		else
			theForm.tblInput1.enableRowByName(ETRow_Type);
		endif;
		self.filterAutoApplyList(theForm, null);	// ### TFS 58761 (60739) 16Nov2023 NAVPW1
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_ResourceType);
		
		//theForm.tblInput1.disableRowByName(ETRow_Type);															//navra1 - 13th March 2024 - BUG 62783
		theForm.tblInput1.enableRowByName(ETRow_Type);																//navra1 - 13th March 2024 - BUG 62783
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_UnitDescription);
		theForm.tblInput1.enableRowByName(ETRow_NumDecimals);
		theForm.tblInput1.enableRowByName(ETRow_IsAvailable);
		theForm.tblInput1.disableRowByName(ETRow_HasBeenUsed);
		theForm.tblInput1.enableRowByName(ETRow_IsMandatory); //23.12.2022 navds21 TFS #54349[54262]
		create toDoColl transient;
		iter := theForm.myProxyObject.CM_ResourceType.allUsageContexts.createIterator;
		while iter.next (obj ) do
			if obj.isKindOf(CM_ToDoTaskDesc) then
				toDoColl.add( obj.CM_ToDoTaskDesc );
			endif;
		endwhile;
		
		theForm.mulSelect1.setSelected(toDoColl);

	endif; 
	
	self.enableMulSelect1Contents();
epilog
	delete iter;
	delete toDoColl;
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="73becd9f-8b2b-4697-b558-84af7899b3ef">
