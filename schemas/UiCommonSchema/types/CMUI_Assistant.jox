    <JadeMethod name="comboBoxVoltageType" id="e89fbd0c-cc02-416c-81c9-d03045e33644">
        <source>comboBoxVoltageType(pTbl : CM_EntryTable input; pAttrName, _type : String);
//-----------------------------------------
//Created: 2 June 2005 By: cnwgd1
//-----------------------------------------
vars
	str	: String;
begin
	
	str := ContainerVoltNullStr &amp; Tab &amp;
		   ContainerSingleVoltStr &amp; Tab &amp;	
		   ContainerDualVoltStr;

	pTbl.setComboValues(pTbl.getRow(pAttrName), str);
