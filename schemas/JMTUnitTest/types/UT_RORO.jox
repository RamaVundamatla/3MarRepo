		unloadArray.add("C,A,,," &amp; subType.code &amp; ",,Cannon Balls,,,,,,,DFBU,,,,,DEBRV,D1002G,,0.0000,,CANB0068,Export,,0.0000,NZPOE,,,,,,MSL,,,,,,,,00:00:00," &amp; utCreatedBy &amp; ",,,,1000,,,,0.000,VOYSHIP30738_1,,,0.0000,,,");
		unloadArray.add("C,A,,," &amp; subType.code &amp; ",,Cannon Balls,,,,,,,DFBU,,,,,DEBRV,D1002G,,0.0000,,CANB0069,Export,,0.0000,NZPOE,,,,,,MSL,,,,,,,,00:00:00," &amp; utCreatedBy &amp; ",,,,1000,,,,0.000,VOYSHIP30738_1,,,0.0000,,,");
		unloadArray.add("C,A,,," &amp; subType.code &amp; ",,Cannon Balls,,,,,,,DFBU,,,,,DEBRV,D1002G,,0.0000,,CANB0070,Export,,0.0000,NZPOE,,,,,,MSL,,,,,,,,00:00:00," &amp; utCreatedBy &amp; ",,,,1000,,,,0.000,VOYSHIP30738_1,,,0.0000,,,");
		unloadArray.add("C,A,,PAR30360,,,ISO Container,,,GENL,General,,,DFBU,,,,,DEBRV,D10031,,0.0000,,OOTL0307391,Export,2200,0.0000,NZPOE,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00," &amp; utCreatedBy &amp; ",,,,4000,,,,0.000,VOYSHIP30738_1,,,0.0000,,,");
