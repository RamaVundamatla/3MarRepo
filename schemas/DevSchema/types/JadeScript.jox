    <JadeMethod name="eprTestTrucUnload" id="4ee37f4c-b5ff-40eb-84db-8adae0a9e379">
        <source>eprTestTrucUnload();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2017	jlger1	Initial creation
14 Feb 2023 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
*/

vars	
	truckUnLoaderController: CMIF_MobileTruckLoaderUnloader;
	ti : CM_TrackedItem;
	truck : CM_Vehicle;
	tmpFoundLC : CM_LocationsController;
	foundHeight : Integer;
	wle : CM_WorkListEntry;
begin
	
	app.initialize;
	app.myPassport.setMyUserFromCode("CNWER1");
	ti := "2365.356033".asOid.CM_TrackedItem;
	ti :="2365.935876".asOid.CM_TrackedItem;
	truck := "2414.28711".asOid.CM_Vehicle;
	wle:="2425.1428881".asOid.CM_WorkListEntry;
	app.myPassport.setMyTerminal(ti.myTerminal);
	create truckUnLoaderController transient;
	
	truckUnLoaderController.setMyTerminal(app.myPassport.myTerminal);
	truckUnLoaderController.setTruck(truck);
//	truckUnLoaderController.setMyWle(wle);
	app.myPassport.setWarningsIgnored(true); 
	//app.myPassport.warningsAcknowledged := true; 
	truckUnLoaderController.setDoNotShowMsgBox(true);
	truckUnLoaderController.setDoingReversal(true);
	truckUnLoaderController.setChecksState(truckUnLoaderController.TruckUnload);
		
	if ti &lt;&gt; null then
		app.myPassport.myTerminal.findLocationFromString(ti.priorLocation ,true,tmpFoundLC,foundHeight);
	endif;
		
	truckUnLoaderController.saveChangesUnload(ti,tmpFoundLC,null,null,null);				//14.02.2023 navhl20 #62093
	
	//	truckUnLoaderController.saveChangesLoad(ti,null,null);
epilog

end;</source>
