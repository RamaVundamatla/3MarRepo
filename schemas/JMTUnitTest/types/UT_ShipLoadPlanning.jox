	weightPC	: Integer;
	reqs : CM_SlotRequestArray;
	slotRequest : CM_SlotRequest;
	futureMovePlanned : CM_FutureMovePlanned;
	stradStack : CM_StraddleStack;
	gridControler : CM_GridController;
	trackedItem 	: CM_TrackedItem;
	allAssocs: ObjectArray;
	assocDict : CM_AssociationDict;
begin

	//need to delete all containers and only have 20 containers available
	
	
	create allAssocs transient;
	
	stradStack:=self.getTerminal.allTerminalAreas["UTSTRDA"].CM_StraddleStack;
	self.assertTrue(stradStack &lt;&gt; null);
	

	self.getAllContainerDetails(0,24,stradStack,self.getVoyageName(),"AUBNE",TI_IMEX_STATUS_EXPORT,"APPL","2200",self.getOperatorName,allAssocs);

	//will create 23 containers make the first 3 for null voyage;
	assocDict:=allAssocs[1].CM_AssociationDict;
	assocDict.addAssociation("VoyageName",null);
	assocDict:=allAssocs[2].CM_AssociationDict;
	assocDict.addAssociation("VoyageName",null);
	assocDict:=allAssocs[3].CM_AssociationDict;
	assocDict.addAssociation("VoyageName",null);
	self.addContainers(allAssocs);
	self.uRemoveAllStops();
	
	create tmpOptionsUsed transient;
	create allJobs transient;
	create controller transient;
	mode:=3; //this is job mode voyage is 1 crane is 2
	voyage := self.getVoyage(self.getVoyageName);
	jobSheet:=voyage.allJobSheets[self.getCraneID];
	//there's only one job
	job:=self.getJob();
	allJobs.add(job);

	/* the options that could be included
		VoyageFullPlanThirdHeight
		VoyageFullPlanGroundHeight
		VoyageFullPlanOSVoyage
		VoyageFullPlanOSDischPort
	*/
	tmpOptionsUsed.add(VoyageFullPlanThirdHeight);
	planFromRowEnds:=true;
	height:=3;
	//not sure why this sets the config when the chk box changes value?
	app.myTrxUA.trxUpdateTerminalConfig(self.getTerminal, AutoLoadPlanAt3Height,true, app.myPassport );
	//self.setYardAreaFlipped();
	controller.init(self.getTerminal,
					mode, 
					allJobs, 
					jobSheet,
					voyage,
					planIfStops,
					tmpOptionsUsed, 
					height, 
					planFromRowEnds,
					numRowSep,
					null,
					useWeights,
					weightAve,
					weightPC,
					planAccrossTermArea,
					planAccrossTermAreaCol,
					ignoreWarnings,
					planTwinLift);
					
	controller.initQuery();
	controller.doQuery(null);

	// the results should be 
	//get the slot requests in order 20 requests
	create reqs transient;
	job.doSortReqsInToSeqOrder(reqs);
	
	//1st voyage slot request  
	stradStack:=self.getTerminal.allTerminalAreas["UTSTRDA"].CM_StraddleStack;
	// params are slot request, row, col , height
	self.checkSlotRequest(reqs[1],stradStack,1,5,3);
		
	//2nd voyage slot request  
	self.checkSlotRequest(reqs[2],stradStack,1,4,3);
		
	//3rd voyage slot request  
	self.checkSlotRequest(reqs[3],stradStack,1,3,3);
	
	//4th voyage slot request  
	self.checkSlotRequest(reqs[4],stradStack,1,2,3);
	//5th voyage slot request  
	self.checkSlotRequest(reqs[5],stradStack,2,1,3);
	
	//6th voyage slot request  
	self.checkSlotRequest(reqs[6],stradStack,2,3,3);
	//7th voyage slot request  
	self.checkSlotRequest(reqs[7],stradStack,2,2,3);
	//8th voyage slot request  
	self.checkSlotRequest(reqs[8],stradStack,1,5,2);
	//9th voyage slot request  
	self.checkSlotRequest(reqs[9],stradStack,1,5,1);
	//10th voyage slot request  
	self.checkSlotRequest(reqs[10],stradStack,1,4,2);
	//11th voyage slot request  
	self.checkSlotRequest(reqs[11],stradStack,1,4,1);
	//12th voyage slot request  
	self.checkSlotRequest(reqs[12],stradStack,1,3,2);
	//13th voyage slot request  
	self.checkSlotRequest(reqs[13],stradStack,1,3,1);	
	//14th voyage slot request  
	self.checkSlotRequest(reqs[14],stradStack,1,2,2);
	//15th voyage slot request  
	self.checkSlotRequest(reqs[15],stradStack,1,2,1);
	//16th voyage slot request  
	self.checkSlotRequest(reqs[16],stradStack,2,1,2);
	//17th voyage slot request  
	self.checkSlotRequest(reqs[17],stradStack,2,1,1);
	//18th voyage slot request  
	self.checkSlotRequest(reqs[18],stradStack,2,2,2);
	//19th voyage slot request  
	self.checkSlotRequest(reqs[19],stradStack,2,2,1);
	//20th voyage slot request  
	self.checkSlotRequest(reqs[20],stradStack,2,3,2);
	
	
	create allJobSet transient;
	allJobs.copy(allJobSet);
	self.unplanVoyageJobs(allJobSet);
epilog
	delete allJobs;
	delete tmpOptionsUsed;
	delete controller;
	delete reqs;
	if allJobSet &lt;&gt; null then
		delete allJobSet;
	endif;
	if allAssocs &lt;&gt; null then
		allAssocs.purge;
		delete allAssocs;
	endif;

	self.uDeleteContainers();
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="uCreateContainers" id="2c1a5a6b-09ee-4d6a-80d6-566af246ffbd">
        <updating/>
        <source>uCreateContainers() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2008	cnwer1	Initial creation

*/

vars

	operatorName : String;
	shippingLine,
	commodityCode,
	dischargePort,
	isoCode,
	id,
	voyName, opName, 
 	taName : String;
	ti : CM_TrackedItem;
	stradStack : CM_StraddleStack;
	allAssocs: ObjectArray;
	obj : Object;
begin
	operatorName :=self.getOperatorName();
	shippingLine :=self.getShippingLine();
	
	create allAssocs transient;
	taName:="UTSTRDA";
	stradStack:=self.getTerminal.allTerminalAreas["UTSTRDA"].CM_StraddleStack;
	self.assertTrue(stradStack &lt;&gt; null);
	
	commodityCode:="APPL";
	voyName:=self.getVoyageName();
	opName:=self.getOperatorName();
	dischargePort:="AUBNE";
	self.getAllContainerDetails(0,0,stradStack,voyName,dischargePort,TI_IMEX_STATUS_EXPORT,commodityCode,"2200",opName,allAssocs);
	//self.getAllContainerDetails(stradStack,0,ids,tas,rowCols);
	stradStack:=self.getTerminal.allTerminalAreas["UTSTRDB"].CM_StraddleStack;
	self.assertTrue(stradStack &lt;&gt; null);
	self.getAllContainerDetails(allAssocs.size,0,stradStack,voyName,dischargePort,TI_IMEX_STATUS_EXPORT,commodityCode,"2200",opName,allAssocs);
	
	stradStack:=self.getTerminal.allTerminalAreas["UTSTRDC"].CM_StraddleStack;
	self.assertTrue(stradStack &lt;&gt; null);
	self.getAllContainerDetails(allAssocs.size,0,stradStack,self.getVoyageName(),dischargePort,TI_IMEX_STATUS_EXPORT,commodityCode,"2200",self.getOperatorName,allAssocs);
	
	
	self.addContainers(allAssocs);
	
epilog
	allAssocs.purge;
	delete allAssocs;
end;</source>
    </JadeMethod>
