    <JadeMethod name="addToolbarControls" id="e43e9850-8882-4998-a02f-d0717c003aec">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	toolbar : CMUI_Toolbar;
begin
	inheritMethod();
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnTBPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnTBDelete, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnClear, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnTBAdd, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnTBRefresh, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnTBFlip, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnTBImport, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnTBExport, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addFrame(self.frmToolbarCombos, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);			

	
	toolbar.visible := true;
	toolbar.positionToolbarControls();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnClear_click" id="cb3e4b7e-af9f-400b-80d8-12baf2489402">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClear_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		15 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if app.msgBox("Are you sure that you want to clear all the commands?","Confirm",MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
		self.tblDim.rows := self.tblDim.fixedRows;
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnLoadFromCSV_click" id="56f35c61-937a-4cc7-9a40-a66e8d0d31f0">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnLoadFromCSV_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		3 Feb 2009 by cnwjo3
//
// Purpose:		fill things in from a file so i don't need to type it anymore
//
vars
	tRow : Integer;
	fo : CMDFileOpen;
	f : File;
	line : String;
	data : StringArray;
begin
	create fo transient;
	fo.open();
	
	if fo.fileName = null then
		return;
	endif;
	
	create f transient;
	f.fileName := fo.fileName;
	f.kind := File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
	f.mode := File.Mode_Input;
	f.open();
	
	tRow := self.tblDim.fixedRows+1;
	while not f.endOfFile do
		if self.tblDim.rows &lt; tRow then
			self.doBtnTBAddClick();
		endif;
	
		line := f.readLine;
		line.replaceChar(",",";");
		line.replaceChar(" ","_");
		delete data;
		data := line.getTokens();
		self.tblDim.accessCell(tRow,5).text := data[2];
		self.tblDim.accessCell(tRow,6).text := data[3];
		if data.size &gt;= 4 then
			self.tblDim.accessCell(tRow,7).text := data[4].Integer.String;
		endif;
		if data.size &gt;= 5 then
			self.tblDim.accessCell(tRow,8).text := data[5].Integer.String;
		endif;
		tRow := tRow + 1;
	endwhile;
	
epilog
	delete fo;
	delete f;
	delete data;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
