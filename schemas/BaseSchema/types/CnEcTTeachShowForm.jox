    <JadeMethod name="doResize" id="980eeee6-4990-4ea7-a9a6-9fb0087f0fd6">
        <updating/>
        <source>doResize() updating;

vars
	min : Boolean;
	
begin
	// size the parent item for all controls
	picBasePlinth.move(0,0,self.clientWidth,self.clientHeight);

	// position and size the components along the top of the dialog
	picTop1.move(0,0,picTop1.width,picTop1.height);	
	picTop3.move(self.clientWidth - picTop3.width,0,picTop3.width,picTop3.height);
	picTop2.move(picTop1.width,0,picTop3.left - picTop1.width,picTop2.height);

	// position and size the components along the bottom of the dialog
	picBottom1.move(0,self.clientHeight - picBottom1.height,picBottom1.width,picBottom1.height);
	picBottom3.move(self.clientWidth - picBottom3.width,self.clientHeight - picBottom3.height,picBottom3.width,picBottom3.height);
	picBottom2.move(picBottom1.width,self.clientHeight - picBottom2.height,picBottom3.left - picBottom1.width,picBottom2.height);

	// position and size the side components of the dialog
	picSide1.move(0,picTop1.height,picSide1.width,picBottom1.top - picTop1.height);
	picSide2.move(self.clientWidth - picSide2.width, picTop3.height,picSide2.width,picBottom3.top - picTop3.height);

	// size display items
	lstLessons.move(picSide1.width,picTop1.height,picSide2.left - picSide1.width,picBottom1.top - picTop1.height);
	txtText.move(picSide1.width,picTop1.height,picSide2.left - picSide1.width,picBottom1.top - txtTextAction.height - picTop1.height);
	txtTextAction.move(picSide1.width,picBottom1.top - txtTextAction.height,picSide2.left - picSide1.width,txtTextAction.height);
end;</source>
    </JadeMethod>
    <JadeMethod name="getActivityAction" id="b20d8545-7a2e-4e9e-96d7-ff316fc1e0fe">
        <source>getActivityAction(pForDisplay : Boolean) : String;

vars
	textbox	 	: TextBox;
	combo		: ComboBox;
	date		: Date;
	returnStr	: String;

begin
	if aMyActivity = null then
		return "";
	endif;

	returnStr := aMyActivity.action;

	if aMyControl = null then 
		return returnStr;
	endif;

	if pForDisplay and aMyControl.isKindOf(ComboBox) then	// check to strip flag from combo box
		if returnStr.length &gt; 0 and returnStr[1] = '"' then
			if returnStr.length = 1 then
				returnStr := "";
			else
				returnStr := returnStr[2:end];
			endif;
		endif;
	endif;

	if aMyControl.isKindOf(TextBox) then
		textbox := aMyControl.TextBox;
		
		if aMyActivity.useExistingValue and (textbox.text.trimBlanks.length &gt; 0) and (textbox.text.trimBlanks &lt;&gt; "00/00/0000") then
			returnStr := textbox.text.trimBlanks();
		endif;
	endif;

	return returnStr;
end;</source>
        <Parameter name="pForDisplay" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getActivityText" id="b54440df-659f-4714-8232-20bfc1c5fd22">
        <source>getActivityText() : String;

vars
	returnStr	: String;
	posValue	: Integer;
	strLength	: Integer;
	newValue	: String;

begin
	returnStr := self.aMyActivity.text;

	if aMyControl = null then
		return returnStr;
	endif;

	posValue := returnStr.pos(self.TEXTBOX_VALUE_HOLDER, 1);

	if posValue = 0 then
		return returnStr;
	endif;

	// have to replace parts of string with action

	newValue := self.getActivityAction(true);

	while posValue &gt; 0 do
		strLength := returnStr.length;

		if posValue = 1 then
			returnStr := newValue &amp; returnStr[self.TEXTBOX_VALUE_HOLDER.length + 1 : end];
		elseif posValue = strLength then
			returnStr := returnStr[1 : strLength - self.TEXTBOX_VALUE_HOLDER.length] &amp; newValue;
		else
			returnStr := returnStr[1 : posValue - 1] &amp; newValue &amp; returnStr[posValue + self.TEXTBOX_VALUE_HOLDER.length : end];
		endif;

		posValue := returnStr.pos(self.TEXTBOX_VALUE_HOLDER, 1);
	endwhile;

	return returnStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getControl" id="7b88b681-3cbd-41fc-95e3-01ec1d161884">
        <source>getControl(pControlName : String) : Control;

vars
	theControl		: Control;
	controlPointer	: Integer;
	
begin
	if pControlName.length = 0 then
		return null;
	endif;

	foreach controlPointer in 1 to aMyForm.controlCount do
		theControl := aMyForm.controls(controlPointer);
		
		if theControl.name = pControlName then
			return theControl;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="pControlName" type="String"/>
        <ReturnType type="Control"/>
    </JadeMethod>
    <JadeMethod name="getControls" id="53fdf939-1915-46e9-896d-22427afdd59c">
        <updating/>
        <source>getControls() updating;

vars
	controlPointer	: Integer;
	ctrl	: Control;
begin
	if not app.isValidObject(aMyForm) then	// you've jumped to another form
		aMyForm := null;
		aMyControl := null;
		return;
	endif;

	if not app.isValidObject(aMyControl) or aMyControl = null or aMyActivity.controlName &lt;&gt; aMyControl.name then
		aMyControl := null;
	endif;
	if not app.isValidObject(aMyControlAfter) or aMyControlAfter = null or aMyActivity.afterControlName &lt;&gt; aMyControlAfter.name then
		aMyControlAfter := null;
	endif;

	foreach controlPointer in 1 to aMyForm.controlCount do
		ctrl := aMyForm.controls(controlPointer);
		
		if aMyControl = null and ctrl.name = aMyActivity.controlName then
			aMyControl := ctrl;
		endif;
		
		if aMyControlAfter = null and ctrl.name = aMyActivity.afterControlName then
			aMyControlAfter := ctrl;
		endif;

		if (aMyActivity.controlName.length = 0 or aMyControl &lt;&gt; null) and (aMyActivity.afterControlName.length = 0 or aMyControlAfter &lt;&gt; null) then
			// we've found both controls
			break;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="getForm" id="57f29337-bf91-42fa-aa54-aa7add1f014f">
        <source>getForm(pFormName : String; pIsReturnFirst : Boolean) : Form;

//	If returnFirst is TRUE, returns the first occurance of a form with the name myName 
//	&gt;&gt;&gt; this is to find a form with this name - see closeForm
//	If returnFirst is FALSE, returns the first occurance of a form with the name myName if there is another copy 
//	&gt;&gt;&gt; this is to find if there is another version of self running - see loadForm

vars
	theForm			: Form;
	theHeldForm		: Form;
	index			: Integer;
	firstIgnored	: Boolean;

begin
	firstIgnored := pIsReturnFirst;

	foreach index in 1 to app.formsCount() do
		theForm := app.forms(index);
		
		if theForm.name = pFormName then
			theHeldForm := theForm;

			if firstIgnored then
				return theHeldForm;
			endif;
			
			firstIgnored := true;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="pFormName" type="String"/>
        <Parameter name="pIsReturnFirst" type="Boolean"/>
        <ReturnType type="Form"/>
    </JadeMethod>
    <JadeMethod name="getLessonByFormName" id="46350977-95b4-4340-a3df-8529971b2879">
        <updating/>
        <source>getLessonByFormName() updating;

vars
	theLesson	: CnEcTLesson;
	lessons		: ObjectSet;
	object		: Object;
	ctrl		: Control;
begin
	create lessons transient;

	foreach theLesson in app.myBaseRoot.allTLessons do
		if theLesson.formName = self.aMyForm.name then
			lessons.add(theLesson);
		endif;
	endforeach;

	if lessons.size() &lt;= 0 then
		self.doClearGraphics();
		unloadForm();
		return;
	endif;

	if lessons.size() = 1 then
		self.aMyLesson := lessons.first().CnEcTLesson;
		self.displayLesson();

	elseif lessons.size() &gt; 1 then
		lstLessons.clear();
		
		foreach object in lessons do
        	lstLessons.itemObject[lstLessons.addItem(object.CnEcTLesson.name)] := object.CnEcTLesson;
        endforeach;

		ctrl := null;
		lblCaption.caption := "Choose a lesson";
		btnDoIt1.enabled := false;
		btnEndIt1.enabled := false;
		self.positionWizard(ctrl);

		self.toggleMode(self.MODE_LIST);
	endif;
epilog
	delete lessons;
end;</source>
    </JadeMethod>
    <JadeMethod name="getLessonByName" id="c2e51425-5b61-4ed8-b2ef-f43190c3ce10">
        <source>getLessonByName(pName : String) : CnEcTLesson;

vars
	theLesson	: CnEcTLesson;

begin
	foreach theLesson in app.myBaseRoot.allTLessons do
		if theLesson.getName() = pName then
			return theLesson;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="CnEcTLesson"/>
    </JadeMethod>
    <JadeMethod name="getNextActivity" id="f68e132d-0181-46c9-ac57-3820586dff2e">
        <updating/>
        <source>getNextActivity() updating;

begin
	if self.aSequence &gt; 0 then
		btnBack.enabled := true;
	else
		btnBack.enabled := false;
	endif;	

	self.aMyActivity := self.aMyLesson.getNextActivity(self.aSequence);

	if aMyActivity = null then	// end of lesson
		self.aSequence := self.aMyLesson.allActivities.size() + 1;	// make sure of end of lesson
		self.closeForm();
		return;
 	endif;

	lblCaption.caption := self.aSequence.String &amp; ". " &amp; self.aMyActivity.name;

	self.toggleMode(self.MODE_TEXT);
	picRight.visible := true;

	self.getControls();

	if self.aMyActivity.text.length = 0 then	// no action - do afterAction
		self.displayResult();

	elseif (self.aMyControl = null)
	or (not self.aMyControl.visible)
	or (not self.aMyControl.enabled and self.aMyActivity.action.length &gt; 0)
	then
//			control not present, 	or not visible			or not enabled and there's an action for it
//			... then there's an error
		self.handleMissingControlOrForm(self.aMyActivity, self.aMyControl, self.aMyActivity.controlName);

// 			control is ok
	else
		self.writeScriptFileServer("... Activity: " &amp; self.aSequence.String &amp; " " &amp; self.aMyActivity.name);
		txtText.text := self.getActivityText();
		self.setDoItCaption(false);
		self.aIsAbortLesson := false;
		self.positionWizard(self.aMyControl);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="handleMissingControlOrForm" id="bb0bcb2e-2eea-440b-a92f-704da4766052">
        <updating/>
        <source>handleMissingControlOrForm(pActivity : CnEcTActivity; pTheControl : Control; pControlName : String) updating;

// handle case when something is not right - form or control missing or not available

vars
	theControl	: Control;

begin
	theControl := null;	// theControl is passed to positionWizard... null means centre on form - is set later

	// handle wrong form
	if self.aMyForm = null then
		txtText.text := "The form I need is not currently displayed.";
		self.aIsAbortLesson := true;
		self.writeScriptFileServer("### Activity error: " &amp; self.aSequence.String &amp; " " &amp; pActivity.name &amp; " : Form " &amp; pActivity.myLesson.formName &amp; " is not displayed (form changed?)");

	// handle wrong control
	else
		txtText.text := "The control I need is not currently ";

		if pTheControl = null then
			self.aIsAbortLesson := true;
			writeScriptFileServer("### Activity error: " &amp; self.aSequence.String &amp; " " &amp; pActivity.name &amp; " : control " &amp; pControlName &amp; " not found on this form");
		else
			if not pTheControl.visible then
				txtText.text := txtText.text &amp; "visible";
				self.writeScriptFileServer("### Activity: " &amp; self.aSequence.String &amp; " " &amp; pActivity.name &amp; " control " &amp; pControlName &amp; " not visible");
				theControl := null;
			else
				txtText.text := txtText.text &amp; "enabled";
				self.writeScriptFileServer("### Activity: " &amp; self.aSequence.String &amp; " " &amp; pActivity.name &amp; " control " &amp; pControlName &amp; " not enabled");
				theControl := pTheControl;	// will point to it if not enabled
			endif;

			self.aIsAbortLesson := pActivity.onErrorStop;
		endif;
		
		txtText.text := txtText.text &amp; " on this form. ";
	endif;

	if aIsAbortLesson then
		self.aMyControl := null;
		btnDoIt1.caption := self.FINISH;
		txtText.text := txtText.text &amp; "I need to terminate this lesson.";
		txtTextAction.text := "Click '" &amp; btnDoIt1.caption &amp; "' to finish.";

		theControl := null;

	else
		// leave control not null so that you can continue
		if pActivity.onErrorDoAction then
			txtText.text := txtText.text &amp; "Do you want to carry on anyway?";
			btnDoIt1.caption := self.DO_IT;
		else
			txtText.text := txtText.text &amp; "Do you want to go to the next step in this lesson?";
			btnDoIt1.caption := self.NEXT;
		endif;

		if pActivity.errorText.length &gt; 0 then	// override these messages with error text
			txtText.text := pActivity.errorText;
		endif;

		txtTextAction.text := "Click '" &amp; btnDoIt1.caption &amp; "' to continue.";
	endif;

	self.positionWizard(theControl);		// want to position on the form only

	btnDoIt1.setFocus();
end;</source>
        <Parameter name="pActivity" type="CnEcTActivity"/>
        <Parameter name="pTheControl" type="Control"/>
        <Parameter name="pControlName" type="String"/>
    </JadeMethod>
