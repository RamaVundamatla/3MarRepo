    <JadeMethod name="getEDIDataFromDataType" id="06164a8b-b264-455a-b975-53dcb7f460af">
        <source>getEDIDataFromDataType(_ediDataType : Integer; _theFoundEDIData: CM_EDIData output): Boolean;
//----------------------------------------------------------------
//	Created:	06 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	foundEDIData	: CM_EDIData;
begin
	foundEDIData := self.allEDIDatasByTypeNumber.getAtKeyGeq(_ediDataType, null);
//write foundEDIData.String&amp;' '&amp;foundEDIData.number.String&amp;' '&amp;_ediDataType.String;
	// par19403 cnwrs1 Apr 2009 
	if foundEDIData &lt;&gt; null and
	   foundEDIData.ediDataType &lt;&gt; _ediDataType then
		_theFoundEDIData := null;
		return false;
	endif;
	//there is only one of these per ediConfig - so if the type is OK - it must be right
	//par 18508
	if CM_EDIDataCustomStop.hasInstance(foundEDIData) then
		_theFoundEDIData := foundEDIData;
		return true;
	elseif CM_EDIDataOperatorStop.hasInstance(foundEDIData) then
		_theFoundEDIData := foundEDIData;
		return true;
	endif;
	
	_theFoundEDIData := null;
	return false;
	
end;</source>
        <Parameter name="_ediDataType" type="Integer"/>
        <Parameter name="_theFoundEDIData" type="CM_EDIData" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
