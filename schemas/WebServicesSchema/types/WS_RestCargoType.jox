    <JadeMethod name="delete" id="054ad92b-80c3-4388-82f9-fe64949585b5">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2024	jlier1	Initial creation

*/

vars

begin
	self.cargoSubtypes.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="9e6b19ad-b633-427f-8d57-9b0b50ad0053">
        <updating/>
        <source>setProxyFromObject(_object : CM_CargoType; _includeCargoSubTypes, _includeAttributes : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
03 April 2024		jlier1	Initial creation 63022
19 August 2024		navpw1	TFS: 65674 (65675) Addded new parameter to allow the inclusion or exclusion of cargo sub types from the response
06 September 2024	jlizm1	TFS 65952 NSW Dynamics Integration - ISO Type Group and Cargo Type external references

*/

vars
	product			: CM_Product;
	wsCargoSubtype	: WS_RestCargoSubType;
	
begin
	self.id:=_object.id.asStringJMT;
	self.abbreviation:=_object.abbreviation;
	self.description:=_object.description;
	self.allowDuplicates:=_object.allowDuplicates;
	self.canWeightBeCertified:=_object.canWeightBeCertified;
	self.commodityRequired:=_object.isCommodityRequired;
	if _object.myDefaultHandlingType &lt;&gt; null then
		self.defaultHandlingType:=_object.myDefaultHandlingType.id;
	endif;
	self.externalReference := _object.externalReference;
	self.measureType :=_object.trackByMeasureType;
	self.reefer:=_object.isReefer;
	self.showCargoTareWeight:=_object.useTareCargoWeight;
	self.showDamageCodes:=_object.showDamageCodes;
	self.trackAs     		  := _object.productType;	 
	if self.trackAs = ProductType_PieceBreakBulk then
		self.trackAs := ProductType_BreakBulk;
	endif;
	
	if _object.isBulkByWeight then
		if _object.myWeightMeasurementType &lt;&gt; null then
			self.defaultWeightMeasurementId := _object.myWeightMeasurementType.shortName;
		endif;
	elseif _object.isBulkByVolume then		
		if _object.myVolumeMeasurementType &lt;&gt; null then
			self.defaultVolumeMeasurementId := _object.myVolumeMeasurementType.shortName;
		endif;
	endif;
	
	if not _includeCargoSubTypes then
		return;
	endif;
	
	foreach product in _object.allProducts where not product.isNotActive do
		create wsCargoSubtype transient;
		wsCargoSubtype.setProxyFromObject(product, _includeAttributes);
		self.cargoSubtypes.add(wsCargoSubtype);
	endforeach;
epilog

end;</source>
        <Parameter name="_object" type="CM_CargoType"/>
        <Parameter name="_includeCargoSubTypes" type="Boolean"/>
        <Parameter name="_includeAttributes" type="Boolean"/>
    </JadeMethod>
</Class>
