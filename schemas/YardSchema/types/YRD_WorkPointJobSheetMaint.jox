    <JadeMethod name="setupForm" id="7b21b3d8-7d36-4178-89b6-7d2b180f56e1">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2023 navma1  ChangeRequest 57766: EUP - Delivery Dispatch – Define Job Sheet
13 June 2023 navhl20 Defect 58611: MTN - 1090 Exception when defining a job sheet without entering Shift
*/

vars

begin
	inheritMethod();

	if self.myPxyWorkPointJobSheet &lt;&gt; null then
		self.setMode(self.Mode_Update);
	else
		create self.myPxyWorkPointJobSheet transient;
		self.setMode(self.Mode_Add);
	endif;

	/*Load Combos*/
	self.loadCmbWorkPointType();
	self.loadCmbWorkPoint();
	self.loadCmbShifts(null);									//13.6.2023 navhl20 #58611
	
	if self.myPxyWorkPointJobSheet &lt;&gt; null then
		self.populateWorkPointJobSheet();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="93ce9444-312c-41e6-9328-bd3f624e217e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 14 June 2023 08:49:13.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026047, locale);
	btnDelete.translateCaption(Xlat_0026048, locale);
	grpJobSheet.translateCaption(Xlat_0026049, locale);
	lblDateFrom.translateCaption(Xlat_0026050, locale);
	lblDateTo.translateCaption(Xlat_0026051, locale);
	lblExternalName.translateCaption(Xlat_0026052, locale);
	lblExternalRef1.translateCaption(Xlat_0026053, locale);
	lblExternalRef2.translateCaption(Xlat_0026054, locale);
	lblExternalRef3.translateCaption(Xlat_0026102, locale);
	lblShift.translateCaption(Xlat_0026055, locale);
	lblWorkPoint.translateCaption(Xlat_0026056, locale);
	lblWorkPointType.translateCaption(Xlat_0026057, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unloadForm" id="2600e6e5-75aa-49aa-904f-5e1b98f88fe5">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>unloadForm(): Boolean updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2023	navhl20	ChangeRequest 57766:[57767] EUP - Delivery Dispatch – Define Job Sheet

*/

vars

begin
	if self.myPxyWorkPointJobSheet &lt;&gt; null then
		delete self.myPxyWorkPointJobSheet;
	endif;
	self.allShiftsDays.purge;
	
	return inheritMethod();
epilog

end;</source>
