	endif;
	
	if self.myVehicleBooking = null then
		return false;
	endif;

	create jsonLoadNotification transient;
	jsonLoadNotification.setFromVehicleBooking(self.myVehicleBooking);

	//return self.sendMessage(jsonLoadNotification.getJSON, "TransportCreation" ,ETRow_LoadNotification);				// MTN-36569
	return self.sendMessage(jsonLoadNotification.getJSON, "TransportCreation" ,ETRow_LoadNotification, null, null);	// MTN-36569
	
epilog
	delete jsonLoadNotification;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendMessage" id="4cec8774-ac54-4dc2-a6bf-0b8084e2f92b">
        <updating/>
        <source>sendMessage(	_json : String; 
				_transformType : String; 
				_type : String;
				_extraPathParameters : String;
				_extraQueryParameters : StringArray	) : Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Jul 2023	jlier1	Initial creation 58840
04 Feb 2025 naviv1  JIRA-12173 : MTN - JSON CAM Protocol and APIConsumerAgent hard codes EUP as the customer
21 Nov 2025	navdap1	MTN-36569 CPL | Reefer Runner Integration
*/

vars
	apiMapper			: CMIF_ApiMapper;
	verb,
	endpoint,
	jsonPostData,
	errors,
	url,
	resultString	: String;
	resultCode : Integer;
	pathParam : String;		// MTN-36569
	queryParam : String;	// MTN-36569
begin
	if _json = null and _extraPathParameters = null then	// MTN-36569
		return false;
	endif;
	
	// MTN-36569 moved this above the transform call so we can pass the actual verb into the transform
	self.myWebServiceDefinition.getEndpointMethodAndValue(_type, verb, endpoint);
	if verb = null or endpoint = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No verb or endpoint set up for " &amp; _type &amp; " messages", LogERROR);
		app.doRaiseAlert( self.myWebServiceDefinition.name &amp; " is not set up correctly for " &amp; _type &amp; " messages");
		return false;
	endif;
	
	create apiMapper transient;
	//jsonPostData := apiMapper.transformOutgoingMessage(self.myWebServiceDefinition.CM_APIEndpointServiceDef.getCustomer(),_transformType,_json,JadeHTTPConnection.Verb_POST,errors);			// MTN-36569
	jsonPostData := apiMapper.transformOutgoingMessage(self.myWebServiceDefinition.CM_APIEndpointServiceDef.getCustomer(), _transformType, _json, verb, errors); //04-Feb-2025 naviv1 #12173	// MTN-36569
	if errors &lt;&gt; null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Error transforming " &amp; _type &amp; " message" &amp; CrLf &amp; errors, LogERROR);
	endif;
	
	app.writeLog(method.qualifiedName &amp; Tab &amp; _type &amp; " message after transform:"&amp;jsonPostData, LogDEBUG);
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Sending ", LogDEBUG);
	
	// now build the URL, including any extra path and query parameters
	url :=	 self.myWebServiceDefinition.baseEndpoint;
	if url[url.length:1] &lt;&gt; "/" then
		url := url &amp; "/";
	endif;
	url := url &amp; endpoint;		
	// MTN-36569 Append extra path and parameter data if we have any
	if _extraPathParameters &lt;&gt; null then
		pathParam := _extraPathParameters;
		//pathParam := pathParam.replaceCharsWithHTML();
		url := url &amp; "/" &amp; pathParam;
	endif;
	if _extraQueryParameters &lt;&gt; null and _extraQueryParameters.isNotEmpty then
		//foreach queryStr in _extraQueryParameters do
		//	queryStr := queryStr.replaceCharsWithHTML();
		//	queryParam := queryParam &amp; queryStr &amp; "&amp;";
		//endforeach;
		queryParam := _extraQueryParameters.concatenate("&amp;");
		url := url &amp; "?" &amp; queryParam;
	endif;

	resultString := self.doSendHTTPRequest(url, verb, self.getAdditionalHeadersForHTTP(), jsonPostData, resultCode);	

	if resultCode = HttpResponseNoContent then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "NODATA: Response from " &amp; _type &amp; " App was " &amp; resultCode.String &amp; ":" &amp; resultString, LogERROR);
		
	elseif resultCode &lt;&gt; HttpResponseOK and resultCode &lt;&gt; HttpResponseCreated then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "FAILED: Response from " &amp; _type &amp; " App was " &amp; resultCode.String &amp; ":" &amp; resultString, LogERROR);
		
	elseif resultCode = HttpResponseOK or resultCode = HttpResponseCreated then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "SUCCESS: Response from " &amp; _type &amp; " App was " &amp; resultCode.String &amp; ":" &amp; resultString, LogDEBUG);
	endif;
	return true;	
epilog
	delete apiMapper;
end;</source>
        <access>protected</access>
        <Parameter name="_json" type="String"/>
        <Parameter name="_transformType" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_extraPathParameters" type="String"/>
        <Parameter name="_extraQueryParameters" type="StringArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendOnePortStatusRequest" id="4c7a7636-df95-447a-a4ac-de069b3d8d78">
        <updating/>
        <source>sendOnePortStatusRequest(_extDef : CM_ExternalWebServiceDef) : String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//17/11/2025	navkc1 JIRA 36176 NSW | OnePort API - Change voyage creation criteria DB / UI / Process changes

*/

vars
verb,
	type,
	endpoint,
	jsonPostData,
	url,
	resultString	: String;
	resultCode 		: Integer;
	pxyActivity 		: CM_EWSActivityQships;
	activity			: CM_EWSActivityQships;
	extDef			: CM_ExternalWebServiceDef;
begin

	self.createActivityHistory := false;
	extDef := _extDef;
	
	url :=	 extDef.baseEndpoint;
	if url[url.length:1] &lt;&gt; "/" then
		url := url &amp; "/";
	endif;

	verb	:= "GET";
	endpoint := "nswp/Status";
	url 	:= url &amp; endpoint;
	
	type 	:= ETRow_NswVesselMovements;
	resultString := self.doSendHTTPRequest(url, verb, self.getAdditionalHeadersForHTTP(), jsonPostData, resultCode);	
	
	//Record the activity
	create pxyActivity transient;		
	pxyActivity.initialiseActivity(endpoint, extDef.getExternalWebServiceType(), self.myTerminal, null, "G", QshipsInterface.name, null, null);
	pxyActivity.setRequest(url);
	pxyActivity.setMyExtWebServiceDef(extDef);
	
	if process.isInTransactionState then
		activity := app.myUtilityCA.utlCreateEWSActivityHistory(pxyActivity,app.myPassport).CM_EWSActivityQships;
	else
		activity := app.myTrxCA.trxCreateEWSActivityHistory(pxyActivity,app.myPassport).CM_EWSActivityQships;
	endif;
	
	delete pxyActivity;
	
	if resultCode = HttpResponseNoContent then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "NODATA: Response from " &amp; type &amp; " App was " &amp; resultCode.String &amp; ": " &amp; resultString, LogERROR);
		
	elseif not resultCode.isOneOf(HttpResponseOK, HttpResponseCreated) then
		app.writeLog(method.qualifiedName &amp; "[" &amp; verb &amp; "] " &amp; url, LogINFO);
		app.writeLog(method.qualifiedName &amp; Tab &amp; "FAILED: Response from " &amp; type &amp; " App was " &amp; resultCode.String &amp; ": " &amp; resultString, LogERROR);
		
		//Record the activity
		pxyActivity := app.createUpdateProxy(activity).CM_EWSActivityQships;		
		pxyActivity.initialiseActivity("VesselMovementsNSWPorts Request failed", extDef.getExternalWebServiceType(), self.getMyTerminal(), null, "G", QshipsInterface.name, null, null);
		pxyActivity.setResponse(resultString);
		pxyActivity.setResponseCode(resultCode);
		pxyActivity.setProxyStatus(BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_FAILURE);
		pxyActivity.setMyExtWebServiceDef(extDef);
		if process.isInTransactionState then
			app.myUtilityUA.utlUpdateEWSActivity(pxyActivity, app.myPassport);
		else
			app.myTrxUA.trxUpdateEWSActivity(pxyActivity,app.myPassport);
		endif;
		delete pxyActivity;
		
	elseif resultCode = HttpResponseOK or resultCode = HttpResponseCreated then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "SUCCESS: Response from " &amp; type &amp; " App was " &amp; resultCode.String &amp; ": " &amp; resultString, LogDEBUG);
		
		//Record the activity
		pxyActivity := app.createUpdateProxy(activity).CM_EWSActivityQships;		
		pxyActivity.initialiseActivity("VesselMovementsNSWPorts Request successful", extDef.getExternalWebServiceType(), self.getMyTerminal(), null, "G", QshipsInterface.name, null, null);
		pxyActivity.setResponse(resultString);
		pxyActivity.setResponseCode(resultCode);
		pxyActivity.setProxyStatus(BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_SUCCESS);
		pxyActivity.setMyExtWebServiceDef(extDef);
		if process.isInTransactionState then
			app.myUtilityUA.utlUpdateEWSActivity(pxyActivity, app.myPassport);
		else
			app.myTrxUA.trxUpdateEWSActivity(pxyActivity,app.myPassport);
		endif;
		delete pxyActivity;
	endif;
	
	return resultString;
epilog
	delete pxyActivity;
end;</source>
        <Parameter name="_extDef" type="CM_ExternalWebServiceDef"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="sendOnePortVesselDetails" id="1132a089-014c-4f33-9543-90cc4fc3ca8e">
        <updating/>
        <source>sendOnePortVesselDetails(	_webService : CM_APIEndpointServiceDef; 
							_type : String; 
							_imo :String; 
							_terminal : CM_Terminal	): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Jul 2024	navsp1	Initial creation TFS ChangeRequest 63842: NSW | OnePort Integration Dev
09 Sep 2024	navdap1	TFS 66034 NSW OnePort Integration Post-Dev Demo Issues - correct activity details
*/
vars
	verb,
	endpoint,
	jsonPostData,
	url,
	resultString	: String;
	resultCode 		: Integer;
	pxyActivity 		: CM_EWSActivityQships;
	activity			: CM_EWSActivityQships;
begin
	
	url :=	 _webService.baseEndpoint;
	if url[url.length:1] &lt;&gt; "/" then
		url := url &amp; "/";
	endif;
	
	_webService.getEndpointMethodAndValue(_type, verb, endpoint);
	if verb = null or endpoint = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No verb or endpoint set up for " &amp; _type &amp; " messages", LogERROR);
		app.doRaiseAlert( _webService.name &amp; " is not set up correctly for " &amp; _type &amp; " messages");
		return resultString;
	endif;
	url := url &amp;"nswp/"&amp; endpoint &amp; "?IMO=" &amp; _imo;	
	
	resultString := self.doSendHTTPRequest(url, verb, self.getAdditionalHeadersForHTTP(), jsonPostData, resultCode);	
	
	//Record the activity
	create pxyActivity transient;		
	pxyActivity.initialiseActivity("NSWPCurrentVesselDetails Request", _webService.name, _terminal, null, "G", QshipsInterface.name, null, null);
	pxyActivity.setRequest(url);
	if process.isInTransactionState then
		activity := app.myUtilityCA.utlCreateEWSActivityHistory(pxyActivity,app.myPassport).CM_EWSActivityQships;
	else
		activity := app.myTrxCA.trxCreateEWSActivityHistory(pxyActivity,app.myPassport).CM_EWSActivityQships;
	endif;
	delete pxyActivity;
	
	if resultCode = HttpResponseNoContent then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "NODATA: Response from " &amp; _type &amp; " App was " &amp; resultCode.String &amp; ":" &amp; resultString, LogERROR);
		
	elseif resultCode &lt;&gt; HttpResponseOK and resultCode &lt;&gt; HttpResponseCreated then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "FAILED: Response from " &amp; _type &amp; " App was " &amp; resultCode.String &amp; ":" &amp; resultString, LogERROR);
		
		//Record the activity
		pxyActivity := app.createUpdateProxy(activity).CM_EWSActivityQships;
		pxyActivity.initialiseActivity("NSWPCurrentVesselDetails Request failed", _webService.name, _terminal, null, "G", QshipsInterface.name, null, null);
		pxyActivity.setResponse(resultString);
		pxyActivity.setResponseCode(resultCode);
		pxyActivity.setProxyStatus(BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_FAILURE);
		if process.isInTransactionState then
			app.myUtilityUA.utlUpdateEWSActivity(pxyActivity,app.myPassport);
		else
			app.myTrxUA.trxUpdateEWSActivity(pxyActivity,app.myPassport);
		endif;
		delete pxyActivity;
		
	elseif resultCode = HttpResponseOK or resultCode = HttpResponseCreated then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "SUCCESS: Response from " &amp; _type &amp; " App was " &amp; resultCode.String &amp; ":" &amp; resultString, LogDEBUG);
		
		//Record the activity
		pxyActivity := app.createUpdateProxy(activity).CM_EWSActivityQships;
		pxyActivity.initialiseActivity("NSWPCurrentVesselDetails Request Successful", _webService.name, _terminal, null, "G", QshipsInterface.name, null, null);
		pxyActivity.setResponse(resultString);
		pxyActivity.setResponseCode(resultCode);
		pxyActivity.setProxyStatus(BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_SUCCESS);
		if process.isInTransactionState then
			app.myUtilityUA.utlUpdateEWSActivity(pxyActivity,app.myPassport);
		else
			app.myTrxUA.trxUpdateEWSActivity(pxyActivity,app.myPassport);
		endif;
		delete pxyActivity;
	endif;
	
	return resultString;
epilog
	delete pxyActivity;
end;</source>
        <Parameter name="_webService" type="CM_APIEndpointServiceDef"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_imo" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
