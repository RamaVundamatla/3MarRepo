    <JadeMethod name="initShtMultiSelect" id="986e3d0e-4cb7-4653-b2a9-31c20678b064">
        <source>initShtMultiSelect();
// ---------------------------------------------------------------------------
// Created:     23 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
/* Changes

Date		Name	TFS#			Description
============================================================================
18/05/2011	cnwcs5	CCMS SCT 2058 
					/ par 27460 	user defined special charac	ters
15 May 2014	cnwrs1	Par 34159 		include Chassis in Codeco
15 Mar 2019	jlgka1  TFS 41641		SSL - X12 322 Equipment ID Check.
24 Apr 2019 jlgka1	TFS 43785		STWR - Add Produce Codeco for Non Structured Voyage Flag.
21 Jun 2023	navdap1	TFS 56747		EUP Manifest Load - Internal (Zimmer) - Create
05 Jul 2023	jlika1	TFS 58636		EUP - Goods Receipt - Move Transaction area triggers
27 Aug 2023	jlizm1	TFS 59551 		Kiosk Additional Question
01 Aug 2025 navsp1  JIRA-35530 Solution Implementation - COPRAR Trailer Support
============================================================================*/
vars
	form 					: SOP_TableMaintForm;
	localTxtEmailName 		: CMUI_TextBox;
	localTxtEmailAddress 	: CMUI_TextBox;
	localButton 			: CMUI_Button;
begin
	form 						:= self.myForm;
	form.lblName.visible		:= false;
	form.txtName.visible		:= false;
	form.optAllow.visible		:= false;
	form.optDisallow.visible	:= false;
	form.cmbCargoBOLType.visible := false;
	form.cmbCargoType2.visible	 := false;
	form.cmbCargoType2.clear;
	form.btnTransactionFilter.visible := false;
	form.cmbBOLType.visible 	:= false;
	form.cmbCargoGroup.visible	:= false;		// TFS 56747
    form.cmbTrailerCargoType.visible    := false;       //JIRA-35530
	form.cmbOperator.visible 	:= false;
	form.lblName1.visible 		:= false;
	form.lblName2.visible 		:= false;
	form.lblName3.visible 		:= false;
	form.lblName4.visible 		:= false;
	form.lblName5.visible 		:= false;		// TFS 56747
    form.lblName6.visible 		:= false;       //JIRA-35530
	form.btnSetDefault1.visible := false;
	form.btnSetDefault2.visible := false;
	form.comboBox1.visible 		:= false;

	form.chkNonPlanned.visible 	:= false;
// PAR 33644	form.chkNonWorked.visible 	:= false;
	form.chkNullVoyage.visible 	:= false;
	form.chkPandoRInUnPck.visible 	:= false;
	form.chkPandoSntPack.visible 	:= false;
	form.chkRequestedInfo.visible 	:= false;
	form.chkPonOperator.visible 	:= false;
	form.chkFullsOnly.visible 	:= false;
	form.chkMTsOnly.visible 	:= false;
	form.chkMSCForNZPOE.visible := false; //CCMS11491
	form.chkDaysLookBack.visible 	:= false; //CCMS1526
	form.chkTempFormat.visible := false; //par16227 cnwrs1 Mar 2008
	form.chkEDIXlatCtn.visible	:= false;	// cnwrl1 06/07/2009 PAR 20192 - CCMS 1818
	form.chkIncludeChild.visible	:=	false;	// cnwdad1 26/01/2010 - PAR #22199.
	form.chkCliRefBooking.visible := false; // cnwrd par 34369
	
	form.chkSendCarrier.visible		:= false;	// par 27460 cnwcs5
	form.chkUseCarrierRef.visible	:= false;	// par 27460 cnwcs5
	form.lblDelayMins.visible	:= false;	//08 Sep 2015	NDL	Par 36876
	form.txtDelayMins.visible	:= false;	//08 Sep 2015	NDL	Par 36876
	
	form.chkRelaxedIdChecking.visible	:= false;	// jlgka1 TFS 41641
	form.chkUseCodecoNonStruc.visible	:= false;	// jlgka1 TFS 43785
	form.chkDGSDetailsInGroup14.visible	:= false;	//JIRA-20814
	
	form.btnShowSearchMsg.visible := false;
	form.shtTreeViewMulti.visible := false;
	form.shtMultiSelect1.visible := false;
    form.shtMultiSelect2.visible := false;
	form.shtMultiSelect3.visible := false;
    form.shtMultiSelect4.visible := false;
	form.shtMultiSelect6.visible := false;
	form.shtMultiSelect7.visible := false;	// PAR 21905 CCMS MES 1008 - PHB
	form.shtMultiSelect8.visible := false;
    form.mulSelect41.stretchHeight := true;
   	form.shtMultiSelect5.visible := false;
	form.mulSelect1.resetButtonsVisible;
	form.mulSelect2.resetButtonsVisible;
	form.mulSelect3.resetButtonsVisible;
	form.mulSelect6.resetButtonsVisible;
	form.mulSelect7.resetButtonsVisible;		// PAR 21905 CCMS MES 1008 - PHB
	form.mulSelect8.resetButtonsVisible;		
	form.mulSelect41.resetButtonsVisible;
	form.mulSelect42.resetButtonsVisible;
	form.mulSelect42.visible:=false;
   	form.shtMultiAlign.visible 	:= false;
	form.sheetAddress.visible := false;
	
	form.shtSingleSelect1.visible := false;
	form.lstSingleSelect1.parent := form.shtSingleSelect1; //ccms1824 cnwrs1 may 2009
	form.lstSingleSelect1.visible :=false;
	form.lstSingleSelect1.hasTreeLines:=false;
	form.lstSingleSelect1.hasPlusMinus:=false;
	form.frmTBSingle.parent := form.shtSingleSelect1; //ccms1824 cnwrs1 may 2009
	form.frmTBSingle.setToolbarControlsEnabled(false);
	form.btnSingle1Edit.visible:=true;
	form.btnSingle1Delete.visible:=true;
	form.btnSingle1New.visible:=true;
	form.btnSingle1Down.visible:=false;
	form.btnSingle1Up.visible:=false;
	
	form.btnSingle1Down.visible:=false;
	form.btnSingle1Up.visible:=false;  //epr 5/9/07 ccms 1071
    form.shtSingleSelect2.visible := false; //epr 5/9/07 ccms 1071
	form.shtTblInput3.visible	:= false;
	form.btnAddNew.visible 	:= false;
	form.txtEmailName.visible	:= false;
	form.lblEmailAddress.visible	:= false;
	form.lblEmailName.visible	:= false;
	
	form.shtSingleSelect3.visible 	:= false;
	form.lstSingleSelect3.parent 	:= form.shtSingleSelect3;
	form.lstSingleSelect3.visible 	:= false;
	form.lstSingleSelect3.hasTreeLines	:= false;
	form.lstSingleSelect3.hasPlusMinus	:= false;
	form.frmTBSingle3.parent := form.shtSingleSelect3;
	form.frmTBSingle3.setToolbarControlsEnabled(false);
	form.btnSingle3Edit.visible		:= true;
	form.btnSingle3Delete.visible	:= true;
	form.btnSingle3New.visible		:= true;
	form.btnSingle3Down.visible		:= false;
	form.btnSingle3Up.visible		:= false;
	
	//10/03/2010 cnwdz2 22830
	localTxtEmailName := form.txtEmailName.getControl(2);
	if localTxtEmailName &lt;&gt; null then
		localTxtEmailName.visible := false;
	endif;
	//10/03/2010 cnwdz2 22830	
	localTxtEmailAddress := form.txtName.getControl(2);
