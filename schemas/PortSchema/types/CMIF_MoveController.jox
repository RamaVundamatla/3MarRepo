epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTruckReceiveReLoad" id="740b4555-fd66-4dd3-907c-4fef8e4df7ca">
        <source>isTruckReceiveReLoad() : Boolean;
/*

Date		Who		Reason
27 April 2016	cnwer1	Initial creation TFS 1842

*/

vars

begin
	if self.myWorkListEntry &lt;&gt; null and self.myWorkListEntry.status = WLE_COMPLETED then
		if self.myToPrimaryLocation &lt;&gt; null
		and self.myToPrimaryLocation.isVehicle
		and self.myToPrimaryLocation.getFullId = self.myWorkListEntry.locationSource
		then
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidDebtorRelease" id="604cc3be-9b3b-4e36-9458-b0f07228533a">
        <source>isValidDebtorRelease(_intArray : IntegerArray): Boolean protected;
//----------------------------------------------------------------
//	Created:	23 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*
PAR 23816 - RJS   20 April 2010
 - change to check if we have a release transaction.  Error was caused when moving direct from
   an IMV to the vessel.  Could have added check for fromLocn below being a CM_MachineController
   but decided to fix so consistent with the create of a release transaction

*/
vars
//	fromLC, toLC	: CM_LocationsController;
//	yc				: CM_YardController;
	txnType		: Integer;
	isRelease	: Boolean;
begin

	foreach txnType in _intArray do
		if app.isReleaseTypeTransaction(txnType) then
			isRelease := true;
			break;
		endif;
	endforeach;
	
	return isRelease;
	
/*	
	fromLC := self.myOriginatingLocation;
	toLC:= self.myToPrimaryLocation;
	
	if fromLC = null then
		return false;
	endif;
		
	if toLC = null then
		if CM_VehicleController.hasInstance(fromLC) or
		CM_WagonController.hasInstance(fromLC) then
			//road, rail release
			return true;
		endif;
		
		if CM_YardController.hasInstance(fromLC) then
			yc := fromLC.CM_YardController;
			if yc.myTerminalArea &lt;&gt; null and
	   		yc.myTerminalArea.type = TA_TYPE_RELTRANS then
				//3rd party rel
				return true;
			endif;
		endif;
	else
		if CM_VoyageController.hasInstance(toLC) and
		CM_YardController.hasInstance(fromLC) then
			//ship release
			return true;
		endif;
	endif;
	
	//other moves are not of interest
	return false;
*/
	
end;</source>
        <access>protected</access>
        <Parameter name="_intArray" type="IntegerArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWagonMove" id="c0f67a86-470d-4861-9d9a-f2858721066a">
        <source>isWagonMove() : Boolean;
// ---------------------------------------------------------------------------
// Created:     18 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myToPrimaryLocation = null then
		return false;
	endif;
	
	if not self.myToPrimaryLocation.isWagon() then
		return false;
	endif;
	
	
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWagonMovingOffSite" id="74ac5505-f393-455d-8d17-5ad1b46fa3e3">
        <source>isWagonMovingOffSite():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

begin

//	if self.myTargetLocation &lt;&gt; null then
	if self.myToPrimaryLocation &lt;&gt; null then
		// only interested in moves to nowhere (i.e. offsite).
		return false;
	endif;
	
	if self.moveMode &lt;&gt; REAL_MODE then
		// only interested in real moves.
		return false;
	endif;
	
	if self.myOriginatingLocation = null or not CM_WagonController.hasInstance(self.myOriginatingLocation) then
		//only interested in moves from wagons
		return false;
	endif;
	
	//10 Mar 2010	NDL Par 22751
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.state = TI_STATE_NOTIFIED then
		// a prenote being removed from the wagon before it has arrived....
		return false;
	endif;
		
	//OK, this is a real move of a wagon off site.
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isYardLocation" id="af1bf2f5-042b-4a78-b34a-32440001e289">
        <source>isYardLocation() : Boolean;
// ---------------------------------------------------------------------------
// Created:		06 September 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.myToPrimaryLocation = null then
		return false;
	endif;
	
	return self.myToPrimaryLocation.isYardLocation();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveTrackedItemSource" id="f4a82aee-ec25-44f9-9333-d13332ce0a74">
        <updating/>
        <source>moveTrackedItemSource(_terminal : CM_Terminal)updating; 
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 May 2012	cnwer1	Initial creation Par 28965
30 Jul 2019	jlgzm1	TFS 42863 Direct Release Between RORO Voyages and Rail - Break Bulk

*/
constants
	ErrWarnMode_Update = 2; 
	ErrWarnMode_CanAckWarnings = 18;
vars
	moveController	: CMIF_MoveController;
	result	: Integer;
	theSlotRequest : CM_SlotRequest;
	theRORORequest : CM_RORORequest;
	origWLE : CM_WorkListEntry; // TFS 42863
begin


	if self.myTrackedItem.myTerminal &lt;&gt; _terminal then
		app.raiseCMException2(ERR_TERMINAL_TRANSFER, self.myTrackedItem.myTerminal.code, _terminal.code, null, null);
		return;	
	endif;

	if self.myToPrimaryLocation &lt;&gt; null and self.myToPrimaryLocation.isKindOf(CM_VoyageROROController) then	
		theRORORequest :=  self.myToPrimaryLocation.CM_VoyageROROController.myRORORequestLoad;
		
		if theRORORequest &lt;&gt; null then
			if theRORORequest.myBulkReleaseReserveDetail &lt;&gt; null then //cnwrd1 par 30865 11.1.13
				app.raiseCMException1(Slot_alread_alloca_releas_requ, theRORORequest.myBulkReleaseReserveDetail.myReserveHeader.code , null, null);
				return;
			endif;
		elseif self.myVoyageRequest &lt;&gt; null then
			if self.myVoyageRequest.isRehandle then
				self.isRehandleMove := true; // see CMIF_MoveController::setMyToSecondaryLocations
			endif;
		endif;
	elseif self.mySlotRequest &lt;&gt; null then	
		if self.mySlotRequest.myBulkReleaseReserveDetail &lt;&gt; null then //cnwrd1 par 30865 11.1.13
			app.raiseCMException1(Slot_alread_alloca_releas_requ, self.mySlotRequest.myBulkReleaseReserveDetail.myReserveHeader.code , null, null);
			return;
		endif;		
		if self.mySlotRequest.isRehandle then
			self.isRehandleMove := true; // see CMIF_MoveController::setMyToSecondaryLocations
		endif;
	elseif self.myVoyageRequest &lt;&gt; null then
		if self.myVoyageRequest.isRehandle then
			self.isRehandleMove := true; // see CMIF_MoveController::setMyToSecondaryLocations
		endif;
	endif;

	origWLE := self.myWorkListEntry; // TFS 42863
	
	while true do
		app.myTrxUA.trxMoveTrackedItemAssignToJob(self, app.myPassport);

		if app.myPassport.trxCompletedOK then
			break;
		else
			
			result := app.showErrorWarningDialog(app.getErrorString(Move_error), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and  result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				
				// trxMoveTrackedItemAssignToJob used to reset myWorkListEntry in epilog
				// have had to move it up a level in case wle gets deleted during transaction
				if origWLE &lt;&gt; null then					// TFS 42863
					self.setMyWorkListEntry(origWLE);	// TFS 42863
				endif;									// TFS 42863

				continue;
			endif;
		endif;
		break;
	endwhile;
	
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="moveTrackedItemTarget" id="5f00a91b-e2dd-4ae3-925e-70704ad7ce90">
        <updating/>
        <source>moveTrackedItemTarget(	_terminal : CM_Terminal;
						_toLocation : CM_LocationsController;
						_quantity  : Integer;
						_weight  : Decimal) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 May 2012	cnwer1	Initial creation Par 28965
30 Jul 2019	jlgzm1	TFS 42863 Direct Release Between RORO Voyages and Rail - Break Bulk


*/
constants
	ErrWarnMode_Update = 2; 
	ErrWarnMode_CanAckWarnings = 18;
vars
	originalRequest,
	voyageRequest : CM_Request;
	result	: Integer;
	theWLE : CM_WorkListEntry;
	theTI : CM_TrackedItem;
	orginalPlannedLC,
	theSource, theTarget : CM_LocationsController;
	voyageWle : CM_VoyageWLE;
	voyageJob : CM_VoyageJob;
	origWLE : CM_WorkListEntry; // TFS 42863
begin
	theTI := self.myTrackedItem;
	if theTI = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'app.myMoveController.myTrackedItem = null');
		return;
	endif;
	
	if theTI.myTerminal &lt;&gt; _terminal then
		app.raiseCMException2(ERR_TERMINAL_TRANSFER, theTI.myTerminal.code, _terminal.code, null, null);
		return;	
	endif;	
	
	self.setMyToPrimaryLocation(_toLocation);
	
	// PAR 33336 have moved this code to the move controller. CM_LocationsController::validateMoveFrom
// PAR 33336	if theTI.isSOB and not _toLocation.isKindOf(CM_SlotController) then						// 03/08/2012 cnwmh5 #30125
//	PAR 33336	app.raiseCMException1(DragDrop_SOB_ship_to_yard,theTI.id,null, null);
//	PAR 33336	return;
// PAR 33336	endif;


	if self.mySlotRequest &lt;&gt; null then
		voyageRequest:=self.mySlotRequest ;
	elseif self.myVoyageRequest &lt;&gt; null then
		voyageRequest:=self.myVoyageRequest;
	endif;

	if theTI.myCargoType.isBreakBulkMulti then //cnwrd1 ccms 2274
		if self.quantity = 0 then
			if _quantity &gt; 0 then
				//epr TFS 8222 7/12/17
				self.setQuantity(_quantity);
			else
				self.setQuantity( theTI.totalQuantity);
			endif;
		endif;
	endif;
	
	if theTI.myCargoType.isBulkMulti then
		if self.weight = 0 then
			if _weight &gt; 0 then
				self.setWeight(_weight);
			else
				self.setWeight( theTI.totalWeight);
			endif;
		endif; 
	endif;
	
	// save these away incase this is a ship DLR that is auto linked
	if voyageRequest &lt;&gt; null then
		if voyageRequest.getIsRehandle then
			theTarget := self.myOriginatingLocation;
			theSource := self.myToPrimaryLocation;
			self.isRehandleMove := true; // see CMIF_MoveController::setMyToSecondaryLocations
		else
			if self.isMoveAnExportRePlan then
				//epr TFS 4698 7/7/17 
				orginalPlannedLC:=theTI.getPrimaryLocation(PLANNING_MODE);
				if orginalPlannedLC &lt;&gt; null then
					originalRequest:=orginalPlannedLC.getRequest(true);
				endif;
				if originalRequest &lt;&gt; null then
					theWLE := originalRequest.getWLEForTI(theTI);
				endif;
				if theWLE = null then
					theWLE := voyageRequest.getWLEForTI(theTI);
				endif;
				// switch the slot req to the one on the target so that the TI will be added to the correct job
				voyageRequest := self.myToPrimaryLocation.CM_VoyageController.getRequest(true);
				if voyageRequest.isKindOf(CM_SlotRequest) then
					self.mySlotRequest := voyageRequest.CM_SlotRequest;
					self.myVoyageRequest:=null;
				elseif voyageRequest.isKindOf(CM_VoyageRequest) then
					self.myVoyageRequest := voyageRequest.CM_VoyageRequest;
					self.mySlotRequest :=null;
				endif;
				self.isReplanAnExport := true; // AKB2004AUG
				self.isReplan := true; // AKB2004AUG
				self.setMyWorkListEntry(theWLE); // AKB2004AUG. As part of this we need this to be teh 'old' wle so that later we can unassign from it
				if theWLE &lt;&gt; null then //cnwrd1 par 31672
					self.setMoveIndex(theTI.allPlannedFutureMoves.indexOf(theWLE.myFutureMove)); // AKB2004AUG
				endif;
				self.setMyOriginatingLocation(orginalPlannedLC); // AKB2004AUG			
			endif;		
		endif;
	endif;
	
	origWLE := self.myWorkListEntry; // TFS 42863 
	while true do
		app.myTrxUA.trxMoveTrackedItemAssignToJob(self, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Move_error), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				
				// trxMoveTrackedItemAssignToJob used to reset myWorkListEntry in epilog
				// have had to move it up a level in case wle gets deleted during transaction
				if origWLE &lt;&gt; null then					// TFS 42863
					self.setMyWorkListEntry(origWLE);	// TFS 42863
				endif;									// TFS 42863
				
				continue;
			endif;
		endif;
		break;
	endwhile;
	
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_toLocation" type="CM_LocationsController"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="moveTrackedItemsSource" id="e88febcc-2058-4036-beeb-8db48354fd3f">
        <updating/>
        <source>moveTrackedItemsSource(_terminal : CM_Terminal;
						_theTIs : CM_TIArray) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 May 2012	cnwer1	Initial creation Par 28965

*/
constants
	ErrWarnMode_Update = 2; 
	ErrWarnMode_CanAckWarnings = 18;
vars
	theLCs : CM_LCArray;
	anLC : CM_LocationsController;
	aJob : CM_Job;
	loadRequest : CM_Request;
	result	: Integer;
begin
	if self.myTrackedItem.myTerminal &lt;&gt; _terminal then
		app.raiseCMException2(ERR_TERMINAL_TRANSFER, self.myTrackedItem.myTerminal.code, _terminal.code, null, null);
		return;	
	endif;

	
	create theLCs transient;
	
	self.isRehandleMove := false;
	
	self.allToLocations.copy(theLCs);
	self.allToLocations.clear;
	theLCs.sortLCsInToSeqOrder();
	
	foreach anLC in 	theLCs do
		loadRequest:=anLC.getRequest(true);
		if loadRequest &lt;&gt; null then
			if loadRequest.myJob &lt;&gt; aJob and aJob &lt;&gt; null then
				app.raiseCMException(Bulk_planning_same_job,null, null);
				return;
			endif;
			aJob := loadRequest.myJob;
			if aJob = null then
				app.raiseCMException(Bulk_plan_must_cc_job,null, null);
				return;
			endif;
			
			//cnwrd1 par 30865 15.1.13
			if loadRequest.isKindOf(CM_RORORequest) then
				if loadRequest.CM_RORORequest.myBulkReleaseReserveDetail &lt;&gt;  null then
					app.raiseCMException(Bulk_plann_must_slots_witho_as,null, null);
				endif;
			elseif loadRequest.isKindOf(CM_SlotRequest) then
				if loadRequest.CM_SlotRequest.myBulkReleaseReserveDetail &lt;&gt;  null then
					app.raiseCMException(Bulk_plann_must_slots_witho_as,null, null);
				endif;		
			endif;

		else
			app.raiseCMException(Bulk_plan_slots_cc_job,null, null);
			return;
		endif;
	endforeach;
	
	while true do
		app.myTrxUA.trxMoveTrackedItemsAssignToJob(_theTIs, theLCs, self, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Move_error), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and  result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
	
epilog
	//epr par 37386 19/1/16 if you cancelled from a warning and planned again the bulk to locations were lost
	if theLCs &lt;&gt; null then
		theLCs.copy(self.allToLocations);
	endif;
	
	delete theLCs;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_theTIs" type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="nonWorkedInstantPostMove" id="30a3ac42-4fc4-4822-8f22-6291cbc13783">
        <updating/>
        <source>nonWorkedInstantPostMove() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2013	cnwndl1	Initial creation	Par 32140

*/

vars

	ti : CM_TrackedItem;
	unPlanMoveCont	: CMIF_MoveController;
	fmIndex : Integer;

begin

	if not self.priority = 999 then
		return;
	endif;
	
	self.priority := 0;
	
	ti := self.myTrackedItem;
	if ti = null then
		return;
	endif;
	
	if not ti.allPlannedFutureMoves.isEmpty then
	
		create unPlanMoveCont transient;
		unPlanMoveCont.setMoveMode(PLANNING_MODE);
		unPlanMoveCont.setMoveIndex(1);
		unPlanMoveCont.isFullyUnplan:=true;
		unPlanMoveCont.setMyTrackedItem(ti);
		app.myUtilityUA.utlUpdateMoveTIUndo(unPlanMoveCont, app.myPassport);
	
		delete unPlanMoveCont;
		
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="nonWorkedInstantPreMove" id="9d2cc460-c2d4-411a-b250-b51c9118d19b">
        <updating/>
        <source>nonWorkedInstantPreMove() updating;
/*

Purpose:			Ask the user what to do if the cargo is being moved from A to B, but is already planned to C.

Parameters:			

Return Value:		

Date		Who		Reason
01/08/2013	cnwndl1	Initial creation	Par 32140
23/02/2017	cnwdap1	TFS 3489 LNX DLR/SOB - voyage hold jobs are "planned" on "non-planned" voyages
10/10/2017	jlgmd1	TFS 7252 JMT - Confirmation of Planned moves does not show if the voyage has LOLO or RORO definitions.
*/

vars

	ti : CM_TrackedItem;
	sourceLoc : CM_LocationsController;
	targetLoc : CM_LocationsController;
	plannedLoc : CM_LocationsController;
	showWarning : Boolean;
	voyage : CM_Voyage;
	msg : String;
	plannedMoves : CM_FutureMoveArray;
	plannedMove: CM_FutureMove;
	response: Integer;
	hold : CM_GeneralCargoVoyageStructure;
	location : CM_GeneralCargoController;
	iter : Iterator;

begin

	if self.moveMode &lt;&gt; REAL_MODE then
		return;
	endif;
	
	ti := self.myTrackedItem;
	if ti = null then
		return;
	endif;
	
	plannedLoc := ti.myPrimaryPlannedLocation;
	if plannedLoc = null then
		return;
	endif;
	
	sourceLoc := ti.myPrimaryActualLocation;
	if sourceLoc = null then
		return;
	endif;
	
	if sourceLoc.isVoyageController then
		voyage := sourceLoc.CM_VoyageController.myVoyage;
	endif;
	
	targetLoc := self.myToPrimaryLocation;
	if targetLoc = null then
		return;
	endif;
	
	if targetLoc.isVoyageController then
		voyage := targetLoc.CM_VoyageController.myVoyage;
	endif;
	
	if voyage = null then
		return;
	endif;
	
	// TFS 7252 start
	// isNonWorkedVoyage := voyage.isHOLDSorSHIP();		// Renamed isNonWorkedVoyage to showWarning
	
	// 1. Are we moving FROM or TO our voyages BS ?
	if voyage.myShipBlockStack &lt;&gt; null and
		(sourceLoc = voyage.myShipBlockStack or targetLoc = voyage.myShipBlockStack) then
		showWarning := true;
	endif;
	
	// 2. Are we moving FROM or TO our voyages hold ?
	if not showWarning and voyage.myGeneralCargoVoyage &lt;&gt; null then
		iter := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.createIterator;
		if sourceLoc.isKindOf(CM_GeneralCargoController) then
			iter.startAtObject(sourceLoc);
			if iter.next(location) and location = sourceLoc then
				showWarning := true;
			endif;
		endif;
		
		if not showWarning and targetLoc.isKindOf(CM_GeneralCargoController) then
			iter.startAtObject(targetLoc);
			if iter.next(location) and location = targetLoc then
				showWarning := true;
			endif;
		endif;
		delete iter;
	endif;
	// TFS 7252 end
	
	// Only show the warning if the move involves a voyage hold or block stack
	if not showWarning then
		return;
	endif;
		
	
	// Is the ti planned to the targetLoc?   34510 DJW 7 July 2014
	create plannedMoves transient;
	self.myTrackedItem.getFutureMovesOfType(PLANNING_MODE, TI_FutureMovePlanned, plannedMoves );
	foreach plannedMove in plannedMoves do
		if plannedMove.getPrimaryLocation = targetLoc then
			return;
		endif;
	endforeach;
	
	// so we have a real move for cargo loading or discharging from/to a location
	// on a non-worked voyage, where the cargo has been planned to location A,
	// but is being moved to location B.
	// Need to ask whether to remove the planned move to A.
	msg := app.getErrorString3(ConsumePlannedOrNot, ti.id, targetLoc.getFullId, plannedLoc.getFullId);	//14 Jun 2016	NDL	TFS 2156
//	msg := "'" &amp; ti.id &amp; "' is planned to '" &amp; plannedLoc.getFullId &amp; "' but, you are moving it to '" &amp; targetLoc.getFullId &amp; "'";
//	msg := msg &amp; CrLf &amp; "Do you want to unplan it from '" &amp; plannedLoc.getFullId &amp; "'?";
	response := app.msgBox(msg, app.getErrorString(Warning), MsgBox_Yes_No_Cancel);
	if response = MsgBox_Return_Yes then
		self.priority := 999;
	elseif response = MsgBox_Return_Cancel then		// 28/6/17 MAP TFS4719
		self.priority := 888;
	endif;

epilog
	delete plannedMoves;
	if iter &lt;&gt; null then
		delete iter;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="numExpectedLCs" id="51e4f56b-3514-4cef-b81c-abc34a2d31f1">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>numExpectedLCs(set: Boolean; _value: Real io) mapping, updating, protected;
/*
 ------------------------------------------------------------------------
Created:			13 September 2001 by cnwdwq1
Purpose:			Calculates the number of LCs this move will need
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	aTA : CM_TerminalArea;
begin
	if set then
		return;
	endif;
	_value := null;
	if self.myToPrimaryLocation = null then
		return;
	endif;
//	if process.isCnwab1() then
		aTA := self.myToPrimaryLocation.myTerminalArea;
		if aTA &lt;&gt; null then
			_value := aTA.calculateMoveLCs(self.myTrackedItem);
		else // SLOTCONTROLLERS, WagonControllers
			_value := self.myToPrimaryLocation.calculateMoveLCs(self.myTrackedItem);
		endif;
//	else
//		_value := self.myToPrimaryLocation.calculateMoveLCs(self.myTrackedItem);
//	endif;
end;</source>
