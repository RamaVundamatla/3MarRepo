    <JadeMethod name="displayStopArea" id="bd998c60-6190-4a32-ac9b-09b4e85e464f">
        <source>displayStopArea(_area : CM_String; _selected : Boolean) : String;
 //ccms1824 cnwrs1 may 2009
vars

begin

	if _area = null then
		return null;
	endif;

	if _selected then
		return TableCheckBox_Selected &amp; Tab &amp; _area.string;
	else
		return TableCheckBox_NotSelected &amp; Tab &amp; _area.string;
	endif;
	
end;</source>
        <Parameter name="_area" type="CM_String"/>
        <Parameter name="_selected" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayStopTableTemplate" id="f1d63a0d-5dd3-485b-9153-8396ca46ac5f">
        <source>displayStopTableTemplate();
 //ccms1824 cnwrs1 may 2009
vars
	obj : CM_Voyage;
begin
	if self.myProxyStopTableTemplate &lt;&gt; null then
		self.fillStopColls();
		self.setSelectedStopTableTplAreas();
		self.lstStopSet.displayCollection(self.allAvailableSetStopAreas, false, Table.DisplayCollection_Forward, null);
		self.lstStopPrevent.displayCollection(self.allAvailablePreventStopAreas, false, Table.DisplayCollection_Forward, null);
		self.lstStopProcess.displayCollection(self.allAvailableProcessStopAreas, false, Table.DisplayCollection_Forward, null);
		
		//self.setSelectedStopAreas(stopTable);
		self.lstStopSet.setSelected(self.allSetSetStopAreas);
		self.lstStopPrevent.setSelected(self.allSetPreventStopAreas);
		self.lstStopProcess.setSelected(self.allSetProcessStopAreas);
		self.chkFullsOnly.value := self.myProxyStopTableTemplate.isFull;
		self.chkMTsOnly.value := self.myProxyStopTableTemplate.isMT;
		self.chkChildOnly.value := self.myProxyStopTableTemplate.isChildOnly;
		self.chkChildIgnore.value := self.myProxyStopTableTemplate.isChildIgnore;
		self.chkCoastalOnly.value := self.myProxyStopTableTemplate.isCoastalOnly;
		self.chkCoastalIgnore.value := self.myProxyStopTableTemplate.isCoastalIgnore;
//		self.chkTranshipOnly.value := self.myProxyStopTableTemplate.isTranshipOnly;
//		self.chkTranshipIgnr.value := self.myProxyStopTableTemplate.isTranshipIgnore;
		//foreach obj in self.myProxyStopTableTemplate.allHoldVoyages do
		//	write class.name&amp;'::'&amp;method.name&amp;' '&amp;obj.String&amp;' '&amp;obj.code;
		//endforeach;
		self.mulHoldVoyages.setSelected(self.myProxyStopTableTemplate.allHoldVoyages);
	else
		self.lstStopSet.setSelected(null);
		self.lstStopPrevent.setSelected(null);
		self.lstStopProcess.setSelected(null);
		self.chkFullsOnly.value := false;
		self.chkMTsOnly.value := false;
		self.chkChildOnly.value := false;
		self.chkChildIgnore.value := false;
		self.chkCoastalOnly.value := false;
		self.chkCoastalIgnore.value := false;
	endif;
	
	self.populateTblUpdRequests();	//01 May 2019	NDL	TFS 43918
end;
</source>
    </JadeMethod>
    <JadeMethod name="displayUpdateRequest" id="82eaf117-c735-4595-b430-5a22fa141806">
        <source>displayUpdateRequest( updRequest : CM_EventRequestForStop );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

	msg : String;
	form : CMUI_CargoUpdateRequestForStop;

begin

	if self.myProxyStopTableTemplate = null then
		msg := app.getErrorString( Unabl_proce_proxy_stops_templ_ );	
	elseif self.myProxyStopTableTemplate.myTerminal = null then
		msg := app.getErrorString( Unabl_proce_termi_assoc_with_p );
	endif;
	if msg &lt;&gt; null then
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;

	form := app.loadForm(CMUI_CargoUpdateRequestForStop, CMUI_Assistant, false, false, false, self.myProxyStopTableTemplate.myTerminal, null).CMUI_CargoUpdateRequestForStop;
	
	if form &lt;&gt; null then
		form.setMyProxyStopTableTemplate( self.myProxyStopTableTemplate );
		form.myCurrentEventRequest := updRequest;
		form.centreWindow;
		form.showModal;	
		
		self.populateTblUpdRequests();
		
	endif;

epilog

end;</source>
        <Parameter name="updRequest" type="CM_EventRequestForStop"/>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="bcdbe6e1-af8e-4b91-94af-1b3c9bd921e4">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2012	cnwndl1	Initial creation	29859

*/

vars

	realStopTableTemplate : CM_StopTableTemplate;

begin

	//02 May 2019	NDL	TFS 43918
	if not self.unsavedChanges and self.btnSaveBase.enabled then
		if self.myProxyStopTableTemplate &lt;&gt; null then
			realStopTableTemplate := self.myProxyStopTableTemplate.pxyGetProxyObject();
			if realStopTableTemplate = null then
				if not self.myProxyStopTableTemplate.allEventRequests.isEmpty then
					self.unsavedChanges := true;
				endif;
			else
				if realStopTableTemplate.pxyUpdateRequestsDiffer( self.myProxyStopTableTemplate.allEventRequests ) then
					self.unsavedChanges := true;
				endif;
			endif;
		endif;
	endif;

	self.unloadForm;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="2f8843d7-3c9e-4155-85ae-bd7cacf8b6f0">
        <updating/>
        <source>doBaseFormSave() updating, protected;
//ccms1824 cnwrs1 may 2009
vars

begin
	inheritMethod();
	self.doSave();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="15746562-b011-4df6-ad8d-3e1cac8cd04a">
        <updating/>
        <source>doResize() updating;
 //ccms1824 cnwrs1 may 2009
 // 29/06/2010	cnwcs5	par 24341 - new tranship apply option
 //1 Feb 2022 NAVLW1 TFS# 52714 resize the control so that "Costal Ignore" is visible
constants
	LeftMargin		: Integer = 10;
	TopMargin		: Integer = 10;
	VerticalSpacing	: Integer = 5;
	ListBoxHeight : Integer = 70;
	ReservedTailSpace : Integer = 180; // this is bottom of save button minus top of fulls chk
	MinWidth : Integer = 350;
	MinHeight : Integer = 600; // 1 Feb 2022 NAVLW1 TFS# 52714
vars
	currentTop	: Real;
	currentSpace : Real;
	freeSpace : Real;
	reservedHeadSpace : Real;
begin
	inheritMethod();
	if self.width &lt; MinWidth then
		self.width := MinWidth;
	endif;
	if self.height &lt; MinHeight then
		self.height := MinHeight;
	else
		freeSpace := self.height -MinHeight;
	endif;
	currentTop := self.frmToolbar.height;
	self.fld_Details.top := currentTop;
	self.fld_Details.width := self.width - 20;
	self.fld_Details.height := self.height - 40 - currentTop;
//	self.shtSingleSelect2.caption := 'Processing Options'; //ccms1824 cnwrs1 may 2009
//	self.shtSingleSelect2.visible := true;
//	self.shtSingleSelect2.enabled := true;
//	self.label18.visible := true;
//	self.label18.caption := "Terminal:";
//	self.label18.top := currentTop;
//	self.label18.left := LeftMargin;
//	self.label18.width := self.shtSingleSelect2.width -25;
//	currentTop := currentTop;// + self.label18.height + VerticalSpacing;
//	self.cmbStopTerminal.visible := true;
//	self.cmbStopTerminal.top := currentTop;
//	self.cmbStopTerminal.left := LeftMargin;
//	self.cmbStopTerminal.width := self.shtSingleSelect2.width -25;
//	currentTop := currentTop + self.cmbStopTerminal.height + VerticalSpacing;
	self.label1.visible := true;
	self.label1.caption := "Auto Applies Actions:";
	self.label1.top := currentTop - 10;
	self.label1.left := LeftMargin;
	self.label1.width := self.sht_Sheet1.width -25;
	currentTop := currentTop + self.label1.height;// + VerticalSpacing;
	self.lstStopSet.visible := true;
	self.lstStopSet.top := currentTop;
	self.lstStopSet.left := LeftMargin;
	self.lstStopSet.height := ListBoxHeight + 15;	// par 24341
	self.lstStopSet.width := self.sht_Sheet1.width -25;
	currentTop := currentTop + self.lstStopSet.height + VerticalSpacing;
	self.label2.visible := true;
	self.label2.caption := "Prevent Actions:";
	self.label2.top := currentTop;
	self.label2.left := LeftMargin;
	self.label2.width := self.sht_Sheet1.width -25;
	currentTop := currentTop + self.label2.height + VerticalSpacing;
	reservedHeadSpace := currentSpace;
//	freeSpace := (currentSpace - ReservedTailSpace - ListBoxHeight - ListBoxHeight - self.label3.height)/2;
//	if freeSpace &lt; ListBoxHeight then
//		freeSpace := ListBoxHeight;
//	endif;
	self.lstStopPrevent.visible := true;
	self.lstStopPrevent.top := currentTop;
	self.lstStopPrevent.left := LeftMargin;
	self.lstStopPrevent.height := ListBoxHeight + (freeSpace/3);
	self.lstStopPrevent.width := self.sht_Sheet1.width -25;
	currentTop := currentTop + self.lstStopPrevent.height + VerticalSpacing;
	self.label3.visible := true;
	self.label3.caption := "Process Actions:";
	self.label3.top := currentTop;
	self.label3.left := LeftMargin;
	self.label3.width := self.sht_Sheet1.width -25;
	currentTop := currentTop + self.label3.height + VerticalSpacing;
	self.lstStopProcess.visible := true;
	self.lstStopProcess.top := currentTop;
	self.lstStopProcess.left := LeftMargin;
	self.lstStopProcess.height := ListBoxHeight + (freeSpace*2/3);
	self.lstStopProcess.width := self.sht_Sheet1.width -25;
	currentTop := currentTop + self.lstStopProcess.height + VerticalSpacing;
//write "fulls top="&amp;currentTop.String;
	self.chkFullsOnly.visible := true;
	self.chkFullsOnly.caption := "Fulls";
	self.chkFullsOnly.top := currentTop;
	self.chkFullsOnly.left := LeftMargin;
	self.chkFullsOnly.width := self.sht_Sheet1.width -25;
	currentTop := currentTop + self.chkFullsOnly.height + VerticalSpacing;
	self.chkMTsOnly.visible := true;
	self.chkMTsOnly.caption := "MTs";
	self.chkMTsOnly.top := currentTop;
	self.chkMTsOnly.left := LeftMargin;
	self.chkMTsOnly.width := self.sht_Sheet1.width -25;
	currentTop := currentTop + self.chkMTsOnly.height + VerticalSpacing;
	self.chkChildOnly.visible := true;
	self.chkChildOnly.caption := "Children Only";
	self.chkChildOnly.top := currentTop;
	self.chkChildOnly.left := LeftMargin;
	self.chkChildOnly.width := self.sht_Sheet1.width -25;
	currentTop := currentTop + self.chkChildOnly.height + VerticalSpacing;
	self.chkChildIgnore.visible := true;
	self.chkChildIgnore.caption := "Children Ignore";
	self.chkChildIgnore.top := currentTop;
	self.chkChildIgnore.left := LeftMargin;
	self.chkChildIgnore.width := self.sht_Sheet1.width -25;
	currentTop := currentTop + self.chkChildIgnore.height + VerticalSpacing;
	self.chkCoastalOnly.visible := true;
	self.chkCoastalOnly.caption := "Coastal Only";
	self.chkCoastalOnly.top := currentTop;
	self.chkCoastalOnly.left := LeftMargin;
	self.chkCoastalOnly.width := self.sht_Sheet1.width -25;
	currentTop := currentTop + self.chkCoastalOnly.height + VerticalSpacing;
	self.chkCoastalIgnore.visible := true;
	self.chkCoastalIgnore.caption := "Coastal Ignore";
	self.chkCoastalIgnore.top := currentTop;
	self.chkCoastalIgnore.left := LeftMargin;
	self.chkCoastalIgnore.width := self.sht_Sheet1.width -25;
	currentTop := currentTop + self.chkCoastalIgnore.height + VerticalSpacing;
/*	self.chkTranshipOnly.visible := true;
	self.chkTranshipOnly.caption := "Tranship Only";
	self.chkTranshipOnly.top := currentTop;
	self.chkTranshipOnly.left := LeftMargin;
	self.chkTranshipOnly.width := self.sht_Sheet1.width -25;
	currentTop := currentTop + self.chkTranshipOnly.height + VerticalSpacing;
	self.chkTranshipIgnr.visible := true;
	self.chkTranshipIgnr.caption := "Tranship Ignore";
	self.chkTranshipIgnr.top := currentTop;
	self.chkTranshipIgnr.left := LeftMargin;
	self.chkTranshipIgnr.width := self.sht_Sheet1.width -25;
	currentTop := currentTop + self.chkTranshipIgnr.height + VerticalSpacing;
*/
	self.mulHoldVoyages.top := self.sht_Sheet2.top + 5;
	self.mulHoldVoyages.left := self.sht_Sheet2.left;
	self.mulHoldVoyages.width := self.sht_Sheet2.width - 10;
	self.mulHoldVoyages.height := self.sht_Sheet2.height - 20;
	self.mulHoldVoyages.repositionAfterResize;
//	write class.name&amp;'::'&amp;method.name&amp;' '&amp;self.width.String;
	
	//cnwmc5 - 11 April 2014 - CCMS 2532
	if self.allSelectedCargoTypes.includes(app.myRoot.getCargoBOLTypeForId(BOLType_GeneralBillOfLading)) &lt;&gt; null
	and self.allSelectedCargoTypes.size = 1 then
		self.hideCheckBoxes();
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="7e4e3992-4831-4b31-aaa7-954cb5653da6">
        <updating/>
        <source>doSave() updating;
 //ccms1824 cnwrs1 may 2009
vars

begin
	self.updateStopTableTemplate();
	
	self.unsavedChanges := false;	//06 Nov 2012	NDL	Par 29859
	self.unloadForm();
	
	self.modalResult := IDOK;
end;
</source>
    </JadeMethod>
    <JadeMethod name="fillStopColls" id="059860f7-f5b7-4056-9320-84ab20e62e43">
        <source>fillStopColls() protected;
//ccms1824 cnwrs1 may 2009
// cnwrs1 Apr 2007 unlink the set and check list and make the list match what happens in the code
// ie only allow the set or check to be displayed when there is code to process it

// 29/06/2010	cnwcs5	par 24341 - new tranship auto apply option
//15 May 2013	cnwrs1	par31549 stop removal of unused options
//16 Aug 2022   navds20 ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
//19 May 2023	navcs2	Defect 58062: MTN - Mobile Apps from cargo damage deleted the cargo still flagged as damage in client
// 27/06/2023	navcs2	Bug 58902: EUP - Damage - Stop Options Removed
// 22/08/2023	navkc1	CR 59610 Task 59611: Jade - Stop Prevention
//19/12/2024    navsaa30 MTN-33636 TPT | Stops Configuration for Standard Damage
vars
	strObj 		: CM_String;
	//cnwmc5 - 11 April 2014 - CCMS 2352
	cargoType 	: CM_CargoBOLType;
	isBol		: Boolean;
	isBolOnly	: Boolean;
begin
	self.allAvailablePreventStopAreas.purge;
	self.allAvailableSetStopAreas.purge;
	self.allAvailableProcessStopAreas.purge;
	
	//cnwmc5 - 11 April 2014 - CCMS 2352
	isBol := false;
	isBolOnly := false;
	cargoType := app.myRoot.getCargoBOLTypeForId(BOLType_GeneralBillOfLading);
	if self.allSelectedCargoTypes.includes(cargoType) &lt;&gt; null then
		isBol := true;
		if self.allSelectedCargoTypes.size = 1 then
			isBolOnly := true;
		endif;
	endif;
	
	//cnwmc5 - 11 April 2014 - CCMS 2352
	if isBol then
		create strObj transient;	
		strObj.string := StopApplyBOLStr;
		self.allAvailableSetStopAreas.atPut(StopApplyBOL, strObj);
	endif;
	
	if not isBolOnly then
		//CCMS 1184
		create strObj transient;	
		strObj.string := StopApplyExportStr;
		self.allAvailableSetStopAreas.atPut(StopApplyExport, strObj);
		create strObj transient;
		strObj.string := StopApplyImportStr;
		self.allAvailableSetStopAreas.atPut(StopApplyImport, strObj);
		create strObj transient;
		strObj.string := StopApplyPackCompleteStr;
		self.allAvailableSetStopAreas.atPut(StopApplyPackComplete, strObj);
		create strObj transient;
		strObj.string := StopApplyUnpackCompleteStr;
		self.allAvailableSetStopAreas.atPut(StopApplyUnpackComplete, strObj);
		create strObj transient;											// par 24341
		strObj.string := StopApplyTranshipStr;								// par 24341
		self.allAvailableSetStopAreas.atPut(StopApplyTranship, strObj);		// par 24341
		/*create strObj transient;
		strObj.string := StopApplySOLASVGMStr;    						//epr TFS 1946 14/5/16
		self.allAvailableSetStopAreas.atPut(StopApplySOLASVGM,strObj);*/
		
		if app.myCurrentUserCan(self.myCurrentTerminal ,PmAdmDamageCodeAdvancedMaint) then  //19 May 2023 navcs2	Defect 58062		// 27/06/2023	navcs2	Bug 58902
			// 16.08.2022 navds20 TFS 53862
			create strObj transient;
			strObj.string := StopApplyDamagedNotRefusedStr;    					
			self.allAvailableSetStopAreas.atPut(StopApplyDamagedNotRefused,strObj);
			
			create strObj transient;
			strObj.string := StopApplyDamagedAndRefusedStr;    					
			self.allAvailableSetStopAreas.atPut(StopApplyDamagedAndRefused,strObj);
			// 16.08.2022 navds20 TFS 53862
		else																				// 19/12/24  navsaa30 #33636
			create strObj transient;
			strObj.string := StopApplyDamagedStr;    					
			self.allAvailableSetStopAreas.atPut(StopApplyDamaged,strObj);					
		endif;																			   //19 May 2023 navcs2 Defect 58062		
		
	endif;
	
	create strObj transient;
	strObj.string := StopPreventDeliveryRequestStr;
	self.allAvailablePreventStopAreas.atPut(StopPreventDeliveryRequest, strObj);
	create strObj transient;
	strObj.string := StopPreventImportStr;
	self.allAvailablePreventStopAreas.atPut(StopPreventImport, strObj);
	create strObj transient;
	strObj.string := StopPreventExportStr;
	self.allAvailablePreventStopAreas.atPut(StopPreventExport, strObj);
	create strObj transient;
	strObj.string := StopPreventRTQueuingStr;
	self.allAvailablePreventStopAreas.atPut(StopPreventRTQueuing, strObj);
	create strObj transient;
	strObj.string := StopPreventReceiptStr;
	self.allAvailablePreventStopAreas.atPut(StopPreventReceipt, strObj);
	create strObj transient;
	strObj.string := StopPreventReleaseRequestStr;
	self.allAvailablePreventStopAreas.atPut(StopPreventReleaseRequest, strObj);
	create strObj transient;
	strObj.string := StopPreventSubTerminalEditStr;
	self.allAvailablePreventStopAreas.atPut(StopPreventSubTerminalEdit, strObj);
	create strObj transient;
	strObj.string := StopPreventVoyagePlanningStr;
	self.allAvailablePreventStopAreas.atPut(StopPreventVoyagePlanning, strObj);
	create strObj transient;
	strObj.string := StopPreventYardMoveStr;
	self.allAvailablePreventStopAreas.atPut(StopPreventYardMove, strObj);
	create strObj transient;	//03 Jul 2015	NDL	Par 36543
	strObj.string := StopPreventGateOutStr;
	self.allAvailablePreventStopAreas.atPut(StopPreventGateOut, strObj);
	create strObj transient;	//03 Jul 2015	NDL	Par 36543
	strObj.string := StopPreventTruckUnloadStr;
	self.allAvailablePreventStopAreas.atPut(StopPreventTruckUnload, strObj);
	create strObj transient;	// 23/08/2016	cnwjre1 TFS 2570
	strObj.string := StopPreventStorageChargesStr;
	self.allAvailablePreventStopAreas.atPut(StopPreventStorageCharges, strObj);
	
	// 16.08.2022 navds20 TFS 53862
	create strObj transient;	
	strObj.string := StopPreventRelReqDamRefusedStr;
	self.allAvailablePreventStopAreas.atPut(StopPreventRelReqDamRefused, strObj);
	// 16.08.2022 navds20 TFS 53862
	
	//22/08/2023	navkc1	CR 59610 Task 59611 --&gt;
	create strObj transient;	
	strObj.string := StopPreventTrainLoadStr;
	self.allAvailablePreventStopAreas.atPut(StopPreventTrainLoad, strObj);
	create strObj transient;	
	strObj.string := StopPreventTruckLoadStr;
	self.allAvailablePreventStopAreas.atPut(StopPreventTruckLoad, strObj);
	create strObj transient;	
	strObj.string := StopPreventTruckGateInStr;
	self.allAvailablePreventStopAreas.atPut(StopPreventTruckGateIn, strObj);
	create strObj transient;	
	strObj.string := StopPreventVoyageDepartureStr;
	self.allAvailablePreventStopAreas.atPut(StopPreventVoyageDeparture, strObj);
	create strObj transient;	
	strObj.string := StopPreventTrainDepartureStr;
	self.allAvailablePreventStopAreas.atPut(StopPreventTrainDeparture, strObj);
	 // ### JIRA 34756 27MAY2025 NAVAB1
	if app.myPassport.myUser.canDo(null, Sub_CustomDocuments) then
		create strObj transient;	
		strObj.string := StopPreventRelReqAssignStr;
		self.allAvailablePreventStopAreas.atPut(StopPreventRelReqAssign, strObj);
	endif;
	create strObj transient;	
	strObj.string := StopPreventTrainUnloadStr;
	self.allAvailablePreventStopAreas.atPut(StopPreventTrainUnload, strObj);
	//22/08/2023	navkc1	CR 59610 Task 59611 &lt;--
	create strObj transient; //jlier1 TFS 64478 24/6/24
	strObj.string := StopPreventReleaseFromTranStr;
	self.allAvailablePreventStopAreas.atPut(StopPreventReleaseFromTranArea, strObj);
	//cnwmc5 - 11 April 2014 - CCMS 2352
	if not isBolOnly then
		create strObj transient;
		strObj.string := StopProcessCustomsInspectStr;
		self.allAvailableProcessStopAreas.atPut(StopProcessCustomsInspect, strObj);
		
		// CCMS 1585
		create strObj transient;
		strObj.string := StopProcessCustomsScanInsptStr;
		self.allAvailableProcessStopAreas.atPut(StopProcessCustomsScanInspect, strObj);
	
		create strObj transient;
		strObj.string := StopProcessEDICustomExportStr;
		self.allAvailableProcessStopAreas.atPut(StopProcessEDICustomExport, strObj);
		create strObj transient;
		strObj.string := StopProcessEDICustomImportStr;
		self.allAvailableProcessStopAreas.atPut(StopProcessEDICustomImport, strObj);
	//	create strObj transient;
	//	strObj.string := Stop_Process_EDI_Customs_Str;
	//	self.allAvailableProcessStopAreas.atPut(Stop_Process_EDI_Customs, strObj);
	//	create strObj transient;
	//	strObj.string := StopProcessEDIOperatorStr;
	//	self.allAvailableProcessStopAreas.atPut(StopProcessEDIOperator, strObj);
		create strObj transient;
		strObj.string := StopProcessEmptyImportStr;
		self.allAvailableProcessStopAreas.atPut(StopProcessEmptyImport, strObj);
		create strObj transient;	
		strObj.string := StopProcessRemoveOnCoastalStr;
		self.allAvailableProcessStopAreas.atPut(StopProcessRemoveOnCoastal, strObj);
		create strObj transient;	
		strObj.string := StopProcessRemoveWhenChildStr;
		self.allAvailableProcessStopAreas.atPut(StopProcessRemoveWhenChild, strObj);
		
		//cnwrd1 4.11.08 CCMS JMT 1743/1764  start
		
		create strObj transient;	
		strObj.string := StopProcessOpImpReleasePINStr;
		self.allAvailableProcessStopAreas.atPut(StopProcessOpImpReleasePIN, strObj);
		create strObj transient;	//cnwrs1 aug 2009 CCMS1845
		strObj.string := StopProcessOpImpDeliverRelStr;
		self.allAvailableProcessStopAreas.atPut(StopProcessOpImpDeliverRel, strObj);
		
		create strObj transient;	
		strObj.string := StopProcessOpExpReleaseNoStr;
		self.allAvailableProcessStopAreas.atPut(StopProcessOpExpReleaseNo, strObj);
		
		//cnwrd1 4.11.08 CCMS JMT 1743/1764  end
		
		//CCMS 1696
		create strObj transient;	
		strObj.string := StopProcessCopyToChildStr;
		self.allAvailableProcessStopAreas.atPut(StopProcessCopyToChild, strObj);
	
		//PAR 19166 cnwgb1 28.5.09
		create strObj transient;	
		strObj.string := StopProcessImportStorageStr;
		self.allAvailableProcessStopAreas.atPut(StopProcessImportStorage, strObj);
	
		create strObj transient; //CCMS1884 - PAR22207 cnwsh3 27/01/2010
		strObj.string := StopProcessVoyagePlanningStr;
		self.allAvailableProcessStopAreas.atPut(StopProcessVoyagePlanning, strObj);
	//	self.allAvailableCheckStopAreas.copy(self.allAvailableSetStopAreas);

		create strObj transient;	
		strObj.string := StopProcessTransLoadSameCtyStr;
		self.allAvailableProcessStopAreas.atPut(StopProcessTransLoadSameCty, strObj);		// 21/7/17 MAP TFS4916
	endif;
epilog
	strObj := null;
end;</source>
