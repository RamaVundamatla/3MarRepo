<Class name="CM_RemoteDataObject">
    <JadeMethod name="addRemoteRow" id="45a3a638-035d-4c1c-bb91-5ca2c7a7b533">
        <updating/>
        <source>addRemoteRow(_table : CM_EntryTable io; _heading, _value : String; _object : Object) updating, protected;

vars

	tmpRow		: Integer;
	inputType	: Integer;
	cell		: JadeTableCell;

begin

	if _object &lt;&gt; null then
		inputType := Table.InputType_None;
	else
		inputType := Table.InputType_TextBox;
	endif;
	
	tmpRow := _table.addAttribute('', _heading, inputType, 0, true);
	cell := _table.accessCell(tmpRow, CM_EntryTable.ColumnValue);	
	cell.text := _value;

	if inputType = Table.InputType_TextBox then	
		cell.cellControl.TextBox.case := TextBox.Case_Upper;
	else
		cell.itemObject := _object;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="loadRemoteArray" id="81c632cd-9b55-4c6a-bcbc-73b6d4047a2d">
        <updating/>
        <source>loadRemoteArray(_table : CM_EntryTable io) updating;

vars

begin

	_table.rows := 1;

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadRemoteTable" id="c3fc55e8-e7a5-4f20-9701-7f166b029759">
        <updating/>
        <source>loadRemoteTable(_table : CM_EntryTable io) updating;


begin

	_table.rows := 1;
	
end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
</Class>
