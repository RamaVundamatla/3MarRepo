<Class name="CM_DataDumpMaintenanceAgent" id="30b99aae-8857-4895-b42a-dd8ade42ac54">
    <superclass name="CM_DataDumpAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Responsible for maintaining the supporting classes for data dumps, including
the server ini file (for Change Tracker peer schema use).</text>
    <DbClassMap file="cmtrans"/>
    <Constant name="AllClasses" id="ee747d87-3aeb-4ff3-9173-fdbfcab9583f">
        <source>false</source>
        <type name="Boolean"/>
    </Constant>
    <Constant name="AllFeatures" id="764b50ad-3aa7-4ce8-9c8f-c0fd9b2a637c">
        <source>false</source>
        <type name="Boolean"/>
    </Constant>
    <JadeMethod name="changeDataDumpFeatureName" id="72d1ae49-b25f-4600-963a-bda1469456ff">
        <source>changeDataDumpFeatureName(_className : String; _oldFeatureName : String; _newFeatureName : String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 October 2010	#cnwdz2	 

*/

vars
	def   : CM_DataDumpExtractDef;
	class : CM_DataDumpExtractClass;
	feature : CM_DataDumpFeature;
	className,
	featureName : String;
	root  : CM_Root;
	updatedFeature  : Boolean;
begin
	//par25621
	root := CM_Root.firstInstance;
	foreach def in root.allDataDumpExtractDefs do
		if def.extractFormat = CM_DataDumpExtractDef.FmtSQLNative then
			foreach class in def.allDataDumpExtractClasses do : classLoop
				className := class.myDataDumpClass.className;
				if className &lt;&gt; _className then
					continue;
				endif;
				
				foreach feature in class.allDataDumpFeatures do
					featureName := feature.featureName;
					if updatedFeature then
						if featureName &lt;&gt; _newFeatureName then
							continue;
						endif;
						beginTransaction;					
						def.setDefinitionModified(true);
						commitTransaction;
					else
						if featureName &lt;&gt; _oldFeatureName then
							continue;
						endif;
										
						beginTransaction;
						feature.setFeatureName(_newFeatureName);
						def.setDefinitionModified(true);
						commitTransaction;
						updatedFeature := true;						
					endif;									
					
					break classLoop;					
				endforeach;				
			endforeach classLoop;			
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_className" type="String"/>
        <Parameter name="_oldFeatureName" type="String"/>
        <Parameter name="_newFeatureName" type="String"/>
    </JadeMethod>
    <JadeMethod name="createNewDatabaseSQL" id="9032cf18-b05a-40c6-afc3-bea72bc55458">
        <updating/>
        <source>createNewDatabaseSQL(_file: File; _def: CM_DataDumpExtractDef) updating;
// ---------------------------------------------------------------------------
// Created:     20 May 2003 by cnwsb1
//
// Purpose:		Maintains all Data Dump classes and their attributes from the
//				data stored in the text of this method.
//				Also updates server ini file with changes.
//				The data was obtained from the old SQLServerDb structures.
//
//				NB: When loading data from method text, be aware that there
//				is a 65KB limit to method data during a schema load pre-
//				JADE 6.0.16 (see JADE PAR 29803).

//	Updated		
// ---------------------------------------------------------------------------
vars

	ddExClass : CM_DataDumpExtractClass;
	aClass : Class;
	ddFeature : CM_DataDumpFeature;
	feature: Feature;
//	property : Property;
	featureAlias : String;
	typeString : String;
	object : CM_Object;
	type, newType : Type;
	length, newLength : Integer;
	ddExDict : CM_DataDumpExtractClassDict;
		
begin
	
	self.lockMutex("Maintain data dump classes");
	create ddExDict transient;
	foreach ddExClass in _def.allDataDumpExtractClasses do
		ddExDict.add(ddExClass);
	endforeach;
			
	foreach ddExClass in ddExDict do
		aClass := ddExClass.myDataDumpClass.myClass;
		if aClass = CM_VehicleVisitRecord then
			_file.writeLine("DROP TABLE "&amp;"vehicleVisitRecord");
			_file.writeLine("CREATE TABLE "&amp;"vehicleVisitRecord");
		else
			_file.writeLine("DROP TABLE "&amp;ddExClass.myDataDumpClass.classAlias.toLower());
			_file.writeLine("CREATE TABLE "&amp;ddExClass.myDataDumpClass.classAlias.toLower());
		endif;
		_file.writeLine('(');
		_file.writeLine(Tab&amp;"oid objectid NOT NULL,");
		_file.writeLine(Tab&amp;"edition integer,");

		foreach ddFeature in ddExClass.allDataDumpFeatures do
			type := null;
			length := 0;
			featureAlias := ddFeature.getExternalDatabaseFeatureName(aClass, newType, newLength);
			if featureAlias = "edition" or 
			   featureAlias = "oid" then
			   	continue;
			endif;
			if newType = null then
				feature := ddExClass.myDataDumpClass.getFeatureForClass(aClass, ddFeature.featureName);
				if feature = null then
					feature := ddExClass.myDataDumpClass.getFeatureForClass(aClass, featureAlias);
				endif;
				if feature = null then
					feature := ddExClass.myDataDumpClass.getFeatureForSubClass(aClass, ddFeature.featureName);
				endif;
				if feature = null then
					feature := ddExClass.myDataDumpClass.getFeatureForSubClass(aClass, featureAlias);
				endif;
				if feature &lt;&gt; null then
					if feature.isKindOf(Method) and featureAlias &lt;&gt; 'edition' then
						type := feature.Method.getFeatureType();
						if type = String then
							length := 101;
						endif;
					else
						type := feature.type;
						if type = String then
							if feature.Attribute.getLength() &gt; 0 then
								length := feature.Attribute.getLength()-1;
							else
								length := 601;
							endif;
						endif;
					endif;
				else		
					app.writeStatement(ddExClass.myDataDumpClass.classAlias&amp;'::'&amp;ddFeature.featureName&amp;' or '&amp;featureAlias&amp;' no feature.');
				endif;				
			else	
				type := newType;
				length := newLength-1;
			endif;
			if type = null and featureAlias &lt;&gt; "edition" then
				app.writeStatement(ddExClass.myDataDumpClass.classAlias&amp;'::'&amp;ddFeature.featureName&amp;' or '&amp;featureAlias&amp;' type is null');
			endif;
//			// try finding property with the samename of in both Jade and SQL
//			property := aClass.findProperty(ddFeature.featureName);
//			if property = null then
//				// try finding property with alias name in Jade
//				property := aClass.findProperty(featureAlias);
//			endif;
//			if property &lt;&gt; null then
//				type := property.type;
//				length := property.getLength();
//			endif;
//			// still havent found it try using the newType and length from aliasname 
//			if type = null then
//				type := newType;
//				length := newLength;
//			endif;
//			// we still dont have a type
//			// try finding the feature as a method
//			if type = null and
//			   ddFeature.myFeature &lt;&gt; null and
//			   ddFeature.myFeature.isKindOf(Method) then
//				type := ddFeature.myFeature.Method.getType;
//			endif;
//			// attribute may be on a subclass
//			if type = null then
//			endif;
			if featureAlias = "edition"  then
				typeString := 'integer';
			elseif featureAlias = DataDumpOid then
				typeString := "objectid NOT NULL";
			elseif type.isKindOf(Class) or
				   type = Class then
				typeString := "objectid";
			elseif type.name = 'TimeStamp' then
				typeString := "datetime";
			elseif type.name = 'Date' then
				typeString := "date";
			elseif type.name = 'Time' then
				typeString := 'time';
			elseif type.name = 'String' then
				typeString := "varchar("&amp;length.String&amp;")";
			elseif type.name = 'Integer' then
				typeString := "integer";
			elseif type.name = 'Boolean' then
				typeString := "boolean";
			elseif type.name = 'Real' then
				typeString := "real";
			elseif type.name = 'Decimal' then
				if feature.isKindOf(PrimAttribute) then
					typeString := "decimal("&amp;feature.PrimAttribute.precision.Integer.String&amp;','&amp;feature.PrimAttribute.scaleFactor.Integer.String&amp;")";
				else
					typeString := "decimal()";
				endif;
			else
				app.writeStatement( ddExClass.myDataDumpClass.classAlias&amp;'::'&amp;featureAlias&amp;' cant handle type '&amp;type.name);
				typeString := "varchar("&amp;99.String&amp;")";
			endif;
			_file.writeLine(Tab&amp;featureAlias.toLower()&amp;' '&amp;typeString&amp;',');			
		endforeach;
		_file.writeLine(')');
	endforeach;
	
epilog
	delete ddExDict;
	self.unlockMutex;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_def" type="CM_DataDumpExtractDef"/>
    </JadeMethod>
    <JadeMethod name="createNewDbSQLFromEDB" id="e2b803b0-310b-46da-8e87-32c03d2e78e0">
        <source>createNewDbSQLFromEDB(_file: File);

vars
	class : Class;
	property : Property;
	subs : ClassColl;
	propColl : PropertyColl;
	typeString : String;
	str : String;
begin
	create subs transient;
	ExternalObject.allSubclassesInSubschemas(subs);
	foreach class in subs do
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;class.name;
		if class.name[1:4] &lt;&gt; "EDB_" then
			continue;
		endif;
		str := class.name[5:class.name.length].toLower();
		if str = "vehiclevisitrecord" then
			str := "vehicleVisitRecord";
		endif;
		_file.writeLine("DROP TABLE "&amp;str);
		_file.writeLine("CREATE TABLE "&amp;str);
		_file.writeLine('(');
		propColl := class.allProperties();
		foreach property in propColl do
			if property.name[1:1] = '_' then
				continue;
			endif;
			if property.type = String then
				typeString := 'varchar('&amp;(property.getLength()-1).String&amp;')';
			elseif property.type = Binary then
				typeString := 'objectid';
			elseif property.type = TimeStamp then
				typeString := 'datetime';
			elseif property.type = Decimal then
				typeString := "decimal("&amp;property.PrimAttribute.precision.Integer.String&amp;','&amp;property.PrimAttribute.scaleFactor.Integer.String&amp;")";
			else
				typeString := property.type.name;
			endif;
			str := property.name[5:property.name.length];
			str[1:1] := str[1:1].toLower();
			_file.writeLine(Tab&amp;str&amp;' '&amp;typeString.toLower()&amp;',');			
		endforeach;
		_file.writeLine(')');
		_file.writeLine('');
	endforeach;
epilog
	delete subs;
end;
</source>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
    <JadeMethod name="dataDumpGroupChange" id="c276d07c-b17e-40aa-8818-a3cb7110dbfa">
        <source>dataDumpGroupChange(_proxyDdClass : CM_DataDumpClass io;
		_toDeleteProxyFeatures : CM_DataDumpFeatureSet;
		_passport: CM_Passport input) protected;
// ---------------------------------------------------------------------------
// Created:     03 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	newDdClass : CM_DataDumpClass;
	proxyDdFeature : CM_DataDumpFeature;
	
begin
	// Remove any to delete features.
	foreach proxyDdFeature in _toDeleteProxyFeatures do
		_proxyDdClass.allDataDumpFeatures.remove(proxyDdFeature);
	endforeach;
	
	if _proxyDdClass.pxyIsProxy then
		app.myTrxUA.trxUpdateDataDumpClass(_proxyDdClass, _passport);
	else
		app.myTrxCA.trxCreateDataDumpClass(_proxyDdClass, newDdClass, _passport);
	endif;
	if not app.myPassport.trxCompletedOK then
		app.writeStatement(_passport.getErrorsAsString);
	endif;
	
epilog
	delete _proxyDdClass;
end;</source>
        <access>protected</access>
        <Parameter name="_proxyDdClass" type="CM_DataDumpClass" usage="io"/>
        <Parameter name="_toDeleteProxyFeatures" type="CM_DataDumpFeatureSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="extractDefClassChange" id="ff968f7e-79c4-444d-90aa-1090e798db47">
        <source>extractDefClassChange(
		_groupExtractClassName: String io;
		_extractClassName : String;
		_proxyExtractClass: CM_DataDumpExtractClass io;
		_proxyExtractDef : CM_DataDumpExtractDef;
		_realDdClass: CM_DataDumpClass io;
		_realDdFeaturesSorted: CM_DataDumpFeatureArray input;
		_sortedProxyExtractClasses: CM_DataDumpExtractClassArray input) protected;
// ---------------------------------------------------------------------------
// Created:     30 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	// Create proxy for previous extract class group
	if _groupExtractClassName &lt;&gt; null then
		_proxyExtractClass := _proxyExtractDef.getExtractClassByName(_groupExtractClassName);
		if _proxyExtractClass = null then
			_proxyExtractClass := _proxyExtractDef.pxyCreateExtractClass(_realDdClass, _realDdFeaturesSorted);
		else
			_proxyExtractClass.setProxy(_realDdClass, _realDdFeaturesSorted, null, null, null, null, null, null, null, null, null, null, null);
		endif;
		
		_sortedProxyExtractClasses.add(_proxyExtractClass);
	endif;
	
	// setup for new extract class group (if there is one)
	_groupExtractClassName := _extractClassName;
	_realDdFeaturesSorted.clear;
	_realDdClass := app.myRoot.allDataDumpClasses[_extractClassName];
end;</source>
        <access>protected</access>
        <Parameter name="_groupExtractClassName" type="String" usage="io"/>
        <Parameter name="_extractClassName" type="String"/>
        <Parameter name="_proxyExtractClass" type="CM_DataDumpExtractClass" usage="io"/>
        <Parameter name="_proxyExtractDef" type="CM_DataDumpExtractDef"/>
        <Parameter name="_realDdClass" type="CM_DataDumpClass" usage="io"/>
        <Parameter name="_realDdFeaturesSorted" type="CM_DataDumpFeatureArray" usage="input"/>
        <Parameter name="_sortedProxyExtractClasses" type="CM_DataDumpExtractClassArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="extractDefGroupChange" id="8da56ddf-ea55-44c6-999a-0cf010e1a870">
        <source>extractDefGroupChange(
		_groupExtractClassName: String io;
		_extractClassName : String;
		_proxyExtractClass: CM_DataDumpExtractClass io;
		_proxyExtractDef : CM_DataDumpExtractDef io;
		_realDdClass: CM_DataDumpClass io;
		_realDdFeaturesSorted: CM_DataDumpFeatureArray input;
		_sortedProxyExtractClasses: CM_DataDumpExtractClassArray input;
		_passport: CM_Passport input) protected;
// ---------------------------------------------------------------------------
// Created:     30 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	newExtractDef : CM_DataDumpExtractDef;

begin
	// Save prior extract class group proxy and setup for new one
	self.extractDefClassChange(_groupExtractClassName, _extractClassName,
			_proxyExtractClass, _proxyExtractDef, _realDdClass,
			_realDdFeaturesSorted, _sortedProxyExtractClasses);
			
	// Sort the ExtractClassArray
	_proxyExtractDef.allDataDumpExtractClasses.updateSameAsArray(
			_sortedProxyExtractClasses);
	
	// Save prior extract def group data
	if _proxyExtractDef.pxyIsProxy then
		app.myTrxUA.trxUpdateDataDumpExtractDef(_proxyExtractDef, _passport);
	else
		app.myTrxCA.trxCreateDataDumpExtractDef(_proxyExtractDef, newExtractDef, _passport);
	endif;
	if not app.myPassport.trxCompletedOK then
		app.writeStatement(_passport.getErrorsAsString);
	endif;

epilog	
	delete _proxyExtractDef;
	_sortedProxyExtractClasses.clear;
end;</source>
        <access>protected</access>
        <Parameter name="_groupExtractClassName" type="String" usage="io"/>
        <Parameter name="_extractClassName" type="String"/>
        <Parameter name="_proxyExtractClass" type="CM_DataDumpExtractClass" usage="io"/>
        <Parameter name="_proxyExtractDef" type="CM_DataDumpExtractDef" usage="io"/>
        <Parameter name="_realDdClass" type="CM_DataDumpClass" usage="io"/>
        <Parameter name="_realDdFeaturesSorted" type="CM_DataDumpFeatureArray" usage="input"/>
        <Parameter name="_sortedProxyExtractClasses" type="CM_DataDumpExtractClassArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFeaturedClasses" id="274cf387-e3e4-4ea7-977b-aea799c83e15">
        <source>getFeaturedClasses(_classes : ObjectArray input; _sqlTables : StringArray input) protected;
// aug 2005 cnwrs1 this matches the jade class to the sql table
/*
	_classes - the JADE class name
	_sqlTables - the nice name
*/
//13 Jan 2016	cnwrs1	Par 37432 TFS 1268 SQL Native Changes for DPH
//16 Mar 2016	cnwrs1	TFS 1656 SQL Native Event Type and Event Transaction
//09/06/2016	cnwdap1	POL TFS #1963 SQL Native Extract of CM_BulkRelease
//19/01/2017 	cnwrh7	TFS	2929  Additional Fields Required (CM_ReserveSelection/CM_ReserveTI) in SQL Native for Release Requests
//14/07/2022	navsj20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
//29/08/2022	navkc1	ChangeRequest 54568: EUP - Inv Config - Reports and Extracts
//12/09/2022	navpw1	TFS: 54568 - EUP - Inv Config - Reports and Extracts
//14/09/2022    navrk21 TFS ChangeRequest 54635: POL - Are Vessel Crane Move Rates available in SQL Native Extract?
// 04 Oct 2022 	navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
// 13 Oct 2022 	navvt20 ChangeRequest 53424: MTN - MOB - Input Remarks - Jade
// 23 Nov 2022  navmv20 ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance
// 16 Feb 2023  navvt20 TFS CR 55655 Task 55687: Jade - Data Extract
// 25 May 2023	navpw1	TFS: 53902 - Added Data Extract for Vehicle Booking Time Slot
// 26 May 2023	navra1	TFS: 57086 - EUP - Customer Update - New Fields incl Debtor Details incl Financial ID
// 01 June 2023 navlw1 	Bug 58327: MTN - CM_VehicleBookingTimeSlotItem is missing on the data extract
// 30 Jan 2023  navhl20 ChangeRequest 55111: GPHA -- Adding Workpoint to Tracked Item and Transaction Views
// 02 Feb 2024  navnk30 ChangeRequest 62313: ATD - Add feature Marine Service timing
// 28 Feb 2024 	navhl20 Bug 62671: MTN - Expose CM_WorkPointType class for data export to fix the unit test
// 03 Sep 2025 	navbs1	Story 35845: PNL - Cargo forecast string does not contain 'Quantity' field - Dev
vars
	aClass     : Class;
	subClasses : ClassColl;
begin
	if not CM_DataDumpMaintenanceAgent.AllClasses then
		
		_classes.add(CM_AutoIdGenerator); //16 Oct 2020	NDL	TFS 49189
		_sqlTables.add(CM_AutoIdGenerator.name[4:end]); //16 Oct 2020	NDL	TFS 49189
		
		_classes.add(CM_BookingRef); // TFS 2930
		_sqlTables.add(CM_BookingRef.name[4:end]); // TFS 2930
		
		_classes.add(CM_BookingRefItem); // TFS 2930
		_sqlTables.add(CM_BookingRefItem.name[4:end]); // TFS 2930
		
		_classes.add(CM_Bank);
		_sqlTables.add(EDB_Bank.name[5:end]);
		
		_classes.add(CM_BOL);	//10 Jan 2014	NDL	Par 33264
		_sqlTables.add(CM_BOL.name[4:end]);	//10 Jan 2014	NDL	Par 33264
		_classes.add(CM_BOLExtension);	//10 Jan 2014	NDL	Par 33264
		_sqlTables.add(CM_BOLExtension.name[4:end]);	//10 Jan 2014	NDL	Par 33264
		_classes.add(CM_BOLDtl); //16 Oct 2020	NDL	TFS 49189
		_sqlTables.add(CM_BOLDtl.name[4:end]); //16 Oct 2020	NDL	TFS 49189
		
		_classes.add(CM_BulkRelease);							// TFS #1963
		_sqlTables.add(CM_BulkRelease.name[4:end]);				// TFS #1963
		
		_classes.add(CM_ReserveSelection); 				//+TFS2929
		_sqlTables.add(CM_ReserveSelection.name[4:end]);				// +TFS2929
		
		_classes.add(CM_ReserveTI); 				//+TFS2929
		_sqlTables.add(CM_ReserveTI.name[4:end]);				// +TFS2929
		
		_classes.add(CM_TransactionType);	// PAR 33412
		_sqlTables.add(CM_TransactionType.name[4:end]);		// PAR 33412
		
		_classes.add(CM_AuditObject);	// PAR 33412
		_sqlTables.add(CM_AuditObject.name[4:end]);		// PAR 33412
		
		_classes.add(CM_CargoType);
		_sqlTables.add(EDB_Trackeditemtype.name[5:end]);
		
		_classes.add(CM_Carrier);
		_sqlTables.add(EDB_Carrier.name[5:end]);
		
		_classes.add(CM_Charge);
		_sqlTables.add(EDB_Charge.name[5:end]);
		
		_classes.add(CM_CodeGroupLogSpecs);	//10 Jan 2014	NDL	Par 33264
		_sqlTables.add(CM_CodeGroupLogSpecs.name[4:end]);	//10 Jan 2014	NDL	Par 33264
		
		_classes.add(CM_CodeGroup); // TFS 2942
		_sqlTables.add(CM_CodeGroup.name[4:end]); // TFS 2942
		
		_classes.add(CM_Commodity);
		_sqlTables.add(EDB_Commodity.name[5:end]);
		_classes.add(CM_CommodityGroup);
		_sqlTables.add(EDB_Commoditygroup.name[5:end]);
		_classes.add(CM_ConsigneeConsignor);
		_sqlTables.add(EDB_Consigneeconsignor.name[5:end]);
		_classes.add(CM_ConsigneeConsignorGroup);
		_sqlTables.add(EDB_Consigneeconsignorgroup.name[5:end]);
		_classes.add(CM_ContentsStatus);
		_sqlTables.add(EDB_Contentsstatus.name[5:end]);
		_classes.add(CM_Country);
		_sqlTables.add(EDB_Country.name[5:end]);
		_classes.add(CM_DamageInstance);			// PAR 24435
		_sqlTables.add(CM_DamageInstance.name[4:end]);			// PAR 24435
		_classes.add(CM_Delay);                   //28/09/2011 cnwdz2 CCMS 1254 PAR 28270
		_sqlTables.add(CM_Delay.name[4:end]);     //28/09/2011 cnwdz2 CCMS 1254 PAR 28270
		_classes.add(CM_DelayType);               //28/09/2011 cnwdz2 CCMS 1254 PAR 28270
		_sqlTables.add(CM_DelayType.name[4:end]); //28/09/2011 cnwdz2 CCMS 1254 PAR 28270
		_classes.add(CM_Debtor);
		
		_sqlTables.add(EDB_Debtor.name[5:end]);
		
		_classes.add(CM_DebtorTerminal);						//navra1 - TFS 57086 - 26th May 2023
		_sqlTables.add(CM_DebtorTerminal.name[4:end]);			//navra1 - TFS 57086 - 26th May 2023
		
		_classes.add(CM_DocketError);	//10 Jan 2014	NDL	Par 33264
		_sqlTables.add(CM_DocketError.name[4:end]);	//10 Jan 2014	NDL	Par 33264

		
		
		_classes.add(CM_DutyDoc); // PAR 34142
		_sqlTables.add(CM_DutyDoc.name[4:end]); // PAR 34142

		_classes.add(CM_DutyDocItem); // PAR 34142
		_sqlTables.add(CM_DutyDocItem.name[4:end]); // PAR 34142
		
		_classes.add(CM_DutyDocType); // PAR 34142
		_sqlTables.add(CM_DutyDocType.name[4:end]); // PAR 34142
		
		_classes.add(CM_EmailAddress2);  //epr TFS 3418 13/3/17 
		_sqlTables.add(CM_EmailAddress2.name[4:end]); //epr TFS 3418 13/3/17 
		
		_classes.add(CM_EventType);
		_sqlTables.add(CM_EventType.name[4:end]);
		_classes.add(CM_EventTransaction);
		_sqlTables.add(CM_EventTransaction.name[4:end]);
		
		_classes.add(CM_CashReceipt); // PAR 34142
		_sqlTables.add(CM_CashReceipt.name[4:end]); // PAR 34142
		
		_classes.add(CM_CashPayment); // PAR 34142
