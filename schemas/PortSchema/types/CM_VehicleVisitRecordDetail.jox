    <JadeMethod name="setExtraInfo" id="f3b1c60a-9972-4445-b5c9-488b7184dc75">
        <updating/>
        <source>setExtraInfo(_type :Integer; _extra, _context :Any) updating, protected;
/* ---------------------------------------------------------------------------
// Created:     19 May 2009 by concms1
// Purpose:     Par 19715 - Vehicle Visit Record Detail Changes
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/08/2009	cnwcs5		ccms1061 - handle new class CM_LaneController
// 01/09/2009	cnwcs5		ccms1061 - new events for rfid tag
// 25/02/2010	cnwcs5		removed reference to CM_GateLaneController class
// 05/10/2011	cnwrs2		check for null _extra parameter (PAR 28358)
// 17/06/2013	cnwcs5		par 31670 - record qty for breakbulk, new context parameter
// 17/12/2013	cnwdap1		PAR #32849 CCMS PEN 2321 Store bat number in extra info for Security Gate detail
// 13/03/2014	cnwer1		CCMS 1366 BULK changes - new var move Amount will either be quantity for BreakBulk
							or Weight/Volume for Bulk depending on cargo type setup
// 06/04/2023	jlizm1		TFS 57098 EUP Seal numbers on trucks
// ---------------------------------------------------------------------------*/
vars
	id, 
	tiId,
	moveAmount	: String;
	ti			: CM_TrackedItem;
	moveTransaction : CM_Move;
begin

	if _extra = null then		// PAR 28358
		return;
	endif;

	if _type = VisitRecord_Create or
		_type = VisitRecord_Complete_AGate_In or
		_type = VisitRecord_Arrive_PGate_In or
		_type = VisitRecord_Arrive_PGate_Out or
		_type = VisitRecord_Complete_PGate_Out then
		// we expect a CM_LaneController - store area/lane/oid (tab delimited)
		if _extra.isKindOf (CM_LaneController) then		
			self.extraInfo 			:= _extra.CM_LaneController.myTerminalArea.id.asStringJMT &amp; Tab &amp;	// terminal area
										_extra.CM_LaneController.getLaneNumber.asStringJMT &amp; Tab &amp;			// lane
										_extra.CM_LaneController.laneDirection.asStringJMT;			// direction
			self.myExtraInfoObject	:= _extra.CM_LaneController;

		elseif _extra.isKindOf (CM_BlockController) then
			if _extra.CM_BlockController.isPreGateVTA then
				self.extraInfo := _extra.CM_BlockController.myPreGateVTA.id;
			elseif _extra.CM_BlockController.isPostGateVTA then
				self.extraInfo := _extra.CM_BlockController.myPostGateVTA.id;
			elseif _extra.CM_BlockController.isInTransitFrom then						// cnwcs5 10/08/2009
				self.extraInfo := _extra.CM_BlockController.myInterchangeArea_ITF.id;	// cnwcs5 10/08/2009
			elseif _extra.CM_BlockController.isInTransitTo then							// cnwcs5 10/08/2009
				self.extraInfo := _extra.CM_BlockController.myAreaWithLanes_ITT.id;		// cnwcs5 10/08/2009
			endif;
			
			self.myExtraInfoObject	:= _extra.CM_BlockController;
		endif;
		
	elseif _type = VisitRecord_Yard then
		// we expect a CM_YardController
		if not _extra.isKindOf (CM_YardController) then
			return;
		endif;
		
		self.extraInfo			:= _extra.CM_YardController.getFullId;	// full id for area
		self.myExtraInfoObject	:= _extra.CM_YardController;
		
	elseif self.isCargoMove then
		// par 31670 - record quantity for breakbulk
		if _extra.isKindOf (CM_TrackedItem) then
			self.extraInfo			:= _extra.CM_TrackedItem.id;	// id
			self.myExtraInfoObject	:= _extra.CM_TrackedItem;
			
		elseif _extra.isKindOf (CM_WorkListEntry) then
			ti 	:= _extra.CM_WorkListEntry.myTrackedItem;
			//epr TFS 44965 26/6/19
			if ti &lt;&gt; null then
				self.extraInfo	:= ti.id; 
				moveAmount:=_extra.CM_WorkListEntry.getMoveAmountDisplay(true);
					
				if  ti.myCargoType.isBreakBulkMulti or  ti.myCargoType.isBulkMulti then
					if moveAmount &lt;&gt; null then
						self.extraInfo	:= self.extraInfo &amp; '^' &amp; moveAmount;
					endif;
				endif;
							
				self.myExtraInfoObject 	:= ti;

			endif;
			
		//18 Aug 2014	NDL	Par 34665
		elseif _extra.isKindOf (CMIF_MoveController) then
			ti 	:= _extra.CMIF_MoveController.myTrackedItem;
			moveTransaction:=_extra.CMIF_MoveController.myMoveTransaction;
			if moveTransaction &lt;&gt; null then
				self.myExtraInfoObject := moveTransaction;
				//05 Oct 2020	NDL	TFS 49189
				self.setTimeForASPAManualMove( ti.myTerminal, _extra.CMIF_MoveController.myAssociatedVVR, _extra.CMIF_MoveController, null );
			endif;
			if ti &lt;&gt; null then
				self.extraInfo	:= ti.id; 
				moveAmount:=_extra.CMIF_MoveController.getMoveAmountDisplay(true);
				if  ti.myCargoType.isBreakBulkMulti or  ti.myCargoType.isBulkMulti then
					if moveAmount &lt;&gt; null then
						self.extraInfo	:= self.extraInfo &amp; '^' &amp; moveAmount;
					endif;
				endif;
				if moveTransaction = null then
					self.myExtraInfoObject 	:= ti;
				endif;
			endif;
		
		endif;
		
	elseif _type = VisitRecord_AssignRFIDTag or _type = VisitRecord_DeassignRFIDTag then
		
		if _extra &lt;&gt; null then
			self.extraInfo 			:= _extra.CM_RFIDTag.code;
			self.myExtraInfoObject	:= _extra.CM_RFIDTag;
		endif;		
	
	elseif _type = VisitRecord_Cancel then
		self.extraInfo := _extra.String;
		
	elseif _type = VisitRecord_Deleted_Entry then	
		// par 31670 - fix problem where reason for delete was never being recorded
		// _extra contains the reason, context contains the wle
		id 			:= _context.CM_WorkListEntry.id;
		tiId 		:= _context.CM_WorkListEntry.getDisplayStringForAttribute(ETRow_CargoDetails,false);
		
		if id &lt;&gt; tiId then
			id := id &amp; " " &amp; tiId;
		endif;
		
		ti	:= _context.CM_WorkListEntry.myTrackedItem;
		self.extraInfo := _extra.String &amp; '^' &amp; id;
		
		if ti &lt;&gt; null and ( ti.myCargoType.isBreakBulkMulti or  ti.myCargoType.isBulkMulti) then
			moveAmount:=_context.CM_WorkListEntry.getMoveAmountDisplay(true);
			if moveAmount &lt;&gt; null then
				self.extraInfo	:= self.extraInfo &amp; '^' &amp; moveAmount;
			endif;
		endif;
		
		
	elseif _type = VisitRecord_Turnaround then // cnwrd1 par 22624 3.5.2010
		self.extraInfo := _extra.String;		
		
	elseif _type = VisitRecord_ArriveSecurityGate then			// PAR #32849
		self.extraInfo := _extra.String;						// PAR #32849
		
	elseif _type = VisitRecord_WeighBridge  or 
		_type = VisitRecord_WeighBridgeIn or 
		_type = VisitRecord_WeighBridgeOut 		then		//19 Mar 2014	NDL	Par 33268
		self.myExtraInfoObject := _extra.CM_VehicleVisitWeighing;						
	elseif _type = VisitRecord_SwapReleaseCargo then //23/5/14 EPR par 34174
		self.extraInfo := _extra.CM_TrackedItem.id;
	elseif _type = VisitRecord_WayBillPrint then	//26 Aug 2015	NDL	Par 36677
		self.myExtraInfoObject := _extra.CM_WaybillPrintDetail;
	elseif _type = VisitRecord_Bulk_In or _type = VisitRecord_Bulk_Out then	//10 Nov 2016	NDL	TFS 2867 / 2779
		self.extraInfo := _extra.String;
		if _context.isKindOf (CM_WeighBridgeObj) then	
			self.myExtraInfoObject := _context.CM_WeighBridgeObj;
		endif;
	elseif _type = VisitRecord_TruckGrsWeightIn or _type = VisitRecord_TruckGrsWeightOut then	// 20/6/17 MAP TFS4273
		self.extraInfo := _extra.String;
	
	elseif _type = VisitRecord_SealAdd or
		_type = VisitRecord_SealCheck or
		_type = VisitRecord_SealDelete then
		if _extra.isKindOf(CM_TruckSeal) then
			self.extraInfo := _extra.CM_TruckSeal.getSealValueAsString();
			self.myExtraInfoObject := _extra.CM_TruckSeal;
		endif;
		
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_extra" type="Any"/>
        <Parameter name="_context" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e7553597-ccf2-4052-b0f0-f851d82d623d">
        <updating/>
        <source>setForCreate(	_vtaType : Integer;
				_extra, _context : Any;
				_vehicleVisitRecord : CM_VehicleVisitRecord ) updating;
/*

Purpose:		we this is created it shouldn't be setting the dwell end so have left it out	
Return Value:	None	

Date			Who		Reason
15 August 2006	cnwer1	Initial creation - PAR#xxxx
18 May 2009		concms1	Par 19715 - Added _extra parameter
15/09/2009		cnwcs5	ccms 1061 - changed to NOT use app.serverTimestampAtTrxStart as we could
						have several VVRDs created within the same transaction
18 Jun 2013		cnwcs5	par 31670 - new _context parameter	
08 Feb 2024 	navhl20 ChangeRequest 62084:[62379] EUP | Retrospective Operations - [54177.010] - Road Entry	
16 Feb 2024		navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit	
20 Feb 2024 	navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks			
*/
vars
	strExtra	: String;
	lastDetail	: CM_VehicleVisitRecordDetail;
	ti			: TimeStampInterval;
begin 
	self.recordType	:=_vtaType;
	//self.timeStart	:= app.actualTimeServer; // ### TFS 52375 11Nov2021 NAVPW1
	
	// ### TFS 52631 10Jan2022 NAVPW1
	if _vehicleVisitRecord.isRoadJobAutoComplete then
		self.timeStart := _vehicleVisitRecord.timeIn;
	else
		self.timeStart := app.actualTimeServer;
	endif;
	// ### TFS 52631 10Jan2022 NAVPW1
	
	if (_vehicleVisitRecord.myTerminal.roadProcessIsASPA
		and _context &lt;&gt; null
		and _context.isKindOf( TimeStamp )
		and _context.TimeStamp.isValid ) then
		self.setTimeForASPAManualMove( _vehicleVisitRecord.myTerminal, _vehicleVisitRecord, null,  _context.TimeStamp );
	elseif _vehicleVisitRecord.retrospectiveDT.isValid or											//08.02.2023 navhl20 #62084[62379]
		(_context &lt;&gt; null and _context.isKindOf(TimeStamp) and _context.TimeStamp.isValid) then		//16.02.2024 navnk30 #62414
		self.setTimeForRetroMode(_vehicleVisitRecord.myTerminal, _vehicleVisitRecord, _context);	//23.02.2024 navhl20 #62525
	else

		// Make sure that every new detail has a timestamp later then the last detail PAR 27472
		lastDetail := _vehicleVisitRecord.allVehicleVisitRecordDetails.last;
		
		if lastDetail &lt;&gt; null then
			if lastDetail.timeStart &gt;= self.timeStart then
				ti.set(0, 1);
				self.timeStart := lastDetail.timeStart + ti;
			endif;
		endif;
		
	endif;
	
	if _vehicleVisitRecord.retrospectiveDT.isValid and _extra &lt;&gt; null and _extra.isKindOf(CM_TruckSeal) then			//20.02.2024 navhl20 #62525
		self.timeStart := _extra.CM_TruckSeal.sealedDT;
		if _context &lt;&gt; null and _context.isKindOf(CM_TruckSeal) then
			self.timeStart := _context.CM_TruckSeal.sealedDT;
		endif;
	endif;

	self.userCode	:= app.getMyUserCode;				// par 19715

	self.setExtraInfo (_vtaType, _extra, _context);		// par 31670, par 19715
	self.setMyVehicleVisitRecord(_vehicleVisitRecord);
epilog

end;</source>
        <Parameter name="_vtaType" type="Integer"/>
        <Parameter name="_extra" type="Any"/>
        <Parameter name="_context" type="Any"/>
        <Parameter name="_vehicleVisitRecord" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setMyVehicleVisitRecord" id="bc179e0a-1527-4c1a-a044-42ed64c22144">
        <updating/>
        <source>setMyVehicleVisitRecord(_vehicleVisitRecord : CM_VehicleVisitRecord) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.myVehicleVisitRecord &lt;&gt; _vehicleVisitRecord then
		self.myVehicleVisitRecord:= _vehicleVisitRecord;
	endif;
epilog

end;</source>
        <Parameter name="_vehicleVisitRecord" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setTimeForASPAManualMove" id="f555082d-f1dc-438c-a009-3dc7f2c0adce">
        <updating/>
        <source>setTimeForASPAManualMove( _terminal : CM_Terminal; _vvr : CM_VehicleVisitRecord; _moveController : CMIF_MoveController; _ts : TimeStamp ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars
	
	ts : TimeStamp;
	prevVVRD	: CM_VehicleVisitRecordDetail;
	tsi : TimeStampInterval;

begin

	if _vvr = null or _terminal = null then
		return;
	endif;
	
	if _moveController &lt;&gt; null then
		ts := _moveController.effectiveTimeStamp;
	else
		ts := _ts;
	endif;
	
	if not ts.date.isValid then
		return;
	endif;

	if _terminal.roadProcessIsASPA then
	
		//We want to use the 'effective time' off the move controller,
		//but we may need to increment by a millisecond or two so it doesn't clash with any existing VVRD timestamps
		prevVVRD := _vvr.allVehicleVisitRecordDetails.getAtKeyGeq( ts, null );
		if prevVVRD = null or prevVVRD.timeStart &lt;&gt; ts then
			//safe to use, as it is, no one else has it as well
			self.timeStart := ts;
		else
			tsi.set(0, 1);
			while true do
				ts := ts + tsi;
				prevVVRD := _vvr.allVehicleVisitRecordDetails.getAtKeyGeq( ts, null );
				if prevVVRD = null or prevVVRD.timeStart &lt;&gt; ts then
					//OK this one will work.
					self.timeStart := ts;
					break;
				endif;
			endwhile;
		endif;

	endif;

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
        <Parameter name="_ts" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setTimeForRetroMode" id="3a8edfdb-c8c0-4004-a209-530c7bc7bc24">
        <updating/>
        <source>setTimeForRetroMode( _terminal : CM_Terminal; _vvr : CM_VehicleVisitRecord; _context : Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Feb 2024 navhl20 ChangeRequest 62084:[62379] EUP | Retrospective Operations - [54177.010] - Road Entry
16 Feb 2024	navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit
23 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
*/

vars
	ts 			: TimeStamp;
	prevVVRD	: CM_VehicleVisitRecordDetail;
	tsi 		: TimeStampInterval;
begin

	if _vvr = null or _terminal = null then
		return;
	endif;
	
	if _vvr.timeOut.isValid then		//16.02.2024 navnk30 #62414
		ts := _vvr.timeOut;
	else
		ts := _vvr.timeIn;
	endif;
	
	if _context.isKindOf(TimeStamp) and _context.TimeStamp.isValid then			//23.02.2024 navhl20 #62525
		ts := _context.TimeStamp;
	endif;
	
	if not ts.date.isValid then
		return;
	endif;

	//We want to use the 'effective time' off the move controller,
	//but we may need to increment by a millisecond or two so it doesn't clash with any existing VVRD timestamps
	prevVVRD := _vvr.allVehicleVisitRecordDetails.getAtKeyGeq( ts, null );
	if prevVVRD = null or prevVVRD.timeStart &lt;&gt; ts then
		//safe to use, as it is, no one else has it as well
		self.timeStart := ts;
	else
		tsi.set(0, 1);
		while true do
			ts := ts + tsi;
			prevVVRD := _vvr.allVehicleVisitRecordDetails.getAtKeyGeq( ts, null );
			if prevVVRD = null or prevVVRD.timeStart &lt;&gt; ts then
				//OK this one will work.
				self.timeStart := ts;
				break;
			endif;
		endwhile;
	endif;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_context" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setTimeForSecurityGateExit" id="c7e1413c-9964-4c95-b34d-8e6014c13583">
        <updating/>
        <source>setTimeForSecurityGateExit(_dateTime : TimeStamp) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 31/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
//
vars

begin
	if self.timeStart &lt;&gt; _dateTime then
		self.timeStart := _dateTime;
	endif;
epilog

end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setTimeStart" id="d43f76a4-55f5-442b-986f-fafd481c7363">
        <updating/>
        <source>setTimeStart(_dt : TimeStamp)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks

*/

vars

begin
	self.timeStart := _dt;
epilog

end;</source>
        <Parameter name="_dt" type="TimeStamp"/>
    </JadeMethod>
</Class>
