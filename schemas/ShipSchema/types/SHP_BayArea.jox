    <JadeMethod name="amPrinting" id="56bbea71-a6ad-48a2-a7c4-52d86fac8cf7">
        <source>amPrinting() : Boolean;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	amPrinting : Boolean;
begin
	if self.mySDF = null then
		return false;
	endif;
	
	amPrinting := self.iAmPrinting or self.mySDF.amPrinting;
	
	return amPrinting;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
