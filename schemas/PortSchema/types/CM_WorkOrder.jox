    <JadeMethod name="getTaskSequenceNumber" id="345ea5b6-ac8a-47c5-8b7d-18693d5875a9">
        <source>getTaskSequenceNumber(_task : CM_WorkOrderDtl) : Integer;

/*

Purpose:			Return the sequence number for a particular task.  
					The sequence number is incremented for tasks that are of the same type as the task passed in.

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2009	cnwmd1	Initial creation

*/

vars
	type : Class;
	wodtl : CM_WorkOrderDtl;
	seq : Integer;
	found : Boolean;
begin
	type := _task.class;
	seq := 1;
	
	foreach wodtl in self.allWoDtls do
		if wodtl.class = _task.class then
			if wodtl = _task then
				found := true;
				break;
			endif;
			seq := seq + 1;
		endif;
	endforeach;
	
	if not found then
		app.raiseUnexpectedProgramError(self.class.name, method.name, "Developer error - task not found in this work order");
	endif;
epilog
	return seq;
end;</source>
        <Parameter name="_task" type="CM_WorkOrderDtl"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTasksSelectedForDelete" id="8acb99e9-ae26-416d-a52c-1e513b949a0b">
        <source>getTasksSelectedForDelete(_pxyWorkOrder : CM_WorkOrder; _tasksToDelete : CM_WorkOrderDtlArray input);

/*

Purpose:		Get the tasks that the user has requested to be deleted	

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2009	cnwmd1	Initial creation

*/

vars
	pxyTask, realTask : CM_WorkOrderDtl;
	pxyPos, realPos : Integer;
	dynaDict : DynaDictionary;
	//objsToRemove : CM_WorkOrderDtlArray;
begin
	create dynaDict transient;
	dynaDict.setMembership(CM_WorkOrderDtl);
	dynaDict.addMemberKey(CM_WorkOrderDtl::taskID.name, false, true);
	dynaDict.endKeys(true);
	
	_pxyWorkOrder.allWoDtls.copy(dynaDict);
	
	
	foreach realTask in self.allWoDtls do
		
		//realPos := self.allWoDtls.indexOf(realTask);
		pxyTask := dynaDict.getAtKey(realTask.taskID).CM_WorkOrderDtl;
		
		if pxyTask = null then //Pxy Task has been removed
			_tasksToDelete.add(realTask);
		endif;
				
	endforeach;
epilog
	delete dynaDict;
end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrder"/>
        <Parameter name="_tasksToDelete" type="CM_WorkOrderDtlArray" usage="input"/>
    </JadeMethod>
