/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Apr 2013	cnwndl1	Initial creation	Par 31393
10 Sep 2021	navdap1	TFS 51248 SNO Truck Appointment and Pre-Notes - new signature
24 May 2023 navhl20 Defect 58041: MTN - Unable to copy the slots with the status "Booked - Current"
*/

vars

begin

	self.raiseExceptionIfNull(_proxy, app.getErrorString(Vehicle_schedul_booking_slot));
	
	//_proxy.validateForCreate();							// TFS 51248
	_proxy.validateForCreate(_deliveryIds, _pickupIds,_isCopy);		// TFS 51248		//24.5.2023 navhl20 #58041

epilog

end;</source>
