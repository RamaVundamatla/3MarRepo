    <JadeMethod name="addToAlerts" id="544b6a8a-5f3f-48c5-82ba-136559e29702">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_AlertAlarm::addToAlerts"/>
        </interfaceImplements>
        <updating/>
        <source>addToAlerts(_alert: CM_SystemAlert) updating;
/*
----------   ----------  --------------------------------------------------
Created:	15 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	//terminal : CM_Terminal;
begin
	if not self.allAlerts.includes(_alert) then
		self.allAlerts.add(_alert);
	endif;
	
	/*- cnwmd1, CCMS 1871 - No longer required.  app.causeEventForSystemAlertType method is called in CM_SystemAlert::commitAlert()
	terminal := self.getTerminalForAlert;
	if terminal &lt;&gt; null and _alert.mySystemAlertType &lt;&gt; null then
		//terminal.causeEvent(_alert.mySystemAlertType.type,false,_alert); //- cnwmd1, CCMS 1871
		app.causeEventForSystemAlertType(_alert, terminal); 				//+ cnwmd1 CCMS 1871
	endif;
	*/
epilog

end;


</source>
        <Parameter name="_alert" type="CM_SystemAlert"/>
    </JadeMethod>
