    <JadeMethod name="colourSelectedSprite" id="18eaa070-daf5-4bd8-82af-76971e03be88">
        <source>colourSelectedSprite(_selectedMovement : CMIF_HMS_WorkingMovement; _scrollToSelected : Boolean) protected;
//--------------------------------------------------
// Created:	04 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	refreshReq : Boolean;
	dragPic 	: HMS_GraphicalDragPicture;
	
begin

	foreach dragPic in self.allDragPictures do
		if (not global.isValidObject(dragPic.myWorkingMovement)) then
			delete dragPic;
			refreshReq	:=	true;
			break;
		else
			// The following will apply colors to the sprite.
			dragPic.colourSelectedSprite3(_selectedMovement, _scrollToSelected, self.aAllRestrictedWorkingVoyages);
		endif;
	endforeach;

	if refreshReq then
		app.msgBox(class.name &amp; ' ' &amp; method.name &amp; ' ' &amp; app.getErrorString(HMS_Voyage_Updated), app.getErrorString(Voyage_Updated), MsgBox_OK_Only+MsgBox_Stop_Icon);
		self.myViewController.doRefreshView(false);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_selectedMovement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_scrollToSelected" type="Boolean"/>
    </JadeMethod>
