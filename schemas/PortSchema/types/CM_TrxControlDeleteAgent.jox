    <JadeMethod name="trxDeleteDocketError" id="58e1689d-0a17-4dc7-a905-082b95344bf2">
        <updating/>
        <source>trxDeleteDocketError(_logDocketError : CM_DocketError io; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwas3	Initial creation

*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	self.raiseExceptionIfNull(_logDocketError, app.getErrorString(Docket_error));

	app.setContinueCMExceptions(false);

	beginTransaction;

	self.exclusiveLockObjectToDelete(_logDocketError);

	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	if _passport.noErrors then
		app.myUtilityDA.myDeleteAuditAgent.audDeleteGeneric(_logDocketError);
	endif;

	if _passport.noErrors then
		_logDocketError.erase(NORMAL_ERASE);
	endif;

epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_logDocketError" type="CM_DocketError" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
