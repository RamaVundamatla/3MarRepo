    <JadeMethod name="getOOWCreation" id="fe6bdcc1-1cbe-4ca4-bc7a-4fb2940c4321">
        <source>getOOWCreation(_order : Integer io);
// ---------------------------------------------------------------------------
// Created:		April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	hatch : CM_HatchLid;
	incr : Boolean;
	//, use40Id : Boolean;
	srSet : CM_SlotRequestSet;
	deck : Integer;
	slotReq : CM_SlotRequest;
	oowc : CM_OOWCreation;
//	bayID : String;
	cvs : CM_CellularVoyageStructure;
	fwdForty : Boolean;
begin
	cvs := self.myCellularVoyageStructure;

	// ### no colour coding at all
//	if self.allSlotRequestByMoveType.isEmpty then // PAR 17802 do a purge every time
		foreach oowc in cvs.allOOWCreations do
			if oowc.myBay = self then 
				delete oowc;
			endif;
		endforeach;
//		return ;// PAR 17802
//	endif;// PAR 17802

	// PAR 17802
	if self.allSlotRequestByMoveType.isEmpty then
		return ;
	endif;
	
//	use40Id := cvs.use40Id;
//	bayID := self.id;
	
	fwdForty := self.isForwardBay() and self.canHandle4045();

	create srSet transient;
	
	// 
	// Shift On Board UNDER DECK 
	self.getOOWCreationSub(srSet,_order, false,DeckUnderDeck,true,true);
	if fwdForty then
		self.getOOWCreationSub(srSet,_order, true,DeckUnderDeck,true,true);
	endif;
	
	// Shift On Board ON DECK
	self.getOOWCreationSub(srSet,_order, false,DeckOnDeck,true,true);
	if fwdForty then
		self.getOOWCreationSub(srSet,_order, true,DeckOnDeck,true,true);
	endif;
	
	// DISCHARGE ON DECK 
	self.getOOWCreationSub(srSet,_order, false,DeckOnDeck,false,false); // 20s
	if fwdForty then
		self.getOOWCreationSub(srSet,_order, true,DeckOnDeck,false,false); // 40s
	endif;

	// DISCHARGE UNDER DECK 
	self.getOOWCreationSub(srSet,_order, false,DeckUnderDeck,false,false); // 20s
	if fwdForty then
		self.getOOWCreationSub(srSet,_order, true,DeckUnderDeck,false,false); // 40s
	endif;
	
	// LOADS UNDER DECK 
	self.getOOWCreationSub(srSet,_order, false,DeckUnderDeck,true,false);
	if fwdForty then
		self.getOOWCreationSub(srSet,_order, true,DeckUnderDeck,true,false);
	endif;
	
	// LOADS ON DECK
	self.getOOWCreationSub(srSet,_order, false,DeckOnDeck,true,false);
	if fwdForty then
		self.getOOWCreationSub(srSet,_order, true,DeckOnDeck,true,false);
	endif;
epilog
	delete srSet;
end;</source>
        <Parameter name="_order" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getOOWCreationSub" id="a9a7d230-9861-4a3b-b307-8d489a4a2517">
        <source>getOOWCreationSub(_srSet : CM_SlotRequestSet input; _order : Integer io; _get40 : Boolean; _deck : Integer; _getLoad : Boolean; _getSOB : Boolean);
// ---------------------------------------------------------------------------
// Created:		April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	deck : Integer;
	slotReq : CM_SlotRequest;
	oowc : CM_OOWCreation;
	cvs : CM_CellularVoyageStructure;
	invalid : Boolean;
	ct : Integer;
begin
	cvs := self.myCellularVoyageStructure;
	deck := _deck;	
	_srSet.clear;
	self.getActiveSlotReqsForCCByDeck(deck, _srSet, _get40, _getLoad, _getSOB);

	on Exception do app.handleDeletedObject(exception, slotReq, invalid);
	foreach slotReq in _srSet do
		invalid := false;
		// Dereference slotReq to check if valid
		ct := slotReq.cargoType;
		
		if invalid then		// not global.isValidObject(slotReq) then
			_srSet.remove(slotReq);
		endif;
	endforeach;	
	
	if _srSet.isEmpty then
		oowc := cvs.getOOWCreationDetail(self,deck,  _order, _get40, false, _getLoad, _getSOB); // get or create
		delete oowc;
		return;
	endif;

	oowc := cvs.getOOWCreationDetail(self,deck,  _order, _get40, true, _getLoad, _getSOB); // get or create
	oowc.clear();
	
	foreach slotReq in _srSet do		
		oowc.CM_OOWCreationDetail.setFromSlotRequest(slotReq, _get40);
	endforeach;	

	_order := _order + CM_OOWCreation.OOWCreationIncrement;
		
end;</source>
        <Parameter name="_srSet" type="CM_SlotRequestSet" usage="input"/>
        <Parameter name="_order" type="Integer" usage="io"/>
        <Parameter name="_get40" type="Boolean"/>
        <Parameter name="_deck" type="Integer"/>
        <Parameter name="_getLoad" type="Boolean"/>
        <Parameter name="_getSOB" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPlanningGuide" id="612b9378-ebbe-41be-9930-cfcfa0c8e1ff">
        <source>getPlanningGuide(_guide : CMIF_PlanningGuideBay input);
/*
------------------------------------------------------------------------
Created:			21 November 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
---------------------------------------------------------------------------
*/
vars
	hatch : CM_HatchLid;
	use40Id : Boolean;
	srSet : CM_SlotRequestSet;
	cc : Integer;
	slotReq : CM_SlotRequest;
begin

	if _guide = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'Guide reference', null, null);
	endif;
	use40Id := self.myCellularVoyageStructure.use40Id;
	//----------------------------------------
	// Get number of hatch lids for this bay
	//----------------------------------------
	foreach hatch in self.allHatchLids do
		if not hatch.startsAtBay(self.ordinalBay) then
			//only count them on the first bay
			continue;
		endif;
		if use40Id then
			//If a twin bay hatch lid and using 40 nomenclature
			if _guide.is40Bay then
				_guide.hatchLids := _guide.hatchLids +1;
			endif;
		else
			_guide.hatchLids := _guide.hatchLids +1;
		endif;	
	endforeach;
	//----------------------------------------
	// Get the remarks indicator
	//----------------------------------------
	_guide.hasRemarks := self.hasRemarks;
	//------------------------------------------------------------------------
	// Get the slot counts for this bay, both discharge and load colourcodes
	//------------------------------------------------------------------------
	create srSet transient;
	
	foreach cc in DISCHARGE_COLOURCODE to LOAD_COLOURCODE do
		self.getActiveSlotReqsForColourCode(cc, srSet);
		foreach slotReq in srSet do
			slotReq.getPlanningGuide(_guide, use40Id, cc);
		endforeach;		
	endforeach;
epilog
	delete srSet;
end;</source>
        <Parameter name="_guide" type="CMIF_PlanningGuideBay" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSlotController" id="6e2fa738-8fa9-4d3e-acbf-2b65d9a06756">
        <source>getSlotController(ordinalDeck, ordinalCell, ordinalTier : Integer) : CM_SlotController;
// Get the slot controller for this bay slot
begin
	return self.allSlotControllersByOrdinal[ordinalDeck, ordinalCell, ordinalTier];
end;
</source>
        <Parameter name="ordinalDeck" type="Integer"/>
        <Parameter name="ordinalCell" type="Integer"/>
        <Parameter name="ordinalTier" type="Integer"/>
        <ReturnType type="CM_SlotController"/>
    </JadeMethod>
    <JadeMethod name="getSlotControllersBetween" id="07246eff-615b-4341-afc1-4019ea4e4a5c">
        <source>getSlotControllersBetween(_slotFrom, _slotTo : CM_SlotController; _includeUnavailable : Boolean; _selectedSlots: ObjectSet input);
// ---------------------------------------------------------------------------
// Created:     05 February 2004 by cnwrs2
//
// Purpose:     
//
// Note:	If this method needs to be altered you should consider altering
//			CM_Bay.getSlotDefnsBetween as well
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
22 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars
	deckFrom, deckTo,
	cellFrom, cellTo,
	tierFrom, tierTo,
	tmpDeck, 
	tmpCell,
	tmpTier	: Integer;
	tmpSlotController	: CM_SlotController;
	iter		: Iterator;
begin

	if _slotFrom = null or
	   _slotTo = null then
		app.raiseCMException1(MethodWithNullParam, 'slotFrom or slotTo', null, null);
		return;
	endif;
	
	deckFrom := _slotFrom.ordinalDeck;
	tmpDeck := _slotTo.ordinalDeck;

	if deckFrom &lt;&gt; tmpDeck then
		app.raiseUnexpectedProgramError(class.name, method.name, 'The slot from/to must have the same deck ordinal');
		return;
	endif;

	cellFrom := _slotFrom.ordinalCell;
	tierFrom := _slotFrom.ordinalTier;

	tmpCell := _slotTo.ordinalCell;
	tmpTier := _slotTo.ordinalTier;
	
	deckTo := tmpDeck.max(deckFrom);
	cellTo := tmpCell.max(cellFrom);
	tierTo := tmpTier.max(tierFrom);

	deckFrom := tmpDeck.min(deckFrom);
	cellFrom := tmpCell.min(cellFrom);
	tierFrom := tmpTier.min(tierFrom);

	iter := self.allSlotControllersByOrdinal.createIterator;
	
	self.allSlotControllersByOrdinal.startKeyGeq(deckFrom, cellFrom, tierFrom, iter);

/*
write class.name &amp; '::' &amp; method.name &amp; '  getting slots from ' &amp;
		deckFrom.String &amp; ' - ' &amp; deckTo.String &amp; ' :: ' &amp;
		cellFrom.String &amp; ' - ' &amp; cellTo.String &amp; ' :: ' &amp;
		tierFrom.String &amp; ' - ' &amp; tierTo.String;
*/	
	while iter.next(tmpSlotController) do
		self.allSlotControllersByOrdinal.getIteratorKeys(tmpDeck, tmpCell, tmpTier, iter);
		if tmpDeck &gt; deckTo then
			break;
		elseif deckFrom = deckTo and tmpCell &gt; cellTo then
			break;
		elseif deckFrom = deckTo and cellFrom = cellTo and tmpTier &gt; tierTo then
			break;
		endif;	

		if tmpCell &gt;= cellFrom and 
		   tmpCell &lt;= cellTo and
		   tmpTier &gt;= tierFrom and
		   tmpTier &lt;= tierTo then
			if (not _includeUnavailable) and
			   tmpSlotController.mySlotDefnVoyage.unavailable then
				// do nothing
			elseif (not _selectedSlots.includes(tmpSlotController)) then
				_selectedSlots.add(tmpSlotController);
			endif;
		endif;
	endwhile;
	
epilog
	delete iter;		// PAR #26678
	
end;</source>
        <Parameter name="_slotFrom" type="CM_SlotController"/>
        <Parameter name="_slotTo" type="CM_SlotController"/>
        <Parameter name="_includeUnavailable" type="Boolean"/>
        <Parameter name="_selectedSlots" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTierPileWeight" id="f5b917c8-9be4-45fe-978a-f05cbbe45544">
        <source>getTierPileWeight(_ordinalDeck,_ordinalTier:Integer):Decimal;
/*

Date		Who		Reason
04 Jun 2010	cnwkpd1	PAR #24281 - Planning performance changes

*/

vars
	pileWeight		: Decimal[14,4];
	ordinalCell		: Integer;
	ti				: CM_TrackedItem;
	slotController	: CM_SlotController;
	is40Back		: Boolean;
	
begin
	if _ordinalDeck = DeckOnDeck then
		ordinalCell := self.allCellsOnDeck.size;
	else
		ordinalCell := self.allCellsUnderDeck.size;
	endif;	
	slotController := self.allSlotControllersByOrdinal[_ordinalDeck,ordinalCell,_ordinalTier];
	while true do
		if slotController = null then
			break;
		endif;
		is40Back := slotController.isFortyBack;			// PAR #24281 - get this once outside the loop
		foreach ti in slotController.allTrackedItems do
			//total weight of all ti's in pile (current cell)
			if ti.isAttributeTrue(TI_Attrib_IsForty) and is40Back then		// PAR #24281
				  // do not include the back end of a 40 footer			
			else
				pileWeight := pileWeight + ti.totalWeight;
			endif;
		endforeach;
		ordinalCell := ordinalCell - 1;
		if ordinalCell &lt; 1 then
			break;
		endif;
		slotController := self.allSlotControllersByOrdinal[_ordinalDeck,ordinalCell,_ordinalTier];
	endwhile;
	return pileWeight;
end;</source>
        <Parameter name="_ordinalDeck" type="Integer"/>
        <Parameter name="_ordinalTier" type="Integer"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTierPileWeightRounded" id="3bfcf7c2-53ed-42b0-bd1f-6e666d120cc1">
        <source>getTierPileWeightRounded(_mode, _ordinalDeck,_ordinalTier:Integer; interTermVoyage: CM_Voyage):Integer;

/*

Date		Who		Reason
16 Dec 2008	cnwkpd1	PAR #18664 - Performance improvements - change to skip unwanted slots
04 Jun 2010	cnwkpd1	PAR #24281 - Reinstate missing initial startKeyGeq code

*/

vars
	tierWeight,
	splitWeight		: Integer;
	slotController	: CM_SlotController;
	tmpDict			: CM_SlotLCByDeckCellTier;
	iter			: Iterator;
	keyDeck,
	keyCell,
	keyTier			: Integer;
	tier : CM_TierDefn;
	slotDefn : CM_SlotDefn;
begin
	if _ordinalDeck = DeckOnDeck then
		tier := self.allTiersOnDeck[_ordinalTier];
	else
		tier := self.allTiersUnderDeck[_ordinalTier];
	endif;
	
	if tier = null then
		return null;
	endif;
	
	foreach slotDefn in tier.allSlotDefinitions do
		slotController := slotDefn.CM_SlotDefnVoyage.mySlotController;
		if slotController = null then
			continue;
		endif;
			tierWeight := tierWeight + slotController.getWeightRounded(_mode, interTermVoyage, splitWeight);
	endforeach;
	
	return tierWeight;
	
	
	tmpDict	:= self.allSlotControllersByOrdinal;
	iter := tmpDict.createIterator;

	tmpDict.startKeyGeq(_ordinalDeck, null, _ordinalTier, iter);
	while iter.next(slotController) do
		tmpDict.getIteratorKeys(keyDeck, keyCell, keyTier, iter);
		
		// If we have read past the required deck, then we're finished
		if keyDeck &lt;&gt; _ordinalDeck then
			break;
		endif;
		
		// If the current tier is lower than the one we want, then skip forward in the current
		// cell to the tier we want
		if keyTier &lt; _ordinalTier then
			tmpDict.startKeyGeq(keyDeck, keyCell, _ordinalTier, iter);
			continue;
		endif;
		
		// if the current tier is greater than the one we want, then skip forward to the tier we
		// want in the next cell
		if keyTier &gt; _ordinalTier then
			tmpDict.startKeyGeq(keyDeck, keyCell + 1, _ordinalTier, iter);
			continue;
		endif;
		
		// If we get to here, then we must have a match
		tierWeight := tierWeight + slotController.getWeightRounded(_mode, interTermVoyage, splitWeight);
	
	endwhile;
		

	return tierWeight;
	
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_ordinalDeck" type="Integer"/>
        <Parameter name="_ordinalTier" type="Integer"/>
        <Parameter name="interTermVoyage" type="CM_Voyage"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalCells" id="3791732b-b6e6-4406-b37c-418316ff076e">
        <source>getTotalCells() : Integer;
/*
Purpose:		PAR 37240	
Date		Who		Reason
11 December 2015	cnwab1	Initial creation
*/

vars
	ordinalDeck, ordinalCell, ordinalTier,numCell, maxCell, totalCells  : Integer;
	ti : CM_TrackedItem;
	slotController : CM_SlotController;
begin
	
	foreach ordinalDeck in DeckUnderDeck to DeckOnDeck do
		foreach ordinalTier in 1 to 40 do
			numCell := 0;
			foreach ordinalCell in 1 to 40 do
				slotController := self.allSlotControllersByOrdinal[ordinalDeck,ordinalCell,ordinalTier];
				if slotController = null then
					break;
				endif;
				numCell := numCell + 1;
			endforeach;
			
			maxCell := maxCell.max(numCell);
		endforeach;
	endforeach;
	
	return maxCell;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalTiers" id="4ad52c67-a0d9-4191-a4c8-2dcb5e943044">
        <source>getTotalTiers(_onDeck, _underDeck: Boolean) : Integer;
/*
Purpose:		PAR 37240	
Date		Who		Reason
11 December 2015	cnwab1	Initial creation
28/11/2017	MAP		TFS7494
*/

vars
//	ordinalDeck, ordinalCell, ordinalTier,numTier, maxTier,
	totalTiers  : Integer;
//	ti : CM_TrackedItem;
//	slotController : CM_SlotController;
	tier: CM_TierDefn;
begin
/*	
	foreach ordinalDeck in DeckUnderDeck to DeckOnDeck do
		maxTier := 0;
		foreach ordinalCell in 1 to 40 do
			numTier := 0;
			foreach ordinalTier in 1 to 40 do
				slotController := self.allSlotControllersByOrdinal[ordinalDeck,ordinalCell,ordinalTier];
				if slotController = null then
					break;
				endif;
				if slotController.getCellDefn().isTotallyUnavailable() then
					continue;
				endif;
				numTier := numTier + 1;
			endforeach;
			
			maxTier := maxTier.max(numTier);
		endforeach;
		totalTiers := totalTiers + maxTier;
	endforeach;
*/
	if _onDeck then
		foreach tier in self.allTiersOnDeck where not tier.isTotallyUnavailable() do
			totalTiers := totalTiers + 1;
		endforeach;
	endif;

	if _underDeck then
		foreach tier in self.allTiersUnderDeck where not tier.isTotallyUnavailable() do
			totalTiers := totalTiers + 1;
		endforeach;
	endif;

	return totalTiers;

epilog

end;</source>
        <Parameter name="_onDeck" type="Boolean"/>
        <Parameter name="_underDeck" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWorkTotals" id="26bbc564-4937-4b12-8dd5-f3613c675d1b">
        <source>getWorkTotals(_totalWLEs : Integer output; _totalCompleted : Integer output);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 Sep 2011	cnwer1	Initial creation CCMS MES 1033
16 Nov 2011	cnwkpd1	PAR #28699 - Performance issues from JBL testing

*/

vars
	request : CM_SlotRequest;
	iter 	: Iterator;
	wle 	: CM_WorkListEntry;
	loadState : Boolean;
	
begin
	_totalWLEs:=0;
	_totalCompleted:=0;
	
	app.cmsBeginLoad(loadState);		// PAR #28699
	iter:= self.allSlotRequestByMoveType.createIterator;
	while iter.next(request) do
		if not request.isValidForJobStats() then
			continue;
		endif;
		
		foreach wle in request.allWorkListEntries do
			_totalWLEs:=_totalWLEs + 1;
			if wle.status = WLE_COMPLETED then
				_totalCompleted:=_totalCompleted + 1;
			endif;
		endforeach;
	endwhile;
		
epilog
	app.cmsEndLoad(loadState);			// PAR #28699
	delete iter;
end;</source>
        <Parameter name="_totalWLEs" type="Integer" usage="output"/>
        <Parameter name="_totalCompleted" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="hasPlannedTIs" id="3aee35c6-9573-4cc3-bca6-a2668a060d9b">
        <source>hasPlannedTIs(_isLoad : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aOK : Boolean;
	aSlotController : CM_SlotController;
begin
	aOK := false;
	
	foreach aSlotController in self.allSlotControllersByOrdinal do
		if aSlotController.hasPlannedTIs(_isLoad) then
			aOK := true;
			break;
		endif;
	endforeach;
	
	return aOK;
end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasTIsToDischarge" id="6fbd03fe-de29-4f66-a34c-d8883214f92a">
        <source>hasTIsToDischarge() : Boolean;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		have i got any slots that have real TIs that are colour coded for discharge
// ---------------------------------------------------------------------------
vars
	theSlotController : CM_SlotController;
	aOK : Boolean;
begin
	aOK := false;
	foreach theSlotController in self.allSlotControllersByOrdinal do
		if not theSlotController.allTrackedItems.isEmpty and theSlotController.mySlotRequestDischarge &lt;&gt; null then
			aOK := true;
			break;
		endif;
	endforeach;

	return aOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isBridgeAfterBay" id="e1c835aa-0258-4971-b607-400a3b450281">
        <source>isBridgeAfterBay(): Boolean;

vars

begin

	return self.myCellularVoyageStructure.bridgeAfterBay = self.id;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="1ab67ee2-5c78-46c2-9be3-63ff7ceaed47">
        <updating/>
        <source>setForCreate(_proxyBay: CM_Bay; _realVesselVoyage: CM_CellularVoyageStructure; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	_proxyBay.raiseExceptionIfNotTransient(method);

	// these need to be set here, so that teh collections by labels and ordinal are correct
	//  otherwise when we link the bays and slots this bay on the end is put at the front.
	self.id := _proxyBay.id;
	self.ordinalBay := _proxyBay.ordinalBay;
	
	self.setMyVoyageStructure(_realVesselVoyage);
	// use the proxy hold's ordinal to get the matching, by ordinal, real hold
	if _proxyBay.myHold &lt;&gt; null then
		self.myHold := self.myCellularVoyageStructure.allHolds[_proxyBay.myHold.ordinalHold];
	endif;
	self.myCellularVoyageStructure.updateBayLinks();
	inheritMethod(_proxyBay, _realVesselVoyage, _passport);

end;</source>
        <Parameter name="_proxyBay" type="CM_Bay"/>
        <Parameter name="_realVesselVoyage" type="CM_CellularVoyageStructure"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForDelete" id="5b9556dc-1c85-4c3a-aa51-c8386b637e0f">
        <updating/>
        <source>setForDelete() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	delete self;

end;</source>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d1026ed0-992d-477f-9a44-7baebbafefb3">
        <updating/>
        <source>setForUpdate(_proxy:SelfType; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     12 June 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	
	//have to do this before the inheritMethod()
	self.myCellularVoyageStructure	:= _proxy.myCellularVoyageStructure.pxyGetRealObject();	

	// use the proxy hold's ordinal to get the matching, by ordinal, real hold
	if _proxy.myHold &lt;&gt; null then
		self.myHold := self.myCellularVoyageStructure.allHolds[_proxy.myHold.ordinalHold];
	endif;
	
	inheritMethod(_proxy, _passport );

	//have to do this after the inheritMethod()
	self.setMyVoyageStructure(self.myCellularVoyageStructure);	//JC 18/02/2004   this updates my40Voyage if necessary

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateSlots" id="08c4a0c8-74c9-483c-b45f-e32836c269fb">
        <updating/>
        <source>setForUpdateSlots(_iCreatedCellsTeirs: Boolean; _proxy: SelfType; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	//epr TFS 2759 13/12/16 always update any existing slots
	inheritMethod(_iCreatedCellsTeirs, _proxy, _passport);
	/*
	if self.myCellularVoyageStructure.myVoyage.isActiveCargoExchange() then
		inheritMethod(_iCreatedCellsTeirs, _proxy, _passport);
	else
		// PAR 8129 is empty so purge slots and start again and have added cells or teirs so purge and create new. 
		// 			NOTE this will lose all attributes on the slot defn!!!
		if _iCreatedCellsTeirs then
			self.createSlots(); 
		else
			inheritMethod(_iCreatedCellsTeirs, _proxy, _passport);
		
		endif;
	endif;*/

end;</source>
        <Parameter name="_iCreatedCellsTeirs" type="Boolean"/>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setKPIVoyageBayCrane" id="0385043c-dd6d-495c-86b4-be6bd15c62c8">
        <updating/>
        <source>setKPIVoyageBayCrane() updating;
// ---------------------------------------------------------------------------
// Created:     MAY 2010 ANDREW BISHOP
//
// new 2010 KPIs, based on getKPIVoyageBayMovesTRAN
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------


vars
	kpi 		: CM_KPI;
	vKPI 		: CM_KPIVoyageBayCrane;
	dBay 		: CM_BayDefn;
	aTran 		: CM_TITransaction;
	aTI 		: CM_TrackedItem;
	aShipRec 	: CM_ReceiveShip;
	aShipRel 	: CM_ReleaseShip;
	aJS			: CM_JobSheet;
	vJS 		: CM_VoyageJobSheet;
	vess 		: CM_Vessel;
	voy 		: CM_Voyage;
begin
	voy		:= self.myCellularVoyageStructure.myVoyage;
	vess 	:= voy.getMyVessel();
	
	foreach aTran in self.allShipReceivals discreteLock do
		aShipRec := aTran.CM_ReceiveShip;
		vKPI	 := null;
		//KPIs are by Crane and Bay, so must have a job sheet
		vJS := aShipRec.myJobSheet.CM_VoyageJobSheet;
		
		if vJS &lt;&gt; null then
			// get KPI for Crane/Bay
			vKPI := self.getKPIVoyageBayCraneForJS(vJS);
			if vKPI = null then
				create vKPI;
				dBay := self.getBayDefn(vess);
				vKPI.setKPI(vJS.getMyCrane(),	vJS, voy, voy.myTerminal,self,dBay);
			endif;
		endif;
		if vKPI &lt;&gt; null then
			vKPI.setFromTransaction(aShipRec);
			if vKPI.allTrackedItems.isEmpty then
				delete vKPI;
			endif;
		endif;
	endforeach;

	foreach aTran in self.allShipReleases discreteLock do
		aShipRel 	:= aTran.CM_ReleaseShip;
		vKPI 		:= null;
		//KPIs are by Crane and Bay, so must have a job sheet
		vJS := aShipRel.myJobSheet.CM_VoyageJobSheet;
		if vJS &lt;&gt; null then
			// get KPI for Crane/Bay
			vKPI := self.getKPIVoyageBayCraneForJS(vJS);
			if vKPI = null then
				create vKPI;
				dBay := self.getBayDefn(vess);
				vKPI.setKPI(vJS.getMyCrane(),	vJS, voy, voy.myTerminal,self,dBay);
			endif;
		endif;
		if vKPI &lt;&gt; null then
			vKPI.setFromTransaction(aShipRel);
			if vKPI.allTrackedItems.isEmpty then
				delete vKPI;
			endif;
		endif;
	endforeach;
	
	foreach kpi in self.allVoyageKPIBayCranes discreteLock do
		vKPI := kpi.CM_KPIVoyageBayCrane;
		
		vKPI.setTotalTimeAndRate();
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyVoyageStructure" id="48b47e8b-3e9d-4b3d-9f95-52fbe2a261cd">
        <updating/>
        <source>setMyVoyageStructure(_structure : CM_CellularVoyageStructure) updating;
// ---------------------------------------------------------------------------
// Created:     12 June 2002 by cnwrs1
//
// Purpose:     Sets the appropriate 40' reference so inverse works to voyage.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 05 Feb 2003	DQ	Fixed so updates the 40' dicts appropriately.
// ---------------------------------------------------------------------------

vars

begin
	
	self.myCellularVoyageStructure := _structure;
	//self.myVoyage := _voyage;
	if self.canHandle4045() and self.idBay40 &lt;&gt; null then //only include first 20' section
		//self.my40Voyage := _voyage;
		self.my40CellularVoyageStructure := _structure;
	else
		//self.my40Voyage := null;
		self.my40CellularVoyageStructure := null;
	endif;
end;</source>
        <Parameter name="_structure" type="CM_CellularVoyageStructure"/>
    </JadeMethod>
    <JadeMethod name="setProxyBay" id="e484e583-69c3-4bf6-96d5-1c3fb77d8b93">
        <updating/>
        <source>setProxyBay(_id : String; _idBay40 : String; _clonedFromBay : String; _lashFromTier : String; _unlashFromTier : String; _remarks : String; 
			_ordinalBay : Integer; _attributes : Integer; _bayType : Integer; _maxPileWeight20IB : Integer; _maxPileWeight20OB : Integer; 
			_maxPileWeight40IB : Integer; _maxPileWeight40OB : Integer; _maxPileWeightUD : Integer; _numOfPlugs : Integer; _ordinalHold : Integer; 
			_athwartships : Boolean; _fortyFootBay : Boolean; _fortyFootOnly : Boolean; _useCellTierODSequencing : Boolean; _useCellTierUDSequencing : Boolean;
			 _useCellTierODSequencing40 : Boolean; _useCellTierUDSequencing40,_isTwinLiftOD,_isTwinLiftUD : Boolean; 
			_structure : CM_CellularVoyageStructure; _theHold : CM_Hold; _osCrane : Integer; _fortyFiveFootBay,_fortyFiveFootOnly: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     12 June 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.setProxy(_id,_idBay40,_lashFromTier,_unlashFromTier,_remarks,_ordinalBay,_bayType,
		_maxPileWeight20IB,_maxPileWeight20OB,_maxPileWeight40IB,_maxPileWeight40OB,_maxPileWeightUD,_numOfPlugs,_ordinalHold,
		_athwartships,_fortyFootBay,_fortyFootOnly,_useCellTierODSequencing,_useCellTierUDSequencing, _useCellTierODSequencing40,_useCellTierUDSequencing40,_isTwinLiftOD,_isTwinLiftUD,
		_theHold, _fortyFiveFootBay,_fortyFiveFootOnly );
		
	self.myCellularVoyageStructure := _structure;
	self.onShipCrane := _osCrane;

end;</source>
        <Parameter name="_id" type="String"/>
