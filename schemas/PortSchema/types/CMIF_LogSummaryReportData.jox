    <JadeMethod name="getLogGrade" id="425b37eb-de0f-4a12-99c9-1fdaf2d796b2">
        <source>getLogGrade() : CM_LogGrade;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		16 November 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
// 16/11/2010 CCMS JML 1115 PAR26245 cnwsh3
//----------------------------------------------------------------------
vars
	product : CM_Product;
begin
	product := self.myProduct;
	
	if product.isKindOf(CM_ProductLog) then
		return product.CM_ProductLog.myLogGrade;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_LogGrade"/>
    </JadeMethod>
    <JadeMethod name="getLogLength" id="ef2f19b2-a5ca-4a04-b904-1dcce49d5f29">
