    <JadeMethod name="tReceiveWithOverDimensions" id="f1beb899-e2b6-4826-b04a-9ac0129e60ea">
        <source>tReceiveWithOverDimensions();
// cnwdap1
/*
Purpose:			gate in an over-dimension container

Parameters:			

Return Value:		

Date		Who		Reason
02/11/2009	cnwdap1	Initial creation
25/05/2016	cnwdap1	Change to length/weight/height setting - no longer set on container when over- fields are set
*/
vars
	truck: CM_Vehicle;
	ti: CM_TrackedItem;
begin
	deleteContainer("UUT12345678");
	deleteVehicle("UTTRUCK");

	self.opts.addAssociation("Over Left", "10");
	self.opts.addAssociation("Over Right", "20");
	self.opts.addAssociation("Over Front", "30");
	self.opts.addAssociation("Over Rear", "40");
	self.opts.addAssociation("Over Height", "50");
	
	gateInContainer("UTTRUCK", "UUT12345678", "2200", operator.code, "GENL", dualGate);
	ti := self.getTrackedItem("UUT12345678");
	assertNotNull(ti);
	assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
	assertEqual(ti.CM_Container.overWidthLeft, 10.Decimal);
	assertEqual(ti.CM_Container.overWidthRight, 20.Decimal);
	assertEqual(ti.CM_Container.overLengthFront, 30.Decimal);
	assertEqual(ti.CM_Container.overLengthRear, 40.Decimal);
	assertEqual(ti.CM_Container.overHeight, 50.Decimal);
	//assertEqual(ti.CM_Container.width, ti.CM_Container.overWidthLeft + ti.CM_Container.overWidthRight);
	//assertEqual(ti.CM_Container.length, ti.CM_Container.overLengthFront + ti.CM_Container.overLengthRear);
	//assertEqual(ti.CM_Container.overHeight, ti.CM_Container.height);
	assertEqual(ti.CM_Container.width, null);
	assertEqual(ti.CM_Container.length, null);
	assertEqual(ti.CM_Container.height, null);
	
	

end;</source>
