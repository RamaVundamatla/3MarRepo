<Class name="CM_YATypeAvGrade" id="3edbc19b-c353-45ee-9833-bd703ef16cbb">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="d37552fc-6804-4932-a0a8-ea0d1a3e9ba6">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues: ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
// --------------------------------------------------------------------------------
// Created:		04 March 2005 by cnwdad1
//
// Purpose:		Populate the collection parameter with instances of the CM_MTGrade
//				class.
//
// Parameters:	pAllCriteriaValues - A reference to the object set to populate.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
// --------------------------------------------------------------------------------
begin
	// allow 'not availble for entry' grades to be used. May need to create yard allocations for 
	// exsisting objects that have 'not availble for entry' grade 
//	app.myRoot.allAvailableAvailabilityGrades.copy(pAllCriteriaValues);
	app.myRoot.allAvailabilityGrades.copy(_allCriteriaValues);
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaObjectForTi" id="68ca754b-f4bc-482d-bf9c-c023252ffe24">
        <source>getCriteriaObjectForTi(_ti: CM_TrackedItem; _criteriaObject: CM_Object output; _process: Boolean output);

vars

begin
	if _ti.canSetAvailabilityGrade then
		_criteriaObject := app.myRoot.allAvailabilityGrades[_ti.getAvailabilityGrade];
	endif;
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaObject" type="CM_Object" usage="output"/>
        <Parameter name="_process" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="0dd2fc27-a652-4092-a420-f73839f01b6a">
        <source>getDataDisplay(pDataObj : CM_YAData) : String;
//01 August 2008	cnwdw1
begin
	return pDataObj.CM_YADataObjects.getDataDisplay(self);
end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="86431605-41c2-4745-ac4f-15a442128674">
        <source>getDisplay(dataObj : Object) : String;
//01 August 2008	cnwdw1
begin
	return dataObj.CM_MTGrade.code.String;
end;</source>
        <Parameter name="dataObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjects" id="6aaef9b4-0a98-4b9e-a6b5-aca110147759">
        <source>getObjects(objects: ObjectLongNameDict input);
//03 August 2008	cnwdw1	
// Return a dict of objects for this criteria type
vars
	grade: CM_MTGrade;
begin
	foreach grade in app.myRoot.allAvailabilityGrades do
		objects[grade.getYAIdentifier] := grade;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTypeName" id="fb3afd0c-e3f4-41d4-9734-12df6f827dd4">
