    <JadeMethod name="initDataExtractFields_Hazard" id="aaa4e452-9c1f-4713-89a2-d9e2cefdeda9">
        <source>initDataExtractFields_Hazard(_fields : CM_DataExtractFieldSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2011	cnwkpd1	PAR #27436 - CCMS DCT 2073 - Product Transition Services
25 May 2011 cnwdw1	Reviewed

*/

vars
	fieldName		: String;
	childField   : CM_DataExtractField; 
    colField     : CM_DataExtractCollectionField;
begin
	fieldName := CM_Container::allTIHazards.name;
	colField  := self.initDataExtractCollectionField(_fields, CM_TIHazard, fieldName, "Hazardous Details");
	
	fieldName := CM_TIHazard::getClassDesc.name;
	childField := self.initDataExtractField(null, CM_TIHazard.name, null, fieldName, STRING, "Hazardous Class", "Hazardous class", STRING, "No more than 9 characters and/or digits");	
	colField.extractOrder.add(fieldName);
	colField.allChildFields.add(childField);
	
	fieldName := CM_TIHazard::undgCodes.name;
	childField := self.initDataExtractField(null, CM_TIHazard.name, null, fieldName, STRING, "UNDG Code", "United Nations Dangerous Goods (UNDG) identifier assigned to transportable hazardous goods within the United Nations", STRING, "Comma-separated UNDG codes with a maximum legth of 80");	
	colField.extractOrder.add(fieldName);
	colField.allChildFields.add(childField);
	
	fieldName := CM_TIHazard::limitedQuantity.name;
	childField := self.initDataExtractField(null, CM_TIHazard.name, null, fieldName, BOOLEAN, "Limited Quantity", "Limited quantity", BOOLEAN, BOOLEAN_POSSIBLEVAL);	
	colField.extractOrder.add(fieldName);
	colField.allChildFields.add(childField);
epilog

end;</source>
