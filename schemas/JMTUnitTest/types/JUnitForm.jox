    <JadeMethod name="reloadBookmarks" id="4e2c066a-05d9-4bd0-97a6-407a1702333a">
        <source>reloadBookmarks();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2023	navra1	Initial creation

*/

vars
	bookmark:UM_BookmarkFolder;
	parentLevel:Integer;
	childLevel:Integer;
	iter:Integer;
	methodNameInstance : UM_MethodName;
begin
	self.lstBookMarks.clear();
	
	foreach bookmark in UM_BookmarkFolder.instances do
		parentLevel := self.lstBookMarks.addItem(bookmark.bookmarkName);
		self.lstBookMarks.itemObject[parentLevel]:=bookmark;
		self.lstBookMarks.itemLevel[parentLevel]:=1;		
		foreach methodNameInstance in bookmark.methodNames do
			childLevel := self.lstBookMarks.addItem(methodNameInstance.methodNameString);
			self.lstBookMarks.itemObject[childLevel] := methodNameInstance;
			self.lstBookMarks.itemLevel[childLevel] := 2;			
		endforeach;
		
		
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e79b2b5b-6012-46c4-a406-14927b213236">
        <updating/>
        <source>setupForm() updating;
//03 August 2008	cnwdw1	
// 09JULY2025 - Added Show Tests Are Running
vars
	index: Integer;
	stateObjectArray : CM_StateObjectArray;
begin
	app.hideDebug	:= true;
	app.startupForm := self;
	self.registerNotes();
	self.lbxTests.clear();
	self.initializeSchemas("JMTUnitTest");
	self.addClassToTree(UT_UnitTest, 1);
	self.recalcTotals();
	self.showTotals();
	self.populateProfiles();
	self.setupResultsTable();
	self.caption := "Master Terminal Automated Testing for " &amp; app.myCnKarmaCntrl.environmentId.toUpper;
	self.top	:= 10;
	self.left	:= 10;
	self.height	:= 800;
	//self.width	:= 1000;
	self.minimumWidth := self.width.Integer;
	self.minimumHeight := self.height.Integer;
	
	// open with the top 2 levels expanded.
	self.lbxTests.listIndex			:= 2;
	self.lbxTests.itemExpanded[ 2 ]	:= true;
	self.centreWindow();
	
	self.populateClassSearch();
	
	self.txtCategory.text := null;
	self.txtCategory.scrollHorizontal := true;
	
	app.findBlameForNoDays := UM_Blame.DateThreshold;
	self.txtBlameDays.text := app.findBlameForNoDays.String;
	
	if not self.dontPopulateCategories then
		app.populateAllCategories(null, null, null, false);
		self.populateCategories();
	endif;
	
	// 10/12/2014 cnwmh5
	app.mySaveDataObjsToRestore.saveAllStateData(null, self, stateObjectArray);
	
	self.lblCurrent.transparent := true;
	self.lblCurrentMethod.transparent := true;
	self.lblOverall.transparent := true;

	self.showAreTestRunning();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupResultsTable" id="f657f5fa-986c-44df-b457-83571d353cf1">
        <source>setupResultsTable();
//24 April 2009	cnwdw1	
//
vars

begin
	self.tblResults.clear;
	self.tblResults.rows := 1;
	self.tblResults.accessCell(1, 1).text := "Pass";
	self.tblResults.accessColumn(1).width := 30;
	self.tblResults.accessColumn(1).alignment := Table.Alignment_Center;
	self.tblResults.accessCell(1, 2).text := "Class";
	self.tblResults.accessCell(1, 3).text := "Method";
	self.tblResults.accessCell(1, 4).text := "Terminal(s)";
	self.tblResults.accessCell(1, 5).text := "Profile";
	self.tblResults.accessColumn(6).alignment := Table.Alignment_Right;
	self.tblResults.accessCell(1, 6).alignment := Table.Alignment_Center;
	self.tblResults.accessCell(1, 6).text := "Time (secs)";
	self.tblResults.accessCell(1, 7).alignment := Table.Alignment_Center;
	self.tblResults.accessCell(1, 7).text := "Owner";
	self.tblResults.accessColumn(8).visible := false;
	
epilog

end;</source>
    </JadeMethod>
