    <JadeMethod name="doPrintCSV" id="6880b5e0-6471-4961-95e5-cd06b3584e31">
        <updating/>
        <source>doPrintCSV(_tiDict : CM_TIByIdDict; _sort : CMIF_SOHReporter; _blob : Binary io) protected, updating;

// cnwdvb1 19 November 2002 
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars

	iter	: Iterator;
	log		: CM_Log;
	id, lotNo, hatch, species, grade, type,
	treat, length, meanSED, vol, lastLoc, voyage,
	detail, place, supplier, vessel,
	buyer, dischargePort, stevedore, contact	: String;

begin

	iter := _tiDict.createIterator;
	if _sort.mySupplier &lt;&gt; null then
		supplier	:= _sort.mySupplier.description;
	endif;
	lotNo			:= _sort.lot;
	hatch			:= _sort.hatch.String;
	place			:= self.getPlaceString(_sort.place);
	if _sort.myLot.myConsignee &lt;&gt; null then
		buyer	:= _sort.myLot.myConsignee.description;
	endif;
	if _sort.myLot.myDischargePort &lt;&gt; null then
		dischargePort	:= _sort.myLot.myDischargePort.description;
	endif;
	stevedore		:= self.myVoyage.getStevedoreForOperator(_sort.mySupplier);
	contact			:= null;
	voyage			:= self.myVoyage.code;
	vessel			:= self.myVoyage.myVoyageGlobalArrival.vesselName;
		
	while iter.next(log) do
		
		id 				:= log.id; 
		species			:= log.speciesCode;
		grade			:= log.gradeCode;
		type			:= log.typeCode;
		treat			:= log.treatmentCode;
		length			:= log.lengthCode;
		meanSED			:= log.sedMean.sedString;
		vol				:= log.getMyTotalVolume.jasVolumeString;
		lastLoc			:= log.getLoadOutLocationID();

		detail := detail &amp;
					id &amp; COMMA &amp; 
					lotNo &amp; COMMA &amp; 
					hatch &amp; COMMA &amp;
					place &amp; COMMA &amp;
					supplier &amp; COMMA &amp;
					species &amp; COMMA &amp; 
					grade &amp; COMMA &amp; 
					type &amp; COMMA &amp; 
					treat &amp; COMMA &amp; 
					length &amp; COMMA &amp; 
					meanSED &amp; COMMA &amp; 
					vol &amp; COMMA &amp; 
					lastLoc &amp; COMMA &amp; 
					voyage &amp; COMMA &amp; 
					vessel &amp; COMMA &amp; 
					buyer &amp; COMMA &amp; 
					dischargePort &amp; COMMA &amp; 
					stevedore &amp; COMMA &amp; 
					contact &amp; CrLf; 
					
	endwhile;
	_blob := _blob &amp; detail.Binary;

epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_tiDict" type="CM_TIByIdDict"/>
        <Parameter name="_sort" type="CMIF_SOHReporter"/>
        <Parameter name="_blob" type="Binary" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doPrintDetail" id="d5525fa4-cb16-41a3-8d19-316f2ee1c3c4">
        <updating/>
        <source>doPrintDetail(_sort : CMIF_SOHReporter; _blob : Binary io) : Integer protected, updating;

// cnwdvb1 19 November 2002 
vars

	tiDict,
	tiDict2		: CM_TIByIdDict;
	maxLine		: Integer;

begin

	create tiDict transient;
	_sort.mySOHLocation.allTrackedItems.copy(tiDict);
	self.lblStevedoreDtl.caption	:= self.myVoyage.getStevedoreForOperator(_sort.mySupplier);
	if self.isCSV then
		self.doPrintCSV(tiDict, _sort, _blob);
		return 0;
	else
		if tiDict.size &gt; MaxTable then
			create tiDict2 transient;
			while tiDict.size &gt; MaxTable do

				self.doSplitOffLogs(tiDict, tiDict2);
				//epr TFS 6566 31/8/17
				self.printTable(tiDict2);
				self.doNewPage();
			endwhile;

		endif;
		return self.printTable(tiDict);
	endif;
epilog
	delete tiDict;
	delete tiDict2;
end;</source>
        <access>protected</access>
        <Parameter name="_sort" type="CMIF_SOHReporter"/>
        <Parameter name="_blob" type="Binary" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doPrinterClose" id="a28a4fa8-406b-47c5-ae8d-852417102c5a">
        <source>doPrinterClose() protected;

// cnwdvb1 19 November 2002 

vars

begin

	if self.isCSV then
		return;
	endif;
	app.printer.close();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPrinterVoyageReport" id="c0a1dcf0-820e-44b5-92de-0056664eab36">
        <updating/>
        <source>doPrinterVoyageReport(_array : ObjectArray; _blob : Binary io;  _isFirstTime : Boolean) protected, updating;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars

	soh			: CM_SOHLocation;

begin

	if not _isFirstTime then
		app.printer.newPage();
	endif;
	create self.myGroupTotals transient;
	soh := _array.first.CMIF_SOHReporter.mySOHLocation;

	self.myVoyage := soh.myLocationsController.CM_LogVoyageController.myVoyage;	
	
	self.setHeaderAndFooter();
	self.processReport(_array, _blob);
epilog	
	delete self.myGroupTotals;

end;</source>
        <access>protected</access>
        <Parameter name="_array" type="ObjectArray"/>
        <Parameter name="_blob" type="Binary" usage="io"/>
        <Parameter name="_isFirstTime" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSplitOffLogs" id="4567e592-2c03-448b-a9d1-a479b67200c4">
        <source>doSplitOffLogs(_logsLeft, _logsToPrint : CM_TIByIdDict input) protected;

// cnwdvb1 15 April 2003 

vars
	iter	: Iterator;
	ti		: CM_TrackedItem;
	count	: Integer;
begin
	
	_logsToPrint.clear();
	iter := _logsLeft.createIterator;
	while iter.next(ti) do
		count := count + 1;
		_logsLeft.remove(ti);
		_logsToPrint.add(ti);
		if count &gt;= MaxTable then
			break;
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_logsLeft" type="CM_TIByIdDict" usage="input"/>
        <Parameter name="_logsToPrint" type="CM_TIByIdDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCMIF" id="7237dcb7-4b6c-4597-b6e4-f9f14c6fe6c7">
        <source>getCMIF(_sort	: CMIF_SOHReporter) : CMIF_ShipLogListExtra protected;

vars

	iter 			: Iterator;
	extraDetail 	: CMIF_ShipLogListExtra;

begin

	iter := self.myExtraDetailShipLogLst.allShipLogLstExtra.createIterator;
	while iter.next(extraDetail) do
		if extraDetail.lotNo = _sort.lot and extraDetail.operator = _sort.supplier and
			extraDetail.myVoyage = _sort.myLot.myLogVoyageStructure.myVoyage then
			break;
		endif;
		extraDetail := null;
	endwhile;
	return extraDetail;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_sort" type="CMIF_SOHReporter"/>
        <ReturnType type="CMIF_ShipLogListExtra"/>
    </JadeMethod>
    <JadeMethod name="getTotalObject" id="436a1e80-6a09-4e9f-be87-17ee487b1ed2">
        <source>getTotalObject(_lengthCode : String) : CMIF_ShipStowageTotals protected;

vars

	total	: CMIF_ShipStowageTotals;
	iter	: Iterator;

begin

	iter := self.allHeaderTotals.createIterator;
	while iter.next(total) do
		if total.heading = _lengthCode then
			return total;
		endif;
	endwhile;
	create total transient;
	total.heading	:= _lengthCode;
	total.length	:= _lengthCode.Real;
	self.allHeaderTotals.add(total);
	return total;
epilog
	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_lengthCode" type="String"/>
        <ReturnType type="CMIF_ShipStowageTotals"/>
    </JadeMethod>
    <JadeMethod name="printGroup" id="ec343918-77a1-4425-8262-a1f711a56046">
        <updating/>
        <source>printGroup(_group : ObjectArray; _blob : Binary io) protected, updating;


vars

	sort,
	lastSort	: CMIF_SOHReporter;
	total, 
	grandTotal	: CMIF_ShipStowageTotals;
	iter		: Iterator;
	lengthCode	: String;
	isFirst		: Boolean;
	maxEndPos	: Integer;

begin

	isFirst := true;
	iter := _group.createIterator;
	self.allHeaderTotals.purge;
	grandTotal := self.getTotalObject(Total);
	while iter.next(sort) do
		total := self.getTotalObject(sort.myProduct.CM_ProductLog.lengthCode);		
		total.addPcs(sort.mySOHLocation.currentQuantity, PlaceDeck); // Place deck is only filler as we aren't interested in these totals.
		total.addVolume(sort.mySOHLocation.currentVolume, PlaceDeck);
		
		grandTotal.addPcs(sort.mySOHLocation.currentQuantity, PlaceDeck);			
		grandTotal.addVolume(sort.mySOHLocation.currentVolume, PlaceDeck);
	endwhile;	
	self.printHeaderPage(_group, _blob);
	iter.reset;
	while iter.next(sort) do
		if not isFirst then
			app.printer.setPrintPosition(maxEndPos);
			self.printGroupTotals(sort, lastSort);
			self.doNewPage();
		endif;
		self.setSpecificHeader(sort);
		maxEndPos := self.doPrintDetail(sort, _blob) + 20;
		self.myGroupTotals.addPcs(sort.mySOHLocation.currentQuantity);
		self.myGroupTotals.addJas(sort.mySOHLocation.currentVolume);
		lastSort := sort;
		isFirst := false;
	endwhile;
	app.printer.setPrintPosition(maxEndPos);
	self.printGroupTotals(lastSort, lastSort);
	self.doNewPage();
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_group" type="ObjectArray"/>
        <Parameter name="_blob" type="Binary" usage="io"/>
    </JadeMethod>
    <JadeMethod name="printGroupTotals" id="90b7c49f-3484-4e85-a63f-4a2db6bbf1df">
        <source>printGroupTotals(_sort, _lastSort : CMIF_SOHReporter) protected;

vars

	dyna	: DynaDictionary;
	soh		: CM_SOHLocation;
	sort	: CMIF_SOHReporter;
	force	: Boolean;
	total	: CMIF_ShipStowageTotals;

begin

	force := _sort = _lastSort;
	
	self.printSpecTotal(_lastSort.myProduct.CM_ProductLog, self.myGroupTotals.totalSpecPcs, self.myGroupTotals.totalSpecJas);
	self.myGroupTotals.clear(CMIF_ShipLogList.Spec);
	
	if force or _lastSort.hatch &lt;&gt; _sort.hatch or _lastSort.place &lt;&gt; _sort.place then
		self.printStandardTotal('Totals for ' &amp; self.getPlaceString(_lastSort.place), self.myGroupTotals.totalPlacePcs, self.myGroupTotals.totalPlaceJas);	
		self.myGroupTotals.clear(CMIF_ShipLogList.Place);
	endif;
	
	if force or (_lastSort.hatch &lt;&gt; _sort.hatch) then
		self.printStandardTotal('Totals for Hatch ' &amp; _lastSort.hatch.String, self.myGroupTotals.totalHatchPcs, self.myGroupTotals.totalHatchJas);
		self.myGroupTotals.clear(CMIF_ShipLogList.Hatch);
	endif;
	
	if force then
		total := self.getTotalObject(Total);
		self.printStandardTotal('Totals for Lot ' &amp; _lastSort.lot.String, total.lotTotalPcs, total.lotTotalVolume);
		self.myGroupTotals.clear(CMIF_ShipLogList.Hatch);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_sort" type="CMIF_SOHReporter"/>
        <Parameter name="_lastSort" type="CMIF_SOHReporter"/>
    </JadeMethod>
    <JadeMethod name="printHeaderPage" id="039bca73-9233-4b77-b957-0d4cb73d4ab1">
        <updating/>
        <source>printHeaderPage(_group : ObjectArray; _blob : Binary io) protected, updating;

vars

	sailDate,
	ship,
	detail,
	pieces,
	volume,
	headerStrOld,
	headerStr		: String;
	theHeight		: Real;
	extraDetail 	: CMIF_ShipLogListExtra;
	total			: CMIF_ShipStowageTotals;
	lengthTotal		: CMIF_ShipStowageTotals;
	iter			: Iterator;
	idx,
	numLines,
	lineOnlyCount,
	count,
	headerTxtLength : Integer;
	arr				: CnEcArray;
	nextSpace		: Boolean;
	char			: Character;

begin

	app.printer.pageNumber := 1;
	theHeight := self.frmHeader.height;
	self.frmHeader.height := 60;
	extraDetail := self.getCMIF(_group.first.CMIF_SOHReporter);

	if extraDetail &lt;&gt; null then
		self.lblSumSupDtl.caption 	:= extraDetail.operatorDesc;
		ship := (self.myVoyage.code &amp; ' ' &amp; self.myVoyage.myVoyageGlobalArrival.vesselName).toUpper;
		self.lblrSumShipDtl.caption := ship;
		sailDate	:= self.myVoyage.departedDT.date.shortFormatJMT();	// 28551 after CCMS 1120 to use departedDT Nov 2011
		self.lblrSailDtl.caption := sailDate;	
		self.doPrint(self.frmHeading1);
		
		headerStrOld := extraDetail.headerTxt;
		headerTxtLength := headerStrOld.length;
		// Par 8503. Added some Cr to force new line.
		foreach count in 1 to headerTxtLength do
			lineOnlyCount := lineOnlyCount + 1;
			char := headerStrOld[count];
			if lineOnlyCount mod 96 = 0 then
				if char = ' ' then
					headerStr := headerStr &amp; Cr;
					lineOnlyCount := 0;	
				else
					headerStr := headerStr &amp; char;
					nextSpace := true;
				endif;
			else
				if nextSpace and char = ' ' then
					headerStr := headerStr &amp; Cr;
					lineOnlyCount := 0;	
					nextSpace := false;
				else
					headerStr := headerStr &amp; char;
					
				endif;
			endif;
			if char = Cr then
				lineOnlyCount := 0;
			endif;
		endforeach;

		create arr transient;
		if headerStr.cnEcGetArrayOfLines(arr) then
			numLines := arr.size;
			foreach idx in 1 to numLines do
				self.lblSumDtl.caption	:= arr.getStringAt(idx);
				self.doPrint(self.frmHeading2);
			endforeach;
		endif;

		self.lblSumBuyerDtl.caption	:= extraDetail.buyer;
		self.lblSumLotDtl.caption	:= extraDetail.lotNo;
		self.doPrint(self.frmHeading3);
	endif;
	
	
	total := self.getTotalObject(Total);
	iter := self.allHeaderTotals.createIterator;
	self.doPrint(self.frmSpace2);
	while iter.next(lengthTotal) do
		if lengthTotal &lt;&gt; total then
			self.lblLengthHdg.caption	:= 'Log Length        ' &amp; lengthTotal.heading;
			pieces						:= lengthTotal.lotTotalPcs.String;
			self.lblPcsSum.caption		:= pieces;
			volume						:= lengthTotal.lotTotalVolume.String;
			self.lblVolSum.caption		:= volume;
			if self.isCSV then
				detail := detail &amp; 
				ship &amp; COMMA &amp;			
				sailDate &amp; COMMA &amp;
				lengthTotal.heading &amp; COMMA &amp;
				pieces &amp; COMMA &amp;
				volume &amp; CrLf;
			else
				self.doPrint(self.frmSumTotals);
			endif;
			self.doPrint(self.frmSpace2);
		endif;
	endwhile;
	self.doPrint(self.frmULine2);
	self.doPrint(self.frmULine3);
	self.lblLengthHdg.caption	:= '*** Lot Totals ***';
	self.lblPcsSum.caption		:= total.lotTotalPcs.String;
	self.lblVolSum.caption		:= total.lotTotalVolume.String;
	self.doPrint(self.frmSumTotals);
	self.doPrint(self.frmULine2);
	self.doPrint(self.frmULine3);
	if self.isCSV then
		_blob := _blob &amp; detail.Binary;
	endif;

// Ship-Sail Date-Log Length-Pieces-Total Length Volume.
	
epilog

	delete iter;
	self.frmHeader.height := theHeight;
	self.doNewPage();
	
end;</source>
        <access>protected</access>
        <Parameter name="_group" type="ObjectArray"/>
        <Parameter name="_blob" type="Binary" usage="io"/>
    </JadeMethod>
    <JadeMethod name="printSpecTotal" id="e53de6bb-e2ef-4b76-a6b6-8a69436e7215">
        <source>printSpecTotal(_logProduct : CM_ProductLog; _pcs : Integer; _vol : Decimal) protected;

vars
	grade,
	species,
	type,
	length	: String;

begin

	self.lblTotals.caption		:= 'Totals for Specs ' &amp; 
									_logProduct.speciesCode &amp; ' ' &amp; 
									_logProduct.gradeCode &amp; ' ' &amp; 
									_logProduct.typeCode &amp; ' ' &amp; 
									_logProduct.treatmentCode &amp; ' ' &amp; 
									_logProduct.lengthCode;

	self.lblTotalPcs.caption	:= _pcs.String;
	self.lblTotalVol.caption	:= _vol.String;
	if not app.printer.frameFits(self.frmTotals) then
		app.printer.setPrintPosition(0);
		self.doNewPage();
	endif;
	self.doPrint(self.frmTotals);

end;</source>
        <access>protected</access>
        <Parameter name="_logProduct" type="CM_ProductLog"/>
        <Parameter name="_pcs" type="Integer"/>
        <Parameter name="_vol" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="printStandardTotal" id="7523915c-3658-4201-91e7-5cbbadfb8d1b">
        <source>printStandardTotal(_header : String; _pcs : Integer; _vol : Decimal) protected;

vars

begin

	self.lblTotals.caption		:= _header;
	self.lblTotalPcs.caption	:= _pcs.String;
	self.lblTotalVol.caption	:= _vol.String;
	if not app.printer.frameFits(self.frmTotals) then
		app.printer.setPrintPosition(0);
		self.doNewPage();
	endif;
	self.doPrint(self.frmTotals);

end;</source>
        <access>protected</access>
        <Parameter name="_header" type="String"/>
        <Parameter name="_pcs" type="Integer"/>
        <Parameter name="_vol" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="printTable" id="7dedb76b-9026-40d5-9f2b-645fb3b28864">
        <updating/>
        <source>printTable(_tiDict : CM_TIByIdDict) : Integer protected, updating;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
constants
	NumColumns			: Integer	= 3;
vars

	log					: CM_Log;
	iter				: Iterator;
	colNo,
	tempPos,
	maxEndPos,
	saveTopPos			: Integer;
	nextTopRow			: Integer;
	nextLeftColumn		: Integer;
	saveLeft			: Real;
	numRows,
	maxRowsInColumn		: Integer;

begin

	iter := _tiDict.createIterator;
	
	// Force the header frame to be printed and save
	// the first real print position
	self.doPrint(self.frmNull);
	saveTopPos	:= app.printer.getPrintPosition;	
	
	self.tblReport.rows := 0;
	while iter.next(log) do
		
		self.addRowToTable(log.id &amp; Tab &amp; log.sedMean.roundedTo(1).String &amp; Tab &amp; log.getMyTotalVolume.String, false);
	endwhile;
	
	
	self.setMaxTableHeight;
	self.setMaxTableWidth;
	self.setFixedRowHeight;
	self.setFixedColumnWidth;
	nextTopRow := self.tblReport.fixedRows + 1;
	nextLeftColumn := self.tblReport.fixedColumns + 1;
	
	saveLeft := self.frmTable.left;
	numRows := self.tblReport.rows;
	maxRowsInColumn := (numRows / 3).roundedUp;
		
	colNo := 1;
	while nextTopRow &lt;= self.tblReport.rows or nextLeftColumn &lt;= self.tblReport.columns do
		if colNo &gt; NumColumns then
			maxRowsInColumn := ((numRows - nextTopRow + 1) / 3).roundedUp;

		endif;
		self.nextTablePosition(nextTopRow, nextLeftColumn, maxRowsInColumn);
		if colNo &lt;= NumColumns then
			// move the printer back to the saved top position
			app.printer.setPrintPosition(saveTopPos);
			// reset the table left position
			self.frmTable.left := saveLeft + (self.frmTable.width * (colNo-1)) + ((colNo-1) * 10);
		else
			colNo := 1;
			self.doNewPage();
			
			self.doPrint(self.frmNull);
			maxEndPos := 0;
			self.frmTable.left := saveLeft;
		endif;
		if not app.printer.frameFits(self.frmTable) then
		
		endif;
		self.doPrint(self.frmTable);
		tempPos :=  app.printer.getPrintPosition;
		if tempPos &gt; maxEndPos then
			maxEndPos := tempPos;
		endif;
		colNo := colNo + 1;
	endwhile;
	return maxEndPos;
	
	
epilog
	self.frmTable.left := saveLeft;
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_tiDict" type="CM_TIByIdDict"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processReport" id="554ee335-13fd-4c4f-8189-db6b9054e977">
        <updating/>
        <source>processReport(_array : ObjectArray; _blob : Binary io) protected, updating;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars

	soh			: CM_SOHLocation;
	obj			: Object;
	sort,
	lastSort	: CMIF_SOHReporter;
	array		: ObjectArray;

begin

	create array transient;
	foreach obj in _array do
		sort := obj.CMIF_SOHReporter;
		
		if sort.mySOHLocation.allTrackedItems.size = 0 then
			continue;
		endif;
		if	lastSort			= null or 
			(lastSort.lot		= sort.lot and 
			lastSort.supplier	= sort.supplier) then
		else
			self.printGroup(array, _blob);
			array.clear;
		endif;
		array.add(sort);
		lastSort := sort;
	endforeach;
	if array.size &gt; 0 then
		self.printGroup(array, _blob);
	endif;
epilog
	delete array;
end;</source>
        <access>protected</access>
        <Parameter name="_array" type="ObjectArray"/>
        <Parameter name="_blob" type="Binary" usage="io"/>
    </JadeMethod>
    <JadeMethod name="run" id="53a9478b-be96-4272-983a-384c45e9439e">
        <updating/>
        <source>run(_isPrintPreview, _isCSV : Boolean; _extraDetail : CM_ExtraDetail) : Binary updating;
vars

	data		: CM_JRWOld;
	dyna		: DynaDictionary;
	soh			: CM_SOHLocation;
	blob		: Binary;
	array		: ObjectArray;
	iter		: Iterator;
	sort,
	lastSort	: CMIF_SOHReporter;
	isFirstTime	: Boolean;

begin

	inheritMethod(_isPrintPreview,_isCSV, _extraDetail);
	if _extraDetail = null then
		return null;
	endif;
	self.isCSV := _isCSV;
	self.myExtraDetailShipLogLst := _extraDetail.CM_ExtraDetailShipLogLst;
	app.printer.printPreview := _isPrintPreview;
	app.printer.setMargins(Print_Landscape,0,0,10,10);
	self.tblReport.visible := true;
	
	data := app.myQAFilter.myRWLogDocket;
	dyna := self.sortData(data.allSOHLocations);
	if dyna.size &gt; 0 then
		create array transient;
		iter := dyna.createIterator;
		while iter.next(sort) do
			if	lastSort = null or
				(sort.myVoyage = lastSort.myVoyage) then
			else
				self.doPrinterVoyageReport(array, blob, isFirstTime);				
				isFirstTime := false;
				array.clear;
			endif;
			array.add(sort);
			lastSort := sort;	
		endwhile;
		if array.size &gt; 0 then
			self.doPrinterVoyageReport(array, blob, isFirstTime);	
		endif;	
	endif;

	dyna.purge;
	self.allHeaderTotals.purge;
	return blob;

epilog
	
	delete dyna;
	delete iter;
	delete array;
	delete self.myGroupTotals;
	self.doPrinterClose();
	
end;</source>
        <Parameter name="_isPrintPreview" type="Boolean"/>
        <Parameter name="_isCSV" type="Boolean"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setHeaderAndFooter" id="20b74ce9-3443-4aed-bda2-166590d989c7">
        <updating/>
        <source>setHeaderAndFooter() protected, updating;

vars

begin

	self.lblHeading1.caption	:= null;
	self.lblHeading2.caption	:= 'SHIP LOG LIST                                                  ';
	self.lblFooter1.caption		:= self.myVoyage.myTerminal.name;
	self.lblSupplierDtl.caption	:= app.myRoot.companyName;
	self.lblReportId.caption	:= self.myVoyage.code; 
	self.lblReportExtra.caption := self.myVoyage.statusDescription;
	self.lblVesselDtl.caption	:=  (self.myVoyage.code &amp; ' ' &amp; self.myVoyage.myVoyageGlobalArrival.vesselName).toUpper;
	self.tblReport.rows := 0;
	self.tblReport.columns := 3;
	self.tblReport.accessColumn(1).width := 120;
	self.tblReport.accessColumn(2).width := 100;
	self.tblReport.accessColumn(3).width := 130;
			
	self.frmHeader.width := app.printer.pageWidth;
	self.frmFooter.width := app.printer.pageWidth;
	if not self.isCSV then
		app.printer.setHeader(self.frmHeader);
		app.printer.setFooter(self.frmFooter);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setNoDataDisplay" id="1d4c5a72-4bb6-4625-8cf5-c7c9d6d310af">
        <source>setNoDataDisplay();
// -------------------------------------------
// Created 23 September 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.lblNoData.caption := 'No Data To Display For Ship Log List';


end;</source>
    </JadeMethod>
    <JadeMethod name="setSpecificHeader" id="a9afc24f-f7e0-4892-922b-cf846afe62db">
        <source>setSpecificHeader(_sort : CMIF_SOHReporter) protected;

vars

	code	: CM_ProductLog;

begin

	code := _sort.mySOHLocation.myProduct.CM_ProductLog;
	if _sort.myLot.myConsignee &lt;&gt; null then
	//cnwer1 20/7/06 par 11751
		self.lblBuyerDtl.caption 		:= self.lblSumBuyerDtl.caption;//_sort.myLot.myConsignee.description;//
	else
		self.lblBuyerDtl.caption 		:= null;
	endif;
	if _sort.myLot.myDischargePort &lt;&gt; null then
		self.lblDischargeDtl.caption	:= _sort.myLot.myDischargePort.description;
	else
		self.lblDischargeDtl.caption	:= null;
	endif;
	if _sort.mySupplier &lt;&gt; null then
		self.lblSupplierDtl.caption	:= _sort.mySupplier.description;
	endif;
	self.lblSpeciesDtl.caption		:= code.speciesCode;
	self.lblGradeDtl.caption		:= code.gradeCode;
	self.lblTypeDtl.caption			:= code.typeCode;
	self.lblTreatmentDtl.caption	:= code.treatmentCode;
	self.lblLengthDtl.caption		:= code.lengthCode;
	self.lblLotDtl.caption			:= _sort.lot;
	self.lblHatchDtl.caption		:= _sort.hatch.String;
	self.lblDeckDtl.caption			:= self.getPlaceString(_sort.place);

end;</source>
        <access>protected</access>
        <Parameter name="_sort" type="CMIF_SOHReporter"/>
    </JadeMethod>
    <JadeMethod name="sortData" id="9798b381-652c-4c69-abda-e36a69437f1b">
        <source>sortData(_set : CM_SOHLocationSet) : DynaDictionary protected;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars

	dyna	: DynaDictionary;
	soh		: CM_SOHLocation;
	sort	: CMIF_SOHReporter;

begin

	create dyna transient;
	dyna.setMembership(CMIF_SOHReporter);
	dyna.addMemberKey("myVoyage", false, false);
	dyna.addMemberKey("lot", false, false);
	dyna.addMemberKey("supplier", false, false);
	dyna.addMemberKey("hatch", false, false);
	dyna.addMemberKey("place", true, false);
	dyna.addMemberKey("myProduct", false, false);
	dyna.endKeys(false);
	
	foreach soh in _set do
		
		create sort transient;
//		sort.myVoyage		:= soh.myLocationsController.CM_LogVoyageController.myLogLot.myLogVoyage;
		sort.myVoyage		:= soh.myLocationsController.CM_LogVoyageController.myLogLot.myLogVoyageStructure.myVoyage;
		sort.myLot 			:= soh.myLocationsController.CM_LogVoyageController.myLogLot;
		sort.lot			:= soh.myLocationsController.CM_LogVoyageController.myLogLot.lotNo;
		sort.supplier		:= soh.myProduct.getDisplayStringForAttribute(ETRow_OperatorCode, true);
		sort.mySupplier		:= soh.myProduct.myOperator;
		sort.hatch			:= soh.myLocationsController.CM_LogVoyageController.hatch;
		sort.place			:= soh.myLocationsController.CM_LogVoyageController.place;
		sort.myProduct		:= soh.myProduct;
		sort.mySOHLocation	:= soh;
		dyna.add(sort);
	endforeach;
	
	// Do dyna stuff for headings.
	self.allHeaderTotals.setMembership(CMIF_ShipStowageTotals);
	self.allHeaderTotals.addMemberKey("length", true, false);
	self.allHeaderTotals.endKeys(false);
	return dyna;
end;</source>
        <access>protected</access>
        <Parameter name="_set" type="CM_SOHLocationSet"/>
        <ReturnType type="DynaDictionary"/>
    </JadeMethod>
</GUIClass>
