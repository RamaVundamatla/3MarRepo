    <JadeMethod name="findCommodityEdit" id="c6ec7836-9d76-4226-a5c5-3779865daec4">
        <source>findCommodityEdit() : Boolean;
// return true if the bookingref has had its commodity changed by a CM_Edit; 
//  cnwrs1 Nov 2006
vars
	foundEdit : Boolean;
	auditObject : CM_AuditObject;
	oldValue : String;
	newValue : String;
begin
	foundEdit := false;
	foreach auditObject in  self.allAuditObjectsForClass do
		if auditObject.getOldNewValueForTag(CM_BookingRef::commodity.name, oldValue, newValue) then
			if oldValue &lt;&gt; newValue and
			   newValue &lt;&gt; null then
				//write oldValue&amp;'#'&amp;newValue&amp;'#';
				foundEdit := true;
				break;
			endif;
		endif;
	endforeach;
epilog
	return foundEdit;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllDischargePortsCSV" id="e56e8fa5-e63a-427b-b198-44a042b21692">
        <source>getAllDischargePortsCSV() : String;
/*
Purpose:		TFS 2930	
Date		Who		Reason
12 December 2016	cnwab1	Initial creation
*/

vars
	port, ports : String;
begin
	foreach port in self.allDischargePorts discreteLock do
		if ports = null then
			ports := port;
		else
			ports := ports &amp; "," &amp; port;
		endif;
	endforeach;
	
	return ports;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllItemTIIHazards" id="b2ae810f-fa40-452d-9a5d-5b07e63b7514">
        <source>getAllItemTIIHazards(dict: CM_HazardByCodeDict input);
/*
	Created on 07 March 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	haz 	: CM_Hazard;
	brItem : CM_BookingRefItem;
begin
	foreach brItem in allBookingRefItems do
		foreach haz in brItem.allTIHazards do
			if dict[haz.code] = null then
				dict.add(haz);
			endif;
		endforeach;
	endforeach;
end;</source>
        <Parameter name="dict" type="CM_HazardByCodeDict" usage="input"/>
    </JadeMethod>
