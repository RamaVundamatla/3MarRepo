    <JadeMethod name="doControlResetSession" id="c998a871-1905-4816-b334-2bf0ebc11182">
        <updating/>
        <source>doControlResetSession(userInfo : String) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	frm		: HandHeldLogonForm;
begin
	self.frmAccept.visible:=false;
	self.unloadForm();
	create frm transient;
	frm.show;
	app.msgBox(userInfo.String,"Reset Session", MsgBox_OK_Only) ;

epilog

end;</source>
        <Parameter name="userInfo" type="String"/>
    </JadeMethod>
    <JadeMethod name="doKeyDown" id="04ed9bdc-cad4-493f-b6b6-d107752d85fb">
        <updating/>
        <source>doKeyDown(keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
02 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	versionInfo : String;
	file : File;
	wasInfoVisible : Boolean;
begin
	inheritMethod(keyCode, shift);
	wasInfoVisible:=self.frmInfo.visible;
	self.frmInfo.visible:= false;	
	//The generic key functions
	
	//SHOW INFO
	if keyCode = J_key_F1 then
		if wasInfoVisible then
			return;
		endif;
		self.frmInfo.visible:=true;
		
		self.frmInfo.centreWindow;
		self.frmInfo.top:=self.tblJobs.top;
		self.frmInfo.refresh;
	//CHANGE PRIMARY QUEUE
	elseif keyCode = J_key_F3 then
		self.isPrimaryQueue:=true;
		self.setupChangeQueue();
	// LOG OFF
	elseif keyCode = J_key_F4 then
		self.doLogOff();
	//REFRESH TABLE
	elseif keyCode = J_key_F5 then
		//self.btnJobOrder.click(self.btnJobOrder);
		self.doRefresh;
	elseif keyCode = J_key_F7 then
		//versionInfo:=app.myHandHeldGuiAgent.myHandHeldAgent.getFileVersion;
		//app.msgBox(versionInfo,"Version Info ?",MsgBox_OK_Only);
	//WHO AM I who who; who who
	elseif keyCode = J_key_F10 then
		self.getWhoAmIInfo();
		
	elseif 	keyCode = J_key_F11 then
		self.inspect;
	endif;
epilog
	delete file;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doLogOff" id="e7e0cb06-0ef9-47a5-ba85-5800ea60dad7">
        <updating/>
        <source>doLogOff() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	frm		: HandHeldLogonForm;
begin
	if frmAccept.visible = true then
		app.msgBox("Currently working a job either finish or cancel this job","Error",MsgBox_OK_Only);
		return;
	endif;

	self.clearErrors;
	
	if app.msgBox('Are you sure you want to log off?','Are you sure?', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then
		return;
	endif;

	//epr par 18256
	app.myLogonGuiAgent.doLogoff();
	
	self.unloadForm();

	create frm transient;
	frm.show;

	


epilog

end;</source>
    </JadeMethod>
