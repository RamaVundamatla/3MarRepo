    <JadeMethod name="translateForm" id="027c7f48-8084-45f4-8cd5-1f6593257b5e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005927, locale);
	btnCancel.translateBubbleHelp(Xlat_0001564, locale);
	btnCancel.translateCaption(Xlat_0001570, locale);
	btnNewVoyage.translateBubbleHelp(Xlat_0001565, locale);
	btnNewVoyage.translateCaption(Xlat_0001571, locale);
	btnSaveExtra.translateBubbleHelp(Xlat_0001566, locale);
	btnSaveExtra.translateCaption(Xlat_0001572, locale);
	btnSenarioVoyage.translateBubbleHelp(Xlat_0001567, locale);
	btnSenarioVoyage.translateCaption(Xlat_0001573, locale);
	btnStepBack.translateBubbleHelp(Xlat_0001568, locale);
	btnStepBack.translateCaption(Xlat_0001574, locale);
	btnStepForward.translateBubbleHelp(Xlat_0001569, locale);
	btnStepForward.translateCaption(Xlat_0001575, locale);
	lblMeterMarks.translateCaption(Xlat_0001576, locale);
	mnuAddShiftMovement.translateCaption(Xlat_0005928, locale);
	mnuBerthMarks.translateCaption(Xlat_0005929, locale);
	mnuRemarks.translateCaption(Xlat_0005930, locale);
	mnuTableContext.translateCaption(Xlat_0005931, locale);
end;</source>
    </JadeMethod>
