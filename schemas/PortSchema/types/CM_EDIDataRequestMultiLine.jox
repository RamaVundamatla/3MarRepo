    <JadeMethod name="isCoparnFile" id="62505ac9-70f6-4272-bc29-3b5195e08a70">
        <source>isCoparnFile() : Boolean;
//
//11 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
//
// 07 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
vars
	file : CM_EDIFile;
	result : Boolean;
begin
	file := self.myEDIFile;
	
// 07 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	if file &lt;&gt; null and file.myEDIFileType &lt;&gt; null then
		result := file.myEDIFileType.type = EDIFileType_Coparn;
	endif;
	
	return result;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadDB" id="7933ded1-75cd-4e44-8846-85b75a5de343">
        <updating/>
        <source>loadDB(_mergeCargo: Boolean; _passport: CM_Passport input) updating;
//
//16 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
//28 Jan 2016   cnwma1  Par 37438 [RELATED TO TFS1192] Error 70092 while loading EDI Release Request by Type
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 18 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 13 Jul 2023	navdap1	TFS 58923 EUP Call Off EDI Type / EDI Data Load
//27 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
vars
	cmifEDIRequestMultiLine : CMIF_EDIRequestMultiLine;
	tmpStatus : Integer;
	ediData : CM_EDIData;			// TFS 58923
begin
	// Arm our base exception handlers.
	on Exception do self.validationExceptionHandler(exception, _passport);
	
	app.setContinueCMExceptions(true);	// This needs to be set so that EDI exceptions get stored against the EDIData
	create cmifEDIRequestMultiLine transient;
	self.allEDITrackedItems.copy(cmifEDIRequestMultiLine.allEDITrackedItems);
	self.ediFileArray.copy(cmifEDIRequestMultiLine.ediFileArray);
	if self.myEDIDataCallOff &lt;&gt; null then										// TFS 58923
		cmifEDIRequestMultiLine.myCallOffEDIData := self.myEDIDataCallOff;		// TFS 58923
		self.myEDIDataCallOff.ediFileArray.copy(cmifEDIRequestMultiLine.ediFileArray);		//27 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
	endif;																		// TFS 58923
	cmifEDIRequestMultiLine.loadOrVerifyForDB(_passport, false);
	tmpStatus := self.getStatusFromEDITrackedItems(false);
	if tmpStatus &lt;&gt; 0 then
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, tmpStatus);	// par 27392 cnwrs1 14 Apr 2011
		// TFS 58923 start
		if self.myEDIDataCallOff &lt;&gt; null then
			ediData := self.myEDIDataCallOff;
			app.myTrxUA.trxSetEDIDataStatusAfterVerify(ediData, tmpStatus);
		endif;
		// TFS 58923 end
	endif;
epilog
	delete cmifEDIRequestMultiLine;
end;
</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="storePersistentErrors" id="355b48ac-08d7-4ac7-bec8-27f6e95f26c4">
        <source>storePersistentErrors() : Boolean;
//
//11 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
//
vars

begin
	if self.getMyTerminal.getConfig(EdiReleaseAllowPartial).Boolean then
		return false;
	endif;
	
	return true;
epilog

end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="verifyAll" id="4fb98452-9375-4bbd-afc5-997466cce059">
        <updating/>
        <source>verifyAll() updating;
//
// 19 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//19 October 2017	jlgrs1	Initial creation
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 08 Dec 2017	jlgrs1	TFS 8281 - SNO - EDI New Coaprn Issues
// 12 Jul 2023	navdap1	TFS 58923 EUP CallOff EDI Data Type / EDI Data Load
//27 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
//
vars
	cmifEDIRequestMultiLine : CMIF_EDIRequestMultiLine;
	tmpStatus : Integer;
	obj : Object;
	ediTI : CM_EDITrackedItem;
	ediError : CM_EDIError;
	gotException : Boolean;
	ediData : CM_EDIData;		// TFS 58923
begin
	// Arm our base exception handlers.
	on Exception do self.validationExceptionHandler(exception, app.myPassport);
	app.myPassport.clearErrorsWarnings();
	if self.allErrorWarnings.size &gt; 0 then
	on Exception do app.handleDeletedObject(exception, obj, gotException);
		foreach ediError in self.allErrorWarnings do
			obj := ediError.myUserObject;
			if gotException then
				continue;
			endif;
			if obj &lt;&gt; null and obj.isKindOf (CM_EDITrackedItem) then	
				ediTI := obj.CM_EDITrackedItem;
				if ediTI.status &lt;&gt; CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING and
				   ediTI.status &lt;&gt; CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
					beginTransaction;
					self.allErrorWarnings.remove(ediError);
					delete ediError;
					commitTransaction;
				endif;
			endif;
		endforeach;
	endif;
	app.setContinueCMExceptions(true);	// This needs to be set so that EDI exceptions get stored against the EDIData
	create cmifEDIRequestMultiLine transient;
	self.allEDITrackedItems.copy(cmifEDIRequestMultiLine.allEDITrackedItems);
	self.ediFileArray.copy(cmifEDIRequestMultiLine.ediFileArray);
	if self.myEDIDataCallOff &lt;&gt; null then										// TFS 58923
		cmifEDIRequestMultiLine.myCallOffEDIData := self.myEDIDataCallOff;		// TFS 58923
		self.myEDIDataCallOff.ediFileArray.copy(cmifEDIRequestMultiLine.ediFileArray);		//27 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
	endif;																		// TFS 58923
	cmifEDIRequestMultiLine.loadOrVerifyForDB(app.myPassport, true);
	tmpStatus := self.getStatusFromEDITrackedItems(true);
	if tmpStatus &lt;&gt; 0 then
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, tmpStatus);	// par 27392 cnwrs1 14 Apr 2011
		// TFS 58923 start
		if self.myEDIDataCallOff &lt;&gt; null then
			// update status and errors on Call Off data object
			ediData := self.myEDIDataCallOff;
			app.myTrxUA.trxSetEDIDataStatusAfterVerify(ediData, tmpStatus);
		endif;
		// TFS 58923 end
	endif;
epilog
	delete cmifEDIRequestMultiLine;
end;</source>
    </JadeMethod>
