    <JadeMethod name="resetEventType" id="70f76939-1fa3-494f-b122-194de568b27d">
        <source>resetEventType(pConstant : Constant; _passport : CM_Passport);
/*
----------   ----------  --------------------------------------------------
Created:	13 February 2007 By cnwth2

Purpose:	

/*

Date		Who		Reason
12 Aug 2015	cnwkpd1	Prevent 1090 error when event class not found
31 Oct 2022 navma1  ChangeRequest 56636[54258]: EUP - Adding New Event Type for VAS TodoTask Description
*/

vars
	text,
	descr,
	name,
	className		: String;
	cls				: Class;
	proxyEventType,
	realEventType	: CM_EventType;
	eventCategory   : Integer;

begin
	if pConstant.valueAsInteger = EVT_MAX_NEXT or
	   pConstant.valueAsInteger &gt;= EVT_MAX_JMT then
	   	return;
	endif;

	text 		:= pConstant.text;
	name		:= text.cnEcGetTagValueOfName('Name');
	descr 	  	:= text.cnEcGetTagValueOfName('Descr');
	className 	:= text.cnEcGetTagValueOfName('Class');
	
	if name = null or descr = null or className = null then
		return;
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid format for text for cargo type constant (' &amp; pConstant.name &amp; ')');
		return;
	endif;
	
	cls := currentSchema.getClass(className);
	if cls = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Class (' &amp; className &amp; ') not found for (' &amp; pConstant.name &amp; ')');
		return;
	endif;
	//epr CCMS 1405 12/12/14
	if  className = CMEVT_TrainTransaction.name then
		eventCategory:=CM_EventType.TRAIN_EVENT;
	elseif className = CMEVT_TruckEvent.name then
		eventCategory:=CM_EventType.TRUCK_EVENT;
	elseif className = CMEVT_VoyageEvent.name then
		eventCategory:=CM_EventType.VOYAGE_EVENT;
	elseif className = CMEVT_WagonTransaction.name then
		eventCategory:=CM_EventType.WAGON_EVENT;
	elseif className = CMEVT_LocationActivity.name then			//14 Apr 2021	NDL	TFS 50906
		eventCategory:=CM_EventType.LOCATION_EVENT;
	elseif className = CMEVT_VehicleBookingEvent.name then		//31.10.2022 navma1 #56636[54258]
		eventCategory:=CM_EventType.VBS_EVENT;
	elseif className = CMEVT_NonOperationalEvent.name then		//31.10.2022 navma1 #56636[54258]
		eventCategory:=CM_EventType.NONOPS_EVENT;
	else
		eventCategory:=CM_EventType.SYSTEM_EVENT;
	endif;
	
	realEventType := self.allEventTypesByType[pConstant.valueAsInteger];
		
	if realEventType = null then
		// treat as a create
		if eventCategory = CM_EventType.SYSTEM_EVENT    or
			eventCategory = CM_EventType.TRAIN_EVENT    or
			eventCategory = CM_EventType.TRUCK_EVENT    or
			eventCategory = CM_EventType.WAGON_EVENT    or
			eventCategory = CM_EventType.LOCATION_EVENT or
			eventCategory = CM_EventType.VBS_EVENT      or		//31.10.2022 navma1 #56636[54258]
			eventCategory = CM_EventType.NONOPS_EVENT   or		//31.10.2022 navma1 #56636[54258]
			eventCategory = CM_EventType.VOYAGE_EVENT   then 	//epr CCMS 1405 
			create proxyEventType transient;
			proxyEventType.setProxy(pConstant.valueAsInteger, name, descr, className, null, eventCategory, self,0,false,null);
			app.myUtilityCA.utlCreateEventType(proxyEventType, realEventType, app.myPassport);
		endif;
	else
		proxyEventType := app.createUpdateProxy(realEventType).CM_EventType;
		proxyEventType.setProxy(pConstant.valueAsInteger, name, descr, className, null, eventCategory,self,proxyEventType.amountDecimalPlaces,false,null);
		app.myUtilityUA.utlUpdateEventType(proxyEventType, app.myPassport);
	endif;
	
epilog
	delete proxyEventType;
	
end;</source>
        <Parameter name="pConstant" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
