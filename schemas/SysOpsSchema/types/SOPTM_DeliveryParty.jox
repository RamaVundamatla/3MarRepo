    <JadeMethod name="populateShtAddresses" id="90a3d4bd-b214-41df-b13b-f9126b1a90dc">
        <source>populateShtAddresses();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 14 June 2022
TFS#		: 53679
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	iter	 : Iterator;
	address  : CM_Address;
	index	 : Integer;
	theForm  : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	
	theForm.tblAddrDetails.clear();
	
	theForm.tblAddrDetails.columns := 3;
	theForm.tblAddrDetails.fixedColumns := 0;
	theForm.tblAddrDetails.rows := 1;
	theForm.tblAddrDetails.fixedRows := 1;
	theForm.tblAddrDetails.selectMode := Table.SelectMode_CurrentRow;
	
	theForm.tblAddrDetails.setCellText(1,1, app.getErrorString(Id) &amp; Tab &amp; app.getErrorString(Description) &amp; Tab &amp; app.getErrorString(Default) );
	
	if theForm.tblAddrDetails.sortColumn[1] &gt; 0 then
		theForm.tblAddrDetails.accessRow(1).fontBold := false;
		theForm.tblAddrDetails.accessCell(1, theForm.tblAddrDetails.sortColumn[1]).fontBold := true;
	endif;
	
	if theForm.myProxyObject.CM_DeliveryParty &lt;&gt; null or theForm.myCurrentObject.CM_DeliveryParty &lt;&gt; null then
		if theForm.myProxyObject.CM_DeliveryParty &lt;&gt; null then
			iter := theForm.myProxyObject.CM_DeliveryParty.allAddresses.createIterator;
		else 
			iter := theForm.myCurrentObject.CM_DeliveryParty.allAddresses.createIterator;
		endif;
		
		while iter.next( address ) do
		
			index := theForm.tblAddrDetails.addItem( address.code &amp; Tab &amp; address.description &amp; Tab &amp; address.isDefault.getYesNo() );
			theForm.tblAddrDetails.accessRow(index).itemObject := address;
		endwhile;
	
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setAddressScrollRange" id="607c8ab5-700e-48b0-9cdf-944e4e7286b6">
        <source>setAddressScrollRange();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2022	jlier1	Initial creation

*/

vars
	maxHScroll,
	maxVScroll : Integer;
begin
	
	if (self.myForm.tblAddrDetails.left + self.myForm.tblAddrDetails.clientWidth + 20 ).Integer -self.myForm.sheetAddress.clientWidth &gt; 0 then
		maxHScroll:= (self.myForm.tblAddrDetails.left + self.myForm.tblAddrDetails.clientWidth + 20).Integer -self.myForm.sheetAddress.clientWidth;
	else
		maxHScroll:=0;
	endif;
	if (self.myForm.btnAddrUpdate.top + self.myForm.btnAddrUpdate.clientHeight  + 20 ).Integer -self.myForm.sheetAddress.clientHeight &gt; 0 then
		maxVScroll:= (self.myForm.btnAddrUpdate.top + self.myForm.btnAddrUpdate.clientHeight  + 20).Integer -self.myForm.sheetAddress.clientHeight;
	else
		maxVScroll:=0;
	endif;
	self.myForm.picAddress.setScrollRange(1, 0,maxHScroll , 20, 100);
	self.myForm.picAddress.setScrollRange(2, 0,maxVScroll , 20, 100);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="5cff5fde-d84b-42a8-be2c-68f33039b956">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 09 June 2022
TFS#		: 53679
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	theForm : SOP_TableMaintForm;

begin

	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := true;	
	self.clearCurrentAddress();

	if theForm.mode = theForm.Mode_Add then
		self.populateShtAddresses();
		theForm.tblInput1.clearValues;		
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Name);
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.setFocus;
		theForm.mulSelect1.setSelected(null);
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_DeliveryParty);
		// cannot update code
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Name);		
		theForm.mulSelect1.setSelected(theForm.myProxyObject.CM_DeliveryParty.allTerminals);			
	endif;
	
	theForm.btnAddrSave.enabled := false;
	theForm.btnAddrCancel.enabled := false; 
	theForm.btnAddrDelete.enabled := false;	
	theForm.btnAddrUpdate.enabled := false;
	
	theForm.btnAddrNew.enabled := true;
	
	self.enableMulSelect1Contents();		
	self.enableDisableAddressSheetObj(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="d4d1e71c-6cd0-46c5-8d00-a47ded78a9e7">
        <updating/>
        <source>setCtrlsForView() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 10 June 2022
TFS#		: 53679
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	theForm : SOP_TableMaintForm;		
begin
	
	inheritMethod();
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.mulSelect1.setSelected(null);	
	theForm.sheetAddress.visible := true;
	
	theForm.btnAddrSave.enabled := false;
	theForm.btnAddrCancel.enabled := false;
	theForm.btnAddrDelete.enabled := false;	
	theForm.btnAddrUpdate.enabled := false;
	
	theForm.btnAddrNew.enabled := false;
	
	self.enableDisableAddressSheetObj(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="2e5ba698-5419-4f79-bcbe-12f5400c6bbe">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 14 June 2022
TFS#		: 
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	theForm : SOP_TableMaintForm;
begin
  
	theForm := self.myForm;
  	
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_DelPartyMaint);
	
	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_DelPartyMaint);
	theForm.shtTblInput1.visible := true;
	
	self.doCmbCountryBuild();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showCurrentAddress" id="0745b2cc-ce95-4a6a-adcd-58acc0a27407">
        <updating/>
        <source>showCurrentAddress(_address : CM_Address) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 15 June 2022
TFS#		: 53679
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	theForm  : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	
	self.clearCurrentAddress();
	if _address &lt;&gt; null then
		theForm.txtAddrCode.text 			:= _address.code;
		theForm.txtAddrDescription.text 	:= _address.description;
		theForm.txtAddrAdr1.text			:= _address.addr1;
		theForm.txtAddrAdr2.text			:= _address.addr2;
		theForm.txtAddrAdr3.text			:= _address.addr3;
		theForm.txtAddrRegion.text      	:= _address.region;
		theForm.txtAddrPostCode.text    	:= _address.postCode;
		theForm.chkDefultAddess.value       := _address.isDefault;
		theForm.txtAddrCity.text 			:= _address.city;
		theForm.txtAddrDelIns.text 			:= _address.deliveryInstructions;
		
		if _address.countryCode &lt;&gt; null then
			theForm.cmbAddrCountry.listIndex := theForm.cmbAddrCountry.findObject( _address.getCountry() );
		endif;
		
		self.myCurrentAddress := _address;
				
		if theForm.myProxyObject.CM_DeliveryParty &lt;&gt; null then
			theForm.btnAddrDelete.enabled := true;
			theForm.btnAddrUpdate.enabled := true;		
			theForm.btnAddrNew.enabled    := theForm.myProxyObject.CM_DeliveryParty.allAddresses.size() &lt; 9;
		else
			theForm.btnAddrDelete.enabled := false;
			theForm.btnAddrUpdate.enabled := false;
			theForm.btnAddrNew.enabled    := false;
		endif;
	endif;

end;</source>
        <Parameter name="_address" type="CM_Address"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="33cdaa57-0cda-475d-95cd-e3b1ceabfbf8">
        <updating/>
        <source>showThumbnail(pDeliveryParty: CM_DeliveryParty) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 14 June 2022
TFS#		: 53679
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	theForm 	: SOP_TableMaintForm;
	entTableDef	: EntTableDef;
	entTableRow	: EntTableRow;
begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;
	
	entTableDef := app.myController.getEntTableDef(ETDef_DelPartyMaint);
		
	foreach entTableRow in entTableDef.allEntTableRows do
		theForm.tblInput1.setValueByName(entTableRow.name, pDeliveryParty.getDisplayStringForAttribute(entTableRow.name, false));
	endforeach;	
	
	theForm.mulSelect1.setSorted(true);
	theForm.mulSelect1.setSelected(pDeliveryParty.allTerminals);
	self.clearCurrentAddress();
	self.disableMulSelect1Contents();	
	self.populateShtAddresses();
end;</source>
        <Parameter name="pDeliveryParty" type="CM_DeliveryParty"/>
    </JadeMethod>
    <JadeMethod name="tblAddrDetailsClick" id="4c47b799-d685-4900-ac76-51b9d324233b">
        <updating/>
        <source>tblAddrDetailsClick() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 15 June 2022
TFS#		: 
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	address : CM_Address;
	index   : Integer;
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;

	if theForm.btnAddrSave.enabled then
		return;
	endif;
	
	theForm.btnAddrSave.enabled := false;
	theForm.btnAddrCancel.enabled := false;
	index := theForm.tblAddrDetails.row;
	if index &gt; 1 then
		address := theForm.tblAddrDetails.accessRow(index).itemObject.CM_Address;
	endif;
	if address &lt;&gt; null then
	
		self.myCurrentAddress := address;
		showCurrentAddress(address);
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
