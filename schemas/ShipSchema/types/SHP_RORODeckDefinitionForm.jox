        <source>doFrameDrawMouseDownOther(_frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     January 2010 ANDREW BISHOP
//
// CALLED BY CMUI_SliderHandle, no references
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	frame : CMUI_PointDrawingFrame;
begin
	frame := self.getFrameForLayer(self.myCurrentProxyLayerLayout);
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1.' &amp; myCurrentProxyLayerLayout.String &amp; " " &amp; frame.String);	
	if frame = null then
		return;
	endif;
	
	frame.doFrameMouseDownLeft(frame, button, shift, x, y);
end;</source>
