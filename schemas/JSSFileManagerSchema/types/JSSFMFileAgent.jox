    <JadeMethod name="setUnixFlags" id="8873b476-71b3-4bf8-8611-38673ab96030">
        <updating/>
        <source>setUnixFlags(pIsSourceUnix:Boolean; pIsTargetUnix:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		09 September 2002 by cnwdad3
//
// Purpose:		Updates the flags to indicate whether the source and/or target
//				platforms are Unix.
//
// Parameters:	pIsSourceUnix - If true then the source platform is Unix, otherwise
//					Windows is assumed.
// Parameters:	pIsTargetUnix - If true then the target platform is Unix, otherwise
//					Windows is assumed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isSourceUnix	:=	pIsSourceUnix;
	self.isTargetUnix	:=	pIsTargetUnix;
end;</source>
        <Parameter name="pIsSourceUnix" type="Boolean"/>
        <Parameter name="pIsTargetUnix" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="startBackgroundCopy" id="2a3e407a-8791-4145-bd24-fe9f533a3dcc">
        <executionLocation>server</executionLocation>
        <source>startBackgroundCopy(pTheCopy:JSSFMBackgroundCopy input) serverExecution;
// --------------------------------------------------------------------------------
// Created:		20 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.startApplicationWithParameter(JSSFileManagerSchema.name, "JSSBackgroundFileCopy", pTheCopy);
end;</source>
        <Parameter name="pTheCopy" type="JSSFMBackgroundCopy" usage="input"/>
    </JadeMethod>
    <JadeMethod name="writeToDiskFile" id="26dedaf1-17ee-4109-9197-16dc9b494e1b">
        <updating/>
        <source>writeToDiskFile(pDiskFileObj:File; pFileData:Binary; pIsCompressionUsed:Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		27 June 2002 by cnwdad1
//
// Purpose:		Write a chunk of data to the specified disk file.
//
// Parameters:	pDiskFileObj - The file to write the data to.
//				pFileData - The data to be written to the file.
//				pIsCompressionUsed - If true, then the pFileData must be uncompressed
//					before it is written to the file.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 08/08/2002	cnwdad1		Added check for the length of the file data before
//							attempting to uncompress it.
// --------------------------------------------------------------------------------
vars
	fileData	: Binary;
	
begin
	if pIsCompressionUsed and pFileData.length() &gt; 0 then
// cnwdad1 25/02/2009 - PAR #18366.
//		fileData	:=	pFileData.uncompress();
		fileData	:=	pFileData.uncompressToBinary();
	else
		fileData	:=	pFileData;
	endif;
	
	pDiskFileObj.writeBinary(fileData);
	
//	if pDiskFileObj.errorCode() &lt;&gt; 0 then
//		self.doFileErrorSet(pDiskFileObj.errorCode(), pDiskFileObj.fileName);
//	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pDiskFileObj" type="File"/>
        <Parameter name="pFileData" type="Binary"/>
        <Parameter name="pIsCompressionUsed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="writeToDiskFileAppServer" id="dd92ca65-fc8e-404d-8bc8-e2ec36992694">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>writeToDiskFileAppServer(pDiskFileObj:File; pFileData:Binary; pIsCompressionUsed:Boolean) updating, protected, clientExecution;
// --------------------------------------------------------------------------------
// Created:		08 July 2002 by cnwdad2
//
// Purpose:		AppServer node wrapper for the writeToDiskFile method.
// --------------------------------------------------------------------------------
begin
	self.writeToDiskFile(pDiskFileObj, pFileData, pIsCompressionUsed);
end;</source>
        <access>protected</access>
        <Parameter name="pDiskFileObj" type="File"/>
        <Parameter name="pFileData" type="Binary"/>
        <Parameter name="pIsCompressionUsed" type="Boolean"/>
    </JadeMethod>
