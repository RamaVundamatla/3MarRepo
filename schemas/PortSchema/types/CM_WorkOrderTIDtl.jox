    <JadeMethod name="canPerformInstantAction" id="2cbd3e16-e304-4726-817b-66258c70c126">
        <source>canPerformInstantAction():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2018	jlgndl1	Initial creation	TFS 38950
10 Sep 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
*/

vars

begin
	/* 10.09.2021 navma1 #51002
	if self.getMyTerminal.isUsingDefaultProcessJMT then
		return false;
	endif;
	*/
	
	if  self.getMyTerminal.isUseYardJobsForCargoWo() then   //10.09.2021 navma1 #51002
		return false;
	endif;
	
	if self.totalUnactioned &lt; 1 then
		return false;
	endif;
	
	//if self.totalUnactioned &gt; self.allAvailableTIs.size then				//08.02.2023 navma1 #56457 Task#56458
	if self.allActionedTIs.size &gt;self.allAvailableTIs.size then				//08.02.2023 navma1 #56457 Task#56458
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeStatusWoWLE" id="0efda82a-fba0-46db-88c0-b008fcc184cf">
        <source>changeStatusWoWLE(_status 		: Integer;
				  _ti     		: CM_TrackedItem;
				  _toDoTaskDesc : CM_ToDoTaskDesc);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Jul 2022	navcs2  ChangeRequest 53932: MTN - Jobs Changes
19 Aug 2022 navma1	Bug 54324: MTN - The Work List entries are not complete for the Unpack Work Order
23 Aug 2022 navma1	Bug 54297: MTN - Pack Work Order issues
27 Mar 2023 navma1  ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
10 Jul 2023	navma1	ChangeRequest 54550: EUP | Delivery Dispatch Screen - Pack Operation
11 Sep 2023 navhl20 ChangeRequest 59121: EUP | Handle Work orders Packing  By Type
04 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
19 Dec 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
19 Feb 2025	navhl20 Bug MTN-19298: MTN - Performance issue when discharging the cargo items on the Complete job form for Ship jobs
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	woJob		:	CM_Job;
	wle			:	CM_WorkListEntry;
	wod			: 	CM_WorkOrderTIDtl;
	release		: 	CM_WOReleaseCargoJob;
	byType		: 	Boolean;
	ti			: 	CM_TrackedItem;
begin
	foreach woJob in self.allJobs discreteLock do						//06.03.2025 navma1 #MTN-34179
		//23.08.2022 navma1 #54297
		if woJob.isWOPackJob then
			if woJob.CM_WOPackJob.isPackParentJob then
				foreach wle in woJob.workListEntries discreteLock do	//06.03.2025 navma1 #MTN-34179
					
					ti := wle.myTrackedItem;
					
					if ti = null then									//22.08.2023 navma1 #59121
						continue;
					endif;
					
					if ti &lt;&gt; _ti then
						continue;
					endif;
					
					if wle.status = JOB_COMPLETE then
						continue;
					endif;
					wle.setStatus(_status);
				endforeach; 
			else
				foreach wle in woJob.workListEntries discreteLock do		//06.03.2025 navma1 #MTN-34179
					
					ti := wle.myTrackedItem;
					
					if ti = null then										//22.08.2023 navma1 #59121
						continue;
					endif;
					
				
					if ti.myParent &lt;&gt; _ti then
						continue;
					endif;
					
					if wle.status = JOB_COMPLETE then
						continue;
					endif;
					
					wle.setStatus(_status);
				endforeach; 
			endif;
		else
			if  woJob.isVoyageWorkpointJob then														//04.12.2023 navhl20 #58400[61617]
				byType := woJob.isRelByType();														//19.02.2025 navhl20 #19298
				if woJob.CM_VoyageWorkPointJob.plannedLocation &lt;&gt; null or byType then 				//26/08/2024	navkc1 CR 63588 Task 63589
					woJob.CM_VoyageWorkPointJob.completeWLE(_ti);
				endif;
			else																					//04.12.2023 navhl20 #58400[61617]
				foreach wle in woJob.workListEntries discreteLock do								//06.03.2025 navma1 #MTN-34179
					if wle.status = JOB_COMPLETE then
						continue;
					endif;
					if wle.myTrackedItem &lt;&gt; _ti then
						continue;
					endif;
					if woJob.isKindOf(CM_WOToDoTaskJob) and 										 //27.03.2023 navma1 #56614:[56615]
					   woJob.CM_WOToDoTaskJob.myToDoTaskDesc &lt;&gt; _toDoTaskDesc then
					   continue;
					endif;
					wle.setStatus(_status);
				endforeach;
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="completeMe" id="9c553ee8-244c-4e76-9aa1-5a74cbfa1dc2">
        <updating/>
        <source>completeMe() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jul 2009	cnwrd1	Initial creation
08 Feb 2023 navma1 ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
09 Dec 2024	navhl20 Bug MTN-33643: EUP - Partial move by weight is not working in Work Order Operation screen - Receive
*/

vars

begin
	
	/*
	08.02.2023 navma1 #56457 Task#56458
	if self.isLastTask then
		self.myParent.completeMe();
	endif;
	*/
	
	//if self.allCompleteTIs.size = self.myParent.getTotalRequired then			//08.02.2023 navma1 #56457 Task#56458
	if self.allCompleteTIs.size = self.allSelectedTIs.size then					//08.02.2023 navma1 #56457 Task#56458
		self.setStatus(WO_STATUS_COMPLETE);
	endif;
	
	if self.isDetailCompleted then												//09.12.2024 navhl20 #33643
		self.setStatus(WO_STATUS_COMPLETE);
	endif;
	
	if self.myParent.isAllTasksWithStatus(WO_STATUS_COMPLETE) then				//08.02.2023 navma1 #56457 Task#56458
		self.myParent.completeMe();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createTITransaction" id="6092552c-aa0f-4413-893d-0d031ebedcf6">
        <updating/>
        <source>createTITransaction(_type : Integer ; _ti : CM_TrackedItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2023	navma1  	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI

*/

vars
	txnParams : CMIF_WorkOrderTransController;
	
begin
	create txnParams transient;
	
	txnParams.type 		  := TRANS_TYPE_WORKORDER_UNASSIGN;
	txnParams.myWorkOrder := self.myParent.CM_WorkOrderTI;
	_ti.createTransaction(txnParams, app.myPassport);
	
epilog
	delete txnParams;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
