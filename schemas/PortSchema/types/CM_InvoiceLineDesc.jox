    <JadeMethod name="isQuantityBased" id="f04edf8b-3241-49bc-9e83-fff22155a9ba">
        <source>isQuantityBased() : Boolean;
/*
Purpose:	

Date		Who		Reason
30 April 2025	navab1	JIRA 34760
*/
vars
	result	: Boolean;
	chgByUnits : Integer;
begin
	chgByUnits := self.getChargeByUnits();

	if chgByUnits = INV_CALC_TYPE_QUANTITY
	 // ### JIRA 35638 06AUG2025 NAVAB1 added in other quantity  based calc types. For cash, only the cargo ones matter but as a general method it has all invoicing types
	or chgByUnits = INV_CALC_TYPE_RESOURCE_QTY
	or chgByUnits = INV_CALC_TYPE_TRANSQUANTITY
	or chgByUnits = INV_CALC_TYPE_INVENT_QUANTITY
	or chgByUnits = INV_CALC_TYPE_WO_CARGOQUANTITY
	or chgByUnits = INV_CALC_TYPE_WO_RES_QTYQTY
	
	or chgByUnits = INV_CALC_TYPE_QUANTITY_ONBOARD then
		result := true;
	endif;

	return result;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSameCalcType" id="578918e2-2341-492f-b17f-4b5dc3ba2273">
        <source>isSameCalcType(_calcType : CM_CalculationType) : Boolean;
/*
Purpose:			

Date		Who		Reason
31 August 2023	navab1	BUG 59913 
*/

vars

begin
	
	if _calcType.isBolCalcType
	and self.isBolCalcType() then
		return true;
	elseif _calcType.isCargoCalcType
	and self.isCargoCalcType() then
		return true;
	elseif _calcType.isEventCalcType
	and self.isEventCalcType() then
		return true;
	elseif _calcType.isInventoryType
	and self.isInventoryCalcType() then
		return true;
	elseif _calcType.isVoyageCalcType
	and self.isVoyageCalcType() then
		return true;
	elseif _calcType.isWorkOrderType
	and self.isWorkOrderLine() then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_calcType" type="CM_CalculationType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
