    <JadeMethod name="doMultiMove" id="e6045f6b-ca9e-4e3d-bc42-4c751b4642cd">
        <source>doMultiMove():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2015	cnwndl1	Initial creation	Par 36900

*/

vars

	targetLC : CM_LocationsController;
	errMsg : String;
	tiArray : CM_TIArray;
	ti : CM_TrackedItem;
	hideMoveConfirmation : Boolean;

begin

	targetLC := self.txtLocation.userObject.CM_LocationsController; 
	if targetLC = null then
		errMsg := app.getErrorString( No_Target_location_found );
		self.msgBox( errMsg, app.getErrorString(Error), MsgBox_OK_Only, true );
		txtLocation.setFocus();
		return false;
	endif;
	
	create tiArray transient;
	self.getSelectedCargo( tiArray );
	
	if tiArray.isEmpty then
		errMsg := app.getErrorString(Cargo_selected_move);
		self.msgBox( errMsg, app.getErrorString(Error), MsgBox_OK_Only, true );
		txtCargoId.setFocus();
		return false;
	endif;
	
	//Check the user really wants to do the move...
	hideMoveConfirmation := app.myPassport.myTerminal.getConfig(HhMoveConfirmation).Boolean;
	if not hideMoveConfirmation then
		errMsg := app.getErrorString2(Move_selected_items, tiArray.size.String, targetLC.getFullId );
		if app.msgBox( errMsg, app.getErrorString(ConfirmMove), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
			return false;
		endif;
	endif;
	
	foreach ti in tiArray do
		if ti.isChild then
			errMsg := app.getErrorString(ERR_MOVING_CHILD) &amp; " (" &amp; ti.id &amp; ")";
			self.msgBox( errMsg, app.getErrorString(Error), MsgBox_OK_Only, true );
			return false;
		endif;
	endforeach;
	
	app.mousePointer := self.MousePointer_HourGlass;
	
	foreach ti in tiArray do
	
		if self.myMobileGenericAgent.moveTI( ti, null, targetLC, null, true, 0, 0, null ) then
			self.removeCargoFromTable( ti );
		else
			return false;
		endif;
	endforeach;
	
	self.txtLocation.text := null;
	self.txtLocation.lostFocus( self.txtLocation );
	
	return true;

epilog

	app.mousePointer := self.MousePointer_Default;

	delete tiArray;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMultiPack" id="40b08540-2ac9-4931-b322-c56ca9241560">
        <source>doMultiPack():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2015	cnwndl1	Initial creation	Par 36900

*/

vars

	parent : CM_TrackedItem;
	errMsg : String;
	tiArray : CM_TIArray;
	ti : CM_TrackedItem;
	hideMoveConfirmation : Boolean;

begin

	parent := self.txtParent.userObject.CM_TrackedItem; 
	if parent = null then
		errMsg := app.getErrorString( Must_choose_parent_pack_into );
		self.msgBox( errMsg, app.getErrorString(Error), MsgBox_OK_Only, true );
		txtParent.setFocus();
		return false;
	endif;
	
	create tiArray transient;
	self.getSelectedCargo( tiArray );
	
	if tiArray.isEmpty then
		errMsg := app.getErrorString(No_Cargo_To_Pack);
		self.msgBox( errMsg, app.getErrorString(Error), MsgBox_OK_Only, true );
		txtCargoId.setFocus();
		return false;
	endif;
	
	//Check the user really wants to do the pack...
	hideMoveConfirmation := app.myPassport.myTerminal.getConfig(HhMoveConfirmation).Boolean;
	if not hideMoveConfirmation then
		errMsg := app.getErrorString2(Pack_selecte_items_into, tiArray.size.String, parent.id );
		if app.msgBox( errMsg, app.getErrorString1(ConfirmAction, app.getErrorString(Pack) ), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
			return false;
		endif;
	endif;
	
	foreach ti in tiArray do
		if ti.isChild then
			errMsg := app.getErrorString(ERR_MOVING_CHILD) &amp; " (" &amp; ti.id &amp; ")";
			self.msgBox( errMsg, app.getErrorString(Error), MsgBox_OK_Only, true );
			return false;
		endif;
	endforeach;
	
	app.mousePointer := self.MousePointer_HourGlass;
	
	foreach ti in tiArray do
	
		if self.myMobileGenericAgent.doPackCargo( parent, ti, true ) then
			self.removeCargoFromTable( ti );
		else
			return false;
		endif;
	endforeach;
	
	self.txtParent.text := null;
	self.txtParent.lostFocus( self.txtParent );
	
	return true;

epilog

	app.mousePointer := self.MousePointer_Default;

	delete tiArray;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="f2568cee-4c69-40a0-85dd-d4bf6fd05458">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2015	cnwndl1	Initial creation	Par 36900

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth - self.resizedMargin - stdHeight;
	cHeight := stdHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move( 	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
						 
	cWidth := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.setAndIncrementTabIndex( tabIndex );
		self.btnPartCargoId.visible := true;
	endif;
	self.btnPartCargoId.move(	self.txtCargoId.left + self.txtCargoId.width + self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.txtCargoId.height + self.resizedMargin;
	cWidth := ( stdWidth / 2 ) - self.resizedMargin ;
	if _initialSetup then
		self.optMove.setAndIncrementTabIndex( tabIndex );
		self.optMove.visible := true;
	endif;
	self.optMove.move(	 self.resizedMargin,
						cTop,
						cWidth,
						cHeight );
						
	if _initialSetup then
		self.optPack.setAndIncrementTabIndex( tabIndex );
		self.optPack.visible := true;
	endif;
	self.optPack.move(	self.optMove.left + self.optMove.width + self.resizedMargin,
						cTop,
						cWidth,
						cHeight );
						
	cTop := cTop + self.optMove.height + self.resizedMargin;
	cWidth := stdWidth;
	cHeight:= (self.clientHeight - cTop - self.getCMDButtonsHeight() - stdHeight - self.resizedMargin - self.resizedMargin - self.resizedMargin);
	if _initialSetup then
		self.tblProspects.setAndIncrementTabIndex( tabIndex );
		self.tblProspects.visible := true;
	endif;
	self.tblProspects.move(	self.resizedMargin, 
							cTop, 
							stdWidth, 
							cHeight);
							
	if _initialSetup then
		self.setupTable();
	endif;
	self.tblProspects.cnAdjustColumnWidths();
							
	cTop := cTop + self.tblProspects.height + self.resizedMargin;
	if _initialSetup then
		self.txtLocation.setAndIncrementTabIndex( tabIndex );
		self.txtLocation.visible := true;
	endif;
	self.txtLocation.move( 	self.resizedMargin,
							cTop,
							stdWidth,
							stdHeight );

	if _initialSetup then
		self.txtParent.setAndIncrementTabIndex( tabIndex );
		self.txtParent.visible := false;
	endif;
	self.txtParent.move( 	self.resizedMargin,
							cTop,
							stdWidth,
							stdHeight );
	
	
	
	
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="6ab1d356-5aed-41bb-ad35-bdb2aba22496">
        <updating/>
        <source>doSave():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2015	cnwndl1	Initial creation

*/

vars

	parent : CM_TrackedItem;

begin

	if self.optMove.value then
		return self.doMultiMove();
	elseif self.optPack.value then
		parent := self.txtParent.userObject.CM_TrackedItem;
		if not self.doMultiPack() then
			return false;
		endif;
		if self.myTerminal.getConfig(PromptForPackComplete).Boolean then
			self.myMobileGenericAgent.setPackContainerDetails(	null,	//_stockBookingRef : CM_BookingRef;
																	null,	//_stockBookingRefItem : CM_BookingRefItem;
																	null,	//_exportBookingRef : CM_BookingRef;
																	null,	//_exportBookingRefItem : CM_BookingRefItem;
																	parent //_trackedItem : CM_TrackedItem
																	);
			self.gotoForm( MOB_HHPackComplete, false );	
		endif;
		return true;
	endif;

	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findLocationToMoveTo" id="17becbf8-4a92-48e2-a269-90ed90465759">
        <source>findLocationToMoveTo( tmpFoundLC : CM_LocationsController output ):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2015	cnwndl1	Initial creation	Par 36900

*/

vars

	dataString : String;
	term : CM_Terminal;
	tmpFoundHeight : Integer;
	errMess : String;
	strs : StringArray;
	
begin

	
//	if self.txtLocation.userObject &lt;&gt; null then
//		tmpFoundLC := self.txtLocation.userObject.CM_LocationsController;
//		return true;
//	endif;

	// Find the location we are moving to.
	dataString := self.txtLocation.text.trimBlanks.toUpper;
	
	if dataString = null or dataString = lblLocation.caption.toUpper then
		errMess := app.getErrorString( No_Location_entered );
	else
	
		term := self.myMobileDataAgent.myTerminal;
		self.myTerminal.findLocationFromString(dataString, true, tmpFoundLC, tmpFoundHeight);
		
		if tmpFoundLC = null then
			errMess := errMess &amp; app.getErrorString1(Location_NotFound, "'" &amp; dataString &amp; "'");
		endif;
		
	endif;
	
	if errMess &lt;&gt; null then
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		txtLocation.setFocus();
		return false;
	endif; 
	
	return true;
	
epilog

	delete strs;

end;</source>
        <access>protected</access>
        <Parameter name="tmpFoundLC" type="CM_LocationsController" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findParent" id="22f712e1-322b-45c4-99fc-7f5c2dfb63e5">
        <source>findParent( _parent : CM_TrackedItem output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2015	cnwndl1	Initial creation	Par 36900

*/

vars

	parentId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	tiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	errMsg : String;
	
	parentIdLength : Integer;
	
begin

	parentId := txtParent.text.trimBlanks.toUpper;
	if parentId = lblParent.caption.toUpper then
		parentId := null;
	endif;
	
	term := self.myMobileDataAgent.myTerminal;
	
	create tiArray transient;
	
	if parentId &lt;&gt; null then
	
		parentIdLength := parentId.length;	
		
		firstTi := term.allOnsiteTIsByIdCargoType.getAtKeyGeq(parentId,null);
		if firstTi &lt;&gt; null and firstTi.id[1:parentIdLength] = parentId then	
			iter := term.allOnsiteTIsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id[1:parentIdLength] &lt;&gt; parentId then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
	endif;
		
	if tiArray.size = 1 then
		_parent := tiArray.first;
		return true;
	endif;
	
	return false;
	
epilog

	delete tiArray;
	delete iter;

end;</source>
        <Parameter name="_parent" type="CM_TrackedItem" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSelectedCargo" id="5083d15f-2cbe-4df0-abd2-d26504c13277">
        <source>getSelectedCargo( _tiArray : CM_TIArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 September 2015	cnwndl1	Initial creation	Par 36900

*/

vars

	size : Integer;
	index : Integer;
	obj : Object;
	ti : CM_TrackedItem;

begin

	size := self.tblProspects.rows;
	foreach index in 1 to size do
		if self.tblProspects.accessCell(index,1).text = "1" then	// its selected.
			obj := self.tblProspects.accessRow(index).itemObject;
			if obj &lt;&gt; null and obj.isKindOf(CM_TrackedItem) then
				_tiArray.add( obj.CM_TrackedItem );
			endif;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
