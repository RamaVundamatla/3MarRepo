    <JadeMethod name="startupChangeTracker" id="f13b280e-7564-4997-a79f-c35789ee28ac">
        <source>startupChangeTracker(pNotifier: JSSCTNotificationObject);
/*
*/
vars
	nibbler: JSSCTNibblerManager;
begin
	on Exception do handleAppException(exception);

	if pNotifier = null then
		return;
	endif;
	//	create a transient copy of the pSender
	create nibbler transient;

	//	initialize the transient Sender
	nibbler.startedApplication(pNotifier);
end;</source>
        <Parameter name="pNotifier" type="JSSCTNotificationObject"/>
    </JadeMethod>
    <JadeMethod name="startupClassInitializer" id="d29abfab-b953-4a5f-8366-a619c0866f2e">
        <source>startupClassInitializer(pClassInitializer: JSSCTInitializeClassRequest);
/*
*/
vars
	nibbler: JSSCTNibblerManager;
begin
	on Exception do handleAppException(exception);

	//	create a transient copy of the pSender
	create nibbler transient;

	//	initialize the transient Class Initializer
	nibbler.startedClassInitializer(pClassInitializer);
end;</source>
        <Parameter name="pClassInitializer" type="JSSCTInitializeClassRequest"/>
    </JadeMethod>
</Class>
