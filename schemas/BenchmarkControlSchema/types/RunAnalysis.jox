<Class name="RunAnalysis" id="35e8fcae-5f69-40bc-baba-b594c6df0b33">
    <superclass name="ModelEntity"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Helper functions for analysing benchmark runs.</text>
    <DbClassMap file="Coy"/>
    <PrimAttribute name="resultsFolderName" id="89b2b96b-c491-4c6d-84ec-53be63f4b81a">
        <length>257</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="usePresentationFileSystem" id="e2a5b4ce-b360-43d4-b5b1-7523c9c069fc">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="copyFile" id="0e50e552-ca3e-4efe-8b91-d4f01a41d061">
        <updating/>
        <source>copyFile(f,g:File input; upfs:Boolean; s:String) updating;

begin
	g.fileName:=s;
	g.usePresentationFileSystem:=upfs;
	while not f.endOfFile do
		g.writeBinary(f.readBinary(10000));
	endwhile;
	f.close;
	g.lastModifiedTime:=f.lastModifiedTime;
	g.close;
	//app.logMessage("file created: "&amp;g.fileName);
end;</source>
        <Parameter name="f" type="File" usage="input"/>
        <Parameter name="g" type="File" usage="input"/>
        <Parameter name="upfs" type="Boolean"/>
        <Parameter name="s" type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="c62e9e5d-2fe9-4d35-9b30-84828c2eaaa1">
        <updating/>
        <source>create() updating;

begin
	usePresentationFileSystem:=true;
end;
</source>
    </JadeMethod>
    <JadeMethod name="findStartStop" id="328553e6-fcac-4234-b039-7a71e1eb08f8">
        <updating/>
        <source>findStartStop() updating;

vars
	s,t,folderName,folderMask,startLine,startLines,stopLine,cmdLine:String;
	f,g:File; fn:FileNode; ff:FileFolder;
	mask:Integer;
begin
	folderName:=resultsFolderName;
	//include:="looking for a move to make"; hitsmax:=1;  // jmt start time
	//include:="Stopping profile"; hitsmax:=1;                 // jmt stop time
	//include:="startup finished"; exclude:="Timeout";  // UoC enrolment start time
	//include:="Stopping profile";                              // UoC enrolment stop time
	//include:="Starting profile"; andInclude:="/299/";  // investigator start time
	//include:="Stopping profile"; andInclude:="/0/";  // investigator stop time
	//include:="Starting profile"; andInclude:="/419/";  // tui start time
	//include:="Stopping profile"; andInclude:="/0/";  // tui stop time
	
	create f;
	f.mode:=File.Mode_Input;
	f.maxRecordSize:=32000;
	f.kind:=File.Kind_Unknown_Text;
	create g;
	g.mode:=File.Mode_Output;
	create ff;
	ff.fileName:=folderName;
	ff.usePresentationFileSystem:=usePresentationFileSystem;
	g.fileName:=folderName&amp;"\StartStopTimes.log";
	g.usePresentationFileSystem:=f.usePresentationFileSystem;
	startLines:="User List";
	foreach mask in 1 to 2 do
		if      mask = 1 then ff.mask:="*"&amp;folderName[folderName.length]&amp;"_msg*.log";  // saved by creator
		elseif mask = 2 then ff.mask:="msg*.log";													// on native server
		endif;
		foreach fn in ff.files where fn.isKindOf(File) and fn.fileName&lt;&gt;g.fileName
		and not fn.name.contains("StartStopTimes") and fn.name[1:5]&lt;&gt;"grep_"
		do
			f.fileName:=fn.fileName;
			//f.maxRecordSize:=64*1024;  // kills static file optimisation
			f.usePresentationFileSystem:=ff.usePresentationFileSystem;
			if not f.isAvailable then continue; endif;
			while not f.endOfFile do
				s:=f.readLine&amp;" ";
				if folderName.toLower.contains("cmi") or folderName.toLower.contains("ivg") then
					if s.pos("counts of classes", 1) &lt;&gt; 0 then  // keep last command line
						cmdLine:=s;
					endif;
					if s.pos("Starting profile", 1) &lt;&gt; 0 then  // keep last starting line
						startLine:=s;
						startLines:=startLines&amp;CrLf&amp;s;
					endif;
					if s.pos("Stopping profile", 1) &lt;&gt; 0 and stopLine = null then  // keep first stopping line
						stopLine:=s;
					endif;
				endif;

				if folderName.toLower.contains("mtl") then
					if s.pos("Delaying signon", 1) &lt;&gt; 0 and cmdLine = null then  // keep first command line
						cmdLine:=s;
					endif;
					if s.pos("looking for a move to make", 1) &lt;&gt; 0 and startLine = null then  // first rtg action
						startLine:=s;
					endif;
					if s.pos("Starting profile", 1) &lt;&gt; 0 then  // keep all starting lines for user list
						startLines:=startLines&amp;CrLf&amp;s;
					endif;
					if s.pos("Stopping profile", 1) &lt;&gt; 0 and stopLine = null then  // keep first stopping line
						stopLine:=s;
					endif;
				endif;
			endwhile;
			f.close;
		endforeach;
	endforeach;
	
	g.writeLine("cmd"&amp;Tab&amp;getDateTime(cmdLine));
	g.writeLine("start"&amp;Tab&amp;getDateTime(startLine));
	g.writeLine("stop"&amp;Tab&amp;getDateTime(stopLine));
	g.writeLine(null);
	g.writeLine(cmdLine);
	g.writeLine(startLine);
	g.writeLine(stopLine);
	g.writeLine(null);
	g.writeLine(startLines);
	g.close;
epilog
	delete f;
	delete g;
	delete ff;
end;</source>
    </JadeMethod>
    <JadeMethod name="getDateTime" id="983bade4-ca70-4d24-afab-6642ac40d9bc">
        <updating/>
        <source>getDateTime(s:String):String updating;

vars
	i,j:Integer;
	t,date,time:String;
begin
	t:=s&amp;" none none ";
	i:=1;
	date:=t.scanUntil(" ", i); i:=i+1;
	time:=t.scanUntil(" ", i);
	return date&amp;" "&amp;time;
end;
</source>
        <Parameter name="s" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="splitDumpsProfilers" id="17d3606b-8725-42af-ac97-5a1bc297020d">
        <updating/>
        <source>splitDumpsProfilers() updating;

vars
	s,t,folderName,folderMask,startLine,stopLine,cmdLine:String;
	f,g:File; fn:FileNode; ff,ffDumps,ffProfilers:FileFolder;
	mask:Integer;
begin
	folderName:=resultsFolderName;
	create ff;
	ff.fileName:=folderName;
	ff.usePresentationFileSystem:=usePresentationFileSystem;
	create ffDumps;
	ffDumps.fileName:=folderName&amp;"\"&amp;"dumps";
	ffDumps.usePresentationFileSystem:=usePresentationFileSystem;
	ffDumps.make;
	create ffProfilers;
	ffProfilers.fileName:=folderName&amp;"\"&amp;"profilers";
	ffProfilers.usePresentationFileSystem:=usePresentationFileSystem;
	ffProfilers.make;

	create f;
	f.mode:=File.Mode_Input;
	f.maxRecordSize:=32000;
	f.usePresentationFileSystem:=usePresentationFileSystem;
	f.kind:=File.Kind_Binary;
	create g;
	g.mode:=File.Mode_Output;
	g.usePresentationFileSystem:=usePresentationFileSystem;
	g.kind:=File.Kind_Binary;

	foreach fn in ff.files where fn.isKindOf(File) and fn.fileName&lt;&gt;g.fileName do
		f.fileName:=fn.fileName;
		if fn.name.contains("_profiler_") then
			copyFile(f, g, usePresentationFileSystem, ffProfilers.fileName&amp;"\"&amp;fn.name);
			f.purge;
		elseif fn.name.contains("_cn_dump_") or fn.name.contains("_jtd_") then
			copyFile(f, g, usePresentationFileSystem, ffDumps.fileName&amp;"\"&amp;fn.name);
			f.purge;
		endif;
	endforeach;
epilog
	delete f;
	delete g;
	delete ff;
	delete ffDumps;
	delete ffProfilers;
end;</source>
    </JadeMethod>
    <JadeMethod name="summariseDumps" id="98d2b35a-0e60-402d-b01b-b3d2049be79b">
        <updating/>
        <source>summariseDumps() updating;

vars

begin

end;
</source>
    </JadeMethod>
</Class>
