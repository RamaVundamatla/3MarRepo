31 August 2009	cnwer1	Initial creation

*/

vars
	ta : CM_TerminalArea;
begin
	inheritMethod(_proxy);
	self.label:=_proxy.label;
	
	self.updateAllTerminalAreas(_proxy);
epilog

end;</source>
        <Parameter name="_proxy" type="CM_TerminalAreaGroup"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="a6c46b7d-f632-4737-94df-670243780eef">
        <updating/>
        <source>setProxy(_id 		: String;
		_type		: Integer;
		_terminal 		: CM_Terminal;
		_label,
		_comment : String;
		_allTAs : CM_TerminalAreaArray input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	07 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
19 AUG		CNWER1	 	PAR 17760 Changed parameter was _area now _terminal 
									- use to just set self.myTerminal to _area.myTerminal
*/	
vars

begin
	self.id 			:= _id;
	self.type 			:= _type;
	
	self.myType:=app.myRoot.allTerminalAreaTypes[self.type];
	self.myTerminal 	:= _terminal;
	self.label			:= _label;
	self.comment		:=_comment;


	self.allTAsByTypeId.clear;
	if _allTAs &lt;&gt; null then
		_allTAs.copy(self.allTAsByTypeId);
	endif;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_label" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_allTAs" type="CM_TerminalAreaArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateAllTerminalAreas" id="59f16ba5-e2a7-46a2-8c05-8f202f1d3eb1">
        <updating/>
        <source>updateAllTerminalAreas(_proxy : CM_TerminalAreaGroup ) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 September 2009	cnwer1	Initial creation

*/

vars
	ta : CM_TerminalArea;
begin
	self.allTAsByTypeId.clear;
	foreach ta in _proxy.allTAsByTypeId do
		
		if ta.allTerminalAreaGroups.first  &lt;&gt; null and not ta.allTerminalAreaGroups.first = self then
			ta.allTerminalAreaGroups.first.allTAsByTypeId.remove(ta);
		endif;
		self.allTAsByTypeId.add(ta);
	endforeach;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_TerminalAreaGroup"/>
    </JadeMethod>
