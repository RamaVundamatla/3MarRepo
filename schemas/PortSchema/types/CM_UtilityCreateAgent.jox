        <source>utlCreateTimeSlot(pProxyTimeSlot : CM_TimeSlotEntity input;
				_passport : CM_Passport input;
				pNewTimeSlot : CM_TimeSlotEntity output;
				isStandard : Boolean) updating;

vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valTimeSlot(pProxyTimeSlot, _passport, isStandard);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
		
	app.setContinueCMExceptions(false);

	create pNewTimeSlot as pProxyTimeSlot.class persistent ;
	
	if isStandard then
		pNewTimeSlot.CM_TimeSlotStd.setForCreate(pProxyTimeSlot.CM_TimeSlotStd);
