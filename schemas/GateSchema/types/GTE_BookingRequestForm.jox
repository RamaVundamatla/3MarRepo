    <JadeMethod name="setFieldAlignmentOnTable" id="d3a784d0-34c0-40f1-8772-5e7962ab4403">
        <source>setFieldAlignmentOnTable(_table : CM_DataTable io);
// --------------------------------------------------------------------------------
// Created:		3 September 2009 by cnwjo3, par 20606
//
// Purpose:		Set the alignment for some fields on bookingrefitem table
//
// 04/03/2010	cnwcs5	par 22565
vars
	entRowArray : StringArray;
	entRow : String;
	align : Integer;
	entRowColumn : Integer;
begin
	create entRowArray transient;
	entRowArray.add(ETRow_QuantityTxt);
	entRowArray.add(ETRow_NumOnsiteTIs);
	entRowArray.add(ETRow_Released);
	entRowArray.add(ETRow_MaxToRelease);
	entRowArray.add(ETRow_MyWeight);
	entRowArray.add(ETRow_TempC);
	entRowArray.add(ETRow_TempF);
	entRowArray.add(ETRow_CarbonDioxide);
	entRowArray.add(ETRow_Oxygen);
	entRowArray.add(ETRow_Ventilation);
	entRowArray.add(ETRow_Humidity);
	entRowArray.add(ETRow_Grade);
	entRowArray.add(ETRow_VolumeTotal);	// par 22562
	entRowArray.add(ETRow_MyLength);
	entRowArray.add(ETRow_MyWidth);
	entRowArray.add(ETRow_MyHeight);
	entRowArray.add(ETRow_MyQuantity);
	entRowArray.add(ETRow_MyVolume);
	entRowArray.add(ETRow_MyDensity);
	entRowArray.add(ETRow_Overunder);
	entRowArray.add(ETRow_TotalWeight);
	entRowArray.add(ETRow_NumberPrenoted);
	entRowArray.add(ETRow_ReservedCount);
	
	align := Table.Alignment_Right;
	foreach entRow in entRowArray do
		if _table.getEntRowColumnByRowName(entRow, entRowColumn) &lt;&gt; null then
			_table.accessColumn(entRowColumn).alignment := align;
		endif;
	endforeach;
epilog
	delete entRowArray;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setFormObject" id="308b142c-9d1b-4a16-bb45-4fca93884391">
        <updating/>
