    <JadeMethod name="btnAddKW_click" id="59c88585-9c55-4d7f-a42b-4cb33d67a640">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddKW_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2022	jlier1	Initial creation

*/

vars	
	keyword : String;
begin
	keyword := self.txtKeyword.text;
	if keyword &lt;&gt; null then
		self.lstKeywords.addItem(keyword.trimBlanks);
		self.txtKeyword.text:=null;
		self.txtKeyword.setFocus();
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnRemoveKW_click" id="f0172d5a-c033-41e8-a27f-34d2b577b018">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRemoveKW_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2022	jlier1	Initial creation

*/

vars

begin	
	if self.txtKeyword.text &lt;&gt; null and lstKeywords.listIndex &gt; 0 then
		lstKeywords.removeItem(lstKeywords.listIndex);
		self.lstKeywords.listIndex:=1;
		self.lstKeywords.click(self.lstKeywords);
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnUpdateKW_click" id="d1789bc0-3bec-40bb-a30e-0d4cbd1a06d4">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdateKW_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2022	jlier1	Initial creation

*/

vars

begin
	if self.txtKeyword.text &lt;&gt; null then
		lstKeywords.itemText[lstKeywords.listIndex]:=self.txtKeyword.text;
		self.lstKeywords.listIndex:=1;
		self.lstKeywords.click(self.lstKeywords);
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkNonAlphaRemoved_click" id="181a3b01-00e3-494a-97f6-3f00348919d8">
