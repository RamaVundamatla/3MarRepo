    <JadeMethod name="convertFromEDIFleetTi" id="11a06b7d-cc85-44c7-b530-4c947c7a509c">
        <updating/>
        <source>convertFromEDIFleetTi( _ediFleet : CM_EDIFleetTI; _operator : CM_Operator) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2008	cnwrd1	Initial creation
15/05/2025	navcs2	MTN-34844 Development - Portschema Implementation
*/


vars

	tilcType : CM_TILCType;
	cargoType : CM_CargoType;
begin
	inheritMethod( _ediFleet , _operator );

	self.licenseIssuer := _ediFleet.licenseIssuer;
	self.licenseNumber := _ediFleet.licenseNumber;	
	
	
	cargoType := app.myRoot.allCargoTypesById[self.cargoType];
	
	if cargoType &lt;&gt; null then
		tilcType := cargoType.allTILCTypes[_ediFleet.tILCType];
	endif;

	self.myTILCType := tilcType;

	self.floorType := _ediFleet.floorType;		// 15/05/2025	navcs2	MTN-34844
epilog

end;</source>
        <Parameter name="_ediFleet" type="CM_EDIFleetTI"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypeObject" id="7175e963-f2cc-4b8c-91b2-22c6f5db3c44">
        <source>getCargoTypeObject(): CM_CargoType;
/* ---------------------------------------------------------------------------
Created:	22 January 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if self.myTILCType = null then
		return null;
	else
		return self.myTILCType.myCargoType;
	endif;

end;</source>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="7c2041d7-7763-46f3-9e05-16567532a7c3">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
12 Apr 2007	cnwer1	Initial creation - PAR#xxxx
30 Jun 2008	cnwkpd1	PAR #17210 - Need to handle possible invalid references to non-inversed myInitialLocation
13 Aug 2008 cnwrd1 	ccms 1034 
12 Mar 2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
*/

vars
	/*
	stops 			: ObjectArray;
	toDoTaskDesc 	: ObjectArray;
	damageInstances : ObjectArray;
	*/
	returnVal		: String;
	invalidLoc		: Boolean;
	row, type		: String;			// PAR #31155
	
begin
	if _attrName = ETRow_TiLCType then
		if self.myTILCType &lt;&gt; null then
			return self.myTILCType.code;
		else
			return null;
		endif;
//	elseif _attrName = ETRow_TareWeight then
//		return self.tWeight.String;
	elseif _attrName = ETRow_LicenseNumber then
		return self.licenseNumber;
	elseif _attrName = ETRow_LicenseIssuer then
		return self.licenseIssuer;
		
	elseif _attrName.isMeasurementType then											// PAR #31155
		// _attrName will be formatted as WTRow_&lt;real ent row name&gt;_&lt;weight unit&gt;	// PAR #31155
		_attrName.getRowNameMeasureType(row, type);									// PAR #31155
		return self.getMeasurementStringForAttrib(row, type, _short);				// PAR #31155
	elseif _attrName = ETRow_FloorType then
		return self.getFloorTypeDisplay();
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
