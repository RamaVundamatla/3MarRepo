    <JadeMethod name="addMovement" id="df5018ac-4cd7-41b2-84ad-a49893446fb9">
        <updating/>
        <source>addMovement(_workingMovement: CMIF_HMS_WorkingMovement) updating, protected;

vars

	str 		: String;
	idx			: Integer;

begin

	str :=  _workingMovement.getAttributeStringForDefArray(self.allTblDataEntRows);
	idx := self.addItem(str);
	self.accessRow(idx).itemObject := _workingMovement;
end;</source>
        <access>protected</access>
        <Parameter name="_workingMovement" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="buildBackground" id="78689008-abe6-40a1-8c97-b4961364b8f4">
        <updating/>
        <source>buildBackground() updating;

vars
begin
	if self.columnHeadings.size = 0 then
		self.buildTableArraysNew();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildTableArrays" id="6aa46feb-9bb7-449b-a1d2-4bf2381774c9">
        <updating/>
        <source>buildTableArrays() updating, protected;

vars
	count:		Integer;
begin
 	// This method builds the arrays for the table that specify column headings,
 	// all columns in current view, their ordering and their width

 	// Build Column Headings and Widths Array's  - ColumnHeadings &amp; ColumnWidths
    columnHeadings.clear;
    columnWidths.clear;
    columnHeadings.add("Reference To Movement");
    columnWidths.add(5);
   	columnHeadings.add(app.getErrorString(Move));
    columnWidths.add(55);
    columnHeadings.add(app.getErrorString(MOVEHEAD_Day));
    columnWidths.add(30);
    columnHeadings.add(app.getErrorString(DateStr));
    columnWidths.add(55);
    columnHeadings.add(app.getErrorString(MOVEHEAD_Time));
    columnWidths.add(55);

    // Modified By Russell 11/08/99
    columnHeadings.add(app.getErrorString(Status));
    columnWidths.add(60);

    columnHeadings.add(app.getErrorString(MOVEHEAD_ShipName));
    columnWidths.add(100);
    columnHeadings.add(app.getErrorString(VoyageCode));
    columnWidths.add(100);
    columnHeadings.add(app.getErrorString(MOVEHEAD_VoyageNum));
    columnWidths.add(100);
    columnHeadings.add(app.getErrorString(MOVEHEAD_FromPort));
    columnWidths.add(100);
    columnHeadings.add(app.getErrorString(MOVEHEAD_ToPort));
    columnWidths.add(100);
    columnHeadings.add(app.getErrorString(MOVEHEAD_BerthFrom));
    columnWidths.add(60);
    columnHeadings.add(app.getErrorString(MOVEHEAD_BerthTo));
    columnWidths.add(60);
    columnHeadings.add(app.getErrorString(MOVEHEAD_MarkBow));
    columnWidths.add(60);
    columnHeadings.add(app.getErrorString(MOVEHEAD_MarkStern));
    columnWidths.add(60);
    columnHeadings.add(app.getErrorString(MOVEHEAD_ForeClearTo));
    columnWidths.add(70);
    columnHeadings.add(app.getErrorString(MOVEHEAD_AftClearTo));
    columnWidths.add(70);
    columnHeadings.add(app.getErrorString(MOVEHEAD_Orient));
    columnWidths.add(90);
    columnHeadings.add(app.getErrorString(MOVEHEAD_PilotExempt));
    columnWidths.add(65);
    columnHeadings.add(app.getErrorString(MOVEHEAD_Pilot));
    columnWidths.add(90);
    columnHeadings.add(app.getErrorString(MOVEHEAD_ShipsMaster));
    columnWidths.add(100);
    columnHeadings.add(app.getErrorString(MOVEHEAD_PilotLaunch));
    columnWidths.add(80);
    columnHeadings.add(app.getErrorString(MOVEHEAD_TugsUsed));
    columnWidths.add(120);
    columnHeadings.add(app.getErrorString(MOVEHEAD_LinesCo));
    columnWidths.add(100);
    columnHeadings.add(app.getErrorString(MOVEHEAD_LinesCrewReqd));
    columnWidths.add(80);
    columnHeadings.add(app.getErrorString(MOVEHEAD_LinesTime));
    columnWidths.add(80);
    columnHeadings.add(app.getErrorString(MOVEHEAD_TugsTime));
    columnWidths.add(80);
    columnHeadings.add(app.getErrorString(MOVEHEAD_PLaunchTime));
    columnWidths.add(90);
    columnHeadings.add(app.getErrorString(MOVEHEAD_DfltTideClass));
    columnWidths.add(95);
    columnHeadings.add(app.getErrorString(MOVEHEAD_MoveTideClass));
    columnWidths.add(90);
    columnHeadings.add(app.getErrorString(Resources));
    columnWidths.add(100);
    columnHeadings.add(app.getErrorString(MOVEHEAD_ChargeMove));
    columnWidths.add(80);
    columnHeadings.add(app.getErrorString(MOVEHEAD_Customer));
    columnWidths.add(80);
    columnHeadings.add(app.getErrorString(MOVEHEAD_MainContact));
    columnWidths.add(80);







    // Initilise indexes and Build index for default column order
    count:=1;
    while count&lt;=columnHeadings.size do
    	if count=1 then
    		// hide reference column
    		indexColumnShowByOrigPosn.add(false);
    	else 
    		indexColumnShowByOrigPosn.add(true);	
    	endif;	
    	indexCurrPosnByOrginalRow.add(count);
    	indexOrginalRowByCurrPos.add(count);
    	indexOrginalRowByDefaultPosn.add(count);
    	count:=count+1;
    endwhile;





end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="buildTableArraysNew" id="39484516-c1cf-47dd-ab06-f8284c393a63">
        <updating/>
        <source>buildTableArraysNew() updating, protected;

vars

	def	: EntTableDef;
	row	: EntTableRow;

begin

	def := app.myController.getEntTableDef(ETDef_MovementsTable);
	self.zAddSortColumn(ETRow_HmsMovementDate, false);	
	self.setTblDataEntRowsFromDef(def);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadFullTable" id="006ea3b3-aca6-44f7-990a-e2100d9d735a">
        <updating/>
        <source>loadFullTable(_colour1, _colour2 : Integer) updating;

vars
	workingMovement	: CMIF_HMS_WorkingMovement;
begin
	// This method loads all movements in the current view into the table

	self.readOnly := true;
	self.rows := self.fixedRows;

    if self.currentVoyage = null then
    	if self.showAllVoyages then
  			foreach workingMovement in self.ofViewController.allMovementsInViewByDT do
  				self.addMovement(workingMovement);
  				self.accessMode := self.AccessMode_Row;
  			endforeach;    	
    	endif;

    else
    	// Edit mode 
       	if self.currentVoyage.ofClonedVoyage &lt;&gt; null then
			foreach workingMovement in self.currentVoyage.allClonedMovements do
  				self.addMovement(workingMovement);
  			endforeach;
		else
  			foreach workingMovement in self.ofViewController.allMovementsInViewByDT do
  				self.addMovement(workingMovement);
  				self.accessMode:=self.AccessMode_Row;
  			endforeach;
  		endif;

  	endif;

  	self.paintStripes();

end;</source>
        <Parameter name="_colour1" type="Integer"/>
        <Parameter name="_colour2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="paintStripes" id="8f574d56-f569-46ef-8c1f-c4abb5137b60">
        <updating/>
        <source>paintStripes() updating;
// -------------------------------------------
// Created 18 May 2004 by cnwdvb1
// -------------------------------------------
vars

	count,
	idx,
	tmpColour,
	fixedRow	: Integer;
	obj			: Object;	
	voyage		: CMIF_HMS_WorkingVoyage;
	found		: Boolean;
	
begin

	voyage := self.currentVoyage;
	fixedRow := self.fixedRows + 1;
	foreach idx in  fixedRow to self.rows do
		found := false;
		if self.accessRow(idx).visible then
			obj := self.accessedRow.itemObject;
			if obj &lt;&gt; null and global.isValidObject(obj) then // AKB2002MAY added
				if obj.CMIF_HMS_WorkingMovement.myClonedVoyage &lt;&gt; null then
					if obj.CMIF_HMS_WorkingMovement.myClonedVoyage= voyage then
 		        		self.accessedRow.backColor:=VoyageSelectedSaved;
 		        		found := true;
	 				endif;
 	 			elseif obj.CMIF_HMS_WorkingMovement.myWorkingVoyage = voyage then
		 			self.accessedRow.backColor:=VoyageSelectedSaved;
		 			found := true;
				endif;
			endif;
			if not found then
		  		if count mod 2 = 0 then
		 			tmpColour := self.parent.CM_BaseForm.colorRow1;
		  		else
		 			tmpColour := self.parent.CM_BaseForm.colorRow2;
		  		endif;
				self.accessedRow.backColor := tmpColour;
				count := count + 1;
			endif;
			
		endif;
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setColumnsForView" id="f74adb10-cf13-49ee-81b7-b4362f9a3820">
        <updating/>
        <source>setColumnsForView() updating;

vars
	newPosnInCurrentView:	Integer;
	oldPosnInCurrentView:	Integer;
	originalRowToMove:		Integer;
	count:					Integer;
begin
 	// This method takes the array indexOrginalRowByNewPos and updates 
 	// the order in which the table columns are displayed
return;
 	newPosnInCurrentView:=1;
	while newPosnInCurrentView&lt;=indexOrginalRowByNewPos.size do

		originalRowToMove:=indexOrginalRowByNewPos[newPosnInCurrentView];
 		
 		oldPosnInCurrentView:=indexCurrPosnByOrginalRow[originalRowToMove];
 		
 		// Move column to new position
 		self.moveColumn(oldPosnInCurrentView,newPosnInCurrentView);
 		// Update indexOriginalRowByCurrPos with this change
 		indexOrginalRowByCurrPos.removeAt(oldPosnInCurrentView);
 		indexOrginalRowByCurrPos.insert(newPosnInCurrentView,originalRowToMove);
 		// Update indexCurrPosByOriginalRow with this change
 		count:=1;
 		while count&lt;=indexOrginalRowByCurrPos.size do
 			indexCurrPosnByOrginalRow[indexOrginalRowByCurrPos[count]]:=count;
 			count:=count+1;
 		endwhile;
 		newPosnInCurrentView:=newPosnInCurrentView+1;
 	endwhile;


 	// Set columns to show or hide
 	count:=1;
 	
 	while count&lt;=self.columns do
 		self.columnVisible[count]:=indexColumnShowByOrigPosn[indexOrginalRowByCurrPos[count]];
 		
 		count:=count+1;
 	endwhile;



end;</source>
    </JadeMethod>
    <JadeMethod name="setCurrentVoyage" id="0708c9f4-185d-4ca8-9017-7e83e100983f">
        <updating/>
        <source>setCurrentVoyage(voyage : CMIF_HMS_WorkingVoyage) updating;

vars
 
 	
begin

