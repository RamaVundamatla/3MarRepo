    <JadeMethod name="rel811_par30073" id="c73cc0af-d7c6-4b37-acdb-46d8058748d6">
        <source>rel811_par30073();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/07/2012	cnwdap1	Initial creation PAR #30072 Allow VTMIS and Voyage Commodity Planning licenses
					to access Locale Maintenance, Text Translations and Holidays
*/
vars
	termRole : CM_SecurityRoleTerminalRoot;
	sysRole : CM_SecurityRoleSystemRoot;
	newPerms : IntegerArray;
	menuAgent : CM_MenuAgent;

begin
	app.initialize;
	
	create newPerms transient;
	newPerms.add(PmAdmLocaleMaint);
	newPerms.add(PmAdmLocaleView);
	newPerms.add(PmAdmTranslationMaint);
	newPerms.add(PmAdmTranslationView);
	newPerms.add(PmAdmHolidayMaint);
	newPerms.add(PmAdmHolidayView);
	termRole := CM_SecurityRoleTerminalRoot.firstInstance;
	sysRole := CM_SecurityRoleSystemRoot.firstInstance;
	beginTransaction;
	termRole.setPermissionsFromIntArray(newPerms, false);	//true if terminal permission
	sysRole.setPermissionsFromIntArray(newPerms, true);	//true if system permission
	commitTransaction;

	// ### RESET MENUS
	beginTransaction;
	app.myRoot.resetRootSecurityRoles(null);
	commitTransaction;
	create menuAgent transient;
	menuAgent.resetAllMenuDetails();
	
epilog
	delete newPerms;
	delete menuAgent;
end;</source>
    </JadeMethod>
