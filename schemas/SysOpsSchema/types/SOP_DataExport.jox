    <JadeMethod name="getOIDFormat" id="d948dfe8-b2d0-4b5a-993b-b99006d6ef45">
        <source>getOIDFormat():Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2010	#cnwdz2	 24641

*/

vars
	oidFormatStr : String;
begin
	oidFormatStr := self.tblExtractDef.getValueByName(ETRow_OidFormat).String;
	if oidFormatStr = global.getOIDFormatDescr(CM_DataDumpExtractDef.OIDFormatHex) then
		return CM_DataDumpExtractDef.OIDFormatHex;
	endif;
	
	if oidFormatStr = global.getOIDFormatDescr(CM_DataDumpExtractDef.OIDFormatString) then
		return CM_DataDumpExtractDef.OIDFormatString;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getProxyObject" id="42b55c97-1ddb-4ff0-86fb-c74bb7cb2abd">
        <updating/>
        <source>getProxyObject() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		07 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	if self.myProxyObject = null then
		if self.mode = Mode_Add or  
		   cmbExtractFormat.text = global.getExtractFormatDescr(CM_DataDumpExtractDef.FmtSQLNative) then //30/04/2010 cnwdz2 
			create self.myProxyObject as CM_DataDumpExtractDef transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	return true;	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleDupDefForLoad" id="e8d877b3-9bd3-4e9c-8e1f-406708b1936d">
        <updating/>
        <source>handleDupDefForLoad(_definition:CM_DataDumpExtractDef input):CM_DataDumpExtractDef protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2010	#cnwdz2	 
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars
	loadDefInfoForm  : SOP_SQLNativeLoadDefInfoForm;
	newDefName       : String;
	proxyDef,
	realDefinition      : CM_DataDumpExtractDef;
	createNewDef     : Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	createNewDef := true;
	realDefinition := app.myRoot.allDataDumpExtractDefs[_definition.description];
	if realDefinition &lt;&gt; null then
		loadDefInfoForm := app.loadForm(SOP_SQLNativeLoadDefInfoForm, 
										CMUI_Assistant, 
										false, 
										false,
										false, 
										self.myTerminal,
										self.myMasterMenuAction).SOP_SQLNativeLoadDefInfoForm;	
		if loadDefInfoForm = null then
			return null;
		endif;
		loadDefInfoForm.currentDefname := _definition.description;
		loadDefInfoForm.maxDefNameLength := realDefinition.description.maxLength;
		loadDefInfoForm.showModal();
	
		if loadDefInfoForm.modalResult = IDCANCEL or
			loadDefInfoForm.modalDialogReturnValue = IDCANCEL then 		
			return null;
		endif;
		self.myCurrentObject := realDefinition;
		self.createProxiesForEdit();
		proxyDef := self.myProxyObject.CM_DataDumpExtractDef;		
		newDefName := loadDefInfoForm.currentDefname;
		if newDefName &lt;&gt; null and newDefName &lt;&gt; _definition.description then
			_definition.setDescription(newDefName);
		else
			createNewDef := false;
			proxyDef.allDataDumpExtractClasses.clear();
			
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxUA.trxUpdateDataDumpExtractDef(proxyDef, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog( "Update Data Export Definition", app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				break;
				
			endwhile;
	
			
		endif;
	endif;
	
	if createNewDef then
	
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxCA.trxCreateDataDumpExtractDef(_definition, realDefinition, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Extract Definition',app.myPassport, ErrWarnMode_AddUpdate);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
		
		if realDefinition &lt;&gt; null then
			self.myCurrentObject := realDefinition;
		endif;
	endif;
	
	return realDefinition;
epilog
	self.clearErrorWarnings();
end;</source>
        <access>protected</access>
        <Parameter name="_definition" type="CM_DataDumpExtractDef" usage="input"/>
        <ReturnType type="CM_DataDumpExtractDef"/>
    </JadeMethod>
