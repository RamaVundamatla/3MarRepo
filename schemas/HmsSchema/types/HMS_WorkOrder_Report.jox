        <type name="TimeStamp"/>
    </PrimAttribute>
    <JadeMethod name="getTidesForDay" id="19329ae3-4b33-4db0-9a7f-3cedbb0cdc3d">
        <updating/>
        <source>getTidesForDay(dateForTides:TimeStamp; tide1: String io; tide2: String io; tide3: String io; tide4: String io; draftChkPoint: HMS_CheckPoint io) updating;

vars
	highLow: 		Integer;
	timeOfTide:		TimeStamp;
	timeToTest:		TimeStamp;
	t1:				TimeStamp;
	t2:				TimeStamp;
	t3:				TimeStamp;
	t4:				TimeStamp;
	t1_HL_State:	Integer;
	t2_HL_State:	Integer;
	t3_HL_State:	Integer;
	t4_HL_State:	Integer;
	timeStep:		Time;
	lastTideAt:		TimeStamp;
	numTidesFound:	Integer;
	tideTolerance:	Time;
begin
	// This method returns 4 strings describing the tides on the given day 

	// Get tides
//	timeToTest:=(dateForTides.Date.String &amp; ", 00:00:00".String).TimeStamp;
	timeToTest.setDate(dateForTides.date);
	timeToTest.setTime(null);
	
	numTidesFound:=0;

	// Set tide tolerance to 1hr - ie if the next tide found is not at least 1hr different from the last 
	// tide found, then it is considered to be the same tide.
	tideTolerance:="01:00:00".Time;	

	// Set time test step to 3hrs
	timeStep:="03:00:00".Time;

	while timeToTest.Date=dateForTides.Date do
		app.myHMSRvTide.getNearestHighLowTide(draftChkPoint,timeToTest,timeOfTide,highLow);
 		if timeOfTide.Date=dateForTides.Date then
 			// Tide is on the correct day, check to see if tide has already been found  	
 			if numTidesFound=0 then
 				// This is the first tide of the day
 				t1:=timeOfTide;
 				t1_HL_State:=highLow;
 				numTidesFound:=1;
 				lastTideAt:=t1;
 			else
 				// Check that the new tide that has been found is not the same as the last tide found
 				if timeOfTide&gt;(lastTideAt+timeStep) or timeOfTide&lt;(lastTideAt-timeStep) then
 					// Tide is different
 					if numTidesFound=1 then
 						// The tide we have found is the 2nd tide of the day
 						t2:=timeOfTide;
 						t2_HL_State:=highLow;
 						lastTideAt:=t2;
 					elseif numTidesFound=2 then
 						// The tide we have found is the 3rd tide of the day
 						t3:=timeOfTide;
 						t3_HL_State:=highLow;
 						lastTideAt:=t3;
 					else
 						// The tide we have found is the 4th tide of the day
 						t4:=timeOfTide;
 						t4_HL_State:=highLow;
 						lastTideAt:=t4;
 					endif;
 					numTidesFound:=numTidesFound+1;
 				else
 					// Same tide
 				endif;
 			endif;
 		else
 			// Tide is on wrong day
 		endif;
 		timeToTest:=timeToTest+timeStep;
 	endwhile;

 	// Generate return strings
 	// 1st tide of the day
 	if t1_HL_State=TideHigh then
 		tide1:=t1.Time.userFormat($CM_HMS_Time24Hour) &amp; " H";
 	else		
    	tide1:=t1.Time.userFormat($CM_HMS_Time24Hour) &amp; " L";
    endif;

    // 2nd tide of the day
 	if t2_HL_State=TideHigh then
 		tide2:=t2.Time.userFormat($CM_HMS_Time24Hour) &amp; " H";
 	else		
    	tide2:=t2.Time.userFormat($CM_HMS_Time24Hour) &amp; " L";
    endif;

    // 3rd tide of the day
 	if t3_HL_State=TideHigh then
 		tide3:=t3.Time.userFormat($CM_HMS_Time24Hour) &amp; " H";
 	else		
    	tide3:=t3.Time.userFormat($CM_HMS_Time24Hour) &amp; " L";
    endif;

    // 4th tide of the day
 	if t4_HL_State=TideHigh then
 		tide4:=t4.Time.userFormat($CM_HMS_Time24Hour) &amp; " H";
 	else		
    	tide4:=t4.Time.userFormat($CM_HMS_Time24Hour) &amp; " L";
    endif;

end;</source>
        <Parameter name="dateForTides" type="TimeStamp"/>
        <Parameter name="tide1" type="String" usage="io"/>
        <Parameter name="tide2" type="String" usage="io"/>
        <Parameter name="tide3" type="String" usage="io"/>
        <Parameter name="tide4" type="String" usage="io"/>
        <Parameter name="draftChkPoint" type="HMS_CheckPoint" usage="io"/>
    </JadeMethod>
    <JadeMethod name="initialReportSetup" id="d785adad-6a1d-46d0-b3df-5ea1c9e58a7a">
        <updating/>
        <source>initialReportSetup() updating;

vars
	date : TimeStamp;
	usr  : String;
begin
	inheritMethod();

	if app.getMyUser &lt;&gt; null then
		usr := app.getMyUser.userName;
	else
		usr := '** User Not Defined **';
	endif;		

	lblReportTitle.caption 	:= 'WORK ORDERS REPORT';
	txtUserCode.text		:= usr;
	txtReportDate.text 		:= date.date.shortFormatJMT() &amp; ", " &amp; date.Time.userFormat($CM_HMS_Time24Hour);

	// Modified by Russell 05/05/99
	// --------------------------------------------------
	txtUserCode.visible:=false;
	txtReportDate.visible:=false;
	// --------------------------------------------------

	txtFooterLeft.text 		:= 'Work Orders Report';
	txtHeaderLeft.text 		:= 'Work Orders Report';
	txtHeaderRight.text 	:= 'Printed by: ' &amp; usr;
	app.printer.setHeader(fHeader);
	app.printer.setFooter(fFooter);

	tableHeader.accessMode  := Table.AccessMode_Row;
	tableHeader.rowHeight[1]:= 34;
	tableHeader.gridLines	:= false;
	tableBody.borderStyle 	:= Table.BorderStyle_None;
	tableBody.gridLines		:= false;
	picTGAIcon.picture := app.getPicLogoPort();	
    picTitleLogo.picture	:= picTGAIcon.picture;

end;</source>
    </JadeMethod>
    <JadeMethod name="printBerthMetersReport" id="db5ef303-bd9f-4f4e-9e64-cff1fe922e57">
        <updating/>
        <source>printBerthMetersReport() updating, protected;

/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
17 Jun 2014	cnwdap1	PAR #34422 Remoev beginLock / endLock
*/

vars
	iter 	: Iterator;
	harbour	: HMS_Harbour;
	voyage  : CM_Voyage;
	voyageData	: HMS_VoyageData;
	mov,movPrev: HMS_VoyageMovement;
	str,sDate,sName,sMoveType,sBerthFrom,sBerthTo,sAgent,sLOA,sSB,sBow,sBridge,sStern,sFwd,sAft : String;
	int		: Integer;
	date	: TimeStamp;
begin
	app.printer.print(fBlank);
	app.printer.print(fTableHeader);
	txtHeading.text := headText;
	app.printer.print(fHeading);	
	int := 1;

	harbour := app.getMyTerminalDO_NOT_USE.myHarbour;
	iter := harbour.allVoyageMovements.createIterator;
	harbour.allVoyageMovements.startKeyGeq(portDate_From, iter);
	while iter.next(mov) do
		//beginLock;		// PAR #34422
		if mov.occursOnDTNEW &lt;= portDate_To then
			date		:= mov.occursOnDTNEW;
			voyage 		:= mov.myHMSVoyageData.myVoyage;
			voyageData	:= mov.myHMSVoyageData;
			sDate 		:= date.date.format('dd/MM') &amp; "- " &amp; date.Time.userFormat($CM_HMS_Time24Hour);
			sName 		:= voyage.vesselName;
			sMoveType 	:= mov.moveType;

			voyage := mov.myHMSVoyageData.myVoyage;
			if mov.moveType=HMSMovementTypeArrival then
				if harbour.defaultDepartBerth &lt;&gt; null then
					sBerthFrom	:= harbour.defaultDepartBerth.description;
				else
					sBerthFrom := null;
				endif;
			else
				movPrev:= voyage.myHMSVoyageData.allVoyageMovements.getAtKeyLss(date).HMS_VoyageMovement;			
				if movPrev &lt;&gt; null then
					sBerthFrom:= movPrev.getMyBerth.description;
				endif;	
			endif;	
			if mov.moveType=HMSMovementTypeDeparture then
				if harbour.defaultDepartBerth &lt;&gt; null then
					sBerthTo := harbour.defaultDepartBerth.description;
				else
					sBerthTo := null;
				endif;
			else
				sBerthTo	:= mov.getMyBerth.description;
			endif;


			// Set agent for movement
			if mov.isAgentDefault=true then
				// Agent is default customer for this movement
				if mov.myShippingAgent&lt;&gt;null then
					sAgent:=mov.myShippingAgent.description;
				else
					sAgent:=app.getErrorString(NoneSelected);
				endif;
			else
				// ShippingLine is default customer for this movement
				if mov.myHMSVoyageData.myVoyage.myShippingLine &lt;&gt; null then
					sAgent:=mov.myHMSVoyageData.myVoyage.myShippingLine.description;
				else
					sAgent:=app.getErrorString(NoneSelected);
				endif;
			endif;

			sLOA		:= voyageData.dim_LengthOverall.String;

			sBow	:= mov.bowMarkTo.String;
			sStern	:= mov.sternMarkTo.String;
			if mov.bowMarkTo&gt;mov.sternMarkTo then
				sBridge	:= (mov.bowMarkTo - voyageData.dist_BridgeToBow).String;
			else	
				sBridge	:= (mov.bowMarkTo + voyageData.dist_BridgeToBow).String;
			endif;

			if voyageData.dist_BridgeToBow&lt;1 then
            	sSB:=app.getErrorString(StemToBridgeDistReq);
            	sBridge:="-";
			else
				sSB	:=  voyageData.dist_BridgeToBow.String;
			endif;




			if mov.foreClearanceTo = ClearanceUnbounded then
				sFwd	:= app.getErrorString(Unlimited);
			else	
		    	sFwd	:= mov.foreClearanceTo.String;
		    endif;	
	 		if mov.aftClearanceTo = ClearanceUnbounded then
	 			sAft	:= app.getErrorString(Unlimited);
	 		else
	 			sAft	:= mov.aftClearanceTo.String;	
	 		endif;

	 		if mov.isLogicalBerth() then
				// Moving to logical berth - marks are not applicable
				sBow:="-";
				sBridge:="-";
				sStern:="-";
				sFwd:="-";
				sAft:="-";

			endif;

			// print the line
			str := sDate &amp; Tab &amp; sName &amp; Tab &amp; sMoveType &amp; Tab &amp; sBerthFrom &amp; Tab &amp; sBerthTo &amp; Tab &amp; sAgent;
			str := str &amp; Tab &amp; sLOA &amp; Tab &amp; sSB &amp; Tab &amp; sBow &amp; Tab &amp; sBridge &amp; Tab &amp; sStern &amp; Tab &amp; sFwd &amp; Tab &amp; sAft;
			doPrinting(str,int);

			// reset variables
			str 		:= null;
			sDate		:= null;
			sName		:= null;
			sMoveType	:= null;
			sBerthFrom	:= null;
			sBerthTo	:= null;
			sAgent		:= null;
			sLOA		:= null;
			sSB			:= null;
			sBow		:= null;
			sBridge		:= null;
			sStern		:= null;
			sFwd		:= null;
			sAft		:= null;
		else
			break;
		endif;
		//endLock;		// PAR #34422
	endwhile;
epilog
	//endLock;			// PAR #34422
	delete iter;		// PAR #26678
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="printWorkOrdersReport" id="e9514898-e43a-4d75-a9fb-a5a0cfed87f3">
        <updating/>
        <source>printWorkOrdersReport() updating, protected;

/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
17 Jun 2014	cnwdap1	PAR #34422 Remove beginLock / endLock
*/

vars
	iter: 			Iterator;
	harbour: 		HMS_Harbour;
	voyage: 		CM_Voyage;
	mov,movePrev: 	HMS_VoyageMovement;
	str,sDate,sName,sMoveType,sBerthFrom,sBerthTo,sLineTime,sPilotLaunch,sTugTime,sTugs,sTide,sOrientation,sBunkers : String;
	int: 			Integer;
	date:		 	TimeStamp;
	date2: 			TimeStamp;
	timeOfTide:		TimeStamp;
	highLow:		Integer;
	region: 		HMS_HarbourRegion;
	regionForTide: 	HMS_HarbourRegion;
	chkPoint:		HMS_CheckPoint;
	draftChkPoint:	HMS_CheckPoint;
	tug:			HMS_Tug;
	offsetTime:		Time;
	orderTime:		Time;
	fromToLogical:	Boolean;
	bunkersReqd:	Boolean;
	permResUsed:	HMS_ResourceUsed;
	tide1:			String;
	tide2:			String;
	tide3:			String;
	tide4:			String;
	nextDay:		TimeStamp;


begin
	app.printer.print(fBlank);
	app.printer.print(fTableHeader);
	txtHeading.text := headText;
	app.printer.print(fHeading);	
	int := 1;
	harbour := app.getMyTerminalDO_NOT_USE.myHarbour;
	// Setup parameters for calculating closest high or low tide
	// --------------------------------------------------------------------------------
	// NOTE: uses the first harbour region with a draft checkpoint
	foreach region in harbour.allRegions do
		draftChkPoint:=region.myHeightCheckpoint;
		/* th2 - note this code still sucks - should it break once found? can be null? etc.
		if region.allCheckpoints.size&gt;0 then
			foreach chkPoint in region.allCheckpoints do
				if chkPoint.getTidalDataType() = HMS_TidalDataType_Height then
					draftChkPoint:=chkPoint;
				endif;
			endforeach;
		endif;
		*/
	endforeach;


	// Modified by Russell 05/05/99
	// --------------------------------------
	// Get tides for first day of report
	self.getTidesForDay(portDate_From,tide1,tide2,tide3,tide4,draftChkPoint);
	
//	nextDay:=((((portDate_From.Date).Date)+1).Date.String &amp; ", " &amp; portDate_From.Time.String).TimeStamp;
	nextDay.setDate(portDate_From.date + 1);
	nextDay.setTime(portDate_From.Time);
	
	
	
	getTidesForDay(nextDay,tide1,tide2,tide3,tide4,draftChkPoint);
	

	iter := harbour.allVoyageMovements.createIterator;
	harbour.allVoyageMovements.startKeyGeq(portDate_From, iter);
	while iter.next(mov) do
		//beginLock;			// PAR #34422
		if mov.archived then
			continue;
		endif;
		if mov.occursOnDTNEW &lt;= portDate_To then
			date		:= mov.occursOnDTNEW;
			sDate 		:= date.Date.format('dd/MM') &amp; "- " &amp; date.Time.userFormat($CM_HMS_Time24Hour);
			voyage 		:= mov.myHMSVoyageData.myVoyage;

			sName 		:= voyage.vesselName;
			sMoveType 	:= mov.moveType;
			// Reset fromToLogical
			fromToLogical:=false;

			movePrev:=null;
			if mov.moveType=HMSMovementTypeArrival then
				if harbour.defaultDepartBerth &lt;&gt; null then
					sBerthFrom	:= harbour.defaultDepartBerth.description;
				else
					sBerthFrom := null;
				endif;
				if mov.isLogicalBerth() then
					fromToLogical:=true;
				endif;
			else
				movePrev:= voyage.myHMSVoyageData.allVoyageMovements.getAtKeyLss(date).HMS_VoyageMovement;			
				if movePrev &lt;&gt; null then
					sBerthFrom:= movePrev.getMyBerth.description;
					if mov.isLogicalBerth() and movePrev.isLogicalBerth() then
						fromToLogical:=true;		
					endif;
				endif;	
			endif;	
			if mov.moveType=HMSMovementTypeDeparture then
				if harbour.defaultDepartBerth &lt;&gt; null then
					sBerthTo	:= harbour.defaultDepartBerth.description;
				else
					sBerthTo := null;
				endif;

				movePrev:= voyage.myHMSVoyageData.allVoyageMovements.getAtKeyLss(date).HMS_VoyageMovement;			
				if movePrev &lt;&gt; null then
					if  movePrev.isLogicalBerth() then
						fromToLogical:=true;
					endif;
				endif;	
			else
				sBerthTo	:= mov.getMyBerth.description;
			endif;

			// -------------------------------------------------------------------------------------------
			// Set lines time 
 			if mov.relativeOrderTimeLines&lt;0 then
 				offsetTime.setTime(0,((mov.relativeOrderTimeLines)*-1),0,0);
 				orderTime:=(mov.occursOnDTNEW-offsetTime).Time;
 			else
 				offsetTime.setTime(0,(mov.relativeOrderTimeLines),0,0);
 				orderTime:=(mov.occursOnDTNEW+offsetTime).Time;
 			endif;
 			sLineTime:=orderTime.Time.userFormat($CM_HMS_Time24Hour);

 			// Set tugs time
 			if mov.relativeOrderTimeTugs&lt;0 then
 				offsetTime.setTime(0,((mov.relativeOrderTimeTugs)*-1),0,0);
 				orderTime:=(mov.occursOnDTNEW-offsetTime).Time;
 			else
 				offsetTime.setTime(0,(mov.relativeOrderTimeTugs),0,0);
 				orderTime:=(mov.occursOnDTNEW+offsetTime).Time;
 			endif;
 			if mov.locationTug=AlongSide then
 				sTugTime:="(A)  " &amp; orderTime.Time.userFormat($CM_HMS_Time24Hour);
 			else
 				sTugTime:="(O)  " &amp; orderTime.Time.userFormat($CM_HMS_Time24Hour);
 			endif;

 			// Set pilot launch time 
 			// Modified by Russell 07/04/99
 			// ---------------------------------------------------------------------------------------------
 			if mov.pilotExempt=false then
 				// Check to see whether vessel is moving between physical whaves - if so, launch not required
 				if mov.moveType=HMSMovementTypeShift then
 					if mov&lt;&gt;null and movePrev&lt;&gt;null then
 						if mov.isLogicalBerth() or movePrev.isLogicalBerth() then
 							if mov.relativeOrderTimePlaunch&lt;0 then
 								offsetTime.setTime(0,((mov.relativeOrderTimePlaunch)*-1),0,0);
 								orderTime:=(mov.occursOnDTNEW-offsetTime).Time;
 							else
 								offsetTime.setTime(0,(mov.relativeOrderTimePlaunch),0,0);
 								orderTime:=(mov.occursOnDTNEW+offsetTime).Time;
 							endif;
 							if mov.locationPilotLaunch=AlongSide then
 								sPilotLaunch:="(A)  " &amp; orderTime.Time.userFormat($CM_HMS_Time24Hour);
 							else
 								sPilotLaunch:="(O)  " &amp; orderTime.Time.userFormat($CM_HMS_Time24Hour);
 							endif;
 						else
 							sPilotLaunch:=app.getErrorString(NotRequired);
 						endif;
 					else
 						sPilotLaunch:=app.getErrorString(NotRequired);
 					endif;
   				else
   					if mov.relativeOrderTimePlaunch&lt;0 then
 						offsetTime.setTime(0,((mov.relativeOrderTimePlaunch)*-1),0,0);
 						orderTime:=(mov.occursOnDTNEW-offsetTime).Time;
 					else
 						offsetTime.setTime(0,(mov.relativeOrderTimePlaunch),0,0);
 						orderTime:=(mov.occursOnDTNEW+offsetTime).Time;
 					endif;
 					if mov.locationPilotLaunch=AlongSide then
 						sPilotLaunch:="(A)  " &amp; orderTime.Time.userFormat($CM_HMS_Time24Hour);
 					else
 						sPilotLaunch:="(O)  " &amp; orderTime.Time.userFormat($CM_HMS_Time24Hour);
 					endif;
 				endif;
   			else
    			sPilotLaunch:=app.getErrorString(NotRequired);
   			endif;
   			// ---------------------------------------------------------------------------------------------

   			if fromToLogical=true then 
   				sLineTime:=app.getErrorString(NotRequired);	
   				sTugTime:=app.getErrorString(NotRequired);	
   				sPilotLaunch:=app.getErrorString(NotRequired);	
   			endif;

			// -------------------------------------------------------------------------------------------


            // Set tugs used
 			foreach tug in mov.allTugsUsed do
 				sTugs:=sTugs &amp; tug.description &amp; ", ";
 			endforeach;
 			if mov.allTugsUsed.size&gt;0 then
 				// trim last comma
				sTugs:=sTugs.String[1:((sTugs.length)-2)];
			endif;



			// Get closet high or low tide
			// ------------------------------------------------------------------------------
			app.myHMSRvTide.getNearestHighLowTide(draftChkPoint,mov.occursOnDTNEW,timeOfTide,highLow);
		
 			if highLow=TideHigh then
 				sTide:= "H " &amp; timeOfTide.Time.userFormat($CM_HMS_Time24Hour);
 			else
 				sTide:= "L " &amp; timeOfTide.Time.userFormat($CM_HMS_Time24Hour);
 			endif;
			// ------------------------------------------------------------------------------

			/*if mov.sideTo = OrientPortSideTo then
				sOrientation := 'PST';
			else
				sOrientation := 'SST';
			endif;*/
			sOrientation := app.sideToNumToString(mov.sideTo);

			// Set bunkers required status		
			foreach permResUsed in mov.allResourceUsed do
				if permResUsed.myResource &lt;&gt; null then
					if permResUsed.myResource.myResourceType=harbour.ofBunkersGroup then
						sBunkers:=app.getErrorString(Required);
					endif;
				endif;
			endforeach;

			// print the line
			str := sDate &amp; Tab &amp; sName &amp; Tab &amp; sMoveType &amp; Tab &amp; sBerthFrom &amp; Tab &amp; sBerthTo &amp; Tab &amp; sLineTime;
			str := str &amp; Tab &amp; sPilotLaunch &amp; Tab &amp; sTugTime &amp; Tab &amp; sTugs &amp; Tab &amp; sTide &amp; Tab &amp; sOrientation &amp; Tab &amp; sBunkers;
			doPrinting(str,int);

			// reset variables
			str 			:= null;
			sDate			:= null;
			sName			:= null;
			sMoveType		:= null;
			sBerthFrom		:= null;
			sBerthTo		:= null;
			sLineTime		:= null;
			sPilotLaunch	:= null;
			sTugTime		:= null;
			sTugs			:= null;
			sTide			:= null;
			sOrientation	:= null;
			sBunkers		:= null;
		else
			break;
		endif;
		//endLock;			// PAR #34422
	endwhile;

epilog
	//endLock;				// PAR #34422
	delete iter;		// PAR #26678
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="processReport" id="8c0670b4-0d91-4cfe-ab08-3a395d51d251">
        <updating/>
        <source>processReport() updating;

vars
	pxyJadeReport	: JadeReport;
	
begin
	// this method drives the report
	inheritMethod();

	create pxyJadeReport transient;	
	app.printer.printPreview := false;
	app.printer.setReport( pxyJadeReport );	

	// setup the report headings etc
	initialReportSetup();

	// print the initial report header and attributes strips
	app.printer.print(fTitle);
	app.printer.print(fTitleSep);

	// print the report
	if portDate_From &lt;&gt; null then
		setupWorkOrdersReport();
		if portDate_From &lt;&gt; null then
			headText := 'Work Orders for the period ' &amp; portDate_From.date.shortFormatJMT() &amp; ' - ' &amp; portDate_To.date.shortFormatJMT();
			printWorkOrdersReport();
		endif;
		setupBerthMetersReport();
		headText := 'Berthage Marks for the period ' &amp; portDate_From.date.shortFormatJMT() &amp; ' - ' &amp; portDate_To.date.shortFormatJMT();
		printBerthMetersReport();
	endif;	
	fTitleSep.width := fTableHeader.width;
	app.printer.print(fTitleSep);

	app.printer.close;
	app.printPreview( pxyJadeReport, true);
	
epilog
	app.printer.close();		
end;</source>
    </JadeMethod>
    <JadeMethod name="setupBerthMetersReport" id="1e20415f-1b5f-49a1-a49c-36b989357dea">
        <updating/>
        <source>setupBerthMetersReport() updating;

vars
	columnWidths : IntegerArray;
	columnText	 : StringArray;
	int			 : Integer;
begin

	create columnWidths transient;
	create columnText	transient;

	columnWidths[01] := 85;
	columnWidths[02] := 140;
	columnWidths[03] := 80;
	columnWidths[04] := 70;
	columnWidths[05] := 70;
	columnWidths[06] := 150;
	columnWidths[07] := 55;
	columnWidths[08] := 65;
	columnWidths[09] := 55;
	columnWidths[10] := 55;
	columnWidths[11] := 55;
	columnWidths[12] := 65;
	columnWidths[13] := 65;

	columnText[01]   := 'DATE';
	columnText[02]   := 'VESSEL NAME';
	columnText[03]   := 'MOVEMENT';
	columnText[04]   := 'FROM';
	columnText[05]   := 'TO';
	columnText[06]   := 'AGENT';
	columnText[07]   := "LOA";
	columnText[08]   := 'S/B';
	columnText[09]   := 'BOW';
	columnText[10]   := 'BRIDGE';
	columnText[11]   := 'STERN';
	columnText[12]   := 'FWD';
	columnText[13]	 := 'AFT';



	// setup the header table
	setReportTables(tableHeader,columnWidths,columnText);

	// setup the body table
	columnText.clear;
	columnText[columnWidths.size] := null;
	setReportTables(tableBody,columnWidths,columnText);

	// Modified by Russell 12/04/99
	// ---------------------------------------------------------------------------------
	tableBody.accessMode:=tableBody.AccessMode_Column;
	// Set 'LOA' column to Bold
	tableBody.column:=07;
	tableBody.fontBold:=true;
	// Set 'S/B' column to Bold
	tableBody.column:=08;
	tableBody.fontBold:=true;
	// Set 'Bow' column to Bold
	tableBody.column:=09;
	tableBody.fontBold:=true;
	// Set 'Bridge' column to Bold
	tableBody.column:=10;
	tableBody.fontBold:=true;
	// Set 'Stern' column to Bold
	tableBody.column:=11;
	tableBody.fontBold:=true;
	// Set 'Fwd' column to Bold
	tableBody.column:=12;
	tableBody.fontBold:=true;
	// Set 'Aft' column to Bold
	tableBody.column:=13;
	tableBody.fontBold:=true;
	tableBody.accessMode:=tableBody.AccessMode_Cell;
	// ---------------------------------------------------------------------------------
epilog
	delete columnWidths;
	delete columnText;
end;</source>
    </JadeMethod>
