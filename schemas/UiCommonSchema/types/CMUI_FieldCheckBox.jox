<GUIClass name="CMUI_FieldCheckBox" id="abbe7e1a-eecf-4243-abcc-7d4fc1139464">
    <superclass name="CMUI_FieldFrame"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="_usergui"/>
    <ExplicitInverseRef name="myCheckBox" id="a19abdbb-7fb9-40b0-9486-fa9d07c943b6">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CMUI_FieldCheckBoxControl"/>
        <access>protected</access>
        <Inverse name="CMUI_FieldCheckBoxControl::myFieldFrame"/>
