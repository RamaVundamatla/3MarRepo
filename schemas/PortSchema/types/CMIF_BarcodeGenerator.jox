<Class name="CMIF_BarcodeGenerator" id="1881a785-fb89-462e-9560-30a03da1b26b">
    <superclass name="CMIF_DotNetWrap"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="myBarcodeGenerator" id="e5dd3b00-a975-469e-80d3-a3b513e58e6f">
        <embedded/>
        <type name="JMTBarcodeGenerator"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="48595980-45ad-4b88-b473-db4d7ad345c2">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Oct 2015	cnwkpd1	GPHA Cash Receipt print

*/

vars
	hadException	: Boolean;
	fileName		: String;
	iniValue		: String;
	usePresentation	: Boolean;
	
begin
	on Exception do self.handleExceptions(exception, hadException);
	
	create self.myBarcodeGenerator transient;
	if self.myBarcodeGenerator &lt;&gt; null then
		self.myBarcodeGenerator.usePresentationClient := self.usePresentationClient;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="1b27665a-b0aa-44d0-adbe-c6b44540b853">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
