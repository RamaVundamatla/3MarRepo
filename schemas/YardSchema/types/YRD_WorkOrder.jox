    <JadeMethod name="loadTabVoyageTimeChange" id="24c58910-558f-47c3-ab80-d00362ba8c57">
        <updating/>
        <source>loadTabVoyageTimeChange() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 April 2022	navhl20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	workOrder : CM_WorkOrder;
begin
	if self.myPxyTask = null then
		return;
	endif;
	self.shtTimeChange.visible	:= true;
	self.fldVoyage.topSheet  	:= self.shtTimeChange;
	
	self.myAssistant.comboBoxVoyageWorkOrders(self.cmbWorkOrder, self.myVoyage, workOrder, null);
	self.cmbWorkOrder.listIndex := self.cmbWorkOrder.findObject(myPxyTask.CM_WodTimeChange.myWorkOrderToUpdate);
	if self.myPxyTask &lt;&gt; null and self.myPxyTask.myParent &lt;&gt; null then
		workOrder := self.myPxyTask.myParent;
		if not workOrder.hasBeenApproved then
			workOrder := null;
		endif;
	endif;
	self.cmbWorkOrder.listIndex := self.cmbWorkOrder.findObject(myPxyTask.CM_WodTimeChange.myWorkOrderToUpdate);
	
	buildCmbTimeChange();
