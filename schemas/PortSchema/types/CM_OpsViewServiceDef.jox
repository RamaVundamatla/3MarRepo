    <JadeMethod name="setForUpdate" id="14b945e3-258d-4727-9ce2-fdf9e5139eba">
        <updating/>
        <source>setForUpdate(_extWebService: CM_ExternalWebServiceDef) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1  ChangeRequest 49906: MTN - Ops View External Webservice
*/

vars
	terms : CM_TerminalSet;
	term : CM_Terminal;
	failedDAC  :CM_DataAccessController;
begin
	inheritMethod(_extWebService);

// NOT USED	self.isVesselData	:= _extWebService.CM_OpsViewServiceDef.isVesselData;
	self.mandatorySnapshot := _extWebService.CM_OpsViewServiceDef.mandatorySnapshot; // ### TFS 50669 06AUG2021 NAVAB1
	self.baseEndpointAPI := _extWebService.baseEndpointAPI;		//navra1 - 50529 - 22nd Sep 2021 - Create a new global constant for baseEndpointAPI
//	self.hoursDownBeforeSnapshot := _extWebService.CM_OpsViewServiceDef.hoursDownBeforeSnapshot;

	create terms transient; // ### TFS 53753 31MAY2022 NAVAB1
	foreach term in self.allTerminals discreteLock do // ### TFS 53753 31MAY2022 NAVAB1
		if not term.canUserAccessSelf(app.myPassport.myUser, failedDAC, app.myPassport) then // ### TFS 53753 31MAY2022 NAVAB1
			terms.add(term); // ### TFS 53753 31MAY2022 NAVAB1
		endif; // ### TFS 53753 31MAY2022 NAVAB1
	endforeach; // ### TFS 53753 31MAY2022 NAVAB1
	
	self.allTerminals.clear();		
	
	_extWebService.allTerminals.copy(self.allTerminals);
	
	terms.copyNoDuplicates(self.allTerminals,false); // ### TFS 53753 31MAY2022 NAVAB1
	
	
epilog
	delete terms;
end;</source>
        <Parameter name="_extWebService" type="CM_ExternalWebServiceDef"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateStatus" id="cf14f91b-71eb-48c8-9022-49f697f47cf8">
