    <JadeMethod name="getProposedVisiblity" id="336a0c07-3832-45d9-b386-77aa041deba4">
        <source>getProposedVisiblity(_colour : Integer output): Boolean;
/*
Purpose:			
Date		Who		Reason
21 September 2011	cnwab1	Initial creation
*/

vars

	slotLC : CM_ROROLanePositionController;
	theTI : CM_TrackedItem;
begin
	_colour := White;
	
	slotLC := self.myLanePositionController;
	foreach theTI in slotLC.allTrackedItems discreteLock do
		// if Remain on Board or Export etc then show me
		if theTI.getImExStatus() &lt;&gt; TI_IMEX_STATUS_IMPORT then
			// PAR 31096 - DO not show discharge rehandles in proposed
			if (theTI.isRehandle or theTI.isSOB)	
			and not theTI.hasBeenLoadedToShip() then // PAR 31805 do show loaded rehandles in proposed.
				return false;
			endif;
					
				if theTI.isTranshipItem then
					if slotLC.myRORORequestDischarge &lt;&gt; null then
						if slotLC.myRORORequestDischarge.getTIofMode(REAL_MODE) = theTI then
						return false;
						endif;
					endif;
				endif;
			_colour := theTI.getDrawingColour(TI_ColourMode_DischargePort);
			return true;
		endif;
	endforeach;

	// Is colour coded and planned for load
	if not self.myLanePositionController.allRequestsLoad.isEmpty()  then
		return self.myLanePositionController.allRequestsLoad.first.getProposedVisiblity(_colour);
	endif;
		
	return false; // do not show is for an IMPORT
epilog

end;</source>
        <Parameter name="_colour" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleAllWLEsComplete" id="833999ba-6b28-44b8-881f-9979cef39744">
        <source>handleAllWLEsComplete(_isLoad : Boolean) : Boolean;
/*
Purpose:			Are ALL the WLES on this location completed?
Date				Who			Reason
November 2012		CNWAB1		Initial creation
*/


vars
	theReq : CM_RORORequest;
begin
	if _isLoad then
		theReq := self.myLanePositionController.myRORORequestLoad;
	else
		theReq := self.myLanePositionController.myRORORequestDischarge;
	endif;
	
	if theReq &lt;&gt; null then
		if theReq.isComplete then
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasColourCoding" id="519318c0-6a7b-4c0c-83ed-0b9927075268">
        <source>hasColourCoding(_type: Integer): CM_RORORequest;
/*
Purpose:			
Date		Who		Reason
27 September 2011	cnwab1	Initial creation
*/

vars

begin
	if _type = LOAD_MOVETYPE then
		return self.myLanePositionController.myRORORequestLoad;
	elseif _type = DISCHARGE_MOVETYPE then
		return self.myLanePositionController.myRORORequestDischarge;
	endif;
	
	return inheritMethod(_type);

epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_RORORequest"/>
    </JadeMethod>
    <JadeMethod name="hasCompletedWLE" id="4b24fa84-5fe4-4137-9ff2-e5a0f61a3962">
        <source>hasCompletedWLE(_isLoad: Boolean): Boolean;
/*
Purpose:			 // PAR 29807
Date		Who		Reason
20 June 2012	cnwab1	Initial creation
*/

vars

begin
	if _isLoad then
		if self.myLanePositionController.myRORORequestLoad &lt;&gt; null then
			if self.myLanePositionController.myRORORequestLoad.isComplete then
				return true;
			endif;
		endif;
	else
		if self.myLanePositionController.myRORORequestDischarge &lt;&gt; null then
			if self.myLanePositionController.myRORORequestDischarge.isComplete then
				return true;
			endif;
		endif;
	endif;
	
	
	return false;

epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
