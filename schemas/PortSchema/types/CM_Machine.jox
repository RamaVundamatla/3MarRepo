    <JadeMethod name="addToQueue" id="4807ad4f-2e24-4e92-8170-3aa5d91e6cb3">
        <updating/>
        <source>addToQueue(pQueue : CM_RadioTelemetryQueue; pPrimary : Boolean; pPos : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     09 October 2001 by cnwrs2
//
// Purpose:     Adds this machine to a queue
//

// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pPrimary then
		if self.myPrimaryQueue &lt;&gt; pQueue then
			self.myPrimaryQueue := pQueue;
			//epr TFS 4620 16/6/17
			if self.loggedOn then
				self.addInfoToHistory(CM_MachineInfoHistory.InfoType_ChangeQueue,self.currentQueueTask,null,null);
			endif;
		endif;
	else
		if pPos = 0 then
			// just add to the end
			self.allQueues.add(pQueue);
		else
			self.allQueues.insert(pPos, pQueue);
		endif;
	endif;
	
end;</source>
        <Parameter name="pQueue" type="CM_RadioTelemetryQueue"/>
        <Parameter name="pPrimary" type="Boolean"/>
        <Parameter name="pPos" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="amendMoveHistoryForIMVSwitch" id="dd99e79d-826a-4ec8-a049-6b4de7e313b6">
        <updating/>
        <source>amendMoveHistoryForIMVSwitch( _oldMachine: CM_Machine; _theTI : CM_TrackedItem; _trx :CM_Move) updating;
/*
Purpose:		Move relevant machine history entries from old to new machine after
				IMV switch is done
Parameters:		_oldMachine
				_theTI
				_trx		- move transaction from one IMV to the other
Return Value:		

Date			Who		Reason
28 April 2010	cnwrd1	Initial creation
//cnwrd1 par 23997 28.4.2010
22/11/2010		cnwcs5	par 23714/ccms 1132 - move accept history over as well
											- fix up next/prior lift history links
*/

vars
	moveHistory		: CM_MachineMoveHistory;
	oldMachine 		: CM_Machine;
	oldHistory, 
	newHistory		: CM_MachineMoveHistory;			// 24/11/2010 cnwcs5 par 23714/ccms 1132
begin
	oldMachine := _oldMachine;
	
	if oldMachine = null then
		return;
	endif;
	// look for the most recent pickup for the machine/TI
	moveHistory := oldMachine.findLastMoveForTI(_theTI);
	
	if moveHistory = null then							// 06/12/2010 cnwcs5 par 25803/ccms 1132
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'No history found for IMV switch');	// 06/12/2010 cnwcs5 par 25803/ccms 1132
	endif;												// 06/12/2010 cnwcs5 par 25803/ccms 1132
	// adjust the history
	moveHistory.amendMoveHistoryForIMVSwitch (self);	// 23/11/2010 cnwcs5 par 23714/ccms 1132
	
	//then need to add move Amendment to both.
	oldHistory	:= oldMachine.addAmendMoveHistory( oldMachine.code, self.code, _theTI );
	newHistory	:= self.addAmendMoveHistory( oldMachine.code, self.code, _theTI );
	
	newHistory.setQuantity( oldHistory.quantity );	//27 Sep 2013	NDL	Par 31799
	
	oldHistory.setMyMoveTransaction (_trx);				// 24/11/2010 cnwcs5 par 23714/ccms 1132
	newHistory.setMyMoveTransaction (_trx);				// 24/11/2010 cnwcs5 par 23714/ccms 1132
epilog

end;</source>
        <Parameter name="_oldMachine" type="CM_Machine"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_trx" type="CM_Move"/>
    </JadeMethod>
    <JadeMethod name="auditClass" id="0197d54b-6baf-4b47-96be-4633a7924071">
        <options>4</options>
        <source>auditClass(): Class typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

begin
	return CM_Machine;

epilog

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="auditId" id="6b353fe1-b34c-4cc0-90a6-e88b520d97f7">
        <source>auditId(): String;
// ---------------------------------------------------------------------------
// Created:     May 2006 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
