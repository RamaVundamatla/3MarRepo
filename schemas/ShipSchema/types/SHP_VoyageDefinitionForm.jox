    <JadeMethod name="tblNewDimensions_keyDown" id="5614c012-61eb-4929-9e1b-8b599da19a52">
        <controlMethod name="CM_BaseTable::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblNewDimensions_keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	tmpRow	: Integer;
begin

	if keyCode = J_key_Tab then
		tmpRow := table.row;
		if tmpRow = table.rows and 
		   shift = 0 then
			table.tabKey := 0;

			// so that if we move to the tblKeyDistances we are on the right row
			table.row := table.fixedRows + 1;

			self.tabNext();
			table.selected := false;
		elseif tmpRow = table.fixedRows + 1 and 
		   shift = 1 then
			table.tabKey := 0;
			self.tabPrior();
			table.selected := false;
		endif;
		
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
