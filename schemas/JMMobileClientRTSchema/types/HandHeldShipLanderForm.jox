    <JadeMethod name="btnAftSealNo_click" id="ea315d4e-abe9-4142-be3c-7244cda8a593">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAftSealNo_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2009	cnwer1	Initial creation

*/

vars
	sealMissing : String;
begin
	sealMissing:=app.myHandHeldShipLanderGuiAgent.getSealMissingString;
	self.txtSealCustAft.text:=sealMissing;
	self.txtSealOpAft.text:=sealMissing;
	self.txtSealShipAft.text:=sealMissing;
	btn.buttonPicture:=Button.ButtonPicture_Tick;
	self.btnAftSealYes.buttonPicture:=null;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnAftSealYes_click" id="b978efe1-dfee-4a03-a5e3-cc560462d453">
