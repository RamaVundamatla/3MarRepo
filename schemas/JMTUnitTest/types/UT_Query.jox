  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tRangeQueryMultiRangeValues" id="9b2066bd-89d4-483b-9202-4c8e00b927ec">
        <updating/>
        <source>tRangeQueryMultiRangeValues()updating;
// cnwndl1
//27 August 2009	
// cnwdw1	
vars
	agent : CM_QueryBuilderAgent;
	ti, ti1, ti2, ti3: CM_TrackedItem;
	results: CM_TISet;
	obj: Object;
	msg: String;
	iter: Iterator;
begin
	self.deleteTerminalArea(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString);
	bs := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString, 100, null);

	self.deleteContainer("UUT00000001");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 0);
	ti := self.addContainer("UUT00000001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti, bs);
	assertTrue(ti.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 1);
	
	self.deleteContainer("UUT00000002");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 1);
	ti1 := self.addContainer("UUT00000002", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti1, bs);
	assertTrue(ti1.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti1.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 2);
	
	self.deleteContainer("TEST0000003");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 2);
	ti2 := self.addContainer("TEST0000003", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti2, bs);
	assertTrue(ti2.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti2.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 3);
	
	self.deleteContainer("TEST0000004");
	self.assertEqual(bs.getNumTIs(REAL_MODE), 3);
	ti3 := self.addContainer("TEST0000004", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti3, bs);
	assertTrue(ti3.myTerminalArea.myTerminal = self.getTerminal);
	self.assertEqual(ti3.getPrimaryLocation(REAL_MODE), bs.myLocationsController);
	self.assertEqual(bs.getNumTIs(REAL_MODE), 4);
	
	create agent transient;
	create results transient;
	agent.setResultArray(results);
	agent.setQueryMode(null);
	agent.addCriteria('myTerminal', 'equal to', getTerminal);
	agent.addCriteria('id', 'range', "UUT00000001-UUT00000002, TEST");
	agent.doQuery();
	
	assertTrue(results.size &gt; 0);
	iter := results.createIterator;
	
	while iter.next(obj) do
		msg := msg &amp; CrLf &amp; obj.String &amp; ":" &amp; obj.CM_TrackedItem.id;
	endwhile;
		
	assertTrueMsg(results.includes(ti), msg &amp; CrLf &amp; CrLf &amp; ti.String&amp;":"&amp;ti.CM_TrackedItem.id);
	assertTrueMsg(results.includes(ti1), msg &amp; CrLf &amp; CrLf &amp; ti.String&amp;":"&amp;ti.CM_TrackedItem.id);
	assertTrueMsg(results.includes(ti2), msg &amp; CrLf &amp; CrLf &amp; ti.String&amp;":"&amp;ti.CM_TrackedItem.id);
	assertTrueMsg(results.includes(ti3), msg &amp; CrLf &amp; CrLf &amp; ti.String&amp;":"&amp;ti.CM_TrackedItem.id);
epilog
	delete agent;
	delete results;
	delete iter;
end;</source>
