    <JadeMethod name="b_clearLocks_click" id="c16bf410-1798-47c7-a4d2-04dc18c83eff">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>b_clearLocks_click(btn: Button input) updating;

vars

begin
	beginTransaction;
	abortTransaction;
	v_objectNumber := 0;
	colourBackground;
end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="b_forward_click" id="2e16e353-6806-40e1-9316-ce86d63fb6a6">
