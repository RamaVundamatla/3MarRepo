    <JadeMethod name="getPlannersGroupDesc" id="0fdf938b-a7bb-4d3f-b0a2-8d6d3e09316b">
        <source>getPlannersGroupDesc(): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	cargoType : CM_CargoType;
	criteria : CM_YACriteria;
begin
	criteria := self.getAttrByType(YACriteriaType_CargoType);
	if criteria &lt;&gt; null then
		cargoType := criteria.myYAData.CM_YADataObjects.allObjects.first().CM_CargoType;
	endif;
	
	if cargoType = null then
		return "???";
	else
		return cargoType.abbreviation;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProposedVisiblity" id="bef6f1f0-c5a6-4fff-bae6-661f1d06142e">
        <source>getProposedVisiblity(_colour : Integer output): Boolean;
/*
Purpose:			
Date		Who		Reason
21 September 2011	cnwab1	Initial creation
*/

vars
	req : CM_RORORequest;
	slotLC : CM_ROROGCController;
	theTI : CM_TrackedItem;
	aWLE : CM_WorkListEntry;
	tis : CM_TIArray;
	defn : CM_DeckItem;
	slot : CM_ROROSlotDefn;
	isComp, found : Boolean;
	//invalidLc: Boolean;      //cnwma1 PAR 37716 25/03/2016
	roroGC : CM_ROROGCDefnVoyage; 
	//roroGC :  CM_ROROGCController;//cnwma1 PAR 37716 25/03/2016
begin
	_colour := White;

	if not  self.isLoad then // ONLY LOAD
		return false;
	endif;
	
	
	
	
	/* WAS
	
	on Exception do app.handleDeletedObject(exception, roroGC, invalidLc);  //cnwma1 PAR 37716 25/03/2016
	

	//roroGC := self.myROROController.CM_ROROGCController.myGCDefn;   //cnwma1 PAR 37716 25/03/2016
	roroGC := self.myROROController.CM_ROROGCController;   //cnwma1 PAR 37716 25/03/2016
	// ### Load Colour Coding
	foreach aWLE in self.allWorkListEntries discreteLock do
		// If load CC has a TI it is planned
		if aWLE.myTrackedItem &lt;&gt; null then
			if not found then
				_colour := self.getAllocationColour(); 
			endif;
			if  not invalidLc then   //cnwma1 PAR 37716 25/03/2016
				if self.myROROController.CM_ROROGCController.myGCDefn.isOnLayerGC() then // PAR 31166
					return false;
				else
					return true;
				endif;
			endif;
		endif;
	endforeach;
	NOW */
	

	roroGC := self.myROROControllerLoad.CM_ROROGCController.myGCDefn;   
	// ### Load Colour Coding
	foreach aWLE in self.allWorkListEntries discreteLock do
		// If load CC has a TI it is planned
		if aWLE.myTrackedItem &lt;&gt; null then
			_colour := self.getAllocationColour(); 
			if roroGC.isOnLayerGC() then // PAR 31166
				return false;
			else
				return true;
			endif;
		endif;
	endforeach;

	return false; // do not show 

epilog
	delete tis;
end;</source>
        <Parameter name="_colour" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleAllWLEsComplete" id="ff9a0c40-fd83-4eba-bb29-f45e44a6bd7d">
        <updating/>
        <source>handleAllWLEsComplete() updating;
/*
Purpose:	The first WLE moved in this request moves the GC defn layout to the GC Cargo layer
Purpose:	If the discharge request is complete and we are for a GC then hide the GC defn layout 
Date		Who		Reason
31 August 2011	cnwab1	Initial creation
*/

vars
	layer, newLayer : CM_DeckLayerLayout;
	defn : CM_DeckItem;
begin

	defn := self.myROROController.getDefn();

	if self.isLoad then
		if self.myLayout &lt;&gt; null
		and defn &lt;&gt; null then
			layer := defn.myLayout.myDeckLayer;
			
			if layer &lt;&gt; null then
				if not layer.isActualCargoLayer() then
				
					if layer.myDeckLayout &lt;&gt; null then
						newLayer := layer.myDeckLayout.getGCLayer(); // The actual GC Cargo Layer
						if newLayer &lt;&gt; null then
							// Move the GC layout to the GC Layer
							defn.myLayout.setMyDeckLayer(newLayer);
							defn.CM_ROROGCDefn.setMyDeckLayerLayout(newLayer); // PAR 32732 - Move the GC defn to the GC Layer
						endif;
					endif;
				endif;
			endif;
		endif;
	elseif self.isDischarge and self.isComplete then
		defn := self.myROROController.getDefn();
		defn.myLayout.hideMe(); // this will stop any moves to the LC, see CM_LC::testIsControllerAvailable
		defn.myLayout.showAllCoveredPolygons();
	endif;

epilog

end;</source>
    </JadeMethod>
