    <JadeMethod name="setTableDataFromOrganiser" id="733e3b6f-0cee-4c36-9884-0e26a53fc915">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	05 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	colPointer	: Integer;
	
begin
	if _theTable = null then
		return;
	endif;
	
	_theTable.sortColumn[1]	:=	null;
// cnwdad1 30/03/2006 - PAR #11580.
//	_theTable.accessColumn(_theTable.getColumnByRowName(ETRow_Dockage)).alignment := Table.Alignment_Right_Middle;
	colPointer	:=	_theTable.getColumnByRowName(ETRow_Dockage);
	
	if colPointer &gt; _theTable.fixedColumns and colPointer &lt;= _theTable.columns then
		_theTable.accessColumn(colPointer).alignment	:=	Table.Alignment_Right_Middle;
	endif;
	
	self.displayBerthUsage();
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="eaad8805-c68a-4def-8e89-37be1c7263a2">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	23 November 2005 By: cnwgd1
//--------------------------------------------------
vars
begin
	inheritMethod();

	self.frmToolbar.alignContainer	:=	Frame.AlignContainer_Top; // this will make the dkcMain line up its top	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	self.initTblData();	
	//self.setFilterDefaults(true);

	self.setNavigatorHeading(self.caption);

	self.beginClassNotification(HMS_Berth, false, Object_Create_Event, Response_Continuous, 0);
	self.beginClassNotification(HMS_Berth, false, Object_Update_Event, Response_Continuous, 0);
	self.beginClassNotification(HMS_Berth, false, Object_Delete_Event, Response_Continuous, 0);	
	
	// not use on this form, disable 
	self.btnSaveBase.enabled := false;
	
	self.fldMain.useSheetBackColors := true;
	self.fldMain.setDefaultSheetBackColors();
	self.fldMain.initSheetBackColors();

	/*if (not app.myRoot.isMultiHarbour()) then
		self.lstHarbours.visible := false;
		self.lblHarbours.visible := false;
		self.lstTerminals.width := self.lstTerminals.width + self.lstHarbours.width+5;		
		self.lstTerminals.left := self.lstHarbours.left;
		self.lblTerminals.left := self.lstTerminals.left;						
	else
		self.lstHarbours.visible := true;
	endif;				
	
	if (not app.myRoot.isMultiTerminal()) then
		self.lstTerminals.visible := false;
		self.lblTerminals.visible := false;		
		self.lstHarbours.width := self.lstHarbours.width + self.lstTerminals.width+5;
	else
		self.lstTerminals.visible := true;
	endif;
	
	if (not self.lstTerminals.visible)
	and (not self.lstHarbours.visible) then
		self.grpHarbours.visible := false;
		self.grpWharves.top := self.grpHarbours.top;
		self.frmSearch.height := self.grpWharves.top + self.grpWharves.height+20;				
	endif;*/
		
end;</source>
    </JadeMethod>
    <JadeMethod name="showHideSearcher" id="c5286774-d914-4933-a03d-d0158d1c2e97">
        <source>showHideSearcher() protected;
//--------------------------------------------------
// Created:	24 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.btnSearch.enabled := false;

	if self.frmSearch.visible then
		self.frmSearch.visible := false;
	else
		self.btnSearch.enabled := true;
		self.frmSearch.visible := true;
		self.frmSearch.zOrder(1);
		self.frmSearch.centreWindow();
		//We're showing the searcher, move to the first row ready for new values.
		//23 Feb 2012	NDL	Par 29120
		if self.grpDateRange.enabled then
			self.cmbMonth.setFocus();
		else
			self.txtFromDate.setFocus();
		endif;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showWithObjectMode" id="54f05773-509c-45f3-b09a-95b57a16625f">
        <updating/>
        <source>showWithObjectMode(_berth : HMS_Berth; _doMode: Boolean) updating;
//--------------------------------------------------
// Created:	23 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_berth, _doMode);

	if HMS_Berth.hasInstance(_berth) then
		self.setMyCurrentBerth(_berth.HMS_Berth);
	endif;

	self.show;

end;</source>
        <Parameter name="_berth" type="HMS_Berth"/>
        <Parameter name="_doMode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblData_contextMenu" id="ab47f6d9-88d8-487e-81fb-a75eee9790c0">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------
// Created:	01 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	x1, y1 : Real;
begin

	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	popupMenu(self.mnuTblContext, x1.Integer, y1.Integer);
	return false;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c995e9e7-6d48-4691-b4ec-3755c4491ec4">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005822, locale);
	btnAllBerths.translateBubbleHelp(Xlat_0001430, locale);
	btnAllBerths.translateCaption(Xlat_0001438, locale);
	btnAllHarbour.translateBubbleHelp(Xlat_0014378, locale);
	btnAllHarbour.translateCaption(Xlat_0014379, locale);
	btnAllTerminals.translateBubbleHelp(Xlat_0001413, locale);
	btnAllTerminals.translateCaption(Xlat_0001415, locale);
	btnAllWharves.translateBubbleHelp(Xlat_0001424, locale);
	btnAllWharves.translateCaption(Xlat_0001427, locale);
	btnCloseSearch.translateBubbleHelp(Xlat_0014380, locale);
	btnCloseSearch.translateCaption(Xlat_0001420, locale);
	btnPrintOptions.translateBubbleHelp(Xlat_0001414, locale);
	btnPrintOptions.translateCaption(Xlat_0001416, locale);
	btnResetSearch.translateBubbleHelp(Xlat_0001418, locale);
	btnResetSearch.translateCaption(Xlat_0001421, locale);
	btnSearch.translateBubbleHelp(Xlat_0001431, locale);
	btnSearch.translateCaption(Xlat_0001439, locale);
	btnShowSearch.translateBubbleHelp(Xlat_0001425, locale);
	btnShowSearch.translateCaption(Xlat_0001428, locale);
	btnThisMonth.translateBubbleHelp(Xlat_0001432, locale);
	btnThisMonth.translateCaption(Xlat_0001440, locale);
	btnThisYear.translateBubbleHelp(Xlat_0001433, locale);
	btnThisYear.translateCaption(Xlat_0001441, locale);
	ckbIncludeFuture.translateBubbleHelp(Xlat_0001450, locale);
	ckbIncludeFuture.translateCaption(Xlat_0001451, locale);
	ckbNoItinerary.translateBubbleHelp(Xlat_0001419, locale);
	ckbNoItinerary.translateCaption(Xlat_0001422, locale);
	lblBerth.translateCaption(Xlat_0001442, locale);
	lblFromDate.translateCaption(Xlat_0017964, locale);
	lblHarbours.translateCaption(Xlat_0014381, locale);
	lblMonth.translateCaption(Xlat_0001444, locale);
	lblPeriod.translateCaption(Xlat_0017965, locale);
	lblPeriod_1.translateCaption(Xlat_0017966, locale);
	lblTerminals.translateCaption(Xlat_0001445, locale);
	lblToDate.translateCaption(Xlat_0017967, locale);
	lblWharf.translateCaption(Xlat_0001446, locale);
	lblYear.translateCaption(Xlat_0001447, locale);
	lstBerths.translateBubbleHelp(Xlat_0001434, locale);
	lstHarbours.translateBubbleHelp(Xlat_0001435, locale);
	lstTerminals.translateBubbleHelp(Xlat_0001436, locale);
	lstWharves.translateBubbleHelp(Xlat_0001437, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0005823, locale);
	mnuPrintOptions.translateCaption(Xlat_0005824, locale);
	mnuTblContext.translateCaption(Xlat_0005825, locale);
	shtBarGraph.translateCaption(Xlat_0001448, locale);
	shtBerthUsage.translateCaption(Xlat_0001429, locale);
	shtPieGraph.translateCaption(Xlat_0001449, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="e77a4697-e105-4150-a0bc-490818e6b2b1">
