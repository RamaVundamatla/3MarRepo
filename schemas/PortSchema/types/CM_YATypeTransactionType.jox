    <JadeMethod name="getObjects" id="3332fcda-fb4c-4ef9-aac0-f1ed99a1d4c3">
        <source>getObjects(objects: ObjectLongNameDict input);
/*
Purpose:			
Date				Who			Reason
MARCH 2015		CNWAB1		Initial creation
*/

vars
	type: CM_TransactionType;
begin
	foreach type in app.myRoot.allTransactionTypesByDesc where not type.isForHMS() do 
		objects[type.getYAIdentifier] := type;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
