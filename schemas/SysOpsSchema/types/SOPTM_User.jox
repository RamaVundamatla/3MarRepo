    <JadeMethod name="setSsoLinkedIdentifier" id="a763d7f3-dfbb-4d08-b042-5aace9c59efd">
        <source>setSsoLinkedIdentifier(_value	: String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 July 2022 navam1 ChangeRequest 52824: EUP - Azure Active Directory Single Sign On - MTN

*/
vars
	notLinked : String;
	tblInput	: CM_EntryTable;
begin
	notLinked := '--' &amp; app.getErrorString(SSO_Account_Not_linked) &amp;  '--';
    tblInput := self.myForm.tblInput1;
	
	if _value = null or _value = "" then
		tblInput.setValueByName(ETRow_SsoLinkedIdentifier, notLinked);
	else
		tblInput.setValueByName(ETRow_SsoLinkedIdentifier, _value);
	endif;
	
	if _value &lt;&gt; null and _value &lt;&gt; notLinked then
		tblInput.hideRowByName(ETRow_SsoMatchingId, false);
	else
		tblInput.showRowByName(ETRow_SsoMatchingId, false);
	endif;
	
	tblInput.disableRowByName(ETRow_SsoLinkedIdentifier);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="9a1eb677-1b7a-4d13-91ce-49b83a80179b">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;

/*

Purpose:	 NFS 30581 	

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2013	cnwrd1	Initial creation

*/

vars
	tempStr		: String;
	theForm 	: SOP_TableMaintForm;
	tmpMenu		: MenuItem;
	bVisible	: Boolean;
	aUser		: CM_User;
	reason		: String;
	entTableDef	: EntTableDef;
	entRow		: EntTableRow;
	heading		: String;
begin
	inheritMethod( conwin );
	theForm := self.myForm;

	if theForm.mode &lt;&gt; theForm.Mode_View then	//only in view mode
		return;
	endif;
	
	if theForm.myCurrentObject &lt;&gt; null and theForm.myCurrentObject.isKindOf(CM_User) then
		aUser := theForm.myCurrentObject.CM_User;
			
	//	if aUser.isSuspended and self.canUserUnlock(aUser) then //and I am higher or equl in security	
		if ( aUser.isSuspendedOrIsDisabled() ) and self.canUserUnlock(aUser) then	 //23 Nov 2020	NDL TFS 50378
			theForm.mnuContext1.visible	:= true;
			theForm.mnuContext1.caption	:=  app.getErrorString1( Unlock_user, aUser.userName );
			tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext1, false ); 	
		endif;
		//epr TFS 3596 10/4/17
		theForm.mnuContext2.visible:=true;
		theForm.mnuContext2.caption	:=  app.getErrorString( Clear_saved_window_setting );
		tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext2, false ); 
		
		
		//22 May 2018	NDL	TFS 38768
		if app.myRoot.getConfig( UserEmailTemplate ).CM_UserPasswordDefaultEmail = null then
			entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ ETDef_SecurityConfig ];
			heading := "Email Template for Generated User Password";
			if entTableDef &lt;&gt; null then
				entRow := entTableDef.getEntTableRow( ETRow_UserEmailTemplate );
				if entRow &lt;&gt; null then
					heading := entRow.getHeading(null, null, app.myCurrentLocale);
				endif;
			endif;
			reason := " ( disabled - '" &amp; heading &amp; "' "&amp; app.getErrorString(Not_Set) &amp; ")";
		elseif aUser.getEmailAddress = null then
			reason := " ( disabled - " &amp; app.getErrorString1(Users_does_not_have_email, aUser.code) &amp; ")";
		elseif not app.getMyUser.canDo(null,PmCmpUserTableMaint) then
			reason := " ( disabled - " &amp; app.getErrorString(Insufficient_permission) &amp; ")";
		endif;
		
		theForm.mnuContext3.visible := not aUser.isSuperUser;
		theForm.mnuContext3.caption	:=  app.getErrorString( Email_temporary_password );
		tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext3, false ); 
		
		if reason &lt;&gt; null then
			tmpMenu.enabled := false;
			tmpMenu.caption :=  tmpMenu.caption &amp; reason;
		endif;
		
		//20.07.2022 navam1 #52824
		if aUser.ssoMatchingId &lt;&gt; null and aUser.ssoUniqueId &lt;&gt; null then
			theForm.mnuContext4.visible	:= true;
			theForm.mnuContext4.caption	:= app.getErrorString(Unlink_SSO_account);
			tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext4, false ); 	
		endif;
	endif;
	

epilog

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupTerminalsTable" id="b78278b2-55a9-4afc-a068-9de09ac90ce5">
        <updating/>
        <source>setupTerminalsTable(pUser : CM_User) updating;

vars
	theForm 		: SOP_TableMaintForm;
	userTerminal	: CM_UserTerminal;	
	terminal		: CM_Terminal;
	tmpDataTable	: CM_DataTable;
	idx				: Integer;
	allDescrs,
	cargoBOLTypeDescr,
	bolTypeDescr,
	cargoTypeDescr,
	secRoleName		: String;
	
begin
  
  	theForm := self.myForm;
		
	tmpDataTable := theForm.tblData1;
	tmpDataTable.userInputEnabled := false;

	tmpDataTable.rows := 1;
	//now add the user terminal security roles

	foreach terminal in app.myRoot.allTerminals do
	
		executeWhen JMTDevelopmentEnvironment;
			if (not  process.isJLGAB1()) and terminal.code = "BISH" then
				continue;
			endif;
		endExecuteWhen;
	
		userTerminal := pUser.getUserTerminal(terminal);
		if userTerminal &lt;&gt; null then
			if userTerminal.mySecurityRole &lt;&gt; null then
				secRoleName := userTerminal.mySecurityRole.name;
			endif;
			idx := tmpDataTable.addItemObject(terminal, 
											TableCheckBox_Selected &amp; Tab &amp; 
											terminal.name &amp; Tab &amp; 
											secRoleName);
			
			
			tmpDataTable.accessCell(idx, self.Column_CargoType).itemObject := userTerminal.myDefaultCargoType;
			if userTerminal.myDefaultCargoType &lt;&gt; null then
				tmpDataTable.accessedCell.text := userTerminal.myDefaultCargoType.description;
			endif;
			
			tmpDataTable.accessCell(idx, self.Column_BOLType).itemObject := userTerminal.myDefaultBOLType;
			if userTerminal.myDefaultBOLType &lt;&gt; null then
				tmpDataTable.accessedCell.text := userTerminal.myDefaultBOLType.description;
			endif;
			
			tmpDataTable.accessCell(idx, self.Column_CargoBOLType).itemObject := userTerminal.myDefaultCargoBOLType;
			if userTerminal.myDefaultCargoBOLType &lt;&gt; null then	
				tmpDataTable.accessedCell.text := userTerminal.myDefaultCargoBOLType.description;
			endif;
			
		else
			idx := tmpDataTable.addItemObject(terminal, 
												TableCheckBox_NotSelected &amp; Tab &amp; 
												terminal.name &amp; Tab &amp;
												Tab &amp;
												Tab &amp;
												Tab &amp;
												Tab);
												
			theForm.cmbCargoBOLType.listObject := null;
		endif;
		tmpDataTable.accessCell(idx, 3).cellControl := theForm.cmbSecurityRole;
		tmpDataTable.accessCell(idx, Column_CargoType).cellControl := theForm.cmbCargoBOLType;
		tmpDataTable.accessCell(idx, Column_BOLType).cellControl := theForm.cmbCargoBOLType;
		tmpDataTable.accessCell(idx, Column_CargoBOLType).cellControl := theForm.cmbCargoBOLType;
	endforeach;

end;</source>
        <Parameter name="pUser" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDefaults" id="92a952ad-b408-4193-a489-2a11389b1a14">
        <source>setupThumbnailDefaults();
// cnwvu1 28/11/2006
vars
	theForm	: SOP_TableMaintForm;

begin

	theForm := self.myForm;

	theForm.allowSearch := true;
	theForm.btnShowSearchTV.visible := true;
	theForm.btnShowSearchTV.enabled := true;
	
	//theForm.btnExportCSV.visible := true;
	inheritMethod();
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="60e07487-d381-4bf7-819c-ec19bfda094d">
        <updating/>
        <source>setupThumbnailDetails() updating;
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/12/2018	jlgdap1		TFS 42542 PEL1 Freight Forwarder Access and Visibility
//
vars
	theForm : SOP_TableMaintForm;

begin
  
  	theForm := self.myForm;
	theForm.setTblDataEntRows(ETDef_UserTbl);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);
	
	//14 Feb 2018	NDL	TFS 36947
	if not app.getMyUser.canDo( null, PmCmpUserTableDelete ) then
		// override the maintenance permission if they don't have the delete one as well.
		theForm.allowDelete	:= false;
	endif;
	

	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_UserMaint);
	theForm.shtTblInput1.visible := true;
	theForm.myAssistant.comboBoxUserStatus(theForm.tblInput1, ETRow_Status, false);
	theForm.myAssistant.comboBoxSecurityRoleSystem(theForm.cmbSystemRole, null);
	theForm.myAssistant.comboBoxSecurityRoleTerminal(theForm.cmbSecurityRole, null);
	//11/10/21 jlier1 TFS 51963

	theForm.tblInput1.hideRowByName(ETRow_UserIsFreightForwarder, false);			// TFS 42542
																					// TFS 42542
	
	theForm.txtBox01.passwordField := true;
	
	theForm.fldInput.topSheet := theForm.shtTblInput1;

	
	theForm.shtMultiSelect1.caption := app.getErrorString(Alert_Types);
	theForm.mulSelect1.formDisplayEntryMethodName := SOP_TableMaintForm::displayEntryAlertType.name;
	theForm.mulSelect1.availableHeading := app.getErrorString(Alert_Types) &amp; ' ' &amp; app.getErrorString(Available);
	theForm.mulSelect1.selectedHeading  := app.getErrorString(Alert_Types) &amp; ' ' &amp; app.getErrorString(Selected);
	theForm.mulSelect1.setAvailable(app.myRoot.allSystemAlertTypes, true);
	
	theForm.shtMultiSelect2.caption := app.getErrorString(Event_Types);
	theForm.mulSelect2.formDisplayEntryMethodName := SOP_TableMaintForm::displayEntryEventTypes.name;
	theForm.mulSelect2.availableHeading := app.getErrorString(Event_Types) &amp; ' ' &amp; app.getErrorString(Available);
	theForm.mulSelect2.selectedHeading  := app.getErrorString(Event_Types) &amp; ' ' &amp; app.getErrorString(Selected);
	theForm.mulSelect2.setAvailable(app.myRoot.allEventTypesByType, true);    
	
	theForm.shtMultiSelect3.caption := app.getErrorString(Email_address_access);
	theForm.mulSelect3.formDisplayEntryMethodName := SOP_TableMaintForm::displayEntryEmailAddress.name;
	theForm.mulSelect3.availableHeading := app.getErrorString(System_email_addresses);
	theForm.mulSelect3.selectedHeading  := app.getErrorString(Selected_email_addresses);

	// PAR 14833
	//theForm.mulSelect2.setAvailable(app.myRoot.allEmailEntities, true);    
	if app.myPassport.myUser.canDo(theForm.myTerminal, PmAdmEmailSystem) then
		theForm.mulSelect3.setAvailable(app.myRoot.allEmailEntities, true);
	else
		theForm.mulSelect3.setAvailable(app.myPassport.myUser.allEmailsICanSee, true);
	endif;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="showDataAccessDetails" id="ff9a830c-d35f-4acb-8e12-2beb04341d13">
        <source>showDataAccessDetails(pUser : CM_User);
// ---------------------------------------------------------------------------
// Created:     04 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 30/05/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
vars
	da		: CM_DataAccessController;
	theForm : SOP_TableMaintForm;

begin
  	theForm := self.myForm;
  	
  	theForm.cmbDACarrier.setObject(null);
  	theForm.cmbDAConsignee.setObject(null);
  	theForm.cmbDAOperator.setObject(null);
  	theForm.cmbDAOrg.setObject(null);
	theForm.cmbDASubTerminal.setObject(null);
	theForm.cmbDAAgent.setObject(null);
	theForm.cmbDAStevedore.setObject(null);												// TFS 44554

	foreach da in pUser.allDataAccessControllers do
		if da.myClassContained = CM_Carrier then
			theForm.tblInput1.setValueByName(ETRow_DataAccessCarrier, da.name);
			theForm.cmbDACarrier.setObject(da);
		elseif da.myClassContained = CM_ConsigneeConsignor then
			theForm.tblInput1.setValueByName(ETRow_DataAccessConsignee, da.name);
			theForm.cmbDAConsignee.setObject(da);
// cnwdad1 26/03/2009 - PAR #19232.
//		elseif da.myClassContained = CM_Operator then
		elseif da.classContainedName = CM_Operator.name then
			theForm.tblInput1.setValueByName(ETRow_DataAccessOperator, da.name);
			theForm.cmbDAOperator.setObject(da);
// cnwdad1 26/03/2009 - PAR #19232.
		elseif da.classContainedName = CM_Organisation.name then
			theForm.tblInput1.setValueByName(ETRow_DataAccessOrganisation, da.name);
			theForm.cmbDAOrg.setObject(da);
		elseif da.classContainedName = CM_SubTerminal.name then //09/04/2009 cnwdz2 ccms1735
			theForm.tblInput1.setValueByName(ETRow_DataAccessSubTerminal, da.name);
			theForm.cmbDASubTerminal.setObject(da);
		elseif da.classContainedName = CM_CustomsAgent.name then
			theForm.tblInput1.setValueByName(ETRow_DataAccessCustomsAgent, da.name);
			theForm.cmbDAAgent.setObject(da);
		elseif da.classContainedName = CM_Stevedore.name then							// TFS 44554
			theForm.tblInput1.setValueByName(ETRow_DataAccessStevedore, da.name);		// TFS 44554
			theForm.cmbDAStevedore.setObject(da);										// TFS 44554
		endif;
	endforeach;
end;</source>
        <Parameter name="pUser" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="2375ff3d-1471-4a8f-b9d9-3a8c28dcf347">
        <updating/>
        <source>showThumbnail(pUser : CM_User) updating;

// 10/09/2008	concms1	par17903/ccms 1741 Welcome screen - interim solution
// 19/12/2018	jlgdap1	TFS 42542 PEL1 Freight Forwarder Access and Visibility
// 05/08/2021	navmd1	TFS 51226 Allow users with permission to force off old sessions
// 04 Feb 2025	navah1	Story 14660: MTN - New option to disable users from changing their own passwords
// 05 Dec 2025  navlc30 JIRA 36748 CUX - Enforce SSO Login
vars
	theForm 		: SOP_TableMaintForm;
	userTerminal	: CM_UserTerminal;	
	terminal		: CM_Terminal;
	tmpDataTable	: CM_DataTable;
	idx				: Integer;
	isSSOLoginEnforced : Boolean;

begin
  
  	theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.hideRowByName(ETRow_ShowWelcomeScreen, false);
	
	//22/06/2009 cnwdz2  par20027
	if app.isSubTerminalsLicensed then
		theForm.tblInput1.showRowByName(ETRow_DataAccessSubTerminal, false);
	else
		theForm.tblInput1.hideRowByName(ETRow_DataAccessSubTerminal, false);
	endif;
	
	theForm.tblInput1.setValueByName(ETRow_Code, pUser.code);
	theForm.tblInput1.setValueByName(ETRow_UserName, pUser.userName);
	theForm.tblInput1.setValueByName(ETRow_Status, app.userStatusEnumToString(pUser.status));
	// do not set currentPassword
	theForm.tblInput1.setValueByName(ETRow_PersistentPassword, pUser.persistentPassword);
	theForm.tblInput1.setValueByName(ETRow_PreventPasswordChange, pUser.preventPasswordChange);  //04.02.2025 navah1 #14660
//	theForm.tblInput1.setValueByName(ETRow_IsExternal, (pUser.isExternal));
	
	theForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, (pUser.isNotAvailableForEntry));
	theForm.tblInput1.setValueByName(ETRow_AllowAutomaticDisability, (pUser.allowAutomaticDisability));	// cnwvu1	20/11/2006	ccms1051
	theForm.tblInput1.setValueByName (ETRow_ShowWelcomeScreen, (pUser.getShowWelcomeScreen));	// par 17903
	theForm.tblInput1.setValueByName (ETRow_SingleSignOnOnly, (pUser.getUserSingleSignOnOnly)); 	//+ cnwmd1 Par 22287
	theForm.tblInput1.setValueByName(ETRow_SingleSignOnOverride, (pUser.getUserSingleSignAllowOverride));	// TFS 51226
	theForm.tblInput1.setValueByName(ETRow_SsoMatchingId, (pUser.getSSOMatchingId));   //20.07.2022 navam1 #52824
	theForm.tblInput1.setValueByName(ETRow_SsoLinkedIdentifier, (pUser.getSSOUniqueId));   //20.07.2022 navam1 #52824
	
	isSSOLoginEnforced := app.myRoot.getConfig(SsoEnforceSingleSignOn).Boolean;							//08.12.2025 navlc30 #36748
	if isSSOLoginEnforced then																			//08.12.2025 navlc30 #36748
		theForm.tblInput1.showRowByName(ETRow_SsoAllowLocalLogin,false);
		theForm.tblInput1.setValueByName(ETRow_SsoAllowLocalLogin, (pUser.isLocalMTNLoginAllowed));   	
	else
		theForm.tblInput1.hideRowByName(ETRow_SsoAllowLocalLogin,false);
	endif;

	
	//cnwmc5
	theForm.tblInput1.hideRowByName(ETRow_NotificationPlatform, false);
	theForm.tblInput1.hideRowByName(ETRow_NotificationToken, false);
	
	//cnwmc5
	if app.isSpecial then
		theForm.tblInput1.showRowByName(ETRow_NotificationPlatform, false);
		theForm.tblInput1.showRowByName(ETRow_NotificationToken, false);
		theForm.tblInput1.setValueByName(ETRow_NotificationPlatform, pUser.notificationPlatform);
		theForm.tblInput1.setValueByName(ETRow_NotificationToken, pUser.notificationToken);
	endif;
	
	if pUser.myEmailEntity &lt;&gt; null then
		theForm.tblInput1.setValueByName(ETRow_EmailAddress,pUser.myEmailEntity.name);
	endif;

	theForm.cmbEmailAddress.setObject(pUser.myEmailEntity);	
	
	if pUser.mySystemSecurityRole &lt;&gt; null then
		theForm.tblInput1.setValueByName(ETRow_SystemSecurityRole, pUser.mySystemSecurityRole.name);
		if theForm.cmbSystemRole.findObject(pUser.mySystemSecurityRole) &gt; 0 then
			theForm.cmbSystemRole.listObject := pUser.mySystemSecurityRole;
		endif;
	endif;
	
	// Par 14766
	// This method nulls out organisation on occasion because dataaccess combo organisation is pointing
	// at the wrong row and nulls out organisation. Easy fix was to move it above orgasation.
	self.showDataAccessDetails(pUser);
	
	if pUser.myOrganisation &lt;&gt; null then
		theForm.tblInput1.setValueByName(ETRow_MyOrganisation, pUser.myOrganisation.name);
		theForm.cmbOrganisation.setObject(pUser.myOrganisation);
	else
		theForm.cmbOrganisation.setObject(null);
	endif;
	
	if pUser.myLocale &lt;&gt; null then
		theForm.tblInput1.setValueByName(ETRow_MyLocale, pUser.myLocale.localeDescription);
	endif;
	theForm.cmbLocale.setObject(pUser.myLocale);

	self.setupTerminalsTable(pUser);
		
	theForm.mulSelect1.setSorted(true);
	theForm.mulSelect1.setSelected(pUser.allSystemAlertTypes);
	self.disableMulSelect1Contents();
	
	theForm.mulSelect2.setSorted(true);
	theForm.mulSelect2.setSelected(pUser.allEventTypes);
	self.disableMulSelect2Contents();
	
	theForm.mulSelect3.setSorted(true);
	theForm.mulSelect3.setSelected(pUser.allEmailsICanSee);
	self.disableMulSelect2Contents();
	
	theForm.tblInput1.setValueByName(ETRow_UserIsFreightForwarder, pUser.getUserIsFreightForwarder);	// TFS 42542
	self.setSsoLinkedIdentifier(pUser.ssoUniqueId); //TFS 52824, AjitM, navam1
end;</source>
        <Parameter name="pUser" type="CM_User"/>
    </JadeMethod>
</Class>
