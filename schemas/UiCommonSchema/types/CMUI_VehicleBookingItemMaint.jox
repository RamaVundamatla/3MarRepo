    <JadeMethod name="validateSlotControls" id="236ac151-dc99-4402-876d-cdc91b361de4">
        <source>validateSlotControls();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
23 Dec 2022		navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
03 May 2023		navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
21 Jul 2023 	navhl20 Bug 59245: MTN | Validation required to stop adding same cargo item in multiple Slot item
16 Jan 2023 	navhl20 Bug 62053: FR | 53429 - VBS prompts error when adding multiple Release Request lines.
19 Jan 2024		navcs2	ChangeRequest 61199: EUP | FR | 54329 | VBS - Release Line validation
29 Apr 2024 	navlc30 Bug 63641: EUP- 54329 | VBS - Release Line validation - No validation if the Weight is greater than the Outstanding Release line weight.
03 Sep 2024		navcs2	Bug 65612: EUP - Error when creating a VBS slot using the release by weight request
17 Jan 2025		navah1	Bug	33795: MTN | If the Max Weight exceeds the Reserve Details Weight on the VBS Slot Item form, no exception is triggered.
13 Feb 2025		navah1	Bug 34035: Error on the VBS form when the default measurement type is lbs for the terminal
*/

vars
	direction,
	source			: Integer;	// 23.12.2022 navak20 TFS 55979
	reserveDetail	: CM_ReserveDetail;
	quantity,
	availQuantBook,
	availQuantRes,
	availQuantTi	: Integer;
	bookingItem		: CM_BookingRefItem;
	weight,
	availWeightBook,
	availWeightRes,
	availWeightTi,
	maxWeightBook,												//17.01.2025 navah1 #33795 
	maxWeightRes,												//17.01.2025 navah1 #33795 
	maxWeightTi		: Decimal[14,4];							//17.01.2025 navah1 #33795 
	vbsItem			: CM_VehicleBookingTimeSlotItem;
	quantityStr,
	weightStr,
	weightString,
	cargoId,
	cargoTypeDesc,												//17.01.2025 navah1 #33795 
	//cargoTypeUnit,											//17.01.2025 navah1 #33795 
	maxWeightString,											//13.02.2025 navah1 #34035 
	totalWeightRequestedString: String;						 	//13.02.2025 navah1 #34035 	
	relReq			: CM_BulkRelease;
	booking			: CM_BookingRef;
	measurementType,											// 03 Sep 2024	navcs2	Bug 65612
	//weightMeasurementType,									//17.01.2025 navah1 #33795 
	reserveMeasurementType	: CM_MeasurementType;				// 03 Sep 2024	navcs2	Bug 65612
	totalWeightRequested,										//17.01.2025 navah1 #33795 
	maxWeight 		: Decimal[14,2]; 							//17.01.2025 navah1 #33795 
	cargoType		: CM_CargoType;  							//17.01.2025 navah1 #33795 
	
begin
	//direction := self.cmbDirection.getCurrentItemData;		// 23.12.2022 navak20 TFS 55979			//03.5.2023 navhl20 #57402[57471]
	//source := self.cmbSourceType.getCurrentItemData;		// 23.12.2022 navak20 TFS 55979				//03.5.2023 navhl20 #57402[57471]
	
	if self.optBtnPickUp.value then																		//03.5.2023 navhl20 #57402[57471]
		direction := DIRECTION_PICKUP;
	else
		direction := DIRECTION_DELIVERY;
	endif;
	
	if self.optBtnRR.value then																			//03.5.2023 navhl20 #57402[57471]
		source := self.SOURCE_RELEASE;
	elseif self.optBtnBooking.value then
		source := self.SOURCE_BOOKING;
	else
		source := self.SOURCE_CARGO; 
	endif;
	
	//if self.cmbDirection.getCurrentItemData &lt;&gt; DIRECTION_DELIVERY and self.cmbDirection.getCurrentItemData &lt;&gt; DIRECTION_PICKUP then	// 23.12.2022 navak20 TFS 55979
	if direction &lt;&gt; DIRECTION_DELIVERY and direction &lt;&gt; DIRECTION_PICKUP then	// 23.12.2022 navak20 TFS 55979
		app.raiseCMException(Vbs_time_slot_needs_dir, null , null);
	endif;
	
	//if self.cmbSourceType.getCurrentItemData &lt;&gt; SOURCE_RELEASE and self.cmbSourceType.getCurrentItemData &lt;&gt; SOURCE_CARGO and cmbSourceType.getCurrentItemData &lt;&gt; SOURCE_BOOKING then	// 23.12.2022 navak20 TFS 55979
	if source &lt;&gt; self.SOURCE_RELEASE and source &lt;&gt; self.SOURCE_CARGO and source &lt;&gt; self.SOURCE_BOOKING then	// 23.12.2022 navak20 TFS 55979
		app.raiseCMException(Vbs_must_spec_source, null , null);
	endif;
	
	reserveDetail 	:= self.cmbReserveDetail.listObject.CM_ReserveDetail;
	relReq			:= self.cmbReleaseReq.listObject.CM_BulkRelease;
	bookingItem		:= self.cmbBookingItem.listObject.CM_BookingRefItem;
	booking			:= self.cmbBooking.listObject.CM_BookingRef;
	cargoId			:= self.txtCargo.text;																//21.7.2023 navhl20 #59245
	
	if self.mode &lt;&gt; self.MODE_UPDATE then																//04.5.2023 navhl20 #57402[57471]
		if self.myPxyVehicleBookingSlot.allVehicleBookingItems.isNotEmpty() then						//16.01.2023 navhl20 #62053
			foreach vbsItem in self.myPxyVehicleBookingSlot.allVehicleBookingItems do
				if self.txtQuantity.text &lt;&gt; null then
					if bookingItem &lt;&gt; null and booking &lt;&gt; null and 
					vbsItem.myBookingItem &lt;&gt; null and vbsItem.myBooking &lt;&gt; null and
					vbsItem.myBooking.bookingReference = booking.bookingReference and
					vbsItem.myBookingItem.getDisplayString() = bookingItem.getDisplayString() then
						availQuantBook := availQuantBook + vbsItem.quantity;
					endif;
					if reserveDetail &lt;&gt; null and relReq &lt;&gt; null and 
					vbsItem.myReserveDetails &lt;&gt; null and vbsItem.myBulkRelease &lt;&gt; null and
					vbsItem.myBulkRelease.CM_BulkRelease.code = relReq.code and
					//vbsItem.myReserveDetails.getDescription() = reserveDetail.getDescription() then	//16.01.2023 navhl20 #62053
					vbsItem.myReserveDetails = reserveDetail then										//16.01.2023 navhl20 #62053
						availQuantRes := availQuantRes + vbsItem.quantity;
					endif;
					if self.txtCargo.visible and
					vbsItem.myTrackedItem &lt;&gt; null and
					vbsItem.myTrackedItem.id = self.myTrackedItem.id then
						availQuantTi := availQuantTi + vbsItem.quantity;
					endif;
				elseif self.tblWeight.text &lt;&gt; null and self.tblWeight.visible then						//17.01.2025 navah1 #33795 
					if bookingItem &lt;&gt; null and 
					vbsItem.myBookingItem &lt;&gt; null and
					vbsItem.myBookingItem.getDisplayString() = bookingItem.getDisplayString() then
						availWeightBook := availWeightBook + vbsItem.weight;
					endif;
					if reserveDetail &lt;&gt; null and 
					vbsItem.myReserveDetails &lt;&gt; null and
					//vbsItem.myReserveDetails.getDescription() = reserveDetail.getDescription() then	//16.01.2023 navhl20 #62053
					vbsItem.myReserveDetails = reserveDetail then										//16.01.2023 navhl20 #62053
						availWeightRes := availWeightRes + vbsItem.weight;
					endif;
					if self.txtCargo.visible and
					vbsItem.myTrackedItem &lt;&gt; null and
					vbsItem.myTrackedItem.id = self.myTrackedItem.id then
						availWeightTi := availWeightTi + vbsItem.weight;
					endif;	 
				elseif self.tblMaxWeight.text &lt;&gt; null and self.tblMaxWeight.visible then				//17.01.2025 navah1 #33795 
					if bookingItem &lt;&gt; null and 
					vbsItem.myBookingItem &lt;&gt; null and
					vbsItem.myBookingItem.getDisplayString() = bookingItem.getDisplayString() then
						maxWeight := maxWeightBook + vbsItem.maxWeight;
					endif;
					if reserveDetail &lt;&gt; null and 
					vbsItem.myReserveDetails &lt;&gt; null and 
					vbsItem.myReserveDetails = reserveDetail then										 
						maxWeightRes := maxWeightRes + vbsItem.maxWeight;
					endif;
					if self.txtCargo.visible and
					vbsItem.myTrackedItem &lt;&gt; null and
					vbsItem.myTrackedItem.id = self.myTrackedItem.id then
						maxWeightTi := maxWeightTi + vbsItem.maxWeight;
					endif;
				endif;
				if bookingItem &lt;&gt; null and booking &lt;&gt; null and 
					vbsItem.myBookingItem &lt;&gt; null and vbsItem.myBooking &lt;&gt; null and
					vbsItem.myBooking.bookingReference = booking.bookingReference and
					vbsItem.myBookingItem.getDisplayString() = bookingItem.getDisplayString() and 
					vbsItem.myTrackedItem = null and self.cmbCargo.listObject = null then
						app.raiseCMException2(Booking_booking_already_added, bookingItem.getDisplayString(), booking.bookingReference, null , null);
				endif;
				if reserveDetail &lt;&gt; null and relReq &lt;&gt; null and 
					vbsItem.myBulkRelease &lt;&gt; null and vbsItem.myReserveDetails &lt;&gt; null and
					vbsItem.myBulkRelease.code = relReq.code and
					vbsItem.myReserveDetails.getDescription() = reserveDetail.getDescription() and
					//vbsItem.myReserveDetails.getDescription() = reserveDetail.getDescription() then	//16.01.2023 navhl20 #62053
					vbsItem.myReserveDetails = reserveDetail and										//16.01.2023 navhl20 #62053
				 	//not self.txtQuantity.visible and not self.tblWeight.visible then									//20.01.2025 navah1 #33795 
					not self.txtQuantity.visible and not self.tblWeight.visible and not self.tblMaxWeight.visible then  //20.01.2025 navah1 #33795 
						app.raiseCMException2(Reser_detai_relea_reque_alrea_, reserveDetail.getDescription(), relReq.code, null , null);
				endif;
				if reserveDetail = null and relReq &lt;&gt; null and vbsItem.myReserveDetails = null and		//16.01.2023 navhl20 #62053
				   vbsItem.myBulkRelease &lt;&gt; null and vbsItem.myBulkRelease = relReq then
						app.raiseCMException1(Release_request_already_added, relReq.code, null , null);
				endif;
			endforeach;
		endif;
	endif;
	if self.myPxyVehicleBookingSlot.allVehicleBookingItems.size &gt; 1 then									//21.7.2023 navhl20 #59245
		foreach vbsItem in self.myPxyVehicleBookingSlot.allVehicleBookingItems do
			if self.txtCargo.visible and 
			cargoId &lt;&gt; null and vbsItem.myTrackedItem &lt;&gt; null and 
			cargoId = vbsItem.myTrackedItem.id and 
			vbsItem &lt;&gt; self.myPxyVehicleBookingSlot.allVehicleBookingItems.last then
				app.raiseCMException2(Selec_cargo_alrea_added_this_b, cargoId, self.myPxyVehicleBookingSlot.id, null , null);
			endif;
		endforeach;
	endif;
	
	if self.txtQuantity.text &lt;&gt; null and self.txtQuantity.visible then
		quantity 	:= self.txtQuantity.text.Integer;
		quantityStr := app.getErrorString(VBS_Quantity);
		if availQuantRes &gt; 0 then
			quantity := quantity + availQuantRes;
		elseif availQuantBook &gt; 0 then
			quantity := quantity + availQuantBook;
		elseif availQuantTi &gt; 0 then
			quantity := quantity + availQuantTi;
		endif;
		if reserveDetail &lt;&gt; null and reserveDetail.getTotalOutstanding &lt; quantity then																								// 19 Jan 2024		navcs2	ChangeRequest 61199
			app.raiseCMException5(Quant_shoul_less_than_reserve,quantityStr,reserveDetail.getTotalOutstanding.String,quantityStr,availQuantRes.String,quantityStr,null,null);		// 19 Jan 2024		navcs2	ChangeRequest 61199
		endif;
		if self.myTrackedItem &lt;&gt; null and not self.myTrackedItem.isKindOf(CM_Container) and self.myTrackedItem.totalQuantity &lt; quantity then
			app.raiseCMException5(Quant_shoul_less_than_ti,quantityStr,quantityStr,self.myTrackedItem.totalQuantity.String,quantityStr,availQuantTi.String,null,null);
		endif;
		if bookingItem &lt;&gt; null and bookingItem.quantity &lt; quantity then
			app.raiseCMException5(Shoul_less_than_booki_item,quantityStr,bookingItem.quantity.String,quantityStr,quantityStr,availQuantBook.String,null,null);
		endif;
	endif;
	
	//if self.tblWeight.text &lt;&gt; null and self.txtQuantity.visible then			//29.04.2024 navlc30 #63641
	if self.tblWeight.text &lt;&gt; null and self.tblWeight.visible then				//29.04.2024 navlc30 #63641
		weight		:= self.tblWeight.getConvertedValue();						// 03 Sep 2024	navcs2	Bug 65612
		weightStr	:= app.getErrorString(VBS_Weight);
		
		if availWeightBook &gt; 0 then
			weight := weight + availWeightBook;
		elseif availWeightRes &gt; 0 then
			weight := weight + availWeightRes;
		elseif availWeightTi &gt; 0 then
			weight := weight + availWeightTi;
		endif;	

		if reserveDetail &lt;&gt; null then
			cargoType := reserveDetail.getMyCargoType;
			
			if cargoType &lt;&gt; null then
				weightString := cargoType.getConvertedWeightDisplay(weight,  true);
				availWeightRes := cargoType.getConvertedWeightDisplay(availWeightRes, true).Decimal;
			endif;
			
			if reserveDetail.getWeightOutstanding &lt; weight then																			// 19 Jan 2024		navcs2	ChangeRequest 61199
				app.raiseCMException5(Quant_shoul_less_than_reserve,weightStr,weightString,weightStr,availWeightRes.String,weightStr,null,null);			// 19 Jan 2024		navcs2	ChangeRequest 61199
			endif;
		endif;
		if self.myTrackedItem &lt;&gt; null and not self.myTrackedItem.isKindOf(CM_Container) and self.myTrackedItem.totalWeight &lt; weight then
			cargoType := self.myTrackedItem.myCargoType;
			if cargoType &lt;&gt; null then
				weightString := cargoType.getConvertedWeightDisplay(weight,  true);
				availWeightTi := cargoType.getConvertedWeightDisplay(availWeightRes, true).Decimal;
			endif;
			app.raiseCMException5(Quant_shoul_less_than_ti,weightStr,weightStr,weightString,weightStr,availWeightTi.String,null,null);
		endif;
		if bookingItem &lt;&gt; null and bookingItem.weight &lt; weight then
			cargoType := bookingItem.myCargoType;
			if cargoType &lt;&gt; null then
				weightString := cargoType.getConvertedWeightDisplay(weight,  true);
				availWeightBook := cargoType.getConvertedWeightDisplay(availWeightRes, true).Decimal;
			endif;
			app.raiseCMException5(Shoul_less_than_booki_item,weightStr,weightString,weightStr,weightStr,availWeightBook.String,null,null);
		endif;
	endif;

	//17.01.2025 navah1 #33795 Start
	if self.tblMaxWeight.text &lt;&gt; null and self.tblMaxWeight.visible then 
		//maxWeight := self.tblMaxWeight.text.Decimal;     //13.02.2025 navah1 #34035 
		maxWeight := self.tblMaxWeight.getConvertedValue();//13.02.2025 navah1 #34035 
		if reserveDetail &lt;&gt; null then
			relReq := reserveDetail.myReserveHeader;
			if relReq.releaseByType and reserveDetail.byTypeByWeight then 
				totalWeightRequested := reserveDetail.getTotalWeightRequested;
				cargoType := reserveDetail.getCargoType();
				
				if cargoType &lt;&gt; null then
					cargoTypeDesc := cargoType.description;
					//weightMeasurementType := app.getDefaultMeasurementForType(Type_Weight); //20.02.2025 navah1 #34035 
					//if weightMeasurementType &lt;&gt; null then //20.02.2025 navah1 #34035 
					//	cargoTypeUnit := weightMeasurementType.shortName;
					//endif;
					totalWeightRequestedString := cargoType.getConvertedWeightDisplay(totalWeightRequested, true); //13.02.2025 navah1 #34035 
				endif; 
				
				if maxWeight = null then
					//app.raiseCMException3(Vbs_max_weight_required, relReq.code, totalWeightRequested.asStringJMT() &amp; Space &amp; cargoTypeUnit, cargoTypeDesc, null, null); //13.02.2025 navah1 #34035 
					app.raiseCMException3(Vbs_max_weight_required, relReq.code, totalWeightRequestedString, cargoTypeDesc, null, null); //13.02.2025 navah1 #34035 
				endif; 
				
				if maxWeightBook &gt; 0 then
					maxWeight := maxWeight + maxWeightBook;
				elseif maxWeightRes &gt; 0 then
					maxWeight := maxWeight + maxWeightRes;
				elseif maxWeightTi &gt; 0 then
					maxWeight := maxWeight + maxWeightTi;
				endif;	
				
				if cargoType &lt;&gt; null then  //13.02.2025 navah1 #34035 
					maxWeightString := cargoType.getConvertedWeightDisplay(maxWeight,  true);
				endif; 
				
				if maxWeight &lt;&gt; null and maxWeight &gt; totalWeightRequested then
					//app.raiseCMException5(Vbs_max_weight_too_much, maxWeight.asStringJMT &amp; Space &amp; cargoTypeUnit, relReq.code, totalWeightRequested.asStringJMT() &amp; Space &amp; cargoTypeUnit, cargoTypeDesc, totalWeightRequested.asStringJMT() &amp; Space &amp; cargoTypeUnit, null, null); //13.02.2025 navah1 #34035 
					app.raiseCMException5(Vbs_max_weight_too_much, maxWeightString, relReq.code, totalWeightRequestedString, cargoTypeDesc, totalWeightRequestedString, null, null); //13.02.2025 navah1 #34035 
				endif;
			endif;
		endif;
	endif;
	//17.01.2025 navah1 #33795 End

epilog

end;</source>
    </JadeMethod>
</GUIClass>
