end;</source>
    </JadeMethod>
    <JadeMethod name="updateItem" id="2b59aa9c-3428-485f-ac70-8cde73e0dc3f">
        <updating/>
        <source>updateItem() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     05 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	oldId,
	newId		: String;
	logReticket	: CMIF_TIReticket;
begin
	oldId := tblItem.getValueByName(ETRow_OldLogId).String;
	newId := tblItem.getValueByName(ETRow_NewLogId).String;
	
	if newId = null or oldId = null then
		return false;
	endif;
	
	logReticket := self.tblAll.accessRow(self.tblAll.row).itemObject.CMIF_TIReticket;
	if logReticket = null then
		app.msgBox('Please select an item to update first', 'Error', 0);
		return false;
	endif;
	
	if logReticket &lt;&gt; null then
		logReticket.oldId := oldId;
		logReticket.newId := newId;
	endif;
	
	self.tblAll.accessCell(self.tblAll.row, 1).text := logReticket.oldId;
	self.tblAll.accessCell(self.tblAll.row, 2).text := logReticket.newId;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
