    <JadeMethod name="tblEDITI_keyDown" id="27781827-dd5e-4287-baf5-0049eba2fb2a">
        <controlMethod name="CM_DataTable::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEDITI_keyDown(_table: CM_DataTable input; _keyCode: Integer io; _shift: Integer) updating;
//----------------------------------------------------------------
//	Created:	14 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	col : Integer;
begin

	if _keyCode &gt;= 37 and _keyCode &lt;= 40 then
		//arrow keys
		return;
	endif;	

	if self.mode = self.Mode_Update then
		col	:= _table.getColumnByRowName(ETRow_HasChanged);
		if col &gt; 0 then
			_table.accessCell(_table.row, col).text := self.HAS_CHANGED;
			self.tiDataHasChanged := true;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'table definition has no "changed" column');
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_keyCode" type="Integer" usage="io"/>
        <Parameter name="_shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblEDITI_mouseDown" id="6d3876d4-995e-4937-a298-7beddd50318b">
        <controlMethod name="CM_DataTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEDITI_mouseDown(_table: CM_DataTable input; _button: Integer; _shift: Integer; _x: Real; _y: Real) updating;
//----------------------------------------------------------------
//	Created:	06 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	col : Integer;
begin
	if self.mode = self.Mode_Update then
		col	:= _table.getColumnByRowName(ETRow_HasChanged);
		if col &gt; 0 then
			_table.accessCell(_table.row, col).text := self.HAS_CHANGED;
			self.tiDataHasChanged := true;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'table definition has no "changed" column');
		endif;
	endif;
	
	if _table.column &gt; 0 then
		self.mnuEDISortByCol.caption := "&amp;Sort By " &amp; _table.accessCell(1, _table.column).text;
	endif;
	
	self.setTblFindReplace(_table);
	
epilog

end;</source>
