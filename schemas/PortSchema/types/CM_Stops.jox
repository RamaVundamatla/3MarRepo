    <JadeMethod name="setPxyStopOverrideReason" id="0c4e9c09-eb4a-484e-8087-865a45102912">
        <updating/>
        <source>setPxyStopOverrideReason(_reason :CM_StopOverridenReason)updating;
// ---------------------------------------------------------------------------
// Created:     24 August 2010 by cnwcs5 PAR 23697
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient (method);
	
	if _reason &lt;&gt; null then
		if self.myStopOverrideTxn = null then
			create self.myStopOverrideTxn transient;
		endif;
		
		self.myStopOverrideTxn.setMyStopOverrideReason (_reason);
	else	
		if self.myStopOverrideTxn &lt;&gt; null then
			delete self.myStopOverrideTxn;
		endif;
	endif;
epilog

end;
</source>
        <Parameter name="_reason" type="CM_StopOverridenReason"/>
    </JadeMethod>
    <JadeMethod name="setStopForTI" id="df33b9af-5fe9-4410-b2da-1065bd721e56">
        <updating/>
        <source>setStopForTI(_txnParams : CMIF_TITransactionController input; _aStop : Integer; _stopTable : CM_StopsTable; _passport : CM_Passport input) updating;
//-----------------------------------------
// Created: 20 May 2005 By: cnwgd1
//-----------------------------------------
vars
	tmpTI			: CM_TrackedItem;
	aTITrans		: CM_TITransaction;
//	stopsTblDict	: CM_StopsTableByIdDict;
	theTI			: CM_TrackedItem;
begin

	self.raiseExceptionIfTransient(method);

	if _stopTable = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_stopTable', null, null);
		return;
	endif;

	if _txnParams = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_txnParams', null, null);
		return;
	endif;
	
	tmpTI := _txnParams.myTrackedItem;
	
	self.id := _aStop;
	// DVB CCMS 1235	
	if (not app.myRoot.allAvailableStopsTables.includes(_stopTable)) then
		app.raiseCMException1(NotAvailableForEntry, _stopTable.heading.display, null, null);
		return;
	endif;

	if self.setMyTrackedItem(tmpTI) then
		self.userId := _passport.userCode;
		self.dateTime := _txnParams.dateTime;
		self.myStopsTable := _stopTable;
		
		_txnParams.myStop := self;
		
		aTITrans := tmpTI.createTransaction(_txnParams, _passport);

	else
		delete self;
	endif;

end;</source>
        <Parameter name="_txnParams" type="CMIF_TITransactionController" usage="input"/>
        <Parameter name="_aStop" type="Integer"/>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setStopOverrideReason" id="232827e8-feb0-4040-baf5-7f15dc7a4761">
        <updating/>
        <source>setStopOverrideReason( _reason : CM_StopOverridenReason ) updating;
// ---------------------------------------------------------------------------
// Created:     2 Sept 2010 by cnwrs2 PAR 23697
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfTransient( method );
	
	if _reason = null then
		// if we are setting to null and has not been overridded then do not worry about exception
		if self.myStopOverrideTxn &lt;&gt; null then
			self.myStopOverrideTxn	:= null;
		endif;
	else
		// Assume that is get this far we already have a stop override txn
		if self.myStopOverrideTxn = null then
			app.raiseUnexpectedProgramError( class.name, method.name, 'Attempt to set override reason for stop that has not been overridden' );
			return;
		endif;
		
		//self.myStopOverrideTxn.setMyStopOverrideReason( _reason );
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_reason" type="CM_StopOverridenReason"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="ee95aff4-11c2-44bd-a17b-4807349cfb41">
        <source>validateForCreate(_theTI : CM_TrackedItem);
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20 Oct 2022	navsj20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
// ---------------------------------------------------------------------------

vars

begin
	//if self.myStopsTable.isValidForCargoType(_theTI.myCargoType.id) then	//20.10.2022	navsj20	TFS 53862
	if self.myStopsTable.isValidForStopCriteria(_theTI) then	//20.10.2022	navsj20	TFS 53862
		//app.raiseCMException2(ERR_INVALID_VALUE, "Tracked Item", " You do not have security clearance to set stops on this cargo type.",null, null);		//20.10.2022	navsj20	TFS 53862
		app.raiseCMException2(ERR_INVALID_VALUE, "Tracked Item", " You do not have security clearance to set stops on this tracked item.",null, null);		//20.10.2022	navsj20	TFS 53862
	endif;	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
