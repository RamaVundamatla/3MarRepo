    <JadeMethod name="getMyTrain" id="6e20f86e-dd85-4a41-baa3-1c74dfb4aaa2">
        <source>getMyTrain() : CM_Train;
//
///20 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//26 Jan 2015	cnwrs1	par 35564/35566/35573 - units 1 uom Units coli qty removed / Stevedore carrier should be from vehicleVisitRecord / 1090 when trying to produce train remarks with no train 
//09 Feb 2015	cnwrs1	Par35581 - get assignedTrain
//08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
//
vars
	train : CM_Train;
	aTrain : CM_Train;
	trainCode : String;
	tokens : StringArray;
	startTrain : CM_Train;
	iter : Iterator;
begin
	if self.myTrackedItem &lt;&gt; null then			// 08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
		train := self.myTrackedItem.myTrainAssigned;
	endif;
	if train &lt;&gt; null then
		return train;
	endif;
	tokens := self.getReceiveTrainCode.getTokens();
	trainCode := tokens.first;
	if trainCode &lt;&gt; null then
	
		foreach aTrain in self.myTerminal.allTrainsArrival reversed do
			if aTrain.code = trainCode then
				if aTrain.departureDT.isValid then //train has departed
					if aTrain.departureDT &gt; self.dateTime then
						train := aTrain;
						break;
					else	//matching train code but has departed before our receive transation
						break;
					endif;
				else	// matching code and train hasn't departed
					train := aTrain;
					break;
				endif;
			endif;
		endforeach;
		
		//20 Oct 2020	NDL	TFS 50140 - OK check the departed trains too. ( Collection changes based on changing myTerminal to myDepartedTerminal on Train )
		if train = null then
			startTrain := self.myTerminal.allTrainsDeparted.getAtKeyGeq( trainCode, null );
			if startTrain &lt;&gt; null and startTrain.code = trainCode then
				iter := self.myTerminal.allTrainsDeparted.createIterator;
				iter.startAtObject( startTrain );
				while iter.next( aTrain ) do
					if aTrain.code &lt;&gt; trainCode then
						break;
					endif;
					if aTrain.departureDT &gt;= self.dateTime
					and aTrain.arrivalDT &lt;= self.dateTime
					then
						train := aTrain;
						break;
					endif;
				endwhile;
			endif;
		endif;
		
	endif;
	
	return train;
	
epilog

	delete tokens;
	delete iter;
	
end;
</source>
        <ReturnType type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="getMyWagon" id="33d9309a-c110-432a-9bb6-475cf3856e93">
        <source>getMyWagon() : CM_Wagon;
//
///20 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//
vars
	wagon : CM_Wagon;
	train : CM_Train;
	wagonCode : String;
begin
	train := self.getMyTrain;
	if train &lt;&gt; null then
		wagon := train.allWagonsByIdInward[self.myTrackedItem.wagon];
	endif;
	return wagon;
end;
</source>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="getReceiveTrainCode" id="827ce40b-46bf-40c9-a6ab-cfa5cfc0c5bf">
        <source>getReceiveTrainCode(): String;
// cnwjre1 June 2011 par 25618 item selector receive train
// Note: an Any.String returns '** not initialised **' for a null Any value, not null
vars
	any	: Any;
begin
	any := self.getExtraData(TrnsExtraDataReceiveTrain);
	if any = null then
		return null;
	else
		return any.String;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
