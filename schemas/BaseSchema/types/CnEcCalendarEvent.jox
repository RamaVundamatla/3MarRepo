    <JadeMethod name="getProxy" id="4b60bfc8-7c13-4bff-a68a-be2148aae786">
        <source>getProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		27 May 2008 by cnwdad1
//
// Purpose:		Creates a transient clone of the receiver, and returns it.  Note
//				that this method should always be reimplemented on real subclasses
//				to also copy references and inverses.
//
// Parameters:	None
//
// Returns:		A transient deep clone of the receiver.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	proxyObj	: SelfType;
	
begin
	proxyObj					:=	self.cloneSelf(true);
	proxyObj.originalDate		:=	self.eventDate;
	proxyObj.associatedObject	:=	self.associatedObject;
	
	return proxyObj;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="isRepeatInRange" id="510b4187-1a32-408a-9607-a1dac1465c23">
        <updating/>
        <source>isRepeatInRange(pDateFrom:Date; pDateTo:Date):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		20 May 2008 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether a repeat of the receiver
//				falls within the specified date range.
//
//				If the result is true, and the receiver is a transient, then the
//				repeatDate attribute will be set to the date of the repeat.
//
// Parameters:	pDateFrom - The start of the date range.
//				pDateTo - The end of the date range.
//
// Returns:		True if a repeat falls within the date range, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentDate		: Date;
	calendarObj		: CnEcCalendarControl;
	originalDay		: Integer;
	newDay			: Integer;
	daysInMonth		: Integer;
	
begin
	if self.isTransient() then
		calendarObj				:=	self.myCalendarControl;
		self.myCalendarControl	:=	null;
		self.eventDate			:=	self.originalDate;
		currentDate				:=	self.originalDate;
	else
		currentDate	:=	self.eventDate;
	endif;
	
	originalDay	:=	currentDate.day();
	
	while true do
		if currentDate &gt; pDateTo then
			return false;
			
		elseif currentDate &lt; pDateFrom then
			if self.repeatTerm = self.REPEAT_DAY then
				currentDate	:=	currentDate.cnEcAddDays(self.repeatEvery);
			elseif self.repeatTerm = self.REPEAT_MONTH then
				currentDate	:=	currentDate.cnEcAddMonths(self.repeatEvery);
			elseif self.repeatTerm = self.REPEAT_WEEK then
				currentDate	:=	currentDate.cnEcAddWeeks(self.repeatEvery);
			elseif self.repeatTerm = self.REPEAT_YEAR then
				currentDate	:=	currentDate.cnEcAddYears(self.repeatEvery);
			endif;
			
			// The situation can arise where the date gets out of whack because the day gets reset
			// when adding a month if the old day exceeds the total number of days in the new month
			// e.g. when switching from 30 January to 30 February, the day will be reset to 28 February.
			// However, if we susequently go past February, we need to reset back to the original 30th.
			
			newDay		:=	currentDate.day();
			daysInMonth	:=	currentDate.cnEcDaysInMonth();
			
			if newDay &lt;&gt; originalDay then
				// If the new day equals the number of days in the month, then leave it,
				// otherwise see if we need to reset the day.
				
				if newDay &lt;&gt; daysInMonth then
					if originalDay &lt;= daysInMonth then
						currentDate.setDate(originalDay, currentDate.month(), currentDate.year());
					elseif newDay &lt; daysInMonth then
						currentDate.setDate(daysInMonth, currentDate.month(), currentDate.year());
					endif;
				endif;
			endif;
		else
			if self.isTransient() then
				// Save off the reference to the Calendar control, reset the event date,
				// and then reset the Calendar reference, thus adding the event back to
				// the Calendar control's collection of events.
				self.eventDate			:=	currentDate;
			endif;
			
			return true;
		endif;
	endwhile;
	
	return false;
epilog
	if self.isTransient() then
		self.myCalendarControl	:=	calendarObj;
	endif;
end;</source>
        <Parameter name="pDateFrom" type="Date"/>
        <Parameter name="pDateTo" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAssociatedObject" id="94ca79f5-3725-4235-b993-9beeb29084eb">
        <updating/>
        <source>setAssociatedObject(pValueObj:Object) updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Sets a reference to an object that is associated with a calendar
//				date/event (CnEcCalendarControl).
//
// Parameters:	pValueObj - The associated object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

epilog	
	if self.associatedObject &lt;&gt; pValueObj then 
		self.associatedObject	:=	pValueObj;
	endif;
end;</source>
        <Parameter name="pValueObj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setDisplayText" id="545b8479-86a0-4033-a877-e29e4485d255">
        <updating/>
        <source>setDisplayText(pValue: String) updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Sets the display value of a Calendar date/event.
//
// Parameters:	pValue - The display values.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.displayText &lt;&gt; pValue then 
		if pValue.length &gt; 50 then
			self.displayText	:=	pValue[1:50];
		else
			self.displayText	:=	pValue;
		endif;
	endif;
end;</source>
        <Parameter name="pValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="setEventDate" id="3039a3c1-410a-4ffc-bb10-7789c5057aa2">
        <updating/>
        <source>setEventDate(pValue: Date) updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Sets the date of a Calendar event.
//
// Parameters:	pValue - The date of the event.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

epilog	
	if self.eventDate &lt;&gt; pValue then 
		self.eventDate	:=	pValue;
		
		if self.isTransient() then
			self.originalDate	:=	pValue;
		endif;
	endif;
end;</source>
        <Parameter name="pValue" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setEventTime" id="c948f32d-954d-4770-93fe-8671bf884c71">
        <updating/>
        <source>setEventTime(pTime:Time) updating;
// --------------------------------------------------------------------------------
// Created:		22 May 2008 by cnwdad1
//
// Purpose:		Sets the time of a Calendar event.
//
// Parameters:	pTime - The time of the event.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

epilog	
	if self.eventTime &lt;&gt; pTime then 
		self.eventTime	:=	pTime;
	endif;
end;</source>
        <Parameter name="pTime" type="Time"/>
    </JadeMethod>
    <JadeMethod name="setMyCalendarControl" id="138f790e-82cc-4e10-93e4-33bc74139e2a">
        <updating/>
        <source>setMyCalendarControl(pCalendarObj : CnEcCalendarControl) updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2000 by cnwdad1
//
// Purpose:		Sets a reference to the event's Calendar control.
//
// Parameters:	pCalendarObj - The calendar control.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myCalendarControl &lt;&gt; pCalendarObj then
		self.myCalendarControl	:=	pCalendarObj;
	endif;
end;</source>
        <Parameter name="pCalendarObj" type="CnEcCalendarControl"/>
    </JadeMethod>
    <JadeMethod name="setRepeat" id="c7647a02-c220-436b-aa1f-b0b2ed7bf78e">
        <updating/>
        <source>setRepeat(pIsRepeat:Boolean; pRepeatEvery:Integer; pRepeatTerm:Integer; pRepeatTimes:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		20 May 2008 by cnwdad1
//
// Purpose:		Updates the receiver's repeat settings.
//
// Parameters:	pIsRepeat - True if the receiver is to be repeated.
//				pRepeatEvery - The frequency of the repeat.
//				pRepeatTerm - The term of the repeat (i.e. day month etc).
//				pRepeatTimes - The number of times to repeat (0 = forever).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
// adm 200509 Par 19207  change abstract exception class
begin
	if pIsRepeat then
		if pRepeatTerm &lt;&gt; self.REPEAT_DAY
		and pRepeatTerm &lt;&gt; self.REPEAT_MONTH
		and pRepeatTerm &lt;&gt; self.REPEAT_WEEK
		and pRepeatTerm &lt;&gt; self.REPEAT_YEAR
		then
			CnEcBaseSchemaException.raise_(CNEC_X_13999, "Invalid Repeat term - choose Day, Week, Month or Year.");
			return;
		endif;
		
		self.isRepeating	:=	true;
		self.repeatEvery	:=	pRepeatEvery;
		self.repeatTerm		:=	pRepeatTerm;
		self.repeatTimes	:=	pRepeatTimes;
	else
		self.isRepeating	:=	false;
		self.repeatEvery	:=	0;
		self.repeatTerm		:=	0;
		self.repeatTimes	:=	0;
	endif;
end;</source>
        <Parameter name="pIsRepeat" type="Boolean"/>
        <Parameter name="pRepeatEvery" type="Integer"/>
        <Parameter name="pRepeatTerm" type="Integer"/>
        <Parameter name="pRepeatTimes" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="ecb14f01-ec28-4985-bcdc-a81577887ed6">
        <updating/>
        <source>updateMe(pProxyObj: SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		06 June 2008 by cnwdad1
//
// Purpose:		Updates the receiver from a proxy object.
//
// Parameters:	pProxyObj - A reference to the proxy Calendar Event object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Set any non-key properties, and non-inverse references.
	
	self.isRepeating		:=	pProxyObj.isRepeating;
	self.repeatEvery		:=	pProxyObj.repeatEvery;
	self.repeatTerm			:=	pProxyObj.repeatTerm;
	self.repeatTimes		:=	pProxyObj.repeatTimes;
	
	// Set any key property values.
	
	self.displayText		:=	pProxyObj.displayText;
	self.eventTime			:=	pProxyObj.eventTime;
	
	if pProxyObj.originalDate &lt;&gt; null and pProxyObj.originalDate &lt;&gt; pProxyObj.eventDate then
		self.eventDate			:=	pProxyObj.originalDate;
	else
		self.eventDate			:=	pProxyObj.eventDate;
	endif;
	
	// Set any inverse references.
	
	self.associatedObject	:=	pProxyObj.associatedObject;
end;</source>
        <Parameter name="pProxyObj" type="SelfType"/>
    </JadeMethod>
</Class>
