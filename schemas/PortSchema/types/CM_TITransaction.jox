    <JadeMethod name="isReleaseType" id="fb1cab8a-1c04-4b10-81c9-542ba425040e">
        <source>isReleaseType(): Boolean;
// included in "Release type transactions are
//   CM_CompanyTransfer because companies can have different charging regimes

// THIS IS FOR STORAGE???

begin
	return type = TRANS_TYPE_RELEASE or
		type = TRANS_TYPE_REL_RAIL or
		type = TRANS_TYPE_REL_RAIL_INTER_TERM or
		type = TRANS_TYPE_REL_ROAD or
		type = TRANS_TYPE_REL_ROAD_INTER_TERM or
		type = TRANS_TYPE_REL_SHIP or
		type = TRANS_TYPE_DISASSEMBLY or
		type = TRANS_TYPE_REJECT or
		type = TRANS_TYPE_BUSINESS_U_RELEASE or
		type = TRANS_TYPE_REL_TRANSHIP or
		type = TRANS_TYPE_REL_ST_DEPOT_INT or
		type = TRANS_TYPE_REL_ST_MARINE_INT or
		type = TRANS_TYPE_REL_ST_WHOUSE_INT;
end;</source>
