    <JadeMethod name="doesTransactionExistForHold" id="e5d6b4c5-2c16-44a1-9d84-44a49ed4d7fc">
        <source>doesTransactionExistForHold(_start,_end :TimeStamp):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2018 cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data

*/
vars
	trans : CM_TITransaction;
begin

	foreach trans in self.myVoyage.allTITransactionsByDTType discreteLock do
		if trans.dateTime &gt; _start and trans.dateTime &lt;= _end then
			return true;
		endif;
	endforeach;
	 
	return false;
end;
</source>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_end" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getATForAMovement" id="cf15eb80-d278-43ed-860e-7cdcca98071b">
        <source>getATForAMovement(_movement: HMS_Movement): Real;
/*

Purpose: Will return the approach time for the movement to a physical or logical berth			

Parameters:			

Return Value:		

Date		Who		Reason
04 Apr 2019	jlggb1	Initial creation 43211
29 Apr 2019 jlggb1	44564 Movements without Work Orders have no timings - so ignore these (typically unassisted departures)

*/

vars
	moveTimings : HMS_MarineServicesTimings;

begin
	moveTimings := _movement.myMarineServiceTimings;
	if moveTimings = null then //44564 jlggb1 after testing 29/04 2019
		return 0;
	endif;

	if _movement.moveType = HMSMovementTypeArrival then
		return moveTimings.pilotActualTS.differenceInHoursReal(moveTimings.pilotFinishMoving);
	elseif _movement.moveType = HMSMovementTypeDeparture then
		return moveTimings.pilotStartsMoving.differenceInHoursReal(moveTimings.pilotOffboard);
	elseif _movement.moveType = HMSMovementTypeShift then
		if self.isToLogical(_movement) then // Physical to Logical and Logical to Logical
			return moveTimings.pilotStartsMoving.differenceInHoursReal(moveTimings.pilotOffboard);
		else
			if self.isFromLogical(_movement) then // Logical to Physical
				return moveTimings.pilotActualTS.differenceInHoursReal(moveTimings.pilotFinishMoving);
			else //Physical to Physical
				return moveTimings.pilotStartsMoving.differenceInHoursReal(moveTimings.pilotFinishMoving);
			endif;
		endif;
	endif;	
	return 0.0;
epilog

end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getHoldFromDelayDesc" id="7ad756b2-27d2-433d-8d35-2b65151f321c">
        <source>getHoldFromDelayDesc(_delay : CM_Delay):Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Dec 2018	cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data

*/

vars
	desc : String;
	holdStr :Integer;
begin
	desc 	:= _delay.getDescription(true);
	holdStr	:= (desc[desc.length-2 : desc.length]).Integer;
	return holdStr;
end;
</source>
        <Parameter name="_delay" type="CM_Delay"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getHoldFromShipLoc" id="194d4155-a986-4860-b727-dec1b8145d82">
        <source>getHoldFromShipLoc(_trans :CM_TITransaction;_shipLoc : String):Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Dec 2018	cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data

*/


vars
	hold 		: Integer;
	relShip     : CM_ReleaseShip;
 	recShip     : CM_ReceiveShip;
	structure   : CM_CellularVoyageStructure;
	lBayId,
	lStowageId  : String;
	is40        : Boolean;
	ti          : CM_TrackedItem;
	bay    		: CM_Bay ;
	foundLC		: CM_LocationsController;
	foundHeight	: Integer;
	theBay 		: CM_BayVoyage;
	
begin

	if _trans.isKindOf(CM_ReceiveShip) then
		recShip := _trans.CM_ReceiveShip;
	else
		relShip := _trans.CM_ReleaseShip;

	endif;
	ti        := _trans.myTrackedItem;
	structure := self.myVoyage.myCellularVoyageStructure;
	

	_trans.myTerminal.findLocationFromString(_shipLoc, false, foundLC, foundHeight);
	
	if foundLC.isKindOf(CM_GeneralCargoController) then
		return foundLC.CM_GeneralCargoController.hatch;
	elseif foundLC.isKindOf(CM_SlotController) then
		if foundLC.CM_SlotController.mySlotDefnVoyage &lt;&gt; null then
			theBay := 	foundLC.CM_SlotController.mySlotDefnVoyage.myBay.CM_BayVoyage;
		endif;
	endif;

	if structure.use40Id then
		if ti &lt;&gt; null then
			if ti.isAttributeTrue(TI_Attrib_IsForty) 
			or ti.isOverSizedContainer() then 
				is40 := foundLC.CM_SlotController.myBayVoyage.canHandle4045();
			endif;
		endif;
	endif;


	lStowageId := foundLC.CM_SlotController.mySlotDefnVoyage.getStowageId(is40, false);
	
	if theBay &lt;&gt; null then
		if is40 then
			if theBay.isAftBay 
			and not theBay.isForwardBay then 
				if theBay.myForwardBay &lt;&gt; null then
					lBayId := theBay.myForwardBay.idBay40;
				else
					lBayId := theBay.id;
				endif;
			else
				lBayId := theBay.idBay40;
			endif;
		else
			lBayId := theBay.id;
		endif;
	endif;
	lStowageId := lBayId;
	
	return lStowageId.Integer;
epilog

end;</source>
        <Parameter name="_trans" type="CM_TITransaction"/>
        <Parameter name="_shipLoc" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMaxCapcity" id="d1c39323-a710-4cee-a333-74b0a98406ee">
        <source>getMaxCapcity(_termArea : CM_TerminalArea):Real;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 Feb 2019	cnwma1	Bug 43211: PEL1 - Kinerja Issues/Changes

*/

vars
	gcMaxCapcity : Real;
begin
	if _termArea.isKindOf(CM_BlockStack) then
		
		gcMaxCapcity := _termArea.getMaxCapacity().Real;
	
	elseif _termArea.isKindOf(CM_IrregularBlockArea) then 
		
		if _termArea.CM_IrregularBlockArea.allLocationsControllers.first.CM_IrregularBlockController &lt;&gt; null then
			gcMaxCapcity := _termArea.CM_IrregularBlockArea.allLocationsControllers.first.CM_IrregularBlockController.maximumWeight;
		endif;
		
	else
		gcMaxCapcity := 1;
	endif;
	
	return gcMaxCapcity;
epilog

end;</source>
        <Parameter name="_termArea" type="CM_TerminalArea"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getPeriodDays" id="c4c60ed6-2b78-46da-8922-6cdf195a5aa4">
        <source>getPeriodDays(_startDate,_endDate : Date):Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 Sep 2018 cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data

*/

vars
	days : Integer;
begin
	days := ( _endDate - _startDate).Integer;
	
	return days;
epilog

end;</source>
        <Parameter name="_startDate" type="Date"/>
        <Parameter name="_endDate" type="Date"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalBoxContainer" id="2ba55558-318d-4288-8717-8d0e52ddabe1">
        <updating/>
        <source>getTotalBoxContainer(_objArr : ObjectArray):Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 Jan 2019	cnwma1	Bug 42895: PEL1 - Kinerja Change for fields

*/

vars
	box    ,
	tmpBox  : Integer;
	obj     : Object;
	shipLoc : String;
begin
	if _objArr = null then
		return null;
	endif;
	
	foreach obj in _objArr do 
		
		if  obj.CM_TITransaction.myTrackedItem.myCargoType.abbreviation = "CONT" then
			box := 	box + 1;
		endif;
	endforeach;
	
	return 	box;
epilog

end;</source>
        <Parameter name="_objArr" type="ObjectArray"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalContainers" id="91b283e7-8f0a-4e36-95e9-0cddafc8abc0">
        <source>getTotalContainers(_objArr : ObjectArray) : Real;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 February 2019	jlgma1	Initial creation

*/

vars
	teu : Real;
	obj : Object;
	ti  : CM_TrackedItem;
begin
	if _objArr = null then
		return null;
	endif;

	foreach obj in _objArr discreteLock do 
		ti := obj.CM_TITransaction.myTrackedItem;
		
		if  ti.isKindOf(CM_Container) then
			teu := 	teu + ti.getNumTEU ;
		endif;
	endforeach;
	
	return 	teu;
epilog

end;
</source>
        <Parameter name="_objArr" type="ObjectArray"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTotalTEUConatiner" id="6c01afb3-5940-46f2-a7da-9f138bf91972">
        <updating/>
        <source>getTotalTEUConatiner(_moveTrans : ObjectArray;_movement : HMS_Movement ;_delay : CM_Delay;_start ,_end :TimeStamp):Real updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Dec 2018	cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data

*/

vars
	teu    	  : Real;
	obj       : Object;
	shipLoc   : String;
	cargoType : CM_CargoType; 
	ti        : CM_TrackedItem;
begin
	if _moveTrans = null then
		return null;
	endif;

	foreach obj in _moveTrans discreteLock do 
		
		if obj.isKindOf(CM_ReleaseShip) then
			shipLoc := obj.CM_ReleaseShip.locationShip;
		elseif obj.isKindOf(CM_ReceiveShip) then
			shipLoc := obj.CM_ReceiveShip.locationShip;
		endif;
		
		cargoType := obj.CM_TITransaction.myTrackedItem.myCargoType ;
		ti 		  := obj.CM_TITransaction.myTrackedItem;
		if  cargoType.abbreviation = "CONT" or cargoType.abbreviation = "BBCONT"   then
			if obj.CM_TITransaction.dateTime &gt;= _start and obj.CM_TITransaction.dateTime &lt;= _end then
				if self.getHoldFromShipLoc(obj.CM_TITransaction,shipLoc) = self.getHoldFromDelayDesc(_delay) then
						
				/*	write  _delay.getDescription(false)
						&amp; Tab &amp; ti.id
						&amp; Tab &amp; shipLoc
						&amp; Tab &amp; "Teu : " &amp; ti.getNumTEU.String
						&amp; Tab &amp; obj.CM_TITransaction.dateTime.String 
						&amp; Tab &amp; obj.CM_TITransaction.id  
						&amp; Tab &amp; cargoType.abbreviation
						&amp; Tab &amp; shipLoc  
						&amp; Tab &amp; obj.CM_TITransaction.totalWeight.String 
						&amp; Tab &amp; self.getHoldFromDelayDesc(_delay).String  
						&amp; Tab &amp; self.getHoldFromShipLoc(obj.CM_TITransaction,shipLoc).String;*/
						
					if obj.isKindOf(CM_ReleaseShip) or obj.isKindOf(CM_ReceiveShip)  then
						
						teu := teu + ti.getNumTEU();
					endif;
				endif;
			endif;
		endif;
	endforeach;
	//write "Total Teu : " &amp; teu.String;
	return 	teu;
epilog

end;</source>
        <Parameter name="_moveTrans" type="ObjectArray"/>
        <Parameter name="_movement" type="HMS_Movement"/>
        <Parameter name="_delay" type="CM_Delay"/>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_end" type="TimeStamp"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTotalWTAtBerth" id="bf314363-4779-4200-87d8-1bbecf5ffc63">
        <updating/>
        <source>getTotalWTAtBerth(_movement : HMS_Movement;_type :Integer):Real updating;



/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2018	cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data

*/

vars
	tot	  	   	      : Real;
	totTeu            : Real;
	trans      		  : CM_TITransaction;
	voyage 			  : CM_Voyage;
	servTimeMoveNext  : HMS_MarineServicesTimings;
	cargoType         : CM_CargoType;
	ti                : CM_TrackedItem;                
begin

	voyage := _movement.getVoyage();
	
	if _movement.myNextMovement &lt;&gt; null then
		servTimeMoveNext := _movement.myNextMovement.myMarineServiceTimings;
	endif;
	
	if servTimeMoveNext &lt;&gt; null then
		
		write "MoveType:" 
			&amp; Tab &amp; _movement.getMoveTypeName 
			&amp; Tab &amp; "Berth:"
			&amp; Tab &amp; _movement.getBerthToBerthDescription
			&amp; Tab &amp; "occursOnDT:"
			&amp; Tab &amp; _movement.occursOnDTNEW.asStringJMT
			&amp; Tab &amp; "pilotActualTS:"
			&amp; Tab &amp; servTimeMoveNext.pilotActualTS.asStringJMT;

		foreach trans in voyage.allTITransactionsByDTType discreteLock do
			if trans.dateTime &gt;= _movement.occursOnDTNEW and trans.dateTime &lt;= servTimeMoveNext.pilotStartsMoving then
				cargoType := trans.myTrackedItem.myCargoType;
				ti        := trans.myTrackedItem;
				write "Found Inside Period :" &amp; trans.dateTime.String
				&amp; Tab &amp; "Trans Type :" &amp; trans.getTypeString
				&amp; Tab &amp; "Cargo Type :" &amp; cargoType.abbreviation
				&amp; Tab &amp; "Cargo ID : "  &amp; ti.id;
				if trans.isKindOf(CM_ReleaseShip) or trans.isKindOf(CM_ReceiveShip) then			
					
					if _type = self.BTP_CONTAINER then
						if  cargoType.abbreviation.isOneOf("CONT","BBCONT") then
							tot := tot + ti.getNumTEU();
						endif;
					elseif _type = self.BTP_NONCONTAINER then
						if not cargoType.abbreviation.isOneOf("CONT","BBCONT") then
							tot := tot + trans.totalWeight;
						endif;
					endif;
					
				endif;
			endif;
		endforeach;
			
		write " Berth Total WT : " &amp; tot.String;
	endif;
	return tot;
epilog
	
end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTotalWTProdLiquid" id="67ed6cdc-ee82-4b21-a9e0-3cabead1bdfa">
        <updating/>
        <source>getTotalWTProdLiquid(_moveTrans : ObjectArray;_movement : HMS_Movement ;_delay : CM_Delay;_start ,_end :TimeStamp):Real updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2018	jlgma1	Initial creation

*/

vars
	wt    ,
	tmpwT   	: Real;
	obj     	: Object;
	shipLoc 	: String;
	cargoType   : CM_CargoType;
begin
	if _moveTrans = null then
		return null;
	endif;

	foreach obj in _moveTrans discreteLock do 
		if obj.isKindOf(CM_ReleaseShip) then
			shipLoc := obj.CM_ReleaseShip.locationShip;
		elseif obj.isKindOf(CM_ReceiveShip) then
			shipLoc := obj.CM_ReceiveShip.locationShip;
		endif;
		
		cargoType := obj.CM_TITransaction.myTrackedItem.myCargoType;
		
		if  cargoType.abbreviation = "CC" or cargoType.abbreviation = "CC02" then
			
			if obj.CM_TITransaction.dateTime &gt;= _start and obj.CM_TITransaction.dateTime &lt;= _end then
				if self.getHoldFromShipLoc(obj.CM_TITransaction,shipLoc) = self.getHoldFromDelayDesc(_delay) then
					/*write _delay.getDescription(true)
						&amp; Tab &amp; obj.CM_TITransaction.dateTime.String 
						&amp; Tab &amp; obj.CM_TITransaction.id 
						&amp; Tab &amp; cargoType.abbreviation
						&amp; Tab &amp; shipLoc  
						&amp; Tab &amp; obj.CM_TITransaction.totalWeight.String 
						&amp; Tab &amp; self.getHoldFromDelayDesc(_delay).String 
						&amp; Tab &amp; self.getHoldFromShipLoc(obj.CM_TITransaction,shipLoc).String;*/
					
					tmpwT := 0;
					if obj.isKindOf(CM_ReleaseShip)  then
						tmpwT:= obj.CM_ReleaseShip.totalWeight;
						wt := wt + tmpwT;
					elseif obj.isKindOf(CM_ReceiveShip) then
						tmpwT:= obj.CM_ReceiveShip.totalWeight;
						wt := wt + tmpwT;
					endif;
				endif;
			endif;
		endif;
	endforeach;
	
	return wt;
epilog

end;</source>
        <Parameter name="_moveTrans" type="ObjectArray"/>
        <Parameter name="_movement" type="HMS_Movement"/>
        <Parameter name="_delay" type="CM_Delay"/>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_end" type="TimeStamp"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTotalWTProduktvitas" id="98741473-44cb-4434-b772-56f760c9a961">
        <updating/>
        <source>getTotalWTProduktvitas(_moveTrans : ObjectArray;_movement : HMS_Movement ;_delay : CM_Delay;_start ,_end :TimeStamp):Real updating;
/*

Purpose:			
	

Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2018 cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data

*/
vars
	wt,
	tmpwT     : Real;
	obj       : Object;
	shipLoc   : String;
	cargoType : CM_CargoType;
begin
	if _moveTrans = null then
		return null;
	endif;

	foreach obj in _moveTrans discreteLock do 

		if obj.isKindOf(CM_ReleaseShip) then
			shipLoc := obj.CM_ReleaseShip.locationShip;
		elseif obj.isKindOf(CM_ReceiveShip) then
			shipLoc := obj.CM_ReceiveShip.locationShip;
		endif;
		cargoType := obj.CM_TITransaction.myTrackedItem.myCargoType;
		if  cargoType.abbreviation = "CK"  or cargoType.abbreviation = "GC01"  or
			cargoType.abbreviation = "GC02"or cargoType.abbreviation = "HW"    or 
			cargoType.abbreviation = "VEHICLE"  then
			if obj.CM_TITransaction.dateTime &gt;= _start and obj.CM_TITransaction.dateTime &lt;= _end then
				if self.getHoldFromShipLoc(obj.CM_TITransaction,shipLoc) = self.getHoldFromDelayDesc(_delay) then
						
						/*write _delay.getDescription(true)
						&amp; Tab &amp; obj.CM_TITransaction.dateTime.String 
						&amp; Tab &amp; obj.CM_TITransaction.id  
						&amp; Tab &amp; cargoType.abbreviation
						&amp; Tab &amp; shipLoc  
						&amp; Tab &amp; obj.CM_TITransaction.totalWeight.String 
						&amp; Tab &amp; self.getHoldFromDelayDesc(_delay).String 
						&amp; Tab &amp; self.getHoldFromShipLoc(obj.CM_TITransaction,shipLoc).String;*/
						
						tmpwT := 0;
						if obj.isKindOf(CM_ReleaseShip) then
							tmpwT:= obj.CM_ReleaseShip.totalWeight;
							wt := wt + tmpwT;
						elseif obj.isKindOf(CM_ReceiveShip) then
							tmpwT:= obj.CM_ReceiveShip.totalWeight;
							wt := wt + tmpwT;
						endif;
				endif;
			endif;
		endif;
	endforeach;
	
	return wt;
epilog

end;</source>
        <Parameter name="_moveTrans" type="ObjectArray"/>
        <Parameter name="_movement" type="HMS_Movement"/>
        <Parameter name="_delay" type="CM_Delay"/>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_end" type="TimeStamp"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTransactionsPerMovement" id="83b94102-4bae-4941-addd-6f7794009d1f">
        <source>getTransactionsPerMovement(_movement : HMS_Movement):CM_ObjectArray;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 Nov 2018	cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data
27 Feb 2018 cnwma1	Bug 43211: PEL1 - Kinerja Issues/Changes    
*/

vars
	objArr 			 : CM_ObjectArray;
	trans  			 : CM_TITransaction;
	voyage			 : CM_Voyage;
	servTimeMoveNext : HMS_MarineServicesTimings;
begin

	voyage := _movement.getVoyage();
	
	if _movement.myMarineServiceTimings &lt;&gt; null then
		if _movement.myNextMovement &lt;&gt; null then
			servTimeMoveNext := _movement.myNextMovement.myMarineServiceTimings;
		endif;
		
		if servTimeMoveNext &lt;&gt; null then
			if not voyage.allTITransactionsByDTType.isEmpty then
				if servTimeMoveNext.pilotActualTS &lt;&gt; null then		
					create objArr transient;
					foreach trans in voyage.allTITransactionsByDTType discreteLock do
						
						//if trans.dateTime &gt;= servTimeMove.movementBerthArrival and   trans.dateTime &lt;= servTimeMoveNext.movementActualTS then  //27.02.2019 cnwma1 #43211
						if trans.dateTime &gt;= _movement.occursOnDTNEW and trans.dateTime &lt;= servTimeMoveNext.pilotStartsMoving then               //27.02.2019 cnwma1 #43211
							if trans.isKindOf(CM_ReceiveShip) or trans.isKindOf(CM_ReleaseShip) then
								objArr.add(trans);
							endif;
						endif;
					endforeach;
				endif;
			endif;
		endif;
	endif;
	return objArr;
epilog

end;
</source>
        <Parameter name="_movement" type="HMS_Movement"/>
        <ReturnType type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getWHoldsCount" id="a1cc2352-358a-4dd8-ad89-57b99e041d8a">
        <source>getWHoldsCount(_movement : HMS_Movement; _startMove ,_endMove : TimeStamp):Integer;

/*

Purpose:			


Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2018 cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data

*/
vars
	cnt : Integer;
	delayBwT :CM_Delay;
begin
	foreach delayBwT in _movement.getMyVoyage.allDelays discreteLock do
	
		if delayBwT.getDelayTypeGroupDesc = "STARTENDOPR" then
			if delayBwT.startDT &gt;= _startMove and delayBwT.endDT &lt;= _endMove then
				if self.doesTransactionExistForHold(delayBwT.startDT ,delayBwT.endDT) then
					 cnt :=  cnt +1;
				endif;
			endif;
		endif;
	endforeach;
	return cnt;
end;
</source>
        <Parameter name="_movement" type="HMS_Movement"/>
        <Parameter name="_startMove" type="TimeStamp"/>
        <Parameter name="_endMove" type="TimeStamp"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isFirstPhysicalMovement" id="0574f77c-3b6c-49ea-a690-37ebf60ddfb4">
        <source>isFirstPhysicalMovement(_movement : HMS_Movement): Boolean;
/*

Purpose:	Checks if aren't any previous movements to a physical wharf		

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2019	jlggb1	Initial creation

*/

vars
	prevMove : HMS_Movement;
begin
	if self.isToLogical(_movement) then //jlggb1 WT sometimes calculated for arrival
		return false;
	endif;
	prevMove := _movement.myPreviousMovement;
	while prevMove &lt;&gt; null do
		if self.isToPhysical(prevMove) then
			return false;
		endif;
		prevMove := prevMove.myPreviousMovement;
	endwhile;
	return true;
end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isFromLogical" id="4e1d08a5-9a59-4a95-901a-05745069e1de">
        <source>isFromLogical(_movement : HMS_Movement): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Feb 2019	jlgma1	Initial creation
04 Apr 2019	jlggb1	New Approach to Approach 	
*/
begin
	return not self.isFromPhysical( _movement );
end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isFromPhysical" id="01066e40-a152-4b62-a1e8-d8776d799276">
        <source>isFromPhysical(_movement : HMS_Movement): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Feb 2019	jlgma1	Initial creation
04 Apr 2019	jlggb1	New Approach to approach 43211
*/

vars

begin
	return _movement.myPreviousMovement &lt;&gt; null and not _movement.myPreviousMovement.getMyWharf.isLogicalWharf;
end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLastPhysicalMovement" id="a01ac3e6-9688-4dfc-a045-d18886b3add5">
        <source>isLastPhysicalMovement(_movement : HMS_Movement): Boolean;
/*

Purpose:	Checks if there are any following movements to a physical wharf		

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2019	jlggb1	Initial creation

*/

vars
	nextMove : HMS_Movement;
begin
	nextMove := _movement.myNextMovement;
	while nextMove &lt;&gt; null do
		if self.isToPhysical(nextMove) then
			return false;
		endif;
		nextMove := nextMove.myNextMovement;
	endwhile;
	return true;
end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isToLogical" id="a456dc39-9352-4557-bd43-2cec733df2ac">
        <source>isToLogical(_movement : HMS_Movement): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Feb 2019	jlgma1	Initial creation
04 Apr 2019	jlggb1	New Approach to Approach 	

*/
begin
	return not self.isToPhysical(_movement);
end;</source>
        <Parameter name="_movement" type="HMS_Movement"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isToPhysical" id="dd40371b-e725-4761-b2b3-f90dc2fe2c12">
        <source>isToPhysical(_movement : HMS_Movement): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Feb 2019	jlgma1	Initial creation
04 Apr 2019	jlggb1	New approach to Approach Times
*/
begin
	return not _movement.getMyWharf.isLogicalWharf;
end;</source>
