        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDateSearch" id="f801a30a-26b4-497e-8fce-79ab5942bec2">
        <updating/>
        <source>doDateSearch() protected, updating;
//  CCMS 1262 Feb 2012 transaction enquiry and selector queries
//11/07/2025	naviv1	MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
vars
	iteratorObj		: Iterator;
	transObj		: CM_EventTransaction;
	keyTimeStamp	: TimeStamp;
	breakOut		: Boolean;
	passport		: CM_Passport;
	
begin
	passport := app.myPassport;
	
	iteratorObj	:=	myTerminal.allEventsByDateTime.createIterator();
	myTerminal.allEventsByDateTime.startKeyGeq(self.startDateTime, iteratorObj);
	
	while iteratorObj.next(transObj) do

		iteratorObj.getCurrentKeys(keyTimeStamp);  //MTN-35226
		
		if (self.endDateTime &lt;&gt; null and keyTimeStamp &gt; self.endDateTime) then
			break;
		endif;
		
		if self.includesObject(transObj, breakOut, passport) then
			self.addObjectToSet(transObj);
		endif;
			
		if breakOut or self.breakOutOfSearch then
			break;
		endif;
	endwhile;
epilog
	delete iteratorObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEventSearch" id="6564f226-f39c-4738-adc4-57abda03a37a">
        <updating/>
        <source>doEventSearch(_type : Integer) protected, updating;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
// 11/07/2025 naviv1	MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
vars
	iteratorObj		: Iterator;
	transObj		: CM_EventTransaction;
	keyTimeStamp	: TimeStamp;
	keyType			: Integer;
	breakOut		: Boolean;
	passport		: CM_Passport;
	
begin
	passport := app.myPassport;
	
	iteratorObj	:=	myTerminal.allEventsByTypeDateTime.createIterator();
	myTerminal.allEventsByTypeDateTime.startKeyGeq(_type, self.startDateTime, iteratorObj);
	
	while iteratorObj.next(transObj) do
		iteratorObj.getCurrentKeys(keyType,keyTimeStamp);  //MTN-35226
		
		if (keyType &lt;&gt; _type) or
		   (self.endDateTime &lt;&gt; null and keyTimeStamp &gt; self.endDateTime) then
			break;
		endif;
		
		if self.includesObject(transObj, breakOut, passport) then
			self.addObjectToSet(transObj);
		endif;
			
		if breakOut or self.breakOutOfSearch then
			break;
		endif;
	endwhile;
epilog
	delete iteratorObj;
end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doQuery" id="8f4f7c1b-c0ba-46da-862f-4ee3d16c47b3">
        <updating/>
        <source>doQuery(_qDef: CM_QueryDefinition) updating;
//  CCMS 1262 Feb 2012 transaction enquiry and selector queries
// top-level search by terminal then either date or event type
vars
	now				: TimeStamp;
	crit			: CM_SelectorCriteriaLine;
	termSet			: CM_TerminalSet;
	ut				: CM_UserTerminal;
	tranType		: CM_TransactionType;
	term			: CM_Terminal;
begin

	self.reset();
	now := app.actualTimeServer();
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_EventTransaction::dateTime.name, _qDef.className];	//06 Sep 2019	NDl	TFS 45891
	if crit &lt;&gt; null then
		if crit.myQueryOperator.isKindOf(CM_QDateEquals) then
			self.startDateTime := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.endDateTime := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.endDateTime.setTime('23:59:59:999'.Time);
		elseif crit.myQueryOperator.isKindOf(CM_QDateGreaterThan) then
			self.startDateTime := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.endDateTime := now;
		elseif crit.myQueryOperator.isKindOf(CM_QDateLessThan) then
			self.endDateTime := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.endDateTime.setTime('23:59:59:999'.Time);
			self.startDateTime := null;
		elseif crit.myQueryOperator.isKindOf(CM_QDateRange) then
			self.startDateTime := crit.myQueryOperator.CM_QDateRange.getSearchValueFromDate().TimeStamp;
			self.endDateTime := crit.myQueryOperator.CM_QDateRange.getSearchValueToDate().TimeStamp;
			self.endDateTime.setTime('23:59:59:999'.Time);
		endif;
	endif;
	
	create termSet transient;	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName['myTerminal', _qDef.className];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(termSet);
	else
		foreach ut in app.myPassport.myUser.allUserTerminals do
			termSet.add(ut.getMyTerminal);
		endforeach;
	endif;

	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName['myEventType', _qDef.className];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(self.eventTypes);
	endif;

	if not termSet.isEmpty then
		foreach term in termSet do
			self.myTerminal := term;
			self.doSearch;
		endforeach;
	endif;
	
epilog
	endLoad;
	delete termSet;
end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="e46ea8cb-c376-4804-aa64-b98e052c3c21">
        <updating/>
        <source>doSearch() updating, protected;
//  CCMS 1262 Feb 2012 transaction enquiry and selector queries
vars
	eventType	: CM_EventType;
begin
	if not self.eventTypes.isEmpty() then
		foreach eventType in self.eventTypes do
			self.doEventSearch(eventType.type); 
		endforeach;
	else
		self.doDateSearch();
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="reset" id="4859c6cd-5be1-4206-946c-91ff2c864c52">
        <updating/>
        <source>reset() updating;
//  CCMS 1262 Feb 2012 transaction enquiry and selector queries
vars

begin
	inheritMethod();
	
	self.myTerminal := null;
	self.startDateTime := null;
	self.endDateTime := null;
	self.eventTypes.clear();
end;
</source>
    </JadeMethod>
    <JadeMethod name="setMyFilterClass" id="a4c80c28-e18f-4e90-9332-55cfd49e49e1">
        <updating/>
        <source>setMyFilterClass() updating;
//  CCMS 1262 Feb 2012 transaction enquiry and selector queries
vars

begin
	self.myFilterClass := CM_EventTransaction;

end;</source>
    </JadeMethod>
</Class>
