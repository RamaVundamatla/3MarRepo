    <JadeMethod name="doBuildMnuTasksAdd" id="bfd17137-8ea7-4e85-ba0c-dbedaeac0ac4">
        <updating/>
        <source>doBuildMnuTasksAdd(_theTI : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	dynaDict	: DynaDictionary;
	obj			: Object;
	taskDesc	: CM_ToDoTaskDesc;
	mnuChild,mnuMaster	: MenuItem;
	taskDict		: CM_ToDoTaskDescByCode;
	useTaskForm : Boolean;
	
begin

	//07 Oct 2015	NDL	Par 37011
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;
	if useTaskForm then
		self.mnuTaskAdd.visible := false;
		return;
	endif;
	
	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForTerm(self.myTerminal, taskDict);
	if taskDict.isEmpty then
		// no permission to add any tasks
		self.mnuTaskAdd.visible := false;
		return;
	endif;
	
	// ##############################################
	// Build up menu of ToDo Tasks that can be set
	mnuMaster := self.mnuTaskAdd;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.caption :=  app.getErrorString(Tasks_ADDDDdd); 	//"Add Tasks";
	self.mnuTaskAddSub.visible := true;

	// 36868 sort menu items by sortKey then description, so that if there is no sort key or it is not unique then the description becomes the main sort field
	create dynaDict transient;
	dynaDict.setMembership(CM_ToDoTaskDesc);
	dynaDict.addMemberKey("sortKey", false, true);
	dynaDict.addMemberKey("description", false, true);
	dynaDict.endKeys(true);
	
	foreach taskDesc in taskDict do
		dynaDict.add(taskDesc);
	endforeach;
	
	foreach obj in dynaDict do
		taskDesc := obj.CM_ToDoTaskDesc;
		// Always delete the tasks to complete menu
		mnuChild := mnuTaskComplete.getMenuItem(taskDesc.code); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;

		if taskDesc.description = null then 
			continue;
		endif;
		
			// DVB added to screen for cargo type.
		if not taskDesc.isAvailableForCargoType(_theTI.cargoType) then
			continue;
		endif;
		
		// add each todo task type into the add menu
		mnuChild := mnuMaster.getMenuItem(taskDesc.code); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
		self.mnuTaskAddSub.visible := false;
		mnuChild := mnuMaster.loadSubMenu(taskDesc.code); // Clone menu
		mnuChild.caption := taskDesc.description;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := taskDesc.description;
		mnuChild.userObject := _theTI;
	endforeach;
epilog
	delete taskDict;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTasksComplete" id="042229f4-6ae7-4877-8d1d-cae0dcd4321a">
        <updating/>
        <source>doBuildMnuTasksComplete(_theTI : CM_TrackedItem) updating, protected;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	task	: CM_ToDoTask;
	taskDesc	: CM_ToDoTaskDesc;
	idx	: Decimal[3,1];
	lFactor : Real;
	lIndex,lMoveMode : Integer;
	lCaption	: String;
	mnuChild,mnuMaster	: MenuItem;
	mnuIndex 	: Integer;
	lPicture : Picture;
	root : CM_Root;
	useTaskForm : Boolean;

begin

	//07 Oct 2015	NDL	Par 37011
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;
	if useTaskForm then
		self.mnuTaskComplete.visible := false;
		return;
	endif;
	
	// ##############################################
	// Build up menu of ToDo Tasks that have been set, but are uncomplete
	mnuMaster := self.mnuTaskComplete;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.caption := "Complete Tasks";
	self.mnuTaskCompleteSub.visible := true;
	self.mnuTaskCompleteSub.caption := "No Tasks";
	
	foreach task in _theTI.allToDoTasksToDo do
	
		// Hide the todo tasks inthe add menu that we already have to do
		mnuChild := self.mnuTaskAdd.getMenuItem(task.toDoTaskDescCode); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			mnuChild.visible := false;
		endif;
		
		// create a list of the todo tasks that we have to do
		mnuChild := mnuMaster.getMenuItem(task.toDoTaskDescCode); // check if the menu is already cloned
		// always delete as this is different for each TI
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
		self.mnuTaskCompleteSub.visible := false;
		mnuChild := mnuMaster.loadSubMenu(task.toDoTaskDescCode); // Clone menu
		mnuChild.caption := task.toDoTaskDescDesc;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := task.toDoTaskDescDesc;
		mnuChild.userObject := _theTI;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTblObj" id="ce0593a4-bbdb-4dd3-8b40-2c948eea4820">
        <updating/>
        <source>doBuildMnuTblObj(_wle : CM_WorkListEntry) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/01/2013	cnwdap1		PAR #31018 CCMS POL 2223 added menu item to disconnect reefers
// 19/10/2022	jlizm1		TFS 54118 Assigning Releases to Wagons
// ---------------------------------------------------------------------------

vars
	lReq : CM_Request;
	tiId : String;
begin

	if _wle = null then
		self.doBuildMnuNullObj();
		return;
	endif;
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	lReq := _wle.myRequest;
	
	if self.myCurrentWLE &lt;&gt; _wle then		
		self.tblWLEChange(self.tblWorkEntries.row);
	endif;
	/*self.myCurrentTrackedItem := _wle.myTrackedItem;
	self.myCurrentWLE := _wle;*/
		
	self.mnuContextTable.enabled := true;
	self.mnuSource.visible := false;
	self.mnuAdditional.visible := false;
	self.mnuComplete.visible := false;			
	self.mnuRebuildWLEStatus.visible := false;
	self.mnuRebuildWLEStatus.userObject := null;
	self.mnuMoveIt.visible := true;
	self.mnuQueue.visible := true;	
	
	self.mnuEnquire.visible := false;
	self.mnuEnquire.userObject := null;				
	self.mnuAllocateTI.visible := false;
	self.mnuEdit.visible := false;
	self.mnuPackUnpack.visible := false;
	self.mnuRemarks.visible := false;
	self.mnuRemarks.userObject := null;	
	self.mnuDisconnect.visible := false;				// PAR #31018
	self.mnuDisconnect.userObject := null;				// PAR #31018
	self.mnuAssignRelWagon.visible := false; 
	self.mnuAssignRelWagon2.visible := false;
	self.mnuWagonAssignBulk.visible := false;	//23 Feb 2017	NDL	TFS 3514
	//process.isCCMS1935; 	//12 May 2010 NDL	Otago CCMS 1935 testing... //cnwrd1 par 24169 11/6/2010
	self.mnuAssignRelWagonAndQ.visible := false;	//11 may 2010	NDL	Otago CCMS 1935 in testing...
	self.mnuAssignRelWagonAndQ2.visible := false;	//11 may 2010	NDL	Otago CCMS 1935 in testing...
	self.mnuUnAssignRelWagon.visible := false; 
	self.mnuUnAssignRelWagon2.visible := false; 
	self.mnuAssignToTBA.visible := false;
	
	

	if self.myCurrentTrackedItem &lt;&gt; null then
		tiId := self.myCurrentTrackedItem.id;
		self.mnuEnquire.visible := true;
		self.mnuEnquire.caption := "Enquire on " &amp; tiId &amp; '...';
		self.mnuRemarks.visible := true;
		self.mnuRemarks.caption := "Edit remarks for " &amp; tiId &amp; '...';
		self.mnuRemarks.userObject := self.myCurrentTrackedItem;
		if self.myCurrentTrackedItem.myMatchedTBA &lt;&gt; null and self.myCurrentTrackedItem.myPrimaryQueuedLocation = null then // PAR 35574
			self.mnuAssignToTBA.visible := true; 
		endif;
		if self.myCurrentTrackedItem.getOnPower and self.myCurrentTrackedItem.getOnPowerDuringTransit then	// PAR #31018
			self.mnuDisconnect.visible := true;																// PAR #31018
			self.mnuDisconnect.caption := "Disconnect " &amp; tiId &amp; "...";										// PAR #31018
			self.mnuDisconnect.userObject := self.myCurrentTrackedItem;										// PAR #31018
		endif;																								// PAR #31018
	endif;
			
	if CM_DeliveryRequest.hasInstance(lReq) then
		// cnwjre1 May 2011 27097 use combined edit form for remarks, additional info and source
		//self.mnuAdditional.visible := true;
		//self.mnuAdditional.userObject := lReq;
		//self.mnuSource.visible := true;
		self.mnuRemarks.visible := true;
		//self.mnuRemarks.caption := "Edit remarks for " &amp; lReq.myJob.jobId &amp; '...';
		self.mnuRemarks.caption 	:= "Edit Request Details for " &amp; lReq.myJob.jobId &amp; '...';
		self.mnuRemarks.userObject := lReq;
	endif;
	
	self.mnuDeleteCurrentEntry.visible := false;
	self.mnuTurnAround.visible := false;
	self.mnuProcessRoadExit2.visible := false;
	self.mnuSetTargetLocn.visible := false;	
	self.mnuReturnWorkEntry.visible := false;
	self.mnuAddDeliveryRequest.visible := false;
	self.mnuAddDeliveryRequest.userObject := null;					
	
	self.doBuildMnuTblWle(_wle);

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTblWle" id="138d8fc0-4fbe-42b0-bac6-7d8ed8dadcad">
        <source>doBuildMnuTblWle(_wle : CM_WorkListEntry);
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 14/12/2010	cnwdap1		PAR #26426 CCMS MES 1102 Don't show UnAssign Cargo menu if wle's TI is a TBA
// 25/01/2013	cnwdap1		PAR #31018 Added menu item to disconnect reefers received on power
vars
	job : CM_Job;
	req	: CM_Request;
	reqType : Integer;
begin

	job 	:= _wle.job;
	req 	:= _wle.myRequest;
	reqType := _wle.getRequestType();
	
	if job = null then
		job := req.myJob;
	endif;

	self.mnuAutoplan.visible := true;	
	self.mnuProcessRoadExit2.visible := false;
	self.mnuRebuildWLEStatus.visible := true;
	self.mnuRebuildWLEStatus.userObject := job;
	self.mnuUnassignTI.visible := false;
	self.mnuAutoplanTrain.visible := false;
	self.mnuDeleteCurrentWLE.visible := false;	//18 Nov 2009	NDL	Par 21519
	
	if reqType = REQ_TI_RECEIPT and
	   req.isKindOf(CM_TIRequest) and
	   _wle.queue = null then
		self.mnuTurnAround.visible := true;
	endif;	
	
	if _wle.isKindOf(CM_WOToDoWLE) then
		self.mnuDeleteCurrentEntry.visible := false;
		if _wle.status = WLE_UNACTIONED and (not req.CM_ToDoRequest.isComplete) then
			self.mnuComplete.visible := true;				
			self.mnuComplete.caption := 'Complete Task';	
		endif;
	elseif _wle.status = WLE_COMPLETED then
		self.mnuDeleteCurrentEntry.visible := true;
		self.mnuAutoplan.visible := false;
		//self.mnuQueue.visible := false;
		//self.mnuMove.visible := false;
	endif;
	
	if _wle.status = WLE_UNACTIONED then
		self.mnuDeleteCurrentEntry.visible := true;			
		if req.isKindOf(CM_DeliveryRequest) then
			// cnwjre1 May 2011 27097, single edit form for remarks, additional info and source
			//self.mnuAdditional.visible := true;
			//self.mnuAdditional.userObject := req;			
			self.mnuSource.visible := true;
			self.mnuSource.userObject := req;
		endif;
	else
		self.mnuSource.visible := false;
		self.mnuSource.userObject := null;						
		self.mnuAdditional.visible := false;
		self.mnuAdditional.userObject := null;			
	endif;
	
	//Autoplan iso release
	if _wle.allRTQueueEntries.isEmpty and  _wle.status = WLE_UNACTIONED then
		if reqType = REQ_ISO_RELEASE and _wle.myTrackedItem &lt;&gt; null and not _wle.myTrackedItem.isTBAorIsRRP then	// PAR #26426
			self.mnuUnassignTI.visible := true;	
		endif;
	endif;

	if job &lt;&gt; null then
		if job.jobType = BOLType_Log then
			if _wle.myBOL &lt;&gt; null and
			   _wle.myBOL.isKindOf(CM_BOLIn) then
				self.mnuEnquire.visible := true;
				self.mnuEnquire.caption := 'Enquire ' &amp; _wle.myBOL.number &amp; '...';		
			else
				self.mnuEnquire.visible := false;
			endif;
			self.mnuRemarks.visible := false;
			self.mnuRemarks.userObject := null;			
			self.mnuDisconnect.visible := false;			// PAR #31018
			self.mnuDisconnect.userObject := null;			// PAR #31018
			self.mnuAdditional.visible := false;
			self.mnuSetTargetLocn.visible := false;		
			self.mnuDeleteCurrentEntry.visible := false;

		elseif job.status &lt;&gt; JOB_COMPLETE
		and CM_DeliveryRequest.hasInstance(req) then
			self.mnuAddDeliveryRequest.visible := true;
			self.mnuAddDeliveryRequest.userObject := req;											
		endif;
	endif;
	
	if self.myCurrentTrackedItem &lt;&gt; null then
		self.mnuEnquire.visible := true;
		self.mnuRemarks.visible := true;
		self.mnuRemarks.userObject := self.myCurrentTrackedItem;	
		if self.myCurrentTrackedItem.getOnPower and self.myCurrentTrackedItem.getOnPowerDuringTransit then	// PAR #31018
			self.mnuDisconnect.visible := true;																// PAR #31018
			self.mnuDisconnect.caption := "Disconnect " &amp; self.myCurrentTrackedItem.id &amp; "...";				// PAR #31018
			self.mnuDisconnect.userObject := self.myCurrentTrackedItem;										// PAR #31018
		endif;																								// PAR #31018
	endif;
	
	if not self.myTerminal.isAutoPlanningEnabled() then	  //SFW1030 04/08/2008
		self.mnuAutoplan.visible := false;						
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuAutoplan.visible := false;	
		self.mnuProcessRoadExit2.visible := false;
		self.mnuRebuildWLEStatus.visible := false;
		self.mnuUnassignTI.visible := false;
		self.mnuAutoplanTrain.visible := false;
		self.mnuDeleteCurrentWLE.visible := false;
		self.mnuQueue.visible := false;

	endif;


end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuZoom" id="6503aad0-b218-455d-b133-88b5e06b3978">
        <source>doBuildMnuZoom();
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/05/2009	consw1		SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------

vars

	idx	: Decimal[3,1];
	lFactor : Real;
	lIndex : Integer;
	lCaption : String;
	mnuChild : MenuItem;
	mnuIndex : Integer;
	gridArea : CMUI_GridArea;
	
begin
	self.mnuGridAreaContext.enabled := true;
	self.mnuZoomSub.visible := self.shtTransportView.visible;
	
	gridArea := self.mySDF.allGridAreasByRowColumn.first;
	if gridArea = null then
		self.mnuZoomSub.visible := false;
		return;
	endif;

	lFactor := gridArea.scaleXFactor;
	
	foreach idx in 1 to 4 step 0.5 do

		lCaption := "View At " &amp; idx.String &amp; " Scale" ;
		lIndex := (idx * 2).Integer;
		mnuChild := mnuZoomSub.getMenuItem(lIndex); // check if the menu is already cloned
		if mnuChild = null then
			mnuChild := mnuZoomSub.loadSubMenu(lIndex); // Clone menu
		endif;
		mnuChild.caption := lCaption;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := idx.String;
		if lFactor = idx then
			mnuChild.checked := true;
		else
			mnuChild.checked := false;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
