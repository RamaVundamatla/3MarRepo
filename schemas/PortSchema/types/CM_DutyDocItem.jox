    <JadeMethod name="setDutyItemValue" id="006d5176-fc2f-4455-8f50-f9fb70cb93d4">
        <updating/>
        <source>setDutyItemValue() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2014	cnwma1	Initial creation

*/

vars

begin
		self.duty 		  := 0.00;
		self.dutyRate 	  := 0.00;
		self.currency	  := null;
		self.currencyRate := 0.00;
		self.foreignValue := 0.00;
		self.localValue	  := 0.00;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="7ec37fd6-b1ec-49a6-a718-c40eedfacd12">
        <updating/>
        <source>setForCreate( _proxyDutyItem : CM_DutyDocItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwer1	Initial creation HAT 2189

*/

vars
	
begin
	
	self.setMyTrackedItem(_proxyDutyItem.myTrackedItem);
	self.myDutyDocTerminalRoot:=_proxyDutyItem.myDutyDocTerminalRoot;
	self.cargoDetails:=_proxyDutyItem.cargoDetails;
	self.voyageDetails:=_proxyDutyItem.voyageDetails;
	self.operator:=_proxyDutyItem.operator;
	self.agent:=_proxyDutyItem.agent;	

	
	self.setForUpdate(_proxyDutyItem);
	
epilog
	
end;</source>
        <Parameter name="_proxyDutyItem" type="CM_DutyDocItem"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="8fdb946a-f483-47fc-931b-8b9e6d4dc817">
        <updating/>
        <source>setForUpdate(_proxyDutyItem : CM_DutyDocItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwer1	Initial creation HAT 2189

*/

vars
	tiUpdateCntrl : CMIF_TIUpdateController;
begin
	self.myDutyDoc:=_proxyDutyItem.myDutyDoc;	
	self.hsCode:=_proxyDutyItem.hsCode;
	
	self.consignee:=_proxyDutyItem.consignee;
	self.pod:=_proxyDutyItem.pod;
	self.pol:=_proxyDutyItem.pol;
	self.bol:=_proxyDutyItem.bol;
	self.deliveryOrder:=_proxyDutyItem.deliveryOrder;
	self.deliveryOrderExpiryDate:=_proxyDutyItem.deliveryOrderExpiryDate;
	
	
	self.packing:=_proxyDutyItem.packing;
	self.origin:=_proxyDutyItem.origin;
	self.quantity:=_proxyDutyItem.quantity;
	self.volume:=_proxyDutyItem.volume;
	self.grossWeight:=_proxyDutyItem.grossWeight;
	self.netWeight:=_proxyDutyItem.netWeight;
	self.currency:=_proxyDutyItem.currency;
	self.currencyRate:=_proxyDutyItem.currencyRate;
	self.foreignValue:=_proxyDutyItem.foreignValue;
	self.localValue:=_proxyDutyItem.localValue;
	self.freight:=_proxyDutyItem.freight;
	self.insurance:=_proxyDutyItem.insurance;
	self.exemptDutyCode:=_proxyDutyItem.exemptDutyCode;
	self.duty:=_proxyDutyItem.duty;
	self.dutyCode:=_proxyDutyItem.dutyCode;
	self.dutyRate:=_proxyDutyItem.dutyRate;
	self.exemptSource:=_proxyDutyItem.exemptSource;
	self.exemptBenefit:=_proxyDutyItem.exemptBenefit;
	
	
	if self.myTrackedItem &lt;&gt; null then
		tiUpdateCntrl:=app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.myPassport.userCode, null);
		
		tiUpdateCntrl.saveTIDataPriorUpdate(self.myTrackedItem, app.myPassport);	
		if self.pod &lt;&gt; null then
			self.myTrackedItem.setDischargePort(self.pod);  // PAR 32924
		endif;
		if self.pol &lt;&gt; null then
			self.myTrackedItem.setLoadPort(self.pol);
		endif;
		if self.consignee &lt;&gt; null then
			self.myTrackedItem.setConsignee(self.consignee,tiUpdateCntrl,app.myPassport);
		endif;
		if self.agent &lt;&gt; null then
			self.myTrackedItem.setFreightForwarder(self.agent);
		endif;
		self.myTrackedItem.endUpdate(tiUpdateCntrl,app.myPassport);
	endif;
	
	
	if  self.myDutyDoc &lt;&gt; null then
		app.myEventManager.createSingleObjInfoNoteEvt(self.myDutyDoc,self.myDutyDoc.myDutyDocTerminalRoot.myTerminal.getTerminalEvent(EVENT_DUTYDOCITEM_UPDATE),self);
	endif;
epilog
	delete tiUpdateCntrl;
end;</source>
        <Parameter name="_proxyDutyItem" type="CM_DutyDocItem"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="527e5640-433a-4317-88d6-d8e2c4ce6d10">
        <updating/>
        <source>setMyTrackedItem(_ti : CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 February 2013	cnwer1	Initial creation HAT 2189

*/

vars

begin
	self.myTrackedItem:=_ti;
	if _ti = null then
		return;
	endif;
	self.cargoId:=self.myTrackedItem.id;
	self.cargoType:=self.myTrackedItem.myCargoType.abbreviation;
	self.voyage:=self.myTrackedItem.voyageCode;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="9853412e-5509-4c8e-9c84-13e5f5135e98">
        <updating/>
        <source>setProxy(	_dutyDocRoot : CM_DutyDocTerminalRoot;	
			_dutyDoc 	 : CM_DutyDoc;
			_ti 		 : CM_TrackedItem;
			_cargoDetails,
			_voyageDetails,
			_operator,
			_agent 		: String;
			_consignee,
			_portOfLoad,
			_portOfDestination,
			_bol,
			_deliveryNo : String;
			_deliveryExpiry : Date;
			_hsCode : String;
			_packing : Integer;
			_origin : String;
			_quantity : Integer;
			_volume,
			_grossWeight,
			_netWeight : Decimal;
			_currency : String;
			_currencyRate : Decimal;
			_foreignValue,
			_localValue,
			_freight,
			_insurance : Decimal;
			_dutyCode : String;
			_dutyExempt : String;
			_duty, 
			_dutyRate: Decimal;
			_exemptBenefit : String;
			_exemptSource : String
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

begin
	self.myDutyDocTerminalRoot:=_dutyDocRoot;
	self.myDutyDoc:=_dutyDoc;
	self.myTrackedItem:=_ti;
	self.hsCode:=_hsCode;
	self.cargoDetails:=_cargoDetails[1:50];
	self.voyageDetails:=_voyageDetails[1:50];
	self.operator:=_operator;
	self.agent:=_agent;
	self.consignee:=_consignee;
	self.pol:=_portOfLoad;
	self.pod:=_portOfDestination;
	self.bol:=_bol;

	self.deliveryOrder:=_deliveryNo;
	self.deliveryOrderExpiryDate:=	_deliveryExpiry;
	
	self.packing:=_packing;
	self.origin:=_origin;
	self.quantity:=_quantity;
	self.volume:=_volume;
	self.grossWeight:=_grossWeight;
	self.netWeight:=_netWeight;
	self.currency:=_currency;
	self.currencyRate:=_currencyRate;
	self.foreignValue:=_foreignValue;
	self.localValue:=_localValue;
	self.freight:=_freight;
	self.insurance:=_insurance;
	self.exemptDutyCode:=_dutyExempt;
	self.duty:=_duty;
	self.dutyCode:=_dutyCode;
	self.dutyRate:=_dutyRate;
	self.exemptSource:=_exemptSource;
	self.exemptBenefit:=_exemptBenefit;
epilog

end;</source>
