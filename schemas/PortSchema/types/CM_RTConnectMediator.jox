    <JadeMethod name="setActiveTerminal" id="c753d37a-fc96-4ee0-9b3f-ad065a2c271c">
        <updating/>
        <source>setActiveTerminal(_terminal : CM_Terminal) updating;
// -------------------------------------------
// Created 16 January 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.myActiveTerminal &lt;&gt; _terminal then
		self.myActiveTerminal := _terminal;
	endif;


end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setAttributes" id="9dce8b93-3420-48b8-9d1e-4c0690ddc227">
        <updating/>
        <source>setAttributes(	_device : CM_RadioTelemetryDevice;
				_id 	: Integer;
				_user : CM_User) updating;
// -------------------------------------------
// Created 10 January 2006 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
16 Mar 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Always default twin tasks to false
					
*/

vars
	
	terminal	: CM_Terminal;

begin

	self.device 			:= _device;
	self.user				:= _user;
	self.devicePhysicalId	:= _id;
	self.machine			:= _device.getMachine();
	terminal := _device.getMyTerminal();
	if terminal &lt;&gt; null then
		self.terminalCode := terminal.code;
	endif;
	self.setTwinTasks(false);
	self.setCanBeAllocatedMixedTasks(false); //cnwrd1 32293

end;</source>
        <Parameter name="_device" type="CM_RadioTelemetryDevice"/>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="setCanBeAllocatedMixedTasks" id="80f1e0b7-4252-4c77-86d8-397bd31e55da">
        <updating/>
        <source>setCanBeAllocatedMixedTasks( _value : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2013	cnwrd1	Initial creation
//cnwrd1 32293
*/

vars

begin
	if self.machine &lt;&gt; null then 
		self.machine.setCanBeAllocatedMixedTasks(_value);
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTwinTasks" id="85a371d1-4b0a-4391-a1fc-17aa4b544a9f">
        <updating/>
        <source>setTwinTasks(_value : Boolean) updating;

/*

Purpose:			Set the canBeAllocatedTwinTasks attribute of the receiver

Parameters:			Value to set attribute

Return Value:		None


Date		Who		Reason
16 Mar 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars

begin
	self.canBeAllocatedTwinTasks := _value;
	
	
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
</Class>
