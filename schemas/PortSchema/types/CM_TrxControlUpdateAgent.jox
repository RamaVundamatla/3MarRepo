    <JadeMethod name="trxUpdateTransactionMapCSV" id="69dee4cc-272b-4f7f-9224-e1a51821fc70">
        <updating/>
        <source>trxUpdateTransactionMapCSV(_allFileRows:ObjectArray; _passportObj:CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		April 2010 by cnwjre1
//
// Purpose:		Updates invoice transaction maps that have been read from a CSV file
//				(in the same format as the Rate Table extract).
//
// Parameters:	_allFileRows - An object array of file rows (each one being a HugeStringArray).
//				_passportObj - A reference to the current user's Passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passportObj, method);
	
	// Arm our base exception handlers
	on Exception do self.agtPassportExHandler(exception, _passportObj);
	on LockException do self.agtPassportLockExHandler(exception, _passportObj);
	
	app.setContinueCMExceptions(false);
	
	beginTransaction;
	
	app.myUtilityUA.utlUpdateTransactionMapCSV(_allFileRows, _passportObj);
epilog
	self.finaliseActivityWithPassport(_passportObj);
end;</source>
        <Parameter name="_allFileRows" type="ObjectArray"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTransactionType" id="528e3747-149c-47c0-9596-1940cb08dcd8">
        <updating/>
        <source>trxUpdateTransactionType(pProxyObj:CM_TransactionType; _passport:CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		25 November 2005 by cnwdad1
//
// Purpose:		Updates a Transaction Type object.
//
// Parameters:	pProxyObj - A reference to the proxy object.
//				_passport - A reference to the user passport.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	realObj			: CM_TransactionType;
	expectedEdition	: Integer;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do self.agtPassportExHandler(exception, _passport);
	on LockException do self.agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;

	pProxyObj.raiseExceptionIfNotProxy(method);
	app.setContinueCMExceptions(true);
	pProxyObj.pxyGetRealObjectAndEdition(realObj, expectedEdition);
	
	if realObj = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Trade.name, null, null);
		return;
	endif;

	app.myValUA.valTransactionType(realObj, pProxyObj, false);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realObj);

	if _passport.noErrors and realObj.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, "Transaction Type", null, null);
		return;
	endif;
	
	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(realObj, true);
	endif;
	
	if _passport.noErrors then
		realObj.setForUpdate(pProxyObj);
	endif;

	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(realObj, false);
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pProxyObj" type="CM_TransactionType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTransactionTypeSystem" id="7514eb33-5af8-4ad8-93b7-464ec2d08e75">
