    <JadeMethod name="displayString" id="104a4c1d-1ac2-49a4-aede-2fab4d136712">
        <source>displayString(): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2012	cnwdw1	Initial creation
*/
vars

begin
	return inheritMethod() &amp; " Gate: " &amp; gate &amp; " Truck: " &amp; truck &amp; " Visit: " &amp; visit ;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromVehicleVisit" id="bb256c92-3c12-4c03-8411-14de18b33a48">
        <updating/>
        <source>setFromVehicleVisit(_visit: CM_VehicleVisitRecord) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2012	cnwdw1	Initial creation
*/
vars

begin
	self.startTime := _visit.timeIn;
	self.finishTime := _visit.timeOut;
	self.gate := _visit.getGateInName.cnEcFindReplace(" ", "_", false);
	self.truck := _visit.vehicle.code;
	self.visit := _visit.getVisitId;
	self.finishGateInTime := _visit.getArrivalAtYardIC;
	self.startGateOutTime := _visit.getArrivalAtGateOutTime;
	
epilog

end;</source>
        <Parameter name="_visit" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
</Class>
