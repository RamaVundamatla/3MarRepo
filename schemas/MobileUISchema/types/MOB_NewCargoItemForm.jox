    <JadeMethod name="setupForm" id="457553bb-1163-4ebf-b243-dac9b1c6649c">
        <updating/>
        <source>setupForm() updating, protected;
/*
	Created on 10 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	intCargoType 	: Integer;
	product 		: CM_Product;
	mark 			: String;
	location 		: CM_LocationsController;
	strOperator 	: String;
	ti 				: CM_TrackedItem;
	cmifPrenote		: CMIF_PreNote;
	weight 			: Decimal[14,4];
	dev				: String;
begin
	inheritMethod();
	dev 		:= app.myMobileGUIAgent.strDevice;
	self.myMobileDataAgent.setupRoadJob(myRoadJob, dev);

	if strCargoId &lt;&gt; null then
		txt_CargoID.text := strCargoId;
	endif;
	setDefaultsFromTemplate(intCargoType,
						product, mark,
						location, strOperator,
						weight);
						
	if location &lt;&gt; null then
		txt_Location.text := location.getFullId;
	endif;
	self.loadComboBoxCargoType(self.cmb_CargoType, intCargoType);
	self.loadComboBoxOperator(self.cmb_Operator, strOperator);
	self.loadComboBoxProduct(self.cmb_Product, 
								app.myRoot.getCargoTypeDescription(intCargoType),
								product);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a23a8a1f-73b4-4cf4-a7da-d4b5a995b759">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017613, locale);
	btn_Cancel.translateCaption(Xlat_0013189, locale);
	btn_OK.translateCaption(Xlat_0013190, locale);
	lbl_CargoID.translateCaption(Xlat_0013191, locale);
	lbl_CargoType.translateCaption(Xlat_0013192, locale);
	lbl_Location.translateCaption(Xlat_0013193, locale);
	lbl_Mark.translateCaption(Xlat_0013194, locale);
	lbl_Operator.translateCaption(Xlat_0013195, locale);
	lbl_Product.translateCaption(Xlat_0013196, locale);
	lbl_Tile.translateCaption(Xlat_0013197, locale);
	lbl_Weight.translateCaption(Xlat_0013198, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
