    <JadeMethod name="shouldPushObject" id="491fe0a0-989e-4eb3-ae37-7c96680be176">
        <source>shouldPushObject(_obj: CM_Object): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 October 2022	navcs2	ChangeRequest 54621: PNL - Event Stream Sending Though Old Records

*/

vars

begin
	if self.myTerminal = null then
		return false;
	else
		return true;
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="typeString" id="5523f3a2-0e5d-4c3c-b719-ecf189048c76">
        <methodInvocation>mapping</methodInvocation>
        <source>typeString(_set: Boolean; _value: String io) mapping;
//--------------------------------------------------------------
//Created: 30 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

	str : String;
begin
	if _set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	str := 'TransType_' &amp; self.type.String;
	_value := app.currentLocale.getStringValue(str);
	if _value = null then
		_value := 'Unknown Type';
	endif;

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validate" id="29b87b58-eef3-4d17-83d6-5940acbcb9ad">
        <source>validate(_transController : CMIF_HMS_TransactionController) : Boolean;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if _transController = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null CMIF_HMS_TransactionController passed to method.');
		return false;
	endif;
	return true;
end;</source>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
