    <JadeMethod name="loadFromBGPObject" id="8474de5a-f8a1-41fe-8f9f-e7ee107e49a3">
        <updating/>
        <source>loadFromBGPObject(_bgpObject:BGP_Object input) updating;
// --------------------------------------------------------------------------------
// Created:		15 February 2006 by cnwdad1
//
// Purpose:		Populates the receiver with the appropriate data, depending upon
//				whether the parameter is a BGP controller or manager.
//
// Parameters:	_bgpObject - A reference to the BGP object.
//
// Returns:		The populated BGP object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _bgpObject.isKindOf(BGP_Controller) then
		self.loadFromController(_bgpObject.BGP_Controller);
	else
		self.loadFromManager(_bgpObject.BGP_Manager);
	endif;
end;</source>
        <Parameter name="_bgpObject" type="BGP_Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadFromController" id="0b0c3af0-1667-4d71-877c-69384bc74545">
        <updating/>
        <source>loadFromController(_bgpController : BGP_Controller) updating;

// cnwdvb1 12 November 2002 

begin


	_bgpController.setCMIF(self);

end;</source>
        <Parameter name="_bgpController" type="BGP_Controller"/>
    </JadeMethod>
    <JadeMethod name="loadFromManager" id="53456f22-49da-4cdc-ba26-6ba18e8a2503">
        <updating/>
        <source>loadFromManager(_manager : BGP_Manager) updating;

// cnwdvb1 25 October 2002 
//
//28 Apr 2016	cnwrs1	TFS Push Events Geneva
// 10 May 2017	cnwrs1	TFS 3518 remove Push Events
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
//
vars
	controller	: BGP_Controller;
	iter		: Iterator;
begin
	self.managerName		:= _manager.name;
	self.isServer			:= _manager.isRunOnServer;
	self.isFatClientOnly	:= _manager.isManagedService;
	self.machineNameSpecific := _manager.machineNameSpecific;
	iter := _manager.allBGPControllers.createIterator;
	while iter.next(controller) do
		if controller.isKindOf(BGP_BackupJournal) then
			self.isBackupJournal := true;
		elseif controller.isKindOf(BGP_CalendarCheckController) then	// 02 Nov 2010	NDL	Par 25530
			self.isCalendarCheck := true;		
		elseif controller.isKindOf(BGP_ChangeTrackerController) then
			self.isChangeTracker := true;
		elseif controller.isKindOf(BGP_ExternalWSController) then
			self.numberOfExtWSServices := self.numberOfExtWSServices + 1;
		elseif controller.isKindOf(BGP_GenericController) then
			self.numberOfRemotes := self.numberOfRemotes + 1;
		elseif controller.isKindOf(BGP_LocationStatistics) then
			self.isLocationStatistics := true;
		elseif controller.isKindOf(BGP_LockKeeperController) then
			self.isLockKeeper := true;
		elseif controller.isKindOf(BGP_RFIDListenController) then
			self.isRFIDListenController := true;
		elseif controller.isKindOf(BGP_ReportController) then
			self.numberOfReports := self.numberOfReports + 1;
		elseif controller.isKindOf(BGP_TCPClient) then
			self.numberOfTcpIpClients := self.numberOfTcpIpClients + 1;
		elseif controller.isKindOf(BGP_AutoTimerController) then
			self.isAutoTimer := true;
		elseif controller.isKindOf(BGP_AutoWarningController) then
			self.isAutoWarning := true;
		elseif controller.isKindOf(BGP_DirectoryController) then
			self.numberOfDirectories := self.numberOfDirectories + 1;
		elseif controller.isKindOf(BGP_FutureTimerController) then		// ****
			self.isFutureTimer	:= true;
		elseif controller.isKindOf(BGP_VehicleBookingSlotCont) then	//15 Apr 2013	NDL	Par 31393
			self.isVSBookGen := true;
		elseif controller.isKindOf(BGP_DeferredChargingController) then	//06 Jul 2021	NDL	TSF 51443
			self.isDeferred := true;
		elseif controller.isKindOf(BGP_WorkOrderScheduler) then
			self.isWorkOrderScheduler := true;
		elseif controller.isKindOf(BGP_XMLListenController) then
			self.numberOfTcpIpServers := self.numberOfTcpIpServers + 1;
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_manager" type="BGP_Manager"/>
    </JadeMethod>
    <JadeMethod name="setWorker" id="9a827058-3008-4341-9b1c-46a968bf0c76">
        <updating/>
        <source>setWorker(_worker : String) : Boolean updating;

// cnwdvb1 13 November 2002 


begin

	if _worker &lt;&gt; null then
		self.workerClass := _worker;
		return true;
	endif;
	return false;

	
end;</source>
        <Parameter name="_worker" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="2e39c325-83af-48c0-a29e-f609b7a2a711">
        <source>validate();

// cnwdvb1 25 October 2002 
// 28 Sep 2016	cnwrs1	TFS 2756 PAR38267 allow Cams to run per terminal
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
constants
	MaxApps = 25;
vars
	timer 	: BGP_AutoTimerController;
	futureTimer	: BGP_FutureTimerController;
begin
	if self.myManager = null or not self.myManager.name = self.managerName then
		if self.managerName = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Manager ID', null, null);
			app.raiseCMException(Input_required_field_managerID, null, null); // cnwdb2	PAR 35364
		endif;
		if app.myRoot.allBGPManagers[managerName] &lt;&gt; null then
			//app.raiseCMException2(DuplicateItem, managerName,'database', null, null); //14.06.2022 navds20 53760
			// %1 already exists for database : Already_exists_database
			app.raiseCMException1(Already_exists_database, managerName, null, null); //14.06.2022 navds20 53760
		endif;
	endif;
	
	if self.isServer and self.numberOfReports &gt; 0 then
		app.raiseCMException(ReportsMustBeGui, null, null);
	endif;
	
	timer := BGP_AutoTimerController.firstInstance;
	if (timer &lt;&gt; null and timer.myBGPManager &lt;&gt; self.myManager) and self.isAutoTimer then
		app.raiseCMException(DuplicateAutoTimer, null, null);
	endif;

	futureTimer := BGP_FutureTimerController.firstInstance;		// CCMS DPH 2278
	if (futureTimer &lt;&gt; null and futureTimer.myBGPManager &lt;&gt; self.myManager) and self.isFutureTimer then
		app.raiseCMException(DuplicateFutureTimer, null, null);
	endif;
	
	if self.numberOfRemotes &gt; MaxApps or self.numberOfReports &gt; MaxApps or self.numberOfDirectories &gt; MaxApps or
	   self.numberOfTcpIpClients &gt; MaxApps or self.numberOfTcpIpServers &gt; MaxApps then
		app.raiseCMException1(BackgroundErrorGeneral, 'Maximum of ' &amp; MaxApps.String &amp; ' applications has been exceeded','Error', null);
	endif;
end;</source>
    </JadeMethod>
</Class>
