    <JadeMethod name="fldMain_sheetChg" id="047f9942-cca9-4877-b1df-add95dcc974d">
        <controlMethod name="Folder::sheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldMain_sheetChg(folder: Folder input) updating;
/*
------------------------------------------------------------------------
Created:			25 March 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars

begin
	self.btnPerfOpts.enabled := false;	//Disable until the performance graph tab is enabled
	self.btnSample.enabled := false;	//Disable until the performance graph tab is enabled

	if folder.topSheet = self.shtLocks then
		self.getLocksDisplay();
	elseif folder.topSheet = self.shtPerf then
		self.btnPerfOpts.enabled := true;
		self.btnSample.enabled := true;
		self.getProcessesDisplay();
	endif;
epilog
end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getLocksDisplay" id="55b9729b-db65-4d8b-82dc-445a00115d39">
        <updating/>
        <source>getLocksDisplay() updating, protected;
// ---------------------------------------------------------------------------
// Created:     13 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	HEAPS_O_LOCKS =  5000;
vars
	trxn : CM_LockTransaction;
	numLocks, rowColor1, rowColor2, currentColor, idx : Integer;
	lock : Lock;
	lockArray : LockArray;
	str : String;
	proc : Process;
	user : CM_User;
begin
	app.mousePointer := MousePointer_HourGlass;

	currentColor := self.colorRow1;
	
	self.tblLocks.rows := self.tblLocks.fixedRows;
	
	rowColor1 := self.colorRow1;
	rowColor2 := self.colorRow2;
	currentColor := rowColor1;

	create lockArray transient;

	beginLoad;
	system.getLocks(lockArray, HEAPS_O_LOCKS);

	foreach lock in lockArray do
		if lock.type.Integer = Share_Lock then
			str := app.getErrorString(Shared_Lock);
		elseif lock.type.Integer = Exclusive_Lock then
			str := app.getErrorString(ExclusiveLock);
		elseif lock.type.Integer = Reserve_Lock then
			str := app.getErrorString(ReserveLock);
		else
			str := app.getErrorString(UnknownLockType);
		endif;
		
		if lock.duration.Integer = Persistent_Duration	 then
			//2	Reserved for future use (not yet implemented)
			str := str &amp; Tab &amp; app.getErrorString(S_Persistent_Lock);
		elseif lock.duration.Integer = Session_Duration	then
			//1	Automatically unlocks the object at the end of the current session (that is, the current thread, or process) if no manual unlocks are issued
			str := str &amp; Tab &amp; app.getErrorString(S_Session_Lock);
		elseif lock.duration.Integer = Transaction_Duration	then
			//0	Automatically unlocks the object at the end of 
			str := str &amp; Tab &amp; app.getErrorString(Transaction);
		endif;
		proc := lock.requestedBy;
		str := str &amp; 
			Tab &amp; lock.requestTime.shortCurrentLocaleFormatSecs() &amp; 
			Tab &amp; lock.elapsedTime.String &amp; 
			Tab &amp; lock.target.String &amp; 
			Tab &amp; proc.userCode;
		if proc.userInfo &lt;&gt; null then
			if app.myRoot &lt;&gt; null then
				user := app.myRoot.allUsers[proc.userCode];
			endif;
			if user &lt;&gt; null then
				str := str &amp; '-' &amp; user.userName;	//node.name.String ;
			endif;
		endif;
		
		if lock.lockedBy &lt;&gt; null then
			str := str &amp; Tab &amp; lock.lockedBy.userInfo;
		else
			str := str &amp; Tab &amp; "Unknown";
		endif;

		if currentColor = rowColor1 then
			currentColor	:= rowColor2;
		else
			currentColor	:= rowColor1;
		endif;

		//Set string to table - do not add object to row as object gets deleted in epilog below
		idx := self.tblLocks.addItem(str);
		self.tblLocks.accessRow(idx).backColor := currentColor;
		
		numLocks := numLocks + 1;
		
	endforeach;

	staMain.caption := app.getErrorString1(CMUI_UserNodes_LocksStatusLine, numLocks.String);
	
epilog
	endLoad;
	lockArray.purge;
	delete lockArray;
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getProcessesDisplay" id="f8b49873-0ce0-4324-8001-ba7df980cd2b">
        <source>getProcessesDisplay() protected;
/*
------------------------------------------------------------------------
Created:			19 March 2004 by cnwdwq1
Purpose:			Sets up the display for the process counter details display
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	gblR : CM_GlobalProcessRoot;
	gblDtl : CM_GlobalProcessDetail;
	iter : Iterator;
	dict : CM_GlbProcessDetailByDTDict;
	numInDict : Integer;
	startPos : Integer;
	plotValues : IntegerArray;
	colorArray : IntegerArray;
	str : String;
	ts : TimeStamp;
	numToGet : Integer;
	agent : CMUI_SysPerformAgent;
begin

	app.mousePointer := MousePointer_HourGlass;
	gblR := CM_GlobalProcessRoot.firstInstance;
	if gblR = null then
		return;
	endif;
	numToGet := self.mySysPerformAgent.numToRetrieve;
	if numToGet = 0 then
		return;
	endif;
	
	agent := self.mySysPerformAgent;
	dict := gblR.allGlobalProcessDetails;
	numInDict := dict.size;
	
	iter := dict.createIterator();
	//----------------
	//Grab the last few
	//----------------
	if numInDict &lt;= numToGet then
		startPos := 1;
	else
		startPos := numInDict - numToGet;
	endif;
	iter.startAtIndex(startPos);
	self.grfPerform.isShowLineLegend := true;
	self.grfPerform.clearGraph();
	self.grfPerform.setAndShowGraphTitle(app.getErrorString(CMUI_SysPerform_Statistics));
	self.grfPerform.init(app.getErrorString(CMUI_SysPerform_Statistics), "Date/Time", "Frequency");
	
	create plotValues transient;
	create colorArray transient;	
	while iter.next(gblDtl) do
		//Grab each detail object, and plot it on the graph
		plotValues.clear;
		agent.addGraphDetails(gblDtl, plotValues);
		ts := gblDtl.sampledDT;
		str := ts.time.format("HH.mm.ss") &amp; CrLf &amp; ts.Date.shortFormatJMT();
		self.grfPerform.addYPoints(str, plotValues);
	endwhile;
	
	agent.addGraphLegends(self.grfPerform, colorArray);
	
	self.grfPerform.addLineColors(colorArray);
	self.grfPerform.drawGraph();
	
epilog
	delete iter;
	delete plotValues;
	delete colorArray;
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="6e25e7eb-a801-4bba-a42d-b9f914b24be8">
