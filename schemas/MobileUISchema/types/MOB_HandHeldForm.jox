    </JadeMethod>
    <JadeMethod name="setResizeableMarginAndFontSize" id="0557d480-1cd1-4e90-98c7-fe8709d04165">
        <updating/>
        <source>setResizeableMarginAndFontSize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	currentFontSize : Decimal [5,2];
	margin : Integer;
	newFontSize : Decimal [5,2];
	index : Integer;
	control : Control;

begin

	if not useHHResizeCode then
		self.resizedMargin := self.MARGIN;
		
	else
	
		currentFontSize := self.drawFontSize;
		margin := self.MARGIN;
		newFontSize := 9.75;
		//default approx 232 W x 286 H.  font 9.75
		if self.clientWidth &gt; 300 and self.clientHeight &gt; 400 then
			margin := 3;
			newFontSize := 12;
			if self.clientWidth &gt; 500 and self.clientHeight &gt; 700 then
				margin := 4;
				newFontSize := 14;
				if self.clientWidth &gt; 700 and self.clientHeight &gt; 900 then
					margin := 5;
					newFontSize := 16;
				endif;
			endif;
		endif;
		
		if currentFontSize &lt;&gt; newFontSize then
			self.drawFontSize := newFontSize;
			foreach index in 1 to self.controlCount do
				control := self.controls( index );
				control.fontSize := newFontSize;
			endforeach;
		endif;
		
		self.resizedMargin := margin;
		
	endif;

epilog

end;</source>
    </JadeMethod>
