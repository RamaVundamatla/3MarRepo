    <JadeMethod name="setAllErrors" id="8df69d07-9dc7-47b1-9058-255a65a2e423">
        <source>setAllErrors(_heading : String) protected;

vars
	err	: CM_Error;
	
begin

	app.writeLog('HEADING &gt;&gt; ' &amp; _heading, LogINFO);

	self.newErrors.clear;	
	foreach err in app.myPassport.allWarnings do
		if not self.allErrors.includes(err) then
			self.allErrors.add(err);
			self.newErrors.add(err);
			app.writeLog('WARNING &gt;&gt; ' &amp; err.errorCode.String &amp; '  ' &amp; err.text, LogINFO);
		endif;
	endforeach;

	foreach err in app.myPassport.allErrors do
		if not self.allErrors.includes(err) then
			self.allErrors.add(err);
			self.newErrors.add(err);
			app.writeLog('ERROR &gt;&gt; ' &amp; err.errorCode.String &amp; '  ' &amp; err.text, LogINFO);
		endif;
	endforeach;
	
	foreach err in self.newErrors do
		err.removeFromPassport();
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_heading" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupQuantityTypes" id="2d71feed-4e56-495f-abf6-18ab59fd5b5d">
        <updating/>
        <source>setupQuantityTypes() updating, protected;
// get each possible calculation type description, for the
constants
	TagLabel = "LABEL";
	TagCaption = "CAPTION";

vars
	appScm : Schema;
	category : ConstantCategory;
	const : Constant;
	calTypeValue : Integer;
	lenTagLabel	: Integer;
	label : String;

begin
	
	appScm := rootSchema.getSchema(PortSchemaName);
	if appScm = null then
		return;
	endif;
	
	category := appScm.getCategory(InvoiceCalculationTypes);
	if category = null then
		return;
	endif;

	lenTagLabel := TagLabel.length;
	
	foreach const in category.getConstants do
		calTypeValue := const.GlobalConstant.valueAsInteger;
		label := const.text.String.cnEcGetTagValueOfName(TagLabel);
		if calTypeValue = INV_CALC_TYPE_DAYS_ONSITE_AT then
			if self.myBank &lt;&gt; null then
				label := label &amp; " " &amp; self.myBank.onsiteStorageChargeTime.String;
			endif;
		endif;
	endforeach;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateBOLCSV" id="7c8e82a0-1869-4abf-b301-b6f2dd209f66">
        <updating/>
        <source>updateBOLCSV(_allFileRows:ObjectArray) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars
	object				: Object;
	allRowFields		: HugeStringArray;
	bankObj				: CM_Bank;
	rootDebtorObj		: CM_DebtorNode;
	rootObj				: CM_Root;

	bolMapObj			: CM_TranMapBOL;
	bolBrokerObj	 	: CM_BOLServiceBroker;
	brokerObj			: CM_ServiceBroker;
	debtorMapObj 		: CM_DebtorMap;
	quantityMapObj 		: CM_QuantityMap;
	quantityRangeMapObj	: CM_QuantityRangeMap;

	rows				: Integer;
	
	// The following are the file field values.
	
	rowType				: String;
	debtorCode			: String;
	mapName				: String;
	bolTrxName			: String;
	quantityType		: String;
	quantityRange		: String;
	groupingType		: String;
	invoiceLine			: String;
begin
	
	self.createCount	:=	0;
	self.updateCount	:=	0;
	bankObj			:=	self.myBank;
	rootDebtorObj	:=	bankObj.rootDebtorGroup;
	rootObj			:=	app.myRoot;
	
	self.rowCount := 1;
	foreach object in _allFileRows do
		self.rowCount := self.rowCount + 1;

		allRowFields	:=	object.HugeStringArray;
		rows := allRowFields.size;
		if rows &lt; 7 then
			continue;
		endif;
		// Get the field values.
		
		rowType			:=	allRowFields[1];
		mapName			:=	allRowFields[2];
		bolTrxName		:=	allRowFields[3];
		debtorCode		:=	allRowFields[4];
		quantityType	:=	allRowFields[5];
		quantityRange	:=	allRowFields[6];
		if self.baseColumnCount = 8 then
			groupingType :=	allRowFields[7];
			invoiceLine	:=	allRowFields[8];
		else
			invoiceLine	:=	allRowFields[7];
		endif;
		// no methods
		
		// BOL Map
		if not self.createBOLMap(bankObj, mapName, bolMapObj) then
			app.raiseCMException3(LoadUpdateError, 'BOL map', mapName, self.rowCount.String, null, null);	
			setAllErrors('Create BOL Map (' &amp; mapName &amp; ')');
			return;
		endif;
		
		// WorkOrder type
		if not self.createBOLTypeMap(bolTrxName, bolMapObj, bolBrokerObj) then
			app.raiseCMException3(LoadUpdateError, 'BOL type map', bolTrxName, self.rowCount.String, null, null);	
			setAllErrors('Create BOL Type Map (' &amp; bolTrxName &amp; ')');
			return;
		endif;
		brokerObj := bolBrokerObj;

		// debtor
		if not self.createDebtorMap(debtorCode,  brokerObj, debtorMapObj) then
			app.raiseCMException3(LoadUpdateError, 'debtor map', debtorCode, self.rowCount.String, null, null);	
			setAllErrors('Create Debtor Map (' &amp; debtorCode &amp; ')');
			return;
		endif;
		
		// quantity type
		if debtorMapObj &lt;&gt; null then
			quantityMapObj := debtorMapObj.myChildQuantityMap;
		else
			quantityMapObj := brokerObj.myChildQuantityMap;
		endif;
		if not self.updateQuantityMap(quantityType, quantityMapObj) then
			app.raiseCMException3(LoadUpdateError, 'quantity map', quantityType, self.rowCount.String, null, null);	
			setAllErrors('Update Quantity Map (' &amp; quantityType &amp; ')');
			return;
		endif;
		
		// quantity range
		if not self.createQuantityRangeMap(quantityRange, quantityMapObj, quantityRangeMapObj) then
			app.raiseCMException3(LoadUpdateError, 'quantity range map', quantityRange, self.rowCount.String, null, null);	
			setAllErrors('Create Quantity Range Map (' &amp; quantityRange &amp; ')');
			return;
		endif;
		
		// invoice line
		self.createInvoiceLineMapBOL(invoiceLine, quantityRangeMapObj, BOLMap, false, groupingType, null, null); // TFS 40620 seperate method
		
	endforeach;
epilog
end;
</source>
        <access>protected</access>
        <Parameter name="_allFileRows" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="updateCargoCSV" id="1bd25a8f-eadb-43f9-bacf-048df1a64503">
        <updating/>
        <source>updateCargoCSV(_allFileRows:ObjectArray) updating, protected;
// --------------------------------------------------------------------------------
// Created:		April 2010 by cnwjre1
//
// Purpose:		Updates multiple invoice transaction map that have been read from a CSV file
//				(in the same format as the Rate Table extract).
//
// Parameters:	_allFileRows - An object array of file rows (each one being a HugeStringArray).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//13/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
//jngns1 19/9/17 TFS 6924 Import Transaction Map causes Exception
// --------------------------------------------------------------------------------
vars
	object				: Object;
	allRowFields		: HugeStringArray;
	bankObj				: CM_Bank;
	rootDebtorObj		: CM_DebtorNode;
	rootObj				: CM_Root;

	cargoMapObj			: CM_TranMap;
	serviceMapObj		: CM_TIServiceMap;
	cargoTypeObj		: CM_CargoType;
	productGroupObj 	: CM_ProductGroup;
	productGroupMapObj	: CM_ProductGroupMap;
	productMapObj		: CM_ProductMap;
	imexMapObj			: CM_ImexServiceMap;
	contentsMapObj 		: CM_ContentsMap;
	commodityMapObj 	: CM_CommodityMap;
	tranMapObj			: CM_TransServiceBroker;
	brokerObj			: CM_ServiceBroker;
	debtorMapObj 		: CM_DebtorMap;
	quantityMapObj,
	quantitySubMapObj   : CM_QuantityMap;          //13/02/2017 cnwma1 TFS #2901
	quantityRangeMapObj,
	quantitySubRangeMapObj: CM_QuantityRangeMap;

	i, row				: Integer;
	columns				: Integer;
	isMove				: Boolean;
	
	// The following are the file field values.
	
	rowType				: String;
	debtorCode			: String;
	mapName				: String;
	cargoType			: String;
	cargoSubtypeGroup	: String;
	cargoSubtype		: String;
	imex				: String;
	contentsStatus		: String;
	commodity			: String;
	transaction			: String;
	moveType			: String;
	quantityType		: String;
	quantityRange		: String;
	groupingType		: String;
	invoiceLine			: String;
	quantitySubType		: String;   //13/02/2017 cnwma1 TFS #2901
	quantitySubRange	: String;   //13/02/2017 cnwma1 TFS #2901
	pos : Integer;
	transferType : String; // TFS 41096
	transferJobType : CM_VoyageJobTransferType;
	transferTypeId : Integer;
begin
	
	self.createCount	:=	0;
	self.updateCount	:=	0;
	bankObj			:=	self.myBank;
	rootDebtorObj	:=	bankObj.rootDebtorGroup;
	rootObj			:=	app.myRoot;
	
	self.rowCount := 1;

	foreach object in _allFileRows do
		self.rowCount := self.rowCount + 1;

		allRowFields	:=	object.HugeStringArray;
		columns := allRowFields.size;
		if columns &lt; 14 then
			continue;
		endif;
		
		// Get the field values.
		
		rowType			:=	allRowFields[1];
		mapName			:=	allRowFields[2];
		cargoType		:=	allRowFields[3];
		cargoSubtypeGroup	:=	allRowFields[4];
		cargoSubtype	:=	allRowFields[5];
		imex			:=	allRowFields[6];
		contentsStatus	:=	allRowFields[7];
		commodity		:=	allRowFields[8]; 
		transaction		:=	allRowFields[9];
		moveType		:=	allRowFields[10];
		debtorCode		:=	allRowFields[11];
		quantityType	:=	allRowFields[12];
		quantityRange	:=	allRowFields[13];
		
		/*if self.baseColumnCount = 15 then          //13/02/2017 cnwma1 TFS #2901
			groupingType :=	allRowFields[14];
			invoiceLine	:=	allRowFields[15];
		else
			invoiceLine	:=	allRowFields[14];
		endif;*/
		
		if self.baseColumnCount = 15 then 
			groupingType :=	allRowFields[14];
			invoiceLine	:=	allRowFields[15];
		elseif self.baseColumnCount = 17 then            //13/02/2017 cnwma1 TFS #2901
			quantitySubType	:=	allRowFields[14];        //13/02/2017 cnwma1 TFS #2901
			quantitySubRange	:=	allRowFields[15];    //13/02/2017 cnwma1 TFS #2901
			//groupingType :=	allRowFields[15];
			//invoiceLine	:=	allRowFields[16];
			groupingType :=	allRowFields[16];
			invoiceLine	:=	allRowFields[17];
		elseif self.baseColumnCount = 18 then 
			transferType := allRowFields[16]; // TFS 41096
			groupingType :=	allRowFields[17];
			invoiceLine	:=	allRowFields[18];
			quantitySubType	:=	allRowFields[14];
			quantitySubRange	:=	allRowFields[15];
		else
		
			if self.baseColumnCount =14 then
				invoiceLine	:=	allRowFields[14];
			elseif  self.baseColumnCount =15   then
				invoiceLine	:=	allRowFields[15];
			endif;
		
		endif;
		
		// plus any methods
		self.currentMethods.clear;
	
		foreach i in self.baseColumnCount + 1 to columns do
			if allRowFields[i] &lt;&gt; "" then
				self.currentMethods[i - self.baseColumnCount] := "X";
			endif;
		endforeach;
		
		// Cargo Map
		if not self.createCargoMap(bankObj, mapName, cargoMapObj) then
			app.raiseCMException3(LoadUpdateError, 'cargo map', mapName, self.rowCount.String, null, null);	
			setAllErrors('Create Cargo Map (' &amp; mapName &amp; ')');
			return;
		endif;
		
		// cargo type
		if not self.createCargoTypeMap(cargoType, cargoMapObj, cargoTypeObj, serviceMapObj) then
			app.raiseCMException3(LoadUpdateError, 'cargo type map', cargoType, self.rowCount.String, null, null);	
			setAllErrors('Create Cargo Type Map (' &amp; cargoType &amp; ')');
			return;
		endif;
		self.myMapTIService := serviceMapObj;
		
		//product group
		if not self.createProductGroupMap(cargoSubtypeGroup, cargoTypeObj, serviceMapObj, productGroupMapObj) then
			app.raiseCMException3(LoadUpdateError, 'product group map', cargoSubtypeGroup, self.rowCount.String, null, null);	
			setAllErrors('Create Product Group Map (' &amp; cargoSubtypeGroup &amp; ')');
			return;
		endif;
		
		// product
		if not self.createProductMap(cargoSubtype, cargoTypeObj, productGroupObj, productGroupMapObj, productMapObj) then
			app.raiseCMException3(LoadUpdateError, 'product map', cargoSubtype, self.rowCount.String, null, null);
			setAllErrors('Create Product Map (' &amp; cargoSubtype &amp; ')');
			return;
		endif;
		
		// imex
		if not self.createImexMap(imex, productMapObj, imexMapObj) then
			app.raiseCMException3(LoadUpdateError, 'imex map', imex, self.rowCount.String, null, null);	
			setAllErrors('Create Imex Map (' &amp; imex &amp; ')');
			return;
		endif;
		
		// contents status
		if not self.createContentsStatusMap(contentsStatus, imexMapObj, contentsMapObj) then
			app.raiseCMException3(LoadUpdateError, 'contents status map', contentsStatus, self.rowCount.String, null, null);	
			setAllErrors('Create Contents Status Map (' &amp; contentsStatus &amp; ')');
			return;
		endif;
		
		// commodity
		if not self.createCommodityMap(commodity, contentsMapObj, commodityMapObj) then
			app.raiseCMException3(LoadUpdateError, 'commodity map', commodity, self.rowCount.String, null, null);	
			setAllErrors('Create Commodity Map (' &amp; commodity &amp; ')');
			return;
		endif;
		
		// transaction
		if not self.createTransactionMap(transaction, commodityMapObj, isMove, tranMapObj) then
			app.raiseCMException3(LoadUpdateError, 'transaction map', transaction, self.rowCount.String, null, null);	
			setAllErrors('Create Transaction Map (' &amp; transaction &amp; ')');
			return;
		endif;
		brokerObj := tranMapObj;
		self.myMapServiceBroker := tranMapObj;

		// move/resource
		if moveType &lt;&gt; null then
			if not self.createMoveOrResourceMap(moveType, commodityMapObj, tranMapObj, isMove, brokerObj) then
				app.raiseCMException3(LoadUpdateError, 'move/resource map', moveType, self.rowCount.String, null, null);	
				setAllErrors('Create Move/Resource Map (' &amp; moveType &amp; ')');
				return;
			endif;
		endif;
		
		// debtor
		if not self.createDebtorMap(debtorCode,  brokerObj, debtorMapObj) then
			app.raiseCMException3(LoadUpdateError, 'debtor map', debtorCode, self.rowCount.String, null, null);	
			setAllErrors('Create Debtor Map (' &amp; debtorCode &amp; ')');
			return;
		endif;
	
		// quantity type
		if debtorMapObj &lt;&gt; null then
			quantityMapObj := debtorMapObj.myChildQuantityMap;
		else
			quantityMapObj := brokerObj.myChildQuantityMap;
		endif;
		if not self.updateQuantityMap(quantityType, quantityMapObj) then
			app.raiseCMException3(LoadUpdateError, 'quantity map', quantityType, self.rowCount.String, null, null);	
			setAllErrors('Update Quantity Map (' &amp; quantityType &amp; ')');
			return;
		endif;
	
		// quantity range
		if not self.createQuantityRangeMap(quantityRange, quantityMapObj, quantityRangeMapObj) then 	
			app.raiseCMException3(LoadUpdateError, 'quantity range map', quantityRange, self.rowCount.String, null, null);	
			setAllErrors('Create Quantity Range Map (' &amp; quantityRange &amp; ')');
			return;
		endif;
		
		// Quantity Sub type
		if quantitySubType &lt;&gt; null and quantitySubRange &lt;&gt; null then 	
			if not self.createSubQuantityMap(quantitySubType,quantitySubRange,quantityRangeMapObj,quantitySubMapObj)  then
				app.raiseCMException3(LoadUpdateError, 'Sub quantity map', quantityRange, self.rowCount.String, null, null);	
				setAllErrors('Update Sub Quantity Map (' &amp; quantityRange &amp; ')');
				return;
			endif;	
		
		endif;
		// 34477 just save the QRM and update the methods used
		self.updateQuantityRangeMapMethods(quantityRangeMapObj);
		self.allQuantityRangeMaps.add(quantityRangeMapObj); // TFS 8360
		
	endforeach;
	
	// 34477 do invoice lines separately once all of the methods used have been updated to the quantity range map
	groupingType := null;
	row := 0;
	self.rowCount := 1; // TFS 41202

	foreach object in _allFileRows do
		self.rowCount := self.rowCount + 1; // TFS 41202

		transferJobType := null; // TFS 41096
		transferTypeId := null; // TFD 41096
		
		allRowFields	:=	object.HugeStringArray;
		columns := allRowFields.size;
		if columns &lt; 14 then
			continue;
		endif;
		// update the methods
		self.currentMethods.clear;
		foreach i in self.baseColumnCount + 1 to columns do
			if allRowFields[i] &lt;&gt; "" then
				self.currentMethods[i - self.baseColumnCount] := "X";
			endif;
		endforeach;
		//13/02/2017 cnwma1 TFS #2901  
		/*if self.baseColumnCount = 15 then
			groupingType :=	allRowFields[14];
			invoiceLine	:=	allRowFields[15];
		else
			invoiceLine	:=	allRowFields[14];
		endif;
		*/
		//13/02/2017 cnwma1 TFS #2901
		if self.baseColumnCount = 15 then
			groupingType :=	allRowFields[14];
			invoiceLine	:=	allRowFields[15];
		elseif self.baseColumnCount = 17 then
			groupingType :=	allRowFields[16];
			invoiceLine	:=	allRowFields[17];
			quantitySubRange := allRowFields[15];
		elseif self.baseColumnCount = 18 then
			transferType :=	allRowFields[16];
			groupingType :=	allRowFields[17];
			invoiceLine	:=	allRowFields[18];
			quantitySubRange := allRowFields[15];

		else
			if self.baseColumnCount =14 then
				invoiceLine	:=	allRowFields[14];
			elseif self.baseColumnCount =15  then
				invoiceLine	:=	allRowFields[15];
			endif;
		endif;
		row := row + 1;
		if not row &gt;self.allQuantityRangeMaps.size then
			quantityRangeMapObj := self.allQuantityRangeMaps[row].CM_QuantityRangeMap;
			
			//16/02/2017 cnwma1 TFS #2901
			if quantitySubRange &lt;&gt; null then
				pos :=1; 	
				quantitySubRange.scanUntil(" to",pos);
				quantitySubRange:= quantitySubRange[1:pos];
				if  quantityRangeMapObj.myChildQuantityMap &lt;&gt; null then
					if quantityRangeMapObj.myChildQuantityMap.myParentFinancialObject.isKindOf(CM_QuantityRangeMap)then
						quantitySubRangeMapObj := quantityRangeMapObj.myChildQuantityMap.allQuantityRanges[quantitySubRange.asIntegerJMT];
						if quantitySubRangeMapObj &lt;&gt; null then			//TFS 6924
						
						
							self.createInvoiceLineMapCargo(invoiceLine, quantitySubRangeMapObj, CargoMap, false, groupingType, null, null); // TFS 40620 seperate method
							quantitySubRange := null ;
							invoiceLine := null;
							quantityRangeMapObj := null;
							moveType := null;
						endif;											//TFS 6924
					endif;
				endif;
			//16/02/2017 cnwma1 TFS #2901
			else	
				if transferType.isInteger() then
					transferTypeId := transferType.Integer;
					transferJobType := app.myRoot.allVoyageJobTransferTypes[transferTypeId];
				endif;
				
				self.createInvoiceLineMapCargo(invoiceLine, quantityRangeMapObj, CargoMap, false, groupingType, null, transferJobType); // TFS 40620 seperate method
				quantitySubRange := null ;
				invoiceLine := null;
				quantityRangeMapObj := null;
				moveType := null;
			endif;
		endif;
	endforeach;
	
epilog
end;
</source>
        <access>protected</access>
        <Parameter name="_allFileRows" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="updateEventCSV" id="8541caf9-428f-4273-b989-5f03aed9ad04">
        <updating/>
        <source>updateEventCSV(_allFileRows:ObjectArray) updating, protected;
// --------------------------------------------------------------------------------
// Created:		April 2010 by cnwjre1
//
// Purpose:		Updates multiple invoice transaction map that have been read from a CSV file
//				(in the same format as the Rate Table extract).
//
// Parameters:	_allFileRows - An object array of file rows (each one being a HugeStringArray).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 24/05/2023	navkc1	CR 57927 Task 57923: Jade - Transaction Map Export Import
// --------------------------------------------------------------------------------
vars
	object				: Object;
	allRowFields		: HugeStringArray;
	bankObj				: CM_Bank;
	rootDebtorObj		: CM_DebtorNode;
	rootObj				: CM_Root;

	eventMapObj			: CM_TranMapEvent;
	eventBrokerObj	 	: CM_EventServiceBroker;
	brokerObj			: CM_ServiceBroker;
	debtorMapObj 		: CM_DebtorMap;
	quantityMapObj 		: CM_QuantityMap;
	quantityRangeMapObj	: CM_QuantityRangeMap;
	resourceMapObj		: CM_ToDoResourceServiceBroker;
	
	rows				: Integer;
	
	// The following are the file field values.
	
	rowType				: String;
	debtorCode			: String;
	mapName				: String;
	eventName			: String;
	quantityType		: String;
	quantityRange		: String;
	groupingType		: String;
	invoiceLine			: String;
	resourceName		: String;
begin
	
	self.createCount	:=	0;
	self.updateCount	:=	0;
	bankObj			:=	self.myBank;
	rootDebtorObj	:=	bankObj.rootDebtorGroup;
	rootObj			:=	app.myRoot;
	
	self.rowCount := 1;
	foreach object in _allFileRows do
		self.rowCount := self.rowCount + 1;

		allRowFields	:=	object.HugeStringArray;
		rows := allRowFields.size;
		if rows &lt; 8 then
			continue;
		endif;
			
		// Get the field values.
		
		rowType			:=	allRowFields[1];
		mapName			:=	allRowFields[2];
		eventName		:=	allRowFields[3];
		resourceName	:=	allRowFields[4]; // 24/05/2023	navkc1	CR 57927 Task 57923
		debtorCode		:=	allRowFields[5];
		quantityType	:=	allRowFields[6];
		quantityRange	:=	allRowFields[7];
		if self.baseColumnCount = 9 then
			groupingType :=	allRowFields[8];
			invoiceLine	:=	allRowFields[9];
		else
			invoiceLine	:=	allRowFields[8];
		endif;
		// no methods
		
		// Event Map
		if not self.createEventMap(bankObj, mapName, eventMapObj) then
			app.raiseCMException3(LoadUpdateError, 'event map', mapName, self.rowCount.String, null, null);	
			setAllErrors('Create Event Map (' &amp; mapName &amp; ')');
			return;
		endif;
		
		// event type
		if not self.createEventTypeMap(eventName, eventMapObj, eventBrokerObj) then
			app.raiseCMException3(LoadUpdateError, 'event type map', eventName, self.rowCount.String, null, null);	
			setAllErrors('Create Event Type Map (' &amp; eventName &amp; ')');
			return;
		endif;
		brokerObj := eventBrokerObj;
		
		// resource // 24/05/2023	navkc1	CR 57927 Task 57923
		if resourceName &lt;&gt; null then
			if not self.createResourceMapForEventOrWO(resourceName, eventBrokerObj, resourceMapObj) then
				app.raiseCMException3(LoadUpdateError, 'resource map', resourceName, self.rowCount.String, null, null);	
				setAllErrors('Create Resource Map (' &amp; resourceName &amp; ')');
				return;
			endif;
			brokerObj := resourceMapObj;
		endif;

		// debtor
		if not self.createDebtorMap(debtorCode,  brokerObj, debtorMapObj) then
			app.raiseCMException3(LoadUpdateError, 'debtor map', debtorCode, self.rowCount.String, null, null);	
			setAllErrors('Create Debtor Map (' &amp; debtorCode &amp; ')');
			return;
		endif;
		
		// quantity type
		if debtorMapObj &lt;&gt; null then
			quantityMapObj := debtorMapObj.myChildQuantityMap;
		else
			quantityMapObj := brokerObj.myChildQuantityMap;
		endif;
		if not self.updateQuantityMap(quantityType, quantityMapObj) then
			app.raiseCMException3(LoadUpdateError, 'quantity map', quantityType, self.rowCount.String, null, null);	
			setAllErrors('Update Quantity Map (' &amp; quantityType &amp; ')');
			return;
		endif;
		
		// quantity range
		if not self.createQuantityRangeMap(quantityRange, quantityMapObj, quantityRangeMapObj) then
			app.raiseCMException3(LoadUpdateError, 'quantity range map', quantityRange, self.rowCount.String, null, null);	
			setAllErrors('Create Quantity Range Map (' &amp; quantityRange &amp; ')');
			return;
		endif;
		
		// invoice line
		self.createInvoiceLineMapEvent(invoiceLine, quantityRangeMapObj, EventMap, false, groupingType, null, null); // TFS 40620 seperate method TFS 41202
		
	endforeach;
epilog
end;
</source>
        <access>protected</access>
        <Parameter name="_allFileRows" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="updateQuantityMap" id="ef1cbd4d-b7be-4558-86d3-1077be17381b">
        <updating/>
        <source>updateQuantityMap(_quantityType : String; _quantityMapObj : CM_QuantityMap) : Boolean updating, protected;

vars
	isDefault	: Boolean;
	calculationTypeObj	: CM_CalculationType;
	mappingType	: Integer;
	chargeZero	: Boolean;
	proxyQuantityMap	: CM_QuantityMap;
	parentObject	: CM_FinancialObject;
begin
	self.getQuantityTypeDetails(_quantityType, isDefault, calculationTypeObj, mappingType, chargeZero);

	if calculationTypeObj &lt;&gt; _quantityMapObj.myCalculationType or
	   mappingType &lt;&gt; _quantityMapObj.mappingType or
	   chargeZero &lt;&gt; _quantityMapObj.chargeZero then
		parentObject := _quantityMapObj.myParentFinancialObject;
		proxyQuantityMap := app.createUpdateProxy(_quantityMapObj).CM_QuantityMap;
		proxyQuantityMap.setProxy(parentObject, chargeZero, mappingType, calculationTypeObj, null);
		app.myTrxUA.trxUpdateInvoiceTMQty(proxyQuantityMap, self.passport);
		if (not app.myPassport.trxCompletedOK) then
			self.setAllErrors('Updating quantity map (' &amp; _quantityType &amp; '), row ' &amp; rowCount.String);
			return false;
		endif;
		self.updateCount := self.updateCount + 1;
	endif;

	return true;
epilog
	delete proxyQuantityMap;	//13 Jan 2011	NDL leaking trans in testing...
end;
</source>
        <access>protected</access>
        <Parameter name="_quantityType" type="String"/>
        <Parameter name="_quantityMapObj" type="CM_QuantityMap"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateQuantityRangeMapMethods" id="3354d64c-8e3a-4c6c-8299-817b20d28714">
        <updating/>
        <source>updateQuantityRangeMapMethods(_quantityRangeMap : CM_QuantityRangeMap input) updating, protected;
// 34477 update the registered methods on the QRM
//16/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
//21/09/2017 cnwma1  TFS #7043:CPL - High priority issue: Transaction map csv load
vars
	i	: Integer;
	methodFlag,
	methodName	: String;
begin
	if self.currentMethods.size &gt; 0 then
		beginTransaction;
		foreach methodFlag in self.currentMethods do
			i := i + 1;
			if methodFlag &lt;&gt; null then
				methodName := self.fullMethodNames[i];
				_quantityRangeMap.addMethod(methodName);
			endif;
		endforeach;
		commitTransaction;
	endif;
	
	/* TFS 8360 moved to updateCargoCSV line 241ish
	if _quantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_ServiceBroker) then    //16/02/2017 cnwma1 TFS #2901
	
		self.allQuantityRangeMaps.add(_quantityRangeMap);
	elseif  _quantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_DebtorMap) then // 21.09.2017 cnwma1 TFS #7043
		self.allQuantityRangeMaps.add(_quantityRangeMap);
	endif;
*/
end;</source>
        <access>protected</access>
        <Parameter name="_quantityRangeMap" type="CM_QuantityRangeMap" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateSnapshotCSV" id="fd9d78ea-efc1-4df1-b229-a7472d8c9d25">
        <updating/>
        <source>updateSnapshotCSV(_allFileRows:ObjectArray; _headers : HugeStringArray) updating, protected;
// --------------------------------------------------------------------------------
// Created:		April 2010 by cnwjre1
//
// Purpose:		Updates multiple invoice transaction map that have been read from a CSV file
//				(in the same format as the Rate Table extract).
//
// Parameters:	_allFileRows - An object array of file rows (each one being a HugeStringArray).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	object				: Object;
	allRowFields		: HugeStringArray;
	bankObj				: CM_Bank;
	rootDebtorObj		: CM_DebtorNode;
	rootObj				: CM_Root;
	snapshotMap 		: CM_TranMapSSSummary;
	sssBrokerObj		: CM_SnapShotServiceBroker;
	debtorTypeObj		: CM_DebtorType;
	outputFormatObj		: CM_OutputFormat_SS;
	invoiceLineDescObj 	: CM_InvoiceLineDesc;
	field 				: CM_XTABField;
	yaCriteria			: IntegerArray;

	isDefault			: Boolean;
	validatedHeader		: Boolean;
	qtyFrom				: Real;
	qtyTo				: Real;
	index				: Integer;
	max					: Integer;
	
	// The following are the file field values.
	
	rowType				: String;
	mapName				: String;
	snapshotName		: String;
	criteriaValues		: HugeStringArray;
	debtorType			: String;
	default				: String;
	quantityType		: String;
	quantityRange		: String;
	invoiceLine			: String;
	
begin
	on Exception do agtPassportExHandler(exception, self.passport);
	self.passport.initialiseTransaction();	

	self.createCount	:=	0;
	self.updateCount	:=	0;
	bankObj			:=	self.myBank;
	rootDebtorObj	:=	bankObj.rootDebtorGroup;
	rootObj			:=	app.myRoot;
	self.myRootDebtor	:=	bankObj.rootDebtorGroup;

	create criteriaValues transient;
	
	self.rowCount := 1;	// count the csv header which has been skipped from the incoming array
	foreach object in _allFileRows do
		self.rowCount := self.rowCount + 1;
		allRowFields	:=	object.HugeStringArray;
		if allRowFields.size &lt; 8 then
			self.validationError("Not enough columns", allRowFields.size.String);
			continue;
		endif;
		
		// Get the field values.
		max := allRowFields.size - 5;	// trailing fixed items
		criteriaValues.clear;
		
		rowType			:=	allRowFields[1];
		mapName			:=	allRowFields[2];
		snapshotName	:=	allRowFields[3];
		foreach index in 4 to max do
			criteriaValues.add(allRowFields[index]);
		endforeach;
		debtorType		:=	allRowFields[index];
		index := index + 1;
		quantityType	:=	allRowFields[index];
		index := index + 1;
		default			:=	allRowFields[index];
		index := index + 1;
		quantityRange	:=	allRowFields[index];
		index := index + 1;
		invoiceLine		:=	allRowFields[index];

		
		// Snapshot Map
		if not self.createSnapshotMap(bankObj, mapName, snapshotMap) then
			app.raiseCMException3(LoadUpdateError, 'snapshot map', mapName, self.rowCount.String, null, null);	
			setAllErrors('Create Snapshot Map (' &amp; mapName &amp; ')');
			return;
		endif;
		
		// get all referenced objects 
		self.getSnapshotDetails(snapshotName, outputFormatObj);
		self.getDebtorType(debtorType, debtorTypeObj);
		self.getQuantityAttribute(quantityType, outputFormatObj, field);
		self.getQuantityRangeDetails(quantityRange, isDefault, qtyFrom, qtyTo);
		self.getInvoiceLineDetails(invoiceLine, invoiceLineDescObj);

		if yaCriteria = null then
			create yaCriteria transient;
			self.getCriteriaValues(outputFormatObj, _headers, yaCriteria);
		endif;

		// Broker
		if not self.createSSBrokerMap(snapshotMap, outputFormatObj, yaCriteria, debtorTypeObj, sssBrokerObj) then
			app.raiseCMException3(LoadUpdateError, 'quantity range map', quantityRange, self.rowCount.String, null, null);	
			setAllErrors('Create Quantity Range Map (' &amp; quantityRange &amp; ')');
			return;
		endif;
		
		// Allocations and invoice line
		self.createInvoiceAllocation(sssBrokerObj, criteriaValues, field, qtyFrom.Integer, qtyTo.Integer, invoiceLineDescObj);
		
	endforeach;
epilog
	delete yaCriteria;
	delete criteriaValues;	//06 Sep 2017	NDL	TFS 6759
end;
</source>
        <access>protected</access>
        <Parameter name="_allFileRows" type="ObjectArray"/>
        <Parameter name="_headers" type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="updateVoyageCSV" id="b5487111-7d8f-4360-ad32-77f8848e35bd">
        <updating/>
        <source>updateVoyageCSV(_allFileRows:ObjectArray) updating, protected;
// --------------------------------------------------------------------------------
// Created:		April 2010 by cnwjre1
//
// Purpose:		Updates multiple invoice transaction map that have been read from a CSV file
//				(in the same format as the Rate Table extract).
//
// Parameters:	_allFileRows - An object array of file rows (each one being a HugeStringArray).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	object				: Object;
	allRowFields		: HugeStringArray;
	bankObj				: CM_Bank;
	rootDebtorObj		: CM_DebtorNode;
	rootObj				: CM_Root;

	voyageMapObj		: CM_TranMapVoyage;
	voyageBrokerObj	 	: CM_ResourceServiceBroker;
	brokerObj			: CM_ServiceBroker;
	debtorMapObj 		: CM_DebtorMap;
	quantityMapObj 		: CM_QuantityMap;
	quantityRangeMapObj	: CM_QuantityRangeMap;
	vesselCategoryObj	: HMS_VesselCategory;
	transferTypeObj		: CM_VoyageJobTransferType;

	rows				: Integer;
	isInContract, default		: Boolean;

	// The following are the file field values.
	
	rowType				: String;
	debtorCode			: String;
	mapName				: String;
	resourceName		: String;
	quantityType		: String;
	quantityRange		: String;
	inContract			: String;
	groupingType		: String;
	invoiceLine			: String;
	vesselCategory		: String;
	transferType		: String;
	cargotypeStr, subtypeStr, commstr :String;
	cargotype : CM_CargoType;
	subtype : CM_Product;
	comm : CM_Commodity;
begin
	
	self.createCount	:=	0;
	self.updateCount	:=	0;
	bankObj			:=	self.myBank;
	rootDebtorObj	:=	bankObj.rootDebtorGroup;
	rootObj			:=	app.myRoot;
	
	self.rowCount := 1;
	foreach object in _allFileRows do
		self.rowCount := self.rowCount + 1;
			
		allRowFields	:=	object.HugeStringArray;
		rows := allRowFields.size;
		if rows &lt; 10 then
			continue;
		endif;
		
		// Get the field values.
		
		rowType			:=	allRowFields[1];
		mapName			:=	allRowFields[2];
		resourceName	:=	allRowFields[3];
		debtorCode		:=	allRowFields[4];
		quantityType	:=	allRowFields[5];
		quantityRange	:=	allRowFields[6];
		inContract		:=	allRowFields[7];
		
		// ### TFS CR 65333 TASK 65334 08AUG2024 NAVAB1
		cargotypeStr := allRowFields[8];
		subtypeStr := allRowFields[9];
		commstr := allRowFields[10];
		vesselCategory 	:=	allRowFields[11];
		transferType 	:=	allRowFields[12];
		if self.baseColumnCount = 14 then
			groupingType :=	allRowFields[13];
			invoiceLine	:=	allRowFields[14].trimBlanks;
		else
			invoiceLine	:=	allRowFields[13].trimBlanks;
		endif;
		/*
		vesselCategory 	:=	allRowFields[8];
		transferType 	:=	allRowFields[9];
		if self.baseColumnCount = 11 then
			groupingType :=	allRowFields[10];
			invoiceLine	:=	allRowFields[11].trimBlanks;
		else
			invoiceLine	:=	allRowFields[10].trimBlanks;
		endif;
		*/
		// no methods
		
		// Event Map
		if not self.createVoyageMap(bankObj, mapName, voyageMapObj) then
			app.raiseCMException3(LoadUpdateError, 'voyage map', mapName, self.rowCount.String, null, null);	
			setAllErrors('Create Voyage Map (' &amp; mapName &amp; ')');
			return;
		endif;
		
		// event type
		if not self.createResourceMap(resourceName, voyageMapObj, voyageBrokerObj) then
			app.raiseCMException3(LoadUpdateError, 'resource map', resourceName, self.rowCount.String, null, null);	
			setAllErrors('Create Event Type Map (' &amp; resourceName &amp; ')');
			return;
		endif;
		brokerObj := voyageBrokerObj;

		// debtor
		if not self.createDebtorMap(debtorCode,  brokerObj, debtorMapObj) then
			app.raiseCMException3(LoadUpdateError, 'debtor map', debtorCode, self.rowCount.String, null, null);	
			setAllErrors('Create Debtor Map (' &amp; debtorCode &amp; ')');
			return;
		endif;
		
		// quantity type
		if debtorMapObj &lt;&gt; null then
			quantityMapObj := debtorMapObj.myChildQuantityMap;
		else
			quantityMapObj := brokerObj.myChildQuantityMap;
		endif;
		if not self.updateQuantityMap(quantityType, quantityMapObj) then
			app.raiseCMException3(LoadUpdateError, 'quantity map', quantityType, self.rowCount.String, null, null);	
			setAllErrors('Update Quantity Map (' &amp; quantityType &amp; ')');
			return;
		endif;
		
		// quantity range
		if not self.createQuantityRangeMap(quantityRange, quantityMapObj, quantityRangeMapObj) then
			app.raiseCMException3(LoadUpdateError, 'quantity range map', quantityRange, self.rowCount.String, null, null);	
			setAllErrors('Create Quantity Range Map (' &amp; quantityRange &amp; ')');
			return;
		endif;
		
		// in contract
		self.getInContractDetails(inContract, isInContract);
		
		// vessel category
		self.getVesselCategory(vesselCategory, vesselCategoryObj);		// 19/6/18 MAP TFS38899

		// ### TFS CR 65333 TASK 65334 08AUG2024 NAVAB1
		cargotype := null;
		if cargotypeStr &lt;&gt; null then
			self.getCargoTypeDetails(cargotypeStr,default,cargotype);
		endif;
		subtype := null;
		if subtypeStr &lt;&gt; null then
			if cargotype &lt;&gt; null then
				subtype := cargotype.getProductFromCode(subtypeStr);
			endif;
		endif;
		comm := null;
		if commstr &lt;&gt; null then
			comm := app.myRoot.allCommodities[commstr];
		endif;

		
		// TFS 39740 TRANSFER TYPE FOR VOYAGE TRAN MAPS IS NO LONGER SHOWN IN THE UI
		// transfer type
		self.getTransferType(transferType, transferTypeObj);			// 19/6/18 MAP TFS38899

		// invoice line
		 // TFS 40620 seperate method
		self.createInvoiceLineMapVoyage(invoiceLine, quantityRangeMapObj, VoyageMap, isInContract, groupingType, vesselCategoryObj, transferTypeObj,cargotype, subtype, comm);
		
	endforeach;
epilog
end;
</source>
        <access>protected</access>
        <Parameter name="_allFileRows" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="updateWOCSV" id="28ff025e-0fdb-4550-a0a6-f555c31b2255">
        <updating/>
        <source>updateWOCSV(_allFileRows:ObjectArray) updating, protected;
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
24/05/2023		navkc1		CR 57927 Task 57923: Jade - Transaction Map Export Import
*/
vars
	object				: Object;
	allRowFields		: HugeStringArray;
	bankObj				: CM_Bank;
	rootDebtorObj		: CM_DebtorNode;
	rootObj				: CM_Root;

	workOrderMapObj		: CM_TranMapWorkOrder;
	workOrderBrokerObj	 : CM_WorkOrderServiceBroker;
	brokerObj			: CM_ServiceBroker;
	debtorMapObj 		: CM_DebtorMap;
	quantityMapObj 		: CM_QuantityMap;
	quantityRangeMapObj	: CM_QuantityRangeMap;
	resourceMapObj		: CM_ToDoResourceServiceBroker;

	rows				: Integer;
	
	// The following are the file field values.
	
	rowType				: String;
	debtorCode			: String;
	mapName				: String;
	workOrderName		: String;
	quantityType		: String;
	quantityRange		: String;
	groupingType		: String;
	invoiceLine			: String;
	resourceName		: String;
begin
	
	self.createCount	:=	0;
	self.updateCount	:=	0;
	bankObj			:=	self.myBank;
	rootDebtorObj	:=	bankObj.rootDebtorGroup;
	rootObj			:=	app.myRoot;
	
	self.rowCount := 1;
	foreach object in _allFileRows do
		self.rowCount := self.rowCount + 1;

		allRowFields	:=	object.HugeStringArray;
		rows := allRowFields.size;
		if rows &lt; 8 then
			continue;
		endif;
		// Get the field values.
		
		rowType			:=	allRowFields[1];
		mapName			:=	allRowFields[2];
		workOrderName	:=	allRowFields[3];
		resourceName	:=	allRowFields[4]; // 24/05/2023	navkc1	CR 57927 Task 57923
		debtorCode		:=	allRowFields[5];
		quantityType	:=	allRowFields[6];
		quantityRange	:=	allRowFields[7];
		if self.baseColumnCount = 9 then
			groupingType :=	allRowFields[8];
			invoiceLine	:=	allRowFields[9];
		else
			invoiceLine	:=	allRowFields[8];
		endif;
		// no methods
		
		// WorkOrder Map
		if not self.createWorkOrderMap(bankObj, mapName, workOrderMapObj) then
			app.raiseCMException3(LoadUpdateError, 'WorkOrder map', mapName, self.rowCount.String, null, null);	
			setAllErrors('Create WorkOrder Map (' &amp; mapName &amp; ')');
			return;
		endif;
		
		// WorkOrder type
		if not self.createWorkOrderTypeMap(workOrderName, workOrderMapObj, workOrderBrokerObj) then
			app.raiseCMException3(LoadUpdateError, 'WorkOrder type map', workOrderName, self.rowCount.String, null, null);	
			setAllErrors('Create WorkOrder Type Map (' &amp; workOrderName &amp; ')');
			return;
		endif;
		brokerObj := workOrderBrokerObj;
		
		// resource // 24/05/2023	navkc1	CR 57927 Task 57923
		if resourceName &lt;&gt; null then
			if not self.createResourceMapForEventOrWO(resourceName, workOrderBrokerObj, resourceMapObj) then
				app.raiseCMException3(LoadUpdateError, 'resource map', resourceName, self.rowCount.String, null, null);	
				setAllErrors('Create Resource Map (' &amp; resourceName &amp; ')');
				return;
			endif;
			brokerObj := resourceMapObj;
		endif;
			
		// debtor
		if not self.createDebtorMap(debtorCode,  brokerObj, debtorMapObj) then
			app.raiseCMException3(LoadUpdateError, 'debtor map', debtorCode, self.rowCount.String, null, null);	
			setAllErrors('Create Debtor Map (' &amp; debtorCode &amp; ')');
			return;
		endif;
		
		// quantity type
		if debtorMapObj &lt;&gt; null then
			quantityMapObj := debtorMapObj.myChildQuantityMap;
		else
			quantityMapObj := brokerObj.myChildQuantityMap;
		endif;
		if not self.updateQuantityMap(quantityType, quantityMapObj) then
			app.raiseCMException3(LoadUpdateError, 'quantity map', quantityType, self.rowCount.String, null, null);	
			setAllErrors('Update Quantity Map (' &amp; quantityType &amp; ')');
			return;
		endif;
		
		// quantity range
		if not self.createQuantityRangeMap(quantityRange, quantityMapObj, quantityRangeMapObj) then
			app.raiseCMException3(LoadUpdateError, 'quantity range map', quantityRange, self.rowCount.String, null, null);	
			setAllErrors('Create Quantity Range Map (' &amp; quantityRange &amp; ')');
			return;
		endif;
		
		// invoice line
		self.createInvoiceLineMapWO(invoiceLine, quantityRangeMapObj, WOMap, false, groupingType, null, null); // TFS 40620 seperate method
		
	endforeach;
epilog
end;
</source>
        <access>protected</access>
        <Parameter name="_allFileRows" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="validateBOLCSV" id="295fdfe0-fd07-4dd6-87ac-4e5803f61c1f">
        <updating/>
        <source>validateBOLCSV(_allFileRows : ObjectArray) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars
	object				: Object;
	allRowFields		: HugeStringArray;
	debtorObj			: CM_DebtorNode;
	debtorTypeObj		: CM_DebtorType;
	calculationTypeObj	: CM_CalculationType;
	groupTypeObj		: CM_TranMapInvoiceLineGroupType;
	invoiceLineDescObj 	: CM_InvoiceLineDesc;
	trantype : CM_TransactionType;
	chargeZero			: Boolean;
	isDefault			: Boolean;
	currentPath			: String;
	qtyFrom				: Real;
	qtyTo				: Real;
	i					: Integer;
	mappingType			: Integer;
	
	// The following are the file field values.
	
	rowType				: String;
	debtorCode			: String;
	mapName				: String;
	bolTrxName			: String;
	quantityType		: String;
	quantityRange		: String;
	groupingType		: String;
	invoiceLine			: String;
	
begin
	on Exception do agtPassportExHandler(exception, self.passport);
	self.passport.initialiseTransaction();	

	self.myRootDebtor	:=	self.myBank.rootDebtorGroup;
	
	self.rowCount := 1;	// count the csv header which has been skipped from the incoming array
	foreach object in _allFileRows do
		self.rowCount := self.rowCount + 1;
		allRowFields	:=	object.HugeStringArray;
		if allRowFields.size &lt; 7 then
			self.validationError("Not enough columns", allRowFields.size.String);
			continue;
		endif;
		
		// Get the field values.
		
		rowType			:=	allRowFields[1];
		mapName			:=	allRowFields[2];
		bolTrxName		:=	allRowFields[3];
		debtorCode		:=	allRowFields[4];
		quantityType	:=	allRowFields[5];
		quantityRange	:=	allRowFields[6];
		if self.baseColumnCount = 8 then
			groupingType :=	allRowFields[7];
			invoiceLine	:=	allRowFields[8];
		else
			invoiceLine	:=	allRowFields[7];
		endif;
		currentPath := "";
		foreach i in 1 to 6 do
			currentPath := currentPath &amp; allRowFields[i];
		endforeach;
		
		// Work Order Map
		if mapName = "" then
			self.validationError("Map name is null", null);
		endif;
		
		// transaction 
		self.getBOLDetails(bolTrxName, isDefault, trantype);
		
		// debtor
		self.getDebtorDetails(debtorCode, isDefault, debtorObj, debtorTypeObj);
		
		// quantity type
		self.getQuantityTypeDetails(quantityType, isDefault, calculationTypeObj, mappingType, chargeZero);
	
		// quantity range
		self.getQuantityRangeDetails(quantityRange, isDefault, qtyFrom, qtyTo);
		
		// group type
		if self.baseColumnCount = 8 then
			self.getGroupTypeDetails(groupingType, groupTypeObj);
		endif;
		
		// invoice line
		self.getInvoiceLineDetails(invoiceLine, invoiceLineDescObj);
		self.checkForVoidInvoiceLine(currentPath, invoiceLine);
		
	endforeach;

	if not self.passport.hasErrors() then
		self.passport.finaliseTransaction(TRXStatus_Committed);
	endif;
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_allFileRows" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="validateCargoCSV" id="9acd33dd-2291-4475-b450-24a672152c9e">
        <updating/>
        <source>validateCargoCSV(_allFileRows : ObjectArray) updating, protected;
// --------------------------------------------------------------------------------
// Created:		April 2010 by cnwjre1
//
// Purpose:		Do per-field validation 
//
// Parameters:	_allFileRows - An object array of file rows (each one being a HugeStringArray).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//09/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
// --------------------------------------------------------------------------------
vars
	object				: Object;
	allRowFields		: HugeStringArray;
	debtorObj			: CM_DebtorNode;
	debtorTypeObj		: CM_DebtorType;
	cargoTypeObj		: CM_CargoType;
	productGroupObj		: CM_ProductGroup;
	productObj			: CM_Product ;
	imexObj				: CM_CargoStatus;
	contentsStatusObj	: CM_CargoStatus;
	commodityObj		: CM_Commodity;
	resourceTypeObj		: CM_ResourceType;
	calculationTypeObj	: CM_CalculationType;
	tranTypeObj			: CM_TransactionType;
	groupTypeObj		: CM_TranMapInvoiceLineGroupType;
	invoiceLineDescObj 	: CM_InvoiceLineDesc;

	chargeZero			: Boolean;
	isDefault			: Boolean;
	isMove				: Boolean;
	currentPath			: String;
	moveFrom			: String;
	moveTo				: String;
	qtyFrom				: Real;
	qtyTo				: Real;
	i					: Integer;
	mappingType			: Integer;
	
	// The following are the file field values.
	
	rowType				: String;
	debtorCode			: String;
	mapName				: String;
	cargoType			: String;
	cargoSubtypeGroup	: String;
	cargoSubtype		: String;
	imex				: String;
	contentsStatus		: String;
	commodity			: String;
	transaction			: String;
	moveType			: String;
	quantityType		: String;
	quantityRange		: String;
	groupingType		: String;
	invoiceLine			: String;
	quantitySubType		: String;	//13/02/2017 cnwma1 TFS #2901
	quantitySubRange    : String;   //13/02/2017 cnwma1 TFS #2901
	curPath				: Integer;  //13/02/2017 cnwma1 TFS #2901
	transferType : String; // TFS 41096
	
begin
	on Exception do agtPassportExHandler(exception, self.passport);
	self.passport.initialiseTransaction();	

	self.myRootDebtor	:=	self.myBank.rootDebtorGroup;
	
	self.rowCount := 1;	// count the csv header which has been skipped from the incoming array
	foreach object in _allFileRows do
		self.rowCount := self.rowCount + 1;
		allRowFields	:=	object.HugeStringArray;
		if allRowFields.size &lt; 14 then
			self.validationError("Not enough columns", allRowFields.size.String);
			continue;
		endif;
		
		// Get the field values.
		
		rowType			:=	allRowFields[1];
		mapName			:=	allRowFields[2];
		cargoType		:=	allRowFields[3];
		cargoSubtypeGroup	:=	allRowFields[4];
		cargoSubtype	:=	allRowFields[5];
		imex			:=	allRowFields[6];
		contentsStatus	:=	allRowFields[7];
		commodity		:=	allRowFields[8]; 
		transaction		:=	allRowFields[9];
		moveType		:=	allRowFields[10];
		debtorCode		:=	allRowFields[11];
		quantityType	:=	allRowFields[12];
		quantityRange	:=	allRowFields[13];
		
		//13/02/2017 cnwma1 TFS #2901
		/*if self.baseColumnCount = 15 then
			groupingType :=	allRowFields[14];
			invoiceLine	:=	allRowFields[15];
		else
			invoiceLine	:=	allRowFields[14];
		endif;*/	
		//13/02/2017 cnwma1 TFS #2901
		if self.baseColumnCount = 17 then 
			groupingType :=	allRowFields[16];
			invoiceLine	:=	allRowFields[17];
			quantitySubType	:=	allRowFields[14];
			quantitySubRange	:=	allRowFields[15];
			curPath :=15;
		elseif self.baseColumnCount = 18 then 
			transferType := allRowFields[16]; // TFS 41096
			groupingType :=	allRowFields[17];
			invoiceLine	:=	allRowFields[18];
			quantitySubType	:=	allRowFields[14];
			quantitySubRange	:=	allRowFields[15];
			curPath :=15;
		elseif  self.baseColumnCount = 15 then
			groupingType :=	allRowFields[14];
			invoiceLine	:=	allRowFields[15];
			curPath :=13;
		else
			if self.baseColumnCount =14 then
				invoiceLine	:=	allRowFields[14];
			elseif  self.baseColumnCount =15   then
				invoiceLine	:=	allRowFields[15];
			endif;
			curPath := 13;
		endif;
		
		currentPath := "";
	
		//foreach i in 1 to 13 do 				 //13/02/2017 cnwma1 TFS #2901
		foreach i in 1 to curPath do             //13/02/2017 cnwma1 TFS #2901
			currentPath := currentPath &amp; allRowFields[i];
		endforeach;
		
		// Cargo Map
		if mapName = "" then
			self.validationError("Map name is null", null);
		endif;
		
		// Cargo type
		self.getCargoTypeDetails(cargoType, isDefault, cargoTypeObj);
		
		//product group
		self.getProductGroupDetails(cargoSubtypeGroup, cargoTypeObj, isDefault, productGroupObj);
		
		// product
		self.getProductDetails(cargoSubtype, productGroupObj, cargoTypeObj, isDefault, productObj);
		
		// imex
		self.getImexDetails(imex, isDefault, imexObj);
		
		// contents status
		self.getContentsStatusDetails(contentsStatus, isDefault, contentsStatusObj);
		
		// commodity
		self.getCommodityDetails(commodity, isDefault, commodityObj);
		
		// transaction
		self.getTransactionDetails(transaction, isDefault, isMove, tranTypeObj);
		
	
		// move/resource
		self.getMoveDetails(moveType, isMove, moveFrom, moveTo, resourceTypeObj);
		
		// debtor
		self.getDebtorDetails(debtorCode, isDefault, debtorObj, debtorTypeObj);
		
		// quantity type
		self.getQuantityTypeDetails(quantityType, isDefault, calculationTypeObj, mappingType, chargeZero);
	
		// quantity range
		self.getQuantityRangeDetails(quantityRange, isDefault, qtyFrom, qtyTo);
		
		// quantity Sub range
		if quantitySubType &lt;&gt; null and quantitySubRange &lt;&gt; null then			//13/02/2017 cnwma1 TFS #2901
			self.getQuantityTypeDetails(quantitySubType, isDefault, calculationTypeObj, mappingType, chargeZero);
			self.getQuantityRangeDetails(quantitySubRange, isDefault, qtyFrom, qtyTo);
		
		endif;
			
		// group type
		if self.baseColumnCount = 15 then  //13/02/2017 cnwma1 TFS #2901
			self.getGroupTypeDetails(groupingType, groupTypeObj);
		elseif self.baseColumnCount = 17 then   //13/02/2017 cnwma1 TFS #2901
			self.getGroupTypeDetails(groupingType, groupTypeObj);
		elseif self.baseColumnCount = 18 then   // TFS 41096
			self.getGroupTypeDetails(groupingType, groupTypeObj);
		endif;
	
		// invoice line
		self.getInvoiceLineDetails(invoiceLine, invoiceLineDescObj);
		self.checkForVoidInvoiceLine(currentPath, invoiceLine);
				
	endforeach;

	if not self.passport.hasErrors() then
		self.passport.finaliseTransaction(TRXStatus_Committed);
	endif;
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_allFileRows" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="validateEventCSV" id="71af063a-9bfc-409b-9032-da9e80503583">
        <updating/>
        <source>validateEventCSV(_allFileRows : ObjectArray) updating, protected;
// --------------------------------------------------------------------------------
// Created:		April 2010 by cnwjre1
//
// Purpose:		Do per-field validation 
//
// Parameters:	_allFileRows - An object array of file rows (each one being a HugeStringArray).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 24/05/2023	navkc1	CR 57927 Task 57923: Jade - Transaction Map Export Import
// --------------------------------------------------------------------------------
vars
	object				: Object;
	allRowFields		: HugeStringArray;
	debtorObj			: CM_DebtorNode;
	debtorTypeObj		: CM_DebtorType;
	eventTypeObj		: CM_EventType;
	calculationTypeObj	: CM_CalculationType;
	groupTypeObj		: CM_TranMapInvoiceLineGroupType;
	invoiceLineDescObj 	: CM_InvoiceLineDesc;
	resourceTypeObj		: CM_ResourceType;
	
	chargeZero			: Boolean;
	isDefault			: Boolean;
	currentPath			: String;
	qtyFrom				: Real;
	qtyTo				: Real;
	i					: Integer;
	mappingType			: Integer;
	moveFrom			: String;
	moveTo				: String;
	
	// The following are the file field values.
	
	rowType				: String;
	debtorCode			: String;
	resourceName		: String;
	mapName				: String;
	eventName			: String;
	quantityType		: String;
	quantityRange		: String;
	groupingType		: String;
	invoiceLine			: String;
	
begin
	on Exception do agtPassportExHandler(exception, self.passport);
	self.passport.initialiseTransaction();	

	self.myRootDebtor	:=	self.myBank.rootDebtorGroup;
	
	self.rowCount := 1;	// count the csv header which has been skipped from the incoming array
	foreach object in _allFileRows do
		self.rowCount := self.rowCount + 1;
		allRowFields	:=	object.HugeStringArray;
		if allRowFields.size &lt; 8 then
			self.validationError("Not enough columns", allRowFields.size.String);
			continue;
		endif;
		
		// Get the field values.
		
		rowType			:=	allRowFields[1];
		mapName			:=	allRowFields[2];
		eventName		:=	allRowFields[3];
		resourceName	:=	allRowFields[4]; // 24/05/2023	navkc1	CR 57927 Task 57923
		debtorCode		:=	allRowFields[5];
		quantityType	:=	allRowFields[6];
		quantityRange	:=	allRowFields[7];
		if self.baseColumnCount = 9 then
			groupingType :=	allRowFields[8];
			invoiceLine	:=	allRowFields[9];
		else
			invoiceLine	:=	allRowFields[8];
		endif;
		currentPath := "";
		foreach i in 1 to 7 do
			currentPath := currentPath &amp; allRowFields[i];
		endforeach;
		
		// Event Map
		if mapName = "" then
			self.validationError("Map name is null", null);
		endif;
		
		// event 
		self.getEventDetails(eventName, isDefault, eventTypeObj);
		
		// resource // 24/05/2023	navkc1	CR 57927 Task 57923
		self.getMoveDetails(resourceName, false, moveFrom, moveTo, resourceTypeObj);
		
		// debtor
		self.getDebtorDetails(debtorCode, isDefault, debtorObj, debtorTypeObj);
		
		// quantity type
		self.getQuantityTypeDetails(quantityType, isDefault, calculationTypeObj, mappingType, chargeZero);
	
		// quantity range
		self.getQuantityRangeDetails(quantityRange, isDefault, qtyFrom, qtyTo);
		
		// group type
		if self.baseColumnCount = 9 then
			self.getGroupTypeDetails(groupingType, groupTypeObj);
		endif;
		
		// invoice line
		self.getInvoiceLineDetails(invoiceLine, invoiceLineDescObj);
		self.checkForVoidInvoiceLine(currentPath, invoiceLine);
		
	endforeach;

	if not self.passport.hasErrors() then
		self.passport.finaliseTransaction(TRXStatus_Committed);
	endif;
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_allFileRows" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="validateSnapshotCSV" id="07e1b8de-a997-4f93-a48c-9796386b66ce">
        <updating/>
        <source>validateSnapshotCSV(_allFileRows : ObjectArray; _headers : HugeStringArray) updating, protected;
// --------------------------------------------------------------------------------
// Created:		oct 2010 by cnwjre1
//
// Purpose:		Do per-field validation 
//
// Parameters:	_allFileRows - An object array of file rows (each one being a HugeStringArray)
//				_headers	HugeStringArray of the file headers, which contain the query property names
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	object				: Object;
	allRowFields		: HugeStringArray;
	debtorTypeObj		: CM_DebtorType;
	outputFormatObj		: CM_OutputFormat_SS;
	invoiceLineDescObj 	: CM_InvoiceLineDesc;
	field 				: CM_XTABField;

	isDefault			: Boolean;
	validatedHeader		: Boolean;
	qtyFrom				: Real;
	qtyTo				: Real;
	index				: Integer;
	max					: Integer;
	
	// The following are the file field values.
	
	rowType				: String;
	mapName				: String;
	snapshotName		: String;
	criteriaValues		: HugeStringArray;
	debtorType			: String;
	default				: String;
	quantityType		: String;
	quantityRange		: String;
	invoiceLine			: String;
	
begin
	on Exception do agtPassportExHandler(exception, self.passport);
	self.passport.initialiseTransaction();	

	self.myRootDebtor	:=	self.myBank.rootDebtorGroup;
	create criteriaValues transient;
	
	self.rowCount := 1;	// count the csv header which has been skipped from the incoming array
	foreach object in _allFileRows do
		self.rowCount := self.rowCount + 1;
		allRowFields	:=	object.HugeStringArray;
		if allRowFields.size &lt; 8 then
			self.validationError("Not enough columns", allRowFields.size.String);
			continue;
		endif;
		
		// Get the field values.
		max := allRowFields.size - 5;	// trailing fixed items
		criteriaValues.clear;
		
		rowType			:=	allRowFields[1];
		mapName			:=	allRowFields[2];
		snapshotName	:=	allRowFields[3];
		foreach index in 4 to max do
			criteriaValues.add(allRowFields[index]);
		endforeach;
		debtorType		:=	allRowFields[index];
		index := index + 1;
		quantityType	:=	allRowFields[index];
		index := index + 1;
		default			:=	allRowFields[index];
		index := index + 1;
		quantityRange	:=	allRowFields[index];
		index := index + 1;
		invoiceLine		:=	allRowFields[index];

		// Snapshot Map
		if mapName = "" then
			self.validationError("Map name is null", null);
		endif;
		
		// snap shot summary 
		self.getSnapshotDetails(snapshotName, outputFormatObj);
		
		// invoice allocations
		if not validatedHeader then
			self.validateSnapshotHeader(outputFormatObj, _headers);
			validatedHeader := true;
		endif;
		
		// debtor type for derive debtor from
		self.getDebtorType(debtorType, debtorTypeObj);
		
		// quantity attribute
		self.getQuantityAttribute(quantityType, outputFormatObj, field);
	
		// quantity range
		self.getQuantityRangeDetails(quantityRange, isDefault, qtyFrom, qtyTo);
		
		// invoice line
		self.getInvoiceLineDetails(invoiceLine, invoiceLineDescObj);
		
	endforeach;

	if not self.passport.hasErrors() then
		self.passport.finaliseTransaction(TRXStatus_Committed);
	endif;
epilog
	delete criteriaValues;
end;
</source>
        <access>protected</access>
        <Parameter name="_allFileRows" type="ObjectArray"/>
        <Parameter name="_headers" type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="validateSnapshotHeader" id="f5558e7a-c28f-4a1d-83c8-65a379611e92">
        <updating/>
        <source>validateSnapshotHeader(_outputFormat : CM_OutputFormat_SS; _headers : HugeStringArray) updating, protected;
// --------------------------------------------------------------------------------
// Created:		oct 2010 by cnwjre1
//
// Purpose:		Do per-field validation 
//
// Parameters:	_allFileRows - An object array of file rows (each one being a HugeStringArray)
//				_headers	HugeStringArray of the file headers, which contain the query property names
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	max,
	index		: Integer;
	found		: Boolean;
	propName	: String;
	allGroupProps : CM_QueryPropertyArray;
	queryProp	: CM_QueryProperty;
	
begin
	create allGroupProps transient;
	_outputFormat.getGroupingProperties( allGroupProps );
	
	max := _headers.size - 5;	// trailing fixed items
	foreach index in 4 to max do
		propName := _headers[index];
		found := false;
		foreach queryProp in allGroupProps where queryProp.allocationAttribute &lt;&gt; 0 do
			if queryProp.niceName = propName then
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			self.validationError("Invalid snapshot attribute", propName);
		endif;
	endforeach;

epilog
	delete allGroupProps;

end;
</source>
        <access>protected</access>
        <Parameter name="_outputFormat" type="CM_OutputFormat_SS"/>
        <Parameter name="_headers" type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="validateVoyageCSV" id="4c89277a-0ba4-4d1c-8ef0-43492c5fbd77">
        <updating/>
        <source>validateVoyageCSV(_allFileRows : ObjectArray) updating, protected;
// --------------------------------------------------------------------------------
// Created:		April 2010 by cnwjre1
//
// Purpose:		Do per-field validation 
//
// Parameters:	_allFileRows - An object array of file rows (each one being a HugeStringArray).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	object				: Object;
	allRowFields		: HugeStringArray;
	debtorObj			: CM_DebtorNode;
	debtorTypeObj		: CM_DebtorType;
	resourceObj 		: HMS_Resource;
	calculationTypeObj	: CM_CalculationType;
	groupTypeObj		: CM_TranMapInvoiceLineGroupType;
	invoiceLineDescObj 	: CM_InvoiceLineDesc;
	vesselCategoryObj	: HMS_VesselCategory;
	transferTypeObj		: CM_VoyageJobTransferType;

	chargeZero			: Boolean;
	isDefault			: Boolean;
	isInContract		: Boolean;
	qtyFrom				: Real;
	qtyTo				: Real;
	i					: Integer;
	mappingType			: Integer;
	currentPath			: String;
	
	// The following are the file field values.
	
	rowType				: String;
	debtorCode			: String;
	mapName				: String;
	resourceName		: String;
	quantityType		: String;
	quantityRange		: String;
	inContract			: String;
	groupingType		: String;
	invoiceLine			: String;
	vesselCategory		: String;
	transferType		: String;
	cargotype, subtype, comm : String;
	cargoTypeObj : CM_CargoType;
	productObj : CM_Product;
	commodityObj : CM_Commodity;
begin
	on Exception do agtPassportExHandler(exception, self.passport);
	self.passport.initialiseTransaction();	
	

	self.myRootDebtor	:=	self.myBank.rootDebtorGroup;
	
	self.rowCount := 1;	// count the csv header which has been skipped from the incoming array
	foreach object in _allFileRows do
		self.rowCount := self.rowCount + 1;
		allRowFields	:=	object.HugeStringArray;
		if allRowFields.size &lt; 10 then
			self.validationError("Not enough columns", allRowFields.size.String);
			continue;
		endif;
		
		// Get the field values.
		
		rowType			:=	allRowFields[1];
		mapName			:=	allRowFields[2];
		resourceName	:=	allRowFields[3];
		debtorCode		:=	allRowFields[4];
		quantityType	:=	allRowFields[5];
		quantityRange	:=	allRowFields[6];
		inContract		:=	allRowFields[7];
		
		cargotype := allRowFields[8];
		subtype := allRowFields[9];
		comm := allRowFields[10];
		
		
		vesselCategory 	:=	allRowFields[11];
		transferType 	:=	allRowFields[12];
		if self.baseColumnCount = 14 then
			groupingType :=	allRowFields[13];
			invoiceLine	:=	allRowFields[14].trimBlanks;
		else
			invoiceLine	:=	allRowFields[13].trimBlanks;
		endif;
		
		
		
/*		
		vesselCategory 	:=	allRowFields[8];
		transferType 	:=	allRowFields[9];
		if self.baseColumnCount = 11 then
			groupingType :=	allRowFields[10];
			invoiceLine	:=	allRowFields[11].trimBlanks;
		else
			invoiceLine	:=	allRowFields[10].trimBlanks;
		endif;
*/
		currentPath := "";
		foreach i in 1 to 7 do
			currentPath := currentPath &amp; allRowFields[i];
		endforeach;
		
		// map
		if mapName = "" then
			self.validationError("Map name is null", null);
		endif;
		
		// resource 
		self.getResourceDetails(resourceName, isDefault, resourceObj);
		
		// debtor
		self.getDebtorDetails(debtorCode, isDefault, debtorObj, debtorTypeObj);
		
		// quantity type
		self.getQuantityTypeDetails(quantityType, isDefault, calculationTypeObj, mappingType, chargeZero);
	
		// quantity range
		self.getQuantityRangeDetails(quantityRange, isDefault, qtyFrom, qtyTo);
		
		// in contract
		self.getInContractDetails(inContract, isInContract);

		// vessel category
		self.getVesselCategory(vesselCategory, vesselCategoryObj);		// 19/6/18 MAP TFS38899
		
		// ### TFS CR 65333 TASK 65334 08AUG2024 NAVAB1
		// Cargo type
		self.getCargoTypeDetails(cargotype, isDefault, cargoTypeObj);
		
		// product
		self.getProductDetails(subtype, null, cargoTypeObj, isDefault, productObj);

		// commodity
		self.getCommodityDetails(comm, isDefault, commodityObj);
	
		
		
		
		
		

		// TFS 39740 TRANSFER TYPE FOR VOYAGE TRAN MAPS IS NO LONGER SHOWN IN THE UI
		// transfer type
		self.getTransferType(transferType, transferTypeObj);			// 19/6/18 MAP TFS38899

		// group type
		if self.baseColumnCount = 11 then
			self.getGroupTypeDetails(groupingType, groupTypeObj);
		endif;
		
		// invoice line
		self.getInvoiceLineDetails(invoiceLine, invoiceLineDescObj);
		self.checkForVoidInvoiceLine(currentPath, invoiceLine);
		
	endforeach;

	if not self.passport.hasErrors() then
		self.passport.finaliseTransaction(TRXStatus_Committed);
	endif;
epilog

end;

</source>
        <access>protected</access>
        <Parameter name="_allFileRows" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="validateWOCSV" id="53a6f22b-22a0-49d4-a6ad-2e7d99fafec7">
        <updating/>
        <source>validateWOCSV(_allFileRows : ObjectArray) updating, protected;
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
24/05/2023		navkc1		CR 57927 Task 57923: Jade - Transaction Map Export Import
*/
vars
	object				: Object;
	allRowFields		: HugeStringArray;
	debtorObj			: CM_DebtorNode;
	debtorTypeObj		: CM_DebtorType;
	calculationTypeObj	: CM_CalculationType;
	groupTypeObj		: CM_TranMapInvoiceLineGroupType;
	invoiceLineDescObj 	: CM_InvoiceLineDesc;
	trantype 			: CM_TransactionType;
	chargeZero			: Boolean;
	isDefault			: Boolean;
	currentPath			: String;
	qtyFrom				: Real;
	qtyTo				: Real;
	i					: Integer;
	mappingType			: Integer;
	resourceTypeObj		: CM_ResourceType;
	moveFrom			: String;
	moveTo				: String;
	
	// The following are the file field values.
	
	rowType				: String;
	debtorCode			: String;
	mapName				: String;
	workorderName		: String;
	quantityType		: String;
	quantityRange		: String;
	groupingType		: String;
	invoiceLine			: String;
	resourceName		: String;
	
begin
	on Exception do agtPassportExHandler(exception, self.passport);
	self.passport.initialiseTransaction();	

	self.myRootDebtor	:=	self.myBank.rootDebtorGroup;
	
	self.rowCount := 1;	// count the csv header which has been skipped from the incoming array
	foreach object in _allFileRows do
		self.rowCount := self.rowCount + 1;
		allRowFields	:=	object.HugeStringArray;
		if allRowFields.size &lt; 8 then
			self.validationError("Not enough columns", allRowFields.size.String);
			continue;
		endif;
		
		// Get the field values.
		
		rowType			:=	allRowFields[1];
		mapName			:=	allRowFields[2];
		workorderName	:=	allRowFields[3];
		resourceName	:= 	allRowFields[4]; // 24/05/2023	navkc1	CR 57927 Task 57923
		debtorCode		:=	allRowFields[5];
		quantityType	:=	allRowFields[6];
		quantityRange	:=	allRowFields[7];
		if self.baseColumnCount = 9 then
			groupingType :=	allRowFields[8];
			invoiceLine	:=	allRowFields[9];
		else
			invoiceLine	:=	allRowFields[8];
		endif;
		currentPath := "";
		foreach i in 1 to 7 do
			currentPath := currentPath &amp; allRowFields[i];
		endforeach;
		
		// Work Order Map
		if mapName = "" then
			self.validationError("Map name is null", null);
		endif;
		
		// transaction 
		self.getWODetails(workorderName, isDefault, trantype);
		
		// resouce // 24/05/2023	navkc1	CR 57927 Task 57923
		self.getMoveDetails(resourceName, false, moveFrom, moveTo, resourceTypeObj);
		
		// debtor
		self.getDebtorDetails(debtorCode, isDefault, debtorObj, debtorTypeObj);
		
		// quantity type
		self.getQuantityTypeDetails(quantityType, isDefault, calculationTypeObj, mappingType, chargeZero);
	
		// quantity range
		self.getQuantityRangeDetails(quantityRange, isDefault, qtyFrom, qtyTo);
		
		// group type
		if self.baseColumnCount = 9 then
			self.getGroupTypeDetails(groupingType, groupTypeObj);
		endif;
		
		// invoice line
		self.getInvoiceLineDetails(invoiceLine, invoiceLineDescObj);
		self.checkForVoidInvoiceLine(currentPath, invoiceLine);
		
	endforeach;

	if not self.passport.hasErrors() then
		self.passport.finaliseTransaction(TRXStatus_Committed);
	endif;
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_allFileRows" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="validationError" id="7ffb8b6c-244d-4dfd-aa77-98cb4c58c78b">
        <updating/>
        <source>validationError(_message : String; _value : String) updating, protected;

vars

begin
	app.raiseCMException3(CsvLoadError, _message, _value, self.rowCount.String, null, null);
end;
</source>
        <access>protected</access>
        <Parameter name="_message" type="String"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="xHandlerFile" id="e4f84bcc-08ac-4723-bc0a-64a0a89d747d">
        <source>xHandlerFile(_exceptionObj:FileException):Integer protected;
// --------------------------------------------------------------------------------
// Created:		12 December 2008 by cnwdad1
//
// Purpose:		General file exception handler to report any errors and abort the
//				current action.
//
// Parameters:	_exceptionObj - A reference to the file exception object.
//
// Returns:		The abort action code.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMsg	: String;
	
begin
	errorMsg	:=	process.getErrorText(_exceptionObj.errorCode) &amp; ".";
	
	app.msgBox(errorMsg, app.getString(Error), MsgBox_Information_Icon + MsgBox_OK_Only);
	
	return Ex_Abort_Action;
end;</source>
        <access>protected</access>
        <Parameter name="_exceptionObj" type="FileException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
