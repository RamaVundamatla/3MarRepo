    <JadeMethod name="getDisplayStringForAttribute" id="2663af0c-bf26-4ed0-824c-575c2d57d98b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// -------------------------------------------
// Created 08 December 2005 by cnwdvb1
// -------------------------------------------
// 10/12/2012	cnwcs5	par 30852
// 22/02/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
// 10/03/2023	jlika1	TFS 56923 - Add width to Trailer
vars
	str		: String;					// PAR #31155
	type	: String;					// PAR #31155
	value	: Decimal [18,10];			// PAR #31155
	measure	: CM_MeasurementType;		// PAR #31155

begin
	if _attrName = ETRow_Description then
		return self.description;

	elseif _attrName  = ETRow_CargoType then
		if self.myCargoType &lt;&gt; null then
			return self.myCargoType.description;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_NumberLCs then
		return self.numControllers.String;
		
	elseif _attrName = ETRow_MaxHeight then   // cnwrd1 part fix for change to decimal and CMUI_TILCType form error text length issue.
		return self.maxHeight.asStringMeasurementJMT();
		
	elseif _attrName = ETRow_MaxWeight then
		return self.maxWeight.asStringWeightJMT();
		
	elseif _attrName = ETRow_Length then
		return self.length.asStringMeasurementJMT();
	elseif _attrName = ETRow_Width then
		return self.width.asStringMeasurementJMT();	
	elseif _attrName = ETRow_NotAvailableForEntry then
		return self.isNotAvailableForEntry.getYes;	// par 30852
	elseif _attrName = ETRow_Category then
		return self.getCategoryDisplay(); //jlier1 TFS 54700 13/9/22
	elseif _attrName = ETRow_AllowUpdateTotWeight then
		return self.allowUpdateTotalWeight.getYesNo(); //15/10/2025	navkc1 JIRA 36057
	elseif _attrName.isMeasurementType then											// PAR #31155
		// _attrName will be formatted as WTRow_&lt;real ent row name&gt;_&lt;weight unit&gt;	// PAR #31155
		_attrName.getRowNameMeasureType(str, type);									// PAR #31155
		return self.getMeasurementStringForAttrib(str, type, _short);				// PAR #31155
			
	else
		return inheritMethod(_attrName, _short);
	endif;


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
