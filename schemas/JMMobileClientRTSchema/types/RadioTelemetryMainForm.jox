    <JadeMethod name="setupForm" id="acc93c9f-57f4-43a9-823b-1d77967a4386">
        <updating/>
        <source>setupForm() updating;
/*

Date		Who		Reason
21 Nov 2005	cnwdvb1
05 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	bin : Binary;

begin
	inheritMethod();
	
	self.aIsUsingThinClient :=	process.isUsingThinClient();
	self.centreWindow();
	self.aState				:=	RadioTelemetryGuiAgent.LoggedOff;
	fldMainReal.fontBold	:=	true;
	fld1.fontBold			:=	true;
	fraOptions.move(0, 0, shtOptions.width, shtOptions.height);
	fraTasks.move(0, 0, shtTasks.width, shtTasks.height);
	fraGrading.move(0, 0, shtGrading.width, shtGrading.height);
	btnPDDetails.visible	:=	false;
	btnPUDetails.visible	:=	false;
//	picLogo.autoRedraw		:=	true;
	self.aIniFileName		:=	app.getIniFileName();
	self.setClientConnectionDetails();
	self.updateFromState();
	self.tableEnqInitialize();
	self.setAviOnOff(false);
	self.registerForNotes();
	
	// Turn this on if you want the on hold functionality.
	self.btnOnHold.visible := false;
	
	// preparing the sheet Reports
//	if app.isDevelopmentSystem then
	self.lblControlFont.visible	:= false;
	self.shtReports.enabled := true;
	self.setupQueryControls();
	self.showSheetReports();
	self.setModeQuery( self.Mode_QueryList );
	
	self.picLogo.picture := null;
//	bin := 

	lblControlFont.visible	:= false;
	btnQr_rpt1.visible		:= false;
	self.tableContainerSearchInit();		// PAR #16010
	self.tableQueueEntriesInitialize();
	
	self.setEnquiryScrollButtons();
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupQueryControls" id="061d08e1-9ab8-4800-a7dc-2367872cc29b">
        <source>setupQueryControls();
// -------------------------------------------
// Created 02 may 2008 by cnwvu1
// -------------------------------------------

vars
	leftCol : Integer;

begin
	
	lblCriteria1.visible	:= false;
	txtSearchValueA1.visible:= false;
	txtSearchValueB1.visible:= false;
	optBtnTrue1.visible		:= false;
	optBtnFalse1.visible	:= false;

	// centering criteria on the screen
	leftCol := self.frmReportDtl.width div 2;
	
	lblCriteria1.left		:= leftCol - lblCriteria1.width - 20;
	txtSearchValueA1.left	:= leftCol;
	txtSearchValueB1.left	:= leftCol + txtSearchValueA1.width + 6;
	optBtnTrue1.left		:= leftCol;
	optBtnFalse1.left		:= leftCol + optBtnTrue1.width;

end;
</source>
    </JadeMethod>
    <JadeMethod name="showLogonFrame" id="34905f3c-197a-4bea-ab97-208999db15d2">
        <source>showLogonFrame(_show : Boolean) protected;

/*

Date		Who		Reason
16 Jan 2006	cnwdvb1	Created 
11 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

begin
	if _show then
		self.picBackdrop.visible:=true;
		fraLogon.visible		:=	true;
		fraLogon.zOrder(1);
		txtNewPassword.text		:=	null;
		btnLogOff.visible		:=	false;
		btnLogOffExit.visible	:=	false;
		btnChangePass.visible	:=	false;
		btnPreferences.visible	:=	false;
		btnChangeQueue.visible	:=	false;						// PAR #16010
		btnReset.visible		:=	false;
	else
		self.picBackdrop.visible:=false;
		fraLogon.visible		:=	false;
		fraLogon.zOrder(-1);
		btnLogOff.visible		:=	true;
		btnLogOff.zOrder(1);
		btnLogOffExit.visible	:=	true;
		btnLogOffExit.zOrder(1);
		btnChangePass.visible	:=	true;
		btnChangePass.zOrder(1);
		btnPreferences.visible	:=	true;
		btnPreferences.zOrder(1);
		btnChangeQueue.visible	:=	self.aCanChangeQueue;		// PAR #16010
		btnChangeQueue.zOrder(1);
		btnReset.visible		:=	true;
		btnReset.zOrder(1);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showMessage" id="7954b2dc-e8a5-4dd8-9e6b-c2a95b50642f">
        <updating/>
        <source>showMessage(_str	: String; _isError : Boolean) : Boolean protected, updating;
// -------------------------------------------
// Created 24 November 2005 by cnwdvb1
// -------------------------------------------
vars

//	frm	: HeyYouMessageForm;
	
begin

	if _str = null then
		return false;
	endif;
	
	if _isError then
		if self.aWarnings then
			if not app.msgBox(	_str &amp; CrLf &amp; 'Do you wish to continue?',
								'Warning',
								MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
				self.aWarnings := false;
			else
				return true;
			endif;
		else
			app.msgBox(_str, 'Error', MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		endif;
	else
		app.msgBox(_str, 'Information', MsgBox_Information_Icon + MsgBox_OK_Only);
	endif;
	
	return false;


end;</source>
        <access>protected</access>
        <Parameter name="_str" type="String"/>
        <Parameter name="_isError" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showSheetReports" id="f6eb4465-c2ef-408d-8aa0-103baa49b5ad">
        <source>showSheetReports() protected;
// -------------------------------------------
// Created 18 Aprilr 2008 by cnwvu1
// -------------------------------------------

vars

begin

	if self.aCanRunSelectorQueries then
		self.shtReports.visible := true;
		self.queryResultTableInitialize();
	endif;

end;
</source>
