    <JadeMethod name="doToggleTransportView" id="d63db1a3-e81b-4698-be6a-0e53f4de344b">
        <updating/>
        <source>doToggleTransportView() updating, protected;

/*

Purpose:		Hide/Show rail graphic

Parameters:			

Return Value:		


Date			Who		Reason
12 May 2009		consw1	Initial creation

*/

vars
	ratio : Integer;
begin

	self.mnuShowGraphic.visible := true;
	if self.xmlShowGraphic then
		if not self.xmlShowMacroInfo then
			ratio := 100;
		else
			ratio := 50;
		endif;
		self.splExtraInfo.showLeftControl(ratio, true);
		self.mnuToggleTransportView.caption := app.getErrorString(Hide_graphic_view);
		self.mnuShowGraphic.caption := app.getErrorString(Hide_graphic_view);
		self.frmRakeToolbar.visible := true;
		self.tblInfoSmall.visible := true;
	else
		self.splExtraInfo.hideLeftControl( true);
		self.mnuToggleTransportView.caption := app.getErrorString(Show_graphic_view);
		self.mnuShowGraphic.caption := app.getErrorString(Show_graphic_view);
		self.frmRakeToolbar.visible := false;
		self.tblInfoSmall.visible := true;
	endif;
	self.doResizeGridContainer;
	



epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doToogleToolbar" id="374c7b42-6a0a-42c3-b738-463d1d904531">
        <source>doToogleToolbar() protected;
// ---------------------------------------------------------------------------
// Created:      07 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	if self.mnuToggleToolbar.caption = self.MNU_TOOLBAR_SHOW and self.xmlShowGraphic then
	
		self.frmRakeToolbar.height := 28;
		self.frmRakeToolbar.visible := true;
		self.mnuToggleToolbar.caption := self.MNU_TOOLBAR_HIDE;
	else
		self.frmRakeToolbar.visible := false;
		self.frmRakeToolbar.height := 0;
		self.mnuToggleToolbar.caption := self.MNU_TOOLBAR_SHOW;
	endif;
	
	self.doResizeGridContainer;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTransitWagons" id="382bca4a-7d62-4b47-ab8e-ef29ca816072">
        <updating/>
        <source>doTransitWagons(mnuItem : MenuItem; _status : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwndl1	Initial creation

*/

vars

	theReturn : Integer;
	wagon : CM_Wagon;
	wagonSet : CM_WagonSet;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815

	
begin

	wagon := mnuItem.userObject.CM_Wagon;
	
	create wagonSet transient;
	if wagon &lt;&gt; null then
		wagonSet.add(wagon);
	endif;
	
	if warnedOfNoSelectedData(wagonSet,app.getErrorString(Wagon) ) then
		return;
	endif;
	
	if _status = TI_IMEX_STATUS_REMAINONBOARD then
		if app.msgBox(app.getErrorString1(Please_Confirm_Intransit, wagon.id), app.getErrorString(Transit_Rail), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	elseif _status = TI_IMEX_STATUS_EXPORT then
		if app.msgBox(app.getErrorString1(Please_Confirm_Not_Intransit, wagon.id), app.getErrorString(Transit_Rail), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	endif;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateWagonInTransit(wagonSet, _status, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Transit_Rail), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
		
epilog

	delete wagonSet;
	
end;</source>
        <Parameter name="mnuItem" type="MenuItem"/>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUnplanTI" id="ffd73169-708a-4f20-8913-042437eb7753">
        <updating/>
        <source>doUnplanTI(_theTI : CM_TrackedItem input;_isLoad : Boolean) updating;

// ---------------------------------------------------------------------------
// Created:      01 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars

	idx : Integer;
	lTI	: CM_TrackedItem;
	aStr : String;
	lResult : Integer;
	lTransferArea : CM_TerminalArea;
	lQEntry : CM_RTQueueEntry;
	sLocation, tLocation : CM_LocationsController;

	aProxyJob : CM_VoyageJob;
	ls : Boolean;
	aSlotRequest : CM_SlotRequest;
	theWLE : CM_WorkListEntry;
	theVWLE : CM_VoyageWLE;
	result : Integer;
	theMoveController : CMIF_MoveController;
	msg : String;

begin
	mousePointer := MousePointer_HourGlass;	

	// #############################
	// ### UNPLAN THE TI
	// #############################
	if _theTI = null then
		app.msgBox(app.getErrorString(SELECT_TI_TA),app.getErrorString(Unplanning), MsgBox_OK_Only);
		return;
	else
		delete app.myMoveController;
		create theMoveController transient;
		theMoveController.setMoveMode(PLANNING_MODE);
		theMoveController.setMyTrackedItem(_theTI);
		
		//23 Feb 2021	NDL	TFS 50837
		if not validateRetrospectiveTS(null) then
			return;
		elseif self.chkRetrospect.value and self.retrospectiveDate.isValid then
			theMoveController.setEffectiveTimeStampOverride( self.retrospectiveDate );
		endif;	
		
		app.myTrxUA.trxUpdateMoveTIUndo(theMoveController, app.myPassport);
		if (not app.myPassport.trxCompletedOK) then
			app.showErrorWarningDialog(app.getErrorString(Unplanning), app.myPassport, ErrWarnMode_Update);
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		else
			self.clearErrorWarnings();
		endif;
	endif;

	// ###################################
	// ### UNASSIGN THE TI FROM THE WLE AND THE JOB - ONLY IF THIS IS A LOAD.
	// ###################################

	if (app.myPassport.trxCompletedOK)  then
		// detach this Load TI from the load request WLE
		theVWLE := _theTI.getVoyageWLEUnactioned(true); // PAR 8953 added param
		if theVWLE &lt;&gt; null then
			if theVWLE.myRequest.CM_SlotRequest.isLoad then
				delete theMoveController;
				create theMoveController transient;
				theMoveController.setMyWorkListEntry(theVWLE);
				theMoveController.setMoveMode(PLANNING_MODE);
				aSlotRequest := theVWLE.myRequest.CM_SlotRequest;

				theMoveController.mySlotRequest := aSlotRequest;
				theMoveController.setMyTrackedItem(_theTI);
				
				//23 Feb 2021	NDL	TFS 50837
				if self.chkRetrospect.value and self.retrospectiveDate.date.isValid then
					theMoveController.setEffectiveTimeStampOverride( self.retrospectiveDate );
				endif;
	
				if aSlotRequest.myJob &lt;&gt; null and aSlotRequest.isLoad then
					app.cmsBeginLoad(ls);
					aProxyJob := aSlotRequest.myJob.CM_VoyageJob.pxyCreateUpdateProxy();
					app.cmsEndLoad(ls);

					while true do
						app.myTrxUA.trxUpdateVoyageJobUnassignTI(theMoveController,aProxyJob, app.myPassport);	
						if app.myPassport.trxCompletedOK then
							// Clear errors/warnings from form and err/warnings window
							self.clearErrorWarnings();
							break;
						else
							result := app.showErrorWarningDialog(app.getErrorString(Unassi_slot_load_reques_from), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings); //+ cnwmd1, CCMS 1067, Par 19710
							if app.myPassport.noErrors and
							   result = IDOK then
								// there must have just been warnings that the user has acknoledged so ..
								app.myPassport.warningsAcknowledged	:= true;
								continue;
							endif;
							self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
						endif;
						break;
					endwhile;
				endif;
			endif;
		endif;
	endif;
epilog	
	
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	
	delete aProxyJob;
	delete theMoveController;
 
	mousePointer := MousePointer_Default;	
	if theMoveController &lt;&gt; null then
		delete theMoveController;
	endif;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUnqueueTI" id="182d43e9-754f-4d13-aac8-27e8c4b00044">
        <updating/>
        <source>doUnqueueTI(_theTI : CM_TrackedItem input) updating, protected;
// ---------------------------------------------------------------------------
// Created:      01 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	idx : Integer;
	lTI	: CM_TrackedItem;
	aStr : String;
	lResult : Integer;
	lMoveControl : CMIF_MoveController;
	lTransferArea : CM_TerminalArea;
	lQEntry : CM_RTQueueEntry;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	msg : String;

begin

	if _theTI = null then
		//app.msgBox("Please select a Tracked Item.","Unplanning", MsgBox_OK_Only);//- cnwmd1, CCMS 1067, Par 19710
		app.msgBox(app.getErrorString(Please_Select_A_Tracked_Item),app.getErrorString(Unplanning), MsgBox_OK_Only);//+ cnwmd1, CCMS 1067, Par 19710
		return;
	endif;

	mousePointer := MousePointer_HourGlass;	

	create lMoveControl transient;
	lMoveControl.setMoveMode(QUEUE_MODE);
	lMoveControl.setMyTrackedItem(_theTI);
	lMoveControl.setMyWorkListEntry(_theTI.allWorklistEntries.last);
	
	//23 Feb 2021	NDL	TFS 50837
	if not validateRetrospectiveTS(null) then
		return;
	elseif self.chkRetrospect.value and self.retrospectiveDate.date.isValid then
		lMoveControl.setEffectiveTimeStampOverride( self.retrospectiveDate );
	endif;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateMoveTIUndo(lMoveControl, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Unplan), app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog 
	if lMoveControl &lt;&gt; null then
		delete lMoveControl;
	endif;
	mousePointer := MousePointer_Default;	
end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doWagonColorCode" id="44bdf1cb-4cbf-4df4-8781-d749944ceba4">
        <source>doWagonColorCode(wagonColl	: ObjectSet input);
/*
----------   ----------  --------------------------------------------------
Created:	21 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
7/07/2009	cnwmd1	Removed sinle wagon colour coding and replaced with a wagon collection
----------   ----------  --------------------------------------------------
*/
vars
	wagonCollection : ObjectSet;
begin
	
	create wagonCollection transient;
	self.getSelectedWagons(wagonCollection, self.myCurrentWagon); //+ cnwmd1, CCMS 1067, Par 20211
	
	self.myAssistant.YRD_Assistant.showColorCodeWagons(wagonCollection, self.myMasterMenuAction);
	
epilog
	delete wagonCollection;
	
end;


</source>
