    <JadeMethod name="clickSelectAll" id="a9475a27-f804-49c5-b2b4-794cb8a0910d">
        <source>clickSelectAll() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation

*/

vars

	index : Integer;
	value : Boolean;

begin

	value := self.chkSelectAll.value;

	foreach index in 2 to self.tblObjects.rows do
		self.tblObjects.setCellText( index, 1, value.Integer.String );
	endforeach;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doChangeSheet" id="a9afdcb7-0bc1-4478-805f-96a7be9099e9">
        <source>doChangeSheet( _newSheet: Sheet ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation

*/

vars

	allSelectedObjects : ObjectArray;

begin

	if _newSheet = self.shtExtract then
	
		self.shtClasses.visible := true;
		self.shtObjects.visible := true;
		self.lblFormat.parent := _newSheet;
		self.cmbFormat.parent := _newSheet;
		self.lblNoid.parent := _newSheet;
		self.txtNoid.parent := _newSheet;
		self.lblMain.parent := _newSheet;
		self.lblMain.caption := "Main Output file";
		self.txtMain.parent := _newSheet;
		self.lblLog.parent := _newSheet;
		self.lblLog.caption := "Log file";
		self.txtLog.parent := _newSheet;
		create allSelectedObjects transient;
		self.getAllSelectedObjects( allSelectedObjects );
		if allSelectedObjects.isEmpty then
			self.lblMessage.caption := "EXTRACT";
		else
			self.lblMessage.caption := "EXTRACT " &amp; allSelectedObjects.size.String &amp; " selected objects";
		endif;
		self.lblMessage.parent := _newSheet;
	
	elseif _newSheet = self.shtImport then
	
		self.shtClasses.visible := false;
		self.shtObjects.visible := false;
		self.lblFormat.parent := _newSheet;
		self.cmbFormat.parent := _newSheet;
		self.lblNoid.parent := _newSheet;
		self.txtNoid.parent := _newSheet;
		self.lblMain.parent := _newSheet;
		self.lblMain.caption := "Main Input file";
		self.txtMain.parent := _newSheet;
		self.lblLog.parent := _newSheet;
		self.lblLog.caption := "Error file";
		self.txtLog.parent := _newSheet;
		self.lblMessage.caption := "IMPORT";
		self.lblMessage.parent := _newSheet;
	
	endif;

epilog

	delete allSelectedObjects;

end;</source>
        <access>protected</access>
        <Parameter name="_newSheet" type="Sheet"/>
    </JadeMethod>
    <JadeMethod name="doExtract" id="4da4cd26-d93f-4709-8eda-cf1d35f25c96">
        <source>doExtract() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	allSelectedObjects : ObjectArray;
	formatName : String;
	errorFileName : String;
	inputFileName : String;
	noidFileName : String;
	logFileName : String;
	outputFileName : String;
	
	oidTableRootObj : CnEcOidTable;
	hubbleObj : CnEcHubble;

begin

	create allSelectedObjects transient;
	self.getAllSelectedObjects( allSelectedObjects );
	
	if allSelectedObjects.isEmpty then
		app.msgBox( "No objects selected to extract", "Warning", MsgBox_OK_Only );
		return;
	endif;
	
	formatName := self.cmbFormat.text;
	if formatName = null then
		app.msgBox( "No extract format selected", "Warning", MsgBox_OK_Only );
		return;
	endif;
	
	inputFileName := null;
	errorFileName := self.txtLog.text;
	noidFileName := self.txtNoid.text;
	outputFileName := self.txtMain.text;
	logFileName := self.txtLog.text;
	
	if logFileName = null then
		app.msgBox( "Log file name required", "Warning", MsgBox_OK_Only );
		return;
	endif;
	if noidFileName = null then
		app.msgBox( "Noid file name required", "Warning", MsgBox_OK_Only );
		return;
	endif;
	if outputFileName = null then
		app.msgBox( "Main Output file name required", "Warning", MsgBox_OK_Only );
		return;
	endif;
	
	lblMessage.caption := allSelectedObjects.size().String &amp; " objects being extracted.";
	self.btnExtractCode.enabled := false;
	self.doWindowEvents(1);
	
	create oidTableRootObj transient;
	create hubbleObj transient;
	
	hubbleObj.initializeMe(	errorFileName,
							inputFileName,
							noidFileName,
							logFileName,
							outputFileName,
							formatName,
							oidTableRootObj,
							allSelectedObjects
							);
	
	lblMessage.caption := "Exporting...." &amp; " - " &amp; self.systemToLocalTime(app.actualTimeServer()).Time.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.doWindowEvents(1);
	
    if allSelectedObjects.size() &lt; 1000 then
    	hubbleObj.export(0,false);
 	else
 		hubbleObj.export((allSelectedObjects.size() div 10),false);
 	endif;   	   	
    
    lblMessage.caption :=  "Deleting transients...." &amp; " - " &amp; self.systemToLocalTime(app.actualTimeServer()).Time.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.doWindowEvents(1);
	
epilog

	delete allSelectedObjects;
	delete oidTableRootObj;
	delete hubbleObj;
	
	lblMessage.caption :=  "Exporting complete" &amp; " - " &amp; self.systemToLocalTime(app.actualTimeServer()).Time.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.btnExtractCode.enabled := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doImport" id="e3f257b8-205e-4461-9b7f-ea3080cb0ea6">
        <source>doImport() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	inputFileName	: String;
	noidFileName	: String;
	errorFileName	: String;
	logFileName		: String;
	outputFileName	: String;
	hubbleId		: String;
	formatName		: String;
	fileKind 		: Integer;
	oidTableObj		: CnEcOidTable;
	hubbleObj 		: CnEcHubble;
	displayMessage	: String;
	commitEveryXtrx : Integer;
	baseCaption : String;


begin

	inputFileName := self.txtMain.text;
	errorFileName := self.txtLog.text;
	noidFileName := self.txtNoid.text;
	outputFileName := null;
	logFileName := self.txtLog.text;
	
	if errorFileName = null then
		app.msgBox( "Error file name required", "Warning", MsgBox_OK_Only );
		return;
	endif;
	if noidFileName = null then
		app.msgBox( "Noid file name required", "Warning", MsgBox_OK_Only );
		return;
	endif;
	if inputFileName = null then
		app.msgBox( "Input file name required", "Warning", MsgBox_OK_Only );
		return;
	endif;

	hubbleId := "Import";
	
	oidTableObj := app.myBaseRoot.allXmlOidTables.getAtKey( hubbleId );
	if oidTableObj &lt;&gt; null then
		beginTransaction;
		delete oidTableObj;
		oidTableObj := null;
		commitTransaction;
	endif;
	
	formatName := self.cmbFormat.text;
	if formatName = null then
		app.msgBox( "No extract format selected", "Warning", MsgBox_OK_Only );
		return;
	endif;
	
	commitEveryXtrx := 1;
	//fileKind := 2;  // Kind_ANSI	
	fileKind := File.Kind_Unknown_Text;        // 23/2/16 cnwmp6 PAR 36286 unicode version
	
	create hubbleObj transient;

	hubbleObj.initializeMe(	errorFileName,
							inputFileName,
							noidFileName,
							logFileName,
							outputFileName,
							formatName,
							oidTableObj,
							null);	
	
	hubbleObj.setMyOidTable(hubbleId);
	hubbleObj.setObjectsPerTrx(commitEveryXtrx);
	hubbleObj.setMergeDuplicateCheck(true);

    baseCaption :=  "Started at " &amp; self.systemToLocalTime(app.actualTimeServer()).Time.String &amp; ".  ";// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
    lblMessage.caption := baseCaption &amp; CrLf &amp; "currently 'Loading NOID's ";
	self.doWindowEvents(1);
    
    hubbleObj.loader(CNEC_DATA_LOAD_NOID, fileKind);
	
    lblMessage.caption := baseCaption &amp; CrLf &amp; "Processing of 'Noid's completed at " &amp; self.systemToLocalTime(app.actualTimeServer()).Time.String &amp; CrLf &amp; "Currently 'Loading Primary attribute's.";// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.doWindowEvents(1);
	
   	hubbleObj.loader(CNEC_DATA_LOAD_ATTRIBUTE, fileKind);
   	
   	lblMessage.caption := baseCaption &amp; CrLf &amp; "Processing of 'Primary attribute's completed at " &amp; self.systemToLocalTime(app.actualTimeServer()).Time.String &amp; CrLf &amp; "Currently 'Loading Singleton's.";// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
    self.doWindowEvents(1);
	
  	hubbleObj.loader(CNEC_DATA_LOAD_SINGLETON, fileKind);
	
  	lblMessage.caption := baseCaption &amp; CrLf &amp; "Processing of 'Singleton's completed at " &amp; self.systemToLocalTime(app.actualTimeServer()).Time.String &amp; CrLf &amp; "Currently 'Loading Collection's.";// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
    self.doWindowEvents(1);
	
	hubbleObj.loader(CNEC_DATA_LOAD_COLLECTION, fileKind);
	
	lblMessage.caption := baseCaption &amp; CrLf &amp; "Processing of 'Collection's completed at " &amp; self.systemToLocalTime(app.actualTimeServer()).Time.String &amp; CrLf &amp; "Currently 'running Epilogue's.";// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
    self.doWindowEvents(1);
	
	hubbleObj.epilogue();
	
	lblMessage.caption := baseCaption &amp; CrLf &amp; "Processing of 'Epilogue's completed at " &amp; self.systemToLocalTime(app.actualTimeServer()).Time.String &amp; CrLf &amp; "Currently 'deleting transient's.";// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.doWindowEvents(1);
	
	hubbleObj.deleteMyOidTable(hubbleId);
	
epilog

	delete hubbleObj;
	lblMessage.caption := baseCaption &amp; CrLf &amp; "Complete at " &amp; self.systemToLocalTime(app.actualTimeServer()).Time.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="dd582be1-8b09-4cd5-acd8-552f0e4dd784">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation

*/

vars

begin

	self.grpBaseCode.top := 1;
	self.grpBaseCode.left := 1;
	self.grpBaseCode.width := self.clientWidth - 2;
	self.grpBaseCode.height := self.clientHeight - 2;
	self.grpBaseCode.parentAspect := 3;
	
	inheritMethod();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveSelection" id="19a8982b-0cdb-4cc1-99a8-966a315952b4">
        <updating/>
        <source>doSaveSelection() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation

*/

vars

	objSet : ObjectSet;
	index : Integer;
	obj : Object;

begin

	if self.myCurrentClass &lt;&gt; null then
		self.getSelectedObjects( self.myCurrentClass, objSet );
		if objSet = null then
			create objSet transient;
		endif;
		objSet.clear();
		if self.chkSelectAll.value then
			if self.myCurrentClass = CM_Organisation then
				CM_ExternalOrganisation.instances.copy(objSet);
				CM_InternalOrganisation.instances.copy(objSet);
			else
				self.myCurrentClass.instances.copy(objSet);
			endif;
		else
			foreach index in 2 to self.tblObjects.rows do
				if self.tblObjects.getCellText( index, 1 ).Integer = 1 then
					obj := self.tblObjects.accessRow( index ).itemObject;
					objSet.add( obj );
				endif;
			endforeach;
		endif;
		
		if not self.selectedObjectSets.includes( objSet ) then
			self.selectedObjectSets.add( objSet );
		endif;
		
	endif;
	
	self.populateClasses();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
