<Class name="CM_QStrMarinePollutantMethod" id="9e3f2783-6e87-489c-a4cc-afad95c826ff">
    <superclass name="CM_QStringLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="dd19f3e5-9183-4044-8efe-69be6c6a8dbf">
        <updating/>
        <source>create() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/12/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then
		return;
	endif;
	
	create oper as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(oper);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getValueForObject" id="8c10b09e-8aec-489a-93b4-8cc0aa8ca246">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/12/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
// 189/09/2019	jlgdap1		TFS 45769 JMT Web Portal selector query parameters
//
vars
	propValue : String;
	ti : CM_TrackedItem;
	haz : CM_Hazard;
	marinePoll : String;

begin
	if _op = null then
		return inheritMethod(_obj, _op);
	endif;
	
	ti := _obj.CM_TrackedItem;
	foreach haz in ti.allTIHazards do
		marinePoll := app.isMarinePollutantEnumToString(haz.CM_TIHazard.isMarinePollutant);
		//if marinePoll = _op.CM_QStringLookup.selectionValue then														// TFS 45769
		if (_op.isKindOf(CM_QStringLookup) and marinePoll = _op.CM_QStringLookup.selectionValue) 						// TFS 45769
		or (_op.isKindOf(CM_QStringIsOneOf) and _op.CM_QStringIsOneOf.allSelectionValues.includes(marinePoll)) then		// TFS 45769
			propValue := marinePoll;
			break;
		endif;
	endforeach;
	
	if self.needToUpperCase then
		propValue := propValue.toUpper;
	endif;

	return propValue;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getWebDataRowName" id="6c731de5-1c48-4f51-bc66-000449141ec8">
        <source>getWebDataRowName(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars

begin
	return ETRow_MarinePollutant;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="69538120-62a7-47e3-ad92-65e8d133e3a5">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19 December 2016	cnwdap1		Initial creation PAR #
//
vars
	selectStr : String;

begin
	_combo.clear;
	_combo.addItem(MarinePollutant_NullString);
	_combo.addItem(MarinePollutant_NoString);
	_combo.addItem(MarinePollutant_YesString);

	if CM_QStringLookup.hasInstance(_queryOperator) then
		selectStr := _queryOperator.CM_QStringLookup.selectionValue;
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		selectStr := _queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;
	
	_combo.text := selectStr;
epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="cacc1a02-ec88-4fdc-a728-5c4500c62e2c">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/12/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	idx, selectionValue : Integer;

begin
	_tbl.rows := _tbl.fixedRows;
	
	if _params = null then
		return;
	endif;
	selectionValue := 0;
	if _operator &lt;&gt; null and _operator.CM_QStringIsOneOf.allSelectionValues.includes(MarinePollutant_NullString) then
		selectionValue := 1;
	endif;
	idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; MarinePollutant_NullString);
	_tbl.row := idx;
	_tbl.change(_tbl);
	selectionValue := 0;
	if _operator &lt;&gt; null and _operator.CM_QStringIsOneOf.allSelectionValues.includes(MarinePollutant_NoString) then
		selectionValue := 1;
	endif;
	idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; MarinePollutant_NoString);
	_tbl.row := idx;
	_tbl.change(_tbl);
	selectionValue := 0;
	if _operator &lt;&gt; null and _operator.CM_QStringIsOneOf.allSelectionValues.includes(MarinePollutant_YesString) then
		selectionValue := 1;
	endif;
	idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; MarinePollutant_YesString);
	_tbl.row := idx;
	_tbl.change(_tbl);
epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="7f264443-699e-4dac-be0b-777e2c963994">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/12/2016	cnwdap1		Initial creation TS 2844 STWR Hazardous Details Enhancements
//
vars
	str	: String;
	numRows, idx : Integer;
	codeArray : StringArray;
	code : String;
	
begin

	create codeArray transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			code := _tbl.accessCell(idx, 2).text;
			codeArray.add(code);
		endif;
	endforeach;
	
	_op.setSearchValue(codeArray);
	
epilog
	delete codeArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="896d9571-b6d1-4fca-b233-9c9d88336a52">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24 September 2019	jlgdap1		Initial creation TFS 
//
// 19/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	str, returnVal : String;
	strArray : StringArray;

begin
	if _value.isKindOf(StringArray) then
		foreach str in _value.StringArray do
			returnVal := returnVal &amp; str &amp; CNEC_COMMA &amp; Space;
		endforeach;
		returnVal := returnVal[1:returnVal.length-2];
		return returnVal;
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			str := _value.String;
			create strArray transient;
			str.getTokensForDelimiter("|", strArray);
			return strArray;
		endif;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
