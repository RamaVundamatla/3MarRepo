    <JadeMethod name="addTIs" id="99949a07-c5a4-41e0-ade3-2377baab9dff">
        <updating/>
        <source>addTIs()updating;
//27 August 2009	cnwml2
//
// Changed On 	By			Reason
// ----------	--------	------------------------------------------------------
// 14/12/2016	cnwdap1		TFS 3039 SNO Empty Container Pool Management
// 24 Jul 2025  navhn30 	MTN-35315: MTN | Pagination - Work Order Maintenance
vars
	allSelectedObjects : CM_TIArray;
	obj : Object;
	row, count : Integer;
	ti : CM_TrackedItem;
	iter : Iterator;
	idx : Integer;
	isFullRelease : Boolean;
	msg : String;
	release : CM_BulkRelease;						// TFS 3039
	poolParty : CM_MTPoolingParty;					// TFS 3039

begin
	create allSelectedObjects transient;
	self.tblResults.allSelectedObjects.copy(allSelectedObjects);
	if allSelectedObjects.size = 0  then
		app.msgBox(app.getErrorString2(CMUI_Please_Select, "cargo item(s)", "add"),app.getErrorString(NOTHING_SELECTED), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	//14 Mar 2013	NDL	Par 30918
	if self.myParentForm &lt;&gt; null and self.myParentForm.isKindOf( CMUI_ReleaseCargoForm ) then
		if self.myParentForm.CMUI_ReleaseCargoForm.currentEntTableDef = ETDef_ReleaseContainerFull then
			isFullRelease := true;
		endif;
	endif;
	
	foreach ti in allSelectedObjects do
		if not self.allSelectedTrackedItems.includes(ti) then
			//14 Mar 2013	NDL	Par 30918
			if isFullRelease and ti.isEmpty then
				msg := app.getErrorString1(Selecte_release_full_empty, ti.id) &amp; CrLf &amp; app.getErrorString(Continue);
				if app.msgBox(msg,app.getErrorString(Continue), MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
					continue;
				endif;
			endif;
			
			// TFS 3039 Check if release has a pool party, and if the TI matches						// TFS 3039
			if self.myReserveDetail &lt;&gt; null and self.myReserveDetail.myReserveHeader &lt;&gt; null then		// TFS 3039
				release := self.myReserveDetail.myReserveHeader;										// TFS 3039
				poolParty := release.myPoolingParty;													// TFS 3039
				if poolParty &lt;&gt; null and ti.myPoolingParty &lt;&gt; poolParty then							// TFS 3039
					msg := app.getErrorString2(Cont_Not_In_Pooling_Party, ti.id, poolParty.code);		// TFS 3039
					app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only);							// TFS 3039
					continue;																			// TFS 3039
				endif;																					// TFS 3039
			endif;																						// TFS 3039
			
			self.allSelectedTrackedItems.add(ti);
			self.tblResults.removeItemObject(ti);														//24.07.2025	navhn30  MTN-35315
		endif;
	endforeach;
	
	//+cnwml2 PAR21663
	self.tblSelectedItems.clearAllData();
	self.tblSelectedItems.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null,self.allSelectedTrackedItems, true); //24.07.2025	navhn30  MTN-35315
	/*iter := self.allSelectedTrackedItems.createIterator();
	count := 1;
	while iter.next(ti) do	
		count := count + 1;
		idx := self.tblSelectedItems.updateItemObject(ti, self.colorRow1, self.colorRow2, app.myPassport);
		self.tblSelectedItems.accessRow(idx).itemObject := ti;
		self.tblResults.removeItemObject(ti);
	endwhile;*/



epilog
	delete allSelectedObjects;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="alignButtons" id="855228f4-2d35-4287-84a2-a2efc1d2a172">
        <source>alignButtons() protected;
//08 September 2009	cnwml2


vars
	
begin
	inheritMethod();
	
	self.frmEntTblControl.width := self.width;
	self.frmEntTblControl.left := 0;
	
	self.frmResults.width := self.width;
	self.frmResults.left := 0;
	
	self.frmSelectedItems.width := self.width;
	self.frmSelectedItems.left := 0;
	
	btnSave.caption := "OK";	
	// no Next button
	btnNext.visible := false;
	btnSave.left := btnNext.left;
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
