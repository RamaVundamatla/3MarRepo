    <JadeMethod name="getMyTerminalFromForm" id="ec853121-511f-4b84-be91-9a0947baa25d">
        <source>getMyTerminalFromForm() : CM_Terminal;

/*

Purpose:		Get terminal from control's form.  If not available get from app.

Parameters:		None

Return Value:	Current terminal


Date		Who		Reason
01 Oct 2008	consw1	Initial creation for Par 17090

*/

vars
	terminal	: CM_Terminal;

begin
	if self.form &lt;&gt; null and self.form.isKindOf(CM_BaseForm) then
		terminal := self.form.CM_BaseForm.myTerminal;
	endif;
	if terminal = null then
		terminal := app.getMyTerminalDO_NOT_USE();
	endif;

	return terminal;
	
epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
