    <JadeMethod name="updateValuesFromMaster" id="8b9e820b-d55a-495e-9c3d-240752a85e97">
        <updating/>
        <source>updateValuesFromMaster( attributesToUpdate : StringArray ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 July 2009	cnwndl1	Initial creation

*/

vars

	attribName : String;
	
begin

	if myWagonMaster = null then
		// should never happen.
		return;
	endif;

	foreach attribName in attributesToUpdate do
	
	/*	if attribName = CM_WagonMaster::maxCargoHeight.name then
			self.maxCargoHeight := myWagonMaster.getMaxCargoHeight;	//Par 21924
			continue;
		elseif attribName = CM_WagonMaster::maxCargoWeight.name then
			self.maxCargoWeight := myWagonMaster.getMaxCargoWeight;	//Par 21924
			continue;
		else
		if attribName = CM_WagonMaster::tareWeight.name then
			self.tareWeight := myWagonMaster.getTareWeight;	//Par 21924
			continue;	
		else */
		if attribName = CM_WagonMaster::myCarrier.name then
			self.myCarrier := myWagonMaster.myCarrier;
			continue;
		endif; 
	
	endforeach;

	
epilog

