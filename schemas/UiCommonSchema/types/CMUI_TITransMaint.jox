    <JadeMethod name="doComboTranTypeClick" id="53500dfd-c876-4763-a26b-599df33344e8">
        <updating/>
        <source>doComboTranTypeClick(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//09	May 2016	cnwrs1	TFS 1546 POL - Unpacking Process Options
//18 Aug 2017		cnwma1	TFS #5027:POL - CAMS Transaction not being correctly processed
// ---------------------------------------------------------------------------

vars
	viewName 			: String;
	theIndex			: Integer;
	entTableView : EntTableView;
	entTableDef	: EntTableDef;
begin
	theIndex := self.cmbTranType.listIndex;
	if theIndex &lt; 1 then
		return;
	endif;
	
	self.myCurrentTransactionType := self.cmbTranType.itemData[theIndex];
	if myCurrentContainerEnqForm &lt;&gt; null then
		myCurrentContainerEnqForm.defaultBulkAddTransType := self.myCurrentTransactionType;
	endif;
	
	self.doEnableButtonsByType();
	
	entTableDef := app.myController.getEntTableDef(ETDef_TITMaint); 
	
	if self.myCurrentTransactionType = TRANS_TYPE_FUELED then
		viewName :=  ETView_TITFueled;
	elseif self.myCurrentTransactionType = TRANS_TYPE_MOVE then
		viewName :=  ETView_TITMove;
	elseif self.myCurrentTransactionType = TRANS_TYPE_REPAIR then
		viewName :=  ETView_TITRepair;
	elseif self.myCurrentTransactionType = TRANS_TYPE_SEALED then
		viewName :=  ETView_TITSeal;
	elseif self.myCurrentTransactionType = TRANS_TYPE_HIRE then
		viewName :=  ETView_TITHire;
	elseif self.myCurrentTransactionType = TRANS_TYPE_PACK
	or  self.myCurrentTransactionType = TRANS_TYPE_UNPACK 
	or  self.myCurrentTransactionType = TRANS_TYPE_REPACK then
		viewName :=  ETView_TITPack;
	elseif self.myCurrentTransactionType = TRANS_TYPE_STOWAGE_CONFIRM then
		viewName := ETView_TIStowageConfirm;
		self.tblEntry.disableRowByName(ETRow_StowageType);
		if self.myCurrentTransaction = null then	
			self.myAssistant.comboBoxROROVoyage(self.cmbVoyage,self.myTerminal,null);		
		endif;
	// 4.8.2017 cnwma1 TFS #5027
	elseif self.myCurrentTransactionType = TRANS_TYPE_RECEIVE_ST_DEPOT
	or     self.myCurrentTransactionType = TRANS_TYPE_RECEIVE_ST_MARINE
	or 	   self.myCurrentTransactionType = TRANS_TYPE_RECEIVE_ST_WHOUSE
	or 	   self.myCurrentTransactionType = TRANS_TYPE_REC_ST_DEPOT_INT
	or     self.myCurrentTransactionType = TRANS_TYPE_REC_ST_DEPOT_RAIL
	or     self.myCurrentTransactionType = TRANS_TYPE_REC_ST_DEPOT_ROAD
	or     self.myCurrentTransactionType = TRANS_TYPE_REC_ST_DEPOT_SHIP
	or     self.myCurrentTransactionType = TRANS_TYPE_REC_ST_MARINE_INT
	or     self.myCurrentTransactionType = TRANS_TYPE_REC_ST_MARINE_RAIL
	or     self.myCurrentTransactionType = TRANS_TYPE_REC_ST_MARINE_ROAD
	or     self.myCurrentTransactionType = TRANS_TYPE_REC_ST_MARINE_SHIP
	or     self.myCurrentTransactionType = TRANS_TYPE_REC_ST_WHOUSE_INT
	or     self.myCurrentTransactionType = TRANS_TYPE_REC_ST_WHOUSE_RAIL
	or     self.myCurrentTransactionType = TRANS_TYPE_REC_ST_WHOUSE_ROAD
	or     self.myCurrentTransactionType = TRANS_TYPE_REC_ST_WHOUSE_SHIP
	or	   self.myCurrentTransactionType = TRANS_TYPE_RELEASE_ST_DEPOT
	or     self.myCurrentTransactionType = TRANS_TYPE_RELEASE_ST_MARINE
	or 	   self.myCurrentTransactionType = TRANS_TYPE_RELEASE_ST_WHOUSE
	or     self.myCurrentTransactionType = TRANS_TYPE_REL_ST_DEPOT_INT
	or     self.myCurrentTransactionType = TRANS_TYPE_REL_ST_DEPOT_RAIL
	or     self.myCurrentTransactionType = TRANS_TYPE_REL_ST_DEPOT_ROAD
	or     self.myCurrentTransactionType = TRANS_TYPE_REL_ST_DEPOT_SHIP
	or     self.myCurrentTransactionType = TRANS_TYPE_REL_ST_MARINE_INT
	or     self.myCurrentTransactionType = TRANS_TYPE_REL_ST_MARINE_RAIL
	or     self.myCurrentTransactionType = TRANS_TYPE_REL_ST_MARINE_ROAD
	or     self.myCurrentTransactionType = TRANS_TYPE_REL_ST_MARINE_SHIP
	or     self.myCurrentTransactionType = TRANS_TYPE_REL_ST_WHOUSE_INT
	or     self.myCurrentTransactionType = TRANS_TYPE_REL_ST_WHOUSE_RAIL
	or     self.myCurrentTransactionType = TRANS_TYPE_REL_ST_WHOUSE_ROAD
	or     self.myCurrentTransactionType = TRANS_TYPE_REL_ST_WHOUSE_SHIP then
		
		viewName :=  ETView_TITSubTerm;
		self.doBuildComboFromSubTerm(self.myCurrentTransactionType);
		self.doBuildComboToSubTerm(self.myCurrentTransactionType);
	// 4.8.2017 cnwma1 TFS #5027
	else
		viewName :=  ETView_TITGeneral; 
	endif;

	entTableView:=entTableDef.allEntTableViews[viewName];
	self.tblEntry.setEntTableFromView(entTableDef,entTableView,null,null);
		
	if self.isBulkUpdate then
		self.tblEntry.disableRowByName(ETRow_ContainerID);
		theIndex := self.tblEntry.getRow(ETRow_ContainerID);
		self.tblEntry.accessCell(theIndex, 1).text := app.getErrorString(CargoId);
	else
		
		self.tblEntry.setValueByControlName(self.cmbContainers.name,self.cmbContainers.text);
		//epr TFS 2996 8/12 /16
		self.resetMeasurementRows(self.tblEntry);																								// PAR #31155
		self.loadMeasurementTypes(self.tblEntry, self.tblEntry.myEntTableDef.name, self.tblEntry.myEntTableDef.allEntTableRows, true);
	endif;
	self.displayTableList(self.myCurrentTransactionType,self.myCurrentTrackedItem);
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDeleteTxn" id="a7792977-faf6-433a-b904-169e38c13456">
        <updating/>
        <source>doDeleteTxn() updating, protected;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	txnController			: CMIF_TITransactionController;
	txn						: CM_TITransaction;
begin
	if self.isForCargoEdit then
		txnController := self.tblList.accessRow(self.tblList.row).itemObject.CMIF_TITransactionController;
		if txnController = null then
			app.msgBox('Please select a transaction to delete', 'Nothing selected', 0);
			return;
		endif;
		
		txnController.deleted := true;
	else
		txn := self.tblList.accessRow(self.tblList.row).itemObject.CM_TITransaction;
		if txn = null then
			app.msgBox('Please select a transaction to delete', 'Nothing selected', 0);
			return;
		endif;
		
		app.myTrxDA.trxDeleteTITransaction(txn, null, app.myPassport);		// 12/10/18 MAP TFS41191
		
		if not app.myPassport.trxCompletedOK then
			app.showErrorsAsMsgBox(app.myPassport.allErrors, false);
			return;
		endif;
	endif;
	
	self.doComboTranTypeClick(self.cmbTranType);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDisplayTxn" id="219652a0-3e6b-45ad-8740-5b0d7a7a5137">
        <updating/>
        <source>doDisplayTxn() protected, updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2003		cnwth2	
// Purpose:     		 
//18 Aug 2017	cnwma1		TFS #5027:POL - CAMS Transaction not being correctly processed
//30 Oct 2019	NDL	TFS 47283, Setting listObject directly to a value not in the combo causes 140087 errors
// ----------   ----------  --------------------------------------------------
vars
	txn			: CM_TITransaction;
	cargoType 	: CM_CargoType;
	subtype 	: CM_Product;
	measureType	 : CM_MeasurementType;
	measureTable : CMUI_MeasurementTable;
	amountDisplay : String;
begin
	txn := self.myCurrentTransaction;
	if txn = null then
		return;
	endif;

	self.tblEntry.setTableFromCM_Object(txn,null);	
	self.cmbUser.setObject(app.myRoot.allUsers[txn.userId]);
	
	// 18.8.2017 cnwma1 TFS #5027
	if txn &lt;&gt; null and txn.isKindOf(CM_SubTerminalRelease) then
		if txn.CM_SubTerminalRelease.mySubTerminalTo &lt;&gt; null then
		//	self.cmbSubTermTo.listObject :=txn.CM_SubTerminalRelease.mySubTerminalTo;
			self.cmbSubTermTo.listIndex := self.cmbSubTermTo.findObject( txn.CM_SubTerminalRelease.mySubTerminalTo );	//30 Oct 2019	NDL	TFS 47283
		endif;
		//self.cmbSubTermFrom.listObject := txn.mySubTerminal;
		self.cmbSubTermFrom.listIndex := self.cmbSubTermFrom.findObject( txn.mySubTerminal );	//30 Oct 2019	NDL	TFS 47283
	endif;
	
	// 18.8.2017 cnwma1 TFS #5027
	if txn &lt;&gt; null and txn.isKindOf(CM_SubTerminalReceive) then
		if txn.CM_SubTerminalReceive.mySubTerminalFrom &lt;&gt; null then
		//	self.cmbSubTermFrom.listObject :=txn.CM_SubTerminalReceive.mySubTerminalFrom;
			self.cmbSubTermFrom.listIndex := self.cmbSubTermFrom.findObject( txn.CM_SubTerminalReceive.mySubTerminalFrom );	//30 Oct 2019	NDL	TFS 47283
		endif;
	//	self.cmbSubTermTo.listObject := txn.mySubTerminal;
		self.cmbSubTermTo.listIndex := self.cmbSubTermTo.findObject( txn.mySubTerminal );	//30 Oct 2019	NDL	TFS 47283
	endif;
	
	//epr TFS 2996 8/12/16
	self.tblEntry.hideRowByName(ETRow_TotalQuantity,false);
	self.tblEntry.hideRowByName(ETRow_TotalWeight,false);
	self.tblEntry.hideRowByName(ETRow_TotalVolume,false);
	
	//epr TFS 2996 8/12/16
	if txn.canEditAmount then
		txn.getCargoTypeAndSubType(cargoType,subtype);
		if cargoType.isBulkByQuantity then
			self.tblEntry.showRowByName(ETRow_TotalQuantity,false);
		endif;
		if cargoType.isBulkMulti then
			amountDisplay:= txn.getAmountDisplay();
			if cargoType.isBulkByWeight then
				self.tblEntry.showRowByName(ETRow_TotalWeight,false);
				measureType:=cargoType.myWeightMeasurementType;
				measureTable:=self.tblEntry.getMeasurementTableForRowName(ETRow_TotalWeight);
			elseif cargoType.isBulkByVolume then
				self.tblEntry.showRowByName(ETRow_TotalVolume,false);
				measureType:=cargoType.myVolumeMeasurementType;
				measureTable:=self.tblEntry.getMeasurementTableForRowName(ETRow_TotalVolume);				
			endif;
			if 	measureType &lt;&gt; null and measureTable &lt;&gt; null then			
				measureTable.setMeasurementType(measureType.measurementType);
				measureTable.setValues( amountDisplay );
				tblEntry.setValueByControlName(measureTable.name, amountDisplay);
			endif;
			
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDisplayTxnController" id="34b488ef-5a2f-4738-b3e4-0b035bfe64a8">
        <updating/>
        <source>doDisplayTxnController(_txnController : CMIF_TITransactionController) protected, updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2003		cnwth2	
//
// Purpose:     		 
// 
// Changed On	Changed By	Reason
// ----------   ----------  --------------------------------------------------
// 20/06/2022	navdap1		TFS 53362 EUP Master Data interface customers between TOS and ERP
vars
	user			: CM_User;
	operator 		: CM_Operator;		// TFS 53362
	str 			: String;			// TFS 53362
begin
	self.myCurrentTxnController := _txnController;
	self.tblEntry.setValueByName(ETRow_UrNumber,_txnController.urNumber);
	user := app.myRoot.allUsers[_txnController.userId];

	self.cmbUser.setObject(user);

	self.tblEntry.setValueByName(ETRow_UserID,_txnController.userId);
	self.tblEntry.setValueByName(ETRow_Charge,(not _txnController.noCharge).String);

	self.tblEntry.setValueByName(ETRow_Date2, self.systemToLocalTime( _txnController.dateTime).date()); //epr par 32438 31/12/13
	self.tblEntry.setValueByName(ETRow_Time,  self.systemToLocalTime( _txnController.dateTime).time());
	if _txnController.myOtherTrackedItem &lt;&gt; null then
		self.tblEntry.setValueByName(ETRow_Item, _txnController.myOtherTrackedItem.id);
	endif;
	
	if _txnController.type = TRANS_TYPE_FUELED then
		self.tblEntry.setValueByName(ETRow_Litres, _txnController.CMIF_FuelTransController.litres.String);
	elseif _txnController.type = TRANS_TYPE_MOVE then
		self.tblEntry.setValueByName(ETRow_SourceLocation, _txnController.CMIF_MoveTransactionController.sourceLocn);
		self.tblEntry.setValueByName(ETRow_TargetLocation, _txnController.CMIF_MoveTransactionController.targetLocn);
		self.tblEntry.setValueByName(ETRow_Machine, _txnController.CMIF_MoveTransactionController.machineId);
	elseif _txnController.type = TRANS_TYPE_REPAIR then
		self.tblEntry.setValueByName(ETRow_GenToDoTask, _txnController.autoToDoTask.String);
	elseif _txnController.type = TRANS_TYPE_SEALED then
		self.tblEntry.setValueByName(ETRow_SealNum, _txnController.CMIF_SealTransController.sealNum.String);
	elseif _txnController.type = TRANS_TYPE_HIRE then
		self.tblEntry.setValueByName(ETRow_OtherParty, _txnController.CMIF_HireTransController.otherParty.String);
		self.tblEntry.setValueByName(ETRow_Disposition, _txnController.CMIF_HireTransController.fleetDisposition.String);
		self.tblEntry.setValueByName(ETRow_HireType, _txnController.CMIF_HireTransController.hireType.String);
		self.tblEntry.setValueByName(ETRow_MessageStatus, _txnController.CMIF_HireTransController.messageStatus.String);
		if app.myRoot.getConfig(ComboByNameOperator).Boolean then														// TFS 53362
			str := _txnController.CMIF_HireTransController.operatorCode;												// TFS 53362
			operator := app.myRoot.allOperators[_txnController.CMIF_HireTransController.operatorCode];					// TFS 53362
			if operator &lt;&gt; null then																					// TFS 53362
				str := operator.description;																			// TFS 53362
			endif;																										// TFS 53362
		endif;																											// TFS 53362
		//self.tblEntry.setValueByName(ETRow_Operator, _txnController.CMIF_HireTransController.operatorCode.String);	// TFS 53362
		self.tblEntry.setValueByName(ETRow_Operator, str);																// TFS 53362
		self.tblEntry.setValueByName(ETRow_Owner, _txnController.CMIF_HireTransController.ownership.String);
		
	endif;


end;</source>
        <access>protected</access>
        <Parameter name="_txnController" type="CMIF_TITransactionController"/>
    </JadeMethod>
    <JadeMethod name="doEnableButtonsByType" id="df6c80f8-4a7c-4c13-9f6d-3d9d587dd0a5">
        <source>doEnableButtonsByType();
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myCurrentTransactionType = null then
		return;
	endif;

	self.btnAdd.enabled := true;
	self.btnUpdate.enabled := true;
	self.btnDelete.enabled := true;
	
	if self.myCurrentTransactionType = TRANS_TYPE_MOVE then
		self.btnAdd.enabled := false;

	elseif self.myCurrentTransactionType = TRANS_TYPE_CONNECT_POWER
	or  self.myCurrentTransactionType = TRANS_TYPE_CONNECT_TOWER 
	or  self.myCurrentTransactionType = TRANS_TYPE_DISCONNECT_TOWER 
	or  self.myCurrentTransactionType = TRANS_TYPE_DISCONNECT_POWER then
		self.btnAdd.enabled := false;
		self.btnDelete.enabled := false;
		
	elseif self.myCurrentTransactionType = TRANS_TYPE_PACK
	or  self.myCurrentTransactionType = TRANS_TYPE_UNPACK 
	or  self.myCurrentTransactionType = TRANS_TYPE_REPACK then
		self.btnAdd.enabled := false;
		self.btnUpdate.enabled := false;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doEnableTableEntry" id="70952aa5-f522-4424-86ca-fd869a7ecd08">
        <source>doEnableTableEntry(_enable : Boolean);
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04/08/2011	cnwmh5		#27888 - Should only display Transaction Type if in Add State.
//30 Mar 2016	cnwrs1	TFS 1546 POL - Unpacking Process Options
// ---------------------------------------------------------------------------

vars
	row,
	numRows			: Integer;
	tbl				: CM_EntryTable;
begin
	tbl := self.tblEntry;
	numRows := tbl.rows;
	
	foreach row in tbl.fixedRows + 1 to numRows do
		if _enable then
			tbl.enableRow(row);
		else
			tbl.disableRow(row);
		endif;
	endforeach;
	
	if self.isForCargoEdit or 
	   self.editModeOnly 
	   or self.isBulkUpdate then
		tbl.disableRowByName(ETRow_ContainerID);
	endif;
	
	//30 Oct 2019	NDL	TFS 47283
	if self.myCurrentTransactionType = TRANS_TYPE_PACK or self.myCurrentTransactionType = TRANS_TYPE_UNPACK then
		self.tblEntry.disableRowByName(ETRow_Item);
	endif;
	
	if self.state = self.State_Add then					// 04/08/2011 cnwmh5 #27888
		tbl.enableRowByName(ETRow_TransactionType);
	else
		tbl.disableRowByName(ETRow_TransactionType);
		tbl.disableRowByName(ETRow_Voyage);
		tbl.disableRowByName(ETRow_Job);
		tbl.disableRowByName(ETRow_StowageType);
		tbl.disableRowByName(ETRow_Action);				//cnwmc5 - 1 Dec 2015 - PAR 37108
	endif;

end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="c1178db4-66db-4d00-b2a4-4e535c430605">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.width &lt; 400 then
		self.width := 400;
	endif;
	if self.height &lt; 400 then
		self.height := 400;
	endif;
	self.btnCancel.move(self.clientWidth - self.btnCancel.width - 5, self.clientHeight - self.btnCancel.height - 5,self.btnCancel.width, self.btnCancel.height);
	self.btnSave.move(self.btnCancel.left - self.btnCancel.width - 5, self.btnCancel.top,self.btnCancel.width, self.btnCancel.height);
	self.btnUpdate.move(self.btnCancel.left - self.btnCancel.width - 5, self.btnCancel.top,self.btnCancel.width, self.btnCancel.height);
	self.btnAdd.move(self.btnUpdate.left - self.btnCancel.width - 5, self.btnCancel.top,self.btnCancel.width, self.btnCancel.height);
	self.btnDelete.move(self.btnAdd.left - self.btnCancel.width - 5, self.btnCancel.top,self.btnCancel.width, self.btnCancel.height);

	self.splMain.move(5,5,self.clientWidth - 10, self.btnCancel.top - 10);
	self.splMain.cnEcResizeContents();
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="db6eb64c-7480-44bf-9187-7b59b69ffb30">
        <updating/>
        <source>doSave() protected, updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
//21 Apr 2016	cnwrs1	TFS 1546 POL - Unpacking Process Options
//08 Nov 2017	jlgrh7 TFS 7258 Editing an Unpack transaction Date
vars
	tranType					: Integer;
	txnController 				: CMIF_TITransactionController;
	newTITxn					: CM_TITransaction;
	origTrans					: CM_TITransaction;
	terminal					: CM_Terminal;
begin
	if (not global.isValidObject(self.myCurrentTxnController)) then
		self.myCurrentTxnController := null;
		//epr par 12024 5/7/2006, revised Feb 2012 from CCMS 1262 testing, allow for edit of transaction type which is not in trans type combo
		//  i.e. can update but not add this type
		if self.state = self.State_Update then
			tranType := self.myCurrentTransactionType;
		elseif self.cmbTranType.listIndex &gt; 0 then
			tranType := self.cmbTranType.itemData[self.cmbTranType.listIndex];
		endif;
		if tranType = 0 then
			app.msgBox('Please select a transaction type', 'Required field',0);
			return;
		endif;
		global.createTxnControllerForType(tranType, self.myCurrentTxnController);
		if self.myCurrentTxnController &lt;&gt; null then		// 8/3/19 MAP TFS43243
			terminal := self.myTerminal;
			if terminal &lt;&gt; null then
				self.myCurrentTxnController.bulkCompleteContainer := terminal.getConfig(BulkCompleteContainer).Boolean;
			endif;
		endif;
	endif;
	
	txnController := self.myCurrentTxnController;
	
	self.setTxnControllerFromTable(txnController);
	txnController.userGenerated 		:= true;
	txnController.hasBeenUpdated		:= true;
	txnController.myTerminal			:= self.myTerminal;
	txnController.myTrackedItem 		:= self.myCurrentTrackedItem;

/*	30 Oct 2019	NDL	TFS 47283 - migrated to 'setTxnControllerFromTable' method
	// 08 Nov 2017	jlgrh7 TFS #7258
	if txnController.isKindOf(CMIF_PackTransController) then
		if self.myCurrentTransaction &lt;&gt; null and self.myCurrentTransaction.isKindOf(CM_Pack) then
			txnController.CMIF_PackTransController.action := self.myCurrentTransaction.CM_Pack.action ;
		elseif self.myCurrentTransaction &lt;&gt; null and self.myCurrentTransaction.isKindOf(CM_Unpack) then
			txnController.CMIF_PackTransController.action := self.myCurrentTransaction.CM_Unpack.action ;
		endif;
	endif; */
	// Feb 2012 from CCMS 1262 testing, to do task added for MES CCMS 1006
	if self.myCurrentTransaction &lt;&gt; null then
		txnController.myToDoTask 			:= self.myCurrentTransaction.myToDoTask;
	endif;
	if not self.isForCargoEdit then	
		if not self.isBulkUpdate then
			self.doSaveTxn(txnController);
		else
			self.doSaveTxnMulti(txnController);
		endif;
	else
		if not self.validateTITxnController(txnController) then
			return;
		else
			if self.state = self.State_Add then
				self.allTITxnControllers.add(txnController);
			endif;
			
			self.setState(self.State_View);
		endif;
	endif;
	
epilog
	if not self.isForCargoEdit then
		delete txnController;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSaveTxn" id="6c1ddb7d-d591-41fa-98dc-c6e14373b5d9">
        <updating/>
        <source>doSaveTxn(_txnController : CMIF_TITransactionController input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	newTITxn 			: CM_TITransaction;
	result				: Integer;
begin
	while true do
		if self.state = self.State_Add then
			app.myTrxCA.trxCreateTITransaction(_txnController, newTITxn, app.myPassport);	
		elseif self.state = self.State_Update then
			app.myTrxUA.trxUpdateTITransaction(_txnController, self.myCurrentTransaction, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			if self.editModeOnly then
				self.unloadForm();
				return;
			endif;
		
			self.setState(self.State_View);
			return;
		else
			result := app.showErrorWarningDialog('Transaction Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		return;
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="_txnController" type="CMIF_TITransactionController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSaveTxnMulti" id="1a2b3ca4-9fcf-4bd7-a1cc-3f0913a53499">
        <updating/>
        <source>doSaveTxnMulti(_txnController : CMIF_TITransactionController input) updating, protected;
// ---------------------------------------------------------------------------
//11 May 2016	cnwrs1	TFS 1546 POL - Unpacking Process Options
// ---------------------------------------------------------------------------
vars
	newTITxn : CM_TITransaction;
	result : Integer;
	ti : CM_TrackedItem;
begin
	foreach ti in self.allTITrackitems do
		_txnController.myTrackedItem := ti;
		while true do
			if self.state = self.State_Add then
				app.myTrxCA.trxCreateTITransaction(_txnController, newTITxn, app.myPassport);	
			elseif self.state = self.State_Update then
				app.myTrxUA.trxUpdateTITransaction(_txnController, self.myCurrentTransaction, app.myPassport);
			endif;
			
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				if self.editModeOnly then
					self.unloadForm();
					break;
				endif;
			
				self.setState(self.State_View);
				break;
			else
				result := app.showErrorWarningDialog('Transaction Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
	
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
			return;
		endwhile;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_txnController" type="CMIF_TITransactionController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblListRowColChange" id="b5ee80c1-4aeb-48a4-bb83-f847ceadbf2d">
        <updating/>
        <source>doTblListRowColChange() updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	txn					: CM_TITransaction;
	txnController		: CMIF_TITransactionController;
begin
	if self.tblList.row &lt;= self.tblList.fixedRows then
		return;
	endif;
	
	if self.isForCargoEdit then
		txnController := self.tblList.accessRow(self.tblList.row).itemObject.CMIF_TITransactionController;	
		self.doDisplayTxnController(txnController);
	else
		txn := self.tblList.accessRow(self.tblList.row).itemObject.CM_TITransaction;
		self.myCurrentTransaction := txn;
		self.doDisplayTxn();	
	endif;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getSubTermType" id="4506658f-fc5b-40ca-aefa-985c0f976538">
        <source>getSubTermType(_transType : Integer):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Aug 2017	cnwma1	TFS #5027:POL - CAMS Transaction not being correctly processed

*/

vars
	subTermType :Integer;
begin
	 
	if _transType = TRANS_TYPE_RECEIVE_ST_DEPOT
	or _transType = TRANS_TYPE_RELEASE_ST_DEPOT
	or _transType = TRANS_TYPE_REC_ST_DEPOT_INT
	or _transType = TRANS_TYPE_REC_ST_DEPOT_RAIL
	or _transType = TRANS_TYPE_REC_ST_DEPOT_ROAD
	or _transType = TRANS_TYPE_REC_ST_DEPOT_SHIP 
	or _transType = TRANS_TYPE_REL_ST_DEPOT_INT
	or _transType = TRANS_TYPE_REL_ST_DEPOT_RAIL
	or _transType = TRANS_TYPE_REL_ST_DEPOT_ROAD
	or _transType = TRANS_TYPE_REL_ST_DEPOT_SHIP then
	
		subTermType :=SubTermType_Depot_Int;
	
	elseif _transType = TRANS_TYPE_RECEIVE_ST_MARINE
	or _transType = TRANS_TYPE_RELEASE_ST_MARINE
	or _transType = TRANS_TYPE_REC_ST_MARINE_INT
	or _transType = TRANS_TYPE_REC_ST_MARINE_RAIL
	or _transType = TRANS_TYPE_REC_ST_MARINE_ROAD
	or _transType = TRANS_TYPE_REC_ST_MARINE_SHIP 
	or _transType = TRANS_TYPE_REL_ST_MARINE_INT
	or _transType = TRANS_TYPE_REL_ST_MARINE_RAIL
	or _transType = TRANS_TYPE_REL_ST_MARINE_ROAD
	or _transType = TRANS_TYPE_REL_ST_MARINE_SHIP then
		subTermType :=SubTermType_Marine_Int;
	
	else
		
		subTermType:= SubTermType_Warehouse_Int;
	endif;
	return subTermType;
epilog

end;</source>
        <Parameter name="_transType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initEntTableDef" id="f1db3bbb-ef01-4e64-9531-2c85460d297e">
        <updating/>
        <source>initEntTableDef(_theTable : CM_EntryTable; _entDef : String) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//30 Mar 2016	cnwrs1	TFS 1546 POL - Unpacking Process Options
// ---------------------------------------------------------------------------

vars

	entTableControl	: EntTableDef;
	theTable		: CM_EntryTable;	
begin

	theTable := _theTable;
	theTable.rows := 0;
	entTableControl := app.myController.getEntTableDef(_entDef); 
	theTable.setEntTableDef(entTableControl, null, null);
	
	if self.isForCargoEdit or
	   self.isBulkUpdate then
		self.tblEntry.disableRowByName(ETRow_ContainerID);
	endif;
	
end;</source>
        <Parameter name="_theTable" type="CM_EntryTable"/>
        <Parameter name="_entDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="initTableList" id="77487523-6090-4424-922a-024052c17e9e">
        <source>initTableList();
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.tblList.rows := 0;
	self.tblList.fixedColumns := 0;
	self.tblList.show3D := Table.Show3D_Not3D;
	self.tblList.columns := 2;
	self.tblList.selectMode := Table.SelectMode_CurrentRow;
	self.tblList.addItem("Type" &amp; Tab &amp; "Date &amp; Time");
	self.tblList.fixedRows := 1;
end;</source>
    </JadeMethod>
    <JadeMethod name="isBulkUpdate" id="eda45802-067c-44bf-94f7-b9bb9bc9864b">
        <source>isBulkUpdate() : Boolean;
//
//30 Mar 2016	cnwrs1	TFS 1546 POL - Unpacking Process Options
//
vars

begin
	if self.allTITrackitems.size &gt; 0 then
		return true;
	endif;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isReleaseSubTerm" id="d764cf6d-d678-4d55-835a-8640854d50be">
        <source>isReleaseSubTerm(_transType : Integer):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//18 Aug 2017		cnwma1	TFS #5027:POL - CAMS Transaction not being correctly processed

*/

vars

begin
	if  _transType = TRANS_TYPE_RECEIVE_ST_DEPOT
	or     _transType = TRANS_TYPE_RECEIVE_ST_MARINE
	or 	   _transType = TRANS_TYPE_RECEIVE_ST_WHOUSE
	or 	   _transType = TRANS_TYPE_REC_ST_DEPOT_INT
	or     _transType = TRANS_TYPE_REC_ST_DEPOT_RAIL
	or     _transType = TRANS_TYPE_REC_ST_DEPOT_ROAD
	or     _transType = TRANS_TYPE_REC_ST_DEPOT_SHIP
	or     _transType = TRANS_TYPE_REC_ST_MARINE_INT
	or     _transType = TRANS_TYPE_REC_ST_MARINE_RAIL
	or     _transType = TRANS_TYPE_REC_ST_MARINE_ROAD
	or     _transType = TRANS_TYPE_REC_ST_MARINE_SHIP
	or     _transType = TRANS_TYPE_REC_ST_WHOUSE_INT
	or     _transType = TRANS_TYPE_REC_ST_WHOUSE_RAIL
	or     _transType = TRANS_TYPE_REC_ST_WHOUSE_ROAD
	or     _transType = TRANS_TYPE_REC_ST_WHOUSE_SHIP then
		return false;
	elseif _transType = TRANS_TYPE_RELEASE_ST_DEPOT
	or     _transType = TRANS_TYPE_RELEASE_ST_MARINE
	or 	   _transType = TRANS_TYPE_RELEASE_ST_WHOUSE
	or     _transType = TRANS_TYPE_REL_ST_DEPOT_INT
	or     _transType = TRANS_TYPE_REL_ST_DEPOT_RAIL
	or     _transType = TRANS_TYPE_REL_ST_DEPOT_ROAD
	or     _transType = TRANS_TYPE_REL_ST_DEPOT_SHIP
	or     _transType = TRANS_TYPE_REL_ST_MARINE_INT
	or     _transType = TRANS_TYPE_REL_ST_MARINE_RAIL
	or     _transType = TRANS_TYPE_REL_ST_MARINE_ROAD
	or     _transType = TRANS_TYPE_REL_ST_MARINE_SHIP
	or     _transType = TRANS_TYPE_REL_ST_WHOUSE_INT
	or     _transType = TRANS_TYPE_REL_ST_WHOUSE_RAIL
	or     _transType = TRANS_TYPE_REL_ST_WHOUSE_ROAD
	or     _transType = TRANS_TYPE_REL_ST_WHOUSE_SHIP then
	
		return true;
	endif;
epilog

end;</source>
        <Parameter name="_transType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="f537ab13-ec38-44ae-8a54-6d0046e1e36a">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      29 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
//07 Apr 2016	cnwrs1	TFS 1546 POL - Unpacking Process Options
//18 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	rightNow : TimeStamp;
	idx,lCount : Integer;
	ti : CM_TrackedItem;
	str : String;
begin

	rightNow := self.systemToLocalTime(app.actualTimeServer);
	
	// Update the navigator
	self.setNavigatorHeading(self.caption); 
	if not self.isBulkUpdate then
		self.doBuildComboContainers();
	endif;
	self.doBuildComboHireType();
	self.doBuildComboMachine();
	self.doBuildComboMessageStatus();
	self.doBuildComboOwner();
	self.doBuildComboOperator();
	self.doBuildComboTranType();
	self.tblEntry.setValueByName(ETRow_Charge, self.myCurrentChargeSetting);
	
	self.tblEntry.setValueByName(ETRow_Date2, rightNow.date()); //epr par 32438 31/12/13
	self.tblEntry.setValueByName(ETRow_Time, rightNow.time());
	
	//may be initializing with a particular txn, just particular type, or nothing at all
	if self.myCurrentTransaction &lt;&gt; null then
		self.myCurrentTransactionType := self.myCurrentTransaction.type;
	endif;
	
	if self.editModeOnly then
		self.tblList.visible := false;
	endif;
	// If this is called by a context menu then setup default values
	if self.myCurrentTrackedItem &lt;&gt; null then
		idx := self.cmbContainers.findObject(self.myCurrentTrackedItem);
		if idx &gt; 0 then
			self.cmbContainers.listIndex := idx;
			self.cmbContainers.text := self.cmbContainers.itemText[idx];
		endif;
		if self.allTITrackitems.isEmpty then
			self.tblEntry.setValueByControlName(self.cmbContainers.name, self.myCurrentTrackedItem.id);
		else
			foreach ti in self.allTITrackitems do
				if str = null then
					str := ti.id;
				else
					str := str&amp;', '&amp;ti.id;
				endif;
			endforeach;
			self.tblEntry.setValueByControlName(self.cmbContainers.name, str);
		endif;
		if self.myCurrentTransactionType &lt;&gt; null then
			lCount := self.cmbTranType.listCount;
			foreach idx in 1 to lCount do
				if self.myCurrentTransactionType = self.cmbTranType.itemData[idx] then
					self.cmbTranType.listIndex := idx;
					self.cmbTranType.text := self.cmbTranType.itemText[idx];
					self.tblEntry.setValueByControlName(self.cmbTranType.name,self.cmbTranType.text);
					self.doComboTranTypeClick(self.cmbTranType);
					break;
				endif;
			endforeach;
			
			self.displayTableList(self.myCurrentTransactionType,self.myCurrentTrackedItem);
		endif;
	endif;
	
	self.splMain.setLeftToRightRatioAndResize(60);
	
	if self.editModeOnly then
		self.doDisplayTxn();
		if self.myCurrentTransaction &lt;&gt; null then
			self.setState(self.State_Update);
		else
			self.setState(self.State_Add);
		endif;
	else
		self.setState(self.State_View);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setState" id="6fcab7f6-a8b0-4059-a7e4-8f73ad16558c">
        <updating/>
        <source>setState(_state : Integer) protected, updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.state := _state;
	
	if _state = self.State_View then
		self.cmbTranType.click(self.cmbTranType);
		self.doEnableTableEntry(false);
		self.btnCancel.caption 			:= '&amp;Close';
		self.tblList.enabled 			:= true;
		
		self.btnSave.visible 			:= false;
		self.btnDelete.visible 			:= true;
		self.btnAdd.visible 			:= true;
		self.btnUpdate.visible 			:= true;
		
	elseif _state = self.State_Add or
	   	_state = self.State_Update then
	   	self.btnCancel.caption := '&amp;Cancel';
		self.doEnableTableEntry(true);
		self.tblList.enabled 			:= false;
		
		self.btnSave.visible 			:= true;
		self.btnDelete.visible 			:= false;
		self.btnAdd.visible 			:= false;
		self.btnUpdate.visible 			:= false;
		
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTxnControllerFromTable" id="91964ec8-5a44-4164-9666-d3e0193e6a5d">
        <updating/>
        <source>setTxnControllerFromTable(txnController : CMIF_TITransactionController input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 March 2003		cnwth2	
//
// Purpose:     		 
/****Changes

Date		Name	TFS#			Description
============================================================================
27/04/2016	cnwrs1	TFS 1546 		POL - Unpacking Process Options
08/08/2017	cnwma1	TFS #5027:		POL - CAMS Transaction not being correctly processed
07/07/2018  cnwma1	Bug 39406: 		STWR - Steinweg Rotterdam - Error when adding transactions (Weights)
27/11/2018	jlgka1	TFS 41225		SNO - Repaired Transactions - Revisit.
20/06/2022	navdap1	TFS 53362 		EUP Master Data interface customers between TOS and ERP
============================================================================*/
vars
	theDateTime : TimeStamp;		
	ti 			: CM_TrackedItem;
	str 		: String;
	opcode		: String;			// TFS 53362
	
begin
	theDateTime.setDate(self.tblEntry.getValueByName(ETRow_Date2).Date);
	theDateTime.setTime(self.tblEntry.getValueByName(ETRow_Time).Time);
	
	txnController.dateTime := self.localToSystemTime(theDateTime);
	txnController.noCharge := not self.tblEntry.getValueByName(ETRow_Charge).Boolean;
	txnController.userId 	:= self.tblEntry.getValueByName(ETRow_UserID).String;
	txnController.urNumber := self.tblEntry.getValueByName(ETRow_UrNumber).String;
	if self.myCurrentContainerEnqForm &lt;&gt; null then
		self.myCurrentChargeSetting := not txnController.noCharge;
		self.myCurrentContainerEnqForm.defaultBulkAddCharge := self.myCurrentChargeSetting;
	endif;
	
	if txnController.type = TRANS_TYPE_FUELED then
		txnController.CMIF_FuelTransController.litres 	:= self.tblEntry.getValueByName(ETRow_Litres).Decimal;
	
	elseif txnController.type = TRANS_TYPE_MOVE then
		txnController.CMIF_MoveTransactionController.sourceLocn := self.tblEntry.getValueByName(ETRow_SourceLocation).String;
		txnController.CMIF_MoveTransactionController.targetLocn := self.tblEntry.getValueByName(ETRow_TargetLocation).String;
		txnController.CMIF_MoveTransactionController.machineId := self.tblEntry.getValueByName(ETRow_Machine).String;
		
	elseif txnController.type = TRANS_TYPE_REPAIR then
		txnController.autoToDoTask := self.tblEntry.getValueByName(ETRow_GenToDoTask).Integer;
		
	elseif txnController.type = TRANS_TYPE_REPAIR_DETAILS then // jlgka1 TFS 41225 --&gt;
		txnController.CMIF_RepairDetailsController.damageCode := self.tblEntry.getValueByName(ETRow_DamageCode).asStringJMT;		
		txnController.CMIF_RepairDetailsController.damagePositionCode := self.tblEntry.getValueByName(ETRow_DamagePosition).asStringJMT;
		txnController.CMIF_RepairDetailsController.severity := self.tblEntry.getValueByName(ETRow_Severity).Integer;
		txnController.CMIF_RepairDetailsController.quantity := self.tblEntry.getValueByName(ETRow_Quantity).Integer;
		txnController.CMIF_RepairDetailsController.remarks := self.tblEntry.getValueByName(ETRow_Remarks).asStringJMT; // jlgka1 TFS 41225 &lt;--
		
	elseif txnController.type = TRANS_TYPE_SEALED then
		txnController.CMIF_SealTransController.sealNum := self.tblEntry.getValueByName(ETRow_SealNum).String;
	
	elseif txnController.type = TRANS_TYPE_HIRE then
		opcode := self.tblEntry.getValueByName(ETRow_Operator).String;																// TFS 53362
		if opcode &lt;&gt; null and self.cmbOperator.listObject &lt;&gt; null and app.myRoot.getConfig(ComboByNameOperator).Boolean then		// TFS 53362
			txnController.CMIF_HireTransController.operatorCode		:= self.cmbOperator.listObject.CM_Operator.code;				// TFS 53362
		else																														// TFS 53362
			//txnController.CMIF_HireTransController.operatorCode 		:= self.tblEntry.getValueByName(ETRow_Operator).String;		// TFS 53362
			txnController.CMIF_HireTransController.operatorCode 		:= opcode;													// TFS 53362
		endif;																														// TFS 53362
		txnController.CMIF_HireTransController.operatorCode 		:= self.tblEntry.getValueByName(ETRow_Operator).String;
		txnController.CMIF_HireTransController.ownership 			:= self.tblEntry.getValueByName(ETRow_Owner).String;
		txnController.CMIF_HireTransController.fleetDisposition 	:= self.tblEntry.getValueByName(ETRow_Disposition).String;
		txnController.CMIF_HireTransController.hireType 			:= self.tblEntry.getValueByName(ETRow_HireType).String;
		txnController.CMIF_HireTransController.otherParty 			:= self.tblEntry.getValueByName(ETRow_OtherParty).String;
		txnController.CMIF_HireTransController.messageStatus 		:= self.tblEntry.getValueByName(ETRow_MessageStatus).String;
	elseif txnController.type = TRANS_TYPE_STOWAGE_CONFIRM then
		txnController.CMIF_StowageConfirmController.plannedLocation := self.tblEntry.getValueByName(ETRow_PlannedLocation).String;
		txnController.CMIF_StowageConfirmController.confirmedLocation := self.tblEntry.getValueByName(ETRow_ConfirmedLocation).String;	
		txnController.CMIF_StowageConfirmController.myVoyageJob:= self.cmbJob.listObject.CM_VoyageJob;
		txnController.CMIF_StowageConfirmController.isForVoyage := true; // ### TFS CR 56806 TASK 56807 01MAR2023 NAVAB1
		
	//30 Oct 2019	NDL	TFS 47283
	elseif txnController.type = TRANS_TYPE_PACK or txnController.type = TRANS_TYPE_UNPACK then	
		if self.myCurrentTransaction &lt;&gt; null and self.myCurrentTransaction.isKindOf(CM_Pack) then
			txnController.CMIF_PackTransController.action := self.myCurrentTransaction.CM_Pack.action ;
		elseif self.myCurrentTransaction &lt;&gt; null and self.myCurrentTransaction.isKindOf(CM_Unpack) then
			txnController.CMIF_PackTransController.action := self.myCurrentTransaction.CM_Unpack.action ;
		endif;
	
	
	// 18.8.2017 cnwma1 TFS #5027
	elseif txnController.type = TRANS_TYPE_RECEIVE_ST_DEPOT
	or     txnController.type = TRANS_TYPE_RECEIVE_ST_MARINE
	or 	   txnController.type = TRANS_TYPE_RECEIVE_ST_WHOUSE
	or 	   txnController.type = TRANS_TYPE_REC_ST_DEPOT_INT
	or     txnController.type = TRANS_TYPE_REC_ST_DEPOT_RAIL
	or     txnController.type = TRANS_TYPE_REC_ST_DEPOT_ROAD
	or     txnController.type = TRANS_TYPE_REC_ST_DEPOT_SHIP
	or     txnController.type = TRANS_TYPE_REC_ST_MARINE_INT
	or     txnController.type = TRANS_TYPE_REC_ST_MARINE_RAIL
	or     txnController.type = TRANS_TYPE_REC_ST_MARINE_ROAD
	or     txnController.type = TRANS_TYPE_REC_ST_MARINE_SHIP
	or     txnController.type = TRANS_TYPE_REC_ST_WHOUSE_INT
	or     txnController.type = TRANS_TYPE_REC_ST_WHOUSE_RAIL
	or     txnController.type = TRANS_TYPE_REC_ST_WHOUSE_ROAD
	or     txnController.type = TRANS_TYPE_REC_ST_WHOUSE_SHIP
	or	   txnController.type = TRANS_TYPE_RELEASE_ST_DEPOT
	or     txnController.type = TRANS_TYPE_RELEASE_ST_MARINE
	or 	   txnController.type = TRANS_TYPE_RELEASE_ST_WHOUSE
	or     txnController.type = TRANS_TYPE_REL_ST_DEPOT_INT
	or     txnController.type = TRANS_TYPE_REL_ST_DEPOT_RAIL
	or     txnController.type = TRANS_TYPE_REL_ST_DEPOT_ROAD
	or     txnController.type = TRANS_TYPE_REL_ST_DEPOT_SHIP
	or     txnController.type = TRANS_TYPE_REL_ST_MARINE_INT
	or     txnController.type = TRANS_TYPE_REL_ST_MARINE_RAIL
	or     txnController.type = TRANS_TYPE_REL_ST_MARINE_ROAD
	or     txnController.type = TRANS_TYPE_REL_ST_MARINE_SHIP
	or     txnController.type = TRANS_TYPE_REL_ST_WHOUSE_INT
	or     txnController.type = TRANS_TYPE_REL_ST_WHOUSE_RAIL
	or     txnController.type = TRANS_TYPE_REL_ST_WHOUSE_ROAD
	or     txnController.type = TRANS_TYPE_REL_ST_WHOUSE_SHIP then
		
		txnController.mySubTerminalFrom := cmbSubTermFrom.listObject.CM_SubTerminal;
		txnController.mySubTerminalTo := cmbSubTermTo.listObject.CM_SubTerminal;
		txnController.isManual := true;
	// 18.8.2017 cnwma1 TFS #5027
	endif;
	
	//epr TFS 2996 8/12/16
	if not self.isBulkUpdate then
		if self.tblEntry.isRowVisible(ETRow_TotalQuantity) then
			txnController.totalQuantity := self.tblEntry.getValueByName(ETRow_TotalQuantity).Integer;
		endif;
		if self.tblEntry.isMeasurementRowVisible(ETRow_TotalWeight) then
			//_txnController.totalWeight := self.tblEntry.getMeasurementValueByName(ETRow_TotalWeight).String.asDecimalJMT; 	 //7/7/2018 cnwma1 TFS 39406 
			txnController.totalWeight := self.tblEntry.getMeasurementValueByName(ETRow_TotalWeight).asStringJMT.asDecimalJMT;   //7/7/2018 cnwma1 TFS 39406 
		endif;
		if self.tblEntry.isMeasurementRowVisible(ETRow_TotalVolume) then
			//_txnController.totalWeight := self.tblEntry.getMeasurementValueByName(ETRow_TotalVolume).String.asDecimalJMT;     //7/7/2018 cnwma1 TFS 39406
			txnController.totalWeight := self.tblEntry.getMeasurementValueByName(ETRow_TotalVolume).asStringJMT.asDecimalJMT;  //7/7/2018 cnwma1 TFS 39406
			txnController.totalWeight := txnController.totalWeight * self.myCurrentTrackedItem.getDensity();
			txnController.totalVolume := txnController.totalWeight * self.myCurrentTrackedItem.getDensity(); // TFS 7031
		endif;
	endif;
	
	
	if self.isBulkUpdate then
		foreach ti in self.allTITrackitems do
			if str = null then
				str := ti.id;
			else
				str := str&amp;', '&amp;ti.id;
			endif;
		endforeach;
		self.tblEntry.setValueByControlName(self.cmbContainers.name, str);
		self.tblEntry.disableRowByName(ETRow_ContainerID);
		self.tblEntry.setFocus();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="txnController" type="CMIF_TITransactionController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="8fbc993f-2cd8-4ff7-871d-b17921f0927f">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	18 November 2003 By: cnwgd1
//--------------------------------------------------
//09 May 2016	cnwrs1	TFS 1546 POL - Unpacking Process Options
vars
	entTableDef	: EntTableDef;
	entTableView : EntTableView;
	theIndex : Integer;
begin
	inheritMethod();

	self.initTableList();
	
	entTableDef := app.myController.getEntTableDef(ETDef_TITMaint); 
	entTableView := entTableDef.allEntTableViews[ETView_TITGeneral];
	self.tblEntry.setEntTableFromView(entTableDef,entTableView, null, null);	
	self.setColorsForEntryTable(tblEntry);
	
	//epr TFS 2996 8/12/16
	self.resetMeasurementRows(self.tblEntry);																								// PAR #31155
	self.loadMeasurementTypes(self.tblEntry, self.tblEntry.myEntTableDef.name, self.tblEntry.myEntTableDef.allEntTableRows, true);
	self.tblEntry.hideRowByName(ETRow_TotalQuantity,false);
	self.tblEntry.hideRowByName(ETRow_TotalWeight,false);
	self.tblEntry.hideRowByName(ETRow_TotalVolume,false);
	
	if self.isForCargoEdit then
		self.tblEntry.disableRowByName(ETRow_ContainerID);
	endif;
	if self.isBulkUpdate then
		self.tblEntry.disableRowByName(ETRow_ContainerID);
		theIndex := self.tblEntry.getRow(ETRow_ContainerID);
		self.tblEntry.accessCell(theIndex, 1).text := app.getErrorString(CargoId);
	endif;
	
	self.splMain.backColor := self.backColor;
	
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSave.enabled:= false;
		self.tblEntry.userInputEnabled := false;
	endif;

end;</source>
    </JadeMethod>
