    <JadeMethod name="getDisplayStringForAttribute" id="f06ecf6a-a56c-4335-b476-5258833e8f93">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Oct 2023 navhl20 ChangeRequest 60090: EUP | Ship Operations in DD - [54176.020] -[Receive] Allocate Jobs to Gangs and Gangs to Holds
31 Oct 2023 navhl20 ChangeRequest 60091: EUP | Ship Operations in DD - [54176.040] - [Receive] Allocation List
02 Jan 2023 navhl20 Defect 61894: EUP - Ship Operations - Voyage Hold entered on the Add Jobs Details form is not saving the details correctly.
*/

vars
	
begin
	if _attrName = ETRow_Type then
		return self.getType();
	elseif _attrName = ETRow_VoyageTransType then	//31.10.2023 navhl20 #60091
		return self.getTransferTypeStr();
	elseif _attrName = ETRow_ExtRef1 then
		return self.externalReference1;
	elseif _attrName = ETRow_ExtRef2 then
		return self.externalReference2;
	elseif _attrName = ETRow_JobRemarks then
		return self.remarks;
	elseif _attrName = ETRow_StartDT then
		return self.actualStartTs.asStringJMT;
	elseif _attrName = ETRow_EndDT then
		return self.actualEndTs.asStringJMT;
	elseif _attrName = ETRow_VoyageHold then
		return self.getVoyageHold();				//02.01.2023 navhl20 #61894
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
