    <JadeMethod name="getAuditText" id="9df99213-548a-4862-9129-f97b2cc6b3f4">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2018	jlgndl1	Initial creation	TFS 37550

*/

vars
	txt,
	tmpStr,str	: String;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	tmpStr := null;
	str    :=null;
	if self.code &lt;&gt; null then
		tmpStr:=self.code;
		txt := txt &amp; app.getErrorString(Code) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	str    :=null;
	if self.currencySymbol &lt;&gt; null then
		tmpStr:=self.currencySymbol;
		txt := txt &amp; app.getErrorString(Currency_symbol) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	str    :=null;
	if self.description &lt;&gt; null then
		tmpStr:=self.description;
		txt := txt &amp; app.getErrorString(Err_Description) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	tmpStr := self.getRoundingTypeString;
	txt := txt &amp; app.getErrorString(Rounding) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;

	
	tmpStr := null;
	if self.roundingInterval &lt;&gt; 0 then
		tmpStr := self.roundingInterval.asStringJMT;
		txt := txt &amp; app.getErrorString(Rounding_interval) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	return txt;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="ea6a6a74-1c89-40c3-a9ac-4ab210ddb9ee">
        <source>getDisplayDetails(_short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2018	jlgndl1	Initial creation

*/

vars

begin

	if _short then
		return self.code &amp; " (" &amp; self.currencySymbol &amp; ")";
	else
		return self.description &amp; " (" &amp; self.currencySymbol &amp; ")";
	endif;

epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRate" id="4b32d58e-a42a-4ab6-bb4a-c1927042d9cd">
        <source>getRate( _asAtDateTime : TimeStamp ):CM_CurrencyRate;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2018	jlgndl1	Initial creation	TFS 37550

*/

vars

	ts : TimeStamp;
	rate : CM_CurrencyRate;

begin

	if self.allCurrencyRates.isEmpty then
		return null;
	endif;

	if _asAtDateTime = null or not _asAtDateTime.Date.isValid then
		ts := app.actualTimeAppServer;
	else
		ts := _asAtDateTime;
	endif;
	
	rate := self.allCurrencyRates.getAtKeyGeq( ts );
	
	return rate;

epilog

end;</source>
        <Parameter name="_asAtDateTime" type="TimeStamp"/>
        <ReturnType type="CM_CurrencyRate"/>
    </JadeMethod>
    <JadeMethod name="getRoundingTypeString" id="1e379012-37a0-4e79-891b-2a9f09079ec9">
        <source>getRoundingTypeString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2018	jlgndl1	Initial creation	TFS 37550

*/

vars

begin

	if self.roundingType = RoundingType_None then
		return RoundingType_None_Str;
	elseif self.roundingType = RoundingType_Up then
		return RoundingType_Up_Str;
	elseif self.roundingType = RoundingType_Down then
		return RoundingType_Down_Str;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
