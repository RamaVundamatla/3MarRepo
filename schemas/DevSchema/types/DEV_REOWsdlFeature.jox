    <JadeMethod name="setForProperty" id="0ef236ee-72fe-46ce-be70-3c95430bbad6">
        <updating/>
        <source>setForProperty(_name, _type : String; _method : DEV_REOWsdlFeature) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 May 2019		jlgmd1	Initial creation TFS 39667 - JMT - API Documentation

*/

vars

begin
	self.name := _name;
	self.type := _type;
	
	self.myMethod := _method;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_method" type="DEV_REOWsdlFeature"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateFromProxy" id="47514207-e5e4-42ff-ad2a-effa4f64f1fa">
        <updating/>
        <source>setForUpdateFromProxy(_pxyCMObject: DEV_REOWsdlFeature; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 May 2019		jlgmd1	Initial creation TFS 39667 - JMT - API Documentation
21 June 2019	jlgmd1	TFS 45268 - JMT fix 1310 when updating existing inputs

*/

vars
	pxyInput,
	input : DEV_REOWsdlFeature;
begin
	self.name			:= _pxyCMObject.name;
	self.signature		:= _pxyCMObject.signature;
	self.size			:= _pxyCMObject.size;
	self.type			:= _pxyCMObject.type;
	self.deleted		:= _pxyCMObject.deleted;
	
	// Copy over all the input properties too
	foreach pxyInput in _pxyCMObject.allInputs do
		input := self.allInputs[pxyInput.name];
		if input = null then
			// :'( I have no idea what I was thinking here... something something good idea at the time. // navmd1 26/01/2023
			if process.isInTransactionState then
				create input persistent;
			else
				create input transient;
			endif;
		endif;
		input.setForProperty(pxyInput.name, pxyInput.type, self);
	endforeach;
	
	// This should be set manually, and not from the proxy
	self.myWSDLClass	:= null;
epilog

end;</source>
        <Parameter name="_pxyCMObject" type="DEV_REOWsdlFeature"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setWSDLClass" id="dfd64d49-ad49-494a-84e4-4b2a12649a79">
