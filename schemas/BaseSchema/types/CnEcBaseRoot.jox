    <JadeMethod name="createWebTest" id="4b60ed60-3494-4809-bbd8-679c800c42c2">
        <source>createWebTest(pTestName:String; pTestCycles:Integer; pIsStopOnMessageFail:Boolean):CnEcWebTest;
// --------------------------------------------------------------------------------
// Created:		01 June 2000 by cnwdad2
//
// Purpose:		Create a Web Test object.
//
// Parameters:	pTestName - The name of the web test.
//				pTestCycles - The number of time the test will be repeated.
//				pIsStopOnMessageFail - If true, then the test will stop as soon as
//					a test message fails.
//
// Returns:		The newly created Web Test object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	webTestObj	: CnEcWebTest;

begin
	create webTestObj;
	webTestObj.initializeMe(self, pTestName, pTestCycles, pIsStopOnMessageFail);
	return webTestObj;
end;</source>
        <Parameter name="pTestName" type="String"/>
        <Parameter name="pTestCycles" type="Integer"/>
        <Parameter name="pIsStopOnMessageFail" type="Boolean"/>
        <ReturnType type="CnEcWebTest"/>
    </JadeMethod>
    <JadeMethod name="createWebTestMessage" id="3192c5b9-e92b-4108-8109-9f99aa36fa2a">
        <updating/>
        <source>createWebTestMessage(	pMessageName:String;
						pMessageData:String;
						pWebServerName:String;
						pWebServerPath:String):CnEcWebTestMessage updating;
// --------------------------------------------------------------------------------
// Created:		01 June 2000 by cnwdad2
//
// Purpose:		Create a Web Test Message.
//
// Parameters:	pMessageName - The name of the test message.
//				pMessageData - The contents of the test message, i.e. HTML or XML.
//				pWebServerName - The name of the destination web server.
//				pWebServerPath - The web server path name to deliver the message to.
//
// Returns:		The newly created Web Test Message object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	testMessageObj	: CnEcWebTestMessage;

begin
	create testMessageObj;
	testMessageObj.initializeMe(self,
							pMessageName,
							pMessageData,
							pWebServerName,
							pWebServerPath);
	return testMessageObj;
end;</source>
        <Parameter name="pMessageName" type="String"/>
        <Parameter name="pMessageData" type="String"/>
        <Parameter name="pWebServerName" type="String"/>
        <Parameter name="pWebServerPath" type="String"/>
        <ReturnType type="CnEcWebTestMessage"/>
    </JadeMethod>
    <JadeMethod name="createWebTestResult" id="c364d452-fccd-4c9f-b6d4-0f3dd88fbffa">
        <updating/>
        <source>createWebTestResult(pTestMessage:CnEcWebTestMessage;
					pTimeRequested:TimeStamp;
					pTimeReceived:TimeStamp;
					pResponseData:String):CnEcWebTestResult updating;
// --------------------------------------------------------------------------------
// Created:		01 June 2000 by cnwdad2
//
// Purpose:		Create a Web Test Result.
//
// Parameters:	pTestMessage - The owner of the test result.
//				pTimeRequested - The timestamp when the test message was requested.
//				pTimeReceived - The timestamp when the test message processed.
//				pResponseData - The content of the web server response message.
//
// Returns:		The newly created Web Test Result object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	testResponseObj	: CnEcWebTestResult;

begin
	create testResponseObj;
	testResponseObj.initializeMe(self, pTestMessage, pTimeRequested, pTimeReceived, pResponseData);
	return testResponseObj;
end;</source>
        <Parameter name="pTestMessage" type="CnEcWebTestMessage"/>
        <Parameter name="pTimeRequested" type="TimeStamp"/>
        <Parameter name="pTimeReceived" type="TimeStamp"/>
        <Parameter name="pResponseData" type="String"/>
        <ReturnType type="CnEcWebTestResult"/>
    </JadeMethod>
    <JadeMethod name="getAllFormatsForSchema" id="df8c2d2d-6850-497b-8064-9b42f9292d37">
        <source>getAllFormatsForSchema(pXmlFormatColl : CnEcXmlFormatDict io; pSchemaName : String);

vars
	xmlFormatObj	: CnEcXmlFormat;
		
begin
	pXmlFormatColl.clear();
	
	foreach xmlFormatObj in app.myBaseRoot.allXmlFormats where xmlFormatObj.schemaName = pSchemaName do
		pXmlFormatColl.add(xmlFormatObj);
	endforeach;
end;</source>
        <Parameter name="pXmlFormatColl" type="CnEcXmlFormatDict" usage="io"/>
        <Parameter name="pSchemaName" type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllXmlExcludedClasses" id="02b8172e-cab7-4cd2-a217-641e41160653">
        <source>getAllXmlExcludedClasses():StringArray;

vars
	allExcludedClasses	: CnEcXmlExcludedClasses;
	
begin
	allExcludedClasses := self.allXmlExcludedClassesBySchema[app.myCnEcXmlSchema.name];
	
	if allExcludedClasses &lt;&gt; null then
		return allExcludedClasses.allXmlExcludedClasses;		
	else
		if app.myCnEcXmlSchema &lt;&gt; null then
			beginTransaction;
			createCnEcXmlExcludedClasses(app.myCnEcXmlSchema.name, allExcludedClasses);
			commitTransaction;
		else
			return null;			
		endif;
	endif;
	
	return allExcludedClasses.allXmlExcludedClasses;	
end;</source>
        <ReturnType type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="getSpellRoot" id="df9d6f5b-16e4-4639-8f07-540a183b3b19">
        <updating/>
        <source>getSpellRoot():CnEcSpellRoot updating;

begin
	if self.mySpellRoot = null then
		beginTransaction;
			self.zInitializeSpellRoot();
		commitTransaction;
	endif;
	
	return self.mySpellRoot;
end;</source>
        <ReturnType type="CnEcSpellRoot"/>
    </JadeMethod>
    <JadeMethod name="getXmlFormat" id="a1d5f58f-5b76-4570-ae8e-7febc9cd8670">
        <source>getXmlFormat(pSchemaName : String; pName : String ) : CnEcXmlFormat;
// --------------------------------------------------------------------------------
// Created:		10 October 2000 by cnwdad1
//
// Purpose:		Return an XML Format for the requested schema and format names.
//
// Parameters:	pSchemaName - The name of the format's schema.
//				pName - The name of the XML format.
//
// Returns:		The XML Format object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.allXmlFormats[pSchemaName, pName];
end;</source>
        <Parameter name="pSchemaName" type="String"/>
        <Parameter name="pName" type="String"/>
        <ReturnType type="CnEcXmlFormat"/>
    </JadeMethod>
    <JadeMethod name="setCurrentBaseSchemaRelease" id="1bb1609b-051f-4296-8015-a2c9cc0ea1f6">
        <updating/>
        <source>setCurrentBaseSchemaRelease(pCurrentRelease:String):String updating;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Purpose:		Updates the receiver with a History Release version number.
//
// Parameters:	pCurrentRelease - The release (version) number.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.currentBaseSchemaRelease &lt;&gt; pCurrentRelease then
		self.currentBaseSchemaRelease	:=	pCurrentRelease;
	endif;
	
	return null;
end;</source>
        <Parameter name="pCurrentRelease" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setLastBackedUpLog" id="3379c309-a7e2-4201-bbc4-01c8e45441da">
        <updating/>
        <source>setLastBackedUpLog(pLogNumber:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		21 July 2001 by cnwdad2
//
// Purpose:		Updates the log file number from the latest backup.
//
// Parameters:	pLogNumber - The number of the log file.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.lastBackedUpLog &lt;&gt; pLogNumber then
		self.lastBackedUpLog	:=	pLogNumber;
	endif;
end;</source>
        <Parameter name="pLogNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setXmlDefaultFormatLastRebuilt" id="e7e80ee6-a94d-4822-b955-80031e8779c8">
        <updating/>
        <source>setXmlDefaultFormatLastRebuilt(pDefaultFormatLastRebuilt:TimeStamp) updating;
// --------------------------------------------------------------------------------
// Created:		10 October 2000 by cnwdad1
//
// Purpose:		Sets a timestamp of when the default XML Format was last rebuilt.
//
// Parameters:	pDefaultFormatLastRebuilt - The date/time of the rebuild.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.xmlDefaultFormatLastRebuilt &lt;&gt; pDefaultFormatLastRebuilt then
		self.xmlDefaultFormatLastRebuilt := pDefaultFormatLastRebuilt;
	endif;
end;</source>
        <Parameter name="pDefaultFormatLastRebuilt" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="zInitializeSpellRoot" id="7adf63b4-1d40-4341-83c9-4694b8fc6fa6">
        <updating/>
        <source>zInitializeSpellRoot() updating, protected;

vars
	spellRootObj	: CnEcSpellRoot;
	
begin
	create spellRootObj;
	self.mySpellRoot	:=	spellRootObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
