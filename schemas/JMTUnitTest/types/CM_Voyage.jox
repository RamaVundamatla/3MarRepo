</source>
        <Parameter name="_cargoType" type="CM_CargoType" usage="io"/>
        <Parameter name="_useDuplicateID" type="Boolean"/>
        <Parameter name="_doGetNextID" type="Boolean"/>
        <Parameter name="_nextNum" type="Integer" usage="io"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextVoyageId" id="253a1dbf-c3c3-4ce8-ba39-6492b99e19f8">
        <source>getNextVoyageId(terminal:CM_Terminal):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2022	navsp1	Initial creation TFS#53956

*/

vars
	voyage	: CM_Voyage;
	newNum  : Integer;
begin
	if terminal &lt;&gt; null then
		voyage	:= terminal.allVoyagesByCode.first;
		newNum	:= voyage.getId().Integer+1;
	else
		newNum := app.random(999999);
	endif;
	
	return newNum;
epilog

end;</source>
        <Parameter name="terminal" type="CM_Terminal"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="unitTestDeleteObject" id="3599bb28-753e-47bd-b469-a0ca3798b1b9">
        <updating/>
        <source>unitTestDeleteObject(_dsl: UT_DSL io) updating;

/*

Purpose:			

Date			Who		Reason
11/08/2015		cnwmh5	Initial creation

*/

vars

begin
	
	//write self.String &amp; Tab &amp; self.code &amp; Tab &amp; self.creationTime.String;
	app.writeLog(self.String &amp; Tab &amp; self.code &amp; Tab &amp; self.creationTime.String, LogINFO);
	_dsl.opts.purge();
	_dsl.opts.addAssoc("Terminal", self.getMyTerminal().code);
	_dsl.sendMsgWithParams("deleteVoyage", self.code);	

epilog

end;</source>
        <Parameter name="_dsl" type="UT_DSL" usage="io"/>
    </JadeMethod>
</Class>
