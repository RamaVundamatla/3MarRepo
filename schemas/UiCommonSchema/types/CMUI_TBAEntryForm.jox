    <JadeMethod name="doTblItemCellInputReady" id="4bc100ee-eda3-4441-b2a4-cc11c0e6bb78">
        <updating/>
        <source>doTblItemCellInputReady(table: CM_BaseTable input; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/11/2016	cnwdap1		Initial creation TFS 2842 STWR Hazardous Details Enhancements
//
vars

begin
	if CMUI_MeasurementTable.hasInstance(inputControl) and not inputControl = self.tblMeasurement then
		app.doMeasureTableCellInputReady(table, inputControl);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="table" type="CM_BaseTable" usage="input"/>
