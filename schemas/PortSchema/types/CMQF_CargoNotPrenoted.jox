<Class name="CMQF_CargoNotPrenoted" id="605a0d75-2b9c-4f3a-8d9c-a5582ad4d322">
    <superclass name="CMQF_TrackedItem"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="e3392ab9-86f0-4338-8030-9ef053b47b80">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//11 February 2010	cnwml2
/*

Date		Who		Reason
17 Feb 2015	cnwkpd1	PAR #35704 - Changes to prevent extended locking

*/

vars
	ti : CM_TrackedItem;
	terminal : CM_Terminal;
	breakOut : Boolean;
begin
	foreach terminal in self.allTerminals do
		foreach ti in  terminal.allOnsiteTIsByCargoTypeId discreteLock do
				if self.getMySubTerminal &lt;&gt; null and					//+cnwml2 PAR23671
				   self.getMySubTerminal &lt;&gt; ti.mySubTerminal then
					continue;
				endif;
				
				if self.getMyVoyage &lt;&gt; null and
				   ti.myVoyage &lt;&gt; self.getMyVoyage then
					continue;
				endif;
				
				if self.myOperator &lt;&gt; null and
					ti.myOperator &lt;&gt; self.myOperator then
					continue;
				endif;
				
				if self.getMyCargoType &lt;&gt; null and
				   ti.myCargoType &lt;&gt; self.getMyCargoType then
					continue;
				endif;
				
				if ti.isPreNote then					//+cnwml2 PAR23257
					continue;
				endif;
				
				if ti.wasPrenotified() then  //cnwrd1 par 23671 6.5.2010 , this checks the create transaction's state field to se if the item was prenotified initialy, if so we can exclude it
					continue;
				endif;

			if self.checkStatusIncludesObject(ti, _passport, breakOut) then	
				if not _collection.includes(ti) then
					_collection.add(ti);
				endif;
			endif;

		endforeach;
	endforeach;
	
	// 06/04/2011 cnwar2 #27339 - check onship items if voyage specified
	if self.getMyVoyage &lt;&gt; null then
		foreach ti in self.getMyVoyage.allOnshipTIsByIdCargoType discreteLock do
			if self.getMySubTerminal &lt;&gt; null and
			   self.getMySubTerminal &lt;&gt; ti.mySubTerminal then
				continue;
			endif;
			if self.myOperator &lt;&gt; null and
				ti.myOperator &lt;&gt; self.myOperator then
				continue;
			endif;
			if self.getMyCargoType &lt;&gt; null and
			   ti.myCargoType &lt;&gt; self.getMyCargoType then
				continue;
			endif;
			
			if ti.isPreNote then
				continue;
			endif;
			if ti.wasPrenotified() then
				continue;
			endif;
		
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
				if not _collection.includes(ti) then
					_collection.add(ti);
				endif;
			endif;			
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="dabd961f-048b-4208-94c6-ea6574b6919a">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//11 February 2010	cnwml2


vars
	stamp : TimeStamp;
begin
	self.numSearched := self.numSearched +1;
	
	//stamp.setDate(_ti.expectedArrivalDate);
	//stamp.setTime(_ti.expectedArrivalTime);
	//29 Jul 2013	NDL	Par 31763
	stamp.setDate(_ti.getExpectedArrivalDate);
	stamp.setTime(_ti.getExpectedArrivalTime);
	
	if stamp &lt;&gt; null then
		return false;
	endif;
	
	self.numFound := self.numFound + 1;
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
