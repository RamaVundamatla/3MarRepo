    <JadeMethod name="tblVoyageCutoffs_click" id="5972265a-8113-41c8-be57-788268d25b26">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblVoyageCutoffs_click(table: Table input) updating;
/*
Purpose:	

Date		Who		Reason
07 March 2025	navab1	JIRA 34233
*/

vars
	cutoff : CM_ReceivalCutoffVoyage;
	targetTS, earliestTS, earliestTSPN,cutoffTS,cutoffTSPN : TimeStamp;
	defRelativeTo : Integer;
	defEarliest, defEarliestPN,defCutoff,defCutoffPN  : Decimal[23,2];
	opCode : String;
	showForCargo : Boolean;
begin
	self.myProxyCutoff := null; // ### JIRA 34553 08APR2025 NAVAB1

	if self.mode = Mode_View then
		return;
	endif;
	if not table.userInputEnabled then
		return;
	endif;

	if table.row &lt;= table.fixedRows then
		return;
	endif;
	
	cutoff := table.accessRow(table.row).itemObject.CM_ReceivalCutoffVoyage;
	
	self.myProxyCutoff := cutoff;

	self.lblCutoffCode.caption := cutoff.code;
	if cutoff.myOperator &lt;&gt; null then
		 opCode := cutoff.myOperator.code;
	endif;
		
	self.lblCutoffOpCode.caption := opCode;
	
	defRelativeTo := cutoff.defaultRelativeTo;
	
	// ### NON PRENOTE
	// ### JIRA 36847 16DEC2025 NAVAB1
	cutoffTS := self.systemToLocalTime(cutoff.cutoffDateTime); 
	earliestTS := self.systemToLocalTime(cutoff.earliestDateTime); 
	
	self.mskNonPNCutoffDate.setDate(cutoffTS.date);
	self.mskNonPNCutoffTime.setTime(cutoffTS.time);
	self.mskNonPNEarlyDate.setDate(earliestTS.date);
	self.mskNonPNEarlyTime.setTime(earliestTS.time);
	self.txtNonPNEarlyHours.text := cutoff.hoursEarly.asStringJMT();
	self.txtNonPNCutoffHours.text := cutoff.hoursCutoff.asStringJMT();
	
	// ### PRENOTE
	// ### JIRA 36847 16DEC2025 NAVAB1
	cutoffTSPN := self.systemToLocalTime(cutoff.cutoffDateTimePN); 
	earliestTSPN := self.systemToLocalTime(cutoff.earliestDateTimePN); 
	
	self.mskPNCutoffDate.setDate(cutoffTSPN.date);
	self.mskPNCutoffTime.setTime(cutoffTSPN.time);
	self.mskPNEarlyDate.setDate(earliestTSPN.date);
	self.mskPNEarlyTime.setTime(earliestTSPN.time);
	self.txtPNEarlyHours.text := cutoff.hoursEarlyPN.asStringJMT();
	self.txtPNCutoffHours.text := cutoff.hoursCutoffPN.asStringJMT();

	// ### Enable / Disable
	self.mskNonPNCutoffDate.enabled := true;
	self.mskNonPNCutoffTime.enabled := true;
	self.txtNonPNCutoffHours.enabled := true;
	self.mskPNCutoffDate.enabled := true;
	self.mskPNCutoffTime.enabled := true;
	self.txtPNCutoffHours.enabled := true;
	
	if cutoff.defaultRelativeTo = DefaultRelativeTo_RecCutOff then
		self.mskNonPNCutoffDate.enabled := false;
		self.mskNonPNCutoffTime.enabled := false;
		self.txtNonPNCutoffHours.enabled := false;
		self.mskPNCutoffDate.enabled := false;
		self.mskPNCutoffTime.enabled := false;
		self.txtPNCutoffHours.enabled := false;
		self.mskNonPNCutoffDate.setDate(null);
		self.mskNonPNCutoffTime.setTime(null);
		self.mskPNCutoffDate.setDate(null);
		self.mskPNCutoffTime.setTime(null);
		
		showForCargo := false;
	else
		showForCargo := not cutoff.isEDIType();
	endif;
	
	if  cutoff.isEDIType() then
		self.mskNonPNEarlyDate.setDate(null);
		self.mskNonPNEarlyTime.setTime(null);
		self.txtNonPNEarlyHours.text := null;
		self.mskPNEarlyDate.setDate(null);
		self.mskPNEarlyTime.setTime(null);
		self.txtPNEarlyHours.text := null;
	
	endif;
	
	self.mskNonPNEarlyDate.enabled := showForCargo;
	self.mskNonPNEarlyTime.enabled := showForCargo;
	self.txtNonPNEarlyHours.enabled := showForCargo;
	self.mskPNEarlyDate.enabled := showForCargo;
	self.mskPNEarlyTime.enabled := showForCargo;
	self.txtPNEarlyHours.enabled := showForCargo;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
