    <JadeMethod name="isBulkMove" id="b47ad907-c072-4d30-b752-606c1abc6623">
        <source>isBulkMove() : Boolean;
/*

Date		Who		Reason
19 March 2014	cnwer1	Initial creation PAR

*/

vars
	wle : CM_WorkListEntry;
begin
	
	wle := self.myWorkListEntry;
	
	if wle = null then
		return false;
	endif;
	
	if wle.myRequest &lt;&gt; null and wle.myRequest.isBulkMulti then
		return true;
	endif;
	
	return false;
epilog

end;</source>
