    <JadeMethod name="pxyCreateUpdateProxy" id="4bf33600-6387-422f-84f4-cf393cd01991">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     16 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// 11 Nov 2019	jlgrs1		TFS 47300 not all collections are in the proxy create
// 02 Nov 2022 navds20 		ChangeRequest 54253: EUP - VAS Work Orders - Types and Roles
// ---------------------------------------------------------------------------
vars
	pxyRole	: CM_SecurityRole;
	completedOK		: Boolean;
	
begin
	pxyRole := inheritMethod();
	
	self.allChildMaintenanceRoles.copy(pxyRole.allChildMaintenanceRoles);
	self.allInvoiceStatusesMaint.copy(pxyRole.allInvoiceStatusesMaint);
	self.allQryReports.copy(pxyRole.allQryReports);
	self.allStopsMaint.copy(pxyRole.allStopsMaint);
	self.allStopsCancel.copy(pxyRole.allStopsCancel);		// cnwdad1 03/06/2010 - CCMS 1129.
	self.allStopsView.copy(pxyRole.allStopsView);
	self.allToDoTasksComplete.copy(pxyRole.allToDoTasksComplete);
	self.allToDoTasksAddRemove.copy(pxyRole.allToDoTasksAddRemove);
	self.allTransactionTypesForEvents.copy(pxyRole.allTransactionTypesForEvents);	// 14/7/17 MAP TFS4846
	self.allVolumeDiscrepancyReasons.copy(pxyRole.allVolumeDiscrepancyReasons);
	self.allVoyageStatusesMaint.copy(pxyRole.allVoyageStatusesMaint);
	self.allWorkOrderStatusMaint.copy(pxyRole.allWorkOrderStatusMaint);	//02/11/2022 navds20 TFS 54253
	self.allEventTypes.copy(pxyRole.allEventTypes);	//09 Mar 2020	NDL	TFS 48784
	
	pxyRole.mySecurityRoleVisibility := self.mySecurityRoleVisibility.pxyCreateUpdateProxy();
	
	pxyRole.myParentRole	:= self.myParentRole;
	pxyRole.myRoot 			:= self.myRoot;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyRole;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyRole;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="refreshPermissions" id="de57c505-2033-447a-bdd1-e3b4eb0bfcc6">
        <updating/>
        <source>refreshPermissions(perms : IntegerArray) updating;
// ---------------------------------------------------------------------------
// Created:			01 May 2001 by cnwdwq1
// Purpose:			For each user in this role, make sure that if the permission is represented
//                      in the user's permission list. If its not, then clear out.
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	counter, maxNum : Integer;
begin
	//-------------------------
	//The perms array is a list of the current permission GLOBAL constants
	//there may have been deletions and additions. Where we DONT find a value 
	//then NULL it in the role to be safe.
	//-------------------------
	maxNum := perms.last;
	foreach counter in 1 to maxNum do
		if perms.includes(counter) then
			continue;
		endif;
		//-----------------
		//The permission is NOT in the globals list. Make sure its NULL in this role.
		//-----------------
		self.permissions[counter] := false;
	endforeach;
end;</source>
        <Parameter name="perms" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="resetRootRole" id="ad841006-082d-4a5e-8575-d968bdc800a3">
        <updating/>
        <source>resetRootRole(_permAgent : CM_PermissionAgent; _cmifMonitor : CMIF_Monitor input) updating;
// ---------------------------------------------------------------------------
// Created:     20 February 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 29/03/2016	cnwdap1		PAR #35843 Make monitor time-based rather than object-based
vars
	child	: CM_SecurityRole;
	userTerm	: CM_UserTerminal;
	lastUpdated	: Decimal [20];						// PAR #35843

begin

	if self.class &lt;&gt; CM_SecurityRoleTerminalRoot and
	   self.class &lt;&gt; CM_SecurityRoleSystemRoot then
		return;
	endif;

	self.addAllPermissions(_permAgent);
	self.addAllStopTables();
	self.addAllToDoTasks();
	self.addAllQryReports();
	self.addAllTransactionTypes();
	self.addAllEventTypes();	//09 Mar 2020	NDL	TFS 48784

	if _cmifMonitor &lt;&gt; null then
	   	_cmifMonitor.message := app.getErrorString(Updating_User_Permissions);
	   	_cmifMonitor.partsDone := 0;
	   	_cmifMonitor.partsInJob := app.myRoot.allUsers.size * app.myRoot.allTerminals.size;
	endif;

	foreach userTerm in self.allUserTerminals do
		userTerm.checkNavMenuAgainstPermissions(false);
		userTerm.checkReportMenuAgainstSecurity();
		if _cmifMonitor &lt;&gt; null then
			_cmifMonitor.partsDone := _cmifMonitor.partsDone + 1;
			//if (_cmifMonitor.partsDone mod 20 = 0) then 												// PAR #35843
			if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
				_cmifMonitor.updateProgress(_cmifMonitor.message,
										_cmifMonitor.partsInJob,
										_cmifMonitor.partsDone);
				lastUpdated := app.relativeMachineTime;													// PAR #35843
			endif;
		endif;
	endforeach;

	foreach child in self.allChildRoles do
		child.updateFromParent(_cmifMonitor);
	endforeach;

end;</source>
        <Parameter name="_permAgent" type="CM_PermissionAgent"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setChildMaintRoles" id="20b0363e-b559-42bf-bee6-1339cb323f96">
        <updating/>
        <source>setChildMaintRoles( _maintRoles	: CM_SecurityRoleSet ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 February 2018	jlgndl1	Initial creation	TFS 36947

*/

vars

begin

	self.allChildMaintenanceRoles.clear();
	if _maintRoles &lt;&gt; null and not _maintRoles.isEmpty then
		_maintRoles.copy( self.allChildMaintenanceRoles );
	endif;

	
epilog

end;</source>
        <Parameter name="_maintRoles" type="CM_SecurityRoleSet"/>
    </JadeMethod>
