<Class name="DEV_SupportRoot" id="a5c04355-52bc-4d25-9f1d-20a2a7b54a6d">
    <superclass name="DEV_Support"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <ExplicitInverseRef name="allContacts" id="f9edd0a4-cc15-4ab5-bc71-964eb050119a">
        <kind>child</kind>
        <type name="DEV_SupportContactDict"/>
        <Inverse name="DEV_SupportContact::myRoot"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="allContactsRpt" id="3c553f08-0b74-480a-b105-98d719896e37">
        <memberTypeInverse/>
        <type name="DEV_SupportContactDict"/>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="allTimezones" id="7ab50901-d94e-482d-90bf-83c8a165adfb">
        <kind>parent</kind>
        <updateMode>automatic</updateMode>
        <type name="DEV_SupportTimezoneDict"/>
        <Inverse name="DEV_SupportTimezone::myRoot"/>
    </ExplicitInverseRef>
    <JadeMethod name="doExport" id="f67ddf3a-7620-4fd5-b4d9-25675f4f3732">
        <source>doExport();

/*
Date			Who		Reason
15 July 2016	cnwar2	Initial creation - note does NOT export remarks

workspace to run:
vars
begin
DEV_SupportRoot.firstInstance.doExport();
end;

*/
constants
	FileName : String = "c:\temp\supportKPIData.txt";
vars
	file 	 : File;
	line	 : String;
	contact  : DEV_SupportContact;
	state	 : DEV_SupportState;
	timezone : DEV_SupportTimezone;
	
begin
	create file;
	file.fileName := FileName;
	file.kind := File.Kind_Unknown_Text;
	file.open();
	
	// timezone details
	foreach timezone in self.allTimezones do
		line := timezone.name &amp; Tab &amp; timezone.gmtDiff.String &amp; Tab &amp; timezone.customers;
		file.writeLine(line);
	endforeach;
	
	// contact + state details
	foreach contact in self.allContacts do
		line := contact.number.String &amp; Tab &amp; contact.tfsNumber.String &amp; Tab &amp; contact.customer &amp; Tab &amp; contact.description &amp; Tab &amp;
				contact.owner &amp; Tab &amp; contact.openedTS.String &amp; Tab &amp; contact.kpi1Done.String &amp; Tab &amp; contact.kpi1FailedBy &amp; Tab &amp;
				contact.kpi2Done.String &amp; Tab &amp; contact.kpi2FailedBy &amp; Tab &amp; contact.kpi3FailedBy &amp; Tab &amp; contact.allStates.size.String;
		file.writeLine(line);
		foreach state in contact.allStates do
			line := state.type &amp; Tab &amp; state.startTS.String &amp; Tab &amp; state.endTS.String;
			file.writeLine(line);
		endforeach;
	endforeach;
	
	// contact remarks (multi-line)
	file.writeLine("REMARKS");
	foreach contact in self.allContacts where contact.remarks &lt;&gt; "" do
		file.writeLine(contact.number.String);
		file.writeString(contact.remarks &amp; CrLf);
		file.writeLine("ENDREMARKS");
	endforeach;
		
epilog
	file.close();
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="doImport" id="69a63424-785b-4e83-8d29-507cc335c1db">
        <source>doImport();

/*
Date			Who		Reason
15 July 2016	cnwar2	Initial creation

*/
constants
	FileName : String = "c:\temp\supportKPIData.txt";
vars
	file 	 : File;
	line, str, tzName, tzGMT, tzCust,
	contNum, contTFS, contCust, contDesc, contOwnr,
	contOpnd, contK1Dn, contK1FB, contK2Dn, contK2FB, 
	contK3FB, contStat, statTyp, statStr, statEnd : String;
	
	contact  	: DEV_SupportContact;
	state	 	: DEV_SupportState;
	timezone	: DEV_SupportTimezone;
	i, j	 	: Integer;
	
begin

	create file;
	file.fileName := FileName;
	file.kind := File.Kind_Unknown_Text;
	file.mode := File.Mode_Input;
	file.open;
	
	beginTransaction;
	while not file.endOfFile do
		line := file.readLine;
		i 	 	:= 1;
		tzName  := line.scanUntil(Tab,i);
		i	 	:= i + 1;
		if tzName.isInteger then
			break;	// finished with timezones, this is first contact number
		endif;
		tzGMT  	:= line.scanUntil(Tab,i);
		i	 	:= i + 1;
		tzCust  := line.scanUntil(Tab,i);
		i	 	:= i + 1;
		
		create timezone;
		timezone.name 		:= tzName;
		timezone.gmtDiff 	:= tzGMT.Integer;
		timezone.customers 	:= tzCust;
		timezone.myRoot		:= self;
		
	endwhile;
	commitTransaction;
	
	beginTransaction;
	while not file.endOfFile do
		i 	 	 := 1;
		contNum  := line.scanUntil(Tab,i);
		i	 	 := i + 1;
		contTFS  := line.scanUntil(Tab,i);
		i	 	 := i + 1;
		contCust := line.scanUntil(Tab,i);
		i	 	 := i + 1;
		contDesc := line.scanUntil(Tab,i);
		i	 	 := i + 1;
		contOwnr := line.scanUntil(Tab,i);
		i	 	 := i + 1;
		contOpnd := line.scanUntil(Tab,i);
		i	 	 := i + 1;
		contK1Dn := line.scanUntil(Tab,i);
		i	 	 := i + 1;
		contK1FB := line.scanUntil(Tab,i);
		i	 	 := i + 1;
		contK2Dn := line.scanUntil(Tab,i);
		i	 	 := i + 1;
		contK2FB := line.scanUntil(Tab,i);
		i	 	 := i + 1;
		contK3FB := line.scanUntil(Tab,i);
		i	 	 := i + 1;
		contStat := line.scanUntil(Tab,i);
		
		create contact;
		contact.number			:= contNum.Integer;
		contact.tfsNumber		:= contTFS.Integer;
		contact.customer		:= contCust;
		contact.description		:= contDesc;
		contact.owner			:= contOwnr;
		contact.openedTS		:= contOpnd.TimeStamp;
		contact.kpi1Done		:= contK1Dn.Boolean;
		contact.kpi1FailedBy	:= contK1FB;
		contact.kpi2Done		:= contK2Dn.Boolean;
		contact.kpi2FailedBy	:= contK2FB;
		contact.kpi3FailedBy	:= contK3FB;
		contact.myTimezone		:= self.getTimezoneForCust(contCust);
		contact.myRoot			:= self;
		
		commitTransaction;
		beginTransaction;
		foreach j in 1 to contStat.Integer do
			line 	 := file.readLine;
			i 	 	 := 1;
			statTyp  := line.scanUntil(Tab,i);
			i	 	 := i + 1;
			statStr	:= line.scanUntil(Tab,i);
			i	 	 := i + 1;
			statEnd	:= line.scanUntil(Tab,i);
			
			create state;
			state.type		:= statTyp;
			state.startTS	:= statStr.TimeStamp;
			state.endTS		:= statEnd.TimeStamp;
			state.myContact := contact;
		endforeach;
		commitTransaction;
		beginTransaction;
		
		line := file.readLine;
		if line = 'REMARKS' then
			break;
		endif;
	endwhile;
	commitTransaction;
	
	// do remarks
	while not file.endOfFile do
		line := file.readLine;
		if line = null then
			return;
		endif;
		contNum := line;
		if not contNum.isInteger then
			return;
		endif;
		contact := self.allContacts.getAtKey(contNum.Integer);
		line 	:= file.readLine;
		while line &lt;&gt; 'ENDREMARKS' do
			str := str &amp; line;
			line := file.readLine;
			if line = 'ENDREMARKS' then
				beginTransaction;
				contact.remarks := str;
				commitTransaction;
				str  := "";
				break;
			endif;
		endwhile;			
			
	endwhile;
	
	
	/*foreach timezone in self.allTimezones do
		line := timezone.name &amp; Tab &amp; timezone.gmtDiff.String &amp; Tab &amp; timezone.customers;
		file.writeLine(line);
	endforeach;
	
	foreach contact in self.allContacts do
		line := contact.number.String &amp; Tab &amp; contact.tfsNumber.String &amp; Tab &amp; contact.customer &amp; Tab &amp; contact.description &amp; Tab &amp;
				contact.owner &amp; Tab &amp; contact.openedTS.String &amp; Tab &amp; contact.kpi1Done.String &amp; Tab &amp; contact.kpi1FailedBy &amp; Tab &amp;
				contact.kpi2Done.String &amp; Tab &amp; contact.kpi2FailedBy &amp; Tab &amp; contact.kpi3FailedBy &amp; Tab &amp; contact.allStates.size.String;
		file.writeLine(line);
		foreach state in contact.allStates do
			line := state.type &amp; Tab &amp; state.startTS.String &amp; Tab &amp; state.endTS.String;
			file.writeLine(line);
		endforeach;
	endforeach;
	
	file.writeLine("REMARKS");
	foreach contact in self.allContacts where contact.remarks &lt;&gt; "" do
		file.writeLine(contact.number.String);
		file.writeString(contact.remarks);
		file.writeLine("ENDREMARKS");
	endforeach;*/
	
epilog
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="getTimezoneForCust" id="af92fd7e-79a3-4b36-93e4-f3a1526ed804">
        <source>getTimezoneForCust(_cust : String): DEV_SupportTimezone;

/*
Date			Who		Reason
11 July 2016	cnwar2	Initial creation

*/
vars
	root 		: DEV_SupportRoot;
	timezone 	: DEV_SupportTimezone;
	
begin
	root := DEV_SupportRoot.firstInstance;
	
	foreach timezone in root.allTimezones do
		if timezone.customers.pos(_cust,1) &gt; 0 then
			return timezone;
		endif;
	endforeach;
	
	return null;
	
end;</source>
        <Parameter name="_cust" type="String"/>
        <ReturnType type="DEV_SupportTimezone"/>
    </JadeMethod>
</Class>
