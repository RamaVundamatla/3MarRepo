<Class name="BGP_KiwiRailWSRequest" id="a7882665-d19c-4e92-96e5-950927df05b8">
    <superclass name="BGP_ExternalWSRequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;KiwiRail Web Service&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="myEventTransaction" id="bc2d5be0-4859-461c-8119-50d4ed34683c">
        <embedded/>
        <type name="CM_EventTransaction"/>
        <access>readonly</access>
        <text>TFS 40360</text>
    </ImplicitInverseRef>
    <JadeMethod name="action" id="09ac1c8c-35e4-4ec7-b811-d169f9bf3278">
        <updating/>
        <source>action(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Feb 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message

*/

vars
	errCode : Integer;
	errTxt, msg: String;
	returnVal : Boolean;
	wsDefinition : CM_KiwiRailCheckInWSDef;
	response : CMIF_KRFCheckInResponse;
	train : CM_Train;
	wagon : CM_Wagon;
	trackedItem : CM_TrackedItem;	
begin
	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	self.setUser();

	msg := 'Call KIWIRAIL Web Service';
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	
	wsDefinition := self.myEventTransaction.getMappedWSDef();
	if wsDefinition &lt;&gt; null then
		app.myPassport.setMyTerminal(self.myTerminal);
		train := myEventTransaction.CMEVT_TrainTransaction.myTrain;
		foreach wagon in train.allWagonsByIdOutward do
			foreach trackedItem in wagon.allReportTIsOutwards do
				response := self.sendWSRequest(wsDefinition, trackedItem.CM_Container);
			endforeach;
		endforeach;		
	endif;
epilog
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	endif;
	inheritMethod();
	return returnVal;
end;</source>
        <text>TFS 40360</text>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="a7e9e074-5757-420b-9a9d-655112e235c1">
        <source>getDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message

*/

vars

begin
	return inheritMethod() &amp; Tab &amp; ' Process ' &amp; myEventTransaction.myEventType.name &amp; " event";

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHazardous" id="bd72ba4d-3400-4415-a7ab-997794d22065">
        <source>getHazardous(_container : CM_Container; _hazards : CMIF_KRFCheckInHazardousArray io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message

*/

vars
	containerHazard : CM_Hazard;
	sealNumber : String;
	requestHazard : CMIF_KRFCheckInHazardous;
begin
	foreach containerHazard in _container.allTIHazards do
		create requestHazard transient;
		requestHazard.setHazardCodeClass(containerHazard.code, containerHazard.CM_TIHazard.getUndgCodesAsString(false));	//25 Sep 2019	NDL	TFS 46633 - use full string not truncated version
		_hazards.add(requestHazard);
	endforeach;
epilog

end;</source>
        <Parameter name="_container" type="CM_Container"/>
        <Parameter name="_hazards" type="CMIF_KRFCheckInHazardousArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMappedWS" id="347ae8ca-1e5a-42ec-a634-f059a587b3b8">
        <source>getMappedWS() : CM_KiwiRailCheckInWSDef;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Mar 2019	jlgsl4	TFS40360 - NXL - KiwiRail EDI message
*/

vars
	mapping : CM_ExtWebServiceEventMapping;
	matched : Boolean;
begin
	foreach mapping in self.myEventTransaction.myEventType.allExtWebServiceEventMappings do
		if mapping.myExternalWebServiceDef.isA(CM_KiwiRailCheckInWSDef) then
			matched := true;
			break;
		endif;
	endforeach;
	if matched then
		return mapping.myExternalWebServiceDef.CM_KiwiRailCheckInWSDef;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="CM_KiwiRailCheckInWSDef"/>
    </JadeMethod>
    <JadeMethod name="getSeals" id="c4e4f6ce-9671-4318-a240-d6c95ea28fa6">
        <source>getSeals(_container : CM_Container; _seals : CMIF_KRFCheckInSealArray io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message

*/

vars
	containerSeal : CM_SealTI;
	sealNumber : String;
	requestSeal : CMIF_KRFCheckInSeal;
begin
	foreach containerSeal in _container.allSeals do
		foreach sealNumber in containerSeal.allSealNums do
			create requestSeal transient;
			requestSeal.setSealNumber(sealNumber);
			_seals.add(requestSeal);
		endforeach;
	endforeach;
epilog

end;</source>
        <Parameter name="_container" type="CM_Container"/>
        <Parameter name="_seals" type="CMIF_KRFCheckInSealArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="sendWSRequest" id="67850ae0-759c-4206-84bf-b6347b8465aa">
        <source>sendWSRequest(_wsDef : CM_KiwiRailCheckInWSDef; _container : CM_Container) : CMIF_KRFCheckInResponse;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message
*/

vars
	ca : CM_KiwiRailCheckInWSAgent;
	req : CMIF_KRFCheckInRequest;
	resp : CMIF_KRFCheckInResponse;
	credentials : CMIF_KRFCredentials;
	metadata : CMIF_KRFMetadata;
	checkIn : CMIF_KRFCheckInA;
	equipment : CMIF_KRFCheckInEquipment;
	particulars : CMIF_KRFCheckInParticulars;
	refrigeratedDetails : CMIF_KRFCheckInRefrigeration;
	seals : CMIF_KRFCheckInSealArray;
	hazards : CMIF_KRFCheckInHazardousArray;
begin
	create ca transient;
	ca.setupFromWebServiceDefinition(_wsDef);
	create credentials transient;
	credentials.setFromWSDef(_wsDef);
	create metadata transient;
	metadata.setFromWSDef(_wsDef);
	metadata.setRequestResponseID(_container); // set 'unique' request &amp; response IDs
	metadata.setCredentials(credentials);
	create particulars transient;
	particulars.setWagonID(_container.wagonNumber);
	create equipment transient;
	if equipment.setFromContainer(_container) then // set reefer details if it's reefer ctr.
		create refrigeratedDetails transient;
		refrigeratedDetails.setFromContainer(_container);
	endif;
	equipment.checkInParticulars := particulars;
	equipment.refrigeration := refrigeratedDetails;
	create seals transient;
	self.getSeals(_container, seals);
	equipment.allSeals := seals;
	create hazards transient;
	self.getHazardous(_container, hazards);
	equipment.allHazardous := hazards;
	create checkIn transient;
	checkIn.setFromWSDef(_wsDef);
	checkIn.populateBookingID(_container); // get BookingID from Release Request's Release No
	checkIn.allEquipment.add(equipment);

	create req transient;
	req.metadata := metadata;
	req.checkIn := checkIn;	
	resp := ca.checkIn(req);
	self.updateActivityHistory(ca,resp);
	if app.myPassport.hasErrors then
		app.createAlert(app.myPassport.getErrorsAndWarningsAsString, true);
	endif;
	return resp;
	
epilog
	delete ca;
	delete equipment;
	delete seals;
	delete hazards;
	delete checkIn;
	delete credentials;
	delete metadata;
	delete particulars;	
	delete req;
	delete refrigeratedDetails;
end;</source>
        <Parameter name="_wsDef" type="CM_KiwiRailCheckInWSDef"/>
        <Parameter name="_container" type="CM_Container"/>
        <ReturnType type="CMIF_KRFCheckInResponse"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="9ec7d7c5-3b8f-48a7-9f13-2b14f4655137">
        <updating/>
        <source>setForCreate(_proxySelf: SelfType input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message

*/

vars

begin
	inheritMethod(_proxySelf);
	self.myTerminal := _proxySelf.myTerminal;
	self.myEventTransaction := _proxySelf.myEventTransaction;
epilog

end;</source>
        <Parameter name="_proxySelf" type="SelfType" usage="input"/>
    </JadeMethod>
