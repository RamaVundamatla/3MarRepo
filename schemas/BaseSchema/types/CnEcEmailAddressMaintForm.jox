    <JadeMethod name="deleteAddress" id="f9dde19f-53f7-4243-9407-bd60fdacd9ce">
        <updating/>
        <source>deleteAddress() updating, protected;

vars
	agentObj	: CnEcEmailAgent;
	errorMsg	: String;
	
begin
	agentObj	:=	self.aMyEmailSendForm.aMyTA;
	errorMsg	:=	agentObj.trxCnEcEmailAddressDelete(self.aMyEmailAddress);
	
	if errorMsg &lt;&gt; null then
		app.msgBox(errorMsg,"Error",MsgBox_OK_Only);
	else
		self.aMyEmailAddress := null;
		unloadForm();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="46ef5a27-cb9c-4a34-8463-6361b80db34f">
        <updating/>
        <source>doFormLoad() updating, protected;

begin
	centreWindow();
	self.setButtons();
	
	if self.aMyEmailAddress &lt;&gt; null then
		txtEmailAddress.text	:= aMyEmailAddress.emailAddress;
		txtGivenName.text		:= aMyEmailAddress.getGivenName();
		txtLastName.text		:= aMyEmailAddress.getLastName();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="c6dcbcf5-2fa1-4f60-b6c6-1731b79020e7">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	inheritMethod();
	self.doFormLoad();
end;</source>
    </JadeMethod>
    <JadeMethod name="setButtons" id="f4dc00f6-2d9f-4907-ad00-a457286840a9">
        <source>setButtons() protected;

begin
	if self.aMyEmailAddress = null then
		btnAdd.enabled		:= true;
		btnDelete.enabled	:= false;
		btnUpdate.enabled	:= false;
	else
		btnAdd.enabled		:= false;
		btnDelete.enabled	:= true;
		btnUpdate.enabled	:= true;		
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateAddress" id="9c602235-4f57-4a2f-a79b-1f0399c64d2a">
        <updating/>
        <source>updateAddress() updating, protected;

vars
	agentObj	: CnEcEmailAgent;
	baseDataObj	: CnEcEmailBaseData;
	addressName	: String;
	errorMsg	: String;
	
begin
	agentObj	:=	self.aMyEmailSendForm.aMyTA;
	baseDataObj	:=	self.aMyEmailSendForm.aMyEmailBaseData;
	addressName	:=	txtLastName.text &amp; ", " &amp; txtGivenName.text;
	
	errorMsg	:=	agentObj.trxCnEcEmailAddressUpdate(	aMyEmailAddress,	//pCnEcEmailAddressToUpdate : CnEcEmailAddress io;
														aMyEmailAddress.edition(),	//pRequiredEdition : Integer;
														txtEmailAddress.text,	//pEmailAddress:String;
														baseDataObj,	//pMyBaseData:CnEcEmailBaseData;
														addressName	//	pName:String
														);
	
	if errorMsg &lt;&gt; null then
		app.msgBox(errorMsg,"Error",MsgBox_OK_Only);
	else
		unloadForm();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
