<CollClass name="CM_WorkOrderToDoSet" id="7337e7e9-9b69-44df-8519-3e16eccf4220">
    <loadFactor>98</loadFactor>
    <memberType name="CM_WodToDo"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="planning"/>
    <JadeMethod name="includesToDo" id="20facc7c-de57-4916-9f5d-4dac174511d1">
        <source>includesToDo( _toDo : CM_ToDoTaskDesc ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2018	jlgndl1	Initial creation	TFS 39638
15 Mar 2023  	navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
*/

vars

	wodToDo : CM_WodToDo;

begin

	foreach wodToDo in self do
		//if wodToDo.myToDoTaskDesc = _toDo then				//15.3.2023 navhl20	#56614[56615]
		if wodToDo.allToDoTasksDescs.includes(_toDo) then		//15.3.2023 navhl20	#56614[56615]
			return true;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="_toDo" type="CM_ToDoTaskDesc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
