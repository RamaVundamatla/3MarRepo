    <JadeMethod name="createHistoryDetail" id="dd7c9005-7583-4f36-b383-0a0385f2e980">
        <source>createHistoryDetail(pTimestamp:TimeStamp; pText:String):CnEcReleaseHistoryDetail;
// --------------------------------------------------------------------------------
// Created:		19 August 2001 by cnwdad1
//
// Purpose:		Creates a release history detail object to describe a release event.
//
// Parameters:	pTimestamp - The timestamp of the release event.
//				pText - A description of the release event.
//
// Returns:		The new release history details object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	historyDetailObj	: CnEcReleaseHistoryDetail;
	
begin
	create historyDetailObj;
	historyDetailObj.updateMe(pTimestamp, pText, self);
	
	return historyDetailObj;
end;</source>
        <Parameter name="pTimestamp" type="TimeStamp"/>
        <Parameter name="pText" type="String"/>
        <ReturnType type="CnEcReleaseHistoryDetail"/>
    </JadeMethod>
    <JadeMethod name="createMultipleDetails" id="a718326a-9137-4373-a9fc-222bca70032e">
        <source>createMultipleDetails(pAllTransientDetails:CnEcRelHistoryDetailByTimeDict);
// --------------------------------------------------------------------------------
// Created:		19 August 2001 by cnwdad1
//
// Purpose:		Creates persists multiple transient release history detail objects
//				to describe numerous release events, and then purges the transient
//				history detail objects.
//
// Parameters:	pAllTransientDetails - A collection of transient release history
//					detail objects.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	historyDetailObj	: CnEcReleaseHistoryDetail;
	
begin
	foreach historyDetailObj in pAllTransientDetails do
		self.createHistoryDetail(historyDetailObj.itemTime, historyDetailObj.itemText);
	endforeach;
	
	pAllTransientDetails.purge();
end;</source>
        <Parameter name="pAllTransientDetails" type="CnEcRelHistoryDetailByTimeDict"/>
    </JadeMethod>
    <JadeMethod name="fullReleasePatchNumber" id="2d9ba6a4-b2ff-4432-b46d-0534047e1667">
        <methodInvocation>mapping</methodInvocation>
        <source>fullReleasePatchNumber(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     27 March 2003 by cnwrs2
//
// Purpose:     Mapping method for the corresponding virtual attribute.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if set then
		return;
	endif;
	
	_value := self.currentReleaseNumber &amp; ' ' &amp; self.currentPatchNumber;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="09045810-e4ca-48e0-bcab-601c69e93840">
        <updating/>
        <source>initializeMe() updating;
// ---------------------------------------------------------------------------
// Created:     11 July 2001 by cnwrs2
//
// Purpose:		Initializes the receiver ready for processing.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
begin
	// Set the property values...
	
	self.isCompletedOK		:= false;
	self.computerName		:= app.computerName();
	self.processAppName		:= app.name;
	self.processUser		:= process.userCode;
	
	// Next, set any dictionary keys...
	
	self.processStartTime	:= app.actualTimeServer();// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	// Finally, set any references...
	
	self.myBaseRoot			:=	app.myBaseRoot;
end;</source>
    </JadeMethod>
    <JadeMethod name="setCompleted" id="a5b34769-6291-4256-8fc6-9b965c9aebc9">
        <updating/>
        <source>setCompleted(pFinishTime:TimeStamp; pIsCompletedOK:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		18 August 2001 by cnwdad1
//
// Purpose:		Sets timestamp of completed flag.
//
// Parameters:	pFinishTime - The timestamp of when the release processing completed.
//				pIsCompletedOK - True if the release completed without errors.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.processFinishTime		:=	pFinishTime;
	self.isCompletedOK			:=	pIsCompletedOK;
end;</source>
        <Parameter name="pFinishTime" type="TimeStamp"/>
        <Parameter name="pIsCompletedOK" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setPatchNumber" id="73fd9c78-46fc-4696-9921-45ce5cf3468a">
        <updating/>
        <source>setPatchNumber(pPatchNumber : String) updating;
// ---------------------------------------------------------------------------
// Created:     27 March 2003 by cnwrs2
//
// Purpose:     Sets the value of the current patch number attribute.
//
// Parameters:  pPatChNumber - The release patch number.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.currentPatchNumber := pPatchNumber;
end;</source>
        <Parameter name="pPatchNumber" type="String"/>
    </JadeMethod>
    <JadeMethod name="setReleaseNumber" id="961ad777-b593-40fe-95cf-980fdb51dfef">
        <updating/>
        <source>setReleaseNumber(pCurrentRelease:String) updating;
// --------------------------------------------------------------------------------
// Created:		19 August 2001 by cnwdad1
//
// Purpose:		Sets the release version number.
//
// Parameters:	pCurrentRelease - The currentl release number (String).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.currentReleaseNumber	:=	pCurrentRelease;
end;</source>
        <Parameter name="pCurrentRelease" type="String"/>
    </JadeMethod>
    <JadeMethod name="setUpgrader" id="2558726a-e9e0-44dd-8fe7-3ace194f146c">
        <updating/>
        <source>setUpgrader(pUpgraderObj : CnEcReleaseUpgrader) updating;
// ---------------------------------------------------------------------------
// Created:     11 July 2001 by cnwrs2
//
// Purpose:     Sets a reference to the release upgrade object.  It is this
//				object's class on which the release processing has been
//				implemented by developers.
//
// Parameters:  pUpgraderObj - The release upgrade object.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.myUpgrader := pUpgraderObj;
end;</source>
        <Parameter name="pUpgraderObj" type="CnEcReleaseUpgrader"/>
    </JadeMethod>
</Class>
