    <JadeMethod name="getReportHeader1" id="aeb98089-bc25-4176-8fec-572fdde72518">
        <source>getReportHeader1() : String;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpStr : String;
begin
	tmpStr := app.getErrorString(SHP_Container_Hatch_Summary) &amp; ". " &amp; 
		 "Voyage: " &amp;  self.myCurrentVoyage.code &amp; " " &amp; self.myCurrentVoyage.description.trimBlanks ;
	tmpStr := tmpStr &amp;  ". Vessel: " &amp; self.myCurrentVoyage.vesselCode.trimBlanks &amp; " " &amp; self.myCurrentVoyage.vesselName.trimBlanks  ;

	return tmpStr;

	tmpStr := tmpStr &amp;  "Arrival Time: " ;

	//now get the voyage
	if self.myCurrentVoyage.arrivedDT = null then
		tmpStr := tmpStr &amp;  "Not yet arrived" &amp; Cr;
	else
		tmpStr := tmpStr &amp; self.systemToLocalTime(self.myCurrentVoyage.arrivedDT).String &amp; Cr;	// 9/5/16 cnwmp6 TFS 488 - Multi timezone support
	endif;
	tmpStr := tmpStr &amp;  "Departure Time: " ;

	if self.myCurrentVoyage.departedDT = null then
		tmpStr := tmpStr &amp;  "Not yet arrived" &amp; Cr;
	else
		tmpStr := tmpStr &amp; self.systemToLocalTime(self.myCurrentVoyage.departedDT).String &amp; Cr;	// 9/5/16 cnwmp6 TFS 488 - Multi timezone support
	endif;
	tmpStr := tmpStr &amp;  "Remarks: " &amp; self.myCurrentVoyage.remarks &amp; Cr;

	tmpStr := tmpStr &amp;  "Status: ";
	if self.optPlanned.value then
		tmpStr := tmpStr &amp; "Planned Summary";
	else
		tmpStr := tmpStr &amp; "Actuals Summary";
	endif;
	tmpStr := tmpStr &amp;  "Discrepancies: " &amp; self.discrepancies;

	return tmpStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReportHeader2" id="d3a6de63-e857-433c-bfc5-4587f977055c">
        <source>getReportHeader2() : String;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpStr : String;
begin


	tmpStr := "Arrival Time: " ;

	//now get the voyage
	if self.myCurrentVoyage.arrivedDT = null then
		tmpStr := tmpStr &amp;  "Not yet arrived" ;
	else
		tmpStr := tmpStr &amp; self.systemToLocalTime(self.myCurrentVoyage.arrivedDT).String ;	// 9/5/16 cnwmp6 TFS 488 - Multi timezone support
	endif;
	tmpStr := tmpStr &amp;  ". Departure Time: " ;

	if self.myCurrentVoyage.departedDT = null then
		tmpStr := tmpStr &amp;  "Not yet arrived" ;
	else
		tmpStr := tmpStr &amp; self.systemToLocalTime(self.myCurrentVoyage.departedDT).String ;	// 9/5/16 cnwmp6 TFS 488 - Multi timezone support
	endif;

	tmpStr := tmpStr &amp;  ". Status: ";
	if self.optPlanned.value then
		tmpStr := tmpStr &amp; "Planned Summary";
	else
		tmpStr := tmpStr &amp; "Actuals Summary";
	endif;

	return tmpStr;

	tmpStr := tmpStr &amp;  "Remarks: " &amp; self.myCurrentVoyage.remarks &amp; Cr;
	tmpStr := tmpStr &amp;  "Discrepancies: " &amp; self.discrepancies;

	return tmpStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleGetDataCancel" id="c990e4ce-719d-4845-9e64-d18aacb9bdac">
        <updating/>
        <source>handleGetDataCancel(ex : CM_ProgressException) : Integer updating;

vars

begin
	if app.msgBox(app.getErrorString(WARN_CANCEL_PROGRESS),
										"Cancel Progress",
										MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
		self.tblData.rows := 55;
		self.tblData.columns := 4;
		self.tblData.columnWidth[1] := 140;
		self.tblData.columnWidth[2] := 20;
		self.tblData.rowHeight[1] := self.tblData.rowHeight[2] * 3;
		self.loadNone(self.tblData, 3);
		self.loadServiceStrings();
		optPlanned.value := true;

		return Ex_Abort_Action;
	else
		return Ex_Continue;
	endif;

end;</source>
        <Parameter name="ex" type="CM_ProgressException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleNormalException" id="b04bd5f7-26b3-4ee4-a4f3-2482ade08146">
        <updating/>
        <source>handleNormalException(ex : NormalException) : Integer updating;

vars
begin

	if ex.errorCode = ERR_TI_NOLGD then
		errorString := errorString &amp; app.getErrorString(ERR_TI_NOLGD) &amp; CrLf;
		return Ex_Resume_Next;
	elseif ex.errorCode = ERR_SHIPPINGLINE_INVALID then
		app.msgBox(app.getErrorString(ERR_SHIPPINGLINE_INVALID),
										"Shipping Line Problem",
										MsgBox_OK_Only + MsgBox_Stop_Icon);
		cmbVoyage.listIndex := -1;
		return Ex_Abort_Action;
	endif;

	return Ex_Pass_Back;



end;</source>
        <Parameter name="ex" type="NormalException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleNotification" id="7db7e4d2-8a75-4a6b-8c5d-2eb4df3f588e">
        <updating/>
        <source>handleNotification(_eventType: Integer; _theObject: Object; _eventTag: Integer; _userInfo: Any) updating;
//----------------------------------------------------------------
//	Created:	11 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	snap		: CM_TISnapShot;
	summaryTLG	: CMIF_CandHTradeLineGeo;
	colIdx		: Integer;
	colTot		: Integer;
	allTLGs		: CMIF_CandHTradeLineGeoByCodeDt;
begin

if self.myCandHReport &lt;&gt; null and
   self.myCandHReport.usePRE_CCMS1468 then
app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' handling old way');
	self.handleNotificationOLD(_eventType, _theObject, _eventTag, _userInfo);
	return;
endif;

app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' got event');

	if _eventType = Event_HatchSummary_Update 
	and _userInfo.isKindOf(CM_TISnapShot) then
		//redo the column and also row total	
		snap := _userInfo.CM_TISnapShot;
app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' handling event for ' &amp; snap.asStringJMT);
		
		create allTLGs transient;
		self.myCandHReport.updateForSnapShot(snap, allTLGs);
		
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' did upd &gt;&gt; ' &amp; allTLGs.size.asStringJMT);
		
		foreach summaryTLG in allTLGs do
			if self.tblData.findObjectInColumn(summaryTLG, colIdx) then
				//app.writeStatement(class.name &amp; " " &amp; method.name &amp; " " &amp; "found col");
				self.showColumnDataForTLG(summaryTLG, colIdx, colTot);
				//do totals
				self.calcTotals();
			endif;
		endforeach;
		
	endif;

epilog
	delete allTLGs;
end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="handleNotificationOLD" id="28cfb7fc-2689-4f5b-a05f-317e22cc82d4">
        <updating/>
        <source>handleNotificationOLD(_eventType: Integer; _theObject: Object; _eventTag: Integer; _userInfo: Any) updating;
//----------------------------------------------------------------
//	Created:	11 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// PRE CCMS-1468 verrsion - retained for testing

vars
	snap		: CM_TISnapShot;
	lgd			: CM_LineGroupDebtor;
	summaryTLG	: CMIF_CandHTradeLineGeo;
	colIdx		: Integer;
	colTot		: Integer;
	allTLGs		: CMIF_CandHTradeLineGeoByCodeDt;
begin

	if _eventType = Event_HatchSummary_Update 
	and _userInfo.isKindOf(CM_TISnapShot) then
		//redo the column and also row total	
		snap := _userInfo.CM_TISnapShot;
		
		create allTLGs transient;
		self.myCandHReport.updateForSnapShot(snap, allTLGs);
		foreach summaryTLG in allTLGs do
			lgd := summaryTLG.myLineGroupDebtor;
			if self.tblData.findObjectInColumn(lgd, colIdx) then
				//app.writeStatement(class.name &amp; " " &amp; method.name &amp; " " &amp; "found col");
				self.showColumnDataForLGD(lgd, colIdx, colTot);
				//do totals
				self.calcTotals();
			endif;
		endforeach;
		
	else
//	app.writeStatement(class.name &amp; " " &amp; method.name &amp; " " &amp; "2");
	endif;

epilog
	delete allTLGs;
end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="initQueryFrame" id="a1d9314b-9c42-46a9-8627-dbb5f5309b6d">
