    <JadeMethod name="showLocationForCurrentObject" id="47758e2d-2967-4de8-b4e1-fadb5115b7c9">
        <updating/>
        <source>showLocationForCurrentObject() updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 November 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	ti				: CM_TrackedItem;
	lc				: CM_LocationsController;
begin
