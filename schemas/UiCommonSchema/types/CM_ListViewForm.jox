    <JadeMethod name="doBaseFormCancel" id="cbf302fe-8b77-44dd-b103-9dc44578a02c">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
//--------------------------------------------------
// Created:	10 September 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	
	if self.mode = self.Mode_View then
		self.unloadForm();
		return;
	endif;
	app.mousePointer := MousePointer_HourGlass;
	self.zDoCancel();

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
