    <JadeMethod name="getCargoMap" id="35395839-dfc7-422e-a907-26aa56a5814d">
        <source>getCargoMap(_name : String) : CMIF_TMCTranGroup;
// 23659
vars
	member1,
	member2	: CMIF_TranMapController;
	type 	: CMIF_TMCType;
	group	: CMIF_TMCTranGroup;
begin

	foreach member1 in self.allGroupMembers do
		type := member1.CMIF_TMCType;
		if type.type = CMIF_TMCType.TYPE_TRACKEDITEM then
			foreach member2 in type.allGroupMembers do
				group := member2.CMIF_TMCTranGroup;
				if group.extractName = _name then
					return group;
				endif;
			endforeach;
		endif;
	endforeach;
	
	return null;
end;
</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="CMIF_TMCTranGroup"/>
    </JadeMethod>
    <JadeMethod name="getCargoMapNames" id="8fd509f4-afec-446f-987c-8294909e574a">
        <source>getCargoMapNames(_names : StringArray input);
// 23659
vars
	member1,
	member2	: CMIF_TranMapController;
	type : CMIF_TMCType;
begin
	_names.clear();
	foreach member1 in self.allGroupMembers do
		type := member1.CMIF_TMCType;
		if type.type = CMIF_TMCType.TYPE_TRACKEDITEM then
			foreach member2 in type.allGroupMembers do
				_names.add(member2.extractName);
			endforeach;
		endif;
	endforeach;
end;
</source>
        <Parameter name="_names" type="StringArray" usage="input"/>
    </JadeMethod>
