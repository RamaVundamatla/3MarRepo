    <JadeMethod name="getTotalWeight" id="809a6267-e401-4da2-a2ca-f6f353b88c74">
        <source>getTotalWeight() : Real;
// ---------------------------------------------------------------------------
// Created:     15 August 2002 by cnwth2
//
// Purpose:     Even if there are no references to this method, DO NOT DELETE IT! It is
//				used in reports
// Parameters:  None
//
// Returns:     Nothing
