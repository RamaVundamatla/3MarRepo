    </JadeMethod>
    <JadeMethod name="moveTypeString" id="2b40de68-c49e-4a23-95aa-3a5d9ab6475c">
        <methodInvocation>mapping</methodInvocation>
        <source>moveTypeString(set: Boolean; _value: String io) mapping;
/*
Purpose:			
Date		Who		Reason
20 June 2011	cnwab1	Initial creation
*/

vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.moveType = DISCHARGE_MOVETYPE then
		_value := "Discharge";
	elseif self.moveType = LOAD_MOVETYPE then
		_value := "Load";
	elseif self.moveType = DLR_MOVETYPE then
		_value := "DLR";
	elseif self.moveType = SOB_MOVETYPE then
		_value := "SOB";
	elseif self.moveType = NULL_MOVETYPE then
		_value := "Null";
	else
		_value := "Unknown";
	endif;


epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="removeWLE" id="d1c29ade-1cc7-42d3-9f16-129d1a3ce3c0">
        <updating/>
        <source>removeWLE(_wle : CM_VoyageWLE io; _ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		removes a WLE from the request. IF you do not know the WLE then pass in the TI instead
// ---------------------------------------------------------------------------

vars
	jobType: Integer;
	associatedRequest: CM_SlotRequest;
	tmpLC: CM_LocationsController;
	aWLE, removeWLE : CM_WorkListEntry;
begin

	if _wle &lt;&gt; null then
		if self.allWorkListEntries.includes(_wle) then
			_wle.erase(NORMAL_ERASE);
		endif;
	else
		if _ti = null then
			app.setContinueCMExceptions(false);
			app.raiseCMException1(ERR_NO_WLE_TI, self.myJob.jobId, null, null);
			return;
		endif;
		removeWLE := null;
		foreach aWLE in self.allWorkListEntries do
			if aWLE.myTrackedItem = _ti then
				removeWLE := aWLE;
				break;
				
			endif;
		endforeach;
		if removeWLE &lt;&gt; null then
			removeWLE.erase(NORMAL_ERASE);
		endif;
	endif;
end;</source>
        <Parameter name="_wle" type="CM_VoyageWLE" usage="io"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
