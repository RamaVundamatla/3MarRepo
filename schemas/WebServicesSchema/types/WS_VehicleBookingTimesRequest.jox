12 Aug 2022 navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
*/

vars

	cm_driver : CM_DriverDetails;

begin

	//cm_driver := self.driverFilter.asOid.CM_DriverDetails;		//12.08.2022 navtnr20 52451
