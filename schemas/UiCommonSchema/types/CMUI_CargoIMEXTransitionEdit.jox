    <JadeMethod name="applyFormChanges" id="cd73e23f-ca50-48f6-a4f5-639cb161f3d6">
        <updating/>
        <source>applyFormChanges() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 March 2018	jlgsl4	TFS 37410 Import MTs IMEX transition status
*/

vars
	oldTransition : CM_IMEXTransitionCriteria;
	newDescription, description, newName, name : String;
	newTransitionIMEXcode, transitionIMEXcode : Integer;
begin
	newDescription := self.txtDescr.text;
	description := self.transDescription;
	if newDescription &lt;&gt; null then // description isn't blank...
		if newDescription &lt;&gt; description then
			description := newDescription;
		endif;
	endif;
	name := self.transName;
	newName := txtName.text;
	if newName &lt;&gt; null then // name isn't blank...
		if newName &lt;&gt; name then
			name := newName;
		endif;
	endif;
	transitionIMEXcode := self.transIMEXstatus;
	newTransitionIMEXcode := self.cmbIMEX.listObject.CM_IMEXStatus.code;
	if newTransitionIMEXcode &lt;&gt; null then
		if newTransitionIMEXcode &lt;&gt; transitionIMEXcode then
			transitionIMEXcode := newTransitionIMEXcode;
		endif;
	endif;
	self.myProxyObject.CM_IMEXTransitionCriteria.setBaseData(description, name, self.myTerminal,
		transitionIMEXcode);
epilog

end;</source>
    </JadeMethod>
