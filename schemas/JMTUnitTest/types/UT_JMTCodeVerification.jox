    <JadeMethod name="tCheckIsRTAppBackGroundUnset" id="ab9a3353-0db8-43a7-adfe-a891101a98ca">
        <source>tCheckIsRTAppBackGroundUnset();

/*

Purpose:		Check that setting of app.isRTApp and app.isBackGroundApp are unset

Date			Who		Reason
16/10/2013		cnwmh5	Initial creation
23/10/2014		cnwmh5	Rewritten.  Considerably faster now.

*/
vars

	klass					: Class;
	prop					: Property;
	meth					: Method;
	
	failingMethods			: HugeStringArray;
	methodSet				: MethodSet;
	
	methodSource			: String;
	posItemSetTo			: Integer;
	line					: String;
	itemSetTo				: Boolean;
	posEqual				: Integer;
	

begin

	klass := rootSchema.getSchema(PortSchema.name).getClass(PortSchema.name);
	self.assertNotNull(klass);
	
	create methodSet transient;
	create failingMethods transient;
	
	// get methods calling isRTApp
	prop := klass.getProperty('isRTApp');
	self.assertNotNull(prop);
	prop.getMethodRefs(methodSet);
	app.writeLog("Checking isRTApp.  Please wait...", LogINFO);
	
	foreach meth in methodSet do
		if meth.getSchema().name &lt;&gt; "JMTUnitTest" then
			continue;
		endif;
		itemSetTo := false;
		methodSource := self.removeCommentsFromSource(meth.getSource());
		posItemSetTo := 1;
		while posItemSetTo &gt; 0 do
			posItemSetTo := methodSource.pos("isRTApp", posItemSetTo);
			if posItemSetTo = 0 then
				continue;
			endif;
			line := methodSource.scanUntil(";", posItemSetTo);
			posEqual := 1;
			posEqual := line.pos("=", posEqual);
			line := line[posEqual+1:end];
			itemSetTo := line.Boolean;
		endwhile;
		if itemSetTo then
			failingMethods.add(meth.getSchemaType().name &amp; '::' &amp; meth.name &amp; Tab &amp; 'isRTApp: ' &amp; itemSetTo.String);
		endif;
		
	endforeach;
	
	// get methods calling isBackGroundApp
	methodSet.clear();
	prop := klass.getProperty('isBackGroundApp');
	self.assertNotNull(prop);
	prop.getMethodRefs(methodSet);
	app.writeLog("Checking isBackGroundApp.  Please wait...", LogINFO);

	foreach meth in methodSet do
		if meth.getSchema().name &lt;&gt; "JMTUnitTest" then
			continue;
		endif;
		itemSetTo := false;
		methodSource := self.removeCommentsFromSource(meth.getSource());
		posItemSetTo := 1;
		while posItemSetTo &gt; 0 do
			posItemSetTo := methodSource.pos("isBackGroundApp", posItemSetTo);
			if posItemSetTo = 0 then
				continue;
			endif;
			line := methodSource.scanUntil(";", posItemSetTo);
			posEqual := 1;
			posEqual := line.pos("=", posEqual);
			line := line[posEqual+1:end];
			itemSetTo := line.Boolean;
		endwhile;
		if itemSetTo then
			failingMethods.add(meth.getSchemaType().name &amp; '::' &amp; meth.name &amp; Tab &amp; 'isBackGroundApp: ' &amp; itemSetTo.String);
		endif;
		
	endforeach;
	
	// get methods calling setIsBackGroundApp
	methodSet.clear();
	meth := klass.getMethodInHTree("setIsBackGroundApp");
	self.assertNotNull(meth);
	meth.getMethodRefs(methodSet);
	app.writeLog("Checking setIsBackGroundApp.  Please wait...", LogINFO);
	
	foreach meth in methodSet do
		if meth.getSchema().name &lt;&gt; "JMTUnitTest" then
			continue;
		endif;
		itemSetTo := false;
		methodSource := self.removeCommentsFromSource(meth.getSource());
		posItemSetTo := 1;
		while posItemSetTo &gt; 0 do
			posItemSetTo := methodSource.pos("setIsBackGroundApp(", posItemSetTo);
			if posItemSetTo = 0 then
				continue;
			endif;
			line := methodSource.scanUntil(")", posItemSetTo);
			itemSetTo := line.Boolean;
		endwhile;
		if itemSetTo then
			failingMethods.add(meth.getSchemaType().name &amp; '::' &amp; meth.name &amp; Tab &amp; 'setIsBackGroundApp: ' &amp; itemSetTo.String);
		endif;
		
	endforeach;
	
	// if have failing test then want to know about it
	if failingMethods.size &gt; 0 then
		foreach line in failingMethods do
			app.writeLog(line, LogINFO);
		endforeach;
		self.assertEqual(failingMethods.size, 0);
	endif;	
	
epilog

	delete methodSet;
	delete failingMethods;

end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Fails&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
