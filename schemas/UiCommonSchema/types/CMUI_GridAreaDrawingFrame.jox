    <JadeMethod name="clearDeskTopRectangle" id="2e441e95-8575-4852-8960-6ef088aa61d4">
        <updating/>
        <source>clearDeskTopRectangle(frame: Frame input) updating;
// ---------------------------------------------------------------------------
// Created:     21 April 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	WIDTH	= 1;
vars
	theHeight, theWidth : Integer;
begin

	if (not self.amDrawingDeskTopRectangle) then
		return;
	endif;
	frame.drawDeskTopRectangle(0, self.firstMouseX, self.firstMouseY,
											self.lastMouseX, self.lastMouseY, Black, WIDTH);
		
	self.amDrawingDeskTopRectangle := false;
	
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
