    <JadeMethod name="getProxyTask" id="e2dda630-ebda-496b-8dbb-71f3d0df9053">
        <source>getProxyTask(_realTask : CM_WorkOrderDtl) : CM_WorkOrderDtl;

/*

Purpose:		Return the equivelent proxy task for the passed in real task
				Note: self should be a proxy work order.

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2009	cnwmd1	Initial creation

*/

vars
	proxyTask : CM_WorkOrderDtl;
begin
	if _realTask = null then
		return null;
	endif;
	foreach proxyTask in self.allWoDtls do
		if proxyTask.taskID = _realTask.taskID then
			return proxyTask;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_realTask" type="CM_WorkOrderDtl"/>
        <ReturnType type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="getReleaseRequestIDStr" id="d2294ff6-fef8-41ad-bc34-bfc131041804">
        <source>getReleaseRequestIDStr() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	returnStr,
	str		: String;
	woDtl 	: CM_WorkOrderDtl;
	
begin
	
	foreach woDtl in self.allWoDtls discreteLock do
		str := woDtl.getReleaseRequestID();
		
		if str = null then
			continue;
		endif;
		
		/*
		if returnStr = null then
			returnStr := str;
		else
			if returnStr.pos(str, 1) &gt; null then
				continue;
			else
				returnStr &amp;= Comma &amp; str;
			endif;
		endif;
		*/
		
		returnStr.addStringToList(str, Comma); //04/04/2025	navkc1 JIRA Story MTN-33940
	endforeach;
	
	return returnStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
