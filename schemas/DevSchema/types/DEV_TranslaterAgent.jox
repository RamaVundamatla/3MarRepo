<Class name="DEV_TranslaterAgent" id="85c49057-8e9d-4353-bd45-025eb52e70db">
    <superclass name="Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <JadeMethod name="translateFile" id="b45cd523-fcb8-4d05-b682-4d5abb2805ce">
        <source>translateFile();

vars
	inFile,
	outFile		: File;
	inLine,
	outLine,
	heading,
	xHeading,
	short,
	xShort		: String;
	sa			: HugeStringArray;
	
	_inFileName,
	_outFileName	: String;
begin


// NOTE - this does not appear to work in S2.  Probably due to firewall settings
// works ok if run locally (test as a FAT client)

	_inFileName := 'c:\tmp\EntTableHeadings.csv';
	_outFileName := 'c:\tmp\EntTableHeadingsOUT.csv';

	create inFile transient;
	create outFile transient;
	create sa transient;
	inFile.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
	inFile.fileName := _inFileName;
	inFile.mode := File.Mode_Input;
	inFile.allowCreate := false;
	if (not inFile.isAvailable) then
		app.msgBox('File (' &amp; _inFileName &amp; ') not found', 'Error', MsgBox_OK_Only);
		return;
	endif;

	outFile.fileName := _outFileName;
	outFile.mode := File.Mode_Output;
	outFile.allowCreate := true;
	if (outFile.isAvailable) then
		if app.msgBox('File (' &amp; _outFileName &amp; ') already exists.  Overwrite?', 'Error', MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;
		outFile.purge();
	endif;
	
	while true do
		inLine := inFile.readLine();
		if inFile.endOfFile then
			break;
		endif;
		inLine.parseCSV(sa);
		if sa.size &lt;&gt; 4 then
			app.writeStatement( 'Error with line &gt;&gt; ' &amp; inLine);
			continue;
		endif;
		heading := sa[1];
		short	:= sa[3];
		if heading &lt;&gt; null then
			xHeading := self.translateWord(heading);
		else
			xHeading := null;
		endif;
		if short &lt;&gt; null then
			xShort := self.translateWord(short);
		else
			xShort := null;
		endif;
		outFile.writeLine(heading.asDoubleQuotedString &amp; ',' &amp;
						  xHeading.asDoubleQuotedString &amp; ',' &amp;
						  short.asDoubleQuotedString &amp; ',' &amp;
						  xShort.asDoubleQuotedString);
	endwhile;
	
epilog
	if inFile &lt;&gt; null then
		inFile.close;
	endif;
	if outFile &lt;&gt; null then
		outFile.close;
	endif;
	delete inFile;
	delete outFile;
	delete sa;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateWord" id="a436f52f-1727-4a86-b863-198299264012">
        <source>translateWord(_wordToTranslate : String) : String;
// ---------------------------------------------------------------------------
// Created:     13 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	cn : DEV_Http;
	dll	:String;
	headers,
	parms : String;
	binData : Binary;
	xmlStr,
	rtnStr,
	server : String;
	ts		: TimeStamp;
	xmlDoc	: JadeXMLDocument;
	xmlElem	: JadeXMLElement;

begin

// http://www.webservicex.net/TranslateService.asmx/Translate?LanguageMode=EnglishTOSpanish&amp;Text=bird

	server := 'www.webservicex.net';
	dll	:= '/TranslateService.asmx/Translate';

	create cn transient;
	cn.setServerName(server);
	cn.setSecure(false);	
	cn.cnConnect;        // connect to sever

	parms := 'LanguageMode=EnglishTOSpanish&amp;Text=' &amp; _wordToTranslate;

	headers :=	"Content-Type:application/x-www-form-urlencoded" &amp; CrLf &amp;
				"Content-Length:" &amp; parms.length.String &amp; CrLf;

	binData := parms.asANSI(0);// 9/3/16  cnwns1 PAR 36286 unicode version

	xmlStr := cn.ebpPostConnect(dll, binData, headers);  // send data and get reply
	
	create xmlDoc transient;
	xmlDoc.parseString(xmlStr);
	xmlElem := xmlDoc.getElementByTagName('string');
	if xmlElem &lt;&gt; null then
		 rtnStr := xmlElem.textData;
	endif;

	cn.ebpCloseConnect;
	
	return rtnStr;

epilog
	delete xmlDoc;
	delete cn;
end;</source>
        <Parameter name="_wordToTranslate" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
