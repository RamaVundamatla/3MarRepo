    <JadeMethod name="sendTruckDepartureCargoToEDBIC" id="18f4f944-ab7d-45fa-9603-5efc228df83b">
        <updating/>
        <source>sendTruckDepartureCargoToEDBIC(_cargo : CM_TrackedItem) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 June 2024	jlier1	Initial creation 63898

*/

vars
	extWebService			: CM_ExternalWebServiceDef;		
	activeCuxPortInterface	: CM_CuxportServiceDef;
	cargoOnly				: CMIF_JsonCargoOnlyCUX;
	cargo					: CMIF_JsonCargoCUX;
	jsonPostData			: String;
	methodType,
	endpointPath			: String;
begin
	extWebService := app.myRoot.getFirstActiveEWSForEndpoint( ETRow_TruckDepartureEDBIC );	
	if extWebService &lt;&gt; null and extWebService.isEDBIC then									
		activeCuxPortInterface := extWebService.CM_CuxportServiceDef;						
	endif;																					
	
	if activeCuxPortInterface = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No Truck Departure Cuxport Interface defined", LogERROR);
		app.doRaiseAlert(method.qualifiedName &amp; Tab &amp; "No Truck Departure Cuxport Interface defined");
		return false;
	endif;
	if _cargo = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No cargo  - no message sent", LogDEBUG); 
		return true;
	endif;
	
	create cargoOnly transient;
	create cargo transient;
	cargo.setFromTI(_cargo, false);
	cargoOnly.cargo.add(cargo);
	
	cargoOnly.deserializeJSON(jsonPostData);
	app.writeLog(method.qualifiedName &amp; Tab &amp; "jsonPostData is " &amp; jsonPostData, LogDEBUG);
	

	activeCuxPortInterface.getEndpointMethodAndValue(ETRow_TruckDepartureEDBIC, methodType, endpointPath);
	if methodType = null or endpointPath = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; activeCuxPortInterface.name &amp; " is not set up correctly for " &amp; activeCuxPortInterface.name &amp; Space &amp; ETRow_TruckDepartureEDBIC &amp; " messages", LogERROR);
		app.doRaiseAlert(activeCuxPortInterface.name &amp; " is not set up correctly for " &amp; activeCuxPortInterface.name &amp; Space &amp; ETRow_TruckDepartureEDBIC &amp; " messages");
		return true;
	endif;

	self.sendToEDBIC(method.qualifiedName, activeCuxPortInterface.baseEndpoint &amp; "/" &amp; endpointPath, methodType, jsonPostData, _cargo.myTerminal, activeCuxPortInterface);
	return true;
	
epilog
	delete cargoOnly;
end;</source>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendTruckDepartureToEDBIC" id="16ef23c5-6246-434f-984c-775e1d316459">
        <updating/>
        <source>sendTruckDepartureToEDBIC(_activeCuxPortInterface : CM_CuxportServiceDef; _vehicleVisit : CM_VehicleVisitRecord; _terminal : CM_Terminal) : Boolean updating;
//
// Purpose:			User Story 57370.130 Send Import Cargo Details to EDBIC for Cargo Released at the Gate House
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/04/2023	navdap1		Initial creation TFS 57362 CUX - Changes to Outgoing Message Formats
// 17/04/2023	navdap1		TFS 57207 EUP - Refactor Inspection App API Message
// 20/06/2023	navdap1		TFS 58722 EUP "Class of object is invalid in this context" error when gating in cargo
// 14/05/2025	jlizm1		MTN 34849 EDBIC truck departure shouldn't care about imex status
//
vars
	extWebService			: CM_ExternalWebServiceDef;		// TFS 58722
	activeCuxPortInterface	: CM_CuxportServiceDef;
	ti						: CM_TrackedItem;
	
	cargoOnly				: CMIF_JsonCargoOnlyCUX;
	cargo					: CMIF_JsonCargoCUX;
	jsonPostData			: String;
	methodType,
	endpointPath			: String;
	
begin
	extWebService := app.myRoot.getFirstActiveEWSForEndpoint( ETRow_TruckDepartureEDBIC );	// TFS 58722
	if extWebService &lt;&gt; null and extWebService.isEDBIC then									// TFS 58722
		activeCuxPortInterface := extWebService.CM_CuxportServiceDef;						// TFS 58722
	endif;																					// TFS 58722
	
	if activeCuxPortInterface = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No Truck Departure Cuxport Interface defined", LogERROR);
		app.doRaiseAlert(method.qualifiedName &amp; Tab &amp; "No Truck Departure Cuxport Interface defined");
		return false;
	endif;
	
	create cargoOnly transient;
	foreach ti in _vehicleVisit.allReleasedTrackedItems do
		create cargo transient;
		cargo.setFromTI(ti, false);
		cargoOnly.cargo.add(cargo);
	endforeach;
	// any data to send? 
	if cargoOnly.cargo.isEmpty then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No Import cargo for visit " &amp; _vehicleVisit.visitNumber &amp; " - no message sent", LogDEBUG); 
		return true;
	endif;
	
	cargoOnly.deserializeJSON(jsonPostData);
	app.writeLog(method.qualifiedName &amp; Tab &amp; "jsonPostData is " &amp; jsonPostData, LogDEBUG);
	
	// TFS 57207 start
	activeCuxPortInterface.getEndpointMethodAndValue(ETRow_TruckDepartureEDBIC, methodType, endpointPath);
	if methodType = null or endpointPath = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; activeCuxPortInterface.name &amp; " is not set up correctly for " &amp; activeCuxPortInterface.name &amp; Space &amp; ETRow_TruckDepartureEDBIC &amp; " messages", LogERROR);
		app.doRaiseAlert(activeCuxPortInterface.name &amp; " is not set up correctly for " &amp; activeCuxPortInterface.name &amp; Space &amp; ETRow_TruckDepartureEDBIC &amp; " messages");
		return true;
	endif;
	// TFS 57207 end
	self.sendToEDBIC(method.qualifiedName, activeCuxPortInterface.baseEndpoint &amp; "/" &amp; endpointPath, methodType, jsonPostData, _terminal, activeCuxPortInterface);
	return true;
	
epilog
	delete cargoOnly;
end;</source>
        <Parameter name="_activeCuxPortInterface" type="CM_CuxportServiceDef"/>
        <Parameter name="_vehicleVisit" type="CM_VehicleVisitRecord"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendVoyageArrivalToEDBIC" id="215c0534-f0f5-4460-b6c1-74c6b71686e9">
        <updating/>
        <source>sendVoyageArrivalToEDBIC(_activeCuxPortInterface : CM_CuxportServiceDef; _voyage : CM_Voyage; _terminal : CM_Terminal) : Boolean updating;
//
// Purpose:			User Story 57370.120 Send Vessel Arrival Message to EDBIC
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/04/2023	navdap1		Initial creation TFS 57362 CUX - Changes to Outgoing Message Formats
// 17/04/2023	navdap1		TFS 57207 EUP - Refactor Inspection App API Message
// 20/06/2023	navdap1		TFS 58722 EUP "Class of object is invalid in this context" error when gating in cargo
//
vars
	extWebService			: CM_ExternalWebServiceDef;		// TFS 58722
	activeCuxPortInterface	: CM_CuxportServiceDef;
	ti						: CM_TrackedItem;
	thisPort				: String;
	voyage					: CMIF_JsonVoyageCUX;
	cargo					: CMIF_JsonCargoCUX;
	jsonPostData			: String;
	methodType,
	endpointPath			: String;
	
begin
	extWebService := app.myRoot.getFirstActiveEWSForEndpoint( ETRow_VoyageArrivalEDBIC );	// TFS 58722
	if extWebService &lt;&gt; null and extWebService.isEDBIC then									// TFS 58722
		activeCuxPortInterface := extWebService.CM_CuxportServiceDef;						// TFS 58722
	endif;																					// TFS 58722
	
	if activeCuxPortInterface = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No Voyage Arrival Cuxport Interface defined", LogERROR);
		app.doRaiseAlert(method.qualifiedName &amp; Tab &amp; "No Voyage Arrival Cuxport Interface defined");
		return false;
	endif;
	
	thisPort := _terminal.getConfig(PortDestCode).String;
	
	create voyage transient;
	voyage.voyageCode := _voyage.code;
	voyage.voyageExternalCode := _voyage.voyageCodeExternal;
	voyage.voyageInwardCode := _voyage.inwardCode;
	voyage.voyageOperator := _voyage.operatorCode;
	voyage.lloydsNumber := _voyage.lloydsNumber;
	voyage.vesselCode := _voyage.vesselCode;
	voyage.vesselName := _voyage.vesselName;
	if _voyage.arrivedDT.isValid then
		voyage.voyageArrivalDT := _voyage.arrivedDT;
	elseif _voyage.estimatedArrivalDT.isValid then
		voyage.voyageArrivalDT := _voyage.estimatedArrivalDT;
	endif;
	if _voyage.departedDT.isValid then
		voyage.voyageDepartureDT := _voyage.departedDT;
	elseif _voyage.departTargetDT.isValid then
		voyage.voyageDepartureDT := _voyage.departTargetDT;
	elseif _voyage.estimatedDepartureDT.isValid then
		voyage.voyageDepartureDT := _voyage.estimatedDepartureDT;
	endif;
	
	// we want all Import cargo to be discharged "here"
	foreach ti in _voyage.allOnshipTIsByIdCargoType where ti.isImport and ti.dischargePort = thisPort do
		create cargo transient;
		cargo.setFromTI(ti, true);
		voyage.cargo.add(cargo);
	endforeach;
	
	voyage.deserializeJSON(jsonPostData);
	app.writeLog(method.qualifiedName &amp; Tab &amp; "jsonPostData is " &amp; jsonPostData, LogDEBUG);
	
	// TFS 57207 start
	activeCuxPortInterface.getEndpointMethodAndValue(ETRow_VoyageArrivalEDBIC, methodType, endpointPath);
	if methodType = null or endpointPath = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; activeCuxPortInterface.name &amp; " is not set up correctly for " &amp; activeCuxPortInterface.name &amp; Space &amp; ETRow_VoyageArrivalEDBIC &amp; " messages", LogERROR);
		app.doRaiseAlert(activeCuxPortInterface.name &amp; " is not set up correctly for " &amp; activeCuxPortInterface.name &amp; Space &amp; ETRow_VoyageArrivalEDBIC &amp; " messages");
		return true;
	endif;
	// TFS 57207 end
	self.sendToEDBIC(method.qualifiedName, activeCuxPortInterface.baseEndpoint &amp; "/" &amp; endpointPath, methodType, jsonPostData, _terminal, activeCuxPortInterface);
	return true;
	
epilog
	delete voyage;
end;</source>
        <Parameter name="_activeCuxPortInterface" type="CM_CuxportServiceDef"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendVoyageDepartureToEDBIC" id="dd018c4d-00af-4815-94b7-1b11c8cb343e">
        <updating/>
        <source>sendVoyageDepartureToEDBIC(_activeCuxPortInterface : CM_CuxportServiceDef; _voyage : CM_Voyage; _terminal : CM_Terminal) : Boolean updating;
//
// Purpose:			User Story 57370.060 Send Vessel Departed Message to EDBIC
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/04/2023	navdap1		Initial creation TFS 57362 CUX - Changes to Outgoing Message Formats
// 17/04/2023	navdap1		TFS 57207 EUP - Refactor Inspection App API Message
// 20/06/2023	navdap1		TFS 58722 EUP "Class of object is invalid in this context" error when gating in cargo
//
vars
	extWebService			: CM_ExternalWebServiceDef;		// TFS 58722
	activeCuxPortInterface	: CM_CuxportServiceDef;
	ti						: CM_TrackedItem;
	thisPort				: String;
	voyage					: CMIF_JsonVoyageCUX;
	cargo					: CMIF_JsonCargoCUX;
	jsonPostData			: String;
	methodType,
	endpointPath			: String;
	
begin
	extWebService := app.myRoot.getFirstActiveEWSForEndpoint( ETRow_VoyageDepartureEDBIC );		// TFS 58722
	if extWebService &lt;&gt; null and extWebService.isEDBIC then										// TFS 58722
		activeCuxPortInterface := extWebService.CM_CuxportServiceDef;							// TFS 58722
	endif;																						// TFS 58722
	
	if activeCuxPortInterface = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No Voyage Departure Cuxport Interface defined", LogERROR);
		app.doRaiseAlert(method.qualifiedName &amp; Tab &amp; "No Voyage Departure Cuxport Interface defined");
		return false;
	endif;
	
	thisPort := _terminal.getConfig(PortDestCode).String;
	
	create voyage transient;
	voyage.voyageCode := _voyage.code;
	voyage.voyageExternalCode := _voyage.voyageCodeExternal;
	voyage.voyageInwardCode := _voyage.inwardCode;
	voyage.voyageOperator := _voyage.operatorCode;
	voyage.lloydsNumber := _voyage.lloydsNumber;
	voyage.vesselCode := _voyage.vesselCode;
	voyage.vesselName := _voyage.vesselName;
	if _voyage.arrivedDT.isValid then
		voyage.voyageArrivalDT := _voyage.arrivedDT;
	elseif _voyage.estimatedArrivalDT.isValid then
		voyage.voyageArrivalDT := _voyage.estimatedArrivalDT;
	endif;
	if _voyage.departedDT.isValid then
		voyage.voyageDepartureDT := _voyage.departedDT;
	elseif _voyage.departTargetDT.isValid then
		voyage.voyageDepartureDT := _voyage.departTargetDT;
	elseif _voyage.estimatedDepartureDT.isValid then
		voyage.voyageDepartureDT := _voyage.estimatedDepartureDT;
	endif;
	
	// we want all cargo loaded "here"
	foreach ti in _voyage.allOnshipTIsByIdCargoType where ti.loadPort = thisPort do
		create cargo transient;
		cargo.setFromTI(ti, true);
		voyage.cargo.add(cargo);
	endforeach;
	
	voyage.deserializeJSON(jsonPostData);
	app.writeLog(method.qualifiedName &amp; Tab &amp; "jsonPostData is " &amp; jsonPostData, LogDEBUG);
	
	// TFS 57207 start
	activeCuxPortInterface.getEndpointMethodAndValue(ETRow_VoyageDepartureEDBIC, methodType, endpointPath);
	if methodType = null or endpointPath = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; activeCuxPortInterface.name &amp; " is not set up correctly for " &amp; activeCuxPortInterface.name &amp; Space &amp; ETRow_VoyageDepartureEDBIC &amp; " messages", LogERROR);
		app.doRaiseAlert(activeCuxPortInterface.name &amp; " is not set up correctly for " &amp; activeCuxPortInterface.name &amp; Space &amp; ETRow_VoyageDepartureEDBIC &amp; " messages");
		return true;
	endif;
	// TFS 57207 end
	self.sendToEDBIC(method.qualifiedName, activeCuxPortInterface.baseEndpoint &amp; "/" &amp; endpointPath, methodType, jsonPostData, _terminal, activeCuxPortInterface);
	return true;
	
epilog
	delete voyage;
end;</source>
