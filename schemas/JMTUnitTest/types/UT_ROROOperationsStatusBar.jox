Date			Who		Reason
13/05/2013		cnwmh5	Initial creation

*/

vars

	job									: CM_Job;
	theSlot								: CM_LocationsController;
	
	idx									: Integer;

begin

	app.writeLog("STEP 10SOBC", LogINFO);
	app.writeLog("Move the SOBs containers.  Please wait...", LogINFO);
	
	self.loadAllJobsToOps(self.myVoyage, true);
	
	
	self.locationArray.clear();
	self.locationArray.add("D40321");
	
	
	self.myVoyage.findLocation(locationArray, false, theSlot, idx);
	self.assertNotNull(theSlot);
	
	self.move(theSlot.CM_ROROSlotController.myRORORequestLoad.getTrackedItem(), theSlot);
	
	self.locationArray.clear();
	self.locationArray.add("D40334");
	
	self.myVoyage.findLocation(locationArray, false, theSlot, idx);
	self.assertNotNull(theSlot);
	
