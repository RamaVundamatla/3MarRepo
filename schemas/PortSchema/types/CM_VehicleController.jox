<Class name="CM_VehicleController" id="9d86be74-07ab-4773-b838-d556ed194c81">
    <superclass name="CM_LocationsController"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This is the locations controller belonging to a road vehicle.
There is one per vehicle. TI's coming in by road are moved to
the vehicle controller, rather than the VTA. The vehicle then
goes to another part of the yard to be serviced. This service area 
temporarily becomes the parent of the locations controller.
The parent area is nulled when the vehicle leaves the yard.</text>
    <DbClassMap file="location"/>
