    <JadeMethod name="setForUpdate" id="8f97b262-70fd-4dc0-aaf9-48877a2c7d5a">
        <updating/>
        <source>setForUpdate(_proxy : CM_OwnershipChange)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2023 navtnr20	TFS CR 58507	Task 58209: Jade - TRX CM_OwnershipChange

*/

vars

begin
	
	
	self.myOperatorOld				:= _proxy.myOperatorOld;
	self.condition					:= _proxy.condition;
	self.dateTimeApproved			:= _proxy.dateTimeApproved;
	self.dateTimeCOO				:= _proxy.dateTimeCOO;
	self.freeDaysAdditional			:= _proxy.freeDaysAdditional;
	self.freeDaysOperatorNew		:= _proxy.freeDaysOperatorNew;
	self.freeDaysOperatorOld		:= _proxy.freeDaysOperatorOld;
	self.refNumber 					:= _proxy.refNumber;
	self.remarks					:= _proxy.remarks;
	self.storageExpiryOperatorNew 	:= _proxy.storageExpiryOperatorNew;
	self.transferredQuantity		:= _proxy.transferredQuantity;
	self.transferredVolume			:= _proxy.transferredVolume;
	self.transferredWeight			:= _proxy.transferredWeight;
	self.userCode					:= _proxy.userCode;
	self.userCodeApproved			:= _proxy.userCodeApproved;
	self.myOperatorNew				:= _proxy.myOperatorNew;
	self.myOperatorOrig				:= _proxy.myOperatorOrig;
	self.myOperatorStorage			:= _proxy.myOperatorStorage;
	//self.myOwnershipChangePrevious	:= _proxy.myOwnershipChangePrevious;
	self.myTerminal					:= _proxy.myTerminal;
	self.myIncoterm					:= _proxy.myIncoterm;
	self.myFreightForwarder			:= _proxy.myFreightForwarder;
	self.myInvoiceContract			:= _proxy.myInvoiceContract;				//navra1 - TFS 64874 - 14th Aug 2024
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_OwnershipChange"/>
    </JadeMethod>
    <JadeMethod name="setOrigOperator" id="54d75599-348b-43c3-880d-437e5a7ed872">
        <updating/>
        <source>setOrigOperator() updating;
/*
Purpose:			

Date		Who		Reason
24 July 2023	navab1	// ### TFS CR 58230 TASK 58231 24JUL2023 NAVAB1
*/

vars

	detail, subDetail : CM_OwnershipChangeDetail;
	ti : CM_TrackedItem;
begin
	
	detail := self.allDetails.first();
	
	if detail &lt;&gt; null then
		ti := detail.myTrackedItem;
		
		// ### TFS BUG 64126 14MAY2024 NAVAB1 switch to cargo item
		if ti.isCargoGroupItem then
			subDetail := detail.allSubDetails.first;
			if subDetail &lt;&gt; null then
				ti := subDetail.myTrackedItem;
			endif;
		endif;
		if ti &lt;&gt; null then
			self.myOperatorOrig := ti.getReceiveOperator();
			
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setOrigOperatorFreeDays" id="9a2d0ed9-39f5-46a0-b334-a09cdc550a9e">
        <updating/>
        <source>setOrigOperatorFreeDays() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 16MAY2024
ADO -  BUG 64126
*/

vars

	detail, subDetail : CM_OwnershipChangeDetail;
	ti : CM_TrackedItem;
	detailSto : CM_StorageDetail;
begin
	
	detail := self.allDetails.first();
	
	if detail &lt;&gt; null then
		ti := detail.myTrackedItem;
		
		// switch to cargo item
		if ti.isCargoGroupItem then
			subDetail := detail.allSubDetails.first;
			if subDetail &lt;&gt; null then
				ti := subDetail.myTrackedItem;
			endif;
		endif;
		if ti &lt;&gt; null then
			detailSto:= ti.getMatchingFreeStorageDetail(null);
			if detailSto &lt;&gt; null then
				self.freeDaysOperatorOld := detailSto.freeStorageDays;
			
			endif;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="e91a517a-2de1-4a88-95a1-c638ef0b2a43">
