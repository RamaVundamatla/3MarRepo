    <JadeMethod name="populateDataTable" id="b99084bf-acf7-45ea-ba1c-92a62e14b790">
        <updating/>
        <source>populateDataTable() updating, protected;
/*
Purpose:			
Date				Who			Reason
AUGUST 2017			CNWAB1		Initial creation
20 October 2017		jlgmd1		TFS #7228 - ADP - Storage Configuration Validation and Auditing
*/
vars
	str		: String;
	savedRow,
	row		: Integer;
	storageConfig : CM_StorageConfig;
	storageDetail : CM_StorageDetail;
	ya : CM_YardAllocation;

begin

	if self.tblData.rows &gt; 1 then
		savedRow := self.tblData.row;
	endif;
	self.tblData.rows:= self.tblData.fixedRows;
	
	storageConfig := self.myStorageConfig;
	if storageConfig = null then
		return;
	endif;

	foreach ya in storageConfig.allStorageDetailsByPriority do	//18 May 2016	NDL	TFS 1981 use the byPriority collection
		storageDetail := ya.CM_StorageDetail;
		self.doQueryAddItem(storageDetail);
	endforeach;
	
	// restore the current row
	if savedRow &gt; 0 and savedRow &lt;= self.tblData.rows then
		self.tblData.row := savedRow;
	else
		if self.tblData.rows &gt; 1 then
			self.tblData.row := 2;	// first data row
		endif;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="45bcd59b-4061-49a2-b0b0-5475885da1ba">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwer1	Initial creation SFW 1295
// 10 Oct 2017    jlgrh7 TFS #7228 ADP - Storage Configuration Validation and Auditing

*/

vars

begin
	self.myStorageConfig := self.myTerminal.myStorageConfig;
	// 34917 navigator goes to this detail from 841, if no storage config defined yet, go to the config form for it to be defined
	if self.myStorageConfig = null then
		self.showConfig();
		self.unloadForm();
		return;
	endif;
	
	self.useTableSorting := true; // TFS 5225
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.useTableInfo := false; 
	self.caption := app.getErrorString(Storage_Details);
	
	inheritMethod();
	self.mnuSendReportMain.visible		:= false;
	self.mnuContextColourLegend.visible	:= false;
	self.mnuColumnOrganiser.visible		:= true; // TFS 5225
	// show context menus for add, change and delete
	self.mnuInvNew.visible := true;
	self.mnuInvUpdate.visible := true;
	self.mnuContextJobDelete.caption := app.getErrorString(Menu_Delete);		// &amp;Delete - click already calls doDelete()
	self.mnuContextJobDelete.visible := true;
	// 34917 add context menu to config
	self.mnuContextCompare.caption := app.getErrorString(Menu_Configuration);		// &amp;Configuration - click calls doMnuCompare()
	self.mnuContextCompare.visible := true;
	
	// TFS 1981 TFS BUG 58789 26JUNE2023 NAVAB1self.mnuInvAudits.visible := true;	//17 May 2016	NDL
	self.mnuAuditsForObject.visible := true; // TFS BUG 58789 26JUNE2023 NAVAB1	
	// minimum form size
	self.minimumHeight := 150;
	self.minimumWidth := 600;
	
	
	self.initTableData(ETDef_StorageDetailList); // TFS 5225
	// TFS 5225 self.setupTable();
	
	self.doQuery();
	
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_STORAGE_CRITERIA_CREATE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_STORAGE_CRITERIA_UPDATE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_STORAGE_CRITERIA_DELETE), Response_Continuous, null);
	
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_STORAGECONFI_CREATE), Response_Continuous, null);						//+TFS7228
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_STORAGECONFI_DELETE), Response_Continuous, null);						//+TFS7228
	

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNew.enabled:= false;
		self.btnEditItem.enabled:= false;
		self.btnDelete.enabled:= false;
		
		self.mnuInvNew.enabled := false;
		self.mnuInvUpdate.enabled := false;
		self.mnuContextJobDelete.enabled:= false;
		
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupTable" id="5a9693a6-281b-4e16-9fff-fe0bacc06edd">
        <source>setupTable() protected;
//21 Jul 2017	cnwma1	TFS #5409:STWO - Storage Slab Auto Commercial Hold
//06 Sep 2017	jlgmd1	TFS #6764 This method is no longer used, as we've gone back to using the ETDef_StorageCriteriaList
//						Method kept to retain history
vars
	row,
	col		: Integer;
	critType	: CM_YACriteriaType;

begin
	// NOTE: the original code for this form used ent table ETDef_StorageCriteriaList - this is no longer used here, so may not be needed
	/*row := 1;
	col := 1;
	self.tblData.fixedRows := 1;
	//self.tblData.columns := self.myStorageConfig.allYACriteriaTypes.size + 2;		// properties plus free and charged days
	//self.tblData.columns := self.myStorageConfig.allYACriteriaTypes.size + 4;		// properties plus free and charged days plus Priority plus Has FS Mapping 
