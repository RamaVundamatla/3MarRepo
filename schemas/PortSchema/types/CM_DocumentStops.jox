<Class name="CM_DocumentStops" id="996546a5-24a8-4ea9-9abe-5a0e3596ca72">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="docActions"/>
    <PrimAttribute name="amount" id="01e6c7c2-9863-4a7e-9d83-f1d2d144f352">
        <embedded/>
        <type name="Real"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="dateTime" id="c0bacba9-9500-4a72-ae1f-0af159a6e131">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myDocumentActionsObj" id="9c14ac09-dc75-4b59-a690-bcd5a5fec432">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_DocumentActions"/>
        <access>readonly</access>
        <Inverse name="CM_DocumentActions::allDocumentStopsApplied"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myStopsTable" id="20ca78eb-a70d-476e-83f4-efb4b080adce">
        <embedded/>
        <type name="CM_StopsTable"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTrackedItem" id="32a22273-21cf-48f9-83a9-5ccf2035de14">
        <embedded/>
        <type name="CM_TrackedItem"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="userId" id="aa2f6265-7923-4d8b-a3b3-5c440dfdf5aa">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="adjustAmount" id="88d4fe5b-36bc-4ee8-97da-a0310ac54f23">
        <updating/>
        <source>adjustAmount( _newAmount : Real ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2016	cnwndl1	Initial creation	TFS 3016 / 2549

*/

vars

begin

	self.amount := _newAmount;

epilog

end;</source>
        <Parameter name="_newAmount" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="a2abb389-775e-4d24-9106-b3e7e010a5bd">
        <updating/>
        <source>setDetails(	_ti : CM_TrackedItem;
			_amount : Real;
			_stopTable : CM_StopsTable;
			_docActions : CM_DocumentActions
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2016	cnwndl1	Initial creation	TFS 2644

*/

vars
	maxAmount : Integer;
begin

	self.myTrackedItem := _ti;

	// TFS 3283 self.amount := _amount;
	maxAmount := _docActions.getDocumentAmount(); // TFS 3283
	self.amount := _amount.min(maxAmount); // TFS 3283 set maximum to the document detail's amount

	self.userId := app.getMyUserCode;
	self.dateTime := app.serverTimestampAtTrxStart;
	self.myStopsTable := _stopTable;
	
	self.myDocumentActionsObj := _docActions;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_amount" type="Real"/>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
        <Parameter name="_docActions" type="CM_DocumentActions"/>
    </JadeMethod>
</Class>
