    <JadeMethod name="xCopyToJugDeploymentPS" id="3f12fee9-45ba-4b3e-9764-10f260708349">
        <source>xCopyToJugDeploymentPS(_psFile : File);

/*

Purpose:		Create the ps file to copy to jugdeployment	

Date			Who		Reason
15/08/2016		cnwmh5	Initial creation
17/08/2017		jlgmd1	Added JLGOJMT and Unicode support

*/

constants

	ReleaseDirectory				: String = "\\cnwchcm24\cnwpod$\Releases\";			// "\\cwmchcm24\";
	JugDeploymentDirectory			: String = "\\cnwchcm24\jugdeployment\";			//"jugdeployment\cnw\";				// "D:\Releases\";
	DirectoryPDFCopyFrom			: String = "\jmt_documentation";
	DirectoryHTDOCSCopyFrom			: String = "\jmt_htdocs";
	DirectoryPDF					: String = "\documentation";
	DirectoryWeb					: String = "\web";
	DirectoryANSI					: String = "\ANSI";
	DirectoryUNICODE				: String = "\Unicode";
	DirectorySchemaFiles			: String = "\SchemaFiles";
	DirectorySchemas				: String = "\schemas";
	DirectoryPDFCopyTo				: String = "\x64-msoft-win64\server\misc\documentation";
	DirectoryHTDOCSCopyTo			: String = "\x64-msoft-win64\server\misc\htdocs";

vars

	source							: String;
	version							: String;

begin

	// get the version
	version := CM_Version.VERSION;
	version := version.replaceString(".", "");

	source := 'Clear-Host
	
#****************************************************************************************************************
# Change History
# ==============
# 04/05/2017 cnwmh5 Fix issue with Interim cut directories not being required
# 11/08/2017 jlgmd1 Updated to include Unicode directories
#                   Fixed the script not creating the environment directory if it was missing
# 17/08/2017 jlgmd1 Made Unicode and ANSI mutually exclusive
# 02/11/2017 jlgmd1 Copy live_preextract.bat if it exists in the DailyJARI folder
#
#****************************************************************************************************************

#Directories
$versionNumber = "' &amp; version &amp; '"
$releaseDirectoryBase = "' &amp; ReleaseDirectory &amp; '"
$releaseDirectory =  $releaseDirectoryBase + $versionNumber
$jugDeployment = "' &amp; JugDeploymentDirectory &amp; '"
$copyToDirectory = $jugDeployment

$copyToANSIDirectory = "' &amp; DirectoryANSI &amp; '"
$copyToUNICODEDirectory = "' &amp; DirectoryUNICODE &amp; '"
$copyToSchemaFilesDirectory = "' &amp; DirectorySchemaFiles &amp; '"
$copyToPDFDirectory = $copyToANSIDirectory + "' &amp; DirectoryPDFCopyTo &amp; '"
$copyToHTDOCSDirectory = $copyToANSIDirectory + "' &amp; DirectoryHTDOCSCopyTo &amp; '"

$copyFromRANSIDirectory = "' &amp; DirectoryANSI &amp; '"
$copyFromRUNICODEDirectory = "' &amp; DirectoryUNICODE &amp; '"
$copyFromRPDFDirectory = "' &amp; DirectoryPDFCopyFrom &amp; '"
$copyFromRHTDOCSDirectory = "' &amp; DirectoryHTDOCSCopyFrom &amp; '"
$copyFromRSchemaFilesDirectory = "' &amp; DirectorySchemaFiles &amp; '"

$copyFromSANSIDirectory = "' &amp; DirectoryANSI &amp; '"
$copyFromSUNICODEDirectory = "' &amp; DirectoryUNICODE &amp; '"
$copyFromSPDFDirectory = "' &amp; DirectoryPDF &amp; '"
$copyFromSHTDOCSDirectory = "' &amp; DirectoryWeb &amp; '"
$copyFromSSchemaFilesDirectory = "' &amp; DirectorySchemas &amp; '"

$copyFromSchemaFilesDirectory = ""
$copyFromPDFDirectory = ""
$copyFromHTDOCSDirectory = ""
$copyFromANSIDirectory = ""
$copyFromUNICODEDirectory = ""
$copyFromLivePreExtractFile = ""

$CurrentlySelectedSystem = ""
$CurrentlySelectedRelease = ""

$NumberOfReleasesToGet = 3

#Load Assemblies
[System.Reflection.Assembly]::LoadWithPartialName("System.Windows.Forms") | Out-Null
[System.Reflection.Assembly]::LoadWithPartialName("System.Drawing") | Out-Null

$net = New-Object -ComObject Wscript.Network

#Groupboxes
$GrpJugDeploymentDirectories = New-Object System.Windows.Forms.GroupBox
$GrpSystems = New-Object System.Windows.Forms.GroupBox
$GrpJugDeploymentCopyTo = New-Object System.Windows.Forms.GroupBox
$GrpDirectoriesCopyFrom = New-Object System.Windows.Forms.GroupBox
$GrpReleaseDirectories = New-Object System.Windows.Forms.GroupBox
$GrpSourceDirectories = New-Object System.Windows.Forms.GroupBox

#Labels
$lblJugSchemaFiles = New-Object System.Windows.Forms.Label
$lblJUgDocPDF = New-Object System.Windows.Forms.Label
$lblJugHTDOCS = New-Object System.Windows.Forms.Label
$lblJugANSI = New-Object System.Windows.Forms.Label
$lblJugUNICODE = New-Object System.Windows.Forms.Label
$ReleaseSchemaFiles = New-Object System.Windows.Forms.Label
$ReleaseDocPDF = New-Object System.Windows.Forms.Label
$ReleaseHTDOCS = New-Object System.Windows.Forms.Label
$ReleaseANSI = New-Object System.Windows.Forms.Label
$ReleaseUNICODE = New-Object System.Windows.Forms.Label
$SourceSchemaFiles = New-Object System.Windows.Forms.Label
$SourceDocPDF = New-Object System.Windows.Forms.Label
$SourceHTDOCS = New-Object System.Windows.Forms.Label
$SourceANSI = New-Object System.Windows.Forms.Label
$SourceUNICODE = New-Object System.Windows.Forms.Label
$sourceVersion = New-Object System.Windows.Forms.Label

#TextBox
$JugTSchemaFiles = New-Object System.Windows.Forms.Textbox
$JugTDocPDF = New-Object System.Windows.Forms.Textbox
$JugTHTDOCS = New-Object System.Windows.Forms.Textbox
$jugTANSI = New-Object System.Windows.Forms.Textbox
$jugTUNICODE = New-Object System.Windows.Forms.Textbox
$ReleaseTSchemaFiles = New-Object System.Windows.Forms.Textbox
$ReleaseTDocPDF = New-Object System.Windows.Forms.Textbox
$ReleaseTHTDOCS = New-Object System.Windows.Forms.Textbox
$ReleaseTANSI = New-Object System.Windows.Forms.Textbox
$ReleaseTUNICODE = New-Object System.Windows.Forms.Textbox
$SourceTSchemaFiles = New-Object System.Windows.Forms.Textbox
$SourceTDocPDF = New-Object System.Windows.Forms.Textbox
$SourceTHTDOCS = New-Object System.Windows.Forms.Textbox
$SourceTANSI = New-Object System.Windows.Forms.Textbox
$SourceTUNICODE = New-Object System.Windows.Forms.Textbox

#Buttons
$btnCopy = New-Object System.Windows.Forms.Button
$btnCancel = New-Object System.Windows.Forms.Button

#RadioButton
$SystemHMAST = New-Object System.Windows.Forms.RadioButton
$SystemGMAST = New-Object System.Windows.Forms.RadioButton
$SystemLMAST = New-Object System.Windows.Forms.RadioButton
$SystemJMAST = New-Object System.Windows.Forms.RadioButton
$SystemTMAST = New-Object System.Windows.Forms.RadioButton
$SystemOJMT = New-Object System.Windows.Forms.RadioButton

#Combobox
$SourceVersionC = New-Object System.Windows.Forms.ComboBox
$last3Releases = @()

#Checkbox
$IncludeUnicode = New-object System.Windows.Forms.CheckBox

#Status Bar
$stsBar = New-Object System.Windows.Forms.StatusBar

#Create GroupBoxes
function CreateGroupBox($ComponentObject, $LocX, $LocY, $SizeX, $SizeY, $ComponentText, $ComponentParent) {
    $ComponentObject.Location = New-Object System.Drawing.Size($LocX, $LocY)
    $ComponentObject.size = New-Object System.Drawing.Size($SizeX, $SizeY)
    $ComponentObject.Text = $ComponentText
    $ComponentParent.Controls.Add($ComponentObject)
}

function CreateLabel($ComponentObject, $LocX, $LocY, $ComponentText, $ComponentParent) {
    $ComponentObject.Location = New-Object System.Drawing.Size($LocX, $LocY)
    $ComponentObject.Size = New-Object System.Drawing.Size(10, 10) #Default size for autosize to work
    $ComponentObject.AutoSize = $true
    $ComponentObject.Text = $ComponentText
    $ComponentParent.Controls.Add($ComponentObject)
}

function CreateRadioButton($ComponentObject, $LocX, $LocY, $SizeX, $SizeY, $ComponentText, $ComponentParent, $ComponentChecked, $ComponentAction) {
    $ComponentObject.Location = New-Object System.Drawing.Size($LocX, $LocY)
    $ComponentObject.size = New-Object System.Drawing.Size($SizeX, $SizeY)
    if ($ComponentChecked -eq "CHECKED") {
        $ComponentObject.Checked = $ComponentChecked
    }
    $ComponentObject.Text = $ComponentText
    $componentObject.Add_Click($ComponentAction)
    $ComponentParent.Controls.Add($ComponentObject)
}

function CreateTextBox($ComponentObject, $LocX, $LocY, $SizeX, $SizeY, $ComponentText, $ComponentParent) {
    $ComponentObject.Location = New-Object System.Drawing.Size($LocX, $LocY)
    $ComponentObject.size = New-Object System.Drawing.Size($SizeX, $SizeY)
    $ComponentObject.Text = $ComponentText
    $ComponentParent.Controls.Add($ComponentObject)
}

function CreateButton($ComponentObject, $LocX, $LocY, $SizeX, $SizeY, $ComponentText, $ComponentParent, $ComponentAction) {
    $ComponentObject.Location = New-Object System.Drawing.Size($LocX, $LocY)
    $ComponentObject.size = New-Object System.Drawing.Size($SizeX, $SizeY)
    $ComponentObject.Text = $ComponentText
    $ComponentObject.Add_Click($ComponentAction)
    $ComponentParent.Controls.Add($ComponentObject)
}

function CreateStatusBar($ComponentObject, $LocX, $LocY, $SizeX, $SizeY, $ComponentParent) {
    $ComponentObject.Location = New-Object System.Drawing.Size($LocX, $LocY)
    $ComponentObject.size = New-Object System.Drawing.Size($SizeX, $SizeY)
    $ComponentParent.Controls.Add($ComponentObject)
}

function CreateComboBox($ComponentObject, $LocX, $LocY, $SizeX, $SizeY, $ComponentParent, $ComponentItems, $ComponentAction) {
    $ComponentObject.Location = New-Object System.Drawing.Size($LocX, $LocY)
    $ComponentObject.size = New-Object System.Drawing.Size($SizeX, $SizeY)
    foreach ($item in $ComponentItems) {
        $ComponentObject.Items.Add($item)
    }
    $ComponentObject.SelectedIndex = 0
    $CurrentlySelectedRelease = $ComponentObject.Text
    $componentObject.Add_SelectedValueChanged($ComponentAction)
    $ComponentParent.Controls.Add($ComponentObject)
}

function CreateCheckBox($ComponentObject, $LocX, $LocY, $ComponentParent, $ComponentAction) {
    $ComponentObject.Location = New-Object System.Drawing.Size($LocX, $LocY)
    $ComponentObject.Size = New-Object System.Drawing.Size(15, 15)
    $ComponentObject.Add_Click($ComponentAction)
    $ComponentParent.Controls.Add($ComponentObject)
}

function RadioButtonSelected($componentObject) {
    if ($SystemHMAST.Checked) {
        $SelectedSystem = $SystemHMAST.Text.Substring(0,8)
    } elseif ($SystemLMAST.Checked) {
        $SelectedSystem = $SystemLMAST.Text
    } elseif ($SystemGMAST.Checked) {
        $SelectedSystem = $SystemGMAST.Text
    } elseif ($SystemJMAST.Checked) {
        $SelectedSystem = $SystemJMAST.Text
    } elseif ($SystemTMAST.Checked) {
        $SelectedSystem = $SystemTMAST.Text.Substring(0,8)
    } else {
        $SelectedSystem = $SystemOJMT.Text.Substring(0,7)
    }

	$newJugDir = $SelectedSystem.Substring(0,3).ToLower()
	$newCopyToDirectory = $jugDeployment + "$newJugDir\$SelectedSystem"

    $script:copyToSchemaFilesDirectory = $copyToSchemaFilesDirectory.Replace($copyToDirectory, $newCopyToDirectory)
    $script:copyToPDFDirectory = $copyToPDFDirectory.Replace($copyToDirectory, $newCopyToDirectory)
    $script:copyToHTDOCSDirectory = $copyToHTDOCSDirectory.Replace($copyToDirectory, $newCopyToDirectory)
    $script:copyToANSIDirectory = $copyToANSIDirectory.Replace($copyToDirectory, $newCopyToDirectory)
    $script:copyToUNICODEDirectory = $copyToUNICODEDirectory.Replace($copyToDirectory, $newCopyToDirectory)

    $JugTSchemaFiles.Text = $copyToSchemaFilesDirectory
    $JugTDocPDF.Text = $copyToPDFDirectory
    $JugTHTDOCS.Text = $copyToHTDOCSDirectory
    $jugTANSI.Text = $copyToANSIDirectory
    $jugTUNICODE.Text = $copyToUNICODEDirectory
    
    $CurrentlySelectedSystem = $SelectedSystem
	$script:copyToDirectory = $newCopyToDirectory
}

function SourceReleaseChanged($ComponentObject) {

    $first3Characters  = $ComponentObject.Text.SubString(0,3)
    $last3Characters = $ComponentObject.Text.SubString(3,3)
   
    if ($CurrentlySelectedRelease -match ".{5}") {
        # monthly release found
       
        $oldVersion = "\\" + $VersionNumber + "\\"
        $newVersion =  "\" + $first3Characters + "\"
        $oldRelease = "\\" + $CurrentlySelectedRelease + "\\"
        $newRelease = ""
       
        if ($last3Characters -ne "000") {
            $newRelease = "\" + $ComponentObject.Text + "\"
        }
        
        $SourceTSchemaFiles.Text = $copyFromSSchemaFilesDirectory -replace $oldVersion, $newVersion
        $SourceTSchemaFiles.Text = $SourceTSchemaFiles.Text  -replace $oldRelease, $newRelease
    
        $SourceTDocPDF.Text = $copyFromSPDFDirectory -replace $oldVersion, $newVersion
        $SourceTDocPDF.Text = $SourceTDocPDF.Text -replace $oldRelease, $newRelease
    
        $SourceTHTDOCS.Text = $copyFromSHTDOCSDirectory -replace $oldVersion, $newVersion
        $SourceTHTDOCS.Text = $SourceTHTDOCS.Text -replace $oldRelease, $newRelease
    
        $oldVersion = "\\" + $VersionNumber + "\\"
        $oldRelease = "\\" + $CurrentlySelectedRelease + "\\JARI_JMT" + $CurrentlySelectedRelease + "\\"
        $newRelease = ""
        
        if ($last3Characters -ne "000") {
            $newRelease = "\" + $ComponentObject.Text + "\JARI_JMT" + $ComponentObject.Text + "\"
        }

        $SourceTANSI.Text = $copyFromSANSIDirectory -replace $oldVersion, $newVersion
        $SourceTANSI.Text = $SourceTANSI.Text -replace $oldRelease, $newRelease

        $SourceTUNICODE.Text = $copyFromSUNICODEDirectory -replace $oldVersion, $newVersion
        $SourceTUNICODE.Text = $SourceTUNICODE.Text -replace $oldRelease, $newRelease

    } else {
        # base release found
                
        if ($last3Characters -eq "000") {
           $newVersion = $releaseDirectoryBase + $first3Characters + "\JADEMASTER\"
        } else {
           $newVersion = $releaseDirectoryBase + $first3Characters + "\Monthly\" + 
               $ComponentObject.Text + "\JADEMASTER\"
        }

        $SourceTSchemaFiles.Text = $newVersion + "schemas"
        $SourceTDocPDF.Text = $newVersion + "documentation"
        $SourceTHTDOCS.Text = $newVersion + "web"

        if ($last3Characters -eq "000") {
           $newVersion = $releaseDirectoryBase + $first3Characters + "\JARI_JMT" + $first3Characters + "\"
        } else {
           $newVersion = $releaseDirectoryBase + $first3Characters + "\Monthly\" + 
               $ComponentObject.Text + "\JARI_JMT" + $ComponentObject.Text + "\"
        }
        
        $SourceTANSI.Text = $newVersion + "ansi"
        $SourceTUNICODE.Text = $newVersion + "unicode"

    }

}

function IncludeUnicodeTicked($ComponentObject) {
    if ($ComponentObject.Checked) {
        $jugTUNICODE.ForeColor = [System.Drawing.Color]::Black
        $jugTANSI.ForeColor = [System.Drawing.Color]::Gray
    } else {
        $jugTUNICODE.ForeColor = [System.Drawing.Color]::Gray
        $jugTANSI.ForeColor = [System.Drawing.Color]::Black
    }
}

function CloseForm() {
    Add-Type -AssemblyName System.Windows.Forms
    $Form.Close()
}

function CopyToDirectories() {
    
    #Check copyTo Directory exists
    if ( -not (Test-Path $copyToDirectory)) {
        New-Item -Path $copyToDirectory -Type Directory &gt;$null
    }

    #setup the copy from directory
    $copyFromSchemaFilesDirectory = SetCopyFromDirectory "SCHEMA"
    $copyFromPDFDirectory = SetCopyFromDirectory "PDF"
    $copyFromHTDOCSDirectory = SetCopyFromDirectory "HTDOCS"
    if ( -not ($IncludeUnicode.Checked)) {
        $copyFromANSIDirectory = SetCopyFromDirectory "ANSI"
		$copyFromLivePreExtractFile = $copyFromLivePreExtractFile.Replace("\unicode\", "\ansi\")
    } else {
        $copyFromUNICODEDirectory = SetCopyFromDirectory "UNICODE"
		$copyFromLivePreExtractFile = $copyFromLivePreExtractFile.Replace("\ansi\", "\unicode\")
        if (!(Test-Path $copyFromLivePreExtractFile)) {
            #switch back to the ansi version if the unicode version doesnt exist
            $copyFromLivePreExtractFile = $copyFromLivePreExtractFile.Replace("\unicode\", "\ansi\")
        }
    }

    #delete any exising dirertories
    $removeFromDirectory = $JugTSchemaFiles.Text + "\*"
    $stsBar.Text = "Deleting files from " + $copyToDirectory + ".  Please wait..."
    Remove-Item $copyToDirectory"\*" -Force -Recurse
    
    #copy the SchemaFiles directory to the jugDeployment directory
    $stsBar.Text = "Copying from " + $copyFromSchemaFilesDirectory + " to " + $JugTSchemaFiles.Text + ".  Please wait..."
   
    #### Source copy exclude the following files *.unl, *.mul, 100*.scm 100*.ddb
    Copy-Item -Path $copyFromSchemaFilesDirectory -Destination $JugTSchemaFiles.Text -Force -Recurse
    Remove-Item $removeFromDirectory -Include 100*, *.unl, *.mul

    if ( -not ($IncludeUnicode.Checked)) {
        #copy the Ansi directory to the jugDeployment directory
        $stsBar.Text = "Copying from " + $copyFromANSIDirectory + " to " + $jugTANSI.Text + ".  Please wait..."
        Copy-Item -Path $copyFromANSIDirectory -Destination $jugTANSI.Text -Force -Recurse
		#copy the live_preextract.bat file
        Copy-Item -Path $copyFromLivePreExtractFile -Destination ($jugTANSI.Text + "$copyToMiscDirectory\") -Force
    } else {
	    #copy the Unicode directory to the jugDeployment directory
	    $stsBar.Text = "Copying from " + $copyFromUNICDEDirectory + " to " + $jugTUNICODE.Text + ".  Please wait..."
        Copy-Item -Path $copyFromUNICODEDirectory -Destination $jugTUNICODE.Text -Force -Recurse
		#copy the live_preextract.bat file
        Copy-Item -Path $copyFromLivePreExtractFile -Destination ($jugTUNICODE.Text + "$copyToMiscDirectory\") -Force
    }
	
    #copy releasePDFDirectory
    if ( -not ($IncludeUnicode.Checked)) {
        #ANSI
        $stsBar.Text = "Copying from " + $copyFromPDFDirectory + " to " + $JugTDocPDF.Text + ".  Please wait..."
        Copy-Item -Path $copyFromPDFDirectory -Destination $JugTDocPDF.Text -Force -Recurse
    } else {
        #UNICODE
        $pdfDir = $JugTDocPDF.Text.Replace($jugTANSI.Text, $jugTUNICODE.Text)
        $stsBar.Text = "Copying from " + $copyFromPDFDirectory + " to " + $pdfDir + ".  Please wait..."
        Copy-Item -Path $copyFromPDFDirectory -Destination $pdfDir -Force -Recurse
    }

    # copy HTDOCS
    $excludeDirectory = $copyFromHTDOCSDirectory + "\HTML5"
    $directoriesToCopy = Get-ChildItem -Path $copyFromHTDOCSDirectory -Directory

    if ( -not ($IncludeUnicode.Checked)) {
        #ANSI
        $docsDir = $JugTHTDOCS.Text
    } else {
        #UNICODE
        $docsDir = $JugTHTDOCS.Text.Replace($jugTANSI.Text, $jugTUNICODE.Text)
    }

    foreach ($directory in $directoriesToCopy) {

        if ($directory.FullName -ne $excludeDirectory) {
           $stsBar.Text = "Copying from " + $directory.FullName + " to " + $docsDir + ".  Please wait..."
           $htdocsDeploy = $docsDir + "\" + $directory
           
           Copy-Item -Path $directory.FullName -Destination $htdocsDeploy -Force -Recurse
        }

    }

    CloseForm
}

#Define Form Functions

#Define Functions

function SetCopyFromDirectory ($DirectoryType) {

    $copyFrom = ""

    if (($SystemHMAST.Checked -and $SystemHMAST.Text.Contains("Testing")) -or 
                ($SystemTMAST.Checked -and $SystemTMAST.Text.Contains("Testing")) -or
                ($SystemOJMT.Checked -and $SystemOJMT.Text.Contains("Testing"))) {
        switch ($DirectoryType) {
            SCHEMA {
                $copyFrom = $ReleaseTSchemaFiles.Text
            }
            PDF {
                $copyFrom = $ReleaseTDocPDF.Text
            }
            ANSI {
                $copyFrom = $ReleaseTANSI.Text
            }
			UNICODE {
				$copyFrom = $ReleaseTUNICODE.Text
			}
            default {
                $copyFrom = $ReleaseTHTDOCS.Text
            }
        }
    } elseif ($SystemLMAST.Checked -or $SystemGMAST.Checked -or $SystemJMAST.Checked) {
        switch ($DirectoryType) {
            SCHEMA {
                $copyFrom = $SourceTSchemaFiles.Text
            }
            PDF {
                $copyFrom = $SourceTDocPDF.Text
            }
            ANSI {
                $copyFrom = $SourceTANSI.Text
            }
			UNICODE {
				$copyFrom = $SourceTUNICODE.Text
			}
            default {
                $copyFrom = $SourceTHTDOCS.Text
            }
        }
    } 

    return $copyFrom

}

function GetLast4Releases() {

    #Get Release Directories
    $releaseDirectories = @()
    $releaseDirectories = Get-ChildItem -Directory -Path $releaseDirectoryBase | Sort-Object FullName -Descending
    
    $releaseCount = 0
    $releases = @()
    $releases1 = @()
    
    #$releases = New-Object System.Collections.Generic.List[System.Object]
    $Last4Releases = @()

    foreach ($directory in $releaseDirectories) {

        [string]$directoryName = $directory.FullName
        [string]$tempVerionsNumber = $directoryName.Substring($directoryName.Length-$versionNumber.Length, $versionNumber.Length)
       
        if (($releaseCount -eq 0 ) -and ($versionNumber -ne $tempVerionsNumber)) {
            continue
        }
        
        #Test to see if monthly direcotry exists
        $releaseDirectory = $releaseDirectoryBase + $tempVerionsNumber
        if (Test-Path $releaseDirectory"\Monthly")
        {
            $releaseDirectory = $releaseDirectory + "\Monthly"
            $releases = Get-ChildItem -Directory -Path $releaseDirectory | Sort-Object FullName -Descending 
        } else {
            #empty so just add
            $Last4Releases += ($tempVerionsNumber + "000")
            $releaseCount = $Last4Releases.Count
        }

        #Monthly exists so get from there
        foreach ($release in $releases) {

            $directoryPath = $release.FullName
			
			# 04/05/2017 cnwmh5 Fix issue with Interim cut directories not being required
            if ($directoryPath.Contains("Interim")) {
                continue;
            }
            $releaseNumber = $directoryPath.Substring($directoryPath.Length - 3, 3)
            
            if (($releaseCount -eq 0) -or (($releaseCount -ge 1) -and 
                    ($Last4Releases[$releaseCount - 1].ToString().Substring(3,2) -ne $releaseNumber.Substring(0,2)))) {
                $Last4Releases += $tempVerionsNumber + $releaseNumber
                $releaseCount = $Last4Releases.Count
            }

            # found the last 4 so time to get out
            $releaseCount = $Last4Releases.Count
            if ($releaseCount -gt $NumberOfReleasesToGet) {
                break
            }
        }
    
        # found the last 4 so time to get out
        $releaseCount = $Last4Releases.Count
        if ($releaseCount -gt $NumberOfReleasesToGet) {
            break
        }

    }
    
    return $Last4Releases

}
#End Define Functions


#Get last 4 releases
$last4Release = GetLast4Releases

# Get the release directories to check
$releaseNumber = $versionNumber
if (Test-Path $releaseDirectory"\Monthly")
{
    $releaseDirectory = $releaseDirectory + "\Monthly"
    #$releaseNumber = Get-ChildItem -Directory -Path $releaseDirectory -Exclude *Interim* | Sort-Object CreationTime -desc | Select-Object -First 1
	$releaseNumber = $last4Release[0] #Keep the default directories in line with the first selected release
    [string]$tempStr = $releaseNumber
    $releaseNumber = $tempStr.Substring($tempStr.Length - 6, 6)
    $releaseDirectory = $releaseDirectory + "\" + $releaseNumber
 
}

#Copy from Release Directories
$copyFromRSchemaFilesDirectory = $releaseDirectory + "\JARI_JMT" + $releaseNumber + $copyFromRSchemaFilesDirectory
$copyFromRPDFDirectory = $releaseDirectory + "\JARI_JMT" + $releaseNumber + $copyFromRPDFDirectory
$copyFromRHTDOCSDirectory = $releaseDirectory + "\JARI_JMT" + $releaseNumber + $copyFromRHTDOCSDirectory
$copyFromRANSIDirectory = $releaseDirectory + "\JARI_JMT" + $releaseNumber + $copyFromRANSIDirectory
$copyFromRUNICODEDirectory = $releaseDirectory + "\JARI_JMT" + $releaseNumber + $copyFromRUNICODEDirectory

#Copy from Source Directories
$copyFromSSchemaFilesDirectory = $releaseDirectory + "\JADEMASTER" + $copyFromSSchemaFilesDirectory
$copyFromSPDFDirectory = $releaseDirectory + "\JADEMASTER" + $copyFromSPDFDirectory
$copyFromSHTDOCSDirectory = $releaseDirectory + "\JADEMASTER" + $copyFromSHTDOCSDirectory
$copyFromSANSIDirectory = $releaseDirectory + "\JARI_JMT" + $releaseNumber + $copyFromSANSIDirectory
$copyFromSUNICODEDirectory = $releaseDirectory + "\JARI_JMT" + $releaseNumber + $copyFromSUNICODEDirectory

$copyFromLivePreExtractFile = $dailyJARIDirectoryBase + "\ansi" + $copyToMiscDirectory + "\live_preextract.bat"
$CurrentlySelectedRelease = $releaseNumber


#Draw form
$Form = New-Object System.Windows.Forms.Form
$Form.width = 801
$Form.height = 641
$Form.FormBorderStyle = [System.Windows.Forms.FormBorderStyle]::Fixed3D
$Form.Text = "Copy to JugDeployment Directories"
$Form.MaximumSize = New-Object System.Drawing.size(801, 641)
$Form.MinimumSize = New-Object System.Drawing.size(801, 641)
$Form.StartPosition = "centerscreen"
$Form.KeyPreview = $true
$Form.Add_KeyDown({if ($_.KeyCode -eq "Enter") {}})
$Form.Add_KeyDown({if ($_.KeyCode -eq "Escape") {$Form.Close()}})

CreateGroupBox $GrpJugDeploymentDirectories 15 12 761 175 "JugDeployment Directories" $Form

CreateGroupBox $GrpSystems 10 19 150 152 "Systems" $GrpJugDeploymentDirectories
CreateRadioButton $SystemHMAST 6 15 140 17 "CNWHMAST (Testing)" $GrpSystems "CHECKED" ({ RadioButtonSelected($SystemHMAST) })
CreateRadioButton $SystemLMAST 6 33 140 17 "CNWLMAST" $GrpSystems "" ({ RadioButtonSelected($SystemLMAST) })
CreateRadioButton $SystemGMAST 6 52 140 17 "CNWGMAST" $GrpSystems "" ({ RadioButtonSelected($SystemGMAST) })
CreateRadioButton $SystemJMAST 6 71 140 17 "CNWJMAST" $GrpSystems "" ({ RadioButtonSelected($SystemJMAST) })
CreateRadioButton $SystemTMAST 6 90 140 17 "CNWTMAST (Testing)" $GrpSystems "" ({ RadioButtonSelected($SystemTMAST) })
CreateRadioButton $SystemOJMT 6 109 140 17 "JLGOJMT (Testing)" $GrpSystems "" ({ RadioButtonSelected($SystemOJMT) })


if ($SystemHMAST.Checked) {
    $SelectedSystem = $SystemHMAST.Text.Substring(0,8)
} elseif ($SystemLMAST.Checked) {
    $SelectedSystem = $SystemLMAST.Text
} elseif ($SystemGMAST.Checked) {
    $SelectedSystem = $SystemGMAST.Text
} elseif ($SystemJMAST.Checked) {
    $SelectedSystem = $SystemJMAST.Text
} elseif ($SystemTMAST.Checked) {
    $SelectedSystem = $SystemTMAST.Text.Substring(0,8)
} else {
    $SelectedSystem = $SystemOJMT.Text.Substring(0,7)
}
$newJugDir = $SelectedSystem.Substring(0,3).ToLower() + "\"

$copyToDirectory = $copyToDirectory + $newJugDir + $SelectedSystem
$copyToSchemaFilesDirectory = $copyToDirectory + $copyToSchemaFilesDirectory
$copyToPDFDirectory = $copyToDirectory + $copyToPDFDirectory
$copyToHTDOCSDirectory = $copyToDirectory + $copyToHTDOCSDirectory
$copyToANSIDirectory = $copyToDirectory + $copyToANSIDirectory
$copyToUNICODEDirectory = $copyToDirectory + $copyToUNICODEDirectory
$CurrentlySelectedSystem = $SelectedSystem

CreateGroupBox $GrpJugDeploymentCopyTo 166 19 587 152 "Directories to copy to" $GrpJugDeploymentDirectories
CreateLabel $lblJugSchemaFiles 7 20 "SchemaFiles:" $GrpJugDeploymentCopyTo
CreateTextBox $JugTSchemaFiles 112 17 469 20 $copyToSchemaFilesDirectory $GrpJugDeploymentCopyTo
CreateLabel $lblJugDocPDF 7 46 "PDF:" $GrpJugDeploymentCopyTo
CreateTextBox $JugTDocPDF 112 43 469 20 $copyToPDFDirectory $GrpJugDeploymentCopyTo
CreateLabel $lblJugHTDOCS 7 72 "htdocs:" $GrpJugDeploymentCopyTo
CreateTextBox $JugTHTDOCS 112 69 469 20 $copyToHTDOCSDirectory $GrpJugDeploymentCopyTo
CreateLabel $lblJugANSI 7 98 "ANSI:" $GrpJugDeploymentCopyTo
CreateTextBox $JugTANSI 112 95 469 20 $copyToANSIDirectory $GrpJugDeploymentCopyTo
CreateCheckBox $IncludeUnicode 10 127 $GrpJugDeploymentCopyTo ({ IncludeUnicodeTicked($IncludeUnicode) })
CreateLabel $lblJugUNICODE 25 127 "Unicode ?:" $GrpJugDeploymentCopyTo
CreateTextBox $JugTUNICODE 112 124 469 20 $copyToUNICODEDirectory $GrpJugDeploymentCopyTo
#Unicode folder will not be copied by default
$jugTUNICODE.ForeColor = [System.Drawing.Color]::Gray

CreateGroupBox $GrpDirectoriesCopyFrom 15 190 761 361 "Directories to copy from" $Form

CreateGroupBox $GrpReleaseDirectories 6 19 745 153 "Release (JMT)" $GrpDirectoriesCopyFrom
CreateLabel $ReleaseSchemaFiles 7 20 "SchemaFiles:" $GrpReleaseDirectories
CreateTextBox $ReleaseTSchemaFiles 122 17 618 20 $copyFromRSchemaFilesDirectory $GrpReleaseDirectories
CreateLabel $ReleaseDocPDF 7 46 "PDF:" $GrpReleaseDirectories
CreateTextBox $ReleaseTDocPDF 122 43 618 20 $copyFromRPDFDirectory $GrpReleaseDirectories
CreateLabel $ReleaseHTDOCS 7 72 "htdocs:" $GrpReleaseDirectories
CreateTextBox $ReleaseTHTDOCS 122 69 618 20 $copyFromRHTDOCSDirectory $GrpReleaseDirectories
CreateLabel $ReleaseANSI 7 98 "ANSI:" $GrpReleaseDirectories
CreateTextBox $ReleaseTANSI 122 95 618 20 $copyFromRANSIDirectory $GrpReleaseDirectories
CreateLabel $ReleaseUNICODE 7 128 "Unicode:" $GrpReleaseDirectories
CreateTextBox $ReleaseTUNICODE 122 125 618 20 $copyFromRUNICODEDirectory $GrpReleaseDirectories


CreateGroupBox $GrpSourceDirectories 6 175 745 179 "Source (Master)" $GrpDirectoriesCopyFrom
CreateLabel $SourceVersion 7 20 "Version:" $GrpSourceDirectories
CreateComboBox $SourceVersionC 122 17 121 21 $GrpSourceDirectories $last4Release ({ SourceReleaseChanged($SourceVersionC) })
CreateLabel $SourceSchemaFiles 7 46 "SchemaFiles:" $GrpSourceDirectories
CreateTextBox $SourceTSchemaFiles 122 43 618 20 $copyFromSSchemaFilesDirectory $GrpSourceDirectories
CreateLabel $SourceDocPDF 7 72 "PDF:" $GrpSourceDirectories
CreateTextBox $SourceTDocPDF 122 69 618 20 $copyFromSPDFDirectory $GrpSourceDirectories
CreateLabel $SourceHTDOCS 7 98 "htdocs:" $GrpSourceDirectories
CreateTextBox $SourceTHTDOCS 122 95 618 20 $copyFromSHTDOCSDirectory $GrpSourceDirectories
CreateLabel $SourceANSI 7 125 "ANSI:" $GrpSourceDirectories
CreateTextBox $SourceTANSI 122 121 618 20 $copyFromSANSIDirectory $GrpSourceDirectories
CreateLabel $SourceUNICODE 7 155 "Unicode:" $GrpSourceDirectories
CreateTextBox $SourceTUNICODE 122 151 618 20 $copyFromSUNICODEDirectory $GrpSourceDirectories


CreateButton $btnCopy 611 556 75 23 "Copy" $Form ({ CopyToDirectories })
CreateButton $btnCancel 701 556 75 23 "Cancel" $Form ({ CloseForm })

CreateStatusBar $stsBar 0 850 785 22 $Form

#Create the form
$Form.Add_Shown({$Form.Activate()})
$Form.ShowDialog()';

	_psFile.writeString(source);
	_psFile.close();

epilog

end;</source>
        <Parameter name="_psFile" type="File"/>
    </JadeMethod>
    <JadeMethod name="xKnownLeaks" id="07ca2fae-5691-4287-9ae2-70d6763d6d1a">
        <source>xKnownLeaks(_checkFor : String) : Boolean;

/*

Purpose:		Check for known leaks

Date			Who		Reason
24 July 2014	cnwmh5	Initial creation

*/

vars

	checkForLen					: Integer;

begin

	if _checkFor = null then
		return true;
	endif;

	checkForLen := _checkFor.length;
	if checkForLen &gt; 3 then
		if _checkFor[1:3] = "JRD" then
			return true;
		elseif checkForLen &gt; 9 and _checkFor[1:10]="JadeMethod" then
			return true;
		elseif checkForLen &gt; 11 and _checkFor[1:12]="DictIterator" then
			return true;
		endif;
	endif;
	if checkForLen &gt; 7 and
	   _checkFor[1:7] = "JadeLog" then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_checkFor" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xPowerShellRelDocCopy" id="3fd01ba1-7a0d-4eb5-bd9e-9755a220496b">
        <source>xPowerShellRelDocCopy(_directory, _fileName : String);

/*

Purpose:		

Date			Who		Reason
06 April 2016	cnwmh5	Initial creation

*/

vars

	file						: File;
	
	release						: String;

begin

	release := CM_Version.VERSION;
	release := release.replaceString(".", "");

	create file transient;
	file.fileName := _directory &amp; "\" &amp; _fileName;
	
	file.writeLine('$release = "' &amp; release &amp; '"
$baseLocation = "D:\Releases\" + $release + "\"
#$baseLocation = "\\cnwchcm24\cnwpod$\Releases\" + $release + "\"

#Directories to copy From
$locationFromNonJARIPDF = $baseLocation + "BaseRelease\documentation\*"
$locationFromJARIAnsiPDF = $baseLocation + "BaseJARIRelease\ansi\x64-msoft-win64\server\misc\documentation\*"
$locationFromJARIUnicodePDF = $baseLocation + "BaseJARIRelease\unicode\x64-msoft-win64\server\misc\documentation\*"
$locatonFromHTML = $baseLocation + "BaseRelease\web\HTML5*"

#Directories to copy To (BASE)
$locationToJADEMASTERPDF = $baseLocation
$locationToJADEMASTERHTML = $baseLocation
$locationToEncryptedPDF = $baseLocation
$locationToEncryptedHTML = $baseLocation
$locationToJARIAnsiPDF = $baseLocation
$locationToJARIUnicodePDF = $baseLocation


# Check to see if doing monthly or initial release
Write-Host "Checking to see if doing monthly release.   Please wait..."
if (Test-Path $baseLocation"Monthly") {
    Write-Host "Getting the latest release directory.  Please wait..."
    $latestDirectory = Get-ChildItem -Path $baselocation"Monthly" -Directory | sort -Descending -Property Name | select -first 1 name
   
    $locationToJADEMASTERPDF = $locationToJADEMASTERPDF + "Monthly\" + $latestDirectory.Name + "\"
    $locationToJADEMASTERHTML = $locationToJADEMASTERHTML + "Monthly\" + $latestDirectory.Name + "\"
    $locationToEncryptedPDF = $locationToEncryptedPDF + "Monthly\" + $latestDirectory.Name + "\JMT" + $latestDirectory.Name + "\"
    $locationToEncryptedHTML = $locationToEncryptedHTML + "Monthly\" + $latestDirectory.Name + "\JMT" + $latestDirectory.Name + "\"
    $locationToJARIAnsiPDF = $locationToJARIAnsiPDF + "Monthly\" + $latestDirectory.Name + "\JARI_JMT" + $latestDirectory.Name + "\"
    $locationToJARIUnicodePDF = $locationToJARIUnicodePDF + "Monthly\" + $latestDirectory.Name + "\JARI_JMT" + $latestDirectory.Name + "\"
} else {
    $locationToJARIAnsiPDF = $locationToJARIAnsiPDF + "JARI\JARI_JMT" + $release + "\"
    $locationToJARIUnicodePDF = $locationToJARIUnicodePDF + "JARI\JARI_JMT" + $release + "\"
    $locationToEncryptedPDF = $locationToEncryptedPDF + "JMT842\"
    $locationToEncryptedHTML = $locationToEncryptedHTML + "JMT842\"
}

$locationToJADEMASTERPDF = $locationToJADEMASTERPDF + "JadeMaster\documentation"
$locationToJADEMASTERHTML = $locationToJADEMASTERHTML + "JadeMaster\web"
$locationToEncryptedPDF = $locationToEncryptedPDF + "documentation"
$locationToEncryptedHTML = $locationToEncryptedHTML + "web"
$locationToJARIAnsiPDF = $locationToJARIAnsiPDF + "ansi\x64-msoft-win64\server\misc\documentation"
$locationToJARIUnicodePDF = $locationToJARIUnicodePDF + "unicode\x64-msoft-win64\server\misc\documentation"


#Copy files to the appropriate locations

#JADEMASTER
Write-Host "Copying PDF Documentation from"$locationFromNonJARIPDF" to "$locationToJADEMASTERPDF".  Please wait..."
Copy-Item -Path $locationFromNonJARIPDF -Destination $locationToJADEMASTERPDF -Force -Recurse 
Write-Host "Copying HTML Documentation from"$locatonFromHTML" to "$locationToJADEMASTERHTML".  Please wait..."
Copy-Item -Path $locatonFromHTML -Destination $locationToJADEMASTERHTML -Force -Recurse 

#ENCRYPTED
Write-Host "Copying PDF Documentation from"$locationFromNonJARIPDF" to "$locationToEncryptedPDF".  Please wait..."
Copy-Item -Path $locationFromNonJARIPDF -Destination $locationToEncryptedPDF -Force -Recurse 
Write-Host "Copying HTML Documentation from"$locatonFromHTML" to "$locationToEncryptedHTML".  Please wait..."
Copy-Item -Path $locatonFromHTML -Destination $locationToEncryptedHTML -Force -Recurse 

#JARI
Write-Host "Copying PDF Documentation from"$locationFromNonJARIPDF" to "$locationToJARIAnsiPDF".  Please wait..."
Copy-Item -Path $locationFromNonJARIPDF -Destination $locationToJARIAnsiPDF -Force -Recurse
Write-Host "Copying PDF Documentation from"$locatonFromHTML" to "$locationToJARIUnicodePDF".  Please wait..."
Copy-Item -Path $locationFromJARIUnicodePDF -Destination $locationToJARIUnicodePDF -Force -Recurse');

	file.close;
	
epilog
	delete file;
end;</source>
        <Parameter name="_directory" type="String"/>
        <Parameter name="_fileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="xPowerShellSetupScheduleTask" id="ca920a94-7d06-4490-a10f-d0734af5daf0">
        <source>xPowerShellSetupScheduleTask(_directory, _fileName : String);

/*

Purpose:		Setup the scehduled task for the copying of the documetnation

Date			Who		Reason
07/04/2016		cnwmh5	Initial creation

*/

constants

	TASKDIRECTORY				: String = "C:\Windows\System32\Tasks";
	TASKDESCRIPTION				: String = "Copy Release Documentation";

vars

	file						: File;
	
	args						: StringArray;

	text 						: String;
	result						: Integer;
	fileToRun					: String;
	
begin

	fileToRun := _directory &amp; "/" &amp; _fileName;

	text := '&lt;?xml version="1.0" encoding="UTF-16"?&gt;
&lt;Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task"&gt;
  &lt;RegistrationInfo&gt;
    &lt;Date&gt;2016-04-05T09:56:48.0134995&lt;/Date&gt;
    &lt;Author&gt;CNW\cnwmh5&lt;/Author&gt;
    &lt;Description&gt;' &amp; TASKDESCRIPTION &amp; '&lt;/Description&gt;
  &lt;/RegistrationInfo&gt;
  &lt;Triggers&gt;
    &lt;CalendarTrigger&gt;
      &lt;StartBoundary&gt;2016-04-05T03:00:00&lt;/StartBoundary&gt;
      &lt;Enabled&gt;true&lt;/Enabled&gt;
      &lt;ScheduleByMonthDayOfWeek&gt;
        &lt;Weeks&gt;
          &lt;Week&gt;1&lt;/Week&gt;
        &lt;/Weeks&gt;
        &lt;DaysOfWeek&gt;
          &lt;Sunday /&gt;
        &lt;/DaysOfWeek&gt;
        &lt;Months&gt;
          &lt;January /&gt;
          &lt;February /&gt;
          &lt;March /&gt;
          &lt;April /&gt;
          &lt;May /&gt;
          &lt;June /&gt;
          &lt;July /&gt;
          &lt;August /&gt;
          &lt;September /&gt;
          &lt;October /&gt;
          &lt;November /&gt;
          &lt;December /&gt;
        &lt;/Months&gt;
      &lt;/ScheduleByMonthDayOfWeek&gt;
    &lt;/CalendarTrigger&gt;
  &lt;/Triggers&gt;
  &lt;Settings&gt;
    &lt;MultipleInstancesPolicy&gt;IgnoreNew&lt;/MultipleInstancesPolicy&gt;
    &lt;DisallowStartIfOnBatteries&gt;true&lt;/DisallowStartIfOnBatteries&gt;
    &lt;StopIfGoingOnBatteries&gt;true&lt;/StopIfGoingOnBatteries&gt;
    &lt;AllowHardTerminate&gt;true&lt;/AllowHardTerminate&gt;
    &lt;StartWhenAvailable&gt;false&lt;/StartWhenAvailable&gt;
    &lt;RunOnlyIfNetworkAvailable&gt;false&lt;/RunOnlyIfNetworkAvailable&gt;
    &lt;IdleSettings&gt;
      &lt;StopOnIdleEnd&gt;true&lt;/StopOnIdleEnd&gt;
      &lt;RestartOnIdle&gt;false&lt;/RestartOnIdle&gt;
    &lt;/IdleSettings&gt;
    &lt;AllowStartOnDemand&gt;true&lt;/AllowStartOnDemand&gt;
    &lt;Enabled&gt;true&lt;/Enabled&gt;
    &lt;Hidden&gt;false&lt;/Hidden&gt;
    &lt;RunOnlyIfIdle&gt;false&lt;/RunOnlyIfIdle&gt;
    &lt;WakeToRun&gt;false&lt;/WakeToRun&gt;
    &lt;ExecutionTimeLimit&gt;P3D&lt;/ExecutionTimeLimit&gt;
    &lt;Priority&gt;7&lt;/Priority&gt;
  &lt;/Settings&gt;
  &lt;Actions Context="Author"&gt;
    &lt;Exec&gt;
      &lt;Command&gt;'&amp; fileToRun &amp; '&lt;/Command&gt;
      &lt;Arguments&gt;' &amp; _directory &amp; '&lt;/Arguments&gt;
    &lt;/Exec&gt;
  &lt;/Actions&gt;
&lt;/Task&gt;';

	create file transient;
	file.fileName := "c:\temp\" &amp; TASKDESCRIPTION &amp; ".xml";

	if file.isAvailable() then
		file.purge();
	endif;
	
	file.writeLine(text);
	file.close();
	
	// Create the Scheduled Task
	create args transient;
	args.clear();
	args.add("/Create");
	args.add('/XML "' &amp; file.fileName &amp; '"');
	args.add('/TN "' &amp; TASKDESCRIPTION &amp; '"');
	args.add("/F");

	node.createExternalProcess(TASKDIRECTORY, "schtasks", args, null, true, true, result);

	if result &lt;&gt; 0 and result &lt;&gt; 4 then
		write "Failed to create Scheduled Task (" &amp; TASKDESCRIPTION &amp; ").  Result: " &amp; result.String;
		app.writeLog("Failed to create Scheduled Task (" &amp; TASKDESCRIPTION &amp; ").  Result: " &amp; result.String, LogINFO);
		return;
	endif;
	
epilog

	// delete the actual file

	delete file;
	delete args;

end;</source>
        <Parameter name="_directory" type="String"/>
        <Parameter name="_fileName" type="String"/>
    </JadeMethod>
</Class>
