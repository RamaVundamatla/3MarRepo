    <JadeMethod name="mpdGetClassProperties" id="59772391-d0eb-4a9b-92cf-1297634d5ee6">
        <source>mpdGetClassProperties();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 November 2021	navmd1	Initial creation

*/

vars
	prop		: Property;
	pDict		: PropertyNDict;
	
	mth			: Method;
	mDict		: MethodNDict;
	signature	: String;
	
	scm			: Schema;
	cls			: Class;
begin
	scm := rootSchema;
	cls := scm.getClass(WebSessionManager.name);
	//cls.inspect;
	write "*** " &amp; cls.name &amp; "/" &amp; cls.getOidAsString() &amp; " ***";
	write "^^^ " &amp; cls.getSuperclass().name &amp; " (super) ^^^";
	
	write "--- properties ---";
	pDict := cls.getPropertyValue('properties').PropertyNDict;

	foreach prop in pDict do
		write prop.name &amp; Tab &amp; prop.type.name &amp; Tab &amp; prop.cnEcGetAccessType();
	endforeach;
	
	write "--- methods ---";
	mDict := cls.getPropertyValue('methods').MethodNDict;
	
	foreach mth in mDict do
		signature := mth.display().replace__(CrLf, null, true).replace__(Tab, null, true);
		write mth.cnEcGetAccessType() &amp; Tab &amp; signature;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
