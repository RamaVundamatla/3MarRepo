        <source>delete() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.endNotificationForSubscriber(self);
	delete self.myVehicleMountedRTGAgent;
	delete self.myNotesObj;
epilog

end;</source>
