    <JadeMethod name="clearThumbnailData" id="52a718d1-753a-4737-bf6d-f24753dc6467">
        <updating/>
        <source>clearThumbnailData() updating;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//
//----------------------------------------------------------

vars
	theForm : SOP_TableMaintForm;
begin
	inheritMethod();
	theForm := self.myForm;
	theForm.tblInput1.clearValues();
	theForm.mulSelect1.setSelected(null);  	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="d5f83eb0-210e-4b9e-b46d-c4feb4fc2790">
