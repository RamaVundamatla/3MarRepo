    <JadeMethod name="setForCreate" id="e759a328-b3fe-43d5-bf7b-ac22c5889cf9">
        <updating/>
        <source>setForCreate(_proxy: SelfType) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17 Apr 2023	navdap1		TFS 57491 FR | 53667 - EUP - Inspection App Activity not visible in External Web Service Monitor
//
vars

begin
	inheritMethod(_proxy);
	
	self.request := _proxy.request;
	self.response := _proxy.response;
	self.responseCode := _proxy.responseCode;
	self.myVehicleBooking:=_proxy.myVehicleBooking; //jlier1 TFS 58839 3/7/23
epilog

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setMyVehicleBooking" id="fd834969-76e0-4010-bf9d-f68450f2b3cf">
