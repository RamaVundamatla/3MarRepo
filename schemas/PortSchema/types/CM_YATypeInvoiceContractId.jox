    <JadeMethod name="isSnapShotDataMatch" id="e5abd81c-a35b-41f6-a3ad-1f515ba57f10">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;
/*
Purpose:			

Date		Who		Reason
20JAN2023	NAVAB1	TFS CR 55625 TASK 56131
*/

vars

begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	if _criteria.myYAData.CM_YADataString.value = _propertyValue or
	   _criteria.myYAData.CM_YADataString.value = null then
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="37972182-ac2e-4aea-8040-f4e50d483066">
        <source>isStorageDetailMatch(_criteria: CM_YACriteria; _ti: CM_TrackedItem; _tiTrx: CM_TITransaction): Boolean;
/*
Purpose:			

Date		Who		Reason
20 January 2023	navab1	TFS CR 55625 TASK 56131
*/

vars
	conid : String;
begin
	if _tiTrx &lt;&gt; null then	
		conid := _tiTrx.contractId;
	elseif _ti &lt;&gt; null then
		conid := _ti.contractId;
	endif;
	
	return _criteria.myYAData.CM_YADataString.doesValueMatch( conid);

epilog

end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
