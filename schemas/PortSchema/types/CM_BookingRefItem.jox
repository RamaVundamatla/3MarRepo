    <JadeMethod name="handleInvalidClass" id="625b9be2-cebb-4b9f-96c5-0cc77a8e3457">
        <source>handleInvalidClass(_exc : Exception) : Integer;
/*

Purpose:			TFS 8098

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2017	jlgab1	Initial creation

*/

constants
	InvalClass	= 1046;
	InvalidClass = 1086;
	InvalidAddress = 8;
vars
	returnVal		: Integer;
	aForm : Form;
begin
	returnVal := Ex_Pass_Back;
	
	if _exc.errorCode = InvalClass 
	or _exc.errorCode = InvalidClass
	or _exc.errorCode = InvalidAddress then
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;
epilog
	return returnVal;
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
