    <JadeMethod name="addSelectedUserTerminals" id="a8225033-dd4b-4656-8fee-62e382441795">
        <updating/>
        <source>addSelectedUserTerminals( _selectedTerminals : CM_TerminalSet ) updating;
/* ---------------------------------------------------------------------------
Created:	20 May 2009	by cnwvu1

Purpose:	ccms 1080 - User Defined Cargo types.
			A user selects all terminals in the multi select box, Cargo Tyoes screen.
			All selected terminals are related to user's permissions.
			
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	term 			: CM_Terminal;
	userTerminals	: CM_TerminalByCodeDict;
	realCargoType	: CM_CargoType;
	
begin

	self.raiseExceptionIfNotTransient(method);
	
	realCargoType := app.myProxyManager.getRealObject(self).CM_CargoType;
	self.allTerminals.clear();
	if realCargoType &lt;&gt; null then
		realCargoType.allTerminals.copy(self.allTerminals);	// there are all terminals including unvisible for a user
	endif;
	
	create userTerminals transient;
	app.getMyUser.getTerminals(userTerminals);
	
	foreach term in userTerminals discreteLock do

		if not self.allTerminals.includes(term) and _selectedTerminals.includes(term) then
			self.allTerminals.add(term);	// terminal has been added by a user
			
		elseif self.allTerminals.includes(term) and not _selectedTerminals.includes(term) then
			self.allTerminals.remove(term);	// terminal has been removed by a user
			
		endif;
		
	endforeach;
	
epilog
	delete userTerminals;
	
end;</source>
        <Parameter name="_selectedTerminals" type="CM_TerminalSet"/>
    </JadeMethod>
    <JadeMethod name="calculateCargoVolume" id="c54e34ef-b35d-44d7-8f8e-becfe117a606">
        <source>calculateCargoVolume(_ti : CM_TrackedItem; _qty : Integer;  _pieces : Integer; _width,_length,_height,_volume : Decimal):Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2017	cnwma1	TFS #5695:STWO - Re-Calculate Volumes on Forms and EDI

*/

vars
	volume : Decimal [16,4];
begin
	
	if not self.allowAutoVolumeCalc then
		return _volume;
	endif;

	if _width = 0 or _length = 0 or _height = 0 then
		return _volume;
	endif;	
	
  //Formula Used
  //---------------TotalVolume = (H*W*L)*Quantity Pieces * Total Quantity ------------------
 
	if _ti &lt;&gt; null then
		
	else
		// we want the volume for a specific number of these items calculated
		volume := (_height/100 *_width/100 * _length/100) * _pieces.max(1) * _qty.max(1);
	endif;

	return volume;
epilog
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_qty" type="Integer"/>
        <Parameter name="_pieces" type="Integer"/>
        <Parameter name="_width" type="Decimal"/>
        <Parameter name="_length" type="Decimal"/>
        <Parameter name="_height" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
