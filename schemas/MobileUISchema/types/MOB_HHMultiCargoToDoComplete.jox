    <JadeMethod name="setupTables" id="9d5bfe09-1965-4011-a86b-263b6791ff6f">
        <source>setupTables();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2015	cnwndl1	Initial creation	Par 36993

*/

vars

begin

	self.tblAvailable.columns := 1;
	self.tblAvailable.fixedColumns := 0;
	self.tblAvailable.fixedRows := 1;
	self.tblAvailable.accessColumn(1).inputType := Table.InputType_None;
	self.tblAvailable.selectMode := Table.SelectMode_WholeRows;
	self.tblAvailable.setCellText(1,1, app.getErrorString(Available) );
	self.tblAvailable.sortColumn[1] := 1;
	
	self.tblSelected.columns := 1;
	self.tblSelected.fixedColumns := 0;
	self.tblSelected.fixedRows := 1;
	self.tblSelected.accessColumn(1).inputType := Table.InputType_None;
	self.tblSelected.selectMode := Table.SelectMode_WholeRows;
	self.tblSelected.setCellText(1,1, app.getErrorString(Selected) );
	self.tblSelected.sortColumn[1] := 1;
	
	self.resetColumnHeadings();

epilog

end;</source>
    </JadeMethod>
