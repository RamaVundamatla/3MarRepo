    <JadeMethod name="getDetailForRemoteQuery" id="2bd1a3b0-c6b7-46c8-bb04-424935a97876">
        <source>getDetailForRemoteQuery() : String;

vars
	response	: String;
	

begin

	response := inheritMethod();

	return response &amp; 
		   self.speciesCode &amp; ',' &amp; 
		   self.gradeCode &amp; ',' &amp; 
		   self.typeCode &amp; ',' &amp; 
		   self.treatmentCode &amp; ',' &amp; 
		   self.lengthCode &amp; ',';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="7e390349-1ef7-478c-b3df-930ebab30feb">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     13 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _attrName = ETRow_MyLogLength or _attrName = ETRow_LogLengthCode then
		return self.lengthCode;
	elseif _attrName = ETRow_MyLogTreatment or _attrName = ETRow_LogTreatmentCode then
		return self.treatmentCode;
	elseif _attrName = ETRow_LogSpecies or _attrName = ETRow_LogSpeciesCode then
		return self.speciesCode;
	elseif _attrName = ETRow_MyLogType or _attrName = ETRow_LogTypeCode then
		return self.typeCode;
	elseif _attrName = ETRow_MyLogGrade or _attrName = ETRow_LogGradeCode then
		return self.gradeCode;
	endif;
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoOLD" id="22f83001-dd76-4244-994e-2b7d5b175d69">
        <source>getExtraInfoOLD(_array: HugeStringArray input);
//--------------------------------------------------------------
//Created: 07 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	_array.add("Specifications" &amp; Tab &amp; self.code);
end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSGTT" id="db14f36c-c59e-4b31-afd6-9d70231d01bf">
        <source>getSGTT() : String;
// ---------------------------------------------------------------------------
// Created:     24 March 2004	cnwth2
//
// Purpose:     Used in reports - DO NOT DELETE - 
//				Needed for grouping in the JRW
//			 
// ----------   ----------  --------------------------------------------------
vars
	str			: String;
begin
	str := self.speciesCode &amp; ':' &amp; self.gradeCode &amp; ':' &amp; self.typeCode &amp; ':' &amp; self.treatmentCode;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
