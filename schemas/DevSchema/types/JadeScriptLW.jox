    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="camsRunNotAdhoc" id="f1284c01-dc94-4104-b6f8-8857a811d4fa">
        <source>camsRunNotAdhoc();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On		By			Reason
// ----------		--------	-----------------------------------------------------------------------
// 27 Sept 2023		navlw1		Initial creation TFS 
//
constants
	Terminal1 : String = 'LWT';
vars
	terminal : CM_Terminal;
	bgpRequest : BGP_CamsRequest;
begin
	app.initialize;
	terminal := app.myRoot.allTerminals[Terminal1];
	if terminal = null then
		app.writeStatement('Can not find required terminal ' &amp; Terminal1);
		return;
	endif;
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	app.changeLogLevel(LogDEBUG);
	create bgpRequest transient;
	bgpRequest.setPropertyValue(BGP_CamsRequest::myTerminal.name, terminal);
	bgpRequest.setPropertyValue(BGP_CamsRequest::myUser.name, app.myPassport.myUser);
	bgpRequest.action();
epilog
	delete bgpRequest;
end;</source>
    </JadeMethod>
    <JadeMethod name="collectionOrdering" id="9e9beb6a-cb27-47dd-ae50-4d4d6a796da9">
        <updating/>
        <source>collectionOrdering() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2025	navlw1	Initial creation

*/
constants
	Terminal1 : String = 'LWT';
	Terminal12 : String = 'DP1';
	Terminal13 : String = 'PW';
vars
	nexIndex,
	currIndex,
	totalCount,
	idx						: Integer;
	iter					: Iterator;
	theText,
	item					: Object;
	selectedCollection 		: DynaDictionary;
	parentCol				: ObjectArray;
	terminal 				: CM_Terminal;
	topIdx 					: Integer;
begin
	app.initialize;
	
	create selectedCollection transient;
	create parentCol transient;
	
	selectedCollection.setMembership(Object);
	selectedCollection.addExternalKey(Integer, null, false, false);
	selectedCollection.endKeys(false);
	
	terminal := app.myRoot.allTerminals[Terminal1];
	parentCol.add(terminal);
	
	terminal := app.myRoot.allTerminals[Terminal12];
	selectedCollection.putAtKey(2,terminal);
	parentCol.add(terminal);
	
	terminal := app.myRoot.allTerminals[Terminal13];
	selectedCollection.putAtKey(3,terminal);
	parentCol.add(terminal);
	
	// reorder the collection
	// put terminal2 to the top
	topIdx := 1;
	iter := selectedCollection.createIterator;
	while iter.next(terminal) do
		iter.getCurrentKeys(idx);
		parentCol.removeAt(idx); //current position
		parentCol.insert(topIdx, terminal); // should be first item?
		topIdx += 1;
	endwhile;
	
	// remove the item
	//selectedCollection.removeAt(2); //current position
	//selectedCollection.insert(1, theText); // should be first item?
	
epilog
	delete selectedCollection;
	delete parentCol;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="createUsers" id="76658345-7583-4726-ade5-eeecb023a55a">
        <source>createUsers();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Nov 2025	navlw1	JIRA-36674: UE 96966 When Initialising Root

*/
vars
  releaseController 	: CnEcReleaseController;
  portSchemaRelease  	: PortSchema_24_0_26;

begin
  create portSchemaRelease transient;
  create releaseController transient;
  
  portSchemaRelease.createInternalUsers(releaseController);
  portSchemaRelease.createJMTSupportUser(releaseController);

epilog
  delete portSchemaRelease;
  delete releaseController;

end;</source>
    </JadeMethod>
    <JadeMethod name="lwDeleteOperators" id="f2a6855d-4aa1-4213-bf8c-8ec75bace1a6">
        <source>lwDeleteOperators();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
29 January 2024	navlw1	delete operators that have been created multiple times

*/

vars
	klass		: Class;
	operator 	: CM_Operator;
	scm 		: Schema;
	dsl			: Object;
begin
	app.initialize;
	scm := rootSchema.getSchema("JMTUnitTest");
	klass := scm.getClass("UT_DSL");
	if klass = null then
		return;
	endif;
	
	create dsl as klass transient;
	dsl.sendMsg("setActiveProfileMDHONLY");

	foreach operator in app.myRoot.allOperators do 
		if operator.code &lt;&gt; "7C97" and operator.description = "TFS53854EUP" then
			dsl.sendMsgWithParams("deleteOperator", operator.code);
		endif;
	endforeach;
epilog
	delete dsl;
end;</source>
    </JadeMethod>
    <JadeMethod name="setInwardsCodeAutoToNull" id="ec2eff3b-abba-4d26-a939-39f52a7e4079">
        <source>setInwardsCodeAutoToNull();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 November 2024	navlw1	Initial creation

*/

vars
	voyage : CM_Voyage;
begin
	beginTransaction;
	voyage := "4480.2945176".asOid.CM_Voyage;
	if voyage &lt;&gt; null then
		voyage.setPropertyValue(CM_Voyage::inwardCodeAuto.name, null);
	endif;
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
</Class>
