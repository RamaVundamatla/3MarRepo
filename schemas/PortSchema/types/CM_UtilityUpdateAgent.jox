        <source>utlUpdateHookCode(_cmifHook : CMIF_HookCode; _passport : CM_Passport input);
// -------------------------------------------
// Created 07 February 2005 by cnwdvb1
// -------------------------------------------
vars

	realHookCode,
	proxyHookCode	: CM_HookCode;
	expectedEdition	: Integer;

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	_cmifHook.setForUpdate();
	
	proxyHookCode := _cmifHook.myProxyHookCode;
	
	app.myValUA.valHookCode(proxyHookCode);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	proxyHookCode.pxyGetRealObjectAndEdition(realHookCode, expectedEdition);
	if realHookCode.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'HookCode', null, null);
		return;
	endif;
	
	self.exclusiveLock(realHookCode);
	
	realHookCode.setForUpdate(proxyHookCode);
	
end;</source>
