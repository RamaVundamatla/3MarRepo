    <JadeMethod name="trxUpdateSubTerminalDefaults" id="a7733892-0451-4f39-a6be-a2572ae2d20b">
        <updating/>
        <source>trxUpdateSubTerminalDefaults(_terminalObj:CM_Terminal;
							_isTurnedOn:Boolean;
							_wasTurnedOn:Boolean;		//cnwdad1 21/07/2009 - PAR #20325.
							_isAreaDefined:Boolean; // 26 Nov 2014	NDL	Par 35295
							_stForExportFullObj:CM_SubTerminal;
							_stForExportMTYObj:CM_SubTerminal;
							_stForImportFullObj:CM_SubTerminal;
							_stForImportMTYObj:CM_SubTerminal;
							_stForStorageFullObj:CM_SubTerminal;
							_stForStorageMTYObj:CM_SubTerminal;
							_stForImportGenObj:CM_SubTerminal;
							_stForExportGenObj:CM_SubTerminal;
							_stForStorageGenObj:CM_SubTerminal;
							_stForCargoOtherObj:CM_SubTerminal;
							_stForSourceBulkRdObj:CM_SubTerminal;	// cnwdad1 PAR 22205.
							_stForSourceBulkRlObj:CM_SubTerminal;	// cnwdad1 PAR 22205.
							_stForSourceBulkShObj:CM_SubTerminal;	// cnwdad1 PAR 22205.
							_stForSourceBulkPkObj:CM_SubTerminal;	// cnwdad1 PAR 22205.
							_stForTargetBulkObj:CM_SubTerminal;
							_stForBOLInwardsObj:CM_SubTerminal;
							 _stForDelReq:CM_SubTerminal;			// 31 OCT 2022 NAVSKS20 TFS 52721
							_isAllowChangeInSubTerm:Boolean; 		// 31 OCT 2022 NAVSKS20 TFS 52721
							_passportObj:CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		07 April 2009 by cnwdad1
//
// Purpose:		Transaction to set the Sub-Terminal Options for the specified Terminal.
//
//	NOTE: The first time that Sub-Terminals are turned on, the system needs to take
//	the default Sub-Terminals and update all on-site TI's, all Pre-Notes and all
//	active Voyages.  Suffice to say, it will be a long transaction and should only
//	be done when no other activity is going on in JMT.
//
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 27/01/2010	cnwdad1		PAR 22205 (CCMS POL 1904).  Added extra Bulk Release
//							Sub-Terminal parameters.
// --------------------------------------------------------------------------------
begin
	// Always initialize the activity first.
	self.initialiseActivityWithPassport(_passportObj, method);

	// Arm our base exception handlers.
	on Exception do agtPassportExHandler(exception, _passportObj);
	on LockException do agtPassportLockExHandler(exception, _passportObj);

	beginTransaction;

	app.myUtilityUA.utlUpdateSubTerminalDefaults(_terminalObj,
												_isTurnedOn,
												_wasTurnedOn,
												_isAreaDefined,	//26 Nov 2014	NDL	Par 35295
												_stForExportFullObj,
												_stForExportMTYObj,
												_stForImportFullObj,
												_stForImportMTYObj,
												_stForStorageFullObj,
												_stForStorageMTYObj,
												_stForImportGenObj,
												_stForExportGenObj,
												_stForStorageGenObj,
												_stForCargoOtherObj,
												_stForSourceBulkRdObj,	// cnwdad1 PAR 22205.
												_stForSourceBulkRlObj,	// cnwdad1 PAR 22205.
												_stForSourceBulkShObj,	// cnwdad1 PAR 22205.
												_stForSourceBulkPkObj,	// cnwdad1 PAR 22205.
												_stForTargetBulkObj,
												_stForBOLInwardsObj,
												_stForDelReq,			// 31 OCT 2022 NAVSKS20 TFS 52721
												_isAllowChangeInSubTerm,// 31 OCT 2022 NAVSKS20 TFS 52721
												_passportObj);
epilog	
	self.finaliseActivityWithPassport(_passportObj);
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_isTurnedOn" type="Boolean"/>
        <Parameter name="_wasTurnedOn" type="Boolean"/>
        <Parameter name="_isAreaDefined" type="Boolean"/>
        <Parameter name="_stForExportFullObj" type="CM_SubTerminal"/>
        <Parameter name="_stForExportMTYObj" type="CM_SubTerminal"/>
        <Parameter name="_stForImportFullObj" type="CM_SubTerminal"/>
        <Parameter name="_stForImportMTYObj" type="CM_SubTerminal"/>
        <Parameter name="_stForStorageFullObj" type="CM_SubTerminal"/>
        <Parameter name="_stForStorageMTYObj" type="CM_SubTerminal"/>
        <Parameter name="_stForImportGenObj" type="CM_SubTerminal"/>
        <Parameter name="_stForExportGenObj" type="CM_SubTerminal"/>
        <Parameter name="_stForStorageGenObj" type="CM_SubTerminal"/>
        <Parameter name="_stForCargoOtherObj" type="CM_SubTerminal"/>
        <Parameter name="_stForSourceBulkRdObj" type="CM_SubTerminal"/>
        <Parameter name="_stForSourceBulkRlObj" type="CM_SubTerminal"/>
        <Parameter name="_stForSourceBulkShObj" type="CM_SubTerminal"/>
        <Parameter name="_stForSourceBulkPkObj" type="CM_SubTerminal"/>
        <Parameter name="_stForTargetBulkObj" type="CM_SubTerminal"/>
        <Parameter name="_stForBOLInwardsObj" type="CM_SubTerminal"/>
