    <JadeMethod name="checkSQLColumnPositions" id="577d4b92-5cd3-45a1-bd1b-4a23018a44f5">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>checkSQLColumnPositions() : String updating, serverExecution;
//
//   Check the Column Positions from the SQL tables
//   Returns a string with the results
//
constants
	PositionMisMatch   : String = " mis match";
	PositionOK         : String = " OK";
vars

	xdbAgent            : CM_ExternalDatabaseAgent;
	sqlTable            : CM_DataDumpExtractClass;
	sqlColumn           : CM_DataDumpSQLColumn;
	extDB               : ExternalDatabase;
	dropStoredProcString: String;
	getColPositionString: String;
	columnPos           : Integer;
	returnString        : String;
begin
	app.initialize;
	extDB := app.getExternalDatabase(JMT_SQLNative.getName);

	create xdbAgent transient;

	xdbAgent.openDb(JMT_SQLNative, self.edbConnectionString, self.getPwForUse(null), 
			self.edbServerName, self.edbUserName, self.edbMachineDSN);	

	dropStoredProcString      := xdbAgent.buildDropStoredProcString("getColumnOrdinalPosition");
	getColPositionString      := xdbAgent.buildGetColumnPosStoredProc();

	xdbAgent.myExternalDatabase.executeSQL(dropStoredProcString);
	xdbAgent.myExternalDatabase.executeSQL(getColPositionString);

	returnString := self.description &amp; CrLf;
	foreach sqlTable in self.allDataDumpExtractClasses do

		if sqlTable.myDataDumpExtractDef.oidColumnName &lt;&gt; null then
			columnPos := xdbAgent.getColumnOrdinalPosition(sqlTable.sqlTableName, sqlTable.myDataDumpExtractDef.oidColumnName);
			returnString := returnString &amp; sqlTable.sqlTableName &amp; " : " &amp;  sqlTable.myDataDumpExtractDef.oidColumnName &amp; " " &amp; columnPos.String;
			if columnPos = sqlTable.oidColumnPos then
				returnString := returnString &amp; PositionOK &amp; CrLf;
			else
				returnString := returnString &amp; PositionMisMatch &amp; CrLf;
			endif;
		endif;

		if sqlTable.lastOperationColumnName &lt;&gt; null then
			columnPos := xdbAgent.getColumnOrdinalPosition(sqlTable.sqlTableName, sqlTable.lastOperationColumnName);
			returnString := returnString &amp; sqlTable.sqlTableName &amp; " : " &amp;  sqlTable.lastOperationColumnName &amp; " " &amp; columnPos.String;
			if columnPos = sqlTable.lastOperationColumnPos then
				returnString := returnString &amp; PositionOK &amp; CrLf;
			else
				returnString := returnString &amp; PositionMisMatch &amp; CrLf;
			endif;
		endif;

		if sqlTable.exportedTimestampColumnName &lt;&gt; null then
			columnPos := xdbAgent.getColumnOrdinalPosition(sqlTable.sqlTableName, sqlTable.exportedTimestampColumnName);
			returnString := returnString &amp; sqlTable.sqlTableName &amp; " : " &amp;  sqlTable.exportedTimestampColumnName &amp; " " &amp; columnPos.String;
			if columnPos = sqlTable.exportedTimestampColumnPos then
				returnString := returnString &amp; PositionOK &amp; CrLf;
			else
				returnString := returnString &amp; PositionMisMatch &amp; CrLf;
			endif;
		endif;

		if sqlTable.deleteActionColumnName &lt;&gt; null then
			columnPos := xdbAgent.getColumnOrdinalPosition(sqlTable.sqlTableName, sqlTable.deleteActionColumnName);
			returnString := returnString &amp; sqlTable.sqlTableName &amp; " : " &amp;  sqlTable.deleteActionColumnName &amp; " " &amp; columnPos.String;
			if columnPos = sqlTable.deleteActionColumnPos then
				returnString := returnString &amp; PositionOK &amp; CrLf;
			else
				returnString := returnString &amp; PositionMisMatch &amp; CrLf;
			endif;
		endif;

		foreach sqlColumn in sqlTable.allDataDumpSQLColumns do
			columnPos := xdbAgent.getColumnOrdinalPosition(sqlTable.sqlTableName, sqlColumn.name);
			returnString := returnString &amp; sqlTable.sqlTableName &amp; " : " &amp;  sqlColumn.name &amp; " " &amp; columnPos.String;
			if columnPos = sqlColumn.sqlColumnOrdinalPosition then
				returnString := returnString &amp; PositionOK &amp; CrLf;
			else
				returnString := returnString &amp; PositionMisMatch &amp; CrLf;
			endif;
		endforeach;
	endforeach;

	return returnString;

epilog
	delete xdbAgent;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createExtractClass" id="a360ed95-0a9c-447a-82d9-5fbe78cb0c9b">
        <source>createExtractClass(_proxyExtractClass: CM_DataDumpExtractClass) : CM_DataDumpExtractClass;
// ---------------------------------------------------------------------------
// Created:     26 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	cls : CM_DataDumpExtractClass;
	
begin
	create cls persistent;
	cls.setForCreate(_proxyExtractClass);
	self.allDataDumpExtractClasses.add(cls);
	
	return cls;
end;</source>
        <Parameter name="_proxyExtractClass" type="CM_DataDumpExtractClass"/>
        <ReturnType type="CM_DataDumpExtractClass"/>
    </JadeMethod>
    <JadeMethod name="createExtractHistory" id="5e453793-7bb2-4d69-ba93-5eb3f8eb2476">
        <source>createExtractHistory(_extractClass: CM_DataDumpExtractClass;
		_extractedFromDateTime, _extractedUpToTs, _startTs, _finishTs: TimeStamp;
		_numCreates, _numUpdates, _numDeletes: Integer;
		_systemAlertCreated: Boolean; _userCode, _userName: String; _deleteOids, _addOids, _updateOids : StringArray) : CM_DataDumpExtractHistory;
// ---------------------------------------------------------------------------
// Created:     28 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	hist : CM_DataDumpExtractHistory;

begin
	create hist persistent;
	hist.setForCreate(_extractClass, _extractedFromDateTime, _extractedUpToTs, _startTs, _finishTs,
			_numCreates, _numUpdates, _numDeletes, _systemAlertCreated,
			_userCode, _userName, _deleteOids, _addOids, _updateOids);
	self.allDataDumpExtractHistory.add(hist);
	
	return hist;
end;</source>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass"/>
        <Parameter name="_extractedFromDateTime" type="TimeStamp"/>
        <Parameter name="_extractedUpToTs" type="TimeStamp"/>
        <Parameter name="_startTs" type="TimeStamp"/>
        <Parameter name="_finishTs" type="TimeStamp"/>
        <Parameter name="_numCreates" type="Integer"/>
        <Parameter name="_numUpdates" type="Integer"/>
        <Parameter name="_numDeletes" type="Integer"/>
        <Parameter name="_systemAlertCreated" type="Boolean"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_userName" type="String"/>
        <Parameter name="_deleteOids" type="StringArray"/>
        <Parameter name="_addOids" type="StringArray"/>
        <Parameter name="_updateOids" type="StringArray"/>
        <ReturnType type="CM_DataDumpExtractHistory"/>
    </JadeMethod>
    <JadeMethod name="createSQLTablesAndStoredProcs" id="d94107b0-df7e-4e2a-a4a3-fdaf58961850">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>createSQLTablesAndStoredProcs(_tableName : String) serverExecution, updating;
//
//   Build All SQL Tables (or just 1) and place them into the SQL Database
//   This runs as a server execution, so the SQL DB must be on the server machine
//
vars

	sqlTable         : CM_DataDumpExtractClass;
	xdbAgent         : CM_ExternalDatabaseAgent;
	returnString     : String;
	dropString       : String;
	extDB            : ExternalDatabase;
begin

	extDB := app.getExternalDatabase(JMT_SQLNative.getName);

	create xdbAgent transient;

	xdbAgent.openDb(JMT_SQLNative, self.edbConnectionString, self.getPwForUse(null), 
			self.edbServerName, self.edbUserName, self.edbMachineDSN);	

	foreach sqlTable in self.allDataDumpExtractClasses do
	
		if _tableName = null or _tableName = sqlTable.sqlTableName then

			dropString   := xdbAgent.buildDropTableString(sqlTable.sqlTableName);
			extDB.executeSQL(dropString);
			returnString := xdbAgent.buildCreateTableString(sqlTable);
			extDB.executeSQL(returnString);
		endif;

	endforeach;

	return;

epilog
	delete xdbAgent;
end;</source>
        <Parameter name="_tableName" type="String"/>
    </JadeMethod>
    <JadeMethod name="doChangeOIDFormat" id="499f66b7-ca9c-4249-af7e-728a304a33cb">
        <source>doChangeOIDFormat(_proxyExtractDef : CM_DataDumpExtractDef);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	#cnwdz2	 

*/

vars
	extractClass : CM_DataDumpExtractClass;
	sqlColumn : CM_DataDumpSQLColumn;
	feature : CM_DataDumpFeature;
	oidFormat : String;
	oidLength : String;
begin
	foreach extractClass in _proxyExtractDef.allDataDumpExtractClasses do
		foreach sqlColumn in extractClass.allDataDumpSQLColumns do	
			feature := sqlColumn.myDataDumpFeature;
			if feature.isObjectType() then
			   if _proxyExtractDef.oidFormat = CM_DataDumpExtractDef.OIDFormatHex then
					oidFormat := CM_DataDumpSQLDataType.SQLBinary;
					oidLength := CM_DataDumpSQLDataType.SQL_OIDBinaryLength;
			   elseif _proxyExtractDef.oidFormat = CM_DataDumpExtractDef.OIDFormatString then
					oidFormat := CM_DataDumpSQLDataType.SQLNVarChar;
					oidLength := CM_DataDumpSQLDataType.SQL_OIDStringLength;
			   endif;
			   sqlColumn.changeOIDFormat(app.myRoot.allDataDumpSQLDataTypes[oidFormat.toUpper()], oidLength.asIntegerJMT());
			endif;		
		endforeach;
	endforeach;
epilog

end;</source>
        <Parameter name="_proxyExtractDef" type="CM_DataDumpExtractDef"/>
    </JadeMethod>
    <JadeMethod name="doChangeSQLServerVersion" id="6a6c8a3e-a8bb-442d-8953-6c30cfe2cfb3">
        <source>doChangeSQLServerVersion(_proxyExtractDef : CM_DataDumpExtractDef);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	#cnwdz2	 24815

*/

vars
	extractClass   : CM_DataDumpExtractClass;
	sqlColumn      : CM_DataDumpSQLColumn;
	feature        : CM_DataDumpFeature;
	featureTypeName : String;
begin
	foreach extractClass in _proxyExtractDef.allDataDumpExtractClasses do
		foreach sqlColumn in extractClass.allDataDumpSQLColumns do	
			feature := sqlColumn.myDataDumpFeature;
			featureTypeName := feature.getFeatureTypeName();
			if featureTypeName.toUpper() = CM_DataDumpFeature.JadeType_Date then
				if _proxyExtractDef.sqlServerVersion = CM_DataDumpExtractDef.SQLVersion2008 then
					sqlColumn.changeSQLDataType(CM_DataDumpSQLDataType.SQLDate);
				else			
					sqlColumn.changeSQLDataType(CM_DataDumpSQLDataType.SQLDateTime);
				endif;
				
			elseif featureTypeName.toUpper() = CM_DataDumpFeature.JadeType_Time then							
				if _proxyExtractDef.sqlServerVersion = CM_DataDumpExtractDef.SQLVersion2008 and
				   sqlColumn.isEqualToSQLDataType(CM_DataDumpSQLDataType.SQLDateTime) then
						sqlColumn.changeSQLDataType(CM_DataDumpSQLDataType.SQLTime);
				endif;
				
				if (_proxyExtractDef.sqlServerVersion = CM_DataDumpExtractDef.SQLVersion2005 or 
				   _proxyExtractDef.sqlServerVersion = CM_DataDumpExtractDef.SQLVersion2000) and
				   sqlColumn.isEqualToSQLDataType(CM_DataDumpSQLDataType.SQLTime) then
						sqlColumn.changeSQLDataType(CM_DataDumpSQLDataType.SQLDateTime);
				endif;
				
			elseif featureTypeName.toUpper() = CM_DataDumpFeature.JadeType_TimeStamp then							
				if _proxyExtractDef.sqlServerVersion = CM_DataDumpExtractDef.SQLVersion2008 and
				   sqlColumn.isEqualToSQLDataType(CM_DataDumpSQLDataType.SQLDateTime) then
						sqlColumn.changeSQLDataType(CM_DataDumpSQLDataType.SQLDateTime2);
				endif;
				
				if (_proxyExtractDef.sqlServerVersion = CM_DataDumpExtractDef.SQLVersion2005 or 
				   _proxyExtractDef.sqlServerVersion = CM_DataDumpExtractDef.SQLVersion2000) and
				   sqlColumn.isEqualToSQLDataType(CM_DataDumpSQLDataType.SQLDateTime2) then
						sqlColumn.changeSQLDataType(CM_DataDumpSQLDataType.SQLDateTime);
				endif;
			endif;
		endforeach;
	endforeach;
epilog

end;</source>
        <Parameter name="_proxyExtractDef" type="CM_DataDumpExtractDef"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="52d0bca2-cbf1-4e1d-b85e-610166e7c4e5">
