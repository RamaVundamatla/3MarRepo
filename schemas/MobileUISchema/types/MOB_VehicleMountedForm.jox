	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2010	cnwer1	Initial creation

*/

vars
	dtoEntry : DTO_RTQueueEntry;
begin
	if _table = self.tblDirector then
		if self.myMachine.currentQueueTask &lt;&gt; null then
			dtoEntry:=app.myVMAgent.findDTOEntryByRTQueueEntry(self.myMachine.currentQueueTask.myEntry);
		endif;
		if dtoEntry = null then
			return CM_RTVehicleConfig.DIRECTOR_FEILDS;
		endif;
		if dtoEntry &lt;&gt; null and dtoEntry.isForDirectorTask then
			return CM_RTVehicleConfig.DIRECTOR_FEILDS;
		else
			return CM_RTVehicleConfig.CARGO_FEILDS;
		endif;
	endif;
	
	if _table = self.tblTasks then
		if self.isEnquiryMode or self.btnVoyDischarge.value then
			return CM_RTVehicleConfig.CARGO_FEILDS;
		else
			return CM_RTVehicleConfig.QENTRY_FIELDS;
		endif;
	endif;
	
	if _table = self.tblMoveInfo then
		if self.isEnquiryMode or self.myMachine.currentQueueTask  = null then
			return CM_RTVehicleConfig.CARGO_FEILDS;
			
		else
			return CM_RTVehicleConfig.QENTRY_FIELDS;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTandemCargoID" id="a910e14c-6f4c-41da-ab7c-5cd0b1b64328">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_VehicleMountedDetails::getTandemCargoID"/>
        </interfaceImplements>
        <source>getTandemCargoID() : String;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwer1	Initial creation

*/

vars
	twinId : String;
	row : Integer;	
	accessCell : JadeTableCell;
begin
	 //epr par 34682 4/8/14 getDataForEntRowName returns false if row not visible we need value regardless because now this row might be hidden
	if app.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen  then
		row:=self.myMoveTableDetails.findRowWithEntRowName(ETRow_CargoID);
		if row &gt;  0 then
			accessCell:=self.myMoveTableDetails.myTable.accessCell(row,5);
			if accessCell &lt;&gt; null then
				if accessCell.itemObject &lt;&gt; null then
					return accessCell.itemObject.getOidString; //epr TFS 6863 14/9/17 so breakbulk works correctly
				endif;
			endif;
		endif;
	endif;
	
	
	row:=self.myMoveTableDetails.findRowWithEntRowName(ETRow_TwinID);
	if row &gt;  0 then
		accessCell:=self.myMoveTableDetails.myTable.accessCell(row,self.myMoveTableDetails.dataColumn);
		if accessCell &lt;&gt; null then
			if accessCell.itemObject &lt;&gt; null then
				return accessCell.itemObject.getOidString; //epr TFS 6863 14/9/17 so breakbulk works correctly			
			endif;
		endif;
	endif;

	
	if self.btnTandem.value then
		row:=self.myMoveTableDetails.findRowWithEntRowName(ETRow_TandemID);
		if row &gt;  0 then
			accessCell:=self.myMoveTableDetails.myTable.accessCell(row,self.myMoveTableDetails.dataColumn);
			if accessCell &lt;&gt; null then
				if accessCell.itemObject &lt;&gt; null then
					return accessCell.itemObject.getOidString; //epr TFS 6863 14/9/17 so breakbulk works correctly
				endif;
			
			endif;
		endif;
	endif;
	
	return null;

epilog
	self.myMoveTableDetails.setDataColumn(DataColumn);
end;</source>
