<Class name="CnEcReleaseController">
    <JadeMethod name="checkPatchReleaseNumber" id="f5eff493-a95c-4368-b99b-2ac20643e345">
        <source>checkPatchReleaseNumber(_class : Class; _patchNumber : String; _currentRelease, _currentPatch : String) : Boolean;
// ---------------------------------------------------------------------------
// Created:     Sept 2008 par17878
//
// Purpose:     Process the a specific method on a release class.
//
// Parameters:  pClass - The release class to create.
//				pMethodName - The method on pClass to run.
//				pMasterObj - The history master object for the current release.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	currReleaseMajor		: Integer;
	currReleaseMinor		: Integer;
	currReleaseInternal		: Integer;

	nextReleaseMajor		: Integer;
	nextReleaseMinor		: Integer;
	nextReleaseInternal		: Integer;

	isSuccessful			: Boolean;
			
begin
	self.logEntry('Checking patch release for class (' &amp; _class.name &amp; '). Patch (' &amp; _patchNumber &amp; ').  Current version is (' &amp; _currentRelease &amp; ')');

	if _currentRelease &lt;&gt; null then
		if (not self.splitVersionString(_currentRelease, '.', currReleaseMajor, currReleaseMinor, currReleaseInternal)) then
			// need exception
			self.logEntry('Error in splitting current release version (' &amp; _currentRelease &amp; ' ' &amp; _currentPatch &amp; ')');
			return false;
		endif;
	else
		currReleaseMajor	:= 0;
		currReleaseMinor	:= 0;
		currReleaseInternal	:= 0;
	endif;
	
	if (not self.getVersionFromClassName(_class.name, nextReleaseMajor, nextReleaseMinor, nextReleaseInternal)) then
		return false;
	endif;
	self.logEntry('Actual patch release is ('&amp;nextReleaseMajor.String&amp;' '&amp;nextReleaseMinor.String&amp;' '&amp;nextReleaseInternal.String&amp;')');
	
	if currReleaseMajor = 0 and
	   currReleaseMinor = 0 and
	   currReleaseInternal = 0 then
		self.logEntry('Invalid current release for patch (' &amp; _currentRelease &amp; ')');
		return false;
	endif;

	// Must be on the same major/minor and internal release for a patch release
	if currReleaseMajor &lt;&gt; nextReleaseMajor or
	   currReleaseMinor &lt;&gt; nextReleaseMinor or
	   currReleaseInternal &lt;&gt; nextReleaseInternal   then
		self.logEntry('Invalid release version class (' &amp; _class.name &amp; ') for current version (' &amp; _currentRelease &amp; ')');
		return false;
	endif;
	
	//epr TFS 336 - monthly release stuff
	if _patchNumber.startsWith("-") then
		//checking that this version is less than the patchVersion passed in
		if  _currentPatch.Integer &gt;= _patchNumber[2:end].Integer then
			self.logEntry('Invalid patch release version, current version ' &amp; _currentRelease&amp;_currentPatch &amp; ' must be less than  ' &amp; _patchNumber[2:end]);
			return false;
		endif;
	else 
		//must be equal
		if	_currentPatch.Integer &lt;&gt; _patchNumber.Integer then
			self.logEntry('Invalid patch release version class (' &amp; _class.name &amp; ') for current version (' &amp; _currentRelease &amp; ')');
			return false;
		endif;
	endif;
	isSuccessful := true;
epilog
	return isSuccessful;
end;
</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_patchNumber" type="String"/>
        <Parameter name="_currentRelease" type="String"/>
        <Parameter name="_currentPatch" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
