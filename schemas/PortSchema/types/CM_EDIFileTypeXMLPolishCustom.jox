    <JadeMethod name="create" id="7953deea-5ce7-47c9-a274-b415f4908bcb">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------
//	Created:	Dec 2007 cnwrs1
//----------------------------------------------------------------
vars

begin
	self.name := "Polish Customs";
	self.type := EDIFileType_XML_Polish_Customs;
end;</source>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="13f01102-d34c-4d43-80e6-df4ddcee7c58">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010
//----------------------------------------------------------------
//	Created:	Dec 2007 cnwrs1
//----------------------------------------------------------------
vars
	ediData : CM_EDIData;

begin
	_ediDataClass := CM_EDIDataCustomStop;
	_dataType := EDIDataType_CustomStop;
	_fileTypeCode := self.type;
end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
