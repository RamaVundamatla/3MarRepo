    <JadeMethod name="addToolbarControls" id="de805f38-0895-46d9-a95d-7de82e410779">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	22 January 2004 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
01 Apr 2008	cnwkpd1	PAR #16384 - add Extract Table option

*/

vars
	toolbar		: CMUI_Toolbar;
	
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnFind, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExportCSVTV, CMUI_Toolbar.Control_Alignment_Left);	// PAR #16374
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

end;</source>
        <access>protected</access>
    </JadeMethod>
