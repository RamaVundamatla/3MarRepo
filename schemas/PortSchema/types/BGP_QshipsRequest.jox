    <JadeMethod name="processQshipsRequest" id="d697168d-cbd9-4053-8d5c-fb01a8726032">
        <updating/>
        <source>processQshipsRequest() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 September 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description
07/12/2022		jlika1		55722		MTN - 1090 Error on Running Qships BGP.
01/03/2023		jlika1		56881		POB - QShips - BGP Not Processing QShip Tasks.
21/03/2023		jlika1		57111		POB - 1090 Error Stops QShips Data Loading to EDI Operations
29/03/2023		jlika1		57276		POB | QShips - Manual Load of XML EDI file
01/05/2023		jlika1		57800		MTN - QShips POST message not shown in External Web Service Monitor form
05/12/2024		navmd1		MTN-33527	Include pre-transformed message on EDI file
21/02/2025		navdap1		MTN-34063	POB | QSHIPS - Voyage Loaded to DB in EDI Operations but No Record of Voyage in Voyage Enquiry
****************************************************/

vars
	pxyActivity 		: CM_EWSActivityQships;
	activity			: CM_EWSActivityQships;
	webService 			: CM_QshipsWebServiceDef;	
	loginResponse		: Qships_LoginResponse;
	agent				: CM_QshipsConsumerAgent;
	invalid 			: Boolean;
	sessionKey			: String;	
	domainId			: Integer;
	voyages				: Qships_GetVoyageExportDataByDomainAndDatesResponse;
	loginResult			: Qships_FullInfo;
	infoKey				: Qships_SessionKey;
	resultString 		: String;
	terminal			: CM_Terminal;
	lastSuccessfullTS	: TimeStamp;
	edifile				: CM_EDIFile;
	loginResultStr		: String;
	requestString		: String;
	tmpStatus			: Integer;
	interfaceName		: String;
	extWebDef			: CM_ExternalWebServiceDef;
	alertMsg			: String;
begin
	
	foreach extWebDef in app.myRoot.allExternalWebServices discreteLock where extWebDef.active do
		if extWebDef.isKindOf(CM_QshipsWebServiceDef)  then
			webService := extWebDef.CM_QshipsWebServiceDef;
			break;
		endif;
	endforeach;  
		
	if webService = null then		
		alertMsg :=  app.getErrorString1(Service_not_been_setup,  "QSHIPS");
		self.createAlert(alertMsg, SEVERE_INFO);		
		return;
	endif;
	
	interfaceName := webService.name;
	
	terminal :=  self.myTerminal;
	
	if terminal.myHarbour = null then		
		alertMsg := app.getErrorString(Termina_default_harbour_null);
		self.createAlert(alertMsg, SEVERE_INFO);				
		return;
	endif;
	
	if terminal.myHarbour.defaultDepartBerth = null then
		alertMsg := app.getErrorString(Termi_harbo_defau_depar_berth);
		self.createAlert(alertMsg, SEVERE_INFO);				
		return;
	endif;						
	
	create pxyActivity transient;		
	pxyActivity.initialiseActivity("Start BGP Instance", interfaceName, terminal, null, "G", QshipsInterface.name, null, null);
		
	activity := app.myTrxCA.trxCreateEWSActivityHistory(pxyActivity,app.myPassport).CM_EWSActivityQships;	
	delete pxyActivity;	
	
	on Exception do app.handleException11052( exception, invalid );
	
	//Mockup Request string as we are sending our request directly using the Interface
	requestString := '&lt;?xml version="1.0" encoding="utf-8"?&gt;
						&lt;soap:Envelope xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/"&gt;
						  &lt;soap:Body&gt;
							&lt;Login xmlns="http://kleinsystem.com/webservices/"&gt;
							  &lt;aUser&gt;' &amp; webService.userCode &amp; '&lt;/aUser&gt;
							  &lt;aPasswd&gt;**********&lt;/aPasswd&gt;
							  &lt;aClientType&gt;' &amp; webService.clientType.asStringJMT &amp; '&lt;/aClientType&gt;
							  &lt;aVersion&gt;'&amp; webService.serviceVersion &amp;'&lt;/aVersion&gt;
							&lt;/Login&gt;
						  &lt;/soap:Body&gt;
						&lt;/soap:Envelope&gt;';
	
	create pxyActivity transient;		
	pxyActivity.initialiseActivity("Qships Login Request", interfaceName, terminal, null, "G", QshipsInterface.name, null, null);
	pxyActivity.setRequest(requestString);
	activity := app.myTrxCA.trxCreateEWSActivityHistory(pxyActivity,app.myPassport).CM_EWSActivityQships;	
	delete pxyActivity;
	
	create agent transient;
	agent.setupFromWebServiceDefinition(webService);
	loginResponse := agent.login();
	
	if invalid then		
		app.writeLog(BGP_QshipsRequest.InvalidCredentials, LogINFO);		
		if activity &lt;&gt; null then		
			app.writeLog(BGP_QshipsRequest.InvalidCredentials, LogINFO);
			if activity &lt;&gt; null then		
				app.myTrxUA.trxUpdateEWSActivityStatus(activity, BGP_QshipsRequest.Status_BGP_Sent_Failure, app.myPassport);	
			endif;	
		endif;
	elseif loginResponse &lt;&gt; null then			
		loginResult := loginResponse.loginResult;
		if activity &lt;&gt; null then 
			if loginResult = null then	
				app.myTrxUA.trxUpdateEWSActivityStatus(activity, BGP_QshipsRequest.Status_BGP_NoData, app.myPassport);	
			else
				if loginResult.infoKey &lt;&gt; null then
					loginResultStr := "Session Key: " &amp; loginResult.infoKey.sESSION_KEY &amp; CrLf &amp; "Domain Id: " &amp; loginResult.infoKey.dOMAIN_ID.String;
				else
					loginResultStr := "No Session Key or Domain Id returned - loginResult.infoKey is null";
				endif;
				
				app.myTrxUA.trxUpdateEWSActivityResponse(activity, loginResultStr, HttpResponseOK, app.myPassport);
			endif;
		endif;
		if loginResult &lt;&gt; null then 
			infoKey := loginResult.infoKey;
			if infoKey &lt;&gt; null then
				sessionKey := infoKey.sESSION_KEY;
				domainId := infoKey.dOMAIN_ID;	
				lastSuccessfullTS := webService.lastSuccessfullTS;
				voyages := agent.getVoyageExportDataByDomainAndDates(sessionKey, domainId, lastSuccessfullTS, webService, terminal);								
				resultString := voyages.getVoyageExportDataByDomainAndDatesResult;
				
				edifile := self.processResponse(resultString, null, webService, lastSuccessfullTS, terminal);	
				
				if edifile &lt;&gt; null and edifile.ediData &lt;&gt; null then					
					edifile.ediData.verifyAll();
					app.myPassport.setWarningsAcknowledged(true);	// MTN-34063
					app.myPassport.setWarningsIgnored(true);		// MTN-34063
					edifile.ediData.loadDB(true, app.myPassport);			
					
					tmpStatus := edifile.ediData.getStatusAfterVerifyOrDBLoad(false, app.myPassport);	
					if tmpStatus &lt;&gt; 0 then
						app.myTrxUA.trxSetEDIDataStatusAfterVerify(edifile.ediData, tmpStatus);	
					endif;
				endif;
			endif;	
		endif;		
	endif;	
	
epilog
	delete agent;	
	delete pxyActivity;
end;</source>
    </JadeMethod>
    <JadeMethod name="processResponse" id="c36809c6-30dd-4523-81cd-177480a01ed6">
        <updating/>
        <source>processResponse(_response, _transformedResponse : String; _webService : CM_QshipsWebServiceDef io; _lastSuccessfullTS : TimeStamp; _terminal : CM_Terminal) : CM_EDIFile updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 08 November 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description
07/12/2022		jlika1		55722		MTN - 1090 Error on Running Qships BGP.
24/01/2023		jlika1		56261		MTN - 1090 error on Verifying QShips EDI file - Error occur when it is an Add mode and there should be an Arrival and Departure Movement.
08/02/2023		jlika1		56453		MTN - QShips - Shift movements completely ignored
21/03/2023		jlika1		57199		POB - QSHIPs Messages Overwritten Each Time a New One Is Received.
29/03/2023		jlika1		57276		POB | QShips - Manual Load of XML EDI file
18/07/2024      navsp1      63842       ChangeRequest 63842: NSW | OnePort Integration Dev
05/12/2024		navmd1		MTN-33527	Include pre-transformed message on EDI file
****************************************************/

vars
	xmlDoc 				: JadeXMLDocument;
	element 			: JadeXMLElement;
	ediDataVoyage		: CM_EDIData;
	ediFile				: CM_EDIFile;	
	filePath			: String;
	tempFilePath		: String;	
	ediFileType			: CM_EDIFileType;//CM_EDIFileTypeXMLQShipsVoyage;
	timeStamp			: String;
	passport			: CM_Passport;
begin
	if _response &lt;&gt; null then
		create xmlDoc transient;
		xmlDoc.parseString(_response);				
		element := xmlDoc.getElementByTagName("NewDataSet");
		
		if element &lt;&gt; null then
			
			// Get a unique file path for this run.
			tempFilePath := app.getTempDirectoryFromSysConfig(); 
			
			app.checkTempDirFolderPath(tempFilePath, method.qualifiedName, CMIF_ConfigRoot.class.name &amp; '::' &amp; CMIF_ConfigRoot::systemTempDir.name );
			
			timeStamp := app.actualTimeAppServer.time.format("HHmmss");
			
			filePath := tempFilePath &amp; "GetVoyageExportDataByDomainAndDates"&amp;timeStamp&amp;".xml" ;	
									
			ediFileType := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_XMLQShipsVoyage, null).CM_EDIFileTypeXMLQShipsVoyage;
			
			passport := app.myPassport;
			
			app.myTrxCA.trxCreateEDIPortAuthVoyage(_webService, _lastSuccessfullTS, _terminal, ediFile, ediFileType, ediDataVoyage, filePath, _response, _transformedResponse, passport);		//TFS 63842 - TRX method renamed from 'trxCreateEDIQshipsVoyage'									
			
			return ediFile;
		endif;		
	endif;			
	
	return null;
	
epilog
	delete xmlDoc;	
end;</source>
        <Parameter name="_response" type="String"/>
        <Parameter name="_transformedResponse" type="String"/>
        <Parameter name="_webService" type="CM_QshipsWebServiceDef" usage="io"/>
        <Parameter name="_lastSuccessfullTS" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_EDIFile"/>
    </JadeMethod>
</Class>
