    <JadeMethod name="isFlatRackStatus_Match" id="ee1f323c-2bc8-4907-95c3-3ae5a28c5578">
        <source>isFlatRackStatus_Match(_yaData: CM_YADataPattern): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/11/2019	jlgdap1		Initial creation TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
//
vars

begin
	if _yaData.pattern = null or not self.myTrackedItem.isContainer then
		return true;
	endif;
	
	return _yaData.pattern = app.flatRackEndsEnumToString(self.myTrackedItem.CM_Container.getFlatRackStatus).toUpper;
epilog

end;</source>
