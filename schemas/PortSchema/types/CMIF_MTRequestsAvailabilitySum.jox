    <JadeMethod name="task01Display" id="88a3a774-0e09-4d0f-8219-dbbf95396207">
        <source>task01Display():String;
//----------------------------------------------------------------
//	Created:	10 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.awaitingTask01 = 0 
	and self.inAreaTask01 = 0 then
		return null;
	endif;
	
	return self.awaitingTask01.String &amp; "/" &amp; self.inAreaTask01.String;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
