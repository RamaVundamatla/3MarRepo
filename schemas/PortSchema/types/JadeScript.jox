				if kinerja.isToPhysical(hmsMove) then
					kinerja.setSTBerthWorkingTM(hmsMove);
					//kinerja.inspectModal();
				endif;
			endforeach;
		endif;
	endif;
	

epilog
	delete kinerja;
end;</source>
