    <JadeMethod name="create" id="2934a2d3-4c40-416d-9997-deaf3599bba9">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		19 May 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isTransient() then
		create self.myLocaleInfo transient;
		create self.myRemoteLocaleInfo transient;
	else
		create self.myLocaleInfo;
		create self.myRemoteLocaleInfo;
	endif;
	
	self.setLocaleInfo(null);
	self.setRemoteLocaleInfo(null);
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="5f1cc505-e1e7-4d6f-b0e0-ec4fffec3e27">
        <updating/>
        <source>delete() updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	delete self.myLocaleInfo;
	delete self.myRemoteLocaleInfo;
end;</source>
    </JadeMethod>
    <JadeMethod name="getCurrencyFormat" id="4820161b-89f3-4d52-b0ca-31682a64b021">
        <source>getCurrencyFormat(pCurrencyFormatObj:CurrencyFormat io; pIsLocal:Boolean);
// --------------------------------------------------------------------------------
// Created:		25 December 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pIsLocal then
		self.myLocaleInfo.myCurrencyFormat.getCurrencyFormat(pCurrencyFormatObj);
	else
		self.myRemoteLocaleInfo.myCurrencyFormat.getCurrencyFormat(pCurrencyFormatObj);
	endif;
end;</source>
        <Parameter name="pCurrencyFormatObj" type="CurrencyFormat" usage="io"/>
        <Parameter name="pIsLocal" type="Boolean"/>
    </JadeMethod>
