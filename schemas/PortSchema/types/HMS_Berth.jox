        <source>isVisibleOnView(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     25 October 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
