    <JadeMethod name="setForCreate" id="1527e042-8efc-4992-b5c9-b594af0b5313">
        <updating/>
        <source>setForCreate(_pxyEventStreamDef : CM_EventStreamDefinition) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars

begin

	self.setForUpdate(_pxyEventStreamDef);
	
epilog

end;</source>
        <Parameter name="_pxyEventStreamDef" type="CM_EventStreamDefinition"/>
