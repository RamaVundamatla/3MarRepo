    <JadeMethod name="tp022_GIOF_tblExtra_click" id="41cebd17-fc7b-4e51-82a5-524ff4d9d1d6">
        <updating/>
        <source>tp022_GIOF_tblExtra_click():Integer updating;

vars
	tblExtra:Table;
	cmbConsignee:ComboBox;
begin
	tblExtra:=myGTE_InOutForm_2.getPropertyValue('tblExtra').Table.getControl(1);
	tblExtra.row:=52;
	tblExtra.column:=2;
	tblExtra.clearAllSelected;
	tblExtra.accessCell(52,2).selected:=true;
	tblExtra.rowColumnChg(tblExtra);
	tblExtra.accessCell(28, 2).text:='3333';
	tblExtra:=myGTE_InOutForm_2.getPropertyValue('tblExtra').Table.getControl(1);
	tblExtra.mouseDown(tblExtra, 1, 0, 184, 227);
	app.doWindowEvents(shortPause);
	tblExtra:=myGTE_InOutForm_2.getPropertyValue('tblExtra').Table.getControl(1);
	tblExtra.setFocus;
	app.doWindowEvents(shortPause);
	cmbConsignee:=myGTE_InOutForm_2.getPropertyValue('cmbConsignee').ComboBox.getControl(1);
	tblExtra:=myGTE_InOutForm_2.getPropertyValue('tblExtra').Table.getControl(1);
	tblExtra.row:=52;
	tblExtra.column:=2;
	cmbConsignee.gotFocus(cmbConsignee);
	tblExtra:=myGTE_InOutForm_2.getPropertyValue('tblExtra').Table.getControl(1);
	tblExtra.mouseUp(tblExtra, 1, 0, 184, 227);
	app.doWindowEvents(shortPause);
	tblExtra:=myGTE_InOutForm_2.getPropertyValue('tblExtra').Table.getControl(1);
	app.doWindowEvents(shortPause);
	tblExtra.row:=52;
	tblExtra.column:=2;
	tblExtra.click(tblExtra);  // 16:06:19
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
