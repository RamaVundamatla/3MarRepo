    <JadeMethod name="doSave" id="54f1ed35-cd0c-4dfa-818c-7ac5aeaed406">
        <updating/>
        <source>doSave()updating;
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
*/

vars
	pxyCustDocDetail : CM_CustomDocumentDetail;
	ti, myTrackedItem : CM_TrackedItem;
	myCMIFCustDocDetail : CMIF_CustomDocumentDetail;
	theReturn : Integer;
	storageDetail : CM_StorageDetail;
	weight, volume : Decimal [23,4];
	quantity : Integer;
	includeMainDtl : Boolean;
begin
	
	// put in the main detail
	pxyCustDocDetail := self.myProxyDetail;
	
	if self.txtClearedVolume.enabled = true then
		volume := self.txtClearedVolume.getConvertedValue();
	else
		volume := self.myCustDocDetail.clearedVolume;
	endif;
	if self.txtClearedWeight.enabled = true then
		weight := self.txtClearedWeight.getConvertedValue();
	else
		weight := self.myCustDocDetail.clearedWeight;
	endif;
	if self.txtClearedQuantity.enabled = true then
		quantity := self.txtClearedQuantity.text.Integer;
	else
		quantity := self.myCustDocDetail.clearedQuantity;
	endif;
	includeMainDtl := self.chkIncludeDetail.value;
	pxyCustDocDetail.setProxyTransfers(weight,volume,quantity,includeMainDtl); 

	if self.mode = CMUI_CustomDocsMaint.Cargo_Review_Mode then
		self.unloadForm();
		return;
	endif;
	
	create myCMIFCustDocDetail transient;
	// put all the sub items in, whether 'included' or not.
	self.allCustomDetails.copy(myCMIFCustDocDetail.allProxyCustDocDetails);
	myCMIFCustDocDetail.allProxyCustDocDetails.add(pxyCustDocDetail);
	
	while true do
		app.myTrxUA.trxUpdateCustDocsDetails(myCMIFCustDocDetail,app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			self.createProxies();
			self.displaySubDetails();
			break;
		else
			theReturn := app.showErrorWarningDialog("Cust Doc Detail", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				  theReturn = IDOK then
				  // there must have just been warnings that the user has acknoledged so ..
				  app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
			
		break;
	endwhile;
	

epilog
	delete myCMIFCustDocDetail;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectAll" id="96b9098f-5663-4998-9229-8f5b00d29198">
        <source>doSelectAll();
/*
Purpose:			

Date		Who		Reason
22 August 2023	navab1	CR 59615 TASK 59620
//20.07.2024 navrv30 Bug 64858: MTN - Ownership Change Maint - Select All issues
*/

vars
	col, row : Integer;
	include : Boolean;
begin

	if self.tblData.rows = self.tblData.fixedRows then
		return;
	endif;
	
	include := self.chkSelectAll.value;
	col := self.tblData.getColumnByRowName(ETRow_IncludeChk);
	if col  &gt; 0 then
	
		foreach row in self.tblData.fixedRows + 1 to self.tblData.rows do
				self.tblData.accessRow(row);
				self.tblData.accessCell(row,col);
				self.tblData.accessedCell.text := include.cnReturnTickDisplayValue();
		endforeach;
	endif;
	
	self.displayContentTotals(self.myCustDocDetail);  // ### TFS CR 60424 TASK 60549 26SEP2023 NAVAB1 custDocDetail);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSetSelectAll" id="ac1ff82b-f2fd-4a5c-a5d3-81d1b78b9f85">
        <source>doSetSelectAll();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//20.07.2024 navrv30 Bug 64858: MTN - Ownership Change Maint - Select All issues

*/

vars
	col, row : Integer;	
	uncheck : Boolean;
begin

	if self.tblData.rows = self.tblData.fixedRows then
		return;
	endif;
	
	self.chkSelectAll.value := false;
	col := self.tblData.getColumnByRowName(ETRow_IncludeChk);
	
	if col  &gt; 0 then	
		foreach row in self.tblData.fixedRows + 1 to self.tblData.rows do
			if self.tblData.accessCell(row, 1).text = "0" then
				uncheck := true;
				break;
			endif;
		endforeach;
		if not uncheck then
			self.chkSelectAll.value := true;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblDatalContexMenu" id="abda138b-ac4b-4f94-aa99-d179fa447d85">
        <updating/>
        <source>doTblDatalContexMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
*/

vars
	canEdit		: Boolean;
	x1,
	y1			: Real;
begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	self.mnuColumnOrganiser.visible := true;
	self.mnuInspectObject.visible := app.isAllowedToInspect();  // ### TFS 60004 24AUG2023 NAVAB1
	self.mnuColumnOrganiser.userObject := self.tblData;
	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="f0887018-91d8-4575-a9d4-029a868de028">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
*/

vars
	theXML : String;
begin
	theXML := inheritMethod();
