    <JadeMethod name="uRunJMTBackup" id="8830016b-111d-4f5a-8384-1a68670a1d1d">
        <source>uRunJMTBackup();
/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
12/01/2016	cnwndl1	Par 37296	Initial creation	
16/04/2019	jlgka1	43863		Added Recurring Value default in existing unit test.
============================================================================*/

constants	
	DummyBackupPath 	: String = "f:\backupUnitTest";  // this is on the env server
	BgpManagerName 		: String = "UT_BGP_MANAGER";
	TaskDefName 		: String = "UT_JMTBACKUP";
	ScheduleName 		: String = "UT BACKUP";	
	RecurValue 			: Integer = 1; 					// jlgka1 TFS 43863
vars
	autoTask 			: CM_AutoTask;
	pxyAutoTask 		: CM_AutoTaskBackupDB;
	autoSchedule		: CM_AutoSchedule;
	ts 					: TimeStamp;
	tmpClass 			: Class;
	bgpController 		: BGP_Controller;
	request 			: BGP_Request;
	bgpManager 			: BGP_Manager;
	proxyCMIF 			: CMIF_BGPManagerChildren;
	deleted 			: Boolean;
	backUpConfigObj 	: CM_Backup;
	existingBackupPath 	: String;
	waitingToStartCount : Integer;
	waitingToEndCount 	: Integer;
	moreSleep 			: Boolean;
	sleepTime 			: Integer;
begin

	backUpConfigObj := app.myRoot.myBackup;  // has all the default settings
	self.assertTrueMsg( backUpConfigObj &lt;&gt; null, "No backup object found in test set up" );
	
	existingBackupPath := backUpConfigObj.dbBackupPath;
	self.setBackupPath( backUpConfigObj, DummyBackupPath );
		
	// create task ( a template with the parameters of what to run )
	autoTask := app.myRoot.allAutoTasks[BGP_BackupDB.name, TaskDefName];
	if autoTask &lt;&gt; null then
		autoSchedule := autoTask.allAutoSchedules.first;
		app.myTrxDA.trxDeleteAutoTask(autoTask, app.myPassport);
		self.assertTrueMsg( not app.myPassport.hasErrorsOrWarnings, "Failed to delete existing auto task '" &amp; TaskDefName &amp; "' in test set up. " &amp;  app.myPassport.getErrorsAndWarningsAsString );
	endif;
	
	create pxyAutoTask transient;
	pxyAutoTask.setValueForRow(ETRow_BgpAutoDescription,TaskDefName);
	pxyAutoTask.setValueForRow(ETRow_BgpAutoUser, app.myRoot.allUsers["ADMIN"]);
	app.myTrxCA.trxCreateAutoTask(pxyAutoTask, autoTask, app.myPassport);
	self.assertTrueMsg( autoTask &lt;&gt; null, "Failed to create new auto task '" &amp; TaskDefName &amp; "' in test set up" );
	
	// create a Schedule for the task.
	ts := app.cnGetServerTime();
	ts.date.addDays(-1);
	ts.setTime("00:00:00".Time);
	autoSchedule := self.addAutoSchedule(ScheduleName, ts, RecurValue); // jlgka1 TFS 43863
	beginTransaction;
	autoSchedule.allAutoTasks.add(autoTask);
	commitTransaction;
	
	app.setIsBackGroundApp(true);
	
	bgpManager := app.myRoot.allBGPManagers[BgpManagerName];
	if bgpManager = null then
		//create a BGP Manager with a controller capable of running this sort of task
		self.opts.purge();
		self.opts.addAssoc("IsServer", true);
		bgpManager := self.addBGPManager(BgpManagerName);
	endif;
	self.assertNotNull(bgpManager);
	
	create proxyCMIF transient;
	proxyCMIF.allClasses.add(BGP_BackupDB.name);
	proxyCMIF.myUser := app.myRoot.allUsers["ADMIN"];
	
	bgpController := bgpManager.allBGPControllers.first;
	app.myTrxUA.trxUpdateBGPControllerSetup(bgpController, proxyCMIF, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// start the bgp manager and its controller
	bgpManager.startBackGroundApp(bgpController, false);
	
	//give the manager and controller a chance to get running
	process.sleep(30000);
	
	//Create the actual request, it should be found by the controller, and started
	tmpClass := self.getClass(autoTask.requestClassName);
	self.assertNotNull(tmpClass);
	app.myTrxCA.trxCreateBGPRequestFromTask(tmpClass, request, autoTask, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg( request &lt;&gt; null, "No request created - check Alerts for reason" );
	
	while true do
		if request.processingStartTime.date.isValid then
			break;
		endif;
		waitingToStartCount := waitingToStartCount + 1;
		process.sleep(5000);	//5 seconds
		if waitingToStartCount &gt; 20 then
			self.assertTrueMsg( false, "Request failed to start processing within 100 seconds. Test aborted" );
			break;
		endif;
	endwhile;
	
	//The request should has started - check for the precesnce of the backup.htm flle
	self.assertTrueMsg( self.backupFileExists(), "No file found when request running!" );
	
	on Exception do app.handleDeletedObject( exception, request, deleted );
	
	waitingToEndCount := 1;
	while not deleted and request &lt;&gt; null do
		waitingToEndCount := waitingToEndCount + 1;
		process.sleep(300000);	//5 minutes;
		if request.isProcessed or request.isAlerted then
			break;
		endif;
		if waitingToEndCount &gt; 18 then
			self.assertTrueMsg( false, "Request failed to complete processing within 90 minutes. Test aborted" );
			break;
		endif;
	endwhile;
	
	//The request should now be finished - check for the NON precesnce of the backup.htm flle
	self.assertTrueMsg( not self.backupFileExists(), "File still present after request completed!" );
	
epilog

	delete pxyAutoTask;
	delete proxyCMIF;

	if backUpConfigObj.dbBackupPath &lt;&gt; existingBackupPath and existingBackupPath &lt;&gt; null then
		self.setBackupPath( backUpConfigObj, existingBackupPath );
	endif;
	
	if autoTask &lt;&gt; null then
		app.myTrxDA.trxDeleteAutoTask(autoTask, app.myPassport);
	endif;
	
	if autoSchedule &lt;&gt; null then
		self.deleteAutoSchedule( ScheduleName, ts );
	endif;

	if bgpManager &lt;&gt; null then	
		bgpManager.terminateProcessing(app.myPassport.userCode);
		while true do
			moreSleep := false;
			foreach bgpController in bgpManager.allBGPControllers do
				if bgpController.isRunning then
					moreSleep := true;
					break;
				endif;
			endforeach;
			if not moreSleep then
				break;
			endif;
			process.sleep(5000);	//5 seconds
			sleepTime := sleepTime + 5;
			if sleepTime &gt; 120 then
				self.assertTrueMsg( false, "slept for 2 minutess, at least one controller still running, bail" );
				return;
			endif;
		endwhile;
		
		self.deleteBGPManager(BgpManagerName);
		
	endif;
	
end;
</source>
    </JadeMethod>
