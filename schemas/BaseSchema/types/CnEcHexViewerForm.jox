    <JadeMethod name="displayHexData" id="af9b0c3a-0334-4b26-a4e2-56aad9bfe2f4">
        <source>displayHexData() protected;
// --------------------------------------------------------------------------------
// Created:		01 May 1999 by cnwdad1
//
// Purpose:		Populates the table with hex data.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj		: Table;
	pointer			: Integer;
	rowCount		: Integer;
	rowIndex		: Integer;
	columnCount		: Integer;
	columnIndex		: Integer;
	hexColumns		: Integer;
	cellPosition	: Integer;
	asciiString		: String;
	charByte		: Character;
	binaryChunk		: Binary;
	chunkSize		: Integer;

begin
	tableObj	:=	tblHexData;

	if (tableObj.tag.Integer &lt; 1) then
		pointer	:=	1;
	else
		pointer	:=	tableObj.tag.Integer;
	endif;

	chunkSize	:=	self.getChunkSize();

	if (chunkSize &gt; 0) then
		if ((pointer + chunkSize - 1) &gt; self.aBinaryData.length) then
			binaryChunk	:=	self.aBinaryData[pointer:end];
		else
			binaryChunk	:=	self.aBinaryData[pointer:chunkSize];
		endif;
	endif;

	rowCount	:=	tableObj.rows;
	columnCount	:=	tableObj.columns;
	hexColumns	:=	columnCount - 2;
	rowIndex	:=	1;

	while (rowIndex &lt;= rowCount) do
		asciiString	:=	'';
		tableObj.setCellText(rowIndex, 1, ((pointer + (hexColumns * rowIndex)) - hexColumns).String.padLeadingZeros(9));
		tableObj.cnEcSetCellBackColor(rowIndex, 1, Gray);

		if (hexColumns &gt; 0) then
			columnIndex	:=	2;

			while (columnIndex &lt;= (columnCount - 1)) do
				charByte		:=	null;
				cellPosition	:=	((rowIndex * hexColumns) - hexColumns) + (columnIndex - 1);

				if (cellPosition &lt;= binaryChunk.length) then
					charByte		:=	binaryChunk[cellPosition:1].Character;
				endif;

				tableObj.setCellText(rowIndex, columnIndex, charByte.toHex);

				if (asciiString.length = 0) then
					if (charByte.isPrintable) then
						asciiString	:=	charByte.String;
					else
						asciiString	:=	'.';
					endif;
				else
					if (charByte.isPrintable) then
						asciiString	:=	asciiString &amp; charByte.String;
					else
						asciiString	:=	asciiString &amp; '.';
					endif;
				endif;

				tableObj.cnEcSetCellBackColor(rowIndex, columnIndex, White);
				tableObj.cnEcSetCellForeColor(rowIndex, columnIndex, Blue);
				columnIndex	:=	columnIndex + 1;
			endwhile;
		endif;

		tableObj.setCellText(rowIndex, columnCount, asciiString);
		tableObj.cnEcSetCellBackColor(rowIndex, columnCount, LightYellow);
		tableObj.cnEcSetCellForeColor(rowIndex, columnCount, DarkBlue);
		rowIndex	:=	rowIndex + 1;
	endwhile;

	tableObj.clearAllSelected;
	lblOffset.caption	:=	pointer.userNumberFormat($CNEC_NO_DECIMALS);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="formSetup" id="1cf3cb1e-c160-439c-82ba-936dc3dd20a9">
        <updating/>
        <source>formSetup() updating, protected;
// --------------------------------------------------------------------------------
// Created:		30 April 1999 by cnwdad1
//
// Purpose:		Initializes the form setup.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: Table;
	colIndex	: Integer;
	colCount	: Integer;

begin
	if self.aAllowEditing then
		self.caption := "Hex Editer:" &amp; self.aDataDescription;
	else
		self.caption := "Hex Browser: " &amp; self.aDataDescription;
	endif;

	self.updateHexRowsAndColumns();

	tableObj			:=	tblHexData;
	tableObj.accessMode	:=	Table.AccessMode_Cell;
	tableObj.row		:=	1;
	tableObj.column		:=	1;
	tableObj.tag		:=	'1';
	vScrollHex.min		:=	1;
//	vScrollHex.max		:=	(self.binaryData.length div self.getChunkSize);

	self.displayHexData();
end;</source>
        <access>protected</access>
    </JadeMethod>
