    <JadeMethod name="getContentStatusAbbrev" id="37fc5a9b-bb8a-46a0-9374-2c0ee3458443">
        <updating/>
        <source>getContentStatusAbbrev() : String updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		28 April 2011
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// 28/04/2011	cnwsh3		PAR27423 - Add get abbreviation for reporting
//----------------------------------------------------------------------
vars
	contentStatus : CM_ContentsStatus;
begin
	contentStatus := app.myRoot.allContentsStatuses[self.contentsStatus];
	
	if contentStatus = null then
		return self.contentsStatus.String;
	endif;
	
	return contentStatus.abbreviation;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getContentsStatusDesc" id="7a569b5e-8bc6-490b-a016-abfcd2ff4fa7">
        <source>getContentsStatusDesc(_long : Boolean) : String;
// -------------------------------------------
// Created 21 February 2006 by cnwdvb1
// -------------------------------------------
vars

	contentsStatus : CM_ContentsStatus;

begin

	contentsStatus := app.myRoot.allContentsStatuses[self.contentsStatus];
	
	if contentsStatus = null then
		return self.contentsStatus.String;
	endif;
	
	if _long then
		return contentsStatus.description;
	else
		return contentsStatus.abbreviation;
	endif;

end;</source>
        <Parameter name="_long" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCountryOfDestRegion" id="704e09fd-5638-4f23-bd5e-3d295515d81e">
        <source>getCountryOfDestRegion() : CM_CountryRegion;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/08/2023	navkc1	CR 59594  Task 59584: Jade - CustDocs New YA Criteria

*/

vars
	country : CM_Country;
	region	: CM_CountryRegion;
begin
	
	country := self.getCountryOfDestination();
	
	if country &lt;&gt; null then
		region := country.myCountryRegion;
	endif;
	
	return region;
	
epilog

end;</source>
        <ReturnType type="CM_CountryRegion"/>
    </JadeMethod>
