    <JadeMethod name="doDelete" id="7c3b3b2d-7607-4c3b-a1c8-e2443f72c362">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	userResponse	: Integer;
	
begin
	while true do
 	 	app.myTrxDA.trxDeleteProductGroup(self.myCurrentObject.CM_ProductGroup, app.myPassport);
 	 	
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep();
			return true;
		else
			userResponse	:=	app.showErrorWarningDialog(	app.getErrorString(Cargo_Subtype_Groups),
															app.myPassport,
															ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors()
			and userResponse = IDOK
			then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:=	true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		
		break;
	endwhile;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
