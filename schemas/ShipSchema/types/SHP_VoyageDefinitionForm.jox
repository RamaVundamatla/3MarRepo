    <JadeMethod name="tblDelays_dblClick" id="6e8e09e6-77e0-4759-a478-3d7c1e21600d">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDelays_dblClick(table: Table input) updating;
//--------------------------------------------------
// Created:	27 October 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.mode = self.Mode_View										// 14/05/2012 cnwar2 #14987
	and app.myCurrentUserCan(self.myTerminal, PmHMSVoyageMaint) then	// 14/05/2012 cnwar2 #14987
		self.showVoyageDelayForm(true);
	endif;
end;</source>
