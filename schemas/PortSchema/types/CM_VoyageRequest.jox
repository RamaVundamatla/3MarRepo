    <JadeMethod name="getAttrCheckAllValuesCriteria" id="9e773c57-f746-4867-976b-2b073c4bf5d6">
        <source>getAttrCheckAllValuesCriteria(_allObjects : CM_ObjectSet; classType : Class; methodToCall : String ) : Boolean;
// --------------------------------------------------------------------------------
// Created:		01 November 2010 by cnwjo3
//
// Purpose:		Check all the values on the criteria and return an OR of all.
//				For example, if the Voyage Allocation has ISO Groups 20BX and GEN4 we need to check both
//				par 26153
//
vars
	obj : Object;
	result : Boolean;
begin
	foreach obj in _allObjects discreteLock do 
		if obj.isKindOf(classType) then
			result := result or obj.sendMsg(methodToCall).Boolean;
		endif;
	endforeach;
	return result;
end;</source>
        <Parameter name="_allObjects" type="CM_ObjectSet"/>
        <Parameter name="classType" type="Class"/>
        <Parameter name="methodToCall" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
