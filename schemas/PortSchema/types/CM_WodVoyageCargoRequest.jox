    <JadeMethod name="getStatusForApproved" id="880bccda-d204-4ef5-931c-aa6fcef622b3">
        <source>getStatusForApproved(_voyage: CM_Voyage): CM_VoyageStatus;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19 July 2018	jlgdap1		Initial creation TFS 39815 PEL1 WO Approved Set Voyage Status
//
vars
	status : CM_VoyageStatus;

begin
	if _voyage.myVoyageProcess.isMTNWOProcess then	 //jlier1 TFS 51963 1/10/21
		status := app.myRoot.allVoyageStatuses[Voyage_Status_ServicesPending];
	endif;
	
	
	
	return status;
epilog

end;</source>
