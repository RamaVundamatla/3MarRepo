    <JadeMethod name="doRefresh" id="d3e8fb39-61dc-4a18-8f3b-74096cd51faf">
        <updating/>
        <source>doRefresh() updating, protected;
//-----------------------------------------
// Created: September 2003 By: cnwgd1
// 08 Oct 2012	PJS		PAr #30438 Voyage Rationalisatiobn
// 24/02/2024 	navcs2 	MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
// 14 Jan 2026 	navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
//-----------------------------------------
vars
	idx 	: Integer;
	aVoyage : CM_Voyage;
begin
	endLoad;
	beginLoad;
	inheritMethod();

	/* PAR 36296
	foreach aVoyage in self.allCurrentVoyages do
		self.endNotification(aVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Create_Event));
		self.endNotification(aVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Update_Event));
		self.endNotification(aVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Delete_Event));
	endforeach;
*/
	self.allCurrentVoyages.clear();
	// PAR 36296 if self.myInitVoyage = null then
	if self.myCurrentVoyage = null then
		self.myTerminal.getAllVoyagesInPort(self.allCurrentVoyages, false, app.myPassport);
	else
		self.allCurrentVoyages.add(self.myCurrentVoyage);
	endif;
	
	
	if self.myCurrentVoyage &lt;&gt; null then // PAR 36296
		self.setMyCurrentVoyage(self.myCurrentVoyage); // PAR 36296
	endif;
	
	/* PAR 36296
	foreach aVoyage in self.allCurrentVoyages do
		self.beginNotification(aVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Create_Event), Response_Continuous, null);
		self.beginNotification(aVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Update_Event), Response_Continuous, null);
		self.beginNotification(aVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Delete_Event), Response_Continuous, null);
	endforeach;
*/	

	//if we have come in with an initial voyage specified then we will never show 
	// the voyages cmb so don't bother loading
	
	if myCurrentVoyage = null  then
		doCmbVoyageBuild;	// 30438
	endif;
	
	
	self.lstJobsSaveSelected;
	
	
	

	if self.myCurrentVoyage = null then
	//	self.loadListJobsAll();  //30438
	
		
//		if myCurrentVoyage &lt;&gt; null then
//			if self.allCurrentVoyages.includes(myCurrentVoyage) then
//				self.cmbVoyage.listObject:=myCurrentVoyage;
//			endif;
		//else
		if app.getMyCurrentVoyage &lt;&gt; null  then
			if self.allCurrentVoyages.includes(app.getMyCurrentVoyage()) then
				self.cmbVoyage.listObject:=app.getMyCurrentVoyage;
				self.setMyCurrentVoyage(app.getMyCurrentVoyage);
			endif;
		endif;
		
		
		if cmbVoyage.listObject &lt;&gt; null then
			loadListJobs(cmbVoyage.listObject.CM_Voyage,null,null);
			
			if self.selectedListObject &lt;&gt; null
			and global.isValidObject(self.selectedListObject) then
				self.lstJobsSetSelectedObject;			
			else
				self.selectedListObject := null;
				idx := self.lstJobs.findObject(self.myCurrentVoyage);
				if idx &lt;= 1 then
					//idx := self.lstJobs.findObject(app.myCurrentVoyage);
					//cnwjo3 par 23105
					idx := self.lstJobs.findObject(app.getMyCurrentVoyage());
				endif;
				if idx &lt;= 1 and (not self.allCurrentVoyages.isEmpty) then
					idx := self.lstJobs.findObject(self.allCurrentVoyages.first);
				endif;
				if idx &lt; 1 then
					idx := 1;
				endif;				
				self.lstJobs.listIndex := idx;
				self.lstJobs.listObject := lstJobs.itemObject[idx];
			//	self.lstJobs.itemSelected[idx] := true;
				self.lstJobsChange(self.lstJobs.listObject.CM_Object);
				self.lstJobs.itemExpanded[idx] := true;
			endif;
		endif;
	elseif self.myInitCrane &lt;&gt; null then
		if self.myInitJob &lt;&gt; null then
		// opening the Job Operations Form when performing double click 
		// on a single job displayed on the Ship Job Controler
		//	self.loadJobsForSelectedCrane();
			self.loadListJobs(myCurrentVoyage,myInitCrane,myInitJob);

		else
			// accesing the Job Operations Form form the Ship Job Controller for a specific Crane only.
		//	self.loadJobsForSelectedCrane();
			self.loadListJobs(myCurrentVoyage,myInitCrane,myInitJob);

		//	self.lstJobs.itemExpanded[3] := true;
		//	self.lstJobs.itemSelected[3] := true;
		endif;
	endif;
	
	
	
	
	if (not self.isFirstActivateComplete) then
		self.showHideSelector();
	else
		endLoad;	//22 Jan 2014	NDL	Par 32448 - loadControls is never in load state in the other calls, so can't be necessary...
		self.loadControlsForSelectedJobs();	
	endif;
	if self.frmSelector.visible then
		self.frmSelector.zOrder(1);
	endif;	
epilog
	endLoad;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRefreshTable" id="8053e2f4-be8a-4d2e-bcf5-1b782ed1afda">
        <updating/>
        <source>doRefreshTable(_table : CM_DataTable input)updating;
//--------------------------------------------------
// Created:	08 October 2003 By: cnwgd1
// 24/02/2024 	navcs2 	MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
// 14 Jan 2026 	navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
//--------------------------------------------------
vars
	rowIdx		: Integer;
	obj			: Object;
	job			: CM_VoyageJob;
	saveSelected : ObjectArray;
begin
	if _table = null then
		self.loadControlsForSelectedJobs();
		return;
	endif;
	
	job := _table.userObject.CM_VoyageJob;
	
	if (not global.isValidObject(job)) then
		self.doRemoveTable(_table);
		return;
	endif;
	create saveSelected transient;
	_table.allSelectedObjects.copy(saveSelected);

	_table.rows := _table.fixedRows;
	
	self.displayAllWLEsForObj(_table, job);

	foreach obj in saveSelected do
		rowIdx := 0;
		_table.findObjectInRow(obj, rowIdx);
		_table.selectRow(rowIdx, false);
	endforeach;	

epilog
	delete saveSelected;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doRemoveTable" id="45b30981-1dcc-4f61-884d-93551863e8e1">
        <updating/>
        <source>doRemoveTable(_table : CM_DataTable)updating;
//--------------------------------------------------
// Created:	07 October 2003 By: cnwgd1
//--------------------------------------------------
vars
	lstIdx : Integer;
	job	: CM_VoyageJob;
	frm : CMUI_Frame;
	vertSplitter,
	horzSplitter : CMUI_SplitContainer;
begin
	if _table = null then
		return;
	endif;
	
	job := _table.userObject.CM_VoyageJob;
	
	if job &lt;&gt; null then
		if self.allSelectedVoyageJobsArray.includes(job) then
			self.allSelectedVoyageJobsArray.remove(job);		
		endif;
		lstIdx := self.lstJobs.findObject(job);
		if lstIdx &gt; 0 then
			self.lstJobs.itemSelected[lstIdx] := false;
		endif;
	endif;
	
	if self.allSelectedVoyageJobsArray.isEmpty then
		self.allClonedSplitters.purge();	
		self.allClonedWLETables.purge();
		// PAR 22175 - clear out dict, WLE objects already purge above
		self.allTablesByWle.clear;
		self.showHideSelector();
		return;	
	endif;	
	
	frm := _table.parent.CMUI_Frame;
	horzSplitter := frm.parent.CMUI_SplitContainer;
	vertSplitter := horzSplitter.parent.CMUI_SplitContainer;
	
	if vertSplitter.getMyRightControl() = horzSplitter then
		vertSplitter.hideRightControl(true);
	else
		vertSplitter.hideLeftControl(true);
	endif;
	
end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="c07982be-6b87-427d-9fca-e2aa4e64a567">
        <updating/>
        <source>doResize()updating;
//-----------------------------------------
// Created: October 2003 By: cnwgd1
//-----------------------------------------
vars
	tmpSpl : CMUI_SplitContainer;
	tmpWidth, splitterTop : Real;

begin
	inheritMethod();
	tmpSpl := self.allClonedSplitters.first.CMUI_SplitContainer;
	
	self.frmToolbar2.left := 0;
	self.frmToolbar2.top := self.frmToolbar.top + self.frmToolbar.height + 1;
	splitterTop := self.frmToolbar.top + self.frmToolbar.height + 1;
	if self.frmToolbar2.visible then
		splitterTop := self.frmToolbar2.top + self.frmToolbar2.height + 1;
	endif;
	
// TFS 3472	splMain.move(0, frmToolbar.height, self.clientWidth, self.clientHeight - frmToolbar.height - self.frmModeStatusBar.height);
	splMain.move(0, splitterTop, self.clientWidth, self.clientHeight - frmToolbar.height - self.frmModeStatusBar.height);
	
	self.frmModeStatusBar.doResize();
	splMain.cnEcResizeContents();
	
	if tmpSpl &lt;&gt; null then
// TFS 3472		tmpSpl.move(0, frmToolbar.height, self.clientWidth, self.clientHeight - frmToolbar.height - self.frmModeStatusBar.height);
		tmpSpl.move(0, splitterTop, self.clientWidth, self.clientHeight - frmToolbar.height - self.frmModeStatusBar.height);
		tmpSpl.cnEcResizeContents();
	endif;	
	if self.myCurrentTableInfo &lt;&gt; null then
		self.doResizeColumnWidths(self.myCurrentTableInfo,true);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTBAMatch" id="08cf5001-c1df-4cd5-a497-9547f5fb5fe2">
        <updating/>
        <source>doTBAMatch(_theTI : CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2019	jlgab1	Initial creation

*/

vars

	updateTI, pxyTI : CM_TrackedItem;
	theReturn : Integer;
begin
	if _theTI = null then
		return;
	endif;
	
	if _theTI.myMatchedTBA = null then
		return;
	endif;
	
	
	
	pxyTI := app.createUpdateProxy(_theTI).CM_TrackedItem;
	
	pxyTI.setFromTBAMatch();
			
	while true do
		app.myTrxUA.trxUpdateTrackedItemFromTBA(pxyTI, null, TI_UPDMODE_NORMAL, _theTI.myMatchedTBA, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(TBAList), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

	
epilog
	delete pxyTI;


end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doTimerReplay" id="2ad518c0-c3ce-4d63-9b61-a64a024623b8">
        <updating/>
        <source>doTimerReplay() protected, updating;

// Created by cnwdvb1 on 26 February 2007
// Updated by conkc1  on 07 December 2009 PAR 21876
// Updated by conkc1  on 11 March 2010 PAR 23072 - check that the table is still valid
// 24/02/2024 	navcs2 	MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
// 14 Jan 2026 	navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars

	wle 			: CM_WorkListEntry;
	breakOut		: Boolean;
	newTable		: CM_DataTable;
	newTableArray : ObjectArray;
	object      	: Object;
begin
	self.startedTimer := false;
	//PAR 21876
	create newTableArray transient;
	
	foreach wle in self.allDeletedWles do
	
		newTable := self.tblWLEUpdateWle(wle, self.Mode_Delete, breakOut, false);
		if newTable &lt;&gt; null and app.isValidObject(newTable) = true then // PAR 23072
			if newTableArray.includes(newTable) = false then
				newTableArray.add(newTable);
			endif;
		endif;

	endforeach;
	
	foreach wle in self.allUpdatedWles do
	
		newTable := self.tblWLEUpdateWle(wle, self.Mode_Update, breakOut, false);
		if newTable &lt;&gt; null and app.isValidObject(newTable) = true then // PAR 23072
			if newTableArray.includes(newTable) = false then
				newTableArray.add(newTable);
			endif;
		endif;

	endforeach;
	
	foreach wle in self.allAddedWles do
	
		newTable := self.tblWLEUpdateWle(wle, self.Mode_Add, breakOut, false);
		if newTable &lt;&gt; null and app.isValidObject(newTable) = true then // PAR 23072
			if newTableArray.includes(newTable) = false then
				newTableArray.add(newTable);
			endif;
		endif;

	endforeach;
	
	foreach object in newTableArray do
		newTable := object.CM_DataTable;
		self.updateWLEStillHasWarnings(newTable);
	endforeach;

	self.tblWLESetSelected();
epilog

	self.allDeletedWles.clear();
	self.allUpdatedWles.clear();
	self.allAddedWles.clear();

	delete newTableArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doToggleExtraInfo" id="c8c2d4f9-d5e4-4ddd-b6ab-8cbe9b99b01a">
        <updating/>
        <source>doToggleExtraInfo(_splitter : CMUI_SplitContainer input) protected, updating;
// ---------------------------------------------------------------------------
// Created:      10 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	if self.mnuToggleExtraInfo.caption = app.getErrorString(Show_Additional_Info) then
		_splitter.showRightControl(100 - self.splTablesRatio, true);
		self.mnuToggleExtraInfo.caption := app.getErrorString(Hide_Additional_Info);
		self.hideExtraInfo := false;
	else
		self.splTablesRatio := _splitter.leftToRightRatio;
		_splitter.hideRightControl(true);
		self.mnuToggleExtraInfo.caption := app.getErrorString(Show_Additional_Info);
		self.hideExtraInfo := true;		
	endif;
	
	_splitter.cnEcResizeContents;
end;</source>
        <access>protected</access>
        <Parameter name="_splitter" type="CMUI_SplitContainer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUnassignTI" id="dce1c4b0-6e8a-48b4-a6ef-48388fc8908f">
        <updating/>
        <source>doUnassignTI(_all : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		22 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	wleSet : CM_WLESet;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	app.mousePointer := MousePointer_HourGlass;	
	
	if self.myCurrentWLE = null then
		return;
	endif;
	
	if self.myCurrentWLE.status &lt;&gt; WLE_UNACTIONED then
		return;
	endif;	
	
	create wleSet transient;
	wleSet.add(self.myCurrentWLE);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateWLEsUnassignTI(wleSet, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Unassign Cargo', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

epilog 
	app.mousePointer := MousePointer_Default;	
	delete wleSet;
end;</source>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUserNotify" id="f09e1cb2-e70f-4777-a946-8c7037c111f9">
        <updating/>
        <source>doUserNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

// Created by cnwdvb1 on 26 February 2007
// 20/11/2018 jlgrh7 TFS #41374 POL - [Fwd: ##RE-9144## : Lori 837R - Archive with active jobe]
// 14 Jan 2026 navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	breakOut 	: Boolean;
	wle 		: CM_WorkListEntry;
	event 		: Integer;
	now			: TimeStamp;
begin
	self.showSelectorOnStartup := false;		// 36236 this is used to indicate a 14022 exception has happened from here

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	self.tblWLESaveSelected();
	
	// Lorcan 20/6/2006 Take out this note as this form doesn't seem to be registered for receiving it
	if /*event = EVENT_UPDATE_VOYAGE_AREA or*/ event = EVENT_VOYAGE_BERTHING_CHANGED then
		self.doRefresh();
	
	elseif event = EVENT_VOY_ALLOC_UPDATE then								//+TFS41374
		self.doRefreshTable(self.myCurrentTableWLE);
		
	elseif event = WLE_Update_Event then
		wle := userInfo.CM_WorkListEntry;

		//self.tblWLEUpdateWle(wle, self.Mode_Update, breakOut);	   
		self.doNotificationStorage(wle, self.Mode_Update);
	elseif event = WLE_Create_Event then
		wle := userInfo.CM_WorkListEntry;	
		//self.tblWLEUpdateWle(wle, self.Mode_Add, breakOut);	   	   
		self.doNotificationStorage(wle, self.Mode_Add);
	elseif event = WLE_Delete_Event then
		wle := userInfo.CM_WorkListEntry;	
		if self.selectedTableObject.String = userInfo.String then
			self.selectedTableObject := null;
		endif;
		//self.tblWLEUpdateWle(wle, self.Mode_Delete, breakOut);
		self.doNotificationStorage(wle, self.Mode_Delete);
		return;
	else
		self.lstJobsUpdateObj(userInfo.CM_Object, event);
	endif;

//	if app.actualTimeAppServer.time &gt;= (self.lastNote + 3000) then // PAR 9401 - only do this every 3 seconds or longer since last event
//		self.tblWLESetSelected();
//	endif;

epilog
	// 36236 if the update of lstJobs has got a 14022 item level exception, this indicates that the list has probably lost entries so rebuild it
	if self.showSelectorOnStartup then
		self.loadListJobs(self.myCurrentVoyage,self.myInitCrane,self.myInitJob);
		self.showSelectorOnStartup := false;
	endif;
	self.lastNote := app.actualTimeServer().time; // PAR 9401
	app.mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="dragTrackedItem" id="10dd0953-b8bc-433c-b441-ac28b678295b">
        <updating/>
        <source>dragTrackedItem(_ti : CM_TrackedItem; _wle : CM_WorkListEntry; _control : Control input) updating;
//--------------------------------------------------------------
//Created: 18 April 2002 By: cnwgd1
//--------------------------------------------------------------
//23 Mar 2011 	cnwer1	PAR 25573 changed to give error is wle status &lt;&gt; unactioned, complete can now been still has rt queue entries
// 17/06/2011	cmwmh5	#27207 - change to handle rehandles correctly
vars
	picture : Picture;
	wle : CM_WorkListEntry;
	obj : Object;
	tmpTi : CM_TrackedItem;
	moveController	: CMIF_MoveController;
	effectiveTimeStamp : TimeStamp;
begin
	delete app.myMoveController;
	if self.myCurrentTableWLE = null then
		return;
	endif;

	if _wle &lt;&gt; null then
		if _wle.status &lt;&gt; WLE_UNACTIONED then
			app.raiseCMException2(VB_JOB_NOT_UNACTIONED, _wle.job.jobId, _wle.statusString, null, null);
			return;
		endif;
	endif;	
		
	create moveController transient;
	
	app.myMoveController := moveController;	
	moveController.setMyTrackedItem(_ti);

	if _wle &lt;&gt; null then
		moveController.setMyWorkListEntry(_wle);
		if _wle.myRequest.isKindOf(CM_SlotRequest) then
			moveController.mySlotRequest := _wle.myRequest.CM_SlotRequest; // 722B testing
		elseif _wle.myRequest.isKindOf(CM_VoyageRequest) then  // PAR 28968
			moveController.myVoyageRequest := _wle.myRequest.CM_VoyageRequest;  // PAR 28968
		endif;
		_wle.setMoveControllerAllOtherTIs(moveController);
	endif;
		
	moveController.setMoveMode(self.moveModeForm);
	
	// TFS 3472
	if self.frmToolbar2.visible then
		effectiveTimeStamp.setDate(self.txtEffectiveDate.getDate());
		effectiveTimeStamp.setTime(self.txtEffectiveTime.getTime());
	endif;
	moveController.setEffectiveTimeStampOverride(effectiveTimeStamp);

	
	// PAR 8072 - APR2004AKB added this replan code.
	if self.moveModeForm = PLANNING_MODE and _wle.myFutureMove &lt;&gt; null then
	//if self.moveModeForm = PLANNING_MODE and _wle.myFutureMove.isKindOf(CM_FutureMovePlanned) then  // 16/06/2011 cnwmh5  #27207
		moveController.isReplan := true;
		moveController.setMoveIndex(_ti.allPlannedFutureMoves.indexOf(_wle.myFutureMove));
		moveController.setMyOriginatingLocation(_ti.getPrimaryLocation(PLANNING_MODE));
	endif;	

	//if moveController.moveMode = REAL_MODE then			
		foreach obj in self.myCurrentTableWLE.allSelectedObjects do
			if obj = _wle then
				continue;
			endif;
			if (not CM_WorkListEntry.hasInstance(obj)) then
				continue;
			endif;
			wle := obj.CM_WorkListEntry;
			if wle.status &lt;&gt; WLE_UNACTIONED then
				continue;
			endif;
			if self.moveModeForm = QUEUE_MODE and wle.queue &lt;&gt; null then
				// Already queued			
				continue;
			elseif self.moveModeForm = PLANNING_MODE and wle.myFutureMove &lt;&gt; null then
				// Already planned or queued
				continue;				
			endif;
			tmpTi := wle.myTrackedItem;
			if tmpTi &lt;&gt; null then
				moveController.allOtherTrackedItems.add(tmpTi);
				moveController.allOtherWLEs.add(wle);
			endif;
		endforeach;
	//endif;	

	_control.dragMode := DragMode_Drag;
	
	create picture transient;
	self.setPictureDragCursor(picture);
	if picture &lt;&gt; null then
		_control.dragCursor := picture.picture;
	endif;

epilog
	if picture &lt;&gt; null then
		delete picture;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_control" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllSelectedWLEs" id="cae3ad63-090d-48a1-a8b9-bfee2fd2ec0f">
        <updating/>
        <source>getAllSelectedWLEs(_wleArray : CM_WLEArray input) updating;
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	first	: Boolean;
	obj 	: Object;
	wle		: CM_WorkListEntry;
	idx,
	sortRow,
	rows 	: Integer;
begin
	if self.myCurrentTableWLE = null then
		return;
	endif;
	
	first := true;
	_wleArray.clear();
	
	// My current job is not reliable at this stage. Needs rethink	
	on Exception do self.handleExceptionWLE(exception, wle);			
	rows := self.myCurrentTableWLE.rows;
	
	
	foreach obj in self.myCurrentTableWLE.allSelectedObjects do
		if CM_WorkListEntry.hasInstance(obj) then
			wle := obj.CM_WorkListEntry;
			wle.fetchLatest();
		endif;
		if wle = null then
			continue;
		endif;
		if first then
			self.myWLESorter.init(self.myCurrentVoyage, wle.job.CM_VoyageJob);		
			first := false;
		endif;
		self.myWLESorter.add(wle);
	endforeach;
	self.myWLESorter.copy(_wleArray);

end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllWLEs" id="6e6e8b54-d805-412c-af97-73a897e1408b">
        <source>getAllWLEs(_wleArray: CM_WLEArray input);
//--------------------------------------------------------------
//Created: 16 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	job	: CM_Job;
	jobArray : CM_JobArray;
	voy : CM_Voyage;
begin

	// get all wles for all current voyages.
	
	create jobArray transient;
	
	// PAR 36296 foreach voy in self.allCurrentVoyages do
	voy := self.myCurrentVoyage;
	if voy &lt;&gt; null then
		voy.getAllWLEs(_wleArray);
		jobArray.clear();
		voy.getUnassignedVoyageJobs(jobArray);
		foreach job in jobArray do
			if hideCompletedJobs and job.status = JOB_COMPLETE then
				continue;
			endif;
			job.getAllWLEs(_wleArray);
		endforeach;			
	// PAR 36296 endforeach;
	endif;
	
epilog
	delete jobArray;	
end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllWLEsInCurrentTbl" id="f8c0e866-0448-4e51-9717-9803544630f7">
        <updating/>
        <source>getAllWLEsInCurrentTbl(_wleArray : CM_WLEArray input) updating;
//-----------------------------------------
//Created: May 2003 By: cnwgd1
//-----------------------------------------
vars
	first			: Boolean;
	obj 			: Object;
	wle 			: CM_WorkListEntry;
	idx,
	sortRow,
	rows 			: Integer;

begin
	if self.myCurrentTableWLE = null then
		return;
	endif;
	
	first := true;

	on Exception do self.handleExceptionWLE(exception, wle);	
	rows := self.myCurrentTableWLE.rows;

	_wleArray.clear();
	// My current job is not reliable at this stage. Needs major rethink!!	
	foreach idx in 2 to rows do
		wle := self.myCurrentTableWLE.accessRow(idx).itemObject.CM_WorkListEntry;
		if wle = null then
			continue;
		endif;
		wle.fetchLatest();
		if wle = null then
			continue;
		endif;		

		if first then
			self.myWLESorter.init(self.myCurrentVoyage, wle.job.CM_VoyageJob);		
			first := false;
		endif;
		if (not self.myWLESorter.includes(wle)) then			
			self.myWLESorter.add(wle);
		endif;
	endforeach;
	
	self.myWLESorter.copy(_wleArray);

end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllWLEsInTableSelected" id="0d8600c7-f8fb-4c0e-ab4e-e669e8bc0809">
        <source>getAllWLEsInTableSelected(	_wleArray : CM_WLEArray input;
															_wleTable	: CM_DataTable input;
															_includeBulkVisitWLEs :Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 November 2018	jlgrh7	Initial creation

*/

vars
	obj 		: Object;
	wle			: CM_WorkListEntry;
	invalidWLE	: Boolean;
begin
	on Exception do app.handleDeletedObject (exception, wle, invalidWLE);
	
	beginLoad;
	
	foreach obj in _wleTable.allSelectedObjects do
		invalidWLE := false;	
		
		if CM_WorkListEntry.hasInstance(obj) then
			wle := obj.CM_WorkListEntry;	// won't cause exception
		endif;	
		
		if wle = null then
			continue;
		endif;
		
		self.sharedLock(wle);
		
		if invalidWLE then
			// an exception occurred doing the lock
			continue;
		endif;
		
		if not _includeBulkVisitWLEs and wle.isBulkGateVisit() then	//nds TFS 2867 17/01/17 PKT - Bulk Process
			continue;												//nds TFS 2867 17/01/17 PKT - Bulk Process
		endif;														//nds TFS 2867 17/01/17 PKT - Bulk Process
		
		_wleArray.add(wle);
	endforeach;
epilog
	endLoad;
end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
        <Parameter name="_wleTable" type="CM_DataTable" usage="input"/>
        <Parameter name="_includeBulkVisitWLEs" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCMIF_ConnectParamsForTI" id="5cfe945d-bade-4334-aca5-e6a59a9e26bc">
        <source>getCMIF_ConnectParamsForTI(_ti : CM_TrackedItem) : CMIF_ConnectParams;
//--------------------------------------------------------------
//Created: 16 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	now	: TimeStamp;
	connectParams : CMIF_ConnectParams;
	theProxyTI : CM_TrackedItem;
	ls	: Boolean;
begin
	now := app.actualTimeServer();	// 9/5/16 cnwmp6 TFS 488 - Multi timezone support
	
	if _ti = null then
		return null;
	endif;
	
	if (not _ti.isKindOf(CM_Container)) then
		return null;
	elseif (not _ti.CM_Container.isConnected) then
		return null;
	endif;
	app.cmsBeginLoad(ls);
	theProxyTI := _ti.pxyCreateUpdateProxy();
	self.allProxies.add(theProxyTI);
	app.cmsEndLoad(ls);	

	create connectParams transient;
	connectParams.dateTime := now;
	connectParams.noCharge := false;	// 19/03/2010 cnwar2 #23251 - changed from true
	connectParams.myTrackedItem := theProxyTI;
	connectParams.myTerminal := self.myTerminal;
	connectParams.myOtherTrackedItem := _ti.getOtherTrackedItem(ACTION_DISCONNECT);
	connectParams.locationsController := _ti.getPrimaryLocation(REAL_MODE);
	connectParams.urNumber := null;
	connectParams.userId := app.getMyUserCode();
	connectParams.action := ACTION_DISCONNECT;
	connectParams.gapController := null;
	connectParams.radioTelemetryIgnoreWarnings := false;
	connectParams.radioTelemetryUser := false;
	
	return connectParams;
			
epilog
	// transients get deleted in the calling method	
	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CMIF_ConnectParams"/>
    </JadeMethod>
    <JadeMethod name="getChildControlByName" id="114ecaea-a2c2-416b-bed1-e70e4fe4270e">
        <source>getChildControlByName(_frm : CMUI_Frame; _name : String) : Control;
//--------------------------------------------------
// Created:	30 October 2003 By: cnwgd1
//--------------------------------------------------
vars
	theControl	: Control;
	array		: CnEcControlArray;
begin
	if _frm = null then
		return null;
	endif;
	
	create array transient;
	_frm.cnEcGetAllChildControls(array, true);

	foreach theControl in array do
		if theControl.parent = _frm then
			if theControl.name = _name then
				return theControl;
			endif;
		endif;
	endforeach;
	
	return null;
epilog
	delete array;	
end;</source>
        <Parameter name="_frm" type="CMUI_Frame"/>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Control"/>
    </JadeMethod>
