    <JadeMethod name="setVesselTypesAvailable" id="22ea3a33-7c43-48bc-bb2b-cb0994f1987b">
        <source>setVesselTypesAvailable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018 cnwma1	ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types

*/

vars
	col : ObjectSet;
	vesselType : HMS_VesselType;
	failedDAC : CM_DataAccessController;
begin
	create col transient;
	foreach vesselType in app.myRoot.allVesselTypes discreteLock do
		if not vesselType.canUserAccessSelf(null, failedDAC, app.myPassport) then
			continue;
		endif;
		col.add(vesselType);
	endforeach;
	self.msgbVesselTypes.setAvailable(col, true);
	self.msgbVesselTypes.setSelected(self.allSelectedVesselTypes);	
epilog
	delete col;
end;</source>
