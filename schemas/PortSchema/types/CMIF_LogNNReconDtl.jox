    <JadeMethod name="moveLogToShip" id="137da876-7e7e-4059-b2aa-c66ff0def6b2">
        <updating/>
        <source>moveLogToShip(_log : CM_Log; _passport : CM_Passport input) : Boolean updating;
//--------------------------------------------------------------
//Created: 30 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	moveController	: CMIF_MoveController;
	cancelSave	 	: Boolean;
	newLocn 		: CM_LocationsController;
begin
	
	exclusiveLock(_log);
	// Initialise move controller parameters.
	create moveController transient;
	
	newLocn := _log.myReleaseBOL.myPlannedLocation;
	moveController.setMoveMode(REAL_MODE);
	moveController.isSystemMove := true;
	moveController.setMyToPrimaryLocation(newLocn);
	moveController.setMyTrackedItem(_log);
	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	if (not _passport.noErrors) then
		return false;
	endif;

	return true;
epilog
	delete moveController;		
end;</source>
        <Parameter name="_log" type="CM_Log"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="noNumberPieces" id="7f753e81-2a1f-4f46-944b-3f558864d5f3">
        <methodInvocation>mapping</methodInvocation>
        <source>noNumberPieces(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     03 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := self.allNoNumberLogs.size;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="offLoadNoNumberLogs" id="c1c9b02d-1241-4c3f-bef2-ddd0d3c48cb2">
        <updating/>
        <source>offLoadNoNumberLogs(_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 29 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	nnLog : CM_LogNoNumber;
	tiUpdCntrl : CMIF_TIUpdateController;
begin
	if self.allNoNumberLogs.size = 0 then
		return;
	endif;
	
	tiUpdCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	
	foreach nnLog in self.allNoNumberLogs do
		exclusiveLock(nnLog);
		/*if nnLog.isRetainedOnVoyage then	#26532 10/12/2010. Now retained on voyage can be downloaded when a blue warning is accepted.
			continue;
		endif;*/
		nnLog.createStockMovementForOffload(tiUpdCntrl, _passport);
		nnLog.erase(NORMAL_ERASE);
	endforeach;
	
epilog
	delete tiUpdCntrl;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="rejectResidue" id="82bc124f-4aef-4c54-a35a-867810b76d47">
        <source>rejectResidue(_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 29 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	obj : Object;
	cnt : Integer;
	log : CM_Log;
	tmpTISet : CM_TISet;
begin

	if self.myDynaDict.size = 0 or self.myDynaDict.size &lt; self.numberOfPieces then
		app.raiseCMException2(LogResidueImbalance, self.myDynaDict.size.String, self.numberOfPieces.String, ETRow_PieceCount, null);				
		return;
	endif;
	create tmpTISet transient;
	cnt := self.numberOfPieces;

	foreach obj in self.myDynaDict do
		log := obj.CM_Log;	
		exclusiveLock(log);
		if log.isOnShip then
			continue;
		endif;
		if cnt &gt; 0 then
			tmpTISet.add(log);
		else
			break;	
		endif;	
		cnt := (cnt - 1);
	endforeach;

	if _passport.noErrors then
		app.myUtilityUA.utlRejectTrackedItems(tmpTISet, self.reasonCode, self.recoveryCode, self.comment, null, _passport);
	endif;

epilog
	delete tmpTISet;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="returnResidueToStock" id="6448dfe4-0cd0-4215-a66d-700f5cd0b7aa">
        <source>returnResidueToStock(_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 29 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	obj			: Object;
	cnt 		: Integer;
	ti 			: CM_TrackedItem;
	firstTime	: Boolean;
	tmpTISet 	: CM_TISet;
	moveController : CMIF_MoveController;
begin
	if self.myDynaDict.size = 0 or self.myDynaDict.size &lt; self.numberOfPieces then
		app.raiseCMException2(LogResidueImbalance, self.myDynaDict.size.String, self.numberOfPieces.String, ETRow_PieceCount, null);				
		return;
	endif;
	create tmpTISet transient;
	cnt := self.numberOfPieces;
	
	foreach obj in self.myDynaDict do
		ti := obj.CM_TrackedItem;			
		exclusiveLock(ti);
		if ti.isOnShip then
			continue;
		endif;
		if cnt &gt; 0 then
			tmpTISet.add(ti);
		else
			break;	
		endif;	
		cnt := (cnt - 1);
	endforeach;
	
	// Initialise move controller parameters.
	create moveController transient;
	
	moveController.setMoveMode(REAL_MODE);
	moveController.isSystemMove := true;
	moveController.setMyToPrimaryLocation(self.myPlannedLocation);
	firstTime := true;
	foreach ti in tmpTISet do
		if firstTime then
			moveController.setMyTrackedItem(ti);
			firstTime := false;
			continue;
		endif;
		moveController.allOtherTrackedItems.add(ti);
	endforeach;	
	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
		
epilog
	delete tmpTISet;
	delete moveController;	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupDynaDict" id="527a7c67-5bf9-4a54-ab2d-5b65327fea81">
        <source>setupDynaDict(_clearFirst : Boolean) protected;
//--------------------------------------------------------------
//Created: 15 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars
begin

	if (not self.myDynaDict.isEmpty) then
		self.myDynaDict.clear();
	endif;
	if _clearFirst then
		self.myDynaDict.clearKeys();
	endif;
	
	self.myDynaDict.setMembership(CM_Log);
	
	self.myDynaDict.addMemberKey('sedMean', false, false);
	
	self.myDynaDict.endKeys(true);

end;</source>
        <access>protected</access>
        <Parameter name="_clearFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="swapIt" id="21d35e42-8ff4-44c8-89d5-f4c3332f574f">
        <updating/>
        <source>swapIt(nnLog : CM_LogNoNumber io; residualLog : CM_Log input; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 12 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tiUpdCntrl : CMIF_TIUpdateController;
begin
	
	if nnLog = null or residualLog = null then
		return;
	endif;
	tiUpdCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, self.userCode, null);
	tiUpdCntrl.isAuditTextRequired := false;

	//Take out of collections first as nnLog is erase in the swap
	self.allNoNumberLogs.remove(nnLog);
	self.myDynaDict.remove(residualLog);
	residualLog.swapWithOnShipLogNoNumber(nnLog, tiUpdCntrl, _passport);

epilog
	delete tiUpdCntrl;	
end;</source>
        <Parameter name="nnLog" type="CM_LogNoNumber" usage="io"/>
        <Parameter name="residualLog" type="CM_Log" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="swapNoNumbers" id="60c0c565-d187-4543-8021-3ad75d8b473f">
        <updating/>
        <source>swapNoNumbers(_passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 29 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	obj			: Object;
	logCnt,
	cntLoop,
	increase,
	decrease	: Integer;
	nnLog		: CM_LogNoNumber;
	residualLog : CM_Log;
	found,
	isDecrease,
	isIncrease 	: Boolean;
	iter 		: Iterator;
	minSed,
	maxSed		: Decimal[6,2];
begin
	if self.allNoNumberLogs.size = 0 then
		//nothing to swap
		return;
	endif;
	
	app.writeLog('swapNoNumbers start:  NNs: ' &amp; self.allNoNumberLogs.size.String &amp;
			     '  Residual ' &amp; self.myDynaDict.size.String, LogINFO);

	foreach obj in self.myDynaDict do
		residualLog := obj.CM_Log;
		exclusiveLock(residualLog);
		if residualLog.isUnscaled or
		   residualLog.myReleaseBOL &lt;&gt; null then
			self.myDynaDict.remove(residualLog);				
		endif;
	endforeach;

	app.writeLog('swapNoNumbers removed invalid residuals:  NNs: ' &amp; self.allNoNumberLogs.size.String &amp;
			     '  Residual ' &amp; self.myDynaDict.size.String, LogINFO);

	// Check to see if any residual logs have the same sedMean as
	// the nn log - if so swap.
	foreach nnLog in self.allNoNumberLogs do
		exclusiveLock(nnLog);

		residualLog := self.myDynaDict[nnLog.sedMean].CM_Log;
		if residualLog &lt;&gt; null then
			self.swapIt(nnLog, residualLog, _passport);
		endif;		
	endforeach;

	app.writeLog('swapNoNumbers done exact matches :  NNs: ' &amp; self.allNoNumberLogs.size.String &amp;
			     '  Residual ' &amp; self.myDynaDict.size.String, LogINFO);

	if (not self.allNoNumberLogs.isEmpty) and
	   (not self.myDynaDict.isEmpty) then
	
		found 	 := false;
		increase := 0;
		decrease := 0;
		cntLoop  := 0;
	
		// Check for the closest match of a residual log
		while (true) do
			cntLoop := cntLoop + 1;
			if cntLoop mod 2 = 0 then
				increase := increase + 1;
			else
				decrease := decrease + 1;
			endif;				 
			foreach nnLog in self.allNoNumberLogs do
				minSed := nnLog.sedMean - decrease;
				maxSed := nnLog.sedMean + increase;
				
				residualLog := self.myDynaDict.getAtKeyGeq(minSed).CM_Log;
				if residualLog = null then
					continue;
				endif;
				if residualLog.sedMean &lt;= maxSed then
				   	logCnt := logCnt + 1;
				   	app.writeLog('swapNoNumbers ' &amp; logCnt.String, LogINFO);
					self.swapIt(nnLog, residualLog, _passport);
				endif;
				
				if self.myDynaDict.isEmpty then
					break;
				endif;
			endforeach;
			if self.allNoNumberLogs.isEmpty or
			   self.myDynaDict.isEmpty then
				break;
			endif;

			app.writeLog('swapNoNumbers looping :  NNs: ' &amp; self.allNoNumberLogs.size.String &amp;
						 '  Residual ' &amp; self.myDynaDict.size.String &amp;
						 '  Cnt: ' &amp; cntLoop.String &amp; '  Inc: ' &amp; increase.String &amp;
						 '  Dec: ' &amp; decrease.String, LogINFO);
			
		endwhile;
	endif;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="3c5a838a-1afd-4b8f-8162-9d9c73a616e6">
        <source>validateForUpdate(_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 29 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	rtnValue	: Boolean;
	search		: CMIF_SearchTypes;
	logVoy		: CM_Voyage;
	log			: CM_Log;
	obj			: Object;
	nnlog		: CM_LogNoNumber;
	nnRetained	: Integer;
	
begin

	if self.myLogVoyageStructure = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Voyage. Contact Developer.');
		return;				
	endif;
	
	if self.mode = Mode_RetainOnVoyageNN then
		if self.allNoNumberLogs.size = 0 then
			app.raiseCMException2(LogNoNumberReconcile, self.myLogVoyageStructure.myVoyage.code, 'retain', null, null);
		endif;
	elseif self.mode = Mode_LoadResidue then
		if self.myDynaDict.size = 0 then
			app.raiseCMException2(LogResidueImbalance, 'zero', self.numberOfPieces.String, null, null);				
		endif;	
		if self.myLogLot = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Lot', ETRow_MyLogLot, null);
			app.raiseCMException(Input_required_field_lot, ETRow_MyLogLot, null);
		endif;
		if self.hatch = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Hatch', ETRow_Hatch, null);
			app.raiseCMException(Input_required_field_hatch, ETRow_Hatch, null); // cnwdb2	PAR 35364
		endif;
		if self.place = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Place', ETRow_Place, null);
			app.raiseCMException(Input_required_field_place, ETRow_Place, null); // cnwdb2	PAR 35364
		endif;
			if self.myStevedore = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Stevedore', ETRow_Stevedore, null);
			app.raiseCMException(Input_required_field_stevedore, ETRow_Stevedore, null); // cnwdb2	PAR 35364
		endif;
		if self.numberOfPieces &lt;= 0 then
//			app.raiseCMException1(REQUIRED_FIELD, 'Number of Pieces', ETRow_PieceCount, null);
			app.raiseCMException(Input_required_field_NumOfPiec, ETRow_PieceCount, null);// cnwdb2	PAR 35364
		endif;
		if _passport.noErrors then
//			if self.myLogLot.myLogVoyage &lt;&gt; self.myLogVoyage then
			if self.myLogLot.myLogVoyageStructure &lt;&gt; self.myLogVoyageStructure then
				app.raiseCMException2(ERR_INVALID_VALUE, 'Lot ' &amp; self.myLogLot.lotNo, 'Not assigned to Voyage.', null, null);			
			endif;		
			if self.numberOfPieces &gt; self.myDynaDict.size then
				app.raiseCMException2(LogResidueImbalance, self.myDynaDict.size.String, self.numberOfPieces.String, ETRow_PieceCount, null);			
			endif;
		endif;
		
	elseif self.mode = Mode_OffLoadNN then
		if self.allNoNumberLogs.size = 0 then
			app.raiseCMException2(LogNoNumberReconcile, self.myLogVoyageStructure.myVoyage.code, 'Off Load', null, null);
		else	// #26532 10/12/2010
			foreach nnlog in self.allNoNumberLogs do
				if nnlog.isRetainedOnVoyage then
					nnRetained := nnRetained + 1;
				endif;
			endforeach;
			if nnRetained &gt; 0 then
				app.raiseCMWarning1(NN_logs_retainOnVoy_discharge, nnRetained.String, 'Off Load', null, null);
			endif;
		endif;
		
		
	elseif self.mode = Mode_RejectResidue then
		if self.myDynaDict.size = 0 then
			app.raiseCMException2(LogResidueImbalance, 'zero', self.numberOfPieces.String, null, null);				
		endif;	
		if self.numberOfPieces &lt;= 0 then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Number of Pieces', ETRow_PieceCount, null);
			app.raiseCMException(Input_required_field_NumOfPiec, ETRow_PieceCount, null); // cnwdb2	PAR 35364
		endif;							
		if self.reasonCode = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Reject Reason Code', ETRow_ReasonCode, null);
			app.raiseCMException(Input_required_field_RRCode, ETRow_ReasonCode, null); // cnwdb2	PAR 35364
		elseif app.myRoot.allLogRejectCodes[self.reasonCode] = null then
			app.raiseCMException2(ERR_FIELD_REASON, self.reasonCode, 'reason code', ETRow_ReasonCode, null);
		endif;
		if self.recoveryCode = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'recovery code', ETRow_RecoveryCode, null);
			app.raiseCMException(Input_required_field_recvryFld, ETRow_RecoveryCode, null); // cnwdb2	PAR 35364
		else
			if (not app.myRoot.allLogRejectRecoveryCodes.includesKey(self.recoveryCode)) then
				app.raiseCMException2(ERR_FIELD_RECOVERY, self.recoveryCode, 'recovery code', ETRow_RecoveryCode, null);
			endif;
		endif;		
		if _passport.noErrors then
			if self.numberOfPieces &gt; self.myDynaDict.size then
				app.raiseCMException2(LogResidueImbalance, self.myDynaDict.size.String, self.numberOfPieces.String, ETRow_PieceCount, null);			
			endif;							
		endif;
	elseif self.mode = Mode_ReturnResidue then
		if self.myDynaDict.size = 0 then
			app.raiseCMException2(LogResidueImbalance, 'zero', self.numberOfPieces.String, null, null);				
		endif;	
		if self.numberOfPieces &lt;= 0 then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Number of Pieces', ETRow_PieceCount, null);
			app.raiseCMException(Input_required_field_NumOfPiec, ETRow_PieceCount, null); // cnwdb2	PAR 35364
		endif;						
		if self.myPlannedLocation = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Yard Location', ETRow_MyPlannedLocation, null);
			app.raiseCMException(Input_required_field_yrdLocn, ETRow_MyPlannedLocation, null);// cnwdb2	PAR 35364
		else
			create search transient;
			search.myOperator := self.myOperator;
			search.mySpecies	:= self.myProductLog.myLogSpecies;
			search.myGrade	:= self.myProductLog.myLogGrade;
			search.myTreatment:= self.myProductLog.myLogTreatment;
			search.myLength	:= self.myProductLog.myLogLength;
			//PAR11644 - cnwsh3 Log Type was being omitted for search values in doesAllowType methods of both the location controller and the CM_LocationRestrictLog::doesAllowType.
			//Was returning false instead of true in some instances as a result.
			search.myType := self.myProductLog.myLogType;
			
			rtnValue := self.myPlannedLocation.doesAllowType(search, true);
			
			if (not rtnValue) then
				app.raiseCMException2(IncompatibleTypeForLocation, self.myPlannedLocation.id, self.myProductLog.code, null, null);			
			endif;
		endif;
		if _passport.noErrors then
			if self.numberOfPieces &gt; self.myDynaDict.size then
				app.raiseCMException2(LogResidueImbalance, self.myDynaDict.size.String, self.numberOfPieces.String, ETRow_PieceCount, null);			
			endif;							
		endif;											
	elseif self.mode = Mode_SwapNN then
		if self.allNoNumberLogs.size = 0 then
			app.raiseCMException2(LogNoNumberReconcile, self.myLogVoyageStructure.myVoyage.code, 'swap', null, null);
		endif;
		if self.myDynaDict.size = 0 then
			app.raiseCMException2(LogResidueImbalance, 'zero', 'No Number Pieces', null, null);				
		endif;			
		// check for possible log ID duplicates already on a boat. PAR 22136 Feb 2010
		logVoy := self.myLogVoyageStructure.myVoyage;
		foreach obj in self.myDynaDict do
			log := obj.CM_Log;
			if logVoy.allOnshipTIsByIdCargoType.includesKey(log.id, log.cargoType) then
				app.raiseCMException1(Log_ID_already_on_vessel, log.id, null, null);
			endif;
		endforeach;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid Mode (' &amp; self.mode.String &amp; ') passed to method. Contact Developer.');
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
