    <JadeMethod name="create" id="97f75dcb-73ed-4c1a-82ea-46c283358d5a">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	oper : CM_QueryOperator;

begin

	if self.isTransient then 
		return;
	endif;
	
	create oper as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(oper);

epilog

end;</source>
    </JadeMethod>
