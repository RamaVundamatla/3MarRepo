    <JadeMethod name="setProxyDeckingOptions" id="e3ac6b7f-3259-4ce4-ab5d-f7664bf4303d">
        <source>setProxyDeckingOptions();
//----------------------------------------------------------------
//	Created:	28 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	pxyDeckingOptions	: CM_YADeckingOptionsBlock;
	locn				: CM_YardController;
	terminalINDeckingRule, terminalOUTDeckingRule: CM_YADeckingRule;
begin
	self.raiseExceptionIfNotTransient(method);
	
	create pxyDeckingOptions transient;
	pxyDeckingOptions.setProxy(false, true, self);
	
	//do this before setting default rules (will need to know what location cells are relevant)
	foreach locn in self.allYardControllers do
		locn.allYAYardLocationCells.copy(pxyDeckingOptions.allYALocationCellsIn);
	endforeach;
	pxyDeckingOptions.setOutDeckingReverseOfIn();

	//now the rules
	if self.myTerminalArea.myYADeckingOptions &lt;&gt; null and self.myTerminalArea.myYADeckingOptions.inOptionType = DeckingRule_Advanced then
		// Default to TA settings
		pxyDeckingOptions.setProxyRules(DeckingRule_Advanced, self.myTerminalArea.myYADeckingOptions.outOptionType);
		terminalINDeckingRule := self.myTerminalArea.myYADeckingOptions.allDeckingRulesIn.first;
		pxyDeckingOptions.allDeckingRulesIn.first.setProxyFromOtherRule(terminalINDeckingRule);
		terminalOUTDeckingRule := self.myTerminalArea.myYADeckingOptions.allDeckingRulesOut.first;
		pxyDeckingOptions.allDeckingRulesOut.first.setProxyFromOtherRule(terminalOUTDeckingRule);
	else
		pxyDeckingOptions.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	endif;

	
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxysLocationCells" id="79a51cf4-7146-47e1-adb4-9162c08b0608">
        <source>setProxysLocationCells();

vars
	locn		: CM_YardController;
	locnCell	: CM_YALocationCell;
begin
	//new DO so wont have any location cells as yet
	//copy from terminal area/row
	foreach locn in self.allYardControllers do
		foreach locnCell in locn.allYAYardLocationCells do
			if not self.myDeckingOptions.allYALocationCellsIn.includes(locnCell) then
				self.myDeckingOptions.allYALocationCellsIn.add(locnCell);
			endif;
		endforeach;
	endforeach;
	
	self.myDeckingOptions.setOutDeckingReverseOfIn();
	
end;</source>
    </JadeMethod>
