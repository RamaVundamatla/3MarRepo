    <JadeMethod name="getCCEventProperties" id="f2a0511f-32c3-4e33-88a4-7b8a7071656c">
        <source>getCCEventProperties(ccEvent: CMIF_CCEvent) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2019	jlgndl1	Initial creation	TFS 45963

*/

vars

	sealNumber : String;
	
begin

	sealNumber := self.sealNum;

	inheritMethod(ccEvent);
	
	ccEvent.addText( "sealNumber", sealNumber );
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="ccEvent" type="CMIF_CCEvent"/>
    </JadeMethod>
