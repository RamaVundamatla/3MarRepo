    <JadeMethod name="setupForm" id="4226438f-dff8-4d36-939b-e32a43024fc3">
        <updating/>
        <source>setupForm() updating, protected;

vars

	hasWarningsOnly : Boolean;
	
begin
	inheritMethod();
	
	self.lblPassword.zOrder(1);
	self.lblUsername.zOrder(1);
	self.txtPassword.zOrder(1);
	self.txtUsername.zOrder(1);
	self.btnLogon.zOrder(1);
	self.btnExit.zOrder(1);
	// Return the app to a blank state
	self.getSessionAgent.doLogout();
		
	self.btnLogon.default := true;
	self.btnExit.cancel := true;
	
	if not app.isOnDevice() then
		self.getSessionAgent().deviceHeightOffset := self.clientHeight - self.height.Integer;
	endif;
	
	///self.windowState := self.WindowState_Normal; //WindowState_Maximized;
	
	////if app.myVMAgent &lt;&gt; null then			// 21/09/2011 cnwmh5 #28230
		
		self.resizeVMControls();
		

	////endif;
	
	self.setupTimeout();	//02 Mar 2011	NDL	Par 26793 / CCMS 2047
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTimeout" id="a859409c-0868-4ad5-90e0-b41c5eb26040">
        <updating/>
        <source>setupTimeout() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 Mar 2011	cnwndl1	Initial creation	Par 26793 / CCMS 2047
20 Oct 2011	cnwkpd1	PAR #28510 - Problems logging on in Windows Mobile 6.5 device

*/

vars

	term : CM_Terminal;
	timeoutMins : Integer;
	
begin

	self.endTimeoutTimer();

	if self.myMobileDataAgent &lt;&gt; null then
		term := self.myMobileDataAgent.myTerminal;
		if term &lt;&gt; null then
			timeoutMins := term.getConfig(MobAppLogonTimeout).Integer;
		endif;
	endif;
	
	if timeoutMins &gt; 0 then
		self.timerUsercodePassword := self.txtUsername.text &amp; "/" &amp; self.txtPassword.getPasswordText();		// PAR #28510
		self.beginTimer( 	timeoutMins * MillisecondsPerMinute,	//delay: Integer;
							Timer_OneShot,	//option: Integer;
							Mobile_App_Timeout//eventTag: Integer
							);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="786a491c-8a7a-443d-a6c3-1a4cd78278b9">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 Mar 2011	cnwndl1	Initial creation	Par 26793 / CCMS 2047
20 Oct 2011	cnwkpd1	PAR #28510 - Problems logging on in Windows Mobile 6.5 device

*/

vars

	currentValues : String;
	activeControl : Control;
	button : Button;
	termAppRequired : Boolean;

begin

	if eventTag = Mobile_App_Timeout then

		currentValues := self.txtUsername.text &amp; "/" &amp; self.txtPassword.getPasswordText();		// PAR #28510
		if self.timerUsercodePassword = currentValues then
			// user hasn't done anything...  log 'em off.
			activeControl := app.activeControl();
			if activeControl &lt;&gt; null and activeControl.isKindOf( Button ) then
				button := activeControl.Button;
				if button.form &lt;&gt; null and button.form.isKindOf( MOB_HandHeldMsgBox ) then
					button.click(button);
				endif;
			endif;
			self.doExit();
			return;
		else
			// changes have occurred, maybe just slow - reset the timer
			self.setupTimeout();
		endif;
	
	else
	
		inheritMethod( eventTag );
		
	endif;

epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="848a273b-1ac3-427f-a2b9-4b7536293b69">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013049, locale);
	btnExit.translateCaption(Xlat_0013050, locale);
	btnLogon.translateCaption(Xlat_0013051, locale);
	lblPassword.translateCaption(Xlat_0013052, locale);
	lblUsername.translateCaption(Xlat_0013053, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
