    <JadeMethod name="displayStringForTransportMode" id="7f057515-8be6-4dc7-93a5-de7c3c2504a2">
        <source>displayStringForTransportMode(): String;
// ---------------------------------------------------------------------------
// Created:     15 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	str : String;
begin

	if self.transportMode = 1 then
		str := 'Road';
	elseif self.transportMode = 2 then
		str := 'Rail';
	elseif self.transportMode = 3 then
		str := 'Both';
	endif;

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doesAllowLength" id="285b28a1-7009-441a-bd26-5daf5471c07d">
        <source>doesAllowLength(_allLengths : CM_CodeSet) : Boolean;
// ---------------------------------------------------------------------------
// Created:     12 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	logCode,
	logLentghCode	: CM_Code;
begin

	if (self.allLogLengths.isEmpty) then
		return true;
	endif;

	foreach logCode in _allLengths do
		//12/10/2009  cnwdz2 par21019
		foreach logLentghCode in self.allLogLengths do
			if logCode.code = logLentghCode.code then
				return true;
			endif;
		endforeach;
		//if self.allLogLengths.includes(logCode) then
	   	//	return true;
	   	//endif;
	endforeach;
	
	return false;	

end;</source>
        <Parameter name="_allLengths" type="CM_CodeSet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesAllowLogType" id="cf52f4a0-0182-4da5-80d9-7712f40a0623">
        <source>doesAllowLogType(_allTypes : CM_CodeSet) : Boolean;
// ---------------------------------------------------------------------------
// Created:     12 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	logCode,
	logTypeCode	: CM_Code;
begin

	if (self.allLogTypes.isEmpty) then
		return true;
	endif;
	
	foreach logCode in _allTypes do
		///12/10/2009  cnwdz2 par21019
		foreach logTypeCode in self.allLogTypes do
			if logCode.code = logTypeCode.code then
				return true;
			endif;
		endforeach;
		//if self.allLogTypes.includes(logCode) then
	    //	return true;
	    //endif;
	endforeach;
	
	return false;	

end;</source>
        <Parameter name="_allTypes" type="CM_CodeSet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesAllowTreatment" id="9ed5f6d2-3e59-4a8e-a789-ad934ff1d1fe">
        <source>doesAllowTreatment(_allTreatments : CM_CodeSet) : Boolean;
// ---------------------------------------------------------------------------
// Created:     12 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	logCode,
	logTreatCode	: CM_Code;
begin

	if (self.allLogTreatments.isEmpty) then
		return true;
	endif;
	
	foreach logCode in _allTreatments do
		//12/10/2009  cnwdz2 par21019
		foreach logTreatCode in self.allLogTreatments do
			if logCode.code = logTreatCode.code then
				return true;
			endif;
		endforeach;
		//if self.allLogTreatments.includes(logCode) then
	   	//	return true;
	   	//endif;
	endforeach;
	
	return false;	

end;</source>
        <Parameter name="_allTreatments" type="CM_CodeSet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesAllowType" id="27b7b074-ecb0-402e-a652-3b499f6b0992">
        <source>doesAllowType(_operator : CM_Operator; 
			_allSpecies,
			_allGrades,
			_allTypes,
			_allTreatments,
			_allLengths : CM_CodeSet) : Boolean;

vars
	logCode,	
	logSpecCode,
	logGradeCode 	: CM_Code;
	isCodeMatching	: Boolean;
	
begin

	if (self.allOperators.isEmpty) then
		return true;
	endif;
	
	if _operator &lt;&gt; null then
		if not self.allOperators.includes(_operator) then	//#25455. It seems we need to check whether operator matches location's operator. 17/08/2010
			return false;
		endif;	//end of #25455
		if self.allOperators.includes(_operator) and
	   	   (self.allLogSpecies.isEmpty) then
			return true;
		endif;
	endif;
	
	// #25521 20/08/2010. Now, need to test whether Log Species code matches the current location.
	if _allSpecies.isEmpty then	// it means there are no species entered for filtering values. It means everything matches. Operator was checked before.
		return true;

	else	// there are _allSpecies entered. Need to check whether Log Species codes are matching
		isCodeMatching := false;
		foreach logCode in _allSpecies do
			foreach logSpecCode in self.allLogSpecies do
				if logCode.code = logSpecCode.code then
					isCodeMatching := true;
				endif;
			endforeach;
		endforeach;
		if not isCodeMatching then
			return false;
		endif;
		
	endif;	// end of #25521
	
	if self.allLogGrades.isEmpty then
		foreach logCode in _allSpecies do
			//12/10/2009  cnwdz2 par21019
			foreach logSpecCode in self.allLogSpecies do
				if logCode.code = logSpecCode.code then
					return true;
				endif;
			endforeach;
			
			//if self.allLogSpecies.includes(logCode) and
			//   (self.allLogGrades.isEmpty) then
			//	return true;
			//endif;
		endforeach;
	endif;
	
	foreach logCode in _allGrades do
		///12/10/2009  cnwdz2 par21019
		foreach logGradeCode in self.allLogGrades do
			if logCode.code = logGradeCode.code then
		//if self.allLogGrades.includes(logCode) and 
				if self.doesAllowLogType(_allTypes) and
				   self.doesAllowTreatment(_allTreatments) and
			       self.doesAllowLength(_allLengths) then
					return true;
				endif;
			endif;
	   	//endif;
		endforeach;
	endforeach;

	return false;

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_allSpecies" type="CM_CodeSet"/>
        <Parameter name="_allGrades" type="CM_CodeSet"/>
        <Parameter name="_allTypes" type="CM_CodeSet"/>
        <Parameter name="_allTreatments" type="CM_CodeSet"/>
        <Parameter name="_allLengths" type="CM_CodeSet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
