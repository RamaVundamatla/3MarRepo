    <JadeMethod name="openWithSavedSettings" id="8edd9ef0-2038-4f5c-acba-7ba5b19412cb">
        <updating/>
        <source>openWithSavedSettings(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2022	navkc1	Initial creation ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables

*/

vars

begin
	
	if not inheritMethod() then
		// Default number of row to 250
		self.txtNumOfRow.text := "250";
		
		// Default to true. We removed the Classic Hybrid Eco behaviour from the screen. Setting this to true to mimic Classic behaviour if there's no user saved settings // navkc1	20/08/2025	JIRA MTN 35788
		self.chkTableCount.value := true;
		self.performTableCount := true;
		self.chkAllowFilter.value := true;
		self.performAllowFilter := true;
		self.chkAllowMore20.value := true;
		self.performAllowMore20 := true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateCargoGroupDetails" id="b9414102-4335-494f-8a46-c1f756f8d3d0">
        <updating/>
        <source>populateCargoGroupDetails(_site: Integer; _cargoGroup: CM_CargoGroup; _columns: EntTableRowArray; _table: CM_DataTable input; _row : Integer io) updating;
/*

Purpose:			
	Reimplement in subclass
Parameters:			

Return Value:		

Date		Who		Reason
08 November 2022	navkc1	Initial creation Bug 54927: MTN - Loading a cargo on ship edi file freeze the system if the New version of the voyage operation screen is opened

*/

vars

begin
	return;
epilog

end;</source>
        <Parameter name="_site" type="Integer"/>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
        <Parameter name="_columns" type="EntTableRowArray"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processStopsEDI" id="91f3ca15-3dc2-479a-a6a5-ee4e2c198a6f">
        <updating/>
        <source>processStopsEDI() updating;
//----------------------------------------------------------------
//	Created:	15 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815


begin

	app.mousePointer := Window.MousePointer_HourGlass;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxProcessStopsEDIOnShip(self.myCurrentVoyage, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Process Customs EDI', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

epilog

	app.mousePointer := Window.MousePointer_Default;						

end;</source>
    </JadeMethod>
    <JadeMethod name="receiveDrop" id="8d4516f2-5c70-44ab-8b8f-49ee586aab0c">
        <updating/>
        <source>receiveDrop(_table : CM_DataTable input;win: Window input) updating;
//--------------------------------------------------------------
//Created: 17 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars

	lc : CM_LocationsController;
	isInterchangeMove : Boolean;
	queueSet : CM_RTQueueSet;
	queue : CM_RadioTelemetryQueue;
	icLc : CM_LocationsController;
	moveRule : CM_RTMoveMethod;
	obj : Object;
	ti : CM_TrackedItem;
	sourceLocation : CM_LocationsController;
	iter : Iterator;
	
begin
	if app.myMoveController = null then
		return;
	endif;
	if _table = win // then	// 20/7/17 MAP TFS4719
	and ( _table = self.tblOffsite or _table = self.tblPreNote ) //19 Sep 2016	NDL TFS 7016
	then
		return;
	endif;
	
	if _table = null then
		app.raiseCMException1(INVALID_MOVE_REQUEST, app.getErrorString(No_Target_location_found), null, null);	
		return;
		
	elseif _table = self.tblOnship then
	
		//23 Jun 2021	NDL	TFS 51231 - Special barge variant for STWR - queued cargo should
		//								go to the interchange area not direct to the barge.
		if self.myCurrentVoyage &lt;&gt; null
		and self.moveModeForm = QUEUE_MODE
		and self.myCurrentVoyage.isBarge
		and win = self.tblOnsite
		and self.tblOnsite.allSelectedObjects.size &gt; 0 then
			lc := self.cmbLoadLocation.listObject.CM_LocationsController;	
			if lc &lt;&gt; null then
				if lc.isKindOf(CM_YardICAreaLaneController) then
					//they selected a wp interchange area
					isInterchangeMove := true;
				elseif lc.isKindOf(CM_CraneLaneController) then
					//they selected a crane transfer interchange area
					isInterchangeMove := true;
				else
					if lc.isKindOf(CM_GeneralCargoController) or lc.isKindOf(CM_ShipBlockController) then
						//they selected an on-barge location
						//If the location is associated with a workpoint or crane queue, and that queue is marked to be
						// loaded by cargo lander (not a machine) and the wp or crane has an associated load lane
						// i.e. interchange area, then that i/c lane becomes the target for our move.
						create queueSet transient;
						lc.getQueues( queueSet );
						foreach queue in queueSet do
							if queue.isUseShipLanderForLoad then
								if queue.isKindOf( CM_VoyageWorkPointQueue ) then
									icLc := queue.CM_VoyageWorkPointQueue.getFirstAvailableLoadLane();
									if icLc &lt;&gt; null then
										lc := icLc;
										isInterchangeMove := true;
										break;
									endif;
								elseif queue.isKindOf( CM_VoyageCraneQueue ) then
									icLc := queue.CM_VoyageCraneQueue.getFirstAvailableLoadLane();
									if icLc &lt;&gt; null then
										lc := icLc;
										isInterchangeMove := true;
										break;
									endif;
								endif;
							endif;
						endforeach;
					endif;
				endif;
			endif;
			
			//now consider the move rules that will be used, because if any end with an IMV then we don't use these rules
			if isInterchangeMove then
				iter := self.tblOnsite.allSelectedObjects.createIterator;
				while iter.next( obj ) do
					ti := obj.CM_TrackedItem;
					sourceLocation := ti.myPrimaryActualLocation;
					moveRule := self.myTerminal.getRTMoveMethod( sourceLocation, lc );
					if moveRule &lt;&gt; null then
						if moveRule.lastMachineIsIMV then
							isInterchangeMove := false;
							break;
						endif;
					endif;
				endwhile;
				delete iter;
			endif;
		endif;
		if isInterchangeMove then
			//23 Jun 2021	NDL	TFS 51231 - Its a move / multi-move for barge to an interchange area
			// and although it is NOT a load (so not actually a voyage job/wle) it is supposed to go into the Voyage queue,
			// as long as a matching queue exists.
			// Also in this scenario, the moves should be queued in the order they were selected.
			self.doBargeLoadMoves( lc );
		else 
			// Par 14970
			self.doLoad(false, _table , win); //cnwrd1 par 28343 14.10.2011
		endif;
		return;
		
	elseif _table = self.tblOnsite then
		// 03/11/2025 MTN 36255
		// if currently selected an RRP ti for a release then try assigned to release, otherwise try to discharge
		if self.tblOnsite.allSelectedObjects.size = 1 then
			ti := self.tblOnsite.allSelectedObjects.first.CM_TrackedItem;
			if ti.isRRPforVoyage then
				self.assignTIToReleaseRequest(ti.allWorklistEntries.first);
				return;
			endif;
		endif;
		
		if self.cmbTerminalArea.listObject = null and cmbTerminalArea.text &lt;&gt; app.getErrorString(Planned_location) then		// 27/6/17 MAP TFS4719
			app.msgBox( app.getErrorString(Select_onsite_location), app.getErrorString(Move_error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		self.doDischarge(false, true, self.tblOnsite, win); //cnwrd1 par 28343 14.10.2011
		return;

	elseif _table = self.tblOffsite then
		self.doDischarge(false, true, self.tblOffsite, win);	//04 Feb 2011	NDL	Par 26867 //cnwrd1 par 28343 14.10.2011
		return;
		
	endif;
	
epilog
	delete app.myMoveController; //epr TFS 8220 7/12/17 leaking transient
	app.myMoveController := null;
	delete queueSet;
	delete iter;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeTI" id="5eb57f54-909d-4e2a-a457-72df0c8a22b8">
        <source>removeTI(_ti : CM_TrackedItem);
//----------------------------------------------------------------
//	Created:	03 October 2005	by Jason Chapman  (cnwjc2)
//	18/11/2022	navkc1	Bug 54927: MTN - Loading a cargo on ship edi file freeze the system if the New version of the voyage operation screen is opened
//  28/11/2022	navkc1	ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default
//----------------------------------------------------------------
vars

//	tmpTbl : CM_DataTable;
	idx : Integer;
	
begin

	// 30 Jun 2010	NDL Par24602
	if (not self.allDisplayedTIs.includes(_ti)) then
		return;
	endif;
	
	if self.tblOnship.findObjectInRow(_ti, idx) then
		self.tblOnship.removeItem(idx);
		self.colourTableRows(tblOnship);	// navkc1	18/11/2022	#54927 colour the table after removing tis
	endif;
	
	if self.tblOnsite.findObjectInRow(_ti, idx) then
		self.tblOnsite.removeItem(idx);
		self.colourTableRows(tblOnsite);	// navkc1	18/11/2022	#54927 colour the table after removing tis
	endif;
	
	if self.tblOffsite.findObjectInRow(_ti, idx) then
		self.tblOffsite.removeItem(idx);
		self.colourTableRows(tblOffsite);	// navkc1	18/11/2022	#54927 colour the table after removing tis
	endif;
	
	//self.updateStatusBarCounts();
	self.updateStatusBarCounts(true, null);  // 28/10/2022	navkc1	#55408
		
	
/*	// removed for Par24602	
	if (not self.allNotableTIs.includes(_ti)) then
		return;
	endif;
	
	if self.tblOnship.findObjectInRow(_ti, idx) then
		tmpTbl := self.tblOnship;
	endif;		
	
	if tmpTbl = null then
		return;
	endif;
	
	tmpTbl.removeItem(idx);
	*/
	
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="resizePostInitialShow" id="45fc0d72-1077-45fd-bc1c-459b9cd48e5a">
        <updating/>
        <source>resizePostInitialShow() updating;
/*
Purpose:		 // PAR 37202	
Date		Who		Reason
02 December 2015	cnwab1	Initial creation
*/

vars

begin
	inheritMethod();
	
	self.setTableParentsFromXML(self.myUserWindow);
	self.setTablePositionsFromXML(self.myUserWindow);


