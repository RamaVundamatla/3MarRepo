    <JadeMethod name="setProxy" id="43fcc4a5-5537-4287-9d67-a90eb109324d">
        <updating/>
        <source>setProxy(	_date : Date;
			_description : String;
			_myCalendar : CM_Calendar;
			_myCalendarYear : CM_CalendarYear;
			_dataSource : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     21 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	
	self.date := _date;
	self.description := _description[1:60];
	self.myCalendar := _myCalendar;
	self.myCalendarYear := _myCalendarYear;
	self.dataSource := _dataSource;
	
end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_myCalendar" type="CM_Calendar"/>
        <Parameter name="_myCalendarYear" type="CM_CalendarYear"/>
        <Parameter name="_dataSource" type="Integer"/>
