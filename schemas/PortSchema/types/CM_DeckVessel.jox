    <JadeMethod name="getSubDeckByCode" id="902a3317-6473-4fa5-83fd-ee7e47233622">
        <source>getSubDeckByCode(_code: String): CM_Deck;
/*
Purpose:			
Date		Who		Reason
21 September 2012	cnwab1	Initial creation
*/

vars
	deck : CM_Deck;
begin

	foreach deck in self.allSubDecks discreteLock where deck.code = _code   do
		return deck;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_Deck"/>
    </JadeMethod>
