    <JadeMethod name="getResourcesInUseFor" id="de1f8d25-45f0-4634-9d9f-193799c53fb5">
        <source>getResourcesInUseFor( _transServiceBroker : CM_TransServiceBroker; _resources : CM_ResourceTypeDict io );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 January 2010	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

begin
	if _resources = null then
		return;
	endif;
	
	_resources.clear();
	
	_transServiceBroker.getResourcesInUse(_resources);
	
epilog

end;</source>
        <Parameter name="_transServiceBroker" type="CM_TransServiceBroker"/>
        <Parameter name="_resources" type="CM_ResourceTypeDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="hasResources" id="9e82d07c-47ee-4c56-969e-3e41b6d3001e">
        <source>hasResources():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

	transType : CM_TransactionType;
	obj : Object;
	toDoTask : CM_ToDoTaskDesc;
	
begin

	if self.myServiceBroker &lt;&gt; null then
		if self.myServiceBroker.isTransServiceBroker then
			transType := self.myServiceBroker.CM_TransServiceBroker.myTransactionType;
			if transType &lt;&gt; null then
				foreach obj in transType.allToDoTaskDesc do
					if not obj.isKindOf(CM_ToDoTaskDesc) then
						continue;
					endif;
					toDoTask := obj.CM_ToDoTaskDesc;
					if not toDoTask.allResourceTypes.isEmpty then
						return true;
					endif;
				endforeach;
			endif;
		endif;
	endif;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="d1c5e12d-7651-4216-b925-5bbac5c7023f">
        <updating/>
        <source>initialise(_groupCount : Integer io) updating;
vars
	tmcDebtor : CMIF_TMCDebtorGroup;
	aDM : CM_DebtorMap;
	resourceBroker : CM_TransResourceServiceBroker;
	tmcBroker : CMIF_TMCTaskResourceTypeGroup;
	tmcResourceHeader : CMIF_TMCTaskResourceTypeHeader;
begin
	self.myTMCController := self.myGroup.myTMCController;	// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
	self.hidePictures := self.myTMCController.hidePictures;

	//07 Jan 2010 NDL CCMS MES 1006	
	if self.myServiceBroker.isTransServiceBroker then
	
		if not self.myServiceBroker.CM_TransServiceBroker.allResourceBrokers.isEmpty then
			create tmcResourceHeader;
			tmcResourceHeader.myTransServiceBroker := self.myServiceBroker.CM_TransServiceBroker;
			tmcResourceHeader.itemName := "Resource Mappings"; 
			tmcResourceHeader.extractName := tmcResourceHeader.itemName;	// 23659
			tmcResourceHeader.myTMCController := self.myTMCController;	// 23659
			tmcResourceHeader.myGroup := self;
			_groupCount := _groupCount + 1;
		endif;
		
		foreach resourceBroker in self.myServiceBroker.CM_TransServiceBroker.allResourceBrokers do
			create tmcBroker;
			tmcBroker.myTransResourceServiceBroker := resourceBroker;
			tmcBroker.itemName := resourceBroker.getTransactionClassName(); 
			tmcBroker.extractName := resourceBroker.getTransactionCode();	// 23659
			tmcBroker.myGroup := tmcResourceHeader;
			tmcBroker.initialise(_groupCount);
		endforeach;
		
	endif; 
		
	create tmcDebtor as CMIF_TMCDebtorGroupDefault;
	tmcDebtor.myDebtor := null;
	tmcDebtor.myDebtorMap := null;
	tmcDebtor.myServiceBroker := self.myServiceBroker;
	tmcDebtor.itemName := tmcDebtor.getItemName();
	tmcDebtor.extractName := tmcDebtor.getItemCode();	// 23659
	tmcDebtor.myGroup := self;
	tmcDebtor.initialise(_groupCount);

	foreach aDM in self.myServiceBroker.allDebtorMapsByDebtor do
		if aDM.myDebtorNode = null then
			continue;
		endif;
		create tmcDebtor;

		tmcDebtor.myDebtor := aDM.myDebtorNode;
		tmcDebtor.myDebtorMap := aDM;
		tmcDebtor.itemName := tmcDebtor.getItemName();
		tmcDebtor.extractName := tmcDebtor.getItemCode();	// 23659
		tmcDebtor.myGroup := self;
		tmcDebtor.initialise(_groupCount);
	endforeach;
		
	_groupCount := _groupCount + 1;	
end;</source>
        <Parameter name="_groupCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setControllerCurrent" id="148e9f5f-5add-47f7-a593-0878941802cd">
        <source>setControllerCurrent() ;
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
vars
	aTransSB : CM_ServiceBroker; 
	aCommMap : CM_CommodityMap;
begin
	inheritMethod();

	myTMCController.myCurrentMapServiceBroker := self.myServiceBroker;

	aTransSB := self.myServiceBroker;
	if aTransSB.isKindOf(CM_TransServiceBroker) then
		aCommMap := aTransSB.CM_TransServiceBroker.commodityMap;
	elseif aTransSB.isKindOf(CM_MoveServiceBroker) then
		aCommMap := aTransSB.CM_MoveServiceBroker.commodityMap;
	else
		return;
	endif;

	myTMCController.myCurrentMapCommodity := aCommMap;
	myTMCController.myCurrentMapContents := aCommMap.contentsMap;
	myTMCController.myCurrentMapIMEX := myTMCController.myCurrentMapContents.imexMap;
	myTMCController.myCurrentMapProduct := myTMCController.myCurrentMapIMEX.myProductMap;
	myTMCController.myCurrentMapProdGrp := 	myTMCController.myCurrentMapProduct.myProductGroupMap;
	myTMCController.myCurrentMapTIService := myTMCController.myCurrentMapProdGrp.myCargoTypeMap;
	myTMCController.myCurrentMapTM := myTMCController.myCurrentMapTIService.transactionMap;

end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="695e2ebe-880b-4470-a57a-5ea6a427a79d">
        <source>setEnableObjects(form: INV_TransactionMap io);
// 30 May 2018	jlgsl4	TFS 38711 - error copying Transaction Map transaction eg. Road-&gt;Yard

vars

begin

	inheritMethod(form);

	form.menuSItemNew.visible := true;  // MAIN CARGO NEW MENU
	form.menuTMVnew.visible := false;  // MAIN VTMIS NEW MENU	
	form.mnuTMExport.visible := false;
	form.menuMappingSetActive.visible := false;
	form.modePropertyNew := INV_TransactionMap.ModeProperty_Debtor;
	if self.myServiceBroker.isKindOf(CM_TransServiceBroker) then
		form.modePropertyUpdate := INV_TransactionMap.ModeProperty_TransType;
		form.modePropertyDelete := INV_TransactionMap.ModeProperty_TransType;		
		if self.hasResources then	//06 Jan 2010 NDL CCMS MES 1006
			form.menuSINewTranType.visible := true;
			form.mnuResourceType.visible := true;
			form.mnuResourceType.enabled := true;		// was missing, found in 33959 qual
		endif;
	else
		form.modePropertyUpdate := INV_TransactionMap.ModeProperty_Move;
		form.modePropertyDelete := INV_TransactionMap.ModeProperty_Move;
	
	endif;
	form.menuSItemNew.enabled := true;
	form.menuSINewDebtor.visible := true;
	if form.modePropertyUpdate &lt;&gt; INV_TransactionMap.ModeProperty_Move then // TFS 38711 - hide move transaction eg. road-&gt;yard 'Copy'
		form.mnuCopy.visible := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 38711
		form.btnCopy.enabled := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 38711
	endif; // TFS 38711
	form.mnuReplace.visible := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
	form.btnReplace.enabled := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
	form.menuSItemDelete.visible := true;
	form.btnDelete.enabled := true;
	form.btnNew.enabled := true;
	
	
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrent" id="a81abd62-b12e-47d7-8291-fb0217e73dea">
        <updating/>
        <source>setMyCurrent(form: INV_TransactionMap io) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aTransSB : CM_ServiceBroker; 
	aCommMap : CM_CommodityMap;
begin
	inheritMethod(form);

	form.myTMCSB := self;
	form.myCurrentMapServiceBroker := self.myServiceBroker;

	aTransSB := self.myServiceBroker;
	if aTransSB.isKindOf(CM_TransServiceBroker) then
		aCommMap := aTransSB.CM_TransServiceBroker.commodityMap;
	elseif aTransSB.isKindOf(CM_MoveServiceBroker) then
		aCommMap := aTransSB.CM_MoveServiceBroker.commodityMap;
	else
		return;
	endif;

	form.myCurrentMapCommodity := aCommMap;
	form.myCurrentMapContents := aCommMap.contentsMap;
	form.myCurrentMapIMEX := form.myCurrentMapContents.imexMap;
	form.myCurrentMapProduct := form.myCurrentMapIMEX.myProductMap;
	form.myCurrentMapProdGrp := 	form.myCurrentMapProduct.myProductGroupMap;
	form.myCurrentMapTIService := form.myCurrentMapProdGrp.myCargoTypeMap;
	form.myCurrentMapTM := form.myCurrentMapTIService.transactionMap;

/*
	form.myCurrentMapContents := aCommMap.contentsMap;
	form.myCurrentMapIMEX := aCommMap.contentsMap.imexMap;
	form.myCurrentMapProduct := aCommMap.contentsMap.imexMap.myProductMap;
	form.myCurrentMapProdGrp := aCommMap.contentsMap.imexMap.myProductMap.myProductGroupMap;
	form.myCurrentMapTIService := aCommMap.contentsMap.imexMap.myProductMap.myProductGroupMap.myCargoTypeMap;
	form.myCurrentMapTM := aCommMap.contentsMap.imexMap.myProductMap.myProductGroupMap.myCargoTypeMap.transactionMap;

*/
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
