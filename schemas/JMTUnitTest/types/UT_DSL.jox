    <JadeMethod name="addWharf" id="017e6dc8-ec61-4e27-ad20-2e58b41cc209">
        <source>addWharf(_wharfId, _wharfDesc : String; _harbour : HMS_Harbour; _length, _width : Integer) : HMS_Wharf;

/*

Purpose:	Add a wharf		

Date			Who		Reason
21/12/2011 		cnwmh5	Initial creation

*/

vars

	pxyWharf			: HMS_Wharf;
	wharf				: HMS_Wharf;
	resource			: HMS_ResourceForWharf;
	
	isLogicalWharf		: Boolean;
	waterOnLeft			: Boolean;
	isVisibleOnView		: Boolean;
	displayLeftToRight	: Boolean;
	overhangStart		: Integer;
	overhangEnd			: Integer;
	timeInHoursAddExtraBlock	: Decimal[12,2];
	
begin

	self.deleteWharf(_wharfId, _harbour);

	create pxyWharf transient;
	
	pxyWharf.setProxy(_harbour,						// Harbour
					  null,							// Jade scode
					  app.myPassport.userCode);		// user code
	
	
	pxyWharf.setPropertyValue("code", _wharfId);
	pxyWharf.setPropertyValue("description", _wharfDesc);
	pxyWharf.setPropertyValue("length", _length);
	pxyWharf.setPropertyValue("width", _width);
	isLogicalWharf := true;
	if self.opts.includesKey("IsLogicalWharf") then
		isLogicalWharf := self.opts.bool("IsLogicalWharf");
	endif;
	pxyWharf.setPropertyValue("isLogicalWharf", isLogicalWharf);
	waterOnLeft := true;
	if self.opts.includesKey("WaterOnLeft") then
		waterOnLeft :=  self.opts.bool("WaterOnLeft");
	endif;
	pxyWharf.setPropertyValue("waterOnLeft", waterOnLeft);
	isVisibleOnView := true;
	if self.opts.includesKey("IsVisibleOnView") then
		isVisibleOnView :=  self.opts.bool("IsVisibleOnView");
	endif;
	pxyWharf.setPropertyValue("isVisibleOnView", isVisibleOnView);
	displayLeftToRight := true;
	if self.opts.includesKey("DisplayLeftToRight") then
		displayLeftToRight :=  self.opts.bool("DisplayLeftToRight");
	endif;
	pxyWharf.setPropertyValue("displayLeftToRight", displayLeftToRight);
		if self.opts.includesKey("OverhangStart") then
		overhangStart := self.opts.int("OverhangStart");
	endif;
	pxyWharf.setPropertyValue("overhangMaxMetreEnd", overhangStart);
	if self.opts.includesKey("OverhangEnd") then
		overhangEnd := self.opts.int("OverhangEnd");
	endif;
	pxyWharf.setPropertyValue("overhangZeroMetreEnd", overhangEnd);
	if self.opts.includesKey("TimeInHoursAddExtraBlock") then
		timeInHoursAddExtraBlock := self.opts.dec("TimeInHoursAddExtraBlock");
	endif;
	pxyWharf.setPropertyValue("timeTill2ndResource", timeInHoursAddExtraBlock);
	
	pxyWharf.allTerminals.add(self.getTerminal());
	
	app.myTrxCA.trxCreateWharf(pxyWharf, wharf, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return wharf;
	
epilog

	delete pxyWharf;

end;</source>
        <Parameter name="_wharfId" type="String"/>
        <Parameter name="_wharfDesc" type="String"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_length" type="Integer"/>
        <Parameter name="_width" type="Integer"/>
        <ReturnType type="HMS_Wharf"/>
    </JadeMethod>
    <JadeMethod name="addWharfResource" id="f654f7e6-8a21-4dd8-a946-71da0d610e69">
        <source>addWharfResource( _wharf : HMS_Wharf input; _hmsResource1 : HMS_Resource; _hmsResource2 : HMS_Resource );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2019	jlgndl1	Initial creation	TFS 44773

*/

vars

	load : Boolean;
	pxyWharf : HMS_Wharf;
	pxyWharfRes : HMS_ResourceForWharf;
	pxyWharfRes2 : HMS_ResourceForWharf;
	wharfRes : HMS_ResourceForWharf;
	harbour : HMS_Harbour;

begin

	harbour := _wharf.getHarbourReal(); 

	app.cmsBeginLoad( load );
	pxyWharf := _wharf.pxyCreateUpdateProxy();
	delete pxyWharf.myHookCode;
	pxyWharf.setPropertyValue( HMS_Wharf::myHookCode.name, null );
	app.cmsEndLoad( load );
	
	pxyWharfRes := pxyWharf.allResourcesForWharf[ harbour, pxyWharf, 1 ];
	if pxyWharfRes = null then
		create pxyWharfRes transient;
	endif;
	pxyWharfRes.setResourceOrder(1);
	pxyWharfRes.setProxy( pxyWharf, harbour, _hmsResource1, _hmsResource1, _hmsResource1 );
	
	if _hmsResource2 &lt;&gt; null then
		pxyWharfRes2 := pxyWharf.allResourcesForWharf[ harbour, pxyWharf, 2 ];
		if pxyWharfRes2 = null then
			create pxyWharfRes2 transient;
		endif;
		pxyWharfRes2.setResourceOrder(2);
		pxyWharfRes2.setProxy( pxyWharf, harbour, _hmsResource2, _hmsResource2, _hmsResource2 );
	endif;
	
	app.myTrxUA.trxUpdateHMSObject( pxyWharf, app.myPassport );
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

epilog

	delete pxyWharf;
	delete pxyWharfRes;
	delete pxyWharfRes2;

end;</source>
        <Parameter name="_wharf" type="HMS_Wharf" usage="input"/>
        <Parameter name="_hmsResource1" type="HMS_Resource"/>
        <Parameter name="_hmsResource2" type="HMS_Resource"/>
    </JadeMethod>
    <JadeMethod name="addWorkOrder" id="05bc7516-2880-4663-bb4a-c5764ec35182">
        <source>addWorkOrder( _id : String; _woStatus : Integer ; _tiset : CM_TISet) : CM_WorkOrderTI;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 Jan 2010	cnwrd1	Initial creation
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
29 Mar 2023 navhl20	ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
*/

vars
	pxyWorkOrder  : CM_WorkOrderTI;
	realWorkOrder : CM_WorkOrder;
	availGrades	  : IntegerArray;
	cargoType     : CM_CargoType;
	root          : CM_Root;
	totalReq      : Integer;
	dtRequired,
	dtStart	      :	TimeStamp;
	remarks       : String;
	emails        : CM_EmailEntityByTypeNameDict;

begin

	deleteWorkOrder(_id);
	
	root      := CM_Root.firstInstance;
	cargoType := root.allCargoTypesById[TI_CargoType_Container];
	
	create emails transient;
		
	if self.opts.includesKey("TotalReq") then
		totalReq := self.opts.int("TotalReq");
	endif;
	
	if self.opts.includesKey("DtRequired") then
		dtRequired := self.opts.str("DtRequired").TimeStamp;
	endif;
	
	if self.opts.includesKey("DtStart") then
		dtStart := self.opts.str("DtStart").TimeStamp;
	endif;
	
	if self.opts.includesKey("Remarks") then
		remarks := self.opts.str("Remarks");
	endif;
	
	
	create pxyWorkOrder transient;

	pxyWorkOrder.setProxy(		
			emails, 							//_allEmailAddresses
			null, 								//_customerReference
			false, 								//_emailNotification
			app.actualTimeServer, 				//_enteredByDT
			app.getMyUser(), 					//_enteredByUser 
			'',									//_approvedBy
			app.getMyUser().myOrganisation, 	// _myOrganisation
			app.myPassport.myTerminal, 			//_myTerminal
			remarks,  							//_remarks
			dtRequired,							//_requiredByDT
			dtStart, 							//_startAtDT
			_woStatus 							//_taskStatus    WO_STATUS_USERENTRY
			);
			
			
	pxyWorkOrder.setID( _id ); //set the ID so we know what one we are creating to delete later..
	//pxyWorkOrder.setTotalRequired(totalReq);								//08.02.2023 navma1 #56457:[56458]

	/*
	12.01.2023 navma1 #56141 Task#56147
	pxyWorkOrderSource := pxyWorkOrder.setProxyWorkOrderSource(
			null,				// real work order, dont have here
			pxyWorkOrder,   	// the source parent, the pxyWorkOrder here (is also used to set source for pack task
			cargoType, 			// cargo type - ISO Container here
			cargoList, 				// CSV string of cargo ID's
			false				// not updating here
			);
	*/
	
	self.addWorkOrderTask(pxyWorkOrder,_tiset,null);							//08.02.2023 navma1 #56457:[56458]			//29.3.2023 navhl20	#56614[56615]
	
	/*
	12.01.2023 navma1 #56141 Task#56147
	operator := self.opts.obj("Operator").CM_Operator;
	if operator &lt;&gt; null then
		create availGrades transient;
		if 	self.opts.includesKey("AvailabilityGrade") then
			availGrades.add(self.opts.int("AvailabilityGrade"));
		endif;
		create pxyRequest transient;
		pxyRequest.setProxy(
				null, 						//_myCargoType		: CM_CargoType;
				self.opts.str("ISOType"), 	//_isoType			: String;
				self.opts.obj("Operator").CM_Operator,	//_operator			: CM_Operator;
				null, 						//_operatorGroup		: CM_OperatorGroup;
				0,							//_totalRequested		: Integer;
				null,						//_isoGroup			: String;
				availGrades, 				//_availabilityGrades	: IntegerArray;
				false,						//_clean 				: Boolean;
				false,						// _heavyRated			: Boolean;
				null,						//		: CM_LocationsController;
				null						//_product			: CM_Product	
				);
		pxyWorkOrderSource.proxyAddWoRequest(pxyRequest);
	endif;
	*/
	
	app.myTrxCA.trxCreateWorkOrder(pxyWorkOrder,realWorkOrder,  app.myPassport);		//12.01.2023 navma1 #56141 Task#56147
	
	//04.11.2021 navma1 #52248
	if app.myPassport.hasErrors  and app.myPassport.allErrors.includesErrorCode(TaskCargoTypeMismatch) then
		assertTrxError(TaskCargoTypeMismatch);
		self.clearExpectedTrxErrors();
	else
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	endif;

	return realWorkOrder.CM_WorkOrderTI;		
	
epilog
	delete pxyWorkOrder;
	delete emails;
	delete availGrades;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_woStatus" type="Integer"/>
        <Parameter name="_tiset" type="CM_TISet"/>
        <ReturnType type="CM_WorkOrderTI"/>
    </JadeMethod>
    <JadeMethod name="addWorkOrderPermitRequest" id="dc2e6606-fe51-4ea6-a817-90e248991d4d">
        <source>addWorkOrderPermitRequest(_id : String; _voyage : CM_Voyage) : CM_WorkOrderVoyage;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/07/2019	jlgdap1		Initial creation TFS 45246 PEL1 Unit Test - Voyage Work Orders Number 2
// 24 Mar 2023  navhl20 	ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
//
vars
	woVoyage : CM_WorkOrderVoyage;
	realWorkOrder : CM_WorkOrder;
	woDtlPermit : CM_WodPermitRequest;
	emails : CM_EmailEntityByTypeNameDict;
	now : TimeStamp;

begin
	if _voyage = null then
		return null;
	endif;
	
	now := app.actualTimeServer;
	create emails transient;
	create woVoyage transient;
	woVoyage.setProxy(
			emails, 						//_allEmailAddresses
			null, 							//_customerReference
			false, 							//_emailNotification
			app.actualTimeServer, 			//_enteredByDT
			app.getMyUser(), 				//_enteredByUser 
			'',								//_approvedBy
			app.getMyUser().myOrganisation, // _myOrganisation
			app.myPassport.myTerminal, 		//_myTerminal
			null,  							//_remarks
			now,							//_requiredByDT
			null,	 						//_startAtDT
			WO_STATUS_USERENTRY 			//_taskStatus
			);
	
	woVoyage.setID( _id ); //set the ID so we know what one we are creating to delete later..
	woVoyage.setMyVoyage( _voyage );
	
	create woDtlPermit transient;
	woDtlPermit.setProxyForCreate(woVoyage, WO_TASK_PERMIT);
	//woDtlPermit.setProxy( now, now, false );													//24.3.2023 navhl20	#57301[57303]
	woDtlPermit.setProxyReqByDT(now);															//24.3.2023 navhl20	#57301[57303]
	woDtlPermit.setProxyPermitRequest(	INV_WO_PERMIT_MANUALETMAL,		// _permitType
										WO_TASK_MARINEINITIAL,			// _permitDetailType
										_voyage.myOperator,				// _cargoOperator
										null	);						// _workOrderDetail
										
	woVoyage.setLengthOfTime(0.5);
	
	app.myTrxCA.trxCreateWorkOrder(woVoyage, realWorkOrder, app.myPassport);
	if not app.myPassport.noErrors then
		realWorkOrder := null;
	endif;
	
	return realWorkOrder.CM_WorkOrderVoyage;
epilog
	delete emails;
	delete woVoyage;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CM_WorkOrderVoyage"/>
    </JadeMethod>
    <JadeMethod name="addWorkOrderSchedule" id="29dfc134-4092-4382-b55d-562e8859a04b">
        <source>addWorkOrderSchedule( _workOrderDtl: CM_WorkOrderTIDtl; _schedDate : TimeStamp; _count: Integer) : CM_WorkOrderSchedule;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 January 2010	cnwrd1	Initial creation

*/

vars
	pxySchedule,
	realSchedule : CM_WorkOrderSchedule;
begin

	create pxySchedule transient;
	pxySchedule.setProxy( _count, _schedDate);
	
	app.myTrxCA.trxCreateWorkOrderSchedule(pxySchedule, realSchedule,_workOrderDtl, app.myPassport);
	
	return realSchedule; 

epilog

end;</source>
        <Parameter name="_workOrderDtl" type="CM_WorkOrderTIDtl"/>
        <Parameter name="_schedDate" type="TimeStamp"/>
        <Parameter name="_count" type="Integer"/>
        <ReturnType type="CM_WorkOrderSchedule"/>
    </JadeMethod>
    <JadeMethod name="addWorkOrderTask" id="535120fc-27d4-403d-826a-7be2c413105a">
        <source>addWorkOrderTask( _workOrder : CM_WorkOrderTI io;_tiset : CM_TISet; _todoSet : CM_ToDoTaskDescSet);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 Jan 2010	cnwrd1	Initial creation
18 May 2022	navcs2	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
24 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
28 Mar 2023 navhl20	ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
31 Mar 2023	navcs2	ChangeRequest 55440:[54990]: EUP - Release Cargo Work Order - Enhancement
18 Apr 2023 navhl20 ChangeRequest 55442:[57629] EUP - Pack Cargo Work Order - Enhancement
05 Jul 2024 navhl20	ChangeRequest 61368: EUP* | Adding Pack Reserve Child to Packing Work order Release Request
*/

vars
	terminal 		: CM_Terminal;
	realWorkOrder,
	pxyWorkOrder	: CM_WorkOrderTI;
	pxyWODtl,
	realWODtl 		: CM_WorkOrderDtl;
	autoQ,
	autoRTQ 		: Boolean;
	taskType		: Integer;
	dtRequired,
	dtStart			: TimeStamp;
	toDoTaskID 		: Integer;
	toDoTask 		: CM_ToDoTaskDesc;
	root		    : CM_Root;
	target,
	unpackLoc		: CM_TerminalArea;
	todoSet 		: CM_ToDoTaskDescSet;
	tiSet			: CM_TISet;
	ti				: CM_TrackedItem;
	vessel			: CM_Vessel;
	voyage 			: CM_Voyage;
	operator		: CM_Operator;
	subTerm1		: CM_SubTerminal;
	release			: CM_BulkRelease;
	code			: String;
	relDate			: TimeStamp;
begin
		
	root := CM_Root.firstInstance;
	terminal := _workOrder.myTerminal;

	if self.opts.includesKey("targetTA") then
		target := terminal.allTerminalAreas[opts.str('targetTA')].CM_TerminalArea;
	endif;
	
	if self.opts.includesKey("unpackTA") then
		unpackLoc := terminal.allTerminalAreas[opts.str('unpackTA')].CM_TerminalArea;
	endif;
	
	if self.opts.includesKey("autoRTQ") then
		autoRTQ := opts.bool("autoRTQ");
	endif;
	
	if self.opts.includesKey("dtRequired") then
		dtRequired := opts.str("dtRequired").TimeStamp;
	endif;
	
	if self.opts.includesKey("dtStart") then
		dtRequired := opts.str("dtStart").TimeStamp;
	endif;
	
	if self.opts.includesKey("autoQ") then
		autoQ := opts.bool("autoQ").Boolean;
	endif;
	
	if self.opts.includesKey("toDoTaskID") then
		toDoTaskID:= opts.int("toDoTaskID");
	endif;
	
	
	if toDoTaskID &lt;&gt; null then
		toDoTask := root.allToDoTaskDescriptions[toDoTaskID];
	endif;
	
	if opts.includesKey("taskType") then
		taskType := opts.int("taskType");
	else
		taskType := WO_TASK_MOVE;
	endif;
	
	if opts.includesKey("bulkReleaseCode") and opts.includesKey("bulkReleaseDT") then
		code :=  opts.str("bulkReleaseCode");
		relDate := opts.timestamp("bulkReleaseDT").TimeStamp;
		release := terminal.allBulkReleasesByCodeDate[code, relDate];
	endif;

	terminal := app.myPassport.myTerminal;
	
	//realWorkOrder :=  terminal.allWorkOrders[_workOrderID].CM_WorkOrderTI;
	
	if _workOrder.isTransient then
		pxyWorkOrder := _workOrder.CM_WorkOrderTI;
	else
		pxyWorkOrder := app.createUpdateProxy(realWorkOrder).CM_WorkOrderTI;
	endif;

	
			
	//WO_TASK_MOVE
	//WO_TASK_TODO
	//WO_TASK_PACK
	//WO_TASK_UNPACK
	
	if taskType = WO_TASK_MOVE then
		create pxyWODtl as CM_WodMove transient;		
		pxyWODtl.CM_WodMove.setProxyMove( null,target,autoRTQ, null); //TFS 53038 05/05/2022 NAVCS2
	
	elseif taskType = WO_TASK_TODO then
		create pxyWODtl as CM_WodToDo transient;
		if _todoSet &lt;&gt; null then													//29.3.2023 navhl20	#56614[56615]
			pxyWODtl.CM_WodToDo.setPxyWoToDo(false, null, null, _todoSet);
			pxyWODtl.CM_WodToDo.setProxyAllToDoRequests( _todoSet );	
		endif;
		
	elseif taskType = WO_TASK_PACK then
		create pxyWODtl as CM_WodPack transient;
		
		self.deleteSubTerminal("SubTerm1");
		subTerm1 := self.addSubTerminal("SubTerm1", SubTermType_Depot_Int);
		operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
		self.deleteContainer("Pack1CNT");
		vessel := self.addVesselWithHolds("UT_VHOLDS", 2, 2);
		voyage := self.addVoyageWithGeneralCargoStruc("UT_VHOLDS", vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
		create tiSet transient;

		//pxyWODtl.CM_WodPack.setProxyWodPack(tiSet, null, null, null, null, null, operator, subTerm1, voyage, "MT", null, null, true);					//18.4.2023 navhl20 #55442[57629] //05.07.2024 navhl20 #61368
		pxyWODtl.CM_WodPack.setProxyWodPack(tiSet, null, null, null, null, null, operator, subTerm1, voyage, "MT", null, null, null, true);				//05.07.2024 navhl20 #61368
		if _todoSet &lt;&gt; null then													//04.3.2023 navhl20	#56614[56615]
			pxyWODtl.CM_WodPack.setProxyAllToDoRequests( _todoSet );	
		endif;
		
	elseif taskType = WO_TASK_UNPACK then
		create pxyWODtl as CM_WodUnpack transient;
		
		pxyWODtl.CM_WodUnpack.setProxyWodUnpack( unpackLoc );	
		//04.11.2021 navma1 #52248
		if _todoSet &lt;&gt; null then													//29.3.2023 navhl20	#56614[56615]
			pxyWODtl.CM_WodUnpack.setProxyAllToDoRequests( _todoSet );	
		endif;
		
	elseif taskType = WO_TASK_EXPORTRETURN then
		create pxyWODtl as CM_WodExportReturn transient;
	elseif taskType = WO_TASK_CHANGEVOYAGE then
		create pxyWODtl as CM_WodNullVoyage transient; 
	elseif taskType = WO_TASK_RECEIVE then
		create pxyWODtl as CM_WodReceive transient;
	elseif taskType = WO_TASK_RELEASE then
		create pxyWODtl as CM_WodRelease transient;
		pxyWODtl.CM_WodRelease.setProxyWodRelease(release , 1, null, null,null,null, null);		//31.03.2023	navcs2  #55440:[54990]
	else
		create pxyWODtl as CM_WodMove transient;
	endif;
	
	pxyWorkOrder.setProxyWorkOrderTask(
										pxyWODtl,
										dtRequired, 	//required by date/time
										dtStart,		// start at date/time
										autoQ,  		// auto queue task for BGP
										taskType, 		// task type constant
										toDoTask); 		//todo task if needed 			
	
	_tiset.copy(pxyWODtl.CM_WorkOrderTIDtl.allSelectedTIs);						//08.02.2023 navma1 #56457:[56458]
	
	if not _workOrder.isTransient then 
		app.myTrxUA.trxUpdateWorkOrderTasks(pxyWorkOrder, app.myPassport);	
	endif;
	
epilog
	if not _workOrder.isTransient then
		delete pxyWorkOrder;
	endif;
	delete  todoSet;
	delete tiSet;
end;
</source>
        <Parameter name="_workOrder" type="CM_WorkOrderTI" usage="io"/>
        <Parameter name="_tiset" type="CM_TISet"/>
        <Parameter name="_todoSet" type="CM_ToDoTaskDescSet"/>
    </JadeMethod>
    <JadeMethod name="addWorkOrderVas" id="a83e04e5-1795-4209-9f0c-57923fc8e16a">
        <source>addWorkOrderVas( _id : String; _woStatus : Integer; _collection : Collection) : CM_WorkOrderToDo;
/*

Purpose:			

Parameters:			

Return Value:		
 
Date				Who		Reason
27 September 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars
	pxyWorkOrder : CM_WorkOrderToDo;
	realWorkOrder : CM_WorkOrder;
	pxyRequest : CM_WorkOrderRequestByType;
	pxyWorkOrderSource : CM_WorkOrderTISource;
	availGrades	: IntegerArray;
	pxyWODtl : CM_WorkOrderDtl;
	cargoType: CM_CargoType;
	cargoList : String;
	root: CM_Root;
	totalReq : Integer;
	dtRequired,
	dtStart	: 	TimeStamp;
	remarks : String;
	emails : CM_EmailEntityByTypeNameDict;
	operator: CM_Operator;
	
begin
	deleteWorkOrder(_id);

	create emails transient;

	create pxyWorkOrder transient;
	
	if self.opts.includesKey("DtRequired") then
		dtRequired := self.opts.str("DtRequired").TimeStamp;
	endif;
	
	if self.opts.includesKey("DtStart") then
		dtStart := self.opts.str("DtStart").TimeStamp;
	endif;
	
	if self.opts.includesKey("Remarks") then
		remarks := self.opts.str("Remarks");
	endif;
	
	pxyWorkOrder.setProxy(		
			emails, 							//_allEmailAddresses
			null, 							//_customerReference
			false, 							//_emailNotification
			app.actualTimeServer, 			//_enteredByDT
			app.getMyUser(), 				//_enteredByUser 
			'',								//_approvedBy
			app.getMyUser().myOrganisation, // _myOrganisation
			app.myPassport.myTerminal, 		//_myTerminal
			remarks,  							//_remarks
			dtRequired,							//_requiredByDT
			dtStart, 							//_startAtDT
			_woStatus 						//	WO_STATUS_USERENTRY 			//_taskStatus
			);
			
	pxyWorkOrder.setID( _id );		

	self.addWorkOrderVasTask(pxyWorkOrder, _collection);

	app.myTrxCA.trxCreateWorkOrder(pxyWorkOrder,realWorkOrder,  app.myPassport);
	
	return realWorkOrder.CM_WorkOrderToDo;
epilog
	delete pxyWorkOrder;
	delete emails;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_woStatus" type="Integer"/>
        <Parameter name="_collection" type="Collection"/>
        <ReturnType type="CM_WorkOrderToDo"/>
    </JadeMethod>
    <JadeMethod name="addWorkOrderVasTask" id="813548f8-ef18-447b-9c3d-01af61bc9e15">
        <source>addWorkOrderVasTask( _workOrder : CM_WorkOrderToDo io; _collection : Collection);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Sep 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
24 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
14 Mar 2023 navma1  ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Screen
24 Mar 2023 navhl20 ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
01 Aug 2023 navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection
*/

vars
	terminal 		: CM_Terminal;
	realWorkOrder,
	pxyWorkOrder	:  CM_WorkOrderToDo;
	pxyWODtl,
	realWODtl 		: CM_WorkOrderDtl;
	autoQ,
	autoRTQ 		: Boolean;
	taskType 		: Integer;
	dtRequired,
	dtStart			: 	TimeStamp;
	toDoTaskID 		: Integer;
	toDoTask 		: CM_ToDoTaskDesc;
	root		    : CM_Root;
	allWagons       : CM_WagonSet;
	allDebtors		: CM_DebtorSet;
	allTrains		: CM_TrainSet;
	allVehicleVisits : CM_VehicleVisitRecordSet;
	allVoyages      : CM_VoyageSet;
	allVBSSlots		: CM_VehicleBookingTimeSlotById;
begin
	terminal := _workOrder.myTerminal;
	
	if opts.includesKey("TaskType") then
		taskType := opts.int("TaskType");
	endif;
	
	if self.opts.includesKey("toDoTaskID") then
		toDoTaskID := opts.int("toDoTaskID");
	endif;
	
	if self.opts.includesKey("DtRequired") then						//01.8.2023 navhl20 #58158
		dtRequired := self.opts.str("DtRequired").TimeStamp;
	endif;
	
	if toDoTaskID &lt;&gt; null then
		toDoTask := app.myRoot.allToDoTaskDescriptions[toDoTaskID];
	endif;
	
	if _workOrder.isTransient then
		pxyWorkOrder := _workOrder.CM_WorkOrderToDo;
	else
		pxyWorkOrder := app.createUpdateProxy(_workOrder).CM_WorkOrderToDo;
	endif;
	
	if taskType = WO_TASK_ToDo_NONOPS then
		create pxyWODtl as CM_WodToDoNonOperational transient;
		allDebtors := _collection.CM_DebtorSet;
		pxyWODtl.CM_WodToDoNonOperational.setProxyToDo(allDebtors);			//24.3.2023 navhl20	#57301[57303]
	elseif taskType = WO_TASK_ToDo_TRAIN then
		create pxyWODtl as CM_WodToDoTrain transient;
		allTrains := _collection.CM_TrainSet;
		pxyWODtl.CM_WodToDoTrain.setProxyToDo(allTrains);					//24.3.2023 navhl20	#57301[57303]
	elseif taskType = WO_TASK_ToDo_TRUCK then
		create pxyWODtl as CM_WodToDoVehicleVisit transient;
		allVehicleVisits := _collection.CM_VehicleVisitRecordSet;
		pxyWODtl.CM_WodToDoVehicleVisit.setProxyToDo(allVehicleVisits);		//24.3.2023 navhl20	#57301[57303]
	elseif taskType = WO_TASK_ToDo_VOYAGE then
		create pxyWODtl as CM_WodToDoVoyage transient;
		allVoyages := _collection.CM_VoyageSet;
		pxyWODtl.CM_WodToDoVoyage.setProxyToDo(allVoyages);					//24.3.2023 navhl20	#57301[57303]
	elseif taskType = WO_TASK_ToDo_VBS then
		create pxyWODtl as CM_WodToDoVBS transient;
		allVBSSlots := _collection.CM_VehicleBookingTimeSlotById;
		pxyWODtl.CM_WodToDoVBS.setProxyToDo(allVBSSlots);					//24.3.2023 navhl20	#57301[57303]
	elseif taskType = WO_TASK_ToDo_WAGON then
		create pxyWODtl as CM_WodToDoWagon transient;
		allWagons := _collection.CM_WagonSet;
		pxyWODtl.CM_WodToDoWagon.setProxyToDo(allWagons);					//24.3.2023 navhl20	#57301[57303]
	endif;
	
	pxyWorkOrder.setProxyWorkOrderTask(
										pxyWODtl,
										dtRequired, 	//required by date/time
										dtStart,		// start at date/time
										autoQ,  		// auto queue task for BGP
										taskType, 		// task type constant
										toDoTask);  	
										
	if not _workOrder.isTransient then 
		app.myTrxUA.trxUpdateWorkOrderTasks(pxyWorkOrder, app.myPassport);	
	endif;
epilog
	if not _workOrder.isTransient then
		delete pxyWorkOrder;
	endif;

end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrderToDo" usage="io"/>
        <Parameter name="_collection" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="addWorkPoint" id="c1ed5c2a-dc74-4b39-a19c-119f04db0009">
        <source>addWorkPoint(_code : String; _autoDelete : Boolean) : CM_WorkPoint;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
02 August 2011	cnwer1	Initial creation CCMS MES 1033
02 Oct  2018    cnwma1  ChangeRequest 41234: SAP Integration - Mapping fields
26 Apr 2023 	navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types
05 Sept 2024	navpw1	TFS: 65623 (65624) - Added opts so other types of Work Points can be created

*/

vars
	pxyWorkPoint , realWorkPoint: CM_WorkPoint;
	workPointType				: CM_WorkPointType;
	workPointTypeCode			: String;
	wpType						: Integer;
	
begin
	if self.opts.includesKey(UT_OPTS_WorkPointType) then
		wpType := self.opts.int(UT_OPTS_WorkPointType);
	else
		wpType := WORK_POINT_TYPE_SHIP;
	endif;
	
	if self.opts.includesKey(UT_OPTS_WorkPointTypeCode) then
		workPointTypeCode := self.opts.str(UT_OPTS_WorkPointTypeCode);
	else
		workPointTypeCode := 'SHIP';
	endif;
	
	realWorkPoint:= self.getTerminal.allWorkPointsByCode[_code];
	workPointType := self.getTerminal.allWorkPointTypes[wpType, workPointTypeCode];												//04.5.2023 navhl20 #57712[54552]
	if realWorkPoint &lt;&gt; null then
		if _autoDelete then
			self.deleteWorkPoint(realWorkPoint.code);
			///app.myTrxDA.trxDeleteWorkPoint(realWorkPoint,app.myPassport);
			///self.assertNoTrxErrorsOrWarnings();
		else
			return realWorkPoint;
		endif;
	endif;
	
	create pxyWorkPoint transient;
	
	//pxyWorkPoint.setProxy(_code,"Work point " &amp; _code &amp; " description",Green,200, 60, 400, self.getTerminal,null); 				//26.4.2023 navhl20 #57712[54552]
	pxyWorkPoint.setProxy(_code,"Work point " &amp; _code &amp; " description",Green,200, 60, 400, self.getTerminal,workPointType,null); 	//26.4.2023 navhl20 #57712[54552]
	
	app.myTrxCA.trxCreateWorkPoint(pxyWorkPoint,realWorkPoint,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	return realWorkPoint;
epilog
	delete pxyWorkPoint;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_autoDelete" type="Boolean"/>
        <ReturnType type="CM_WorkPoint"/>
    </JadeMethod>
    <JadeMethod name="addWorkPointCargoRate" id="628ece23-4020-4753-af3d-c833071b0b6f">
        <source>addWorkPointCargoRate(	_wp : CM_WorkPoint input ):CM_WorkPointCargoRates;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2018	jlgndl1	Initial creation	TFS 37437

*/

constants

	Job_Type_Default : Integer = -1;
	Tsfr_Type_Default : Integer = 1;

vars

	pxyRate : CM_WorkPointCargoRates;
	realRate : CM_WorkPointCargoRates;
	
	dailyHoursWorkable : Decimal[4,2];
	jobType : Integer;
	cargoType : CM_CargoType;
	product : CM_Product;
	targetRatePHQuantity : Integer;
	targetRatePHVolume : Decimal[16,4];
	targetRatePHWeight : Decimal[16,4];
	transferType : Integer;

begin

	//default values
	jobType := Job_Type_Default;
	transferType := Tsfr_Type_Default;
	dailyHoursWorkable := 0;
	
	
	if self.opts.includesKey("dailyHoursWorkable") then
		dailyHoursWorkable := opts.dec("dailyHoursWorkable");
	endif;
	if self.opts.includesKey("jobType") then
		jobType := opts.int("jobType");
	endif;
	if self.opts.includesKey("cargoType") then
		cargoType := opts.obj("cargoType").CM_CargoType;
	endif;
	if self.opts.includesKey("product") then
		product := opts.obj("product").CM_Product;
	endif;
	if self.opts.includesKey("targetRatePHQuantity") then
		targetRatePHQuantity := opts.int("targetRatePHQuantity");
	endif;
	if self.opts.includesKey("targetRatePHVolume") then
		targetRatePHVolume := opts.dec("targetRatePHVolume");
	endif;
	if self.opts.includesKey("targetRatePHWeight") then
		targetRatePHWeight := opts.dec("targetRatePHWeight");
	endif;
	if self.opts.includesKey("transferType") then
		transferType := opts.int("transferType");
	endif;
	
	self.assertTrueMsg( cargoType &lt;&gt; null, "Work point Cargo Rate create not attempted. [ Needs a Cargo type ]"  );
	self.assertTrueMsg( targetRatePHQuantity &gt; 0 or targetRatePHVolume &gt; 0 or targetRatePHWeight &gt; 0, "Work point Cargo Rate create not attempted. [ Needs a Rate &gt; 0 ]"  );

	create pxyRate transient;
	
	pxyRate.setProxy(	dailyHoursWorkable,	//_dailyHoursWorkable : Decimal;
						jobType,	//_jobType : Integer;
						cargoType,	//_myCargoType : CM_CargoType;
						product,	//_myProduct : CM_Product;
						_wp,	//_myWorkPoint : CM_WorkPoint;
						targetRatePHQuantity,	//_targetRatePHQuantity : Integer;
						targetRatePHVolume,	//_targetRatePHVolume : Decimal;
						targetRatePHWeight,	//_targetRatePHWeight : Decimal;
						transferType	//_transferType : Integer
						);
						
	app.myTrxCA.trxCreateWorkPointRate(pxyRate, realRate, app.myPassport);
	
	self.assertTrueMsg( realRate &lt;&gt; null, "Work point Cargo Rate not created. [" &amp; app.myPassport.getErrorsAndWarningsAsString &amp; "]"  );
	
	return realRate;

epilog

	delete pxyRate;

end;</source>
        <Parameter name="_wp" type="CM_WorkPoint" usage="input"/>
        <ReturnType type="CM_WorkPointCargoRates"/>
    </JadeMethod>
    <JadeMethod name="addWorkPointTransferArea" id="4fb93f59-24bb-4813-9818-a93c45323106">
        <source>addWorkPointTransferArea(_name : String; _workPoint: CM_WorkPoint) : CM_WorkPointInterchangeArea;
vars
	pxyWorkPointTA: CM_WorkPointInterchangeArea;
	interchangeArea: CM_InterchangeArea;
	realTA 	: CM_TerminalAreaMaster;
	selectedTAs 	: CM_TerminalAreaSet;
	
begin
	self.deleteTerminalArea(_name);
	
	create pxyWorkPointTA transient;
	create selectedTAs transient;
	
	pxyWorkPointTA.pxyUpdateLaneCount (3);	// cnwcs5 11/09/2009 
	
	pxyWorkPointTA.setProxy(_name, 						// name
						"",							// comment
						self.getTerminal,			// terminal
						_workPoint,
						false,						
						false,						
						selectedTAs,	// allInterchangeAreas
						4);			
	
	
	app.myTrxCA.trxCreateTerminalArea(pxyWorkPointTA, realTA, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	return realTA.CM_WorkPointInterchangeArea;
epilog
	
	delete pxyWorkPointTA;
	delete selectedTAs;
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
        <ReturnType type="CM_WorkPointInterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="addYA" id="28f244ec-03af-40af-bf54-a00990cd1398">
        <source>addYA(name: String; 
	  criteria1: Integer; value1: Any;
	  criteria2: Integer; value2: Any;
	  criteria3: Integer; value3: Any;
	  locations: CM_LCArray; _opts: CM_Association) : CM_YardAllocation protected;
//16 July 2008	cnwdw1	
//
vars
	proxyYA	: CM_YardAllocation;
	yardAllocation : CM_YardAllocation;
	proxyYACriteria : CMIF_Array;
	allowMultiRangeSplit : Integer;
	separateRanges : Boolean;
	projected20 : Integer;
	projected30 : Integer;
	projected40 : Integer;
	projected45 : Integer;
	projected53 : Integer;
	projectedGC : Real;
begin
	self.deleteYA(name);
	
	if self.opts.includesKey("SeparateRanges") then
		separateRanges := self.opts.bool("SeparateRanges");
	endif;
	
	//07 Apr 2021	NDL	TFS 49912
	if self.opts.includesKey("Projected20") then
		projectedGC := self.opts.int("Projected20");
	endif;
	if self.opts.includesKey("Projected30") then
		projectedGC := self.opts.int("Projected30");
	endif;
	if self.opts.includesKey("Projected40") then
		projectedGC := self.opts.int("Projected40");
	endif;
	if self.opts.includesKey("Projected45") then
		projectedGC := self.opts.int("Projected45");
	endif;
	if self.opts.includesKey("Projected53") then
		projectedGC := self.opts.int("Projected53");
	endif;
	if self.opts.includesKey("ProjectedGC") then
		projectedGC := self.opts.real("ProjectedGC");
	endif;
	
		
	proxyYACriteria := self.createYACriterias(criteria1, value1, criteria2, value2, criteria3, value3);
	proxyYA := self.createYA(name, self.getTerminal, locations, YAFillOption_InOrder, YAFillOption_InOrder,separateRanges);
	
	//07 Apr 2021	NDL	TFS 49912
	if projected20 &gt; 0 or projected30 &gt; 0 or projected40 &gt; 0 or projected45 &gt; 0 or projected53 &gt; 0 or projectedGC &gt; 0 then
		proxyYA.setProxyProjectedValues( projected20, projected30, projected40, projected45, projected53, projectedGC );
	endif;
	
	if self.opts.includesKey("AllowMultiRangeSplit") then	//20 Jun 2016	NDL	TFS 2172
		allowMultiRangeSplit := self.opts.int("AllowMultiRangeSplit");
		proxyYA.setAllowMultiRangeSplit(allowMultiRangeSplit);
	endif;
		
	app.myTrxCA.trxCreateYardAllocation(proxyYA, proxyYACriteria, yardAllocation, app.myPassport);

	self.assertNoTrxErrorsOrWarnings();
	return yardAllocation;
epilog
	delete proxyYA;
	if proxyYACriteria &lt;&gt; null then
		proxyYACriteria.purge();
	endif;
	delete proxyYACriteria;
end;</source>
        <access>protected</access>
        <Parameter name="name" type="String"/>
        <Parameter name="criteria1" type="Integer"/>
        <Parameter name="value1" type="Any"/>
        <Parameter name="criteria2" type="Integer"/>
        <Parameter name="value2" type="Any"/>
        <Parameter name="criteria3" type="Integer"/>
        <Parameter name="value3" type="Any"/>
        <Parameter name="locations" type="CM_LCArray"/>
        <Parameter name="_opts" type="CM_Association"/>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="addYA1" id="c0ee18d1-9833-4c2c-8c49-5ec2a0bd931c">
        <source>addYA1(_name: String; _criteria: Integer; _value: Any; _locations: Any) : CM_YardAllocation protected;
//17 July 2008	cnwdw1	
//
vars
	locations: CM_LCArray;
begin

	self.deleteYA(_name);
	if _locations.isKindOf(CM_LocationsController) then
		create locations transient;
		locations.add(_locations.CM_LocationsController);
		return self.addYA(_name, _criteria, _value, 0, 0, 0, 0, locations, null);
	elseif _locations.isKindOf(CM_LCArray) then
		return self.addYA(_name, _criteria, _value, 0, 0, 0, 0, _locations.CM_LCArray, null);
	endif;
epilog
	delete locations;
end;</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
        <Parameter name="_criteria" type="Integer"/>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_locations" type="Any"/>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="addYA1WithFill" id="8a3f227c-3bf5-45fa-a2b4-a7fea32d06ef">
        <source>addYA1WithFill(name: String; 
	  criteria1: Integer; value1: Any;
	  locations: CM_LCArray;
	  _fillOptionIn, _fillOptionOut: Integer;
	  _separateRanges : Boolean) : CM_YardAllocation protected;
//16 July 2008	cnwdw1	
//
vars
	proxyYA	: CM_YardAllocation;
	yardAllocation : CM_YardAllocation;
	proxyYACriteria : CMIF_Array;
begin

	proxyYACriteria := self.createYACriterias(criteria1, value1, 0, 0, 0, 0);
	proxyYA := self.createYA(name, app.getMyTerminalDO_NOT_USE(), locations, _fillOptionIn, _fillOptionOut,_separateRanges);
	app.myTrxCA.trxCreateYardAllocation(proxyYA, proxyYACriteria, yardAllocation, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqual(yardAllocation.fillOptionIn, _fillOptionIn);
	self.assertEqual(yardAllocation.fillOptionOut, _fillOptionOut);
	
	return yardAllocation;
epilog
	delete proxyYA;
	if proxyYACriteria &lt;&gt; null then
		proxyYACriteria.purge();
	endif;
	delete proxyYACriteria;
end;</source>
        <access>protected</access>
        <Parameter name="name" type="String"/>
        <Parameter name="criteria1" type="Integer"/>
        <Parameter name="value1" type="Any"/>
        <Parameter name="locations" type="CM_LCArray"/>
        <Parameter name="_fillOptionIn" type="Integer"/>
        <Parameter name="_fillOptionOut" type="Integer"/>
        <Parameter name="_separateRanges" type="Boolean"/>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="addYA1WithGroups" id="7980fb69-9644-4bc7-a545-c931af6e6e37">
        <source>addYA1WithGroups(name: String; 
	  criteria1: Integer; value1: Any;
	  _groupIn, _groupOut: CM_YABlockGroupArray;
	  _fillOptionIn, _fillOptionOut: Integer) : CM_YardAllocation protected;
//16 July 2008	cnwdw1	
//
vars
	proxyYA	: CM_YardAllocation;
	yardAllocation : CM_YardAllocation;
	proxyYACriteria : CMIF_Array;
begin

	proxyYACriteria := self.createYACriterias(criteria1, value1, 0, 0, 0, 0);
	proxyYA := self.createYAWithGroups(name, app.getMyTerminalDO_NOT_USE(), _groupIn, _groupOut, _fillOptionIn, _fillOptionOut);
							
	app.myTrxCA.trxCreateYardAllocation(proxyYA, proxyYACriteria, yardAllocation, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	return yardAllocation;
epilog
	delete proxyYA;
	if proxyYACriteria &lt;&gt; null then
		proxyYACriteria.purge();
	endif;
	delete proxyYACriteria;
end;</source>
        <access>protected</access>
        <Parameter name="name" type="String"/>
        <Parameter name="criteria1" type="Integer"/>
        <Parameter name="value1" type="Any"/>
        <Parameter name="_groupIn" type="CM_YABlockGroupArray"/>
        <Parameter name="_groupOut" type="CM_YABlockGroupArray"/>
        <Parameter name="_fillOptionIn" type="Integer"/>
        <Parameter name="_fillOptionOut" type="Integer"/>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="addYACatchAll" id="fe7ef04d-c232-41ec-8200-1cf63cb6cdb1">
        <source>addYACatchAll(_name: String; _bs: CM_BlockStack);
//01 September 2009	cnwdw1	
// CReate a YA that will always match any cargo item
vars
	values: CM_ObjectSet;
	ya: CM_YardAllocation;
begin
	deleteYA(_name);
	create values transient;
	getRoot.allImexStatuses.copy(values);
	ya := addYAToBlockStack(_name, YACriteriaType_ImexStatus, values, _bs);
	self.updateYAPriority(ya, 99999);
	
epilog
	delete values;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_bs" type="CM_BlockStack"/>
    </JadeMethod>
    <JadeMethod name="addYAMDH" id="dc01c157-88cf-4788-bca8-cd290dee8abb">
        <source>addYAMDH(name: String; 
	  criteria1: Integer; value1: Any;
	  criteria2: Integer; value2: Any;
	  criteria3: Integer; value3: Any;
	  locations: CM_LCArray; _opts: CM_Association) : CM_YardAllocation;
//16 July 2008	cnwdw1	DO NOT USE
