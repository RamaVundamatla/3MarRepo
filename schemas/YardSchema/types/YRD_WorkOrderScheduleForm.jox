    <JadeMethod name="setupForm" id="02a5d8d2-39d8-4f06-87c2-76b365c4b60a">
        <updating/>
        <source>setupForm() updating;
// -----------------------------------------------------------------------------
// Created:		13 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	inheritMethod();

	//self.lblJobId.caption := self.lblJobId.caption &amp; " " &amp; self.myWorkOrder.id;
	self.lblJobId.visible := false; 
	self.setCaption( 'Work Order ' &amp; self.myWorkOrder.id &amp; ' Schedule ');
	
	self.timerTS := null;
	self.widthDTColumn := 150;
	self.widthValueColumn := 90;
	
	self.colorRow1 := self.colorHeadingColumn;
	
	self.colorRow2 := self.colorValueColumn;
	
	self.cmbTask.displayCollection(self.myWorkOrder.allWoDtls, true, 0, null, app.getErrorString(CM_LIT_ALL) );
	self.cmbTask.listIndex := 1;

	self.beginNotification(self.myWorkOrder, Object_Delete_Event, Response_Cancel, 0);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="624f4903-d722-4af4-875c-dce8f17f6d2b">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// -----------------------------------------------------------------------------
// Created:		19 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	if eventType = Object_Delete_Event then
		if theObject.String = self.myWorkOrder.String then
			app.msgBox(app.getErrorString1(DeletedByAnotherUser, self.lblJobId.caption), self.caption, MsgBox_OK_Only);
			self.unloadForm;
		elseif CM_WorkOrderDtl.hasInstance(theObject) then
			self.loadSchedule();
			self.loadSummary();
		endif;
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblSchedule_cellInputReady" id="d650b219-3c16-45f6-90f9-3db5a4362bf7">
        <controlMethod name="Table::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSchedule_cellInputReady(table: Table input; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 January 2010	cnwrd1	Initial creation

*/

vars
	theRow,
	theColumn 	: Integer;
	allValue,
	theseValue : Integer;
	theTI	: CM_TrackedItem;
	number : Integer;
	parent : CM_WorkOrderTIDtl;
	schedule : CM_WorkOrderSchedule;
begin

//if table.CM_BaseTable.
	if table.CM_BaseTable.getCellFromPosition(cleft,ctop,theRow,theColumn) then
		if table.cnEcIsValidRow(theRow) and  table.cnEcIsValidColumn(theColumn) then		
			schedule :=  table.CM_BaseTable.accessCell(theRow,theColumn).JadeTableCell.itemObject.CM_WorkOrderSchedule;
			if schedule &lt;&gt; null then // we can proceed
				inputControl.TextBox.userObject := schedule;
			else
				inputControl.TextBox.userObject := null;
			endif;
		endif;
	endif;
	inputControl.TextBox.text := table.text;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
    </JadeMethod>
