    <JadeMethod name="updateErrorUserObjects" id="ed3c12f7-7332-47e0-bf29-a1840bb74bff">
        <source>updateErrorUserObjects(_errors :CM_ErrorSet; _xref :DynaDictionary) protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
14 July 2011	cnwcs5	Initial creation - par 26557
*/
vars
	error			: CM_Error;
	obj, userObject	: Object;
begin
	foreach error in _errors do
		obj := error.myUserObject;
		
		if obj = null or obj.isKindOf (CM_EDITrackedItem) then
			continue;
		endif;
		
		userObject := _xref[obj];
		
		if userObject &lt;&gt; null then
			error.setMyUserObject (userObject);
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_errors" type="CM_ErrorSet"/>
        <Parameter name="_xref" type="DynaDictionary"/>
    </JadeMethod>
    <JadeMethod name="updateErrorsAndStatus" id="0ee60d99-ecc1-41b9-adb9-370a5c352f73">
        <updating/>
        <source>updateErrorsAndStatus(_errors : CM_EDIErrorSet; _status : Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/06/2023	navdap1		Initial creation TFS 58813 EUP Instructions and corrections
// 08/08/2023	navdap1		TFS 59747 EUP DB Load Failed with no errors for a Road Transport Manifest
//
vars
	error : CM_EDIError;

begin
	//self.allErrorWarnings.purge;														// TFS 59747
	if _errors &lt;&gt; null then																// TFS 59747
		foreach error in _errors where not self.allErrorWarnings.includes(error) do		// TFS 59747
			error.setMyEDIData(self);
		endforeach;
	endif;																				// TFS 59747
	
	self.status := _status;
epilog

end;</source>
        <Parameter name="_errors" type="CM_EDIErrorSet"/>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
