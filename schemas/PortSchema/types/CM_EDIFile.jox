    <JadeMethod name="getDisplayStringForAttribute" id="fddd0ae7-5c16-4d52-874c-e45a61b4f1ce">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 04 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	ediController 	: CM_EDIControllerAgent;	
begin
	create ediController transient;
	
	if _attrName = ETRow_ClientReference then
		return self.ediClientRef;
	elseif _attrName = ETRow_MessageType then
		return self.ediMessageType;
	elseif _attrName = ETRow_EdiType then
		if self.myEDIFileType &lt;&gt; null then
			return self.myEDIFileType.name;
		endif;
	elseif _attrName = ETRow_Status then
		return ediController.displayStatus(self.fileStatus);
	elseif _attrName = ETRow_Process then		
		
	else
		return inheritMethod(_attrName, _short);
	endif;
	
epilog
	delete ediController;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
