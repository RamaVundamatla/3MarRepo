    <JadeMethod name="doMnuGridTBAClick" id="e733366f-bbaa-4525-8621-39836580b2a8">
        <updating/>
        <source>doMnuGridTBAClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	voyage : CM_Voyage;
	source, target : CM_LocationsController;
begin
	
	if CM_LocationsController.hasInstance(menuItem.userObject) then
		source := menuItem.userObject.CM_LocationsController;
	endif;
	
	if app.myMoveController &lt;&gt; null then
		target := app.myMoveController.myToPrimaryLocation;
		if target &lt;&gt; null then
			if CM_VoyageController.hasInstance(target) then
				voyage := target.CM_VoyageController.myVoyage;
			endif;
		endif;
	else
		//voyage := app.myCurrentVoyage;
		//cnwjo3 par 23105
		voyage := app.getMyCurrentVoyage();
	endif;
	self.myAssistant.showTBAEntryForm(source,target, voyage);		

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuLCLClick" id="f870f4e0-76a0-47a8-92bc-b0fed1a6af4b">
        <updating/>
        <source>doMnuLCLClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	lPackUnpack	: YRD_PackUnpack;
	anObject	: Object;
	theTI 		: CM_Container;
	frm			: Form;
begin
	anObject := menuItem.userObject;
	if anObject = null then 
		return;
	endif;
	
	if not anObject.isKindOf(CM_Container) then
		return;
	endif;
	
	theTI := anObject.CM_Container;
	lPackUnpack := app.loadForm(YRD_PackUnpack,
								CMUI_Assistant,
								false,
								false,
								false,
								self.myTerminal,
								null).YRD_PackUnpack;
								
	//create lPackUnpack;
	//lPackUnpack.centreWindow;
	lPackUnpack.myTI := theTI;
	lPackUnpack.setMyTerminal(self.myTerminal);
//	lPackUnpack.myTerminalArea := self.myCurrentTerminalArea;
	lPackUnpack.show;



end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuRemarksClick" id="8a3a8e14-6f32-4807-9399-e8afc35e644e">
        <updating/>
        <source>doMnuRemarksClick(_menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lForm : CMUI_GetData;
	theTI : CM_TrackedItem;
begin
	if _menuItem.userObject = null then
//		app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " MENU ITEM USER OBJECT WAS FOUND TO BE NULL"); 
		return;
	endif;
	
	theTI := _menuItem.userObject.CM_TrackedItem;

	create lForm;
	lForm.centreWindow;
	self.mousePointer := MousePointer_Default;
	
	lForm.lblTextCaption := app.getErrorString1( Additional_remarks_ti,theTI.id) ;
	
	lForm.txtReadOnly.visible := true;
	lForm.bigSize := true;
	lForm.txtReadOnly.text := theTI.remarks;
	lForm.txtData.text := null;
//	lForm.txtData.height := lForm.txtData.height * 5;
	lForm.txtData.dataType := TextBox.DataType_AlphaNumeric;
	lForm.myCaller := self;
	lForm.formCaption :=  app.getErrorString(Additional_remarks);
	lForm.type := self.GetData_Remarks;
	lForm.show;
epilog
	mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuRemoveLabRestrictClick" id="044c3e08-f8ff-4a35-ab07-8ded337e194d">
        <updating/>
        <source>doMnuRemoveLabRestrictClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     07 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

	rowNum		: Integer;
	theTA		: CM_TerminalArea;
	restrictionLabour	: CM_LabourRestriction;
begin

	if menuItem.helpKeyword &lt;&gt; "MAIN" then
		if menuItem.helpKeyword = "VIEW" then 			
			self.doRestrictionOpenLabour(menuItem.userObject.CM_TerminalArea);
		elseif menuItem.helpKeyword = "ALL" then 
			self.deleteAllLabourRestriction(menuItem.userObject.CM_TerminalArea);
		else 		
			self.deleteLabourRestriction(menuItem.userObject.CM_LabourRestriction);
		endif;	
	endif;
end;</source>
