    <JadeMethod name="getYDrawingPositions" id="18229ccf-7bde-4854-9f26-b9b4e802d6f7">
        <source>getYDrawingPositions(_textHeight, _maxTiersOnDeck, _maxTiersUnderDeck : Integer; 
	_topMargin, _bayHeight, _hatchPos, _onDeckPos, _underDeckEndPos, _underDeckPos : Integer output) protected ;
// ---------------------------------------------------------------------------
// Created:     13 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 21/05/2015	cnwdap1		PAR #36269 TFS 331 Visual Display of Stack Weights
// 29/08/2017	jlgdap1		TFS 5840 Error 15007 when printing large bay plan in LOLO Planning
// 21/03/2018	Jlgns1		Bug 37525: SNO - (re Ticket 36886): Header in bay plan printing
/*
The drawing positions are:

    portLabelPosOD  portPosOD                            starboardPosOD  starboardLabelPosOD
yOnDeckPos     +------------------------------------------+
               |                                          |
               |             on deck containers           |
               |                                          |
               +------------------------------------------+

yHatchPos      |------------ hatch lids ------------------|

    portLabelPosUD  portPosUD                    starboardPosUD  starboardLabelPosUD
yUnderDeckPos  +------------------------------------------+
               +-+                                      +-+
                 +-+       under deck containers      +-+
                   +-+                              +-+
yUnderDeckEndPos     +------------------------------+

               ^
        sideDrawingMargin

*/
vars
	theTopMargin	: Integer;
	theScaleFactor	: Real;
	theRowHeight,
	theColWidth,
	thePrintStyle,
	hatchLidHeight 	: Integer;
	showHeights, 								// PAR #36269
	showWeights		: Boolean;					// PAR #36269
	heightY, 									// PAR #36269
	weightY			: Integer;					// PAR #36269
	
begin

	theScaleFactor 	:= self.scaleFactor;
	theRowHeight	:= self.rowHeight;
	theColWidth		:= self.columnWidth;
	thePrintStyle 	:= self.printOutputStyle;
	hatchLidHeight	:= HatchLidHeight_Screen;
	

	if self.amPrinting then
		if thePrintStyle = PrintOutput_Small then
			theTopMargin := 2; // no bay id and no cell ids PAR 9034 chanegd from 0 to 2
		else
			theTopMargin := 15; // no bay id but has cell ids
		endif;
		hatchLidHeight := HatchLidHeight_Print;
	elseif theScaleFactor = ScaleFactor_1 then	
		theTopMargin := 25;
	else
		theTopMargin := TopMargin;
	endif;

	_onDeckPos := theTopMargin;
	
	showHeights := self.myTerminal.getConfig(ShowHeightsLOLOPlanning).Boolean;						// PAR #36269
	showWeights := self.myTerminal.getConfig(ShowWeightsLOLOPlanning).Boolean;						// PAR #36269
	
	//epr par 37165 27/11/15
	if self.amPrinting and thePrintStyle &lt;&gt; self.PrintOutput_Large then
		showHeights:=false;
		showWeights:=false;	
	endif;
	
	heightY := 5;																					// PAR #36269
	if showHeights then																				// PAR #36269
		heightY := heightY + 30;																	// PAR #36269
	endif;																							// PAR #36269
	if showWeights then																				// PAR #36269
		heightY := heightY + 30;																	// PAR #36269
	endif;																							// PAR #36269
	
	if self.printSeparateODUD then																	// 27/11/17 MAP TFS7494
		_underDeckPos := theTopMargin;
		_hatchPos	:= theTopMargin + (_maxTiersOnDeck * theRowHeight) + _textHeight + heightY;
	else
		if theScaleFactor = ScaleFactor_1 or thePrintStyle = PrintOutput_Small then
			// at this scale we don't draw the pile weights or cell labels
			_hatchPos	:= theTopMargin + (_maxTiersOnDeck * theRowHeight) + 5;
			_underDeckPos := _hatchPos + hatchLidHeight + 5;
		elseif thePrintStyle = PrintOutput_Medium then
			//_hatchPos	:= theTopMargin + (_maxTiersOnDeck * theRowHeight) + 5;							// PAR #36269
			_hatchPos	:= theTopMargin + (_maxTiersOnDeck * theRowHeight) + heightY;					// PAR #36269
			_underDeckPos := _hatchPos + hatchLidHeight + 15;
		else
			//_hatchPos	:= theTopMargin + (_maxTiersOnDeck * theRowHeight) + _textHeight + 5;			// PAR #36269
			//_underDeckPos := _hatchPos + hatchLidHeight + _textHeight + 5;							// PAR #36269
			_hatchPos	:= theTopMargin + (_maxTiersOnDeck * theRowHeight) + _textHeight + heightY;		// PAR #36269
			_underDeckPos := _hatchPos + hatchLidHeight + _textHeight + 10;								// PAR #36269
		endif;
	endif;
	
	//_underDeckEndPos := _underDeckPos + (_maxTiersUnderDeck * theRowHeight);						// PAR #36269
	_underDeckEndPos := _underDeckPos + (_maxTiersUnderDeck * theRowHeight) + 15;					// PAR #36269
	
	if thePrintStyle = PrintOutput_Small then
		// at this scale we don't draw the pile weights or cell labels
		_bayHeight	:= _underDeckEndPos + SHP_BayDrawingFrame.HeadingGraphicHeight + 5;
	elseif thePrintStyle = PrintOutput_Medium then
		_bayHeight	:= _underDeckEndPos + _textHeight + SHP_BayDrawingFrame.HeadingGraphicHeight + 5;
	elseif theScaleFactor = ScaleFactor_1 then
		// at this scale we don't draw the pile weights
		_bayHeight	:= _underDeckEndPos + SHP_BayDrawingFrame.HeadingGraphicHeight + 20;
	else
		if _hatchPos &gt; _underDeckEndPos and	self.printSeparateODUD then																	//Bug 37525
			_bayHeight	:= _hatchPos + _textHeight + SHP_BayDrawingFrame.HeadingGraphicHeight + heightY + 40;	// PAR #36269			//Bug 37525
		else																															//Bug 37525
		//_bayHeight	:= _underDeckEndPos + _textHeight + SHP_BayDrawingFrame.HeadingGraphicHeight + 20;			// PAR #36269		//Bug 37525
			_bayHeight	:= _underDeckEndPos + _textHeight + SHP_BayDrawingFrame.HeadingGraphicHeight + heightY + 40;	// PAR #36269	//Bug 37525
		endif;																															//Bug 37525
	endif;
	if showWeights and showHeights then																// PAR #36269
		_bayHeight := _bayHeight + 15;																// PAR #36269
	endif;																							// PAR #36269
	
	if self.amPrinting and self.printOutputStyle = self.PrintOutput_Large then		// TFS 5840
		if _bayHeight &gt; app.printer.pageHeight then									// TFS 5840
			_bayHeight := app.printer.pageHeight;									// TFS 5840
		endif;																		// TFS 5840
	endif;																			// TFS 5840

end;</source>
