    <JadeMethod name="getXMLSettingsForSetup" id="8f0e5c61-81d5-4364-ae99-7f7d97255162">
        <source>getXMLSettingsForSetup();
/*
Purpose:			

Date		Who		Reason
26 June 2023	navab1	BUG 58793
*/

vars

	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	useQUANTITY : Boolean;
begin

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;
 	theXMLValue := theXML.cnEcGetTagValueOfName("UseQuantity");
 	useQUANTITY := false;
 	if theXMLValue &lt;&gt; null then
 		useQUANTITY := theXMLValue.Integer.Boolean;
 	endif;
 	
	self.chkQuantity.value := useQUANTITY;

epilog

end;</source>
