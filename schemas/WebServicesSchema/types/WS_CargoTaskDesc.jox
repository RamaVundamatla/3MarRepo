        <source>setProxyFromObject(_object: CM_ToDoTaskDesc) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Aug 2019	cnwma1	ChangeRequest 46185: PNL - Tasks, Grades and Marks via REST API

*/

vars

begin
	inheritMethod(_object);
	self.code 				:= _object.code;
	self.description		:= _object.description;
	self.hasResources   	:= _object.allResourceTypes.size &gt; 0;
