end;
</source>
    </JadeMethod>
    <JadeMethod name="createRoot" id="6e996bc8-85e0-402f-9d0b-ba3e82ebb5e0">
        <source>createRoot();

vars
	rt: RootHotFixes;

begin

	beginTransaction;
	RootHotFixes.deleteAllInstances;
	commitTransaction;
	beginTransaction;
	AppInSchema.instances.purge();
	commitTransaction;
	beginTransaction;
	ClassInSchema.instances.purge();
	commitTransaction;
	beginTransaction;
	MethodInClass.instances.purge();
	commitTransaction;
	beginTransaction;
	Patch.instances.purge();
	commitTransaction;
	beginTransaction;
	SchemaInPatch.instances.purge();
	commitTransaction;
	
	beginTransaction;
	create rt;

	//rt.set(  'F:\Setup\', rt.getReleaseVersionNoFromJMT()  );
	rt.set(  'F:\Releases\', rt.getReleaseVersionNoFromJMT()  );
	
	commitTransaction;

end;
</source>
    </JadeMethod>
