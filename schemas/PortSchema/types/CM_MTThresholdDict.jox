<CollClass name="CM_MTThresholdDict" id="66e4db83-44ca-4029-8ab0-2d6d589bcd71">
    <loadFactor>66</loadFactor>
    <memberType name="CM_MTThreshold"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="threshold"/>
    <MemberKey>
        <property name="CM_Threshold::processingPriority"/>
    </MemberKey>
    <JadeMethod name="getThresholdFor" id="d4dec280-83e8-4d4d-aaf7-0709338491db">
        <source>getThresholdFor(	_operator : CM_Operator;
					_isoTypeGroup : CM_ISOTypeGroup;
					_grade : CM_MTGrade
					):CM_MTThreshold;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2011	cnwndl1	Initial creation	Par 27731
*/

vars

	thresh : CM_MTThreshold;
	iter : Iterator;

begin

	iter := self.createIterator;
	while iter.next( thresh ) do
		if thresh.myOperator &lt;&gt; _operator then
			continue;
		endif;
		if thresh.myISOTypeGroup &lt;&gt; _isoTypeGroup then
			continue;
		endif;
		if thresh.myMTGrade &lt;&gt;_grade then
			continue;
		endif;
		return thresh;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_isoTypeGroup" type="CM_ISOTypeGroup"/>
        <Parameter name="_grade" type="CM_MTGrade"/>
        <ReturnType type="CM_MTThreshold"/>
    </JadeMethod>
</CollClass>
