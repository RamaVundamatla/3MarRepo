        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 September 2014	cnwndl1	Initial creation

*/

vars

	id : Integer;
	ct : CM_CargoType;

begin

	id := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "id" ).Integer; 
	
	if id &lt;&gt; null then
		ct := app.myRoot.allCargoTypesById.getAtKey( id );
