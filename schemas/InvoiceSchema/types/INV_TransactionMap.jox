    <JadeMethod name="doUserNoteProductGroup" id="4b6a76f5-ddb9-42aa-8bbd-6cdf13b000dc">
        <updating/>
        <source>doUserNoteProductGroup(_theMap : CM_ProductGroupMap; _event : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		February 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	trGroup : CMIF_TMCProductGroupGroup;
	tmcGroup : CMIF_TMCGroup;

	idx		: Integer;
begin
	// 35872 ignore notes for changes from other business units
	if _theMap &lt;&gt; null and
	   global.isValidObject(_theMap) then
		if _theMap.getBank &lt;&gt; self.myCurrentBank then
			return;
		endif;
	endif;

	if _event = EVENT_TRANSACTIONMAP_CREATE then
		tmcGroup := self.getIndexInList(_theMap.myCargoTypeMap,CMIF_TranMapController.TM_Level_04_CargoType, idx);

		if idx &gt; 0 then
			create trGroup;
			trGroup.myProductGroupMap := _theMap;
			trGroup.itemName := _theMap.itemName;
			trGroup.extractName := _theMap.getItemCode();	// 23659
			trGroup.myGroup := tmcGroup;
			trGroup.initialise(self.myTMCRoot.groupCount);
			trGroup.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			self.lstData.itemExpanded[idx+1] := true;
			self.lstData.listIndex := idx+1;
			// 33535 more than one user updating same trans map
			if not self.isEditing() then
				self.doLstDataClick(self.lstData);
			endif;
		endif;
	elseif _event = EVENT_TRANSACTIONMAP_UPDATE then
	elseif _event = EVENT_TRANSACTIONMAP_DELETE then
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_05_ProductGroup, idx);
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
		
	endif;
end;</source>
        <Parameter name="_theMap" type="CM_ProductGroupMap"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUserNoteQuantity" id="53c32429-a398-4267-a264-461dd887854c">
        <updating/>
        <source>doUserNoteQuantity(_theMap : CM_QuantityMap; _event : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//09/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
// ---------------------------------------------------------------------------

vars
	trGroup : CMIF_TMCQuantityGroup;
	tmcGroup : CMIF_TMCGroup;
	form : INV_TransactionMap;
	level, saveIdx,
	idx		: Integer;
begin
	// 35872 ignore notes for changes from other business units
	if _theMap &lt;&gt; null and
	   global.isValidObject(_theMap) then
		if _theMap.getBank &lt;&gt; self.myCurrentBank then
			return;
		endif;
	endif;

	if _event = EVENT_TRANSACTIONMAP_UPDATE then
		tmcGroup := self.getIndexInList(_theMap,CMIF_TMCDebtorGroup.TM_Level_12_Quantity, idx);
		if tmcGroup = null then
			tmcGroup := self.getIndexInList(_theMap,CMIF_TMCDebtorGroup.TM_Level_13_Quantity, idx);
			if tmcGroup = null then
				tmcGroup := self.getIndexInList(_theMap,CMIF_TMCDebtorGroup.TM_Level_06_Quantity, idx);
				if tmcGroup = null then	//14 Jan 2009	NDL	CCMS MES 1006
					tmcGroup := self.getIndexInList(_theMap,CMIF_TMCDebtorGroup.TM_Level_14_Quantity, idx);
					//09/02/2017 cnwma1 TFS #2901
					if tmcGroup = null then
						tmcGroup := self.getIndexInList(_theMap,CMIF_TMCDebtorGroup.TM_Level_15_QuantityRange, idx);
						if tmcGroup = null then // 15/05/2023	navkc1	CR 57927 Task 54268
							tmcGroup := self.getIndexInList(_theMap,CMIF_TMCDebtorGroup.TM_Level_08_Quantity, idx);
						endif;
					endif;
					//09/02/2017 cnwma1 TFS #2901
				endif;
			endif;
		endif;
		
		if tmcGroup.isKindOf(CMIF_TMCQuantitySubRangeGroup) then								//09/02/2017 cnwma1 TFS #2901
			tmcGroup.itemName := tmcGroup.CMIF_TMCQuantitySubRangeGroup.getItemName();	    	//09/02/2017 cnwma1 TFS #2901
			tmcGroup.extractName := tmcGroup.CMIF_TMCQuantitySubRangeGroup.getExtractDetails(); //09/02/2017 cnwma1 TFS #2901
		else
			tmcGroup.itemName := tmcGroup.CMIF_TMCQuantityGroup.getItemName();
			tmcGroup.extractName := tmcGroup.CMIF_TMCQuantityGroup.getExtractDetails();	// 23659
		endif;
	
		self.lstData.itemText[idx] := tmcGroup.itemName;
		form := self;
		tmcGroup.setEnableObjects(form);
		
	elseif _event = EVENT_TRANSACTIONMAP_NEWQRMS then
		tmcGroup := self.getIndexInList(_theMap,CMIF_TMCDebtorGroup.TM_Level_12_Quantity, idx);
		if tmcGroup = null then
			tmcGroup := self.getIndexInList(_theMap,CMIF_TMCDebtorGroup.TM_Level_13_Quantity, idx);
			if tmcGroup = null then
				tmcGroup := self.getIndexInList(_theMap,CMIF_TMCDebtorGroup.TM_Level_06_Quantity, idx);
				if tmcGroup = null then
					tmcGroup := self.getIndexInList(_theMap,CMIF_TMCDebtorGroup.TM_Level_14_Quantity, idx);
				endif;
			endif;
		endif;
		if idx &gt; 0 then
			level := self.lstData.itemLevel[idx];
			self.lstData.removeItem(idx);
			tmcGroup.allGroupMembers.purge();
			trGroup := tmcGroup.CMIF_TMCQuantityGroup;
			trGroup.itemName := trGroup.myQuantityMap.getName();
			trGroup.extractName := trGroup.myQuantityMap.getExtractDetails();
			trGroup.initialise(self.myTMCRoot.groupCount);
			saveIdx := idx;
			trGroup.loadList2At(self.lstData, level, idx);
			self.lstData.itemExpanded[saveIdx] := true;
			self.lstData.listIndex := saveIdx;
			// 33535 more than one user updating same trans map
			if not self.isEditing() then
				self.doLstDataClick(self.lstData);
			endif;
		endif;
	elseif _event = EVENT_TRANSACTIONMAP_CREATE then
	elseif _event = EVENT_TRANSACTIONMAP_DELETE then
	endif;
end;</source>
        <Parameter name="_theMap" type="CM_QuantityMap"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUserNoteQuantityRange" id="a3b363e6-e18a-4888-8a3e-69062ea211ae">
        <updating/>
        <source>doUserNoteQuantityRange(_theMap : CM_QuantityRangeMap; _event : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
// 09/02/2017 cnwma1  	TFS #2901:ADP - Variable storage charges based on weight and time
// 27/11/2017 jlgmd1	TFS 7496 STWO - JMT shows Error when saving transaction mapping update
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
// ---------------------------------------------------------------------------

vars
	trGroup : CMIF_TMCQuantityRangeGroup;
	tmcGroup : CMIF_TMCGroup;

	qtyMap : CM_QuantityMap;
	idx		: Integer;
	useResourceLevels, useMoveLevels, usesResourceUsageType : Boolean;
	invalidMap : Boolean;
begin

	// TFS7496
	on Exception do app.handleDeletedObject(exception, _theMap, invalidMap);

	// 35872 ignore notes for changes from other business units
	if _theMap &lt;&gt; null and
	   global.isValidObject(_theMap) then
		if _theMap.getBank &lt;&gt; self.myCurrentBank then
			return;
		endif;
	endif;

	if _event = EVENT_TRANSACTIONMAP_UPDATE then
		qtyMap := _theMap.myQuantityMap;
		
		// TFS7496 If our map has just been deleted out from under us, then bail
		if invalidMap then
			return;
		endif;
		
		// find the transient
		tmcGroup := self.getIndexInList(_theMap,CMIF_TMCGroup.TM_Level_13_QuantityRange, idx);
		if tmcGroup = null then
			//14 Jan 2009	NDL	CCMS MES 1006
			tmcGroup := self.getIndexInList(_theMap,CMIF_TMCGroup.TM_Level_15_QuantityRange, idx);
			if tmcGroup &lt;&gt; null and qtyMap.myParentFinancialObject.isKindOf(CM_TransResourceServiceBroker) then
				usesResourceUsageType := true;
			endif;
			if  tmcGroup = null and qtyMap.myParentFinancialObject.isKindOf(CM_QuantityRangeMap) then //21/02/2017 cnwma1 TFS #2901
				if qtyMap.myParentFinancialObject.CM_QuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_TransResourceServiceBroker)then
					tmcGroup := self.getIndexInList(_theMap,CMIF_TMCGroup.TM_Level_17_QuantityRange, idx);
					usesResourceUsageType := true;
				endif;
			endif;
		endif;
		if tmcGroup = null then
			tmcGroup := self.getIndexInList(_theMap,CMIF_TMCGroup.TM_Level_14_QuantityRange, idx);
			if tmcGroup = null then
				tmcGroup := self.getIndexInList(_theMap,CMIF_TMCGroup.TM_Level_07_QuantityRange, idx);
				if tmcGroup = null then
					tmcGroup := self.getIndexInList(_theMap,CMIF_TMCGroup.TM_Level_09_QuantityRange, idx); // 15/05/2023	navkc1	CR 57927 Task 54268
				endif;
				useResourceLevels := true;
			else
				useMoveLevels := true;
			endif;
		endif;
		// remove from list box and delete
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
		// get Parent object
		idx := 0;
		if usesResourceUsageType then	//14 Jan 2009	NDL	CCMS MES 1006
			tmcGroup := self.getIndexInList(qtyMap,CMIF_TMCGroup.TM_Level_14_Quantity, idx);
			if tmcGroup = null then  //21/02/2017 cnwma1 TFS #2901
					tmcGroup := self.getIndexInList(qtyMap,CMIF_TMCGroup.TM_Level_16_QuantityRange, idx); 
			endif;
		elseif useMoveLevels then
			tmcGroup := self.getIndexInList(qtyMap,CMIF_TMCGroup.TM_Level_13_Quantity, idx); 
		elseif useResourceLevels then
			tmcGroup := self.getIndexInList(qtyMap,CMIF_TMCGroup.TM_Level_06_Quantity, idx); 
			if tmcGroup = null then	// 15/05/2023	navkc1	CR 57927 Task 54268
				tmcGroup := self.getIndexInList(qtyMap,CMIF_TMCGroup.TM_Level_08_Quantity, idx);  // 15/05/2023	navkc1	CR 57927 Task 54268
			endif;
		else
			//tmcGroup := self.getIndexInList(qtyMap,CMIF_TMCGroup.TM_Level_12_Quantity, idx);  //09/02/2017 cnwma1 TFS #2901
			//09/02/2017 cnwma1 TFS #2901
			if tmcGroup = null then
				if _theMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_QuantityRangeMap) then
					tmcGroup := self.getIndexInList(qtyMap,CMIF_TMCGroup.TM_Level_14_Quantity, idx); 
				else
					tmcGroup := self.getIndexInList(qtyMap,CMIF_TMCGroup.TM_Level_12_Quantity, idx); 
				endif;
			endif;
		endif;	
		// recreate transient;
		if idx &gt; 0 then
			if qtyMap.myParentFinancialObject.isKindOf(CM_DebtorMap) then
				create trGroup;
			elseif qtyMap.myParentFinancialObject.isKindOf(CM_QuantityMap) then  //09/02/2017 cnwma1 TFS #2901
				create trGroup as CMIF_TMCQuantitySubRangeGroup;
			else
				create trGroup as CMIF_TMCQuantityRangeGroupDeft;
			endif;

			trGroup.myQuantityRangeMap := _theMap;
			trGroup.itemName := trGroup.getItemName();
			trGroup.extractName := _theMap.getExtractDetails();	// 23659
			trGroup.myGroup := tmcGroup;
			trGroup.initialise(self.myTMCRoot.groupCount);
			trGroup.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			self.lstData.itemExpanded[idx+1] := true;
			self.lstData.listIndex := idx+1;
		endif;
		
		
		
	elseif _event = EVENT_TRANSACTIONMAP_CREATE then
		// get the parent and add this range under it.
		qtyMap := _theMap.myQuantityMap;
		tmcGroup := self.getIndexInList(qtyMap,CMIF_TMCGroup.TM_Level_13_Quantity, idx); 
		if tmcGroup = null then	//14 Jan 2009	NDL	CCMS MES 1006
			tmcGroup := self.getIndexInList(qtyMap,CMIF_TMCGroup.TM_Level_14_Quantity, idx); 
		endif;
		if tmcGroup = null then
			tmcGroup := self.getIndexInList(qtyMap,CMIF_TMCGroup.TM_Level_06_Quantity, idx); 
			if tmcGroup = null then
				tmcGroup := self.getIndexInList(qtyMap,CMIF_TMCGroup.TM_Level_08_Quantity, idx);  // 15/05/2023	navkc1	CR 57927 Task 54268
				if tmcGroup = null then
					tmcGroup := self.getIndexInList(qtyMap,CMIF_TMCGroup.TM_Level_12_Quantity, idx); 
					if tmcGroup = null then //17/02/2017 cnwma1 TFS #2901
						tmcGroup := self.getIndexInList(qtyMap,CMIF_TMCGroup.TM_Level_15_QuantityRange, idx); 
						if tmcGroup = null then // 21/01/2017 cnwma1 TFS #2885
							tmcGroup := self.getIndexInList(qtyMap,CMIF_TMCGroup.TM_Level_16_QuantityRange, idx); 
						endif;
					endif;
				endif;
			endif;
		endif;
		if idx &gt; 0 then
			if qtyMap.myParentFinancialObject.isKindOf(CM_DebtorMap) then
				create trGroup;
			elseif qtyMap.myParentFinancialObject.isKindOf(CM_QuantityMap) then //09/02/2017 cnwma1 TFS #2901
				create trGroup as CMIF_TMCQuantitySubRangeGroup;
			else
				create trGroup as CMIF_TMCQuantityRangeGroupDeft;
			endif;

			trGroup.myQuantityRangeMap := _theMap;
			trGroup.itemName := trGroup.getItemName();
			trGroup.extractName := _theMap.getExtractDetails();	// 23659
			trGroup.myGroup := tmcGroup;
			trGroup.initialise(self.myTMCRoot.groupCount);
			trGroup.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			self.lstData.itemExpanded[idx+1] := true;
			self.lstData.listIndex := idx+1;
		endif;
		
	elseif _event = EVENT_TRANSACTIONMAP_DELETE then
		tmcGroup := self.getIndexInList(_theMap,CMIF_TMCGroup.TM_Level_13_QuantityRange, idx);
		if tmcGroup = null then	//14 Jan 2009	NDL	CCMS MES 1006
			tmcGroup := self.getIndexInList(_theMap,CMIF_TMCGroup.TM_Level_15_QuantityRange, idx); 
		endif;
		if tmcGroup = null then
			tmcGroup := self.getIndexInList(_theMap,CMIF_TMCGroup.TM_Level_14_QuantityRange, idx);
			if tmcGroup = null then
				tmcGroup := self.getIndexInList(_theMap,CMIF_TMCGroup.TM_Level_09_QuantityRange, idx); // 15/05/2023	navkc1	CR 57927 Task 54268
				if tmcGroup = null then
					tmcGroup := self.getIndexInList(_theMap,CMIF_TMCGroup.TM_Level_07_QuantityRange, idx);
				endif;
			endif;
		endif;
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
	endif;
end;</source>
        <Parameter name="_theMap" type="CM_QuantityRangeMap"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUserNoteSBBOL" id="7f45308c-463a-4495-a54d-a07e05fc1a73">
        <updating/>
        <source>doUserNoteSBBOL(_theMap : CM_BOLServiceBroker; _event : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars
	trGroup : CMIF_TMCBOLTrxGroup;
	dmDefault : CMIF_TMCDebtorGroupDefault;
	tmcGroup : CMIF_TMCGroup;
	extractName,
	itemName : String;
	tmBOL : CM_TranMapBOL;
	idx		: Integer;
	bolSB : CM_BOLServiceBroker;
begin
	// 35872 ignore notes for changes from other business units
	if _theMap &lt;&gt; null and
	   global.isValidObject(_theMap) then
		if _theMap.getBank &lt;&gt; self.myCurrentBank then
			return;
		endif;
	endif;

	if _event = EVENT_TRANSACTIONMAP_DELETE then
		tmcGroup := self.getIndexInList(_theMap,4, idx);
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
		return;
	endif;
	bolSB := _theMap.CM_BOLServiceBroker;
	tmBOL := bolSB.myTransMap;

	if  bolSB.transactionType = 0 then
		itemName := "Default";
		extractName := CM_FinancialObject.Extract_Default;
	else
		// TFS 40620 added the transaction Id and delimiter, when adding mappings the Id was not in this extract, if the extract was then done the new line would not load
		itemName :=  bolSB.getBOLTypeDesc(); 
		extractName := bolSB.transactionType.String &amp; "|" &amp; bolSB.getBOLTypeDesc(); 
	endif;
	
	if _event = EVENT_TRANSACTIONMAP_CREATE then
		tmcGroup := self.getIndexInList(tmBOL,CMIF_TranMapController.TM_Level_03_TranMap, idx);

		if idx &gt; 0 then
			create trGroup;

			trGroup.myBOLBroker := bolSB;
			trGroup.itemName := itemName;
			trGroup.extractName := extractName;	
			trGroup.myGroup := tmcGroup;
			trGroup.initialise(self.myTMCRoot.groupCount);
			trGroup.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			self.lstData.itemExpanded[idx+1] := true;
			self.lstData.listIndex := idx+1;
			// 33535 more than one user updating same trans map
			if not self.isEditing() then
				self.doLstDataClick(self.lstData);
			endif;
		endif;
	elseif _event = EVENT_TRANSACTIONMAP_UPDATE then
		// find the transient
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_05_Debtor, idx);
		// remove from list box and delete
		if idx &gt; 0 then
			itemName := tmcGroup.itemName;
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
		// get Parent object
		idx := 0;
		tmcGroup := self.getIndexInList(_theMap,4, idx); 
		
		// recreate transient;
		if idx &gt; 0 then
			create dmDefault;

			dmDefault.myDebtor := null;
			dmDefault.myServiceBroker := _theMap;
			dmDefault.itemName := dmDefault.getItemName(); //itemName;
			dmDefault.itemName := CM_FinancialObject.Extract_Default;	// 23659
			dmDefault.myGroup := tmcGroup;
			dmDefault.initialise(self.myTMCRoot.groupCount);
			dmDefault.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			self.lstData.itemExpanded[idx+1] := true;
			self.lstData.listIndex := idx+1;
			// 33535 more than one user updating same trans map
			if not self.isEditing() then
				self.doLstDataClick(self.lstData);
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_theMap" type="CM_BOLServiceBroker"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUserNoteSBEvent" id="495b5777-e459-4113-aacd-e88ff0b3d386">
        <updating/>
        <source>doUserNoteSBEvent(_theMap : CM_ServiceBroker; _event : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
// ---------------------------------------------------------------------------
vars
	trGroup : CMIF_TMCEventGroup;
	dmDefault : CMIF_TMCDebtorGroupDefault;
	tmcGroup : CMIF_TMCGroup;
	extractName,
	itemName : String;
	tmEvent : CM_TranMapEvent;
	idx		: Integer;
	theEveSB : CM_EventServiceBroker;
begin
	// 35872 ignore notes for changes from other business units
	if _theMap &lt;&gt; null and
	   global.isValidObject(_theMap) then
		if _theMap.getBank &lt;&gt; self.myCurrentBank then
			return;
		endif;
	endif;

	if _event = EVENT_TRANSACTIONMAP_DELETE then
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_04_Event, idx);
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
		return;
	endif;
	theEveSB := _theMap.CM_EventServiceBroker;
	tmEvent := theEveSB.myTranMap;

	if  theEveSB.myEventType &lt;&gt; null then
		itemName :=  theEveSB.myEventType.name;
		// TFS 40620 added the event type and delimiter, when adding mappings the Id was not in this extract, if the extract was then done the new line would not load
		extractName := theEveSB.myEventType.type.String &amp; "|" &amp;  theEveSB.myEventType.name;
	else
		itemName := "Default";
		extractName := CM_FinancialObject.Extract_Default;
	endif;
	
	if _event = EVENT_TRANSACTIONMAP_CREATE then
		tmcGroup := self.getIndexInList(tmEvent,CMIF_TranMapController.TM_Level_03_TranMap, idx);

		if idx &gt; 0 then
			create trGroup;

			trGroup.myEventBroker := theEveSB;
			trGroup.itemName := itemName;
			trGroup.extractName := extractName;	// 23659
			trGroup.myGroup := tmcGroup;
			trGroup.myEventType := theEveSB.myEventType; // 15/05/2023	navkc1	CR 57927 Task 54268
			trGroup.initialise(self.myTMCRoot.groupCount);
			trGroup.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			self.lstData.itemExpanded[idx+1] := true;
			self.lstData.listIndex := idx+1;
			// 33535 more than one user updating same trans map
			if not self.isEditing() then
				self.doLstDataClick(self.lstData);
			endif;
		endif;
	elseif _event = EVENT_TRANSACTIONMAP_UPDATE then
		// find the transient
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_05_Debtor, idx);
		// remove from list box and delete
		if idx &gt; 0 then
			itemName := tmcGroup.itemName;
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
		// get Parent object
		idx := 0;
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_04_Event, idx); 
		
		// recreate transient;
		if idx &gt; 0 then
			create dmDefault;

			dmDefault.myDebtor := null;
			dmDefault.myServiceBroker := _theMap;
			dmDefault.itemName := dmDefault.getItemName(); //itemName;
			dmDefault.itemName := CM_FinancialObject.Extract_Default;	// 23659
			dmDefault.myGroup := tmcGroup;
			dmDefault.initialise(self.myTMCRoot.groupCount);
			dmDefault.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			self.lstData.itemExpanded[idx+1] := true;
			self.lstData.listIndex := idx+1;
			// 33535 more than one user updating same trans map
			if not self.isEditing() then
				self.doLstDataClick(self.lstData);
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_theMap" type="CM_ServiceBroker"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUserNoteSBMove" id="06e7ea75-49df-4305-97d3-c4a38c11c735">
        <updating/>
        <source>doUserNoteSBMove(_theMap : CM_ServiceBroker; _event : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	dmDefault : CMIF_TMCDebtorGroupDefault;
	tmcMove : CMIF_TMCMoveGroup;
	trGroup : CMIF_TMCSBGroup;
	tmcGroup, parenttmcGroup : CMIF_TMCGroup;
	aCommMap : CM_CommodityMap;
	itemName : String;
	idx		: Integer;
begin
	// 35872 ignore notes for changes from other business units
	if _theMap &lt;&gt; null and
	   global.isValidObject(_theMap) then
		if _theMap.getBank &lt;&gt; self.myCurrentBank then
			return;
		endif;
	endif;

	if _event = EVENT_TRANSACTIONMAP_DELETE then
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_11_Debtor, idx);
		if idx &gt; 0 then

			// ## AKB2005JUL. if the move being deleted is teh last one, then remove off the GUI the 'Move' entry
			aCommMap := tmcGroup.myGroup.CMIF_TMCMoveGroup.myCommodityMap;
			if aCommMap &lt;&gt; null 
			and aCommMap.moveMap.isEmpty then
				tmcGroup := tmcGroup.myGroup;
				idx := idx - 1;
			endif;

			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
		return;
	endif;
	
	aCommMap := _theMap.CM_MoveServiceBroker.commodityMap;
	
	if _event = EVENT_TRANSACTIONMAP_CREATE then
		// get parent;
		tmcGroup := self.getIndexInList(aCommMap,CMIF_TranMapController.TM_Level_09_Commodity, idx); // GET COMMODITY
		parenttmcGroup := tmcGroup.CMIF_TMCCommodityGroup.getMoveGroup(); // get the 'Move'
		if parenttmcGroup = null then
			create tmcMove;
			parenttmcGroup := tmcMove;
			tmcMove.myCommodityMap := aCommMap;
			tmcMove.itemName := "Move";
			tmcMove.extractName := "Move";	// 23659
			tmcMove.myGroup := tmcGroup;
			tmcMove.initialise(self.myTMCRoot.groupCount);
			tmcMove.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1 ,idx + 1);
		else
			idx := 0;
			tmcGroup := self.getIndexInList(parenttmcGroup,CMIF_TranMapController.TM_Level_10_TranServiceBroker, idx); // get the 'Move' index
			if parenttmcGroup &lt;&gt; null then
				create trGroup;
				trGroup.myServiceBroker := _theMap;
				itemName := _theMap.CM_MoveServiceBroker.moveFrom &amp; " -&gt; " &amp; _theMap.CM_MoveServiceBroker.moveTo; // PAR 9973 &amp; " " &amp; _theMap.CM_MoveServiceBroker.getLimitingDebtors();
				trGroup.itemName := itemName;
				trGroup.extractName := itemName;	// 23659
				trGroup.myGroup := parenttmcGroup;
				trGroup.initialise(self.myTMCRoot.groupCount);
				trGroup.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			endif;
		endif;
		self.lstData.itemExpanded[idx+1] := true;
		self.lstData.listIndex := idx+1;
		// 33535 more than one user updating same trans map
		if not self.isEditing() then
			self.doLstDataClick(self.lstData);
		endif;
		
	elseif _event = EVENT_TRANSACTIONMAP_UPDATE then
		// find the transient
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_14_MoveTransactions, idx);
		// remove from list box and delete
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
		// get Parent object
		idx := 0;
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_11_Debtor, idx); 
		
		// recreate transient;
		if idx &gt; 0 then
			create dmDefault;

			dmDefault.myDebtor := null;
			dmDefault.myServiceBroker := _theMap;
			dmDefault.itemName := dmDefault.getItemName();
			dmDefault.extractName := CM_FinancialObject.Extract_Default;	// 23659
			dmDefault.myGroup := tmcGroup;
			dmDefault.initialise(self.myTMCRoot.groupCount);
			dmDefault.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			self.lstData.itemExpanded[idx+1] := true;
			self.lstData.listIndex := idx+1;
			// 33535 more than one user updating same trans map
			if not self.isEditing() then
				self.doLstDataClick(self.lstData);
			endif;
		endif;
	endif;
		
end;</source>
        <Parameter name="_theMap" type="CM_ServiceBroker"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUserNoteSBResource" id="0cb89e53-6a92-4282-8bcd-6eb5acf79e52">
        <updating/>
        <source>doUserNoteSBResource(_theMap : CM_ServiceBroker; _event : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	trGroup : CMIF_TMCResourceGroup;
	dmDefault : CMIF_TMCDebtorGroupDefault;
	tmcGroup : CMIF_TMCGroup;
	extractName,
	itemName : String;
	tmVoyage : CM_TranMapVoyage;
	idx		: Integer;
	theResSB : CM_ResourceServiceBroker;
begin
	// 35872 ignore notes for changes from other business units
	if _theMap &lt;&gt; null and
	   global.isValidObject(_theMap) then
		if _theMap.getBank &lt;&gt; self.myCurrentBank then
			return;
		endif;
	endif;

	if _event = EVENT_TRANSACTIONMAP_DELETE then
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_04_Resource, idx);
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
		return;
	endif;
	theResSB := _theMap.CM_ResourceServiceBroker;
	tmVoyage := theResSB.myTransMap;

	if  theResSB.myResource &lt;&gt; null then
		itemName :=  theResSB.myResource.description;
		extractName := theResSB.myResource.code;
	else
		itemName := "Default";
		extractName := CM_FinancialObject.Extract_Default;
	endif;
	
	if _event = EVENT_TRANSACTIONMAP_CREATE then
		tmcGroup := self.getIndexInList(tmVoyage,CMIF_TranMapController.TM_Level_03_TranMap, idx);

		if idx &gt; 0 then
			create trGroup;

			trGroup.myResourceBroker := theResSB;
			trGroup.itemName := itemName;
			trGroup.extractName := extractName;	// 23659
			trGroup.myGroup := tmcGroup;
			trGroup.initialise(self.myTMCRoot.groupCount);
			trGroup.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			self.lstData.itemExpanded[idx+1] := true;
			self.lstData.listIndex := idx+1;
			// 33535 more than one user updating same trans map
			if not self.isEditing() then
				self.doLstDataClick(self.lstData);
			endif;
		endif;
	elseif _event = EVENT_TRANSACTIONMAP_UPDATE then
		// find the transient
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_05_Debtor, idx);
		// remove from list box and delete
		if idx &gt; 0 then
			itemName := tmcGroup.itemName;
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
		// get Parent object
		idx := 0;
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_04_Resource, idx); 
		
		// recreate transient;
		if idx &gt; 0 then
			create dmDefault;

			dmDefault.myDebtor := null;
			dmDefault.myServiceBroker := _theMap;
			dmDefault.itemName := dmDefault.getItemName(); //itemName;
			dmDefault.extractName := CM_FinancialObject.Extract_Default;	// 23659
			dmDefault.myGroup := tmcGroup;
			dmDefault.initialise(self.myTMCRoot.groupCount);
			dmDefault.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			self.lstData.itemExpanded[idx+1] := true;
			self.lstData.listIndex := idx+1;
			// 33535 more than one user updating same trans map
			if not self.isEditing() then
				self.doLstDataClick(self.lstData);
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_theMap" type="CM_ServiceBroker"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUserNoteSBSumm" id="a19244b1-f435-4766-8a9d-689ba550147e">
        <updating/>
        <source>doUserNoteSBSumm(_theMap : CM_ServiceBroker; _event : Integer) updating;

vars
	trGroup : CMIF_TMCSSGroup;
	tmcGroup : CMIF_TMCGroup;
	tranMap	: CM_TranMapSSSummary;
	extractName,
	itemName : String;
	idx		 : Integer;
	theSSB : CM_SnapShotServiceBroker;
begin
	// 35872 ignore notes for changes from other business units
	if _theMap &lt;&gt; null and
	   global.isValidObject(_theMap) then
		if _theMap.getBank &lt;&gt; self.myCurrentBank then
			return;
		endif;
	endif;

	if _event = EVENT_TRANSACTIONMAP_DELETE then
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_04_Event, idx);
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
		return;
	endif;
	theSSB := _theMap.CM_SnapShotServiceBroker;
	tranMap := theSSB.myTransactionMap;

	itemName :=  theSSB.getDescription();
	extractName := theSSB.mySnapShotDefinition.name;
	
	if _event = EVENT_TRANSACTIONMAP_CREATE then
		tmcGroup := self.getIndexInList(tranMap,CMIF_TranMapController.TM_Level_03_TranMap, idx);

		if idx &gt; 0 then
			create trGroup;

			trGroup.mySnapShotBroker := theSSB;
			trGroup.itemName := theSSB.getDescription();
			trGroup.extractName := theSSB.getCode();
			trGroup.myGroup := tmcGroup;
			trGroup.myTMCController := tmcGroup.myTMCController;
			trGroup.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			self.lstData.itemExpanded[idx+1] := true;
			self.lstData.listIndex := idx+1;
			// 33535 more than one user updating same trans map
			if not self.isEditing() then
				self.doLstDataClick(self.lstData);
			endif;
		endif;
	elseif _event = EVENT_TRANSACTIONMAP_UPDATE then
		// find the transient
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_04_Event, idx);
		// remove from list box and delete
		if idx &gt; 0 then
			self.lstData.itemText[idx] := itemName;
		endif;
		// get Parent object
		idx := 0;
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_04_Event, idx); 
		
	endif;
end;</source>
        <Parameter name="_theMap" type="CM_ServiceBroker"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUserNoteSBToDoRsrc" id="4f990c7f-28b8-4420-ad41-a6a97cf03e74">
        <updating/>
        <source>doUserNoteSBToDoRsrc(_theMap : CM_ToDoResourceServiceBroker; _event : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map

*/

vars
	trGroupEvent 			: CMIF_TMCEventGroup;
	trGroupWO				: CMIF_TMCWorkOrderGroup;
	tmcGroup 				: CMIF_TMCGroup;
	idx		 				: Integer;
	idx2 					: Integer;
	doDeleteHeader 			: Boolean;
	tmcResourceHeader 		: CMIF_TMCTaskResourceTypeHeader;
	tmcBroker 				: CMIF_TMCTaskResourceTypeGroup;
	isEvent					: Boolean;
	isWO					: Boolean;
	
begin

	if _theMap &lt;&gt; null and
	   global.isValidObject(_theMap) then
		if _theMap.getBank &lt;&gt; self.myCurrentBank then
			return;
		endif;
	endif;
	
	if _event = EVENT_TRANSACTIONMAP_DELETE then
		tmcGroup := self.getIndexInList(_theMap, CMIF_TranMapController.TM_Level_04_Event, idx);
		if tmcGroup = null then
			tmcGroup := self.getIndexInList(_theMap, CMIF_TranMapController.TM_Level_06_ResourceType, idx);
			if tmcGroup &lt;&gt; null and tmcGroup.myGroup &lt;&gt; null and tmcGroup.myGroup.isKindOf(CMIF_TMCTaskResourceTypeHeader) then
				tmcResourceHeader := tmcGroup.myGroup.CMIF_TMCTaskResourceTypeHeader;
				if tmcResourceHeader.allGroupMembers.size = 1 then
					idx2 := idx - 1;
					doDeleteHeader := true;
				endif;
			endif;
		endif;
		
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
		
		if doDeleteHeader then
			self.lstData.removeItem(idx2);
			delete tmcResourceHeader;
		endif;
		return;
	endif;
	
	if _theMap.myServiceBroker.isKindOf(CM_EventServiceBroker) then
		isEvent := true;
	elseif _theMap.myServiceBroker.isKindOf(CM_WorkOrderServiceBroker) then
		isWO := true;
	endif;
	
	if _event = EVENT_TRANSACTIONMAP_CREATE then
		tmcGroup := self.getIndexInList(_theMap.CM_ToDoResourceServiceBroker, CMIF_TranMapController.TM_Level_05_ResourceMapHeader, idx);
				
		if tmcGroup = null then
			if isEvent then
				trGroupEvent := self.getIndexInList(_theMap.CM_ToDoResourceServiceBroker.myServiceBroker, CMIF_TranMapController.TM_Level_04_Event, idx2).CMIF_TMCEventGroup;
			elseif isWO then
				trGroupWO := self.getIndexInList(_theMap.CM_ToDoResourceServiceBroker.myServiceBroker, CMIF_TranMapController.TM_Level_04_WorkOrder, idx2).CMIF_TMCWorkOrderGroup;
			endif;
		endif;
		
		if (isEvent and trGroupEvent &lt;&gt; null) or
			(isWO and trGroupWO &lt;&gt; null) then
			create tmcResourceHeader;
			tmcResourceHeader.myTransServiceBroker := _theMap.CM_ToDoResourceServiceBroker.myServiceBroker;
			tmcResourceHeader.itemName := "Resource Mappings"; 
			tmcResourceHeader.extractName := tmcResourceHeader.itemName;
			if isEvent then
				tmcResourceHeader.myGroup := trGroupEvent;
				tmcResourceHeader.myTMCController := trGroupEvent.myTMCController;
			elseif isWO then
				tmcResourceHeader.myGroup := trGroupWO;
				tmcResourceHeader.myTMCController := trGroupWO.myTMCController;
			endif;
			tmcResourceHeader.loadListaAt(self.lstData, self.lstData.itemLevel[idx2] + 1,idx2 + 1);
			self.lstData.itemExpanded[idx2+1] := true;
			self.lstData.listIndex := idx2+1;
			
			tmcGroup := self.getIndexInList(_theMap.CM_ToDoResourceServiceBroker, CMIF_TranMapController.TM_Level_05_ResourceMapHeader, idx);
		endif;
		
		if idx &gt; 0 then
			create tmcBroker;
			
			tmcBroker.myTransResourceServiceBroker := _theMap;
			tmcBroker.itemName := _theMap.getResourceName();
			tmcBroker.extractName := _theMap.getResourceCode();
			tmcBroker.myGroup := tmcGroup;
			tmcBroker.initialise(self.myTMCRoot.groupCount);
			tmcBroker.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			self.lstData.itemExpanded[idx+1] := true;
			self.lstData.listIndex := idx+1;
			if not self.isEditing() then
				self.doLstDataClick(self.lstData);
			endif;
		endif;
		
	endif;
epilog

end;</source>
        <Parameter name="_theMap" type="CM_ToDoResourceServiceBroker"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUserNoteSBTrans" id="cf6b076f-27ab-4530-aef2-3e6c0c45be74">
        <updating/>
        <source>doUserNoteSBTrans(_theMap : CM_ServiceBroker; _event : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	trGroup : CMIF_TMCSBGroup;
	dmDefault : CMIF_TMCDebtorGroupDefault;
	tmcGroup : CMIF_TMCGroup;
	aCommMap : CM_CommodityMap;
	extractName,
	itemName : String;
	idx		 : Integer;
	tmcResourceHeader : CMIF_TMCTaskResourceTypeHeader;
	trGroup2 : CMIF_TMCSBGroup;
	idx2 : Integer;
	doDeleteHeader : Boolean;
	
begin
	// 35872 ignore notes for changes from other business units
	if _theMap &lt;&gt; null and
	   global.isValidObject(_theMap) then
		if _theMap.getBank &lt;&gt; self.myCurrentBank then
			return;
		endif;
	endif;

	if _event = EVENT_TRANSACTIONMAP_DELETE then
		tmcGroup := self.getIndexInList(_theMap, CMIF_TranMapController.TM_Level_10_TranServiceBroker, idx);
		if tmcGroup = null then	//07 Jan 2010 NDL CCMS MES 1006
			tmcGroup := self.getIndexInList(_theMap, CMIF_TranMapController.TM_Level_12_TranServiceBroker, idx);
			// is this the last trans resource service broker, if so delete the header too.
			if tmcGroup &lt;&gt; null and tmcGroup.myGroup &lt;&gt; null and tmcGroup.myGroup.isKindOf(CMIF_TMCTaskResourceTypeHeader) then
				tmcResourceHeader := tmcGroup.myGroup.CMIF_TMCTaskResourceTypeHeader;
				if tmcResourceHeader.allGroupMembers.size = 1 then
					idx2 := idx - 1;
					doDeleteHeader := true;
				endif;
			endif;
		endif;
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
		//12 Jan 2010 NDL CCMS MES 1006
		if doDeleteHeader then
			self.lstData.removeItem(idx2);
			delete tmcResourceHeader;
		endif;
		return;
	endif;
	
	aCommMap := _theMap.CM_TransServiceBroker.commodityMap;
	itemName := _theMap.CM_TransServiceBroker.getTransactionClassName; // PAR 9973 &amp; " " &amp; _theMap.CM_TransServiceBroker.getLimitingDebtors();
	extractName := _theMap.CM_TransServiceBroker.getTransactionCode();
	
	if _event = EVENT_TRANSACTIONMAP_CREATE then
		if _theMap.isKindOf(CM_TransResourceServiceBroker) then	//07 Jan 2010 NDL CCMS MES 1006
		
			tmcGroup := self.getIndexInList(_theMap.CM_TransResourceServiceBroker, CMIF_TranMapController.TM_Level_11_ResourceMapHeader, idx);
			
			//12 Jan 2009	NDL	CCMS MES 1006
			if tmcGroup = null then
				// We are trying to add a new resource when no mapping header exists, add the header first.
				trGroup2 := self.getIndexInList(_theMap.CM_TransResourceServiceBroker.myTransServiceBroker,CMIF_TranMapController.TM_Level_10_TranServiceBroker, idx2).CMIF_TMCSBGroup;
			
				if trGroup2 &lt;&gt; null then
					create tmcResourceHeader;
					tmcResourceHeader.myTransServiceBroker := _theMap.CM_TransResourceServiceBroker.myTransServiceBroker;
					tmcResourceHeader.itemName := "Resource Mappings"; 
					tmcResourceHeader.extractName := tmcResourceHeader.itemName;	// 23659
					tmcResourceHeader.myGroup := trGroup2;
					tmcResourceHeader.myTMCController := trGroup2.myTMCController;	// 30620 Oct 2012
					tmcResourceHeader.loadListaAt(self.lstData, self.lstData.itemLevel[idx2] + 1,idx2 + 1);
					self.lstData.itemExpanded[idx2+1] := true;
					self.lstData.listIndex := idx2+1;
			
					tmcGroup := self.getIndexInList(_theMap.CM_TransResourceServiceBroker, CMIF_TranMapController.TM_Level_11_ResourceMapHeader, idx);
				endif;
				
			endif; 
			
		else
			tmcGroup := self.getIndexInList(aCommMap,CMIF_TranMapController.TM_Level_09_Commodity, idx);
		endif;

		if idx &gt; 0 then
			create trGroup;

			trGroup.myServiceBroker := _theMap;
			trGroup.itemName := itemName;
			trGroup.extractName := extractName;	// 23659
			trGroup.myGroup := tmcGroup;
			trGroup.initialise(self.myTMCRoot.groupCount);
			trGroup.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			self.lstData.itemExpanded[idx+1] := true;
			self.lstData.listIndex := idx+1;
			// 33535 more than one user updating same trans map
			if not self.isEditing() then
				self.doLstDataClick(self.lstData);
			endif;
		endif;
	elseif _event = EVENT_TRANSACTIONMAP_UPDATE then
		// find the transient
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_11_Debtor, idx);
		// remove from list box and delete
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
		// get Parent object
		idx := 0;
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_10_TranServiceBroker, idx); 
		
		// recreate transient;
		if idx &gt; 0 then
			create dmDefault;

			dmDefault.myDebtor := null;
			dmDefault.myServiceBroker := _theMap;
			dmDefault.itemName := dmDefault.getItemName();
			dmDefault.myGroup := tmcGroup;
			dmDefault.initialise(self.myTMCRoot.groupCount);
			dmDefault.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			self.lstData.itemExpanded[idx+1] := true;
			self.lstData.listIndex := idx+1;
			// 33535 more than one user updating same trans map
			if not self.isEditing() then
				self.doLstDataClick(self.lstData);
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_theMap" type="CM_ServiceBroker"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUserNoteSBWorkOrder" id="fd46c5d1-8e2a-416a-82bc-e76b1e3d7bb9">
        <updating/>
        <source>doUserNoteSBWorkOrder(_theMap : CM_ServiceBroker; _event : Integer) updating;
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
*/

vars
	trGroup : CMIF_TMCWorkOrderGroup;
	dmDefault : CMIF_TMCDebtorGroupDefault;
	tmcGroup : CMIF_TMCGroup;
	extractName,
	itemName : String;
	tmWorkOrder : CM_TranMapWorkOrder;
	idx		: Integer;
	theWOSB : CM_WorkOrderServiceBroker;
begin
	// 35872 ignore notes for changes from other business units
	if _theMap &lt;&gt; null and
	   global.isValidObject(_theMap) then
		if _theMap.getBank &lt;&gt; self.myCurrentBank then
			return;
		endif;
	endif;

	if _event = EVENT_TRANSACTIONMAP_DELETE then
		tmcGroup := self.getIndexInList(_theMap,4, idx);
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
		return;
	endif;
	theWOSB := _theMap.CM_WorkOrderServiceBroker;
	tmWorkOrder := theWOSB.myTransMap;

	if  theWOSB.workOrderType = 0 then
		itemName := "Default";
		extractName := CM_FinancialObject.Extract_Default;
	else
		// TFS 40620 added the transaction Id and delimiter, when adding mappings the Id was not in this extract, if the extract was then done the new line would not load
		itemName :=  theWOSB.getWorkOrderTypeDesc(); 
		extractName := theWOSB.workOrderType.String &amp; "|" &amp; theWOSB.getWorkOrderTypeDesc(); 
	endif;
	
	if _event = EVENT_TRANSACTIONMAP_CREATE then
		tmcGroup := self.getIndexInList(tmWorkOrder,CMIF_TranMapController.TM_Level_03_TranMap, idx);

		if idx &gt; 0 then
			create trGroup;

			trGroup.myWOBroker := theWOSB;
			trGroup.itemName := itemName;
			trGroup.extractName := extractName;	
			trGroup.myGroup := tmcGroup;
			trGroup.workOrderType := theWOSB.workOrderType;	// 15/05/2023	navkc1	CR 57927 Task 54268
			trGroup.initialise(self.myTMCRoot.groupCount);
			trGroup.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			self.lstData.itemExpanded[idx+1] := true;
			self.lstData.listIndex := idx+1;
			// 33535 more than one user updating same trans map
			if not self.isEditing() then
				self.doLstDataClick(self.lstData);
			endif;
		endif;
	elseif _event = EVENT_TRANSACTIONMAP_UPDATE then
		// find the transient
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_05_Debtor, idx);
		// remove from list box and delete
		if idx &gt; 0 then
			itemName := tmcGroup.itemName;
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
		// get Parent object
		idx := 0;
		tmcGroup := self.getIndexInList(_theMap,4, idx); 
		
		// recreate transient;
		if idx &gt; 0 then
			create dmDefault;

			dmDefault.myDebtor := null;
			dmDefault.myServiceBroker := _theMap;
			dmDefault.itemName := dmDefault.getItemName(); //itemName;
			dmDefault.itemName := CM_FinancialObject.Extract_Default;	// 23659
			dmDefault.myGroup := tmcGroup;
			dmDefault.initialise(self.myTMCRoot.groupCount);
			dmDefault.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			self.lstData.itemExpanded[idx+1] := true;
			self.lstData.listIndex := idx+1;
			// 33535 more than one user updating same trans map
			if not self.isEditing() then
				self.doLstDataClick(self.lstData);
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_theMap" type="CM_ServiceBroker"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUserNoteTransactionMap" id="a0c66325-c79d-4d22-9dfa-93b28f9d3add">
        <source>doUserNoteTransactionMap(_theMap : CM_TranMap; _event : Integer);
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	itemName : String;
	trGroup : CMIF_TMCTranGroup;
	tmcGroup : CMIF_TMCGroup;
	idx		: Integer;
begin
	// 35872 ignore notes for changes from other business units
	if _theMap &lt;&gt; null and
	   global.isValidObject(_theMap) then
		if _theMap.getBank &lt;&gt; self.myCurrentBank then
			return;
		endif;
	endif;

	if _event = EVENT_TRANSACTIONMAP_CREATE then		
		tmcGroup := self.getIndexInList(self.myTMCRoot.allGroupMembers[app.getErrorString(Cargo)],CMIF_TranMapController.TM_Level_02_Type, idx);		//par 22970
		if idx &gt; 0 then
			create trGroup;
			trGroup.myTranMapCargo := _theMap;
			trGroup.itemName := _theMap.name;
			trGroup.extractName := _theMap.name;	// 23659
			trGroup.myGroup := tmcGroup;
			trGroup.initialise(self.myTMCRoot.groupCount);

			idx := self.lstData.findItemData(CMIF_TMCType.TYPE_TRACKEDITEM);
			//if idx &gt; 0 then
				trGroup.loadListaAt(self.lstData, self.lstData.itemLevel[idx] + 1,idx + 1);
			//endif;
		endif;   
	elseif _event = EVENT_TRANSACTIONMAP_UPDATE then
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_03_TranMap, idx);
		if idx &gt; 0 then
			itemName := tmcGroup.getName();
			self.lstData.itemText[idx] := itemName;
			// TFS 2352 update the transient CIF_TMCTranGroup itemName as well so it is correct for a subsequent export
			tmcGroup.itemName := itemName;

		endif;
	elseif _event = EVENT_TRANSACTIONMAP_DELETE then
		tmcGroup := self.getIndexInList(_theMap,CMIF_TranMapController.TM_Level_03_TranMap, idx);
		if idx &gt; 0 then
			self.lstData.removeItem(idx);
			delete tmcGroup;
		endif;
		
	endif;
end;</source>
        <Parameter name="_theMap" type="CM_TranMap"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
