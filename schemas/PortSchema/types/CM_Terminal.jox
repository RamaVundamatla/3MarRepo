    <JadeMethod name="getBookingReference" id="0ce4f8ce-c939-4c59-8d1b-5e4998d24d3b">
        <source>getBookingReference(_operatorCode, _bookingRef :String; _voyage :CM_Voyage) :CM_BookingRef;
// adm 150908 Par 17936 rationalise booking reference lookups 
// dap 201011 PAR #28524 Bookings unique by number flag on operator
// 09/01/2012	cnwrs1	Par 28946 - after the flag bookingsUniqueByNumber is set there may already be duplicate bookings by voyage, make sure we pick up the one for the current voyage if it exists
vars
	ref	: CM_BookingRef;
	op  : CM_Operator;		// PAR #28524
begin
	if _operatorCode &lt;&gt; null then
		// PAR #28524 if the operator has the "bookings unique by number" flag set, ignore the voyage
		// when finding the actual booking
		op := self.myRoot.allOperators[_operatorCode];
		if op &lt;&gt; null and op.bookingsUniqueByNumber then
			ref	:= self.allBookingRefsByOperatorRef[_operatorCode, _bookingRef, _voyage];	//cnwrs1 9 Jan 2012 Par 28946
			if ref &lt;&gt; null then
				return ref;
			endif;
			ref := self.allBookingRefsByOperatorRef.getAtKeyGeq(_operatorCode, _bookingRef, null);
			if ref &lt;&gt; null and ref.operatorCode = _operatorCode and ref.bookingReference = _bookingRef then
				return ref;
			endif;
		endif;
		// PAR #28524 end
		//notes 
		ref	:= self.allBookingRefsByOperatorRef[_operatorCode, _bookingRef, _voyage];
		if ref &lt;&gt; null or _voyage = null then
			return ref;
		else
			return self.allBookingRefsByOperatorRef[_operatorCode, _bookingRef, null];
		endif;
	else
		return self.allBookingRefsByRef[_bookingRef];
	endif;
end;
</source>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_bookingRef" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="getBookingReferenceExact" id="05fa185e-608d-408b-8db0-7c0c9f0a5242">
        <source>getBookingReferenceExact(_operatorCode, _bookingRef :String; _voyage :CM_Voyage) :CM_BookingRef;

/* Purpose -  	This is a copy of getBookingReference() but with a few changes, see Change Detail below.

Date		Developer	Par		Change Detail
11/06/2010	cnwmd1		23116	Simplify the booking search.  Note that the voyage is optional.
								This method returns a matching booking based on booking ref, voyage, and operator.
*/
vars

begin
	if _operatorCode &lt;&gt; null then
		return self.allBookingRefsByOperatorRef[_operatorCode, _bookingRef, _voyage];
	else
		return self.allBookingRefsByRef[_bookingRef];
	endif;	
end;
</source>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_bookingRef" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="getBookingReferenceForVoyage" id="06e72209-1329-4f76-ad0b-c28671364ced">
        <source>getBookingReferenceForVoyage(_bookingRef : String; _voyage : CM_Voyage) : CM_BookingRef;
//
//06 June 2014	cnwrs1	par34261 find booking for the booking reaf and voyage specified.
// 04/036/2015 	cnwmh5	Tranisent Leak
//
vars
	ref	: CM_BookingRef;
	iterRef : CM_BookingRef;
	iter : Iterator;
	voyageCode : String;
begin
	if _voyage &lt;&gt; null then
		voyageCode := _voyage.code;
	endif;
	ref := self.allBookingRefsByRef.getAtKeyGeq(_bookingRef);
	if ref &lt;&gt; null and ref.voyageCode = voyageCode and ref.bookingReference = _bookingRef then
		return ref;
	endif;
	iter := self.allBookingRefsByRef.createIterator;
	self.allBookingRefsByRef.startKeyGeq(_bookingRef, iter);
	while iter.next(iterRef) and iter.getCurrentKey(1).String = _bookingRef do
		if iterRef.voyageCode = voyageCode then
		//	ref := iterRef;
			return iterRef;	//10 Mar 2017	NDL	TFS 3703
			break;
		endif;
	endwhile;
	//return ref;
	return null;		//10 Mar 2017	NDL	TFS 3703
epilog
	delete iter;
end;
</source>
        <Parameter name="_bookingRef" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="getBookingReferenceLatest" id="aef66302-504e-4093-818c-89aa615e94af">
        <source>getBookingReferenceLatest(_operatorCode, _bookingRef :String) :CM_BookingRef;
// adm 150908 Par 17936 for prenotes when we may not have the voyage
vars
	ref,
	iterRef	: CM_BookingRef;
	iter	: Iterator;
	voyage	: CM_Voyage;
begin
	ref	:= self.allBookingRefsByOperatorRef[_operatorCode, _bookingRef, null];
	if ref &lt;&gt; null then 
		return ref;
	endif;
	iter	:= self.allBookingRefsByOperatorRef.createIterator;
	self.allBookingRefsByOperatorRef.startKeyGtr(_operatorCode, _bookingRef, null, iter);
	while iter.next(iterRef)
	and iter.getCurrentKey(1).String = _operatorCode
	and iter.getCurrentKey(2).String = _bookingRef do
		if voyage = null
		or iter.getCurrentKey(3).CM_Voyage.departedDT &gt; voyage.departedDT then
			voyage	:= iter.getCurrentKey(3).CM_Voyage;
		endif;
	endwhile;
	return self.allBookingRefsByOperatorRef[_operatorCode, _bookingRef, voyage];
epilog	
	delete iter;
end;
</source>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_bookingRef" type="String"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="getBulkReleaseActiveFromCode" id="fc212d93-02d5-4050-a324-81245de8e3a5">
        <source>getBulkReleaseActiveFromCode(_code : String; _type : Integer) : CM_BulkRelease;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Jul 2021	jlier1	Initial creation TFS 51626
28 Jul 2025 navma1  MTN-35577  MTN - Error 1081 While doing Road Receive Transaction with CM_BulkReleaseByCodeDict
*/

vars
	now 				: Date;
	tomorrow 			: TimeStamp;
	firstBulkRelease,
	bulkRelease 		: CM_BulkRelease;
	iter  				: Iterator;
begin
	
	if _code = null then					//28.07.2025 navma1 #MTN-35577
		return null;
	endif;
	
	now := app.actualTimeServer.Date;		// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	tomorrow.setDate( now + 1 ); 			// dict uses reverse date order...

	firstBulkRelease := self.allBulkReleasesByCodeDate.getAtKeyGeq( _code, tomorrow );
	
	if firstBulkRelease &lt;&gt; null and firstBulkRelease.code = _code then
		iter := self.allBulkReleasesByCodeDate.createIterator;
		iter.startAtObject( firstBulkRelease );
		while iter.next( bulkRelease ) do
			if bulkRelease.code &lt;&gt; _code then
				break;
			endif;
			if bulkRelease.status &lt;&gt; BR_ACTIVE then
				continue;
			endif;
			if bulkRelease.type &lt;&gt; _type then
				continue;
			endif;
			return bulkRelease;
		endwhile;
	endif;

	return null;
epilog
	delete iter;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="getBulkReleaseFromCode" id="44d5e557-e4f2-48a1-8e4f-f999239a6727">
        <source>getBulkReleaseFromCode(_code : String) : CM_BulkRelease;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
// 28 Jul 2025 navma1 MTN-35577  MTN - Error 1081 While doing Road Receive Transaction with CM_BulkReleaseByCodeDict
// ---------------------------------------------------------------------------

vars
	bulkRelease 			: CM_BulkRelease;
	ts						: TimeStamp;
	compareCode				: String;
begin

	if _code = null then					//28.07.2025 navma1 #MTN-35577
		return null;
	endif;
	
	compareCode := _code.toUpper();
	
	ts.setDate('12/12/9999'.Date); // This key is descending so we need to start from a date way in the future
	
	bulkRelease := self.allBulkReleasesByCodeDate.getAtKeyGeq(compareCode, ts);
	
	if bulkRelease = null then //rs aug 2005 stop puking if there are not bulk releases
		return null;
	endif;	
	
	// ### CHeck that it is teh same code
	if bulkRelease.code = compareCode then 
		return bulkRelease;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="getBulkReleaseFromCodeDate" id="9a96c389-91ab-4ea0-9fd7-3b7e4ca9ab5b">
        <source>getBulkReleaseFromCodeDate(_code : String; _ts : TimeStamp) : CM_BulkRelease;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 Jul 2016	cnwmc5	Initial creation	TFS 2148
28 Jul 2025 navma1  MTN-35577  MTN - Error 1081 While doing Road Receive Transaction with CM_BulkReleaseByCodeDict
*/
vars
	bulkRelease 			: CM_BulkRelease;
	compareCode				: String;
begin

	if _code = null then														//28.07.2025 navma1 #MTN-35577
		return null;
	endif;
	
	compareCode := _code.toUpper();

	bulkRelease := self.allBulkReleasesByCodeDate.getAtKey(compareCode, _ts);

	// ### CHeck that it is teh same code
	if bulkRelease &lt;&gt; null and  bulkRelease.code = compareCode then 
		return bulkRelease;
	endif;
	
	//epr TFS 2875 1/11/16 
	//found nothing just return the last bulk release with the code
	return self.getBulkReleaseFromCode(_code);

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="getBulkReleaseNextSeqNumber" id="a77ff011-5dce-447b-acac-a2c91fd3a203">
        <source>getBulkReleaseNextSeqNumber() : String;
//--------------------------------------------------------------
//Created: 11 June 2004 By: cnwgd1
//--------------------------------------------------------------
constants
	KeyDesc = 'Bulk Release Sequence Number';
vars
	theKeySeries 	: CM_KeySeries;
	seriesKey		: CM_SeriesKey;
	prefix,
	suffix 			: String;
	root 			: Integer;	
begin

	prefix := self.code;
	theKeySeries := self.allKeySeriesByCode[SN_BulkReleaseSeqNo];
	
	if theKeySeries = null then
		create theKeySeries persistent;
		theKeySeries.set(SN_BulkReleaseSeqNo, KeyDesc, self);
		create seriesKey persistent;
		seriesKey.set(prefix, 1);
		theKeySeries.nextKey := seriesKey;
	else
		seriesKey := theKeySeries.nextKey;
		if seriesKey.prefix &lt;&gt; prefix then
			seriesKey.set(prefix, 1);
		endif;
	endif;

	lock(theKeySeries, Reserve_Lock, Transaction_Duration, 5000);

	theKeySeries.reserve(app.computerName, process.signOnUserCode, prefix, root, suffix);
	theKeySeries.issue(app.computerName, process.signOnUserCode);

	return prefix &amp; root.String;	

epilog
	unlock(theKeySeries);		
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBulkReleasesFromCode" id="d3be860b-8f89-42fa-a4e3-dded4ed56033">
        <source>getBulkReleasesFromCode(_code : String; iter	: Iterator input;_brs : ObjectArray input);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
// 11/07/2025	naviv1	MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
// 28/07/2025 	navma1 	MTN-35577  MTN - Error 1081 While doing Road Receive Transaction with CM_BulkReleaseByCodeDict
// ---------------------------------------------------------------------------

vars
	bulkRelease 			: CM_BulkRelease;
	ts						: TimeStamp;
	theCode,
	compareCode				: String;
begin

	if _code = null then					//28.07.2025 navma1 #MTN-35577
		return;
	endif;
	compareCode := _code.toUpper();
	
	ts.setDate('12/12/9999'.Date); // This key is descending so we need to start from a date way in the future
	

	iter.reset();
	_brs.clear;
	
	self.allBulkReleasesByCodeDate.startKeyGeq(compareCode, ts, iter);
	
	while iter.next(bulkRelease) do
		iter.getCurrentKeys(theCode,ts); //MTN-35226
		if theCode = compareCode then
			_brs.add(bulkRelease);
		else
			break;
		endif;
	endwhile;

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="iter" type="Iterator" usage="input"/>
        <Parameter name="_brs" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getBusinessUnit" id="e6d6286a-66ef-4412-9847-ff5327543e72">
        <source>getBusinessUnit() : CM_Bank;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		08 July 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	co : CM_Bank;

begin
	foreach co in self.companies where co.isBusinessUnit and 
			(not co.isSuspended) do
		return co;
	endforeach;
	
	// 34318 if all companies are suspended return the configured one regardless if found otherwise the default DFBU otherwise the first one
	co := self.getConfig(DefCompany).CM_Bank;
	if co &lt;&gt; null then
		return co;
	else
		co := self.companies['DFBU'];
		if co &lt;&gt; null then
			return co;
		else
			foreach co in self.companies where co.isBusinessUnit do
				return co;
			endforeach;
		endif;
	endif;

epilog
end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getBusinessUnit4InterTerminal" id="2392547b-c579-4081-a449-f2474a4cfdbc">
        <source>getBusinessUnit4InterTerminal() : CM_Bank;
// ---------------------------------------------------------------------------
// Created:		14 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aBank : CM_Bank;
begin
	foreach aBank in self.companies discreteLock do
		if aBank.isBusinessUnit then
			return aBank;
		endif;
	endforeach;
end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
