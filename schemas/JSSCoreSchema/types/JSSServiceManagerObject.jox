//
// Parameters:	None
//
// Returns:		The transaction agent class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return null;
end;</source>
        <access>protected</access>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="initialize" id="ecb6003a-03e4-4fbf-a82f-9e0f92d592ac">
        <updating/>
        <source>initialize() updating;
// --------------------------------------------------------------------------------
// Created:		28 March 2002 by cnwdad2
//
// Purpose:		Initializes the receiver.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.loadErrorMessages(self.class().schema);
	self.loadErrorMessages(rootSchema.getSchema(JSSCoreSchema.name));


	//	put this application into the process dictionary
	self.myTA.trxSetProcessObjectForApp(self);
end;</source>
    </JadeMethod>
    <JadeMethod name="isLastServiceInterface" id="647cc9e3-1c84-4adc-a166-5148ff997e4d">
        <updating/>
        <source>isLastServiceInterface(pServiceObjectObj:JSSTransientServiceObject):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		03 April 2002 by cnwdad2
//
// Purpose:		Each time a Package Interface is deleted, it's corresponding Service
//				Object will also be deleted.  If the Service Object being deleted is
//				the last one left for the current Service Manager (there is only one
//				Service Manager object for each package), then we'll also delete
//				that Manager object.
//
// Parameters:	pTheServiceObject - The interface's Service Object being deleted.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allCurrentObjects	: JSSServiceObjectSet;
	
begin
	allCurrentObjects	:=	self.allServiceObjects;
	
	if allCurrentObjects.size() = 1 then
		if allCurrentObjects.first() = pServiceObjectObj then
			return true;
		endif;
	endif;
	
	return false;
end;</source>
        <Parameter name="pServiceObjectObj" type="JSSTransientServiceObject"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadErrorMessages" id="d5eee398-92d0-4d3b-8672-7d88930cff18">
        <updating/>
        <source>loadErrorMessages(pSchemaObj:Schema) updating, protected;
// --------------------------------------------------------------------------------
// Created:		26 March 2002 by cnwdad2
//
// Purpose:		Locates all of the peer schema's error (global) constants, and
//				creates transient error objects for use when an error occurs at
//				run-time.
//
// Parameters:	pSchemaObj - The schema in which the error codes constant category
//				is located.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allCategories	: ConstCategoryNDict;
	theCategory		: ConstantCategory;
	theConstant		: Constant;
	errorObj		: JSSErrorMessage;
	categoryName	: String;
	prefixLength	: Integer;
	
begin
	self.baseErrorNumber	:=	JSS_EX_00001;
	prefixLength			:=	JSS_EXCEPTION_NAME_PREFIX.length;
//	allCategories			:=	pTheSchema.jssGetLocalConstantCategories();
	allCategories			:=	pSchemaObj.getPropertyValue("constantCategories").ConstCategoryNDict;
	
	foreach theCategory in allCategories do
		categoryName	:=	theCategory.name;
		
		if categoryName.length &lt; prefixLength
		or categoryName[1:prefixLength] &lt;&gt; JSS_EXCEPTION_NAME_PREFIX
		then
			continue;
		else
			// Create an error object for each constant in this category.
			
			foreach theConstant in theCategory.getConstants do
				create errorObj transient;
				errorObj.initializeFromGlobalConstant(self, theConstant.GlobalConstant);
				
				if errorObj.errorCode &lt; self.baseErrorNumber then
					self.baseErrorNumber	:=	errorObj.errorCode;
				endif;
			endforeach;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pSchemaObj" type="Schema"/>
    </JadeMethod>
    <JadeMethod name="raiseException" id="e339cabd-ade4-459e-be29-3177bf7866d2">
        <updating/>
        <source>raiseException(pExceptionObj:JSSException input; pErrorCode:Integer; pErrorText:String) updating, protected;
// --------------------------------------------------------------------------------
// Created:		26 March 2002 by cnwdad2
//
// Purpose:		Raises a JSSException.
//
// Parameters:	pTheException - The exception object.
//				pErrorCode - The error code to report.
//				pErrorText - A description of the error.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.lastErrorCode	:=	pExceptionObj.errorCode;
	self.lastErrorText	:=	pExceptionObj.extendedErrorText;
	
	pExceptionObj.errorCode			:=	pErrorCode;
	pExceptionObj.errorItem			:=	"Error " &amp; pErrorCode.String;
	pExceptionObj.extendedErrorText	:=	pErrorText;
	
	raise pExceptionObj;
end;</source>
        <access>protected</access>
        <Parameter name="pExceptionObj" type="JSSException" usage="input"/>
        <Parameter name="pErrorCode" type="Integer"/>
        <Parameter name="pErrorText" type="String"/>
    </JadeMethod>
    <JadeMethod name="raiseJSSException" id="e86e7650-e912-496f-8781-b54a1fb7336d">
        <updating/>
        <source>raiseJSSException(pErrorCode:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		26 March 2002 by cnwdad2
//
// Purpose:		Raises an exception for the specified error code.
//
// Parameters:	pErrorCode
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	exceptionObj	: JSSException;
	errorText		: String;
	
begin
	create exceptionObj transient;
	
	errorText	:=	self.getErrorString(pErrorCode);
	self.raiseException(exceptionObj, pErrorCode, errorText);
end;</source>
        <Parameter name="pErrorCode" type="Integer"/>
    </JadeMethod>
