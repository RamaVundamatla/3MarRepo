    <JadeMethod name="initializeForActivityPrefix" id="1eaa0e38-030f-4349-8b2b-6fd3f59e0f74">
        <updating/>
        <source>initializeForActivityPrefix(_any: Any; _ewsOpsView: CM_EWSActivityOpsview; _prefix : String) updating;
/*
Purpose:			

Date		Who		Reason
06JAN2022	NAVAB1	TFS 51855
*/

vars
//	trainVisitDetails : CMIF_RailTrainVisitDetails;
	details : CMIF_ArgoVisitDetails;
	voyage : CM_Voyage;
	train : CM_Train;
	vvr : CM_VehicleVisitRecord;
begin
	inheritMethod(_any, _ewsOpsView, _prefix);
	
	
	self.tableName		:= self.Argo_carrier_visit;
	
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		self.gkey		:= self.generateFullGKey(_any, _prefix); // ### TFS 53936 21JUN2022 NAVAB1 added pre fix
		return;
	endif;
	
	if _any.isKindOf(CM_Voyage) then // ### TFS 53569 06MAY2022 NAVAB1
		voyage := _any.CM_Voyage; // ### TFS 53569 06MAY2022 NAVAB1
		voyage.initializeForActivity(_ewsOpsView, self); // ### TFS 53569 06MAY2022 NAVAB1
		return; // ### TFS 53569 06MAY2022 NAVAB1
	elseif _any.isKindOf(CM_Train) then // ### TFS 53569 06MAY2022 NAVAB1
		train := _any.CM_Train; // ### TFS 53569 06MAY2022 NAVAB1
		train.initializeForActivityPrefix(_ewsOpsView, self, _prefix); // ### TFS 53569 06MAY2022 NAVAB1
		return; // ### TFS 53569 06MAY2022 NAVAB1
	elseif _any.isKindOf(CM_VehicleVisitRecord) then // ### TFS 53569 06MAY2022 NAVAB1
		vvr := _any.CM_VehicleVisitRecord;
		vvr.initializeForActivity(_ewsOpsView, self);
		return;
	endif;
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_prefix" type="String"/>
    </JadeMethod>
</Class>
