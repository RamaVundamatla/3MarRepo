    <JadeMethod name="getXYsFromRectanglePolygon" id="ebd4bb4a-252c-4ae6-9de3-ac66be77aef7">
        <source>getXYsFromRectanglePolygon(_poly : PointArray; _x1,_y1,_x2,_y2 : Integer io);
// ---------------------------------------------------------------------------
// Created:		09 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpX, tmpY : Integer;
	aPoint : Point;
	
begin
	_x1 := 99999999;
	_y1 := 99999999;
	foreach aPoint in _poly do
		tmpX := aPoint.x;
		tmpY := aPoint.y;
		
		_x1 := _x1.min(tmpX);
		_y1 := _y1.min(tmpY);
		_x2 := _x2.max(tmpX);
		_y2 := _y2.max(tmpY);
		
		
	endforeach;
end;</source>
        <Parameter name="_poly" type="PointArray"/>
        <Parameter name="_x1" type="Integer" usage="io"/>
        <Parameter name="_y1" type="Integer" usage="io"/>
        <Parameter name="_x2" type="Integer" usage="io"/>
        <Parameter name="_y2" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="handleException" id="6bc09b11-2e28-47f5-97a7-dca42b16b6fc">
        <source>handleException(_exObj : Exception; divZero : Boolean io) : Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 October 2008	cnwrd1	Initial creation par#18130

*/

constants
	DivZeroError	: Integer = 4030;
	
vars

begin

	if _exObj.errorCode = DivZeroError then
		
		divZero := true;
		return Ex_Resume_Next;
	endif;

	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="divZero" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleLabelFrameMouseMove" id="1a64cfcf-2370-48a0-ba27-f6d2bbdc1991">
        <updating/>
        <source>handleLabelFrameMouseMove(frame: CMUI_ScrollableLabelsFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return; // do later
	
	
	if self.myDrawingFrame.myOverlayDrawingFrame.visible then
		if button = Window.MouseButton_Left 
		and frame.dragMode &lt;&gt; CMUI_ScrollableLabelsFrame.DragMode_Drag
		and app.dragDetected(x, y, frame.origX, frame.origY) then
			frame.dragMode := CMUI_ScrollableLabelsFrame.DragMode_Drag;
	//		frame.dragCursor := yrdForm.picCursorDrag.picture;
			app.isDragging := true;
		endif;
	endif;

end;</source>
        <Parameter name="frame" type="CMUI_ScrollableLabelsFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="notableObjectArmNotes" id="ec98ecc5-35ae-444e-8740-92e871754f5b">
        <source>notableObjectArmNotes(_obj: Object);
// ---------------------------------------------------------------------------
// Created:		09 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
aTA : CM_TerminalArea;
begin
	inheritMethod(_obj);
	if CM_TerminalArea.hasInstance(_obj) then
		aTA := _obj.CM_TerminalArea;
		self.beginNotification(aTA, self.noteTAMove, Response_Continuous, null);
		self.beginNotification(aTA, self.noteTIUpdate, Response_Continuous, null);
		self.beginNotification(aTA, self.noteTALocationUpdate, Response_Continuous, null);
		self.beginNotification(aTA, self.noteTALocationCreate, Response_Continuous, null);
		self.beginNotification(aTA, self.noteTALocationDelete, Response_Continuous, null);
/*
		self.beginNotification(aTA, self.noteTAReverseDecking, Response_Continuous, null);
*/
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
