    <PrimAttribute name="baseUnit" id="f2bb8bdc-803a-4776-8784-bcf7d4f77d36">
        <embedded/>
        <type name="Real"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="measure" id="1278d7f1-0fa4-40b8-97f9-c0e52fc838b7">
        <embedded/>
        <type name="Real"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="unit" id="2eaa74ba-85e1-41cd-b6dc-b156b72a1c92">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
    <JadeMethod name="convertBaseToTarget" id="232df5a8-85e8-4f95-8253-8a4bf472cec5">
        <source>convertBaseToTarget(pMeasure: Real; pUnitTo: Integer): Real protected, abstract, number = 1004;</source>
        <abstract/>
        <access>protected</access>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertMeasure" id="fbba5f67-48d8-454e-8296-bdb59b386c18">
        <source>convertMeasure(pUnitTo: Integer): Real;
// --------------------------------------------------------------------------------
// Created:		25 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	convertedMeasure	:=	self.convertBaseToTarget(self.baseUnit, pUnitTo);
epilog
	return convertedMeasure;
end;</source>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertToBaseUnit" id="71fe244a-7385-444c-b1de-e31089152217">
        <source>convertToBaseUnit(pUnitFrom: Integer): Real protected, abstract, number = 1003;</source>
        <abstract/>
        <access>protected</access>
        <Parameter name="pUnitFrom" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="bad3b686-44fc-4b51-964d-d4ba890422ec">
        <updating/>
        <source>updateMe(pMeasure:Real; pUnit:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		25 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isConvertToBase	: Boolean;
	
begin
	isConvertToBase	:=	false;
	
	if self.measure &lt;&gt; pMeasure then
		self.measure	:=	pMeasure;
		isConvertToBase	:=	true;
	endif;
	
	if self.unit &lt;&gt; pUnit then
		self.unit		:=	pUnit;
		isConvertToBase	:=	true;
	endif;
	
	if isConvertToBase then
		self.baseUnit	:=	self.convertToBaseUnit(pUnit);
	endif;
end;</source>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnit" type="Integer"/>
    </JadeMethod>
</Class>
