    <JadeMethod name="selectTblDataObject" id="1667cdc0-a9cf-4ad1-a21f-a5d4f4b14ea9">
        <updating/>
        <source>selectTblDataObject(_ediData : CM_EDIData) updating;
//----------------------------------------------------------------
//	Created:	01 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/****Changes

Date		Name	TFS#			Description
============================================================================
04/08/2010	cnwcs5	par 25129 		optimize default search after file load
									also used local variable for self.tblData (not part of hot fix)
17/05/2016	cnwns1	TFS 488 		Multi Timezone Support
05/10/2018	jlgrh7 TFS40344  		POL - [Fwd: ##RE-8177## : EDI Operations]
10/01/2019	jlgka1 42014			Use a reload date to set the filter date from value
									when the action is a reload otherwise use the current date.
06 Oct 2023	jlika1	TFS 60232 - EUP | FR 54871 - EDI Management for New EDI Types									
============================================================================*/
vars
	rowIdx			: Integer;
	searchTable		: CM_EntryTable;	// par 25129
	dataTable		: CM_DataTable;		// par 26129
	today			: Date;				// par 25129	
begin
	if _ediData = null then
		//cant select if null
		return;
	endif;
		
	dataTable := self.tblData;	// 04/08/2010 par 25129 cnwcs1
	
	//if self.myDataClass &lt;&gt; _ediData.class then							//-TFS40344  Always Display the content 
		//redo the filter to show the right class
	self.myDataClass := self.getClassForClass(_ediData.class);
	self.setFilterForType(_ediData.class);
	dataTable.setTblDataEntRowsFromDef(self.getTblDataDef());
	
	//epr TFS 2744 21/2/17
	self.cmbFiltEdiType.listIndex := self.cmbFiltEdiType.findItemData(_ediData.ediDataType );
	self.tblSearch.setValueByControlName(self.cmbFiltEdiType.name, self.cmbFiltEdiType.text);
	// cnwcs5 - par 25129 - redo filter to set dates to current date
	// so we don't end up returning heaps of data
	searchTable	:= self.tblSearch;
	if self.isReload and self.reloadDate &lt;&gt; null then 	// jlgka1 TFS 42014
		today := self.reloadDate; 						// jlgka1 TFS 42014
	else												// jlgka1 TFS 42014
		today		:= app.actualTimeServer.Date;		// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;												// jlgka1 TFS 42014
	
	searchTable.setValueByName(ETRow_FilterFromDate,today);
	searchTable.setValueByName(ETRow_FilterToDate, null);
	
	self.filterFromDate	:= today;
	self.filterToDate	:= null;
	
	//jlika1 TFS 60232 --&gt;
	self.setAddlFilterRows();
	//jlika1 TFS 60232 &lt;--
	
	self.zDoSearch();
	dataTable.clearAllSelected();
	//endif;
		
	if dataTable.findObjectInRow(_ediData, rowIdx) then
		dataTable.selectObject(_ediData, false);
	else
		rowIdx := dataTable.rows;
	endif;
	
	dataTable.accessRow(rowIdx).selected := true;
	self.myCurrentObject := dataTable.accessedRow.itemObject;
	
// cnwrs2/cnwdad1 28/05/2010 - PAR 24304 - New code to set to the top row so selected row is on screen.
	dataTable.clearAllSelected();
	dataTable.selectRow(rowIdx, true);
	
	self.zShowThumbnailData(self.myCurrentObject);
end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="setAddlFilterRows" id="b9e040c1-20b0-4dfd-b050-ded0e374f4d0">
        <updating/>
        <source>setAddlFilterRows() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 06 October 2023
TFS#		: 60232
Function	:

*** Changes ***
Date			Name		TFS#		Description
28/11/2023	jlika1	TFS 61135 61143 CUX | Cargo Priority - Vehicle App
****************************************************/

vars
	ediTypeIndex	: Integer;
begin
	//Hide all rows first then show them as necessary	
	self.disableFiltTransManiCallOff();
	
	ediTypeIndex := self.cmbFiltEdiType.listIndex;	
	
	if ediTypeIndex &gt; 0 and self.cmbFiltEdiType.itemData[ediTypeIndex] &lt;&gt; EDIDataType_BayPlan then  //jlika1 TFS 60232
		self.filterVoyage:=null;
		self.disableFiltVoyage();
	else
		self.enableFiltVoyage();
	endif;
	
	if ediTypeIndex &gt; 0 and self.cmbFiltEdiType.itemData[ediTypeIndex] &lt;&gt; EDIDataType_Voyage then //jlika1 TFS 60232
		self.disableFiltEmptyItem();
	else
		self.enableFiltEmptyItem();
	endif;
	
	if ediTypeIndex &gt; 0 and self.cmbFiltEdiType.itemData[ediTypeIndex] &lt;&gt; EDIDataType_TransportManifest	//jlika1 TFS 60232
		and self.cmbFiltEdiType.itemData[ediTypeIndex] &lt;&gt; EDIDataType_CallOff then
		self.disableFiltTransManiCallOff();
	else		
		self.enableFiltTransManifest();		
		self.loadFilterMessageType(self.cmbFiltMessType);
		self.loadFilterAction(self.cmbFiltAction);
		self.loadFilterTransMode(self.cmbFiltTransMode);
		
		if ediTypeIndex &lt;&gt; -1 and  self.cmbFiltEdiType.itemData[ediTypeIndex] = EDIDataType_CallOff then //jlika1 TFS 60232
			self.enableFiltVoyage();
			self.enableFiltCallOff();
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="6c4e9f30-191a-4fe9-bf9a-d193c0b39df9">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
//----------------------------------------------------------------
//	Created:	03 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpBackColor : Integer;
	tmpControlBack : Integer;
	tmpHeadingColor : Integer;
	index : Integer;
	table : CM_DataTable;
begin
	inheritMethod(_colorControl);

	tmpBackColor 	:= self.backColor;
	tmpControlBack	:= self.colorControlBack;
	tmpHeadingColor	:= self.colorHeadingColumn;
	
	self.frmFindReplace.backColor	:= tmpBackColor;
	
	self.fldDetail.backColor		:= tmpBackColor;
	self.shtEDIData.backColor		:= tmpBackColor;	
	self.shtEDIDetails.backColor	:= tmpBackColor;	
	self.shtEDIFile.backColor		:= tmpBackColor;	
	
	// do not call self.setColorsForEntryTable for tblEditX as
	// we watn to set the backColors for the value cells specifically

	self.tblEDIDetails.backColor	:= tmpControlBack;

	self.tblEDIDetails.accessColumn(1).backColor	:= tmpHeadingColor;
	self.tblEDITIError.accessRow(1).backColor 	:= tmpHeadingColor;
	self.tblFileError.accessRow(1).backColor 		:= tmpHeadingColor;
	self.tblFindReplace.accessColumn(1).backColor 	:= tmpHeadingColor;
	self.tblMultiReplace.accessRow(1).backColor 	:= tmpHeadingColor;
	index := 0;
	while true do
		table := self.tblEDITI.getControl( index );
		if table = null then
			break;
		endif;
		table.accessRow(1).backColor 		:= tmpHeadingColor;
		index := index+1;
	endwhile;

epilog

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setColoursForEDITrackedItem" id="59c63904-aee6-4425-b98d-a55839f32856">
        <source>setColoursForEDITrackedItem(_ediData :CM_EDIData; _ediTI :CM_EDITrackedItem; _localPort :String; _row :JadeTableRow input) protected;
/*
Date		Who		Reason
29 Jul 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars
	
begin
	_ediTI.getColoursForEDITrackedItem (_ediData, _localPort, _row.foreColor, _row.backColor);	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_ediTI" type="CM_EDITrackedItem"/>
        <Parameter name="_localPort" type="String"/>
        <Parameter name="_row" type="JadeTableRow" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setControls" id="345fe149-30ae-424c-a00a-24c269df86a2">
        <source>setControls();
//----------------------------------------------------------------
//	Created:	01 September 2003	by Jason Chapman  (cnwjc2)
// 07/02/2017 cnwrh7    TFS3302       EDI Operations missing feature of find/replace option
// 25/01/2022 jlika1	TFS 52472	  MSL - Best Pick field for EDI Release Request
//----------------------------------------------------------------
vars
	numCols			: Integer;
	idx				: Integer;
	tabIndex		: Integer;
	tblTI			: CM_DataTable;
	shtData			: CMUI_Sheet;
	
	etDef : EntTableDef;
	
begin
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEditTV.visible 		:= false;
		self.btnSaveBase.visible 	:= false;
		self.btnSaveVerify.visible 	:= false;
		self.btnDeleteTV.visible	:= false;	
		self.btnShowLoadFile.visible:= false;
		self.btnShowFindRepl.visible:= false;
		self.btnExtractNew.visible	:= false;
		self.btnUserTypes.visible	:= false;
		self.btnDeleteEDITi.visible	:= false;
	endif;
	
	self.btnHideWarnings.enabled		:= true;
	if self.fldDetail.topSheet &lt;&gt; self.shtEDIDetails and self.tblEDITI.columns &gt; 0 then		// 20/05/2011 cnwar2 #27461
		self.btnShowFindRepl.enabled		:= true;
		self.mnuEdiEditFindReplace.enabled	:= true;
		
		if self.tblEDITIError.visible then
			self.btnPrintTV.enabled			:= true;
		endif;	
		
		if self.tblEDITI.visible and self.tblEDITI.rows &gt; 1 then
			self.btnDeleteEDITi.enabled			:= true;
		else
			self.btnDeleteEDITi.enabled			:= false;
		endif;
	else
		self.btnShowFindRepl.enabled		:= false;
		self.mnuEdiEditFindReplace.enabled	:= false;
		self.btnPrintTV.enabled				:= false;
		self.btnDeleteEDITi.enabled			:= false;

		self.sptData.hideRightControl(true);	//par 27392 cnwrs1 14 Apr 2011
	endif;
	
	if self.mode = self.Mode_EditEDIFile then			//edi file in error
		tabIndex := 0;
		while true do
			shtData := self.shtEDIData.getControl(tabIndex);
			if shtData = null or not shtData.visible then
				break;
			endif;
			shtData.enabled := false;
			tabIndex := tabIndex+1;
		endwhile;
		self.tblData.enabled := false;
		self.shtEDIDetails.enabled := false;
		self.shtEDIFile.visible := true;
		self.fldDetail.topSheet := self.shtEDIFile;
		self.frmSearch.enabled := false;
		self.btnDeleteTV.enabled := false;	
		self.btnEditTV.enabled := false;
		self.btnLoadFile.enabled := false;
		self.btnShowLoadFile.enabled := false;
		self.btnExtractNew.enabled := false;
		self.mnuEdiEditFindReplace.enabled := true;
		self.btnFRReplace.enabled := true;
		self.btnAddReplace.enabled := true;
		
	elseif self.mode = Mode_Update then				//update edi data
		tabIndex := 0;
		while true do
			tblTI := self.tblEDITI.getControl(tabIndex);
			if tblTI = null then
				break;
			endif;
			
			//jlika1 only set it when it is not a checkbox
			numCols := tblTI.columns;
			foreach idx in 1 to numCols do
				if(tblTI.accessColumn(idx).inputType &lt;&gt; Table.InputType_CheckBox) then				
					tblTI.accessColumn(idx).inputType := Table.InputType_TextBox;	// ie 2
				endif;
			endforeach;
			
			
			// for each column that has been defined as read only
			// (ie input type of none) make sure the column is disabled.
			tblTI.disableReadOnlyColumns();		// cnwrl1 20/11/2009 PAR 21009
			
			tblTI.clearAllSelected();
			tblTI.selectionType := CM_DataTable.SelectionType_None;
	
			tblTI.userInputEnabled := true;
			tblTI.inputType := CM_BaseTable.InputType_TextBox;
			tabIndex := tabIndex+1;
		endwhile;
		self.tblEDIDetails.userInputEnabled := true;
			
		self.btnDeleteTV.enabled := false;
		self.btnEditTV.enabled := false;
		self.frmSearch.enabled := false;
		self.btnSaveBase.enabled := true;
		self.btnSaveVerify.enabled := true;
		self.btnCancelBase.enabled := true;
		self.btnDeleteEDITi.enabled := false;
		self.btnLoadFile.enabled := false;
		self.btnShowLoadFile.enabled := false;
		self.btnExtractNew.enabled := false;
		self.btnFRReplace.enabled := true;
		self.btnAddReplace.enabled := true;

	else 											//normal mode
		tabIndex := 0;
		while true do
			tblTI := self.tblEDITI.getControl(tabIndex);
			if tblTI = null then
				break;
			endif;
			tblTI.userInputEnabled := false;
			tblTI.selectionType := CM_DataTable.SelectionType_Row;
			self.shtEDIData.getControl(tabIndex).enabled := true;
			tabIndex := tabIndex+1;
		endwhile;
		self.tblData.enabled := true;
		self.tblEDIDetails.userInputEnabled := false;
		self.shtEDIDetails.enabled := true;
		self.shtEDIFile.visible := false;
		self.tblFileError.clear();
		self.tblFileLine.clear();
		self.frmSearch.enabled := true;
		self.btnDeleteTV.enabled := true;	
		self.btnEditTV.enabled := true;
		self.btnLoadFile.enabled := true;
		self.btnShowLoadFile.enabled := true;
		self.btnExtractNew.enabled := true;
		self.btnSaveBase.enabled := false;
		self.btnSaveVerify.enabled := false;
		self.btnCancelBase.enabled := false;
		if self.tblEDITI.rows &gt; 1 and self.tblEDITI.visible then
			self.btnDeleteEDITi.enabled			:= true;
		endif;	
		self.showHideFindReplace(true);
		self.btnFRReplace.enabled := false;
	endif;
	
	self.btnAddReplace.top := self.tblFindReplace.top;								//+TFS3302 to align up the table
	self.btnRemoveReplace.top := self.btnAddReplace.top +28;			//+TFS3302
	self.btnRemoveAll.top := self.btnRemoveReplace.top +28;				//+TFS3302
	
	self.doTblUnboldCells();
	
	// TFS 59811 navmd1 15/08/2023
	if self.cmbTransformAs.listCount = 0 then
		self.cmbTransformAs.addItem("");
		self.cmbTransformAs.addItem(CMIF_ApiMapper.CUSTOMER_EUP);
	endif;
epilog

end;</source>
    </JadeMethod>
