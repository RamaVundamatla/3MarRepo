    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="ba523002-6c82-4423-8607-d324a62a7007">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     24 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.txtName.readOnly	:= false;
	theForm.optAllow.enabled	:= true;
	theForm.optDisallow.enabled	:= true;
	theForm.mulSelect1.userInputEnabled := true;
	theForm.chkIncludeNotSet.visible := true;
	theForm.chkIncludeNotSet.enabled := true;

	if theForm.mode = theForm.Mode_Add then
		theForm.txtName.text := '';
		theForm.txtName.enabled	:= true;
		theForm.optAllow.value := true;
		theForm.mulSelect1.setSelected(null);
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myCurrentObject.CM_DataAccessController);
		// cannot update code

	endif;
	theForm.txtName.setFocus;
	self.enableMulSelect1Contents();

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="541835e5-566e-4041-85cb-63d8e5e34e15">
        <updating/>
        <source>setCtrlsForView() updating;
// ---------------------------------------------------------------------------
// Created:     24 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
	inheritMethod();  
	theForm := self.myForm;
	theForm.txtName.readOnly	:= true;
	theForm.optAllow.enabled	:= false;
	theForm.optDisallow.enabled	:= false;
	theForm.chkIncludeNotSet.visible := true;
	theForm.chkIncludeNotSet.enabled := false;
	theForm.txtName.enabled := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="c005d4d1-471c-4d7a-88fe-ba1cd5ffdc5e">
        <source>setupThumbnailDetails();

vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;

	// setup the controls for the thumbnail display
	
	theForm.mulSelect1.availableHeading := theForm.getDataAccessHeading() &amp; ' available';
	theForm.shtTblInput1.visible := false;
	theForm.shtMultiSelect1.visible := true;
	theForm.lblName.visible := true;
	theForm.txtName.visible := true;
	theForm.optAllow.visible := true;
	theForm.optDisallow.visible := true;
	theForm.mulSelect1.visible := true;

	theForm.mulSelect1.cnEcResizeContents();

end;</source>
    </JadeMethod>
</Class>
