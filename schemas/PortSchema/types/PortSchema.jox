    <JadeMethod name="intendedReleaseModeEnum2String" id="601e8f13-904c-4401-be5a-e7fc029a166c">
        <source>intendedReleaseModeEnum2String(_releaseMode : Integer) : String;
// ---------------------------------------------------------------------------
// Created:     June 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _releaseMode = TI_IntendedReleaseMode_RAIL then
		return app.getErrorString(TI_Intended_Rail);
	elseif _releaseMode = TI_IntendedReleaseMode_ROAD then
		return app.getErrorString(TI_Intended_Road);
	elseif _releaseMode = TI_IntendedReleaseMode_SHIP then
		return app.getErrorString(TI_Intended_Ship);
	elseif _releaseMode = TI_IntendedReleaseMode_NULL then
		return app.getErrorString(TI_Intended_Unknown);
	endif;

	return null;
end;


</source>
        <Parameter name="_releaseMode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="intendedReleaseModeString2Enum" id="01422b8c-11a9-4ae4-8eec-31c4fbfee07d">
        <source>intendedReleaseModeString2Enum(_releaseMode : String) : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	22 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
24/02/2011 	cnwmh5		# 26912 - Add toUpper to tests
*/
vars

begin
	if _releaseMode.toUpper = app.getErrorString(TI_Intended_Rail).toUpper then
		return TI_IntendedReleaseMode_RAIL;
	elseif _releaseMode.toUpper = app.getErrorString(TI_Intended_Road).toUpper then
		return TI_IntendedReleaseMode_ROAD;
	elseif _releaseMode.toUpper = app.getErrorString(TI_Intended_Ship).toUpper then
		return TI_IntendedReleaseMode_SHIP;
	elseif _releaseMode.toUpper = app.getErrorString(TI_Intended_Unknown).toUpper then
		return TI_IntendedReleaseMode_NULL;
	endif;

	return null;
end;


</source>
        <Parameter name="_releaseMode" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="intendedReleaseModeToObject" id="e33df1f1-bd6b-498e-a742-6ded0baed61c">
        <source>intendedReleaseModeToObject(_value : Integer) : CM_String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 May 2009	cnwmd1	Initial creation

*/

vars
	cmString	: CM_String;
begin
	//must be cleaned up else where - maybe use _tbl.purgeTableObjects() if going into a table
	
	create cmString transient;
	cmString.string := self.intendedReleaseModeEnum2String(_value);
	return cmString;
epilog

end;</source>
