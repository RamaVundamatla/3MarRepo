    <JadeMethod name="validate" id="8e91eddd-0f77-49e8-8740-f0ad581c3e34">
        <source>validate( _allTiIdsToCreate : StringArray input; 
			_quantity : Integer output;
			_weight : Decimal output;
			_operator : CM_Operator output ):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk
21 Dec 2015 cnwma1 PAR #37156  UE 1035 in app MobileUISchema::HandHeldApp of CIGPJMT
*/

vars

	newBaseId : String;
	suffixLength : Integer;
	firstSuffix : Integer;
	lastSuffix : Integer;
	msg : String;
	iter : Iterator;
	startObject : Object;
	existingTi : CM_TrackedItem;
	existingTiSuffixString : String;
	existingTiSuffixInteger : Integer;
	proposedId : String;
	suffixInt : Integer;
	allJobs : CM_JobSet;
	job : CM_Job;
	wle : CM_WorkListEntry;
begin

	if self.myTrackedItem.isBulkByQuantity then
		_quantity := txtQuantity.text.Integer;

		if _quantity = 0 or _quantity &gt; self.myTrackedItem.totalQuantity then
			if _quantity = 0 then
				msg := app.getErrorString1(Not_split_zero_quanti_from, self.myTrackedItem.id);
			else
				msg := app.getErrorString1(Not_decla_quant_great_than_tot, self.myTrackedItem.id &amp; " (" &amp; self.myTrackedItem.totalQuantity.String &amp; ")");
			endif;
			app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
			self.txtQuantity.setFocus();
			return false;
		endif;
		
		if _quantity = self.myTrackedItem.totalQuantity then
		create allJobs transient;
		self.myTrackedItem.getAllJobs(allJobs);
		foreach job in allJobs discreteLock do
			if not job.isJobComplete then
				msg := app.getErrorString1(Not_split_items_while_incom_jo, self.myTrackedItem.id);
				app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
				self.txtQuantity.setFocus();
				return false;
			endif;
		endforeach;
		foreach wle in self.myTrackedItem.allWorklistEntries discreteLock do
			if wle.status &lt;&gt; WLE_COMPLETED then
				msg := app.getErrorString1(Not_split_items_while_incom_wo, self.myTrackedItem.id);
				app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
				self.txtQuantity.setFocus();
				return false;
			endif;
		endforeach;
	endif;
		
		
	elseif self.myTrackedItem.isBulkByVolume or self.myTrackedItem.isBulkByWeight then	
		_weight:= self.getWeightMovedKgs;
	endif;
		
	
	
	_operator := self.cmbOperator.listObject.CM_Operator; 
	if _operator = null then
		msg := app.getErrorString(Please_select_operator);
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
		self.cmbOperator.setFocus();
		return false;
	endif;
	
	newBaseId := txtId.text.trimBlanks.toUpper;
	if newBaseId = null then
		msg := app.getErrorString(Must_enter_cargo_item_being_sp);
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
		self.txtIdSuffix.setFocus();
		return false;
	endif;
		
	firstSuffix := txtIdSuffix.text.Integer;
	lastSuffix := ((firstSuffix + _quantity) - 1);
	suffixLength := txtIdSuffix.text.trimBlanks.length;
	startObject := self.myTerminal.allOnsiteTIsByCargoTypeId.getAtKeyGeq(myTrackedItem.cargoType,newBaseId);
	
	
	
	if self.optBreakBulk.value then
		//Going to create one new cargo item with a specific ID.
		//Check they have entered an did and that it is unique in the location.
		
		//Because its break bulk that is allowed to be split or merged, we can have only one of each id per location
		//using an id that was alreday in use in the area would imply an intent to merge!!!
		if startObject &lt;&gt; null then
			iter := self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator;
			iter.startAtObject(startObject);
			while iter.next(existingTi) do
				if existingTi.cargoType &lt;&gt; myTrackedItem.cargoType then
					break;
				endif;
				if existingTi.id &lt;&gt; newBaseId then
					break;
				endif;
				if existingTi.myPrimaryActualLocation = myTrackedItem.myPrimaryActualLocation then
					msg := app.getErrorString1(Propos_alread_used_this_locati,newBaseId);
					app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
					self.txtId.setFocus();
					return false;
				endif;
			endwhile;
		endif;
		
		_allTiIdsToCreate.add( newBaseId );
		return true;
		
	elseif self.optPieceBBB.value then
		// going to create mulitple Piece Break Bulk cargo items each with a quantity of one
		// check that the concatenation of teh values is not too long
		// check that we have a valid starting id, and that each proposed id would be unique 
		
		if lastSuffix.String.length &gt; suffixLength then
			suffixLength := lastSuffix.String.length;
		endif;
		//if newBaseId.length + suffixLength &gt; 30 then			//21/12/2015 cnwma1 PAR #37156
		if newBaseId.length + suffixLength &gt; 20 then			//21/12/2015 cnwma1 PAR #37156
			msg := app.getErrorString(Propo_combi_with_suffi_resul_p);
			app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
			self.txtId.setFocus();
			return false;
		endif;
		//Because its break bulk that is allowed which is allowed to be split or merged, we can have only one of each id per location per cargo type
		//Using an id that was alreday in use in the area would imply an intent to merge!!!
		if startObject &lt;&gt; null then
			iter := self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator;
			iter.startAtObject(startObject);
			while iter.next(existingTi) do
				if existingTi.cargoType &lt;&gt; myTrackedItem.cargoType then
					//differnt cargo type. All done
					break;
				endif;
				if existingTi.id.length &lt; newBaseId.length then
					//this too short to be a match try the next one
					continue;
				endif;
				if existingTi.id = newBaseId then
					//we will be adding a suffix to newBaseId, so wont be a match, try teh next one.
					continue;
				endif;
				if not existingTi.id.startsWith(newBaseId) then
					//stopped matching at all. All done
					break;
				endif;
				if existingTi.myPrimaryActualLocation &lt;&gt; myTrackedItem.myPrimaryActualLocation then
					//not in the same location, so we don't care
					continue;
				endif;
				//Ok we have one where the first part matches, lets see if the second part of the id
				// could match with any of our proposed ids.
				
				//get the last bit of the id
				existingTiSuffixString := existingTi.id[ newBaseId.length + 1 : end];
				if not existingTiSuffixString.isInteger then
					//it contains alpha chars and ours wont.
					continue;
				endif;
				
				existingTiSuffixInteger := existingTiSuffixString.Integer;
				if existingTiSuffixInteger &lt; firstSuffix or existingTiSuffixInteger &gt; lastSuffix then
					//the Integer value is outside our proposed range
					continue;
				endif;
				//we have one in the same range, SOOOOO is it going to result in the same id?
				proposedId := newBaseId &amp; existingTiSuffixInteger.padLeadingWith('0',suffixLength);
				if existingTi.id &lt;&gt; proposedId then
					// must be a different number of leading zeros, all good
					continue;
				endif;
				
				msg := app.getErrorString1(Propos_alread_used_this_locati,proposedId);
				app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
				self.txtId.setFocus();
				return false;
				
			endwhile;
		endif;
		
		_quantity := 1;	
		foreach suffixInt in firstSuffix to lastSuffix do
			proposedId := newBaseId &amp; suffixInt.padLeadingWith('0',suffixLength);
			_allTiIdsToCreate.add( proposedId );
		endforeach;
		return true;
	
	else
		msg := app.getErrorString(Select_option);
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
		return false;
		
	endif;
	
	return false;

epilog

	delete iter;
	delete allJobs;

end;</source>
        <access>protected</access>
        <Parameter name="_allTiIdsToCreate" type="StringArray" usage="input"/>
        <Parameter name="_quantity" type="Integer" usage="output"/>
        <Parameter name="_weight" type="Decimal" usage="output"/>
        <Parameter name="_operator" type="CM_Operator" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
