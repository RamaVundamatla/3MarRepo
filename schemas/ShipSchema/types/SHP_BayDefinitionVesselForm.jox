    <JadeMethod name="bridgeAfterBayChange" id="dbbafc1c-61fb-44c9-a591-5d59e378ebcc">
        <updating/>
        <source>bridgeAfterBayChange()updating;
//--------------------------------------------------
// Created:	20 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	theBayOrder : String;
begin
		
	if self.mode = self.Mode_View then
		return;
	endif;
	
	theBayOrder := self.txtBayOrder.text;

	if self.validateTierCellLabels('Physical Bay Order', theBayOrder) then

		self.doBuildComboBayString(self.cmbBridgeAftBay, theBayOrder);
		self.doBuildProxyBayList(theBayOrder);

	endif;

end;</source>
