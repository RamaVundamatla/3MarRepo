    <JadeMethod name="completedOK" id="5826773d-cc83-4630-98f9-a5927e8ab33d">
        <source>completedOK() : Boolean;
// If the last transaction completed OK or the the user doesn't want to continue after errors then 
// return true
begin
	if app.myPassport.trxCompletedOK then
		return true;
	endif;

	if self.showErrorMessage(app.myPassport.getAllErrorsWarningsAsString(), app.myPassport.hasErrors()) then
		app.myPassport.warningsAcknowledged	:= true;
		return false;
	endif;
	
	return true;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
