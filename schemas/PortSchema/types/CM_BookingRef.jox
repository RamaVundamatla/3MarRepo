    <JadeMethod name="isMaintAllowed" id="2f5824f3-c1e2-4a74-8a02-5f2f777f1b56">
        <source>isMaintAllowed():Boolean;
// --------------------------------------------------------------------------------
// Created:		26 May 2009 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the current User is allowed
//				to maintain the receiver.
//
// Parameters:	None
//
// Returns:		True if the current User can maintain the receiver, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 27 May 2009	cnwkpd1	PAR #19785 - CCMS SFW 1079 - Booking Reference Status changes
// --------------------------------------------------------------------------------

begin
	if self.status = BOOKING_REF_PENDING then
		return true;
	else
		if app.myCurrentUserCan(self.myTerminal, PmGteBookingRefNonPendMaint) then
			return true;
		endif;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isManagedEmptyRelease" id="446e5907-2d1f-4e64-928b-8b7ca4658f20">
        <source>isManagedEmptyRelease(): Boolean;

/*

Purpose: return true or false according to if we are managing our own bulk release			

Parameters:			

Return Value:		


Date		Who		Reason
11 October 2010	cnwrd1	Initial creation

*/

vars
	br : CM_BulkRelease;
	reserve : CM_ReserveDetail;
begin

	// if we are empty we can manage our own BR
	if self.allReleaseRequests.isEmpty then
		return true;
	endif;
	
	//if we have more than 1 BR then we cant manage our own
	if self.allReleaseRequests.size &gt; 1 then
		return false;		
	endif;
	
	// we have 1 need to check it
	// if the booking ref item is linked to its reserve detail then we assume we are managing the release.
	
	br := self.allReleaseRequests.first;
	
	if br.allReserveDetails.isEmpty then
		// do what here should this happen - no
		//return 
	else
		// need to look at a reserve detail see if its linked back to the booking ref item.		
		reserve := br.allReserveDetails.first;
		
		if reserve.myBookingRefItem= null then
			return false; //we arnt managed;
		else
			return true; //we are managed
			
		endif;
	
	endif;
	
	return true;  //default to can/are managed
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
