        <source>qryVoyageSummary(_filter : CMQF_VoyageSummary input; _passport : CM_Passport) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     29 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	numSelected			: Integer;
