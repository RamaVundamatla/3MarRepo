    <JadeMethod name="getObjectEmailBody" id="25f1670c-4194-49bb-88fe-79dce87d2271">
        <source>getObjectEmailBody(_objectEmail: CM_ObjectEmail): String;
/*
Purpose:	

Date		Who		Reason
16 July 2024	navab1	CR 64617 TASK 64638
*/

vars
	bodyStr, errorStr : String;
	lclEmail : CM_EDIDefaultEmail;
begin
	bodyStr :=  inheritMethod(_objectEmail);
	
	if _objectEmail.isKindOf(CM_EDIDefaultEmail) then
		lclEmail := _objectEmail.CM_EDIDefaultEmail;
		
		if lclEmail.showFirst5Issues then
			errorStr := self.getErrorsAsString(5);
		endif;
	endif;
	
	return bodyStr &amp; CrLf &amp; errorStr;

epilog

