    <JadeMethod name="translateForm" id="e14274ac-1494-42e3-8750-36870781cc6e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 August 2024 13:35:35.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026948, locale);
	chkAllResponseCodes.translateCaption(Xlat_0026949, locale);
	chkAllStatuses.translateCaption(Xlat_0026950, locale);
	chkRegex.translateCaption(Xlat_0026951, locale);
	lblCamsProtocols.translateCaption(Xlat_0026952, locale);
	lblEndDate.translateCaption(Xlat_0026953, locale);
	lblSearchText.translateCaption(Xlat_0026954, locale);
	lblStartDate.translateCaption(Xlat_0026955, locale);
	lblStatus.translateCaption(Xlat_0026956, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateProgress" id="66c2300d-1910-475c-a6ec-8c6ff7f395c9">
        <updating/>
        <source>updateProgress(_cmifMonitor : CMIF_Monitor input) updating;
// ---------------------------------------------------------------------------
// Created:     01/08/24 Navcs2	
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.pbProgressBar.visible := true;
	self.pbProgressBar.partsInJob := _cmifMonitor.partsInJob;	
	self.pbProgressBar.partsDone := _cmifMonitor.partsDone;
	self.lblModalMessage.caption := _cmifMonitor.message;																		// TFS 63307
	self.lblModalInfo.caption := 'Found ' &amp; _cmifMonitor.partsDone.String &amp; ' of ' &amp; _cmifMonitor.partsInJob.String;

	//self.modalDialogShow(null, app.getErrorString(Cancel), null, null,
	//				_cmifMonitor.message,
	//				app.getErrorString(Searched)  &amp; ' ' &amp; _cmifMonitor.numSearched.String &amp; ' ' &amp; app.getErrorString(Found) &amp; ' ' &amp; _cmifMonitor.numFound.String);
	
	self.frmModalDialog.refreshNow();
	self.btnModalDefault.doWindowEvents(0);
	self.btnModalOpt1.doWindowEvents(0);

	if self.modalDialogReturnValue &lt;&gt; ModalDialogReturn_Null then
		_cmifMonitor.monitorReturnValue := _cmifMonitor.MonitorReturnValue_Cancel;
	endif;

end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
</GUIClass>
