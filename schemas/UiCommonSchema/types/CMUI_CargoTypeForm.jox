    <JadeMethod name="loadProductType" id="88bce196-6698-4a2e-8f69-48be342b73c4">
        <source>loadProductType();
/*

Purpose:			


Return Value:		


Date		Who		Reason
04 April 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	self.cmbProductType.clear;
	self.myAssistant.comboBoxProductType(self.cmbProductType);
	self.cmbProductType.listIndex := 1;
	
epilog

end;</source>
