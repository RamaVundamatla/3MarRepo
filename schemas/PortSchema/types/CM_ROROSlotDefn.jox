    <JadeMethod name="getAftSlotDefn" id="0771ff4e-f3e1-4aa9-80bf-9072f4f272d8">
        <source>getAftSlotDefn() : CM_ROROSlotDefn;
/*
Purpose:			
Date		Who		Reason
13 June 2011	cnwab1	Initial creation
*/

vars
	aftLocn : CM_ROROLocnDefn;
begin
	if self.myROROLocnDen = null then
		return null;
	endif;
	
	aftLocn := self.myROROLocnDen.myAdjacentSlotAft;
	if aftLocn = null then
		return null;
	endif;

	// PAR 28990 - Pt3
	if self.myROROLocnDen.isPlannedRotated &lt;&gt; aftLocn.isPlannedRotated then
		return null;
	endif;
	
	if aftLocn.allROROSlotDefnByOrdinal.size &gt;= self.ordinal then
		return aftLocn.allROROSlotDefnByOrdinal[aftLocn.ordinal, self.ordinal];
	else
		return null;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_ROROSlotDefn"/>
    </JadeMethod>
    <JadeMethod name="isRotatedLinked" id="86b1dff4-1f66-4672-8dc1-5e0b07c8a4ce">
        <source>isRotatedLinked(_forLoad : Boolean) : Boolean;
/*
Purpose:			
Date		Who		Reason
24 February 2012	cnwab1	Initial creation
*/

vars

begin
	return self.myROROLocnDen.isRotatedLinked(_forLoad);
epilog

end;</source>
        <Parameter name="_forLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
