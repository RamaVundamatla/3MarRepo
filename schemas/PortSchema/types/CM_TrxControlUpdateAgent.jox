        <updating/>
        <source>trxUpdateTIMatchAndQueueToTBA(pProxyWLE: CM_WorkListEntry io; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 04 March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
