<Class name="WS_FormPermissionResponse" id="9e26cd81-844b-4926-a87f-1882b04f9d39">
    <superclass name="WS_Response"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allFormPermissions" id="db12ef30-5c48-4ebb-9d10-f09a452b8913">
        <memberTypeInverse/>
        <type name="WS_FormPermissionArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="09cca08e-f6f5-46fb-9d0c-eb26d1a3b7ba">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2015	cnwmc5	Initial creation

*/

vars

begin
	self.allFormPermissions.purge();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doesContain" id="88e8cc22-b89e-427c-8864-62570a1fa44c">
        <source>doesContain(permissionId : Integer) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 April 2017	cnwhl1	Initial creation

*/

vars
	output : Boolean;
	permission : WS_FormPermission;
begin
	output := false;
	
	foreach permission in self.allFormPermissions do
		if permission.id = permissionId then
			output := true;
		endif;
	endforeach;
	
	return output;

end;</source>
        <Parameter name="permissionId" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
