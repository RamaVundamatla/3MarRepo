    <JadeMethod name="utlCreateBGPRequestExtWS" id="df017a1a-14d5-41eb-a0b7-b676afeb931e">
        <updating/>
        <source>utlCreateBGPRequestExtWS(_proxyBGPRequest : BGP_ExternalWSRequest input; 
					     _newBGPRequest   : BGP_ExternalWSRequest output; 
						 _passport 	      : CM_Passport input) updating;
//
// 20 Jun 2018	jlgrs1	TFS 38630 PIL1 - Perform Credit Check for Auto-Collection Customer
//	11/06/2025	navcs2	MTN-34987  MTN -  Disable SAP Integration

vars

begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	//epr TFS 43260 7/2/19
	
	/*
	No longer using SAP	11/06/2025	navcs2	MTN-34987 
	
	if _proxyBGPRequest.class = BGP_SAPWSRequest and  _proxyBGPRequest.myTerminal &lt;&gt; null then
		if not _proxyBGPRequest.myTerminal.isSapFinancialEnabled then
			return;
		endif;
	endif;
	*/
	
	create _newBGPRequest as _proxyBGPRequest.class persistent;
	
	_newBGPRequest.setForCreate(_proxyBGPRequest);
	
	if _passport.noErrors then
		_newBGPRequest.causeEvent(BGP_Object.BGP_ActionRequest, false, null);
		//self.myCreateAuditAgent.audCreateGeneric(_newBGPRequest);					//31.03.2025 navma1 #MTN-34387
	endif;		
epilog

end;</source>
        <Parameter name="_proxyBGPRequest" type="BGP_ExternalWSRequest" usage="input"/>
        <Parameter name="_newBGPRequest" type="BGP_ExternalWSRequest" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateBOL" id="492e0233-5c31-4975-8d2f-dc6a8f7b2e4d">
        <updating/>
        <source>utlCreateBOL(_proxyBOL : CM_BOL input; 
					_passport : CM_Passport input; 
					pGuiObject:Object; 
					_newBOL : CM_BOLIn output;
					_allNewBOLDtlProxies : CM_ObjectArrayActual input) updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// 19 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 3
// 07 Dec 2022  navma1  ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
vars
	tmpEvent	: Integer;
	voyage 		: CM_Voyage;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valBOL(_proxyBOL, _passport, pGuiObject);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
		
	app.setContinueCMExceptions(false);
	voyage := _proxyBOL.getMyVoyage();
	if voyage &lt;&gt; null then
		self.reserveLock(voyage);
	endif;
	create _newBOL persistent;
	
	_newBOL.setForCreate(_proxyBOL, _passport);
	
	if _passport.noErrors then
		_newBOL.setForUpdateBOLDtl(_proxyBOL, _allNewBOLDtlProxies, null);
	endif;
	
	//06 Nov 2019	NDL	TFS 47100
	if not _passport.isInEdiVerifyMode then					//07.12.2022 navma1 #52499															
		if _passport.noErrors and pGuiObject &lt;&gt; null then
			_newBOL.created( _passport );
		endif;
		
		if _passport.noErrors then
			tmpEvent := _newBOL.myTerminal.getTerminalEvent(Event_BOLAdd);
			_newBOL.causeEvent(tmpEvent, false, _newBOL);

			_newBOL.handleOpsView(BGP_OpsViewWSRequest.OPS_ACTION_CREATE); // ### TFS 53105 30MAY2022 NAVAB1
		endif;
	endif;
	
end;</source>
        <Parameter name="_proxyBOL" type="CM_BOL" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="pGuiObject" type="Object"/>
        <Parameter name="_newBOL" type="CM_BOLIn" usage="output"/>
        <Parameter name="_allNewBOLDtlProxies" type="CM_ObjectArrayActual" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateBOLInFromCMIF" id="a9e89c81-33d9-4b92-94c2-1389b3b53959">
        <source>utlCreateBOLInFromCMIF(_intFaceBOLIn : CMIF_BOLIn input; _realBOL : CM_BOLIn output; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: Sept 2009 cnwrs1
//--------------------------------------------------------------
vars
//	nullObject : CM_Object;
//	realTI : CM_TrackedItem;
//	cancelSave : Boolean;
	//persistantBOL : CM_BOLIn;
	//proxyBOLIn : CM_BOLIn;
	allNewBOLDtlProxies : CM_ObjectArrayActual;
	proxy				: CM_Object;

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	create allNewBOLDtlProxies transient;
	
	if _intFaceBOLIn.allTrackedItems.size &gt; 0 then
		// need to find out why programmed this way (ask Sarge).
		// looks like should be using a different utl
		app.raiseUnexpectedProgramError(class.name, method.name, '_intFaceBOLIn.allTrackedItems should be empty for this trx');
		return;
	endif;
	
	_intFaceBOLIn.validateForCreate(_passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	if _intFaceBOLIn.myProxyBOL = null then
		app.raiseUnexpectedProgramError(class.name, method.name, '_intFaceBOLIn.myProxyBOL = null after validation');
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	// the _intFaceBOLIn.validateForCreate creates a proxy
	//create proxyBOLIn transient;
	//proxyBOLIn.setPxyFromCMIF_BOL(_intFaceBOLIn, _passport);
	
	// already done in _intFaceBOLIn.validateForCreate above
	//create control transient;
	//proxyBOLIn.validateForCreate(control, true, _passport);
	
	//Create the persistant objects
	create _realBOL persistent;
	_realBOL.setForCreate(_intFaceBOLIn.myProxyBOL, _passport);
	
	
	if _passport.noErrors then
		_realBOL.setForUpdateBOLDtl(_intFaceBOLIn.myProxyBOL, allNewBOLDtlProxies, null);
	endif;
	if not _passport.noErrors() then
		return;
	endif;

	// Belts and Braces check
	if (not _realBOL.allTrackedItems.isEmpty) then
		app.raiseUnexpectedProgramError(class.name, method.name,
				"There are already tracked items on the new BOL In: " &amp;
				_realBOL.number);
		return;
	endif;
	
	_realBOL.myVoyage.causeEvent(_realBOL.myTerminal.getTerminalEvent(EVENT_BOLIN_CREATE), false, _realBOL);
	
	_realBOL.handleOpsView(BGP_OpsViewWSRequest.OPS_ACTION_CREATE); // ### TFS 53105 30MAY2022 NAVAB1
	
epilog
	if allNewBOLDtlProxies &lt;&gt; null then
		foreach proxy in allNewBOLDtlProxies do
			app.myProxyManager.deleteProxyLink(proxy);
		endforeach;
		
		delete allNewBOLDtlProxies;
	endif;
end;</source>
        <Parameter name="_intFaceBOLIn" type="CMIF_BOLIn" usage="input"/>
        <Parameter name="_realBOL" type="CM_BOLIn" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateBOLInGeneralCargo" id="2bd067fe-28c7-40e5-a694-9934dcebb596">
        <source>utlCreateBOLInGeneralCargo(_intFaceBOLIn : CMIF_BOLIn input;
				_passport : CM_Passport input);
//-----------------------------------------
// Created: 03 February 2006 By: cnwgd1
//-----------------------------------------
vars
	nullObject : CM_Object;
	persistantBOL : CM_BOLIn;
	ti : CM_TrackedItem;
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	
	self.raiseExceptionIfNull(_intFaceBOLIn, '_intFaceBOLIn');
	
	if _intFaceBOLIn.bolType &lt;&gt; BOLType_GeneralDocket and _intFaceBOLIn.bolType &lt;&gt; BOLType_GeneralBillOfLading then
		app.raiseCMException(ERR_INVALID_CARGOTYPE, null, null);	
	endif;

	if not _intFaceBOLIn.allTrackedItems.isEmpty then
		//  have to do this check here otherwise get not as good message later on. 
		ti := _intFaceBOLIn.allTrackedItems.first();
		if ti.myProduct = null then // product has not been set.
		//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Product), null, null);
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(Product), null, null); // cnwdb2	PAR 35364
		endif;	
		if not self.checkValidationWithPassport(_passport) then
			return;
		endif;

	endif;
	
	_intFaceBOLIn.validateForCreate(_passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	//Create the persistant objects
	_intFaceBOLIn.actionForCreate(nullObject, _passport);
	
	if _passport.hasErrors then
		return;
	endif;

	persistantBOL := _intFaceBOLIn.myPersistentBOL.CM_BOLIn;
	
	if persistantBOL.allTrackedItems.isEmpty and not _intFaceBOLIn.isEDILoad then
		app.raiseCMException1(BOLOutMissingTI, persistantBOL.number, null, null);
	else
		app.myEventManager.createSingleObjInfoNoteEvt(persistantBOL.myVoyage, VoyageBOLIn_Create_Event, persistantBOL);		
	endif;
end;</source>
        <Parameter name="_intFaceBOLIn" type="CMIF_BOLIn" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateBOLInWithTIs" id="6ebb132b-4fa1-4bbb-8255-eeb38bf09a1f">
        <source>utlCreateBOLInWithTIs(_intFaceBOLIn : CMIF_BOLIn input; _persistantBOL : CM_BOLIn output; _control : CMIF_TIUpdateController input; _passport : CM_Passport input);
//METHOD WAS NAMED: utlCreateBOLInCusCar(_intFaceBOLIn : CMIF_BOLIn input; _control : CMIF_TIUpdateController input; _passport : CM_Passport input);
//Created: Dec 2005 cnwrs1
// 10/09/2009 	cnwsh3 		CCMS SFW1044 PAR20300 - AMS changes.  Name changed as we create BOLs across the board if the
// 							terminal createBOLOnship is set.  
//							
// 11/03/2010   cnwrs2		PAR 23147 - return the persistent BOL created
//--------------------------------------------------------------
vars
	nullObject : CM_Object;
	ti : CM_TrackedItem;
	cancelSave : Boolean;
	proxyBOLIn : CM_BOLIn;
	tiSet : CM_TISet;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	create tiSet transient;
	foreach ti in _intFaceBOLIn.allTrackedItems do
		tiSet.add(ti);
	endforeach;
//	tiSet.copy(_intFaceBOLIn.allTrackedItems);
	_intFaceBOLIn.allTrackedItems.clear();
	create proxyBOLIn transient;
	proxyBOLIn.setPxyFromCMIF_BOL(_intFaceBOLIn, _passport);	
	proxyBOLIn.validateForCreate(_control, true, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	//Create the persistant objects
	create _persistantBOL persistent;
	_persistantBOL.setForCreate(proxyBOLIn, app.myPassport);
	foreach ti in tiSet do
		ti.attachToBOL(_persistantBOL);
	endforeach;	
	if not _passport.noErrors() then
		return;
	endif;
	self.myCreateAuditAgent.audCreateGeneric(_persistantBOL);
	
	_persistantBOL.handleOpsView(BGP_OpsViewWSRequest.OPS_ACTION_CREATE); // ### TFS 53105 30MAY2022 NAVAB1
	
epilog
	delete proxyBOLIn;
	delete tiSet;	
end;</source>
        <Parameter name="_intFaceBOLIn" type="CMIF_BOLIn" usage="input"/>
        <Parameter name="_persistantBOL" type="CM_BOLIn" usage="output"/>
        <Parameter name="_control" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateBOLOut" id="e4d80f54-14a6-462a-8eda-903944d7e8de">
        <source>utlCreateBOLOut(_intFaceBOLOut : CMIF_BOLOut input;
				_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 08 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	nullObject 		: CM_Object;
	realTI			: CM_TrackedItem;
	cancelSave 		: Boolean;
	persistantBOL 	: CM_BOLOut;
	
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	
	_intFaceBOLOut.validateForCreate(_passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	//Create the persistant objects
	_intFaceBOLOut.actionForCreate(nullObject, _passport);
	
	if not _passport.noErrors() then
		return;
	endif;

	persistantBOL := _intFaceBOLOut.myPersistentBOL.CM_BOLOut;
	
	// Belts and Braces check
	if not persistantBOL.allTrackedItems.isEmpty then
		app.raiseUnexpectedProgramError(class.name, method.name,
				"There are already tracked items on the new BOL Out: " &amp;
				persistantBOL.number);
		return;
	endif;
	
	// Now add the TIs to the BOL Out.  First check that they are persistant.
	foreach realTI in _intFaceBOLOut.allTrackedItems do
		realTI.raiseExceptionIfTransient(method);
	endforeach;

	persistantBOL.setTIsForCreate(_intFaceBOLOut.allTrackedItems, _passport);
	if persistantBOL.bolType = BOLType_Log then
		persistantBOL.myExtension.setTIsFromCMIF_BOL(_intFaceBOLOut, _passport);
	endif;

	if not _passport.noErrors() then
		return;
	endif;	
	// Validate that the correct number of TIs is now on the BOL
	if persistantBOL.bolType &lt;&gt; BOLType_Log then	//could be empty for logs if id's not found
		if persistantBOL.allTrackedItems.isEmpty then
			app.raiseCMException1(BOLOutMissingTI, persistantBOL.number, null, null);
			return;
		else
			persistantBOL.validateNumTIs(false);
		endif;
	else
		persistantBOL.myExtension.validateNumTIs();		
	endif;
	
	if not _passport.noErrors() then
		return;
	endif;	
	
	if (not _intFaceBOLOut.doNotMoveAsPartOfCreate) then
		if persistantBOL.bolType = BOLType_Log then
			//Instant Mode them to the voyage		
			persistantBOL.executeMoveForMode(REAL_MODE, _passport);

		elseif persistantBOL.bolType = BOLType_GeneralDocket or persistantBOL.bolType = BOLType_GeneralBillOfLading then
			persistantBOL.doUpdateLocation(REAL_MODE, persistantBOL.myPlannedLocation, _passport);
			
		else
			//Set planned location
			persistantBOL.doUpdateLocation(PLANNING_MODE, persistantBOL.myPlannedLocation, _passport);	
		endif;
	endif;

	if persistantBOL.bolType = BOLType_GeneralDocket and
	   _intFaceBOLOut.myStockOrder &lt;&gt; null then
		_intFaceBOLOut.myStockOrder.doMatch(_intFaceBOLOut.myPersistentBOL.CM_BOLOut, _passport);
	endif;
	
end;</source>
        <Parameter name="_intFaceBOLOut" type="CMIF_BOLOut" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateBOLOutHeader" id="88bd1326-8b93-4293-bb7b-da9e5758dc84">
        <source>utlCreateBOLOutHeader(pProxyHdr:CM_BOLOutHeader; pNewHdr : CM_BOLOutHeader output;
					_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 08 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars

	terminal : CM_Terminal;
	
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valBOLOutHeader(pProxyHdr);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	if (not pProxyHdr.attemptMatch(_passport)) then
		// No matching BOLOutHeader was found so store the unmatched data
		create pNewHdr persistent;
		pNewHdr.setForCreate(pProxyHdr);
		if _passport.noErrors then
			terminal := app.getMyTerminalDO_NOT_USE();
			if terminal &lt;&gt; null then
				//terminal.causeEvent(terminal.getTerminalEvent(BOLRecon_Create_Event), false, pNewHdr); //- cnwmd1, Par 25446
				terminal.causeEvent(terminal.getTerminalEvent(BOLRecon_Update_Event), false, pNewHdr); //+ cnwmd1, Par 25446
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="pProxyHdr" type="CM_BOLOutHeader"/>
        <Parameter name="pNewHdr" type="CM_BOLOutHeader" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateBOLOutLog" id="f0a50fe0-eb2d-4e97-936f-3b8f669a1b59">
        <source>utlCreateBOLOutLog(_intFaceBOLOut : CMIF_BOLOut input;
				_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 10 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	nullObject 		: CM_Object;
	realTI			: CM_TrackedItem;
	cancelSave 		: Boolean;
	persistantBOL 	: CM_BOLOut;
	
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	
	_intFaceBOLOut.validateForCreate(_passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	//Create the persistant objects
	_intFaceBOLOut.actionForCreate(nullObject, _passport);
	
	if (not _passport.noErrors) then
		return;
	endif;

	persistantBOL := _intFaceBOLOut.myPersistentBOL.CM_BOLOut;
	if persistantBOL.bolType &lt;&gt; BOLType_Log then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid BOLType (' &amp;	persistantBOL.bolType.String &amp; ')');
		return;
	endif;	
	
	// Belts and Braces check
	if (not persistantBOL.allTrackedItems.isEmpty) then
		app.raiseUnexpectedProgramError(class.name, method.name,
				"There are already tracked items on the new BOL Out: " &amp;
				persistantBOL.number);
		return;
	endif;
	
	// Now add the TIs to the BOL Out.  First check that they are persistant.
	foreach realTI in _intFaceBOLOut.allTrackedItems do
		realTI.raiseExceptionIfTransient(method);
	endforeach;

	persistantBOL.myExtension.setTIsFromCMIF_BOL(_intFaceBOLOut, _passport);

	if (not _passport.noErrors) then
		return;
	endif;
		
	persistantBOL.myExtension.validateNumTIs();
			
end;</source>
        <Parameter name="_intFaceBOLOut" type="CMIF_BOLOut" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateBOLOutLogFromEDIData" id="012a66cf-259b-4051-9e0c-b406ffc1d119">
        <source>utlCreateBOLOutLogFromEDIData(_ediDataBOLOutLog : CM_EDIDataBOLOutLog input;
							_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	cancelSave : Boolean;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	self.raiseExceptionIfNull(_ediDataBOLOutLog, 'EDIDataBOLOutLog');

	if (not _passport.noErrors) then 
		app.writeLog("Shipside Scanning Import File Error :: 1 (Null EDIDataBOLOutLog)", LogINFO);	
		app.convertErrorsWarningsToAlert("Shipside Scanning Import File Error", _passport.allErrorWarnings);
		return;
	endif;	

	app.setContinueCMExceptions(false);

	app.writeLog("Shipside Scanning Import File :: createBOLs (" &amp; _ediDataBOLOutLog.logOutFileName &amp; ')', LogINFO);
	_ediDataBOLOutLog.createBOLs(_passport);

	if (not _passport.noErrors) then 
		app.writeLog("Shipside Scanning Import File Error :: 2 (" &amp; _ediDataBOLOutLog.logOutFileName &amp; ')', LogINFO);
		app.convertErrorsWarningsToAlert("Shipside Scanning Import Error", _passport.allErrorWarnings);
		return;
	endif;	

	app.writeLog("Shipside Scanning Import File :: createBOLs complete (" &amp; _ediDataBOLOutLog.logOutFileName &amp; ')', LogINFO);
		
end;</source>
        <Parameter name="_ediDataBOLOutLog" type="CM_EDIDataBOLOutLog" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateBOLStop" id="39ee9634-d239-4784-aba7-0e7fb33e94ef">
