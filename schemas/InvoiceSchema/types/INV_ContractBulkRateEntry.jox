    <JadeMethod name="setTheCaption" id="523c5971-845d-41f3-8d9c-8d82c1695d99">
        <source>setTheCaption();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2023  navmv20 TFS 55651 Task 57072: UI - Contract Bulk Edit UI

*/

vars
	caption	   : String;
 	contract   : CM_InvoiceContract;
begin
	
	foreach contract in self.allInvoiceContracts do
		if caption &lt;&gt; null then
			caption := caption &amp; ", ";
		else
			caption := "Selected contracts - ";
		endif;
		caption := caption &amp; contract.contractId;
	endforeach;

	self.lblSelectedContracts.caption := caption;

end;</source>
