    <JadeMethod name="clearFilters" id="af71a1f2-15fa-45f9-852a-5fdbaff7e9d0">
        <updating/>
        <source>clearFilters(_clearFilter : Boolean) updating;
/*
Purpose:			

Date		Who		Reason
01 Mar 2023	navab1	TFS CR 56806 TASK 56807
01 Dec 2023	jlika1	TFS 61592 CUX | FLP Priority Quick Filters
12 Dec 2023	jlika1	TFS 61739 CUX | Import &amp; Export Quick Filter Issue
08 Feb 2024 jlier1 TFS 62363
*/

vars

begin
	self.tblAllCargoBottom.deselectAll();
	self.tblAllCargoTop.deselectAll();
	self.tblHazardousBottom.deselectAll();
	self.tblHazardousTop.deselectAll();
	self.tblMAFIBottom.deselectAll();
	self.tblMAFITop.deselectAll();
	self.tblBookingBottom.deselectAll();
	self.tblBookingTop.deselectAll();
	self.tblReefersBottom.deselectAll();
	self.tblReefersTop.deselectAll();
	self.tblTrailersBottom.deselectAll();
	self.tblTrailersTop.deselectAll();
	
	self.doSheetCaptions();

	self.allCargoBooked.clear();
	self.allHazardous.clear();
	self.allMAFI.clear();
	self.allCargoToBeWorked.clear();
	self.allReefers.clear();
	self.allTrailer.clear();
		
	
	if _clearFilter then
		self.txtCargoId.text := "";
		self.cmbCargoType.listIndex := -1;
		self.cmbIMEX.listIndex := -1;
		self.cmbSite.listIndex := -1;
		self.cmbCargoTypeOnBoard.listIndex := -1;
		self.buildComboSubType(null, self.cmbCargoSubType);
		self.buildComboSubType(null, self.cmbCargoSubTypeOnBoard);
		
		self.chkConfirmed.value := false;
		self.chkHasStops.value := false;
		self.chkOnboardCargo.value := false;
		self.chkChecked.value := false;
		
		self.picFiltered.visible := self.hasFilters();
		
	endif;
epilog

end;</source>
        <Parameter name="_clearFilter" type="Boolean"/>
    </JadeMethod>
