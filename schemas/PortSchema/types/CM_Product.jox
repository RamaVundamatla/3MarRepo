/* ---------------------------------------------------------------------------
Created:	25 May 2009	by cnwvu1

Purpose:	CCMS 1080 (Par17904). Creating system dummyn product type unvisible
			for users for cargo types with no subcargo types.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.code		:= SystemProductCode;
	self.description:= SystemProductCode;

end;</source>
    </JadeMethod>
    <JadeMethod name="setAttributesForUpdate" id="194fa564-1ecd-4513-b2d0-8c3a32262fa9">
