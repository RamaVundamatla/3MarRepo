    <JadeMethod name="cnwdad1_Extract_Reports" id="719d8ae5-dd1e-4c20-994f-46ea2dea78f2">
        <source>cnwdad1_Extract_Reports();
// --------------------------------------------------------------------------------
// Created:		10 October 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// --------------------------------------------------------------------------------
constants
	REPORTS_EXTRACT_FORMAT	: String = "Report Definition Extract";
	
vars
	inputFile			: String;
	noidFile			: String;
	errorFile			: String;
	logFile				: String;
	outputFile			: String;
	oidTableObj			: CnEcOidTable;
	objectArray			: ObjectArray;
	hubbleObj 			: CnEcHubble;
	classType			: String;
	object				: Object;
	maxIterations		: Integer;
	startTime			: Integer;
	
begin
	startTime	:=	app.clock();
	app.cnEcSetBaseRoot(true);		// This will create one if it doesn't exist.

	inputFile 	:= "";
	errorFile 	:= "";
	logFile 	:= "";
	noidFile	:= "c:\temp\ReportExportNoid.txt";
	outputFile 	:= "c:\temp\ReportExport.txt"; 

	//******************  Export *******************
	create objectArray transient;

	// Get all of the objects that we want to extract.
	CnEcReportEntity.allInstances(objectArray, 0, true);
	
	write objectArray.size().String &amp; " objects being extracted.";
	
	create oidTableObj transient;
	create hubbleObj transient;
	
	hubbleObj.initializeMe(errorFile, inputFile, noidFile, logFile, outputFile, REPORTS_EXTRACT_FORMAT, oidTableObj, objectArray);
	write "Hubble initialised....";
	write app.actualTimeServer();// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	write "Hubble exporting....";
    hubbleObj.export(0, false);    
	write "Hubble Complete.";
	write app.actualTimeServer();// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

	//******************  End of Export *******************	
epilog
	delete objectArray;
	delete oidTableObj;
	delete hubbleObj;
	
	write "Report Extract completed in " &amp; startTime.cnEcClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Fetch_Http_File" id="02144af7-af80-470b-9089-11990f85354a">
        <source>cnwdad1_Fetch_Http_File();
// --------------------------------------------------------------------------------
// Created:		02 August 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tcpConnect	: CnEcTcpConnection;
	response	: String;
	fileData	: Binary;
	theFile		: File;
	startTime	: Integer;

begin
	startTime	:=	app.clock();
	create tcpConnect transient;

	if tcpConnect.cnEcDoWebGetRequest("cnwdad1a", "/TestImages/bigmark.jpg", null, 2, response) then
		fileData	:=	tcpConnect.cnEcReceiveBuffer;
		write "Got " &amp; fileData.length.String &amp; " bytes of file data (PictureType=" &amp; fileData.pictureType.String &amp; ").  Writing to disk...";

		create theFile;
		theFile.fileName	:=	"c:\temp\__picture.jpg";
		theFile.kind		:=	File.Kind_Binary;
		theFile.writeBinary(fileData);
	else
		write tcpConnect.cnEcErrorMessage;
	endif;
epilog
	delete theFile;
	delete tcpConnect;

	write CrLf &amp; "Done in " &amp; startTime.cnEcClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_FindAcceleratorKey" id="596db158-9883-461f-aa5d-884acb0cd177">
        <source>cnwdad1_FindAcceleratorKey() protected;
// --------------------------------------------------------------------------------
// Created:		02 October 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	alphabet		: CharacterArray;
	allUsed			: CharacterArray;
	caption			: CharacterArray;
	character		: Character;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	create alphabet transient;
	create allUsed transient;
	create caption transient;
	
	alphabet.cnEcLoadFromString("abcdefghijklmnopqrstuvwxyz".toUpper());
	allUsed.cnEcLoadFromString("swbvlmtidearoc".toUpper());
	caption.cnEcLoadFromString("Select Wharves".toUpper().cnEcRemoveSubstring(" "));
	
	foreach character in allUsed do
		if alphabet.includes(character) then
			alphabet.remove(character);
		else
			write "'" &amp; character.String &amp; "' is duplicated in the used characters!";
		endif;
	endforeach;
	
	write "The following letters can be used for an accelerator key:";
	
	foreach character in caption do
		if alphabet.includes(character) then
			write Tab &amp; character;
		endif;
	endforeach;
epilog
	delete alphabet;
	delete allUsed;
	delete caption;
	
	write "Checked accelerator keys in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cnwdad1_FindReturnCollMethods" id="74950066-8816-4cf3-b7d0-ce3cfcc05d8d">
        <source>cnwdad1_FindReturnCollMethods();
// --------------------------------------------------------------------------------
// Created:		28 November 2002 by cnwdad1
//
// Purpose:		It has become known that most of the RootSchema methods which return
//				a collection do not return a reference to an existing object, but
//				rather they return newly instantiated objects which should be deleted
//				by developers.  This script will search for all uses of such methods
//				and report where they're called from.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	schemaObj	: Schema;
	classObj	: Class;
	
begin
//	schemaObj	:=	rootSchema.getSchema("BaseSchema");
	schemaObj	:=	rootSchema.getSchema("JSSCoreSchema");
//	schemaObj	:=	rootSchema.getSchema("JSSExtensionSchema");
//	schemaObj	:=	rootSchema.getSchema("JSSFileManagerSchema");
//	schemaObj	:=	rootSchema.getSchema("JSSLogSchemaSchema");
//	schemaObj	:=	rootSchema.getSchema("JSSSecurityRegistrySchema");
	write "Checking collection methods in " &amp; schemaObj.name &amp; CrLf;
	
	// Application class.
	
	classObj	:=	Application;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "_getHTMLDocumentDict");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getEntitiesForPatchNumber");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getOpenPatchNumbers");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getSkinCollection");
	
	// Class class.
	
	classObj	:=	Class;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "_allPotentialKeys");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "_rwGetDirectSubclasses");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "_withAllSubclassMethods");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "_withAllSubclassProperties");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "allProperties");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "allPropertiesUpTo");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getAllProperties");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getProperties");
	
	// CollClass class.
	
	classObj	:=	CollClass;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getKeys");
	
	// ConstantCategory class.
	
	classObj	:=	ConstantCategory;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getConstants");
	
	// Control class.
	
	classObj	:=	Control;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "_getEvents");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "_getEventsForSchema");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getChildren");
	
	// ExplicitInverseRef class.
	
	classObj	:=	ExplicitInverseRef;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "_rwGetInverses");
	
	// ExternalIterator class.
	
	classObj	:=	ExternalIterator;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getCollection");
	
	// FileFolder class.
	
	classObj	:=	FileFolder;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "files");
	
	// Folder class.
	
	classObj	:=	Folder;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getChildren");
	
	// HugeStringArray class.
	
	classObj	:=	HugeStringArray;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "_findPartialString");
	
	// Iterator class.
	
	classObj	:=	Iterator;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getCollection");
	
	// JadeMethod class.
	
	classObj	:=	JadeMethod;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "_getLocalVars");
	
	// JadePatchControlInterface class.
	
	classObj	:=	JadePatchControlInterface;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getDeletedEntitiesForPatchNo");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getEntitiesForPatchNumber");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getOpenPatchNumbers");
	
	// JadeReportWriterReport class.
	
	classObj	:=	JadeReportWriterReport;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getProfiles");
	
	// Locale class.
	
	classObj	:=	Locale;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getAllTranslatableStrings");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getForms");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getTranslatableStrings");
	
	// MenuItem class.
	
	classObj	:=	MenuItem;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "_getEvents");
	
	// Method class.
	
	classObj	:=	Method;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "_getParameters");
	
	// Picture class.
	
	classObj	:=	Picture;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "_getHotSpots");
	
	// Property class.
	
	classObj	:=	Property;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "usedAsKeyInClasses");
	
	// Schema class.
	
	classObj	:=	Schema;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "__allForms");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "_checkKeyPaths");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "allClasses");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "allDatabases");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "allFormsForNamedLocale");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "allForms_RootSchema");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "allPrimitives");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getAllClasses");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getControlClasses");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "withAllSuperschemas");
	
	// StringArray class.
	
	classObj	:=	StringArray;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "_findPartialString");
	
	// System class.
	
	classObj	:=	System;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getAllUsers");
	
	// Type class.
	
	classObj	:=	Type;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getAccessRefs");
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getAccessTypes");
	
	// WebSessionManager class.
	
	classObj	:=	WebSessionManager;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getSessionsDict");
	
	// Window class.
	
	classObj	:=	Window;
	self.cnwdad1_ReportMethodReferences(schemaObj, classObj, "getWebEventMappings");
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_GetBaseSchemaClasses" id="30a41d50-bc39-407e-80a0-8cabaec9615c">
        <source>cnwdad1_GetBaseSchemaClasses(pAllClassesObj:ClassColl input) protected;
// --------------------------------------------------------------------------------
// Created:		08 May 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	schemaObj		: Schema;
	classObj		: Class;

begin
	write "Fetching BaseSchema classes...";

	schemaObj	:=	rootSchema.getSchema(BaseSchema.name);

	if schemaObj = null then
		write "Schema not found.";
		return;
	endif;
	
	foreach classObj in schemaObj.allClasses() do
		if not classObj.isSystemObject()
		and classObj.rootType().schema = schemaObj
		then
			pAllClassesObj.add(classObj);
		endif;
	endforeach;
	
//	pAllClassesObj.inspectModal();
end;</source>
        <access>protected</access>
        <Parameter name="pAllClassesObj" type="ClassColl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cnwdad1_GetFile" id="7931028c-cc7f-4732-8d3a-61b276839d59">
        <source>cnwdad1_GetFile(pFileName:String output; pMustExist:Boolean):Boolean;
// --------------------------------------------------------------------------------
// Created:		12 May 1999 - getFile
// By:			cnwdad1
//
// Purpose:		
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cmdFile		: CMDFileOpen;

begin
	create cmdFile;

	cmdFile.allowMultiSelect	:=	false;
	cmdFile.createPrompt		:=	false;
	cmdFile.defaultExt			:=	".*";
	cmdFile.fileMustExist		:=	pMustExist;
//	cmdFile.filter				:=	'All Files|*.*';
//	cmdFile.filterIndex			:=	1;
	cmdFile.cnEcSetFilters(true, 1, null);
	cmdFile.hideReadOnly		:=	false;
//	cmdFile.initDir				:=
	cmdFile.noReadOnlyReturn	:=	true;
	cmdFile.pathMustExist		:=	true;
	cmdFile.readOnly			:=	false;
	cmdFile.resetCurrentPath	:=	true;
	cmdFile.shareAware			:=	true;
	cmdFile.validate			:=	true;

	if (cmdFile.open = 0) then
		pFileName	:=	cmdFile.fileName;
		return true;
	else
		return false;
	endif;
epilog
	delete cmdFile;
end;</source>
        <Parameter name="pFileName" type="String" usage="output"/>
        <Parameter name="pMustExist" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnwdad1_JadeSkins_Initialize" id="b9c6ec2c-74c1-4476-9203-8b8e66bc5ed8">
        <source>cnwdad1_JadeSkins_Initialize();
// --------------------------------------------------------------------------------
// Created:		03 March 2001 by cnwdad1
//
// Purpose:		Add this code to your application's initialization method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	skinSetNumber	: Integer;
	startTime		: Integer;
	
begin
	startTime		:=	app.clock();
	skinSetNumber	:=	1;		// Get the first set of skins.
	
	if app.getSkinCollection() &lt;&gt; null and app.getSkinCollection().cnEcIsNotEmpty() then
		app.setSkin(app.getSkinCollection()[skinSetNumber]);
	endif;
epilog
	write "Skins initialization completed in " &amp; startTime.cnEcClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_JadeSkins_Load" id="74505069-4f1c-48ba-ac54-6f4822fd54c0">
        <source>cnwdad1_JadeSkins_Load();
// ---------------------------------------------------------------------------
// Created:     08 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	jadeSkinObj		: JadeSkin;
	theFile			: File;
	propertyFile	: File;
	fileDirectory	: String;
	thePropertyColl	: PropertyColl;
	theProperty		: Property;
	fileRecord		: String;
	tabPosition		: Integer;
	propertyName	: String;
	propertyValue	: String;
	startTime		: Integer;

begin
	startTime		:=	app.clock();
	fileDirectory	:=	"c:\Temp\TpSkins";
	jadeSkinObj		:=	JadeSkin.lastInstance;
	
	if jadeSkinObj = null then
		write "JadeSkin is null.";
		return;
	endif;
	
	create theFile transient;
	create propertyFile transient;
	
	theFile.mode			:=	File.Mode_Input;
	theFile.kind			:=	File.Kind_Binary;
	thePropertyColl			:=	JadeSkin.allProperties;
	
	propertyFile.mode		:=	File.Mode_Input;
	propertyFile.kind		:=	File.Kind_Unknown_Text;	// 3/3/16 cnwmp6 PAR 36286 unicode version
	propertyFile.fileName	:=	fileDirectory &amp; "\JadeSkin.dat";
	propertyFile.open;
	
	beginTransaction;
	
	foreach theProperty in thePropertyColl do
		if theProperty.name[1:3] = "img" then
			theFile.fileName	:=	fileDirectory &amp; "\" &amp; theProperty.name &amp; ".png";
		
			if theFile.isAvailable() then
				theFile.open();
				jadeSkinObj.setPropertyValue(theProperty.name,
				theFile.readBinary(theFile.fileLength() ));
				theFile.close();
			else
				write "No file for: " &amp; theProperty.name;
			endif;
		endif;
	endforeach;
	
	// Now set the properties.
	
	while propertyFile.cnEcIsNotEndOfFile() do
		fileRecord		:=	propertyFile.readLine;
		tabPosition		:=	fileRecord.pos(Tab, 1);
		propertyName	:=	fileRecord[1:(tabPosition - 1)];
		propertyValue	:=	fileRecord[(tabPosition + 1):end];
		theProperty		:=	jadeSkinObj.class().getProperty(propertyName);

		if theProperty.type = String then
			jadeSkinObj.setPropertyValue(propertyName, propertyValue);
		elseif theProperty.type = Real then
			jadeSkinObj.setPropertyValue(propertyName, propertyValue.Real);
		elseif theProperty.type = Integer then
			jadeSkinObj.setPropertyValue(propertyName, propertyValue.Integer);
		elseif theProperty.type = Boolean then
			jadeSkinObj.setPropertyValue(propertyName, propertyValue.Boolean);
		else
			write theProperty.type.name;
		endif;
	endwhile;
	
	commitTransaction;
	
	propertyFile.close;
epilog
	delete theFile;
	delete propertyFile;
	delete thePropertyColl;
	
	write "Skins Load completed in " &amp; startTime.cnEcClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_JadeSkins_Maint" id="9884d012-21c8-4858-b48f-09aee406c24c">
