    <JadeMethod name="loadDataToTable" id="3f9bae8d-6047-4bf8-8f3e-d428917ae00b">
        <updating/>
        <source>loadDataToTable() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2010	#cnwdz2	 

*/

vars
	str : String;
	index : Integer;
	usage : CM_ResourceTypeUsage;
	entTableDef		: EntTableDef;
begin
	self.tblResources.rows := self.tblResources.fixedRows;
	
	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_ToDoUsage];
	foreach usage in self.allNewProxyResourceTypeUsages do
		str := usage.getAttributeStringForDefArray(entTableDef.allEntTableRows);
		index := self.tblResources.addItem(str);
		self.tblResources.accessRow(index).itemObject := usage;
	endforeach;
	
	self.tblResources.row := self.tblResources.fixedRows;
	
	self.tblResources.cnAdjustColumnWidths;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadResourceTypeEditForm" id="e80c5214-413c-4189-89c6-e80ed66fcac8">
        <updating/>
        <source>loadResourceTypeEditForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2010	#cnwdz2	 

*/

vars
	resourceTypeEditForm : MOB_ResourceTypeEditForm;
	type : CM_ResourceType;
	cmObj : CM_Object;
begin
	create resourceTypeEditForm transient;
	resourceTypeEditForm.myMasterForm := self;
	resourceTypeEditForm.myHandlingType := self.myHandlingType;	//18 Apr 2017	NDL	TFS 3141
	
	if self.myToDoTask &lt;&gt; null then
		foreach cmObj in self.myToDoTask.allResourceTypes do
			if cmObj.isKindOf(CM_ResourceType) then
				type := cmObj.CM_ResourceType;
				if not type.isAvailable then //31/03/2010 cnwdz2 par 22410
					continue;
				endif;
				resourceTypeEditForm.addResourceType(type);
			endif;
		endforeach;
	else
		foreach type in app.myRoot.allTaskResourceTypes
			where type.type = TODO_TYPE_GROUP_TI or type.type = TODO_TYPE_GROUP_ALL do // ### TFS #56635[54261] 22NOV2022 NAVAB1

			if not type.isAvailable then //31/03/2010 cnwdz2 par 22410
				continue;
			endif;
			resourceTypeEditForm.addResourceType(type);
		endforeach;
	endif;
	
	if self.myCurrentProxyUsage &lt;&gt; null then
		resourceTypeEditForm.initFieldsForResourceType(self.myCurrentProxyUsage);
	endif;
	
	resourceTypeEditForm.doNotCentreWindow := true; //12 Mar 2015	NDL	Par 35828
	resourceTypeEditForm.move(self.left, self.top, self.width, self.height );	//12 Mar 2015	NDL	Par 35828
	
	resourceTypeEditForm.showModal();
	
	self.doResizeControls(false);
	
epilog
	delete resourceTypeEditForm;
end;</source>
    </JadeMethod>
    <JadeMethod name="setTemplateOnly" id="2438abc0-51f7-4577-a05a-e45d2daec0ea">
        <updating/>
        <source>setTemplateOnly( _templateOnly : Boolean; _callingForm : MOB_HandHeldForm ) updating;
