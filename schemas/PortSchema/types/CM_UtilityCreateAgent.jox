    <JadeMethod name="utlCreateVehicleType" id="fbd45ebc-a47a-44e4-9744-263cc4574abb">
        <source>utlCreateVehicleType(_proxyVehicleType : CM_VehicleType; _newVehicleType : CM_VehicleType output; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valVehicleType(_proxyVehicleType);

