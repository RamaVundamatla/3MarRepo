    <JadeMethod name="setMyCurrentTerminal" id="3f3ef820-0d9a-44f3-bf86-d400677e2afe">
        <updating/>
        <source>setMyCurrentTerminal(_terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     27 January 2003		cnwth2	
//
// Purpose:     This method is called from the app.setMyTerminal. The reason we use
//				self.myCurrentTerminal and not app.getMyTerminal is that the latter
//				returns null if no child windows are open in the main MDI frame 
//				(app.myPassport.myTerminal).
//			 
// ----------   ----------  --------------------------------------------------
vars
	terminalHasChanged	: Boolean;
begin
	if _terminal &lt;&gt; null then
		terminalHasChanged := (self.myCurrentTerminal &lt;&gt; _terminal);
		self.myCurrentTerminal := _terminal;
		if terminalHasChanged and self.frmToolbar.visible then
//		should this not check each time, just in case permissions have changed Par 9711
//		if self.frmToolbar.visible then
			self.frmToolbar.updateSelfForPermissions(app.getMyUser, _terminal);
		endif;
	endif;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setNotifications" id="f8151c37-f729-49ac-9456-a93b388b5585">
        <source>setNotifications();
// ---------------------------------------------------------------------------
// Created:     01 October 2007		cnwvu1	
// ---------------------------------------------------------------------------

vars
	user : CM_User;
begin
	
	self.endNotificationForSubscriber(self);
	
	//Par15018
	user := app.getMyUser();
	if user.myMenuUserToolbarRoot &lt;&gt; null then
		self.beginNotification(user.myMenuUserToolbarRoot, Event_MenuUserToolbarRoot, Response_Continuous, null);
	endif;

end;

</source>
    </JadeMethod>
