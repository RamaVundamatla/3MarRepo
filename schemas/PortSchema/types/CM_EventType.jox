    <JadeMethod name="myClassToCreate" id="72073086-dddd-486d-9aea-1061a48d94a8">
        <methodInvocation>mapping</methodInvocation>
        <source>myClassToCreate(set: Boolean; _value: Class io) mapping;
/*
----------   ----------  --------------------------------------------------
Created:	14 February 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
31 Oct 2022  navma1 	 ChangeRequest 56636[54258]: EUP - Adding New Event Type for VAS TodoTask Description
----------   ----------  --------------------------------------------------
*/
vars
	
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.category = TRAIN_EVENT then
		_value :=CMEVT_TrainTransaction;
	elseif self.category = WARNING_EVENT then
		_value:=CMEVT_OverriddenWarning;
	elseif self.category = WAGON_EVENT then
		_value := CMEVT_WagonTransaction;
	elseif self.category = VOYAGE_EVENT then
		_value := CMEVT_VoyageEvent;
	elseif self.category = TRUCK_EVENT then
		_value := CMEVT_TruckEvent;
	elseif self.category = LOCATION_EVENT then		//14 Apr 2021	NDL	TSF 50906
		_value := CMEVT_LocationActivity;
	elseif self.category = VBS_EVENT then			//31.10.2022 navma1 #56636[54258]
		_value := CMEVT_VehicleBookingEvent;
	elseif self.category = NONOPS_EVENT then		//31.10.2022 navma1 #56636[54258]
		_value := CMEVT_NonOperationalEvent;
	else
		_value := currentSchema.getClass(self.classNameToCreate);
	endif;

end;


</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Class" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="f3343362-a28a-4670-87a0-6a6269b4af4c">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2018	jlgndl1	Initial creation	TFS 40309

*/

vars

	eventType : CM_EventType;
	completedOK : Boolean;

begin

	eventType := inheritMethod();
	
	eventType.myDelayTypeToCreate := self.myDelayTypeToCreate;
	eventType.myWeightType := self.myWeightType;	// jlizm1 TFS 54165 29/07/2022

	completedOK := true;
	return eventType;

epilog

	if not completedOK then
		delete eventType;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
