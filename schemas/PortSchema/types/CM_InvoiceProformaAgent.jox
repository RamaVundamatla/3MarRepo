    <JadeMethod name="copyFromCashInvoiceAgent" id="d0c18dcf-a648-47f9-83e0-86252318bf6e">
        <source>copyFromCashInvoiceAgent(_agent : CM_CashInvoiceProformaAgent);
/*

Purpose:			To copy any Proforma InvoiceLines gathered by a CashInvoiceProformaAgent and add them to our own.
					(Used to show the overall invoice minimum charges on the Proforma view (not the Cash Collection view) on the INV_CashReceiptBOL form)

Parameters:			

Return Value:		

Date		Who		Reason
24/04/2018	jlgmd1	TFS 38165 - JMT - Invoice Proforma Calculate Button causing 14050

*/

vars
	tmpInvLines : CM_InvoiceLineSet;
begin
	if _agent = null or _agent.allProformaInvLines.size = 0 then
		return; // Nothing to do
	endif;
	 
	 tmpInvLines := _agent.allProformaInvLines.cloneSelf(true);
	 tmpInvLines.copy(self.allProformaInvoiceLines);
epilog

end;</source>
        <Parameter name="_agent" type="CM_CashInvoiceProformaAgent"/>
    </JadeMethod>
    <JadeMethod name="createProformaInvLines" id="f628d6e4-a25c-4e52-8e61-be43719e2403">
        <updating/>
        <source>createProformaInvLines(_agent : CM_Object) updating;

/*

Purpose:			

Parameters:			
Return Value:		


Date		Who		Reason
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/


vars
	trxType		: Integer;
	transType	: CM_TransactionType;
	typeDesc	: String;
	logMessage	: String;
	trxTypeArray : IntegerArray;
	localDict : CM_InvoiceLineBySeqNumDict;
	lineTrxTypes : IntegerArray;
	allChildren	: CM_TISet;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
 
	if not self.allProformaInvoiceLines.isEmpty then
		self.allProformaInvoiceLines.purge;
	endif;
	if not self.allCurrentInvoiceLines.isEmpty then
		self.allCurrentInvoiceLines.purge;
	endif;
	
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog(" ", LogINFO.String);
	endif;
	create trxTypeArray transient;
	self.getProformaTransactionTypes( trxTypeArray );
	// logging
	foreach trxType in trxTypeArray do
		transType := app.myRoot.allTransactionTypes[trxType];
		if transType &lt;&gt; null then
			typeDesc := transType.description;
		else
			typeDesc := 'Unknown Type ' &amp; trxType.String;
		endif;
		if canLogExtra then	//27.02.2025 navah1	#34141
			logMessage := "Found Selected pro forma transaction type " &amp; typeDesc;
			app.invLog(logMessage, LogTRACE.String);
		endif;
	endforeach;
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog(" ", LogINFO.String);
	endif;
	app.myTrxCA.trxCreateProformaWithResync(	trxTypeArray,		//_transactionTypes : IntegerArray;
												self.myTrackedItem,	//_cargoItem : CM_TrackedItem input;
												self.effectiveDate,	//_endDate : Date;
												self.releaseDate, // TFS 44275 to make BOL cash screen work with proforma mode
												self.myDebtor,		//_debtor : CM_Debtor
												_agent,				// _agent : CM_Object
												self.allCurrentInvoiceLines,	// _allCurrentLines : CM_InvoiceLineSet input
												self.allProformaInvoiceLines,	// _allProformaLines : CM_InvoiceLineSet input
												app.myPassport		//_passport : CM_Passport input
												);
	
	
epilog

	delete trxTypeArray;
	delete localDict;
	delete allChildren;
	app.allReportObjectSet.purge();		// app.allReportObjectSet hijacked to hold the temporary new invoices for the proforma lines
end;</source>
        <Parameter name="_agent" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="filterDuplicateActualEstimated" id="b1b0ad76-05c4-4683-ba04-dea7bde838b3">
        <source>filterDuplicateActualEstimated(_trxArray : IntegerArray input) protected;
// GPHA 2368 check if any of the configured transaction types have matching existing transactions of the specified types
//	and remove those from the list
//	23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
//	25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	toSkip	: IntegerArray;
	type	: Integer;
	typeDesc	: String;
	tran	: CM_TITransaction;
	trxType	: CM_TransactionType;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	create toSkip transient;
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141 
	foreach tran in self.myTrackedItem.allTransactions do
		if tran.type &gt; TransactionTypeJMTMax or		// user-defined
		   tran.type = TRANS_TYPE_REC_SHIP or
		   tran.type = TRANS_TYPE_REC_ROAD or
		   tran.type = TRANS_TYPE_REC_RAIL or
		   tran.type = TRANS_TYPE_REL_SHIP or
		   tran.type = TRANS_TYPE_REL_ROAD or
		   tran.type = TRANS_TYPE_REL_RAIL or
		   tran.type = TRANS_TYPE_UNPACK  or
		   tran.type = TRANS_TYPE_UnpackComplete or
		   tran.type = TRANS_TYPE_PACK or
		   tran.type = TRANS_TYPE_PackComplete or
		   tran.type = TRANS_TYPE_WHARFAGE then
			if not toSkip.includes(tran.type) then
				toSkip.add(tran.type);
			endif;
		endif;
	endforeach;
	
	foreach type in toSkip do
		if _trxArray.includes(type) then
			_trxArray.remove(type);
			if canLogExtra then	//27.02.2025 navah1	#34141
				trxType := app.myRoot.allTransactionTypes[type];
				if trxType &lt;&gt; null then
					typeDesc := trxType.description;
				else
					typeDesc := 'Unknown Type ' &amp; type.String;
				endif;
				app.invLog("Duplicate transaction type " &amp; typeDesc &amp; " removed from the pro forma transaction list.", LogINFO.String);
			endif;
		endif;
	endforeach;
epilog
	delete toSkip;
end;
</source>
        <access>protected</access>
        <Parameter name="_trxArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExpandedDetails" id="71b65638-ba6b-4962-b2b4-54f6991ae690">
        <source>getExpandedDetails(numRows : Integer output; 
					invoicedString,
					estimatedString,
					totalString : String output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason


*/

vars
	invLine : CM_InvoiceLine;
	payment	: CM_CashPayment;
	trxType : CM_TransactionType;
	showInvoiceLineType	: Boolean;
	invoicedCount,
	estimatedCount	: Integer;
	index : Integer;
	str : String;
	proformaDesc	: String;
	total	: Decimal[14, 4];

begin

	// current charges
	foreach invLine in self.allCurrentInvoiceLines do
		if invoicedString &lt;&gt; null then
			invoicedString := invoicedString &amp; CrLf;
		endif;
		invoicedString := invoicedString &amp; invLine.invoiceLineDesc.narration &amp; " " &amp; invLine.lineTotal.asCurrencyJMT();
		invoicedCount := invoicedCount + 1;
		total := total + invLine.lineTotal;
	endforeach;
	/*
	// 32851 show (partial) payments as well
	foreach payment in self.allCashPayments where not payment.isProformaPayment do
		if invoicedAmount &lt;&gt; null then
			invoicedString := invoicedString &amp; CrLf;
			invoicedAmount := invoicedAmount &amp; CrLf;
		endif;
		invoicedString := invoicedString &amp; "Paid " &amp; payment.myCashReceipt.getExternalInvoiceNumber();
		invoicedAmount := invoicedAmount &amp; "-" &amp; payment.cashValue.asCurrencyJMT();
		invoicedCount := invoicedCount + 1;
	endforeach;
	*/
	
	// estimated charges
	foreach invLine in self.allProformaInvoiceLines do
		if estimatedString &lt;&gt; null then
			estimatedString := estimatedString &amp; CrLf;
		endif;
		estimatedString := estimatedString &amp; invLine.invoiceLineDesc.narration &amp; " (x" &amp; invLine.quantity.String &amp; ") " &amp; invLine.lineTotal.asCurrencyJMT();
		estimatedCount := estimatedCount + 1;
		total := total + invLine.lineTotal;
	endforeach;

	/*
	// 32851 show (partial) payments as well
	foreach payment in self.allCashPayments where payment.isProformaPayment do
		if estimatedAmount &lt;&gt; null then
			estimatedString := estimatedString &amp; CrLf;
			estimatedAmount := estimatedAmount &amp; CrLf;
		endif;
		// 34990 show what the payment was for and accumulate paid extras
		proformaDesc := payment.getPaidProformaDesc();
		estimatedString := estimatedString &amp; "Paid " &amp; payment.myCashReceipt.getExternalInvoiceNumber() &amp; ": " &amp; proformaDesc;
		estimatedAmount := estimatedAmount &amp; "-" &amp; payment.cashValue.asCurrencyJMT();
		estimatedCount := estimatedCount + 1;
	endforeach;
	*/
	totalString := total.asCurrencyJMT();
	
	// number of rows to show is max of invoiced and estimated 
	numRows := invoicedCount.max(estimatedCount);
	numRows := numRows.max(2);		// min 2 lines for the cargo description

epilog
	
end;</source>
        <Parameter name="numRows" type="Integer" usage="output"/>
        <Parameter name="invoicedString" type="String" usage="output"/>
        <Parameter name="estimatedString" type="String" usage="output"/>
        <Parameter name="totalString" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getProformaTransactionTypes" id="a511427d-4aa8-43e6-9093-b2b1bc0d9813">
        <source>getProformaTransactionTypes( _trxArray : IntegerArray input) protected;

/*

Purpose:			

Parameters:		

Return Value:		


Date		Who		Reason
25 July 2012	cnwndl1	Initial creation

*/

vars
	
	trxType : CM_TransactionType;
	transArray	: IntegerArray;
	ti			: CM_TrackedItem;
	units : Integer;
	index, tranType : Integer;
	found : Boolean;
begin

	if _trxArray = null then 
		return;
	endif;
	
	_trxArray.clear();
	
	if self.selectedTrxCriteria = null then
		return;
	endif;
	foreach trxType in self.selectedTrxCriteria.allTransactionTypes do
		units := self.getUnits( trxType );
		if units &lt; 1 then
			continue;
		endif;
		foreach index in 1 to units do
			_trxArray.add( trxType.trxType );
		endforeach;
	endforeach;
	
	// TFS 44275 this was missing
	if self.releaseDate &lt;&gt; null 
	and self.myTrackedItem.isOnShip then
		foreach tranType in _trxArray do
			if tranType = TRANS_TYPE_REC_SHIP then
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			_trxArray.insert(1, TRANS_TYPE_REC_SHIP);
		endif;
	endif;
	
	// need to create special txns for some debtors such as ReeferDaily
	self.getTiTxnTypesForDebtorRelease(_trxArray);

	// 34917 CCMS 2368 run hook code to get any extra user-defined transaction types
	if self.selectedTrxCriteria &lt;&gt; null and 
	   self.selectedTrxCriteria.myHookCode &lt;&gt; null then
		create transArray transient;
		_trxArray.copy(transArray);
		ti := self.myTrackedItem;
		// the hook code adds to transArray based on the tracked item attributes
		app.myHookAgent.runHookLinkReturn(HookType_CashProForma, self.selectedTrxCriteria, self.selectedTrxCriteria, transArray, ti);
		_trxArray.clear();
		transArray.copy(_trxArray);
	endif;
	// 34917 'No duplicates actual/estimated' option
// TFS 44275 		if self.myTrackedItem.myTerminal.getConfig(CashNoDuplicatesActualEst).Boolean then
		self.filterDuplicateActualEstimated(_trxArray);
// TFS 44275 		endif;
	
epilog
	delete transArray;
end;</source>
        <access>protected</access>
        <Parameter name="_trxArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getStoragePaidTS" id="345e45c5-84ab-49e5-8336-0feb7eac5b0e">
        <updating/>
        <source>getStoragePaidTS() : TimeStamp updating;
/*
Purpose:			
Date		Who		Reason
14 May 2015	cnwab1	Initial creation
*/

vars
	ti : CM_TrackedItem;
	invoiceLine		: CM_InvoiceLine;
	storageTS : TimeStamp;
	time : Time;

begin
	ti := self.myTrackedItem;
	
	foreach invoiceLine in self.allCurrentInvoiceLines do
	
		if invoiceLine.remarks = "Storage" then
			return invoiceLine.chargeTime;
		endif;
	endforeach;
	
	foreach invoiceLine in self.allProformaInvoiceLines do
		if invoiceLine.remarks = "Storage" then
			return invoiceLine.chargeTime;
		endif;
	endforeach;
	
	if self.myTrackedItem &lt;&gt; null then
		time.setTime(0,0,0,0);
		storageTS.setDate(myTrackedItem.getFreeStorageExpiryDate());
		storageTS.setTime(time);
		return storageTS;
	endif;
	
	return null;	
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypesForDebtorRelease" id="48f21926-bc1b-4b70-a0d4-c9afb428d24e">
        <source>getTiTxnTypesForDebtorRelease(_intArray : IntegerArray input) protected;
// 32416 copied from CMIF_MoveController
//	23 Oct 2024	navlw1 JIRA-33107: Invoice Logging Use Levels
//  25 Feb 2025	navah1 Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	theDebtor	: CM_Debtor;
	txnType		: Integer;
	debtorType : CM_DebtorType;
	tranType : CM_TransactionType;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
/* TFS 41295 WAS
	if not self.isValidDebtorRelease(_intArray) then
		return;
	endif;

	if self.myTrackedItem = null or 
	self.myTrackedItem.myOperator = null then
		return;
	endif;
	
	theDebtor := self.myTrackedItem.myOperator.debtor;
	
	if theDebtor = null then
		return;
	endif;
	
	foreach txnType in theDebtor.allSpecialReleaseTxnTypes do
		if not _intArray.includes(txnType) and
		   self.myTrackedItem.isRelevantTxnType(txnType) then
			_intArray.add(txnType);
		endif;
	endforeach;
	
	TFS 41295 NOW
*/
	
	
	if not self.isValidDebtorRelease(_intArray) then
		return;
	endif;

	if self.myTrackedItem = null then
		return;
	endif;
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog(method.qualifiedName &amp; " - Checking for configured release reefer transactions", LogINFO.String);
	endif;
	theDebtor := self.myTrackedItem.getDebtorForCashDebtorType();
	
	if theDebtor = null then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " - Debtor Derived From is NULL", LogTRACE.String);
		endif;
		return;
	endif;
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog(method.qualifiedName &amp; " - debtor for release reefer transactions is " &amp; theDebtor.name, LogINFO.String);
		
		if self.myTrackedItem.isReefer then
			app.invLog(method.qualifiedName &amp; " - cargo '" &amp; self.myTrackedItem.id &amp;  " is reefer", LogINFO.String);
		else
			app.invLog(method.qualifiedName &amp; " - cargo '" &amp; self.myTrackedItem.id &amp;  " IS NOT REEFER, no reefer transactions will be chosen", LogINFO.String);
		endif;
	endif;
	foreach txnType in theDebtor.allSpecialReleaseTxnTypes do
		if not _intArray.includes(txnType) and
		   self.myTrackedItem.isRelevantTxnType(txnType) then
			
			_intArray.add(txnType);
		   
			tranType := app.myRoot.allTransactionTypes[txnType];
			if tranType &lt;&gt; null then
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " Adding in reefer transaction '" &amp; tranType.description &amp; "'", LogINFO.String);
				endif;
			endif;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTotal" id="7b84d545-8817-4c78-905c-de5629143d54">
        <source>getTotal() : Decimal;
// total for this cargo
vars
	totalCargoCharges	: Decimal[16,4];
	line			: CM_InvoiceLine;
begin
	foreach line in self.allCurrentInvoiceLines do
		totalCargoCharges := totalCargoCharges + line.getUnpaidAmount();
	endforeach;

	foreach line in self.allProformaInvoiceLines do
		totalCargoCharges := totalCargoCharges + line.lineTotal;
	endforeach;
	
	return totalCargoCharges;
end;
</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getUnits" id="b95db4b5-e07d-4eae-aad4-187500fe1f01">
        <source>getUnits(_trxType : CM_TransactionType ):Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	today : Date;
	processDate : Date;
	arrived : Date;
	criteria : CM_ProformaTransactionCriteria;
	proformaUnit : CM_ProformaTransactionUnit;

begin
	
	if _trxType = null then
		return 0;
	endif;
	
	if self.selectedTrxCriteria &lt;&gt; null then
		proformaUnit :=  self.selectedTrxCriteria.getUnitDetailsForTrxType( _trxType );
	endif;
	
	if proformaUnit = null then
		return 1;
		
	elseif proformaUnit.unitType = CM_ProformaTransactionCriteria.UnitType_UserUnit then
		return proformaUnit.unitValue.Integer;
		
	elseif proformaUnit.unitType = CM_ProformaTransactionCriteria.UnitType_PerDay then
		arrived := null;
		if self.myTrackedItem.isOnSite then
			arrived := self.myTrackedItem.getReceiveDate();
		elseif self.myTrackedItem.isOnShip then
			arrived := self.myTrackedItem.myVoyage.arrivedDT.Date;
		endif;
		
		if not arrived.isValid then
			arrived := today;
		endif;
		
		processDate := self.effectiveDate;
		if not processDate.isValid then
			processDate := today;
		endif;
		
		return ( processDate - arrived ).Integer + 1;
		
	endif;
	
	return 0;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_trxType" type="CM_TransactionType"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="init" id="217f0090-a89c-488a-9f03-187e9b5bf198">
        <updating/>
        <source>init(_bank : CM_Bank; _trackedItem : CM_TrackedItem; _debtor : CM_Debtor; _effDate : Date; releaseDate : Date) updating;

/*

Purpose:			Initialise

Parameters:			

Return Value:		


Date		Who		Reason
18/03/2015	cnwjre1	Initial creation	Par 34917
23 Oct 2024	navlw1 	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars

	iter : Iterator;
	proformaCrit : CM_ProformaTransactionCriteria;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141

	self.releaseDate := releaseDate; // TFS 44275 just making proforma with old cash screen work with storage.
	self.effectiveDate := _effDate;
	self.allProformaCriteria.clear();
	self.myTrackedItem := _trackedItem;
	self.myTerminal := self.myTrackedItem.myTerminal;
	self.myBank := _bank;
	self.myDebtor := _debtor;
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog(" ", LogINFO.String);
		app.invLog("** Create pro forma invoice lines for " &amp; self.myTrackedItem.cargoBOLTypeDescr &amp; " " &amp; self.myTrackedItem.id &amp; " **", LogINFO.String);
		app.invLog("  ", LogINFO.String);
		app.invLog("Find the Estimated Charges", LogINFO.String);
	endif;
	if self.myBank &lt;&gt; null then
		if self.myBank.allProformaCriteria &lt;&gt; null and not self.myBank.allProformaCriteria.isEmpty then
			self.myBank.allProformaCriteria.copy( self.allProformaCriteria );
		else
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("Company has no pro forma criteria defined", LogTRACE.String);
			endif;
		endif;
	else
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("No company so no pro forma criteria", LogTRACE.String);
		endif;
	endif;
	
	self.selectedTrxCriteria := null;

	iter := self.allProformaCriteria.createIterator;
	while iter.next( proformaCrit ) do
		// This is CARGO so ignore VESSEL criteria
		if proformaCrit.type &lt;&gt; CM_ProformaTransactionCriteria.TypeCargo then // TFS 44275 this was missing 
			continue;
		endif;
		if proformaCrit.matches( self.myTrackedItem ) then
			self.selectedTrxCriteria := proformaCrit;
			break;
		endif;
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_effDate" type="Date"/>
        <Parameter name="releaseDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="isValidDebtorRelease" id="49ee369d-3210-41c0-b7a1-bc4bac9bd191">
        <source>isValidDebtorRelease(_intArray : IntegerArray): Boolean protected;
// 32416 copied from CMIF_MoveController
vars
	txnType		: Integer;
	isRelease	: Boolean;
begin

	foreach txnType in _intArray do
		if app.isReleaseTypeTransaction(txnType) then
			isRelease := true;
			break;
		endif;
	endforeach;
	
	return isRelease;
	
end;</source>
        <access>protected</access>
        <Parameter name="_intArray" type="IntegerArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
