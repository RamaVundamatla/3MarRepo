        <source>xGCDCStatusBarStep2() updating;

/*

Purpose:		Discharge colour code and check that the status bar is correct

Date			Who		Reason
14/03/2013		cnwmh5	Initial creation

*/

constants

	ContainerPartialId					: String = 'UT31367';

vars

