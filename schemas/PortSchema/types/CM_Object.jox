    <JadeMethod name="validateUpdate" id="e5cdca49-b9fc-4171-b5c5-ed443a714a06">
        <source>validateUpdate(_passport : CM_Passport input);
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
