        <source>utlUpdateServiceObject(_proxyServiceObject:CM_ServiceObject; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	realServiceObject:CM_ServiceObject;
