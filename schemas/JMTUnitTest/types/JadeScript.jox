    <JadeMethod name="setupDataForEmailManagement" id="7f60a0e6-b873-4d7e-b7f6-65509bddbb04">
        <updating/>
        <source>setupDataForEmailManagement() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 October 2012	cnwmc5	Initial creation
17/04/2014		cnwmh5	Get the Alt User / Admin details from DMAST and save
*/

vars

	root 					: UM_Root;
	userEmail				: UM_UserEmailAddress;
	file					: File;
	emailAddress			: UM_UserEmailAddress;
	testController			: JMTTestController;

	klass					: Class;
	meth					: Method;
	
	classes					: ClassColl;
	methodsDict				: MethodNDict;
	
	tokens					: StringArray512;
	ownerArray				: StringArray;
	args					: StringArray;
	userArray				: StringArray;
	altUserArray			: StringArray;
	isAdminArray			: BooleanArray;
	
	altUser					: String;
	userName				: String;
	methodSource			: String;
	line					: String;
	token					: String;
	linePos 				: Integer;
	found					: Boolean;
	isAdmin					: Boolean;
	cnwPos					: Integer;
	result					: Integer;
	index					: Integer;
	
begin

	app.initialize();

	root := UM_Root.firstInstance();
	if root = null then
		return;
	endif;
	
	create testController transient;
	
	beginTransaction;
		foreach userEmail in root.allUserEmailAddresses do
			delete userEmail;
		endforeach;
	commitTransaction;
	
	/*
	// retreive the details currently setup in dmast
	create args transient;
	app.writeLog("Extracting details from DMAST.  Please wait...", LogAlways);
	args.clear();
	args.add('appServer=jade1.cnwdmast.cnw.co.nz');
	args.add('appServerPort=50691');
	args.add('app=JMTExtractEmailUserAltUserAdm');
	args.add('schema=JMTUnitTest');
	args.add('ini="C:\DevelopmentEnvs\cnwdmast\cnwdmast.ini"');
		
	node.createExternalProcess("C:\DevelopmentEnvs\cnwdmast\c_bin", '"C:\DevelopmentEnvs\cnwdmast\c_bin\jade.exe"', args, null, true, true, result);
	
	create file transient;
	file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version	
	file.usePresentationFileSystem := true;
	file.fileName := app.getTempDir() &amp; "dmastUserAltUserAdmin.txt";
	write file.fileName;
	if not file.isAvailable() then
		app.writeLog("Unable to find file: " &amp; app.getTempDir() &amp; "\dmastUserAltUserAdmin.txt", LogAlways);
		return;
	endif;
	*/
	create tokens transient;
	create userArray transient;
	create altUserArray transient;
	create isAdminArray transient;
	
	/*
	while not file.endOfFile do
		line := file.readLine();
		if line = null then
			continue;
		endif;
		
		tokens.clear();
		line.getTokensForDelimiter(",", tokens);
		
		userArray.add(tokens[1].trimBlanks());
		altUserArray.add(tokens[2].trimBlanks());
		isAdminArray.add(tokens[3].Integer.Boolean);
		
	endwhile;
	file.close();
	*/	
	create ownerArray transient;
	
	// get UT_DSL class
	klass := currentSchema.getClass("UT_DSL");
	if klass = null then
		return;
	endif;
	
	// create classes
	create classes transient;
	classes.add(klass);
	klass.allLocalSubclasses(classes);
	
	foreach klass in classes do
	
		methodsDict := klass.cnGetMethods();
		
		foreach meth in methodsDict where meth.isRunnableUnitTestMethod() do
		
			found := false;
			linePos := 1;
			meth.getSource.cnEcGetNextLine(linePos);
			while linePos &gt; 0 do
				line :=  meth.getSource.cnEcGetNextLine(linePos);
				if (line[1:9] = 'constants' and line.trimBlanks().length = 9) or 		
						(line[1:4] = "vars" and line.trimBlanks().length = 4) then
					break;
				endif;
				line.replaceChar(Tab, ' ');
				tokens.clear;
				line.getTokensForDelimiter(" ", tokens);
				// 04/07/2017 cnwmh5 - new jlg code
				if testController.populateOwnerArray("CNW", tokens, ownerArray) or 
						testController.populateOwnerArray("JLG", tokens, ownerArray) then
					break;
				endif;
				/*
				foreach token in tokens do
					if token.toUpper().cnContains("CNW") then
						cnwPos := token.toUpper.pos("CNW", 1);
						if cnwPos = 0 then
							continue;
						endif;
						userName := token[cnwPos:end];
						if not ownerArray.includes(userName.toUpper) then
							ownerArray.add(userName.toUpper);
							linePos := -1;
							break;
						endif;
						if token.toUpper().cnContains("CNW") then
							linePos := -1;
							break;
						endif;
					endif;
				endforeach;
				*/
			endwhile;
			
		endforeach;
		
	endforeach;
	
	//NEED TO GET JMTTestController - getEmailToUser method to get the alt emails....
	beginTransaction;
		foreach	userName in ownerArray do
			isAdmin := false;
			altUser := null;
			index := userArray.indexOf(userName.toUpper());
			if index &gt; 0 then
				isAdmin := isAdminArray[index];
				altUser := altUserArray[index];
			endif;
			
			if app.masterAddress = "@jadeworld.com" then
				userName := userName.replaceString("CNW", "JLG");
			endif;
			
			emailAddress := root.allUserEmailAddresses[app.returnCorrectUserName(userName.toUpper(), true).String];
			
			/*
			// 18/02/2020 JLGMH5
			userName := "JLG" &amp; userName[4:end];
			userName := app.returnCorrectUserName(userName.toUpper(), true);
			
			///emailAddress := root.allUserEmailAddresses[app.returnCorrectUserName(userName.toUpper(), true).String];
			emailAddress := root.allUserEmailAddresses[userName];
			*/
			
			if emailAddress = null then
				create userEmail persistent;
				userEmail.setNewUserDetails(userName.toUpper, altUser.toUpper, isAdmin, isAdmin, isAdmin, isAdmin, null, null, null);
			endif;
			/*
			create userEmail persistent;
			isAdmin := false;
			altUser := null;
			index := userArray.indexOf(userName.toUpper());
			if index &gt; 0 then
				isAdmin := isAdminArray[index];
				altUser := altUserArray[index];
			endif;
			userEmail.setNewUserDetails(userName.toUpper, altUser.toUpper, isAdmin, isAdmin, isAdmin, isAdmin, null, null);
			//write "User: " &amp; userName &amp; Tab &amp; "Alt User: " &amp; altUser &amp; Tab &amp; "Is Admin: " &amp; Tab &amp; isAdmin.String;
			*/
		endforeach;
	commitTransaction;
	
epilog

	delete classes;
	delete tokens;
	delete ownerArray;
	delete userArray;
	delete altUserArray;
	delete isAdminArray;
	delete file;
	delete testController;

end;</source>
    </JadeMethod>
    <JadeMethod name="showRunningNonRunningClassMeth" id="d119c32e-7873-4c62-8cc7-3d1296e12336">
        <source>showRunningNonRunningClassMeth();

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
27 September 2011	cnwmh5	Initial creation

*/

vars

	klass							: Class;
	meth							: Method;
	category						: UM_Category;
	file							: File;
		
	classes							: ClassColl;
	methodsDict						: MethodNDict;
	
	methodsAddedArray				: ObjectArray;
	fileMethodArray					: StringArray;
	
	totalRunnableTests				: Integer;
	count							: Integer;
	methodText						: String;
	klassText						: String;
	line							: String;
	pos, pos2						: Integer;
	klassNonRun						: Boolean;
	methodNonRun					: Boolean;
	
begin
	
	create file transient;
	file.mode := File.Mode_Output; // 4/3/16  cnwns1 PAR 36286 unicode version
	file.fileName := "c:\temp\runNonRunDetails.txt";
	file.writeLine("name" &amp; Tab &amp; 'klass not run' &amp; Tab &amp; 'meth not run');
	
	// get the main unit test class, not found the leave
	klass := currentSchema.getClass("UT_DSL");
		
	// get the class and subclasses to see what categories we have
	create classes transient;
	klass.allLocalSubclasses(classes);
	classes.add(klass);
	
	create methodsDict transient;
	create methodsAddedArray transient;
	
	foreach klass in classes do
		
		klassText := klass.text;
		klassNonRun := false;
		if klassText.cnContains("SCHEDULE_") then
			klassNonRun := true;
		endif;
		
		methodsAddedArray.clear();
		
		methodsDict := klass.cnGetMethods();
		count := 0;
		
		foreach meth in methodsDict do
			// if not runnable unit test method then next
			if not meth.isRunnableUnitTestMethod() then
				continue;
			endif;
			
			count := count + 1;
					
			methodText := meth.text;
			methodNonRun := false;
			if methodText.cnContains("SCHEDULE_") then
				methodNonRun := true;
			endif;
			
			file.writeLine(klass.name &amp; "::" &amp; meth.name &amp; Tab &amp; klassNonRun.String &amp; Tab &amp; methodNonRun.String);
			
		endforeach;
		
		
		
	endforeach;
	
	write 'Total Runnable: ' &amp; count.String;
	
epilog

	delete file;
	delete classes;
	delete methodsAddedArray;

end;
</source>
    </JadeMethod>
    <JadeMethod name="testEmail" id="c31e1cd4-42cc-49a3-b338-18391d263406">
