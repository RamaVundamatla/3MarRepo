    <JadeMethod name="zOnsiteExample" id="739a6e47-8943-49ba-a560-e98a5a68230f">
        <source>zOnsiteExample(_mode, _voyage, _location, _cargoGroupID, _clientRef : String) : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/06/2023	navdap1		Initial creation TFS 56747 EUP Manifest Load - Internal (Zimmer) - Create
// 11/10/2023   navsp1      TFS 58058
vars
	cgID : String;
	cargoId1 : String;
	cargoId2: String;
begin
	if self.opts.includesKey("CargoID1") &lt;&gt; null then
		cargoId1 := self.opts.str("CargoID1");
	else
		cargoId1 := "F3086022D0--A";
	endif;
	
	if self.opts.includesKey("CargoID2") &lt;&gt; null then
		cargoId2 := self.opts.str("CargoID2");
	else
		cargoId2 := "F3086022D0--B";
	endif;
	
 return '{
  "header": {
    "sender": "DAVE",
    "receiver": "EBTA",
    "date": "2023-06-12T00:00:00",
    "type": "CargoOnSite",
	"status": "'&amp;_mode&amp;'",
    "number": "'&amp;_clientRef&amp;'",
