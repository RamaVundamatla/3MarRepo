    <JadeMethod name="doFrameDrawMouseMoveDisplay" id="b72362c7-3517-46e6-a5e0-0d6a0cbe1c55">
        <updating/>
        <source>doFrameDrawMouseMoveDisplay(_frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     January 2010 ANDREW BISHOP
//
// CALLED BY CMUI_POINTDRAWINGFRAME, no references
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	frame : Frame;
	vertical, horizontal : Decimal[6,2];
	showCross : Boolean;
	scale, pixelPerMetre, tmpX, tmpY : Real;
	cntrl	: Control;
	indx 	: Integer;
begin
	scale := self.scaleFactor;
	if scale = 0 then
		scale := 1;
	endif;
	
	showCross := self.btnDrawTBCross.value.Boolean;
	frame := self.frmScrollable.myDrawingFrame;

	// only show the cross hair and mouse XY if we are drawing something new, i.e. no existing items selected.
//	if not frame.CMUI_PointDrawingFrame.allPointGraphics.isEmpty() then
//	if not showCross then
//		return;
//	endif;
	
	
	self.frameLabelLineV.clearGraphics();
	self.frameLabelLineH.clearGraphics();

	pixelPerMetre := (ROROStructurePixelsPerMetre * scale);
	vertical := (-1 *  ((ROROStructureCentreLine/ROROStructurePixelsPerMetre) - (y /pixelPerMetre)));
	horizontal := ((x/pixelPerMetre) - (ROROStructureRearLine /ROROStructurePixelsPerMetre));
	
	self.lblMouseXY.caption := " X: " &amp; x.String &amp; "px Y: " &amp; y.String &amp; "px | H: " &amp; horizontal.String &amp; "m V: " &amp; vertical.String &amp; "m";
	self.actualMouseY := y.Integer;
	self.actualMouseX := x.Integer;


	// MOUSE POSITION
	if showCross then
		frame.clearGraphics();
		// CENTRE LINE
		self.doDrawCentreRedLine();
		frame.CMUI_PointDrawingFrame.drawAllPolygons(null);
		
		frame.drawWidth := 1;
		frame.drawStyle := Frame.DrawStyle_InsideSolid; //DrawStyle_Solid; //DrawStyle_Dot;
		frame.drawLine(0,y,frame.width,y,Grey);
		frame.drawLine(x,0,x,frame.height,Grey);
		
		if self.frmScrollable.myVLabels.top &lt; 70 then
			tmpY := y -((self.frmScrollable.myVLabels.top - 70) * -1) ;
		else
			tmpY :=  y;
		endif;
		self.frameLabelLineV.zOrder(1);
		self.frameLabelLineV.drawFontSize := 8;
		self.frameLabelLineV.drawTextAlign := Frame.DrawTextAlign_Left;
		self.frameLabelLineV.drawLine(0,tmpY,frame.width,tmpY,Grey);
		
		self.frameLabelLineV.drawTextAt(vertical.String,15,tmpY+5,Red);

		if self.frmScrollable.myHLabels.left &lt; 50 then
			tmpX := x -((self.frmScrollable.myHLabels.left - 50) * -1) ;
		else
			tmpX :=  x;
		endif;
		

		self.frameLabelLineH.zOrder(1);
		self.frameLabelLineH.drawFontSize := 8;
		self.frameLabelLineH.drawTextAlign := Frame.DrawTextAlign_Left;
		self.frameLabelLineH.drawLine(tmpX,0,tmpX,frame.height,Grey);
		self.frameLabelLineH.drawTextAt(horizontal.String,tmpX+5,40,Red);
	endif;
	
	// PAR 29975 - cnwmc5
	self.frmScrollable.myHScroll.zOrder(1);
	self.frmScrollable.myVScroll.zOrder(1);
	self.frmScrollable.myTopLeftFillerFrame.zOrder(1);
	
end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
