    <JadeMethod name="createProxyBaysFromString" id="326a1b12-0f56-4ad7-aab6-347fa05a49fa">
        <updating/>
        <source>createProxyBaysFromString(_theBays : String) updating;
// ---------------------------------------------------------------------------
// Created:		22 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
08 Oct 2008	cnwkpd1	PAR #18009 - Prevent transient leaks
22 Nov 2022 navds21 Bug 55205: GPHA - 1310 on LOLO Definition Wizard
*/

vars
	aVessel : CM_Vessel;
	aProxyBay,previousBayDefn, realBay : CM_Bay; //Defn;
	bayType, labNum, idx,theOrdinal, theHoldOrd,currentColour,lastRowColour : Integer;
	theLabels		: HugeStringArray;	
	theBayLabels : StringArray;
	aLabel, fortyID : String;
	theHold : CM_Hold;
	theBays : CM_BayArray;
	holdLabels, bayLabel : String;

begin
//	create theBays transient;
	
	aLabel := _theBays.replaceString(BaySeperator,"@");
	aLabel := aLabel.replaceString(HoldSeperator,"/");
	
	
	
	theLabels := aLabel.getHugeTokens; //epr TFS 3806 19/4/17
	if self.allHolds.size &lt;&gt; theLabels.size then  //22.11.2022 navds21 TFS 55205
		self.createProxyHolds(theLabels.size);
	endif; //22.11.2022 navds21 TFS 55205
	foreach holdLabels in theLabels do
		holdLabels := holdLabels.replaceString("@","/");
		
		delete theBayLabels;		// PAR #18009
		theBayLabels := holdLabels.getTokens;
		theHoldOrd := theHoldOrd + 1;
		theHold := self.allHolds[theHoldOrd];
		
		if theBayLabels.size = 1 then
			bayType := BAY_TYPE_SINGLE;
		elseif theBayLabels.size = 2 then
			bayType := BAY_TYPE_TWIN ;
		else
			bayType := BAY_TYPE_TRIPLE;
		endif;
		labNum := 0;
		foreach aLabel in theBayLabels do
			if aLabel.trimBlanks &lt;&gt; null then
			
				labNum := labNum + 1;
				
				if ((labNum = 1) or (labNum = 2 and bayType = BAY_TYPE_TRIPLE)) then
					fortyID := (aLabel.Integer + 1).padLeadingWith("0",2);
				else
					fortyID := null;
				endif;
				theOrdinal := theOrdinal + 1;
				aProxyBay := self.allBaysByLabel[aLabel.trimBlanks];
				create aProxyBay as CM_BayDefn transient;
				aProxyBay.CM_BayDefn.setProxyBay(aLabel.trimBlanks,fortyID,null,null,null,null,theOrdinal,bayType,null,null,null,null,null,null,theHoldOrd,false,true,
					/*true,true,true,true,*/false,false,false,false, 	// 25/06/2010 cnwar2 #24545 - set to Tier-Cell sequencing, same as manual creation
					false,true,true, self,theHold,0,false,false);
								
			endif;
		endforeach;
	endforeach;
	
	foreach aProxyBay in self.allBaysByOrdinal do
		if aProxyBay.id.trimBlanks = null then
			continue;
		endif;
		
		if previousBayDefn &lt;&gt; null then
			previousBayDefn.setMyAftBay(aProxyBay);
		endif;
		previousBayDefn := aProxyBay;
	endforeach;
	
	
epilog
	delete theLabels;
	delete theBayLabels;
	
end;</source>
        <Parameter name="_theBays" type="String"/>
    </JadeMethod>
    <JadeMethod name="createProxyHolds" id="ee53a933-7dc8-4fb9-acf3-5eb89ae524ec">
        <updating/>
        <source>createProxyHolds(_numHolds : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx, stHold, numHolds : Integer;
	aHold : CM_VesselHold;
begin
	numHolds := _numHolds;
	foreach idx in 1 to numHolds do
			create aHold as CM_VesselHold transient;
			aHold.CM_VesselHold.setProxy(self,idx);
	endforeach;
end;</source>
        <Parameter name="_numHolds" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doCreateProxyHatchsFromXML" id="d0d72f4a-1458-4756-9c36-f7c15abe8a99">
        <source>doCreateProxyHatchsFromXML(_theXML : String; _onDeck : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aProxyHatch : CM_HatchLidVessel;
	aBay : CM_Bay;
	pos, bayPos: Integer;
	theXML, theBayXML  : String;
	theordinalODStartCell, theordinalODEndCell,theordinalUDStartCell, theordinalUDEndCell, ordinalBay1, ordinalBay2 : Integer;
	doesstartsMidCell, doesendsMidCell : Boolean;
	baySet: CM_BaySet;
begin
	pos := 1;
	create baySet transient;
	
	while (pos &gt; 0) do
		theXML := _theXML.cnEcGetNextTagValueOfName("AH",pos); 
		if theXML = null then
			break;
		endif;
		
		theordinalODStartCell := theXML.cnEcGetTagValueOfName("ODS").Integer; 
		theordinalODEndCell := theXML.cnEcGetTagValueOfName("ODE").Integer; 
		theordinalUDStartCell := theXML.cnEcGetTagValueOfName("UDS").Integer; 
		theordinalUDEndCell := theXML.cnEcGetTagValueOfName("UDE").Integer; 
		
		doesstartsMidCell := theXML.cnEcGetTagValueOfName("SMC").Integer.Boolean; 
		doesendsMidCell := theXML.cnEcGetTagValueOfName("EMC").Integer.Boolean; 

		bayPos := 1;
		baySet.clear;
		while (bayPos &gt; 0) do
			theBayXML := theXML.cnEcGetNextTagValueOfName("BO",bayPos); 
			if theBayXML = null then
				break;
			endif;
			if theBayXML.Integer &lt; 1 or theBayXML.Integer &gt; self.allBaysByOrdinal.size then
				break;
			endif;
			
			aBay := self.allBaysByOrdinal[theBayXML.Integer];
			baySet.add(aBay);
			
		endwhile;
		if baySet.isEmpty =  false then
			ordinalBay1 := baySet.first.ordinalBay;
			ordinalBay2 := baySet.last.ordinalBay;
		endif;
		create aProxyHatch transient;
		aProxyHatch.setProxy(ordinalBay1,ordinalBay2,
									theordinalODStartCell,theordinalODEndCell, theordinalUDStartCell,theordinalUDEndCell,doesstartsMidCell,doesendsMidCell,null,baySet);
	endwhile;
epilog

	if baySet &lt;&gt; null then
		delete baySet;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_theXML" type="String"/>
        <Parameter name="_onDeck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doObjectVolatilityConversion" id="6fef4715-63b2-4032-af74-d062137a9f4b">
        <updating/>
        <source>doObjectVolatilityConversion(_converter: CM_ObjectVolatilityConverter input; _logIndent: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars
	bay				: CM_BayDefn;
	
begin
	inheritMethod(_converter, _logIndent);
	
	_converter.doChangeVolatilityOfObject(self.allBays40ByLabel, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allBaysByLabel, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allBaysByOrdinal, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allHatchlids, _logIndent);
	_converter.doChangeVolatilityOfObject(self.allHolds, _logIndent);
	
	foreach bay in self.allBaysByLabel discreteLock do
		bay.doObjectVolatilityConversion(_converter, _logIndent);
	endforeach;
	

epilog

end;</source>
        <Parameter name="_converter" type="CM_ObjectVolatilityConverter" usage="input"/>
        <Parameter name="_logIndent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLInverseRef" id="441ea5b5-9e3a-4212-8311-aec51ee8d765">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 April 2011	cnwer1	Initial creation

*/

vars

begin
	if _property = CM_CellularVesselStructure::allHolds then
		return ExportAsParent;
	elseif  _property = CM_CellularVesselStructure::allHatchlids then
		return ExportAsParent;
	elseif _property = CM_CellularVesselStructure::allBaysByLabel then
		return ExportAsParent;
	endif;


	return inheritMethod(_property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="exportMyCollections" id="d1064afd-6e8d-4b75-b080-7bf0a2d5f8ee">
        <source>exportMyCollections(_file:File; _objArray:ObjectArray io; _property:Property);
// ---------------------------------------------------------------------------
// Created:     06 June 2002 by cnwrs1
//
// Purpose:     used by method exportMe to create flat file of a ship
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	object:Object;
	coll:Collection;
begin
	
	if _property.getName = CM_CellularVesselStructure::allBaysByOrdinal.name then
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;");
		coll := self.getPropertyValue(_property.getName).Collection;
		foreach object in coll.CM_BayDefnByOrdinalBayDict do
			if object.isKindOf(CM_Object) then
				object.CM_Object.exportMe(_file, _objArray);
			endif;
		endforeach;
		_file.writeLine("&lt;/"&amp;_property.getName&amp;"&gt;");
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
    </JadeMethod>
    <JadeMethod name="exportMyReferences" id="b3cc98da-c6da-4144-9b3d-238795b27562">
        <source>exportMyReferences(_file:File; _object:Object; _property:Property);
// ---------------------------------------------------------------------------
// Created:     06 June 2002 by cnwrs1
//
// Purpose:     used by method exportMe to create flat file of a ship
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _property.getName = "operatorOid" then
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;"&amp;self.getPropertyValue(_property.getName).CM_Operator.code.String.trimBlanks&amp;"&lt;/"&amp;_property.getName&amp;"&gt;");
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_property" type="Property"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="580bfec9-c858-4e76-9faf-d044151d8fd3">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	auditText : String;
	tmpStr	 : String;
	section : CM_VesselSection;
	tank 	: CM_VesselTank;
begin
	auditText:= inheritMethod();

	/*tmpStr:=null;
	foreach section in self.allSectionsByPosition do
		if tmpStr = null then
			tmpStr := section.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; section.code;
		endif;
	endforeach;
	auditText := auditText &amp; 'Vessel Sections ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	tmpStr:=null;
	
	foreach tank in self.allTanks do
		if tmpStr = null then
			tmpStr := tank.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; tank.code;
		endif;
	endforeach;
	auditText := auditText &amp; 'Vessel Tanks ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;*/
	
	
	return auditText;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="f041440c-30c3-4589-810a-fdab489b6b54">
        <source>getDisplayDetails(_short : Boolean): String;
// ---------------------------------------------------------------------------
// Created:     27 March 2002 by cnwdf1
//
// Purpose:     Return a long or short display name
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _short then
		return self.myVessel.code;
	else
		return '('&amp;self.myVessel.code &amp; ')  ' &amp; self.myVessel.name;
	endif;

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="04760133-71fe-4140-b132-1bd99bd772da">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	05 September 2005 By: cnwgd1
//--------------------------------------------------
vars
begin
	
	if _attrName = ETRow_NumberOfHolds then
		return self.allHolds.size.String;
	elseif _attrName = ETRow_BayOrder then
		return self.getPhysicalBayOrder();
	elseif _attrName = ETRow_NumSlotsDefined then
		return self.getTEUExpectedString(); 
	elseif _attrName = ETRow_NumSlotsExpected then
		return self.numSlotsExpected.asStringJMT();
	elseif _attrName = ETRow_ISOVessel then
		return self.isoHalfHeights.asStringJMT;
	elseif _attrName = ETRow_BridgeAfterBay then
		return  self.bridgeAfterBay.asStringJMT();
	
	elseif _attrName = ETRow_Use40Id then
		return  self.use40Id.asStringJMT();
	
	else		
		return inheritMethod(_attrName, _short);
	endif;
	
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="201cab75-b4a0-400b-84b5-aede63a2961b">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
//--------------------------------------------------
// Created:	05 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	block : CM_DataContainerBlock;
	passport : CM_Passport;
	teu : Integer;
	desc : String;
begin
	inheritMethod(_dataContainer);

	passport := app.myPassport;

	// DEFINED
	desc := self.getTEUExpectedString(); // PAR 32642
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CapacityTEU), DC_Label, 1, self);
	block.addNewItem(desc, DC_Data, 1, null);	
	
	// EXPECTED
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Expected_capacity), DC_Label, 1, self);
	block.addNewItem(self.numSlotsExpected.asStringJMT(), DC_Data, 1, null);	
	
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getMaxBaysAndSlots" id="aff62861-cacb-4f27-aa54-180d9ba8c334">
        <executionLocation>server</executionLocation>
        <source>getMaxBaysAndSlots(_numBays, _maxSlotsPerBay : Integer output) serverExecution;
// ---------------------------------------------------------------------------
// Created:     29 November 2001 by cnwrs2
//
// Purpose:     Counts the vessels bays and slots
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	bayDefn: CM_BayDefn;
	
begin

	_numBays := self.allBaysByOrdinal.size;

	_maxSlotsPerBay	:= 0;
	
	foreach bayDefn in self.allBaysByOrdinal do	
		_maxSlotsPerBay := _maxSlotsPerBay.max(bayDefn.allSlotsByOrdinal.size);
	endforeach;
	
end;</source>
        <Parameter name="_numBays" type="Integer" usage="output"/>
        <Parameter name="_maxSlotsPerBay" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getOperatorOid" id="06758196-6273-4a56-822d-b2517279ead7">
        <source>getOperatorOid(): CM_Operator;
// may 2005 PAR 10232 this has been added back to enable the SQLServer database to be 
//          populated with the old operator oid. 

vars

begin
	return self.myVessel.myOperator;
	//return self.operatorOid;
end;</source>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="getPhysicalBayOrder" id="0bd3000c-e9df-494e-834d-3be290b59bab">
        <source>getPhysicalBayOrder() : String;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aBayDef : CM_BayDefn;
	theString : String;
begin

	foreach aBayDef in self.allBaysByOrdinal do
		theString := theString &amp; aBayDef.id.trimBlanks &amp; " " ;
	endforeach;

	return theString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTEUCapacity" id="257b7421-d1ed-473f-98df-697210654796">
        <source>getTEUCapacity() : Integer;
// ---------------------------------------------------------------------------
// Created:     14 July 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aBay : CM_Bay;
	teu : Integer;
	slot : CM_SlotDefn;
begin
	foreach aBay in self.allBaysByOrdinal discreteLock do
		foreach slot in aBay.allSlotsByOrdinal  discreteLock where slot.unavailable = false do
			
		teu := teu + 1;
		endforeach;
	endforeach;
	
	return teu;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTEUExpectedString" id="1af3a9a4-98b5-4f23-9ae1-86c8daa517a0">
        <source>getTEUExpectedString() : String;
/*
Purpose:			
Date		Who		Reason
19 August 2013	cnwab1	Initial creation
*/

vars
	pc : Decimal[16,2]; //epr TFS 2757 13/12/16
	desc : String;
begin
	
	if numSlotsExpected &gt; 0 then
		pc := (numSlotsDefined/numSlotsExpected) * 100;
		desc := " (" &amp; pc.asStringJMTWithPrecision(0,false) &amp; "%)";
	endif;
	return self.numSlotsDefined.asStringJMT() &amp; desc; 

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLDefinition" id="3c170a79-7c3a-4c64-92d9-95ab8be2998c">
        <executionLocation>server</executionLocation>
        <source>getXMLDefinition() : Binary serverExecution;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		FOR VESSEL. This creates a single string with XML tags that 
//				descibe the hold, bay, cells, tiers, slots and hatch lids of 
//				a vessel.  It is used to draw vessels on screen. Basically 
//				the columns and rows.
// ---------------------------------------------------------------------------
// 24/04/2013		cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	aHold			: CM_Hold;
	aBay			: CM_Bay;
	xml				: String;
	colour1			: Integer;
	colour2			: Integer;
	theCol			: Integer;
	theRow			: Integer;
	currentColour	: Integer;
	colEnd			: Integer;
	rowStart		: Integer;
	rowEnd			: Integer;
	colEndRows		: Integer;
	numBays			: Integer;
	
begin
		
	// these are used for the hold colours to give us a checker board effect
	// this '4' will be 6 if there are triple bays
	colour1 := 14671839; //Yellow;
	colour2 := 12566463; //Red;
	
	if self.hasTripleBays() then
		colEndRows := 6;
	else
		colEndRows := 4;
	endif;
	
	numBays := self.allBaysByOrdinal.size();
	
	if numBays &lt;= 12 then
		colEnd := numBays;
	else
		colEnd := (numBays / colEndRows).Integer + 1;
	endif;
	
	rowStart := 1;
	rowEnd := colEndRows;
	
	theRow := 0;
	theCol := 0;
	
	beginLoad;
	
	currentColour := colour1;
	
	foreach aHold in self.allHolds do
		theCol := theCol + 1;
		
		if theCol &gt; colEnd then
			currentColour := colour2;
			theCol := 1;
			rowStart := rowStart + colEndRows;
			rowEnd := rowStart + colEndRows - 1;
		endif;
		
		theRow := rowStart;

		if currentColour &lt;&gt; colour1 then
			currentColour := colour1;
		else
			currentColour := colour2;
		endif;

		foreach aBay in aHold.allBays do
			xml := xml &amp; aBay.getGridDefinitionXML(theRow, theCol, currentColour);
			theRow := theRow + 2;
		endforeach;
	endforeach;

	endLoad;	
// cnwdad1 25/02/2009 - PAR #18366.
	return xml.compressToBinary(Binary.Compression_ZLib);
epilog
	endLoad;
end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getXMLDefinitionString" id="5e27f026-c4f2-4f78-a3e7-caaaaecd0687">
        <source>getXMLDefinitionString() : String;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		This is nothing to do with Grids and showing a vessel on the screen
//				It is the definition export .
//				SEE setProxyVesselFromXML for the import
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave in begin load state
// ---------------------------------------------------------------------------
vars
	ls : Boolean;
	aBay : CM_BayDefn;
	aLid : CM_HatchLid;
	xml, hml, sml : String;
	yml : String;
	zml : String;
	aSlot : CM_SlotDefn;
	theTI : CM_TrackedItem;
	theTITag,theTITagE : String;
	aSect : CM_VesselSection;
	aTank : CM_VesselTank;
begin
	
	// #############################
	// ACTUAL VESSEL STUFF
	xml := inheritMethod().String;

	xml := xml &amp; "&lt;bo&gt;" &amp; self.getPhysicalBayOrder &amp;
			"&lt;/bo&gt;&lt;ba&gt;" &amp; self.bridgeAfterBay &amp;
			"&lt;/ba&gt;&lt;nh&gt;" &amp; self.allHolds.size.String &amp;
			"&lt;/nh&gt;&lt;40&gt;" &amp; self.use40Id.Integer.String &amp;
			"&lt;/40&gt;&lt;sn&gt;" &amp; self.useBayCellTierNumbering.Integer.String &amp;
			"&lt;/sn&gt;&lt;hh&gt;" &amp; self.isoHalfHeights.Integer.String &amp; "&lt;/hh&gt;";
		 
	/*xml := "&lt;ct&gt;" &amp; self.isClassType.Integer.String &amp; "&lt;/ct&gt;&lt;cv&gt;" &amp; self.canCreateVoyages.Integer.String &amp; "&lt;/cv&gt;&lt;cd&gt;" &amp;  self.code.trimBlanks &amp;
		 "&lt;/cd&gt;&lt;nm&gt;" &amp; self.name.trimBlanks &amp; "&lt;/nm&gt;&lt;op&gt;" &amp; self.myOperator.code &amp; "&lt;/op&gt;&lt;cl&gt;" &amp; self.classLabel &amp; "&lt;/cl&gt;&lt;cs&gt;" &amp; self.callSign &amp; "&lt;/cs&gt;" &amp; 
		 "&lt;ln&gt;" &amp; self.lloydsNumber.String &amp; "&lt;/ln&gt;&lt;bo&gt;" &amp; self.getPhysicalBayOrder &amp; "&lt;/bo&gt;&lt;ba&gt;" &amp; self.bridgeAfterBay &amp; "&lt;/ba&gt;&lt;nh&gt;" &amp; self.allHolds.size.String &amp; "&lt;/nh&gt;" &amp; 
		 "&lt;cc&gt;" &amp; self.craneClearance.String &amp; "&lt;/cc&gt;&lt;hh&gt;" &amp; self.iSOVessel.Integer.String &amp; "&lt;/hh&gt;&lt;40&gt;" &amp; self.use40Id.Integer.String &amp; "&lt;/40&gt;" &amp; 
		 "&lt;rm&gt;" &amp; self.remarks &amp; "&lt;/rm&gt;&lt;vt&gt;" &amp; self.vesselType.String &amp; "&lt;/vt&gt;&lt;sn&gt;" &amp; self.useBayCellTierNumbering.Integer.String &amp; "&lt;/sn&gt;";*/
	
	app.cmsBeginLoad(ls);
	foreach aBay in self.allBaysByOrdinal do
		yml := aBay.getDefinitionXML();
		xml := xml &amp; yml;
	endforeach;
	app.cmsEndLoad(ls);

	// need all this stuff though
	hml := "&lt;HATCH&gt;";
	foreach aLid in self.allHatchlids do
		hml := hml &amp; aLid.getDefinitionXML();
	endforeach;
	hml := hml &amp; "&lt;/HATCH&gt;";

	xml := xml &amp; hml;	

/*
	hml := "&lt;SECTIONS&gt;";
	foreach aSect in self.allSections do
		hml := hml &amp; aSect.getDefinitionXML();
	endforeach;
	hml := hml &amp; "&lt;/SECTIONS&gt;";
	xml := xml &amp; hml;	

	hml := "&lt;TANKS&gt;";
	foreach aTank in self.allTanks do
		hml := hml &amp; aTank.getDefinitionXML();
	endforeach;
	hml := hml &amp; "&lt;/TANKS&gt;";
	xml := xml &amp; hml;	
*/
	
	return xml;

epilog
	app.cmsEndLoad(ls);			// 08/04/2011 cnwmh5 #27347
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasBayItemLayouts" id="fc9675d4-4b3f-46cc-86cb-790229932c59">
        <source>hasBayItemLayouts() : Boolean;
/*
Purpose:			
Date		Who		Reason
21 January 2014	cnwab1	Initial creation
*/

vars

    bay : CM_Bay;
    cell : CM_CellDefn;
    tier : CM_TierDefn;
begin
	foreach	bay in self.allBaysByOrdinal discreteLock do
		if bay.hasBayItemLayouts() then
			return true;
		endif;
		
		foreach cell in bay.allCellsOnDeckByOrdinal discreteLock do
			if cell.hasBayItemLayouts() then
				return true;
			endif;
		endforeach;
		
		foreach tier in bay.allTiersOnDeck discreteLock do
			if tier.hasBayItemLayouts() then
				return true;
			endif;
		endforeach;
		
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasTripleBays" id="43a11258-949a-4335-a708-ee39faad84b1">
        <source>hasTripleBays() : Boolean;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aBay : CM_Bay;
begin
	foreach aBay in self.allBaysByOrdinal do
		if aBay.bayType = BAY_TYPE_TRIPLE then
			return true;
		endif;
	endforeach;
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="importFromXMLDoc" id="7e15d831-ba80-46ef-958e-899e790f0311">
        <updating/>
        <source>importFromXMLDoc(_jadeXMLElement: JadeXMLElement input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars

begin
	inheritMethod(_jadeXMLElement);
	self.isImported:=true;

epilog

end;</source>
        <Parameter name="_jadeXMLElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="importFromXMLDocReference" id="4811e15c-29b6-4f87-9ca5-90bc53a3d807">
        <updating/>
        <source>importFromXMLDocReference(_property: Property; _xmlElement: JadeXMLElement input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	 childElement		: JadeXMLElement;
	allChildElements : JadeXMLElementArray;
	pxyBay 			: CM_BayDefn;
	pxyHatchLid 	: CM_HatchLidVessel;
begin
	if _property = CM_CellularVesselStructure::allBaysByLabel then
		create allChildElements transient;
		_xmlElement.getAllElementsByTagName(CM_BayDefn.name,allChildElements);
		
		foreach childElement in  allChildElements do
			create pxyBay transient;
			pxyBay.setMyVessel(self);
			pxyBay.importFromXMLDoc(childElement);
			pxyBay.setMyVessel(self);
		endforeach;
	elseif _property = CM_CellularVesselStructure::allHolds then
		// we will create this down on the BayDefn because the bayDefn has to set its hold before 
		// it gets here
	elseif  _property = CM_CellularVesselStructure::allHatchlids then
		create allChildElements transient;
		_xmlElement.getAllElementsByTagName(CM_HatchLidVessel.name,allChildElements);
		foreach childElement in  allChildElements do
			create pxyHatchLid transient;
			pxyHatchLid.setMyVessel(self);
			pxyHatchLid.importFromXMLDoc(childElement);
		endforeach;
	endif;
	
	inheritMethod(_property, _xmlElement);

epilog
	delete allChildElements;
end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lookupBayDefn" id="7d298fb0-6a1b-4f04-91c5-47f7ec6d5067">
        <source>lookupBayDefn(id: String): CM_BayDefn;
/*
 ------------------------------------------------------------------------
Created:			27 September 2002 by cnwdwq1
Purpose:			What could be passed in here is a 40 OR 20' id.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	bayDef : CM_BayDefn;
begin
	bayDef := self.allBaysByLabel[id];
	if bayDef &lt;&gt; null then
		return bayDef;
	endif;
	return self.allBays40ByLabel[id];
end;</source>
        <Parameter name="id" type="String"/>
        <ReturnType type="CM_BayDefn"/>
    </JadeMethod>
