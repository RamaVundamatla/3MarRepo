    <JadeMethod name="translateForm" id="36616940-64e5-47ad-8b0e-886926e45084">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 16 November 2022 08:51:50.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0012601, locale);
	btnCCWagon.translateBubbleHelp(Xlat_0014692, locale);
	btnCCWagon.translateCaption(Xlat_0014693, locale);
	btnCancelFrm.translateCaption(Xlat_0011081, locale);
	btnCargoForecast.translateCaption(Xlat_0024664, locale);
	btnConfirmCancel.translateCaption(Xlat_0012602, locale);
	btnConfirmIn.translateBubbleHelp(Xlat_0012603, locale);
	btnConfirmIn.translateCaption(Xlat_0012604, locale);
	btnConfirmOut.translateBubbleHelp(Xlat_0012605, locale);
	btnConfirmOut.translateCaption(Xlat_0012606, locale);
	btnConfirmSave.translateCaption(Xlat_0012607, locale);
	btnConfirmTrainI.translateBubbleHelp(Xlat_0011082, locale);
	btnConfirmTrainI.translateCaption(Xlat_0011083, locale);
	btnConfirmTrainO.translateBubbleHelp(Xlat_0011084, locale);
	btnConfirmTrainO.translateCaption(Xlat_0011085, locale);
	btnCopyTrain.translateBubbleHelp(Xlat_0012608, locale);
	btnCopyTrain.translateCaption(Xlat_0012609, locale);
	btnDeleteTrain.translateBubbleHelp(Xlat_0009050, locale);
	btnDeleteTrain.translateCaption(Xlat_0009051, locale);
	btnDeleteWagon.translateBubbleHelp(Xlat_0009052, locale);
	btnDeleteWagon.translateCaption(Xlat_0009053, locale);
	btnDeparture.translateBubbleHelp(Xlat_0012610, locale);
