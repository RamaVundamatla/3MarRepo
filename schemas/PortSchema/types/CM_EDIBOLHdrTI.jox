    <JadeMethod name="setVoyageCode" id="aa9eb866-ddfd-4684-9e2d-d144bbcd4219">
        <updating/>
        <source>setVoyageCode( _value : String ) updating;
/*
Date			Who		Reason
09 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
11 April 2013	cnwcs5	Make use of local variables
// 20 Nov 2018	jlgrs1	TFS 41659 STWR Make EDI MultiThreaded Stage 6
*/
vars
	config			:CM_EDIConfig;
	coll			:CM_EDITIsByVoyageCodeDict;
	code, codeUpper	:String;
begin
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	config := self.myEDIConfig;
	
	if config &lt;&gt; null then
		coll := config.allEDITrackedItemsByVoyageCode;
	endif;
	
	code := self.voyageCode;
	
	// remove the previous non-null value from this collection
	if code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if coll.includesKey( codeUpper, self ) then
			coll.removeKeyEntry( codeUpper, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null).
	code			:= _value[ 1 : self.voyageCode.maxLength ];
	self.voyageCode	:= code;
	if not self.isTransient and
	   code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if not coll.includesKey( codeUpper, self ) then
			coll.putAtKey( codeUpper, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="verifyCarrier" id="6030a879-d643-4a15-a470-8cd6e5214370">
        <updating/>
        <source>verifyCarrier() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	08 July 2010 By cnwdad1

Purpose:	This method was copied from CM_EDICargoTI.

Changed On   Changed By  Reason
03 Mar 2022  navma1 	 ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
----------   ----------  --------------------------------------------------
*/
vars
	loopCarrier,
	carrier					: CM_Carrier;
	carrierDict				: CM_CarrierByCodeDict;
	carrierStr				: String;
begin
	if self.carrierCode = null then
		return;
	endif;
	
	carrierDict := app.myRoot.allCarriers;
	carrier 	:= carrierDict[self.carrierCode];
	
	if carrier = null then
		
		carrierStr := self.carrierCode.toUpper;						//03.03.2022 navma1 #52499
		
		foreach loopCarrier in carrierDict do
			if loopCarrier.description.toUpper = carrierStr then   //03.03.2022 navma1 #52499
				self.carrierCode := loopCarrier.code;
				carrier := loopCarrier;
				break;
			endif;
		endforeach;
	endif;
	
	if carrier = null then
		app.raiseCMWarning2(ERR_FIELD_CARRIER, self.carrierCode, 'carrier code', ETRow_CarrierCode, self, self);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyOperator" id="8104e39c-cf12-4b9b-9b1f-a1b4942c2277">
        <updating/>
        <source>verifyOperator() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	08 July 2010 By cnwdad1

Purpose:	This method was copied from CM_EDICargoTI.

Changed On   Changed By  Reason
03 Mar 2022	 navma1 	 ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
----------   ----------  --------------------------------------------------
*/
vars
	loopOperator,
	operator		: CM_Operator;
	operatorDict	: CM_OperatorByCodeDict;
	operatorStr		: String;
begin
	operatorDict := app.myRoot.allOperators;
	operator 	 := operatorDict[self.operatorCode];
	
	if operator = null then
		
		operatorStr := self.operatorCode.toUpper;						//03.03.2022 navma1 #52499
		
		foreach loopOperator in operatorDict do
			if loopOperator.description.toUpper = operatorStr or		//03.03.2022 navma1 #52499
			   loopOperator.code.toUpper = operatorStr then
				self.operatorCode := loopOperator.code;
				operator 		  := loopOperator;
				break;
			endif;
		endforeach;
	endif;
	
	if operator = null then
		app.raiseCMException1(ERR_FIELD_OPERATOR, self.operatorCode, ETRow_OperatorCode, self);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyPorts" id="b6027597-dcf1-4a2f-9e86-7e4635e0aa01">
        <source>verifyPorts(_terminal : CM_Terminal) protected;
/*
----------   ----------  --------------------------------------------------
Created:	08 July 2010 By cnwdad1

Purpose:	This method was copied from CM_EDICargoTI.

Changed On   Changed By  Reason
30 Nov 2022   navma1 	 ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
----------   ----------  --------------------------------------------------
*/
vars
	portDestCode	: String;
	port			: CM_Port;
	voyageCodeStr	: String;
	voyage			: CM_Voyage;
	root			: CM_Root;
begin
	root := app.myRoot;													//30.11.2022 navma1 #52499
	
	if self.dischargePort &lt;&gt; null then
		port := root.allPorts[self.dischargePort];
		
		if port = null then
			app.raiseCMException2(ERR_FIELD_DISCHARGE_PORT, self.dischargePort, 'discharge port', ETRow_DischargePort, self);
		else
			portDestCode	:=	_terminal.getConfig(PortDestCode).String;
			voyageCodeStr	:= self.getVoyageCode();
			if voyageCodeStr = null then
				voyage := _terminal.lookupVoyage(voyageCodeStr, null, false);
			
				if voyage &lt;&gt; null  then									  //30.11.2022 navma1 #52499
					port	:= root.allPorts[ self.dischargePort ];		  //30.11.2022 navma1 #52499		
					if port &lt;&gt; null and not voyage.allPorts.includes( port ) then
						app.raiseCMException2( ERR_DISCHARGE_VOYAGE, self.dischargePort, voyage.code, ETRow_DischargePort, self );
					endif;
				endif;
			endif;
		endif;
	endif;
	
	if self.destinationPort &lt;&gt; null then
		port := root.allPorts[self.destinationPort];
		if port = null then
			app.raiseCMWarning2(ERR_FIELD_DESTINATION_PORT, self.destinationPort, 'destination port', ETRow_DestinationPort, self, self);
		endif;
	endif;
	
	if self.loadPort &lt;&gt; null then
		port := root.allPorts[self.loadPort];								//30.11.2022 navma1 #52499
		if port = null then
			app.raiseCMException2(ERR_FIELD_LOAD_PORT, self.loadPort, 'load port', ETRow_LoadPort,  self);		
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="verifySelf" id="8461083e-cac2-42e6-a199-a7695a4264d7">
        <updating/>
        <source>verifySelf() updating;
/*
----------   ----------  --------------------------------------------------
Created:	08 July 2010 By cnwdad1

Purpose:	This method was copied from CM_EDICargoTI.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars
	terminalObj			: CM_Terminal;
	voyageObj			: CM_Voyage;
	existingItem		: CM_TrackedItem;
	site				: Integer;
	trxStateEntered		: Boolean;
begin
	terminalObj	:=	self.getMyTerminal();
	
	if terminalObj = null then
		app.raiseCMException1(Err_InvalidTerminal, 'null', null, null);
		return;
	endif;
	
	if id.trimBlanks() = null then
		app.raiseCMException2(ERR_FIELD_ID,id, 'ID', ETRow_Id, self);
	endif;
	
	if CM_EDIDataCargo.hasInstance(self.myEDIData) then
		site := self.myEDIData.CM_EDIDataCargo.createToSite;
	endif;
	
	//th2 for PAR13553 - can already be in transaction state if the user
	//clicks on the 'save and verify' button
	if (not process.isInTransactionState) then
		trxStateEntered := true;
		beginTransaction;	//par 13451 cnwrs1 Feb 2007 this should not be necassary as verifies should be non updating
	endif;
	
	self.verifyCarrier();
	self.verifyPorts(terminalObj);
	self.verifyOperator();
	self.verifyVoyage(terminalObj, site);
	
	if trxStateEntered then
		commitTransaction;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="verifyVoyage" id="cc8105df-561f-41e4-a8dc-090333bb528e">
        <updating/>
        <source>verifyVoyage( _terminal : CM_Terminal; _site : Integer ) : CM_Voyage updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	08 July 2010 By cnwdad1

Purpose:	This method was copied from CM_EDICargoTI.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	voyageCodeStr	: String;
	voyage			: CM_Voyage;
	port			: CM_Port;
	
begin
	voyageCodeStr	:= self.getVoyageCode();
	if voyageCodeStr = null then
		return null;
	endif;
	
	voyage := _terminal.lookupVoyage(voyageCodeStr, null, false);
	if voyage = null then
		if _site = TI_SITE_ONSHIP then
			app.raiseCMException1(ERR_INVALID_VOYAGE, voyageCodeStr, ETRow_VoyageCode, self);
		else
			app.raiseCMWarning1(ERR_INVALID_VOYAGE, voyageCodeStr, ETRow_VoyageCode, self, self);
		endif;
	endif;
	
	// cnwrl1 10/05/2010 PAR 24061 - start of coding
	// Need to make sure the the DischargePort (if entered) is valid for the Voyage selected.
	if voyage &lt;&gt; null then
		if self.dischargePort &lt;&gt; null then
			port	:= app.myRoot.allPorts[ self.dischargePort ];
			if port &lt;&gt; null and not voyage.allPorts.includes( port ) then
				// NOTE: The DischargePort should never be an invalid Port due to previous checks in method verifyPorts.
				app.raiseCMException2( ERR_DISCHARGE_VOYAGE, self.dischargePort, voyage.code, ETRow_DischargePort, self );
			endif;
		endif;
		
		//epr par 37090 23/10/15 CCMS 2538 EDI Admin Improvements
		if voyage.hasDeparted  and  self.getMyTerminal.getConfig(EdiAddVoyageDepartError).Boolean then
			app.raiseCMException1(Voyage_departed,voyage.code,"Voyage Code", self);
		endif;
	endif;
	
epilog
	return voyage;
end;
</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_site" type="Integer"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="zGetAllExtraDataXSD" id="0c1c6592-e9e8-4b7d-a26e-2abd7b422a11">
        <source>zGetAllExtraDataXSD( xsdString : String io; xmlSample : String io );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 June 2017	cnwndl1	Initial creation	TFS 4331
01 Feb	2023	navdb1 TFS 56304 Comment out ClientRef1, ClientRef2 and Vehicle as properties have been created for them causing duplicates in XSD 
*/

vars

	type : Type;
	fieldName : String;
	exampleValue : String;

begin

	inheritMethod(xsdString,xmlSample);
	/*
	fieldName := ETRow_ClientRef1;
	type := String;
	exampleValue := "Service Order Number";
	xsdString := xsdString &amp; '&lt;xs:element name="' &amp; fieldName &amp; '" type="xs:' &amp; type.getTypeNameForXSD() &amp; '" minOccurs="0"/&gt;';
	xmlSample := xmlSample &amp; "&lt;" &amp; fieldName &amp; "&gt;" &amp; exampleValue &amp; "&lt;/" &amp; fieldName &amp; "&gt;";
	
	fieldName := ETRow_ClientRef2;
	type := String;
	exampleValue := "Purchase Order Number";
	xsdString := xsdString &amp; '&lt;xs:element name="' &amp; fieldName &amp; '" type="xs:' &amp; type.getTypeNameForXSD() &amp; '" minOccurs="0"/&gt;';
	xmlSample := xmlSample &amp; "&lt;" &amp; fieldName &amp; "&gt;" &amp; exampleValue &amp; "&lt;/" &amp; fieldName &amp; "&gt;";
	
	fieldName := ETRow_Vehicle;
	type := String;
	exampleValue := "Truck One";
	xsdString := xsdString &amp; '&lt;xs:element name="' &amp; fieldName &amp; '" type="xs:' &amp; type.getTypeNameForXSD() &amp; '" minOccurs="0"/&gt;';
	xmlSample := xmlSample &amp; "&lt;" &amp; fieldName &amp; "&gt;" &amp; exampleValue &amp; "&lt;/" &amp; fieldName &amp; "&gt;";
	*/
epilog

end;</source>
        <Parameter name="xsdString" type="String" usage="io"/>
        <Parameter name="xmlSample" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="zGetExtraItemFields" id="83210994-c40a-49f9-9e95-cf10cf72e71c">
        <source>zGetExtraItemFields(_fields: CM_FieldByTypeSysNameDict input; _fieldClass: Class);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 June 2017	cnwndl1	Initial creation	TFS 4331
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
*/

vars

	field	  : CM_EDIItemField;
	type 	  : Type;
	fieldName : String;

begin

	inheritMethod( _fields, _fieldClass );

	/*
	22.11.2022 navma1 #55424
	fieldName := ETRow_ClientRef1;
	type := String;
	create field as _fieldClass transient;
	field.set(fieldName, false, type.name, self.class.name);
	_fields.add(field);
	
	fieldName := ETRow_ClientRef2;
	type := String;
	create field as _fieldClass transient;
	field.set(fieldName, false, type.name, self.class.name);
	_fields.add(field);
	
	fieldName := ETRow_Vehicle;
	type := String;
	create field as _fieldClass transient;
	field.set(fieldName, false, type.name, self.class.name);
	_fields.add(field);
	*/

epilog

end;</source>
        <Parameter name="_fields" type="CM_FieldByTypeSysNameDict" usage="input"/>
        <Parameter name="_fieldClass" type="Class"/>
    </JadeMethod>
</Class>
