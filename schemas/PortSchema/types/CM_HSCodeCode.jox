    <JadeMethod name="shouldAuditProperty" id="9963c627-190b-4dd6-8643-4d15063cc8ff">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if 	propName = CM_HSCodeCode::allHSSubCodes.name or
		propName = CM_HSCodeCode::myHSHeading.name
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="eb19075f-c4f8-476b-ace2-28012ee26922">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	inheritMethod();
	
	self.validateForUpdate();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="2487c723-c7a2-4230-b2a6-4edf10c2869f">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	realHS,
	exisitngHS : CM_HSCodeCode;
	heading	: CM_HSCodeHeading;
	
begin
	inheritMethod();
	
	if self.id = null then
		app.raiseCMException(Input_required_field_Id, null, null);
		return;
	endif;
	
	if self.id.length &lt;&gt; 6 then
		app.raiseCMException2(Field_length_characters_long, self.id &amp; ": " &amp; app.getErrorString(Id), "6", null, null);
	endif;
	
	if self.myHSHeading = null then
		heading := app.myRoot.allHSHeadings[self.id[1:4]];
		if heading = null then
			app.raiseCMException2(Related_obj_does_not_exist, app.getErrorString(Heading), self.id[1:4], null, null);
		endif;
	endif;
	
	realHS := self.pxyGetRealObject();
	exisitngHS := app.myRoot.allHSCodes[self.id];
	
	if exisitngHS &lt;&gt; null and (realHS = null or exisitngHS &lt;&gt; realHS) then
		app.raiseCMException3(ERR_DuplicateItemWith, app.getErrorString(Code), app.getErrorString(Id), self.id, null, null);
		return;
	endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_Desc, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
