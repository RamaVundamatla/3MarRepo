    </JadeMethod>
    <JadeMethod name="addWLEtoTable" id="3cd165d9-d655-4547-8929-d6e79fc0279c">
        <source>addWLEtoTable(wle : CM_WorkListEntry);
// ---------------------------------------------------------------------------
// Created:     11 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	str : String;
	rtCol, idx, rowIdx : Integer;
begin
	rtCol := self.tblWorkEntries.getColumnByRowName(ETRow_RadioTelemetry);
	str := self.displayRowForDataTable(wle, self.tblWorkEntries);
	if wle = null then
		return;
	endif;
	if self.tblWorkEntries.findObjectInRow(wle, rowIdx) then
		self.tblWorkEntries.removeItem(rowIdx);
		self.tblWorkEntries.addItemAt(str, rowIdx);
		idx := rowIdx;
		rowIdx := 0;
	else
		idx := self.tblWorkEntries.addItem(str);
	endif;
	self.tblWorkEntries.accessRow(idx).itemObject := wle;
	self.tblWLESetRowColour(wle, idx, rtCol);				

epilog

end;</source>
        <Parameter name="wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="addWorkListEntry" id="1130d544-cfa7-46e8-b409-df14044d00c6">
        <updating/>
        <source>addWorkListEntry(_deliveryRequest : CM_DeliveryRequest input) updating, protected;
//--------------------------------------------------
// Created:	24 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	result : Integer;
begin
	if _deliveryRequest = null then
		app.msgBox('Please select a release by type from the list to add a work list entry to.', 'Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);	
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;			
		
	while true do
		app.myTrxUA.trxUpdateReleaseWLEQty(_deliveryRequest, 1, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Add work list entry', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	
epilog 
	app.mousePointer := MousePointer_Default;			
end;</source>
        <access>protected</access>
        <Parameter name="_deliveryRequest" type="CM_DeliveryRequest" usage="input"/>
    </JadeMethod>
    <JadeMethod name="assignTIToReleaseRequest" id="a7270068-1fda-4d7e-b27c-ad218a62cad0">
        <updating/>
        <source>assignTIToReleaseRequest(_wle : CM_WorkListEntry)updating;
//-----------------------------------------
//Created: February 2003 By: cnwgd1
//-----------------------------------------
vars
	result : Integer;
	moveController : CMIF_MoveController;
begin

	if app.myMoveController = null then
		return;
	endif;
	if _wle = null then
		return;
	else
		sharedLock(_wle);
	endif;
	moveController := app.myMoveController;
	moveController.setMyToPrimaryLocation(self.getLocationController);
	if _wle.myRequest.isKindOf(CM_YardDeliveryRequest) then //cnwrd1 par 22331 17.2.2010
		moveController.setMyToPrimaryLocnFromString( self.myTerminal, _wle.myRequest.CM_YardDeliveryRequest.targetLocation, PLANNING_MODE);
	endif;

	// PAR 22933
	if moveController.myTrackedItem &lt;&gt; null and moveController.myTrackedItem.isInTransitOnShip then
		app.msgBox(app.getErrorString2(YOU_NO_USE_TRANSIT_CARGO, moveController.myTrackedItem.id, _wle.id), app.getErrorString(Problem), MsgBox_OK_Only);
		return;
	endif;
	
	if moveController.myWorkListEntry &lt;&gt; null then
		if moveController.myOriginatingForm = null
		and moveController.myOriginatingLocation.isKindOf(CM_WagonController) then
			// do nothing is a drag drop direct  from rail to road so use the origination WLE
		else
			moveController.setMyWorkListEntry(_wle);
		endif;
	else
		moveController.setMyWorkListEntry(_wle);
	endif;

	while true do
		app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);	
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Assign To Release', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	
epilog
	if _wle &lt;&gt; null then
		unlock(_wle);
	endif;
	app.myDraggedTrackedItem := null;
	if app.myMoveController &lt;&gt; null then
		delete app.myMoveController;
	endif;		
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="assignTIToTransport" id="3849ac57-528b-43b0-9156-a96c1802a0d1">
        <updating/>
        <source>assignTIToTransport(_toLocationsController : CM_LocationsController)updating;
//-----------------------------------------
//Created: February 2003 By: cnwgd1
//-----------------------------------------
vars
	theJob : CM_Job;
	tmpTi : CM_TrackedItem;
	result : Integer;
	moveController : CMIF_MoveController;
begin

	if _toLocationsController = null then
		return;
	endif;
	
	if app.myMoveController = null then
		return;
	endif;
	
	moveController := app.myMoveController;
	moveController.setMyToPrimaryLocation(_toLocationsController);
	
	tmpTi := moveController.myTrackedItem;
	if tmpTi = null then
		return;
	endif;
	
	if CM_VehicleController.hasInstance(_toLocationsController) then
		theJob := tmpTi.jobRoadRelease;
	elseif CM_WagonController.hasInstance(_toLocationsController) then
		theJob := tmpTi.jobRailRelease;	
//		if theJob = null then // AKB 2006NOV want to be able to drag drop TIs on inward wagon
//			theJob := tmpTi.jobRailReceive;	
//		endif;
	else
		app.raiseCMException(VB_MOVE_INVALID, null, null);
		return;
	endif;
	if theJob &lt;&gt; null then
		moveController.setMyWorkListEntry(theJob.getWLEForTI(tmpTi));
	else
//	PAR 19710	app.raiseCMException(VB_MOVE_INVALID, null, null);
//	PAR 19710	return;					
	endif;

	while true do
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Assign To Transport', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	
epilog
	app.myDraggedTrackedItem := null;
	if app.myMoveController &lt;&gt; null then
		delete app.myMoveController;
	endif;		
end;</source>
        <Parameter name="_toLocationsController" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="assignToTBA" id="10eeb84d-726a-45d4-80c2-3133a91a3f12">
        <updating/>
        <source>assignToTBA() updating;
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
//This only gets enabled when there is a TBA under the mouse. This will:
//1) Queue move the TI to the TBA's current location.
//2) Add the ti move to a Queue.

// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	wle, 
	proxyWLE : CM_WorkListEntry;
	rtnValue : Boolean;
	theReturn : Integer;
begin

	app.mousePointer := MousePointer_HourGlass;

	if self.myCurrentWLE &lt;&gt; null then
		wle := self.myCurrentWLE;
	else
		return;
	endif;
	
	//Belts and Braces - Menu item should not be visible if ti is null
	if wle.myTrackedItem = null then	
		return;
	endif;
	
	proxyWLE := app.createUpdateProxy(wle).CM_WorkListEntry;

	while true do

		app.myTrxUA.trxUpdateTIMatchAndQueueToTBA(proxyWLE, app.myPassport);	
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog('Assign To Intended TBA', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
epilog
	delete proxyWLE;
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
