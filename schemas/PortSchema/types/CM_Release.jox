    <JadeMethod name="getMyStockMovement" id="4958124e-acff-45eb-a8e4-7d3373cf605d">
        <source>getMyStockMovement():CM_StockMovement;
//--------------------------------------------------------------
//Created: 10 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.myStockMovementIn &lt;&gt; null then
		return self.myStockMovementIn;
	endif;
	
	return self.myStockMovementOut;		
end;</source>
