    <JadeMethod name="setSorted" id="293f617d-281c-4e17-af0a-c7bc27034ccd">
        <source>setSorted(_value : Boolean);
// ---------------------------------------------------------------------------
// Created:     20 March 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	// at some stage should add a global constant and allow follow
	// variations:
	//	- both sorted
	//  - both not-sorted
	//  - available sorted, selected not sorted (for column organiser)

	if (not self.isBuilt) then
