    <JadeMethod name="getExtraInfo" id="fd9b903a-6b17-4e1b-a9cf-649bdceb9528">
        <source>getExtraInfo(_dataCont : CM_DataContainer);
//----------------------------------------------------------------
//	Created:	04 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	block : CM_DataContainerBlock;

begin
	// This needs to be carefully reviewed to see if it is really required.
	
	block := _dataCont.addNewBlock;
	block.addNewItem(app.getErrorString(CM_ID), DC_Label, 1, null);
	block.addNewItem(self.id, DC_Data, 1, null);
	
	block := _dataCont.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Cargo_Type), DC_Label, 1, null);
	block.addNewItem(app.myRoot.getCargoTypeDescription(self.cargoType), DC_Data, 1, null);
	
	block := _dataCont.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Full_Empty), DC_Label, 1, null);
	block.addNewItem(self.fullOrMT, DC_Data, 1, null);
	
	block := _dataCont.addNewBlock;
	block.addNewItem("Load Status ", DC_Label, 1, null);
	block.addNewItem(self.displayStatus, DC_Data, 1, null);

end;
</source>
        <Parameter name="_dataCont" type="CM_DataContainer"/>
    </JadeMethod>
