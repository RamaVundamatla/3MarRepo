    <JadeMethod name="getCargoListForJRW" id="f8a2dc8e-e12b-4f6a-bb30-de3ee5e70f3f">
        <source>getCargoListForJRW():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2013	cnwndl1	Initial creation	Par 31393 - Used in the report writer reports
24 Nov 2022 navhl20 Bug 55445: MTN - Found date issue in CM_VehicleBookings Report screen

*/

vars

	retString : String;
	delString : String;
	puString : String;

begin

	if self.allBookedTrackedItems.isEmpty then
		if self.includesDelivery and self.includesPickUp then
			retString := "Delivery and Pick up. Unspecified cargo.";	//24.11.2022 navhl20 TFS 55445
		elseif self.includesDelivery then
			retString := "Delivery only. Unspecified cargo.";	//24.11.2022 navhl20 TFS 55445
		elseif self.includesPickUp then
			retString := "Pick up only. Unspecified cargo.";	//24.11.2022 navhl20 TFS 55445
		else
			retString := null;
		endif;
	else
		delString := self.getDeliveryIds(",");
		puString := self.getPickUpIds(",");
		
		if delString &lt;&gt; null and puString &lt;&gt; null then
			retString := "Delivering " &amp; delString &amp; ". Picking up " &amp; puString &amp; ".";
		elseif delString &lt;&gt; null then
			retString := "Delivering " &amp; delString &amp; ".";
		elseif puString &lt;&gt; null then
			retString := "Picking up " &amp; puString &amp; ".";
		else
			retString := null;
		endif;
	endif;
	
	return retString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCarrierCode" id="88c134ba-bc0b-44ef-9584-660148e65dbd">
        <source>getCarrierCode() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2023	navpw1	Initial creation TFS: 53902

*/

vars
	carrier : CM_Carrier;
	
begin
	carrier := self.myCarrier;
	if carrier &lt;&gt; null then
		return carrier.code;
	endif;
	
	return null;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCarrierString" id="5d55682c-fbfc-44fb-868b-2ba902a6f940">
        <source>getCarrierString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation	Par 3139
13 Nov 2023	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
*/

vars
	invalid : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myCarrier, invalid); 	// 13 Nov 2023	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests

	if self.myCarrier &lt;&gt; null then
		return self.myCarrier.description;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCreationMethod" id="e24e85c1-3397-4983-a1a2-91e87109df46">
        <source>getCreationMethod() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jun 2023	jlizm1	Initial creation TFS 53901 EUP VBS EDI
14 Jul 2023	navma1	ChangeRequest 59136: EUP | VBS Edi Enhancement [1]
*/

vars

begin
	if self.creationMethod = self.Creation_Method_BGP then
		return app.getErrorString(BGP);
	elseif self.creationMethod = self.Creation_Method_MANUAL then
		return app.getErrorString(Manual);
	elseif self.creationMethod = self.Creation_Method_EDI then
		return app.getErrorString(EDI);
	else
		return app.getErrorString(Manual);
	endif;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDeliveryIds" id="df57f976-9a88-44d6-b267-3372e0c6efe9">
        <source>getDeliveryIds( _delim : String ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24 April 2013	cnwndl1	Initial creation	Par 31393
25 Aug 2023		navlw1	Bug 60046:[60047] FR | 53429 - VBS MTN - Enquiry Screen issues


*/

vars

	tiArray : CM_TIArray;
	ti 		: CM_TrackedItem;
	str 	: String;
	invalid : Boolean;

begin
	on Exception do app.handleDeletedObject( exception, ti, invalid); // 25.08.2023 navlw1 #60046
	
	create tiArray transient;
	self.getDeliveryTis( tiArray );
	
	foreach ti in tiArray do
		invalid := false;
		
		ti.edition;
		if invalid then
			continue;
		endif;
		
		if str = null then
			str := ti.id;
		else
			str := str &amp; _delim &amp; ti.id;
		endif;
	endforeach;
	
	return str;

epilog

	delete tiArray;

end;</source>
        <Parameter name="_delim" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDeliveryString" id="9798a428-021f-4b36-9eed-23f780d66a82">
        <source>getDeliveryString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2022	navhl20	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
25 Aug 2023	navlw1	Bug 60046: FR | 53429 - VBS MTN - Enquiry Screen issues
16 Oct 2023 navlc30 ChangeRequest 58996: EUP | VBS changes MTN - Adding multiple items at once (From Ticket FR 53429)

*/
constants
	MaxLen = 100;
vars
	str : String;
	invalid : Boolean;
	
begin
	str := self.getDeliveryIds(",");
	
	if str &lt;&gt; null then
		if str.length &gt; MaxLen then												//16.10.2023 navlc30 #58996
			return str[1:MaxLen-3] &amp; '...';
		else 	
			return str;
		endif;	
	endif;
	
	on Exception do app.handleDeletedObject( exception, self.myCarrier, invalid);
	
	if self.myCarrier = null then
		return null ;
	endif;
	
	self.myCarrier.edition;
	
	if invalid then
		on Exception do null;
		return null;
	endif;
	
	on Exception do null;
	
	if self.myTerminal.isUsingVbsStandardProcess then						   // 28.08.2023 navma1 #60046
		return self.includesDelivery.getYesNo;
	endif;

	return null;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDeliveryTis" id="49e4b912-221f-4e4e-893b-96498a2386e8">
        <source>getDeliveryTis( _tiSet : CM_TIArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		who		Reason
29 Apr 2013	cnwndl1	Initial creation	Par 31393
22 May 2023 navpw1	TFS: 54049 (55840) - Added code to get the correct delivering tis for Slot type validation vbs process
06 Jul 2023	navma1	ChangeRequest 58753: EUP | Slot Creation - Date and Time defaults and updates
*/

vars
	vbt			: CM_VehicleBookingTerminal;		// ### TFS 54049 (55840) 22May2023 NAVPW1
	vbsProcess	: CM_VBSProcess;					// ### TFS 54049 (55840) 22May2023 NAVPW1
	terminal	: CM_Terminal;						// ### TFS 54049 (55840) 22May2023 NAVPW1
	vbtsi		: CM_VehicleBookingTimeSlotItem;	// ### TFS 54049 (55840) 22May2023 NAVPW1
	bookingItem	: CM_BookingRefItem;				// ### TFS 54049 (55840) 22May2023 NAVPW1
	vvr			: CM_VehicleVisitRecord;			// ### TFS 54049 (55840) 22May2023 NAVPW1
	ti			: CM_TrackedItem;

begin
	vbt := self.myVehicleBookingTerminal;
	
	if vbt &lt;&gt; null then
		terminal := vbt.myTerminal;
		
	endif;
	
	if terminal &lt;&gt; null then
		vbsProcess := terminal.getMyVBSProcess();
	endif;
	
	if vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation then
		
		/*
		06.07.2023 navma1 #58753
		foreach vbtsi in self.allVehicleBookingItems do
			bookingItem := vbtsi.myBookingItem;
			if bookingItem = null then
				continue;
			endif;
			
			foreach ti in bookingItem.allTIs do
				if ti.isNotified and not ti.isOnShip then
					_tiSet.addExclusive( ti );
				elseif ti.isOnSite and ti.isOnTruck and ti.jobRoadReceive &lt;&gt; null and ti.jobRoadReceive.status &lt;&gt; JOB_COMPLETE then
					_tiSet.addExclusive( ti );
				endif;
			endforeach;
		endforeach;
		
		foreach ti in self.allBookedTrackedItems do
			if ti.isNotified and not ti.isOnShip then
				_tiSet.addExclusive( ti );
			elseif ti.isOnSite and ti.isOnTruck and ti.jobRoadReceive &lt;&gt; null and ti.jobRoadReceive.status &lt;&gt; JOB_COMPLETE then
				_tiSet.addExclusive( ti );
			endif;
		endforeach;
		*/
		//06.07.2023 navma1 #58753
		
		vvr := self.myVehicleVisitRecord;
		if vvr &lt;&gt; null then
			if not vvr.allReceivedTrackedItems.isEmpty then
				vvr.allReceivedTrackedItems.copyNoDups( _tiSet );
			endif;
		endif;
		
		foreach vbtsi in self.allVehicleBookingItems do
			if vbtsi.direction = DIRECTION_DELIVERY then
				if vbtsi.myTrackedItem &lt;&gt; null then
					_tiSet.addExclusive( vbtsi.myTrackedItem );
				endif;
			endif;
		endforeach;
	
	else
	
		vvr := self.myVehicleVisitRecord;
		
		if vvr &lt;&gt; null then
			if not vvr.allReceivedTrackedItems.isEmpty then
				vvr.allReceivedTrackedItems.copy( _tiSet );
			endif;
			
		else
			foreach ti in self.allBookedTrackedItems do
				if ti.isNotified and not ti.isOnShip then
					_tiSet.add( ti );
					//13 Feb 2014	NDL	Par 33500
				elseif ti.isOnSite and ti.isOnTruck and ti.jobRoadReceive &lt;&gt; null and ti.jobRoadReceive.status &lt;&gt; JOB_COMPLETE then	//12 Feb 2014	NDL	Par 33500 
					_tiSet.add( ti );
				endif;
			endforeach;
			
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_tiSet" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="f041b0c1-719c-4ae5-a5f2-938a21926b36">
        <source>getDescription( _short : Boolean ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	str : String;
	invalid : Boolean;

begin

	on Exception do app.handleDeletedObject( exception, self.myVehicle, invalid );

	if _short then
		if self.hasID then
			str := self.id &amp; " ";
		endif;
		if self.myVehicle &lt;&gt; null then
			str := str &amp; self.myVehicle.regNumber &amp; ",";
		endif;
		str := str &amp; self.bookingTSstart.asStringJMT;
		return str;
	endif;
	
	str := app.getErrorString(Vehicle_schedul_booking_slot) &amp; " ";
	
	if self.hasID then
		str := str &amp; self.id &amp; " ";
	endif;
	str := str &amp; self.bookingTSstart.asStringJMT;
	str := str &amp; " - " &amp; self.bookingTSend.asStringJMT;
	
	if self.myVBTimeSlotType &lt;&gt; null then
		str := str &amp; " " &amp; self.myVBTimeSlotType.code;
	endif;
	
	if self.myCarrier &lt;&gt; null then
		str := str &amp; " " &amp; self.myCarrier.code;
		if self.myDriver &lt;&gt; null then
			str := str &amp; "/" &amp; self.myDriver.name;
		endif;
		if self.myVehicle &lt;&gt; null then
			str := str &amp; "/" &amp; self.myVehicle.regNumber;
		endif;
	endif;
	
	return str;

epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="ff42f304-bdd7-40ff-aa82-2a887e759874">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			Gets the display string for the attributes passed in

Parameters:			_attrName	String	The attribute name to check for
					_short		Boolean	Whether or not we are using the short name

Return Value:		String	The display string for thwe attribute

Date		Who		Reason
09 Apr 2013	cnwndl1	Initial creation
19 Nov 2015  cnwma1 PAR #36804 VBS fail into Road Operation
19 Sep 2022	navkc1	Bug 54813: dphPjmt3- Object not found when attempting to click on Vehicle Booking
27 Sep 2022 navhl20 ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
03 Jun 2023	jlizm1	TFS 53901 EUP VBS EDI
14 Jul 2023	navma1	ChangeRequest 59136: EUP | VBS Edi Enhancement [1]
15 Aug 2023	navma1  ChangeRequest 59875: EUP | VBS - Add Created by user code
28 Aug 2023 navma1  Bug 60046: FR | 53429 - VBS MTN - Enquiry Screen issues
22 Nov 2023 navlc30 ChangeRequest 61256: EUP | FR | 54329 | VBS - Pending issues - Issue 12
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
27 Mar 2025	navnk30	JIRA 34424: TPT | VBS - Change the information from "Arrived on schedule" to be more clear with the timestamp like "Arrived on schedule at 23:23 on 20th March 2025"
*/

vars
	str			: String;
	invalid 	: Boolean;
	vvr         : CM_VehicleVisitRecord;
begin
	if _attrName = ETRow_Carrier then
		on Exception do app.handleDeletedObject( exception, self.myCarrier, invalid);  // 19/09/2022	navkc1	#54813
		if self.myCarrier &lt;&gt; null then
			return self.myCarrier.description;
		endif;
		return null;
		
	elseif _attrName = ETRow_Driver then
		on Exception do app.handleDeletedObject( exception, self.myDriver, invalid);  // 17/11/2015 cnwma1 PAR #36804
		if self.myDriver &lt;&gt; null then
			return self.myDriver.name;
		endif;
		return null;
		
	elseif _attrName = ETRow_Vehicle then
		on Exception do app.handleDeletedObject( exception, self.myVehicle, invalid);
		if self.myVehicle &lt;&gt; null then
			return self.myVehicle.regNumber;
		endif;
		return null;
		
	elseif _attrName = ETRow_Remarks then
		return self.remarks;
		
	elseif _attrName = ETRow_StartTime then
		return self.bookingTSstart.Time.asStringJMT;
		
	elseif _attrName = ETRow_EndTime then
		return self.bookingTSend.Time.asStringJMT;
		
	elseif _attrName = ETRow_StartTS then
		return self.bookingTSstart.asStringJMT;
		
	elseif _attrName = ETRow_EndTS then
		return self.bookingTSend.asStringJMT;
		
	elseif _attrName = ETRow_EndIntelligent then
		if not endsOnDifferentDate then
			return self.bookingTSend.Time.asStringJMT;
		else
			return self.bookingTSend.asStringJMT;
		endif;
			
	elseif _attrName = ETRow_Range then
		str := self.bookingTSstart.asStringJMT &amp; " - ";
		if self.bookingTSstart.date = self.bookingTSend.date then
			return str &amp; self.bookingTSend.Time.asStringJMT;
		else
			return str &amp; self.bookingTSend.asStringJMT;
		endif;
			
	elseif _attrName = ETRow_Arrived then
		if self.isUsed then
			vvr := self.myVehicleVisitRecord;
			
			str := vvr.carrierCode;
			if vvr.driverCode.trimBlanks &lt;&gt; null then
				if str &lt;&gt; null then
					str := str &amp; "/";
				endif;
				str := str &amp; vvr.driverCode;
			endif;
			if vvr.vehicle &lt;&gt; null then
				if str &lt;&gt; null then
					str := str &amp; "/";
				endif;
				str := str &amp; vvr.vehicle.regNumber;
			endif;
			if str &lt;&gt; null then
				return str &amp; " @ " &amp; vvr.timeIn.Time.asStringJMT;
			else
				return vvr.timeIn.Time.asStringJMT;
			endif;
		endif;
		return null;
		
	elseif _attrName = ETRow_Status then
		//return self.getStatusString;			//27.03.2025 navnk30 JIRA 34424
		return self.getStatusStringWithTS();	//27.03.2025 navnk30 JIRA 34424
		
	elseif _attrName = ETRow_Delivering then
		return self.getDeliveryString(); // 05.08.2023 navlw1 tfs #60046
	
	elseif _attrName = ETRow_PickingUp then // 05.08.2023 navlw1 tfs #60046
		return self.getPickupString();
		
	elseif _attrName = ETRow_CargoBookingIds then		
		return self.allBookingRefs.listString(Space,CM_BookingRef::bookingReference.name);
		
	elseif _attrName = ETRow_CargoReleaseIds then
		return self.allBulkReleases.listString(Space,CM_BulkRelease::code.name);
		
	elseif _attrName = ETRow_TsType then
		if self.myVBTimeSlotType &lt;&gt; null then
			return self.myVBTimeSlotType.description;
		endif;
		return null;
	//Start 27.09.2022 navhl20 TFS 53900
	elseif _attrName = ETRow_SubCarrierFilter then
		on Exception do app.handleDeletedObject( exception, self.mySubCarrier, invalid);  
		if self.mySubCarrier &lt;&gt; null then
			return self.mySubCarrier.description;
		endif;
		return null;
	elseif _attrName = ETRow_KioskCheck then
		return self.kioskCheck.getYesNo;
	elseif _attrName = ETRow_PreGateInCheck then
		return self.preGateInCheck.getYesNo;
	elseif _attrName = ETRow_PreGateOutCheck then
		return self.preGateOutCheck.getYesNo;
	elseif _attrName = ETRow_ExternalRef then
		return self.externalReference;
	elseif _attrName = ETRow_CreationMethod then			// TFS 53901				//14.07.2023 navma1 #59136
		return self.getCreationMethod();
	elseif _attrName = ETRow_SentLoadNotification then	 //jlier1 TFS 58839 4/7/23
		return  self.getSentLoadNotification.getYesNo;
	elseif _attrName = ETRow_CreatedBy then				//17.08.2023 navma1 #59875
		return self.createdUserCode;
	elseif _attrName = ETRow_Created  then				//17.08.2023 navma1 #59875
		return self.systemToLocalTime(self.createdTime).shortCurrentLocaleFormat();
	elseif _attrName = ETRow_Operator then												//22.11.2023 navlc30 #61256
		return self.getOperatorsAsString();
	elseif _attrName = ETRow_TilcType then												// 08 Aug 2024 navcs2	ChangeRequest 63928
		if self.myTILCType &lt;&gt; null then													// 08 Aug 2024 navcs2	ChangeRequest 63928
			return self.myTILCType.code;												// 08 Aug 2024 navcs2	ChangeRequest 63928
		else 																			// 08 Aug 2024 navcs2	ChangeRequest 63928
			return null;																// 08 Aug 2024 navcs2	ChangeRequest 63928
		endif;																			// 08 Aug 2024 navcs2	ChangeRequest 63928
	endif;																				// 08 Aug 2024 navcs2	ChangeRequest 63928
	
	return inheritMethod(_attrName, _short);
	
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDriverCode" id="85777066-8b01-49c8-8b5c-928c6c2830b0">
        <source>getDriverCode() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 June 2024		jlizm1	Initial creation TFS 63908 Allow duplicate driver names

*/

vars
	invalid : Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, self.myDriver, invalid);

	if self.myDriver = null then
		return null;
	endif;
	
	return self.myDriver.code;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDriverString" id="ff07e587-a740-4812-86a5-8232584e2526">
        <source>getDriverString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
08 April 2013		cnwndl1	Initial creation	Par 31393
13 Nov 2023			jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
18 June 2024		jlizm1	TFS 63908 Allow duplicate driver names
*/
vars
	invalid : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myDriver, invalid); 	// 13 Nov 2023	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests

	if self.myDriver = null then
		return null;
	endif;

	if self.myTerminal &lt;&gt; null and self.myTerminal.getConfig(AllowDupDriverNames).Boolean then
		return self.myDriver.name &amp; Space &amp; Hyphen &amp; Space &amp; self.myDriver.code;
	endif;
		
	return self.myDriver.name;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="b8afaff3-7118-4d7e-9b9e-4425ce75dd6d">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			Gets the Extra Info for a CM_VehicleBookingTimeSlot

Parameters:			_dataContainer	CM_DataContainer	The data container to populate with the data

Return Value:		NONE

Date		Who		Reason
22 Sep 2022 navma1	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
22 Sep 2022 navhl20 ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
25 Aug 2023	navlw1	Bug 60046 FR | 53429 - VBS MTN - Enquiry Screen issues
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot

*/

vars
	block 			 : CM_DataContainerBlock;
	vbsItem 		 : CM_VehicleBookingTimeSlotItem;
	str 			 : String;
	bulk			 : CM_BulkReleaseSet;
	isSlotValidation : Boolean;
begin

	isSlotValidation := self.myTerminal.isUsingVbsSlotValProcess;						//29.08.2023 navma1 #60135
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_ID), DC_Label, 1, self);
	block.addNewItem(self.id, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Status), DC_Label, 1, self);
	block.addNewItem(self.getStatusString(), DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Time_slot_type), DC_Label, 1, self);
	block.addNewItem(self.getSlotTypeDescription(), DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Time_slot), DC_Label, 1, self);
	block.addNewItem(self.getRange(), DC_Data, 1, self);
		
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Carrier), DC_Label, 1, self);
	block.addNewItem(self.getCarrierString(), DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Sub_Carrier), DC_Label, 1, self);
	block.addNewItem(self.getSubCarrierString, DC_Data, 1, self);	
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Start1), DC_Label, 1, self);
	block.addNewItem(self.bookingTSstart.asStringJMT, DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(End_Vbs), DC_Label, 1, self);
	block.addNewItem(self.bookingTSend.asStringJMT, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Vehicle), DC_Label, 1, self);
	block.addNewItem(self.getVehicleString, DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Driver), DC_Label, 1, self);
	block.addNewItem(self.getDriverString, DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;									// 08 Aug 2024 navcs2	ChangeRequest 63928
	block.addNewItem("TILC Type", DC_Label, 1, self);						// 08 Aug 2024 navcs2	ChangeRequest 63928
	block.addNewItem(self.getTILCString, DC_Data, 1, self);					// 08 Aug 2024 navcs2	ChangeRequest 63928
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Remarks), DC_Label, 1, self);
	block.addNewItem(self.remarks, DC_Data, 1, self);
	
	
	block := _dataContainer.addNewBlock;
	block.addNewItem('Creation Method', DC_Label, 1, self);
	block.addNewItem(self.getCreationMethod(), DC_Data, 1, self);
	
	if isSlotValidation then
		
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Kiosk_check), DC_Label, 1, self);
		block.addNewItem(self.kioskCheck.getYesNo, DC_Data, 1, self);
	
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Pregatein_check), DC_Label, 1, self);
		block.addNewItem(self.preGateInCheck.getYesNo, DC_Data, 1, self);
		
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Pregateout_check), DC_Label, 1, self);
		block.addNewItem(self.preGateOutCheck.getYesNo, DC_Data, 1, self);
	
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(External_reference), DC_Label, 1, self);
		block.addNewItem(self.externalReference, DC_Data, 1, self);

		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Number_slot_items), DC_Label, 1, self);
		block.addNewItem(self.allVehicleBookingItems.size().asStringJMT, DC_Data, 1, self);
		
		foreach vbsItem in self.allVehicleBookingItems	discreteLock do
			vbsItem.getExtraInfo(_dataContainer);
		endforeach;
	endif;
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getItemBySequence" id="f710072b-cf6b-414c-8619-49e8f43901a5">
        <source>getItemBySequence(_sequence : Integer) : CM_VehicleBookingTimeSlotItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 June 2023		jlizm1	Initial creation TFS 53901 EUP VBS EDI

*/

vars
	item : CM_VehicleBookingTimeSlotItem;
	
begin
	if _sequence = null then
		return null;
	endif;
	
	foreach item in self.allVehicleBookingItems do
		if item.sequence = _sequence then
			return item;
		endif;
	endforeach;
	
	return null;
	
epilog

end;</source>
        <Parameter name="_sequence" type="Integer"/>
        <ReturnType type="CM_VehicleBookingTimeSlotItem"/>
    </JadeMethod>
