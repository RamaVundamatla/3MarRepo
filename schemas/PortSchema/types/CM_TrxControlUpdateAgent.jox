// ---------------------------------------------------------------------------
// Created:     Jan 2006 cnwrs1
//
// Purpose:		Reset a data dump extract class to a given last
//				changed timestamp.
//				Useful when an extract has failed, and needs to be re-run from
//				a certain timestamp.  Also useful for testing.
// ---------------------------------------------------------------------------
begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);

	beginTransaction;
	
	app.myUtilityUA.utlUpdateDataDumpExtrClassTs(
			_extractClass, _expectedEdition, _extractedUpTo, _passport);
		
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
