    <JadeMethod name="clickMapPosition" id="d8715ab9-61fe-4c4a-affc-96455fd836c3">
        <source>clickMapPosition( x : Real; y : Real);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 August 2010	cnwndl1	Initial creation

*/

vars

	realX : Real;
	realY : Real;
	
	index : Integer;
	obj : Object;
	oldPosition : Point;
	oldPositionString : String;
	
	newPosition : Point;
	newPositionString : String;
	msg : String;
	
begin

	realX := picMap.scrollHorzPos + x;
	realY := picMap.scrollVertPos + y;
	
	index := cmbTA.listIndex;
	
	if index &gt; 0 then
		obj := cmbTA.listObject;
		if obj &lt;&gt; null then
			oldPosition := self.mapLocations[index];
			oldPositionString := oldPosition.x.String &amp; ", " &amp; oldPosition.y.String;
			newPosition.set(realX.Integer,realY.Integer);
			newPositionString := realX.String &amp; ", " &amp; realY.String;
			msg := "Current position for '" &amp; cmbTA.text &amp; "' = " &amp; oldPositionString &amp; "." &amp; CrLf
					&amp; "Do you want to update it to " &amp; newPositionString &amp; "?";
			if app.msgBox(msg,"Upadte?",MsgBox_Yes_No) = MsgBox_Return_Yes then
				self.mapLocations[index] := newPosition;
				cmbTA.listIndex := -1;
				loadPicture();
				loadPointsOnMap();
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
