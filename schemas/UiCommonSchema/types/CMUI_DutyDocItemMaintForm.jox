    <JadeMethod name="setBaseData" id="55943e1b-26aa-49c8-acbb-ebed1244a59c">
        <updating/>
        <source>setBaseData( _dutyDoc : CM_DutyDoc; 
			_dutyDocItem : CM_DutyDocItem;
			_allDutyDocItems : CM_DutyDocItemSet;
			_parent : CM_BaseForm ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

begin

	self.setFormParent(_parent);
	self.setParentForm( _parent );
	self.myDutyDoc := _dutyDoc;
	self.myDutyDocItem := _dutyDocItem;
	if _allDutyDocItems &lt;&gt; null then
		_allDutyDocItems.copy(self.allDutyDocItems);
	endif;
	

epilog

	self.btnAsCar.visible := false;	//07 Aug 2013	NDL	Par 31804

end;</source>
        <Parameter name="_dutyDoc" type="CM_DutyDoc"/>
        <Parameter name="_dutyDocItem" type="CM_DutyDocItem"/>
        <Parameter name="_allDutyDocItems" type="CM_DutyDocItemSet"/>
        <Parameter name="_parent" type="CM_BaseForm"/>
    </JadeMethod>
    <JadeMethod name="setCmbOrigin" id="1d1d1954-19b8-4b21-8155-1a16d28d1756">
        <source>setCmbOrigin( _value : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2013	cnwndl1	Initial creation

*/

vars

	index : Integer;
	count : Integer;
	
begin

	count := self.cmbOrigin.listCount;
	foreach index in 1 to count do
		if self.cmbOrigin.itemText[index].pos(_value,1) = 1 then
			self.cmbOrigin.listIndex := index;
			break;
		endif;
	endforeach;

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setHSCodeDesc" id="c8740edd-a1bf-40b1-94f7-e80c86506802">
        <updating/>
        <source>setHSCodeDesc() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars
	hsCode : CM_DutyDocHSCode;
begin

	hsCode:=self.cmbHSCodeCode.getCurrentItemObject.CM_DutyDocHSCode;
	
	if hsCode = null then
		self.myDutyDocHSCode := null;
		self.txtRatePercent.text := null;
		self.txtDutyCode.text := null;
	else
		self.myDutyDocHSCode := hsCode;
		self.txtRatePercent.text := hsCode.dutyRate.asStringJMTWithPrecision(2,false);
		self.txtDutyCode.text := hsCode.dutyType;
	endif;
	
	self.evaluateValues();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="520579a7-1d5f-48e6-9f5f-d22e3750c102">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwndl1	Initial creation	Par 30901
31 July     2014    cnwma1 PAR 34408 Credit Customer current charges
17 Sept		2014    cnwma1 PAR 34830 Quantity Field length

*/

vars

	billType : CM_DutyDocType;
	dutyDocItem : CM_DutyDocItem;
	countDuty   : Integer;
begin
	
	self.txtQuantity.maxLength := 10;   //17/09/2014 cnwma1 PAR #34830
	self.minimumWidth := 920;
	self.minimumHeight := 540;
	self.width := 920;
	self.height := 540;
	self.grpMain.borderStyle := Control.BorderStyle_None;
	
	self.cmbHSCodeCode.style:=ComboBox.Style_DropDown;
	self.populateCmbPacking();
	self.populateCmbOrigin();	//08 Aug 2013	NDL	Par 32305
	self.populateCmbCurrency();
	self.populateCmbHSCode();
	self.populateTextBoxDecimals();
	self.myAssistant.comboBoxConsignor(self.cmbConsignee,null,CONSIGNEE);
	if self.myDutyDoc &lt;&gt; null then
		self.cmbConsignee.enabled := false;					// 31-JUL-2014 cnwma1 PAR 34408 Credit Customer current charges
	endif;
	self.cmbPOD.myTerminal := self.myTerminal; 
	self.cmbPOD.myAssistant := self.myAssistant;
	self.cmbPOL.myTerminal := self.myTerminal; 
	self.cmbPOL.myAssistant := self.myAssistant;
	self.populateCmbVehColour();
	self.populateCmbVehMake();
	self.populateCmbVehModel();
	self.populateCmbVehType();
	
	self.centreOverParent(1);
	
	inheritMethod();
	
	self.grpFinancial.visible:= self.myDutyDoc &lt;&gt; null;
	
	if self.myDutyDoc &lt;&gt; null and self.myDutyDoc.type &lt;&gt; null then
		billType := app.myDutyDocRoot.allDutyDocTypes[self.myDutyDoc.type];
		if billType &lt;&gt; null then
			self.chkDutyExempt.value := ( not billType.dutyCharged );
			self.grpExempt.visible := self.chkDutyExempt.value;      // 34042
		endif;
	endif;
	
	self.grpCar.visible := false;
	self.txtVCCNum.enabled := false;
	
	if self.myDutyDocItem = null then
		self.btnFind.visible := true;
		self.btnSaveNext.visible := true;
		if self.myDutyDoc &lt;&gt; null and self.myDutyDoc.getMyConsignee &lt;&gt; null then
			self.cmbConsignee.setIndexFromObject(self.myDutyDoc.getMyConsignee);
		endif;
	else
		self.btnFind.visible := false;
		self.btnSaveNext.visible := false;
		self.populateFromDutyDocItem();
	endif;
	
	if self.allDutyDocItems.size &gt; 1 then
		self.txtID.maxLength:=0;
		foreach dutyDocItem in self.allDutyDocItems do
			//self.lstTIs.addItemObject(dutyDocItem.cargoId,dutyDocItem);
			if self.allDutyDocItems.first = dutyDocItem then
				self.txtID.text:=dutyDocItem.cargoId;
			else
				self.txtID.text:=self.txtID.text &amp; ", " &amp; dutyDocItem.cargoId;
			endif;
		endforeach;
		//self.lstTIs.visible:=true;
		self.setCaption(app.getErrorString(Bulk_Duty_Doc_Item_Maint));  
		countDuty :=0;
		foreach dutyDocItem in allDutyDocItems do
		if dutyDocItem.currency &lt;&gt; null then  // 25-AUG-2014 cnwma1 PAR 34408 Credit Customer current charges
			countDuty := countDuty+1;
		endif;
		endforeach;
		if countDuty &gt;0 then
			btnSave.enabled :=false;
		endif;
		
	endif;
	
	if self.myDutyDoc &lt;&gt; null then
		self.beginNotification(self.myDutyDoc, Object_Delete_Event, Response_Continuous, 0);
	endif;
	if self.myDutyDocItem &lt;&gt; null then
		self.beginNotification(self.myDutyDocItem, Object_Delete_Event, Response_Continuous, 0);
	endif;
	
	self.modalResult := ModalResultCancel;

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="d390de79-a0a4-4aba-b543-1d92a33b8922">
