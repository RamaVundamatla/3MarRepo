    <JadeMethod name="getServiceBroker" id="dc0385aa-9053-4491-8e37-3016bb1b7e20">
        <source>getServiceBroker(_theTransaction: CM_BOLTransaction) : CM_BOLServiceBroker;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100
23 Oct 2024 		navlw1  JIRA-33107: Invoice Logging Use Levels
25 Feb 2025			navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	theBroker : CM_BOLServiceBroker;
	invalid : Boolean;
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	if _theTransaction = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _theTransaction, invalid);
	
	theBroker := self.allBOLServiceBrokers[_theTransaction.type];
	if theBroker &lt;&gt; null then
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("BOL transaction map found for '" &amp; _theTransaction.getTypeString() &amp; "'", LogTRACE.String);
		endif;
	endif;
	
	if theBroker = null then
		theBroker := self.allBOLServiceBrokers[null]; // DEFAULT
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("BOL transaction map DEFAULT used", LogTRACE.String);
		endif;
	endif;
	
	
	return theBroker;
end;</source>
        <Parameter name="_theTransaction" type="CM_BOLTransaction"/>
        <ReturnType type="CM_BOLServiceBroker"/>
    </JadeMethod>
