<Class name="JadeScript">
    <JadeMethod name="cnwdad1_TestCalendar" id="969b4cf8-4254-470d-b6ea-03b742367b62">
        <source>cnwdad1_TestCalendar() protected;
// --------------------------------------------------------------------------------
// Created:		01 February 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	formObj		: MB_CalendarSelectForm;
	result		: Integer;
	timestamp	: TimeStamp;
	
begin
	create formObj transient;
	formObj.setDateTime(timestamp.date, timestamp.time, true);
	result	:=	formObj.showModal();
	
	if result = 0 then
		write "Calendar form was cancelled.";
	elseif result = 4 then
		write formObj.aTimeStamp;
	else
		write "Unexpected result from Calendar form.";
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cnwdad1_TestMsgBox" id="962c9586-f841-4efb-9fba-5cda46dced10">
