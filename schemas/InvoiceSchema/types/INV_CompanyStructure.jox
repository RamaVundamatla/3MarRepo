    <JadeMethod name="translateForm" id="cc2023fa-dbbf-4665-9f91-8da61ca502dc">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 09 January 2023 09:30:56.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006136, locale);
	btnAutoId.translateCaption(Xlat_0025336, locale);
	btnDelete.translateBubbleHelp(Xlat_0002063, locale);
	btnDelete.translateCaption(Xlat_0002068, locale);
	btnNew.translateBubbleHelp(Xlat_0006137, locale);
	btnNew.translateCaption(Xlat_0002069, locale);
	btnNewCompany.translateBubbleHelp(Xlat_0002060, locale);
	btnNewCompany.translateCaption(Xlat_0002061, locale);
	btnSusp.translateBubbleHelp(Xlat_0002065, locale);
	btnSusp.translateCaption(Xlat_0002070, locale);
	btnUpdate.translateBubbleHelp(Xlat_0002066, locale);
	btnUpdate.translateCaption(Xlat_0002071, locale);
	mnuAudits.translateCaption(Xlat_0021725, locale);
	mnuCSBU.translateCaption(Xlat_0006138, locale);
	mnuCSComp.translateCaption(Xlat_0006139, locale);
	mnuCSDelete.translateCaption(Xlat_0006141, locale);
	mnuCSMain.translateCaption(Xlat_0006142, locale);
	mnuCSSuspend.translateCaption(Xlat_0006143, locale);
	mnuCSUpdate.translateCaption(Xlat_0006144, locale);
	mnuInspect.translateCaption(Xlat_0006145, locale);
end;</source>
    </JadeMethod>
</GUIClass>
