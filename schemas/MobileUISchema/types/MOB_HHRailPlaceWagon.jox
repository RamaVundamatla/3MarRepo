    <JadeMethod name="setRakeButtons" id="c1d6a576-56dd-4481-9570-6456a05b7c41">
        <source>setRakeButtons();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	pos : Integer;
	
begin

	if self.cmbRakePos.listCount &lt; 1 then
		btnRakeForward.enabled := false;
		btnRakeBack.enabled := false;
		return;
	endif;

	pos := self.cmbRakePos.listIndex;
	if pos &gt;= self.cmbRakePos.listCount then
		if self.myMobileGenericAgent.forward then
			btnRakeForward.enabled := false;
		else
			btnRakeBack.enabled := false;
		endif;
	else
		if self.myMobileGenericAgent.forward then
			btnRakeForward.enabled := true;
		else
			btnRakeBack.enabled := true;
		endif;
	endif;
	
	if pos &lt;= 1 then
		if self.myMobileGenericAgent.forward then
			btnRakeBack.enabled := false;
		else
			btnRakeForward.enabled := false;
		endif;
	else
		if self.myMobileGenericAgent.forward then
			btnRakeBack.enabled := true;
		else
			btnRakeForward.enabled := true;
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setRakePositionFromWagon" id="774e44d8-677a-4e00-8355-74be34288948">
        <updating/>
        <source>setRakePositionFromWagon( _wagon : CM_Wagon ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars
	rakePos : Integer;
begin
	if _wagon &lt;&gt; null then
		rakePos := self.myMobileGenericAgent.myCurrentRailLine.allWagons.indexOf(_wagon);
		if rakePos &gt; 0 then
			if cmbRakePos.listCount &gt;= rakePos then
				cmbRakePos.listIndex := rakePos;
			endif;
		endif;
	endif;
epilog

end;</source>
