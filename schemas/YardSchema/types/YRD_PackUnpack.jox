vars
	ta				: CM_TerminalArea;
begin

//	if self.myNotableTerminalArea &lt;&gt; null then
//		self.endNotificationForSubscriber(self.myNotableTerminalArea);
//	endif;
	ta := combobox.listObject.CM_TerminalArea;
//	if ta &lt;&gt; null then
//		self.myNotableTerminalArea := ta;
//		self.beginNotification(self.myNotableTerminalArea, self.myTerminal.getTerminalEvent(EVENT_UPDATE_GRID_AREA), Response_Continuous, null);
//	endif;
	self.endNotificationForSubscriber(self.tblUnpacked);

	if ta &lt;&gt; null then 
		self.tblUnpacked.beginNotification(ta, self.myTerminal.getTerminalEvent(EVENT_TI_MOVE_FROM_LOCATION), Response_Continuous, null);//HG 2005 Dec added
		self.tblUnpacked.beginNotification(ta, self.myTerminal.getTerminalEvent(EVENT_TI_MOVE_TO_LOCATION), Response_Continuous, null);// HG 2005 Dec added
	endif;

	self.doLoadCmbQryRow(ta);

