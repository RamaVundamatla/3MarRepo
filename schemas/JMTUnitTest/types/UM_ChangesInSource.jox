        <source>externalProcessSetupWMAST(_appName : String; _binDirectory, _command : String io; _args : StringArray io);

/*

Purpose:		Details for calling external process for dmast	

Date			Who		Reason
08/09/2016		cnwmh5	Initial creation

*/

vars

begin

	_args.clear();
	_args.add('appServer=jade1.cnwwmast.cnw.co.nz');                                
	_args.add('appServerPort=50821');							
	_args.add('ini="C:\DevelopmentEnvs\cnwwmast\cnwwmast.ini"');				
	_args.add('app=' &amp; _appName);						
	_args.add('schema=JMTUnitTest');									
	_args.add('endJade');											
	_args.add("DATE=" &amp; self.fromTS.date.format("dd/MM/yyyy"));			
	_args.add("TIME=" &amp; self.fromTS.time.String);							
	_args.add("DIRECTORY=" &amp; self.directoryName);							
	_args.add("DONTCALL=TRUE");	
	
	_binDirectory := "C:\DevelopmentEnvs\cnwwmast\c_bin";				
	_command := _binDirectory &amp; "\jade.exe";			
			

epilog

end;</source>
        <Parameter name="_appName" type="String"/>
        <Parameter name="_binDirectory" type="String" usage="io"/>
        <Parameter name="_command" type="String" usage="io"/>
        <Parameter name="_args" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="extractAdditionalDetails" id="1f094c4c-4f8e-47c8-859f-96a263db8cc9">
        <updating/>
        <source>extractAdditionalDetails() updating;

/*

Purpose:		Extract the additional details	

Date			Who		Reason
09/09/2016		cnwmh5	Initial creation

*/

vars

	fileFolder						: FileFolder;
	file							: File;
		
	tokens							: StringArray512;
	
	line							: String;

begin

	// load xml document
	documentC.parseFile(self.directoryName &amp; "\" &amp; self.fileName);
	
	self.elementSchemasC := documentC.getElementByTagName(self.SchemasTag);
	if self.elementSchemasC = null then
		self.elementSchemasC := documentC.addElement(self.SchemasTag);
	endif;
			
	self.elementGlobals := documentC.getElementByTagName(self.GlobalsTag);
	
	create file transient;
	file.fileName := self.directoryName &amp; "\DetailsToGet.csv";
	
	while not file.endOfFile do
	
		line := file.readLine();
		if line = null then
			continue;
		endif;
		
		delete tokens;
		create tokens transient;
		line.getTokensForDelimiter(",", tokens);
		
		
		if tokens[3] &lt;&gt; "CATEGORY" and tokens[3] &lt;&gt; "GLOBAL" then
			// get the schema
			self.elementSchemaC := self.elementSchemasC.getElementByTagName(tokens[1]);
			if self.elementSchemaC = null then
				self.elementSchemaC := self.elementSchemasC.addElement(tokens[1]);
			endif;
		
			// get the class
			self.elementClassesC := self.elementSchemaC.getElementByTagName(self.ClassesTag);
			if self.elementClassesC = null then
				self.elementClassesC := elementSchemaC.addElement(self.ClassesTag);
			endif;
			self.elementClassC := self.elementClassesC.getElementByTagName(tokens[2]);
			if self.elementClassC = null then
				self.elementClassC := self.elementClassesC.addElement(tokens[2]);
			endif;
		else
			// global constant 
			if tokens[3] = "GLOBAL" then
				self.elementGlobalCategoryC := self.elementGlobals.getElementByTagName(tokens[2]);
				if self.elementGlobalCategoryC = null then
					self.elementGlobalCategoryC := self.elementGlobals.addElement(tokens[2]);
				endif;
			endif;
		endif;
		
		// get the method		
		if tokens[3] = "METHOD" then
			self.elementMethodsC := self.elementClassC.getElementByTagName(self.MethodsTag);
			if self.elementMethodsC = null then
				self.elementMethodsC := self.elementClassC.addElement(self.MethodsTag);
			endif;	
			self.addMethodToFile(null, tokens);
		elseif tokens[3] = "PROPERTY" then
			self.elementPropertiesC := self.elementClassC.getElementByTagName(self.PropertiesTag);
			if self.elementPropertiesC = null then
				self.elementPropertiesC := self.elementClassC.addElement(self.PropertiesTag);
			endif;	
			self.addPropertyToFile(null, tokens);
		elseif tokens[3] = "CONSTANT" then
			self.elementConstantsC := self.elementClassC.getElementByTagName(self.ConstantsTag);
			if self.elementConstantsC = null then
				self.elementConstantsC := self.elementClassC.addElement(self.ConstantsTag);
			endif;				
			self.addConstantToFile(null, tokens);
		elseif tokens[3] = "CATEGORY" or tokens[3] = "GLOBAL" then
			self.addGlobalConstantToFile(null, tokens);
		endif;
	
	endwhile;
	file.close();
	delete file;
	
	create file transient;
	file.fileName := self.directoryName &amp; "\" &amp; self.fileName;
	if file.isAvailable() then
		file.purge();
	endif;
	
	documentC.writeToFile(self.directoryName &amp; "\" &amp; self.fileName);	
	
epilog

	delete fileFolder;
	delete file;
	delete tokens;

end;</source>
    </JadeMethod>
    <JadeMethod name="extractChangesCurrent" id="e5077d9b-9cd3-4f43-b9fe-d3ad84f1cc88">
        <updating/>
        <source>extractChangesCurrent() updating;

/*

Purpose:		Extract changes from the current system	

Date			Who		Reason
08/092016		cnwmh5	Initial creation

*/

vars

	fileFolder					: FileFolder;
	file						: File;
	schema						: Schema;
	meth						: Method;
	klass						: Class;
	obj							: Object;
	type						: Type;
	prop						: Property;
	constant					: Constant;
	
	schemaColl					: SchemaColl;
	classColl					: ClassColl;
	methDict					: MethodNDict;
	typeColl					: TypeColl;
	constDict					: ConstantNDict;
	propertyNDict				: PropertyNDict;
	
	iter						: Iterator;
	
	schemaName					: String;
	methodConstName				: String;
	className					: String;
	currentClassName			: String;
	currentSchemaName			: String;

	devSchemaReleaseAgent		: Object;
	releaseSchemas				: StringArray;
	
begin

	app.writeLog("Extracting details from " &amp; self.systemName &amp; ".  Please wait...", LogINFO);
	write "Extracting details from " &amp; self.systemName &amp; ".  Please wait...";
	
	self.elementDifferences := self.documentC.addElement(self.DifferencesTag);
	self.elementSchemasC := self.elementDifferences.addElement(self.SchemasTag);
	self.elementGlobals := self.elementDifferences.addElement(self.GlobalsTag);
	
	create fileFolder transient;
	fileFolder.usePresentationFileSystem := true;
	fileFolder.fileName := self.directoryName;
	if not fileFolder.isAvailable() then
		fileFolder.make();
	endif;
	
	create file transient;
	file.fileName := fileFolder.fileName &amp; "\" &amp; self.fileName;
	if file.isAvailable() then
		file.purge();
	endif;
	
	// get global const changes
	self.getGlobalConstantChanges();
	
	create devSchemaReleaseAgent as rootSchema.getSchema('DevSchema').getClass('DEV_ReleaseExtractAgent') transient;
	create releaseSchemas transient;
	devSchemaReleaseAgent.sendMsgWithIOParams('getReleaseSchemas', releaseSchemas);
	
	// get all schemas from Root Schema down
	create schemaColl transient;

	rootSchema.allSubschemas(schemaColl);
	
	foreach schema in schemaColl where not self.doReleaseSchemasOnly or releaseSchemas.includes(schema.name) do
	
		if schema.name[1:4] = "Jade" then
			continue;
		endif;
	
		delete typeColl;
		delete classColl;
		typeColl := schema.allPrimitives();
		classColl := schema.allClasses();
		classColl.copy(typeColl);
		
		self.schemaName := schema.name;
		
		foreach type in typeColl do
			if type.schema.name &lt;&gt; schema.name then
				continue;
			endif;
			
			klass := type.Class;
			self.className := klass.name;
			
			// get the changed methods
			methDict := type.cnGetMethods();
			foreach meth in methDict do
				if meth.getSchema() &lt;&gt; schema or meth.cnGetModifiedTimeStamp() &lt; self.fromTS then
					continue;
				endif;
				if not self.diffClassMeth.includesKey(self.schemaName, self.className, meth.name) then
					self.diffClassMeth.putAtKey(self.schemaName, self.className, meth.name, meth);		
				endif;
			endforeach;
			
			// class constants
			delete constDict;
			create constDict transient;
			type.getConstants(constDict);
			foreach constant in constDict do
				if constant.cnGetModifiedTimeStamp() &lt; self.fromTS then
					continue;
				endif;
				if not self.diffClassMeth.includesKey(self.schemaName, self.className, constant.name) then
					self.diffClassMeth.putAtKey(self.schemaName, self.className, constant.name, constant);		
				endif;
			endforeach;
			
			// class properties
			propertyNDict := klass.cnGetProperties();
			foreach prop in propertyNDict do
				
				if prop.cnGetModifiedTimeStamp() &lt; self.fromTS then
					continue;
				endif;
				
				if not self.diffClassMeth.includesKey(self.schemaName, self.className, prop.name) then
					self.diffClassMeth.putAtKey(self.schemaName, self.className, prop.name, prop);	
				endif;
				
			endforeach;
			
		endforeach;
		
	endforeach;
	
	delete iter;
	iter := self.diffClassMeth.createIterator;
	while iter.next(obj) do
	
		constant := null;
		meth := null;
		prop := null;
		if obj.isKindOf(Constant) then
			constant := obj.Constant;
		elseif obj.isKindOf(Method) then
			meth := obj.Method;
		else
			prop := obj.Property;
		endif;
	
		self.diffClassMeth.getIteratorKeys(schemaName, className, methodConstName, iter);
				
		if currentSchemaName &lt;&gt; schemaName then
			self.elementSchemaC := self.elementSchemasC.addElement(schemaName);
			self.elementClassesC := self.elementSchemaC.addElement(ClassesTag);
			currentSchemaName := schemaName;		
		endif;
		
		if currentClassName &lt;&gt; className then
			self.elementClassC := self.elementClassesC.addElement(className);
			self.elementConstantsC := self.elementClassC.addElement(ConstantsTag);
			self.elementPropertiesC := self.elementClassC.addElement(PropertiesTag);
			self.elementMethodsC := self.elementClassC.addElement(MethodsTag);
			currentClassName := className;
		endif;
		
		if meth &lt;&gt; null then
			self.addMethodToFile(meth, null);
		elseif constant &lt;&gt; null then
			self.addConstantToFile(constant, null);
		else
			self.addPropertyToFile(prop, null);
		endif;
		
	endwhile;
		
	self.documentC.writeToFile(file.fileName);	
	
	app.writeLog("Finished extracting details from " &amp; self.systemName &amp; ".", LogINFO);
	write "Finished extracting details from " &amp; self.systemName &amp; ".";

epilog

	if schemaColl &lt;&gt; null then
		schemaColl.clear();
	endif;
	delete schemaColl;

	delete classColl;
	delete typeColl;
	delete iter;
	delete constDict;
	delete file;
	delete fileFolder;

end;</source>
    </JadeMethod>
    <JadeMethod name="extractChangesOtherSystem" id="f25f9645-7de5-4828-bca9-c1a77bf5e86e">
        <source>extractChangesOtherSystem();

/*

Purpose:		Extract the changes from the other system		

Date			Who		Reason
08/09/2016		cnwmh5	Initial creation

*/

vars

	args						: StringArray;
	
	binDirectory				: String;
	command						: String;
	result						: Integer;

begin

	app.writeLog("Extracting details from other system.  Please wait...", LogINFO);
	write "Extracting details from other system.  Please wait...";

	// don't need to call so don't get into recursive call
	app.writeLog(method.qualifiedName() &amp; Tab &amp; 'dontCall: ' &amp; self.dontCall.String, LogINFO);
	write method.qualifiedName() &amp; Tab &amp; 'dontCall: ' &amp; self.dontCall.String;
	if self.dontCall then
		return;
	endif;
	
	// now get the details for the other system
	create args transient;
	if systemName = "WMAST" then
		self.externalProcessSetupSMAST("JMTExtractChangedDetails", binDirectory, command, args);			
	else
		self.externalProcessSetupWMAST("JMTExtractChangedDetails", binDirectory, command, args);		
	endif;
	
	node.createExternalProcess(binDirectory, '"' &amp;  command &amp; '"', args, null, true, true, result);
	
	if result &lt;&gt; 0 and result &lt;&gt; 4 then
		app.writeLog("Failed to extract from other system with result= " &amp; result.String &amp; ".  Aborting...", LogINFO);
		write "Failed to extract from other system with result= " &amp; result.String &amp; ".  Aborting...";
		return;
	endif;

	app.writeLog("Finished extracting details from other system.", LogINFO);
	write "Finished extracting details from other system.";
	
epilog

	delete args;

end;</source>
    </JadeMethod>
    <JadeMethod name="findMissingDetails" id="05a105c5-7e65-4311-ace2-27c0e08bb020">
        <updating/>
        <source>findMissingDetails() updating;

/*

Purpose:		Find the missing details so we can update the appropriate file	

Date			Who		Reason
08/09/2016		cnwmh5	Initial creation

*/

vars

	file						: File;
	
	fileName					: String;

begin

	fileName := self.fileName;

	// get and parse the xml docs
	create file transient;
	file.fileName := self.directoryName &amp; "\" &amp; self.fileName;
	self.documentC.parseFile(file.fileName);
	delete file;
	
	// get the other file
	if fileName[1:5] = "WMAST" then
		fileName[1:1] := "S";
	else
		fileName[1:1] := "W";
	endif;
	
	create file transient;
	file.fileName := self.directoryName &amp; "\" &amp; fileName;
	self.documentO.parseFile(file.fileName);
	delete file;
	
	self.compareChangesGlobalConstants();
	
	self.compareChangesSchemas();
	
epilog

	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="getGlobalConstantChanges" id="50d532ca-93e1-40e7-bce6-f3b8ecc1c1a2">
        <updating/>
        <source>getGlobalConstantChanges() updating;

/*

Purpose:		Get global constant changes	

Date			Who		Reason
14/09/2016		cnwmh5	Initial creation

*/

vars

	globalConst					: GlobalConstant;
	
	iter						: Iterator;
	
	currentCategoryName			: String;

begin

	foreach globalConst in GlobalConstant.instances discreteLock do
		if globalConst.cnGetModifiedTimeStamp() &lt; self.fromTS then
			continue;
		endif;
		self.categoryName := globalConst.getCategory().name;
		self.schemaName := globalConst.getCategory().cnEcGetSchema().name;
		if not self.diffGlobalConsts.includesKey(self.schemaName, self.categoryName, globalConst.name) then
			self.diffGlobalConsts.putAtKey(self.schemaName, self.categoryName, globalConst.name, globalConst);		
		endif;
	endforeach;
	
	delete iter;
	iter := self.diffGlobalConsts.createIterator;
	while iter.next(globalConst) do
	
		self.diffGlobalConsts.getIteratorKeys(self.schemaName, self.categoryName, self.constantName, iter);
				
		if currentCategoryName &lt;&gt; categoryName then
			self.elementGlobalCategoryC := elementGlobals.addElement(self.categoryName);
			self.elementGlobalCategoryC.addAttribute("Schema", self.schemaName);
			currentCategoryName := categoryName;		
		endif;
		
		self.addGlobalConstantToFile(globalConst, null);
		
	endwhile;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="reloadXMLDocuments" id="08497396-e645-4c3a-acd8-124a9e5ada21">
        <source>reloadXMLDocuments();

/*

Purpose:		Reload the XML Documents for comparison	

Date			Who		Reason
09/09/2016		cnwmh5	Initial creation

*/

vars

	fileName					: String;

begin

	fileName := self.fileName;

	self.documentC.parseFile(self.directoryName &amp; "\" &amp; fileName);
	
	// get the other file
	if fileName[1:5] = "WMAST" then
		fileName[1:1] := "S";
	else
		fileName[1:1] := "D";
	endif;

	self.documentO.parseFile(self.directoryName &amp; "\" &amp; fileName);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="removeCommentsFromSource" id="59115572-4465-4fec-9334-ece17406399a">
        <source>removeCommentsFromSource(_source: String): String;

/*
Purpose:			To remove the fluff from a method source. Fluff is comment text and the contents of string literals.
					This is for use when checking for leaking transients.
					The purpose of this is two-fold: to reduce the number of (1) tokens to be processed, and (2) false positives
					which occur when the 'never delete a line of code' brigade comment out foreach statements and replace them
					with while statements.

Return Value:		The defluffed source.

Date				Who			Reason
14 Jun 2005			cnwjub1		Creation
02 Sep 2008	cnwkpd1	"Borrowed" code from JSMS

*/

vars
	dq, sq, sa, ss, p, p1, sz, first, eol: Integer;
	src, str: String;

begin
	src:= _source;
	p:= 1;
	sz:= src.length;
	dq:= src.pos('"', 1);
	sq:= src.pos("'", 1);
	sa:= src.pos("/*", 1);
	ss:= src.pos("//", 1);
	while true do
		if dq &gt; 0 and dq &lt; p then
			dq:= src.pos('"', p);
		endif;
		if sq &gt; 0 and sq &lt; p then
			sq:= src.pos("'", p);
		endif;
		if sa &gt; 0 and sa &lt; p then
			sa:= src.pos("/*", p);
		endif;
		if ss &gt; 0 and ss &lt; p then
			ss:= src.pos("//", p);
		endif;
		first:= 0;
		p1:= sz + 1;
		if dq &gt; 0 then
			first:= 1;
			p1:= dq;
		endif;
		if sq &gt; 0 and sq &lt; p1 then
			first:= 2;
			p1:= sq;
		endif;
		if sa &gt; 0 and sa &lt; p1 then
			first:= 3;
			p1:= sa;
		endif;
		if ss &gt; 0 and ss &lt; p1 then
			first:= 4;
			p1:= ss;
		endif;
		if first = 1 then
			// Double quote: copy up to and including, then discard up to but not including match
			str:= str &amp; src[p:(p1-p+1)];
			p:= p1 + 1;
			if p &gt; sz then
				break;
			endif;
			dq:= src.pos('"', p);
			if dq &lt;= 0 then // No match
				break;
			endif;
			p:= dq + 1;
			str:= str &amp; '"';
		elseif first = 2 then
			// Single quote: copy up to and including, then discard up to but not including match
			str:= str &amp; src[p:(p1-p+1)];
			p:= p1 + 1;
			if p &gt; sz then
				break;
			endif;
			sq:= src.pos("'", p);
			if sq &lt;= 0 then // No match
				break;
			endif;
			p:= sq + 1;
			str:= str &amp; "'";
		elseif first = 3 then
			// Slash asterisk: copy up to but not including, then discard up to and including mate
			str:= str &amp; src[p:(p1-p)];
			p:= p1 + 2;
			if p &gt; sz then
				break;
			endif;
			sa:= src.pos("*/", p);
			if sa &lt;= 0 then // No match
				break;
			endif;
			p:= sa + 2;
		elseif first = 4 then
			// Slash slash: copy up to but not including, then discard up to but not including end of line
			str:= str &amp; src[p:(p1-p)];
			p:= p1 + 2;
			if p &gt; sz then
				break;
			endif;
			eol:= src.pos(Cr, p);
			if eol &lt;= 0 then // No end of line
				break;
			endif;
			p:= eol;
		else
			// No more: copy to end and exit
			str:= str &amp; src[p:end];
			break;
		endif;
		if p &gt; sz then
			break;
		endif;
	endwhile;
	return str;
end;</source>
        <Parameter name="_source" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateDoFullCompare" id="9bdfd11b-77a8-40a6-8bf2-4ae6b306527d">
        <updating/>
        <source>updateDoFullCompare(_value : Boolean) updating;

/*

Purpose:		Update doFullCompare	

Date			Who		Reason
09/09/2016		cnwmh5	Initial creation

*/

vars

begin
	
	self.doFullCompare := _value;
	
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateOtherOutputFile" id="72d144c2-2211-4349-b331-d30570c71553">
        <source>updateOtherOutputFile();

/*

Purpose:		Update the other file with the missing details	

Date			Who		Reason
09/09/2016		cnwmh5	Initial creation

*/

vars

	fileFolder				: FileFolder;
	file					: File;
	obj						: Object;
	
	args					: StringArray;
	
	iter					: Iterator;
	
	schemaName				: String;
	className				: String;
	objTypeName				: String;
	objName					: String;
	binDirectory			: String;
	command					: String;
	result					: Integer;

begin

	create file transient;
	file.fileName := self.directoryName &amp; "\DetailsToGet.csv";
	if file.isAvailable() then
		file.purge();
	endif;
	
	iter := self.missingItems.createIterator;
	while iter.next(obj) do
		
		self.missingItems.getIteratorKeys(schemaName, className, objTypeName, objName, iter);
		file.writeLine(schemaName &amp; "," &amp; className &amp; "," &amp; objTypeName &amp; "," &amp; objName);
	
	endwhile;
	file.close();
	
	// right go to the other system and update the details
	app.writeLog("Extracting additional details from other system.  Please wait...", LogINFO);
	write "Extracting additional details from other system.  Please wait...";

	// don't need to call so don't get into recursive call
	app.writeLog(method.qualifiedName() &amp; Tab &amp; 'dontCall: ' &amp; self.dontCall.String, LogINFO);
	write method.qualifiedName() &amp; Tab &amp; 'dontCall: ' &amp; dontCall.String;
	if self.dontCall then
		return;
	endif;
	
	// now get the details for the other system
	create args transient;
	if systemName = "WMAST" then
		self.externalProcessSetupSMAST("JMTExtractChangedDetailsAdd", binDirectory, command, args);			
	else
		self.externalProcessSetupWMAST("JMTExtractChangedDetailsAdd", binDirectory, command, args);		
	endif;
	
	node.createExternalProcess(binDirectory, '"' &amp;  command &amp; '"', args, null, true, true, result);
	
	if result &lt;&gt; 0 and result &lt;&gt; 4 then
		app.writeLog("Failed to extract from other system with result= " &amp; result.String &amp; ".  Aborting...", LogINFO);
		write "Failed to extract from other system with result= " &amp; result.String &amp; ".  Aborting...";
		return;
	endif;

	app.writeLog("Finished extracting additional details from other system.", LogINFO);
	write "Finished extracting additional details from other system.";
	
epilog

	delete fileFolder;
	delete file;
	delete iter;
	delete args;
	
end;</source>
    </JadeMethod>
</Class>
