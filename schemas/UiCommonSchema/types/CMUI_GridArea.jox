    <JadeMethod name="doColumnSelection" id="ad8385c3-dd93-4da4-b897-4c30a65a8484">
        <updating/>
        <source>doColumnSelection( gridColumn : CMUI_GridColumn input; button : Integer; shift : Integer; x : Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2008	cnwjk3	CCMS 1032

*/

vars
	fromColumn, 
	toColumn		: Integer;
begin

	if not shift.isControlKeyPressed and not shift.isShiftKeyPressed then			
		// Clear all selections
		self.allSelectedPoints.clear();
	endif;
	
	if shift.isShiftKeyPressed then
		if myLastColumnClicked &lt;&gt; null then 
			if gridColumn.column &lt; myLastColumnClicked.column then
				fromColumn := gridColumn.column;
				toColumn := myLastColumnClicked.column;
			else
				fromColumn := myLastColumnClicked.column;
				toColumn := gridColumn.column;		
			endif;
			while fromColumn &lt;= toColumn do
				allGridColumns[fromColumn].doSelection();
				fromColumn := fromColumn + 1;
			endwhile;
		endif;
	else
		gridColumn.doSelection();	
	endif;
	myLastColumnClicked := gridColumn;
	drawSelf();
end;</source>
        <Parameter name="gridColumn" type="CMUI_GridColumn" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doFlipH" id="7caf5813-715c-47a0-ae67-0fbbe2d2b456">
        <updating/>
        <source>doFlipH() updating;

vars
	idx, theRow, theCol : Integer;
	aColumn : CMUI_GridColumn;
	theObjects : ObjectArray;
	anObject : Object;
begin

	create theObjects transient;
	self.allGridColumns.copy(theObjects);
	foreach anObject in theObjects do
		aColumn := anObject.CMUI_GridColumn;
		aColumn.column := aColumn.column + 500;
	endforeach;
	idx := 0;
	foreach anObject in theObjects reversed do
		idx := idx + 1;
		aColumn := anObject.CMUI_GridColumn;
		aColumn.column := idx;
	endforeach;
epilog
	delete theObjects;
end;</source>
    </JadeMethod>
    <JadeMethod name="doFlipV" id="1243813e-d9f9-49d9-a578-6bddb3ef0b3e">
        <updating/>
        <source>doFlipV() updating;

vars
	idx, theRow, theCol : Integer;
	aRow : CMUI_GridRow;
	theObjects : ObjectArray;
	anObject : Object;
begin

	create theObjects transient;
	self.allGridRows.copy(theObjects);
	foreach anObject in  theObjects do
		aRow := anObject.CMUI_GridRow;
		aRow.row := aRow.row + 500;
	endforeach;
	idx := 0;
	foreach anObject in  theObjects reversed do
		idx := idx + 1;
		aRow := anObject.CMUI_GridRow;
		aRow.row := idx;
	endforeach;
epilog
	delete theObjects;
end;</source>
    </JadeMethod>
    <JadeMethod name="doRowSelection" id="708892f1-7c89-45b2-8e02-1e92404fe106">
        <updating/>
        <source>doRowSelection( gridRow : CMUI_GridRow input; button : Integer; shift : Integer; x : Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2008	cnwjk3	CCMS 1032

*/

vars
	fromRow, 
	toRow		: Integer;
begin

	if not shift.isControlKeyPressed and not shift.isShiftKeyPressed then			
		self.allSelectedPoints.clear();
	endif;
	
	if shift.isShiftKeyPressed then
		if myLastRowClicked &lt;&gt; null then 
			if gridRow.row &lt; myLastRowClicked.row then
				fromRow := gridRow.row;
				toRow := myLastRowClicked.row;
			else
				fromRow := myLastRowClicked.row;
				toRow := gridRow.row;		
			endif;
			while fromRow &lt;= toRow do
				allGridRows[fromRow].doSelection();
				fromRow := fromRow + 1;
			endwhile;
		endif;
	else
		gridRow.doSelection();	
	endif;
	myLastRowClicked := gridRow;
	drawSelf();
end;</source>
        <Parameter name="gridRow" type="CMUI_GridRow" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
