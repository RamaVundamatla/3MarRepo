        <updating/>
        <source>ecl032_CEF_mnuTblVCloneTop_cli():Integer updating;

vars
	mnuTblVCloneTop:MenuItem;
begin
	myCMUI_EDIForm_1.tblData.mouseDown(myCMUI_EDIForm_1.tblData, 2, 0, 141, 41);
	app.doWindowEvents(shortPause);
	myCMUI_EDIForm_1.tblData.contextMenu(myCMUI_EDIForm_1.tblData, myCMUI_EDIForm_1.tblData, true, 141, 41);
	app.doWindowEvents(shortPause);
	myCMUI_EDIForm_1.tblData.mouseUp(myCMUI_EDIForm_1.tblData, 2, 0, 141, 41);
	app.doWindowEvents(shortPause);
	mnuTblVCloneTop:=myCMUI_EDIForm_1.mnuTblVCloneTop.getMenuItem(111);
	if mnuTblVCloneTop.caption = 'Load to DB' and mnuTblVCloneTop.checked = false then
		myCMUI_EDIForm_1.mnuTblVCloneTop_click(mnuTblVCloneTop);
	endif;
	return 0;
end;</source>
