    <JadeMethod name="validateCreate" id="1478ce90-c6cb-4727-9629-1ecdb3698da0">
        <source>validateCreate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2011	cnwer1	Initial creation CCMS MES 1033
06 March  2015  cnwma1  PAR #35815 Error: 1090, While creating voyage Queue
*/

vars

begin
	inheritMethod(_passport);

	if self.myVoyage &lt;&gt; null then    // 06/03/2015   cnwma1 PAR #35815
		if (not self.isCraneQueue and not self.isWorkPointQueue) and self.myVoyage.myQueue &lt;&gt; null then
			app.raiseCMException1(Voyag_alrea_been_selec_voyag_q, self.myVoyage.myQueue.id,null,null);	
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="64768e25-0ff2-49c8-bf3f-b0930c58bde7">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	realObj : CM_VoyageQueue;
begin
	inheritMethod(_passport);

	
	if self.myVoyage = null then
	//	app.raiseCMException1(REQUIRED_FIELD,"voyage",null,null);
		app.raiseCMException(Input_required_field_voyage,null,null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if self.isCraneQueue() or self.isWorkPointQueue then
		return;
	endif;
	
	realObj := self.pxyGetRealObject;
	
	if realObj &lt;&gt; null and realObj.myVoyage &lt;&gt; self.myVoyage then
		if self.myVoyage.myQueue &lt;&gt; null then
			app.raiseCMException1(Voyag_alrea_been_selec_voyag_q, self.myVoyage.myQueue.id,null,null);	
		endif;	
	endif;		
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
