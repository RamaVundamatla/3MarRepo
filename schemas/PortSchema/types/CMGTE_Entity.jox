    <JadeMethod name="getCargoSubTypeCode" id="747a64fc-fd87-464b-aa6c-37025d2edaa4">
        <source>getCargoSubTypeCode() : String;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
01 May 2023			jlizm1	TFS 55453 Cargo uniqueness by subtype

*/

vars
	product : CM_Product;
	invalid	: Boolean; 
	
begin
	product := self.myProduct;
	if product = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception, product, invalid);
	
	product.fetchLatest;
	if invalid then
		return null;
	endif;
		
	return product.code;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
