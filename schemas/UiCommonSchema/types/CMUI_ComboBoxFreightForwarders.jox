    <JadeMethod name="displayEntry" id="6b46eab3-6854-42c7-bf90-6184124299dd">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; con : CM_ConsigneeConsignor; lstIndex: Integer): String updating, clientExecution;
//17 February 2010	cnwml2


vars

	 failedDAC  :CM_DataAccessController;

begin
	if con = null then
		return null;
	endif;
	
	if (not con.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;
	
	if con.isNotAvailableForEntry then
		if self.myObject &lt;&gt; con then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;
	
	if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then	//18 Oct 2013	NDL	Par 32594
		return con.getDescriptionTabCode;
	else
		return con.code &amp; Tab &amp; con.description;
	endif;
	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="con" type="CM_ConsigneeConsignor"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="38fe5b0f-4a96-453f-a5c7-5ff45ec31536">
        <source>getCollectionJMT(): Collection protected;
//17 February 2010	cnwml2
//+cnwml2 PAR22371

vars
	con : CM_ConsigneeConsignor;
begin
	self.allFreightFwders.clear();
	foreach con in app.myRoot.allConsigneeConsignors do
		if con.isFreightFwdr then
			self.allFreightFwders.add(con);
		endif;
	endforeach;
	return self.allFreightFwders;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="getListUpdateStatus" id="723dbd33-a741-40e9-88c9-9a98cdcab8dd">
        <source>getListUpdateStatus(): Boolean;
//18 February 2010	cnwml2
//+cnwml2 PAR22371

vars

begin
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setObject" id="1da4db7d-6da0-432e-b5da-2debcf20915c">
        <updating/>
        <source>setObject(_value: Object) updating;
//17 February 2010	cnwml2


vars
	value : Object;
begin
	value := _value;
	if value &lt;&gt; null then
		if not self.getCollectionJMT.includes(_value) then
			app.msgBox(app.getErrorString2(InvalidSettings, app.getString(FreightForwarder), value.CM_ConsigneeConsignor.code), app.getString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			value := null;
		endif;
	endif;
	
	inheritMethod(value);

epilog

end;</source>
        <Parameter name="_value" type="Object"/>
    </JadeMethod>
