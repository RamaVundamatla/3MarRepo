    <JadeMethod name="clearFields" id="811b4c65-a97a-4e86-a1af-1671be0e086c">
        <updating/>
        <source>clearFields()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers

*/

vars

begin
	self.setMyTrackedItem(null);
	self.setMyGenerator(null);
	self.txtCargoId.setFocus();
	self.txtCargoId.text := self.lblCargoId.caption.toUpper;
	self.txtGenerator.text := self.lblGeneratorId.caption.toUpper;
	self.showHideControls(true,false);
epilog

end;</source>
