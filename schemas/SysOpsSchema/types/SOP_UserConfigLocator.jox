    <JadeMethod name="applyColumnFilter" id="3faf81ea-9b26-4135-b6b0-2113b5ee16b5">
        <updating/>
        <source>applyColumnFilter(_table: CM_DataTable io): Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2014	cnwndl1	Initial creation

*/

vars

	visibleCount : Integer;

begin

	if _table &lt;&gt; null then
		if _table.allowsColumnFilters then
			visibleCount := _table.applyColumnFilter( self.allColumnFilters );
		endif;
	endif;
	
	return visibleCount;

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="assessMainCodeImportFile" id="7866138d-f1d6-4846-a104-2804100a5819">
        <source>assessMainCodeImportFile();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation  Work out what's in the file

*/

constants

	BLOCK_SIZE		: Integer = 1024;
	
vars

	inputFileName : String;
	inFile : File;
	block : String;
	tag : String;
	loadData : String;
	isNewTag : Boolean;
	index : Integer;
	tagData : String;
	count : Integer;
	tagArray : StringArray;
	intArray : IntegerArray;
	arrayIndex : Integer;
	msg : String;

begin

	inputFileName := self.txtMain.text;
	if inputFileName = null then
		return;
	endif;
	
	create inFile;
	inFile.fileName := inputFileName;
	//inFile.kind := 2;						// 1/3/16  cnwns1 PAR 36286 unicode version
	inFile.kind := File.Kind_Unknown_Text; 	// 1/3/16  cnwns1 PAR 36286 unicode version
	inFile.open;
	
	loadData := null;
	isNewTag := true; 
	create tagArray transient;
	create intArray transient;
	
	
	while not inFile.endOfFile() do
    	block := inFile.readString(BLOCK_SIZE);
    	loadData := loadData &amp; block;
    	///
    	while true do
	    	if isNewTag then
	    		tag := loadData.cnEcXmlExtractFirstTag();
	    		
                if tag = null then
                	break;
                endif;
                
	    		isNewTag := false;
	    	endif;
	    	
	        index := loadData.pos("&lt;/" &amp; tag &amp; "&gt;", 1);
	        
	        if index &gt; 0 then
	        	index := index + ("&lt;/" &amp; tag &amp; "&gt;").length;       

	        	if tagArray.includes(tag) then
					arrayIndex := tagArray.indexOf(tag);
					intArray[arrayIndex] := intArray[arrayIndex] + 1;
				else
					tagArray.add(tag);
					intArray.add(1);
				endif;
	        	
	        	if index &lt; loadData.length then
					loadData := loadData[index+1: end];
				else
					loadData := null;
				endif;
				
				isNewTag := true;
			else
				break;
			endif;
		endwhile;
		///
	endwhile;
	
	
	foreach index in 1 to tagArray.size do
		if msg &lt;&gt; null then
			msg := msg &amp; ", ";
		endif;
		msg := msg &amp; " " &amp; tagArray[index] &amp; " (x" &amp; intArray[index].String &amp; ")"; 
	endforeach;
	
	self.lblMessage.caption := "File has: " &amp; msg;

epilog

	if inFile &lt;&gt; null then
		inFile.close;
	endif;
	delete inFile;
	delete tagArray;
	delete intArray;

end;</source>
    </JadeMethod>
