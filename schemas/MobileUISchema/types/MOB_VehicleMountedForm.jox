    <JadeMethod name="doControlUnallocatedTask" id="01318670-87b7-4d52-a941-1c0aedab5daf">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_VehicleMountedDetails::doControlUnallocatedTask"/>
        </interfaceImplements>
        <updating/>
        <source>doControlUnallocatedTask() updating;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwer1	Initial creation
07/02/2011	cnwmh5		#26548 - Needs to return to main form rather than stay where it is
*/

vars
	row : Integer;
	theRow :JadeTableRow;
begin
	self.addInfoDisplay(app.getErrorString1(Message_from_control,app.getErrorString(Task_been_unallocated)));
	row:=self.tblTasks.fixedRows;
	while row &lt;= self.tblTasks.rows do
		theRow:=self.tblTasks.accessRow(row);
		theRow.visible:=true;
		row:=row+1;
	endwhile;
	
epilog

end;</source>
