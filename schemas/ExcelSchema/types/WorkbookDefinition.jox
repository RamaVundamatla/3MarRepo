    <JadeMethod name="setValues" id="db2bf264-2f03-4c62-9677-f72e260840e8">
        <updating/>
        <source>setValues(pRoot: Root;
		 pWBName	: String;
		 pWBDescription	: String;
		 pWBDataWS : String;
		 pWBHideDataWS : Boolean;
		 pWBTopWS 	: String;
		 pWBAppExtractOption : Object;
		 pWBAssocObject :Object;
		 pAssociatedObjectName : String;
		 pAssociatedObjectType : String) updating;

/*****************************************************
	Written by	:	cnwgrp1		04 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	if workbookName &lt;&gt; pWBName then
		workbookName := pWBName;
	endif;
	if workbookDescription 	&lt;&gt; pWBDescription then
		workbookDescription := pWBDescription;
	endif;
	if dataWorksheet &lt;&gt; pWBDataWS then
		dataWorksheet := pWBDataWS;
	endif;
	if hideDataWorksheet &lt;&gt; pWBHideDataWS then
		hideDataWorksheet 				:= pWBHideDataWS;
	endif;
	if topWorksheet &lt;&gt; pWBTopWS then
		topWorksheet := pWBTopWS;
	endif;
	if myApplicationExtractOptions &lt;&gt; pWBAppExtractOption then
		myApplicationExtractOptions := pWBAppExtractOption;
	endif;
	if myAssociatedObject &lt;&gt; pWBAssocObject then
		myAssociatedObject 				:= pWBAssocObject;
	endif;
	setAssociatedObjectName(pAssociatedObjectName);
	setAssociatedObjectType(pAssociatedObjectType);
	if myRoot &lt;&gt; pRoot then
		myRoot := pRoot;
	endif;

epilog

end;</source>
        <Parameter name="pRoot" type="Root"/>
        <Parameter name="pWBName" type="String"/>
        <Parameter name="pWBDescription" type="String"/>
        <Parameter name="pWBDataWS" type="String"/>
        <Parameter name="pWBHideDataWS" type="Boolean"/>
        <Parameter name="pWBTopWS" type="String"/>
        <Parameter name="pWBAppExtractOption" type="Object"/>
        <Parameter name="pWBAssocObject" type="Object"/>
        <Parameter name="pAssociatedObjectName" type="String"/>
        <Parameter name="pAssociatedObjectType" type="String"/>
    </JadeMethod>
