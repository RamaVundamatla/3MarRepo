<Class name="CM_StatusMessageReceived" id="f84ae82f-8b4c-4439-be26-5411f088835f">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <PrimAttribute name="code" id="576228e9-33c1-4edc-8b35-9ed83a793bd3">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="isUSCustomsMessage" id="ccdffcdb-1ac8-45ec-91c1-506b6fb985f9">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="quantity" id="0028b5b4-8855-4ca4-8ef3-beded5438692">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="quantityEntered" id="2b754bcd-1705-4825-a65b-c0be3bc14cc2">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="quantityRelease" id="16b116ca-9a3e-4490-8d77-cc95b72f7e67">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="transmitDate" id="07ff869c-3853-4be3-9ccc-c4aeba187b92">
