    <JadeMethod name="aatEdiInfo" id="5367e90c-e9dc-4cd3-9fd2-a0c52834bcfe">
        <source>aatEdiInfo();
vars
	lFile      		: File;
	counter			: Integer;
	ediInfo			: CM_InfoEDISent;
	parent			: String;
	tiOid			: String;
	clock			: String;
	camStr			: String;
	transDateStr	: String;
	transOid		: String;
begin
	clock  := app.clock.String;
	create lFile transient;
	lFile.fileName := "E:\aatTjmt\Logs\AAT-InfoEDI" &amp; clock &amp;".csv";
    lFile.open;
	
	lFile.writeLine(
					"Oid"    		 			&amp; Comma &amp;   //01
					"Created" 					&amp; Comma &amp; 
 	  				"Cam"						&amp; Comma &amp;
					"Trans Oid"						&amp; Comma &amp; 
					"Trans DT"						
					);	
	foreach ediInfo in CM_InfoEDISent.instances do 
		
		camStr 			:= null;
		transDateStr	:= null;
		transOid		:= null;
		
		if ediInfo.myCamProtocol &lt;&gt; null then
			camStr := ediInfo.myCamProtocol.description;
		endif;
		
		if ediInfo.myOtherTransaction &lt;&gt; null then
			transOid	 := ediInfo.myOtherTransaction.getOidAsString;
			transDateStr := ediInfo.myOtherTransaction.createdTime.String;
		endif;
		
		
		lFile.writeLine(ediInfo.getOidString  							&amp; Comma &amp;	//01
						ediInfo.createdTime.asStringJMT					&amp; Comma &amp;	//02
						camStr											&amp; Comma &amp;	//02
						transOid										&amp; Comma &amp;	//02
						transDateStr							
						);   //02

						
	
		counter := counter +1;
		if counter &gt; 1000000 then
			break;
		endif;
		
	endforeach;
	
	lFile.close;
epilog
	delete lFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="aatStateString" id="34d286b0-c1b0-4893-96a7-064a4f4ab212">
        <executionLocation>server</executionLocation>
        <source>aatStateString()serverExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2024		navma1	Initial creation

*/



vars
	lFile      		: File;
	counter			: Integer;
	state			: CM_StateString;
	parent			: String;
	tiOid			: String;
	clock			: String;
begin
	create lFile transient;
	lFile.fileName := "C:\TEMP\AAT\AAT-Extra" &amp; clock &amp;".csv";
    lFile.open;
	clock  := app.clock.String;
	lFile.writeLine(
					"Oid"    		 			&amp; Comma &amp;   //01
					"Created"  	  				&amp; Comma &amp;   //02
					"Key"  						&amp; Comma &amp;   //03
					"Value" 					&amp; Comma &amp;	//04
					"Parent"					&amp; Comma &amp;	//05
					"tiOid"
					);	
	foreach state in CM_StateString.instances do 
		
		if state.key.isOneOf(
			TrnsExtraDataContext,
			TrnsExtraDataAuditInfo ,
			TrnsExtraDataComment ,
			TrnsExtraDataAssignedRel ,
			TrnsExtraDataChild , 
			TrnsExtraDataDiscrepancy , 
			TrnsExtraDataReceiveTrain , 
			TrnsExtraDataReleaseTrain , 
			EDITranshipPort , 
			InvoiceNumber , 
			OrderNumber , 
			HSCode , 
			OperatorImportReleasePIN , 
			OperatorExportReleaseNumber , 
			BOL_ExtraData_OPID , 
			BOL_ExtraData_UnloadPoint)	then
			continue;
		endif;
		
		parent := null;
		tiOid  := null;
		
		
		if state.myParent&lt;&gt; null then
			parent := state.myParent.getName();
		endif;
		
		
		if state.myTrackedItem &lt;&gt; null then
			tiOid := state.myTrackedItem.getOidAsString;
		endif;
		lFile.writeLine(state.getOidString  							&amp; Comma &amp;	//01
						state.createdTime.asStringJMT					&amp; Comma &amp;   //02
						state.key  										&amp; Comma &amp;   //03
						state.value										&amp; Comma &amp;	//04
						parent											&amp; Comma &amp;	//05
						tiOid
						);
						
		counter := counter +1;
		if counter &gt; 1000000 then
			break;
		endif;
	endforeach;
	
	lFile.close;
epilog
	delete lFile;
end;
</source>
    </JadeMethod>
    <JadeMethod name="aatStateString1" id="4c33945d-db3f-4b69-a9f0-cbed8a477c52">
        <source>aatStateString1();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2024		navma1	Initial creation

*/

vars
	lFile      				  : File;
	counter					  : Integer;
	state					  : CM_StateString;
	parent					  : String;
	tiOid					  : String;
	trnsExtraDataContext,
	trnsExtraDataComment,
	trnsExtraDataAssignedRel,
	trnsExtraDataChild,
	trnsExtraDataDiscrepancy,
	trnsExtraDataReceiveTrain,
	trnsExtraDataReleaseTrain,
	trnsExtraDataAuditInfo,
	eDITranshipPort,
	invoiceNumber,
	hSCode,
	orderNumber,
	opid,
	unloadPoint,
	operatorImportReleasePIN,
	operatorExportReleaseNumber,
	cnt: Integer;
begin

	create lFile transient;
	lFile.fileName := "C:\TEMP\state-keys.csv";
    lFile.open;
	
	foreach state in CM_StateString.instances do 
		
		
		if state.key = TrnsExtraDataContext then  //1
			trnsExtraDataContext := trnsExtraDataContext +1 ;
		endif;
		
		if state.key = TrnsExtraDataAuditInfo then  //02
			trnsExtraDataAuditInfo := trnsExtraDataAuditInfo +1 ;
		endif;
		
		if state.key = TrnsExtraDataComment then      //03
			trnsExtraDataComment := trnsExtraDataComment +1 ;
		endif;
		
		if state.key = TrnsExtraDataAssignedRel then    //04
			trnsExtraDataAssignedRel := trnsExtraDataAssignedRel +1 ;
		endif;
		
		if state.key = TrnsExtraDataChild then          //05
			trnsExtraDataChild := trnsExtraDataChild +1 ;
		endif;
		
		if state.key = TrnsExtraDataDiscrepancy then    //06
			trnsExtraDataDiscrepancy := trnsExtraDataDiscrepancy +1 ;
		endif;
		
		if state.key = TrnsExtraDataReceiveTrain then   //07
			trnsExtraDataReceiveTrain := trnsExtraDataReceiveTrain +1 ;
		endif;
		
		if state.key = TrnsExtraDataReleaseTrain then	//08						
			trnsExtraDataReleaseTrain := trnsExtraDataReleaseTrain +1 ;
		endif;
	
		if state.key = EDITranshipPort then	//09						
			eDITranshipPort := eDITranshipPort +1 ;
		endif;
		
		if state.key = InvoiceNumber then	//10						
			invoiceNumber := invoiceNumber +1 ;
		endif;
		
		if state.key = OrderNumber then	//11						
			orderNumber := orderNumber +1 ;
		endif;
		
		if state.key = HSCode then	//12						
			hSCode := hSCode +1 ;
		endif;
		
		if state.key = OperatorImportReleasePIN then	//13						
			operatorImportReleasePIN := operatorImportReleasePIN +1 ;
		endif;
		
		if state.key = OperatorExportReleaseNumber then	//14						
			operatorExportReleaseNumber := operatorExportReleaseNumber +1 ;
		endif;
		
		if state.key = BOL_ExtraData_OPID then	//15						
			opid := opid +1 ;
		endif;
		
		
		if state.key = BOL_ExtraData_UnloadPoint then	//16						
			unloadPoint := unloadPoint +1 ;
		endif;
		

	endforeach;
	
	lFile.writeLine(TrnsExtraDataContext 		&amp; Comma &amp; trnsExtraDataContext.String);
	lFile.writeLine(TrnsExtraDataAuditInfo		&amp; Comma &amp; trnsExtraDataAuditInfo.String);
	lFile.writeLine(TrnsExtraDataComment		&amp; Comma &amp; trnsExtraDataComment.String);	
	lFile.writeLine(TrnsExtraDataAssignedRel	&amp; Comma &amp; trnsExtraDataAssignedRel.String);		
	lFile.writeLine(TrnsExtraDataChild			&amp; Comma &amp; trnsExtraDataChild.String);	
	lFile.writeLine(TrnsExtraDataDiscrepancy	&amp; Comma &amp; trnsExtraDataDiscrepancy.String);		
	lFile.writeLine(TrnsExtraDataReceiveTrain	&amp; Comma &amp; trnsExtraDataReceiveTrain.String);	
	lFile.writeLine(TrnsExtraDataReleaseTrain	&amp; Comma &amp; trnsExtraDataReleaseTrain.String);	
	lFile.writeLine(EDITranshipPort				&amp; Comma &amp; eDITranshipPort.String);	
	lFile.writeLine(InvoiceNumber				&amp; Comma &amp; invoiceNumber.String);	
	lFile.writeLine(OrderNumber					&amp; Comma &amp; orderNumber.String);	
	lFile.writeLine(HSCode						&amp; Comma &amp; hSCode.String);	
	lFile.writeLine(OperatorImportReleasePIN	&amp; Comma &amp; operatorImportReleasePIN.String);	
	lFile.writeLine(OperatorExportReleaseNumber	&amp; Comma &amp; operatorExportReleaseNumber.String);	
	
	lFile.writeLine(BOL_ExtraData_OPID			&amp; Comma &amp; opid.String);	
	lFile.writeLine(BOL_ExtraData_UnloadPoint	&amp; Comma &amp; unloadPoint.String);	
epilog

	delete lFile;
end;</source>
    </JadeMethod>
