    <JadeMethod name="doesTIMatchMe" id="ac43e8c2-a8a5-414e-a141-b6c40d9cf2c3">
        <source>doesTIMatchMe(_cmifAutoPlan : CMIF_YAAutoPlan input; _doNotLogAll : Boolean) : Boolean;
/*
Purpose:			
Date			Who			Reason
MARCH 2015		CNWAB1		Initial creation
20 Sept 2022 	navvt20 	ChangeRequest 54844: MTN - Invoice Allocation Logging
05 Oct 2022 	navma1		Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
23 Oct 2024		navlw1		JIRA-33107: Invoice Logging Use Levels
25 Feb 2025		navah1		Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	criteria		: CM_YACriteria;
	criteriaType	: CM_YACriteriaType;
	noMatch 		: Boolean;
	warningString 	: String;
	pod				: String;
	ti				: CM_TrackedItem;
	canLogExtra	    : Boolean;
	
begin
	canLogExtra := app.canLogExtraDetail();	
	if canLogExtra then								//25.02.2025 navah1	#34141	
		app.invLog("Checking Allocation - " &amp; self.description, LogINFO.String);   // 27 Sept 2022 navvt20 TFS 54845
	endif;

	ti 			:= _cmifAutoPlan.getMyTrackedItem();		   //05.10.2022 navma1 #52967
	
	if ti &lt;&gt; null then
		pod := ti.dischargePort;
	endif;
	
	foreach criteria in self.allCriteria do
		
		if not criteria.isCMIFAutoPlanDataMatch(_cmifAutoPlan) then		
			criteriaType := criteria.myYACriteriaType;
			
			// more verbose logging for mismatch of discharge port
			if criteriaType.isKindOf(CM_YATypeDischargePort) then		//05.10.2022 navma1 #52967
				warningString := app.getErrorString3(Does_not_match,criteriaType.description,pod,criteriaType.getDataDisplay(criteria.myYAData));	//05.10.2022 navma1 #52967
				_cmifAutoPlan.allLogging.add(warningString);
			else
				_cmifAutoPlan.allLogging.add(criteriaType.description);
			endif;
			if canLogExtra then		//05.10.2022 navma1 #52967
				app.invLog("Invoice Allocation No Match - " &amp; app.getErrorString1(Item_failed_match_criteri,criteria.getDescription()), LogINFO.String); 			// 20 Sept 2022 navvt20 TFS 54844
			endif;
			
			noMatch := true;
			if _doNotLogAll then
				break;
			endif;
		else  // 20 Sept 2022 navvt20 TFS 54844
			if canLogExtra then	  //05.10.2022 navma1 #52967
				app.invLog("Invoice Allocation Matched - " &amp; app.getErrorString1(Item_matched_criteria,criteria.getDescription()), LogINFO.String); 				 // 20 Sept 2022 navvt20 TFS 54844
			endif;
		endif;
	endforeach;
	
	return not noMatch;
end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan" usage="input"/>
        <Parameter name="_doNotLogAll" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
