    <JadeMethod name="getDatesAsLocalTime" id="772e3c99-1dc8-4d77-a42c-63cee6673f4a">
        <source>getDatesAsLocalTime(_arrivalDateTimeLocal, _departureDateTimeLocal, _estimatedArrivalDateTimeLocal, _estimatedDepartureDateTimeLocal : TimeStamp output);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
15 July 2024		navmd1	Initial creation TFS 65226 Move all date validation/logic to one place

*/

vars

begin
	if self.arrivalDT &lt;&gt; null and self.arrivalDT.isValid then
		_arrivalDateTimeLocal := self.arrivalDT.asLocalTimeStampJMT;
	endif;
	
	if self.departureDT &lt;&gt; null and self.departureDT.isValid then
		_departureDateTimeLocal := self.departureDT.asLocalTimeStampJMT;
	endif;
	
	_estimatedArrivalDateTimeLocal := null;
	if self.estimatedArrivalDT &lt;&gt; null and  self.estimatedArrivalDT.isValid then
		_estimatedArrivalDateTimeLocal := self.estimatedArrivalDT.asLocalTimeStampJMT;
	endif;
	
	_estimatedDepartureDateTimeLocal := null;
	if self.estimatedDepartureDT &lt;&gt; null and self.estimatedDepartureDT.isValid then
		_estimatedDepartureDateTimeLocal := self.estimatedDepartureDT.asLocalTimeStampJMT;
	endif;
epilog

end;</source>
        <Parameter name="_arrivalDateTimeLocal" type="TimeStamp" usage="output"/>
        <Parameter name="_departureDateTimeLocal" type="TimeStamp" usage="output"/>
        <Parameter name="_estimatedArrivalDateTimeLocal" type="TimeStamp" usage="output"/>
        <Parameter name="_estimatedDepartureDateTimeLocal" type="TimeStamp" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setPortRotationsForProxy" id="57aab434-d2a1-413f-bfc9-ddcd8c343237">
        <source>setPortRotationsForProxy(_pxyVoyage : CM_Voyage input; _trade : CM_Trade);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 July 2024		navmd1	Initial creation TFS 65226 Move Port Rotation code to centralised place

*/

vars
	portRotationObj		: WS_RestPortRotationObject;
	port				: CM_Port;
	pxyPortRotation,
	tradePortRotation	: CM_PortRotation;
	isOk				: Boolean;
begin
	if not self.portRotation.isEmpty then
		// loop through the port rotations on the request body
		foreach portRotationObj in self.portRotation do
			port := app.myRoot.allPorts[portRotationObj.id];
			if port &lt;&gt; null then
				if not portRotationObj.tranship then
					// for none tranship ports
					create pxyPortRotation transient;
					pxyPortRotation.setProxy(port, _pxyVoyage);
				elseif portRotationObj.tranship and pxyPortRotation &lt;&gt; null then
					// This works because portRotations is an ordered array!
					// add port to tranship collection if not already in collection
					if not pxyPortRotation.allTranshipPorts.includes(port) then
						pxyPortRotation.allTranshipPorts.add(port);
					endif;
				endif;
			endif;
		endforeach;
	else
		// Try and set the port rotation based on the trade
		if _trade &lt;&gt; null and not _trade.allPortRotations.isEmpty then
			foreach tradePortRotation in _trade.allPortRotations do 
				create pxyPortRotation transient;
				pxyPortRotation.setProxy(tradePortRotation.myPort, _pxyVoyage);
			endforeach;
		endif;
	endif;
	
	isOk := true;
epilog
	if not isOk then
		// There are children on voyage, so the rest will get cleaned up when voyage is deleted
		delete pxyPortRotation;
	endif;
end;</source>
        <Parameter name="_pxyVoyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_trade" type="CM_Trade"/>
    </JadeMethod>
    <JadeMethod name="validateRequest" id="490c08ca-8a55-47dc-b2ee-f6b5772e06e6">
        <source>validateRequest() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 July 2024		navmd1	Initial creation TFS 65226 Move common validation to one place

*/

vars
	vesselObj		: WS_RestVesselObject;
	portRotationObj	: WS_RestPortRotationObject;
begin
	if self.id = null then
		app.raiseCMException1(REQUIRED_FIELD, "Voyage Id", null, null);
		return false;
	endif;
	
	vesselObj := self.vessel;
	if vesselObj = null or vesselObj.id = null then
		app.raiseCMException1(REQUIRED_FIELD, "Vessel Id", null, null);
		return false;
	endif;
	
	// New/Unknown vessel then make sure we have an Operator and LOA
	if app.myRoot.allVessels[vesselObj.id.toUpper] = null then
		app.writeLog(method.qualifiedName &amp; " Vessel [" &amp; vesselObj.id &amp; "] not found", LogDEBUG);
		// check that we have a vessel id
		if vesselObj.operatorId = null then
			app.raiseCMException1(REQUIRED_FIELD, "Vessel Operator Id", null, null);
			return false;
		endif;
	
		// check that we have a vessel LOA
		if vesselObj.loa = null then
			app.raiseCMException1(REQUIRED_FIELD, "Vessel LOA ", null, null);
			return false;
		endif;
	endif;
	
	// Port Rotation Ids
	if not self.portRotation.isEmpty then
		foreach portRotationObj in self.portRotation do				
			if portRotationObj.id = null then
				app.raiseCMException1(REQUIRED_FIELD, "Port Rotation Id", null, null);
				return false;
			endif;
		endforeach;
	endif;

	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
