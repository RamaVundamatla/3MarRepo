    <JadeMethod name="checkBaySet" id="eb74b7f5-fe6e-4ab7-86f9-587f6f74fa5d">
        <source>checkBaySet() protected;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     This method is responsible for checking that the bays belonging to a baySet are adjacent
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
 
vars
	bay:CM_Bay;
	associate: CM_BayDefn;
	aHold : CM_Hold;
	aMess, bayTypeStr : String;
//  	tForwardBay: CM_BayDefn;
begin
	if self.bayType = BAY_TYPE_SINGLE then
		return;
	endif;
	aHold := self.myHold;
	if aHold.allBays = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_INVALID_BAYTYPE, null, null);
		return;
	endif;
	//------------------
	//For all bays in the old associated set (except the head) check that they
	// are in the same position
	//------------------

	foreach bay in aHold.allBays do
		aMess := aMess &amp; bay.id &amp; " ";
	endforeach;
	aMess := app.getErrorString(CM_Too_Many_Bays) &amp; aMess;

	if self.bayType = BAY_TYPE_TWIN then
		bayTypeStr := app.getErrorString(CM_Twin);
		if aHold.allBays.size &gt; 2 then
//			app.raiseCMException1(ERR_BAY_ORDER, self.id, null, null);
			// ### PAR 8931
 			app.raiseCMException6(ERR_BAYS_IN_HOLD, self.id,bayTypeStr, aHold.ordinalHold.String,aHold.ordinalHold.String,	
									aHold.allBays.size.String,  aMess, null, null);
			
		endif;
	endif;
	if self.bayType = BAY_TYPE_TRIPLE then
		bayTypeStr := app.getErrorString(CM_Tripple);
		if aHold.allBays.size &gt; 3 then
//			app.raiseCMException1(ERR_BAY_ORDER, self.id, null, null);
			// ### PAR 8931
			app.raiseCMException6(ERR_BAYS_IN_HOLD, self.id,bayTypeStr, aHold.ordinalHold.String,aHold.ordinalHold.String,	
									aHold.allBays.size.String,  aMess, null, null);
			
		endif;
	endif;

	// if this is a twin type and I am first then check that my forward bay is the next in the hold
	if self.isFirstInHold() then
		associate := self.myAftBay.CM_BayDefn;
	elseif self.isAftBay then
		associate := self.myForwardBay.CM_BayDefn;
	endif;

	if associate &lt;&gt; null then
		sharedLock(associate);
		if not aHold.allBays.includes(associate) then
//			app.raiseCMException1(ERR_BAY_ORDER, associate.id, null, null);
			// ### PAR 8931
			aMess := aMess &amp; app.getErrorString(CM_This_Does_Not_Include_Bay) &amp; associate.id;
			app.raiseCMException6(ERR_BAYS_IN_HOLD, self.id,bayTypeStr, aHold.ordinalHold.String,aHold.ordinalHold.String,	
									aHold.allBays.size.String,aMess, null, null);
		endif;	
	endif;	
epilog
	if associate &lt;&gt; null then
		unlock(associate);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cloneMySelf" id="8d1c5ffd-3651-49aa-98f8-a78983800765">
        <updating/>
        <source>cloneMySelf(_vessel:CM_CellularVesselStructure):SelfType updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	newBayDefn: SelfType;
	slotDefnVessel, newSlotDefn, pxySlotDefn: CM_SlotDefnVessel;
	slotDefn: CM_SlotDefn;
	cellDefn, newCellDefn: CM_CellDefn;
	tierDefn, newTierDefn: CM_TierDefn;
	holdIndex : Integer;
	aPxyHold : CM_Hold;
begin
	newBayDefn := self.cloneSelf(false);
	holdIndex := self.myVesselCellular.allHolds.indexOf(self.myHold);
	
	newBayDefn.myVesselCellular := _vessel;
	aPxyHold := _vessel.allHolds[holdIndex];
	newBayDefn.setMyHold(aPxyHold);
	
	foreach cellDefn in self.allCellsOnDeckByOrdinal do
		newCellDefn := cellDefn.cloneMySelf();
		newCellDefn.setMyBay(newBayDefn,true);
	endforeach;
	foreach cellDefn in self.allCellsUnderDeckByOrdinal do
		newCellDefn := cellDefn.cloneMySelf();
		newCellDefn.setMyBay(newBayDefn,false);
	endforeach;
	foreach tierDefn in self.allTiersOnDeck do
		newTierDefn := tierDefn.cloneMySelf();
		newTierDefn.setMyBay(newBayDefn,true);
	endforeach;
	foreach tierDefn in self.allTiersUnderDeck do
		newTierDefn := tierDefn.cloneMySelf();
		newTierDefn.setMyBay(newBayDefn,false);
	endforeach;
	
	foreach slotDefn in self.allSlotsByOrdinal do
		slotDefnVessel := slotDefn.CM_SlotDefnVessel;
		pxySlotDefn := slotDefnVessel.pxyCreateUpdateProxy();

		create newSlotDefn;
		newSlotDefn.setMyBay(newBayDefn,slotDefn.ordinalDeck = DeckOnDeck);
		newSlotDefn.setForCreate(pxySlotDefn,app.myPassport);
		newSlotDefn.setFortyFrontBack(slotDefnVessel.fortyFront,slotDefnVessel.fortyBack); // PAR 9716. We are cloning so make exactly the same, (setForCraete tries to work it out)

		if slotDefn.ordinalDeck = DeckOnDeck then // PAR 7843 added
			tierDefn := newBayDefn.allTiersOnDeck[slotDefn.ordinalTier];
			cellDefn := newBayDefn.allCellsOnDeckByOrdinal[slotDefn.ordinalCell];
		else
			tierDefn := newBayDefn.allTiersUnderDeck[slotDefn.ordinalTier]; // PAR 7843 added
			cellDefn := newBayDefn.allCellsUnderDeckByOrdinal[slotDefn.ordinalCell]; // PAR 7843 added
		endif;
		newSlotDefn.setCellAndTierDefn(cellDefn,tierDefn);
		
		if slotDefnVessel.ordinalDeck = DeckOnDeck then
			newSlotDefn.setMyBay(newBayDefn,true);
		else
			newSlotDefn.setMyBay(newBayDefn,false);
		endif;
		
		delete pxySlotDefn;	//Cleanup, else we leak like sieve!
	endforeach;

	newBayDefn.updateSlotLinks;
	
	return newBayDefn;
epilog
	delete pxySlotDefn;
end;</source>
        <Parameter name="_vessel" type="CM_CellularVesselStructure"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="copyMySelf" id="f03242f7-e7fc-4b45-8111-363e4dce2e02">
        <updating/>
        <source>copyMySelf(_vessel:CM_CellularVesselStructure; _targetBay : SelfType input; _isTransient : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	slotDefnVessel, newSlotDefn, pxySlotDefn: CM_SlotDefnVessel;
	slotDefn: CM_SlotDefn;
	cellDefn, newCellDefn: CM_CellDefn;
	tierDefn, newTierDefn: CM_TierDefn;
	holdIndex : Integer;
	aPxyHold : CM_Hold;
begin
	holdIndex := self.myVesselCellular.allHolds.indexOf(self.myHold);
	
	_targetBay.myVesselCellular := _vessel;
	aPxyHold := _vessel.allHolds[holdIndex];
	_targetBay.setMyHold(aPxyHold);
	
	foreach cellDefn in self.allCellsOnDeckByOrdinal do
		newCellDefn := cellDefn.cloneSelf(_isTransient);
		newCellDefn.setMyBay(_targetBay,true);
	endforeach;
	foreach cellDefn in self.allCellsUnderDeckByOrdinal do
		newCellDefn := cellDefn.cloneSelf(_isTransient);
		newCellDefn.setMyBay(_targetBay,false);
	endforeach;
	foreach tierDefn in self.allTiersOnDeck do
		newTierDefn := tierDefn.cloneSelf(_isTransient);
		newTierDefn.setMyBay(_targetBay,true);
	endforeach;
	foreach tierDefn in self.allTiersUnderDeck do
		newTierDefn := tierDefn.cloneSelf(_isTransient);
		newTierDefn.setMyBay(_targetBay,false);
	endforeach;
	
	foreach slotDefn in self.allSlotsByOrdinal do
		slotDefnVessel := slotDefn.CM_SlotDefnVessel;
		pxySlotDefn := slotDefnVessel.pxyCreateUpdateProxy();

		if _isTransient then
			create newSlotDefn transient;
		else
			create newSlotDefn;
		endif;
		newSlotDefn.setMyBay(_targetBay,slotDefn.ordinalDeck = DeckOnDeck);
		newSlotDefn.setForCreate(pxySlotDefn,app.myPassport);

		if slotDefn.ordinalDeck = DeckOnDeck then // PAR 7843 added
			tierDefn := _targetBay.allTiersOnDeck[slotDefn.ordinalTier];
			cellDefn := _targetBay.allCellsOnDeckByOrdinal[slotDefn.ordinalCell];
		else
			tierDefn := _targetBay.allTiersUnderDeck[slotDefn.ordinalTier]; // PAR 7843 added
			cellDefn := _targetBay.allCellsUnderDeckByOrdinal[slotDefn.ordinalCell]; // PAR 7843 added
		endif;
		newSlotDefn.setCellAndTierDefn(cellDefn,tierDefn);
		
		if slotDefnVessel.ordinalDeck = DeckOnDeck then
			newSlotDefn.setMyBay(_targetBay,true);
		else
			newSlotDefn.setMyBay(_targetBay,false);
		endif;
		
		delete pxySlotDefn;	//Cleanup, else we leak like sieve!
	endforeach;

	_targetBay.updateSlotLinks;
	
epilog
	delete pxySlotDefn;
end;</source>
        <Parameter name="_vessel" type="CM_CellularVesselStructure"/>
        <Parameter name="_targetBay" type="SelfType" usage="input"/>
        <Parameter name="_isTransient" type="Boolean"/>
    </JadeMethod>
