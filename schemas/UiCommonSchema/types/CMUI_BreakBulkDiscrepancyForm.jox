    <JadeMethod name="doSaveOverage" id="96325afd-354a-45e2-a6b4-6791b30df38d">
        <updating/>
        <source>doSaveOverage():Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk
06/04/2023	navkc1	CR# 56431 Task 56441: UI - Discrepancy Form
17/05/2023	jlika1	TFS 56398 EUP - OUT - Overlanded Cargo Handling - Web
*/

vars
	quantity : Integer;
	theReturn : Integer;
	totalWeight : Decimal[14,4];
	cargoWeight : Decimal[14,4];
	tareWeight : Decimal[14,4];
	reason : String;
	isShortlanded : Boolean;
	isOverlanded : Boolean;
begin

	quantity := self.txtAmount.text.Integer;
	totalWeight := self.getWeightMovedKgs;
	if self.tblCargoWeight.visible and self.tblTareWeight.visible then	//26 Jan 2018	NDL	TFS 36697
		cargoWeight := self.tblCargoWeight.getConvertedValue();
		tareWeight := self.tblTareWeight.getConvertedValue();
	endif;
	
	reason := self.txtReason.text;
	
	isShortlanded := self.chkShortlanded.value; //06/04/2023	navkc1	CR# 56431 Task 56441
	isOverlanded  := self.chkOverlanded.value; // TFS 56398
	
	while true do 
	
		app.myTrxUA.trxBreakBulkOverage(self.myTrackedItem, self.class.name, quantity , totalWeight, cargoWeight, tareWeight, reason, isShortlanded, isOverlanded, true, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			break;			
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(BreakBulkDiscrepancy), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
		
	endwhile;
	return true;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="eventWeightChange" id="2370e691-44e7-4eff-908c-6fdab769dc8c">
        <source>eventWeightChange();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2013	cnwndl1	Initial creation	Par 33073

*/

vars

	dec,volume : Decimal [16,4];
	weight : Decimal [16,4];
	diff : Decimal [16,4];
	measure : CM_MeasurementType;
	convertedDiff : String;
	ct : CM_CargoType;
	cargoWeight : Decimal [16,4];
	cargoWeightDiff : Decimal [16,4];
	tareWeight : Decimal [16,4];
	tareWeightDiff : Decimal [16,4];
begin

	if self.myTrackedItem = null then
		self.lblTotalWtChg.caption := null;
		self.lblCargoWtChg.caption := null;
		self.lblTareWtChg.caption := null;
		return;
	endif;
	
	weight := self.myTrackedItem.totalWeight;
	ct:= self.myTrackedItem.myCargoType;
	if  ct.isBulkMulti and ct.isTrackByVolume then
		volume:=self.tblWeight.getConvertedValue();
		diff := (volume -  self.myTrackedItem.totalVolume);
	else
		dec :=  self.tblWeight.getConvertedValue();
		diff := (dec - weight);
	endif;
	
	
	measure := app.myRoot.allMeasurementTypesByShortName[self.tblWeight.getUnit];
	convertedDiff := app.convertMeasurementForDisplay( measure.shortName, diff);
	
	if diff = 0 then
		self.lblTotalWtChg.caption := null;
	else
		self.lblTotalWtChg.caption := convertedDiff;
	endif;
	
	//25 Jan 2018	NDL	TFS 36697
	if self.tblCargoWeight.visible then
		measure := app.myRoot.allMeasurementTypesByShortName[self.tblCargoWeight.getUnit];
		cargoWeight := self.myTrackedItem.weightCargo;
		dec := self.tblCargoWeight.getConvertedValue();
		cargoWeightDiff := (dec - cargoWeight);
		if cargoWeightDiff = 0 then
			self.lblCargoWtChg.caption := null;
		else
			convertedDiff := app.convertMeasurementForDisplay( measure.shortName, cargoWeightDiff);
			self.lblCargoWtChg.caption := convertedDiff;
		endif;
	endif;
	
	if self.tblTareWeight.visible then
		measure := app.myRoot.allMeasurementTypesByShortName[self.tblTareWeight.getUnit];
		tareWeight := self.myTrackedItem.weightTare;
		dec := self.tblTareWeight.getConvertedValue();
		tareWeightDiff := (dec - tareWeight);
		if tareWeightDiff = 0 then
			self.lblTareWtChg.caption := null;
		else
			convertedDiff := app.convertMeasurementForDisplay( measure.shortName, tareWeightDiff);
			self.lblTareWtChg.caption := convertedDiff;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getWeightMovedKgs" id="4adbdee4-0ceb-4401-8b5b-cdd2874e28c6">
        <source>getWeightMovedKgs() : Decimal;
/*
Date		Who		Reason
19/03/2014	cnwer1	Initial creation PAR
03/10/2016	cnwdap1	TFS 2721 Setting weight to zero was not deleting a discrepancy TI
*/

vars
	ct : CM_CargoType;
	kgValue, volume  : Decimal[14,4];

begin
	if self.myTrackedItem = null then
		return null;
	endif;
	
	// TFS 2721 Default weight to current TI weight
	kgValue := self.myTrackedItem.totalWeight;				// TFS 2721
	
	if self.myTrackedItem.isBulkByVolume then
		volume:=self.tblWeight.getConvertedValue();
		kgValue:= volume * self.myTrackedItem.getDensity;

	else
		kgValue:=self.tblWeight.getConvertedValue();
	endif;
	
	// TFS 2721 Don't return TI weight here, this then over-writes the setting of weight to 0 
	// to delete a discrepancy
	//if kgValue = null then								// TFS 2721
	//	return self.myTrackedItem.totalWeight;				// TFS 2721
	//endif;												// TFS 2721
	return kgValue;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="9cfe33df-9f3b-4bc2-a87e-f2701af99470">
        <updating/>
        <source>setMyTrackedItem( _ti : CM_TrackedItem ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

	msg : String;

begin

	self.myTrackedItem := _ti;
	
	if _ti &lt;&gt; null and _ti.canMergeBreakBulk then
		self.lblExistingCargo.caption := _ti.id &amp; " (" &amp; _ti.totalQuantity.String &amp; ")";
		self.txtAmount.text := self.myTrackedItem.totalQuantity.String;
		self.tblWeight.setValueDefault( self.myTrackedItem.totalWeight.String );
		
		return true;
		
	else
		self.lblExistingCargo.caption := null;
		if _ti = null then
			msg := app.getErrorString(No_Cargo_selected);
		else
			msg := app.getErrorString(No_split_cargo_not_BB);
		endif;
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		self.unloadForm();
		return false;
		
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
