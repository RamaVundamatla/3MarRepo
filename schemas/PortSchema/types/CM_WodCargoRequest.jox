    <JadeMethod name="getInvoiceQuantityForWOExtra" id="c1fefc2c-fdee-41db-bb49-eaad6f6e119c">
        <source>getInvoiceQuantityForWOExtra(_chargeByUnits: Integer): Decimal;
/*
Purpose:	TFS 42221		
Date				Who			Reason
DECEMBER 2018		CNWAB1		Initial creation
*/

vars
	value :Real;
	lengthOfStay : Decimal[23,2];
begin
	lengthOfStay := self.getCurrentLengthOfTime();
	
	if _chargeByUnits = INV_CALC_TYPE_UNITY then
			value := 1.0;
	elseif _chargeByUnits = INV_CALC_TYPE_WO_UNITS then // TFS 42221 19DEC18
		if self.myCargoType &lt;&gt; null 
		and self.myCargoType.isBulkMulti() then
			value := self.totalWeight;
		else
			value := self.totalQuantity;
		endif;
	elseif _chargeByUnits = INV_CALC_TYPE_QUANTITY then
		value := self.totalQuantity;
	elseif _chargeByUnits = INV_CALC_TYPE_WEIGHT then
		value := self.totalWeight;
	elseif _chargeByUnits = INV_CALC_TYPE_WEIGHT_TON then
		value := self.totalWeight/1000;
	elseif _chargeByUnits = INV_CALC_TYPE_VOLUME then
		value := self.totalVolume;
	elseif _chargeByUnits = INV_CALC_TYPE_REVENUE_TONS then
		if (self.totalWeight/1000) &gt; self.totalVolume then
			value := self.totalWeight/1000;
		else
			value := self.totalVolume;
		endif;
	elseif _chargeByUnits = INV_CALC_TYPE_WO_ETMAL_DAYS then
		value := lengthOfStay;
	elseif _chargeByUnits = INV_CALC_TYPE_WO_ETMAL_HOURS then
		if lengthOfStay = 0 then
			return 0;
		endif;
		value := (lengthOfStay * 24);
		
	elseif _chargeByUnits = INV_CALC_TYPE_WO_ETMAL_MINUTES then
		if lengthOfStay = 0 then
			return 0;
		endif;
		
		value := ((lengthOfStay * 24) * 60);
	endif;

	
	return value;
epilog

end;</source>
        <Parameter name="_chargeByUnits" type="Integer"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getJobTypeDescription" id="ab67789f-a304-4a47-aeab-4661d48f1983">
        <source>getJobTypeDescription():String;
/*

