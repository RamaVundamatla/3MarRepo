    <JadeMethod name="doMnuEdiEditViewFile" id="5571e743-7943-4e23-950b-03fc32afbac8">
        <source>doMnuEdiEditViewFile();
//----------------------------------------------------------------
//	Created:	08 June 2004	by Jason Chapman  (cnwjc2)
//  Note: CustomsStop has only one type of EDITrackedItem. Only one
// 	EDITI tab - cnwgb1 Multiple record types MES 1011 September 2009
//----------------------------------------------------------------
/*

Date		Who		Reason
15 Dec 2014	cnwkpd1	PAR #34713 - Changes for .NET EDI Integration
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
*/
vars
	table		: CM_DataTable;
	rowPointer	: Integer;
	ediTI		: CM_EDICustomStopTI;
	tableObj	: Object;
	selectText	: String;
	fileData	: String;
	theLines : HugeStringArray;
begin
	table	:=	self.tblEDITI.getControl(0);
	rowPointer	:=	table.row;
	tableObj	:=	table.accessRow(rowPointer).itemObject;
	
	if tableObj &lt;&gt; null
	and CM_EDICustomStopTI.hasInstance(tableObj)
	then
		ediTI := tableObj.CM_EDICustomStopTI;
	else
		app.msgBox("You must select a Customs Stop entry that is in the file you want to display.", "Error", MsgBox_Stop_Icon);
		return;
	endif;
	
	if ediTI.myEDIFile = null then
		return;
	endif;
	
	if ediTI.cargoType = TI_CargoType_BreakBulk then
		selectText := ediTI.billOfLading;
	else
		selectText := ediTI.id;
	endif;
	
	// PAR #34713 - Allow for case where original message is not in allCompressedFileLines
	fileData := ediTI.myEDIFile.getOriginalFileDataString();
	if fileData &lt;&gt; null then
		app.msgBoxScroll(fileData, null, selectText,  "EDI File", 1);
	else
			create theLines transient;
			ediTI.myEDIFile.myEDIFileType.rawDataToHSA(ediTI.myEDIFile, theLines);
		app.msgBoxScroll(null, theLines, selectText,  "EDI File", 1);
	endif;
epilog
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuEdiFindTI" id="936b1833-2016-444d-b756-905aef806cfc">
        <source>doMnuEdiFindTI();
//----------------------------------------------------------------
//	Created:	29 March 2005	by Jason Chapman  (cnwjc2)
//  Note: Customs and Operator Stops only have one EDITrackedItem
//  type and hence only one data tab - cnwgb1 MES 1011
//  checked 26.9.09 cnwgb1
//
//	cnwdad1 09/04/2010 - Refactored because this wasn't written
//	properly and caused 1090 exceptions when trying to find an
//	Operator Stop's tracked item. Original code saved at end.
//----------------------------------------------------------------
vars
	cargoType	: Integer;
	cargoId		: String;
	masterTI	: CM_TrackedItem;
	table		: CM_DataTable;
	rowPointer	: Integer;
	ediTI		: CM_EDITrackedItem;
	tableObj	: Object;
	invalidTI	: Boolean; //par19446
	
begin
	table		:=	self.tblEDITI.getControl(0);
	rowPointer	:=	table.row;
	tableObj	:=	table.accessRow(rowPointer).itemObject;
	
	if tableObj &lt;&gt; null then
		if CM_EDICustomStopTI.hasInstance(tableObj) then
			ediTI		:=	tableObj.CM_EDITrackedItem;
			invalidTI	:=	ediTI.CM_EDICustomStopTI.getMyTrackedItem(masterTI);
		elseif CM_EDIOperatorStopTI.hasInstance(tableObj) then
			ediTI		:=	tableObj.CM_EDITrackedItem;
			invalidTI	:=	ediTI.CM_EDIOperatorStopTI.getMyTrackedItem(masterTI);
		else
			return;
		endif;
	else
		return;
	endif;
	
	if invalidTI = true then
		if app.msgBox('The cargo item this entry has been matched to has been deleted.' &amp; CrLf &amp; 'Would you like to search for the cargo item onsite?', 'Matched Entry Deleted', MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
			cargoId		:=	ediTI.id;
			cargoType	:=	ediTI.cargoType;
			masterTI	:=	self.myTerminal.allOnsiteTIsByCargoTypeId[cargoType, cargoId];
		else
			return;
		endif;
	else
		if masterTI = null then
			if app.msgBox('This entry has not been matched to a cargo item.' &amp; CrLf &amp; 'Would you like to search for the cargo item onsite?', 'Entry Not Matched', MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
				cargoId		:=	ediTI.id;
				cargoType	:=	ediTI.cargoType;
				masterTI	:=	self.myTerminal.allOnsiteTIsByCargoTypeId[cargoType, cargoId];
			else
				return;
			endif;
		endif;
	endif;
	
	if masterTI = null then
		app.msgBox('There is no cargo associated with this entry.', 'No Cargo Found', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.myAssistant.showCargoEnquiryForm(	masterTI,
											self.myMasterMenuAction,
											false,
											false);
end;
/*
//----------------------------------------------------------------
//	Created:	29 March 2005	by Jason Chapman  (cnwjc2)
//  Note: Customs and Operator Stops only have one EDITrackedItem
//  type and hence only one data tab - cnwgb1 MES 1011
//  checked 26.9.09 cnwgb1
//----------------------------------------------------------------
constants
	FIND_OPERATOR_STOP : String = "Operator";
	FIND_CUSTOM_STOP : String = "Custom";

vars
	cargoType	: Integer;
	id			: String;
	masterTI	: CM_TrackedItem;
	
	table		: CM_DataTable;
	lineText	: String;
	result		: Integer;
	row			: Integer;
	ediTI		: CM_EDICustomStopTI;
	ediTIOp		: CM_EDIOperatorStopTI;
	tableObj	: Object;
	strArray	: HugeStringArray;
//	cmString	: CM_LongString;
	selectText	: String; 
	searchType	: String;
	invalidTI	: Boolean; //par19446
	
begin
	table := self.tblEDITI.getControl(0);
	row := table.row;
	tableObj := table.accessRow(row).itemObject;
	
	if tableObj &lt;&gt; null then
		if CM_EDICustomStopTI.hasInstance(tableObj) then
			ediTI := tableObj.CM_EDICustomStopTI;
			searchType := FIND_CUSTOM_STOP;
		elseif CM_EDIOperatorStopTI.hasInstance(tableObj) then
			ediTIOp := tableObj.CM_EDIOperatorStopTI;
			searchType := FIND_OPERATOR_STOP;
		else
			return;
		endif;
	else
		return;
	endif;
	
	if searchType = FIND_CUSTOM_STOP then
		invalidTI := ediTI.getMyTrackedItem(masterTI); //par19446
	elseif searchType = FIND_OPERATOR_STOP then
		invalidTI := ediTIOp.getMyTrackedItem(masterTI);
	endif;
	
	if invalidTI = true then //par19446
		if app.msgBox('The cargo item his entry has been matched to has been deleted.' &amp; CrLf &amp; 'Would you like to search for the cargo item onsite?', 'Matched Entry Deleted', MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
			id := ediTI.id;
			cargoType := ediTI.cargoType;
			masterTI := self.myTerminal.allOnsiteTIsByCargoTypeId[cargoType, id];
		else
			return;
		endif;
	else
		if masterTI = null then
			if app.msgBox('This entry has not been matched to a cargo item.' &amp; CrLf &amp; 'Would you like to search for the cargo item onsite?', 'Entry Not Matched', MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
				id := ediTI.id;
				cargoType := ediTI.cargoType;
				masterTI := self.myTerminal.allOnsiteTIsByCargoTypeId[cargoType, id];
			else
				return;
			endif;
		endif;
	endif;
	
	if masterTI = null then
		app.msgBox('There is no cargo associated with this entry.', 'No Cargo Found', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.myAssistant.showCargoEnquiryForm(	masterTI,
											self.myMasterMenuAction,
											false,
											false);
end;
*/</source>
    </JadeMethod>
    <JadeMethod name="doMnuFormatClick" id="f613a2fe-76ed-493f-9af0-85a1be665e36">
        <updating/>
        <source>doMnuFormatClick(_fileFormat: CM_FileFormatEDI; _mnuItem: MenuItem) updating;
//----------------------------------------------------------------
//	Created:	17 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.doLoadAsFormat(_fileFormat);	
	
	

end;</source>
        <Parameter name="_fileFormat" type="CM_FileFormatEDI"/>
        <Parameter name="_mnuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuQueuedForBGP" id="0882ae0f-a771-41c7-b2f7-13b28ff3085d">
        <updating/>
        <source>doMnuQueuedForBGP() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP
*/

vars
	table : CM_DataTable;
	passport : CM_Passport;
	objArray : CM_ObjectArray;
 	valid : Boolean;
	result : Integer;
	object : Object;
	ediData : CM_EDIData;
	cmifMonitor : CMIF_Monitor;
	status : Integer;
begin
	passport := app.myPassport;
	table := self.tblData;
	if table.allSelectedObjects.size = 0 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'no current ediData object');	
		return;
	endif;
	
	create objArray transient;
	
	table.allSelectedObjects.copy(objArray);

	foreach object in objArray do 
		ediData := object.CM_EDIData;
		if ediData = null then
			return;
		endif;
		app.mousePointer := Window.MousePointer_HourGlass;
	
		while true do
			app.myTrxUA.trxSetEDIDataStatus(ediData, CM_EDIFile.EDI_STATUS_QUEUED_FOR_BGP);
			
			//passport.trxCompletedOK is a null value in this context, because the TRX call (trxSetEDIDataStatus) does not include the passport in its transaction, //22.Mar.24 navsp1 TFS 62781
			//So rather than using passport.trxCompletedOK, checking the value against the updated object to make sure the TRX call was success.   					//22.Mar.24 navsp1 TFS 62781
			if ediData.status = CM_EDIFile.EDI_STATUS_QUEUED_FOR_BGP then																		   					//22.Mar.24 navsp1 TFS 62781
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				break;
			else
				result := app.showErrorWarningDialog(app.getErrorString(QueuedForBGP), passport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if passport.noErrors and result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					passport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(passport);	// copies errors to this form and shows in err/warnings window
			endif;
			break;
		endwhile;
		if app.myPassport.trxCompletedOK then  
			ediData.causeEvent(EVENT_EDI_EDIDATA_UPDATE, true, ediData);
		endif;					
	endforeach;
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPrint" id="d3d6a9aa-2960-463c-a89a-98062f3ecebb">
        <updating/>
        <source>doPrint() updating;

vars
	tiReport	: CM_TIEnquiryOutput;
	progress	: CMS_Progress;
	now			: TimeStamp;
	ti 			: CM_TrackedItem;
	tmpReport	: JadeReport;
	tp			: CM_GenericTablePrint;
	///docType		: Integer;
begin
	if self.tblData.rows &lt;= self.tblData.fixedRows then
		app.msgBox('No items are currently listed','Nothing to print', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	now := self.systemToLocalTime(app.actualTimeServer());	// 13/6/16 cnwmp6 TFS 488 - Multi timezone support
	// 17/01/2011 cnwmh5 #26743
	///docType := app.printer.getDefaultDocumentType();
	///app.printer.abort();
	app.setPrinterDocumentType(false);
	
	create tmpReport transient;
	///app.printer.documentType := docType;			// 17/01/2011 cnwmh5 #26743
	app.printer.setMargins(Print_Landscape,10,10,10,10);
	app.printer.topOfPage := 1;
	app.printer.bottomOfPage := 1;
	app.printer.setReport(tmpReport);	//Capture for print preview.

	create tiReport transient;
	tiReport.initReport;
	tiReport.initReportForLandscape();	
	app.printer.setHeader(tiReport.frHeader);
	app.printer.setFooter(null);
	tiReport.lblPrintedBy.caption := app.getMyUserCode &amp; " - " &amp; now.String;
	
	tmpReport.description := "EDI Error/Warning List";
	tiReport.picLogo.picture := app.getPicLogoPort; // The bitmap called rptlogo.bmp in reports/formats
	tiReport.lblPrintedBy.caption := app.getMyUserCode &amp; " - " &amp; now.String;
	tiReport.lblCargoType.caption := 'EDI Error/Warning List';
	tiReport.lblTIID.caption := null;
	tiReport.lblCargoTypeLbl.visible := false;
	tiReport.lblTIIDlbl.visible := false;
	tiReport.lblTIID.visible := false;
		
	create tp transient;
	create progress transient;
	
	tp.printTable(self.tblEDITIError, true, progress);
		
	app.printer.close;
	app.printPreview(tmpReport, true);
	
epilog
	app.printer.close;
	delete progress;
	delete tp;
	delete tiReport;
	app.mousePointer := MP_DEFAULT;

end;</source>
    </JadeMethod>
    <JadeMethod name="doReLoadNew" id="26c2c0a4-9fc0-4c07-8a2c-adc45edb573e">
        <updating/>
        <source>doReLoadNew()updating;
//----------------------------------------------------------------
//	Created:	08 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	newEDIData	: CM_EDIData;
	cmifMonitor	: CMIF_Monitor;
	passport	: CM_Passport;
begin
	passport := app.myPassport;
	self.updateEDIFileIfChanged();
	
	self.initEDITables(0);

	if passport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		passport.setMyCMIFMonitor(cmifMonitor);
	endif;
			
	self.initModalDialog();
	self.lblModalMessage.caption := Cr &amp; "Reloading EDI file.";
	self.frmModalDialog.visible := true;
	
	app.doWindowEvents(0);
	
	newEDIData := self.myEDIAgent.reloadFileForTerminal(self.myEDIFileInError, passport); 
	
	if passport.allErrorWarnings.size &gt; 0 then
		//we are still in Mode_EditEDIFile
		self.showFileLoadErrors(passport);
//		passport.clearErrorsWarnings(); //cnwrs1 par17172 July 2008 we have just displayed the errors sont remove them yet
	else
		//app.msgBox("File reload successful.","File Reload",MsgBox_OK_Only + MsgBox_Information_Icon);
		self.staMain.caption := "File reload successful";
		self.mode := Mode_View;
		self.setControls();	
		
		app.doWindowEvents(0);
		
		self.selectTblDataObject(newEDIData);
		
		self.myEDIFileInError := null;
	
	endif;
	
epilog
	delete cmifMonitor;
	passport.setMyCMIFMonitor(null);
	self.closeModalDialog();
end;</source>
    </JadeMethod>
    <JadeMethod name="doRefreshWithTimer" id="a69cdbe3-1d2c-4eba-8a6f-6de71a607e96">
        <source>doRefreshWithTimer() protected;
//
// 27 Mar 2018	jlgrs1	TFS 37419 - QNS Sundry
//
vars

begin
	self.endTimer(self.EVENT_REFRESH);
	self.beginTimer(500, Timer_OneShot, self.EVENT_REFRESH);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doReloadEDIFile" id="f6445c7a-ff13-4fdb-b132-d2b6ea03226b">
        <updating/>
        <source>doReloadEDIFile(_reLoadFileInError : Boolean)updating;
//----------------------------------------------------------------
//	Created:	Jan 2007 CCMS 1049 cnwrs1
//----------------------------------------------------------------
/****Changes

Date		Name	TFS#			Description
============================================================================
16/12/2011 	cnwrs1  CCMS POL 2122 
					/ PAR 28696  	The reload of a rel req deletes the edidata
23/02/2012	cnwrs1	Par 29181 		Fix up Coparn reprocess
07/08/2012	cnwcs5	par 30136
08/10/2015	cnwrs1	Par 36863  		Make EDI consistant times when refreshing progress bar
06/07/2018 	JLGNS1	Bug 39173: 		MSL - Roro baplie not entirely loaded - HIGH PRIORITY
10/01/2018	jlgka1	42014			Set Filter Date based from the earliest loaded date
									of all selected files.
============================================================================*/
vars
	ediData 		: CM_EDIData;
	ediFile 		: CM_EDIFile;
	cmifMonitor		: CMIF_Monitor;
	passport		: CM_Passport;
	obj				: Object;
	objArray 		: ObjectArray;
	invalidEDIData, hasErrors 	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, ediData, invalidEDIData);
	
	passport := app.myPassport;

	if passport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		passport.setMyCMIFMonitor(cmifMonitor);
	endif;

	create objArray transient;
	
	if _reLoadFileInError then							//Bug 39173
		objArray.add(self.myEDIFileInError.ediData);	//Bug 39173
	else												//Bug 39173
		self.tblData.allSelectedObjects.copy(objArray);	//Bug 39173
	endif;												//Bug 39173
	
	setReloadDate(objArray); // jlgka1 TFS 42014
	
	foreach obj in objArray do
		invalidEDIData 	:= false;
		ediData 		:= obj.CM_EDIData;
		
		if ediData = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'no current ediData object');	
		endif;
		
		if ediData.myEDIFile = null then // ediFileArray.size &lt;&gt; 1 then // ccms1118 cnwrs1 29 Apr 2010
			app.raiseUnexpectedProgramError(class.name, method.name, 'no current ediFile object');	
		endif;
		
		self.initModalDialog();
		self.lblModalMessage.caption 	:= Cr &amp; "Reloading EDI file.";
		self.frmModalDialog.visible 	:= true;
		
		self.beginNotification(ediData, Object_Delete_Event, Response_Cancel, 0);

		passport.clearErrorsWarnings();
		hasErrors:=false;
		ediFile := ediData.myEDIFile; // ediFileArray[1]; // ccms1117 cnwrs1 29 Apr 2010
		
		self.myEDIAgent.reloadEDIFileForTerminal(ediFile, ediData, passport);	//23 Feb 2012	cnwrs1	Par 29181 Fix up Coparn reprocess
			
		if ediData.storePersistentErrors and 
			ediData.allErrorWarnings.size &gt; 0 then	// par 30136 Aug 2012, par 27392 13 Apr 2011
			//we are still in Mode_EditEDIFile
			self.showVerifyErrors(ediData);					// par 27392 13 Apr 2011
			hasErrors :=true;
		endif;
			
		if passport.allErrorWarnings.size &gt; 0 then
			//self.showFileLoadErrors(passport);
			app.showErrorWarningDialog('File Reload', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			//endif;
			hasErrors :=true;
		endif;
		
		if hasErrors then
			passport.clearErrorsWarnings();
		else
			self.staMain.caption 	:= "File reload successful";
			self.mode 				:= Mode_View;
			
			self.setControls();	
			app.doWindowEvents(0);

			self.myEDIFileInError 	:= null;
		endif;
		
		if invalidEDIData then
			continue;
		endif;
	endforeach;
	
	invalidEDIData 	:= false;
	ediFile 		:= ediData.myEDIFile; // to test ediData is valid
	
	if not invalidEDIData then
		self.selectTblDataObject(ediData);
	endif;
	
	self.ediTIDataNeedsRefresh := true; // TFS 40335
	self.showDataForCurrentObject(false); // TFS 40335
epilog
	passport.setMyCMIFMonitor(null);

	self.closeModalDialog();
	
	delete cmifMonitor;
	delete objArray;
end;</source>
        <Parameter name="_reLoadFileInError" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRemoveDeletedEDITIs" id="b7ab25d0-0e63-4124-9d93-8e637b84b917">
        <updating/>
        <source>doRemoveDeletedEDITIs(_ediData: CM_EDIData; _userInfo: Any)updating;
//----------------------------------------------------------------
//	Created:	10 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 13/03/2012	cnwdap1		PAR #29226 We don't know in this method what table the notification of delete 
//							has come from, so we have to look through all cloned tables, not just the first clone
//							We also match on oid now, not id, as not all EDI tracked items have ids
// 28/08/2012	cnwcs5		par 30134 - rework method to be more efficient and handle situation wheer userInfo can't store all deleted oids
// 27 Mar 2018	jlgrs1	TFS 37419 - QNS Sundry
constants
	DELETE_LIMIT_EXCEEDED 	= 'LIMIT EXCEEDED';
vars
	tbl		: CM_DataTable;
	intRow	: Integer;
	obj, deletedObj	: Object;
	sa		: StringArray;
	idx		: Integer;											// PAR #29226
	str		: String;			// par 30134
	set		: ObjectSet;		// par 30134
	redisplayAll	:Boolean;	// par 30134
begin
	// only refresh if we are displaying the EDI Data that caused the event
	if self.myDisplayedEDIData &lt;&gt; _ediData then
		return;
	endif;
	
	// create an array containing the oids as strings									
	if _userInfo = null or not _userInfo.isKindOf(String) then
		return;
	endif;
	
	// if too many items were deleted to pass back in_userInfo parameter we 
	// will just re-display everything
	redisplayAll := _userInfo.String = DELETE_LIMIT_EXCEEDED;
	
	if not redisplayAll then
		// get the oids as strings
		create sa transient;										// PAR #29226
		_userInfo.String.getTokensForDelimiter("^", sa);			// PAR #29226
	endif;
	
	if not redisplayAll then
		// create a set containing all the deleted EDI TIs
		// set.includes/remove is more efficient than array.includes/remove when we
		// remove deleted bjects below
		create set transient;
		
		foreach str in sa do
			// deleteObj is invalid
			deletedObj := str.asOid;
			
			set.add (deletedObj);
		endforeach;
	endif;
	
	// check all cloned tables, not just the first	
	while true do	:outerLoop
		tbl := self.tblEDITI.getControl(idx);					
		
		if tbl = null or not tbl.visible then					
			break outerLoop;												
		endif;	
		
		//epr TFS 2368 28/7/16
		if tbl.myDataClass = null then
			//if not data class then the table dynaDict will not have its membership set and will get 1319 exception if we continue
			idx := idx + 1;	
			continue;
		endif;
		// each table has a collection of objects it is displaying
		// if we are in the business of deleting the we should rebuild that collection
		// as it may contain deleted objects
		
		tbl.myDynaDict.removeInvalidObjects;	// PAR 30134:2
		
		if redisplayAll then
			// redisplay all EDI TIs - it will be faster
			// need to remember topRow and anything that was selected in the table
			self.showEDITIs (tbl);	// par 29842 Sep 2012
		else
			// just remove the deleted EDi TIs - we will go through each table
			// and look to see if each item in the table has been deleted
			intRow := tbl.fixedRows + 1;
		
			while intRow &lt;= tbl.rows do
				obj 	:= tbl.accessRow(intRow).itemObject;		
				// does the set include this object
				if set.includes (obj) then
					// remove row in table
					tbl.removeItem(intRow);	
					// remove EDI TI from set 
					set.remove (obj);
					// if set is empty there is nothing else to do
					if set.isEmpty then
						//  we are done
						break outerLoop;
					endif;
				else
					// look in the next row
					intRow := intRow + 1;
				endif;
			endwhile;
		endif;
		// check out the next table
		idx := idx + 1;										
	endwhile;												
	
	// of course if we have deleted some EDI TIs then we should also update the display for the EDI Data
	_ediData.causeEvent(EVENT_EDI_EDIDATA_UPDATE, true, _ediData);
//	self.updateTblData (_ediData);
epilog
	delete sa;	
	delete set;	// par 30134
end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doRemoveOthers" id="bba8c8fc-d5eb-49d2-95b9-6851537aaec2">
        <updating/>
        <source>doRemoveOthers() updating;
// ---------------------------------------------------------------------------
// Created:     01 July 2002 by cnwrs1
//
// Purpose:		Remove all edi TrackedItem that will not be discharged at this port  
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 05/05/2010	cnwcs5		par 23580 - use trx method for updating
// ---------------------------------------------------------------------------

vars
	ediData			: CM_EDIData;
	answer			: Integer;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin

	answer := app.msgBox(app.getErrorString2(ConfirmDelete, 'non-discharge', 'tracked items'), 'Delete Tracked Items', MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	
	if answer = MsgBox_Return_Yes then
		ediData := self.myCurrentObject.CM_EDIData;
		
		//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxEDILeaveMyContainers(ediData.CM_EDIDataBayPlan, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog(self.mnuRemoveOthers.caption, app.myPassport, ErrWarnMode_Delete);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
	
	endif;
	
	//will have to do for now
	self.ediTIDataNeedsRefresh 	:= true;
	self.myDisplayedEDIData 	:= null;
	
	self.showDataForCurrentObject(false);	
end;</source>
    </JadeMethod>
    <JadeMethod name="doReplaceAll" id="3be851e9-3bdd-4fc5-b26f-d6e04ca25856">
        <updating/>
        <source>doReplaceAll() updating;
//----------------------------------------------------------------
//	Created:	06 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	numRows,
	intRow,
	count			: Integer;
	strCol,
	strFind,
	strReplace		: String;
	cmif_FindReplace: CMIF_Object;
	fullWord,
	selectedOnly	: Boolean;
	index : Integer;
begin
	numRows := self.tblMultiReplace.rows;
	
	foreach intRow in 2 to numRows do
		count		:= 0;
		strCol		:= self.tblMultiReplace.accessCell(intRow,1).text;
		strFind		:= self.tblMultiReplace.accessCell(intRow,2).text;
		strReplace	:= self.tblMultiReplace.accessCell(intRow,3).text;
		fullWord	:= self.tblMultiReplace.accessCell(intRow,4).text.Boolean;
		selectedOnly:= self.tblMultiReplace.accessCell(intRow,5).text.Boolean;
		
		if self.isDataSheetDisplayed(index) then //cnwgb1 30.9.09 MES 1011 Par 20320 Handle cloned tables
			count := self.doEDIDataReplace(self.tblEDITI.getControl(index), strCol, strFind, strReplace, fullWord, selectedOnly);
		elseif self.fldDetail.topSheet = self.shtEDIFile then
			count := self.doEDIFileReplace(self.tblFileLine, strCol, strFind, strReplace, fullWord);
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'unsupported mode for Find/Replace');
		endif;	
		
		
		self.tblMultiReplace.accessCell(intRow,6).text := count.String;
		self.tblMultiReplace.accessRow(intRow).backColor := LightBlue;
		if count &gt; 0 then
			self.tiDataHasChanged := true;
		endif;
	endforeach;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="971acd39-098d-48e9-ab6a-5b953a33bcbe">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		20 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 14/10/2009	cnwcs5	par 20836 - re-parent verify error table
// 02/12/2009	cnwmh5	PAR21651 - 
constants
	GAP : Real = 10;
vars
	topVal		: Real;
	widthVal	: Real;
	buttonTop	: Real;
begin

	inheritMethod();
	
	self.sptFile.move(0,0,self.sptFile.parent.Control.clientWidth,self.sptFile.parent.Control.clientHeight - (self.WinBottomMargin + self.btnReLoad.height));	// par 20836
	self.sptData.move(0,0,self.sptData.parent.Control.clientWidth,self.sptData.parent.Control.clientHeight);	// par 20836

	buttonTop := self.sptFile.height + 25;
	
	self.btnReLoad.move(self.WinLeftMargin, buttonTop, 90,25);
	self.btnCancelLoad.move((self.WinLeftMargin*2) + 90, buttonTop, 90,25);

	self.tblFileLine.accessColumn(self.COLUMN_DATA).width := self.tblFileLine.clientWidth; //par17172 cnwrs1 July 2008
	
	self.sptFile.cnEcResizeContents();
	self.sptData.cnEcResizeContents();
	
	// set the load file / find replace frames control top/left/height correctly
	self.setFrmFindRCntrlsTopLeftHeight();			// 20/12/2009 cnwmh5 #21651
	self.setFrmLoadFileCntrlsTop();					// 20/12/2009 cnwmh5 #21651
	
	self.frmLoadFile.left := ((self.width / 2) - (self.frmLoadFile.width /2));
end;</source>
    </JadeMethod>
    <JadeMethod name="doRevokeEDIData" id="2f3a73cc-f2b2-4497-a676-a8527b49d710">
        <updating/>
        <source>doRevokeEDIData() updating;
/*

Purpose:			

Parameters:			

Return Value:		
Date		Who		Reason
14 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
26 oct 2022 navvt20 ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars
	ediData		: CM_EDIData;
	passport	: CM_Passport;
	result		: Integer;
begin
	passport := app.myPassport;
	ediData := self.myCurrentObject.CM_EDIData;
	if ediData = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'no current ediData object');	
	endif;
	if not ediData.canBeRevoked() then
		app.raiseCMException(EDIFile_Incorrect_Status_Revok, null, null);
		return;
	endif;
	
	while true do
		app.myTrxUA.trxSetEDIDataStatus(ediData, CM_EDIFile.EDI_STATUS_REVOKED);
		if passport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString (EDI_Set_To_Revoke), passport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if passport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				passport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(passport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	if app.myPassport.trxCompletedOK then  // 26 Oct 2022 navvt20 TFS 55084
		ediData.causeEvent(EVENT_EDI_EDIDATA_UPDATE, true, ediData);
	endif;	// 26 Oct 2022 navvt20 TFS 55084				
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="dda0192f-44be-4a13-bfd6-fe01a9c9eccc">
        <updating/>
        <source>doSave(): Boolean updating;
//----------------------------------------------------------------
//	Created:	02 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	return self.doSaveEDIDataDetails();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveAndVerify" id="2886899b-b880-46c3-9a42-4e5faf8b02eb">
        <updating/>
        <source>doSaveAndVerify() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Mar 2006			by Jason Chapman  (cnwjc2)up
27 Mar 2020 cnwma1  Bug 48970: SNO - Save and Verify Issue

*/
vars

begin

	//if self.doSaveEDIDataDetails() then  //27.03.2020 cnwma1 #48970
	
	self.doSaveEDIDataDetails();
	if app.myPassport.noErrors then        //27.03.2020 cnwma1 #48970
		self.doVerifyEDITIs();	
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveEDIDataDetails" id="9d289643-9960-400d-9f0c-5ae60c2012af">
        <updating/>
        <source>doSaveEDIDataDetails(): Boolean updating;
//----------------------------------------------------------------
//	Created:	02 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 05 January 2017	jlgrh7 TFS #36404  C3 - Vessel field dropping second word from Baplie
// 17 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator
// 17 Apr 2023  navmp20 Bug 56230: MTN - String Too Long Error When Verifying Load/Discharge List EDI
// 09 Aug 2023	navra1	TFS 59666 - EUP - CallOff fields not available in the column organiser
// 25 Aug 2023	navdap1	TFS 60021 EUP - Unable to edit CallOff EDI message via EDI Operations
vars
	proxyEDIData	: CM_EDIData;
	loadState		: Boolean;
	ediDataDetails	: CMIF_EDIDataDetails;
	cmifMonitor		: CMIF_Monitor;
	passport		: CM_Passport;
	saveOK			: Boolean;
	ediData		 	: CM_EDIData;
	theResult 		: Integer;	//13 Jan 2020 NDL	TFS 46815
	op 				: CM_Operator;
begin

	saveOK 			 := false;
	app.mousePointer := MP_HOURGLASS;
	passport 		 := app.myPassport;
	
	app.cmsBeginLoad(loadState);
	proxyEDIData := self.myCurrentObject.CM_EDIData.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);

	create ediDataDetails transient;

	// ### TFS CR 56806 TASK 56807 01MAR2023 NAVAB1 - getConfig(ComboByNameOperator) break this if it is DESC - CODE
	op := self.cmbOperator.listObject.CM_Operator;
	//if op &lt;&gt; null then
	if op &lt;&gt; null and not app.myRoot.getConfig(ComboByNameOperator).Boolean then     //17.04.2023 navmp20 TFS 56230
		ediDataDetails.setOperator(op.code);
	else
		ediDataDetails.setOperator(self.tblEDIDetails.getValueByName(ETRow_OperatorCode).String);
	endif;
	//PAR21446 - cnwsh3 for US Customs Loading
	if self.tblEDIDetails.isRowVisible(ETRow_VoyageCodeSystem) then
		ediDataDetails.voyage := self.tblEDIDetails.getValueByName(ETRow_VoyageCodeSystem).String;
	else
		ediDataDetails.voyage := self.tblEDIDetails.getValueByName(ETRow_VoyageCode).String;
	endif;
	//ediDataDetails.vessel		:= self.tblEDIDetails.getValueByName(ETRow_VesselName).String; 							//-TFS36404	 only the first bit of name
	if self.cmbVessel.getCurrentItemObject &lt;&gt; null then																												//+TFS36404 To Get Full Name
		ediDataDetails.vessel	:= self.cmbVessel.getCurrentItemObject.CM_Vessel.name[1:30];
	endif;
	ediDataDetails.shipperCode := self.tblEDIDetails.getValueByName(ETRow_ShipperDesc).String; 
	if ediDataDetails.shipperCode = null then //par16270 cnwrs1 Mar 2008
		ediDataDetails.shipperCode := self.tblEDIDetails.getValueByName(ETRow_OperatorCode).String;
	endif;
	//th2 for user defined EDI data
	if self.cmbSite.listIndex &gt; 0 then //rs1 aug 2006
		ediDataDetails.createToSite	:= self.cmbSite.itemData[self.cmbSite.listIndex]; 
	endif;

	//navra1 - TFS 59666 - 9th Aug 2023 - start
	if self.tblEDIDetails.isRowVisible(ETRow_Vehicle) then
		ediDataDetails.vehicleNumber := self.tblEDIDetails.getValueByName(ETRow_Vehicle).String;
	endif;
	if self.tblEDIDetails.isRowVisible(ETRow_VbsNumberExternal) then
		ediDataDetails.transportReferenceCustomer := self.tblEDIDetails.getValueByName(ETRow_VbsNumberExternal).String;
	endif;
	if self.tblEDIDetails.isRowVisible(ETRow_VbSlotType) then
		ediDataDetails.vbSlotType := self.tblEDIDetails.getValueByName(ETRow_VbSlotType).String;
	endif;
	//navra1 - TFS 59666 - 9th Aug 2023 - end

	// cnwrs1 june 2006 new port code
	if self.cmbToPort.myObject &lt;&gt; null then
		ediDataDetails.dischargePort := self.cmbToPort.myObject.CM_Port.code;
	endif;
	if self.cmbFromPort.myObject &lt;&gt; null then
		ediDataDetails.loadPort	:= self.cmbFromPort.myObject.CM_Port.code;
	endif;
	ediDataDetails.arriveDate.setDate(self.tblEDIDetails.getValueByName(ETRow_ADate).Date);
	ediDataDetails.arriveDate.setTime(self.tblEDIDetails.getValueByName(ETRow_ATime).Time);
	ediDataDetails.departDate.setDate(self.tblEDIDetails.getValueByName(ETRow_DDate).Date);
	ediDataDetails.departDate.setTime(self.tblEDIDetails.getValueByName(ETRow_DTime).Time);
	ediDataDetails.exportVoyage	:= self.tblEDIDetails.getValueByName(ETRow_ExportVoyage).String;
//	ediDataDetails.importVoyage	:= self.tblEDIDetails.getValueByName(ETRow_ImportVoyage).String;	// cnwrl1 14/07/2010 PAR 23499 - what it was
	ediDataDetails.importVoyage	:= self.tblEDIDetails.getValueByName(ETRow_ImportVoyageCode).String;
	ediDataDetails.listType := self.tblEDIDetails.getValueByName(ETRow_ListType).String; //cnwrs1 CCMS 1137 15 June 2010
	ediDataDetails.cargoTypeCode := self.tblEDIDetails.getValueByName(ETRow_CargoTypes).String;
	proxyEDIData.setPxyFromCMIF(ediDataDetails);	
			
	if passport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		passport.setMyCMIFMonitor(cmifMonitor);
	endif;
	
	self.initModalDialog();
	self.lblModalMessage.caption := Cr &amp; "Saving EDI data.";
	self.frmModalDialog.visible := true;
	
	app.doWindowEvents(0);
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateEDIDataDetails(proxyEDIData, passport);
	
		if app.myPassport.trxCompletedOK then
			// TFS 60021 CallOff proxy creation also creates a proxy release multiline and release header
			// So we need to delete the proxy call off here in case the header has been edited
			// (otherwise we get a "trying to edit in two places" error
			if proxyEDIData.isCallOff then
				delete proxyEDIData;
			endif;
			// TFS 60021 end
			
			if self.tiDataHasChanged then
				self.saveEDITIChanges(passport);
			endif;
			self.mode := Mode_View;
			self.setControls();
			self.clearErrorWarnings();
			self.staMain.caption := "EDI Details saved";
			self.tiDataHasChanged := false;
			break;
		else
			theResult := app.showErrorWarningDialog('Save EDI Details', passport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

	// EDIData Carrier access has EDI Data that is shown in EDI TI so need to refresh edi TIs table
	ediData := self.myCurrentObject.CM_EDIData;
	if ediData.isKindOf(CM_EDIDataOpCarrierAcessByCT) then
		self.ediTIDataNeedsRefresh := true;
		self.showDataForCurrentObject(false);
	endif;
	
	return saveOK;
	
epilog
	app.cmsEndLoad(loadState);		// 08/04/2011 cnwmh5 #27347
	self.closeModalDialog();
	delete ediDataDetails;
	delete proxyEDIData;
	delete cmifMonitor;
	passport.setMyCMIFMonitor(null);
	app.mousePointer := MP_DEFAULT;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblBoldSelected" id="71b3050c-4448-4a56-9457-c8baef603a07">
        <source>doTblBoldSelected(_table : Table) protected;
/*
----------   ----------  --------------------------------------------------
Created:	10 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	jCell		: JadeTableCell;
	numRows,
	loopRow,
	currentRow			: Integer;
	tbl					: CM_DataTable;
begin
	tbl := _table.CM_DataTable; // cnwgb1 27.9.09 MES 1011 add _table parameter to handled cloned controls
	
	if (tbl = null or not tbl.userInputEnabled) then
		return;
	endif;
	
	numRows := tbl.rows;
	currentRow := tbl.row;
	
	foreach loopRow in tbl.fixedRows + 1 to numRows do
		tbl.accessCell(loopRow, 1).fontBold := (loopRow = currentRow) or tbl.accessRow(loopRow).selected;
	endforeach;
	

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table"/>
    </JadeMethod>
    <JadeMethod name="doTblUnboldCells" id="5bbd4fbb-1e6f-492a-8135-94a4eeaed69b">
        <source>doTblUnboldCells() protected;
/*
----------   ----------  --------------------------------------------------
Created:	10 July 2006 By cnwth2

Purpose: This is called from setControls() to clear any state.

Changed On  Changed By  Reason
28 May 2013	cnwcs5		Fix 14050 exception
----------  ----------  --------------------------------------------------
*/
vars
	numRows, fixedRows,
	row, index			: Integer;
	table				: CM_DataTable;
begin
	while true do // cnwgb1 MES 1011 PAR 20320 Handle cloned tables
		table := self.tblEDITI.getControl(index);
		
		if table = null or not table.visible then
			break;
		endif;
		
		numRows 	:= table.rows;
		fixedRows	:= table.fixedRows;
		
		if numRows &gt; fixedRows and table.columns &gt; 0 then	// cnwcs5 May 2013			
			foreach row in fixedRows + 1 to numRows do
				table.accessCell(row, 1).fontBold := false;
			endforeach;
		endif;
		
		index := index + 1;
	endwhile;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTranshipSummary" id="97f0e9dc-8c42-487f-b9c7-bdbe5e4987a6">
        <source>doTranshipSummary();

vars
	form : CMUI_EDITranshipSummary;
begin
	if not self.myCurrentObject.isKindOf(CM_EDIDataTranship) then
		return;
	endif;
	create form transient;
	form.myEDIDataTranship := self.myCurrentObject.CM_EDIDataTranship;
	form.show;
end;</source>
