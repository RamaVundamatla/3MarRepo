	drawAttr := atttDict[PicTIConnected];
	if drawAttr &lt;&gt; null then
		self.btnPenPower.setFontFromDrawingAttr(drawAttr);
	endif;

	drawAttr := atttDict[PicTIFlat];
	if drawAttr &lt;&gt; null then
		self.btnPenFlat.setFontFromDrawingAttr(drawAttr);
	endif;
	
	drawAttr := atttDict[PicTIFantainer];
	if drawAttr &lt;&gt; null then
		self.btnPenFantainer.setFontFromDrawingAttr(drawAttr);
	endif;
	drawAttr := atttDict[PicTICrib];
	if drawAttr &lt;&gt; null then
		self.btnPenCrib.setFontFromDrawingAttr(drawAttr);
	endif;
	drawAttr := atttDict[PicTIFrame];	//05 Feb 2018	NDL	TFS 36752
	if drawAttr &lt;&gt; null then
		self.btnPenFrame.setFontFromDrawingAttr(drawAttr);
	endif;
	drawAttr := atttDict[PicTIOpentop];
	if drawAttr &lt;&gt; null then
		self.btnPenOpentop.setFontFromDrawingAttr(drawAttr);
	endif;
	drawAttr := atttDict[PicTITank];
