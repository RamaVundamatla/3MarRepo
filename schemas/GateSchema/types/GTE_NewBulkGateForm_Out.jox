    <JadeMethod name="getVvrFromTable" id="6e55263f-7bd6-4920-ac03-4577af389153">
        <updating/>
        <source>getVvrFromTable():CM_VehicleVisitRecord updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2016	cnwns1	Initial creation

*/

vars

begin
    if self.tblItems.rows = self.tblItems.fixedRows then
		app.raiseCMException(Err_No_Vehicle_visit_found, "Err_No_Vehicle_visit_found", null);
		return null;
	endif;
	
	if self.tblItems.allSelectedObjects.size = 0 then
		app.raiseCMException(Err_No_Vehicle_visit_selected, "Err_No_Vehicle_visit_selected", null);
		self.txtRegno.setFocus;
		return null;
	endif;
		
	if self.tblItems.allSelectedObjects.size = 1 then
		return self.tblItems.allSelectedObjects.first.CM_VehicleVisitRecord;
	else
		app.raiseCMException2(Too_many_items_selected,self.tblItems.allSelectedObjects.size.String,"1", "objectCount", null);
		return null;
	endif;
	
	if not self.myBulkGateAgent.myRealVVR.isBulkGateVVR then
		app.raiseCMException1(Vehicle_Visit__Not_Bulk_only,self.caption,"wrongGate", null);
		return null;
	endif;
end;
</source>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
