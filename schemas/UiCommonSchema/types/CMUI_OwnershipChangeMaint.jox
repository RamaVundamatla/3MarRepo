    <JadeMethod name="tblData_click" id="949d804c-1386-44ef-939b-8bd386f133cf">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58235: UI - Change of Ownership Maint
09 August 2023 navmv20 CR 59391 Task 59417: COO Maint Include Changes
//20.07.2024 navrv30 Bug 64858: MTN - Ownership Change Maint - Select All issues
*/

vars
	option, timeRemaining,	colSelected, colInclude : Integer;
begin
	// click on include column?
	colInclude := self.tblData.getColumnByRowName(ETRow_Include);
	colSelected := self.tblData.column;
	if colSelected &lt;&gt; 0
	and colInclude &lt;&gt; 0
	and colInclude = colSelected then

		// ### TFS CR 64164 TASK 64180 27MAY2024 NAVAB1 - 
		if self.getTimerStatus(self.Timer_DelayedClick, option, timeRemaining) then
			self.endTimer(self.Timer_DelayedClick);
		endif;
		
		self.beginTimer(1000, Timer_OneShot,self.Timer_DelayedClick);
	endif;
	self.doSetSelectAll();						//20.07.2024 navrv30 Bug 64858
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
