<Class name="CM_SwapStack" id="7ecb5f35-b979-4ac7-8498-b5e420390a44">
    <superclass name="CM_BlockStack"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>These are used for machine swapping. Every Terminal area
that can take Tracked Items has one. If a machine cannot
access an area, then the TI gets moved to one of these stacks.
For all intents and purposes, the main move is complete
however, another machine must complete the move to the required area.</text>
    <DbClassMap file="location"/>
