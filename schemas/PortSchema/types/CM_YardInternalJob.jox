    <JadeMethod name="isJobComplete" id="0ecfdfcc-e47b-4021-9dd0-a47049ef5c31">
        <source>isJobComplete(): Boolean;

vars
begin
	if self.status = JOB_COMPLETE then 
		return true;
	endif;
	//-----------------
	//Do we have an RTQueueEntries that are still around?
	//(users may have deleted them manually!)
	//-----------------
	if allEntries.isEmpty then
		//------------------
		//No RTQueueEntries on job, someone has nuked em!
		//This job can go! The erase method lets jobs with NO entries get
		//nuked, even though their status &lt;&gt; complete.
		//------------------
		return true;
	endif;
	//-----------------
	//Check to see the queuing state of the TI's
	//-----------------

	return self.areAllTIsInQueuedLocn();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMultiQueueJob" id="124f8f64-318f-42c3-8388-eeb68d6208fb">
        <source>isMultiQueueJob() : Boolean;

// Created by cnwdvb1 on 14 September 2007

vars

	wle  :CM_WorkListEntry;

begin

	foreach wle in self.workListEntries discreteLock do
		if wle.myTrackedItem = null then	// Par15743
			continue;
		endif;
		if wle.myTrackedItem.isMultiQueued() then
			return true;
		endif;
	endforeach;
	
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPlanOnPickup" id="3b2ad0ad-2f58-47e9-a731-596dc4554eac">
