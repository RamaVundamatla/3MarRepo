    <JadeMethod name="setFromXML" id="da32ccc8-fbfd-44b2-923d-6feeac0b3606">
        <updating/>
        <source>setFromXML(pCode, pXML : String; pRoot : CM_Root) updating;
// ---------------------------------------------------------------------------
// Created:     27 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.code			:= pCode;
	self.actionCode		:= pXML.cnEcGetTagValueOfName(XMLTag_ActionCode);
	self.actionType		:= pXML.cnEcGetTagValueOfName(XMLTag_ActionType);
	self.extraTableDef	:= pXML.cnEcGetTagValueOfName(XMLTag_ExtraTableDef);
	self.heading		:= pXML.cnEcGetTagValueOfName(XMLTag_Heading);
	self.mainTableDef	:= pXML.cnEcGetTagValueOfName(XMLTag_MainTableDef);
	self.schemaName		:= pXML.cnEcGetTagValueOfName(XMLTag_SchemaName);
	
	self.myRoot := pRoot;
	
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pXML" type="String"/>
        <Parameter name="pRoot" type="CM_Root"/>
    </JadeMethod>
</Class>
