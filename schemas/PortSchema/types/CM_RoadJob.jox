    <JadeMethod name="isRoadReleaseJob" id="36388a41-a0e1-4886-8bee-e13066dd96d6">
        <source>isRoadReleaseJob() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2024	navlc30	Initial creation
23 May 2024 navlc30 Bug 64084: FR | 53729 - Delivery Dispatch screen - wrong Job Type &amp; 1239 error
31 May 2024 navlc30 Defect 64408: EUP - Receive Cargo Job Type is generated for Release work orders
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/


vars
	trackedItem 	 : CM_TrackedItem;
	invalid			 : Boolean;
	request          : CM_Request;
	isRemainOnBoardTrailer : Boolean;
begin	
	on Exception do app.handleDeletedObject(exception, trackedItem, invalid);

	
	foreach request in self.allRequests discreteLock do											//31.05.2024 navlc30 #64408
		trackedItem := request.getTrackedItem();
		if trackedItem &lt;&gt; null then
			trackedItem.edition;
			if invalid then
				continue;
			endif;
			isRemainOnBoardTrailer := trackedItem.getImExStatus = TI_IMEX_STATUS_REMAINONBOARD 
									and trackedItem.isTrailer();
			if 	isRemainOnBoardTrailer then
				continue;
			endif;	
		endif;
		if request.isKindOf(CM_YardRequest) and
		   (not request.CM_YardRequest.isReceipt) then
			return true;
		endif;
	endforeach;

	return false;	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTrackedItemOnTransport" id="65ae8579-5156-4a2d-aa77-3dcaddc38961">
        <source>isTrackedItemOnTransport(_ti: CM_TrackedItem): Boolean;
//--------------------------------------------------------------
//Created: 02 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if _ti = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null TI. Contact Developer.');
		return false;
	endif;

	return self.myVehicle.locationsController.allTrackedItems.includes(_ti);
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
