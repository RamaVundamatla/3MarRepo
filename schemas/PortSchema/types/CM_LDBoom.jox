<Class name="CM_LDBoom" id="89e007d7-5e7d-4ca5-a7ba-6514ad9edf5f">
    <superclass name="CM_LaneDevice"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <ExplicitInverseRef name="myBoom" id="e2ec07fc-f290-4002-8611-0dbe7fe0b339">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Boom"/>
        <access>readonly</access>
        <Inverse name="CM_Boom::allLaneDevices"/>
    </ExplicitInverseRef>
    <JadeMethod name="getAuditText" id="ff992ff0-3d1d-4cfa-bc93-5838f25f7a26">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     11 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2010	cnwcs5		gDansk gate issue 
// ---------------------------------------------------------------------------
vars
	txt		:String;
begin
	txt 	:= inheritMethod();

	if self.myBoom = null then														// 20/04/2010	cnwcs5		gDansk gate issue 
		txt := txt &amp; self.formatAuditText("Boom", app.getErrorString (Unknown));	// 20/04/2010	cnwcs5		gDansk gate issue 
	else																			// 20/04/2010	cnwcs5		gDansk gate issue 
		txt := txt &amp; ' ' &amp; self.formatAuditText("Boom", self.myBoom.code);			// 20/04/2010 cnwcs5
	endif;																			// 20/04/2010	cnwcs5		gDansk gate issue 
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasDevice" id="2bfcfd4a-d31c-4179-b9c4-8e3719c08704">
        <source>hasDevice(): Boolean;
// ---------------------------------------------------------------------------
// Created:     20 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2010	cnwcs5		gDansk gate issue
// ---------------------------------------------------------------------------
vars

begin
	return self.myBoom &lt;&gt; null;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isBoom" id="6515c39c-ef9b-4ccc-815b-dd8a0b8474f7">
        <source>isBoom():Boolean;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="20bf0f48-9555-401c-a229-53c08740177f">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     28 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxy	:SelfType;
	completedOK		: Boolean;
begin
	proxy :=  inheritMethod();

	proxy.myBoom	:= self.myBoom;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setBoom" id="ac0dfdd2-c048-4acf-8c8d-ea696c800852">
        <updating/>
        <source>setBoom(_boom :CM_Boom) updating;
// ---------------------------------------------------------------------------
// Created:     29 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient (method);
	
	if self.myBoom &lt;&gt; _boom then
		self.myBoom := _boom;
	endif;
epilog

end;</source>
        <Parameter name="_boom" type="CM_Boom"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="07535676-9cbf-4253-a576-d1949a2139e7">
        <updating/>
        <source>setForUpdate(_proxy: CM_LDBoom) updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_proxy);

	self.myBoom	:= _proxy.myBoom;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_LDBoom"/>
    </JadeMethod>
    <JadeMethod name="setType" id="38bdb3f9-7314-455c-96e9-d90275b2a0b6">
        <updating/>
        <source>setType(_type : Integer) updating;

/*
Date			Who		Reason
08 July 2009	cnwar2	Initial creation

*/
vars

begin
	self.type := _type;
end;</source>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validate" id="b0fc63d5-15a0-4958-84c3-119e5a4eafed">
        <source>validate(_passport: CM_Passport input)protected;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_passport);

	if self.myBoom = null or not self.myBoom.isKindOf (CM_Boom) then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Boom required');
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
