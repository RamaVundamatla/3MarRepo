        <source>zCoparn_mtrel_multi(_sender, _voyageCode, _vesselName, _extraText :String; _reqTS, _estReqTS :TimeStamp):String protected;
/*
Purpose:	Coparn file for MT release with pre-assigned container number

Date		        Who		Reason
01 December 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
08 January 2013     cnwgb1  Heavy Rated Releases CCMS 2216/PAR 30902 
*/
vars
	str,	strTS1, strTS2	:String;
begin
	strTS1 := _reqTS.date.format ('yyyyMMdd') &amp; _reqTS.time.format ('HHmm');
	strTS2 := _estReqTS.date.format ('yyyyMMdd') &amp; _estReqTS.time.format ('HHmm');
	
	str := 	
"UNA:+.? '
UNB+UNOA:1+" &amp; _sender &amp; "+NZPORTM+111011:0105+45++++++1'
