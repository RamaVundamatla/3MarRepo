    <JadeMethod name="addNotableTi" id="31d6b7c6-dd85-4f00-ae5d-b1175dcca6e5">
        <source>addNotableTi( ti : CM_TrackedItem );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 March 2012	cnwndl1	Initial creation	Par 29195

*/

vars

begin

	

	if not self.allNotableTis.includes( ti ) then
		self.allNotableTis.add( ti );
		self.beginNotification( ti, Any_System_Event, Response_Continuous, null );
	endif;

epilog

end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addSelectedCargo" id="879feaae-723f-4172-8dbd-fb64385e38cb">
        <source>addSelectedCargo( _tiArray : ObjectArray );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;
	rowIndex : Integer;
	updated : Boolean;
	size : Integer;

begin

	if _tiArray = null or _tiArray.isEmpty then
		return;
	endif;
	
	ti := _tiArray.first.CM_TrackedItem;
	// 30069 null test already just added by DW

	if ti.myPrimaryActualLocation &lt;&gt; null and  ti.myPrimaryActualLocation.myTerminal &lt;&gt; self.myTerminal then
		app.msgBox( app.getErrorString2(Testplan_Term_Mismatch, ti.myPrimaryActualLocation.myTerminal.code, self.myTerminal.code ), app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	self.shtSelected.setFocus();

	iter := _tiArray.createIterator;
		
	while iter.next( ti ) do
		rowIndex := 0;
		self.tblSelected.findObjectInRow(ti, rowIndex);
		if rowIndex &gt; 1 then
			// it already exists, don't add it.
			continue;
		endif;
		//15 July 2014	NDL	Par 
	//	if ti.isChild then	//18 Jul 2013	NDL	Par 31899
	//		continue;
	//	endif;
		rowIndex := self.tblSelected.addItemObject( ti, ti.getAttributeStringForDefArray(self.tblSelected.allTblDataEntRows) );
		if ti.myPrimaryPlannedLocation &lt;&gt; null then
			self.tblSelected.accessRow( rowIndex ).backColor := Grey;
		endif;
		updated := true;
		addNotableTi( ti );
	endwhile;
	
	//The selection has changed, clear the other sheets.
	if updated then
		self.clearWouldPlanAndFailed();
		size := self.tblSelected.rows - self.tblSelected.fixedRows;
		self.shtSelected.caption := "(x" &amp; size.String &amp; ") " &amp; app.getErrorString(Selected_Cargo);
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_tiArray" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="allowsTableFilters" id="82b76de6-1544-4fed-bd7c-f229607d88f0">
        <source>allowsTableFilters(_table: Table): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

begin

	if _table = self.tblSelected
	or _table = self.tblFailed
	or _table = self.tblWouldPlan
	then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="applyColumnFilter" id="95be0f7d-c875-43b3-9143-b46ef15076e9">
        <updating/>
        <source>applyColumnFilter(_table: CM_DataTable io): Integer updating;
/*
Date		Who		Reason
29 February 2012	cnwndl1	Initial creation	Par 29195

*/
vars
	visibleCount : Integer;
begin
	if _table &lt;&gt; null then
		if _table.allowsColumnFilters then
			visibleCount := _table.applyColumnFilter( self.allColumnFilters );
		endif;
	endif;
	
	return visibleCount;

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
