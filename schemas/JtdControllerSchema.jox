    <Function name="winGlobalMemoryStatus" id="f57301f0-525d-4f5b-bca4-fe679fc95a80">
        <entrypoint>GlobalMemoryStatus</entrypoint>
        <executionLocation>presentationClient</executionLocation>
        <library name="kernel32"/>
        <source>// Allocate 256 bytes in which memory information will be returned. This
// needs to be at least the size of a Windows MEMORYSTATUS structure. At
// the time of writing (18 Sept 2001), the Win32 documentation says this
// structure holds 8 4-byte elements, so 256 bytes is plenty of room.

winGlobalMemoryStatus(b : Binary[256] io) is GlobalMemoryStatus in kernel32;</source>
        <Parameter name="b" type="Binary" length="256" usage="io"/>
    </Function>
