    <JadeMethod name="createProxy" id="a32a36b9-2239-4ee4-9cb2-9f6f93a0888b">
        <updating/>
        <source>createProxy() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		

	
Date			Who		Reason
05 August 2009	cnwmd1	Initial creation
08/04/2011		cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
22/05/2018		jlgdap1	TFS 38560 PEL1 Voyage Work Orders
*/

vars
	ls : Boolean;
begin
	app.cmsBeginLoad(ls);
	
	if self.mode = self.Mode_Add then
		if self.workOrderMode = WorkOrderMode_Cargo then														// TFS 38560
			create self.myCurrentProxyWorkOrder as CM_WorkOrderTI transient;
			self.setProxyWorkOrderSource();
		else																									// TFS 38560
			create self.myCurrentProxyWorkOrder as CM_WorkOrderVoyage transient;								// TFS 38560
		endif;																									// TFS 38560
	elseif self.mode = self.Mode_Update then
		if self.workOrderMode = WorkOrderMode_Cargo then														// TFS 38560
			self.myCurrentProxyWorkOrder := app.createUpdateProxy(self.myCurrentWorkOrder).CM_WorkOrderTI;
		else																									// TFS 38560
			self.myCurrentProxyWorkOrder := app.createUpdateProxy(self.myCurrentWorkOrder).CM_WorkOrderVoyage;	// TFS 38560
		endif;																									// TFS 38560
	endif;

epilog			// 08/04/2011 cnwmh5 #27347 - Move epilog before cmsEndLoad
	app.cmsEndLoad(ls);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createProxyChildren" id="b0fc1583-edbf-48dd-b882-ef49bada8557">
        <updating/>
        <source>createProxyChildren() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05/08/2009	cnwmd1	Initial creation
23/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
24 Jan 2023	navma1  	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	id			: Integer;
	pxyWOSource	: CM_WorkOrderTISource;
	totalReq 	: Integer;
	source      : CM_WorkOrderTISource;
begin
	if not self.setProxyWorkOrder(self.myCurrentProxyWorkOrder) then
		return;
	endif;
	
	// 37013 do the cargo type conditionally.  If missing the validation code from the utl will return an error.
	if self.cmbCargoType.listObject &lt;&gt; null then
		id := self.cmbCargoType.listObject.CM_CargoType.id;
	endif;
	
	if self.workOrderMode = WorkOrderMode_Cargo then						// TFS 38560
		
		source := self.myCurrentProxyWorkOrder.CM_WorkOrderTI.mySource;
		if source = null then
			if self.myCurrentProxyWorkOrder.requiresWorkOrderTISource() and self.mode = self.Mode_Add then
				pxyWOSource := self.setProxyWorkOrderSource();
			endif;
		else
			if not source.hasNonIDSource() then
				source.setProxy(id, self.txtSourceList.text );
				//06 Jun 2018	NDL	TFS 38950
				if self.myCurrentProxyWorkOrder.CM_WorkOrderTI.totalRequired = 0 then
					totalReq := source.getTotalCargoCount();
					self.myCurrentProxyWorkOrder.CM_WorkOrderTI.setTotalRequired(totalReq);							//24.01.2023 navma1 #56141 Task#56147
				endif;
			endif;
		endif;
	endif;																	// TFS 38560
	
	if self.myCurrentProxyWorkOrder.allWoDtls.size = 0  and self.mode = self.Mode_Add then  //cnwrd1 par 25332 6.8.2010
		self.setProxyWorkOrderTasks(self.myCurrentProxyWorkOrder);
	endif;
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
