    <JadeMethod name="getEventName" id="74bb0938-8dd2-43d2-a675-8ea19f6bd7ef">
        <source>getEventName(_obj : Object):String;
/*
Purpose:			
Date				Who			Reason
MARCH 2018		JLGAB1		Initial creation
*/


vars

begin
	if _obj.isKindOf(CM_EventType) then
		return _obj.CM_EventType.name;
