    <JadeMethod name="getAlertDetail" id="43bad24c-ddc8-42a3-b50d-b8e4f66c7a50">
        <source>getAlertDetail( _proxy : CM_VehicleBookingTimeSlot ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	detail : String;
	tiId : String;
	ti : CM_TrackedItem;
	
begin

	//is called just before we make the update from the proxy
	if _proxy = null or not _proxy.isTransient then
		return null;
	endif;
	
	//we are really only interested in a carrier making a new booking,
	//or clearing themselves from one, or changing the pickup and delivery info
	if self.isUsed or self.isExpired then
		//history, who cares
		return null;
	endif;
	if self.isUnBookedTimeslot and _proxy.isUnBookedTimeslot then
		//neither is booked, no change
		return null;
	endif;
	
	if self.myCarrier &lt;&gt; null and _proxy.myCarrier = null then
		//real is populated and the proxy is going to clear the carrier
		detail := detail &amp; self.myCarrier.code &amp; " " &amp; app.getErrorString(Cancelled_vehicle_booking) &amp; " ";
	else
		if self.myCarrier = null and _proxy.myCarrier &lt;&gt; null then
		//real is NOT populated and the proxy is going to set the carrier
			detail := detail &amp; _proxy.myCarrier.code &amp; " " &amp; app.getErrorString(New_Vehicle_booking) &amp; " ";
		elseif self.myCarrier = _proxy.myCarrier then
			// no carrier change, check for delivery/pickup changes
			if self.includesDelivery &lt;&gt; _proxy.includesDelivery
			or self.includesPickUp &lt;&gt; _proxy.includesPickUp
			then
				detail := detail &amp; app.getErrorString(Pickup_or_delivery_chgs) &amp; " ";
			else
				if self.allBookedTrackedItems.size &lt;&gt; _proxy.allTiIds.size then
					detail := detail &amp; app.getErrorString(Pickup_or_delivery_chgs) &amp; " ";
				else
					foreach ti in self.allBookedTrackedItems do
						tiId := ti.id;
						if not _proxy.allTiIds.includes(tiId) then
							detail := detail &amp; app.getErrorString(Pickup_or_delivery_chgs) &amp; " ";
							break;
						endif;
					endforeach;
				endif;
				
			endif;
		endif;
	endif;
	
	if detail &lt;&gt; null then
		detail := self.getDescription(false) &amp; "  " &amp; detail;
	endif;
	
epilog

	return detail;
	
end;
</source>
        <Parameter name="_proxy" type="CM_VehicleBookingTimeSlot"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditChildSubjects" id="60f80d5b-8b58-402a-9162-b722e86c6ffc">
        <source>getAuditChildSubjects(_childAuditSubjectNames: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Aug 2023 navhl20 Defect 59936: MTN - Displaying only the first tracked item on the Audit Enquiry for the Vehicle Booking Time Slot

*/

vars
	vbsItem : CM_VehicleBookingTimeSlotItem;
begin	
	inheritMethod(_childAuditSubjectNames);
	foreach vbsItem in self.allVehicleBookingItems discreteLock do
		vbsItem.getAuditChildSubjects(_childAuditSubjectNames);
	endforeach;
epilog

end;</source>
        <Parameter name="_childAuditSubjectNames" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="64a0cf2d-a04d-4661-b91f-48532d76b3b3">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Aug 2023	navlw1	ChangeRequest 59132:[59133] EUP | VBS Audits
15 Aug 2023	navma1	ChangeRequest 59875: EUP | VBS - Add Created by user code
*/

vars
	txt,
	tmpStr,
	str				: String;
	slotItem   		: CM_VehicleBookingTimeSlotItem;
	term 			: CM_Terminal;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	tmpStr := null;
	if self.myCarrier &lt;&gt; null then
		tmpStr := self.getCarrierString;
		txt    := txt &amp; app.getErrorString(Carrier) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myDriver &lt;&gt; null then
		tmpStr := self.getDriverString();
		txt    := txt &amp; app.getErrorString(Driver) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myVehicle &lt;&gt; null then
		tmpStr := self.getVehicleString();
		txt    := txt &amp; app.getErrorString(Vehicle) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.mySubCarrier &lt;&gt; null then
		tmpStr := self.getSubCarrierString();
		txt    := txt &amp; "Sub Carrier" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myTerminal &lt;&gt; null then
		term := self.getMyTerminal();
		tmpStr := term.code;
		txt    := txt &amp; app.getErrorString(Terminal) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myVBTimeSlotType &lt;&gt; null then
		tmpStr := self.getSlotTypeDescription();
		txt    := txt &amp; app.getErrorString(VBS_Slot_type) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myVehicleVisitRecord &lt;&gt; null then
		tmpStr := self.getVehicleVisitNumber();
		txt    := txt &amp; app.getErrorString(Err_No_Vehicle_visit_found) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.remarks &lt;&gt; null then
		tmpStr := self.remarks;
		txt    := txt &amp; app.getErrorString(Remarks) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.bookingTSstart &lt;&gt; null then
		tmpStr := self.getBookingTSStartLocalTZ().asStringJMT;
		txt    := txt &amp; app.getErrorString(Start_date) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.bookingTSend &lt;&gt; null then
		tmpStr := self.getBookingTSEndLocalTZ().asStringJMT;
		txt    := txt &amp; app.getErrorString(EndDate) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.bookingTSend &lt;&gt; null then
		tmpStr := self.getBookingTSEndLocalTZ().asStringJMT;
		txt    := txt &amp; app.getErrorString(EndDate) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	tmpStr := self.getCreationMethod();
	txt    := txt &amp; 'Creation Method' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

	tmpStr := null;
	if self.myVehicleVisitRecord &lt;&gt; null then
		tmpStr := self.myVehicleVisitRecord.visitNumber;
		txt    := txt &amp; app.getErrorString(Visit_number) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.externalReference &lt;&gt; null then
		tmpStr := self.externalReference;
		txt    := txt &amp; "External Reference" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
		
	tmpStr := null;
	if self.id &lt;&gt; null then
		tmpStr := self.id;
		txt    := txt &amp; "Id" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	tmpStr := self.includesDelivery.getYesNo();
	txt    := txt &amp; "Include Delivery" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	tmpStr := self.includesPickUp.getYesNo();
	txt    := txt &amp; "Include Pickup" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	tmpStr := self.kioskCheck.getYesNo();
	txt    := txt &amp; app.getErrorString(Kiosk_check) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	tmpStr := self.preGateInCheck.getYesNo();
	txt    := txt &amp; "PreGateIn Check" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	tmpStr := self.preGateOutCheck.getYesNo();
	txt    := txt &amp; "PreGateOut Check" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

	tmpStr := null;					
	tmpStr := self.createdUserCode;		//17.08.2023 navma1 #59875
	txt    := txt &amp; "Created By " &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	foreach slotItem in self.allVehicleBookingItems discreteLock do	
		tmpStr := tmpStr &amp; slotItem.getAuditText() &amp; AuditStringSeparator;
	endforeach;
	txt := txt &amp; tmpStr;

	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBookInAdvanceTimeInterval" id="c49b9b8a-e96a-4871-9cd0-60dec07e16a5">
        <source>getBookInAdvanceTimeInterval( _origHrs : Integer output; _typeString : String output ):TimeStampInterval;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	delTS : TimeStampInterval;
	delHrs : Integer;
	puTS : TimeStampInterval;
	puHrs : Integer;
	returnTS : TimeStampInterval;

begin

	if self.includesDelivery then
		delTS := self.myVehicleBookingTerminal.getBookInAdvanceDelivTimeInt( delHrs );
		_origHrs := delHrs;
		_typeString := app.getErrorString(Delivery);
		returnTS := delTS;
	endif;
	
	if self.includesPickUp then
		puTS := self.myVehicleBookingTerminal.getBookInAdvancePuTimeInt( puHrs );
		if puHrs &gt; delHrs then
			_origHrs := puHrs;
			_typeString := app.getErrorString(Pickup);
			returnTS := puTS;
		endif;
	endif;

	return returnTS;

epilog

end;</source>
        <Parameter name="_origHrs" type="Integer" usage="output"/>
        <Parameter name="_typeString" type="String" usage="output"/>
        <ReturnType type="TimeStampInterval"/>
    </JadeMethod>
    <JadeMethod name="getBookingRefIdsAsString" id="b50b1ea7-b858-4237-a94c-960678864353">
        <source>getBookingRefIdsAsString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwndl1	Initial creation	Par 35008

*/

vars

	bookingRef : CM_BookingRef;
	str : String;

begin

	foreach bookingRef in self.allBookingRefs do
		if str &lt;&gt; null then
			str := str &amp; ", ";
		endif;
		str := str &amp; bookingRef.bookingReference;
	endforeach;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
