/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Dec 2022 navtnr20	TFS CR 55622 Task 55690: Jade - Shipping Terms TRX

*/

vars

begin
	self.priority := _priority;
	self.myShippingTerm := _myShippingTerm;
	self.myDebtorType := _debtor;
	self.allInvoiceLineTypes.clear();
	_allInvoice.copy(self.allInvoiceLineTypes);
epilog

end;</source>
