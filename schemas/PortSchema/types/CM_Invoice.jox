    <JadeMethod name="getSignOffUser" id="88370131-1c0f-40e7-850a-bd7040e82cc3">
        <source>getSignOffUser():CM_InvoiceSignoffUser;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2018	jlgndl1	Initial creation	TFS 38535

*/

vars

	effectiveDT : TimeStamp;
	signoff : CM_InvoiceSignoffUser;

begin

	effectiveDT := self.toDT;
	
	if not effectiveDT.date.isValid then
		effectiveDT := self.postedDT;
	endif;

	if not effectiveDT.date.isValid then
		effectiveDT := self.createdTime;
	endif;
	
	signoff := self.bank.getSignOffUser( effectiveDT );
	
	return signoff;

epilog

end;</source>
        <ReturnType type="CM_InvoiceSignoffUser"/>
    </JadeMethod>
