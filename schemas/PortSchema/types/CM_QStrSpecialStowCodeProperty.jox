    <JadeMethod name="create" id="4419900d-aae5-4425-9097-ab2f34dec52b">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2015	cnwma1	Initial creation

*/

vars
	specialStow 		: CM_QStringIsOneOf;
begin

	if self.isTransient then	
		return;
	endif;

	create specialStow as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(specialStow);
end;</source>
    </JadeMethod>
