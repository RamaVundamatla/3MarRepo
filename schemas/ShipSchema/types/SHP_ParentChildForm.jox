    <JadeMethod name="setupForm" id="4ed2ad86-92f6-4ca8-97c9-4f5ea1e722ce">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	inheritMethod();
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	self.picDetails.parentAspect:=Control.ParentAspect_CenterHorz;
	
	self.setCaption(null);
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDeleteChild.enabled:= false;
		self.btnEditChild.enabled:= false;
		self.btnNewChild.enabled:= false;
		self.btnSaveBase.enabled:= false;
		self.picDetails.enabled:= false;
		self.btnCancelBase.visible:= false;
		endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="startNotes" id="c40a3fd7-eb23-4e7e-80ee-059dfba1c7b9">
        <source>startNotes() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin

	if self.myParent &lt;&gt; null then
		self.beginNotification(self.myParent,self.createNote,Response_Continuous,null);
		self.beginNotification(self.myParent,self.updateNote,Response_Continuous,null);
		self.beginNotification(self.myParent,self.deleteNote,Response_Continuous,null);
	endif;

	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3615eeb3-4c48-4efe-8ef2-00fd5d8ee34d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015303, locale);
	btnDeleteChild.translateBubbleHelp(Xlat_0015304, locale);
	btnDeleteChild.translateCaption(Xlat_0015305, locale);
	btnEditChild.translateBubbleHelp(Xlat_0015306, locale);
	btnEditChild.translateCaption(Xlat_0015307, locale);
	btnNewChild.translateBubbleHelp(Xlat_0015308, locale);
	btnNewChild.translateCaption(Xlat_0015309, locale);
	lblChild.translateCaption(Xlat_0015310, locale);
	lblParent.translateCaption(Xlat_0015311, locale);
end;</source>
    </JadeMethod>
