    <JadeMethod name="create" id="0396c52b-b1fa-438a-90fc-0bff5bcf67f5">
        <updating/>
        <source>create() updating;
// -----------------------------------------------------------------------------
// Created:		18 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.canAddChild 	:= true;
	self.canAddPeer 	:= true;
	self.canEdit 		:= true;
	self.canDelete 		:= true;
	self.expanded 		:= false;
end;</source>
    </JadeMethod>
    <JadeMethod name="createChild" id="d9ece2e7-b989-4c10-b4b2-e1e57230a3bf">
        <updating/>
        <source>createChild() :  SOP_ViewModelObject updating;
// -----------------------------------------------------------------------------
// Created:		11 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	child : SOP_ViewModelObject;
begin
	
	create child as self.getChildClass transient;
	child.createEmptyChild(self);
	return child;
end;</source>
        <ReturnType type="SOP_ViewModelObject"/>
    </JadeMethod>
