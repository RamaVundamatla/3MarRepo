        <source>getEDIDisplayStrForType(_type: Integer): String;
/*
----------   ----------  --------------------------------------------------
Created:	01 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
22/04/2010	cnwcs5		ccms 1118 - par 23580 - enhanced edi form
						localise translation code into one place (CM_EDIControllerAgent)
*/
vars
	agent	: CM_EDIControllerAgent;	// 22/04/2010 cnwcs5 par 23580
begin
/* 	NOTE
	If you are going to call this method repeatedly then you are better off calling the method on 
	CM_EDIControllerAgent directly so you don't create/delete the agent multiple times
*/	
	create agent transient;
	
	return agent.getEDIDisplayStrForType (_type);
	
epilog
