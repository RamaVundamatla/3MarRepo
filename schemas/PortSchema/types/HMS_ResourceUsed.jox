    <JadeMethod name="pxyCreateUpdateProxy" id="27be66ce-1063-4aad-a35f-fb95e9bf66eb">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	17 February 2005 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy : HMS_ResourceUsed;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myHarbour := self.myHarbour;
	proxy.myResource := self.myResource;
	proxy.myResourceType := self.myResourceType;
	proxy.myHMSObject := self.myHMSObject;
	
	proxy.myWorkOrderVoyageDtl := self.myWorkOrderVoyageDtl;	//31 Oct 2018	NDL	TFS 41281
	proxy.myDebtor := self.myDebtor;	//26 Nov 2018	NDL	TFS 41980
	
	// Do not create proxy VTMIS Transaction as it cannot be updated
	// Used to determine whether a charge is needed or not
	// if object is null then ok to create charge
	// if object is transient then on the set for update aa actual charge will be created
	proxy.myVTMISTransaction := self.myVTMISTransaction;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="requiresInput" id="da7bd5e8-aab8-45dd-8a33-94738486bb93">
        <source>requiresInput() : Boolean;
// ---------------------------------------------------------------------------
// Created:		11 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	msgStr : String;
	tmpResourceType : HMS_ResourceType;
	realObj : HMS_ResourceUsed;
	hmsRO :	HMS_ResourceForObject;
begin
	
	
	tmpResourceType := self.myResourceType;

	if tmpResourceType = null then
		return false;
	endif;

	if tmpResourceType.isFromToDateTimeRequired then
		if (not self.fromDateTime.isValid) or (not self.toDateTime.isValid) then
			return true;
		endif;		
	elseif tmpResourceType.isActionDateTimeRequired then
		if (not self.fromDateTime.isValid) then
			return true;
		endif;	
	endif;	

	if tmpResourceType.isQuantityRequired then
		if self.unitsUsed &lt;= 0 then
			return true;
		endif;	
	endif;
	
	if self.myResource = null then
		return true;
	endif;
	
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDefaultForMovement" id="c08f7186-88ca-45c1-a641-66b6b19798a6">
        <updating/>
        <source>setDefaultForMovement(_partOfContract : Boolean; _resource : HMS_Resource; _resourceType : HMS_ResourceType; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 30 July 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 12/10/2015	cnwdap1		PAR #36945 Ensure resources that don't get updated later
//							(from entering a quantity, or dates/times) have a quantity of 1
// 21 Sep 2016	cnwrs1	TFS 2615 1090 creating voyage in new termuinal
vars
	tmpResource, aRes : HMS_Resource;
	vm : HMS_VoyageMovement;
	numRes : Integer;
begin
	if _resource = null
	and _resourceType = null then
		app.raiseCMException1(ERR_NO_OBJECT, 'Resource / Resource Type', null, null);
		return;
	endif;
	if self.myVoyageMovement = null then
		app.raiseCMException1(ERR_NO_OBJECT, 'Movement', null, null);
		return;
	endif;
		
	self.myHarbour := self.myVoyageMovement.myHarbour;
	vm := self.myVoyageMovement;
	
	if self.myHarbour = null then
		app.raiseCMException1(HMSNoHarbourForTerminal, _passport.myTerminal.code, null, null);
		return;
	endif;
	
	self.partOfContract := _partOfContract;
	
	if _resource &lt;&gt; null then					
		self.myResource := _resource;
		self.code := self.myResource.code.toUpper.trimBlanks;
		self.description := self.myResource.description;
		self.myResourceType := self.myResource.myResourceType;
		tmpResource := _resource;// PAR 11707 
		
	elseif _resourceType &lt;&gt; null then
		self.myResourceType := _resourceType;	
		self.code := _resourceType.code.toUpper.trimBlanks;
		self.description := _resourceType.description;
		
		// ### PAR 10220. If there is only 1 resource for the type use it.
		foreach tmpResource in _resourceType.allResources do
			if self.myHarbour &lt;&gt; tmpResource.myHarbour and tmpResource.myHarbour &lt;&gt; null then
				continue;
			endif;
			if tmpResource.isNotAvailableForEntry then
				continue;
			endif;
			numRes := numRes + 1;
			aRes := tmpResource;
		endforeach;
//		if _resourceType.allResources.size = 1 then 
		if numRes = 1 then
			tmpResource := aRes; //_resourceType.allResources.first;
			if tmpResource &lt;&gt; null then
				self.myResource := tmpResource;
				self.code := tmpResource.code.toUpper.trimBlanks;
				self.description := tmpResource.description;
				
				// ### PAR 10220. default date
				if _resourceType.isActionDateTimeRequired then
					if self.myVoyageMovement.occursOnDTNEW.isValid() then
						self.fromDateTime := self.myVoyageMovement.occursOnDTNEW;
					endif;
				endif;
			endif;
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Resource/ResourceType');
		return;	
	endif;

	self.unitsUsed := 0; // ### PAR 10220. Default to 0
	// PAR #36945 If it's a marine service, and doesn't require date/time or units, 	// PAR #36945
	// default to 1																		// PAR #36945
	if _resourceType.isMarineService 													// PAR #36945
	and not _resourceType.isActionDateTimeRequired 										// PAR #36945
	and not _resourceType.isFromToDateTimeRequired 										// PAR #36945
	and not _resourceType.isQuantityRequired then										// PAR #36945
		self.unitsUsed := 1;															// PAR #36945
	endif;																				// PAR #36945

	self.setDefaultForObject(vm); // PAR 11707
	
	if (not self.isTransient) then
		self.createTransaction(self.myVoyageMovement, TRANS_TYPE_ResourceBooked, _passport);
	endif;
	
end;</source>
        <Parameter name="_partOfContract" type="Boolean"/>
        <Parameter name="_resource" type="HMS_Resource"/>
        <Parameter name="_resourceType" type="HMS_ResourceType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setDefaultForObject" id="77bdd1f2-a4d9-490d-ad34-5a66a495fc1a">
        <updating/>
        <source>setDefaultForObject(_vm : HMS_VoyageMovement) updating;
// ---------------------------------------------------------------------------
// Created:		03 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
// 23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
// 24 May 2019	jlgsl4	TFS 44932 - PEL1 - null myPilotLaunch causes 1090
// ---------------------------------------------------------------------------
vars
	pilot : HMS_Pilot;
	movementPilotDetails : HMS_MovementPilotDetails; // TFS 44438	
begin

	// ### LINE COMPANY DEFAULTS
	if _vm.myLineCompany &lt;&gt; null then
		if _vm.myLineCompany.getResourceForHarbourMovement(_vm.myHarbour,_vm.moveType) = self.myResource then
			self.unitsUsed := _vm.numLineCrewRequired;
			if self.myHMSObject = null then
				self.myHMSObject := _vm.myLineCompany;
			endif;
		endif;
	endif;

	// ### PILOT DEFAULTS
/*	if _vm.myPilot &lt;&gt; null then // --&gt; TFS 44438
//		if _vm.myPilot.getResourceForHarbourMovement(_vm.myHarbour,_vm.moveType) = self.myResource then 
	pilot := _vm.getUnConvertedMyPilotRef;
	if pilot &lt;&gt; null then	//31 Oct 2018	NDL	TFS 41662
		if pilot.getResourceForHarbourMovement(_vm.myHarbour,_vm.moveType) = self.myResource then 
			if self.myHMSObject = null then
				self.myHMSObject := pilot;
			endif;
		endif;
	else*/ // &lt;-- TFS 44438
	if not _vm.allMovementPilotDetails.isEmpty then //allPilots.isEmpty then	//31 Oct 2018	NDL	TFS 41662 // TFS 44438
		foreach movementPilotDetails in _vm.allMovementPilotDetails do //pilot in _vm.allPilots do // TFS 44438
			if /*pilot*/ movementPilotDetails.myPilot.getResourceForHarbourMovement(_vm.myHarbour,_vm.moveType) = self.myResource then // TFS 44438
				if self.myHMSObject = null then
					self.myHMSObject := movementPilotDetails.myPilot; //pilot; // TFS 44438
				endif;
			elseif movementPilotDetails.myPilotLaunch &lt;&gt; null then// TFS 44932
				if movementPilotDetails.myPilotLaunch.getResourceForHarbourMovement(_vm.myHarbour,_vm.moveType) = self.myResource then // --&gt; TFS 44438
					if self.myHMSObject = null then
						self.myHMSObject := movementPilotDetails.myPilotLaunch;
					endif;
				endif; // TFS 44932
			endif; // &lt;-- TFS 44438
		endforeach;
	endif;

	// ### LAUNCH DEFAULTS
	/*if _vm.myPilotLaunch &lt;&gt; null then // --&gt; TFS 44438 after 040 cut/release
		if _vm.myPilotLaunch.getResourceForHarbourMovement(_vm.myHarbour,_vm.moveType) = self.myResource then 
			if self.myHMSObject = null then
				self.myHMSObject := _vm.myPilotLaunch;
			endif;
		endif;
	endif;*/
	
	if _vm.getFirstPilotLaunch() &lt;&gt; null then
		if _vm.getFirstPilotLaunch().getResourceForHarbourMovement(_vm.myHarbour,_vm.moveType) = self.myResource then 
			if self.myHMSObject = null then
				self.myHMSObject := _vm.getFirstPilotLaunch();
			endif;
		endif;
	endif; // &lt;-- TFS 44438 after 040 cut/release

	// ### PILOT DEFAULTS
/*	if _vm.myPilot &lt;&gt; null then
		if _vm.myPilot.getResourceForHarbourMovement(_vm.myHarbour,_vm.moveType) = self.myResource then 
			if self.myHMSObject = null then
				self.myHMSObject := _vm.myPilot;
			endif;
		endif;
	endif; */	
end;</source>
        <Parameter name="_vm" type="HMS_VoyageMovement"/>
    </JadeMethod>
    <JadeMethod name="setDetailsFromWorkOrder" id="48406d69-249f-474e-a408-28d6b7ce9c26">
        <updating/>
        <source>setDetailsFromWorkOrder(_fromDateTime, _toDateTime : TimeStamp) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars

begin
	self.fromDateTime := _fromDateTime;
	if _toDateTime.isValid then
		self.toDateTime := _toDateTime;
	endif;
epilog

end;</source>
