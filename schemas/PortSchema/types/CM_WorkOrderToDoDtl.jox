    <JadeMethod name="getDisplayString" id="c5bc1395-baaf-4f09-a344-a2c5f9ce898c">
        <source>getDisplayString(_useShortDesc: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 October 2021		navma1	Initial creation

*/

vars
	displayString 	: String;
	desc			: String;
	woTaskType	 	: CM_WorkOrderDetailType;
begin
	
	desc := app.myRoot.getWorkOrderTaskDescByType(WorkOrderMode_ToDo,self.detailType);
	
	if desc = null then
		return null;
		
	endif;
	if _useShortDesc then
		displayString :=  desc;
	else
		displayString := "(" &amp; self.taskID.String &amp; ") " &amp; desc;
		
	endif;
	
	return displayString;
epilog

end;</source>
        <Parameter name="_useShortDesc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="13c5362a-039e-47b5-bdbf-54388eb2d370">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Mar 2023	navdp20	Defect 57143: MTN - Priority field is missing in the column organiser in the work order enquiry form
17 Mar 2023	navcs2	ChangeRequest 56842:[56843]: EUP - VAS Task Priority
20 Mar 2023 navma1  Defect 57195: MTN - WO - Priority is showing some random number on the to do work orders on the yard operations form
*/

vars

begin
	if _attrName = ETRow_Priority then
		if self.priority = CM_WorkOrder.WO_Priority_High then			//17.03.2023	navcs2	#56842:[56843] //20.03.2023 navma1 #57195
			return app.getErrorString(WO_PRIORITY_HIGH);				//17.03.2023	navcs2	#56842:[56843]
		endif;															//17.03.2023	navcs2	#56842:[56843]
		return null;
	else
		return inheritMethod(_attrName,	_short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="f89c1dbb-bd57-4e9c-895b-65495e48004c">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jan 2023	navcs2	ChangeRequest 54698:[54264] EUP - [Framework] - Enable VAS Work Order in Work Order Enquiry Screen
12 Apr 2023 navma1  ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
*/

vars
	block   	: CM_DataContainerBlock;
	addStr  	: String;	
	taskDesc 	: CM_ToDoTaskDesc;
begin
	
	inheritMethod(_dataContainer);
	block 	:= _dataContainer.addNewBlock;
	
	addStr  := self.allToDoTasksDescs.listString(Comma,CM_ToDoTaskDesc::description.name);
	
	if addStr &lt;&gt; null then
		taskDesc	:=  self.allToDoTasksDescs.first;
		block.addNewItem(app.getErrorString(Todo_task), DC_Label, 1, taskDesc);
		block.addNewItem(addStr, DC_Data, 1, taskDesc);
	endif;	
	
	
	if app.isSpecial then														//08.02.2023 navma1 #56457:[56458]
		block.addNewItem('All Jobs', DC_Label, 1, self);
		block.addNewItem(self.allJobs.size.String, DC_Data, 1, self);
	endif;
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getInstructionsForContext" id="363cbe00-609a-4511-a7d7-2b2da162d7fc">
        <source>getInstructionsForContext(_instructions: CM_InstructionsIssuedSet io; _passingObject: Object; _context: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2
19 Oct 2023	navma1  Defect 60923: MTN - Exception when selecting the Job Type as Truck Load on the Work Order Operations app
*/

vars
	dynaDict	: DynaDictionary;
	todoObj		: CM_ToDoTask;
	object		: Object;
begin
	inheritMethod(_instructions, _passingObject, _context);
	create dynaDict transient;
	dynaDict.setMembership(CM_ToDoTask);
	dynaDict.addMemberKey(CM_ToDoTask::myInstructions.name, true, true);
	dynaDict.endKeys(true);

	self.allToDoTasks.copy(dynaDict);
	
	foreach object in dynaDict do
		todoObj := object.CM_ToDoTask;
		if todoObj.getInstructions() = null then
			break;
		endif;
		todoObj.getInstructionsForContext(_instructions, _passingObject, _context);
	endforeach;
epilog
	delete dynaDict;
end;</source>
        <Parameter name="_instructions" type="CM_InstructionsIssuedSet" usage="io"/>
        <Parameter name="_passingObject" type="Object"/>
        <Parameter name="_context" type="String"/>
    </JadeMethod>
