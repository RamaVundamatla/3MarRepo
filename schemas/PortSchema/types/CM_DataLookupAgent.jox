    <JadeMethod name="resolveReference" id="25ae8ee1-4107-4d41-a171-ce63b35e5ecc">
        <source>resolveReference(
    _className: String;
    _propertyName: String;
    _key: String): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36789 - JADE Core Framework - Import Engine

*/

vars

begin
    if _key = null or _key = "" then
        return null;
    endif;
    
    // Route to class-specific methods
	
	if _className = CM_Commodity.name then
		return self.resolveCommodity(_propertyName,_key);
	elseif _className = CM_CommodityGroup.name then
		return self.resolveCommodityGroup(_propertyName,_key);
	elseif _className = CM_Carrier.name then
		return self.resolveCarrier(_propertyName,_key);
	elseif _className = CM_Debtor.name then
		return self.resolveDebtor(_propertyName,_key);
	elseif _className = CM_EventType.name then
		return self.resolveEventType(_propertyName,_key);
	elseif _className = CM_CargoType.name then
		return self.resolveCargoType(_propertyName,_key);
	elseif _className = CM_Product.name then
		return self.resolveProduct(_propertyName,_key);
	elseif _className = CM_Terminal.name then
		return self.resolveTerminal(_propertyName,_key);
	elseif _className = CM_TerminalArea.name then
		return self.resolveTerminalArea(_propertyName,_key);
	elseif _className = CM_TerminalAreaType.name then
		return self.resolveTerminalAreaType(_propertyName,_key);
	elseif _className = CM_InterchangeArea.name then
		return self.resolveInterchangeArea(_propertyName,_key);
	elseif _className = CM_TerminalAreaView.name then
		return self.resolveTerminalArea(_propertyName,_key);
	elseif _className = CM_TerminalAreaViewPosition.name then
		return self.resolveTerminalAreaViewPosition(_propertyName,_key);
	elseif _className = CM_Machine.name then
		return self.resolveMachine(_propertyName,_key);
	elseif _className = CM_DataAccessController.name then
		return self.resolveDataAccessController(_propertyName,_key);
	endif;	
	return null;
epilog

end;</source>
        <Parameter name="_className" type="String"/>
        <Parameter name="_propertyName" type="String"/>
        <Parameter name="_key" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
