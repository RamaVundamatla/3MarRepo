    </JadeMethod>
    <JadeMethod name="setCargoItem" id="5d43eb76-f218-484f-901e-00c2eadd18e5">
        <updating/>
        <source>setCargoItem(_cargoItemObj:CM_Object; _totalWeight:Decimal; _cargoCount:Integer; _isAddNew:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		02 August 2006 by cnwdad1
//
// Purpose:		Sets a reference to the Tracked Item being confirmed.
//
// Parameters:	_cargoItemObj - A reference to the cargo object to confirm.
//				_totalWeight - The total weight of the cargo item currently being
//					edited - this may have been amended by the driver.
//				_cargoCount - The unique "index" of the Cargo item.
//				_isAddNew - True if a new container is being confirmed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 25/07/2007	cnwdad1		CCMS #1493 - Added cargo item weight, which may be amended
//							by the driver.
// --------------------------------------------------------------------------------
begin
	self.aMyCargoItem	:=	_cargoItemObj;
	self.aThisWeight	:=	_totalWeight;
	self.aCargoCount	:=	_cargoCount;
	self.aIsAddNew		:=	_isAddNew;
end;</source>
        <Parameter name="_cargoItemObj" type="CM_Object"/>
        <Parameter name="_totalWeight" type="Decimal"/>
        <Parameter name="_cargoCount" type="Integer"/>
        <Parameter name="_isAddNew" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTIInterface" id="cf415d1d-a766-4437-8b24-fc3c6a7b997b">
        <updating/>
        <source>setTIInterface(_interfaceObj:CMIF_TIObject) updating;
// --------------------------------------------------------------------------------
// Created:		22 August 2006 by cnwdad1
//
// Purpose:		Sets a reference to a Bulk Release TI Interface object.
//
// Parameters:	_interfaceObj - The reference to the interface object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyTIInterface	:=	_interfaceObj;
end;</source>
        <Parameter name="_interfaceObj" type="CMIF_TIObject"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e080780b-247b-42ce-9092-b694b5764bb0">
        <updating/>
        <source>setupForm() updating, protected;
// --------------------------------------------------------------------------------
// Created:		29 June 2006 by cnwdad1
//
// Purpose:		Standard form setup method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 25/07/2007	cnwdad1		CCMS #1493 - Added cargo item weight, which may be amended
//							by the driver.
// --------------------------------------------------------------------------------
vars
	proxyLoadObj		: GTE_KioskProxyLoad;
	cargoItemObj		: CM_Object;
	proxyCargoObj		: GTE_KioskProxyCargo;
	allProxyCargoObj	: GTE_KioskProxyCargoArray;
	handleType			: String;
	isRelease			: Boolean;
	
begin
	inheritMethod();
	self.modalResult	:=	self.CNEC_MODAL_CANCEL;
	
	proxyLoadObj	:=	self.aMyProxyLoad;
	cargoItemObj	:=	self.aMyCargoItem;
	isRelease		:=	proxyLoadObj.isReleaseItem(cargoItemObj);
	if proxyLoadObj = null then
		app.writeLog("KIOSK PROXY LOAD: !null!", LogINFO);
	else
		app.writeLog("KIOSK PIN: " &amp; proxyLoadObj.pinNumber, LogINFO);
		app.writeLog("KIOSK REGO: " &amp; proxyLoadObj.regoNumber, LogINFO);
	endif;
	if cargoItemObj = null then
		app.writeLog("KIOSK CARGO ITEM: !null!", LogINFO);
	else
		app.writeLog("KIOSK CARGO ITEM: " &amp; cargoItemObj.String, LogINFO);
	endif;
	
	if isRelease then
		allProxyCargoObj	:=	proxyLoadObj.allReleases;
		handleType			:=	"released";
	else
		allProxyCargoObj	:=	proxyLoadObj.allReceivals;
		handleType			:=	"received";
	endif;
	
	if self.aIsAddNew then
	//	if allProxyCargoObj.size() &gt;= 4 then
		if allProxyCargoObj.size() &gt;= 4 and not self.isAAAI then	//19 May 2020	NDL	TFS 49167
			app.msgBox(	"The maximum containers that can be " &amp; handleType &amp; " is 4.",
						"Error",
						MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
			
			self.unloadForm();
			return;
		endif;
	
		proxyCargoObj	:=	proxyLoadObj.createCargo(	cargoItemObj,
														self.aMyTIInterface,
														self.aThisWeight,
														true);
		self.aCargoCount	:=	proxyCargoObj.count;
	else
		proxyCargoObj	:=	proxyLoadObj.findCargoForId(self.getCurrentCargoId(), self.aCargoCount);
	endif;
	
	if self.isAAAI then
		self.btnSwap.visible := false;
		self.btnMoveLoad.visible := false;
	endif;
	
	self.setupLabels(proxyCargoObj);
	self.adjustContainerLayout(allProxyCargoObj);
	
	self.caption := "KIOSK - Cargo Confirm";	//10 Sep 2021	NDL	TFS 51934
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupLabels" id="701b7995-c22b-4e3e-8fee-a00b086d2177">
        <source>setupLabels(_proxyCargoObj:GTE_KioskProxyCargo) protected;
// --------------------------------------------------------------------------------
// Created:		13 October 2006 by cnwdad1
//
// Purpose:		Sets to the form's labels depending upon whether we're processing
//				an Empty, Export or Import.
//
// Parameters:	_proxyCargoObj - A reference to the proxy Cargo object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 06/08/2007	cnwdad1		PAR #14613.  The confirmed weight of a receival was not
//							being populated in the details table - was incorrectly
//							still getting the original weight from the persistent
//							TI object.
// --------------------------------------------------------------------------------
vars
	proxyLoadObj	: GTE_KioskProxyLoad;
	bulkReleaseObj	: CM_BulkRelease;
	tiObj			: CM_TrackedItem;
	containerObj	: CM_Container;
	reserveSelObj	: CM_ReserveSelection;
	tableObj		: Table;
	columnObj		: JadeTableColumn;
	isEmpty			: Boolean;
	isExport		: Boolean;
	isImport		: Boolean;
	regoNumber		: String;
	carrierName		: String;
	weight			: String;
	commodityDesc	: String;
	hazardCode		: String;
	isHazard		: Boolean;
	temperature		: String;
	isTemperature	: Boolean;
	containerId		: String;
	overHeight		: String;
	overDim			: String;	// Over dimensional.
	dimensions		: String;
	releaseNo		: String;	// Release number.
	quantity		: String;	// Quantity;
	avaGrade		: String;	// Description.
	isoType			: String;
	remarks			: String;
	consigneeName	: String;
	tmpDisplay		: String;
	cnt				: Integer;
	res				: CM_ReserveDetail;
	
begin
	tableObj	:=	tblDetails;
	tableObj.borderStyle	:=	Table.BorderStyle_None;
	tableObj.columns		:=	4;
	tableObj.rows			:=	0;
	columnObj				:=	tableObj.accessColumn(1);
	columnObj.alignment		:=	Table.Alignment_Right;
	columnObj				:=	tableObj.accessColumn(2);
	columnObj.alignment		:=	Table.Alignment_Left;
	columnObj				:=	tableObj.accessColumn(3);
	columnObj.alignment		:=	Table.Alignment_Right;
	columnObj				:=	tableObj.accessColumn(4);
	columnObj.alignment		:=	Table.Alignment_Left;
	tableObj.partialTextIndication	:=	true;

	isEmpty		:=	false;
	isExport	:=	_proxyCargoObj.isForRelease();
	isImport	:=	_proxyCargoObj.isForReceival();
	
	if _proxyCargoObj.isBulkRelease() then
		isEmpty			:=	true;
		bulkReleaseObj	:=	_proxyCargoObj.myCargoItem.CM_BulkRelease;
//		requestObj		:=	bulkReleaseObj.getFirstTIRequest(false);
		
		if bulkReleaseObj.releaseByType then
			reserveSelObj	:=	bulkReleaseObj.allReserveDetails.first().CM_ReserveSelection;
		endif;
		
	elseif _proxyCargoObj.isTrackedItem() then
		tiObj			:=	_proxyCargoObj.myCargoItem.CM_TrackedItem;
		
		if _proxyCargoObj.isContainer() then
			containerObj	:=	_proxyCargoObj.myCargoItem.CM_Container;
		endif;
		
	endif;
	
	if _proxyCargoObj.isForReceival() then
		proxyLoadObj	:=	_proxyCargoObj.myReceivalLoad;
	elseif _proxyCargoObj.isForRelease() then
		proxyLoadObj	:=	_proxyCargoObj.myReleaseLoad;
	endif;
	
	regoNumber	:=	"TRUCK REGO: " &amp; Tab &amp; proxyLoadObj.regoNumber;
	carrierName	:=	"CARRIER: " &amp; Tab &amp; proxyLoadObj.myCarrier.code;
	containerId	:=	"CONTAINER: " &amp; Tab &amp; _proxyCargoObj.id();
	
	self.tableAddRow(tableObj, regoNumber, carrierName);
	
	if isImport then
// cnwdad1 06/08/2007 - PAR #14613.
//		weight			:=	"WEIGHT: " &amp; Tab &amp; tiObj.weight.cnEcNumberFormat();
		weight			:=	"WEIGHT: " &amp; Tab &amp; _proxyCargoObj.totalWeight.cnEcNumberFormat();
		isoType			:=	"ISO TYPE: " &amp; Tab &amp; tiObj.getISOType();
		commodityDesc	:=	"COMMODITY: " &amp; Tab &amp; tiObj.commodity;
		
		self.tableAddRow(tableObj, containerId, weight);
		self.tableAddRow(tableObj, isoType, commodityDesc);
		
		//if tiObj.allHazards.isNotEmpty() then
		if tiObj.allTIHazards.isNotEmpty() then
			isHazard	:=	true;
			hazardCode	:=	"HAZARDS: " &amp; Tab &amp; tiObj.getHazardsAsString();
		endif;
		
		if tiObj.getTemperature() &lt;&gt; NULL_TEMPERATURE then
			isTemperature	:=	true;
			temperature		:=	"TEMPERATURE: " &amp; Tab &amp; tiObj.getTemperature().String;
		endif;
		
		if isHazard or isTemperature then
			self.tableAddRow(tableObj, hazardCode, temperature);
		endif;
		
		if tiObj.isOverDimensions then
			if tiObj.length = 0 and tiObj.width = 0 then
				dimensions	:=	"H=" &amp; tiObj.height.asStringMeasurementJMT();
				overHeight	:=	"OVER HEIGHT: " &amp; Tab &amp; dimensions;
				overDim		:=	"OVER DIMENSIONAL: " &amp; Tab &amp; "NO";
			else
				if tiObj.height &lt;&gt; 0 then
					dimensions	:=	"H=" &amp; tiObj.height.asStringMeasurementJMT();
				endif;
				
				if tiObj.width &lt;&gt; 0 then
					if dimensions = null then
						dimensions	:=	"W=" &amp; tiObj.width.asStringMeasurementJMT();
					else
						dimensions	:=	dimensions &amp; " W=" &amp; tiObj.width.asStringMeasurementJMT();
					endif;
				endif;
				
				if tiObj.length &lt;&gt; 0 then
					if dimensions = null then
						dimensions	:=	"L=" &amp; tiObj.length.asStringMeasurementJMT();
					else
						dimensions	:=	dimensions &amp; " L=" &amp; tiObj.length.asStringMeasurementJMT();
					endif;
				endif;
			
				if containerObj &lt;&gt; null then
					overHeight	:=	"OVER HEIGHT: " &amp; Tab &amp; "NO";
					overDim		:=	"OVER DIMENSIONAL: " &amp; Tab &amp; dimensions;
				endif;
			endif;
		else
			overHeight	:=	"OVER HEIGHT: " &amp; Tab &amp; "NO";
			overDim		:=	"OVER DIMENSIONAL: " &amp; Tab &amp; "NO";
		endif;
		
		self.tableAddRow(tableObj, overHeight, overDim);
		
	elseif isEmpty then
		releaseNo	:=	"RELEASE: " &amp; Tab &amp; bulkReleaseObj.code;

		if _proxyCargoObj.myConsignee = null then
			consigneeName	:=	"CONSIGNEE: " &amp; Tab &amp; "";
		else
			consigneeName	:=	"CONSIGNEE: " &amp; Tab &amp; _proxyCargoObj.myConsignee.description;
		endif;
		
		self.tableAddRow(tableObj, releaseNo, consigneeName);
		
		if bulkReleaseObj.releaseByType then
			//quantity	:=	"QUANTITY: " &amp; Tab &amp; bulkReleaseObj.totalRequested.String;
			//avaGrade	:=	"AVA GRADE: " &amp; Tab &amp; bulkReleaseObj.getAvailabilityGrades();
			//isoType	:=	"ISO TYPE: " &amp; Tab &amp; reserveSelObj.getISOCode;
			//remarks	:=	"REMARKS: " &amp; Tab &amp; reserveSelObj.remarks;
			
			// 12/08/2008 cnwar2 #16563
			// if multiple reserve lines, list attributes for all reserves
			quantity	:=	"QUANTITY: " &amp; Tab;
			avaGrade	:=	"AVA GRADE: " &amp; Tab;
			isoType		:=	"ISO TYPE: " &amp; Tab;
			remarks		:=	"REMARKS: " &amp; Tab;
			if bulkReleaseObj.allReserveDetails.size &gt; 1 then
				cnt := 1; //cnwjo3 looks better when counter starts from 1
				foreach res in bulkReleaseObj.allReserveDetails discreteLock do
					tmpDisplay 	:= res.CM_ReserveSelection.getISOCode;
					isoType 	:= isoType &amp; tmpDisplay &amp; "[" &amp; cnt.String &amp; "], ";
					
					tmpDisplay 	:= res.totalRequested.String;
					quantity 	:= quantity &amp; tmpDisplay &amp; "[" &amp; cnt.String &amp; "], ";
										
					tmpDisplay 	:= res.CM_ReserveSelection.getAvailabilityGradesDescr;
					if tmpDisplay &lt;&gt; null then
						avaGrade := avaGrade &amp; tmpDisplay &amp; "[" &amp; cnt.String &amp; "], ";
					endif;
					
					tmpDisplay 	:= res.remarks;
					if tmpDisplay &lt;&gt; null then
						remarks := remarks &amp; tmpDisplay &amp; "[" &amp; cnt.String &amp; "], ";
					endif;
										
					cnt := cnt + 1;
				endforeach;
				quantity := quantity[1:quantity.length-2];
				avaGrade := avaGrade[1:avaGrade.length-2];
				isoType  := isoType[1:isoType.length-2];
				remarks  := remarks[1:remarks.length-2];
			else
				res := bulkReleaseObj.allReserveDetails.first;
				if res &lt;&gt; null then
					quantity := quantity &amp; res.totalRequested.String;
					avaGrade := avaGrade &amp; res.CM_ReserveSelection.getAvailabilityGradesDescr;
					isoType  := isoType &amp; res.CM_ReserveSelection.getISOCode;
					remarks  := remarks &amp; res.remarks;
				endif;
			endif;
					
			self.tableAddRow(tableObj, quantity, avaGrade);
			self.tableAddRow(tableObj, isoType, remarks);
		endif;
		
	elseif isExport then
		//weight			:=	"WEIGHT: " &amp; Tab &amp; tiObj.weight.cnEcNumberFormat();				//-cnwml2 MSL CCMS 1017
		weight			:=  "WEIGHT: " &amp; Tab &amp; tiObj.totalWeight.asStringWeightJMT();			//+cnwml2 MSL CCMS 1017
		isoType			:=	"ISO TYPE: " &amp; Tab &amp; tiObj.getISOType();
		
		if tiObj.getTemperature() &lt;&gt; NULL_TEMPERATURE then
			temperature		:=	"TEMPERATURE: " &amp; Tab &amp; tiObj.getTemperature().String;
		endif;
		
		if tiObj.isOverDimensions then
			if tiObj.length = 0 and tiObj.width = 0 then
				overHeight	:=	"OVER HEIGHT: " &amp; Tab &amp; "YES";
				overDim		:=	"OVER DIMENSIONAL: " &amp; Tab &amp; "NO";
			else
				if containerObj &lt;&gt; null then
					overHeight	:=	"OVER HEIGHT: " &amp; Tab &amp; "NO";
					overDim		:=	"OVER DIMENSIONAL: " &amp; Tab &amp; "YES";
				endif;
			endif;
		else
			overHeight	:=	"OVER HEIGHT: " &amp; Tab &amp; "NO";
			overDim		:=	"OVER DIMENSIONAL: " &amp; Tab &amp; "NO";
		endif;
		
		self.tableAddRow(tableObj, containerId, weight);
		self.tableAddRow(tableObj, isoType, temperature);
		self.tableAddRow(tableObj, overHeight, overDim);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_proxyCargoObj" type="GTE_KioskProxyCargo"/>
    </JadeMethod>
    <JadeMethod name="tableAddRow" id="e6b85e5d-9093-4b23-8d56-88369bc78aee">
        <source>tableAddRow(_tableObj:Table input; _pair1:String; _pair2:String) protected;
// --------------------------------------------------------------------------------
// Created:		16 October 2006 by cnwdad1
//
// Purpose:		Adds a row to the table showing the container details.  There are
//				two label/value pairs for each row (of 4 columns).
//
// Parameters:	_tableObj - A reference to the table control.
//				_pair1 - The tab-delimited label/value pair 1.
//				_pair2 - The tab-delimited label/value pair 2.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	_tableObj.addItem(_pair1 &amp; Tab &amp; _pair2);
end;</source>
        <access>protected</access>
        <Parameter name="_tableObj" type="Table" usage="input"/>
        <Parameter name="_pair1" type="String"/>
        <Parameter name="_pair2" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateForm" id="b01d5d7f-8b55-4496-857f-50a588e7c39a">
        <updating/>
        <source>updateForm(_isDelete:Boolean):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		07 August 2006 by cnwdad1
//
// Purpose:		Standard form update method.
//
// Parameters:	None
//
// Returns:		True if the update was successful, otherwise alse.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	containerObj	: CMUI_ContainerLoad;
	proxyLoadObj	: GTE_KioskProxyLoad;
	proxyCargoObj	: GTE_KioskProxyCargo;
	
begin
	proxyLoadObj	:=	self.aMyProxyLoad;
	containerObj	:=	self.getCurrentContainer();
	
	if self.isAAAI then	//25 May 2020	NDL	TFS 49167 
		proxyCargoObj := self.aMyProxyLoad.allReleases.last();
	endif;
	
	if proxyCargoObj &lt;&gt; null then	//25 May 2020	NDL	TFS 49167 
		//All good we are isAAAI and we found one.
	elseif containerObj = null or not global.isValidObject(containerObj) then
		return inheritMethod(_isDelete);
	else
		proxyCargoObj	:=	proxyLoadObj.findCargoForId(containerObj.cargoId, self.aCargoCount);
	endif;
	
	if _isDelete then
		if self.aIsAddNew then
			delete proxyCargoObj;
		endif;
	else
		proxyCargoObj.setIsConfirmed();
	endif;
	
	return inheritMethod(_isDelete);
end;</source>
        <access>protected</access>
        <Parameter name="_isDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
