    <JadeMethod name="isOutboundShipOperator_Match" id="44180858-380f-4643-86e5-f30a37655154">
        <source>isOutboundShipOperator_Match(_yaData: CM_YADataObjects): Boolean;
// TFS 3258
vars
	op : CM_Operator;
begin

	if self.myTransaction.myTrackedItem = null then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	op := self.myTransaction.myTrackedItem.getTranshipExportOperator;
	if op = null then
		return false;
	endif;

	if _yaData.isKindOf(CM_YADataPattern) then
		if _yaData.CM_YADataPattern.pattern = op.code then
			return true;
		endif;
	else
		return _yaData.matches(op);
	endif;
end;
</source>
