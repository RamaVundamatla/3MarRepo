		criteria := self.getCriteriaOfTypeValue( YACriteriaType_Colour );
	//cnwmc5 - 6 Oct 2015 - PAR 37019
	elseif _attrName = ETRow_DwellDays or _attrName = ETRow_DwellDaysNumeric then		//cnwmc5 - 4 Feb 2016 - PAR 37494
