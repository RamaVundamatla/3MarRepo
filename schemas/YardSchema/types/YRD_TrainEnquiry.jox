    <JadeMethod name="timeRefreshTrains" id="06c291c3-766b-4c96-a1e3-72a913ed73f9">
        <source>timeRefreshTrains();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2024	jlier1	Initial creation JIRA#33496 

*/

vars
	theDataLine : String;
	theTrain : CM_Train;
	colourCol,
	idx : Integer;
	invalidTrain : Boolean;
begin
	colourCol := self.tblData.getColumnByRowName(ETRow_Colour);
	on Exception do app.handleDeletedObject(exception,theTrain,invalidTrain);
	foreach theTrain in self.allTrainsToRefresh discreteLock do
		theDataLine := theTrain.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
		self.tblData.removeItemObject(theTrain);
		if invalidTrain then
			invalidTrain:=false;
			continue;
		endif;
		
		idx := self.tblData.addItem(theDataLine);
		self.tblData.accessRow(idx).itemObject := theTrain;
		if colourCol &gt; 0 then
			self.tblData.accessCell(idx, colourCol).backColor := theTrain.colour;
			self.tblData.accessedCell.text := null;
		endif;
		self.allTrainsToRefresh.tryRemove(theTrain);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="3a5dd634-dd9c-4a7c-9f74-cbc6977f36cd">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2009	cnwmd1	Initial creation

*/

vars

begin
	if eventTag = Timer_Refresh then
		self.timerRefreshActive := false;
		self.timerUpdateDwellTime();
		self.timeRefreshTrains(); //jlier1 JIRA#33496 5/12/24
	endif;
	self.beginTimerForRefresh();
epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="timerUpdateDwellTime" id="a8911074-16b5-4c66-a482-ed261115beaf">
        <source>timerUpdateDwellTime();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2009	cnwmd1	Initial creation

*/

vars
	row,
	cnt,
	pos,
	col : Integer;
	train : CM_Train;
	str	: String;
	table : CM_DataTable;
begin

	table := self.tblData;
	col := table.getColumnByRowName(ETRow_DwellTime);	
	if col &lt; 1 then
		// Dwell TIme column is not visible
		return;
	endif;
	
	on Exception do self.handleExceptionTrain(exception, train);		
	
	cnt := table.rows;
	pos := table.fixedRows+1;
	
	foreach row in pos to cnt do
		train := table.accessRow(row).itemObject.CM_Train;
		if train = null then
			continue;
		endif;
		train.fetchLatest();
		if train = null then
			continue;
		endif;		
		str := train.getDisplayStringForAttribute(ETRow_DwellTime, false);
		table.accessCell(row, col).text := str;
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="8a1c3fbc-13ac-42a9-ab80-014d86ddb3ec">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 May 2022 08:18:25.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0011032, locale);
	btnAddRequest.translateBubbleHelp(Xlat_0011033, locale);
	btnAddRequest.translateCaption(Xlat_0011034, locale);
	btnCancelFrm.translateCaption(Xlat_0011035, locale);
	btnCancelPM.translateCaption(Xlat_0013818, locale);
	btnCargoForecast.translateCaption(Xlat_0024663, locale);
	btnClearRake.translateBubbleHelp(Xlat_0012585, locale);
	btnClearRake.translateCaption(Xlat_0012586, locale);
	btnConfirmIn.translateBubbleHelp(Xlat_0014677, locale);
	btnConfirmIn.translateCaption(Xlat_0011037, locale);
	btnConfirmOut.translateBubbleHelp(Xlat_0014678, locale);
	btnConfirmOut.translateCaption(Xlat_0011039, locale);
	btnCopyTrain.translateBubbleHelp(Xlat_0011040, locale);
	btnCopyTrain.translateCaption(Xlat_0011041, locale);
	btnDefault.translateBubbleHelp(Xlat_0011042, locale);
	btnDefault.translateCaption(Xlat_0011043, locale);
	btnEnquiryRec.translateBubbleHelp(Xlat_0014679, locale);
	btnEnquiryRec.translateCaption(Xlat_0011045, locale);
	btnEnquiryRel.translateBubbleHelp(Xlat_0014680, locale);
	btnEnquiryRel.translateCaption(Xlat_0011047, locale);
	btnExport.translateBubbleHelp(Xlat_0012587, locale);
	btnExport.translateCaption(Xlat_0012588, locale);
	btnMoveToRail.translateBubbleHelp(Xlat_0011048, locale);
	btnMoveToRail.translateCaption(Xlat_0011049, locale);
	btnNew.translateBubbleHelp(Xlat_0014681, locale);
	btnNew.translateCaption(Xlat_0011051, locale);
	btnPrintCargo.translateBubbleHelp(Xlat_0011052, locale);
	btnPrintCargo.translateCaption(Xlat_0011053, locale);
	btnPrintManClose.translateCaption(Xlat_0012589, locale);
	btnPrintManOK.translateCaption(Xlat_0012590, locale);
	btnPrintManifest.translateBubbleHelp(Xlat_0014682, locale);
	btnPrintManifest.translateCaption(Xlat_0014683, locale);
	btnPrintPM.translateCaption(Xlat_0013819, locale);
	btnPrintPlainM.translateBubbleHelp(Xlat_0014684, locale);
	btnPrintPlainM.translateCaption(Xlat_0014685, locale);
	btnPrnFrame.translateCaption(Xlat_0011054, locale);
	btnRefresh.translateBubbleHelp(Xlat_0011055, locale);
	btnRefresh.translateCaption(Xlat_0011056, locale);
	btnRemarks.translateBubbleHelp(Xlat_0014686, locale);
	btnRemarks.translateCaption(Xlat_0011058, locale);
	btnSetToday.translateBubbleHelp(Xlat_0011059, locale);
	btnSetToday.translateCaption(Xlat_0011060, locale);
	btnSummariseAll.translateBubbleHelp(Xlat_0014687, locale);
	btnSummariseAll.translateCaption(Xlat_0014688, locale);
	btnTrainArrCancl.translateCaption(Xlat_0012593, locale);
	btnTrainArrSave.translateCaption(Xlat_0012594, locale);
	btnWagonIn.translateBubbleHelp(Xlat_0014689, locale);
	btnWagonIn.translateCaption(Xlat_0011064, locale);
	btnWagonOut.translateBubbleHelp(Xlat_0014690, locale);
	btnWagonOut.translateCaption(Xlat_0011066, locale);
 	chkDeparted.translateCaption(Xlat_0011067, locale);		   			//navsp1 24MAY2022 TFS#53619 - uncommented
 //	chkIncludeOnSite.translateBubbleHelp(Xlat_0023538, locale);		 	//navsp1 17MAY2022 TFS#53619
 //	chkIncludeOnSite.translateCaption(Xlat_0023539, locale);		  	//navsp1 17MAY2022 TFS#53619
	chxConsignee.translateCaption(Xlat_0011068, locale);
