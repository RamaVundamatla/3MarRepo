    <JadeMethod name="exportAsXMLDocGetChildRefKey" id="32d73473-709a-4c49-95da-58ff35285cb8">
        <source>exportAsXMLDocGetChildRefKey(_property: Property input): Property;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars

begin
	if _property = CM_HatchLid::allHolds then
		return CM_Hold::ordinalHold;
	endif;

	return inheritMethod(_property);

epilog

end;</source>
        <Parameter name="_property" type="Property" usage="input"/>
        <ReturnType type="Property"/>
    </JadeMethod>
    <JadeMethod name="getLastBayInHold" id="f7335b0f-9b05-4c35-ab1b-6eea72bfe734">
        <source>getLastBayInHold():CM_Bay;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2012	cnwndl1	Initial creation	Par 28640

*/

vars

	bay : CM_Bay;
	oridinalBay : Integer;
	highestOrdinal : Integer;
	lastBay : CM_Bay;

begin

	highestOrdinal := CM_Bay.BayOrdinalOffset;  // offset value for ordinals during update.
	
	foreach bay in self.allBays discreteLock do
		oridinalBay := bay.ordinalBay;
		if oridinalBay &lt; CM_Bay.BayOrdinalOffset then
			oridinalBay := oridinalBay + CM_Bay.BayOrdinalOffset;
		endif;
		if highestOrdinal &lt; oridinalBay then
			highestOrdinal := oridinalBay;
			lastBay := bay;
		endif;
	endforeach;
	
	return lastBay;

epilog

end;</source>
        <ReturnType type="CM_Bay"/>
    </JadeMethod>
