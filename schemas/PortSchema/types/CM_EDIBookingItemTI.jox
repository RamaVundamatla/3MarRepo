    <JadeMethod name="setImCodes" id="125a8464-89b9-47dd-9327-16b2061c4b34">
        <updating/>
        <source>setImCodes(_codes: String) updating;
//
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
//
vars
	tmpIMCodes : StringArray;
begin
	create tmpIMCodes transient;
	self.addImCodes(_codes, tmpIMCodes);			// MES1008 allow imCodes in toehr classes. Was typecasting to _ediTI.CM_EDIPrenoteTI.imCodes.add(_processedValue);
	self.imCodes.clear();							// 17/03/2014 cnwmh5 #33648
	tmpIMCodes.copy(self.imCodes);
epilog    
	delete tmpIMCodes;
end;
</source>
