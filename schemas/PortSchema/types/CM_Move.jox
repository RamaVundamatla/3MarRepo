    <JadeMethod name="isVoyageRelivant" id="15d38834-08fc-421c-8eda-8562090acd5c">
        <methodInvocation>mapping</methodInvocation>
        <source>isVoyageRelivant(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     22 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else 
		if self.transitStatus = TI_TransitStatusSOB then
			_value := true;
		else
			_value := false;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="listFlags" id="1b15f571-4e17-46de-9b50-d983415ba635">
        <source>listFlags(): String;
// ---------------------------------------------------------------------------
// Created:     Oct 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str: String;
begin
	str := str&amp;inheritMethod();
	if self.forced then
		str := str&amp;"/Forced ";
	elseif self.operational then
		str := str&amp;"/Operational ";
	elseif self.supplementary then
		str := str&amp;"/Supplementary ";
	elseif self.tbaPatch then
		str := str&amp;"/TBAPatch ";
	elseif self.unplan then
		str := str&amp;"/Unplan ";
	endif;
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="locationsControllerIsRail" id="af4a9de6-ba7c-49f8-acd4-c0ea0d2d34d7">
        <source>locationsControllerIsRail( source : Boolean ) : Boolean;

/*

Purpose:			
	// Temporary method until the database has been re-orged with a reference.....
Parameters:			

Return Value:		


Date		Who		Reason
11 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	locString : String;
	workPos : Integer;
	workString : String;
	termArea : CM_TerminalArea;
	rail : CM_Rail;
	terminal : CM_Terminal;
begin

	// temporary solution, as per Andrews request....

	if source then
		//we want the location controller of the source
		//but only if its target is not "Nowhere"
		// target of nowhere, means moveing offsite i.e. not a real wagon unload
		if targetLocn = "Nowhere" then
			return false;
		endif;
		locString := sourceLocn;
	else
		locString := targetLocn;
	endif;
	
	// If the first part of the location string is the 'id' of a 'CM_Rail' in my terminal
	// carry on, otherwise flag it we don't care..
	workPos := locString.pos(" ",1);
	if workPos = 0 then
		return false;
	endif;
	workString := locString[1:workPos - 1];
	terminal:= self.getMyTerminal;
	// 33428 Feb 2014 when this method is called from report run in background, passport.myTerminal is null, use self.myTerminal instead
	///termArea := app.myPassport.myTerminal.allTerminalAreas.getAtKey(workString);
	termArea := self.myTerminal.allTerminalAreas.getAtKey(workString);
	if termArea = null then
		return false;
	else
		if termArea.isKindOf(CM_Rail) then
			rail := termArea.CM_Rail;
		endif;
	endif;
	if rail = null then
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="source" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myTerminal" id="ae5161e6-a19d-48ce-b98f-1db55d09e7e1">
        <methodInvocation>mapping</methodInvocation>
        <source>myTerminal(set : Boolean; _value : CM_Terminal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2013	cnwndl1	Initial creation	Par 32845

*/

vars

begin

	if not set then
		if _value = null then
			if self.myTrackedItem &lt;&gt; null then
				_value := self.myTrackedItem.myTerminal;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Terminal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="operational" id="d5e46d58-5ed6-4c34-9c35-d6a79d4db7eb">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>operational(set: Boolean; _value: Boolean io) updating, mapping;
begin
	if set then
		if _value then
			flags := flags.bitOr(OperationalFlag);
		else
			flags := flags.getValueWithBitUnset(OperationalFlag);
		endif;
	else
		_value := (flags.bitAnd(OperationalFlag) &lt;&gt; 0);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="removeFromStockMovement" id="a87f2071-1334-43b3-9b97-e16eb621fc53">
        <updating/>
        <source>removeFromStockMovement( _stkMove: CM_StockMovement ) updating;
// ---------------------------------------------------------------------------
// Created:     11 March 2008 by cnwvu1
// ---------------------------------------------------------------------------
vars

begin

	if _stkMove = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unable to null stockmove reference for ' &amp; self.String);
		return;
	endif;

	if _stkMove.isInwards then
		self.myStockMovementIn 	:= null;
	else
		self.myStockMovementOut := null;
	endif;

end;</source>
        <Parameter name="_stkMove" type="CM_StockMovement"/>
    </JadeMethod>
    <JadeMethod name="sendSAP" id="1f53e5ec-2408-4460-9b80-dc636fa92ea3">
        <source>sendSAP();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 April 2019	jlgndl1	Initial creation
11/06/2025	navcs2	MTN-34987  MTN -  Disable SAP Integration

*/

vars

	term : CM_Terminal;
	iter : Iterator;
	wo : CM_WorkOrder;
	inv : CM_Invoice;
	invLineSet : CM_InvoiceLineSet;
	invLine : CM_InvoiceLine;
	sapSent : Boolean;

begin
	
	/* REMOVED FOR NOW
	
	if not isRealMove then
		// only want to do this when the ti actually moves
		return;
	endif;
	
	term := self.myTerminal;
	if term = null then		// during deferred updating
		term := self.myTrackedItem.myTerminal;
	endif;
	
	if not term.isSapFinancialEnabled then
		return;
	endif;
	
	create invLineSet transient;
	iter := self.myTrackedItem.allWorkOrders.createIterator;
	while iter.next( wo ) do
		if not wo.isWorkOrderForMove then
			continue;
		endif;
		//We only want to process work orders for moves here.
		foreach inv in wo.allInvoices discreteLock where inv.paymentType = PaymentType_PrePay do
			invLineSet.clear();
			foreach invLine in inv.invoiceLines discreteLock
			where ( invLine.getTrackedItem = self.myTrackedItem or invLine.getTrackedItem = null ) do	//14 May 2019	NDL	TFS 44248
				if invLine.externalTS05.date.isValid then
					continue;
				endif;
				if inv.hasWSDL112BgpForLine( invLine ) then	//14 May 2019	NDL	TFS 44248
					continue;
				endif;
				invLineSet.add( invLine );
			endforeach;
			if not invLineSet.isEmpty then
				inv.sendSAP( 0, CM_Invoice.INVOICE_SEND_WSDL112, invLineSet );
				sapSent := true;
				break;
			endif;
		endforeach;
		if sapSent then
			//we only want to do one SAP call per move.
			break;
		endif;
	endwhile;
	*/	
epilog

	delete invLineSet;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setCraneMoveDetailsFrom" id="f621ec3f-b96b-42e2-a215-b0f827e2f1c9">
        <updating/>
        <source>setCraneMoveDetailsFrom(_txn: CM_Move; _cta: CM_CraneLaneController) updating;

vars
begin
	self.myTerminal := _txn.myTerminal;
	self.myTrackedItem := _txn.myTrackedItem;
	self.dateTime := _txn.dateTime.addSeconds(1);
	self.voyageCode := _txn.voyageCode;
	self.machineId := _cta.myTerminalArea.CM_CraneTransferArea.getCrane.id;
	self.sourceLocn :=  _txn.allMachineMoveHistories.first.CM_MachineMoveHistory.targetLocation;
	self.targetLocn := _txn.targetLocn;
	
end;
</source>
        <Parameter name="_txn" type="CM_Move"/>
        <Parameter name="_cta" type="CM_CraneLaneController"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="71ff508a-fd2f-4215-aca7-828352f8e9b8">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_MoveTransactionController; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 11 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if _tiTransCntrl = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _tiTransCntrl. Contact Developer.');
		return;
	endif;
	self.isOverStow := _tiTransCntrl.isOverStow;  // ### TFS 53569 13MAY2022 NAVAB1
	self.completedDateTime 	:= _tiTransCntrl.completedDateTime;
	self.forced 			:= _tiTransCntrl.forced;
	self.machineId 			:= _tiTransCntrl.machineId;
	self.mode 				:= _tiTransCntrl.mode;
	self.operational 		:= _tiTransCntrl.operational;
	self.rehandle 			:= _tiTransCntrl.rehandle;
	self.sourceLocn 		:= _tiTransCntrl.sourceLocn;
	self.supplementary 		:= _tiTransCntrl.supplementary;
	self.systemGenerated := _tiTransCntrl.systemGenerated; //par19702 cnwrs1 May 2009
	self.targetLocn 		:= _tiTransCntrl.targetLocn;
	self.tbaPatch 			:= _tiTransCntrl.tbaPatch;
	self.unplan 			:= _tiTransCntrl.unplan;
	self.isReplan 			:= _tiTransCntrl.isReplan; // PAR 8072 AKB2004APR
	self.isReQueue				:= _tiTransCntrl.isReQueue; // PAR 19600
	self.isShiftMove 			:= _tiTransCntrl.isShiftMove; // PAR 18682 
	self.shiftDirection 			:= _tiTransCntrl.shiftDirection; // PAR 18682
	self.isShufflingInCurrentLocation	:= _tiTransCntrl.isShufflingInCurrentLocation; // cnwjk3 CCMS 1018 15/01/10
	self.isDirectReleaseMove 	:= _tiTransCntrl.isDirectReleaseMove; // tfs42840 jlgzm1 31/05/2019
	inheritMethod(_tiTransCntrl, _passport);
	
	if self.mode = PLANNING_MODE or  self.mode = QUEUE_MODE then
		self.sourceLocn 		:= _tiTransCntrl.sourceLocn;
		self.targetLocn 		:= _tiTransCntrl.targetLocn;
	endif;
	
	//29 Jul 2020	NDL	TFS 49581
	self.doReeferAutoJobs();
	
	//set quantity for break bulk move. Will already have set totalQuantity to the ti quantity so we only need to do if we are greater than zero
	//cnwrd1 ccms 2274
	//epr TFS 2996 7/12/16 - moved quantity and weight to CMIF_TITransaction so now handled in CM_TITransaction
	/*
	if _tiTransCntrl.quantity &gt; 0 then 
		self.totalQuantity := _tiTransCntrl.quantity;
	endif;
	
	//epr CCMS 1366 21/3/14
	if _tiTransCntrl.weight &gt; 0 then
		self.totalWeight:= _tiTransCntrl.weight;
	endif;*/

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_MoveTransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMoveDetails" id="6e910b11-be80-4205-88a2-c4fdfc239d9a">
        <updating/>
        <source>setMoveDetails(pCompleted : TimeStamp;
			   pForced : Boolean; pMachineId : String;
			   pMode : Integer; pOperational : Boolean;
			   pRehandle : Boolean; pSourceLocn : String;
			   pSupplementary, pSystemGenerated : Boolean;
			   pTargeLocn : String; 
			   pTbaPatch, pUnplan : Boolean; 
			   pIsReplan : Boolean; 
			   _isShift : Boolean; 
			   _shiftDir : Integer; 
			   _isReQueue : Boolean; 
			   _isShufflingInCurrentLocation : Boolean;
			   _quantity : Integer;
			   _weight : Decimal;
			   _volume : Decimal;
			   _isDirectReleaseMove : Boolean	//10 Sep 2019	NDL	TFS 42882
			   ) updating;
// ---------------------------------------------------------------------------
// Created:     26 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.completedDateTime	:= pCompleted;
	self.forced			:= pForced;
	self.machineId		:= pMachineId;
	self.mode			:= pMode;
	self.operational	:= pOperational;
	self.rehandle		:= pRehandle;
	self.sourceLocn		:= pSourceLocn;
	self.supplementary	:= pSupplementary;
	self.systemGenerated:= pSystemGenerated;
	self.targetLocn		:= pTargeLocn;
	self.tbaPatch		:= pTbaPatch;
	self.unplan			:= pUnplan;
	self.isReplan 		:= pIsReplan;
	self.isShiftMove := _isShift;
	self.shiftDirection := _shiftDir;
	self.isReQueue := _isReQueue; // PAR 19600
	self.isShufflingInCurrentLocation := _isShufflingInCurrentLocation; // cnwjk3 CCMS 1018 15/01/10
	self.isDirectReleaseMove := _isDirectReleaseMove;	//10 Sep 2019	NDL	TFS 42882
	
		
	//set quantity for break bulk move. Will already have set totalQuantity to the ti quantity so we only need to do if we are greater than zero
	//cnwrd1 ccms 2274
	if _quantity &gt; 0 then 
		self.totalQuantity := _quantity;
	endif;
	
	if _weight &gt; 0  then
		self.totalWeight := _weight;
	endif;
	if _volume &gt; 0 then // TFS 7031
		self.totalVolume := _volume; // TFS 7031
	endif;
end;</source>
        <Parameter name="pCompleted" type="TimeStamp"/>
        <Parameter name="pForced" type="Boolean"/>
        <Parameter name="pMachineId" type="String"/>
        <Parameter name="pMode" type="Integer"/>
        <Parameter name="pOperational" type="Boolean"/>
        <Parameter name="pRehandle" type="Boolean"/>
        <Parameter name="pSourceLocn" type="String"/>
        <Parameter name="pSupplementary" type="Boolean"/>
        <Parameter name="pSystemGenerated" type="Boolean"/>
        <Parameter name="pTargeLocn" type="String"/>
        <Parameter name="pTbaPatch" type="Boolean"/>
        <Parameter name="pUnplan" type="Boolean"/>
        <Parameter name="pIsReplan" type="Boolean"/>
        <Parameter name="_isShift" type="Boolean"/>
        <Parameter name="_shiftDir" type="Integer"/>
        <Parameter name="_isReQueue" type="Boolean"/>
        <Parameter name="_isShufflingInCurrentLocation" type="Boolean"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_isDirectReleaseMove" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="300430c6-4431-4185-a9d6-667b019cbdcd">
        <updating/>
        <source>setMyTrackedItem(pTI: CM_TrackedItem; _tiTransCntrl: CMIF_TITransactionController) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 13/06/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//
vars

	priorLocation : CM_LocationsController;
	void : Integer;
	sourceLC : CM_LocationsController;
	targetLC : CM_LocationsController;
	createLA : Boolean;
	updateType : Character;
	wle : CM_WorkListEntry;
	makeMove : Boolean;
	ti : CM_TrackedItem;
begin
	inheritMethod(pTI, _tiTransCntrl);

	ti := self.myTrackedItem; // ### TFS 53369 28APR2022 NAVAB1

	// if we are a tranship on site, set stevedore from the import voyage
	// this is for invoicing purposes
	if self.imExStatus = TI_IMEX_STATUS_TRANSHIP then
		app.myPassport.myTerminal.findLocationFromString(ti.priorLocation, false, priorLocation, void);
		if priorLocation &lt;&gt; null and priorLocation.isKindOf(CM_VoyageController) and priorLocation.CM_VoyageController.myVoyage = ti.myVoyageTranshipImport then
			self.stevedoreCode := ti.getStevedoreForTranshipImport();
		endif;
	endif;
	
	//13 Apr 2021	NDL	TFS 50906
	if self.mode = REAL_MODE then
		//We actually only want moves that involve Yard Locations
		createLA := true;
		//jlier1 MTN-34609 15/4/25
		if _tiTransCntrl &lt;&gt; null then
			sourceLC:=_tiTransCntrl.myOriginatingLocation;
			targetLC:=_tiTransCntrl.myToPrimaryLocation;
		else
			sourceLC := self.getSourceLocationsController;
			targetLC := self.getTargetLocationsController;
		endif;
	
		if sourceLC = null and targetLC = null then
			createLA := false;
		elseif sourceLC = null then
			if not targetLC.isActivityTrackingLocation then
				createLA := false;
			endif;
		elseif targetLC = null then
			if not sourceLC.isActivityTrackingLocation then
				createLA := false;
			endif;
		endif;
		
	endif;
	if createLA then
		self.createEventLocationActivity( pTI, _tiTransCntrl );
	endif;
	
	 // ### TFS 51855 21DEC2021 NAVAB1
	if app.myPassport.isOpsViewEnabled(self.getMyTerminal()) then
		if _tiTransCntrl &lt;&gt; null then // ### TFS 51855 08FEB2022 NAVAB1
			wle :=  _tiTransCntrl.getWLE(); // ### TFS 51855 08FEB2022 NAVAB1
		endif;
			
		if wle = null then // ### TFS 53369 28APR2022 NAVAB1 straight instant move 
			makeMove := true; // ### TFS 53369 28APR2022 NAVAB1
		else
			makeMove := (wle.isRoad or wle.isRail  // ### TFS 53369 28APR2022 NAVAB1 not LOLO voyage jobs
				or wle.isVoyageHoldJob()); // ### TFS 53105 16JUN2022 NAVAB1
		endif;
		
		// ROAD and RAIL Instant Moves
		if not self.isMachineMove()  // ### TFS 51855 08FEB2022 NAVAB1
 // ### TFS 53369 28APR2022 NAVAB1		and wle &lt;&gt; null // ### TFS 51855 08FEB2022 NAVAB1
 // ### TFS 53369 28APR2022 NAVAB1		and (wle.isRoad or wle.isRail) // ### TFS 51855 09FEB2022 NAVAB1
		and makeMove // ### TFS 53369 28APR2022 NAVAB1
		and self.isRealMove then  // ### TFS 51855 08FEB2022 NAVAB1
			// ### TFS 53630 17MAY2022 NAVAB1  updateType := BGP_OpsViewWSRequest.OPS_ACTION_CREATE;  // ### TFS 51855 03FEB2022 NAVAB1
		
			self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_MOVE, self);  // ### TFS 51855 03FEB2022 NAVAB1  // ### TFS 53630 17MAY2022 NAVAB1 stopped using local variable
			if ti &lt;&gt; null then // ### TFS 53369 28APR2022 NAVAB1
				if sourceLC &lt;&gt; null then // ### TFS 53569 10MAY2022 NAVAB1 ignore moves from NOWHERE
					ti.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM, ti);  // ### TFS 53369 28APR2022 NAVAB1
					
				
 // ### TFS 53105 16JUN2022 NAVAB1				elseif not ti.isContainer() then // ### TFS 53105 08JUN2022 NAVAB1 
 // ### TFS 53105 16JUN2022 NAVAB1					ti.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM, ti); // ### TFS 53105 08JUN2022 NAVAB1
				endif;
			endif;
		
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
    </JadeMethod>
    <JadeMethod name="setNewProperties" id="79d24684-0849-4fb8-8490-9ca23cc1536d">
        <updating/>
        <source>setNewProperties(previousTrans: CM_TITransaction input) updating;

vars
	slc:  CM_LocationsController;
	tlc:  CM_LocationsController;
	term : CM_Terminal;
	atHeight : Integer;
	
begin
	inheritMethod(previousTrans);
	
	term := self.myTrackedItem.myTerminal;

	// if we were received by ship and
	//   this is a move from ship to terminal and
	//   the contents status is empty (TI_CONTENTS_STATUS_EMPTY) and
	//   the IMEX status is storage then it is a fairly good bet that
	if self.myTrackedItem.receiptTransportMode = TI_TRANSMODE_SHIP and
	   self.imExStatus = TI_IMEX_STATUS_STORAGE and
	   self.contentsStatus = TI_CONTENTS_STATUS_EMPTY then	

		term.findLocationFromString(sourceLocn, false, slc, atHeight);
		term.findLocationFromString(targetLocn, false, tlc, atHeight);
		if slc &lt;&gt; null and tlc &lt;&gt; null and
			CM_SlotController.hasInstance(slc) and
			not CM_SlotController.hasInstance(tlc) then
			// we are a ship to terminal move
			previousTrans.imExStatus := TI_IMEX_STATUS_IMPORT;
		endif;

	endif;
	
end;</source>
        <Parameter name="previousTrans" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
    <JadeMethod name="sourceTATypeDesc" id="9d9b8c5a-7fdd-47ce-9142-6b1e1e6b41b4">
        <methodInvocation>mapping</methodInvocation>
        <source>sourceTATypeDesc(set: Boolean; _value: String io) mapping;
//----------------------------------------------------------------
//	Created:	11 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpFoundLC : CM_LocationsController;
	tmpFoundHeight : Integer;
begin

	
	_value := null;
	if set then
		// set code here
		app.raiseSetVirtualError(class.name, method.name);
		return;		
	else
		// get code here
		self.myTerminal.findLocationFromString(self.sourceLocn, false, tmpFoundLC, tmpFoundHeight);
		if tmpFoundLC &lt;&gt; null then
			//some locations do not have terminal areas e.g. voyage locations
			if tmpFoundLC.myTerminalArea &lt;&gt; null then
				_value := tmpFoundLC.myTerminalArea.typeString;
			endif;
		endif;		
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="sourceTerminalAreaType" id="280b18b4-487c-4d8c-b950-8f5213762f60">
        <methodInvocation>mapping</methodInvocation>
        <source>sourceTerminalAreaType(set: Boolean; _value: Integer io) mapping;
//--------------------------------------------------
// Created:	07 September 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpFoundLC : CM_LocationsController;
	tmpFoundHeight : Integer;
begin

	//CCMS 1277 - they want the Terminal area type integer as per DQ
	_value := TA_TYPE_NULL;
	if set then
		// set code here
		app.raiseSetVirtualError(class.name, method.name);
		return;		
	else
		//cnwmc5 - 31 Oct 2013 - PAR 32890
		if self.myTerminal = null then
			return;
		endif;
		
		// get code here
		self.myTerminal.findLocationFromString(self.sourceLocn, false, tmpFoundLC, tmpFoundHeight);
		if tmpFoundLC &lt;&gt; null then
			//some locations do not have terminal areas e.g. voyage locations
			if tmpFoundLC.myTerminalArea &lt;&gt; null then
				_value := tmpFoundLC.myTerminalArea.type;
			endif;
		endif;		
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="supplementary" id="b2fbd4a4-c0e9-4669-9a42-c4f3f25f2238">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>supplementary(set: Boolean; _value: Boolean io) updating, mapping;
begin
	if set then
		if _value then
			flags := flags.bitOr(SupplementaryFlag);
		else
			flags := flags.getValueWithBitUnset(SupplementaryFlag);
		endif;
	else
		_value := (flags.bitAnd(SupplementaryFlag) &lt;&gt; 0);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="targetTATypeDesc" id="5954aa00-ebe2-46ba-ab70-9fb6a5c2e43d">
        <methodInvocation>mapping</methodInvocation>
        <source>targetTATypeDesc(set: Boolean; _value: String io) mapping;
//----------------------------------------------------------------
//	Created:	11 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	tmpFoundLC : CM_LocationsController;
