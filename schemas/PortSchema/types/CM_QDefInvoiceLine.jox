    <JadeMethod name="getSelectorVisibleColumns" id="ddd42dc2-050e-4bbc-9cb2-94ceb2cfcb95">
        <source>getSelectorVisibleColumns(_sa: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars
	qProp	: CM_QueryProperty;
begin
	inheritMethod(_sa);
	
	qProp := self.allQueryProperties[CM_InvoiceLine::getTerminal.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	qProp := self.allQueryProperties[CM_InvoiceLine::bank.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	qProp := self.allQueryProperties[CM_InvoiceLine::getDebtor.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	qProp := self.allQueryProperties[CM_InvoiceLine::getInvSequenceNum.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	qProp := self.allQueryProperties[CM_InvoiceLine::sequenceNum.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	
	qProp := self.allQueryProperties[CM_InvoiceLine::lineTotal.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;

epilog

end;</source>
        <Parameter name="_sa" type="StringArray" usage="input"/>
    </JadeMethod>
