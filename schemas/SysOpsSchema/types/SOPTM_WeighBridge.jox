    <JadeMethod name="doMnuContext1Click" id="2338287c-ec98-46cc-9f89-6ba1c1e090f8">
        <updating/>
        <source>doMnuContext1Click(theMenuItem: MenuItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

	weighBridge : CM_WeighBridgeObj;
	strArray : StringArray512;
	str : String;
	msg : String;
	weightType : CM_MeasurementType;
	rawWeight : Integer;
	weightStr : String;

begin

	weighBridge := self.myForm.myCurrentObject.CM_WeighBridgeObj;
	if weighBridge = null then
		weighBridge := self.myForm.myProxyObject.CM_WeighBridgeObj;
	endif;
	if weighBridge &lt;&gt; null then
		create strArray transient;
		weighBridge.doWeighBridgeRequest(weightType,rawWeight,true,strArray,null);
		foreach str in strArray do
			if msg &lt;&gt; null then
				msg := msg &amp; CrLf;
			endif;
			msg := msg &amp; str;
		endforeach;
		if rawWeight &lt;&gt; null then
			weightStr := rawWeight.String;
			if weightType &lt;&gt; null then
				weightStr := weightStr &amp; " " &amp; weightType.shortName;
			endif;
		else
			if weightType &lt;&gt; null then
				weightStr := "0 " &amp; weightType.shortName;
			endif;
		endif;
		if weightStr &lt;&gt; null then
			if msg &lt;&gt; null then
				msg := msg &amp; CrLf &amp; weightStr;
			else
				msg := weightStr;
			endif;
		endif;
		app.msgBox(msg,"Log",MsgBox_OK_Only);
	endif;

epilog

	delete strArray;

end;</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="62cc79da-73f2-49b5-9732-f7e5b4255c03">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2014	cnwndl1	Initial creation	Par 33268
21 02 17 cnwns1 TFS3153:PKT - Bulk Process - WeighBridge Integration
*/

vars

	proxyWeighBridgeObj : CM_WeighBridgeObj;
	lName : String;
	lIpAddress : String;
	lWeighBridgeType : CM_WeighBridgeObjType;
	lPortNumber : Integer;
	lTimeOutSeconds : Integer;
	theForm : SOP_TableMaintForm;
	lAutoRequest : Boolean;
	lComputerName : String;							//TFS 3153
	lGateLaneController : CM_GateAreaLaneController;//TFS 3153
	lMeasurementType : CM_MeasurementType;			//TFS 3153
	deviceAddress : Integer;	//25 May 2017	NDL	TFS 4383
	updateCargoMode : Integer;	//05 Jul 2019	NDL	TFS 44965
	canUpdateRTS : Boolean;	//11 May 2020	NDL	TFS 49296
	deviceId		: String; // ### TFS 52773 1APR2022 NAVPW1
	
begin

	theForm := self.myForm; 
	lName := theForm.tblInput1.getValueByName(ETRow_Name).String;
	lIpAddress := theForm.tblInput1.getValueByName(ETRow_IpAddress).String;
	lWeighBridgeType := theForm.cmbWBridgeType.listObject.CM_WeighBridgeObjType;
	lPortNumber := theForm.tblInput1.getValueByName(ETRow_PortNumber).Integer;
	lTimeOutSeconds := theForm.tblInput1.getValueByName(ETRow_TimeOutSeconds).Integer;
	lAutoRequest := theForm.tblInput1.getValueByName(ETRow_AutoRequest).Boolean;
	canUpdateRTS := theForm.tblInput1.getValueByName(ETRow_CanUpdateRTS).Boolean;	//11 May 2020	NDL	TFS 49296
	
	lComputerName := theForm.tblInput1.getValueByName(ETRow_ComputerName).String;	//TFS 3153
	lGateLaneController := theForm.cmbGateLane.listObject.CM_GateAreaLaneController;//TFS 3153
	
	lMeasurementType	:= theForm.cmbMeasureUnit.listObject.CM_MeasurementType;
	deviceAddress 		:= theForm.tblInput1.getValueByName(ETRow_DeviceAddress).Integer;		//25 May 2017	NDL	TFS 4383
	deviceId			:= theForm.tblInput1.getValueByName(ETRow_DeviceID).String;			// ### TFS 52773 1APR2022 NAVPW1
	
	//05 Jul 2019	NDL	TFS 44965
	if theForm.cmbUpdatedAfter.listIndex &gt; 0 then
		updateCargoMode := theForm.cmbUpdatedAfter.itemData[ theForm.cmbUpdatedAfter.listIndex ];
	endif;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_WeighBridgeObj transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	
	
	
	
	proxyWeighBridgeObj := theForm.myProxyObject.CM_WeighBridgeObj;
	proxyWeighBridgeObj.setProxy(	lName,	//_name : String;
									lIpAddress,	//_ipAddress : String;
									lPortNumber,	//_portNumber : Integer;
									lTimeOutSeconds,	//_timeOutSeconds : Integer;
									lWeighBridgeType,	//_myWeighBridgeType : CM_WeighBridgeObjType;
									theForm.myTerminal,	//_myTerminal : CM_Terminal;
									lAutoRequest,	//_autoRequest : Boolean 
									lComputerName,		//TFS3153
									lGateLaneController,//TFS3153
									lMeasurementType,	//TFS3153
									deviceAddress,	//_deviceAddress : Integer	//25 May 2017	NDL	TFS 4383
									updateCargoMode,	//_updateCargoMode : Integer	//05 Jul 2019	NDL	TFS 44965
									canUpdateRTS,	//11 May 2020	NDL	TFS 49296
									deviceId		// ### TFS 52773 21APR2022 NAVPW1
									);

									
				
	
		
	
	if theForm.mode = theForm.Mode_Add then
		 app.myTrxCA.trxCreateWeighBridgeObj(proxyWeighBridgeObj, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateWeighBridgeObj(proxyWeighBridgeObj, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
