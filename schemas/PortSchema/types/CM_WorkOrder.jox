    <JadeMethod name="setProxy" id="58801368-b6f7-4b52-955f-391749897308">
        <updating/>
        <source>setProxy(
		_allEmailAddresses 	: CM_EmailEntityByTypeNameDict; 
		_customerReference 	: String;
		_emailNotification	: Boolean;
		_enteredByDT		: TimeStamp;
		_enteredByUser 		: CM_User;
