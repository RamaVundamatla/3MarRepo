    <JadeMethod name="calculateCheckSum" id="e830b4ac-dfe5-4987-ab8f-4ed02cd1c956">
        <source>calculateCheckSum(pRegistrationData:Binary):Integer protected;
// --------------------------------------------------------------------------------
// Created:		16 January 2003 by cnwdad1
//
// Purpose:		Calculates a checksum for the binary registration data to verify
//				that the registration details have not been altered.
//
// Parameters:	pRegistrationData - The binary registration data.
//
// Returns:		The checksum value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	checkSum		: Integer;
	dataLength		: Integer;
	bytePosition	: Integer;
	
begin
	dataLength	:=	pRegistrationData.length();
	
	foreach bytePosition in 5 to dataLength do
		checkSum	:=	checkSum.bitXor(pRegistrationData[bytePosition]);
	endforeach;
epilog
	return checkSum;
end;</source>
        <access>protected</access>
        <Parameter name="pRegistrationData" type="Binary"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="convertHexToBinary" id="1b87aad2-77d1-4172-8e5c-50dc1a77d847">
        <source>convertHexToBinary(pHex:String):Binary protected;
// --------------------------------------------------------------------------------
// Created:		16 January 2003 by cnwdad1
//
// Purpose:		Convert the integer value of the string of hex characters into binary
//				data.  Take the leading hex characters, maximum of 7 to fit within
//				integer max size, or take 0 if first character of string is not hex.
//
// Parameters:	pHex - The hex character to convert to binary.
//
// Returns:		The binary data.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	charIndex			: Integer;
	hexValueOfString	: Integer;
	integerValueOfChar	: Integer;
	maximumLength		: Integer;
	multiplier			: Integer;
	substringChar		: Character;
	workString			: String;

begin
	hexValueOfString	:=	0;
	multiplier			:=	1;
	maximumLength		:=	pHex.trimBlanks().length();
	
	if maximumLength &gt; 7 then
		maximumLength	:=	7;
	endif;
	
	multiplier	:=	16 ^ (maximumLength - 1);
	
	foreach charIndex in 1 to maximumLength do
		substringChar		:=	pHex[charIndex:1].toUpper().Character;
		integerValueOfChar	:=	"0123456789ABCDEF".pos(substringChar, 1);
		
		if integerValueOfChar = 0 then
			break;
		else
			integerValueOfChar	:=	integerValueOfChar - 1;
			hexValueOfString	:=	hexValueOfString + integerValueOfChar * multiplier;
		endif;
		
		multiplier	:=	multiplier div 16;
	endforeach;

	//return hexValueOfString.Character.Binary;	// - #26588	01/02/2011
	return hexValueOfString.Byte.Binary;		// + #26588 01/022011. License key is always dealing with 'ansi' characters in the range 0 - 255. Just take the first byte.

	// Following from changes made by Brian Johnstone in their copy for unicode.
	// ------------------------------------------------------------------------
	// Unicode 'characters' should be 2 or 4 bytes and we have Endian considerations that
	// could also affect the "binary" representation of a given character.  However, we're
	// always dealing with characters in the ranage 0 - 255.  We can therfore take the
	// integer value of the character, convert that to a 'byte' and then to a Binary.
	// Then we get the same result regardless of Unicode/Ansi, bytes per character or Endian-ness.
	// hexValueOfString.Character.Integer.Byte.Binary;
	
	
end;</source>
        <access>protected</access>
        <Parameter name="pHex" type="String"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="decompose" id="f95f6547-a670-4f1e-b95c-59ae9354655f">
        <updating/>
        <source>decompose(pCustomerName:String; pLicenseKey:String):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		16 January 2003 by cnwdad1
//
// Purpose:		Installs the Customer's Product license key.
//
// Parameters:	pCustomerName - The name of the Customer.
//				pLicenseKey - The product license key.
//
// Returns:		True if the license was successfull installed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	registrationData	: Binary;
	testCustomerHash	: Integer;
	currentDate			: Date;
	
	// Serial checksum and key.
	
	checkSum			: Integer;		// Bytes 1-4
	keyByte				: Integer;		// Bytes 5-8
	
	// Encrypted details.
	
	productCodeSize		: String[2];	// Bytes 9-10
	productCode			: String[10];	// Bytes 11-20
	customerHash		: Integer;		// Bytes 21-24
	expiryDate			: Date;			// Bytes 25-28
	bitMask				: Binary;		// Bytes 29-... (depending upon the number of options)
	
begin
	// Convert the hex key into a binary, and unencrypt the data.

	if pLicenseKey.length &lt;= 8 then
		self.myServiceManager.raiseJSSException(JSS_EX_00073);
		return false;
	endif;
	
	registrationData	:=	self.doHexToBinary(pLicenseKey);
	self.xorRegistrationData(registrationData);
	
	// Validate the checksum to ensure that the license hasn't been tampered with.
	
	if not self.validateCheckSum(registrationData) then
		self.myServiceManager.raiseJSSException(JSS_EX_00073);
		return false;
	endif;

	if registrationData.length &lt;= 29 then
		self.myServiceManager.raiseJSSException(JSS_EX_00073);
		return false;
	endif;
	
	// Extract the license key information from the registration data.
	
	checkSum		:=	registrationData[1:4].Integer;
	keyByte			:=	registrationData[5:4].Integer;
	if app.isUnicode then	// #26588 01/02/2011 - need to interpret binary as ansi characters
		productCodeSize	:=	registrationData[9:2].ansiToUnicode().String;
		productCode		:=	registrationData[11:(productCodeSize.Integer)].ansiToUnicode().String;
	else
		productCodeSize	:=	registrationData[9:2].String;
		productCode		:=	registrationData[11:(productCodeSize.Integer)].String;
	endif;
	customerHash	:=	registrationData[21:4].Integer;
	expiryDate		:=	registrationData[25:4].Date;
	bitMask			:=	registrationData[29:end];
	
	// Compare the customer name hash to ensure that the license is for the correct customer.
	
	testCustomerHash	:=	self.hashCustomer(pCustomerName);
	
	if customerHash &lt;&gt; testCustomerHash then
		self.myServiceManager.raiseJSSException1(JSS_EX_00074, pCustomerName);
		return false;
	endif;
	
	// Check the expiry date of the license key.
	
	currentDate	:=	app.actualTimeServer().date();
	
	if currentDate &gt; expiryDate then
		self.myServiceManager.raiseJSSException1(JSS_EX_00075, expiryDate.display());
		return false;
	endif;
	
	// All is well, so store the license key information on the receiver.
	
	self.data1	:=	pLicenseKey;
	self.data2	:=	bitMask;
	self.data3	:=	expiryDate.Binary;
	self.data4	:=	productCode.Binary;
	
	return true;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pLicenseKey" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="decomposeEWS" id="6e3c7013-c18d-4d54-8778-5937bc8e5410">
        <updating/>
        <source>decomposeEWS(pCustomerName:String; pLicenseKey:String):Boolean updating;
// ### JIRA 33541 12DEC2024 NAVAB1
vars
	registrationData	: Binary;
	testCustomerHash	: Integer;
	currentDate			: Date;
	
	// Serial checksum and key.
	
	checkSum			: Integer;		// Bytes 1-4
	keyByte				: Integer;		// Bytes 5-8
	bitMaskLength 		: Integer;		// Bytes 9-12
	
	// Encrypted details.
	
	productCodeSize		: String[2];	// Bytes 13-10
	productCode			: String[10];	// Bytes 15-20
	customerHash		: Integer;		// Bytes 25-24
	expiryDate			: Date;			// Bytes 29-28
	bitMask				: Binary;		// Bytes 33-... (depending upon bitMaskLength)
	datesArray			: Binary;		// Bytes ...-end;
	
begin
	// Convert the hex key into a binary, and unencrypt the data.
	
	registrationData	:=	self.doHexToBinary(pLicenseKey);
	self.xorRegistrationData(registrationData);
	
	// Validate the checksum to ensure that the license hasn't been tampered with.
	
	if not self.validateCheckSum(registrationData) then
		self.myServiceManager.raiseJSSException(JSS_EX_00073);
		return false;
	endif;
	
	// Extract the license key information from the registration data.
	
	checkSum		:=	registrationData[1:4].Integer;
	keyByte			:=	registrationData[5:4].Integer;
	bitMaskLength	:=	registrationData[9:4].Integer;
	if app.isUnicode then	
		productCodeSize	:=	registrationData[13:2].ansiToUnicode().String;
		productCode		:=	registrationData[15:(productCodeSize.Integer)].ansiToUnicode().String;
	else
		productCodeSize	:=	registrationData[13:2].String;
		productCode		:=	registrationData[15:(productCodeSize.Integer)].String;
	endif;

	customerHash	:=	registrationData[25:4].Integer;
	expiryDate		:=	registrationData[29:4].Date;
	bitMask			:=	registrationData[33:bitMaskLength];
	datesArray 		:= registrationData[33+bitMaskLength:end];
	
	// Compare the customer name hash to ensure that the license is for the correct customer.
	
	testCustomerHash	:=	self.hashCustomer(pCustomerName);
	
	if customerHash &lt;&gt; testCustomerHash then
		self.myServiceManager.raiseJSSException1(JSS_EX_00074, pCustomerName);
		return false;
	endif;
	
	// Check the expiry date of the license key.
	
	currentDate	:=	app.actualTimeServer().date();
	
	if customerHash &lt;&gt; testCustomerHash then
		self.myServiceManager.raiseJSSException1(JSS_EX_00074, pCustomerName);
		return false;
	endif;
	
	// All is well, so store the license key information on the receiver.
	
	self.data1	:=	pLicenseKey;
	self.data2	:=	bitMask;
	self.data3	:=	expiryDate.Binary;
	self.data4	:=	productCode.Binary;
	self.data5	:=	datesArray;

	return true;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pLicenseKey" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="decomposeSubs" id="e2bc69e8-23a6-4eba-bbe5-cf1cd25902d4">
        <updating/>
        <source>decomposeSubs(pCustomerName:String; pLicenseKey:String):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 June 2020	jlgndl1	Initial creation	TFS 49586

*/

vars
	registrationData	: Binary;
	testCustomerHash	: Integer;
	currentDate			: Date;
	
	// Serial checksum and key.
	
	checkSum			: Integer;		// Bytes 1-4
	keyByte				: Integer;		// Bytes 5-8
	bitMaskLength 		: Integer;		// Bytes 9-12
	
	// Encrypted details.
	
	productCodeSize		: String[2];	// Bytes 13-10
	productCode			: String[10];	// Bytes 15-20
	customerHash		: Integer;		// Bytes 25-24
	expiryDate			: Date;			// Bytes 29-28
	bitMask				: Binary;		// Bytes 33-... (depending upon bitMaskLength)
	datesArray			: Binary;		// Bytes ...-end;
	
begin
	// Convert the hex key into a binary, and unencrypt the data.
	
	registrationData	:=	self.doHexToBinary(pLicenseKey);
	self.xorRegistrationData(registrationData);
	
	// Validate the checksum to ensure that the license hasn't been tampered with.
	
	if not self.validateCheckSum(registrationData) then
		self.myServiceManager.raiseJSSException(JSS_EX_00073);
		return false;
	endif;
	
	// Extract the license key information from the registration data.
	
	checkSum		:=	registrationData[1:4].Integer;
	keyByte			:=	registrationData[5:4].Integer;
	bitMaskLength	:=	registrationData[9:4].Integer;
	if app.isUnicode then	
		productCodeSize	:=	registrationData[13:2].ansiToUnicode().String;
		productCode		:=	registrationData[15:(productCodeSize.Integer)].ansiToUnicode().String;
	else
		productCodeSize	:=	registrationData[13:2].String;
		productCode		:=	registrationData[15:(productCodeSize.Integer)].String;
	endif;
	// 11/3/16  cnwns1 PAR 36286 unicode version
	customerHash	:=	registrationData[25:4].Integer;
	expiryDate		:=	registrationData[29:4].Date;
	bitMask			:=	registrationData[33:bitMaskLength];
	datesArray 		:= registrationData[33+bitMaskLength:end];
	
	// Compare the customer name hash to ensure that the license is for the correct customer.
	
	testCustomerHash	:=	self.hashCustomer(pCustomerName);
	
	if customerHash &lt;&gt; testCustomerHash then
		self.myServiceManager.raiseJSSException1(JSS_EX_00074, pCustomerName);
		return false;
	endif;
	
	// Check the expiry date of the license key.
	
	currentDate	:=	app.actualTimeServer().date();
	
	if customerHash &lt;&gt; testCustomerHash then
		self.myServiceManager.raiseJSSException1(JSS_EX_00074, pCustomerName);
		return false;
	endif;
	
	// All is well, so store the license key information on the receiver.
	
	self.data1	:=	pLicenseKey;
	self.data2	:=	bitMask;
	self.data3	:=	expiryDate.Binary;
	self.data4	:=	productCode.Binary;
	self.data5	:=	datesArray;

	return true;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pLicenseKey" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doHexToBinary" id="9714dcd7-5edf-4948-a321-9ceb8a9f5fb8">
        <source>doHexToBinary(pLicenseKey:String):Binary protected;
// --------------------------------------------------------------------------------
// Created:		16 January 2003 by cnwdad1
//
// Purpose:		Converts the hex license key into binary data.
//
// Parameters:	pLicenseKey - The product license key.
//
// Returns:		The binary registration data.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	hexPointer			: Integer;
	stringLength		: Integer;
	hexCharacter		: String;
	registrationData	: Binary;
	
begin
	stringLength	:=	pLicenseKey.trimBlanks().length();
	
	foreach hexPointer in 1 to stringLength step 2 do
		hexCharacter		:=	pLicenseKey[hexPointer:2];
		registrationData	:=	registrationData &amp; self.convertHexToBinary(hexCharacter);
	endforeach;
epilog
	return registrationData;
end;</source>
        <access>protected</access>
        <Parameter name="pLicenseKey" type="String"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="hashCustomer" id="e9476e6e-ade9-4a8b-a0c8-9c56ee55c994">
        <source>hashCustomer(pCustomerName:String):Integer protected;
// --------------------------------------------------------------------------------
// Created:		15 January 2003 by cnwdad1
//
// Purpose:		Generate a hash from the Customer's name, for inclusion in the
//				binary registration data, and hence the license key.
//
// Parameters:	pCustomerName - The name of the Customer.
//
// Returns:		The name hash.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	nameHash		: Integer;
	charPosition	: Integer;
	nameLength		: Integer;
	currentChar		: Character;
	
begin
	nameLength	:=	pCustomerName.length();
	
	foreach charPosition in 1 to nameLength do
		currentChar	:=	pCustomerName[charPosition];
		// Multiplying nameHash by 2 rotates all bits to the left, leaving the low-end bit as "0".
		nameHash	:=	(nameHash * 2).bitXor(currentChar.Integer);
	endforeach;
	
	if nameHash &lt; 0 then
		nameHash	:=	nameHash * -1;
	endif;
epilog
	return (nameHash.bitAnd(#FF000000) div #1000000);	// Return the high-byte value of the hash.
end;</source>
        <access>protected</access>
        <Parameter name="pCustomerName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setServiceManager" id="7626ad79-f04d-4e65-9585-061d4c7fb6a2">
        <updating/>
        <source>setServiceManager(pTheServiceManager:JSSLKServiceManager) updating;
// --------------------------------------------------------------------------------
// Created:		26 March 2003 by cnwdad1
//
// Purpose:		Sets a reference to the peer schema Service Manager object.
//
// Parameters:	pTheServiceManager - A reference to the Service Manager object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myServiceManager	:=	pTheServiceManager;
end;</source>
        <Parameter name="pTheServiceManager" type="JSSLKServiceManager"/>
    </JadeMethod>
    <JadeMethod name="validateCheckSum" id="a659992e-53ab-4291-9a64-14306e54fda3">
        <source>validateCheckSum(pRegistrationData:Binary):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		16 January 2003 by cnwdad1
//
// Purpose:		Validates the binary registration data by comparing a checksum of
//				it against the checksum stored in the registration data itself, to
//				determine whether the registration details have been altered.
//
// Parameters:	pRegistrationData - The binary registration data.
//
// Returns:		True if the checksum is successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	checkSum	: Integer;
	
begin
	checkSum	:=	self.calculateCheckSum(pRegistrationData);
	
	if checkSum = pRegistrationData[1:4].Integer then
		return true;
	else
		return false;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pRegistrationData" type="Binary"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xorRegistrationData" id="661b4fb8-d7b9-4bd8-8402-1111a75d5607">
        <source>xorRegistrationData(pRegistrationData:Binary io) protected;
// --------------------------------------------------------------------------------
// Created:		16 January 2003 by cnwdad1
//
// Purpose:		Encrypts the "secret" part of the binary registration data.
//
// Parameters:	pRegistrationData - The binary registration data.
//
// Returns:		The binary registration data, as the I/O parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	keyByte			: Byte;
	bytePosition	: Integer;
	dataLength		: Integer;
	
begin
	
	keyByte		:=	pRegistrationData[5:4].Byte;
	dataLength	:=	pRegistrationData.length();
	
	// Only XOR the encrypted stuff, not the whole binary.
	
	foreach bytePosition in 9 to dataLength do
		pRegistrationData[bytePosition]	:=	pRegistrationData[bytePosition].bitXor(keyByte);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pRegistrationData" type="Binary" usage="io"/>
    </JadeMethod>
</Class>
