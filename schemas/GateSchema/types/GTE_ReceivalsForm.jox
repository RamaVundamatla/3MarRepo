    <JadeMethod name="packTempC_lostFocus" id="feb735fa-da6d-44f1-b567-5c49a25ed59e">
        <updating/>
        <source>packTempC_lostFocus(table : CM_EntryTable input; row : Integer; rowName : String; pValue : Any) updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	
begin
	if pValue &lt;&gt; null then
		//	table.setValue(row, pValue.Real.userNumberFormat($CM_Temperature));
		//  AER Par 14632
		table.setValue(row, pValue.Real.asStringJMTWithPrecision(PRECISION_TEMPERATURE, false));
	endif;
	self.myAssistant.GTE_Assistant.temperatureFieldLostFocus(pValue.String, table, ETRow_PackTempF, false, true);
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
        <Parameter name="row" type="Integer"/>
        <Parameter name="rowName" type="String"/>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
    <JadeMethod name="packTempF_lostFocus" id="ef4db304-347e-4633-b85c-6be3996f7f14">
        <updating/>
        <source>packTempF_lostFocus(table : CM_EntryTable input; row : Integer; rowName : String; pValue : Any) updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	
begin
	if pValue &lt;&gt; null then
		//	table.setValue(row, pValue.Real.userNumberFormat($CM_Temperature));
		//  AER Par 14632
		table.setValue(row, pValue.Real.asStringJMTWithPrecision(PRECISION_TEMPERATURE, false));
	endif;
	self.myAssistant.GTE_Assistant.temperatureFieldLostFocus(pValue.String, table, ETRow_PackTempC, true, false);
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
        <Parameter name="row" type="Integer"/>
        <Parameter name="rowName" type="String"/>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
    <JadeMethod name="populateWithProductDefaults" id="46ea4b9f-f022-45d1-b3fb-d72d942b9de1">
        <updating/>
        <source>populateWithProductDefaults(_comboProduct : ComboBox input) updating;
//-----------------------------------------------------------------------
//	Created:	25 May 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
// 19/11/2009	cnwmh5		PAR21492 - Show the Type row in the extra table
//-----------------------------------------------------------------------
vars
	entRow			: EntTableRow;
	prodAttr		: CM_ProductAttr;
	pro				: CM_Product;
	attrStr			: String;
	table			: CM_EntryTable;
	cargoType		: CM_CargoType;
	entRowArray		: EntTableRowArray;	
begin
	
	pro := _comboProduct.listObject.CM_Product;
	if pro = null then
		return;
	endif;
	cargoType := pro.myCargoType;
	table := self.tblExtra;
	entRowArray := table.myEntTableDef.allEntTableRows;
	
	foreach entRow in entRowArray do
		prodAttr := pro.getProdAttrFromName(entRow.name);
		if prodAttr = null then
			continue;
		endif;
		attrStr := entRow.name;
		if (cargoType.allAttributesOnProduct.includes(attrStr)) and (prodAttr.isViewable) or
				attrStr = ETRow_MyType then						// 19/11/2009 cnwmh5 PAR21492
		// This is the new one for after 7.4.1 release	
		//if (cargoType.getAttributeValue(attrStr).Boolean) and (prodAttr.isViewable) then
			table.showRowByName(attrStr, false);
			table.setValueByName(attrStr, prodAttr.getDisplayValueString());
			table.setCellText(table.accessedRow.row, table.ColumnHeading, prodAttr.displayName);	
			if attrStr = ETRow_MyType then					// 30/11/2009 cnwmh5 #21492
				self.setSysSubTypeDetails(null);
			endif;
		else
			table.hideRowByName(attrStr, false);
		endif;
	endforeach;

end;</source>
        <Parameter name="_comboProduct" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="f30337c3-3187-4dc3-9b60-372b26dc18f0">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     27 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_colorControl);
	
	self.setColorsForEntryTable(self.tblExtra);
	self.setColorsForEntryTable(self.tblMain);

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="91ff0633-951f-4925-baee-8d20d28b2556">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 24/11/2011	cnwcs5	CCMS POL 2122 / par 28696 - View EDI Messages

vars
	assistant	: GTE_Assistant;
begin
	inheritMethod();
	
	assistant := self.myAssistant.GTE_Assistant;

	self.clearEditControls; // dh 8/2/2008 moved below code to this method for reuse
	
	tblExtra.setValueByName(ETRow_AddAttachment, app.getErrorString(Dbl_Click_To_Add_Update));
	
	self.setDefaultsFromObject(self.myProxyObject);

	tblMain.visible 	:= true;
	tblExtra.visible 	:= true;

	tblMain.hideRowByName(ETRow_YardLocationTxt, false);

	sptThumbEdit.showRightControl(40, true);
	assistant.mainExtraSplitterRatio(tblMain, tblExtra, sptThumbEdit);
	assistant.mainExtraSyncColWidths(tblMain, tblExtra);
	
	tblMain.moveFirst();
	tblMain.setFocus();
	
	saveRowHeight := 0;

	//par 17383 cnwjo3
	self.cmbProduct.setCargoType(self.cmbTiType.listObject.CM_CargoType);
	self.cmbProduct.setOperator(self.cmbOperator.listObject.CM_Operator);
	self.cmbProduct.setObject(self.cmbProduct.listObject.CM_Product);
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="a6bd1c0e-3ab5-4bee-b1de-401e0cf3bd7a">
        <updating/>
        <source>setControlsForView() updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod();
	
	// 7/6/2006 Lorcan Allow printing from the booking ref form.
	if self.isKindOf(GTE_PreNoteForm) 
//	or self.isKindOf(GTE_BookingRefForm) 
	or self.isKindOf(GTE_BookingRefMultiForm) then
		self.allowPrint 	:= true;
		self.allowExportCSV	:= true;
	else
		self.allowPrint 	:= false;
		self.allowExportCSV	:= false;
	endif;
	tblMain.visible := false;
	tblExtra.visible := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="setDefaultsCallBack" id="2cf241c2-0236-485a-8c7a-7e3fc67af76c">
        <source>setDefaultsCallBack(_table : CM_EntryTable input; _attrName : String; _row : Integer; _obj : Object): Boolean;
/*
	Created on 22 January 2008 by Debby Hutchison

28/01/2011	cnwdap1		PAR #26769 Correct handling of over-dimensions from bookings
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
*/

vars
	booking			: CM_BookingRef;
	str				: String;
	assistant		: GTE_Assistant;
	result			: Boolean;
	tmpInt			: Integer;
	theRowObject 	: CM_Object;
begin
	assistant := self.myAssistant.GTE_Assistant;

	if _obj.isKindOf(CM_BookingRef) then
		booking := _obj.CM_BookingRef;
		
	elseif _obj.isKindOf(CM_BookingRefItem) then  						// dh 17/1/2008 for CCMS 1618 added this condition
		booking := _obj.CM_BookingRefItem.myBookingReference; 			//
	endif;
	
	result := true; 
	
	if _attrName = ETRow_AllDischargePorts then
		assistant.setListTablePorts(self.lstDischarge, _obj.IF_CargoField.getAllDischargePorts); 
		
		str := self.lstDischarge.getSelectedString(CM_Port::code.name); 
		
	elseif _attrName = ETRow_AllTIHazards then		// CCMS 1203 JC
		self.lstHazardList.loadHazardObjects;
		
		self.lstHazardList.setSelectedFromObject(_obj); 	

		str := _obj.IF_CargoField.getStringForETRow(_attrName);
		
	elseif _attrName = ETRow_ConsignorCode then
		theRowObject 	:= app.getCargoFieldObject(_obj, ETRow_ConsignorCode);
		tmpInt 			:= self.cmbConsignor.findObject(theRowObject);
		
		if tmpInt &gt; -1 then
			self.cmbConsignor.listIndex := tmpInt;
			str 						:= self.cmbConsignor.text;
		endif;	
		
	elseif _attrName = ETRow_FreightForwarderCode then
		theRowObject	:= app.getCargoFieldObject(_obj, ETRow_FreightForwarderCode);
		tmpInt 			:= cmbFreightFwdr.findObject(theRowObject);
		
		if tmpInt &gt; -1 then
			self.cmbFreightFwdr.listIndex 	:= tmpInt;
			str 							:= self.cmbFreightFwdr.text;
		endif;		
		
//	elseif _attrName = ETRow_MultiItem then	//05 Nov 2012	NDL	Par 29859
//		str := booking.isMultiItemBookingRef.cnEcGetTableCheckBoxValue;
		
	elseif _attrName = ETRow_WeightTotal and booking &lt;&gt; null then // cnwrd1 par 19793 26.6.09 remoevd to stop setting default weight.
		if _obj.isKindOf(CM_BookingRefItem) then 
			if _obj.CM_BookingRefItem.quantity = 1 then // we set the weight for a quanitity of 1.
				str := _obj.IF_CargoField.getStringForETRow(_attrName);
			endif;
		endif;
		//do nothing		
	elseif _attrName = ETRow_BolType 
	or _attrName = ETRow_CargoType 
	or _attrName = ETRow_CarriageTempC
	or _attrName = ETRow_CarriageTempF 
	or _attrName = ETRow_Humidity
	or _attrName = ETRow_IdTextBox
	or _attrName = ETRow_StatusString 
	or _attrName = ETRow_Ventilation 
	or _attrName = ETRow_CarbonDioxide						// CCMS 1654 - slw 15/09/2008
	or _attrName = ETRow_Oxygen								// CCMS 1654 - slw 15/09/2008
	or _attrName = ETRow_AllowableTimeOffPower
	or _attrName = ETRow_WeightTotal   					
	or _attrName = ETRow_MyHeight 
	or _attrName = ETRow_MyWeight 
	or _attrName = ETRow_MyLength 
	or _attrName = ETRow_MyWidth 
	or _attrName = ETRow_Quantity 
	or _attrName = ETRow_MyQuantity 
	or _attrName = ETRow_MyDensity 
	or _attrName = ETRow_MyVolume 
	or _attrName = ETRow_CoolingType 
	or _attrName = ETRow_VoltageType 
	or _attrName = ETRow_VoyageCode 
	or _attrName = ETRow_DischargePort 
	or _attrName = ETRow_MyTranshipToPort 
	or _attrName = ETRow_DestinationPort 
	or _attrName = ETRow_OperatorCode 
	or _attrName = ETRow_MyGeneratorType
	or _attrName = ETRow_SealNum	//03 Dec 2010	NDL	Par 26506	
	or _attrName = ETRow_SealNumCustoms	//03 Dec 2010	NDL	Par 26506	
	or _attrName = ETRow_SealNumShippers	//03 Dec 2010	NDL	Par 26506	
	or _attrName = ETRow_SealNumVent	//03 Dec 2010	NDL	Par 26506	
	or _attrName = ETRow_SealNumTerminalOperator
	or _attrName = ETRow_SealNumUnknown
//	or _attrName = ETRow_MultiItem //05 Nov 2012	NDL	Par 29859
	or _attrName = ETRow_OverLengthFront	// PAR #26769
	or _attrName = ETRow_OverLengthBack		// PAR #26769
	or _attrName = ETRow_OverWidthLeft		// PAR #26769
	or _attrName = ETRow_OverWidthRight		// PAR #26769
	or _attrName = ETRow_OverHeight	then	// PAR #26769
		str := _obj.IF_CargoField.getStringForETRow(_attrName);
		
	// PAR #26769 set over dimensions if required
	elseif _attrName = ETRow_IsOverDimensions then
		if CM_BookingRefItem.hasInstance(_obj) then
			if _obj.CM_BookingRefItem.length = null and _obj.CM_BookingRefItem.height = null and _obj.CM_BookingRefItem.width = null then
				str := '0';
			else
				str := '1';
			endif;
		endif;
	// PAR #26769 end
	else
		result := false;
	endif;
	
	if str &lt;&gt; null then
		_table.setValue(_row, str);
	endif;
	
	return result;
end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsCallBack_Old" id="0214a747-8394-4c3e-9a71-93d80409bed2">
        <source>setDefaultsCallBack_Old(pTbl : CM_EntryTable input; pAttrName : String; pRow : Integer; pObj : Object) : Boolean;
// ---------------------------------------------------------------------------
// Created:     27 September 2001 by cnwrs2
//
// Purpose:     Callback method from CM_EntryTable::setTableFromObject 
//				Refer to self.setDefaultsFromObject() for use.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theBookingRef	: CM_BookingRef;
	theBookingRefItem : CM_BookingRefItem;
	theBRefContainer : CM_BRefItemContainer;
	theTI			: CM_TrackedItem;
	theContainer	: CM_Container;
	theConsignor	: CM_ConsigneeConsignor;
	str				: String;
	assistant		: GTE_Assistant;
	rtnCode			: Boolean;
	tmpDecimal : Decimal[14,4]; //par19252 cnwrs1 may 2009
	tmpReal : Real;
	tmpInt			: Integer;
	tmpIntArray		: IntegerArray;
	tmpHumidity : Decimal[6,2];	//02 Apr 2020	NDL TFS 47958
begin

	assistant := self.myAssistant.GTE_Assistant;

	if pObj.isKindOf(CM_BookingRef) then
		theBookingRef := pObj.CM_BookingRef;
	elseif pObj.isKindOf(CM_BookingRefItem) then  						// dh 17/1/2008 for CCMS 1618 added this condition
		theBookingRefItem := pObj.CM_BookingRefItem; 					//
		if theBookingRefItem.isKindOf(CM_BRefItemContainer) then		//
			theBRefContainer := theBookingRefItem.CM_BRefItemContainer;	//
		endif;															//
		theBookingRef := theBookingRefItem.myBookingReference; 			//
	else
		theTI := pObj.CM_TrackedItem;
		if theTI.isKindOf(CM_Container) then
			theContainer := theTI.CM_Container;
		endif;
	endif;
	rtnCode := true;
	if pAttrName = ETRow_AllDischargePorts then
		rtnCode := true;
		if theBookingRef &lt;&gt; null then
			assistant.setListTablePorts(lstDischarge, pObj.CM_BookingRef.allDischargePorts);
		else
			assistant.setListTablePorts(lstDischarge, pObj.CM_TrackedItem.allDischargePorts);
		endif;
		str := lstDischarge.getSelectedString('code');

/*	elseif pAttrName = ETRow_AllHazards then		// CCMS 1203 JC
		rtnCode := true;
		if theBookingRef &lt;&gt; null then
			self.lstHazardList.setSelectedFromObject(pObj.CM_BookingRef);
			//assistant.setListTableHazards(lstHazard, pObj.CM_BookingRef.allHazards);
		else
			self.lstHazardList.setSelectedFromObject(pObj.CM_TrackedItem);
			//assistant.setListTableHazards(lstHazard, pObj.CM_TrackedItem.allHazards);
		endif;
		str := lstHazard.getSelectedString('code');
*/
	elseif pAttrName = ETRow_AllTIHazards then		// CCMS 1203 JC
		rtnCode := true;
		if theBookingRefItem &lt;&gt; null then  							// dh 17/1/2008 for CCMS 1618 added this condition
			self.lstHazardList.loadHazardObjects;
			lstHazardList.setSelectedFromObject(theBookingRefItem); 	//
//		if theBookingRef &lt;&gt; null then								//
		elseif theBookingRef &lt;&gt; null then							//
			self.lstHazardList.loadHazardObjects;
			self.lstHazardList.setSelectedFromObject(theBookingRef);
			//assistant.setListTableHazards(lstHazard, pObj.CM_BookingRef.allHazards);
		else
			self.lstHazardList.loadHazardObjects;
			self.lstHazardList.setSelectedFromObject(theTI);
			//assistant.setListTableHazards(lstHazard, pObj.CM_TrackedItem.allHazards);
		endif;
		str := pObj.CM_Object.getDisplayStringForAttribute(pAttrName, false);//lstHazard.getSelectedString('code');
//	elseif pAttrName = ETRow_BolType then // adm 160310 Par 22937 remove bolType
//		rtnCode := true;
//		if theBookingRefItem &lt;&gt; null then			// dh 17/1/2008 for CCMS 1618 added this condition
//			str := theBookingRefItem.bolTypeDescr; 	//
//		if theBookingRef &lt;&gt; null then				//
//		elseif theBookingRef &lt;&gt; null then			//
//			str := theBookingRef.bolTypeDescr;
//		endif;
	elseif pAttrName = ETRow_CargoType then
		rtnCode := true;
		if theBookingRefItem &lt;&gt; null then				// dh 17/1/2008 for CCMS 1618 added this condition
			str := theBookingRefItem.cargoTypeDescr; 	//
		elseif theBookingRef &lt;&gt; null then				//
//		if theBookingRef &lt;&gt; null then					//
			str := theBookingRef.cargoTypeDescr;
		else
			str := theTI.cargoTypeDescr;
		endif;

	elseif pAttrName = ETRow_Quantity then
		rtnCode := true;
		if theBookingRef &lt;&gt; null and self.isKindOf(GTE_BookingRefMultiForm) then
			str := theBookingRef.quantity.String;
		else
			//Quantity should default to 1, not the booking ref quantity
			str := 1.String;
		endif;

	elseif pAttrName = ETRow_CarriageTempC then
		rtnCode := true;
		if theBookingRef &lt;&gt; null then
			tmpReal := theBookingRef.temperature;
		elseif theContainer &lt;&gt; null then
			tmpReal := theContainer.getTemperature;
		else
			tmpReal := NULL_TEMPERATURE;
		endif;
		if tmpReal &lt;&gt; NULL_TEMPERATURE then
//			str := assistant.displayTemperature(tmpReal, false, false);
			str := app.getTemperatureDisplay(tmpReal, false, false);
		endif;

	elseif pAttrName = ETRow_CarriageTempF then
		rtnCode := true;
		if theBookingRef &lt;&gt; null then
			tmpReal := theBookingRef.temperature;
		elseif theContainer &lt;&gt; null then
			tmpReal := theContainer.getTemperature;
		else
			tmpReal := NULL_TEMPERATURE;
		endif;
		if tmpReal &lt;&gt; NULL_TEMPERATURE then
//			str := assistant.displayTemperature(tmpReal, false, true);
			str := app.getTemperatureDisplay(tmpReal, false, true);
		endif;

		
	elseif pAttrName = ETRow_ConsignorCode then
		rtnCode := true;
		if theBookingRef &lt;&gt; null then
			theConsignor := theBookingRef.myConsignor;
		else
			theConsignor := app.myRoot.allConsigneeConsignors[theTI.consignor];
		endif;
		/*if theConsignor &lt;&gt; null then
			str := self.myAssistant.displayEntryConsignor(theConsignor);
		endif;
		self.cmbConsignor.text := str;*/
		tmpInt := cmbConsignor.findObject(theConsignor);
		if tmpInt &gt; -1 then
			cmbConsignor.listIndex := tmpInt;
			str := cmbConsignor.text;
		endif;
		
	// 21/11/2006 par#12903 Mohammad	
	elseif pAttrName = ETRow_FreightForwarderCode then
		rtnCode := true;
		if theBookingRef &lt;&gt; null then
			//theConsignor := theBookingRef.myConsignor; // need to add to bookref\
		else
			theConsignor := app.myRoot.allConsigneeConsignors[theTI.freightForwarderCode];
		endif;
		/*if theConsignor &lt;&gt; null then
			str := self.myAssistant.displayEntryConsignor(theConsignor);
		endif;
		self.cmbConsignor.text := str;*/
		tmpInt := cmbFreightFwdr.findObject(theConsignor);
		if tmpInt &gt; -1 then
			cmbFreightFwdr.listIndex := tmpInt;
			str := cmbFreightFwdr.text;
		endif;		
	
	elseif pAttrName = ETRow_Humidity then
		rtnCode := true;
		if theBookingRef &lt;&gt; null then
			tmpHumidity := theBookingRef.getHumidity;
		elseif theContainer &lt;&gt; null then
			tmpHumidity := theContainer.getHumidity;
		else
			tmpHumidity := NULL_HUMIDITY;
		endif;
		if tmpHumidity &lt;&gt; NULL_HUMIDITY then
			str := tmpHumidity.String;
		endif;
	elseif pAttrName = ETRow_IdTextBox then
		rtnCode := true;
		if theTI &lt;&gt; null then
			str := theTI.id;
		endif;

	elseif pAttrName = ETRow_StatusString then
		rtnCode := true;
		if theTI &lt;&gt; null then
			str := app.getIMEXStringFromIMEXStatus(theTI.getImExStatus);
		endif;

	elseif pAttrName = ETRow_Ventilation then
		rtnCode := true;
		if theBookingRef &lt;&gt; null then
	   		tmpDecimal := theBookingRef.ventilation;
	   	elseif theContainer &lt;&gt; null then
	   		tmpDecimal := theContainer.getVentilation;
	   	else
	   		tmpDecimal := NULL_VENTILATION;
	   	endif;
		if tmpDecimal &lt;&gt; NULL_VENTILATION then
	   		str := tmpReal.asStringJMT(); //par19252 cnwrs1 may 2009;
	   	endif;
	elseif pAttrName = ETRow_WeightTotal then
		rtnCode := true;
		if theBookingRef &lt;&gt; null then
			str := theBookingRef.weight.asStringWeightJMT();
		else
		//	str := theTI.weight.asStringWeightJMT();					//-cnwml2 MSL CCMS 1017
			str := theTI.totalWeight.asStringWeightJMT();				//+cnwml2 MSL CCMS 1017
		endif;
	elseif pAttrName = ETRow_MyHeight then
		rtnCode := true;
		if theBookingRef &lt;&gt; null then
			str := theBookingRef.height.asStringMeasurementJMT();
		else
			str := theTI.height.asStringMeasurementJMT();
		endif;
	elseif pAttrName = ETRow_MyWeight then
		rtnCode := true;
		if theBookingRef &lt;&gt; null then
			str := theBookingRef.weight.asStringWeightJMT();
		else
		//	str := theTI.weight.asStringWeightJMT();					//-cnwml2 MSL CCMS 1017
			str := theTI.totalWeight.asStringWeightJMT();				//+cnwml2 MSL CCMS 1017
		endif;
	elseif pAttrName = ETRow_MyLength then
		rtnCode := true;
		if theBookingRef &lt;&gt; null then
			str := theBookingRef.length.asStringMeasurementJMT();
		else
			str := theTI.length.asStringMeasurementJMT();
		endif;
	elseif pAttrName = ETRow_MyWidth then
		rtnCode := true;
		if theBookingRef &lt;&gt; null then
			str := theBookingRef.width.asStringMeasurementJMT();
		else
			str := theTI.width.asStringMeasurementJMT();
		endif;
	elseif pAttrName = ETRow_MyQuantity then
		rtnCode := true;
		if theBookingRef &lt;&gt; null then
			str := theBookingRef.productQuantity.String;
		endif;
	elseif pAttrName = ETRow_MyDensity then
		rtnCode := true;
		if theBookingRef &lt;&gt; null then
			str := theBookingRef.density.String;
		else
			str := theTI.density.String;
		endif;
	elseif pAttrName = ETRow_MyVolume then
		rtnCode := true;
		if theBookingRef &lt;&gt; null then
			str := theBookingRef.volume.String;
		else
			str := theTI.getMyTotalVolume.String;
		endif;

	elseif pAttrName = ETRow_CoolingType then
		rtnCode := true;
		if theContainer &lt;&gt; null then
			str := app.coolingTypeENumToString(theContainer.getCoolingType, false);
		endif;
	elseif pAttrName = ETRow_VoltageType then
		rtnCode := true;
		if theContainer &lt;&gt; null then
			str := app.voltageTypeENumToString(theContainer.getVoltageType, false);
		endif;	
	else
		rtnCode := false;
	endif;	
	if str &lt;&gt; null then
		pTbl.setValue(pRow, str);
	endif;
		
	return rtnCode;
	
end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="pObj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
