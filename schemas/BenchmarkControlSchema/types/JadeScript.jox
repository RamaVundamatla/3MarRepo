    <JadeMethod name="jhpXmlPar" id="12bc8103-fc27-43a8-be64-53ae1a11361a">
        <source>jhpXmlPar();

vars
	f:File;
	doc:JadeXMLDocument;
	el,el2:JadeXMLElement;
	els:JadeXMLElementArray;
begin
	create f transient;
	f.fileName:="C:\temp\ParTest.conf";

	if f.isAvailable then
		create doc transient;
		doc.parseFile(f.fileName);
		
		create els transient;
		doc.findElementsByTagName("step", els);
		foreach el in els do
			el2:=el.getElementByTagName("name");
			write "&lt;" &amp; el2.textData.Binary.display &amp; "&gt;";
		endforeach;
	else
		write f.fileName&amp;" not found";
	endif;
epilog
	delete f;
	delete els;
	delete doc;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jhpXmlReader" id="bd567ed7-40ab-465e-b83a-9309f871413b">
        <source>jhpXmlReader();

vars
	doc:JadeXMLDocument;
	topElement,testconfig,executionplan:JadeXMLElement;
	testconfigs,executionplans:JadeXMLElementArray;
	version,queue:String;
begin
	create doc transient;
	create testconfigs transient;
	create executionplans transient;
	//doc.parseFile("\\cnwchcm24\cnwjbl$\jade\FunctionalTests\q_DevActiveXMenus.conf");
	doc.parseFile("\\cnwchcm24\cnwjbl$\ManualRunPlayPen\testgroupings\allcurrent.jhp.conf");
	//doc.parseFile("T:\plant\TestingTools\suiteconfig\allcurrent.conf");
	
	topElement:=doc.findElementByTagName("testsuite");
	topElement.findAllElementsByTagName("testconfig", testconfigs);
	foreach testconfig in testconfigs do
		testconfig.findAllElementsByTagName("executionplan", executionplans);
		foreach executionplan in executionplans do
			version:=executionplan.getElementByTagName("productversion").textData;
			queue:=executionplan.getElementByTagName("queue").textData;
			if version.contains("63") and queue.contains("win") then
				write testconfig.getAttributeByName("name").value &amp; Tab &amp; queue;
			endif;
		endforeach;
	endforeach;
epilog
	delete doc;
	delete testconfigs;
	delete executionplans;
end;
</source>
    </JadeMethod>
    <JadeMethod name="logGrep" id="2793836e-e12f-4d5e-8c2e-a894f2d76ebd">
        <source>logGrep();

vars
	s,t,folderName,folderMask,include,exclude,andInclude,orInclude:String;
	i,j,k,l,hits,hitsmax,lines,linesmax:Integer;
	presentationFileSystem,firstOnly,showFileName:Boolean;
	ts:TimeStamp;
	f,g:File; fn:FileNode; ff:FileFolder;
begin
	folderName:="G:\BenchMarkResults\jmt\C3781to782\Tlogs";
