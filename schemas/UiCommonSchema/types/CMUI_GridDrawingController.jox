    <JadeMethod name="minimisedStateBegin" id="bfc0e8aa-cd48-498d-8bb1-a4ad702f5aee">
        <updating/>
        <source>minimisedStateBegin() updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 May 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.currentlyMinimised := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="minimisedStateEnd" id="24dc13ba-f7cb-4b5a-a00f-a6d4f780c03c">
        <updating/>
        <source>minimisedStateEnd() updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 May 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	noteRecord			: CMIF_NotificationRecord;
	obj					: Object;
begin
	self.currentlyMinimised := false;
	
	
	if self.allNotificationsReceived.size &gt; 50 then //th2 to check threshold
		self.drawSelf(false);
	else
		foreach noteRecord in self.allNotificationsReceived do
			obj := noteRecord.userInfoString.asObject();
			
			if obj &lt;&gt; null then
				self.userNotification(noteRecord.eventType, noteRecord.myObject, noteRecord.eventTag, obj);
			else
				self.userNotification(noteRecord.eventType, noteRecord.myObject, noteRecord.eventTag, noteRecord.userInfoString);
			endif;
		endforeach;
	endif;

epilog
	self.allNotificationsReceived.purge();
		
end;</source>
    </JadeMethod>
    <JadeMethod name="normaliseRealRectanglePoints" id="9882d404-b3bc-422d-a388-248d277ec7ce">
        <source>normaliseRealRectanglePoints(_x1, _y1, _x2, _y2 : Real io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwjk3	ccms 1018

*/

vars
	x1, x2, y1, y2 : Real;
begin
	x1 := _x1.min(_x2);
	y1 := _y1.min(_y2);
	x2 := _x2.max(_x1);
	y2 := _y2.max(_y1);
	_x1 := x1;
	_x2 := x2;
	_y1 := y1;
	_y2 := y2;
epilog

end;
</source>
        <Parameter name="_x1" type="Real" usage="io"/>
        <Parameter name="_y1" type="Real" usage="io"/>
        <Parameter name="_x2" type="Real" usage="io"/>
        <Parameter name="_y2" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="normaliseRectanglePoints" id="316d13cd-76a1-4837-9099-14e0ea3a239f">
        <source>normaliseRectanglePoints(_x1, _y1, _x2, _y2 : Integer io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2009	cnwjk3	SFW1030

*/

vars
	x1, x2, y1, y2 : Integer;
begin
	x1 := _x1.min(_x2);
	y1 := _y1.min(_y2);
	x2 := _x2.max(_x1);
	y2 := _y2.max(_y1);
	_x1 := x1;
	_x2 := x2;
	_y1 := y1;
	_y2 := y2;
epilog

end;</source>
        <Parameter name="_x1" type="Integer" usage="io"/>
        <Parameter name="_y1" type="Integer" usage="io"/>
        <Parameter name="_x2" type="Integer" usage="io"/>
        <Parameter name="_y2" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="notableObjectAdd" id="e44ce7a9-a74c-4f64-8898-db4bbb0cb0d1">
        <source>notableObjectAdd(_obj : Object);
// ---------------------------------------------------------------------------
// Created:     05 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _obj = null then
		return;
	endif;

	if (not self.allNotableObjects.includes(_obj)) then
		self.allNotableObjects.add(_obj);
		self.notableObjectArmNotes(_obj);
	endif;
end;</source>
