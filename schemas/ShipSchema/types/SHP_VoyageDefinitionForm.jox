    <JadeMethod name="doTankDelete" id="b1c63d3b-e8af-40d7-b71c-7ecd4fd79a25">
        <source>doTankDelete() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	result : Integer;
	tank : CM_VesselTankVoyage;
begin
	if self.tblTanks.accessRow(self.tblTanks.row) = null then
		return;
	endif;
	tank:=self.tblTanks.accessRow(self.tblTanks.row).itemObject.CM_VesselTankVoyage;

	if tank = null then
		return;
	endif;


	if app.msgBox(app.getErrorString2(ConfirmDelete,app.getErrorString(Voyage_tank),tank.code.String),app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt;  MsgBox_Return_Yes then
		return;
	endif;

	while true do
	
		app.myTrxDA.trxDeleteVesselTank(tank,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_tank), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		
		break;
	endwhile;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
