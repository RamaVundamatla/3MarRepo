    <JadeMethod name="addDetailsForTI" id="2dd9e763-a5d7-4bc7-b339-553bf1190e90">
        <source>addDetailsForTI(_sortIndex : Integer; _ti : CM_TrackedItem) protected;
/*
Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
Aug 08		Richard S	PAR 16831 - check permissions
29/05/2013	cnwdap1		CCMS 2274 Split/Merge Break Bulk Cargo
19/06/2013	cnwcs5		par 31686a - fix problem with expanding details as superuser
*/
vars
	txn					: CM_TITransaction;
	idx	, detailCol, 
	count				: Integer;
	user				: CM_User;
	table				: CM_DataTable;
	listbox				: CMUI_ListBox;
begin
	user	:= app.getMyUser;		// PAR 16831 
	table	:= self.tblTrans;
	
	table.getEntRowColumnByRowName(ETRow_Details, detailCol);	// par 31686a

	
	foreach txn in _ti.allTransactions reversed do
	
		// leave commented till CCMS approved
		if not (txn.canView(user)) then			// PAR 16831
			continue;
		endif;
		
		idx := self.addTransactionToTblTrans( _sortIndex, txn );
		
		if (idx mod 2 = 0) then
			table.accessRow(idx).backColor := self.colorRow1;
		else
			table.accessRow(idx).backColor := self.colorRow2;
		endif;
		
		// show extra details for Merge/Split type transactions
		if ((txn.isKindOf(CM_Merge) or txn.isKindOf(CM_Split)) and txn.getOtherTrackedItem &lt;&gt; null )
		or ( txn.isKindOf(CM_Blend) and not txn.CM_Blend.allChildBlendTrxs.isEmpty )	//26 May 2021	NDL	TFS 51243
		then
			if detailCol &gt; 1 then
				table.setCellText(idx, detailCol,"[+] " &amp; table.getCellText(idx,detailCol));
			endif;
			
			count 	:= count + 1;
			listbox := self.lstMergeSplit.getControl(count);
			if listbox = null then
				listbox := self.lstMergeSplit.loadControl(count).CMUI_ListBox;
			endif;
			//epr par 31686 13/6/13
			listbox.backColor	:= table.accessRow(idx).backColor;
			listbox.borderStyle	:= Control.BorderStyle_None;
			
			table.accessCell(idx, detailCol).cellControl := listbox; 	// par 31686a
			
			listbox.visible 	:= true;
			
			listbox.move(-100, -100, 100, 18);
		endif;
		
		// adding hidden edited transactions: transaction.previousVersions. cnwvu1 March 2008
		if self.chkTransAudit.value and txn.previousVersions &lt;&gt; null then
			self.addDetailsForTI_TransAudit( _sortIndex, txn );
		endif;
		
	endforeach;
	
	
	foreach txn in _ti.allPriorTransactions reversed do
		
		idx := self.addTransactionToTblTrans( _sortIndex, txn );
		
		if (idx mod 2 = 0) then
			table.accessRow(idx).backColor := self.colorRow1;
		else
			table.accessRow(idx).backColor := self.colorRow2;
		endif;

		// adding hidden edited transactions: transaction.previousVersions. cnwvu1 March 2008
		if self.chkTransAudit.value and txn.previousVersions &lt;&gt; null then
			self.addDetailsForTI_TransAudit( _sortIndex, txn );
		endif;
		
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_sortIndex" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addDetailsForTI_TransAudit" id="8bf3464d-bec6-49f7-b155-199a73415be0">
        <source>addDetailsForTI_TransAudit( _sortIndex : Integer; _trn : CM_TITransaction ) protected;
// ---------------------------------------------------------------------------
// Created:     04 March 2008 by cnwvu1
//
// Purpose:		Displaying edited transactions: transaction.previousVersions
// ---------------------------------------------------------------------------

vars
	trn : CM_TITransaction;
	idx			: Integer;
	
begin

	foreach trn in _trn.previousVersions do
	
		idx := self.addTransactionToTblTrans( _sortIndex, trn );	//08 Jun 2010	NDL	Par 23498
		tblTrans.setCellText(idx, 2, idx.String.padLeadingZeros(3));	//08 Jun 2010	NDL	Par 23498
		tblTrans.accessRow(idx).backColor := LightGray;
		tblTrans.accessRow(idx).foreColor := DarkGray;
		
	endforeach;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_sortIndex" type="Integer"/>
        <Parameter name="_trn" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="addObjectToCollection" id="22ed2815-b324-4bae-a52f-93a59a8293a4">
        <updating/>
        <source>addObjectToCollection(_trn : CM_Transaction; _user : CM_User) : Boolean updating, protected;

vars

begin
	
	if not (_trn.canView(_user)) then			// PAR 16831
		return false;
	endif;
		
	if self.numItemsShown &gt; JadeTableRowLimit then
		return true;
	endif;

	self.numItemsShown := self.numItemsShown + 1;
	self.allTransactions.add(_trn);
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_trn" type="CM_Transaction"/>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="81b5d461-14c5-483e-a23c-99c9ee9028b3">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 September 2003	cnwth2
//
// Purpose:     
//		 
// ----------   ----------  --------------------------------------------------
// 11 Jul 2023 navhl20 Bug 59047: MTN - The Refresh button on the Transaction Enquiry is refreshing all the transactions.
vars
	
begin
	inheritMethod();

	if self.mode = self.Mode_CargoItem_Enquiry then
		self.addToolbarControlsItem();
	elseif self.mode = self.Mode_BOLItem_Enquiry or //epr par 35427 29/1/15
			self.mode = self.Mode_WO_Transaction_Enquiry then		//11.7.2023 navhl20 #59047
		self.addToolbarsBOL;
	// ### JIRA 33348 22NOV2024 NAVAB1
	elseif self.mode = self.Mode_ContractAccumulation then
		self.addToolbarsForAccumulation();
	else
		self.addToolbarControlsTransaction();
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsItem" id="46324169-067d-4492-8785-e0aa26ae8d58">
        <updating/>
        <source>addToolbarControlsItem() updating, protected;
// toolbars for transactions for a specific tracked item from cargo enquiry
// Date				Who 			Reason
// 26 Aug 2022 		navvt20 		ChangeRequest 54616: MTN - Transaction List Filter
vars
	toolbar	: CMUI_Toolbar;
begin
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	if app.isSpecial() then
		toolbar.addButton(self.btnCSV, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	// Feb 2012 CCMS 1262 transaction enquiry added permission for add/edit
	if app.myCurrentUserCan(self.myTerminal, PmAdmTransactioneditMaint) then
		toolbar.addButton(self.btnAdd, CMUI_Toolbar.Control_Alignment_Left);	
		toolbar.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
	else
		self.mnuTxnAdd.visible := false;
		self.mnuTxnDelete.visible := false;
		self.mnuTxnEdit.visible := false;
		self.mnuTxnUndelete.visible := false;
	endif;
	if app.myCurrentUserCan(self.myTerminal, PmAdmResyncTrans) then
		toolbar.addButton(self.btnResync, CMUI_Toolbar.Control_Alignment_Left);
	else
		self.mnuTxnResync.visible := false;
	endif;
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	// adding checkbox - Transaction Audit ccms1089. March 2008
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmTransAudit, CMUI_Toolbar.Control_Alignment_Left);
	// Start 26 Aug 2022 navvt20 TFS 54616
	/*//25/06/2024	navkc1 CR 64823 Task 64824
	toolbar.addFrame(self.frmFilter, CMUI_Toolbar.Control_Alignment_Left); 
    self.txtFilterBox.parent 	:= self.frmFilter;
	self.txtFilterBox.visible 	:= true;
	self.txtFilterBox.left 		:= 10;
	self.txtFilterBox.top 		:= 1;
	toolbar.addButton(self.btnClearFilter, CMUI_Toolbar.Control_Alignment_Left);*/
	//End 26 Aug 2022 navvt20 TFS 54616
	toolbar := self.frmToolbarRP;
	toolbar.addButton(self.btnRPSave, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRPSelect, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRPCancel, CMUI_Toolbar.Control_Alignment_Right);
	toolbar.positionToolbarControls();
	toolbar.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsTransaction" id="a541ba3f-6b99-4fdf-889d-c1c72be02375">
        <updating/>
        <source>addToolbarControlsTransaction() updating, protected;
// toolbars for transaction enquiry as standalone function
// Date				Who 			Reason
// 26 Aug 2022 		navvt20 		ChangeRequest 54616: MTN - Transaction List Filter
vars
	queryToolbar,
	toolbar	: CMUI_Toolbar;
begin
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCSV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnSearchTV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	if app.myCurrentUserCan(self.myTerminal, PmAdmTransactioneditMaint) then 
		toolbar.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnUnDelete, CMUI_Toolbar.Control_Alignment_Left);
	else
		self.mnuTxnDelete.visible := false;
		self.mnuTxnEdit.visible := false;
		self.mnuTxnUndelete.visible := false;
		self.mnuSetCharge.visible := false;
		self.mnuResetCharge.visible := false;
	endif;
	toolbar.addButton(self.btnSelectAllTV, CMUI_Toolbar.Control_Alignment_Left);
	if app.myCurrentUserCan(self.myTerminal, PmAdmResyncTrans) then
		toolbar.addButton(self.btnResync, CMUI_Toolbar.Control_Alignment_Left);
	else
		self.mnuTxnResync.visible := false;
	endif;
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	/* //23/04/2024	navkc1 CR63736 Task 63770 Use new filter control
	//Start 26 Ayg 2022 navvt20 TFS 54616
	toolbar.addFrame(self.frmFilter, CMUI_Toolbar.Control_Alignment_Left);
    self.txtFilterBox.parent 	:= self.frmFilter;
	self.txtFilterBox.visible 	:= true;
	self.txtFilterBox.left 		:= 10;
	self.txtFilterBox.top 		:= 2;
	toolbar.addButton(self.btnClearFilter, CMUI_Toolbar.Control_Alignment_Left); 
	//End 26 Aug 2022 navvt20 TFS 54616
	*/
	//23/04/2024	navkc1 CR63736 Task 63770 end
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	//05/06/2024	navkc1 CR 63736 Task 63770
	toolbar.addFrame(self.frmTableFilter, CMUI_Toolbar.Control_Alignment_Left); //05/06/2024	navkc1 CR 63736 Task 63770
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	toolbar := self.frmToolbarRP;
	toolbar.addButton(self.btnRPSave, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRPSelect, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRPCancel, CMUI_Toolbar.Control_Alignment_Right);
	toolbar.positionToolbarControls();
	toolbar.visible := true;

    queryToolbar := self.frmQueryToolbar;
    queryToolbar.showCaptions := false;
    queryToolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
    queryToolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
    queryToolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);
    queryToolbar.positionToolbarControls();
    queryToolbar.visible := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
