    <JadeMethod name="getAvailableMemoryMegabytes" id="f2ac5f76-faf2-41e1-914d-d63c78c39dd5">
        <source>getAvailableMemoryMegabytes() : Real;

begin
	if self.myMachineDescriptor = null then
		return 0;
	endif;
	return self.myMachineDescriptor.availableMemory.asMegabytes;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getCommandTarget" id="63f52ab1-da0c-4972-a855-764a8a4857ec">
        <source>getCommandTarget() : Object;

begin
	return self.myProcess;
end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getProcessSchema" id="6e461191-82c2-4fd8-ab29-cdbd3e1767ba">
        <source>getProcessSchema() : Schema;

vars
	errNo : Integer;
	errTxt : String;
	scm : Schema;
	
begin
	if self.myProcess = null then
		return null;
	endif;

	errNo := 0;	
	on Exception do app.resumeNextExHandler(exception, errNo, errTxt);

	scm := self.myProcess.schema;
	
	if errNo &lt;&gt; 0 then
		return null;
	endif;
	
	return scm;	
end;</source>
        <ReturnType type="Schema"/>
    </JadeMethod>
    <JadeMethod name="getTableString" id="4ff5ecb9-bf0a-476e-b319-21a085a33ceb">
        <source>getTableString() : String;

vars
	s : String;
	
begin
	if self.myMachineDescriptor &lt;&gt; null then
		s := self.myMachineDescriptor.getAvailableMemoryString;
	endif;

	return self.myMachineDescriptor.name &amp; ' [' &amp;
		   self.processInstanceId.String &amp;
		   "] " &amp;
		   self.signOnUserCode &amp;
		   " (" &amp;
		   self.profileName &amp;
		   ')' &amp;
		   Tab &amp;
		   self.getTableStringFromSummary &amp;
		   Tab &amp;
		   s;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialize" id="5fdd1f5f-d84a-4e2a-9f64-827ae0189973">
        <updating/>
        <source>initialize() updating;

begin
	self.allTransactionDescsByName.purge;
	self.mySummary.jtdInitialize;
	self.profileName := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="isRunning" id="66146427-70ad-4349-8477-65be791ec7c9">
        <source>isRunning() : Boolean;

begin
	return self.mySessionDescriptorWhenRunning &lt;&gt; null;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setNodeNameFromProcess" id="01e8a6c8-c62a-411d-a2eb-ea59557b6393">
        <updating/>
        <source>setNodeNameFromProcess(_process : Process) updating, protected;

constants
	NullProcessString = "*** Null Process ***";
	
begin
	if _process = null then
		if self.nodeName &lt;&gt; NullProcessString then
			self.nodeName := NullProcessString;
		endif;
		return;
	endif;

	if self.nodeName &lt;&gt; _process.node.name then
		self.nodeName := _process.node.name;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_process" type="Process"/>
    </JadeMethod>
    <JadeMethod name="setRunning" id="10a4c78a-3561-4a23-9f1b-5454d315f7bc">
        <updating/>
        <source>setRunning(running : Boolean) updating, protected;

begin
	if running then
		self.myNodeDescriptorWhenRunning := self.myNodeDescriptor;
		self.mySessionDescriptorWhenRunning := self.mySessionDescriptor;
	else
		self.myNodeDescriptorWhenRunning := null;
		self.mySessionDescriptorWhenRunning := null;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="running" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSignOnUserCodeFromProcess" id="277147ae-f854-45e0-ba10-6ba0fa16fecb">
        <updating/>
        <source>setSignOnUserCodeFromProcess(_process : Process) updating, protected;

constants
	NullProcessString = "*** Null Process ***";

begin
	if _process = null then
		if self.signOnUserCode &lt;&gt; NullProcessString then
			self.signOnUserCode := NullProcessString;
		endif;
		return;
	endif;

	if self.signOnUserCode &lt;&gt; _process.signOnUserCode then
		self.signOnUserCode := _process.signOnUserCode;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_process" type="Process"/>
    </JadeMethod>
    <JadeMethod name="start" id="ff42afce-f86e-4f50-9c9f-95f4f6e4e680">
        <updating/>
        <source>start() updating;

begin
	self.startClock;

	self.setRunning(true);
	
	if self.myNodeDescriptor &lt;&gt; null then
		self.myNodeDescriptor.startClock;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="stop" id="5efd132f-78d2-4ed0-8259-cd4aa832ea31">
        <updating/>
        <source>stop() updating;

vars
	nd : NodeDescriptor;
	sd : SessionDescriptor;
	
begin
	self.stopClock;
	
	self.setRunning(false);
	
	nd := self.myNodeDescriptor;
	
	if nd &lt;&gt; null and (not nd.isRunning) then
		nd.stopClock;
	endif;

	sd := self.mySessionDescriptor;
	
	if sd &lt;&gt; null and (not sd.isRunning) then
		sd.stopClock;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateDriverDetailsFromString" id="5cf126a3-e543-449e-87e6-0edd65dd8818">
        <updating/>
        <source>updateDriverDetailsFromString(details, _profileName : String) updating;

begin
	self.mySummary.jtdSetFromString(details);
	
	if self.profileName &lt;&gt; _profileName then
		self.profileName := _profileName;
	endif;
end;</source>
        <Parameter name="details" type="String"/>
        <Parameter name="_profileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateForCreate" id="53eba023-c296-464d-8c85-633d2b92c5a6">
        <updating/>
        <source>updateForCreate(_process : Process; _procMachine : MachineDescriptor;
	_session : SessionDescriptor; _node : NodeDescriptor) updating;

begin
	self.myProcess := _process;
	
	self.updateProcessDetails;
	
	self.mySessionDescriptor := _session;
	
	self.myNodeDescriptor := _node;
	
	self.myMachineDescriptor := _procMachine;
end;</source>
        <Parameter name="_process" type="Process"/>
        <Parameter name="_procMachine" type="MachineDescriptor"/>
        <Parameter name="_session" type="SessionDescriptor"/>
        <Parameter name="_node" type="NodeDescriptor"/>
    </JadeMethod>
    <JadeMethod name="updateProcessDetails" id="5ea5a648-0f96-4681-8193-5b1edf179f6e">
        <updating/>
        <source>updateProcessDetails() : Node updating, protected;

vars
	errNo : Integer;
	errTxt : String;
	n : Node;
	
begin
	errNo := 0;
	on Exception do app.resumeNextExHandler(exception, errNo, errTxt);
	
	self.setSignOnUserCodeFromProcess(self.myProcess);
	if errNo &lt;&gt; 0 then
		self.signOnUserCode := "*** Unknown ***";
		errNo := 0;
	endif;
	
	self.setNodeNameFromProcess(self.myProcess);
	if errNo &lt;&gt; 0 then
		self.nodeName := "*** Unknown ***";
		errNo := 0;
	endif;
	
	self.processInstanceId := jtdGetInstanceIdForObject(self.myProcess);
	if errNo &lt;&gt; 0 then
		self.processInstanceId := 0;
		errNo := 0;
	endif;
	
	n := self.myProcess.node;
	if errNo &lt;&gt; 0 then
		return null;
	endif;
	return n;
end;</source>
        <access>protected</access>
        <ReturnType type="Node"/>
    </JadeMethod>
</Class>
