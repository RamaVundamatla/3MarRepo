    <JadeMethod name="enableStatusNotApproved" id="9a671f83-f840-4311-b33e-6ff99a858365">
        <source>enableStatusNotApproved():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Apr 2023	navma1	Bug 57456: EUP - Not Approved Status is not enabled for ToDo work orders

*/

vars
	user			 	: CM_User;
	isExternalUser   	: Boolean;
	voyageProcess   	: CM_VoyageProcess;
begin
	user			:= app.getMyUser();
	isExternalUser	:= user.myOrganisation.isExternal;
	
	if self.taskStatus &lt; WO_STATUS_APPROVED  then
		if not isExternalUser then
			if self.taskStatus = WO_STATUS_PENDING or self.taskStatus = WO_STATUS_USERENTRY  then								
				return true;
			endif;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="erase" id="fc4f0f95-89c7-4faa-bd70-811e75f56da6">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23/07/2009	cnwrd1	Initial creation
16/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
22/11/2023	navcs2	ChangeRequest 60866: EUP | Manifest - Single Work Order per transport
*/

vars
	woDtl : CM_WorkOrderDtl;
begin
	//self.allWoDtls.purge();  // now a child collection
	if self.myPinNo &lt;&gt; null then					// TFS 38501
		self.myPinNo.removeItem(self, true);		// TFS 38501
	endif;											// TFS 38501
	
	self.causeEvent(self.getMyTerminal.getTerminalEvent(Object_Delete_Event), true, self);		// 22/11/2023	navcs2	ChangeRequest 60866
	
	//jlier1 29/5/25 MTN-34591 
	self.causeTerminalEvent(Event_WorkOrder_Delete);
	
	//07/05/2025	navkc1 JIRA MTN-34592 - When deleting a work order, also send notification to work order details
	foreach woDtl in self.allWoDtls discreteLock do
		woDtl.causeTerminalEvent(Event_WODtl_Delete);
	endforeach;
	
	inheritMethod(_eraseLevel);
epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
