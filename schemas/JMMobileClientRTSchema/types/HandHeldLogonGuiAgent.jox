    <JadeMethod name="getClientConnectionDetails" id="ccbafd37-2449-4053-8918-b7b41665d686">
        <source>getClientConnectionDetails(_deviceName, _terminalCode, _username : String output) : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	iniFileName : String;
begin
	iniFileName 			:= app.getIniFileName();
	_terminalCode			:= app.getProfileString(iniFileName, HandHeldIniFileSection, Key_HandHeldTerminal, null);
	_deviceName				:= app.getProfileString(iniFileName, HandHeldIniFileSection, Key_HandHeldDevice, null);
	_username				:= app.getProfileString(iniFileName, HandHeldIniFileSection, Key_HandHeldUser, null);
	/*
	if _terminalCode = null then
		app.msgBox('Ini file [' &amp; HandHeldIniFileSection &amp; '] section has not been configured correctly.' &amp; CrLf &amp;
		'It is missing a "' &amp; Key_HandHeldTerminal &amp; '" parameter', 'Inialization file error', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	if _deviceName = null then
		app.msgBox('Ini file [' &amp; HandHeldIniFileSection &amp; '] section has not been configured correctly.' &amp; CrLf &amp;
		'It is missing a "' &amp; Key_HandHeldDevice &amp; '" parameter', 'Inialization file error', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	*/
	return true;
	
end;

</source>
        <Parameter name="_deviceName" type="String" usage="output"/>
        <Parameter name="_terminalCode" type="String" usage="output"/>
        <Parameter name="_username" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
