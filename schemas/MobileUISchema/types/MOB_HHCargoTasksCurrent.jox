    <JadeMethod name="doComplete" id="df97ce29-5800-4d1c-b79d-500a90342048">
        <source>doComplete():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2015	cnwndl1	Initial creation	Par 37011

*/

vars

	localSet : CM_TiToDoTaskSet;
	tiToDoTask : CM_TiToDoTask;
	toDoTaskDesc : CM_ToDoTaskDesc;
	rows : Integer;
	rowIndex : Integer;
	msg : String;
	
	resourceTypeForm : MOB_ResourceTypeUsageForm;
	localTiSet : CM_TISet;
	result : Integer;
	
	handlingType : CM_HandlingType;	//18 Apr 2017	NDL	TFS 3414
	
begin

	create localSet transient;
	create localTiSet transient;
	
	self.allNewProxyResourceTypeUsages.purge();
	
	tiToDoTask := self.cmbTasks.itemObject[self.cmbTasks.listIndex].CM_TiToDoTask;
	if tiToDoTask &lt;&gt; null then
		localSet.add( tiToDoTask );
		localTiSet.add( tiToDoTask.myTrackedItem );
		handlingType := tiToDoTask.myTrackedItem.getHandlingType;
		if handlingType &lt;&gt; null and not handlingType.isPallet then
			handlingType := null;
		endif;
	endif;
	
	if localSet.isEmpty or localTiSet.isEmpty then
		msg := app.getErrorString(NO_Items_selected);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	toDoTaskDesc := localSet.first.toDoTaskDesc;
	if toDoTaskDesc = null then
		msg := app.getErrorString(ERR_INVALID_TODOTASKDESCR);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if not toDoTaskDesc.allResourceTypes.isEmpty then
	
		//collect up a template of the resources used
		create resourceTypeForm transient;
		resourceTypeForm.myToDoTask := toDoTaskDesc;
		resourceTypeForm.setTemplateOnly( true, self );
		resourceTypeForm.doNotCentreWindow := true; 
		resourceTypeForm.move(self.left, self.top, self.width, self.height );
		resourceTypeForm.myHandlingType := handlingType;
		resourceTypeForm.showModal();
		if resourceTypeForm.modalResult &lt;&gt; IDOK then
			return false;
		endif;
		
	endif;
	
	//04 Feb 2016	NDL	Par 37513
	if toDoTaskDesc.requiredExtraInfo &lt;&gt; null then
		self.doToDoReqdExtraInfo( toDoTaskDesc, self.myTrackedItem );
		if toDoTaskDesc.requiredExtraInfo = EXTRA_INFO_WEIGHT then		// from TFS 2357 testing have already removed the to do in MOB_WeighTaskForm, or have cancelled
			return true;
		endif;
	endif;
	
	while true do	
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk( toDoTaskDesc, localTiSet, self.allNewProxyResourceTypeUsages, app.myPassport );
		
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			return true;
		else
			//If there were warnings, give the user a chance to see them. If there are no _errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog("", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;

epilog

	delete localSet;
	delete resourceTypeForm;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="ed0b81c6-a97d-43bf-a5ff-0d6fdaf6e5c9">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2015	cnwndl1	Initial creation	Par 37011

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth - self.getSearchButtonSpace();
	cHeight := stdHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move( 	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
						 
	cWidth := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.setAndIncrementTabIndex( tabIndex );
		self.btnPartCargoId.visible := true;
	endif;
	self.btnPartCargoId.move(	self.txtCargoId.left + self.txtCargoId.width + self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.txtCargoId.height;// + self.resizedMargin;
	if _initialSetup then
		self.lblCargoType.visible := true;
		self.lblCargoType.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblCargoType.move( self.resizedMargin,
							cTop,
							stdWidth,
							cHeight ); 
	
	cTop := cTop + self.lblCargoType.height;// + self.resizedMargin;
	if _initialSetup then
		self.lblCargoDesc.visible := true;
		self.lblCargoDesc.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblCargoDesc.move(	self.resizedMargin,
							cTop,
							stdWidth,
							cHeight );
						 
	cTop := cTop + self.lblCargoDesc.height;// + self.resizedMargin;
	if _initialSetup then
		self.cmbTasks.setAndIncrementTabIndex( tabIndex );
		self.cmbTasks.visible := true;
	endif;
	self.cmbTasks.move( 	self.resizedMargin,
							cTop,
							stdWidth,
							cHeight );
	
	cTop := cTop + self.cmbTasks.height;// + self.resizedMargin;
	if _initialSetup then
		self.lblDescription.setAndIncrementTabIndex( tabIndex );
		self.lblDescription.visible := true;
	endif;
	self.lblDescription.move(	self.resizedMargin,
								cTop,
								stdWidth,
								cHeight * 2 );
								
	cTop := cTop + self.lblDescription.height;// + self.resizedMargin;
	cHeight:= (self.clientHeight - cTop - self.getCMDButtonsHeight() - self.resizedMargin - self.resizedMargin);
	if _initialSetup then
		self.txtRemarks.setAndIncrementTabIndex( tabIndex );
		self.txtRemarks.visible := true;
	endif;
	self.txtRemarks.move(	self.resizedMargin, 
							cTop, 
							stdWidth, 
							cHeight);
						
	
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
