    <JadeMethod name="getSelectorVisibleColumns" id="4f079f5b-6650-461b-ab6c-17d855e31ebf">
        <source>getSelectorVisibleColumns(_sa: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2022	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query

*/

vars
	qProp	: CM_QueryProperty;
begin
	_sa.clear();

	qProp := self.allQueryProperties[CM_WOTransaction::getTransactionType.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CM_WOTransaction::dateTime.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CM_WOTransaction::getWONumber.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CM_WOTransaction::myTerminal.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
epilog

end;</source>
        <Parameter name="_sa" type="StringArray" usage="input"/>
    </JadeMethod>
</Class>
