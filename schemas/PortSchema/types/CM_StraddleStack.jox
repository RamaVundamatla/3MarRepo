<Class name="CM_StraddleStack" id="708560ca-c5dd-4e93-acbf-77f5fdfe28d3">
    <superclass name="CM_GridArea"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Is responsible for looking after the straddle stack areas defined in the system.
Looks after its graphical representation.
Rows, CM_YardLCArray, and location controllers are all created from the block definition at definition time.
A Row is bound to the first and last location controller in each row at definition time
The location dictionary is then populated by iterating over each row and related
location controllers.
CM_RestrictionSet apply at this level.</text>
    <DbClassMap file="location"/>
    <PrimAttribute name="autoStackDirection" id="e1d3d458-0322-46de-a27b-f37c6fe8f045">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
        <text>Determines the way this straddle stack's rows are stacked.
Either along the row at low height, or up the stack
See CM_Autoplan consts
NOTE: THIS IS FOR RECEIVALS INTO THE STACK</text>
    </PrimAttribute>
    <PrimAttribute name="autoStackDirectionOut" id="9ac7ea3b-7adc-4078-aedb-cd40a0d2af68">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
        <text>Determines the way this straddle stack's rows are stacked.
Either along the row at low height, or up the stack
See CM_Autoplan consts
NOTE: THIS IS FOR RELEASES from THE STACK</text>
    </PrimAttribute>
    <PrimAttribute name="height" id="1ba0ebba-68bc-4f3e-b209-9d437279e7ce">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="numRowsMachineSep" id="47105ef5-aa74-42c3-9cc1-439e4d43a794">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
        <text>The number of straddle rows we separate machines working in
this area by.</text>
    </PrimAttribute>
    <ExplicitInverseRef name="subBlockStacks" id="c935ac63-655d-485a-921c-4f46cc1c528e">
        <updateMode>automatic</updateMode>
        <type name="CM_SubBlockStackByIdDict"/>
        <access>protected</access>
        <text>This dictionary contains the references to any sub-block stacks within a specific Straddle Stack
block.</text>
        <Inverse name="CM_SubBlockStack::parent"/>
    </ExplicitInverseRef>
    <JadeMethod name="autoPlan" id="7123478b-d1d8-4f71-bc44-b8bbab6e7572">
        <updating/>
        <source>autoPlan(theAutoMovePlan: CMIF_AutoMovePlan input; theAttributeArea: CM_AttributeArea input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// v
// ---------------------------------------------------------------------------

vars

	lc						: CM_LocationsController;
	i						: Integer;
	numInColl				: Integer;
	firstRowLC				: Boolean;
	autoStackDir			: Integer;
	locnId					: String;
	maxHeight,maxLCHeight, maxLCsXHeight, numOfLoops				: Integer;
	prevIndex				: Integer;
	overStowHuntToRow		: Boolean;
	tiLocationParentObject	: CM_Object;
	heightIter				: Integer;
	firstEntry				: Boolean;
	objLocation				: CM_LocationsController;
	currentGridRow 			: CM_GridRow;
	currentRowOrd			: Integer;
	theTI					: CM_TrackedItem;
begin

	theTI := theAutoMovePlan.myTrackedItem;

	if theAutoMovePlan.isOverstowMove then
		if self.myTerminal.isAutoPlanUseOverstowRules() then   //SFW1030 04/08/2008
			self.doOverstowMoveYA(theAutoMovePlan);
		else
			if theTI.myTerminal &lt;&gt; null and theTI.myTerminal.testYAOverstowTI(theTI) then
				self.doOverstowMoveYA(theAutoMovePlan);
			else
				self.doOverStowMove(theAutoMovePlan);
			endif;
		endif;
		return;
	endif;
	firstEntry := true;

	//theAutoMovePlan.addLogEntry("Testing Terminal Area " &amp; self.id, IsForLogging); //- cnwmd1, Par 20524
	theAutoMovePlan.addLogEntry(app.getErrorString1(Testing_terminal_area, self.id), IsForLogging, Testing_terminal_area);

	if not self.myTerminal.isAutoPlanningEnabled() then   //SFW1030 04/08/2008
		theAutoMovePlan.updateController(null);
		return;
	endif;

	if theAutoMovePlan.myTrackedItem = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "No TI Reference", null, null);
		return;		
	endif;
	//---------------
	//Iterate through all the LC's in this list, test each one
	//---------------
	numInColl := theAttributeArea.allLocationControllers.size;
	if numInColl = 0 then
		/* Andrew and Steve changed this so that 96/2000 fault from Ponty is fixed, line below was added to ensure that the
		   autoplan continues with the next Attribute Area */
		theAutoMovePlan.updateController( null);
		//theAutoMovePlan.addLogEntry("No Locations to search in Attribute Area: " &amp; self.id &amp; " , continuing with next Area." , IsForLogging); //- cnwmd1, Par 20524
		theAutoMovePlan.addLogEntry(app.getErrorString1(Locat_searc_attri_area_conti_w, self.id), IsForLogging, Locat_searc_attri_area_conti_w);
		return;
	endif;

	theAutoMovePlan.iteration := 1;
	autoStackDir := self.autoplanStackDirection;
	maxHeight := self.heightOfStack;
	if autoStackDir = STACK_ALONG_ROW then
		//theAutoMovePlan.addLogEntry("Stack directional processing = Stack Along Row.", IsForLogging); //- cnwmd1, Par 20524
		theAutoMovePlan.addLogEntry(app.getErrorString(Stack_direct_proces_stack_alon), IsForLogging, Stack_direct_proces_stack_alon);
	elseif autoStackDir = STACK_ALL_HEIGHT then
		//theAutoMovePlan.addLogEntry("Stack directional processing = Stack All at lowest height.", IsForLogging); //- cnwmd1, Par 20524
		theAutoMovePlan.addLogEntry(app.getErrorString(Stack_direc_proce_stack_lowes_), IsForLogging, Stack_direc_proce_stack_lowes_);
	elseif autoStackDir = STACK_UP_STACK then
		//theAutoMovePlan.addLogEntry("Stack directional processing = Stack UP Stack", IsForLogging); //- cnwmd1, Par 20524
		theAutoMovePlan.addLogEntry(app.getErrorString(Stack_direct_proces_stack_stac), IsForLogging, Stack_direct_proces_stack_stac);
	endif;

	//------------------
	//Call the terminal area hunt for similar TI to place besides.
	//It is. ONLY implimented for Straddle Stacks at the moment...
	//------------------
	i := 1;
	if self.autoPlanTest.testHuntToFirstSimiliar = false then
		//theAutoMovePlan.addLogEntry("Hunt to first object equal Voyage, CmdtyGroup and Disch Port in area test not selected, Skipping.", IsForLogging); //- cnwmd1, Par 20524
		theAutoMovePlan.addLogEntry(app.getErrorString(Hunt_first_objec_equal_voyag_c), IsForLogging, Hunt_first_objec_equal_voyag_c);
	else
		lc := self.testFindHuntedTILC(theAutoMovePlan, theAttributeArea);
		//----------------
		//If the hunt finds nothing, simply contine from the start of available LC's.
		//----------------
		if lc = null then
			//theAutoMovePlan.addLogEntry("Hunting to first object equal Voyage, Commodity Group and Discharge Port failed, continuing with normal search.", IsForLogging); //- cnwmd1, Par 20524
			theAutoMovePlan.addLogEntry(app.getErrorString(Hunti_first_objec_equal_voyag_), IsForLogging, Hunti_first_objec_equal_voyag_);
		endif;
	endif;

	if lc &lt;&gt; null then
		//----------------
		//Start at this controller...
		//----------------
		i := theAttributeArea.allLocationControllers.indexOf(lc);	//&lt;-- default to hunted index.
		if theAutoMovePlan.prevAutoPlanLCToStartFrom &lt;&gt; null then
			prevIndex := theAttributeArea.allLocationControllers.indexOf(theAutoMovePlan.prevAutoPlanLCToStartFrom);
			if prevIndex &gt; 0 and prevIndex &gt; theAttributeArea.allLocationControllers.indexOf(lc) then
				//------------------
				//Our LAST good index is FURTHER on than our HUNTED index.
				//Use the LAST one.
				//------------------
				//theAutoMovePlan.addLogEntry("Using Super-Fast testing, starting at " &amp; theAutoMovePlan.prevAutoPlanLCToStartFrom.getFullId &amp; " for the test, better than Hunted found location.", IsForLogging); //- cnwmd1, Par 20524
				theAutoMovePlan.addLogEntry(app.getErrorString1(Using_super_testi_start_test_b, theAutoMovePlan.prevAutoPlanLCToStartFrom.getFullId), IsForLogging, Using_super_testi_start_test_b);
				i := prevIndex;
			endif;
		endif;
	else
		//--------------------
		//If we have the "super fast" option set, then try and locate the lc in this list...
		//--------------------
		if theAutoMovePlan.prevAutoPlanLCToStartFrom &lt;&gt; null then
			i := theAttributeArea.allLocationControllers.indexOf(theAutoMovePlan.prevAutoPlanLCToStartFrom);
			if i &lt;= 0 then
				//----------------
				//Hmm, it aint here.. Oh well, start at the start again
				//----------------
				i := 1;
			else
				//theAutoMovePlan.addLogEntry("Using Super-Fast testing, starting at " &amp; theAutoMovePlan.prevAutoPlanLCToStartFrom.getFullId &amp; " for the test...", IsForLogging); //- cnwmd1, Par 20524
				theAutoMovePlan.addLogEntry(app.getErrorString1(Using_superf_testin_starti_tes, theAutoMovePlan.prevAutoPlanLCToStartFrom.getFullId), IsForLogging, Using_superf_testin_starti_tes);
			endif;
		endif;
	endif;
	//-------------------
	//Hunt to first available overstow position
	//-------------------
	objLocation := theAutoMovePlan.myTrackedItem.getPrimaryLocation(REAL_MODE);

	tiLocationParentObject := objLocation.getParent;
	maxLCsXHeight := (maxHeight * numInColl); // PAR 8217
	firstRowLC := true;
	currentRowOrd := 1;
	while true do	//Loop for overstow moves.
		while true do
			numOfLoops := numOfLoops + 1; // how many times have we looped round this while?
			
			theAutoMovePlan.numLCsTested := theAutoMovePlan.numLCsTested +1;

			lc := theAttributeArea.allLocationControllers[i];			//Get the lc pointed to by i

			// ################################################
			// Stack pad position one layer at a time, then move to next height in Row
			// ################################################
			if autoStackDir = STACK_ALL_HEIGHT then
				if lc.isKindOf(CM_GridController) then
					if currentGridRow &lt;&gt; null 
					and currentGridRow &lt;&gt; lc.CM_GridController.myGridRow then // If I have changed row
						theAutoMovePlan.iteration := theAutoMovePlan.iteration + 1; // go to the next height
						if theAutoMovePlan.iteration &gt; maxHeight then  // if the height is maxed out
							currentRowOrd := i ;  // if the height is maxed out go to the first LC in the next row
							theAutoMovePlan.iteration :=  1; // and start at the bottom height
						endif; 
						i := currentRowOrd; // this will restart the LCs at the first within the current row
						lc := theAttributeArea.allLocationControllers[i];			// Switch to the first in the current row
					endif;
				endif;
			endif;

			locnId := lc.getFullId &amp; theAutoMovePlan.iteration.String;
			//theAutoMovePlan.addLogEntry("Testing : " &amp; locnId , IsForLogging); //- cnwmd1, Par 20524
			theAutoMovePlan.addLogEntry(app.getErrorString1(Testing, locnId), IsForLogging, Testing);
			//-------------
			//Test this LC and see if it meets the criteria in the autoplan
			//-------------

			/*
			if not tryLock(lc, Share_Lock, Transaction_Duration, LockTimeout_Server_Defined ) then
			//If we cannot get a lock, then someone else is hacking at it!
			//Skip to next LC in list.
			theAutoMovePlan.addLogEntry(locnId &amp; " is locked by someone else, skipping to next...");
			theAutoMovePlan.updateController( null);
			return;
			endif;
			*/
			if autoStackDir = STACK_UP_STACK then
				maxLCHeight := lc.getMaxStackingHeight(); // PAR 7861 added. Looks at height availability 
				foreach heightIter in 1 to maxLCHeight do
					theAutoMovePlan.iteration := heightIter;
					lc.testAutoPlan(theAutoMovePlan);		//Test this lc against the autoplan criteria
				endforeach;
			else
				lc.testAutoPlan(theAutoMovePlan);		//Test this lc against the autoplan criteria
			endif;
			if theAutoMovePlan.getController &lt;&gt; null then
				//-------------
				//We have found a suitable location for this TI, we can go home now. The End
				//-------------
				return;

			endif;
			if lc.isKindOf(CM_GridController) then
				currentGridRow := lc.CM_GridController.myGridRow;
			endif;

			i := i + 1;
			if i &gt; numInColl then
				break;
			endif;
		//if isLockedByMe(lc) then
		//	unlock(lc);
		//endif;
		endwhile;
		
		// maxLCsXHeight is the total number of LCs times the max height for this stack. We should not iterate round this while for more than that
		//					as we check each height for each location
		if numOfLoops &gt; maxLCsXHeight then // PAR 8217
			break; // PAR 8217
		endif; // PAR 8217
		//------------------
		//Outer while loop, for overstow moves. We firstly attempt to start at the NEXT location
		//from TI's current location. If we cannot find a position, then we simply start again.
		//------------------
		if overStowHuntToRow = true then
			//--------------
			//Start again, from the start!
			//--------------
			i := 1;
			overStowHuntToRow := false;
		elseif autoStackDir = STACK_ALONG_ROW then // PAR 7861
			i := 1; // PAR 7861
			theAutoMovePlan.iteration := theAutoMovePlan.iteration + 1; // PAR 7861
			if theAutoMovePlan.iteration &gt; maxHeight then // PAR 7861
				break; // PAR 7861
			endif; // PAR 7861
		elseif autoStackDir = STACK_ALL_HEIGHT then // PAR 7861
			i := 1; // PAR 7861
			theAutoMovePlan.iteration := theAutoMovePlan.iteration + 1; // PAR 7861
			currentGridRow := null;
			if theAutoMovePlan.iteration &gt; maxHeight then // PAR 7861
				break; // PAR 7861
			endif; // PAR 7861
		else
			//Normal situation, quit now.
			break;
		endif;
	endwhile;

end;</source>
        <Parameter name="theAutoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
        <Parameter name="theAttributeArea" type="CM_AttributeArea" usage="input"/>
    </JadeMethod>
    <JadeMethod name="autoPlanGetMaxHeight" id="35bf979c-7a3c-44f0-b734-08185a6cff37">
        <source>autoPlanGetMaxHeight(theAutoMovePlan: CMIF_AutoMovePlan input): Integer;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	return self.height;

end;</source>
        <Parameter name="theAutoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="calculateMoveLCs" id="51d732bb-26da-48a2-bbc5-5a37f625cda8">
        <source>calculateMoveLCs(ti : CM_TrackedItem): Real;
// ---------------------------------------------------------------------------
// Created:		28 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
//	return ti.getActualLength() / self.locationLength;
	return ti.getMoveLengthForLCs() / self.locationLength; // PAR 16415 CCMS 1029

end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="doOverStowMove" id="abbe585c-def6-45b2-80b2-0926da02669d">
        <updating/>
        <source>doOverStowMove(_cmifAutoPlan: CMIF_AutoMovePlan input) protected, updating;

// cnwdvb1 25 July 2003 

vars

	tiToMove		: CM_TrackedItem;
	moveLocn		: CM_StackController;
	tiToMoveLC		: CM_LocationsController;
	isMoveable		: Boolean;
	alert			: CM_SystemAlert;
	moveController	: CMIF_MoveController;
	lcArray			: CM_LCArray;

begin
	
	tiToMove := _cmifAutoPlan.myTrackedItem;
	//_cmifAutoPlan.addLogEntry("Trying to move overstowing item " &amp; tiToMove.id, IsForLogging); //- cnwmd1, Par 20524
	_cmifAutoPlan.addLogEntry(app.getErrorString1(Trying_move_oversto_item, tiToMove.id), IsForLogging, Trying_move_oversto_item);
	exclusiveLock(tiToMove);
	isMoveable := true;  				//general purpose variable
		
	//Test if it is connected...
	
	if tiToMove.CM_Container.isConnected  then
		if not tiToMove.myTerminal.getConfig(ReeferMoveOSConnected).Boolean then  // ### TFS 51521 17AUG2021 NAVAB1
			isMoveable := false;
			//_cmifAutoPlan.addLogEntry(tiToMove.id &amp; " is still connected. It is not currently moveable", IsForLogging); //- cnwmd1, Par 20524
			_cmifAutoPlan.addLogEntry(app.getErrorString1(Still_connect_current_moveabl, tiToMove.id), IsForLogging, Still_connect_current_moveabl);
			//app.raiseCMException1(Err_QueueTaskUpdate, tiToMove.id &amp; " is still connected. It is not currently moveable", null, null); //- cnwmd1, Par 20524
			app.raiseCMException1(Still_connect_current_moveabl, tiToMove.id, null, null);
			return;

		endif;
	endif;
	//See if another machine is already working the top box
	if tiToMove.getPrimaryLocation(QUEUE_MODE) &lt;&gt; null then		
		if tiToMove.queueTaskStatus &lt;&gt; TASK_UNACTIONED and
			tiToMove.queueTaskStatus &lt;&gt; TASK_COMPLETE then
			//_cmifAutoPlan.addLogEntry(tiToMove.id &amp; " is assigned to another machine. It cannot be moved in this task", IsForLogging); //- cnwmd1, Par 20524
			_cmifAutoPlan.addLogEntry(app.getErrorString1(Assig_anoth_machi_canno_moved_, tiToMove.id), IsForLogging, Assig_anoth_machi_canno_moved_);
			isMoveable := false;
		endif;
	endif;
	_cmifAutoPlan.updateController(null);

	if isMoveable then
		create moveController transient;
		//_cmifAutoPlan.addLogEntry("Testing ground positions in current row", IsForLogging); //- cnwmd1, Par 20524
		_cmifAutoPlan.addLogEntry(app.getErrorString(Testing_ground_positio_current), IsForLogging, Testing_ground_positio_current);
		_cmifAutoPlan.iteration := 1;		//ground level

		tiToMoveLC := tiToMove.getPrimaryLocation(REAL_MODE);
		tiToMoveLC.testOverstowLocations(_cmifAutoPlan,0);

		if _cmifAutoPlan.getController = null then
			//_cmifAutoPlan.addLogEntry("Testing other heights in current row", IsForLogging); //- cnwmd1, Par 20524
			_cmifAutoPlan.addLogEntry(app.getErrorString(Testing_other_heights_current), IsForLogging, Testing_other_heights_current);
			_cmifAutoPlan.iteration := 100;	//any height
			tiToMoveLC.testOverstowLocations(_cmifAutoPlan,0);
		endif;

		if _cmifAutoPlan.getController = null then
			//_cmifAutoPlan.addLogEntry("Testing ground positions in adjacent rows", IsForLogging); //- cnwmd1, Par 20524
			_cmifAutoPlan.addLogEntry(app.getErrorString(Testin_ground_positi_adjace_ro), IsForLogging, Testin_ground_positi_adjace_ro);
			_cmifAutoPlan.iteration := 1;
			tiToMoveLC.testOverstowLocations(_cmifAutoPlan,100);	//NFS GD Xpose 1571 - was 1 row either side
		endif;

		if _cmifAutoPlan.getController = null then
			//_cmifAutoPlan.addLogEntry("Testing other heights in adjacent rows", IsForLogging); //- cnwmd1, Par 20524
			_cmifAutoPlan.addLogEntry(app.getErrorString(Testin_other_height_adjace_row), IsForLogging, Testin_other_height_adjace_row);
			_cmifAutoPlan.iteration := 100;
			tiToMoveLC.testOverstowLocations(_cmifAutoPlan,100);	//NFS GD Xpose 1571 - was 1 row either side
		endif;

		if _cmifAutoPlan.getController() = null then
			create alert;
			alert.details := "Could not find an overstow move location for " &amp; tiToMove.id &amp; 
			" in " &amp; tiToMove.locationId &amp; ". Manual intervention required";
			alert.setSeverity(SEVERE_WARNING);
			alert.add;
			//_cmifAutoPlan.addLogEntry("Unable to find an overstow move location for " &amp; tiToMove.id, IsForLogging);   	 //- cnwmd1, Par 20524
			_cmifAutoPlan.addLogEntry(app.getErrorString1(Unable_find_overst_move_locati, tiToMove.id), IsForLogging, Unable_find_overst_move_locati);   	
			return;
		endif;		

		moveLocn := _cmifAutoPlan.getController.CM_StackController;

		//_cmifAutoPlan.addLogEntry(tiToMove.id &amp; " will be moved to " &amp; moveLocn.getID &amp; " as an overstow move", IsForLogging); //- cnwmd1, Par 20524
		_cmifAutoPlan.addLogEntry(app.getErrorString2(Will_moved_oversto_move, tiToMove.id, moveLocn.getID), IsForLogging, Will_moved_oversto_move);

		moveController.setMyTrackedItem(tiToMove);
		moveController.setMyToPrimaryLocation(moveLocn);
//		if tiToMove.isAttributeTrue(TI_Attrib_IsForty) then
//			create lcArray transient;
//			lcArray.add(moveLocn.myNextController);
//			moveController.setMyToSecondaryLocations(lcArray);			
//		endif;
		
		moveController.setMoveMode(QUEUE_MODE);
		moveController.isRadioTelemetryMove := true;
		moveController.isOverstowMove := true;
		moveController.isSystemMove := true;
		moveController.setMyWorkListEntry(null);
//		moveController.setJobForMove(_cmifAutoPlan.jobForMove);
		moveController.myRTQueueEntry := _cmifAutoPlan.myRTQueueEntry;
		//-------------
		//Call the move method
		//-------------

		//app.myPassport.clearErrorsWarnings();
		app.myEventManager.initialise;
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, app.myPassport);
		if not app.myPassport.noErrors then
			app.convertErrorsWarningsToAlert("Overstow Move Error", app.myPassport.allErrorWarnings);
		endif;
	endif;

epilog
	delete moveController;
	delete lcArray;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifAutoPlan" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doOverstowMoveYA" id="084ff278-0d02-4ac5-a440-6447df8d01cc">
        <updating/>
        <source>doOverstowMoveYA(_cmifAutoPlan: CMIF_AutoMovePlan input) protected, updating;

// cnwdvb1 25 July 2003 

vars

	tiToMove		: CM_TrackedItem;
	moveLocn,
	tiToMoveLC		: CM_LocationsController;
	isMoveable		: Boolean;
	alert			: CM_SystemAlert;
	moveController	: CMIF_MoveController;
	lcArray			: CM_LCArray;
	yaAgent			: CM_YAAutoplanAgent;
	passport		: CM_Passport;

begin
	
	passport := app.myPassport;
	
	tiToMove := _cmifAutoPlan.myTrackedItem;
//	_cmifAutoPlan.addLogEntry("Trying to move overstowing item " &amp; tiToMove.id, IsForLogging);
	exclusiveLock(tiToMove);
	isMoveable := true;  				//general purpose variable
		
	//Test if it is connected...
	if tiToMove.CM_Container.isConnected then
		if not tiToMove.myTerminal.getConfig(ReeferMoveOSConnected).Boolean then  // ### TFS 51521 17AUG2021 NAVAB1 NOTE. doOverstowMoveYA is only called if the move is an overstow
			//_cmifAutoPlan.addLogEntry(tiToMove.id &amp; " is still connected. It is not currently moveable", IsForLogging); //- cnwmd1, Par 20524
			_cmifAutoPlan.addLogEntry(app.getErrorString1(Still_connect_current_moveabl, tiToMove.id), IsForLogging, Still_connect_current_moveabl);
			isMoveable := false;
		endif;
	endif;

	//See if another machine is already working the top box
	if tiToMove.getPrimaryLocation(QUEUE_MODE) &lt;&gt; null then		
		if tiToMove.queueTaskStatus &lt;&gt; TASK_UNACTIONED and
			tiToMove.queueTaskStatus &lt;&gt; TASK_COMPLETE then
			//_cmifAutoPlan.addLogEntry(tiToMove.id &amp; " is assigned to another machine. It cannot be moved in this task", IsForLogging); //- cnwmd1, Par 20524
			_cmifAutoPlan.addLogEntry(app.getErrorString1(Assig_anoth_machi_canno_moved_, tiToMove.id), IsForLogging, Assig_anoth_machi_canno_moved_);
			isMoveable := false;
		endif;
	endif;
	
	if isMoveable then
	
		moveLocn := app.autoPlanOverstowYA(self.myTerminal, self, tiToMove);
		
		if moveLocn = null then
			tiToMove.createInfomationTransaction(YardAllocationOSLogging, app.myYAAgent.getLoggingArray(true), null, passport);
			// Try for normal autoplan.
			moveLocn := app.autoPlanTiYA(self.myTerminal, null, tiToMove);
			if moveLocn = null then
				return;
			endif;
		endif;
		
		create moveController transient;
		moveController.hazardSegregationValidated := true;
		moveController.setMyTrackedItem(tiToMove);
		moveController.setMyToPrimaryLocation(moveLocn);

		moveController.setMoveMode(QUEUE_MODE);
		moveController.isRadioTelemetryMove := true;
		moveController.isOverstowMove := true;
		moveController.isSystemMove := true;
		moveController.setMyWorkListEntry(null);
		moveController.myRTQueueEntry := _cmifAutoPlan.myRTQueueEntry;
		//-------------
		//Call the move method
		//-------------
		app.myEventManager.initialise;
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, passport);
		if not passport.noErrors then
			app.convertErrorsWarningsToAlert("Overstow Move Error", passport.allErrorWarnings);
		endif;
		
		if app.myYAAgent &lt;&gt; null then
			tiToMove.createInfomationTransaction(YardAllocationOSLogging, app.myYAAgent.getLoggingArray(true), null, passport);
		endif;
	endif;

epilog
	delete moveController;
	delete lcArray;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifAutoPlan" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="694e4469-e528-40e8-a1dc-1f794b078bcf">
        <source>findLocation(_strs: StringArray; _noException : Boolean; _foundLC: CM_LocationsController io; _foundHeight: Integer io);
// ---------------------------------------------------------------------------
// Created:			05 July 2001 by cnwdwq1
// Purpose:			By here, the strs array will contain :
//								array1: the row, column &amp; height (height is entirely OPTIONAL)
//								array2: the tower pos ("T") (OPTIONAL)
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
// 5 Nov 09		cnwer1		PAR 21526	 - Commented out alot of code that wouldn't of done much
// ---------------------------------------------------------------------------
constants
	TOWER_POS = "T";
vars
	tmpStr,
	tStr		: String;
	lc			: CM_GridController;

begin
	//20 Feb 2014	NDL	Par 33550
	inheritMethod(_strs, _noException, _foundLC, _foundHeight);

	if _strs.isEmpty or _foundLC = null then
		return;
	endif;

	tStr := _strs[1].trimBlanks;
	
	if tStr = null then
		return;
	endif;
	
	if _foundLC.isKindOf(CM_GridController) then
		lc:=_foundLC.CM_GridController;
		
		if lc.mySubBlockStack &lt;&gt; null then
			//Tell the sub-block to findLocation
			lc.mySubBlockStack.findLocation(_strs, _noException, _foundLC, _foundHeight);
		else
			if _strs.size = 1 then
				//no last part.
				return;
			endif;
			tStr := _strs[2].trimBlanks;

			if tStr.length = 1 and tStr[1] = TOWER_POS then	//17 Feb 2014	NDL	Par 33460
				_foundLC := lc.getMyNextController(CM_TowerController).CM_TowerController;
			elseif _strs.size = 2 and tStr.isInteger then 	//17 Feb 2014	NDL	Par 33460
				_foundHeight := tStr.Integer;
			endif;
		
			
		endif;
	endif;
end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getGridCaption" id="950cb0ce-5c96-454c-8148-cc184ae54c31">
        <source>getGridCaption() : String;
// ---------------------------------------------------------------------------
// Created:		19 February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	accessString : String;
begin
	accessString := null;
	if not self.noAccessLeft and not self.noAccessRight then
		accessString := null; //"Full Access";
	elseif not self.noAccessLeft and self.noAccessRight then
		accessString := "Access Left Only";
	elseif self.noAccessLeft and not self.noAccessRight then
		accessString := "Access Right Only";
	else
		accessString := "No Access Left or Right";
	endif;
	if accessString = null then
		return  self.id.trimBlanks &amp; ", ";
	else
		return  self.id.trimBlanks &amp; " (" &amp; accessString &amp; "), ";
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
