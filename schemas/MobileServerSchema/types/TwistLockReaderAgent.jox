    <JadeMethod name="connectionExceptionHandler" id="8331b189-94dd-47d6-be80-84998bf875c5">
        <source>connectionExceptionHandler(exObj :  ConnectionException): Integer;
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.writeLog(method.name &amp; " " &amp; exObj.errorCode.String &amp; " - " &amp; exObj.extendedErrorText);
	return Ex_Abort_Action;


epilog

end;</source>
        <Parameter name="exObj" type="ConnectionException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createRTGTelegram" id="80fa9c70-7089-4914-a0f7-6258edaa1769">
        <updating/>
        <source>createRTGTelegram(_telegramStr : String input) :CM_RTGTelegram updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	twistLockXML : JadeXMLDocument;
	rootXMLElement,
	childElement : JadeXMLElement;
	num,
	ver,
	height,
	weight,
	length,
	xPos,
	yPos,
	locn,
	twistLock : String;
	pxyRTGTelegram,
	realRTGTelegram: CM_RTGTelegram;
	error : CM_Error;
begin
	self.initialiseForNewRequest(null);  //cnwjo3 par 24636

	if _telegramStr = null then
		self.writeLog("twistlock info is null ???");
		return null;
	endif;
	on JadeXMLException do self.xmlExceptionHandler(exception);
	
	create twistLockXML transient;
	twistLockXML.parseString(_telegramStr);
	rootXMLElement:=twistLockXML.rootElement;
	if rootXMLElement.tagName &lt;&gt; CM_RTGTelegram.XMLRoot then
		self.writeLog(method.name &amp; " -  xml root tag invalid is " &amp; CM_RTGTelegram.XMLRoot);
		return null;
	endif;
	
	if self.myMachine = null then
		self.writeLog(method.name &amp; " machine is null");
		return null;
	endif;
	
	//get num 
	num:=rootXMLElement.getTagValueOfName(CM_RTGTelegram.XMLNum);	
	// get ver
	ver:=rootXMLElement.getTagValueOfName(CM_RTGTelegram.XMLVer);
	// get height
	height:=rootXMLElement.getTagValueOfName(CM_RTGTelegram.XMLHeight);
	// get weight
	weight:=rootXMLElement.getTagValueOfName(CM_RTGTelegram.XMLWeight);
	// get length
	length:=rootXMLElement.getTagValueOfName(CM_RTGTelegram.XMLLength);
	// get location
	locn:=rootXMLElement.getTagValueOfName(CM_RTGTelegram.XMLLocn);
	// get xPos
	xPos:=rootXMLElement.getTagValueOfName(CM_RTGTelegram.XMLXpos);
	//get yPos
	yPos:=rootXMLElement.getTagValueOfName(CM_RTGTelegram.XMLYpos);
	// get Twistlock
	twistLock:=rootXMLElement.getTagValueOfName(CM_RTGTelegram.XMLTwist);
	
	create pxyRTGTelegram transient;
	pxyRTGTelegram.setProxy(ver.Integer,
							height.Real,
							length.Integer,
							xPos.Real,
							yPos.Real,
							locn,
							twistLock.Character,
							weight.Real,
							num.Integer);
	self.writeLog("machine is " &amp; self.myMachine.String);
	app.myTrxCA.trxCreateRTGTelegram(pxyRTGTelegram,realRTGTelegram,self.myMachine,app.myPassport);
	
	if app.myPassport.noErrors then
		if realRTGTelegram = null then
			self.writeLog("no errors but telegram is null");
		else
			self.writeLog("created telegram " &amp; realRTGTelegram.String);
		endif;
		return realRTGTelegram;
	else
		self.writeLog(method.name &amp; " had errors ");
	//create hand held errors
		foreach error in app.myPassport.allErrors do
			self.writeLog(method.name &amp; " -"  &amp; error.errorCode.String &amp; " - " &amp; error.text);
		endforeach;
	endif;
	
	return null;
epilog
	delete twistLockXML;
	delete pxyRTGTelegram;

end;</source>
        <Parameter name="_telegramStr" type="String" usage="input"/>
        <ReturnType type="CM_RTGTelegram"/>
    </JadeMethod>
    <JadeMethod name="delete" id="2377f61b-25f3-4750-a070-caff26786050">
        <updating/>
        <source>delete() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.endNotificationForSubscriber(self);
	if self.myWinCESerialPort &lt;&gt; null then
		delete self.myWinCESerialPort;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClose" id="c41c2ea2-e9bb-4cb3-8c8b-70afebe97302">
        <source>doClose();
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	if self.myWinCESerialPort &lt;&gt; null then
		if self.myWinCESerialPort.JadeSerialPort.state = JadeSerialPort.Connected then
			self.myWinCESerialPort.JadeSerialPort.close;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOpen" id="956df3f3-a6b5-4c71-8928-a9322a95457d">
        <source>doOpen();
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin


	
	if self.myWinCESerialPort &lt;&gt; null then
		self.myWinCESerialPort.openAsynch(self,TwistLockReaderAgent::doOpenSuccessful.name);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOpenSuccessful" id="6ad72bca-d980-4f04-b0f2-7abfe6f542f6">
        <source>doOpenSuccessful(connection: Connection);
/*

Purpose:			


Return Value:		


Date		Who		Reason
27 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	messge : String;
begin
	messge:="Open connection successfully";
	self.writeLog(messge);
	self.startNotes();
	self.doRead();
epilog

end;</source>
        <Parameter name="connection" type="Connection"/>
    </JadeMethod>
    <JadeMethod name="doRead" id="e369a787-7302-429e-86ba-af34e66482cf">
        <source>doRead();
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	self.writeLog(method.name &amp; " starting twist lock read");
	self.myWinCESerialPort.fillReadBuffer:=true;
	self.myWinCESerialPort.readUntilAsynch(EOLBinary ,200,self,TwistLockReaderAgent::doReadSuccessful.name);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doReadSuccessful" id="1bac7bd6-e5bc-439d-a2b6-e727734dc3d9">
        <updating/>
        <source>doReadSuccessful(connection: Connection;bin: Binary) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	twistlockInfo : Binary;
	telegram :		CM_RTGTelegram;
begin
	twistlockInfo:=bin;
	self.writeLog(method.name &amp; " - received telegram: " &amp; bin.String);
	telegram:=self.createRTGTelegram(twistlockInfo.String);
	self.writeLog(method.name &amp; " - sending note: " &amp;  twistlockInfo.String);
	//send note even if something has gone wrong
	self.myMachine.causeEvent(EVENT_TWISTLOCK_RESPONSE,true,telegram);

epilog

end;</source>
        <Parameter name="connection" type="Connection"/>
        <Parameter name="bin" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getAppName" id="d36ae710-acc2-4270-a156-8293a5f921b1">
        <source>getAppName(): String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
