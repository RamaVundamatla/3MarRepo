    <JadeMethod name="formatNYKRemarksForCooling" id="9ff0a9a7-c607-4dfa-9b9a-8a656155e318">
        <source>formatNYKRemarksForCooling() : Integer;
//-----------------------------------------------------------------------
//	Created:	03 May 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

begin
	if self.ediString = null then
		return ContainerCooledNull;
	endif;

	if self.ediString.pos('W',1) &lt;&gt; 0 then
		return ContainerWaterCooled;
	elseif self.ediString.pos('A',1) &lt;&gt; 0 then
		return ContainerAirCooled;
	endif;
	return ContainerCooledNull;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="formatNYKRemarksForVoltage" id="2a75dd5b-6bf8-45d7-a3c9-e2680a9bf4c6">
        <source>formatNYKRemarksForVoltage() : Integer;
//-----------------------------------------------------------------------
//	Created:	03 May 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

begin
	if self.ediString = null then
		return ContainerVoltNull;
	endif;

	if self.ediString.pos('S',1) &lt;&gt; 0 then
		return ContainerSingleVolt;
	elseif self.ediString.pos('A',1) &lt;&gt; 0 then
		return ContainerDualVolt;
	endif;
	return ContainerVoltNull;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="formatPreloadDGRecords" id="860f8b7a-1ba2-4044-ac5e-55877bb0e84f">
        <source>formatPreloadDGRecords();
//----------------------------------------------------------------
//	Created:	10 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
constants
	TagDGRec	: String	= 'DGRecord';
	TagDGLine	: String	= 'DGLineNo';
	TagHaz		: String	= 'HazardousClass';
	TagUNN		: String	= 'UNNumber';
	
vars
	theXMLStr	: String;
	lineNo		: Integer;
	hazClass	: String;
	unNumber	: String;
	xmlDoc		: JadeXMLDocument;
	dgElements	: JadeXMLElementArray;
	xmlElem		: JadeXMLElement;
begin
	self.imCodes.clear;
	theXMLStr := self.ediString;
	
	if theXMLStr = null then
		return;
	endif;
	
	on JadeXMLException do null; 
	
	create xmlDoc transient;
	create dgElements transient;
	
	xmlDoc.parseString(self.ediString);
	
	xmlDoc.getElementsByTagName(TagDGRec, dgElements);
	
	if dgElements.isEmpty then
		return;
	endif;
	
	foreach xmlElem in dgElements do
		lineNo := xmlElem.getElementByTagName(TagDGLine).textData.Integer;
		hazClass := xmlElem.getElementByTagName(TagHaz).textData;
		unNumber := xmlElem.getElementByTagName(TagUNN).textData;
		
		self.imCodes.atPut(lineNo, hazClass &amp; ":+" &amp; unNumber);
	endforeach;

epilog
	delete xmlDoc;
	delete dgElements;
end;</source>
    </JadeMethod>
    <JadeMethod name="formatString_InputReversed" id="fba75556-474d-456a-84ea-996cf5a2cb6b">
        <source>formatString_InputReversed(): String;
//----------------------------------------------------------------
//	Created:	10 December 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	return self.ediString.reverse;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="formatTS_YYYYxMMxDDxHHxMMxSS" id="945c77f5-9b5c-4df9-b27b-b0036297bc1f">
        <source>formatTS_YYYYxMMxDDxHHxMMxSS(): TimeStamp;
//----------------------------------------------------------------
//	Created:	07 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	timeStmp	: TimeStamp;
	date		: Date;
	time		: Time;
	strDT		: String;
begin
	strDT := self.ediString;
	
	if strDT.length &lt; 10 then
		//must be 10 or longer to get a date
		return null;
	endif;
	
	//1234567890123456789
	//YYYYxMMxDDxHHxMMxSS
	date.setDate(strDT[9:2].Integer, strDT[6:2].Integer, strDT[1:4].Integer);
	timeStmp.setDate(date);

	if strDT.length &gt;= 19 then
		time.setTime(strDT[12:2].Integer, strDT[15:2].Integer, strDT[18:2].Integer, null);
		timeStmp.setTime(time);
	elseif strDT.length &gt;= 16 then
		time.setTime(strDT[12:2].Integer, strDT[15:2].Integer, null, null);
		timeStmp.setTime(time);
	endif;
	
	return timeStmp;

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="formatTimeStamp_YYMMDDHHMM" id="2e0e522b-e02c-41a2-afdc-6472bff51ec6">
        <source>formatTimeStamp_YYMMDDHHMM(): TimeStamp;
//----------------------------------------------------------------
//	Created:	07 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	timeStmp	: TimeStamp;
	date		: Date;
	time		: Time;
	strDT		: String;
begin
	strDT := self.ediString;
		
	if strDT.length &lt; 6 then
		//must be 6 or longer
		return null;
	endif;
	
	//123456789012
	//YYMMDDHHMMSS
	
	date.setDate(strDT[5:2].Integer, strDT[3:2].Integer, strDT[1:2].Integer);
	timeStmp.setDate(date);

	if strDT.length &gt;= 12 then
		time.setTime(strDT[7:2].Integer, strDT[9:2].Integer, strDT[11:2].Integer, null);
		timeStmp.setTime(time);
	elseif strDT.length &gt;= 10 then
		time.setTime(strDT[7:2].Integer, strDT[9:2].Integer, null, null);
		timeStmp.setTime(time);
	endif;
	
	return timeStmp;

end;</source>
        <text>TimeStamp</text>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="formatTimeStamp_YYYYMMDDHHMMSS" id="7b8bd43b-d36a-4e9c-ab8f-1095be91b38b">
        <source>formatTimeStamp_YYYYMMDDHHMMSS(): TimeStamp;
//----------------------------------------------------------------
//	Created:	07 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	timeStmp	: TimeStamp;
	date		: Date;
	time		: Time;
	strDT		: String;
begin
	strDT := self.ediString;
	
	if strDT.length &lt; 8 then
		//must be 8 or longer, to get the date at least
		return null;
	endif;
	
	//12345678901234
	//YYYYMMDDHHMMSS
	date.setDate(strDT[7:2].Integer, strDT[5:2].Integer, strDT[1:4].Integer);
	timeStmp.setDate(date);
	

	if strDT.length &gt;= 14 then
		time.setTime(strDT[9:2].Integer, strDT[11:2].Integer, strDT[13:2].Integer, null);
		timeStmp.setTime(time);
	elseif strDT.length &gt;= 12 then
		time.setTime(strDT[9:2].Integer, strDT[11:2].Integer, null, null);
		timeStmp.setTime(time);
	endif;
	
	return timeStmp;

end;</source>
        <text>TimeStamp</text>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="formatTime_HHMM" id="8c25ad5d-a7c6-4b4b-a138-a51effa95be7">
        <source>formatTime_HHMM():Time;
//----------------------------------------------------------------
//	Created:	10 December 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	time		: Time;
	strT		: String;
begin
	strT := self.ediString;
		
	if strT.length &lt; 4 then
		//must be 4 or longer
		return null;
	endif;
	
	time.setTime(strT[1:2].Integer, strT[3:2].Integer, null, null);
	
	return time;

end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="formatWriteElements" id="3c7c4c3f-2022-491d-94f8-94669bff6222">
        <source>formatWriteElements();
//----------------------------------------------------------------
//	Created:	10 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
begin
	app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " " &amp; self.ediString);
end;</source>
    </JadeMethod>
    <JadeMethod name="multiplyReal" id="3765a71d-d354-43fc-a0d7-18085d692f8f">
        <source>multiplyReal(_real: Real; _multiplier: Integer): Integer protected;
//----------------------------------------------------------------
//
//	Created:	05 July 2005	by Jason Chapman  (cnwjc2)
//
//	Wrapper for multiplying a Real by another number.  Protects against overflow.
//
//----------------------------------------------------------------
vars

begin

	if _multiplier = null then
		return null;
	endif;

	if _real &gt; (Max_Integer/_multiplier) then
		return null;
	elseif _real &lt; (Min_Integer/_multiplier) then
		return null;
	else
		return (_real * _multiplier).Integer;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_real" type="Real"/>
        <Parameter name="_multiplier" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
