    <JadeMethod name="getYardMenuItem" id="b184d34e-892d-4f10-9274-772e6a1a59fa">
        <source>getYardMenuItem():MenuItem protected;
// ---------------------------------------------------------------------------
// Created:     18 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj		:Object;
	menu	:MenuItem;
begin
	foreach obj in self.allMenuItems do
		menu := obj.MenuItem;
		
		if menu.name = YRD_RoadOperationsForm::mnuProceed.name and
			menu.userObject &lt;&gt; self then
			// this must be our one
			return menu;
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="8bd30676-606b-47ba-9fa3-d7633ce1496d">
        <source>includeObject(_wle: CM_WorkListEntry; _controller: CMIF_RoadOpController): Boolean protected;

/*
Date			Who		Reason
25 September 2014	cnwar2	Initial creation

*/
vars
	job	:CM_RoadJob;
begin
	// 25/09/2014 cnwar2 #34333
	if _controller.hideCompletedJobs then
		job := _wle.job.CM_RoadJob;
		
		if job &lt;&gt; null and job.isJobComplete then
			return false;
		endif;
	endif;
	
	return inheritMethod(_wle, _controller);

end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_controller" type="CMIF_RoadOpController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
