    <JadeMethod name="eprTestChangeRTQueueStatus" id="14bb1f10-d643-45be-b3b8-dbe06070c365">
        <source>eprTestChangeRTQueueStatus();
/*

Purpose:			


Return Value:		


Date		Who		Reason
02 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	rtQueueTask :  CM_RTQueueTask;
	machine : CM_Machine ;
	newStatus : Integer;
myTerminal : CM_Terminal;
	error : CM_Error;
begin
	app.initialize;
	
	machine:="2296.274".asOid.CM_Machine;
/*	rtQueueTask:="2832.858".asOid.CM_RTQueueTask;
	myTerminal:=app.myRoot.allTerminals["T01"];
	app.myPassport.setMyTerminal(myTerminal);
	app.myTrxRT.trxChangeTaskStatus(null,
					machine,
					TASK_UNACTIONED,
					app.myPassport);*/
	beginTransaction;				
	machine.setMachineStatus(STATUS_IDLE,"", false);
	commitTransaction;
	if not app.myPassport.trxCompletedOK then
		//create hand held errors
		foreach error in app.myPassport.allErrors do
			write error.errorCode.String &amp; Tab &amp; error.text;
		endforeach;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="eprTestMachineAccept2Tasks" id="4bff433d-f356-4af8-aa0b-73bbda4c0863">
        <source>eprTestMachineAccept2Tasks();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2009	cnwer1	Initial creation

*/

vars

	machine : CM_Machine;
	task  : CM_RTQueueTask;
	mediator :  CM_RTConnectMediator;
	isAllocatedTask : Boolean;
begin
	app.initialize;
	create mediator transient;
	machine:="2296.984".asOid.CM_Machine;
	task:="2832.7574".asOid.CM_RTQueueTask;
	isAllocatedTask:=machine.allAllocatedQueueTasks.first &lt;&gt; null;
	beginTransaction;
	machine.setMachineStatus(STATUS_ASSIGNED  , "", false);
	task.setStatus(TASK_ACCEPTED);
	
	task:="2832.7576".asOid.CM_RTQueueTask;
	machine.setMachineStatus(STATUS_ASSIGNED  , "", false);
	task.setStatus(TASK_ACCEPTED);
	commitTransaction;
epilog
	app.finalize;
	delete mediator;
end;</source>
    </JadeMethod>
    <JadeMethod name="eprTestMachineOffer2Tasks" id="f2cdcb1b-6fd6-4260-96ab-fbff3e2e39e9">
        <source>eprTestMachineOffer2Tasks();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2009	cnwer1	Initial creation

*/

vars
	machine : CM_Machine;
	task  : CM_RTQueueTask;
	mediator :  CM_RTConnectMediator;
	isAllocatedTask : Boolean;
begin
	app.initialize;
	create mediator transient;
	machine:="2296.984".asOid.CM_Machine;
	write machine.id;
	task:="2832.7574".asOid.CM_RTQueueTask;
	isAllocatedTask:=machine.allAllocatedQueueTasks.first &lt;&gt; null;
	//---------------
	//We have the task. Tell it to hookup to the machine
	//---------------
	beginTransaction;
	task.setMachine(machine);
	if isAllocatedTask then	
		//---------------
		//deref the allocated task, we are all linked properly now...
		//---------------
		task.intendedMachine := null;
	endif;
	//-------------
	//Update the history
	//-------------
	
	//machine.setMachineStatus(STATUS_ASSIGNED , "", false);
	if isAllocatedTask then
		//---------------
		//They GET NO CHOICE, its do this, or NOTHING!
		//---------------
		task.setStatus(TASK_ACCEPTED);
	else
		task.setStatus(TASK_OFFERED);
	endif;
	
	task:="2832.7576".asOid.CM_RTQueueTask;
	
	task.setMachine(machine);
	if isAllocatedTask then	
		//---------------
		//deref the allocated task, we are all linked properly now...
		//---------------
		task.intendedMachine := null;
	endif;
	//-------------
	//Update the history
	//-------------
	
	//machine.setMachineStatus(STATUS_ASSIGNED , "", false);
	if isAllocatedTask then
		//---------------
		//They GET NO CHOICE, its do this, or NOTHING!
		//---------------
		task.setStatus(TASK_ACCEPTED);
	else
		task.setStatus(TASK_OFFERED);
	endif;
	commitTransaction;
epilog
	app.finalize;
	delete mediator;
end;</source>
    </JadeMethod>
    <JadeMethod name="eprTestTWMsgs" id="3da1b325-4f8b-4ee0-ba31-119ed2dda94c">
        <source>eprTestTWMsgs();
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	telegram : CM_RTGTelegram;
	telegramString : String;
	tlReader : TwistLockReaderAgent;
	openStr,
	locStr,
	len,
	xpos,
	ypos,
	zpos,
	weight,
	str: String;
	bin : Binary;
	ver,num : Integer;
	machine : CM_Machine;
	terminal : CM_Terminal;
	loc : CM_LocationsController;
	foundHeight : Integer;
begin
	app.initialize;
	
	machine:="2296.272".asOid.CM_Machine;
	terminal:=machine.myTerminal;
	ver:=1;
	len:="20";
	xpos :="23123";
	ypos :="10567";
	zpos := "10567";
	locStr :="A_RTGL80103";
	openStr :="O";
	weight :="12897";
	num :=12;
	
	telegramString:="&lt;MSG&gt;&lt;VER&gt;" &amp; ver.String &amp; "&lt;/VER&gt;&lt;LEN&gt;" &amp; len &amp; "&lt;/LEN&gt;&lt;XPOS&gt;"
					&amp; xpos &amp; "&lt;/XPOS&gt;&lt;YPOS&gt;" 
					&amp; ypos &amp; "&lt;/YPOS&gt;&lt;ZPOS&gt;"
					&amp; zpos &amp; "&lt;/ZPOS&gt;&lt;LOCN&gt;"
					&amp; locStr &amp; "&lt;/LOCN&gt;&lt;TWL&gt;"
					&amp; openStr &amp; "&lt;/TWL&gt;&lt;WGHT&gt;"
					&amp; weight &amp; "&lt;/WGHT&gt;&lt;NUM&gt;"
					&amp; num.String &amp; "&lt;/NUM&gt;&lt;/MSG&gt;";
			
//	create tlReader transient;
	app.myPassport.setMyTerminal(terminal);
	
	terminal.findLocationFromString("RS456 Road", false, loc, foundHeight);
	
	write loc;
	//tlReader.setMyMachine(machine);
	//tlReader.doReadSuccessful(null,telegramString.Binary );
	
	app.finalize;
epilog
	//delete tlReader;
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdMonitorCallback" id="ba70c167-f79b-407c-b152-5ccab88d2fcf">
        <source>kpdMonitorCallback(_monitor : CMIF_Monitor input);

/*

Purpose:			


Return Value:		


Date		Who		Reason
29 February 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars

begin
	app.writeStatement( "Number searched = " &amp; _monitor.numSearched.String &amp; 
		  ", number found = " &amp; _monitor.numFound.String);
	
	if _monitor.numFound &gt; 1000 or _monitor.numSearched &gt; 1000 then
		_monitor.monitorReturnValue := CMIF_Monitor.MonitorReturnValue_Cancel;
	endif;
	

epilog

end;</source>
        <Parameter name="_monitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="kpdSetupTCPIniFile" id="9175bbe3-d996-4863-9ebe-1ad221d938e2">
        <source>kpdSetupTCPIniFile();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

constants
	SectionName			= "JMTTCPListener";
	StatistcsInterval	= "TCPStatisticsLogInterval";
	QueueDepthLimit		= "TCPQueueDepthLimit";
	QueueDepthTimeout	= "TCPQueueDepthLimitTimeout";
	WorkerIdleTimeout	= "TCPWorkerIdleTimeout";
	DumpCMException		= "CreateStackDumpOnCMException";
	DummyValue			= "Dummy";
	
vars
	iniValue,
	iniFileName		: String;
	integerValue	: String;
	
begin
	iniFileName := app.getIniFileNameAppServer;
	
	// Get each of the required values, setting the default for any not found
	
	// Statistics log interval
	app.setProfileStringAppServer(iniFileName, SectionName, StatistcsInterval, "300");
	
	// Queue depth limit
	app.setProfileStringAppServer(iniFileName, SectionName, QueueDepthLimit, "10");
	
	// Queue depth limit timeout
	app.setProfileStringAppServer(iniFileName, SectionName, QueueDepthTimeout, "5");
	
	// Worker idle timeout
	app.setProfileStringAppServer(iniFileName, SectionName, WorkerIdleTimeout, "20");
	
	// Dump CM Exceptions
	app.setProfileStringAppServer(iniFileName, SectionName, DumpCMException, "true");
	
		
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdTestOnsiteFind" id="de084288-447b-40ab-abd7-c2b15a923cb3">
        <source>kpdTestOnsiteFind();

/*

Purpose:			


Return Value:		


Date		Who		Reason
29 February 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
*/

vars
	coll : ObjectSet;
	monitor : CMIF_Monitor;
	
begin
	create coll transient;
	create monitor transient;
	monitor.myParent := self;
	monitor.callBackMethodName := JadeScript::kpdMonitorCallback.name;
	
	CM_Terminal.firstInstance.lookupAllOnsiteTrackedItems(TI_CargoType_Container,
														  "45",
														  coll,
														  false,
														  monitor);
														  
	coll.inspectModal;


epilog
	delete coll;
	delete monitor;
	
end;</source>
    </JadeMethod>
