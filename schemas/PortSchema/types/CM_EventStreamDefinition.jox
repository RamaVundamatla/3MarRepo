    <JadeMethod name="disable" id="0ea8d786-1efb-4b62-abf8-3d0ac72c9b60">
        <updating/>
        <source>disable(_ts : TimeStamp) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI
22 January 2025		jlizm1	MTN 33782 Set disabled ts at first fail not at disabled time

*/

vars

begin
	// This method should be used only to update transient
	self.raiseExceptionIfNotTransient(method);
	
	if self.isActive = true then
		self.isActive := false;
		
		if _ts = null then
			self.disabledTS := app.actualTimeServer;
		else
			self.disabledTS := _ts;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="erase" id="768762a1-b1c1-4b49-9305-59d37126fd27">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars
	eventType : CM_EventStreamEventType;
begin

	//clear out all event stream event types
	foreach eventType in self.allEventStreamEventTypes do
		eventType.erase(_eraseLevel);
	endforeach;
	
	inheritMethod(_eraseLevel);

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLDocIgnoreAttr" id="781ad0ba-32e6-4d41-83c9-f1617d2591ef">
        <source>exportAsXMLDocIgnoreAttr(_property: Property input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
