06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wle : CM_WorkListEntry;
begin
	foreach wle in self.workListEntries discreteLock where wle.myTrackedItem = null do
		return wle;
	endforeach;
	return null;
epilog

end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
