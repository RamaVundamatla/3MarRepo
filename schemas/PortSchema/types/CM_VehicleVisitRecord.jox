Return Value:		

Date		Who		Reason
04 Nov 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	
begin
	if self.getStevedore() &lt;&gt; null then
		return self.getStevedore().code;
	endif;
	
	return null;
epilog

end;</source>
