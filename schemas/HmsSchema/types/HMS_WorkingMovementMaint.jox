        <updating/>
        <source>cmbToBerth_displayEntry(combobox: ComboBox input; _berth : HMS_Berth; lstIndex: Integer):String updating;

begin
	return self.myAssistant.displayEntryHMSBerth(_berth.HMS_Berth);
/*	
	if self.aMySelectedMovement = null then
		return null;
	endif;
	
	if self.aMySelectedMovement.moveType = HMSMovementTypeDeparture then
		// Only list valid departure berths
		if _berth = self.aMyDefaultDepartBerth then
 			return _berth.description;
 		endif;
 	
 	elseif self.aMySelectedMovement.moveType = HMSMovementTypeShift then
		// Only list valid shift berths
		//PAR 10293 ok create shift to any berth
		return _berth.description;
 	
 	elseif self.aMySelectedMovement.moveType = HMSMovementTypeArrival then
		// Only list valid arrival berths
		if _berth = self.aMyDefaultDepartBerth then
			return null;
		else
 			return _berth.description;
 		endif;
 	else
 		return null;
 	endif;
*/
end;</source>
