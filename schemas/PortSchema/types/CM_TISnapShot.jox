    <JadeMethod name="cAndH_category" id="5d6d919a-326c-4717-834c-0e50f747fdb7">
        <methodInvocation>mapping</methodInvocation>
        <source>cAndH_category(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     28 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 07/06/2010	cnwdap1		CCMS 1116 Tranship changes - detect import side of tranship
vars
	transhipImport : Boolean;	// PAR #23645 CCMS 1116

begin
	if set then
		// set code here
		app.raiseSetVirtualError(class.name, method.name);
	else
		// PAR #23645 CCMS 1116
		transhipImport := false;
		if self.imExStatus = TI_IMEX_STATUS_TRANSHIP then
			if CM_ReceiveShip.hasInstance(self.myTransaction) then
				//cnwjo3 par 26361
				if self.myTransaction.CM_ReceiveShip.myJobSheet &lt;&gt; null then
					if self.myTransaction.CM_ReceiveShip.myJobSheet.myVoyage = self.myTrackedItem.myImportVoyage then
						transhipImport := true;
					endif;
				endif;
			endif;
		endif;																							
		
		_value := app.getCandHSummaryCategory(self.transitStatus, self.is40,
						//(self.imExStatus = TI_IMEX_STATUS_IMPORT or self.imExStatus = TI_IMEX_STATUS_STORAGE) 	// isImport					// PAR #23645 CCMS 1116
						(self.imExStatus = TI_IMEX_STATUS_IMPORT or self.imExStatus = TI_IMEX_STATUS_STORAGE or transhipImport), 	// isImport	// PAR #23645 CCMS 1116
						self.isEmpty,
						self.isTransship,
						(self.requiresTemperature and (self.contentsStatus = TI_CONTENTS_STATUS_FCL)),	// isReefer
						(self.contentsStatus = TI_CONTENTS_STATUS_LCL));
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cAndH_isOverridden" id="023b7a17-1b93-46b9-90f1-a143b05d6cc7">
        <methodInvocation>mapping</methodInvocation>
        <source>cAndH_isOverridden(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     28 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if set then
		// set code here
		app.raiseSetVirtualError(class.name, method.name);
	else
		// get code here
		_value := (self.myUserTISnapShot &lt;&gt; null);
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cAndH_shipPortGroupCode" id="6fddb887-8f31-4081-bfc8-23195111e923">
        <methodInvocation>mapping</methodInvocation>
        <source>cAndH_shipPortGroupCode(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     28 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpShipPortGroup	: CM_ShipPortGroup;
	tmpTerm				: CM_Terminal;
begin
	if set then
		// set code here
		app.raiseSetVirtualError(class.name, method.name);
	else
		// get code here
		tmpShipPortGroup := self.getCandHShipPortGroup();
		if tmpShipPortGroup &lt;&gt; null then
			_value := tmpShipPortGroup.code;
		else
			//if app.getMyTerminal &lt;&gt; null then //cnwrs1 CCMS1684 June 2008
			tmpTerm := self.myTerminal;
			if tmpTerm &lt;&gt; null then
				_value := tmpTerm.getConfig(CandHShipPortGrpNullHead).String; // cnwrs1 Feb 2008 par 15848 (ccms1468) CMIF_CandHRpt.ShipPortGroup_Null_Heading;
			else
				_value := CMIF_CandHRpt.ShipPortGroup_Null_Heading;
			endif;
		endif;
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="dischargePort" id="a8cdae2c-bfdb-40fe-92fc-3c7e1decd46e">
        <methodInvocation>mapping</methodInvocation>
        <source>dischargePort(set: Boolean; _value: String io) mapping;
// cnwrs1 June 2006 protected the old 3 digit codes
vars
	port : CM_Port;
begin
	if not set then
		if self.dischargePort.length = 3 then
			port := app.myRoot.allLocodesByShortCode.getAtKeyGeq(self.dischargePort, null);
			if port &lt;&gt; null and port.portCode = self.dischargePort then
				_value := port.code;
			else
				_value := self.dischargePort;
			endif;
		else
			_value := self.dischargePort;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="erase" id="239c81d4-7ac8-4d60-9162-45ea9f87f9c5">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
07/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	invalid 		: Boolean;
	sShotOf			: CM_Object;
begin
	exclusiveLock(self);
	//-----------------------------
	// Remove all links and delete
	//-----------------------------
	sShotOf := self.snapShotOf;
	if sShotOf &lt;&gt; null then		// and global.isValidObject(self.snapShotOf) then
		on Exception do app.handleDeletedObject(exception, sShotOf, invalid);
		sShotOf.CM_TrackedItem.snapShots.remove(self);
		on Exception do null;
	endif;

	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
