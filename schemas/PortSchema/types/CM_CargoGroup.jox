    <JadeMethod name="setCompleteFromTransactions" id="512d57bf-a8c4-4570-9937-461bc7a63354">
        <updating/>
        <source>setCompleteFromTransactions() updating;
/*

Purpose:			Re-derive the current value of the complete flag from the transactions attached to the
					receiver, and set it accordingly

Parameters:			None

Return Value:		None

Date		Who		Reason
27 Jun 2018	jlgkpd1	TFS #39132 - Ship manifest load performance

*/

vars
	trx 			: CM_GroupComplete;

begin
	trx := self.getLastTransOfType(TRANS_TYPE_GRP_COMPLETE).CM_GroupComplete;
	
	self.setComplete(trx &lt;&gt; null);

epilog

end;
</source>
