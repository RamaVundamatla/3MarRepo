    <JadeMethod name="noUserInputReq" id="31c6e7e9-c584-4dda-8d66-0fd4e13539e1">
        <source>noUserInputReq():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2018	jlgndl1	Initial creation	TFS 39248

*/

vars

begin

	if self.isQuantityRequired then
		return false;
	endif;
	
	if self.isActionDateTimeRequired then
		return false;
	endif;
	
	if self.isFromToDateTimeRequired then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="3e249f51-9d13-4ff9-bd87-5b13c0607df3">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 22 July 2003
//
//----------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy 	:	HMS_ResourceType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myRoot := self.myRoot;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
