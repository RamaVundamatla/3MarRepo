    <JadeMethod name="containsOnlyIrregularBlockLCs" id="67141608-2148-44ea-8b19-c45005e06e5c">
        <source>containsOnlyIrregularBlockLCs(objs : ObjectArray) : Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 Feb 2009	cnwjk3	SFW1030
11 Jul 2022	navdap1	TFS 53765 EUP Warehouse Yard Allocation
*/

vars
	obj : Object;
begin
	foreach obj in objs do
		if not obj.isKindOf(CM_IrregularBlockController) then
			if self.getForm.getMyTerminal.getAutoPlanAllowFullGCArea and 	// TFS 53765
			obj.isKindOf(CM_IrregularBlockArea) then						// TFS 53765
				// this is ok												// TFS 53765
			else															// TFS 53765
				return false;
			endif;															// TFS 53765
		endif;
	endforeach;
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="objs" type="ObjectArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyYardAllocation" id="fce2d857-397c-4880-b330-68f9c6023546">
        <updating/>
        <source>copyYardAllocation(_yalloc : CM_YardAllocation; _objs : CMUI_GridObjectByX1Y1X2Y2Dict) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

constants
	WIDTH	= 1;
vars
	tmpPoint : Point;
	x1,x2,y1,y2,idx : Integer;
	yalloc : CM_YardAllocation;
	iterator : Iterator;
	obj : Object;
	yalColour : Integer;
begin
	yalloc := _yalloc;

	iterator := _objs.createIterator();
	
	while iterator.next(obj) do
		yalloc := obj.CM_YardAllocation;
		if _yalloc = null or yalloc = _yalloc then
			_objs.getIteratorKeys(x1, y1, x2, y2, iterator);
			if self.allObjects.getAtKey(x1, y1, x2, y2) = null then
				self.allObjects.putAtKey(x1, y1, x2, y2, yalloc);
			endif;
			continue;
		endif;

	endwhile;		
epilog
	delete iterator; //epr par 18417 3/11/08
end;</source>
        <Parameter name="_yalloc" type="CM_YardAllocation"/>
        <Parameter name="_objs" type="CMUI_GridObjectByX1Y1X2Y2Dict"/>
    </JadeMethod>
