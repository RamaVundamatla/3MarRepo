    <JadeMethod name="getCAMSTimeStampOld" id="f1addf0c-b1d7-4219-b3f7-4f170d173db1">
        <source>getCAMSTimeStampOld() : TimeStamp;
//
//22 Apr 2014	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
//
vars
	any	: Any;
	dt : TimeStamp;
begin
	any := self.getExtraData("CAMSTimeStamp").TimeStamp;
	if any = null then
		return null;
	else
		dt := any.TimeStamp;
		if dt.isValid then
			return dt;
		else
			return null;
		endif;
	endif;
end;
</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
