    <JadeMethod name="setUseProxyOld" id="92dd1932-4fe3-4f2a-96cc-77206ce881a6">
        <source>setUseProxyOld(_value : Boolean);
//
//30 Apr 2014	cnwrs1	Par 34062 add useProxy to FTP Get/Put
//
vars
	ediParty : CM_EDIParty;
begin
	ediParty := self.allEDIParties.first;
	if _value then 
		if ediParty = null then
			create ediParty;
			ediParty.setMyFTPEntity(self);
		endif;
	elseif ediParty &lt;&gt; null then
		ediParty.setMyFTPEntity(null);
		delete ediParty;
	endif;
end;
</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="e60fd591-6389-49eb-95f3-73487e20cc18">
        <source>validateForCreate();
//
// CCMS 1143 cnwrs1 10 Aug 2010
//
vars

	existing : CM_FTPEntity;

begin

	//01 Apr 2016	NDL	TFS 1765
	if self.id &lt;&gt; null then
		existing := app.myRoot.allFTPEntities.getAtKey( self.id );
		if existing &lt;&gt; null then
			app.raiseCMException1(Entity_with_already_exists, self.id, app.getString(Id), null);
		endif;
	endif;
	
	self.validateMe();
end;
</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="2dfb9b5f-0737-4df8-96d4-2eeeb70a4253">
        <source>validateForDelete();
//
// CCMS 1143 cnwrs1 10 Aug 2010
//
vars

begin
	if self.allCamProtocols.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.id, "Cam Protocols", null, null);
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="3c33a3cc-3284-4b93-a9a4-c2f1628df9d1">
        <source>validateForUpdate();
//
// CCMS 1143 cnwrs1 10 Aug 2010
//
vars

	existing : CM_FTPEntity;
	realMe : CM_FTPEntity;

begin

	//01 Apr 2016	NDL	TFS 1765
	if self.id &lt;&gt; null then
		if self.isTransient then
			realMe := self.pxyGetRealObject();
		else
			realMe := self;
		endif;
		existing := app.myRoot.allFTPEntities.getAtKey( self.id );
		if existing &lt;&gt; null and realMe &lt;&gt; null and realMe &lt;&gt; existing then
			app.raiseCMException1(Entity_with_already_exists, self.id, app.getString(Id), null);
		endif;
	endif;
	
	self.validateMe();
end;
</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="fd771bbb-ecff-47bd-8d40-6fcac55c55a3">
        <source>validateMe() protected;
