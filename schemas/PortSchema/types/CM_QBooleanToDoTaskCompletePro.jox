<Class name="CM_QBooleanToDoTaskCompletePro" id="1846d639-2efa-4456-b97f-fc756f3c9e8d">
    <superclass name="CM_QBooleanProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>cnwjo3, par 23349</text>
    <DbClassMap file="query"/>
    <Constant name="PREFIX_NICE_NAME" id="9a65879b-93bd-4f0c-babf-1c002a5b4b19">
        <source>'ToDo Complete-'</source>
        <type name="String"/>
    </Constant>
    <Constant name="PREFIX_PROPERTY_NAME" id="b8d9695e-c538-4fb1-abbf-036bffcdd34f">
        <source>'toDo Complete-'</source>
        <type name="String"/>
    </Constant>
    <PrimAttribute name="toDoTaskCode" id="d7c2abd7-2b4a-43cc-8e37-0f3f8497c3f3">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="getValueForObject" id="291476b3-25ae-47e3-94d4-8a3d5557a418">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
// --------------------------------------------------------------------------------
// Created:		05 May 2010 by cnwjo3
//
// Purpose:		What ToDo tasks have been completed.  par 23349
//
// Parameters:	
//
// Returns:		Nothing
//
vars
	toDoArray			: CM_ToDoTaskArray;
	toDoTask			: CM_ToDoTask;
begin
	toDoArray := _obj.CM_TrackedItem.allToDoTasksCompleted;
	
	foreach toDoTask in toDoArray do
		if toDoTask.toDoTaskDescCode = self.toDoTaskCode then
			return true;
		endif;
	endforeach;

	return false;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="isToDoTaskProperty" id="b37d2e1b-80b2-4cfa-b429-d33f42c3dee7">
