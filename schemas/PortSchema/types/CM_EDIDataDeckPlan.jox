    <JadeMethod name="getEDIDataTypeChildren" id="90f31f88-d302-4919-a926-34bb7ac1d2df">
        <source>getEDIDataTypeChildren(_ediDataType: Integer; _childrenDataTypes: IntegerArray input);
//
// 27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML 
//
// 30 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
vars

begin
	if _ediDataType = EDIDataType_JMTInternal then
		_childrenDataTypes.add(EDIDataType_VoyageHeader);
	elseif _ediDataType = EDIDataType_VoyageHeader then
		_childrenDataTypes.add(EDIDataType_Layout);
		_childrenDataTypes.add(EDIDataType_CargoOnShip);
	elseif _ediDataType = EDIDataType_Layout then
		_childrenDataTypes.add(EDIDataType_LayoutPoint);
	elseif _ediDataType = EDIDataType_CargoOnShip then
		_childrenDataTypes.add(EDIDataType_TISeal);
	endif;
end;
</source>
        <Parameter name="_ediDataType" type="Integer"/>
        <Parameter name="_childrenDataTypes" type="IntegerArray" usage="input"/>
