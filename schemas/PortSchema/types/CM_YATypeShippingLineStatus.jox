<Class name="CM_YATypeShippingLineStatus" id="9f83a814-cace-4130-aa4a-da3f07ddc381">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="1d744382-4dca-4295-bbbf-e036c5415876">
        <source>getAllCriteriaValues(_terminalObj: CM_Terminal; _allCriteriaValues: ObjectSet input; _filter: Integer; _allDependentObjs: CM_ObjectArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/08/2023	navkc1	CR 59594  Task 59584: Jade - CustDocs New YA Criteria
18/08/2023	navkc1	CR 59603 Task 59604: UI - CustDocs More Stop Criteria
*/

vars
	user	: CM_User;
	userTerm: CM_UserTerminal;
	terminal : CM_Terminal;
begin
	terminal := _terminalObj;
	if terminal = null then
		user := app.getMyUser();
		
		foreach userTerm in user.allUserTerminals do
			terminal := userTerm.getMyTerminal();
			
			if terminal = null then
				continue;
			endif;
			
			terminal.allShippingLineStatus.copy(_allCriteriaValues);
		endforeach;
	else
		terminal.allShippingLineStatus.copy(_allCriteriaValues);
	endif;
	
	

epilog

end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaObjectForTi" id="55bd8b5f-e65d-49d5-8d07-939cb3d7026c">
