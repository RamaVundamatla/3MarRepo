    <JadeMethod name="aTrxSample" id="95a0d219-bbf7-4158-9202-a98fe2d393b6">
        <updating/>
        <source>aTrxSample(_pxyObject : CM_TrxTestObject; _realObject : CM_TrxTestObject output; 
		_controller : CM_TrxTestController; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     11 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	app.myUtilityCA.aUtlSample(_pxyObject, _realObject, _controller, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
