<Class name="CM_YATypeVoyagePlanCode" id="5861cfea-81b4-46d0-b4ef-be31f0f3065b">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="59448987-c81c-4666-8e51-f41d99f8e9a8">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues: ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
// --------------------------------------------------------------------------------
vars
	terminalObj	: CM_Terminal;
	
begin
	terminalObj	:=	_terminalObj;
	
	if terminalObj = null and app.isDevelopmentSystem() then
		terminalObj	:=	CM_Terminal.firstInstance();
	endif;
	
	terminalObj.allVoyagePlanningCodes.copy(_allCriteriaValues);
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="17989271-7c9f-4006-988a-98052f57ffd4">
        <source>getDataDisplay(pDataObj : CM_YAData) : String;
//01 August 2008	cnwdw1
begin
	return pDataObj.CM_YADataObjects.getDataDisplay(self);
end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="1b076bde-29a7-47b3-9a55-5844fc7f9697">
        <source>getDisplay(dataObj : Object) : String;
//01 August 2008	cnwdw1
begin
	return dataObj.CM_VoyagePlanningCode.code;
end;</source>
        <Parameter name="dataObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjects" id="8fd57d52-fc76-4b24-95ce-7471dd591ff0">
        <source>getObjects(objects: ObjectLongNameDict input);
//03 August 2008	cnwdw1	
// Return a dict of objects for this criteria type
vars
	plan: CM_VoyagePlanningCode;
begin
	foreach plan in app.getMyTerminalDO_NOT_USE().allVoyagePlanningCodes do
		objects[plan.getYAIdentifier] := plan;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTypeName" id="6ee02340-319d-4208-810b-00f9b6417012">
        <source>getTypeName(): String;
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "Voyage Planning Code";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCMIFDataMatch" id="2ba9120a-c989-4bb5-9dee-f3b7b71414fb">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
// ---------------------------------------------------------------------------
// Created:		15 July 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return _cmifAutoPlan.isVoyagePlanCode_Match(_yaData);

end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
