    <JadeMethod name="generateUtlCreate" id="8e88226a-c0d8-43be-a3f5-bcfb208dc79d">
        <updating/>
        <source>generateUtlCreate() updating, protected;

vars
	className	: String;
	paramName1	: String;
	paramName2	: String;
begin
	className := self.genClass.name;
	paramName1 := '_proxy' &amp; self.genClassName;
	paramName2 := '_new' &amp; self.genClassName;

	self.genFile.writeLine("CM_UtilityCreateAgent");
	self.genFile.writeLine('utlCreate' &amp; self.genClassName &amp; '(' &amp; paramName1 &amp; ' : ' &amp; className &amp; ' input; ' &amp; paramName2 &amp;
							' : ' &amp; className &amp; ' output; _passport : CM_Passport input);');
	self.genFile.writeLine(self.genComment);
	self.genFile.writeLine('begin');
	self.genFile.writeLine(Tab &amp; 'self.initialiseActivity();' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'app.setContinueCMExceptions(true);' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'app.myValCA.val' &amp; self.genClassName &amp; '(' &amp; paramName1 &amp; ');' &amp; CrLf);
	
	self.genFile.writeLine(Tab &amp; 'if not self.checkValidationWithPassport(_passport) then');
	self.genFile.writeLine(Tab &amp; '	return;');
	self.genFile.writeLine(Tab &amp; 'endif;' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'app.setContinueCMExceptions(false);' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'create ' &amp; paramName2 &amp; ' as ' &amp; paramName1 &amp; '.class persistent;');
	self.genFile.writeLine(Tab &amp; paramName2 &amp; '.setForCreate(' &amp; paramName1 &amp; ', app.myPassport);' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'if _passport.noErrors then');
	self.genFile.writeLine(Tab &amp; Tab &amp; 'self.myCreateAuditAgent.audCreateGeneric(' &amp; paramName2 &amp; ');');
	self.genFile.writeLine(Tab &amp; 'endif;');
	self.genFile.writeLine('end;' &amp; CrLf);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="generateUtlDelete" id="3765ce7d-1b80-47e4-8399-5f12b3a050fe">
        <updating/>
        <source>generateUtlDelete() updating, protected;

vars
	className	: String;
	paramName	: String;
begin
	className := self.genClass.name;
	paramName := self.genClassName;
	paramName.firstCharToLower;

	self.genFile.writeLine("CM_UtilityDeleteAgent");
	self.genFile.writeLine('utlDelete' &amp; self.genClassName &amp; '(_' &amp; paramName &amp; ' : ' &amp; className &amp; ' input; _passport : CM_Passport input) updating;');
	self.genFile.writeLine(self.genComment);
	self.genFile.writeLine('begin');
	self.genFile.writeLine(Tab &amp; 'self.initialiseActivity();' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'app.setContinueCMExceptions(true);' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'app.myValDA.val' &amp; self.genClassName &amp; '(_' &amp; paramName &amp; ');' &amp; CrLf);
	
	self.genFile.writeLine(Tab &amp; 'if not self.checkValidationWithPassport(_passport) then');
	self.genFile.writeLine(Tab &amp; '	return;');
	self.genFile.writeLine(Tab &amp; 'endif;' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'app.setContinueCMExceptions(false);' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'if _passport.noErrors then');
	self.genFile.writeLine(Tab &amp; Tab &amp; 'self.myDeleteAuditAgent.audDeleteGeneric(_' &amp; paramName &amp; ');');
	self.genFile.writeLine(Tab &amp; 'endif;' &amp;  CrLf);
	self.genFile.writeLine(Tab &amp; 'if _passport.noErrors then');
	self.genFile.writeLine(Tab &amp; Tab &amp; '_' &amp; paramName &amp; '.erase(NORMAL_ERASE);');
	self.genFile.writeLine(Tab &amp; 'endif;' &amp;  CrLf);
	self.genFile.writeLine('end;' &amp; CrLf);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="generateUtlUpdate" id="1df0c4a3-364d-49b9-9384-bf7f0bdcb748">
        <updating/>
        <source>generateUtlUpdate() updating, protected;

vars
	className	: String;
	paramName	: String;
	varName		: String;
	errorName	: String;
begin
	className := self.genClass.name;
	paramName := '_proxy' &amp; self.genClassName;
	varName	:= 'real' &amp; self.genClassName;
	errorName := self.genClassName;
	errorName.firstCharToLower;

	self.genFile.writeLine("CM_UtilityUpdateAgent");
	self.genFile.writeLine('utlUpdate' &amp; self.genClassName &amp; '(' &amp; paramName &amp; ' : ' &amp; className &amp; '; _passport : CM_Passport input);');
	self.genFile.writeLine(self.genComment);
	self.genFile.writeLine('vars');
	self.genFile.writeLine(Tab &amp; varName &amp; Tab &amp; ': ' &amp; className &amp; ';');
	self.genFile.writeLine(Tab &amp; 'expectedEdition' &amp; Tab &amp; ': Integer;' &amp; CrLf);
	self.genFile.writeLine('begin');
	self.genFile.writeLine(Tab &amp; 'self.initialiseActivity();' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; paramName &amp; '.raiseExceptionIfNotProxy(method);' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'app.setContinueCMExceptions(true);' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; paramName &amp; '.pxyGetRealObjectAndEdition(' &amp; varName &amp; ', expectedEdition);' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'if ' &amp; varName &amp; '= null then');
	self.genFile.writeLine(Tab &amp; Tab &amp; 'app.raiseCMException1(ProxyMgrCannotLocateReal, ' &amp; className &amp; '.name, null, null);');
	self.genFile.writeLine(Tab &amp; Tab &amp; 'return;');
	self.genFile.writeLine(Tab &amp; 'endif;' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'app.myValUA.val' &amp; self.genClassName &amp; '(' &amp; paramName &amp; ');' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'if not self.checkValidationWithPassport(_passport) then');
	self.genFile.writeLine(Tab &amp; '	return;');
	self.genFile.writeLine(Tab &amp; 'endif;' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'app.setContinueCMExceptions(false);' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'exclusiveLock(' &amp; varName &amp; ');' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'if _passport.noErrors and ' &amp; varName &amp; '.edition &lt;&gt; expectedEdition then');
	self.genFile.writeLine(Tab &amp; Tab &amp; 'app.raiseCMException1(ObjectUpdatedByAnotherUserSave, "' &amp; errorName &amp; '", null, null);');
	self.genFile.writeLine(Tab &amp; Tab &amp; 'return;');
	self.genFile.writeLine(Tab &amp; 'endif;' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'if _passport.noErrors then');
	self.genFile.writeLine(Tab &amp; Tab &amp; 'self.myUpdateAuditAgent.audUpdateGeneric(' &amp; varName &amp; ', true);');
	self.genFile.writeLine(Tab &amp; 'endif;' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'if _passport.noErrors then');
	self.genFile.writeLine(Tab &amp; Tab &amp; varName &amp; '.setForUpdate(' &amp; paramName &amp; ');');
	self.genFile.writeLine(Tab &amp; 'endif;' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'if _passport.noErrors then');
	self.genFile.writeLine(Tab &amp; Tab &amp; 'self.myUpdateAuditAgent.audUpdateGeneric(' &amp; varName &amp; ', false);');
	self.genFile.writeLine(Tab &amp; 'endif;' &amp; CrLf);
	self.genFile.writeLine('end;' &amp; CrLf);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="generateValCreate" id="668e117c-1a5b-49c8-a3eb-1c029cbb98fc">
        <updating/>
        <source>generateValCreate() updating, protected;

vars
	className	: String;
	paramName	: String;
begin
	className := self.genClass.name;
	paramName := '_proxy' &amp; self.genClassName;

	self.genFile.writeLine("CM_ValidationCreateAgent");
	self.genFile.writeLine('val' &amp; self.genClassName &amp; '(' &amp; paramName &amp; ' : ' &amp; className &amp; ');');
	self.genFile.writeLine(self.genComment);
	self.genFile.writeLine('begin');
	self.genFile.writeLine(Tab &amp; 'self.raiseExceptionIfNull(' &amp; paramName &amp; ', "' &amp; self.genClassName &amp; ' Proxy");' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; paramName &amp; '.raiseExceptionIfNotTransient(method);' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; paramName &amp; '.validateForCreate();' &amp; CrLf);
	self.genFile.writeLine('end;' &amp; CrLf);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="generateValDelete" id="e5eca911-afa4-453f-9a43-9c3f2f1197f7">
        <updating/>
        <source>generateValDelete() updating, protected;

vars
	className	: String;
	paramName	: String;
begin
	className := self.genClass.name;
	paramName := self.genClassName;
	paramName.firstCharToLower;
	paramName := '_' &amp; paramName;

	self.genFile.writeLine("CM_ValidationDeleteAgent");
	self.genFile.writeLine('val' &amp; self.genClassName &amp; '(' &amp; paramName &amp; ' : ' &amp; className &amp; ');');
	self.genFile.writeLine(self.genComment);
	self.genFile.writeLine('begin');
	self.genFile.writeLine(Tab &amp; 'self.raiseExceptionIfNull(' &amp; paramName &amp; ', "' &amp; self.genClassName &amp; '");' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; 'self.exclusiveLockObjectToDelete(' &amp; paramName &amp; ') ;' &amp; CrLf);
	self.genFile.writeLine(Tab &amp; paramName &amp; '.validateForDelete();' &amp; CrLf);
	self.genFile.writeLine('end;' &amp; CrLf);
end;
</source>
