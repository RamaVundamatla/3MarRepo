    <JadeMethod name="buildCmbHold" id="f4058593-8d2b-405f-941c-9f3635637ee7">
        <source>buildCmbHold();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Oct 2023 navhl20 ChangeRequest 60037: EUP | Ship Operations in DD - [54176.030] - [Receive] Additional Job Details
04 Jan 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
*/

vars
	lc 			: CM_LocationsController;
	lcSet 		: CM_LCSet;
begin
	self.cmbHold.clear();
	
	if self.myVoyage = null then
		return;
	endif;
	
	create lcSet transient;													//04.01.2023 navhl20 #61092[61621]
	self.myVoyage.getHolds(lcSet);											//04.01.2023 navhl20 #61092[61621]
	
	foreach lc in lcSet do													//04.01.2023 navhl20 #61092[61621]
		self.cmbHold.addItemObject(lc.getFullId(), lc);
	endforeach;
epilog
	delete lcSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbJobSheet" id="bb190a80-a107-4230-aac2-4432db48b0fa">
        <source>buildCmbJobSheet();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Nov 2023 navhl20 ChangeRequest 60037: EUP | Ship Operations in DD - [54176.030] - [Receive] Additional Job Details
25 Feb 2025 navma1  MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
*/

vars
	jobSheet 	 : CM_WorkPointJobSheet;
	jobSheetDict : CM_WPJobSheetByDate;
begin
	self.cmbJobSheet.clear();
	
	create jobSheetDict transient;
	self.myTerminal.allJobSheetsForWorkPoints.copy(jobSheetDict);
	
	foreach jobSheet in jobSheetDict discreteLock where jobSheet.myWorkPoint.myWorkPointType.type = WORK_POINT_TYPE_SHIP do
		self.cmbJobSheet.addItemObject(jobSheet.externalName,jobSheet);
	endforeach;
epilog
	delete jobSheetDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbTransType" id="0ae14bef-2248-4aed-aca1-0f623e8adb4d">
        <source>buildCmbTransType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Oct 2023 navhl20 ChangeRequest 60037: EUP | Ship Operations in DD - [54176.030] - [Receive] Additional Job Details

*/

vars
	jobTransType : CM_VoyageJobTransferType;
begin
	self.cmbTransType.clear();
	
	foreach jobTransType in app.myRoot.allVoyageJobTransferTypes do
		self.cmbTransType.addItemObject(jobTransType.description,jobTransType);
	endforeach;
	
	if self.cmbTransType.listCount &gt; 0 then
		self.cmbTransType.listIndex := 1;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="7947c868-f918-41f0-b704-fe4f909d46ee">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Oct 2023 navhl20 ChangeRequest 60037: EUP | Ship Operations in DD - [54176.030] - [Receive] Additional Job Details

*/

vars

begin
	self.permissionView		:= PmAdmVoyageJobUpdateView;
	self.permissionMaint	:= PmAdmVoyageJobUpdateMaint;
	self.helpFileName 		:= HelpFile_Yard;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="413eb6c1-51a8-41af-9d5c-cca6a6527c62">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Oct 2023 navhl20 ChangeRequest 60037: EUP | Ship Operations in DD - [54176.030] - [Receive] Additional Job Details

*/

vars
	startDT,
	endDT			: TimeStamp;
	extRef1,
	extRef2,
	remarks			: String;
	transTypeObj	: CM_VoyageJobTransferType;
	transType,
	result			: Integer;
	pxyVoyJob		: CM_VoyageWorkPointJob;
	jobSheet		: CM_WorkPointJobSheet;
	complete		: Boolean;
	hold			: CM_GeneralCargoController;
	voyJob			: CM_VoyageJob;
begin
	startDT.setDate(self.dtStart.getDate());
	startDT.setTime(self.tmStart.getTime());
	endDT.setDate(self.dtEnd.getDate());
	endDT.setTime(self.tmEnd.getTime());
	extRef1 		:= self.txtExtRef1.text;
	extRef2 		:= self.txtExtRef2.text;
	remarks 		:= self.txtRemarks.text;
	transTypeObj	:= self.cmbTransType.listObject.CM_VoyageJobTransferType;
	jobSheet		:= self.cmbJobSheet.listObject.CM_WorkPointJobSheet;
	complete		:= self.chkComplete.value;
	if self.cmbHold.listObject.isKindOf(CM_GeneralCargoController) then
		hold		:= self.cmbHold.listObject.CM_GeneralCargoController;
	endif;
	
	if transTypeObj &lt;&gt; null then
		transType 	:= transTypeObj.id;
	endif;
	
	if self.context = self.TO_GANG_UPDATE then
		pxyVoyJob := app.createUpdateProxy(self.myJob).CM_VoyageWorkPointJob;
	else
		create pxyVoyJob transient;
	endif;
	pxyVoyJob.setProxyForUpdate(startDT,endDT,remarks,transType,jobSheet,extRef1,extRef2);
	
	while true do
		if self.context = self.TO_GANG_UPDATE then
			app.myTrxUA.trxUpdateVoyageWPJob(pxyVoyJob,complete,hold,app.myPassport);
		else
			app.myTrxCA.trxCreateVoyageWPJob(pxyVoyJob,voyJob,jobSheet,self.myJob,hold,app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.unloadForm();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return;
	endwhile;
epilog
	delete pxyVoyJob;
end;</source>
    </JadeMethod>
    <JadeMethod name="getPlannedLocation" id="08b41cb7-e471-43d7-ab29-162bc440bb60">
        <source>getPlannedLocation(_fromTi : Boolean):CM_LocationsController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
11 Jun 2024 navhl20 Bug 64580: EUP - Planned Location is not taken into consideration when allocating the ship job to gang
*/

vars
	tiArr 		: CM_TIArray;
	cmifMobile	: CMIF_MobileGenericAgent;
	relReq		: CM_BulkRelease;
	relsel		: CM_ReserveDetail;
	stwRule 	: Integer;
	sourceLC, 
	lc		 	: CM_LocationsController;
	ti			: CM_TrackedItem;
begin
	if _fromTi then																									//11.06.2024 navhl20 #64580
		foreach ti in self.myJob.CM_WorkOrderJob.allTrackedItems do
			lc := ti.myPrimaryPlannedLocation;
			if lc &lt;&gt; null and lc.isKindOf(CM_ShipBlockController) or lc.isKindOf(CM_GeneralCargoController) then
				return lc;
			endif;
		endforeach;
	else
		relsel := self.myJob.allRequests.first.myReserveDetail;
		
		if relsel = null and not relsel.isKindOf(CM_ReserveSelection) then
			return null;
		endif;
		
		create cmifMobile transient;
		create tiArr transient;
		cmifMobile.setMyTerminal( app.myPassport.myTerminal);
		relReq := relsel.myReserveHeader;
		cmifMobile.getCargoBasedOnSTW12Rules(relReq,relsel, sourceLC, null,stwRule,tiArr);
		
		foreach ti in tiArr do
			lc := ti.myPrimaryPlannedLocation;
			if lc &lt;&gt; null and lc.isKindOf(CM_ShipBlockController) or lc.isKindOf(CM_GeneralCargoController) then	//11.06.2024 navhl20 #64580
				return lc;
			endif;
		endforeach;
	endif;
	
	return null;
epilog
	if not _fromTi then																								//11.06.2024 navhl20 #64580
		delete tiArr;
		delete cmifMobile;
	endif;
end;</source>
        <Parameter name="_fromTi" type="Boolean"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="hideControls" id="6136c1b0-b42c-4f05-b467-b095fefbbe92">
        <source>hideControls();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Nov 2023 navhl20 ChangeRequest 60037: EUP | Ship Operations in DD - [54176.030] - [Receive] Additional Job Details
16 Jan 2023 navhl20 ChangeRequest 62066: EUP | Ship Operations in DD - FR - 01
*/

vars

begin
	if self.context = self.TO_GANG_UPDATE then
		self.cmbJobSheet.enabled 	:= false;
		self.cmbTransType.enabled 	:= false;
		self.lblComplete.visible 	:= true;
		self.chkComplete.visible	:= true;
		if self.myJob.status = JOB_COMPLETE then
			self.lblComplete.enabled 	:= false;
			self.chkComplete.enabled	:= false;
			//self.btnOk.enabled		:= false;		//16.01.2023 navhl20 #62066
			self.txtExtRef1.enabled		:= false;		//16.01.2023 navhl20 #62066
			self.txtExtRef2.enabled		:= false;		//16.01.2023 navhl20 #62066
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateDetails" id="5c14f762-75db-4390-be52-e8bd21de8808">
        <source>populateDetails();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Oct 2023 navhl20 ChangeRequest 60037: EUP | Ship Operations in DD - [54176.030] - [Receive] Additional Job Details
29 Nov 2023 navhl20 ChangeRequest 61510: EUP | Ship Operations in DD - [54176.020] - [Release] Allocate Jobs to Gangs and Gangs to Holds
18 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
10 Jan 2024 navhl20 ChangeRequest 62066: EUP | Ship Operations in DD - FR - 01
06 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
11 Jun 2024 navhl20 Bug 64580: EUP - Planned Location is not taken into consideration when allocating the ship job to gang
*/

vars
	job	: CM_VoyageJob;
	ti	: CM_TrackedItem;
	req	: CM_HoldRequest;
	lc	: CM_LocationsController;
begin
	self.cmbJobSheet.setIndexFromObject(self.myJobSheet);
	self.dtStart.setDate(self.myJobSheet.myShift.startDateTime.Date);
	self.dtEnd.setDate(self.myJobSheet.myShift.endDateTime.Date);
	self.tmStart.setTime(self.myJobSheet.myShift.startDateTime.Time);
	self.tmEnd.setTime(self.myJobSheet.myShift.endDateTime.Time);				//18.12.2023 navhl20 #58400[61617]
	self.txtExtRef1.text := self.myJobSheet.externalReference1;
	self.txtExtRef2.text := self.myJobSheet.externalReference2;
	if self.myJob &lt;&gt; null then
		if self.myJob.isKindOf(CM_WorkOrderJob) then
			//ti := self.myJob.getFirstTi();										//18.01.2024 navhl20 #62066
			ti := self.myJob.getFirstTi(true);										//27/05/2024	navkc1 Bug 64295
			if ti &lt;&gt; null then
				self.cmbHold.listIndex := self.cmbHold.findString(1,ti.locationId);
			endif;
			//Start 11.06.2024 navhl20 #64580
			lc := self.getPlannedLocation(ti &lt;&gt; null);
			if lc &lt;&gt; null then
				self.cmbHold.setIndexFromObject(lc);
			endif;
			//End 11.06.2024 navhl20 #64580
		endif;
		if self.myJob.isKindOf(CM_VoyageJob) then
			job := self.myJob.CM_VoyageJob;
			self.cmbTransType.setIndexFromObject(app.myRoot.allVoyageJobTransferTypes[job.transferType]);
			self.txtRemarks.text := job.remarks;
			self.dtStart.setDate(job.actualStartTs.Date);
			self.dtEnd.setDate(job.actualEndTs.Date);
			self.tmStart.setTime(job.actualStartTs.Time);
			self.tmEnd.setTime(job.actualEndTs.Time);
			self.txtExtRef1.text := job.externalReference1;
			self.txtExtRef2.text := job.externalReference2;
			if job.myJobSheetForWorkPoint &lt;&gt; null then
				self.cmbJobSheet.setIndexFromObject(job.myJobSheetForWorkPoint);
			endif;
			if job.CM_VoyageWorkPointJob.myWorkOrderReceiveJob &lt;&gt; null then						//29.11.2023 navhl20 #61510
				//ti := job.CM_VoyageWorkPointJob.myWorkOrderReceiveJob.getFirstTi();				//18.01.2024 navhl20 #62066
				ti := job.CM_VoyageWorkPointJob.myWorkOrderReceiveJob.getFirstTi(true);			//27/05/2024	navkc1 Bug 64295
			else
				//ti := job.CM_VoyageWorkPointJob.myWorkOrderReleaseJob.getFirstTi();				//18.01.2024 navhl20 #62066
				ti := job.CM_VoyageWorkPointJob.myWorkOrderReleaseJob.getFirstTi(true);				//27/05/2024	navkc1 Bug 64295
			endif;
			if ti &lt;&gt; null then
				self.cmbHold.listIndex := self.cmbHold.findString(1,ti.locationId);
			endif;
			req := job.allRequests.first.CM_HoldRequest;
			if req &lt;&gt; null then
				if req.myHoldControllerDischarge &lt;&gt; null then									//21.12.2023 navhl20 #58400[61617]
					self.cmbHold.setIndexFromObject(req.myHoldControllerDischarge);
				elseif req.myHoldControllerLoad &lt;&gt; null then
					self.cmbHold.setIndexFromObject(req.myHoldControllerLoad);
				endif;
			endif;
			if job.status = JOB_COMPLETE then
				self.chkComplete.value := true;
			endif;
		endif;
	endif;
	if (self.cmbHold.listIndex &gt; -1 and 
	self.cmbHold.listObject.isKindOf(CM_GeneralCargoController)) or self.myJob.status = JOB_COMPLETE then	//06.05.2024 navhl20 #63971
		self.cmbHold.enabled := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setDetails" id="a29c9ab1-e0d0-4ca2-a170-26cafb4706bb">
        <updating/>
        <source>setDetails(_jobsheet : CM_WorkPointJobSheet; _job : CM_Job; _voyage : CM_Voyage; _context : Integer)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Oct 2023 navhl20 ChangeRequest 60037: EUP | Ship Operations in DD - [54176.030] - [Receive] Additional Job Details

*/

vars

begin
	self.myJobSheet := _jobsheet;
	self.myJob		:= _job;
	self.myVoyage	:= _voyage;
	self.context	:= _context;
epilog

end;</source>
        <Parameter name="_jobsheet" type="CM_WorkPointJobSheet"/>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_context" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="50b5302b-92f6-44fe-ac11-1a306feb6d5f">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Oct 2023 navhl20 ChangeRequest 60037: EUP | Ship Operations in DD - [54176.030] - [Receive] Additional Job Details

*/

vars

begin
	inheritMethod();
	if self.context = self.TO_GANG_CREATE then
		self.caption := "Add Job Details";
	endif;
	self.btnOk.caption := app.getErrorString(Save);
	self.btnCancel.caption := app.getErrorString(Close);
	self.buildCmbTransType();
	self.buildCmbHold();
	self.buildCmbJobSheet();
	self.populateDetails();
	self.hideControls();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d4b3e8b6-cda8-45b2-9fb9-1d61b27f3594">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 16 November 2023 09:12:24.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026560, locale);
	lblComplete.translateCaption(Xlat_0026561, locale);
	lblEnd.translateCaption(Xlat_0026562, locale);
	lblExtRef1.translateCaption(Xlat_0026563, locale);
	lblExtRef2.translateCaption(Xlat_0026564, locale);
	lblHold.translateCaption(Xlat_0026565, locale);
	lblJobSheet.translateCaption(Xlat_0026566, locale);
	lblRemarks.translateCaption(Xlat_0026567, locale);
	lblStart.translateCaption(Xlat_0026568, locale);
	lblTransType.translateCaption(Xlat_0026569, locale);
end;</source>
    </JadeMethod>
</GUIClass>
