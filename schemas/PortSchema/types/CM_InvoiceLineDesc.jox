    <JadeMethod name="createInvoiceLineEvent" id="ac875d5c-ff43-4117-ac90-2f2c330b7c9a">
        <updating/>
        <source>createInvoiceLineEvent(_debtor : CM_Debtor; _tran : CM_EventTransaction) : CM_InvoiceLine updating;
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 19/07/2017	cnwdap1		TFS 5286 SSL Minimum Charge being applied when it wasn't required
// 23 Oct 2024	navlw1		JIRA-33107: Invoice Logging Use Levels
vars
	invLine:   CM_InvoiceLine;
	invoice:   CM_Invoice;
	now:       TimeStamp;
	seqNum : Integer;
	invType : CM_InvoiceDesc;
//	tmpTotal : Real;
begin

	invType := self.getInvoiceType(_debtor);

	invoice := bank.getAutoInvoiceEvent(invType, self, _tran, _debtor ); 

	create invLine persistent;
	// PAR 30751seqNum := self.bank.getSeqNumInvoiceLine(); // PAR 18104
	seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE); // PAR 30751
	
	if _tran.dateTime.isValid then
		now := _tran.dateTime;	//else use timestamp set in now.
	else
		now := app.serverTimestampAtTrxStart;	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
	invLine.setForCreate(seqNum, false, null, self, invoice, _debtor, bank, 0, now);
	invLine.setMyTransactionEvent(_tran);
	invLine.createCharges(); 
	
	invLine.doHookCodeForRemarks();	//27 Dec 2018	NDL	TFS 42119
	
	app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(invLine);		// 9/5/18 MAP TFS37718

	//self.checkForMinimumCharge( _debtor, invLine, _tran );	//14 Jun 2017	NDL	TFS 4816		// TFS 5286
	
	app.invLog("New invoice line " &amp; invLine.sequenceNum.String &amp; ", invoice " &amp; invLine.invoice.sequenceNum.String &amp; ", debtor " &amp; _debtor.name, LogTRACE.String);
	
	// PAR 24423 - now done in createCharges
	// tmpTotal := invLine.lineTotal; // ### VERY IMPORTANT TO LEAVE THIS HERE, as it is virtual. This call sets rate and quantity correctly
	
	return invLine;
end;</source>
