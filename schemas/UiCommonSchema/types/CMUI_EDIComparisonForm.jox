    <JadeMethod name="addToolbarControls" id="06e2d441-c761-484c-a847-7ff1bfc0da89">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*
Date		Who		Reason
31 July 2013	cnwcs5	CCMS POL 2221 / par 32094
*/
vars
	toolbar		:CMUI_Toolbar;
begin	
	toolbar := self.frmToolbar;

	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExport, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSaveVerify, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	inheritMethod();
	
	self.addToolbarControlsQuery;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="062d6307-c2b4-4bcd-9607-06a1dc9a299b">
        <source>addToolbarControlsQuery() protected;
/*
Date		Who		Reason
31 Jul 2013	cnwcs5	CCMS POL 2221 / par 32094
*/
vars
	toolbar			: CMUI_Toolbar;
begin
	toolbar := self.frmQueryToolbar;
	
	toolbar.showCaptions := false;
		
	toolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	
	toolbar.visible := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
