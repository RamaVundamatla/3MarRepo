    <JadeMethod name="saveDocketLogDef" id="42dde813-db69-4d3a-8aa8-c4409ac57822">
        <updating/>
        <source>saveDocketLogDef(_docketLogDef : CMIF_DocketLogDef): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	logRegrade	: CMIF_LogRegrade;
	rtnValue	: Boolean;
	location	: CM_LogController;
	newLocation	: CM_LogController;
	isMove		: Boolean;
	cmif		: CMIF_Remote;
	manager		: CM_RemoteDataManagerInternal;
	tmpTI		: CM_TrackedItem;
	result		: Integer;
	passport	: CM_Passport;
	
begin

	if _docketLogDef.allTi.isEmpty then
		return false;
	endif;

	passport := app.myPassport;
	
	tmpTI := _docketLogDef.allTi.first;
	location := tmpTI.getPrimaryLocation(REAL_MODE).CM_LogController;
	newLocation := self.cmbTOLocation.listObject.CM_LogController;
	if newLocation &lt;&gt; null and newLocation &lt;&gt; location then
		isMove := true;
		location := newLocation;
	endif;
	
	self.allTrackedItems.clear;
	_docketLogDef.allTi.copy(self.allTrackedItems);

	create logRegrade transient;
	self.setProxy(logRegrade);

	// There are some errors in GUI phase, not in trx level. It is because we need to manage 
	// some required fields before trx starts eihter in GUI or BGP mode.
	// In this case, errors are populated in self.allErrorsWarnings and the ErrorsWarning dialog to be displayed later in the method above.
	self.validateForSave(logRegrade, passport);		//PAR 21688 Dec 2009

	if passport.hasErrors() then
		self.addAllErrorWarnings(passport);	// copies errors to this form to be displayed in a ErrorsWarnings screen in the method above.
		return false;
	endif;

	
	// ccms 1107 / PAR22727 - need to procede blue warnings
	while true do
	
		if self.btnBackground.value then
			create manager transient;
			create cmif transient;
			cmif.transactionType	:= manager.REGRADERQ;
			cmif.terminalAreaTo		:= location.myTerminalArea.id;
			cmif.terminal			:= self.myTerminal.code;
			cmif.location			:= location.id;
			cmif.myRegradeDetail	:= logRegrade;
			cmif.isMove				:= isMove;
			rtnValue := manager.processInternal(cmif, passport);
		else
			app.myTrxUA.trxRegradeLog(logRegrade, app.getMyUserCode, location, isMove, passport);
		endif;
	
		if passport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			rtnValue := true;	//PAR 22039. Dec 2009
			break;

		else
			result := app.showErrorWarningDialog('Regrade', passport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if passport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				passport.warningsAcknowledged	:= true;
				continue;
			endif;
			//self.setAllErrorWarnings(passport);	// copies errors to this form and shows in err/warnings window
			return false;
			
		endif;
		break;
		
	endwhile;
	
epilog
	delete manager;
	delete cmif;
	delete logRegrade;
	return rtnValue;
	
end;</source>
        <access>protected</access>
        <Parameter name="_docketLogDef" type="CMIF_DocketLogDef"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveTrackedItems" id="b5dbdc60-a02a-42ed-8081-65048b3d19bc">
        <updating/>
        <source>saveTrackedItems(): Boolean updating, protected;

vars
	logRegrade	: CMIF_LogRegrade;
	rtnValue	: Boolean;
	location	: CM_LogController;
	newLocation	: CM_LogController;
	isMove		: Boolean;
	cmif		: CMIF_Remote;
	manager		: CM_RemoteDataManagerInternal;
	ti			: CM_TrackedItem;
	result		: Integer;
	passport	: CM_Passport;
	
begin

	passport := app.myPassport;

	ti := self.allTrackedItems.first;
	location := ti.getPrimaryLocation(REAL_MODE).CM_LogController;
	newLocation := self.cmbTOLocation.listObject.CM_LogController;
	if newLocation &lt;&gt; null and newLocation &lt;&gt; location then
		isMove := true;
		location := newLocation;
	else
		location := self.allTrackedItems.first.getPrimaryLocation(REAL_MODE).CM_LogController;
	endif;
	
	create logRegrade transient;
	self.setProxy(logRegrade);

	self.validateForSave(logRegrade, passport);		//PAR 21688 Dec 2009
	
	if passport.hasErrors() then
		app.showErrorWarningDialog('Regrade', passport, ErrWarnMode_Update);
		self.setAllErrorWarnings(passport);	// copies errors to this form and shows in err/warnings window
		return false;
	endif;
	
	if self.btnBackground.value then
		create manager transient;
		create cmif transient;
		cmif.transactionType	:= manager.REGRADERQ;
		cmif.terminalAreaTo		:= location.myTerminalArea.id;
		cmif.terminal			:= self.myTerminal.code;
		cmif.location			:= location.id;
		cmif.myRegradeDetail	:= logRegrade;
		cmif.isMove				:= isMove;
		
	else
		passport.setMyCMIFMonitor(self.myCMIFMonitor);
		self.myCMIFMonitor.myParent := self;
		self.myCMIFMonitor.message := app.getErrorString(Initialising);
		self.modalDialogShow(null, null, null, null, self.getActionDescription, self.myCMIFMonitor.message);
		
		self.myCMIFMonitor.partsInJob := logRegrade.allTrackedItems.size;
		self.myCMIFMonitor.partsDone := 0;
		self.pbProgressBar.visible := true;   	
		self.updateProgress(self.myCMIFMonitor);
		
	endif;
	
	// ccms 1107 / PAR20999 - need to organize warnings to a user
	while true do
	
		if self.btnBackground.value then
			rtnValue := manager.processInternal(cmif, passport);
		else
			app.myTrxUA.trxRegradeLog(logRegrade, app.getMyUserCode, location, isMove, passport);
		endif;
	
		if passport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			rtnValue := true;	//PAR 22039. Dec 2009
			break;

		else
			result := app.showErrorWarningDialog('Regrade', passport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if passport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				passport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;	
		endif;
		break;
		
	endwhile;
	
epilog
	delete manager;
	delete cmif;
	delete logRegrade;
	return rtnValue;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="b7e54cdc-36f9-476b-aa62-15f48b8b0494">
        <source>setProxy(_logRegrade : CMIF_LogRegrade input) protected;

vars

	operator		: CM_Operator;
	species,
	grade	, treatment,
	type	, length: String;
	sedMIN, sedMAX	: Decimal[12,2];		
	isLogId			: Boolean;
	regradeCode		: CM_LogRegradeCode;
	
begin

	operator 	:= self.cmbNewSupplier.myObject.CM_Operator;
	species		:= self.tblActionData.getValueByName(ETRow_Species).String;
	grade		:= self.tblActionData.getValueByName(ETRow_Grade).String;	
	treatment	:= self.tblActionData.getValueByName(ETRow_Treatment).String;
	type		:= self.tblActionData.getValueByName(ETRow_Type).String;
	length		:= self.tblActionData.getValueByName(ETRow_Length).String;
	regradeCode := self.cmbRegrade.myObject.CM_LogRegradeCode;
	
	// 32210 sedMin and sedMax no longer able to be entered - don't set isLogId then the sedMin and sedMax is not used to update the CM_Log
	//if self.selection = LOGID then
	//	isLogId := true;
	//	sedMAX := self.tblActionData.getValueByName(ETRow_SedMax).Decimal;
	//	sedMIN := self.tblActionData.getValueByName(ETRow_SedMin).Decimal;
	//endif;

	//_logRegrade.init(consignor, operator, species, grade, treatment, type, length, sedMIN, sedMAX, isLogId, regradeCode, self.allTrackedItems);	// commented ccms 1116, #26786 27/01/2011
	_logRegrade.init(operator, species, grade, treatment, type, length, sedMIN, sedMAX, isLogId, regradeCode, self.allTrackedItems);		// ccms 1116, #26786 27/01/2011

	
end;</source>
        <access>protected</access>
        <Parameter name="_logRegrade" type="CMIF_LogRegrade" usage="input"/>
    </JadeMethod>
