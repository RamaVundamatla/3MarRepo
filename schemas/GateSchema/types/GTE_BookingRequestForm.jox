    <JadeMethod name="getAllReservedTIs" id="3696dbc5-c8c6-4e4f-9c42-78c45d517968">
        <source>getAllReservedTIs(_tiArray : CM_TIArray input);
//14 September 2009	cnwml2
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items

vars

	realObj,pxyBookItem : CM_BookingRefItem;
	resDtl : CM_ReserveDetail;
	ti 		: CM_TrackedItem;
	obj		: Object;												
begin
	if self.tblBookingItems.allSelectedObjects.size &gt; 0 then
		foreach obj in self.tblBookingItems.allSelectedObjects do																	
			pxyBookItem := obj.CM_BookingRefItem;																					
			if pxyBookItem &lt;&gt; null then
				resDtl := pxyBookItem.myReserveDetail;
				if resDtl &lt;&gt; null then
					/* //23/06/2023	navkc1	CR 58406 Task 58408
					if resDtl.allTrackedItems.size &gt; 0 then
						foreach ti in resDtl.allTrackedItems do
							tiArray.add(ti);
						endforeach;
					endif;
					*/
					resDtl.getAllTrackedItems(_tiArray, false); //23/06/2023	navkc1	CR 58406 Task 58408
				endif;
			endif;
		endforeach;																																					
	endif;
	
epilog
end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getBookingStatusFromCmb" id="4967b127-f666-423d-b60a-4cd883a85317">
        <source>getBookingStatusFromCmb(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2009	cnwml2	Initial creation			//+cnwml2 PAR19782 CCMS SFW 1079
23 Jun 2009	cnwdad1	PAR #20032 - default to "Active".
*/
begin
	if self.cmbBookingStatus.text = app.bookingRefStatusEnumToString(BOOKING_REF_PENDING) then
		return app.bookingRefStatusStringToEnum(self.cmbBookingStatus.text);
	elseif self.cmbBookingStatus.text = app.bookingRefStatusEnumToString(BOOKING_REF_ACTIVE) then
		return app.bookingRefStatusStringToEnum(self.cmbBookingStatus.text);
	elseif self.cmbBookingStatus.text = app.bookingRefStatusEnumToString(BOOKING_REF_CLOSED) then
		return app.bookingRefStatusStringToEnum(self.cmbBookingStatus.text);
	elseif self.cmbBookingStatus.text = app.bookingRefStatusEnumToString(BOOKING_REF_ARCHIVED) then
		return app.bookingRefStatusStringToEnum(self.cmbBookingStatus.text);
	else
		return BOOKING_REF_ACTIVE;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPackAsFromCmb" id="86e3cb53-a1e6-4df9-9875-d901338ed2ae">
        <source>getPackAsFromCmb():Integer;
//12 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012

vars

begin
	if self.cmbPackAs.text = app.bookingPackAsEnumToString(BOOKING_PACKAS_FCL) then
		return app.bookingPackAsStringToEnumb(self.cmbPackAs.text);
	elseif self.cmbPackAs.text = app.bookingPackAsEnumToString(BOOKING_PACKAS_LCL) then
		return app.bookingPackAsStringToEnumb(self.cmbPackAs.text);
	elseif self.cmbPackAs.text = app.bookingPackAsEnumToString(BOOKING_PACKAS_S) then
		return app.bookingPackAsStringToEnumb(self.cmbPackAs.text);
	else
		return 0;
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
