    <JadeMethod name="removeObjectNEW" id="dda8df44-c9fd-4944-a433-ffbeb6954946">
        <lockReceiver/>
        <updating/>
        <source>removeObjectNEW(_object : CM_Object) updating, lockReceiver;

// Rewritten to be more efficient but needs heavy testing before implementation - AKBJUL2008



//-----------------------------------------
// Created: September 2005 By: cnwgd1

// Lorcan 21/7/2006 
// There is a problem when you try to remove on object from a DynaDict weith external keys
// and the key values have changed. The dictionary doesn't find it.
//
// So the change made here si to check (using getAtKey) that you can find the entry before attempting to delete
// and if you cant then do an iteratoir search for your object, and if you find it, get the real keyts from the 
// iterator and use those to remove the item. Phew!
//-----------------------------------------
//
//======================================================
// THE CODE HERE IS REPLICATED IN THE addObject METHOD
// any changes here may need to be done there as well
//======================================================

vars
	keyValue,	key1,	key2,	key3,	key4,	key5,	key6,	key7,	key8,	key9,	key10,	key11,	key12,	key13,	key14,	key15	: Any; // Max number of keys is 15
	displayStr,
	propName : String;
	sortType,
	numKeys	: Integer;
	iter	: Iterator;
	obj		: MemberType;
begin

	if _object = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _object');
		return;
	endif;

	// ### PAR  13789
	if not app.isValidObject(_object) then
		return;
	endif;

	iter := self.createIterator ();
	iter.startAtObject(_object);
	while iter.next (obj) do
		if obj = _object then
			break;
		endif;
		return;
	endwhile;
	
	numKeys := self.allKeys.size;
	
	if numKeys = 1 then
		self.getIteratorKeys(key1,iter);
		self.removeKeyEntry(key1, _object);
	elseif numKeys = 2 then
		self.getIteratorKeys(key1, key2,iter);
		self.removeKeyEntry(key1, key2, _object);
	elseif numKeys = 3 then
		self.getIteratorKeys(key1, key2, key3 ,iter);
		self.removeKeyEntry(key1, key2, key3 , _object);
	elseif numKeys = 4 then
		self.getIteratorKeys(key1, key2, key3, key4,iter);
		self.removeKeyEntry(key1, key2, key3, key4, _object);
	elseif numKeys = 5 then
		self.getIteratorKeys(key1, key2, key3, key4, key5,iter);
		self.removeKeyEntry(key1, key2, key3, key4, key5, _object);
	elseif numKeys = 6 then
		self.getIteratorKeys(key1, key2, key3, key4, key5, key6,iter);
		self.removeKeyEntry(key1, key2, key3, key4, key5, key6, _object);
	elseif numKeys = 7 then
		self.getIteratorKeys(key1, key2, key3, key4, key5, key6, key7,iter);
		self.removeKeyEntry(key1, key2, key3, key4, key5, key6, key7, _object);
	elseif numKeys = 8 then
		self.getIteratorKeys(key1, key2, key3, key4, key5, key6, key7, key8,iter);
		self.removeKeyEntry(key1, key2, key3, key4, key5, key6, key7, key8, _object);
	elseif numKeys = 9 then
		self.getIteratorKeys(key1, key2, key3, key4, key5, key6, key7, key8, key9,iter);
		self.removeKeyEntry(key1, key2, key3, key4, key5, key6, key7, key8, key9, _object);
	elseif numKeys = 10 then
		self.getIteratorKeys(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10,iter);
		self.removeKeyEntry(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, _object);
	elseif numKeys = 11 then
		self.getIteratorKeys(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11,iter);
		self.removeKeyEntry(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, _object);
	elseif numKeys = 12 then
		self.getIteratorKeys(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12,iter);
		self.removeKeyEntry(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12, _object);
	elseif numKeys = 13 then
		self.getIteratorKeys(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12, key13,iter);
		self.removeKeyEntry(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12, key13, _object);
	elseif numKeys = 14 then
		self.getIteratorKeys(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12, key13, key14,iter);
		self.removeKeyEntry(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12, key13, key14, _object);
	elseif numKeys = 15 then
		self.getIteratorKeys(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12, key13, key14, key15,iter);
		self.removeKeyEntry(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12, key13, key14, key15, _object);
	endif;
epilog
	delete iter;
end;</source>
