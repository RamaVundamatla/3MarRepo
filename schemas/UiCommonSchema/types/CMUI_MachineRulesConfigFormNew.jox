	elseif self.myProxyMultiRule.isKindOf(CM_RTQueueMultiRuleTAMaster) then
		if self.myProxyMultiRule.CM_RTQueueMultiRuleTAMaster.myToTAMaster = obj then
			return;
		endif;
		self.myProxyMultiRule.CM_RTQueueMultiRuleTAMaster.setForProxyTAMaster(self.myProxyMultiRule.CM_RTQueueMultiRuleTAMaster.myFromTAMaster,obj.CM_TerminalArea,self.myProxyMultiRule.myTerminal);
		self.loadTargetICCombo();
	endif;
	
	self.cmbMoveMethod.initialise(true);
