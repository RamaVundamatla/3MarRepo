    <JadeMethod name="addLCbyOID" id="443c03b2-92ab-42cb-abca-1be6479c1d3c">
        <source>addLCbyOID(_obj : CM_Object);
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 07/11/2012	cnwcs5	par 30450 - remove location restrictions
vars

	lcHolder 	: CMIF_LocationControllersByOid;
	oidStr 		: String;
begin

	if _obj = null then
		return;
	endif;
	
	// This is so that we can clear up when a restriction is deleted
	oidStr := self.getOidStringForObject(_obj);
	
	if  self.allOIDSbyOIDString.getAtKey(oidStr) = null then
		create lcHolder transient;
		lcHolder.objectString := oidStr;
		
		if _obj.isKindOf(CM_LabourRestriction) then
			_obj.CM_LabourRestriction.allLocationControllers.copy(lcHolder.allLocationControllers);
		elseif _obj.isKindOf(CM_SubBlockStack) then
			_obj.CM_SubBlockStack.allByPassedControllers.copy(lcHolder.allLocationControllers);
		endif;
		self.allOIDSbyOIDString.add(lcHolder);
	endif;

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="addTILClcsToDrawnObjects" id="64817180-f6b4-4378-8706-46bd502ea030">
        <updating/>
        <source>addTILClcsToDrawnObjects(_tiLC : CM_TILC; _x1, _y1, _x2,_y2 : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		06 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
x1, x2,tiy1 , 
	containerHeight,
	twentyLength,
	fortyLength : Integer;
	numLCs : Integer;
	anLC : CM_TILCController;
	ti : CM_TrackedItem;
	lcMultiplier : Real;
begin
	numLCs := _tiLC.allLCs.size;
	if numLCs = 0 then
		return;
	else
		containerHeight:=self.getContainerHeight();
		twentyLength:=self.getLengthPerFoot(20);
		fortyLength:=self.getLengthPerFoot(40);

		x1 := _x1;
		tiy1:=_y2 - containerHeight;
		foreach anLC in _tiLC.allLCs discreteLock do
			x2 := x1 + twentyLength; // PAR 20984 epr 8/10/09 we need the x2 for the locations on the trailer not just the tis
			
			foreach ti in anLC.allTrackedItems discreteLock do		
				lcMultiplier := ti.getMultiplierForDrawing();
				x2 := x1 + (lcMultiplier * twentyLength).Integer;
				self.drawTI(ti, null,x1, tiy1, x2,_y2,self.myDrawingFrame, null);	// cnwjk3 PAR 23875 23/04/10			
			endforeach;
			self.addToDrawnObjects(x1,_y1, x2,_y2, anLC,true);
			
			x1 := x2 + 1;
		endforeach;
	endif;
end;</source>
        <Parameter name="_tiLC" type="CM_TILC"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToDrawnObjects" id="f0bb8bae-4ed8-48c9-8702-458168450748">
        <updating/>
        <source>addToDrawnObjects(_x1,_y1,_x2,_y2 : Integer ; _obj : Object; _autoRemove : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		05 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aPointArray : PointArray;
begin
	if _autoRemove then
		if  self.allDrawnObjects.includes(_obj)  then
			self.allDrawnObjects.removeObjectFromDict(_obj);
		endif;
	endif;
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 2. ");
	self.setTmpPointArrayXYs(_x1,_y1,_x2,_y2);
	create aPointArray transient;
	self.tmpPointArray.copy(aPointArray);
	self.allDrawnObjects.putAtKey(_x1,_y1,_x2,_y2,aPointArray, _obj);
	self.allPolygons.add(aPointArray); // for cleanup
end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_autoRemove" type="Boolean"/>
    </JadeMethod>
