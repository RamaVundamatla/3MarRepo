    <JadeMethod name="createSelf" id="45a82192-105f-4c18-b1a0-4a61795b8ed4">
        <updating/>
        <source>createSelf(
	_format			: CM_OutputFormat_XTAB;
	_xmlInfo		: String;	// changed parameter type
	_fieldHeadings	: StringArray;
	_rowLevel		: Integer;
	_colLevel		: Integer;
	_tabLevel		: Integer;
	_summaryLevel	: Integer ) updating;
	
// ---------------------------------------------------------------------------
// Created:     19 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  _format 		- XTAB that defines rows and columns
//				_xmlInfo		- property name/value combinations
//				_fieldHeadings	- small optimisation to avoid translation every time we set a heading
//				_rowLevel
//				_collevel
//				_summaryLevel	- 0 = main report, 1 = summary for first row etc etc
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/02/2010 	cnwcs5 		ccms 1028 - store property name/value combinations
// ---------------------------------------------------------------------------

vars
	field			: CM_XTABField;
	int				: Integer;
	size			: Integer;
	numCols			: Integer;
	child			: CMIF_OutputField;
	
begin
	self.tabSummaryLevel	:= _tabLevel;
	self.rowSummaryLevel	:= _rowLevel;
	self.colSummaryLevel	:= _colLevel;
	self.summaryLevel		:= _summaryLevel;
	self.xmlInfo			:= _xmlInfo;	// 16/02/2010 cnwcs5 ccms 1028
	numCols					:= _format.allColumns.size;
	
	// setup children (actual values for cells)
	size := _format.allFields.size;
	foreach int in 1 to size do
		field := _format.allFields[int].CM_XTABField;
		// we don't even bother creating a field object if it is not going to be displayed
		if (_colLevel = 0 and field.hideGrandTotals) or
			(_colLevel &gt; 0 and _colLevel &lt; numCols and field.hideSubtotals) or
			(_colLevel = numCols and field.hideDetail) or
			(_colLevel = -1 and field.hideDetail) then
			// this value does not get output at this level
			continue;
		endif;
		create child as self.getClassForFunction( field.function ) transient;
		child.createSelf( field, _fieldHeadings[ int ] );
		self.allChildren.add( child );
	endforeach;
	
epilog
	
end;</source>
        <Parameter name="_format" type="CM_OutputFormat_XTAB"/>
        <Parameter name="_xmlInfo" type="String"/>
        <Parameter name="_fieldHeadings" type="StringArray"/>
        <Parameter name="_rowLevel" type="Integer"/>
        <Parameter name="_colLevel" type="Integer"/>
        <Parameter name="_tabLevel" type="Integer"/>
        <Parameter name="_summaryLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getClassForFunction" id="10f4fc13-c82a-481b-afc4-7f0f1209cf90">
        <source>getClassForFunction(_function :Integer):Class protected;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/02/2010	cnwcs5	par 22140 - New functions
// ---------------------------------------------------------------------------
vars

begin
	if _function = CM_XTABField.Function_Count then
		return CMIF_OutputField_Count;
	elseif _function = CM_XTABField.Function_Sum then
		return CMIF_OutputField_Sum;
	elseif _function = CM_XTABField.Function_Average then
		return CMIF_OutputField_Average;
	elseif _function = CM_XTABField.Function_Max then
		return CMIF_OutputField_Max;
	elseif _function = CM_XTABField.Function_Min then
		return CMIF_OutputField_Min;
	elseif _function = CM_XTABField.Function_Count_True then	// 12/02/2010 cnwcs5 par 22140
		return CMIF_OutputField_Count_True;						// 12/02/2010 cnwcs5 par 22140
	elseif _function = CM_XTABField.Function_Count_False then	// 12/02/2010 cnwcs5 par 22140
		return CMIF_OutputField_Count_False;					// 12/02/2010 cnwcs5 par 22140
	elseif _function = CM_XTABField.Function_Count_Null then	// 12/02/2010 cnwcs5 par 22140
		return CMIF_OutputField_Count_Null;						// 12/02/2010 cnwcs5 par 22140
	elseif _function = CM_XTABField.Function_Count_NotNull then	// 12/02/2010 cnwcs5 par 22140
		return CMIF_OutputField_Count_NotNull;					// 12/02/2010 cnwcs5 par 22140
	elseif _function = CM_XTABField.Function_Count_Zero then	// 15/02/2010 cnwcs5 par 22140
		return CMIF_OutputField_Count_Zero;						// 15/02/2010 cnwcs5 par 22140
	elseif _function = CM_XTABField.Function_Count_NotZero then	// 15/02/2010 cnwcs5 par 22140
		return CMIF_OutputField_Count_NotZero;					// 15/02/2010 cnwcs5 par 22140
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_function" type="Integer"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="updateSelf" id="7380359f-aa58-4a94-a90d-507f3626fd80">
        <source>updateSelf(_format :CM_OutputFormat_XTAB; _fieldValues :Array; _obj :Object);
// ---------------------------------------------------------------------------
// Created:     19 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/12/2009	cnwcs5		ccms 1023 - allow for field  values to be objects as well as strings
// 12/02/2010	cnwcs5		ccms 1925/par 22295 - Release Summaries
// ---------------------------------------------------------------------------
vars
	child	:Object;
	value	:Decimal[23,8];
	int, 
	start	:Integer;
	any 	:Any;
begin
	// key values have been set so just a matter of updating field values
	
	// if we are adding in missed mapping values _obj may be null
	if _obj &lt;&gt; null then	// cnwcs5 07/12/2009 ccms 1028
		foreach child in self.allChildren do
			// 12/02/2010 cnwcs5 par 22140 - START
			if _fieldValues.isKindOf (StringArray) then
				any := _fieldValues[child.CMIF_OutputField.index].String;
			else
				any := _fieldValues[child.CMIF_OutputField.index];
			endif;
			
			if any.isKindOf (CM_SnapshotField) then
				child.CMIF_OutputField.updateSelf (any.CM_SnapshotField, _obj);	
			elseif child.isKindOf (CMIF_OutputField_Count_True) or 		
				child.isKindOf (CMIF_OutputField_Count_False) then	
				// these functions only apply to booleans
				if any.String.startsWith (CMIF_OutputFormatAgent_XTAB.True_Property_Key_Value) then	
					child.CMIF_OutputField.updateSelf (true, _obj);	// true	
				else											
					child.CMIF_OutputField.updateSelf (false, _obj);	// false	
				endif;					
			elseif child.isKindOf (CMIF_OutputField_Count_Null) or
				child.isKindOf (CMIF_OutputField_Count_NotNull) then
				// these apply to strings
				if any.String = CMIF_OutputFormatAgent_XTAB.Empty_Property_Key_Value then
					child.CMIF_OutputField.updateSelf (true, _obj);	// null
				else
					child.CMIF_OutputField.updateSelf (false, _obj);	// not null
				endif;
			elseif child.isKindOf (CMIF_OutputField_Count_Zero) or
				child.isKindOf (CMIF_OutputField_Count_NotZero) then
				// these apply to numbers
				if any.Decimal = 0 then
					child.CMIF_OutputField.updateSelf (true, _obj);	// zero
				else 
					child.CMIF_OutputField.updateSelf (false, _obj);	// not zero
				endif;

			else
				child.CMIF_OutputField.updateSelf (any.String.Decimal, _obj);	
			endif;				
			// 12/02/2010 cnwcs5 par 22140 - END
		endforeach;
	
		self.allObjects.add (_obj);	
	endif;					// cnwcs5 07/12/2009 ccms 1028
	
	// now update the next sub-total/total
	if self.myColTotalEntry &lt;&gt; null then
		self.myColTotalEntry.updateSelf (_format,_fieldValues, _obj);
	endif;
	
	if self.myRowTotalEntry &lt;&gt; null then
		self.myRowTotalEntry.updateSelf (_format, _fieldValues, _obj);
	endif;
	
	if self.myTabTotalEntry &lt;&gt; null then
		self.myTabTotalEntry.updateSelf (_format, _fieldValues, _obj);
	endif;
epilog

end;</source>
        <Parameter name="_format" type="CM_OutputFormat_XTAB"/>
        <Parameter name="_fieldValues" type="Array"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
