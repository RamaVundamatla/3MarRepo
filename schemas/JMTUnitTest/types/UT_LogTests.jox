    <JadeMethod name="logTransferTest" id="3525ecd4-eef2-4293-9081-50ef8646d6de">
        <source>logTransferTest();

/*

Purpose:			Create logs in LocationTransfer1 then do XML TransferRq to LocationTransfer2.
					Get it working and then add operator restrictions to LocationTransfer2 which don't match the log specs.
					This should now (once 27334 has made these errors) return an error.
Parameters:			

Return Value:		


Date		Who		Reason
3/12/2013	cnwjre1	Test par 27334

*/

vars
	logArea	: CM_LogArea;
	logRow	: CM_LogController;
	ti		: CM_TrackedItem;
	count	: Integer;
	logIds	: String;
begin

	self.createLocationForLogModuleTest(self.LocationTransfer1);
	self.createBOLInLogsForLogModuleTst(self.LocationTransfer1, self.BOLInNumber_Transfer,  self.BOLInNumber_Transfer[1:5] &amp; "LOG", 10);

	self.createLocationForLogTest2(self.LocationTransfer2, "UTO2");		// location with location restrictions for different operator
	logArea := self.getLogArea(LogAreaCode);
	logRow := logArea.allRowControllersById[self.LocationTransfer1].CM_LogController;
	foreach ti in logRow.allTrackedItems do
		count := count + 1;
		if count = 1 then
			logIds := ti.id;
		else
			logIds := logIds &amp; "," &amp; ti.id;
		endif;
	endforeach;
	
	self.xmlTransferTest(logArea, self.LocationTransfer2, logIds);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="logTransferTest2" id="1c9a5f88-f6de-431e-a825-312bfc3d8c26">
        <source>logTransferTest2();

/*

Purpose:			Create logs in LocationTransfer1 then do XML TransferRq to LocationTransfer2.
					Get it working and then add operator restrictions to LocationTransfer2 which don't match the log specs.
					This should now (once 27334 has made these errors) return an error.
Parameters:			

Return Value:		


Date		Who		Reason
3/12/2013	cnwjre1	Test par 27334

*/

constants
//	LocationTransfer3 = "UTTFR3";
//	BOLInNumber_Transfer3 = "UTTFR3";
vars
	logArea	: CM_LogArea;
	logRow	: CM_LogController;
	ti		: CM_TrackedItem;
	count	: Integer;
	logIds	: String;
	now : TimeStamp;
begin

	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.createLocationForLogModuleTest(LocationTransfer1);
	self.createBOLInLogsForLogModuleTst(LocationTransfer1, BOLInNumber_Transfer,  BOLInNumber_Transfer[1:5] &amp; "LOG", 10);

	self.createLocationForLogTest2(LocationTransfer2, self.OperatorCode);		// location with location restrictions for different operator
	logArea := self.getLogArea(LogAreaCode);
	logRow := logArea.allRowControllersById[LocationTransfer1].CM_LogController;
	foreach ti in logRow.allTrackedItems do
		count := count + 1;
		if count = 1 then
			logIds := ti.id;
		else
			logIds := logIds &amp; "," &amp; ti.id;
		endif;
		beginTransaction;
		ti.setPropertyValue(CM_Log::inspectDT.name, now);
		commitTransaction;
	endforeach;
	
	self.xmlTransferTest(logArea, LocationTransfer2, logIds);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tLogModuleTest" id="485e727d-67de-4de9-8915-19d062628ef0">
        <source>tLogModuleTest();
// cnwdap1
//03 September 2010	cnwjre1

/*Purpose:	Log Module Test
	
	Log tests need some common ojects, that are created in this method.
	The method creates:
		Logs Specs codes
		Operator for logs (OpeartorCode)
		Corresponding log products
		Vehicle
		RT Device (it is used when docket is created using XML mechanism)
		Log Area (id = LogAreaCode).
		
	Then, each test needs its own:
		log row (location)
		docket
		logs
		a) Put your code in self.deleteAllLogModuleTest() at the top of the method - to delete your created objects before your test.
		b) Put your test code at the bottom of the method.
	*/

// 17/08/2016 cnwrh7	TFS	2501

vars

	logSpecs		: CM_CodeGroupLogSpecs;
	logType			: CM_LogType;
	logTreatment	: CM_LogTreatment;
	logLen			: CM_LogLength;
	logSpecies		: CM_LogSpecies;
	logGrade		: CM_LogGrade;
	operator		: CM_Operator;
	logArea			: CM_LogArea;
	resetSubTermAreaDefined	: Boolean;
	logSet			: ObjectSet;
	obj				: Object;
	autoMatch 		: Boolean;
	terminal		: CM_Terminal;

begin
	if self.getTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then
		resetSubTermAreaDefined := true;
		self.setSubTerminalAreaDefined(false);	
	endif;
	terminal := self.getTerminal;
	autoMatch := terminal.getConfig(LogDocketAutoMatch).Boolean;
	beginTransaction;
	terminal.setConfig(LogDocketAutoMatch, true);
	commitTransaction;

	//-------------------------------------------------------------------------
	//				Creation of objects for Log Module Test
	//-------------------------------------------------------------------------
	//delete whole log spec
	self.setStrictBOLNumberRule(true);
	self.deleteAllLogModuleTest();
	
	logSpecs	:= self.addLogSpecs(LogSpecsName);
	logType		:= self.addLogType(		LogSpecsTypeBoff,		LogSpecsTypeBoffDesc,		false, logSpecs);
	logType		:= self.addLogType(		LogSpecsTypeBon,		LogSpecsTypeBonDesc,		false, logSpecs);
	logTreatment:= self.addLogTreatment(LogSpecsTreatmentUTN,	LogSpecsTreatmentUTNDesc,	false, logSpecs);
	logTreatment:= self.addLogTreatment(LogSpecsTreatmentUTT,	LogSpecsTreatmentUTTDesc,	false, logSpecs);
	logLen		:= self.addLogLength(	LogSpecsLength2,		LogSpecsLength2Desc,		false, logSpecs);
	logLen		:= self.addLogLength(	LogSpecsLength6,		LogSpecsLength6Desc,		false, logSpecs);
	logLen		:= self.addLogLength(	LogSpecsLength8,		LogSpecsLength8Desc,		false, logSpecs);
	logSpecies	:= self.addLogSpecies(	LogSpecsSpeciesOak,		LogSpecsSpeciesOakDesc,		false, logSpecs);
	self.createGradesForLogModuleTest();
	
	operator := self.addOperatorForLogs(OperatorCode,OperatorDesc,LogSpecsName);

	// need to create CM_ProductLog for possible all combinations	
	self.createDelProductForLogModuTest(true);
	
	self.createVehicleForLogModuleTest();
	self.addRTDevice(RTDevice_HandHeld, RTDeviceId, RTDeviceModel, "PC_LOGS_UT", null, false, false,false); // when creating BOLIn and logs via XML, it requires some RT Device code, //+ 17/08/2016 cnwrh7	TFS	2501

	logArea := self.addLogArea(LogAreaCode, "UT Log Area");

	//------------------------------------------------------------------------------
	//							ALL LOG TESTS SECTION
	//------------------------------------------------------------------------------
	
	// DOCKET WEIGHT UDPATE TEST
	self.logBolWeightUpdateTest();
	
	// Consignor on a BOL and on the corresponding logs should be the same unconditionaly. ccms 1116, #26786
	self.logConsignorTest();	
	  
	// ccms 1121 test xml update of bol maint.
	self.logBolUpdateTest();
	
	// 33046 auto weighing input
	self.logBolWeighTest();
	
	// 27334 log transfer validation
	self.logTransferTest();
	
	//test bad log numbers
	self.logBolBadNumbeTest();

	// CCMS 1119, par 27433. Location maintenance via XML
	self.xmlLocationMaintenanceTest();	
	self.xmlLocationMaintenanceTest2();		// test change of status
	self.xmlLocationQueryTest(self.getLogArea(LogAreaCode), self.LocationXmlMaint); // test additional data in response
	self.xmlLocationMaintenanceTest3();		// test change of status clearing mixedRow value
	
	// 15/09/2015 cnmwh5
	create logSet transient;
	logArea.getAllLocationsTrackedItems(logSet);
	beginTransaction;
	foreach obj in logSet do
		obj.CM_Log.setRemarks(self.createdByUnitTest(obj.CM_Log.remarks), true);
	endforeach;
	commitTransaction;
		
epilog
	if resetSubTermAreaDefined then
		self.setSubTerminalAreaDefined( true );
	endif;
	delete logSet;
	self.setStrictBOLNumberRule(false);
	app.myPassport.getTIAuditController().initialiseTransaction;	// deletes the subTransactionController transient.
	beginTransaction;
	terminal.setConfig(LogDocketAutoMatch, autoMatch);
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="tLogRowsWebServiceTest" id="1e929d56-f9bf-44ee-b93f-0b4a2ab12d56">
        <source>tLogRowsWebServiceTest();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 24/03/2016	cnwdap1		Initial creation PAR #37675 Transient leaks in getLogRows web service
//
constants
	LogArea = "LOGLOC";
	
vars
	terminal : CM_Terminal;
	startTrans, endTrans, oa : ObjectArray;
	obj : Object;
	localLeakChecker : UT_LeakChecker;
	message : String;
	logArea : CM_LogArea;
	logController : CM_LogController;
	isDocketChecked : Boolean;
	logLength : CM_LogLength;
	restriction : CM_LocationRestrictLog;

begin
	terminal := self.getTerminal();
	logArea := terminal.allTerminalAreas[LogArea].CM_LogArea;
	logController := logArea.allRowControllersById.first.CM_LogController;
	isDocketChecked := logController.docketChecked;
	restriction := logController.myLocationRestriction.CM_LocationRestrictLog;
	logLength := app.myRoot.allCodeGroups[2, "UNITTEST"].CM_CodeGroupLogSpecs.allLogLengths["8.0"];
	beginTransaction;
	logController.setPropertyValue(CM_LogController::docketChecked.name, true);
	if restriction = null then
		create restriction;
		logController.setPropertyValue(CM_LogController::myLocationRestriction.name, restriction);
	endif;
	if restriction &lt;&gt; null and not restriction.allLogLengths.includes(logLength) then
		restriction.allLogLengths.add(logLength);
	endif;
	commitTransaction;
	
	// get the transients we currently have and know about
	create startTrans transient;
	create oa transient;
	process.allTransientInstances(oa, 0); 
	oa.copy(startTrans);
	startTrans.remove(oa);
	
	// Call the getLogRow test in WebServicesSchema
	self.webServiceCallWithParams( CM_UnitTestAgent::wsGetLogRows.name, terminal );
	
	// now check for transients again to see if we added any on the way through
	oa.clear;
	process.allTransientInstances(oa, 0); 
	create endTrans transient;
	oa.copy(endTrans);
	endTrans.remove(oa);
	
	create localLeakChecker transient;
	foreach obj in endTrans do
		if startTrans.includes(obj) then
			continue;
		endif;
		if localLeakChecker.excludeKnownLeaksPublic(obj) then
			continue;
		endif;
		
		message := message &amp; CrLf &amp; "----Transient Leak---- " &amp; CrLf &amp; localLeakChecker.getObjectDisplayString(obj, false);
		message := message &amp; localLeakChecker.getIteratorTransientLeakDetail(obj);
		message := message &amp; CrLf &amp; "-----End Transient Leak-----" &amp; CrLf;
	endforeach;
	
	self.assertNullMsg(message, message);
	
epilog
	delete startTrans;
	delete endTrans;
	delete oa;
	delete localLeakChecker;
	
	// reset docket check on log area
	if logController &lt;&gt; null then
		beginTransaction;
		logController.setPropertyValue(CM_LogController::docketChecked.name, isDocketChecked);
		commitTransaction;
	endif;
end;</source>
