/*
----------   ----------  --------------------------------------------------
Created:	15 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	errorDescr			: String;
begin
	errorDescr := self.txtWrongData.text.trimBlanks();
	app.myHandHeldGuiAgent.doSendAlertToControl(self.txtVehicle.text.trimBlanks.toUpper, errorDescr);
	app.msgBox('"' &amp; errorDescr &amp; '" has been sent to control', 'Error sent', MsgBox_OK_Only);
	self.txtWrongData.text := null;
	self.doShowFrmMain();
end;


