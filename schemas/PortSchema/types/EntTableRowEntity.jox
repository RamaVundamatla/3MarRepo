    <JadeMethod name="getHeading" id="724e10a3-6799-4dab-baa2-7f8b9b8ea196">
        <source>getHeading(_cargoBOLType : CM_CargoBOLType; _terminal : CM_Terminal; _locale : CM_Locale) : String;
// ---------------------------------------------------------------------------
// Created:     17 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	return self.heading;
end;</source>
        <Parameter name="_cargoBOLType" type="CM_CargoBOLType"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_locale" type="CM_Locale"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHeadingUnaltered" id="94419f95-8c30-4490-8483-cf47d4783533">
        <source>getHeadingUnaltered(): String;
// ---------------------------------------------------------------------------
// Created:     19 October 2004 by cnwrs2
//
// Purpose:     Returns the heading unaltered by locale or terminology
// ---------------------------------------------------------------------------
vars

begin
	return self.heading;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getShortHeading" id="9c0226bf-1e32-4111-81c4-d1547fd1c17b">
        <source>getShortHeading(_cargoBOLType : CM_CargoBOLType; _terminal : CM_Terminal; _locale : CM_Locale) : String;
// ---------------------------------------------------------------------------
// Created:     17 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	headingStr	: String;
begin

	headingStr := self.shortHeading;
	if headingStr = null then
		headingStr := self.getHeading(_cargoBOLType, _terminal, _locale);
	endif;

	return headingStr;

end;</source>
        <Parameter name="_cargoBOLType" type="CM_CargoBOLType"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_locale" type="CM_Locale"/>
        <ReturnType type="String"/>
    </JadeMethod>
