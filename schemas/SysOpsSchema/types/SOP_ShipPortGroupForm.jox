    <JadeMethod name="btnNext_click" id="4cfc32ad-33c5-4869-9e83-8ce6059e74d3">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNext_click(btn: Button input) updating;
//--------------------------------------------------
// Created:	30 September 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	if doSave() = false	then
		return;
	endif;
	self.clearProxyDetails;
	self.myCurrentShipPortGroup := null;
	self.initShtMultiSelect;
	self.showThumbnail(null);
end;</source>
