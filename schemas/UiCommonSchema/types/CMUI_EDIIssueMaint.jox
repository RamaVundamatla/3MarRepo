    <JadeMethod name="setCurrentIssue" id="ab0e44a7-c752-42b9-9979-9bec4b2755a5">
        <updating/>
        <source>setCurrentIssue() updating;
/*
Purpose:	

Date			Who		Reason
16 July 2024	navab1	CR 64617 TASK 64638
26 Aug 2024		navnk30	Bug 65636: NSW - EDI Issues Configuration UI issues
02 Dec 2024		navlw1	Jira-14844: MTN - Refinement of EDI Issue Save
*/

vars
	table 		: CM_DataTable;
	msgText		: String;
begin
	table := self.tblData;
	
	// navlw1 #Jira-14844 check for ediFileType change before we change row
	self.ediFileTypeChange();
	
	msgText := self.getMsgBoxText();
	
	if msgText &lt;&gt; null then
		if app.msgBox(msgText,app.getErrorString(Confirmation), MsgBox_Yes_No) = MsgBox_Return_Yes then // navlw1 #Jira-14844
			self.doSave(); // navlw1 #Jira-14844
			self.myCurrentEDIIssue := self.tblData.accessRow(table.row).itemObject.CM_EDIIssue; // navlw1 #Jira-14844
			self.displayFields();
			return;
		else				//26.08.2024 navnk30 #65636
			self.emailChanged := false;
			self.ediChanged := false;
		endif;
		
	endif;
	
	
	self.myCurrentEDIIssue := self.tblData.accessRow(table.row).itemObject.CM_EDIIssue;
	
	if table.row = table.fixedRows then
		return;
	endif;

	self.displayFields();

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyMappings" id="aefc4a49-3b85-4473-846d-3de6fbfc8672">
        <source>setProxyMappings(_proxyIssue : CM_EDIIssue);
/*
Purpose:	

Date		Who		Reason
09 July 2024	navab1	CR 64617 TASK 64638
*/

vars
	ediFileType		: CM_EDIFileType;
	pxyMapping : CM_EDIIssueMapping;
	types : CM_EDIFileTypeByNameDict;
begin
	create types transient;
	self.msgEDITypes.getSelected(types);
	
	foreach ediFileType in types discreteLock do
		create pxyMapping transient;
		pxyMapping.setProxy(self.myTerminal, _proxyIssue, ediFileType);
	
	endforeach;
epilog
	delete types;
end;</source>
        <Parameter name="_proxyIssue" type="CM_EDIIssue"/>
