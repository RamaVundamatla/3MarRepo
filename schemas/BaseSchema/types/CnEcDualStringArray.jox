    <JadeMethod name="purge" id="3fbbde0f-6889-4175-bb53-4b8ed6e58a28">
        <lockReceiver/>
        <updating/>
        <source>purge() updating, lockReceiver;
// -----------------------------------------------------------------------------
// Created:		10 October 2001 by cnwndl1
//
// Purpose:		Purges the receiver and its array property.
//
// Parameters:	None
//
// Returns:		Nothing
//
