        <source>isControlKeyDown() : Boolean;
constants
	VK_CONTROL = #0011;  // control key
	HIGH       = 2^15;
vars
	state:               Integer;
begin
	state := call getKeyState(VK_CONTROL);
	return (state.bitAnd(HIGH) = HIGH);
