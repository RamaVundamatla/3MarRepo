    <Function name="internetReadFile" id="eee258a3-c858-4bd0-a346-65b61914eb07">
        <entrypoint>InternetReadFile</entrypoint>
        <executionLocation>presentationClient</executionLocation>
        <library name="wininet"/>
        <source>internetReadFile(	pInternetHandle	: Integer;
					pBuffer			: String[4096] io;
