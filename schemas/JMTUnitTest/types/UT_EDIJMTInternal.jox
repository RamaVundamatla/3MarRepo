			&lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
			&lt;receiveDate&gt;01 January 2010, 12:45:00&lt;/receiveDate&gt;
		&lt;/CargoOnSite&gt;
		&lt;CargoOnSite&gt;
			&lt;weight&gt;25000.0000&lt;/weight&gt;
			&lt;parentCargoTypeCode&gt;1&lt;/parentCargoTypeCode&gt;
			&lt;site&gt;1&lt;/site&gt;
			&lt;bol&gt;BOL01&lt;/bol&gt;
			&lt;bookingRef&gt;BK01&lt;/bookingRef&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;commodity&gt;GENL&lt;/commodity&gt;
			&lt;companyCode&gt;DFBU&lt;/companyCode&gt;
