    <JadeMethod name="pxyCreateUpdateProxy" id="ce13895e-844c-44ee-9d70-0ec8b61c0e55">
        <source>pxyCreateUpdateProxy(): SelfType;
// -------------------------------------------
// Created 09 October 2003 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
20/04/2011	cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
					trying to create the proxy
24 Apr 2012	cnwkpd1	PAR #29471 - Fix problem of leaked CM_Machine proxies
	
*/

vars
	pxyTerminalAreaMaster : CM_TerminalAreaMaster;
	realProd, pxyProd: CM_TerminalAreaProductMinMax;
	completedOK		: Boolean;
	machine,
	pxyMachine		: CM_Machine;
	
	pxyMaxStackHeight : CM_GriddedTAStackHeight;
	realMaxStackHeight : CM_GriddedTAStackHeight;

begin
	pxyTerminalAreaMaster := inheritMethod();

	foreach realProd in self.allProductMinMax discreteLock do
		if realProd.myLocationsController &lt;&gt; null then	//30 Mar 2021	NDL	TFS 49912
			//these ones are created by the Locations controllers when they are prooxied
			continue;
		endif;
		pxyProd := app.createUpdateProxy(realProd).CM_TerminalAreaProductMinMax;
		pxyProd.setMyTerminalAreaMaster(pxyTerminalAreaMaster);
	endforeach;
	
	//08 Sep 2020	NDL	TFS 49984
	foreach realMaxStackHeight in self.allGriddedTAStackHeights discreteLock do
		pxyMaxStackHeight := app.createUpdateProxy(realMaxStackHeight).CM_GriddedTAStackHeight;
		pxyMaxStackHeight.setMyTerminalAreaMaster(pxyTerminalAreaMaster);
	endforeach;

	// PAR #29471
	self.allowedMachines.copy(pxyTerminalAreaMaster.allowedMachines);
	
	/* PAR #29471 - replaced this code
	//cnwrd1 par 29203 1.3.2012
	foreach machine in self.allowedMachines discreteLock do
		pxyMachine := app.myProxyManager.getProxyObject(machine).CM_Machine;
		if pxyMachine = null then
			pxyMachine := app.createUpdateProxy(machine).CM_Machine;
		endif;
		pxyMachine.addTAMaster(pxyTerminalAreaMaster);	
	endforeach;	
	*/
	
	pxyTerminalAreaMaster.myTerminal	:= self.myTerminal;
	pxyTerminalAreaMaster.myType		:= self.myType;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyTerminalAreaMaster;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyTerminalAreaMaster;
	endif;	

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setComment" id="56ccb34d-c835-4e28-afef-a139d551060b">
        <updating/>
        <source>setComment(_value :String)updating;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient (method);
	
	if self.comment &lt;&gt; _value then
		self.comment := _value;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setConfig" id="bec34bbf-a07e-48be-bc67-7c927e7213c0">
        <updating/>
        <source>setConfig(pCode : String; pValue : Any) updating ;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	stateObj	: CM_StateObject;
	
begin

	stateObj := self.myStateObject;
	
	if stateObj = null then
		create stateObj persistent;
		self.myStateObject := stateObj;
 	endif;
	
	stateObj.setStateData(pCode, pValue, true);

end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="c501ae84-4528-414a-8f2d-106f9ec0d88a">
        <updating/>
        <source>setForCreate(_proxy: CM_TerminalAreaMaster input; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Aug 2009	cnwer1	Initial creation
17 May 2010	cnwkpd1	PAR #23525 - System performance enhancements
22 Aug 2011	cnwdap1	PAR #28047 CCMS POL 2095 Update machines for this terminal area
*/

vars
	agent			: CM_ObjectVolatilityConverter;
	
begin
	_proxy.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	self.comment	:= _proxy.comment;
	self.id			:= _proxy.id.trimBlanks.toUpper;
	self.type		:= _proxy.type;
	self.myType		:= _proxy.myType;
	self.myTerminal	:= _proxy.myTerminal;
	
	self.updateMachines(_proxy.allowedMachines);	// PAR #28047
	 
	// PAR #23525 - If system is using stable objects, then need to change the volatility of
	// the newly created object's collections
	if app.myRoot.useStableObjects then
		create agent transient;
		agent.newVolatility := Volatility_Stable;
		agent.multipleTransactions := false;
		
		self.doObjectVolatilityConversion(agent, 1);
	endif;
	
epilog
	delete agent;
	
end;</source>
        <Parameter name="_proxy" type="CM_TerminalAreaMaster" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="33fbd58e-2d61-4045-92f9-67281ce6dd3c">
        <updating/>
        <source>setForUpdate(_proxy: CM_TerminalAreaMaster) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 August 2009	cnwer1	Initial creation
22 August 2011	cnwdap1	PAR #28047 CCMS POL 2095 update machines for this terminal area
*/

vars

begin
	_proxy.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	self.comment	:= _proxy.comment;
	self.id			:= _proxy.id.trimBlanks.toUpper;
	
	self.updateMachines(_proxy.allowedMachines);	// PAR #28047
	
	self.setGriddedStackHeights( _proxy );	//08 Sep 2020	NDL	TFS 49984

epilog

end;</source>
        <Parameter name="_proxy" type="CM_TerminalAreaMaster"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateInUse" id="f5b63a6e-7923-4ddf-a61d-2cd46f3f4553">
        <updating/>
        <source>setForUpdateInUse(_proxy: CM_TerminalAreaMaster; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 August 2009	cnwer1	Initial creation

*/

vars

begin
	_proxy.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	self.comment	:= _proxy.comment;
	self.id			:= _proxy.id.trimBlanks.toUpper;
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_TerminalAreaMaster"/>
