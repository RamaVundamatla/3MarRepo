    <JadeMethod name="setForCreate" id="0300f543-26d9-4f3e-8e88-f8a9ed93bf1c">
        <updating/>
        <source>setForCreate(_proxyInvoice:CM_Invoice) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
// 18 Aug 2022	navpw1	TFS: 54564 (54375) - EUP - Inv Config - Debtor Currencies and Countries
// 03 Oct 2022	navpw1	TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
// 19.01.2023	navvt20 TFS CR 55625 Task 55658: Jade - Contract Id TRX
// 01.02.2023	navkc1	TFS CR 55305 Task 55537 UI - Invoice List UI changes
// 26 Apr 2023  navmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
// 20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes
// 14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
// ---------------------------------------------------------------------------

vars
	
begin

	self.initialiseManual( _proxyInvoice.bank,
							_proxyInvoice.invoiceType,
							_proxyInvoice.debtor,
							_proxyInvoice.myBillingAddress, 	//22.07.2019 cnwma1 TFS #45577
							_proxyInvoice.myVoyage,
							_proxyInvoice.status,
							_proxyInvoice.myTrackedItem,
							_proxyInvoice.paymentType, 			//_paymentType		: Integer
							_proxyInvoice.myCurrencyType,		//_currencyType		: CM_CurrencyType	// ### TFS 54564 (54375) 18Aug2022 NAVPW1
							_proxyInvoice.myAlternativeAddress, //_altAddress		: CM_Address		// ### TFS 54564 (54375) 18Aug2022 NAVPW1
							_proxyInvoice.myLocale,				//_locale			: CM_Locale			// ### TFS 54564 (54375) 18Aug2022 NAVPW1
							_proxyInvoice.myBOL,				//_bol				: CM_BOL;			// ### TFS 54565 (54384) 03Oct2022 NAVPW1
							_proxyInvoice.myBookingRef,			//_booking			: CM_BookingRef;	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
							_proxyInvoice.myCargoGroup,			//_cargoGroup		: CM_CargoGroup;	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
							_proxyInvoice.myReleaseRequest,		//_releaseRequest	: CM_BulkRelease	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
							//_proxyInvoice.contractIds,			//contractIds		: String			// 19/01/2023   navvt20	TFS CR 55625 Task 55658		navtnr20 10-03-2021 56818
							_proxyInvoice.category,				//_category			: Integer			// 01/02/2023	navkc1	TFS CR 55305 TASK 55537
							_proxyInvoice.purchaseOrderNumber, // ### BUG 56925 07MAR2023 NAVAB1
							_proxyInvoice.myInvoiceProcess,		// 26.4.2023 namvk20 TFS 57663
							_proxyInvoice.allWorkOrders,			//navtnr20 23-05-2023 BUG 58089
							_proxyInvoice.fromDT,				//20/07/2023	navkc1	Bug 58995
							_proxyInvoice.narration,			//14/08/2023	navkc1	Bug 59803
							_proxyInvoice.termsOfTradeCode,		//14/08/2023	navkc1	Bug 59803
							_proxyInvoice.termsOfTrade,			//14/08/2023	navkc1	Bug 59803
							_proxyInvoice.debtorReference,		//14/08/2023	navkc1	Bug 59803
							_proxyInvoice.allCreditInvoices		//13/01/2025	navkc1 JIRA Bug MTN-33142
							
							);
end;</source>
        <Parameter name="_proxyInvoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="521390c1-8f1d-40b4-8e3a-9eb87ea3a420">
        <updating/>
        <source>setForUpdate(_proxyInvoice:CM_Invoice) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
// 18 Aug 2022	navpw1	TFS: 54564 (54375) - EUP - Inv Config - Debtor Currencies and Countries
// 19/01/2023	navvt20	TFS CR 55625 Task 55658: Jade - Contract Id TRX
// ---------------------------------------------------------------------------

vars

begin
	self.narration 			 	:= _proxyInvoice.narration;
	self.isZeroRatedTax 	 	:= _proxyInvoice.isZeroRatedTax;
	self.toDT 				 	:= _proxyInvoice.toDT;
	self.purchaseOrderNumber 	:= _proxyInvoice.purchaseOrderNumber;  	// cnwjk3 PAR 18434 - Date - 05/11/2008
	self.debtorReference 	 	:= _proxyInvoice.debtorReference;		// 28218 CCMS 2120 Sep 2011
	self.myBillingAddress	 	:= _proxyInvoice.myBillingAddress;
	self.myInvoiceNote		 	:= _proxyInvoice.myInvoiceNote;			// ### TFS 52752 03Feb2022 NAVPW1
	self.myCurrencyType		 	:= _proxyInvoice.myCurrencyType;		// ### TFS 54564 (54375) 18Aug2022 NAVPW1
	self.myLocale				:= _proxyInvoice.myLocale;				// ### TFS 54564 (54375) 18Aug2022 NAVPW1
	self.myAlternativeAddress 	:= _proxyInvoice.myAlternativeAddress;	// ### TFS 54564 (54375) 18Aug2022 NAVPW1
	//self.contractIds			:= _proxyInvoice.contractIds; 			// 19.01.2023   navvt20  TASK 55658	navtnr20 10-03-2021 56818
	self.termsOfTrade			:= _proxyInvoice.termsOfTrade;			//14/08/2023	navkc1	Bug 59803
	self.termsOfTradeCode		:= _proxyInvoice.termsOfTradeCode;		//14/08/2023	navkc1	Bug 59803
	self.debtor 				:= _proxyInvoice.debtor; 				//17/01/2023	navkc1 Bug 61503
	self.runPackages			:= _proxyInvoice.runPackages;			//navra1 - CR 61910/Task 62303 - 16th Feb 2024
end;</source>
        <Parameter name="_proxyInvoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateMoveLines" id="9171c8da-803b-4900-829e-7c03318fdde6">
        <updating/>
        <source>setForUpdateMoveLines(_controller : CMIF_InvoiceLineMove) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anInvoiceline : CM_InvoiceLine;
begin
	foreach anInvoiceline in _controller.allInvoiceLines do
		exclusiveLock(anInvoiceline);
		anInvoiceline.moveLineToInvoice(self);
	endforeach;

end;</source>
        <Parameter name="_controller" type="CMIF_InvoiceLineMove"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateSeparations" id="4aa525b5-f973-46ac-a0ea-18372c94f425">
        <updating/>
        <source>setForUpdateSeparations(_proxyInvoice:CM_Invoice) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2023  navmv20 Bug 58090: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 050.d

*/

vars
	cargoSpecific, 
	foundMatch		: Boolean;
	debtorRef		: String;
	vesselName,
	voyageCode		: String;
	debtorInvType	: CM_DebtorInvType;
	operator		: CM_Operator;
	now             : TimeStamp;
	finIOClass 		: CM_ExtFinanceIO;
	debtorSep : CM_InvTypeDebtorSeparation;
	
begin
	self.myBillingAddress   	:= _proxyInvoice.myBillingAddress;
	/*if _proxyInvoice.myWorkOrder &lt;&gt; null then		//navtnr20 31-05-2023 TFS 58089
		self.allWorkOrders.add(_proxyInvoice.myWorkOrder);	
	endif;*/
	self.allWorkOrders.clear();	//navtnr20 31-05-2023 TFS 58089
	_proxyInvoice.allWorkOrders.copy(allWorkOrders);	//navtnr20 31-05-2023 TFS 58089
	debtorSep := self.invoiceType.getDebtorSeparation(self.debtor);
	
	cargoSpecific := self.invoiceType.isCargoSpecificSeparation(debtorSep); 
	
	finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	
	if self.myTerminal.getConfig(InvShowAllSeparation).Boolean then
		 self.initialiseAllSeparations(self.debtor,_proxyInvoice.myVoyage,_proxyInvoice.myTrackedItem,_proxyInvoice.myBOL,_proxyInvoice.myBookingRef,_proxyInvoice.myCargoGroup,
										_proxyInvoice.myReleaseRequest,_proxyInvoice.purchaseOrderNumber);
		 self.debtorReference := _proxyInvoice.debtorReference;
	else 
		if self.invoiceType.isVoyageSpecificSeparation(debtorSep)
		or self.invoiceType.isVoyageGrpSpecificSeparation(debtorSep) then 
			if _proxyInvoice.myVoyage &lt;&gt; null then
				self.myVoyage 		 := _proxyInvoice.myVoyage;
				self.vesselName 	 := self.myVoyage.vesselName;
				self.voyageGroupCode := self.myVoyage.voyageGroupCode;
			endif;
		endif;
		if cargoSpecific then
			self.myTrackedItem := _proxyInvoice.myTrackedItem;
		endif;
		
		if self.invoiceType.isBOLSpecificSeparation(debtorSep)
			and _proxyInvoice.myBOL &lt;&gt; null
		then
			self.myBOL := _proxyInvoice.myBOL;
		endif;
		
		//separatedByBooking
		if self.invoiceType.isBookingSpecificSeparation(debtorSep)
			and _proxyInvoice.myBookingRef &lt;&gt; null
		then
			self.myBookingRef := _proxyInvoice.myBookingRef;
		endif;
	
		//separatedByCargoGroupId
		if self.invoiceType.isCargoGroupSpecificSeparation(debtorSep) 
			and _proxyInvoice.myCargoGroup &lt;&gt; null
		then
			self.myCargoGroup := _proxyInvoice.myCargoGroup;
			
		endif;
		
		//separatedByReleaseRequest
		if self.invoiceType.isReleaseSpecificSeparation(debtorSep) 
			and _proxyInvoice.myReleaseRequest &lt;&gt; null
		then
			self.myReleaseRequest := _proxyInvoice.myReleaseRequest;
		endif;
		
		if self.invoiceType.isPONumberSpecificSeparation(debtorSep) then 
			self.purchaseOrderNumber := _proxyInvoice.purchaseOrderNumber;
		endif;
	endif; 

    self.setDetailCode();

end;</source>
        <Parameter name="_proxyInvoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateStatus" id="f797b148-e45a-4993-88c6-5d625aa9b125">
        <updating/>
        <source>setForUpdateStatus(_status : CMIF_InvoiceStatus; _fromFutureActor : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		Change the invoice status with associated attributes
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 21/08/2015	cnwdap1		PAR #36909 CCMS ADP 2537 Minimum Charge changes
// 04/04/2018	jlgdap1		TFS 37560 PEL1 Prepend Invoice Status
// 09/04/2018	jlgdap1		TFS 37858 PEL1 Invoice Status Advancement
// 09/07/2018	jlgdap1		TFS 38641 PEL1 SAP Receive Document Cancellation
// 20 Aug 2018  cnwma1		ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
// 15 Nov 2018  cnwma1		Bug 41992: PEL1 - Disputed Invoice process
// 19 Nov 2018  cnwma1      Bug 42076: PEL1 - Invoice approval clock process
// 21 Jan 2019  cnwma1		ChangeRequest 42942: PEL1 - Container Services - SAP Process
// 21 Jan 2019  jlgdap1		TFS 42925 PEL1 Container Services - Estimation Approval Countdown
// 22 July 2019	cnwma1		ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
// 18 Oct 2019	jlgdi1		47063 Move Future Actor creation code in createFutureActor method
//							and create future actor for Additional Fee invoice
// 18 Aug 2022	navpw1		TFS: 54564 (54381) (54382) - EUP - Inv Config - Debtor Currencies and Countries
// 30/12/2022	navkc1		TFS CR 55300 TASK 55526 - Use of auto ID in Invoicing
// 09/02/2023	navkc1		Bug 56444: Jade - Country in Invoice/Credit note Auto Id
// 14/08/2023	navkc1		Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
// 06/12/2023	navra1		TFS 54090 CR - 61386/Task - 61564
// 15/01/2023	navkc1		ChangeRequest 59145 Task 61332: UI - Invoice Post
// 16/05/2024   navrv30     Bug 64076: InvoiceContractID is null on the External Web service message for the Invoice API
// 18 Feb 2025	navnk30		JIRA 34058: UT_Invoicing::tSnapshotBasic needs to be fixed
//20/06/2025	navcs2		MTN-34987 MTN -  Disable SAP Integration
vars 
	finIOClass 		: CM_ExtFinanceIO;
	now 			: TimeStamp;
	newStatus 		: Integer;
	term 			: CM_Terminal;	
	currentNumber,
	postedNumber	: String;
	oldStatus 		: Integer;
	invoiceStatus   : CM_InvoiceStatus;
	invoiceProcess  : CM_InvoiceProcess;
	linkStatusSet   : Boolean;
	invLines 		: CM_InvoiceLineSet;	//09 Apr 2019	NDL	TFS 44248
	category		: Integer;
	bank			: CM_Bank;
	invStaticData	: CM_InvStaticData;					//navra1 - CR 57933 - 6th Mar 2024
	invLineStaticData	: CM_InvLineStaticData;			//navra1 - CR 57933 - 6th Mar 2024
	bankName 		: String;							//navra1 - CR 57933 - 6th Mar 2024
	debtorName 		: String;							//navra1 - CR 57933 - 6th Mar 2024
	debtorLongName 	: String;							//navra1 - CR 57933 - 6th Mar 2024
	invoiceTypeDesc : String;							//navra1 - CR 57933 - 6th Mar 2024
	currencyTypeDesc : String;							//navra1 - CR 57933 - 6th Mar 2024
	localeDesc 		: String;							//navra1 - CR 57933 - 6th Mar 2024
	eachInvLine		: CM_InvoiceLine;			 		//navra1 - CR 57933 - 6th Mar 2024
	invLinesBySeq	: CM_InvoiceLineBySeqNumDict;		//navra1 - CR 57933 - 6th Mar 2024
	invoiceLineBankName : String;						//navra1 - CR 57933 - 6th Mar 2024
	invoiceLineDebtorName : String;						//navra1 - CR 57933 - 6th Mar 2024
	invoiceLineDescNarration : String;					//navra1 - CR 57933 - 6th Mar 2024
	invoiceContractID : String;							//navra1 - CR 57933 - 6th Mar 2024
	transactionDesc : String;							//navra1 - CR 57933 - 6th Mar 2024
begin

	now 	  := app.serverTimestampAtTrxStart;		// should be using the server timestamp
	oldStatus := self.status;
	newStatus := _status.newStatus;
	term 	  := self.myTerminal;
	bank	  := self.bank;		// 30/12/2022	navkc1	TFS CR 55300 TASK 55526
	
	invoiceStatus := self.getInvoiceStatusObject(newStatus); // TFS 39618
	invoiceProcess := invoiceStatus.myInvoiceProcess; // TFS 39618
	
	//04 Sep 2017	NDL	TFS 6759
	if newStatus = INVOICE_POSTED_CREDIT
	or newStatus = INVOICE_POSTED_REVERSE
	then
		//These status changes are part of specific return processing
		//Not allowed generically.
		if oldStatus = newStatus then
			//nothing to do.
			return;
		endif;
		//jlier1 19/9/24 TFS 65963 - 65949 NSW | Dynamic Integration Development
		if (oldStatus = INVOICE_POSTED_CREDIT_PENDING or oldStatus = INVOICE_POSTED_CREDIT_ERROR) and newStatus = INVOICE_POSTED_CREDIT then
			//continue on 
		else
		
			app.raiseCMException2( ERR_STATUS_CHANGE, app.getInvoiceStatusString(self.getMyInvoiceProcess, newStatus), null, null, null); 
			return;
		endif;
	endif;
	
	//record the person who changes the status to POSTED
	if newStatus = self.INVOICE_POSTED or newStatus = self.INVOICE_POSTED_PENDING then
		self.postingUser := app.getMyUserCode();
		
		//navra1 - CR 57933 - 6th Mar 2024 - start		
		self.initializeMyInvStaticData();

		invStaticData := self.getMyInvStaticData();
		
		invStaticData.setMyInvoice(self);
		
		if self.bank &lt;&gt; null then
			bankName 		:= self.bank.mailingName;
		endif;
		
		if self.debtor &lt;&gt; null then		
			debtorName 		:=  self.debtor.name;
			debtorLongName 	:= self.debtor.longName;
		endif;
		
		if self.invoiceType &lt;&gt; null then
			invoiceTypeDesc := self.invoiceType.description;
		endif;
		
		if self.myCurrencyType &lt;&gt; null then
			currencyTypeDesc := self.myCurrencyType.description;
		endif;
		
		if self.myLocale &lt;&gt; null then
			localeDesc 	:= self.myLocale.localeDescription;
		endif;
		
		invStaticData.setStaticFields(bankName, debtorName, debtorLongName, invoiceTypeDesc, self.getInvoiceTypeSpecifics(), currencyTypeDesc, localeDesc, self.contractIds);
		
		invLinesBySeq := self.invoiceLines;
		
		//10/02/2025	navkc1 JIRA Story MTN-33896
		if term &lt;&gt; null then
			finIOClass := term.getConfig(FinancialIOClass).CM_ExtFinanceIO;
		endif;
		
		foreach eachInvLine in invLinesBySeq do
			eachInvLine.initializeMyInvLineStaticData();
			
			invLineStaticData := eachInvLine.getMyInvLineStaticData();
			
			invLineStaticData.setMyInvoiceLine(eachInvLine);
			
			if eachInvLine.bank &lt;&gt; null then
				invoiceLineBankName := eachInvLine.bank.mailingName;
			endif;
			
			if eachInvLine.debtor &lt;&gt; null then
				invoiceLineDebtorName := eachInvLine.debtor.name;
			endif;
			
			if eachInvLine.invoiceLineDesc &lt;&gt; null then
				invoiceLineDescNarration := eachInvLine.invoiceLineDesc.narration;
			endif;			
			
			//16/05/2024 navrv30 Bug 64076
			invoiceContractID := eachInvLine.invoice.contractIds;
			
			
			if eachInvLine.myTransactionBOL &lt;&gt; null then
				transactionDesc		:= 	eachInvLine.myTransactionBOL.getTransactionDescription();				
			elseif eachInvLine.myTransactionEvent &lt;&gt; null then
				transactionDesc		:= 	eachInvLine.myTransactionEvent.getTransactionDescription();				
			elseif eachInvLine.myTransactionHMS &lt;&gt; null then
				transactionDesc		:= 	eachInvLine.myTransactionHMS.getTransactionDescription();				
			elseif eachInvLine.myTransactionTI &lt;&gt; null then
				transactionDesc		:= 	eachInvLine.myTransactionTI.getTransactionDescription();				
			elseif eachInvLine.myTransactionWO &lt;&gt; null then
				transactionDesc		:= 	eachInvLine.myTransactionWO.getTransactionDescription();				
			endif;			
			
			invLineStaticData.setStaticFields(invStaticData, invoiceLineBankName,invoiceLineDebtorName, invoiceLineDescNarration, invoiceContractID, transactionDesc);
			//11 September 2024	jlier1	65957 : CR 65949 NSW | Dynamics Integration - Financial Dimensions String
			if newStatus = self.INVOICE_POSTED_PENDING then
				//eachInvLine.setFinancialDimenions; //10/02/2025	navkc1 JIRA Story MTN-33896
				//10/02/2025	navkc1 JIRA Story MTN-33896
				if finIOClass &lt;&gt; null then
					finIOClass.setExternalReferences(eachInvLine);
				endif;
			endif;
		endforeach;
		
		//navra1 - CR 57933 - 6th Mar 2024 - end		
	endif;
	
	if invoiceProcess.isLinxProcess() then
		if self.status = self.INVOICE_PENDING_APPROVAL then	
			if newStatus = self.INVOICE_APPROVED then	
				self.setStatus( newStatus );
				linkStatusSet := true;
			 // ### JIRA 35465 28JUL2025 NAVAB1
			elseif newStatus = self.INVOICE_POSTED_DRAFT then
				self.setStatus( newStatus );
				linkStatusSet := true;
			elseif newStatus = self.INVOICE_VOID then
				self.setStatus( newStatus );
				linkStatusSet := true;
			endif;
		// ### JIRA 35468 29JUL2025 NAVAB1
		elseif self.status = self.INVOICE_POSTED_DRAFT then	
			if newStatus = self.INVOICE_APPROVED then	
				self.setStatus( newStatus );
				linkStatusSet := true;
			elseif newStatus = self.INVOICE_VOID then
				self.setStatus( newStatus );
				linkStatusSet := true;
			endif;
		elseif self.status = self.INVOICE_APPROVED then	
			if newStatus = INVOICE_POSTED then
				if self.getMyInvoiceProcess &lt;&gt; null and self.getMyInvoiceProcess.isLinxProcess then	//22 Mar 2019	NDL	TFS 43687
					self.createMovementMinCharge();
				endif;
				linkStatusSet := true;
				self.postAllCharges(null);
				self.postedDT := now;
				self.setStatus( newStatus );						//13 Jun 2018	NDL	TFS 39197
				self.toDT := _status.toDT;
				self.dueDate := _status.dueDate;
				self.narration := _status.narration[1:640];			// from 37141
				self.isZeroRatedTax := _status.isZeroRatedTax; 		// ### PAR 10186
				self.debtorReference := _status.debtorReference;	// 28218 CCMS 2120 Sep 2011
				if _status.myTermsOfTrade &lt;&gt; null then
					self.termsOfTradeCode := _status.myTermsOfTrade.code;
					self.termsOfTrade := _status.myTermsOfTrade.description;
				endif;
				self.purchaseOrderNumber := _status.purchaseOrderNumber;
				self.myLocale := _status.myLocale; //14/08/2023	navkc1	Bug 59803
				self.myAlternativeAddress := _status.myAlternativeAddress; //14/08/2023	navkc1	Bug 59803
				if _status.invoiceType &lt;&gt; null then
					self.invoiceType := _status.invoiceType; //14/08/2023	navkc1	Bug 59803
				endif;
				//28 Feb 2011	NDL	Par 27071
				if term = null and  app.myPassport &lt;&gt; null then
					term := app.myPassport.myTerminal;
				endif;
				if term = null then
					app.raiseCMException2(ERR_STATUS_CHANGE, self.sequenceNum.String, app.getErrorString(Null_terminal_reference) &amp; "[" &amp; method.qualifiedName &amp; "]" ,null, null);
					return;
				endif;
				finIOClass := term.getConfig(FinancialIOClass).CM_ExtFinanceIO;
				//end of 27071
				
				finIOClass.setInvoiceValues(self);					 // ### PAR 10171
				self.decfinBatchDate := now.date;					 // ### PAR 10171
				
				// 31905 separate posted invoice number
				// 36418 but not if already done at invoice creation as for ADP
				//currentNumber := self.getExternalInvoiceNumber;
				currentNumber := self.getExternalInvoiceNumberRaw;//15 Apr 2016	NDL	TFS 1849
				if currentNumber = null then
					postedNumber := finIOClass.setExternalInvoiceNumber(self);
					if postedNumber &lt;&gt; null then		// is implemented for this external financial system (Milaha and now ADP)
						self.setExternalInvoiceNumber(postedNumber);
					endif;
				endif;
				
				if _status.doExport then // XPOSE 1582 AKB2001NOV - set to -1 to auto export from the POST FORM
					self.exportedCount := 0; // XPOSE 1582 AKB2001NOV
				endif;
				
			elseif newStatus = INVOICE_VOID then		
				linkStatusSet := true;
				self.setStatus( newStatus );				//13 Jun 2018	NDL	TFS 39197
			endif;
		elseif self.status = self.INVOICE_POSTED then	// TFS 39618 PATCH 1
			if newStatus = self.INVOICE_APPROVEDRETURNED then	
				self.setStatus( newStatus );
				linkStatusSet := true;
			endif;
		endif;
	endif;
	
	if not linkStatusSet then
		if self.status = INVOICE_OPEN then
			//can go PENDING or VOID
			// TFS 37560 or PREPEND or DISPUTED
			if newStatus = INVOICE_PENDING then
				// ### JIRA 19932 21OCT2024 NAVAB1 self.setStatus( newStatus );						//13 Jun 2018	NDL	TFS 39197
				//self.checkForMinimumCharge();						// PAR #36909					//18.02.2025 navnk30 JIRA 34058
				
				//03 Apr 2018	NDL	TFS 37818
				// JLGAB1 13JUN18 - Surcharges are for all customers not just PELINDO. Surcharges are applied when the invoice is set to PREPEND (PEL1) or PENDING (JMT DEFAULT)
				//if self.myVoyage = null or self.myVoyage.isUsingDefaultProcessJMT then	// ### TFS 54565 (54385) 26Oct2022 NAVPW1 - Andrew decided that we charge surcharges regardless of voyage process
				self.applySurcharges();
				//endif;																	// ### TFS 54565 (54385) 26Oct2022 NAVPW1- Andrew decided that we charge surcharges regardless of voyage process
				
				self.myBillingAddress := _status.myBillingAddress;  //22.07.2019 cnwma1 TFS #45577
				
				// ### TFS 54564 (54381) 19Aug2022 NAVPW1
				if self.myInvoiceProcess &lt;&gt; null and self.myInvoiceProcess.code = InvoiceProcessDefault then //Only do this for the MTN Default Invoice Process
					self.myAlternativeAddress := _status.myAlternativeAddress; 
					finIOClass := term.getConfig(FinancialIOClass).CM_ExtFinanceIO;
					//14/08/2023	navkc1	Bug 59803 - Save more information if not ASPA
					if not finIOClass.isKindOf(CM_ASPAInterface) then
						if _status.myDebtor &lt;&gt; null then
							self.debtor := _status.myDebtor;
						endif;
						self.narration := _status.narration;
						self.debtorReference := _status.debtorReference;
						if _status.myTermsOfTrade &lt;&gt; null then
							self.termsOfTrade := _status.myTermsOfTrade.description;
							self.termsOfTradeCode := _status.myTermsOfTrade.code;
						endif;
						self.isZeroRatedTax := _status.isZeroRatedTax;
						self.toDT.setDate(_status.toDT.date());
						self.purchaseOrderNumber := _status.purchaseOrderNumber;
						self.myCurrencyType := _status.myCurrencyType;
						self.myLocale := _status.myLocale;
					endif;
				endif;
				// ### TFS 54564 (54381) 19Aug2022 NAVPW1
				
				self.setStatus( newStatus );// ### JIRA 19932 21OCT2024 NAVAB1
				self.checkForMinimumCharge();	//18.02.2025 navnk30 JIRA 34058
				
			//elseif newStatus = INVOICE_VOID then											// TFS 37560
			elseif newStatus.isOneOf(INVOICE_VOID, INVOICE_PREPEND, INVOICE_DISPUTED) then	// TFS 37560
				self.setStatus( newStatus );												//13 Jun 2018	NDL	TFS 39197
				
				// TFS 37858 if changing to INOICE_PREPEND, create a future actor 
				if newStatus = self.INVOICE_PREPEND then
				
					self.createMovementMinCharge();	//22 Mar 2019	NDL	TFS 43687
				
					// JLGAB1 13JUN18 - Surcharges are for all customers not just PELINDO. Surcharges are applied when the invoice is set to PREPEND (PEL1) or PENDING (JMT DEFAULT)
					//if self.myVoyage = null or not self.myVoyage.isUsingDefaultProcessJMT then	// ### TFS 54565 (54385) 26Oct2022 NAVPW1 - Andrew decided that we charge surcharges regardless of voyage process
					
					if self.paymentType &lt;&gt;  PaymentType_PrePay then   //21.01.2019 cnwma1 ChangeRequest #42942
						self.applySurcharges();
					endif;
					
					//endif;																		// ### TFS 54565 (54385) 26Oct2022 NAVPW1 - Andrew decided that we charge surcharges regardless of voyage process
					
					if self.myTerminal &lt;&gt; null then
						//if self.paymentType.isOneOf(PaymentType_AutoCollection, PaymentType_PrePay, PaymentType_PostPay) then	//02 Nov 2018	TFS 41769	// TFS 42925
						if self.paymentType.isOneOf(PaymentType_AutoCollection, PaymentType_PostPay) then	//02 Nov 2018	TFS 41769						// TFS 42925
							
							self.createFutureActor(self);
							
							// 18 Oct 2019 47063 jlgdi - create future actor for additional fee
							if self.myAdditionalFeesInvoice &lt;&gt; null then
								self.createFutureActor(self.myAdditionalFeesInvoice);
							endif;
						endif;
					endif;
				endif;
				// TFS 37858 end
			endif;
	
		elseif self.status = INVOICE_PENDING or self.status = INVOICE_POSTED_PENDING or self.status = INVOICE_POSTED_ERROR then			//navra1 - TFS 54090 CR - 61386/Task - 61564 - 6th Dec 2023
			//can go POSTED OR VOID
			if newStatus = INVOICE_POSTED or newStatus = INVOICE_POSTED_PENDING then													//navra1 - TFS 54090 CR - 61386/Task - 61564 - 21st Dec 2023
				if self.status &lt;&gt; INVOICE_POSTED_PENDING  then 											//navra1 - TFS 54090 CR - 61386/Task - 61564 - 21st Dec 2023 - Dont update attributes again if you are updating from INVOICE_POSTED_PENDING status
					if self.getMyInvoiceProcess = null or self.getMyInvoiceProcess.isDefaultProcessJMT then	//22 Mar 2019	NDL	TFS 43687
						self.createMovementMinCharge();
					endif;
					self.postAllCharges(null);
					self.postedDT := now;					
					self.toDT := _status.toDT;
					self.invoiceDate := _status.invoiceDate;													//navra1 - TFS 54090 CR - 61386/Task - 61564 - 21st Dec 2023
					self.dueDate := _status.dueDate;
					self.narration := _status.narration[1:640];			// from 37141
					self.isZeroRatedTax := _status.isZeroRatedTax; 		// ### PAR 10186
					self.debtorReference := _status.debtorReference;	// 28218 CCMS 2120 Sep 2011
					if _status.myTermsOfTrade &lt;&gt; null then
						self.termsOfTradeCode := _status.myTermsOfTrade.code;
						self.termsOfTrade := _status.myTermsOfTrade.description;
					endif;
					self.purchaseOrderNumber := _status.purchaseOrderNumber;
					self.myLocale := _status.myLocale; //14/08/2023	navkc1	Bug 59803
					self.myAlternativeAddress := _status.myAlternativeAddress; //14/08/2023	navkc1	Bug 59803
					self.myBillingAddress := _status.myBillingAddress; //14/08/2023	navkc1	Bug 59803
					if _status.invoiceType &lt;&gt; null then
						self.invoiceType := _status.invoiceType; //14/08/2023	navkc1	Bug 59803
					endif;
				
					
					//28 Feb 2011	NDL	Par 27071
					if term = null and  app.myPassport &lt;&gt; null then
						term := app.myPassport.myTerminal;
					endif;
					if term = null then
						app.raiseCMException2(ERR_STATUS_CHANGE, self.sequenceNum.String, app.getErrorString(Null_terminal_reference) &amp; "[" &amp; method.qualifiedName &amp; "]" ,null, null);
						return;
					endif;
					finIOClass := term.getConfig(FinancialIOClass).CM_ExtFinanceIO;
					//end of 27071
					
					finIOClass.setInvoiceValues(self);					 // ### PAR 10171
					self.decfinBatchDate := now.date;					 // ### PAR 10171
					
					// 31905 separate posted invoice number
					// 36418 but not if already done at invoice creation as for ADP
					//currentNumber := self.getExternalInvoiceNumber;
					currentNumber := self.getExternalInvoiceNumberRaw;//15 Apr 2016	NDL	TFS 1849
					if currentNumber = null then
						postedNumber := finIOClass.setExternalInvoiceNumber(self);
						if postedNumber &lt;&gt; null then		// is implemented for this external financial system (Milaha and now ADP)
							self.setExternalInvoiceNumber(postedNumber);
						endif;
					endif;
					
					if _status.doExport then // XPOSE 1582 AKB2001NOV - set to -1 to auto export from the POST FORM
						self.exportedCount := 0; // XPOSE 1582 AKB2001NOV
						// TFS 1930 May 2016 do the export after the transaction so it is not repeated from a deadlock
						// DO all of the other posting-related updates here still
						///finIOClass.export(self); // ### PAR 10171. localised
					endif;
					
					// ### TFS 54564 (54382) 22Aug2022 NAVPW1
					if self.myInvoiceProcess &lt;&gt; null and self.myInvoiceProcess.code = InvoiceProcessDefault then //Only do this for the MTN Default Invoice Process
						self.myCurrencyType := _status.myCurrencyType; 
					endif;
					// ### TFS 54564 (54382) 22Aug2022 NAVPW1
					
				endif;															//navra1 - TFS 54090 CR - 61386/Task - 61564 - 21st Dec 2023 - Dont update attributes again if you are updating from INVOICE_POSTED_PENDING status
				// 30/12/2022	navkc1	TFS CR 55300 TASK 55526 starts
				//jlier1 TFS 65959 17/9/24 need to also set this on posted pending to send in invoice api for NSW
				if bank &lt;&gt; null then
					category := self.category;
					if self.externalNumber = null then										//navra1 - TFS 54090 - CR 61386/Task 61564 - 15th Dec 2023 - dont change it if you already set it while moving to POSTED_PENDING
						if category = InvoiceCategory_Invoice then
							self.externalNumber := bank.generateNextInvExtNumber();
						elseif category = InvoiceCategory_CreditNote then
							self.externalNumber := bank.generateNextCrdExtNumber();
						endif;
					endif;																	//navra1 - TFS 54090 - CR 61386/Task 61564 - 15th Dec 2023 - dont change it if you already set it while moving to POSTED_PENDING
				endif;
				// 30/12/2022	navkc1	TFS CR 55300 TASK 55526 ends
				
				self.setStatus( newStatus );		//13 Jun 2018	NDL	TFS 39197			//navra1 - TFS 54090 CR - 61386/Task - 61564 - 21st Dec 2023 - Update the status but not the other attributes
			elseif newStatus = INVOICE_VOID then		
				self.setStatus( newStatus );							//13 Jun 2018	NDL	TFS 39197				
			elseif newStatus = INVOICE_POSTED_ERROR then				//navra1 - TFS 54090 CR - 61386/Task - 61564 - 30th Nov 2023
				self.setStatus(newStatus);								//navra1 - TFS 54090 CR - 61386/Task - 61564 - 30th Nov 2023				
			endif;		
		elseif self.status = INVOICE_SUSPENSE then							//Par17895. September 2008
			//can only go VOID
			if newStatus = INVOICE_VOID then
				self.setStatus( newStatus );			//13 Jun 2018	NDL	TFS 39197
			endif;
	
		elseif self.status = INVOICE_VOID then
			//can go PENDING or SUSPENSE
			if newStatus = INVOICE_PENDING then
				self.setStatus( newStatus );			//13 Jun 2018	NDL	TFS 39197
			elseif newStatus = INVOICE_SUSPENSE then	// Par 17895. Ssp 2008
				self.setStatus( newStatus );			//13 Jun 2018	NDL	TFS 39197
			endif;
			
		elseif self.status = self.INVOICE_PREPEND then						// TFS 37560
			// can go PENDING or DISPUTED									// TFS 37560
			if newStatus = self.INVOICE_PENDING then						// TFS 37560
			
				self.setStatus( newStatus );								//13 Jun 2018	NDL	TFS 39197

			elseif newStatus = self.INVOICE_DISPUTED then					// TFS 37560
			
				self.setStatus( newStatus );								//13 Jun 2018	NDL	TFS 39197
				
				/*
					19.11.2018 cnwma1 Bug #42076
					if the Customer Change the invoice From Prepend to Disputed 
					We should delete any future actor to stop the automation of chaning the invoice to pending.
					This will be Pelindo officer responsibility 
				*/
				if  not _fromFutureActor then
					app.myRoot.deleteFutureActor(self, CM_InvoiceStatusAdvanceProcess);
				endif;
				
			elseif newStatus = self.INVOICE_VOID then						// TFS 38641
				self.setStatus( newStatus );								// TFS 38641
				
			endif;															// TFS 37560
		elseif self.status = self.INVOICE_DISPUTED then						// TFS 37560
			// can go PENDING or PREPEND									// TFS 37560
			if newStatus = self.INVOICE_PENDING then						// TFS 37560
				
				self.setStatus( newStatus );								//13 Jun 2018	NDL	TFS 39197
			
			elseif newStatus = self.INVOICE_VOID then						// TFS 38641
				self.setStatus( newStatus );								// TFS 38641
			endif;															// TFS 37560
		elseif self.status = self.INVOICE_POSTED_CREDIT_ERROR then
			//jlier1 19/9/24 TFS 65963 - 65949 NSW | Dynamic Integration Development
			if newStatus = self.INVOICE_POSTED_CREDIT or newStatus = self.INVOICE_POSTED_CREDIT_PENDING  then
				self.setStatus(newStatus);
			endif;
		elseif self.status = self.INVOICE_POSTED_CREDIT_PENDING then
			//jlier1 19/9/24 TFS 65963 - 65949 NSW | Dynamic Integration Development
			if newStatus = self.INVOICE_POSTED_CREDIT_ERROR or newStatus = self.INVOICE_POSTED_CREDIT then
				self.setStatus(newStatus);
			endif;
		endif;
	endif;
	// TFS 37858 if new status is pending, then delete any future actors for status change
	if newStatus = self.INVOICE_PENDING and not _fromFutureActor then
		app.myRoot.deleteFutureActor(self, CM_InvoiceStatusAdvanceProcess);
	endif;
	// TFS 37858 end

	/*
		15.11.2018 cnwma1 BUG #41992
		37189.004 Send Release Hold and Debit for Auto-Collection Customer
		WSDL 1.2: Auto-Collection - Release Hold/Debit                         
		PaymentType_AutoCollection
		
		21.8.2018 cnwma1 TFS #39698
		37189.005 Send Invoice / Data for Auto-Collection Customer
		WSDL 1.3: Auto-Collection - Revenue Journal + Incoming Cash Journal    
		PaymentType_AutoCollection
		
		
		37189.006 Send Invoice/Data for Pre-Billing Customer                   
		WSDL 1.5: Pre-Billing - Revenue Journal + Incoming Cash Journal
		
		37189.007 Send Invoice/Data for Post-Billing Customer
		WSDL 1.7: Post-Billing - Billing Payment Process
					
		23.01.2019 cnwma1 TFS #42942
		37189.010 Cancel Payment Code
		WSDL 1.11: Pre-Billing - Cancellation                                  INVOICE_PREPEND,INVOICE_VOID
		
		WSDL Payment_Type 				 Old Status 		New Status         GenerateTax	Replacement    Payment Status
		1.2  PaymentType_AutoCollection  INVOICE_PREPEND    INVOICE_PENDING
		1.2  PaymentType_AutoCollection  INVOICE_DISPUTED   INVOICE_PENDING
		1.3  PaymentType_AutoCollection  INVOICE_PENDING    INVOICE_POSTED
		1.4  PaymentType_PrePay          INVOICE_OPEN       INVOICE_PREPEND
		1.5  PaymentType_PrePay          INVOICE_PREPEND    INVOICE_PENDING
		1.7  PaymentType_PostPay         INVOICE_PREPEND    INVOICE_PENDING		Yes
		1.7  PaymentType_PostPay         INVOICE_PENDING    INVOICE_POSTED					Yes
		1.7  PaymentType_PostPay         INVOICE_PENDING    INVOICE_POSTED									Paid
		1.7  PaymentType_PostPay         INVOICE_DISPUTED   INVOICE_PENDING		Yes							
		1.11 PaymentType_PrePay          INVOICE_PREPEND    INVOICE_VOID
		1.12 PaymentType_PrePay          INVOICE_PENDING    INVOICE_POSTED
	*/

	//self.sendSAP(oldStatus,newStatus);
	//create invLines transient;					//09 Apr 2019	NDL	TFS 44248				//20/06/2025		navcs2		MTN-34987
	//self.invoiceLines.copy( invLines );			//09 Apr 2019	NDL	TFS 44248				//20/06/2025		navcs2		MTN-34987
	//self.sendSAP(oldStatus,newStatus,invLines);	//09 Apr 2019	NDL	TFS 44248				//20/06/2025		navcs2		MTN-34987
	
	// TFS 39618 PATCH 1 invoiceStatus.processStatus(self); // TFS 39618
	
epilog
	// from 37141 testing, only do this if still in trans state and not from an exception
	if process.isInTransactionState and
	   oldStatus &lt;&gt; newStatus then
		self.doAuditInvStatusChanged(_status,oldStatus); //epr par 36958 30/9/15
	endif;
	//delete invLines;	//09 Apr 2019	NDL	TFS 44248		//23/06/2025		navma1		MTN-34987
end;</source>
        <Parameter name="_status" type="CMIF_InvoiceStatus"/>
        <Parameter name="_fromFutureActor" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateWeb" id="3c8ec85a-5016-4549-a106-6575bac882d1">
        <updating/>
        <source>setForUpdateWeb(_description: String; _proxyInvoice:CM_Invoice) updating;
/*

Purpose:	

	Sets additional values for TAS invoices

Parameters:		

	_proxyInvoice : the proxy invoice to use to set the values on the real invoice

Return Value:		

	None

Date		Who		Reason
06/06/2023	navcs2	ChangeRequest 56901: [58447]: TAS Invoicing Invoice Endpoint - JADE changes
22/01/2023	navkc1 	CR 62038 Task 62039: Jade - Invoice API Context
26/05/2025	navpw1	JIRA: MTN-34644 - self.allCreditInvoices is populated in the iniaitlize &amp; set for create method which can be called before this one.
										Therefore a tryCopy was added to avoid adding duplciates into the collection.
*/

vars

begin
	self.exportCurrencyCode 	:= _proxyInvoice.exportCurrencyCode;
	self.dueDate	  			:= _proxyInvoice.dueDate;
	self.narration 				:= _description;
	self.myOtherInvoice 		:= _proxyInvoice.myOtherInvoice;
	self.context				:= _proxyInvoice.context; //22/01/2023	navkc1 CR 62038 Task 62039
	_proxyInvoice.allCreditInvoices.tryCopy(self.allCreditInvoices); //16/10/2024	navkc1	JIRA Bug MTN-12541 // ### JIRA: MTN-34644 26May2025 NAVPW1 - tryCopy does the same as copyNoDups, it skips over duplicates
epilog

end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_proxyInvoice" type="CM_Invoice"/>
    </JadeMethod>
