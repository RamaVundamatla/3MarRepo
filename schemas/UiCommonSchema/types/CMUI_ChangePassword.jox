    <JadeMethod name="translateForm" id="3ac5d889-b884-432b-b1d1-67c720837880">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007311, locale);
	btnCancel.translateCaption(Xlat_0000248, locale);
	btnOK.translateCaption(Xlat_0000249, locale);
	lblNewPassword.translateCaption(Xlat_0000246, locale);
	lblNewPassword2.translateCaption(Xlat_0000245, locale);
	lblOldPassword.translateCaption(Xlat_0000247, locale);
	lblUserName.translateCaption(Xlat_0000250, locale);
end;</source>
    </JadeMethod>
</GUIClass>
