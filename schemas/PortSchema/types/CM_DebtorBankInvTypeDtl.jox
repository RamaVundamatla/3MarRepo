    <JadeMethod name="auditIdDisplay" id="ea0da64c-2f18-4e4b-9b71-90ede7d52948">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2016	cnwma1	Initial creation

*/

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars

begin
	if self.auditId() &lt;&gt; null then
		return app.getFormCaptionsString(Xlat_0015107) &amp; ' - ' &amp; self.auditId();
	else
		return app.getString(Xlat_0015107);
	endif;
	
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
