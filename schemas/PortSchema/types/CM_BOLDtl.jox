    <JadeMethod name="increaseItemQuantity" id="41c55b66-3f1c-43b9-8beb-021fc2fa0181">
        <updating/>
        <source>increaseItemQuantity(_ti : CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2022	navhl20	ChangeRequest 54979: EUP - Cargo Work Orders Enhancements

*/

vars

begin
	self.quantity := self.quantity + _ti.totalQuantity;
	self.volume := self.volume + _ti.totalVolume;
	self.weight := self.weight + _ti.totalWeight;
epilog

end;</source>
