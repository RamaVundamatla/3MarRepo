    </JadeMethod>
    <JadeMethod name="sysNotify" id="9c3f8e8d-37fd-4f76-b33f-27a8e3c944e5">
        <controlMethod name="ComboBox::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>sysNotify(combobox: ComboBox input; eventType: Integer; theObject: Object; eventTag: Integer) updating, clientExecution;
/*
----------   ----------  --------------------------------------------------
Created:	09 August 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	consign			: CM_ConsigneeConsignor;
	idx				: Integer;
	displayStr		: String;
begin
	inheritMethod(combobox, eventType, theObject, eventTag);
	
	if not CM_ConsigneeConsignor.hasInstance(theObject) then
		return;
	endif;
	consign := theObject.CM_ConsigneeConsignor;
	
	if eventType = Object_Create_Event or eventType = Object_Update_Event then
		idx := self.findObject(consign);
		if idx &lt; 1 then
			displayStr := self.displayEntry(self, consign, null);//listIndex param not used so OK to be null
			if displayStr = null then
				return;
			endif;
			self.itemObject[self.addItem(displayStr)] := consign;
		else
			displayStr := self.displayEntry(self, consign, null);//listIndex param not used so OK to be null
			if displayStr = null then
				return;
			endif;
			self.itemText[idx] := displayStr;
		endif;
		
	
	elseif eventType = Object_Delete_Event then
		idx := self.findObject(consign);
		if idx &gt; 1 then
			self.removeItem(idx);
		endif;
	endif;

end;


</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
