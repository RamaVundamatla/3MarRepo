    <JadeMethod name="populateLogEntries" id="f18c8b34-20f9-4402-b524-f6f848d093c3">
        <source>populateLogEntries();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 March 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	rawStr : String;
	pos : Integer;
	logLevel : Integer;
	logString : String;
	lastLevel : Integer;
	newIndex : Integer;
	parentIndex : Integer;
	turnOffLines : Boolean;

begin

	lastLevel := 1;
	
	if self.myResult &lt;&gt; null and self.myResult.log &lt;&gt; null and not self.myResult.log.isEmpty then
		self.myResult.log.copy( self.myLog );
	endif;
	
	turnOffLines := true;

	foreach rawStr in self.myLog do
		pos := rawStr.pos(",",1);
		if pos &lt; 1 or pos &gt; 5 then
			logLevel := 99;
			logString  := rawStr.trimBlanks;
		else
			logLevel := rawStr[1: pos - 1].trimBlanks.Integer;
			logString  := rawStr[pos + 1:end].trimBlanks;
			turnOffLines := false;
		endif;
		
		if logLevel = AP_Log_YA_Default then	//99
			// default behaviour, i.e. which means add at the same level as the last add.
			newIndex := self.lstLogEntries.addItem( logString );
			self.lstLogEntries.itemLevel[newIndex] := lastLevel;
			if global.cnwer1 then
				if logString.pos("matched",1) &gt; 1 then
					self.lstLogEntries.itemForeColor[newIndex] := Green;
				endif;
			endif;
		elseif logLevel = AP_Log_YA_Global then	//0
			//Unconditionally at the top level.
			newIndex := self.lstLogEntries.addItem( logString );
			self.lstLogEntries.itemLevel[newIndex] := 1;
			lastLevel := 1;
		elseif logLevel = AP_Log_YA_Match then	//2
			//At level 2 , these are the match details and should be under the Allocation name
			newIndex := self.lstLogEntries.addItem( logString );
			self.lstLogEntries.itemLevel[newIndex] := 2;
			lastLevel := 2;
			
		elseif logLevel = AP_Log_YA_No_Match then	//3
			//At level 2 , these are the non match details and should be under the Allocation name
			newIndex := self.lstLogEntries.addItem( logString );
			self.lstLogEntries.itemLevel[newIndex] := 2;
			self.lstLogEntries.itemForeColor[newIndex] := Red;
			parentIndex := self.lstLogEntries.getParentRow(newIndex);
			self.lstLogEntries.itemForeColor[parentIndex] := Black;
			lastLevel := 2;
		elseif logLevel = AP_Log_YA_No_Space then	//4
			//At level 2 , these are the non match details and should be under the Allocation name
			newIndex := self.lstLogEntries.addItem( logString );
			self.lstLogEntries.itemLevel[newIndex] := 2;
			self.lstLogEntries.itemForeColor[newIndex] := Red;
			parentIndex := self.lstLogEntries.getParentRow(newIndex);
			if self.lstLogEntries.itemText[parentIndex].pos("No Space",1) &lt; 1 then
				self.lstLogEntries.itemText[parentIndex] := self.lstLogEntries.itemText[parentIndex] &amp; " - No Space";
			endif;
			lastLevel := 2;
		elseif logLevel = AP_Log_YA_Name then	//1
			//At the top level.  (Allocation name)
			newIndex := self.lstLogEntries.addItem( logString );
			self.lstLogEntries.itemLevel[newIndex] := 1;
			self.lstLogEntries.itemForeColor[newIndex] := Green;
			lastLevel := 1;
		else
			// default behaviour, i.e. which means add at the same level as the last add.
			newIndex := self.lstLogEntries.addItem( logString );
			
			self.lstLogEntries.itemLevel[newIndex] := lastLevel;
			
		endif;
	endforeach;
	
	if turnOffLines then
		self.lstLogEntries.hasTreeLines := false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f0c6760d-3ae5-4372-aac2-7e9d851d268d">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 March 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	invalid : Boolean;
	str : String;

begin

	self.isBaseFormModal := true;
	if self.myTrackedItem &lt;&gt; null then
		self.caption := app.getErrorString1(Test_auto_plan_log_for, self.myTrackedItem.id);
	elseif self.myResult &lt;&gt; null and self.myResult.myTrackedItem &lt;&gt; null then
		self.caption := app.getErrorString1(Test_auto_plan_log_for, self.myResult.myTrackedItem.id);
	elseif self.details &lt;&gt; null then
		self.caption := app.getErrorString1(Test_auto_plan_log_for, self.details);
	elseif myLinkedObject &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, self.myLinkedObject, invalid );
		if self.myLinkedObject.isKindOf( CM_DeliveryRequest ) then
			str := self.myLinkedObject.CM_DeliveryRequest.deliveryNumber;
			if not invalid and str &lt;&gt; null then
				self.caption := app.getErrorString1(Test_auto_plan_log_for, str);
			endif;
		endif;
	endif;

	inheritMethod();
	
	self.populateLogEntries();
	self.centreOverParent(1);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="fa71be93-8757-42a1-8ec3-953dc4c83965">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018868, locale);
	btnClose.translateCaption(Xlat_0018869, locale);
	btnFile.translateCaption(Xlat_0018870, locale);
end;</source>
    </JadeMethod>
</GUIClass>
