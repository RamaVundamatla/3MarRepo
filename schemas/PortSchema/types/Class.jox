    <JadeMethod name="firstNonAbstractSubclass" id="7d20d257-dd61-4d98-937e-919012909f6f">
        <source>firstNonAbstractSubclass() : Class;
/*
----------   ----------  --------------------------------------------------
Created:	01 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	subCls			: Class;
begin
	if not self.abstract then
		return self;
	endif;
	
	foreach subCls in self.subclasses where (not subCls.abstract) do
		return subCls;
	endforeach;

	return self;
end;


</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getAllSubclassesAnywhere" id="9d097377-2638-47dd-883c-ba0edb7d2b05">
        <source>getAllSubclassesAnywhere(_classes : ClassNDict input);
// ---------------------------------------------------------------------------
// Created:     13 March 2006 by cnwrs2
//
// Purpose:     Returns sub-classes in current schema and any sub-schemas
// ---------------------------------------------------------------------------
vars
	cc	: ClassColl;

begin

	create cc transient;
	self.allSubclasses(cc);
	self.allSubclassesInSubschemas(cc);
	
	cc.copy(_classes);

epilog
	delete cc;

end;</source>
        <Parameter name="_classes" type="ClassNDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMethodsInFullTree" id="b1a8650d-e298-4489-939e-fb86a055579e">
        <source>getMethodsInFullTree(name: String; methds: MethodSet input);

vars
	methd:              Method;
	subclass:           Class;
begin
	methd := getMethodInHTree(name);

	if methd &lt;&gt; null then
		// if method exists in this or super class then there is no
		// need to search subclasses.
		methds.add(methd);
	else
		getMethodsInSubclasses(methds);
		foreach methd in methds do
			if methd.name &lt;&gt; name then
				methds.remove(methd);
			endif;
		endforeach;
	endif;

end;</source>
        <Parameter name="name" type="String"/>
        <Parameter name="methds" type="MethodSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMethodsInSubclasses" id="7f5c4a56-c25d-46bd-a627-ecc7308b5f8c">
        <source>getMethodsInSubclasses(methds: MethodSet input);

vars
	subclass:           Class;
	allsubs:            ClassColl;
begin
	create allsubs transient;

	allSubclasses(allsubs);

	foreach subclass in allsubs do
		subclass.methods.copy(methds);
	endforeach;

epilog
	delete allsubs;
end;</source>
        <Parameter name="methds" type="MethodSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMethodsOnlyInSuperclass" id="69cd8ab6-ffc7-4c54-8aeb-c8be5cadd574">
        <source>getMethodsOnlyInSuperclass(_methdsSet: MethodSet input);
// ---------------------------------------------------------------------------
// Created:     Jan 2005		cnwrs1	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	methodDict: MethodNDict;
	cls: Class;
	mth: Method;
begin
	if _methdsSet = null then
		return;
	endif;
	create methodDict transient;
	cls := self.getSuperclass;
	if cls = null then
		return;
	endif;
	while cls.name &lt;&gt; Object.name do
		methodDict.clear;
		cls.getMethods(methodDict);
		foreach mth in methodDict do
			if not _methdsSet.includes(mth) then
				_methdsSet.add(mth);
			endif;
		endforeach;
		cls := cls.getSuperclass;
	endwhile;
epilog
	delete methodDict;
end;</source>
        <Parameter name="_methdsSet" type="MethodSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getNiceName" id="8a64f001-7dfb-49e3-8810-1780b0276708">
        <source>getNiceName(): String;
//----------------------------------------------------------------
//	Created:	22 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	startPos	: Integer;
	myName		: String;
begin
	myName :=  self.name;
	startPos := myName.pos("_",1) + 1;
	
	return myName[startPos:end];

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPropertiesAllSuperclass" id="46a766d7-8a0c-45b5-b530-3869edf097f2">
        <source>getPropertiesAllSuperclass(_propertyDict : PropertyNDict input);
// ---------------------------------------------------------------------------
// Created:     27 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	propDict		: PropertyNDict;
	cls				: Class;
begin
	if (_propertyDict = null)then
		return;
	endif;
	cls := self;
	while cls.name &lt;&gt; Object.name do
		propDict := cls.getProperties();
		propDict.copy(_propertyDict);
		cls := cls.getSuperclass;
	endwhile;

end;</source>
        <Parameter name="_propertyDict" type="PropertyNDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getPropertiesInFullTree" id="1e2f1378-4edf-40ee-8686-8b87e7a2d097">
        <source>getPropertiesInFullTree(name: String; props: PropertySet input);

vars
	property:           Property;
	subclass:           Class;
begin
	property := getPropertyInHTree(name);

	if property &lt;&gt; null then
		// if property exists in this or super class then there is no
		// need to search subclasses.
		props.add(property);
	else
		getPropertiesInSubclasses(props);
		foreach property in props do
			if property.name &lt;&gt; name then
				props.remove(property);
			endif;
		endforeach;
	endif;

end;</source>
        <Parameter name="name" type="String"/>
        <Parameter name="props" type="PropertySet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getPropertiesInSubclasses" id="0fa5a30f-51eb-4fb7-b13f-919f2f4675e5">
        <source>getPropertiesInSubclasses(props: PropertySet input);

vars
	subclass:           Class;
	allsubs:            ClassColl;
begin
	create allsubs transient;

	allSubclasses(allsubs);

	foreach subclass in allsubs do
		subclass.properties.copy(props);
	endforeach;

epilog
	delete allsubs;
end;</source>
        <Parameter name="props" type="PropertySet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getPropertiesOnlyInSuperclass" id="e63933b0-a0a3-4353-bff3-100d2c1c438c">
        <source>getPropertiesOnlyInSuperclass(_propertyDict : PropertyNDict input);
// ---------------------------------------------------------------------------
// Created:     Jan 2005		cnwrs1	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	propDict: PropertyNDict;
	cls: Class;
begin
	if _propertyDict = null then
		return;
	endif;
	cls := self.getSuperclass;
	if cls = null then
		return;
	endif;
	while cls.name &lt;&gt; Object.name do
		propDict := cls.getProperties();
		propDict.copy(_propertyDict);
		cls := cls.getSuperclass;
	endwhile;

end;</source>
        <Parameter name="_propertyDict" type="PropertyNDict" usage="input"/>
    </JadeMethod>
