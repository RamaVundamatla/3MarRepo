    <JadeMethod name="doClickAdd" id="7aaa3cb8-a562-4e8f-b9a6-a3a64e487469">
        <source>doClickAdd();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2015	cnwndl1	Initial creation	Par 36993

*/

vars

	id : String;
	msg : String;
	rows : Integer;
	rowIndex : Integer;
	tiToDoTask : CM_TiToDoTask;
	rowText : String;
	firstPartMatch : Integer;
	idLength : Integer;

begin

	self.tblAvailable.topRow := 1; 
	
	id := self.txtCargoId.text.trimBlanks.toUpper;
	
	if id = null or id = self.lblCargoId.caption.toUpper then
		msg := app.getErrorString(NO_Cargo_ID_entered);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	idLength := id.length;
	rows := self.tblAvailable.rows;
	foreach rowIndex in 1 to rows do
		rowText := self.tblAvailable.accessCell(rowIndex,1).text;
		if rowText = id then
			tiToDoTask := self.tblAvailable.accessRow(rowIndex).itemObject.CM_TiToDoTask;
			if tiToDoTask &lt;&gt; null then
				self.selectTiToDoTask( tiToDoTask );
				return;
			endif;
		elseif firstPartMatch = 0 and rowText.length &gt;= idLength and rowText[1:idLength] = id then
			firstPartMatch := rowIndex;
		endif;
	endforeach;
	
	if firstPartMatch &gt; 0 then
		self.tblAvailable.topRow := firstPartMatch;
		self.tblAvailable.row := firstPartMatch; 
	endif;
	
	msg := app.getErrorString2(Cargo_not_found_with_task, id, cmbTasks.text);
	app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickTableRow" id="41ad975b-4d98-42ef-b450-e90e257c8bac">
        <source>doClickTableRow( table: Table input )protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2015	cnwndl1	Initial creation	Par 36993

*/

vars

	rowIndex : Integer;
	tiToDoTask : CM_TiToDoTask;

begin

	rowIndex := table.row;
	tiToDoTask := table.accessRow(rowIndex).itemObject.CM_TiToDoTask;
	
	if tiToDoTask = null then
		return;
	endif;

	if table = self.tblSelected then
		self.unSelectTiToDoTask( tiToDoTask, true );
	elseif table = self.tblAvailable then
		self.selectTiToDoTask( tiToDoTask );
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doComplete" id="737a233f-5ab3-447b-8bf0-be974f52d86e">
        <source>doComplete():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2015	cnwndl1	Initial creation	Par 36993

*/

vars

	localSet : CM_TiToDoTaskSet;
	tiToDoTask : CM_TiToDoTask;
	toDoTaskDesc : CM_ToDoTaskDesc;
	rows : Integer;
	rowIndex : Integer;
	msg : String;
	
	resourceTypeForm : MOB_ResourceTypeUsageForm;
	localTiSet : CM_TISet;
	result : Integer;
	
	handlingType : CM_HandlingType;
	ti : CM_TrackedItem;
	
begin

	create localSet transient;
	create localTiSet transient;
	
	self.allNewProxyResourceTypeUsages.purge();
	
	rows := self.tblSelected.rows;
	foreach rowIndex in 1 to rows do
		tiToDoTask := self.tblSelected.accessRow(rowIndex).itemObject.CM_TiToDoTask;
		if tiToDoTask &lt;&gt; null then
			localSet.add( tiToDoTask );
			localTiSet.add( tiToDoTask.myTrackedItem );
		endif;
	endforeach;
	
	if localSet.isEmpty or localTiSet.isEmpty then
		msg := app.getErrorString(NO_Items_selected);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	toDoTaskDesc := localSet.first.toDoTaskDesc;
	if toDoTaskDesc = null then
		msg := app.getErrorString(ERR_INVALID_TODOTASKDESCR);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if not toDoTaskDesc.allResourceTypes.isEmpty then
	
		//18 Apr 2017	NDL	TFS 3414
		foreach ti in localTiSet do
			handlingType := ti.getHandlingType;
			if handlingType &lt;&gt; null and not handlingType.isPallet then
				handlingType := null;
			endif;
			if handlingType &lt;&gt; null then
				//we ahave at least one that may require pallet details
				break;
			endif;
		endforeach;
	
		//collect up a template of the resources used
		create resourceTypeForm transient;
		resourceTypeForm.myToDoTask := toDoTaskDesc;
		resourceTypeForm.setTemplateOnly( true, self );
		resourceTypeForm.doNotCentreWindow := true; 
		resourceTypeForm.move(self.left, self.top, self.width, self.height );
		resourceTypeForm.myHandlingType := handlingType;	//18 Apr 2017	NDL	TFS 3414
		resourceTypeForm.showModal();
		if resourceTypeForm.modalResult &lt;&gt; IDOK then
			return false;
		endif;
		
	endif;
	
	//process a new transaction for each of teh tis, passing in teh todo's and resources.
	while true do	
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk( toDoTaskDesc, localTiSet, self.allNewProxyResourceTypeUsages, app.myPassport );
		
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			return true;
		else
			//If there were warnings, give the user a chance to see them. If there are no _errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog("", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;

epilog

	delete localSet;
	delete resourceTypeForm;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="223fb85d-d5f8-49e2-b4bc-ba73e409c750">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2015	cnwndl1	Initial creation	Par 36993

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;

begin
	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cHeight := stdHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.cmbTasks.setAndIncrementTabIndex( tabIndex );
		self.cmbTasks.visible := true;
	endif;
	self.cmbTasks.move( self.resizedMargin,
						cTop,
						stdWidth,
						cHeight );
	
	cTop := cTop + self.cmbTasks.height + self.resizedMargin;
	cWidth := stdWidth - ( self.getSearchButtonSpace() * 2 );
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move( 	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
						 
	cWidth := self.getStdControlHeight() * 2;
	cLeft := self.txtCargoId.left + self.txtCargoId.width + self.resizedMargin;
	if _initialSetup then
		self.btnAdd.setAndIncrementTabIndex( tabIndex );
		self.btnAdd.visible := true;
	endif;
	self.btnAdd.move(	cLeft,
						cTop,
						cWidth,
						cHeight );
								
	cTop := cTop + self.txtCargoId.height + self.resizedMargin;
	cWidth := ( stdWidth / 2 ) -  self.resizedMargin;
	cHeight:= (self.clientHeight - cTop  - self.getCMDButtonsHeight() - self.resizedMargin - self.resizedMargin); //- margin); //- 
	if _initialSetup then
		self.tblAvailable.setAndIncrementTabIndex( tabIndex );
		self.tblAvailable.visible := true;
	endif;
	self.tblAvailable.move(	self.resizedMargin, 
							cTop, 
							cWidth, 
							cHeight);
							
	cLeft := self.tblAvailable.left + self.tblAvailable.width + self.resizedMargin;
	if _initialSetup then
		self.tblSelected.setAndIncrementTabIndex( tabIndex );
		self.tblSelected.visible := true;
	endif;
	self.tblSelected.move(	cLeft, 
							cTop, 
							cWidth, 
							cHeight);

	if _initialSetup then
		self.setupTables();
	endif;
	
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
