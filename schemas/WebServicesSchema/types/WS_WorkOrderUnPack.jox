<Class name="WS_WorkOrderUnPack" id="ba1d904e-193b-474c-9558-83b74ce8b669">
    <superclass name="WS_WorkOrderDetail"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="unPackLocation" id="feb53ab2-d164-44c1-8d92-3e6fe743a147">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="unPackLocationOid" id="7c2d7a01-556e-40fd-aa99-47995143cf2b">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="createProxyWorkOrder" id="842aac71-5b0f-4520-a4e5-56979d70c5a4">
        <source>createProxyWorkOrder(): CM_WorkOrderDtl;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2021 navma1 ChangeRequest 51002: MTN - Web Portal Cargo Work Orders

*/

vars
	pxyWorkOrder : CM_WodUnpack;

begin
	create pxyWorkOrder transient;
	return pxyWorkOrder;
epilog

end;</source>
        <ReturnType type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="c0d08a3e-d6a3-4e5c-a1af-196f2c2fe405">
        <updating/>
        <source>setProxyFromObject(_object: CM_WodUnpack) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2021 navma1 ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars
	ta : CM_TerminalArea;
begin
	inheritMethod(_object);
	if _object.myUnpackToLocation &lt;&gt; null then
		
		if _object.myUnpackToLocation &lt;&gt; null then
			ta := _object.myUnpackToLocation.myTerminalArea;
			
			self.unPackLocationOid := ta.getOidAsString;
			self.unPackLocation    := ta.id;
		endif;
	endif;
	
	self.setProxyToDoTasks(_object);  //29.09.2021 navma1 #51925
	
epilog
	
end;</source>
        <Parameter name="_object" type="CM_WodUnpack"/>
    </JadeMethod>
    <JadeMethod name="updateProxyWorkOrder" id="78d37f29-975b-488a-8bc8-da4b2b78a03b">
        <source>updateProxyWorkOrder(_pxyWorkOrder: CM_WorkOrderTIDtl input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2021 navma1 ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars
	unPackLocation : CM_TerminalArea;
begin
	inheritMethod(_pxyWorkOrder);
	
	unPackLocation:= app.myPassport.getObjectOfTypeFromOid(self.unPackLocationOid,CM_TerminalArea).CM_TerminalArea;
	
	if unPackLocation &lt;&gt; null then
		_pxyWorkOrder.CM_WodUnpack.setProxyWodUnpack(unPackLocation);
	endif;
	
	self.updateProxyToDoTasks(_pxyWorkOrder);     //29.09.2021 navma1 #51925

epilog

end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrderTIDtl" usage="input"/>
    </JadeMethod>
</Class>
