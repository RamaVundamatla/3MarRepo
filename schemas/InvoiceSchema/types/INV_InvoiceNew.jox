        <source>cmbBillOfLading_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			Sets the ent table to the value of the combo box

Parameters:			combobox	ComboBox	The combobox that lost focus

Return Value:		NONE

Date		Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)

*/

begin
	self.tblBOL.setValueByControlName(combobox.name,combobox.text);
	
	self.setMyBOL(combobox.listObject.CM_BOL);
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
