    <JadeMethod name="export" id="84915d41-da25-466f-9d24-f44ee182d037">
        <updating/>
        <source>export(invoice: CM_Invoice input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2023	navra1	Initial creation for TFS 54090 - EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR-61386/Task-61388)
07 December 2023	navra1	Moving procesing to BGP - TFS 54090 CR 61633 - Task 61726 - 7th Dec 2023
22 Jan 		2024	jlier1  33939
*/

vars
	term 				: CM_Terminal;	
	sendMode 			: String;	
	pxyRequest			: BGP_InvoiceAPIWSRequest;
	realRequest			: BGP_ExternalWSRequest;
	allPDFPrinters 		: CM_PrinterDefsByLogicalPrinter;
	sharedPathBase		: String;
	finIOClass 			: CM_ExtFinanceIO;
	pathSeperator 		: String;
	pathBase			: String;	
begin
	term := invoice.myTerminal;	
	sendMode := term.getConfig(InvoiceAPIOpModeConfig).String;
	finIOClass := term.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	
	if finIOClass = null then
		app.writeLog("Financial IO class was null, so returning", LogERROR);
		return;
	endif;
	
	pathBase := finIOClass.exportPath.normaliseDirectory().substituteDirectory();
	if pathBase.endsWith("\") then
		sharedPathBase := pathBase &amp; invoice.externalNumber;
	else
		sharedPathBase := pathBase &amp; "\" &amp; invoice.externalNumber;
	endif;	
	
	if not app.isJMTUnitTest then	
		
			create pxyRequest transient;
		
			pxyRequest.setDetails(invoice, term, sendMode, sharedPathBase, app.getMyUserCode(), app.getMyUserName());
			if not process.isInTransactionState then
				app.myTrxCA.trxCreateBGPRequestExtWS(pxyRequest, realRequest, app.myPassport);
			else
				app.myUtilityCA.utlCreateBGPRequestExtWS(pxyRequest, realRequest,  app.myPassport);
			endif;
	endif;	
	
	//increment of export count will be done once the BGP is actioned and the invoice is actually sent out, not now
	
epilog
	delete pxyRequest;	
end;</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getNiceName" id="d6fab4a9-665c-473a-8d84-f785ffbc5eac">
        <source>getNiceName(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2023	navra1	Initial creation for TFS 54090 - EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR-61386/Task-61388)

*/

vars

begin
	return ExternalWebServiceInvoiceAPI;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
