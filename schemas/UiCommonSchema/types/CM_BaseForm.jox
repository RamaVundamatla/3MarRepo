    <JadeMethod name="doUnplanTI" id="e33875d5-9cf8-4132-abef-f99f79785dea">
        <updating/>
        <source>doUnplanTI(_theTI : CM_TrackedItem input;_isLoad : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars

	idx : Integer;
	lTI	: CM_TrackedItem;
	aStr : String;
	lResult : Integer;
	lTransferArea : CM_TerminalArea;
	lQEntry : CM_RTQueueEntry;
	sLocation, tLocation : CM_LocationsController;

	aProxyJob : CM_VoyageJob;
	ls : Boolean;
//	aSlotRequest : CM_SlotRequest;
	aReq : CM_Request;
	isLoad : Boolean;
	theWLE : CM_WorkListEntry;
	theVWLE : CM_VoyageWLE;
	result : Integer;
	theMoveController : CMIF_MoveController;
	aFutureMove : CM_FutureMove;
	fmIndex : Integer;
begin
	mousePointer := MousePointer_HourGlass;	
	delete app.myMoveController;

	// #############################
	// ### UNPLAN THE TI
	// #############################
	if _theTI = null then
		app.msgBox("Please select a Tracked Item.","Unplanning", MsgBox_OK_Only);
		return;
	endif;
	// get this TIs SlotRequest and WLE - if it has one
	theVWLE := _theTI.getVoyageWLEUnactioned(_isLoad); // PAR 8953 added param

	if theVWLE &lt;&gt; null then
		//aSlotRequest := theVWLE.myRequest.CM_SlotRequest;
		aReq := theVWLE.myRequest;
	endif;
	
	if not _isLoad then // DISCHARGE

		create theMoveController transient;
		theMoveController.setForCreateUnplan(_theTI,theVWLE,aReq,false);
		app.myTrxUA.trxUpdateMoveTIUndo(theMoveController, app.myPassport);
		if (not app.myPassport.trxCompletedOK) then
			app.showErrorWarningDialog('Unplan', app.myPassport, ErrWarnMode_Update);
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		else
			self.clearErrorWarnings();
		endif;
	
	else
	// ###################################
	// ### UNASSIGN THE TI FROM THE WLE AND THE JOB - ONLY IF THIS IS A LOAD.
	// ###################################

		// detach this Load TI from the load request WLE
		if theVWLE &lt;&gt; null and aReq.myJob &lt;&gt; null then
				create theMoveController transient;
				theMoveController.setForCreateUnplan(_theTI,theVWLE,aReq,true);
				if aReq.myJob &lt;&gt; null and aReq.isReleaseType() then
					app.cmsBeginLoad(ls);
					aProxyJob := aReq.myJob.CM_VoyageJob.pxyCreateUpdateProxy();
					app.cmsEndLoad(ls);

					while true do					
						app.myTrxUA.trxUpdateVoyageJobUnassignTI(theMoveController,aProxyJob, app.myPassport);	
						if app.myPassport.trxCompletedOK then
							// Clear errors/warnings from form and err/warnings window
							self.clearErrorWarnings();
							break;
						else
							result := app.showErrorWarningDialog('Unassign Load Request TI from WLE &amp; Job', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
							if app.myPassport.noErrors and
							   result = IDOK then
								// there must have just been warnings that the user has acknoledged so ..
								app.myPassport.warningsAcknowledged	:= true;
								continue;
							endif;
							self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
						endif;
						break;
					endwhile;
				endif;
		else
			create theMoveController transient;
			theMoveController.setForCreateUnplan(_theTI,null,null,true);
			app.myTrxUA.trxUpdateMoveTIUndo(theMoveController, app.myPassport);
			if (not app.myPassport.trxCompletedOK) then
				app.showErrorWarningDialog('Unplan', app.myPassport, ErrWarnMode_Update);
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			else
				self.clearErrorWarnings();
			endif;
		endif;
	endif;
epilog	

	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347

	delete aProxyJob;
	delete theMoveController;
 
	mousePointer := MousePointer_Default;	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUnplanTIs" id="3be1d05c-78f9-42e2-9119-a0c2f95d4660">
        <updating/>
        <source>doUnplanTIs(_wleArray : CM_WLEArray input; _moveMode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		11 September 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
//	Dec 2011	cnwjre1		28636 add moveMode parameter for RORO unplanning of queued load moves
// ---------------------------------------------------------------------------
vars
	result : Integer;
	wlesWithWarnings : CM_WLEArray;
begin

	app.mousePointer := MousePointer_HourGlass;	
	
	
	create wlesWithWarnings transient;

	while true do
		app.myTrxUA.trxUpdateWLEsUnplan(_wleArray, wlesWithWarnings, _moveMode, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				
				// only reprocess the wles that had warnings.
				_wleArray.clear;
				wlesWithWarnings.copy(_wleArray);
				wlesWithWarnings.clear;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	
epilog 
	delete wlesWithWarnings;
	app.mousePointer := MousePointer_Default;		


end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
        <Parameter name="_moveMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUnqueueTIbyFM" id="38133a34-1aef-446e-9eeb-0cea432a829a">
        <updating/>
        <source>doUnqueueTIbyFM(_fm: CM_FutureMove) updating;
/*

Date		Who		Reason
28 May 2014	cnwer1	Initial creation PAR 33948
02 May 2019 jlgmd1	TFS 44599 Error 4 when unqueuing TI by Future Move

*/

vars
	theTI				: CM_TrackedItem; 
	fmIndex 			: Integer;
	result				: Integer;
	lMoveControl		: CMIF_MoveController;
	request				: CM_Request;
	wle					: CM_WorkListEntry;
	proxyJob			: CM_VoyageJob;
	ls					: Boolean;
	invalid				: Boolean;
begin
	// Handle FMs that have been deleted right as they get to us
	on Exception do app.handleDeletedObject(exception, _fm, invalid);
	
	mousePointer := MousePointer_HourGlass;
	
	if _fm = null then
		app.msgBox("Please select a Tracked Item.","Unqueueing", MsgBox_OK_Only);
		return;
	endif;
	
	theTI := _fm.getTrackedItem();
	if theTI = null or invalid then
		app.msgBox("Please select a Tracked Item.","Unqueueing", MsgBox_OK_Only);
		return;
	endif;

	create lMoveControl transient;
	lMoveControl.setMoveMode(_fm.getMoveMode);
	lMoveControl.setMyTrackedItem(theTI);
	lMoveControl.isFullyUnplan := true; // Need this to use the move index to actually get rid of the correct FM
	
	if _fm &lt;&gt; null and not invalid then
		//epr par 34423 23/6/14
		if lMoveControl.moveMode = PLANNING_MODE then
			fmIndex := theTI.allPlannedFutureMoves.indexOf(_fm);
		elseif lMoveControl.moveMode = QUEUE_MODE then
			fmIndex := theTI.allQueuedFutureMoves.indexOf(_fm);
		endif;
		
		lMoveControl.setMoveIndex(fmIndex);
		
		wle:=_fm.myWorkListEntry;
		lMoveControl.setMyWorkListEntry(_fm.myWorkListEntry);
	endif;

	if lMoveControl.moveMode = PLANNING_MODE then
		if wle &lt;&gt; null  then
			request := wle.myRequest;
			if request &lt;&gt; null then
				if request.isKindOf(CM_SlotRequest) then
					lMoveControl.mySlotRequest := request.CM_SlotRequest;
				elseif request.isKindOf(CM_VoyageRequest) then
					lMoveControl.myVoyageRequest := request.CM_VoyageRequest;
				endif;
			endif;
		endif;	
	endif;
	
	lMoveControl.isOverstowMove := false;

	//if this is a Voyage load wle and we are unplanning that have to unassign the ti to the request before doing the undo
	if request &lt;&gt; null and request.myJob &lt;&gt; null and request.isReleaseType  and request.myJob.isKindOf(CM_VoyageJob) then //epr par 34423 23/6/14
		app.cmsBeginLoad(ls);
		proxyJob := request.myJob.CM_VoyageJob.pxyCreateUpdateProxy();
		app.cmsEndLoad(ls);

		while true do					
			app.myTrxUA.trxUpdateVoyageJobUnassignTI(lMoveControl,proxyJob, app.myPassport);	
			if  not app.myPassport.trxCompletedOK then	
				result := app.showErrorWarningDialog('Unassign Load Request TI from WLE &amp; Job', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
	
	else
		while true do	
			app.myTrxUA.trxUpdateMoveTIUndo(lMoveControl, app.myPassport);
			if (not app.myPassport.trxCompletedOK) then
				result := app.showErrorWarningDialog('Unqueue', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and  result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
	endif;
epilog 
	app.cmsEndLoad(ls);	
	delete proxyJob;
	
	delete lMoveControl;
	mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="_fm" type="CM_FutureMove"/>
    </JadeMethod>
