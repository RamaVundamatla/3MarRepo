<Class name="CM_InterestedWarning" id="f7420bee-d0b1-40a2-aa48-e4d6aeb3562f">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="eventTrans"/>
    <ExplicitInverseRef name="allEventTypes" id="f9e593cf-eded-4ac5-b80e-149d70dbbb80">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <type name="CM_EventTypeByTypeDict"/>
        <access>readonly</access>
        <Inverse name="CM_EventType::allInterestedWarnings"/>
    </ExplicitInverseRef>
    <PrimAttribute name="errorCode" id="7291067b-d263-4f1f-ad86-17d144ca1f9d">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myEDIFileConfig" id="72e09d2c-6185-4221-8fd5-8297a9d0daf6">
        <embedded/>
        <type name="CM_EDIFileConfig"/>
        <access>readonly</access>
        <Inverse name="CM_EDIFileConfig::allWarningsToIgnore"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myRoot" id="95a053c6-c0d6-409a-9b02-c31bdce42dc1">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Root"/>
        <access>readonly</access>
        <Inverse name="CM_Root::allInterestedWarnings"/>
    </ExplicitInverseRef>
    <JadeMethod name="addEventType" id="fb95cb4c-d2bb-45f3-a1b5-d47cfa957b20">
        <updating/>
        <source>addEventType(_eventType : CM_EventType) updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if (not self.allEventTypes.includes(_eventType)) then
		self.allEventTypes.add(_eventType);
	endif;
	


end;


</source>
        <Parameter name="_eventType" type="CM_EventType"/>
    </JadeMethod>
    <JadeMethod name="createOverriddenWarningEvents" id="0a2c0f56-1d4a-48f5-afa9-51b0b6abee9b">
        <source>createOverriddenWarningEvents(_warning : CM_Error; _passport : CM_Passport);
/*
----------   ----------  --------------------------------------------------
Created:	13 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	eventType		: CM_EventType;
	event			: CMEVT_OverriddenWarning;
	
begin
	foreach eventType in self.allEventTypes do	
		create event persistent;
		event.setForUpdateFromWarning(eventType,
							app.serverTimestampAtTrxStart,
							_passport.myTerminal,
							_passport.userCode,
							_warning.errorCode,
							_warning.text,
							_warning.fieldName,
							_warning.mySubject);
	endforeach;

end;


</source>
        <Parameter name="_warning" type="CM_Error"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="removeEventType" id="2083f22d-97db-484e-b58a-6f53d7591a78">
        <updating/>
        <source>removeEventType(_eventType : CM_EventType) updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.allEventTypes.includes(_eventType) then
		self.allEventTypes.remove(_eventType);
	endif;
	
	if self.allEventTypes.isEmpty then
		self.erase(NORMAL_ERASE);
	endif;
	
end;


</source>
        <Parameter name="_eventType" type="CM_EventType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a1c138f5-6aa7-472a-b1c9-678d5609ad82">
        <updating/>
        <source>setForUpdate(_pxyInterestedWarning : CM_InterestedWarning) updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.errorCode := _pxyInterestedWarning.errorCode;
	self.myRoot := app.myRoot;

end;


</source>
        <Parameter name="_pxyInterestedWarning" type="CM_InterestedWarning"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="7d36ef51-9eba-4769-ba71-a23f9d9d5b61">
        <updating/>
        <source>setProxy(_errorCode	: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.errorCode := _errorCode;
	
	self.myRoot := app.myRoot;
end;


</source>
        <Parameter name="_errorCode" type="Integer"/>
    </JadeMethod>
</Class>
