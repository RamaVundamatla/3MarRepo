	self.aAllRequests.add(BGP_GateInOutRequest);
	self.aAllRequests.add(BGP_RemoteProcessingRequest);
	self.aAllRequests.add(BGP_ClearRemotesRequest);
	self.aAllRequests.add(BGP_CountProcessesRequest);
	self.aAllRequests.add(BGP_SpecificReportRequest);
	self.aAllRequests.add(BGP_FixupStockRequest);
	self.aAllRequests.add(BGP_AutoProcessExpiredPTI);	
	self.aAllRequests.add(BGP_AutoProcessExpiredWash);	
	self.aAllRequests.add(BGP_ExternalDBRequest);	
	self.aAllRequests.add(BGP_StorageProcessorRequest);
	self.aAllRequests.add(BGP_ClearFilesRequest);
	self.aAllRequests.add(BGP_ReeferAlarm);			//JC 08/01/2004
	self.aAllRequests.add(BGP_ReeferDefrostLimit);		//Aug 2007 cnwrs1 CCMS1551
