    <JadeMethod name="doFormInitialize" id="ba669a06-997d-443c-8a18-bd38a215d71c">
        <updating/>
        <source>doFormInitialize() updating, protected;
// --------------------------------------------------------------------------------
// Created:		10 April 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	cmbSchema.listIndex	:=	JSS_NULL_INDEX;
	lstConstant.clear();
	txtText.text		:=	null;
	self.loadSchemaList();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="774db399-11ef-45a1-894d-c3b946d4cb6b">
