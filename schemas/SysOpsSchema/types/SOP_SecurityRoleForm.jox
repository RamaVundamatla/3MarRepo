    <JadeMethod name="showLstData" id="15af2b90-5a26-4117-8a24-0316af2d80f2">
        <updating/>
        <source>showLstData() updating;
// ---------------------------------------------------------------------------
// Created:     24 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	role,
	firstRole	: CM_SecurityRole;

begin

	self.allRootRoles.clear;

	if self.viewMode = ViewSystem then
		self.allRootRoles.add(app.getMyUser.mySystemSecurityRole);
	else
		app.getMyUser.getAllRootTerminalRoles(self.allRootRoles);
	endif;

	self.lstData.clear;
	self.cmbParentRole.clear;

	foreach role in self.allRootRoles do
		if (self.viewMode = ViewSystem and
		   role.isSystemSecurityRole) or
		   (self.viewMode = ViewTerminal and
		   (not role.isSystemSecurityRole)) then
			self.addRoleToTreeView(role, 1);
			if firstRole = null then
				firstRole := role;
			endif;
		endif;
	endforeach;
	
	if firstRole &lt;&gt; null then
		self.myCurrentObject := firstRole;
		self.zLstDataSelectObject(firstRole);
	else
		self.zLstDataSelectObject(null);
	endif;
	
	self.shtMaintRolesSetup();	//13 Feb 2018	NDL	TFS 36947
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="8da5d5a5-9204-4404-8b1d-30da0d0e94b3">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 21/03/2008	jlgdap1		TFS 37445 PEL1 Voyage Status Security
// 23/09/2022   navds20 	ChangeRequest 54253: EUP - VAS Work Orders

vars
	role			: CM_SecurityRole;
	loadState		: Boolean;
	tmpSheet		: Sheet;
	topRow			: Integer;
	objArr          : CMIF_Array;	//02/11/2022 navds20 TFS 54253
begin
	app.cmsBeginLoad(loadState);
	self.btnAllowAll.enabled := false;
	self.btnDisallowAll.enabled := false;
	//Start 02/11/2022 navds20 TFS 54253
	if self.myWoStatusAgent = null then
		create self.myWoStatusAgent transient;
	else
		self.myWoStatusAgent.allWoStatusItems.purge();
	endif;
	//End 02/11/2022 navds20 TFS 54253
		
	tmpSheet := self.fldPermissions.topSheet;
	topRow := self.tblPermissions.topRow;
	
	role := obj.CM_SecurityRole;
	//epr TfS 36402
	if self.isFiltering  then
		self.setIsFiltering(false);
	endif;

	self.myParentRole := role.myParentRole;
	
	btnEditTV.enabled := role.canUpdate;
	btnDeleteTV.enabled := role.canUpdate;
	
	tblInput.setValueByName(ETRow_Name, role.name);
	
	if self.isTopLevel then
		tblInput.hideRowByName(ETRow_MyParentRole, false);
	else
		tblInput.showRowByName(ETRow_MyParentRole, false);
		if role.myParentRole &lt;&gt; null then
			tblInput.setValueByName(ETRow_MyParentRole, role.myParentRole.name);
			cmbParentRole.text := role.myParentRole.name;
			cmbParentRole.listObject := role.myParentRole;
		else
			tblInput.setValueByName(ETRow_MyParentRole, null);
			cmbParentRole.text := null;
			cmbParentRole.listObject := null;
		endif;
	endif;

	if role.mySecurityRoleVisibility &lt;&gt; null then
		tblInput.setValueByName(ETRow_AvailableToShippingCoy, role.mySecurityRoleVisibility.availableToShippingCompany);
	else
		tblInput.setValueByName(ETRow_AvailableToShippingCoy, false);
	endif;
	self.populateForm(role, false);

	if self.isTopLevel then
		// this is a top level role that the current user can't edit so
		// just add in the selected.
		mulToDoTasksAdd.setAvailable(role.allToDoTasksAddRemove, true);
		mulToDoTasksComp.setAvailable(role.allToDoTasksComplete, true);
		mulReports.setAvailable(role.allQryReports, true);
		mulStopsView.setAvailable(role.allStopsView, true);
		mulStopsMaint.setAvailable(role.allStopsMaint, true);
		mulStopsDelete.setAvailable(role.allStopsCancel, true);		// cnwdad1 03/06/2010 - CCMS 1129.
		self.mulTransType.setAvailable(role.allTransactionTypesForEvents, true);
		self.mulStatusMaint.setAvailable(role.allVoyageStatusesMaint, true);				// TFS 37445
		self.mulInvoiceStatus.setAvailable(role.allInvoiceStatusesMaint, true);	// TFS 39618
		self.mulWorkOrderStatus.setAvailable(self.myWoStatusAgent.loadWOStatus(role), true); //28/10/2022 navds20 TFS 54253
		self.mulEventTypes.setAvailable(role.allEventTypes, true);	//09 Mar 2020	TFS 48784
	elseif self.myParentRole &lt;&gt; null then
		mulToDoTasksAdd.setAvailable(self.myParentRole.allToDoTasksAddRemove, true);
		mulToDoTasksComp.setAvailable(self.myParentRole.allToDoTasksComplete, true);
		mulReports.setAvailable(self.myParentRole.allQryReports, true);
		mulStopsView.setAvailable(self.myParentRole.allStopsView, true);
		mulStopsMaint.setAvailable(self.myParentRole.allStopsMaint, true);
		mulStopsDelete.setAvailable(self.myParentRole.allStopsCancel, true);		// cnwdad1 03/06/2010 - CCMS 1129.
		self.mulTransType.setAvailable(self.myParentRole.allTransactionTypesForEvents, true);		
		self.mulStatusMaint.setAvailable(self.myParentRole.allVoyageStatusesMaint, true);	// TFS 37445
		self.mulInvoiceStatus.setAvailable(self.myParentRole.allInvoiceStatusesMaint, true); // TFS 39618		
		self.mulWorkOrderStatus.setAvailable(self.myWoStatusAgent.loadWOStatus(self.myParentRole), true); //28/10/2022 navds20 TFS 54253
		if self.myParentRole.isKindOf(CM_SecurityRoleTerminalRoot) then
			self.mulVolDescReasons.setAvailable(app.myRoot.allVolumeDiscrepancyReasons, true);		// 30/4/19 MAP TFS41707
		else
			self.mulVolDescReasons.setAvailable(self.myParentRole.allVolumeDiscrepancyReasons, true);		// 30/4/19 MAP TFS41707
		endif;
		self.mulEventTypes.setAvailable(self.myParentRole.allEventTypes, true);	//09 Mar 2020	TFS 48784
	else
		mulToDoTasksAdd.setAvailable(app.myRoot.allToDoTaskDescriptions, true);
		mulToDoTasksComp.setAvailable(app.myRoot.allToDoTaskDescriptions, true);
		mulReports.setAvailable(self.allQryReports, true);
		mulStopsView.setAvailable(app.myRoot.allStopsTable, true);
		mulStopsMaint.setAvailable(app.myRoot.allStopsTable, true);
		mulStopsDelete.setAvailable(app.myRoot.allStopsTable, true);		// cnwdad1 03/06/2010 - CCMS 1129.
		self.mulTransType.setAvailable(app.myRoot.allTransactionTypes, true);				
		self.mulStatusMaint.setAvailable(app.myRoot.allVoyageStatuses, true);				// TFS 37445
		self.mulInvoiceStatus.setAvailable(app.myRoot.allInvoiceStatuses, true); // TFS 39618
		self.mulWorkOrderStatus.setAvailable(self.myWoStatusAgent.loadWOStatus(role), true);	//28/10/2022 navds20 TFS 54253
		self.mulVolDescReasons.setAvailable(app.myRoot.allVolumeDiscrepancyReasons, true);		// 30/4/19 MAP TFS41707
		self.mulEventTypes.setAvailable(app.myRoot.allEventTypesByType, true);	//09 Mar 2020	TFS 48784
	endif;
	mulToDoTasksAdd.setSelected(role.allToDoTasksAddRemove);
	mulToDoTasksComp.setSelected(role.allToDoTasksComplete);
	mulReports.setSelected(role.allQryReports);
	mulStopsView.setSelected(role.allStopsView);
	mulStopsMaint.setSelected(role.allStopsMaint);
	mulStopsDelete.setSelected(role.allStopsCancel);		// cnwdad1 03/06/2010 - CCMS 1129.
	mulTransType.setSelected(role.allTransactionTypesForEvents);
	self.mulStatusMaint.setSelected(role.allVoyageStatusesMaint);							// TFS 37445
	self.mulInvoiceStatus.setSelected(role.allInvoiceStatusesMaint); // TFS 39618	
	self.mulWorkOrderStatus.setSelected(self.myWoStatusAgent.loadWOSelected(role)); //28/10/2022 navds20 TFS 54253
	if self.isTopLevel() then
		self.mulVolDescReasons.setSelected(app.myRoot.allVolumeDiscrepancyReasons);					// 30/4/19 MAP TFS41707
	else
		self.mulVolDescReasons.setSelected(role.allVolumeDiscrepancyReasons);					// 30/4/19 MAP TFS41707
	endif;
	self.mulEventTypes.setSelected(role.allEventTypes);	//09 Mar 2020	TFS 48784

	self.shtMaintRolesSetup();	//13 Feb 2018	NDL	TFS 36947

	self.setNavigatorHeading(role.name);
	
	if tmpSheet.visible then
		self.fldPermissions.topSheet := tmpSheet;
		self.doPermissionsSheetChange(tmpSheet);
		if topRow &gt; self.tblPermissions.fixedRows and
		   topRow &lt;= self.tblPermissions.row then
			self.tblPermissions.topRow := topRow;
		endif;
	else
		self.fldPermissions.topSheet := self.shtRoleDefn;
	endif;
epilog
	app.cmsEndLoad(loadState);
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="shtMaintRolesSetup" id="6ffd31e2-218d-49c3-ac0d-c4f31ed026c9">
        <source>shtMaintRolesSetup();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 February 2018	jlgndl1	Initial creation	TFS 36947
16 April 2019		jlgzm1	TFS44382 Maintenance roles sheet disabled
30 Aug 2019			jlgdi1	45802 Child of JMTSUPPORT should have no roles selected
*/

vars
	
	baseRole : CM_SecurityRole;
	superRole : CM_SecurityRole;
	role : CM_SecurityRole;
	orderedRoles : ObjectArray;
	index : Integer;
	baseIndex : Integer;
	obj : Object;
	selected : Boolean;
	subItemSelected : Boolean;
	level : Integer;

begin

	self.shtMaintRoles.visible := true;
	self.shtMaintRoles.enabled := true; //tfs44382
	
	baseRole := self.myCurrentObject.CM_SecurityRole;
	
	/*
	// jlgdi1 45802 - for confirmation whether the roles to populate will be based on parent role
	if baseRole.myParentRole &lt;&gt; null then
		superRole := baseRole.myParentRole;
	endif;
	
	if self.isTopLevel() or (baseRole.myParentRole = null) then 
		if self.viewMode = ViewSystem then
			superRole := CM_SecurityRoleSystemRoot.firstInstance;
		else
			superRole := CM_SecurityRoleTerminalRoot.firstInstance;
		endif;
	endif;
	*/
	
	if self.viewMode = ViewSystem then
		superRole := CM_SecurityRoleSystemRoot.firstInstance;
	else
		superRole := CM_SecurityRoleTerminalRoot.firstInstance;
	endif;
	
	create orderedRoles transient;
	superRole.getChildHeirAlphaOrder( orderedRoles );
	
	self.tblMaintRoles.left := 1;
	self.tblMaintRoles.top := 1;
	self.tblMaintRoles.width := self.tblMaintRoles.parent.width - 2;
	self.tblMaintRoles.height := self.tblMaintRoles.parent.height - 2;
	self.tblMaintRoles.parentAspect := 3; // Stretch Both
	self.tblMaintRoles.selectMode := Table.SelectMode_None;
	
	self.tblMaintRoles.clear();
	self.tblMaintRoles.fixedColumns := 0;
	self.tblMaintRoles.fixedRows := 0;
	
	self.tblMaintRoles.rows := 1; 
	self.tblMaintRoles.columns := 3;
	self.tblMaintRoles.gridLines := false;
	
	self.tblMaintRoles.accessColumn( self.SelectColumn ).width := 25; 	//checkbox
	self.tblMaintRoles.accessColumn( self.ExpandColumn ).width := 25;	// +/-
	self.tblMaintRoles.accessColumn( self.ExpandColumn ).fontBold := true;
	self.tblMaintRoles.accessColumn( self.DescrColumn ).width := ( self.tblMaintRoles.clientWidth - 50 ).Integer;	//description

	
	if baseRole &lt;&gt; null then
		selected := baseRole.allChildMaintenanceRoles.includes( superRole );
		subItemSelected := not baseRole.allChildMaintenanceRoles.isEmpty;
	endif;
	
	self.addRoleToMaintTable( self.tblMaintRoles.rows, superRole, 1, selected, subItemSelected, true );
	
	foreach obj in orderedRoles do
		role := obj.CM_SecurityRole;
		self.tblMaintRoles.rows := self.tblMaintRoles.rows + 1;
		if baseRole &lt;&gt; null then
			selected := baseRole.allChildMaintenanceRoles.includes( role );
			subItemSelected := baseRole.includesSubMaintRoles( role );
		endif;
		level := role.getLevelRelativeTo( superRole );
		self.addRoleToMaintTable( self.tblMaintRoles.rows, role, level, selected, subItemSelected, level &lt; 2 );
	endforeach;
	
	self.tblMaintRoles.leftColumn := 1;
	
epilog

	delete orderedRoles;

end;</source>
    </JadeMethod>
