    <JadeMethod name="addAppLabel" id="b231c692-dcfd-4633-ac5f-6cffdb1b849a">
        <updating/>
        <source>addAppLabel(res: Object; timStart: Time; intDuration: Integer) updating;

// Adds an appointment label to AppGrid control

vars
	lbl : CnEcAppGridAppLabel;
	intInd : Integer;

begin
	// Check all the parameters first
	if res = null then
		errorMessage("addAppointment: Resource reference is null!");
		self.appLabel := null;
		return;
	endif;	
	intInd := self.appResources.indexOf(res);
	if intInd &lt; 1 then
		errorMessage("addAppointment: Resource " &amp; res.display() &amp; " doesn't exist!");
		self.appLabel := null;
		return;
	elseif timStart &lt; self.startTime then
		errorMessage("addAppointment: Start time " &amp; timStart.format("HH:mm") &amp; " is invalid!");
		self.appLabel := null;		
		return;
	elseif timStart &lt; self.startTime or (timStart + intDuration * 60000) &gt; self.endTime then
		errorMessage("addAppointment: End time " &amp; (timStart + intDuration * 60000).format("HH:mm") &amp; " is invalid!");
		self.appLabel := null;		
		return;
	endif;

	// Create the label and set all the properties
	create lbl transient;
	lbl.appGrid := self;
	lbl.parent := self.gridTable;
	lbl.resource := res;
	lbl.start := timStart;
	lbl.duration := intDuration;
	lbl.color := self.appColor;
	lbl.gridSnap := self.timeSnap / self.timeGrid * self.rowHeight;
	form.addControl(lbl);

	// Create status label as a child of appointment label
	create lbl.status transient;
	lbl.status.parent := lbl;
	lbl.status.color := self.appStatColor;
	lbl.status.width := self.appStatWidth;
	lbl.status.height := self.appStatHeight;
	form.addControl(lbl.status);

	// Create status bitmap as a child of status label
	create lbl.status.bitmap transient;
	lbl.status.bitmap.parent := lbl.status;
	lbl.status.bitmap.width := self.appStatWidth;		
	lbl.status.bitmap.height := self.appStatHeight;
	form.addControl(lbl.status.bitmap);

	// Move the appointment label to requested position and make it visible
	lbl.moveSelf(self.columnWidth * (intInd - self.gridTable.leftColumn), getY(timStart), self.columnWidth, self.rowHeight / self.timeGrid * intDuration, false);

	lbl.status.move(lbl.width - lbl.status.width - 1, -1, lbl.status.width, lbl.status.height);		
	lbl.visible := true;
	lbl.zOrder(1);

	// Set the self.appLabel property of grid control
	self.appLabel := lbl;
end;</source>
        <Parameter name="res" type="Object"/>
        <Parameter name="timStart" type="Time"/>
        <Parameter name="intDuration" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addResource" id="594afd9c-1452-422c-a761-131498572ba2">
        <updating/>
        <source>addResource(res: Object) updating;

// Adds a resource column to an AppGrid control 

vars
 	intRow	: Integer;
 	intCol	: Integer;
// 	rHeight , cWidth : Integer;
	time : Time;
begin
//addResourceSave260104(res);
//return;
	// If resource is null or is already there ...
	if res = null or self.appResources.indexOf(res) &gt; 0 then
		// ...don't add it
		return;
	endif;

//	cWidth := self.columnWidth; // 50; // self.appGridTable.columnWidth[1].String; // stb
//	rHeight := self.rowHeight; // 30; //  self.appGridTable.rowHeight[1].String; // stb

	// Add the resource to the resources collection
	self.appResources.add(res);

	// If not built yet ...
	if self.appGridTable = null then
		// ...build the control
		self.buildSelf();
	endif;

  	//Store Grip co-ordinates so we can restore them after building the column headings
	intRow := self.appGridTable.row;
	intCol := self.appGridTable.column;
	self.gridTable.gridLines := true;
	
	// Adjust all affected properties and refresh the control
	self.appGridTable.columns := self.appGridTable.columns + 1;
	
	

//write self.appGridTable.columnWidth[self.appGridTable.columns].String; //  &amp; " " &amp; self.gridTable.columnWidth[self.appGridTable.columns - 1].String;

	
	self.appGridTable.columnWidth[self.appGridTable.columns] := self.columnWidth; //stb
	self.gridTable.columns := self.appGridTable.columns - 1;
	
	

	self.gridTable.columnWidth[self.appGridTable.columns - 1] := self.columnWidth; // self.appGridTable.columnWidth[self.appGridTable.columns]; //stb
	
	self.appGridTable.column := self.appGridTable.columns;
	//Move 1 to self.appGridTable.row so we are sure that we are using row 1
	self.appGridTable.row := 1;
	self.appGridTable.text := res.display();
	//self.appGridTable.refreshNow();	//cnwcip1
	
	self.gridPlane.height := self.appGridTable.clientHeight() - self.rowHeight; // self.appGridTable.rowHeight[1]; // STB
	//write "rowHeight = " &amp; self.appGridTable.rowHeight[1].String;

	
	//Put row and column values back as they were
    self.appGridTable.row := intRow;
    self.appGridTable.column := intCol;

	//Bug fix for if table has been scrolled right when grid is repainted and labels reloaded
	//self.leftColumn seemed to be getting out of synch with self.appGridTable.leftColumn
//	if self.appGridTable.topRow &gt; 1 then
//		self.topRow := self.appGridTable.topRow;
//	endif;
//	if self.appGridTable.leftColumn &gt; 1 then
//		self.leftColumn := self.appGridTable.leftColumn;
//	endif;
	//*******************************************************************************************

end;</source>
        <Parameter name="res" type="Object"/>
    </JadeMethod>
    <JadeMethod name="buildSelf" id="41435cf8-5af8-4c02-997a-922ea5adcbb2">
        <updating/>
        <source>buildSelf() updating;

// Builds AppGrid control by creating self.appGridTable, self.gridPlane, and self.gridTable child controls

vars
	timScale : Time;
	intCount : Integer;
	datDate : Date;
	res : CnEcAppGridResource;
	rHeight : Integer;
	numberColumns : Integer;
	colWidth : Integer;
begin
	if self.appGridTable = null then
		create self.appGridTable transient;
		self.appGridTable.parent := self;
		form.addControl(self.appGridTable);
		create self.gridPlane transient;
		self.gridPlane.parent := self;
		form.addControl(self.gridPlane);
		self.gridPlane.zOrder(1);
		create self.gridTable transient;
//		self.gridTable.scrollBars := 0;	// stb 17/11
		self.gridTable.parent := self.gridPlane;
		form.addControl(self.gridTable);
		self.gridTable.fixedRows := 0;
		self.gridTable.fixedColumns := 0;
		create self.appInfo transient;
		self.appInfo.parent := form;
		form.addControl(self.appInfo);
		self.appInfo.zOrder(1);
		self.appInfo.height := self.appInfo.fontSize * 2.3;
		self.appInfo.width := self.appInfo.fontSize * 15;

// Partial implementation bug fix
		self.appGridTable.allowResize := 3; // None
		self.gridTable.allowResize := 3; // None

// Table control bug workaround
		self.gridTable.topRow := 2;
		self.gridTable.leftColumn := 2;
		self.gridTable.topRow := 1;
		self.gridTable.leftColumn := 1;
// *******************************

		if isInPainter() then
			self.appGridTable.actualEnabled := false;
			self.gridPlane.actualEnabled := false;
			self.gridTable.actualEnabled := false;
			self.appInfo.actualEnabled := false;			
		endif;
		self.gridColor := self.appGridTable.gridColor;
		
		gridTable.gridLines := false;

 	endif;
	
	// If control is displayed in the painter ...
	if isInPainter() then
		// ...show a sample preview with some arbitrary info
	    self.startTime := "08:00".Time;
	    self.endTime := "18:00".Time;
	    self.timeGrid := 30;
	  	intCount := 1;
	    while intCount &lt;= 7 do
	    	create res transient;
	    	res.myAppGrid := self;
	    	res.caption := datDate.dayName;
 		   	self.appResources[datDate.dayOfWeek] := res;
	    	datDate := datDate + 1;
 	 	  	intCount := intCount + 1;
  		endwhile;

  	elseif (not self.isSet) then
  		self.startTime := null;
  		self.endTime := null;
  		self.timeGrid := 0;
	endif;

	// Set all properties to appropriate values
	self.appInfo.backColor := self.infoColor;
	if self.timeGrid = 0 then
		self.appGridTable.rows := 1;
		self.appGridTable.columns := self.appResources.size() + 1;
	else
  		self.appGridTable.rows := ((self.endTime - self.startTime) / self.timeGrid / 60000).rounded + 1;
  		self.appGridTable.columns := self.appResources.size() + 1;	
	endif;
	self.gridTable.rows := self.appGridTable.rows - 1;
	self.gridTable.columns := self.appGridTable.columns - 1;
	self.appGridTable.accessMode := 0;
	self.gridTable.accessMode := 0;
	self.appGridTable.alignment := Table.Alignment_Center;
    self.appGridTable.foreColor := foreColor;
    self.appGridTable.backColor := backColor;
    self.gridTable.backColor := backColor;
    self.appGridTable.gridColor := self.gridColor;
    self.gridTable.gridColor := self.gridColor;
	if self.appGridTable.fontName &lt;&gt; fontName then
    	self.appGridTable.fontName := fontName;
    endif;
    if self.appGridTable.fontSize &lt;&gt; fontSize then
		self.rowHeight := (self.rowHeight * fontSize / self.appGridTable.fontSize).rounded;
		self.columnWidth := (self.columnWidth * fontSize / self.appGridTable.fontSize).rounded;
	 	self.appGridTable.fontSize := fontSize;
	endif;
 	self.appGridTable.fontBold := fontBold;
 	self.appGridTable.fontItalic := fontItalic;
 	self.appGridTable.fontUnderline := fontUnderline;
 	self.appGridTable.fontStrikethru := fontStrikethru;
	
	//	appGridTable.gridLines := false; 

	timScale := self.startTime;
	self.appGridTable.accessMode := 1;
	self.gridTable.accessMode := 1;
	self.appGridTable.column := 1;
	self.appGridTable.rowHeight[1] := self.firstRowHeight;
	intCount := 2;
	
	rHeight := self.rowHeight; // stb
	while intCount &lt;= self.appGridTable.rows do
		self.appGridTable.rowHeight[intCount] := self.rowHeight; //stb
//		self.appGridTable.rowHeight[intCount] := rHeight; // stb
//		self.gridTable.rowHeight[intCount - 1] := self.appGridTable.rowHeight[intCount]; // stb
		self.gridTable.rowHeight[intCount - 1] := rHeight; // stb
		self.appGridTable.row := intCount;
		self.appGridTable.text := timScale.format("HH:mm");
		timScale := timScale + self.timeGrid * 60000;			
		intCount := intCount + 1;		
	endwhile;
	self.appGridTable.row := 1;
	self.appGridTable.columnWidth[1] := self.firstColumnWidth;
	intCount := 2;
	
	numberColumns := self.appGridTable.columns;
	colWidth := self.columnWidth;
	while intCount &lt;= numberColumns do
//		self.appGridTable.columnWidth[intCount] := self.columnWidth; // stb
//		self.gridTable.columnWidth[intCount - 1] := self.appGridTable.columnWidth[intCount]; // stb
		
		self.appGridTable.columnWidth[intCount] := colWidth; // stb
		self.gridTable.columnWidth[intCount - 1] := colWidth; // stb

		self.appGridTable.column := intCount;
		self.appGridTable.text := self.appResources[intCount - 1].display();
		intCount := intCount + 1;
	endwhile;
	self.appGridTable.width := clientWidth();
	self.appGridTable.height := clientHeight();
	//self.appGridTable.refreshNow(); //cnwcip1

	self.gridPlane.left := self.appGridTable.left + self.appGridTable.columnWidth[1];
	self.gridPlane.top := self.appGridTable.top + self.appGridTable.rowHeight[1];
	self.gridPlane.width := self.appGridTable.clientWidth() - self.appGridTable.columnWidth[1];
	self.gridPlane.height := self.appGridTable.clientHeight() - self.appGridTable.rowHeight[1];
	//self.gridPlane.refreshNow(); //cnwcip1

	self.gridTable.width := self.appGridTable.width - self.appGridTable.columnWidth[1];
	self.gridTable.height := self.appGridTable.height - self.appGridTable.rowHeight[1];
	self.gridTable.refreshNow(); //cnwcip1

	if self.appGridTable.topRow &gt; 1 then
		self.topRow := self.appGridTable.topRow;
	endif;
	if self.appGridTable.leftColumn &gt; 1 then
		self.leftColumn := self.appGridTable.leftColumn;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="clearGrid" id="bbd4ca9e-94eb-44d5-939c-4773b0369c7e">
        <updating/>
        <source>clearGrid() updating;

// Sets the background color to default

vars
	intRow, intCol : Integer;

begin
	if self.gridTable.rows = 0 or self.gridTable.columns = 0 then
		return;
	endif;
	
	self.gridTable.accessMode := Table.AccessMode_Cell;
	intRow := 1;
	
	while intRow &lt;= self.gridTable.rows do
		self.gridTable.row := intRow;
		intCol := 1;
		
		while intCol &lt;= self.gridTable.columns do
			self.gridTable.column := intCol;
			self.gridTable.backColor := backColor;
			self.gridTable.foreColor := foreColor;
			self.gridTable.text := null;
			intCol := intCol + 1;
		endwhile;
		
		intRow := intRow + 1;
	endwhile;
	
	self.gridTable.accessMode := Table.AccessMode_Sheet;
end;</source>
    </JadeMethod>
    <JadeMethod name="click" id="dd4b5b56-9e8e-42f8-8bd8-d35a4d315439">
        <updating/>
        <source>click(cntrl: CnEcAppGrid input) updating;

vars

begin
	// If in print preview mode ...
	if app.printer.printPreview then
		// ...disable event handling
		return;
	endif;
	inheritMethod(cntrl);
	self.changeType := self.ChangeType_NoChange;
end;</source>
        <Parameter name="cntrl" type="CnEcAppGrid" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="6400e94c-90e4-43ab-988c-0aebeb37216e">
        <updating/>
        <source>create() updating;

begin
	// Set default properties
 	borderStyle := Window.BorderStyle_Single;
 	show3D := Control.Show3D_Use3D;
 	self.rowHeight := 20;
 	self.columnWidth := 100;
 	self.firstRowHeight := 30;
 	self.firstColumnWidth := 50;
    self.appColor := backColor;
    self.appStatColor := self.appColor;
    self.appStatWidth := 20;
    self.appStatHeight := 20;
    self.overlapping := false;
    self.overlaying := false;
    self.multiSelect := true;
    self.dragging := false;
    self.infoColor := White;
    self.timeSnap := 1;
    self.changeType := self.ChangeType_NoChange;
   	self.isBuilt := false;
 	self.isSet := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="dblClick" id="b23a20ad-4307-473a-94f7-3c7c68f5bf26">
        <updating/>
        <source>dblClick(cntrl: CnEcAppGrid input) updating;

vars

begin
	// If in print preview mode ...
	if app.printer.printPreview then
		// ...disable event handling
		return;
	endif;
	inheritMethod(cntrl);
	self.changeType := self.ChangeType_NoChange;
end;</source>
        <Parameter name="cntrl" type="CnEcAppGrid" usage="input"/>
    </JadeMethod>
    <JadeMethod name="deselectAll" id="b19462ac-ac2a-4a40-bed7-77e4cf5c259f">
        <updating/>
        <source>deselectAll() updating;

// Deselects all appointment labels

vars
	lbl : CnEcAppGridAppLabel;

begin
	foreach lbl in self.appLabelsSelected do
		lbl.backColor := lbl.color;
		lbl.foreColor := getSystemColor(Window.Color_BtnText);	
		lbl.selected := null;
	endforeach;		
end;</source>
    </JadeMethod>
    <JadeMethod name="dragDrop" id="d68f75bb-0216-4c15-bf4e-8f9db15cf80b">
        <updating/>
        <source>dragDrop(cntrl: CnEcAppGrid input; win: Window input; x: Real; y: Real) updating;

vars
	relX, relY : Real;
	lbl, lblObj : CnEcAppGridAppLabel;
	intCol : Integer;

begin
	// If dropped outside valid grid area ...
	if x &lt; 0 or y &lt; 0 or x &gt; (self.gridTable.columns - self.gridTable.leftColumn + 1) * self.columnWidth or y &gt; getY(self.endTime) then
		// ...don't execute user event handler
		return;
	endif;

	// If appointment label(s) is/are dropped on the grid ...
	if win.isKindOf(CnEcAppGridAppLabel) then

		// ...check if self.overlaying is not allowed ...
		if (not self.overlaying) then
			// ...and make sure dropped labels comply to this rule
			foreach lblObj in self.appLabelsSelected do
				intCol := getColumn(lblObj.appDragX + x - win.CnEcAppGridAppLabel.appDragX);
				if intCol &lt; 1 or intCol &gt; self.gridTable.columns then
					intCol := getColumn(lblObj.appDragX);
				endif;
				relX := self.columnWidth * (intCol - self.gridTable.leftColumn);
				relY := ((lblObj.appDragY / lblObj.gridSnap).rounded * lblObj.gridSnap).rounded;
				foreach lbl in self.appLabels 
				where lbl.selected = null and lbl.resource = getResource(relX) 
				and ((relY &gt;= lbl.top and relY &lt; lbl.top + lbl.height) or (lbl.top &gt;= relY and lbl.top &lt; relY + lblObj.height)) do
					self.changeType := self.ChangeType_NoChange;
					self.appInfo.visible := false;
					self.gridTable.refreshNow();
					inheritMethod(cntrl, win, x, y);
					return;
				endforeach;
			endforeach;
		endif;

		// Move all labels being dropped to correct positions and reset 'moving' flags
		foreach lblObj in self.appLabelsSelected do
			// Snap x coordinate to the column and y coordinate to snap time
			intCol := getColumn(lblObj.appDragX + x - win.CnEcAppGridAppLabel.appDragX);
			if intCol &lt; 1 or intCol &gt; self.gridTable.columns then
				intCol := getColumn(lblObj.appDragX);
			endif;
			relX := self.columnWidth * (intCol - self.gridTable.leftColumn);
			relY := ((lblObj.appDragY / lblObj.gridSnap).rounded * lblObj.gridSnap).rounded;
			lblObj.moving := false;			
			lblObj.moveSelf(relX, relY, lblObj.width, lblObj.height, true);
		endforeach;

		// Set change type to 'Move'
		self.changeType := self.ChangeType_Move;

	else
		// Something other than appointment label has been dropped on the grid, set chnage type to 'Drop'
		self.changeType := self.ChangeType_Drop;
	endif;

	// Make info label invisible and refresh the control
	self.appInfo.visible := false;
	self.gridTable.refreshNow();

	// Execute user event handler and reset change type
	inheritMethod(cntrl, win, x, y);
	self.changeType := self.ChangeType_NoChange;
end;</source>
        <Parameter name="cntrl" type="CnEcAppGrid" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="dragOver" id="f147fb0c-21cf-46ca-b795-b923a263d248">
        <updating/>
        <source>dragOver(cntrl: BaseControl input; win: Window input; x: Real; y: Real; state: Integer) updating;


vars
	lbl : CnEcAppGridAppLabel;

begin
	// If appointment label(s) is/are dragged over ...
	if win.isKindOf(CnEcAppGridAppLabel) then
		// ...draw rectangle for each of the moving labels ...
		foreach lbl in self.appLabelsSelected do
			lbl.moveAppInfo(lbl.left - win.left + x, lbl.top - win.top + y);
		endforeach;

		// ...and scroll the grid control if appropriate
		lbl := win.CnEcAppGridAppLabel;
				
		if not lbl.scrolled then
			if x &lt; 0 and self.gridTable.leftColumn &gt; 1 then
				self.appGridTable.leftColumn := self.appGridTable.leftColumn - 1;
				self.appGridTable.scrolled(self.appGridTable, ScrollBar_Horizontal);
				lbl.scrolled := true;
			//causing a 14050 error - elseif x &gt; self.gridTable.clientWidth() and self.gridTable.leftColumn &lt;= self.gridTable.columns - self.gridTable.clientWidth() div self.columnWidth then
			elseif x &gt; self.gridTable.clientWidth() and self.gridTable.leftColumn &lt; self.gridTable.columns - self.gridTable.clientWidth() div self.columnWidth then  //cp 20/10/2004
				self.appGridTable.leftColumn := self.appGridTable.leftColumn + 1;
				self.appGridTable.scrolled(self.appGridTable, ScrollBar_Horizontal);
				lbl.scrolled := true;
			elseif y &lt; 0 and self.gridTable.topRow &gt; 1 then
				self.appGridTable.topRow := self.appGridTable.topRow - 1;
				self.appGridTable.scrolled(self.appGridTable, ScrollBar_Vertical);
				lbl.scrolled := true;
			elseif y &gt; self.gridTable.clientHeight() and self.gridTable.topRow &lt;= self.gridTable.rows - self.gridTable.clientHeight() div self.rowHeight then
				self.appGridTable.topRow := self.appGridTable.topRow + 1;
				self.appGridTable.scrolled(self.appGridTable, ScrollBar_Vertical);
				lbl.scrolled := true;
			endif;
		elseif x &gt; 0 and x &lt; self.gridTable.clientWidth() and y &gt; 0 and y &lt; self.gridTable.clientHeight() then
			lbl.scrolled := false;
		endif;

	else
		// In case something other than appointment label is being dragged over, execute user event handler
		inheritMethod(cntrl, win, x, y, state);	
	endif;
end;</source>
        <Parameter name="cntrl" type="BaseControl" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="errorMessage" id="32a0ef2a-1027-4012-aa83-53dcd0e1a70b">
        <source>errorMessage(msg: String);

// Displays AppGrid Control standard error message

vars

begin
	app.msgBox(msg, "AppGrid Control", MsgBox_OK_Only + MsgBox_Stop_Icon);
end;</source>
        <Parameter name="msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="getColumn" id="624eaab1-d474-430f-b2c9-adbe64a7506e">
        <source>getColumn(x: Real): Integer;

// Gets column number based on x coordinate passed as an argument

vars
	columnOver	: Integer;

begin
// cnwdad1 10/02/2001 - If the table has only 1 column, and if the width
// of that column is the same as the "x" value, then an invalid column
// number (2) was returned.
//	intCol	:=	self.gridTable.leftColumn + (x / self.columnWidth).truncated;
	if self.gridTable.columns = 1 then
// cnwdad1 20/05/2001 - f there's only one column, then there's no point trying to calculate the column.
//		columnOver	:=	(x / self.columnWidth).truncated;
		columnOver	:=	1;
	else
		columnOver	:=	self.gridTable.leftColumn + (x / self.columnWidth).truncated;
	endif;
	
	if columnOver &gt;= 1 and columnOver &lt;= self.gridTable.columns then
		return columnOver;
	endif;
	
	errorMessage("getColumn: X coordinate " &amp; x.String &amp; " is out of range!");
	
	return 0;
end;</source>
        <Parameter name="x" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getResource" id="4a5ffdd1-ff1f-4b03-968a-7d8f28ea4e61">
        <source>getResource(x: Real): Object;

// Gets resource name based on x coordinate passed as an argument

vars
	intInd: Integer;

begin
	intInd := getColumn(x);
	if intInd &gt;= 1 and intInd &lt;= self.appResources.size() then
		return self.appResources[intInd];
	endif;
	errorMessage("getResource: X coordinate " &amp; x.String &amp; " is out of range!");
	return null;
end;</source>
        <Parameter name="x" type="Real"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getRow" id="e5ea75a4-9d79-49d2-9e4a-bb47e4575b16">
        <source>getRow(y: Real): Integer;

// Gets row number based on x coordinate passed as an argument
// 01 cnwcip1	Changes made to stop grid error when setting colour for whole column and the last row was truncated due to time interval
vars
	intRow : Integer;

begin
	intRow := self.gridTable.topRow + (y / self.rowHeight).truncated;
	if intRow &gt;= 1 and intRow &lt;= self.gridTable.rows then
		return intRow;
	endif;
	if (intRow-1) = self.gridTable.rows then		//01
		//Rounding issue caused by grid interval	//01
		return self.gridTable.rows;					//01
	endif;											//01
	errorMessage("getRow: Y coordinate " &amp; y.String &amp; " is out of range!");
	return 0;
end;</source>
        <Parameter name="y" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTime" id="9eea29d0-cb41-4e21-b009-a1f760c00475">
        <source>getTime(y: Real): Time;

// Gets time based on y coordinate passed as an argument

vars
	timTime : Time;

begin
	timTime := self.startTime + ((self.gridTable.topRow - 1) * self.timeGrid + (y / self.rowHeight * self.timeGrid).rounded) * 60000;
	return timTime;
end;</source>
        <Parameter name="y" type="Real"/>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="getX" id="2012aeab-ab26-4ae5-a47d-260856d36fb3">
        <source>getX(resource: Object): Real;

// Gets x coordinate based on resource passed as an argument

vars
	intInd : Integer;

begin
	intInd := self.appResources.indexOf(resource);
	if intInd &gt; 0 then
		return (intInd - self.gridTable.leftColumn) * self.columnWidth;
	endif;
	errorMessage("getX: Resource " &amp; resource.display() &amp; " doesn't exist!");
	return 0;
end;</source>
        <Parameter name="resource" type="Object"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getY" id="7c487248-21bc-4b60-9c7f-94df91f4c8a7">
        <source>getY(timTime: Time): Real;

// Gets y coordinate based on time passed as an argument

vars

begin
	return ((timTime - self.startTime) / 60000 / self.timeGrid - self.gridTable.topRow + 1) * self.rowHeight;
end;</source>
        <Parameter name="timTime" type="Time"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="isValidX" id="dd5964da-9287-4f42-93f1-468709476249">
        <source>isValidX(relX: Real): Boolean;

// Validates X coordinate

vars

begin
	if relX &lt; 0
	or relX &gt; ((self.gridTable.columns - self.gridTable.leftColumn + 1) * self.columnWidth)
	then
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="relX" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidY" id="417d93bd-81d8-4495-b4b9-8f6bf204faa8">
        <source>isValidY(relY: Real): Boolean;

// Validates Y coordinate

vars

begin
	if relY &lt; 0 or relY &gt; (self.gridTable.rows - self.gridTable.topRow + 1) * self.rowHeight then
		return false;
	endif;
	return true;
end;</source>
        <Parameter name="relY" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="67bdd8ad-8692-4cfb-aaff-d0da4296c371">
        <updating/>
        <source>mouseDown(cntrl: CnEcAppGrid input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars
	lbl : CnEcAppGridAppLabel;
	int : Integer;

begin
	// If in print preview mode ...
	if app.printer.printPreview then
		// ...disable event handling
		return;
	endif;

	// If a reasource (column) header is left-clicked ...
	if button = Window.MouseButton_Left and self.multiSelect and x &gt; 0 and x &lt; (self.gridTable.columns - self.gridTable.leftColumn + 1) * self.columnWidth and y &lt; 0 then
		// ...select all labels for the resource (column)
		int := getColumn(x);
		if int &gt; 0 then
			foreach lbl in self.appLabels
			where lbl.resource = self.appResources[int] do
				select(lbl, true);
			endforeach;
		endif;
	endif;

	// Execute user event handler
	inheritMethod(cntrl, button, shift, x, y);
end;</source>
        <Parameter name="cntrl" type="CnEcAppGrid" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="1f001e4e-9f63-411d-9e86-4d42ce5fc081">
        <updating/>
        <source>mouseMove(cntrl: BaseControl input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars

begin
	// If in print preview mode ...
	if app.printer.printPreview then
		// ...disable event handling
		return;
	endif;
	inheritMethod(cntrl, button, shift, x, y);
end;</source>
        <Parameter name="cntrl" type="BaseControl" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="4b5c4ed9-ddc5-465f-8a55-adcd7c66349f">
        <updating/>
        <source>mouseUp(cntrl: CnEcAppGrid input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars

begin
	// If in print preview mode ...
	if app.printer.printPreview then
		// ...disable event handling
		return;
	endif;

	self.gridTable.refreshNow();
	inheritMethod(cntrl, button, shift, x, y);
end;</source>
        <Parameter name="cntrl" type="CnEcAppGrid" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="paint" id="6fa53e18-2b59-42f5-b159-bda9afebba67">
        <updating/>
        <source>paint(cntrl: CnEcAppGrid input) updating;

vars

begin
	// Build the control in the run-time when painted on the form
	if isInPainter() then
		self.buildSelf();

	elseif (not self.isBuilt) then
		buildSelf;
		self.isBuilt := true;

	elseif self.appGridTable &lt;&gt; null then
		self.appGridTable.width := self.clientWidth();
		self.appGridTable.height := self.clientHeight();
		self.gridPlane.width := self.appGridTable.clientWidth() - self.appGridTable.columnWidth[1];
		self.gridPlane.height := self.appGridTable.clientHeight() - self.appGridTable.rowHeight[1];		
		self.gridTable.width := self.appGridTable.width - self.appGridTable.columnWidth[1];
		self.gridTable.height := self.appGridTable.height - self.appGridTable.rowHeight[1];	
	endif;
	
	inheritMethod(cntrl);
end;</source>
        <Parameter name="cntrl" type="CnEcAppGrid" usage="input"/>
    </JadeMethod>
    <JadeMethod name="paintGrid" id="83f74083-856e-457e-8b30-050f7983d422">
        <updating/>
        <source>paintGrid(resObj: Object; timStart: Time input; intDuration: Integer input; intBackColor: Integer; strText: String; intForeColor: Integer) updating;

// Sets the background color and text for specified resource and time interval 
// 01 cnwcip1	Changes made to stop grid error when setting colour for whole column and the last row was truncated due to time interval

vars
	int, intStart, intEnd : Integer;
	timEnd : Time;

begin
	// Set table access mode
	self.gridTable.accessMode := 1;

	// Get the resource column and start time
	int := getColumn(getX(resObj));
	if int &lt; 1 or int &gt; self.gridTable.columns then
		return;
	endif;
	self.gridTable.column := int;

	// Get the starting row
	intStart := getRow(getY(timStart));
	if intStart &lt; 1 then
		return;
	endif;

	// Calculate ending time and ending row
	timEnd := timStart + intDuration * 60000;
	intEnd := self.gridTable.rows;  //01
	
	if timEnd &gt;= self.endTime then
		intEnd := self.gridTable.rows;
	else
		intEnd := getRow(getY(timEnd));
		if intEnd &lt; 1 then
			return;
		endif;
	endif;
	
	// If less than half of the starting row should be painted ...
	if getY(timStart) &gt; (intStart - self.gridTable.topRow + 0.5) * self.rowHeight and intStart &lt; self.gridTable.rows then
		// ...start with the next row
		intStart := intStart + 1;
	endif;		

	// If less than half of the ending row should be painted ...
	if getY(timEnd) &lt; (intEnd - self.gridTable.topRow + 0.5) * self.rowHeight and intEnd &gt; 1 then
		// ...do not paint the ending row
		//The last row of the grid has already been truncated if painting holiday/weekend colours
		if timStart &lt;&gt; self.startTime or intEnd &lt;&gt; self.gridTable.rows then  //01
			intEnd := intEnd - 1;											 //01
		endif;																 //01
	endif;		

	
	
	// Paint the starting row
	self.gridTable.row := intStart;
	self.gridTable.backColor := intBackColor;
	self.gridTable.foreColor := intForeColor;
	self.gridTable.text := strText;

	// Paint the rest of the grid
	int := intStart + 1;
	while int &lt;= intEnd do
		self.gridTable.row := int;
		self.gridTable.backColor := intBackColor;
		int := int + 1;
	endwhile;

	// Reset table access mode
	self.gridTable.accessMode := 0;
end;</source>
        <Parameter name="resObj" type="Object"/>
        <Parameter name="timStart" type="Time" usage="input"/>
        <Parameter name="intDuration" type="Integer" usage="input"/>
        <Parameter name="intBackColor" type="Integer"/>
        <Parameter name="strText" type="String"/>
        <Parameter name="intForeColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeAllAppLabels" id="5af32eda-9882-4cb7-a518-3dfda052cc09">
        <updating/>
        <source>removeAllAppLabels() updating;

// Removes all appointment labels from AppGrid control

vars

begin
	self.appLabels.purge();
	refreshNow();
end;</source>
    </JadeMethod>
    <JadeMethod name="removeAllResources" id="98f2943d-3621-4b5d-84ed-160109537135">
        <updating/>
        <source>removeAllResources() updating;

// Removes all resources and appointments from the AppGrid control

vars

begin
	self.appLabels.purge();
	self.appResources.clear();
	
	if self.appGridTable &lt;&gt; null then
		self.appGridTable.columns := 1;
	endif;
	if self.gridTable &lt;&gt; null then
		self.gridTable.columns := 0;
		self.gridTable.gridLines := false;
  		
	endif;

	refreshNow(); //cnwcip1
end;</source>
    </JadeMethod>
    <JadeMethod name="removeResource" id="8544df7e-10e1-4fb7-b363-7ec128d513d3">
        <updating/>
        <source>removeResource(resObj: Object) updating;

// Removes the resource column from AppGrid control

vars
	intInd : Integer;
	lbl : CnEcAppGridAppLabel;

begin
	intInd := self.appResources.indexOf(resObj);
	if intInd &gt; 0 then
		self.appResources.remove(resObj);
		self.appGridTable.deleteColumn(intInd + 1);
		self.gridTable.deleteColumn(intInd);
		foreach lbl in self.appLabels do
			if lbl.resource = resObj then
				lbl.remove();
			else
				lbl.moveSelf(getX(lbl.resource), lbl.top, lbl.width, lbl.height, false);
			endif;
		endforeach;
	else
		errorMessage("removeResource: Resource " &amp; resObj.display() &amp; " doesn't exist!");	
	endif;
end;</source>
        <Parameter name="resObj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="scrollAppLabels" id="d16521e5-4ad8-4b00-95e1-ff35d32a33b3">
        <updating/>
        <source>scrollAppLabels() updating;

// Scrolls appointment labels and gridTable when appGridTable is scrolled

vars
	relDx, relDy : Real;
	lbl : CnEcAppGridAppLabel;

begin
	relDx := (self.appGridTable.leftColumn - self.leftColumn) * self.columnWidth;
	relDy := (self.appGridTable.topRow - self.topRow) * self.rowHeight;
	foreach lbl in self.appLabels do
		lbl.move(lbl.left - relDx, lbl.top - relDy, lbl.width, lbl.height);
	endforeach;
	if self.gridTable.columns &gt; 0 then
		self.gridTable.leftColumn := self.appGridTable.leftColumn - 1;
	endif;
	if self.gridTable.rows &gt; 0 then
		self.gridTable.topRow := self.appGridTable.topRow - 1;
	endif;
	self.leftColumn := self.appGridTable.leftColumn;
	self.topRow := self.appGridTable.topRow;
end;</source>
    </JadeMethod>
    <JadeMethod name="scrollTo" id="ce8b6ebe-c2e9-4103-ac0a-e2131c6a8ca7">
        <updating/>
        <source>scrollTo(label: CnEcAppGridAppLabel) updating;

// Scrolls AppGrid control (if needed) to make specified appointment label visible

vars

begin
	if label = null then
		errorMessage("scrollTo: Invalid appointment label!");
		return;
	endif;

	// Scroll up until label is visible
	while label.top &lt; 0 do
		if self.gridTable.topRow &lt;= 1 then
			break;
		endif;
		self.appGridTable.topRow := self.appGridTable.topRow - 1;
		self.appGridTable.scrolled(self.appGridTable, Window.ScrollBar_Horizontal);
		self.appGridTable.refreshNow();		
		self.gridTable.refreshNow();
	endwhile;

	// Scroll down until label is visible
	while label.top + label.height &gt; self.gridTable.clientHeight() + 1 do
		if self.gridTable.topRow &gt; self.gridTable.rows - self.gridTable.clientHeight() div self.rowHeight or self.appGridTable.topRow &gt;= self.appGridTable.rows then
			break;
		endif;
		self.appGridTable.topRow := self.appGridTable.topRow + 1;
		self.appGridTable.scrolled(self.appGridTable, Window.ScrollBar_Horizontal);
		self.appGridTable.refreshNow();
		self.gridTable.refreshNow();
	endwhile;

	// Scroll left until label is visible
	while label.left &lt; 0 do
		if self.gridTable.leftColumn &lt;= 1 then
			break;
		endif;
		self.appGridTable.leftColumn := self.appGridTable.leftColumn - 1;
		self.appGridTable.scrolled(self.appGridTable, Window.ScrollBar_Vertical);
		self.appGridTable.refreshNow();
		self.gridTable.refreshNow();
	endwhile;

	// Scroll right until label is visible
	while label.left + label.width &gt; self.gridTable.clientWidth() + 1 do
		if self.gridTable.leftColumn &gt; self.gridTable.columns - self.gridTable.clientWidth() div self.columnWidth or self.appGridTable.leftColumn &gt;= self.appGridTable.columns then
			break;
		endif;
		self.appGridTable.leftColumn := self.appGridTable.leftColumn + 1;
		self.appGridTable.scrolled(self.appGridTable, Window.ScrollBar_Vertical);
		self.appGridTable.refreshNow();
		self.gridTable.refreshNow();
	endwhile;
end;</source>
        <Parameter name="label" type="CnEcAppGridAppLabel"/>
    </JadeMethod>
    <JadeMethod name="scrolled" id="bad6524c-26ee-473e-b3d8-8410fe9eb445">
        <updating/>
        <source>scrolled(cntrl: CnEcAppGrid input; scrollBar: Integer) updating;

vars

begin
	inheritMethod(cntrl, scrollBar);
end;</source>
        <Parameter name="cntrl" type="CnEcAppGrid" usage="input"/>
        <Parameter name="scrollBar" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="select" id="a8f1d74d-6d0f-48fe-aee6-2d3b0b797d49">
        <updating/>
        <source>select(label: CnEcAppGridAppLabel input; blnSelect: Boolean) updating;

// Selects/deselects specified appointment label

vars

begin
	if blnSelect then
		label.backColor := getSystemColor(Window.Color_Highlight);
		label.foreColor := getSystemColor(Window.Color_HighlightText);
		label.selected := self;
	else		
		label.backColor := label.color;
		label.foreColor := getSystemColor(Window.Color_BtnText);	
		label.selected := null;
	endif;
end;</source>
        <Parameter name="label" type="CnEcAppGridAppLabel" usage="input"/>
        <Parameter name="blnSelect" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setGridScale" id="9b9a82ce-769a-47b5-8b65-452c299f7146">
        <updating/>
        <source>setGridScale(intRowHeight: Integer; intColWidth: Integer; intFirstRowHeight: Integer; intFirstColWidth: Integer) updating;

// Sets AppGrid control row and column scale factors

vars
	lbl : CnEcAppGridAppLabel;
	intOldRowHeight : Integer;

begin
	// Save the old value for row height
	intOldRowHeight := self.rowHeight;

	// Set new values for row heights and column widths
	if intRowHeight &gt; 0 then
		self.rowHeight := intRowHeight;
	endif;
	if intColWidth &gt; 0 then
		self.columnWidth := intColWidth;
	endif;
	if intFirstRowHeight &gt; 0 then
		self.firstRowHeight := intFirstRowHeight;
	endif;
	if intFirstColWidth &gt; 0 then
		self.firstColumnWidth := intFirstColWidth;
	endif;

	// Rebuild the control using new values
	self.buildSelf();

	// Scroll all appointment labels to new positions
	foreach lbl in self.appLabels do
		lbl.gridSnap := lbl.gridSnap * self.rowHeight / intOldRowHeight;
		lbl.moveSelf(self.columnWidth * (self.appResources.indexOf(lbl.resource) - self.gridTable.leftColumn), getY(lbl.start), self.columnWidth, self.rowHeight / self.timeGrid * lbl.duration, false);
		lbl.status.move(lbl.width - lbl.status.width - 1, -1, lbl.status.width, lbl.status.height);		
	endforeach;

	// Refresh the control
	refreshNow();
end;</source>
        <Parameter name="intRowHeight" type="Integer"/>
        <Parameter name="intColWidth" type="Integer"/>
        <Parameter name="intFirstRowHeight" type="Integer"/>
        <Parameter name="intFirstColWidth" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setGridTime" id="9a603eba-446e-47e6-9bdb-34699958468d">
        <updating/>
        <source>setGridTime(timStart: Time; timEnd: Time; timGrid: Integer) updating;

// Sets AppGrid control starting and ending time, and time slot duration

vars
	lbl : CnEcAppGridAppLabel;
	intOldTimeGrid : Integer;

begin
	// Save old value for slot duration and set new values
	intOldTimeGrid := self.timeGrid;
	self.startTime := timStart;
	self.endTime := timEnd;
	self.timeGrid := timGrid;
	self.isSet := true;

	// Rebuild control using new values
	self.buildSelf();	

	// Move all appointment labels to new positions
	foreach lbl in self.appLabels do
		lbl.gridSnap := lbl.gridSnap * intOldTimeGrid / self.timeGrid;
		lbl.moveSelf(lbl.left, getY(lbl.start), lbl.width, self.rowHeight / self.timeGrid * lbl.duration, false);
	endforeach;

	// Refresh the control
	refreshNow();
	self.gridTable.setFocus();
end;</source>
        <Parameter name="timStart" type="Time"/>
        <Parameter name="timEnd" type="Time"/>
        <Parameter name="timGrid" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTitle" id="e72bd3bc-d347-4121-adc1-dd313bdbd89f">
        <updating/>
        <source>setTitle(strTitle: String) updating;

// Sets the caption for the top left 'fixed' cell in the control

vars
	intRow, intCol : Integer;

begin
	intRow := self.appGridTable.row;
	intCol := self.appGridTable.column;
	self.appGridTable.row := 1;
	self.appGridTable.column := 1;
	self.appGridTable.text := strTitle;
	self.appGridTable.row := intRow;
	self.appGridTable.column := intCol;
end;</source>
        <Parameter name="strTitle" type="String"/>
    </JadeMethod>
