    <JadeMethod name="doEnableDisableFields" id="8d1899a0-8855-485a-879a-67faf01db0b3">
        <source>doEnableDisableFields();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars
	inv		: CM_Invoice;
	bank 	: CM_Bank;
	
begin
	
	inv := self.myInvoice;
	
	if inv &lt;&gt; null then
		bank := inv.getBank();
	endif;
	
	if bank &lt;&gt; null then
		// We are using auto generated external number, disable this
		if bank.allAutoIdGenerators[CM_AutoIdGenerator.InvExtNumberType] &lt;&gt; null then
			self.txtExtNumber.enabled := false;
			self.txtExtNumber.bubbleHelp := app.getErrorString(FieldDisableAutoIDExtNum);
		endif;
	endif;
	
	self.btnSave.enabled := self.canUserDoMaint();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuUpdateExtRefClick" id="a28910e3-a6b0-4be3-83b9-3146479276e3">
        <source>doMnuUpdateExtRefClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars
	form				: INV_LinesOverrideExtReferences;
	theReturn			: Integer;
	allCMIFSummaries 	: CMIF_InvoiceExtRefSummaries;
	
begin
	form := app.loadForm(INV_LinesOverrideExtReferences, INV_Assistant, false, false, false, self.getMyTerminal(), null).INV_LinesOverrideExtReferences;
	
	if form = null then
		return;
	endif;
	
	create allCMIFSummaries transient;
	
	self.tblMain.allSelectedObjects.copy(allCMIFSummaries);
	
	form.setMyCMIFSummary(allCMIFSummaries);
	form.myCMIFHeader := self.myCMIFHeader;
	theReturn := form.showModal();
	
	// If something is updated/saved to the invoice lines, update the table
	if theReturn = INV_LinesOverrideExtReferences.SaveOK then
		self.doPopulateTable();
	endif;
	
epilog
	delete allCMIFSummaries;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPopulateTable" id="3a82085a-cb29-46f3-b4a4-0fdc826baad5">
        <source>doPopulateTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars
	tbl 			: CM_DataTable;
	cmifSummary		: CMIF_InvoiceExternalRefSummary;
begin
	tbl := self.tblMain;
	
	foreach cmifSummary in self.myCMIFHeader.allSummaries do
		tbl.updateItemObject(cmifSummary, null, null, app.myPassport);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="fc71a349-9199-4d6a-af3d-dfc72314ce4e">
        <updating/>
        <source>doSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars
	response,
	theReturn 	: Integer;
	cmif		: CMIF_InvoiceExternalRefHeader;
begin
	//23/01/2026	navkc1 JIRA MTN 37053
	if self.fieldHasChanged then
		response := app.msgBox(app.getErrorString(ExtFieldChangedContinue), app.getErrorString(Warning), MsgBox_Information_Icon + MsgBox_Yes_No);
		
		if response = MsgBox_Return_No then
			return;
		endif;
	endif;
	
	cmif := self.myCMIFHeader;
	
	cmif.externalFinancialID 	:= self.txtExtFinID.text;
	cmif.externalNumber 		:= self.txtExtNumber.text;
	cmif.externalTaxNumber 		:= self.txtExtTaxNum.text;
	
	while true do
		app.myTrxUA.trxUpdateInvExtFields(cmif, false, app.myPassport); //20/01/2026	navkc1 JIRA MTN 36571
			
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			app.beep();
			self.unloadForm();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
			return;
		endif;
		break;
	endwhile;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSummary" id="c92b0951-7b5b-46f5-a8ee-6321fe521dd6">
        <updating/>
        <source>doSummary() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars

begin
	
	self.myInvoice.getInvoiceExternalRefGrouped(self.myCMIFHeader);
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="b107893d-54b5-47e4-b29d-ec4b9645bb75">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars
	xmlStr : String;
	entTableRow : EntTableRow;
begin
	xmlStr := inheritMethod();
	
	// Save EntTable columns
	xmlStr &amp;= self.tblMain.getXmlStrForColumns(false);
	
	// Save form postition Top
	xmlStr &amp;= global.formatAsXML(self.XMLTag_Top, self.top.String);
	
	// Save form position Left
	xmlStr &amp;= global.formatAsXML(self.XMLTag_Left, self.left.String);
	
	return xmlStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="5fcfd943-08da-42f3-a628-bae529892f4d">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/12/2025	navkc1 JIRA 36262 ROS - 1 - External Reference updates in MTN 

*/

vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue, entName : String;
	pos : Integer;
	entRowName : EntTableRow;
	criteriaLine			: CM_SelectorCriteriaLine;
	idx	: Integer;
begin
	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;
	
	// Load position Top
	theXMLValue:= theXML.cnEcGetTagValueOfName(self.XMLTag_Top);	
	if theXMLValue &lt;&gt; null then
		self.top := theXMLValue.Real;
	endif;
	
	// Load position Left
	theXMLValue:= theXML.cnEcGetTagValueOfName(self.XMLTag_Left);
	if theXMLValue &lt;&gt; null then
		self.left := theXMLValue.Real;
	endif;
	

epilog

end;</source>
    </JadeMethod>
