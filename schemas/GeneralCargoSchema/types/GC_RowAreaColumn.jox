	TopTextMargin	: Integer = 10;
	
vars
	lX : Real;
	
begin
//	lX := (self.x1 + ((self.x2 - self.x1) / 2)) - ((self.label.length * 7) / 2); // all this puts the label in the middle
//	pFrame.drawTextAt(self.label, lX, TopTextMargin, Black);
end;</source>
        <Parameter name="pFrame" type="CMUI_Frame"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0753510b-9119-4abd-8dab-e3fe775b9a94">
        <updating/>
        <source>setForCreate(_row : CM_RowAreaRow; _idx : Integer; _rowArea : GC_RowArea) updating;
// ---------------------------------------------------------------------------
// Created:     14 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cController	: CM_RowController;
	yPoint		: GC_RowAreaPoint;

begin
	self.column			:= _idx;
	self.myGridArea		:= _rowArea;
	self.myRowAreaRow 	:= _row;
	self.width			:= _row.width;

	foreach cController in _row.allRowControllers do
		create yPoint transient;
		yPoint.setForCreate(cController, _idx, _rowArea);
	endforeach;
end;</source>
        <Parameter name="_row" type="CM_RowAreaRow"/>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_rowArea" type="GC_RowArea"/>
    </JadeMethod>
    <JadeMethod name="setRowPositions" id="cc844133-8a38-4d1a-afae-a9ff9794157b">
        <source>setRowPositions(_totHeight : Real);
// ---------------------------------------------------------------------------
// Created:     14 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cPoint	: CMUI_GridPoint;
	yPoint	: GC_RowAreaPoint;
	idx,
	numRows	: Integer;
	tmpPos,
	rowHeight	: Real;
		
begin
	numRows := self.allGridPointsByRow.size;
	
	if numRows &lt;= 0 then
		return;
	endif;
	rowHeight := _totHeight / numRows;

	foreach cPoint in self.allGridPointsByRow do
		yPoint := cPoint.GC_RowAreaPoint;
		tmpPos := idx * rowHeight;
		yPoint.setYPos(tmpPos, tmpPos + rowHeight);
		idx := idx + 1;
	endforeach;
end;</source>
        <Parameter name="_totHeight" type="Real"/>
    </JadeMethod>
</Class>
