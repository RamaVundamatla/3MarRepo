    <JadeMethod name="getPackLocationString" id="ad74aa89-ea2b-4e78-b51b-a6f7472f3f45">
        <source>getPackLocationString() : String;
// ---------------------------------------------------------------------------
// Created:		12 October 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aStr, tmpStr : String;
begin
	if not self.allPackLocations.isEmpty() then
		foreach aStr in  self.allPackLocations do
			if tmpStr = null then
				tmpStr := aStr;
			else
				tmpStr := tmpStr &amp; ", " &amp; aStr;
			endif;
		endforeach;
	endif;
	return tmpStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPackLocations" id="73b4135b-5429-40d3-a0c5-19d7277f6422">
        <source>getPackLocations(_taColl : Collection input);
// ---------------------------------------------------------------------------
// Created:     06 October 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpStr	: String;
	tmpTA	: CM_TerminalArea;
	
begin
	if _taColl = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_taColl', null, null);
		return;
	endif;
	_taColl.clear;
	if self.allPackLocations.isEmpty then
		return;
	endif;

	foreach tmpStr in self.allPackLocations do
		tmpTA := self.myTerminal.allTerminalAreaMastersById[tmpStr].CM_TerminalArea;
		if tmpTA &lt;&gt; null then
			_taColl.add(tmpTA);
		endif;
	endforeach;

end;</source>
        <Parameter name="_taColl" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getPackQuantity" id="1a617d81-badb-48b8-98c7-d6523a62b268">
        <source>getPackQuantity() : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	20 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	ti			: CM_TrackedItem;
	qty			: Integer;
begin
	//foreach ti in self.allTrackedItemsAssigned do	// PAR-14136 
	foreach ti in self.allTrackedItemsReleased do
		if ti.hasChildren then	//PAR 22954
			qty := qty + 1;
		endif;
	endforeach;

	return qty;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPickerObjectsForGate" id="60b9ba25-d8a7-4c9c-8ae2-c42538fbb5bd">
        <source>getPickerObjectsForGate(_foundObjects : ObjectArray input);
/*

Date		Who		Reason
01 March 2017	cnwer1	Initial creation TFS 1602 -moved code block from Road Gate

*/

vars
	reserve			: CM_ReserveDetail;
begin
	
	if self.releaseByType then
		foreach reserve in self.allReserveDetails discreteLock do
			_foundObjects.addExclusive(reserve);
		endforeach;
	else
		foreach reserve in self.allReserveDetails discreteLock do
		/*	if reserve.hasOutstanding() or
			   reserve = self.allReserveDetails.last then
				_foundObjects.addExclusive(reserve);
				break;
			endif; */
			//25 Oct 2018	NDL	TFS 4140
			if reserve.hasOutstanding() then
				_foundObjects.addExclusive(reserve);
			endif;
		endforeach;
	endif;	
	
epilog

end;</source>
        <Parameter name="_foundObjects" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getPinNumber" id="713425aa-e7c3-486a-b648-dd14d4bf337e">
        <source>getPinNumber() : String;
// Created by cnwvu1 on 28/02/2007

vars

begin

	if self.myPinNo &lt;&gt; null then
		return self.myPinNo.pinNo;
	endif;
	
	return null;

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPlannerReportGroup" id="1029a849-85af-43c7-aa29-1025869c83e1">
        <source>getPlannerReportGroup() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/11/2010	cnwdap1	Initial creation PAR #23794 CCMS MES 1102
29/11/2010	cnwdap1	PAR #26426 CCMS MES 1102 Release requests on ship load list
20/07/2018	jlgmd1	TFS #39261 SNO - Show Reserve Detail lines on Load List
*/
vars
/*	group 		: Integer;
	cargoType	: CM_CargoType;
	isoCode		: String;
	isoGroup	: CM_ISOTypeGroup;
	commString	: String;
	comm		: CM_Commodity;
*/
begin
	
	// Moved to CM_ReserveDetail::getPlannerReportGroup
	
/*	group := null;
	
	// PAR #26426 if we have a voyage, check for voyage allocations
	if self.myVoyage &lt;&gt; null and self.myVoyage.useVoyageAllocations and self.myAssignedTrain = null then
		return self.getVoyageAllocationGroup();
	endif;
	// PAR #26426 end
	
	cargoType := self.getMyCargoType();
	if cargoType &lt;&gt; null then
		if cargoType.id = TI_CargoType_Container then
			isoCode := self.getISOCode;
			if isoCode &lt;&gt; null then
				isoGroup := app.myRoot.allISOTypes[isoCode].myISOTypeGroup;
			else
				isoGroup := self.getISOGroup();
			endif;
			if isoGroup &lt;&gt; null then
				// first get length sorted
				if isoGroup.is40ftLong then
					group := PlanningGroup_FortyFoot;
				elseif isoGroup.is30ftLong then
					group := PlanningGroup_ThirtyFoot;
				elseif isoGroup.is45ftLong then
					group := PlanningGroup_FortyFiveFoot;
				elseif isoGroup.is53ftLong then
					group := PlanningGroup_FiftyThreeFoot;
				else
					group := PlanningGroup_TwentyFoot;
				endif;
				
				// Now check special attributes
				if isoGroup.isFlat() then
					group := group + PlanningGroup_FlatRack;
				elseif isoGroup.isCrib() then
					group := group + PlanningGroup_Crib;
				elseif isoGroup.isFrame() then	//05 Feb 2018	NDL	TFS 36752
					group := group + PlanningGroup_Frame;
				elseif isoGroup.isTank() then
					group := group + PlanningGroup_Tank;
				elseif isoGroup.isOpenTop() then
					group := group + PlanningGroup_OpenTop;
				elseif isoGroup.isFantainer() then
					group := group + PlanningGroup_Fantainer;
				endif;
			endif;
			
			// Now empty or power
			if not self.fullRelease then
				commString := self.myTerminal.getDefaultEmptyCommodity();
				comm := app.myRoot.allCommodities[commString];
			endif;
			if comm &lt;&gt; null then
				if comm.isEmpty then
					group := group + PlanningGroup_Empty;
				elseif comm.requiresPower then
					group := group + PlanningGroup_PowerRequired;
				endif;
			endif;
			
		else
			// Non-container cargo, so sort to the end, with System-defined types before
			// User-defined types
			group := cargoType.id;
			if group &lt; TI_CargoBOLType_Max then
				group := TI_CargoBOLType_Max - group;
			endif;
		
		endif;
	endif;
	
	return group.String.padLeadingZeros(5).truncatedAt(5);
*/

	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPlannerReportGroupDesc" id="926380f2-7f09-4f07-ba56-d4bb88093faf">
        <source>getPlannerReportGroupDesc() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/11/2010	cnwdap1	Initial creation PAR #23794 CCMS MES 1102
29/11/2010	cnwdap1	PAR #26426 Release requests on ship load list 
20/07/2018	jlgmd1	TFS #39261 SNO - Show Reserve Detail lines on Load List
*/
vars
/*	groupDesc		: String;
	cargoType		: CM_CargoType;
	isoCode			: String;
	isoGroup		: CM_ISOTypeGroup;
	cargoTyp		: CM_CargoType;
	comm			: CM_Commodity;
	isGen			: Boolean;
*/	
begin

	// Moved to CM_ReserveDetail::getPlannerReportGroupDesc

/*	groupDesc := null;
	
	// PAR #26426 if voyage uses voyage allocations, return voyage allocation code not planner group
	if self.myVoyage &lt;&gt; null and self.myVoyage.useVoyageAllocations and self.myAssignedTrain = null then
		return self.getVoyageAllocationGroupDesc();
	endif;
	// PAR #26426 end
	
	cargoType := self.getMyCargoType();
	if cargoType &lt;&gt; null then
		if cargoType.id = TI_CargoType_Container then
			// First get length sorted
			isoCode := self.getISOCode;
			if isoCode &lt;&gt; null then
				isoGroup := app.myRoot.allISOTypes[isoCode].myISOTypeGroup;
			else
				isoGroup := self.getISOGroup();
			endif;
			if isoGroup &lt;&gt; null then
				if isoGroup.is40ftLong then	
					groupDesc := app.getErrorString(FortyFoot);
				elseif isoGroup.is30ftLong then
					groupDesc := app.getErrorString(ThirtyFoot);
				elseif isoGroup.is45ftLong then
					groupDesc := app.getErrorString(FortyFiveFoot);
				elseif isoGroup.is53ftLong then
					groupDesc := app.getErrorString(FiftyThreeFoot);
				else
					groupDesc := app.getErrorString(TwentyFoot);
				endif;
			
				// Now check special attributes
				if isoGroup.isFlat() then
					groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_FlatRack);
				elseif isoGroup.isCrib() then
					groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Crib);
				elseif isoGroup.isTank() then
					groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Tank);
				elseif isoGroup.isOpenTop() then
					groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_OpenTop);
				elseif isoGroup.isFantainer() then
					groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Fantainer);
				else
					isGen := true;
				endif;
			endif;
				
			// Now empty or power
			if not self.fullRelease then
				comm := app.myRoot.allCommodities[self.myTerminal.getDefaultEmptyCommodity];
			endif;
			if comm &lt;&gt; null then
				if comm.isEmpty then
					groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Empty);
				elseif comm.requiresPower then
					groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_Integral);
				elseif isGen then
					groupDesc := groupDesc &amp; " " &amp; app.getErrorString(SummaryDesc_General);
				endif;
			endif;
			
		else
			// Non-container cargo, so use Cargo Type Description
			groupDesc := cargoTyp.description;
		endif;
	else
		groupDesc := app.getErrorString(SummaryDesc_Unknown);
	endif;
	
	return groupDesc.truncatedAt(30);
*/
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProspectiveCargo" id="044034f3-8ee3-4191-9c50-092eaad9fb56">
        <source>getProspectiveCargo(	_reserveDetail 	 	: CM_ReserveDetail;
						_stagedYardLocation : CM_TerminalArea;
						_targetLocation 	: CM_LocationsController;
						_parentTI			: CM_TrackedItem;
						_tiDictionary		: Collection input;
						_isByID 			: Boolean;
						_limit, _index		: Integer;
						_count				: Integer io	);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 01 July 2019
TFS#		: 45287
Function	: Copy from MobileUISchema::MOB_HandHeldForm::getBRPropsectiveChildCargo

*** Changes ***
Date		Name	TFS#	Description
15/08/2019	jlgka1	45924	JMT - Pack by Request - Webservice. 
							BA decided to change the logic to use CM_TerminalArea instead of the yard interchanged
							and use a Dictionary instead of TIArray.
30/08/2021	jlier1	51879   Put in all the cargo group stuff so when called by new webservices used by STW apps they work the same as old HH
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
20/12/2024	navkc1	JIRA Bug MTN-33697: MTN - Internal server error in release staging app
05/03/2025	navdap1	MTN-34024 PRP | Deadlock 1081, Yard Allocation &amp; Release Request Performance
****************************************************/

vars
	ti 					 : CM_TrackedItem;
	opTerm 				 : CM_OperatorTerminal;
	reserve 			 : CM_ReserveDetail;
	reserveSelection	: CM_ReserveSelection;
	reason 				 : String;
	reserveDetails		 : CM_ReserveDetailSet;
	locController		 : CM_LocationsController;	
	usesCargoGroup		 : Boolean;		
	truck : CM_Vehicle;	
	jobReserveDetails : CM_ReserveDetailSet;
	roadJob : CM_Job;
	req : CM_Request;
	tiSet : CM_TISet;
	allTis	: CM_TISet;
	tiArea : CM_TerminalArea;	// MTN-34024
begin
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	//if _reserveDetail.isKindOf(CM_ReserveTI) then
	// Is CM_ReserveTI
	if _reserveDetail &lt;&gt; null and not _reserveDetail.isReserveSelection() then //20/12/2024	navkc1 JIRA Bug MTN-33697
		_reserveDetail.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
		//foreach ti in _reserveDetail.allTrackedItems do
		foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
			//epr TFS 45291 23/9/19 
			if not ti.isAvailableToStageFor(self) then
				continue;
			endif;
			
			// MTN-34024 if we're a "by id" query, check whether we have enough yet
			if _isByID then
				if _count &gt; ((_index - 1) + _limit) then
					break;
				endif;
				_count += 1;
				if _index &gt; 1 and _count &lt; _index then
					continue;
				endif;
			endif;
			// MTN-34024 end of this bit
			//_tiDictionary.add(ti);			
			_tiDictionary.tryAdd(ti); //20/12/2024	navkc1 JIRA Bug MTN-33697
		endforeach;
		return;
	endif;
	
	usesCargoGroup := app.isCargoGroupEnabled;	
	//epr TFS 51879 31/8/21
	//if _reserveDetail.isKindOf(CM_ReserveSelection) then
	if _reserveDetail &lt;&gt; null and _reserveDetail.isReserveSelection() then //20/12/2024	navkc1 JIRA Bug MTN-33697
		reserveSelection:=_reserveDetail.CM_ReserveSelection;
	endif;
	if usesCargoGroup then
		if not self.getProspectiveCargoForCG(_targetLocation, _parentTI,reserveSelection,_tiDictionary) then
			return;
		endif;
	endif;
	//epr TFS 45291 23/9/19 
	if self.isPackingType then
		reserveDetails:= self.allReservePackingChildren;
	else
		reserveDetails:=self.allReserveDetails;
	endif;
	
	if _stagedYardLocation &lt;&gt; null then
		foreach locController in _stagedYardLocation.allLocationsControllers discreteLock do
			//all cargo is staged in the interchange area, NO cross-checking is performed
			foreach ti in locController.allTrackedItems discreteLock where ( ti.isAvailableToStageFor(self))  do: outerLoop 
				foreach reserve in reserveDetails discreteLock do 
					if _reserveDetail &lt;&gt; null and reserve &lt;&gt; _reserveDetail  then
						continue;
					endif;
					// then				
						//If we have a reserve selection and it doesn't match skip it.
						//if reserve.isKindOf(CM_ReserveSelection) then
						if reserve.isReserveSelection() then //20/12/2024	navkc1 JIRA Bug MTN-33697
							if not ti.testAgainstReserveSelection( reserve.CM_ReserveSelection, reason, true, null ) then	
								continue;
							endif;
						else
							//jlier1 TFS 52444 29/11/21
							//if  not reserve.allTrackedItems.includes(ti) then
							if  not reserve.includeTrackedItem(ti, false) then //23/06/2023	navkc1	CR 58406 Task 58408
								continue;
							endif;
						endif;
					//endif;
					//_tiDictionary.add(ti);			
					_tiDictionary.tryAdd(ti); //20/12/2024	navkc1 JIRA Bug MTN-33697
					continue outerLoop;
				endforeach;	
			endforeach;
		endforeach;
		return;
		
	endif;
		
	// Release by id or release by type with assigned items
	// get the nominated child cargo
	foreach reserve in self.allReserveDetails discreteLock do
		if _reserveDetail &lt;&gt; null and reserve &lt;&gt; _reserveDetail then	
			continue;
		endif;
		//epr TFS 51879 31/8/21 - refactored into method on reserveDetail
		reserve.getProspectiveCargo(_targetLocation,_tiDictionary);
	endforeach;
	
	if self.isPackingType then
		foreach reserve in self.allReservePackingChildren discreteLock do
			if _reserveDetail &lt;&gt; null and reserve &lt;&gt; _reserveDetail then	//03 Oct 2016	NDL	TFS 
				continue;
			endif;
			//epr TFS 51879 31/8/21 - refactored into method on reserveDetail
			reserve.getProspectiveCargo(_targetLocation,_tiDictionary);
		endforeach;
	endif;
	
	create tiSet transient;
			
	if self.releaseByType and _tiDictionary.isEmpty then
		// release by type
		//epr TFS 51879 31/8/21
		if usesCargoGroup and reserveSelection = null then		
			if _targetLocation &lt;&gt; null then	//16 Apr 2018	NDL TFS 38083
				if _targetLocation.isVehicle then	
					truck := _targetLocation.CM_VehicleController.vehicle;
				elseif _targetLocation.isTILCController then	//27 Feb 2018	NDL	TFS 37354
					truck := _targetLocation.CM_TILCController.getVehicle;
				endif;
			endif;
			if truck &lt;&gt; null then
				//we have a truck, build a set of the reserve details on the associated job.
				create jobReserveDetails transient;
				roadJob := truck.allRoadJobs.first;
				if roadJob &lt;&gt; null then
					foreach req in roadJob.allRequests discreteLock do
						if req.myReserveDetail &lt;&gt; null then
							jobReserveDetails.addNoDuplicates(req.myReserveDetail,false);
						endif;
					endforeach;
				endif;
			endif;
			
		endif;
		
		
		// get the prospective children - i.e. they are for the operator and match the release details
		opTerm := self.myOperatorTerminal;
		if opTerm &lt;&gt; null then
			foreach reserve in reserveDetails discreteLock do
				if _reserveDetail &lt;&gt; null and reserve &lt;&gt; _reserveDetail then	
					continue;
				endif;
				//if not reserve.isKindOf( CM_ReserveSelection ) then
				if not reserve.isReserveSelection() then //20/12/2024	navkc1 JIRA Bug MTN-33697
					continue;
				endif;
				
				if reserve.isComplete then
					continue;
				endif;
				//epr TFS 51879 31/8/21	
				if usesCargoGroup then				
					if truck &lt;&gt; null then
						if jobReserveDetails &lt;&gt; null and not jobReserveDetails.isEmpty then
							if not jobReserveDetails.includes( reserve ) then
								continue;
							endif;
						endif;
					endif;					
					if self.isPackingType then
						if reserve.isFullyPacked then
							continue;
						endif;
					else
						if reserve.isFullyLoaded then
							continue;
						endif;
					endif;					
					tiSet.clear;
					self.getNonStagedAvail( reserve.CM_ReserveSelection, tiSet, _isByID, _index, _limit, _count);	// MTN-34024
					foreach ti in tiSet do
						//_tiDictionary.add(ti);			
						_tiDictionary.tryAdd(ti); //20/12/2024	navkc1 JIRA Bug MTN-33697
					endforeach;
					continue;	//16 Apr 2018	NDL	TFS 38083 - STW unconditionally use cargo id or cargo group id as extra criteria.	
				endif;	
					
					
				foreach ti in opTerm.allOnsiteTIsByCargoTypeId discreteLock do
					tiArea := ti.myPrimaryActualLocation.myTerminalArea;	// MTN-34024
					if tiArea &lt;&gt; null and tiArea.isInterchangeArea then		// MTN-34024
						continue;											// MTN-34024
					endif;													// MTN-34024
					
					if not ti.isAvailableToStageFor(self) then
						continue;
					endif; 
					
					if not ti.testAgainstReserveSelection( reserve.CM_ReserveSelection, reason, true, null ) then
						continue;
					endif;
					
					// MTN-34024 more filtering by count / index for CARGOID ordered queries
					if _isByID then
						_count += 1;
						if _index &gt; 1 and _count &lt; _index then
							continue;
						endif;
					endif;
					// MTN-34024 end first bit
					
					//_tiDictionary.add(ti);			
					_tiDictionary.tryAdd(ti); //20/12/2024	navkc1 JIRA Bug MTN-33697
					
					// MTN-34024 more CARGOID filtering / counting
					if _isByID and _count &gt;= ((_index-1)+_limit) then
						break;
					endif;
					// MTN-34024 end more
				endforeach;
			endforeach;
		endif;
	endif;

epilog
	delete tiSet;
	delete jobReserveDetails;
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <Parameter name="_stagedYardLocation" type="CM_TerminalArea"/>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <Parameter name="_parentTI" type="CM_TrackedItem"/>
        <Parameter name="_tiDictionary" type="Collection" usage="input"/>
        <Parameter name="_isByID" type="Boolean"/>
        <Parameter name="_limit" type="Integer"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_count" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getProspectiveCargoForCG" id="60c38d19-82fa-40b2-885c-838872062f7a">
        <source>getProspectiveCargoForCG(_targetLocation : CM_LocationsController;
						_parentTi : CM_TrackedItem;
						_reserveSelection : CM_ReserveSelection input;
						_tiArray : Collection input) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2021	jlier1	Initial creation TFS 51879
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
20/12/2024	navkc1 JIRA Bug MTN-33697: MTN - Internal server error in release staging app
*/

vars
	tiSet : CM_TISet;
	firstStagingLC : CM_LocationsController;
	outStandingItemCount : Integer;
	stagedItemCount : Integer;
	onTruckCount : Integer;
	allowOtherReleases: Boolean;
	childTi, ti : CM_TrackedItem;
	reserve : CM_ReserveDetail;
begin
	create tiSet transient;
				
	if _reserveSelection &lt;&gt; null then
		//11 Dec 2015	NDL	Par 37288
		outStandingItemCount := _reserveSelection.getTotalOutstanding;
		stagedItemCount := _reserveSelection.getTotalStaged(tiSet, firstStagingLC, null);
		if _targetLocation &lt;&gt; null then
			onTruckCount := _reserveSelection.getTotalAssignedInLocation(_targetLocation);
		//20 Mar 2017	NDL	TFS 3667
		elseif _parentTi &lt;&gt; null then
			foreach childTi in _parentTi.allChildren discreteLock do
				//if _reserveSelection.allTrackedItems.includes( childTi ) then	// 20 Dec 2018	NDL	TFS 38083
				if _reserveSelection.includeTrackedItem( childTi , false) then	//23/06/2023	navkc1	CR 58406 Task 58408
					onTruckCount := onTruckCount + childTi.totalQuantity.max(1);
				endif;
			endforeach;
		endif;
		if outStandingItemCount &gt; 0 and outStandingItemCount = ( stagedItemCount + onTruckCount ) then
			foreach ti in tiSet discreteLock do
			
				//20 Mar 2017	NDL	TFS 3667
				if _parentTi &lt;&gt; null then
					if ti.isChild then
						continue;
					endif;
				endif;
				
				//_tiArray.add( ti );
				_tiArray.tryAdd( ti ); //20/12/2024	navkc1 JIRA Bug MTN-33697
			endforeach;
			return false;
		endif;
		
	else
		if _parentTi &lt;&gt; null then
			//packing type.
			foreach reserve in self.allReservePackingChildren do
				outStandingItemCount := outStandingItemCount + reserve.getTotalOutstanding;
				stagedItemCount := stagedItemCount + reserve.getTotalStaged(tiSet, firstStagingLC, null);
			endforeach;
			foreach childTi in _parentTi.allChildren do
				onTruckCount := onTruckCount + childTi.totalQuantity.max(1);
			endforeach;
			if outStandingItemCount &gt; 0 and outStandingItemCount = ( stagedItemCount + onTruckCount ) then
				foreach ti in tiSet discreteLock where not ti.isChild do
					//_tiArray.add( ti );
					_tiArray.tryAdd( ti ); //20/12/2024	navkc1 JIRA Bug MTN-33697
				endforeach;
				return false;
			endif;
		else
			outStandingItemCount := self.getTotalOutstanding;		
			stagedItemCount := self.getTotalStaged(tiSet, firstStagingLC);
			if _targetLocation &lt;&gt; null then
				if _reserveSelection &lt;&gt; null then                           //cnwma1 TFS #4017 07/04/2017
					onTruckCount := _reserveSelection.getTotalAssignedInLocation(_targetLocation);
				else
					 foreach reserve in self.allReserveDetails discreteLock where reserve.isKindOf(CM_ReserveSelection)  do    //cnwma1 TFS #4017 07/04/2017
							onTruckCount := onTruckCount + reserve.CM_ReserveSelection.getTotalAssignedInLocation(_targetLocation);				
					 endforeach;
				endif;

			endif;
			if outStandingItemCount &gt; 0 and outStandingItemCount = ( stagedItemCount + onTruckCount ) then
				foreach ti in tiSet discreteLock do			
					//_tiArray.add( ti );
					_tiArray.tryAdd( ti ); //20/12/2024	navkc1 JIRA Bug MTN-33697
				endforeach;
				return false;
			endif;
		
		endif;
		
	endif;
	
	return true;
epilog
	delete tiSet;
end;</source>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <Parameter name="_parentTi" type="CM_TrackedItem"/>
        <Parameter name="_reserveSelection" type="CM_ReserveSelection" usage="input"/>
        <Parameter name="_tiArray" type="Collection" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getProspectivePackingParents" id="802ef548-5526-4478-b4a1-b4da66eaed24">
        <source>getProspectivePackingParents( tiArray : CM_TIArray input; isFromWeb : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date				Name	TFS#		Description
============================================================================
11 December 2015	cnwndl1	Par 37288	Initial creation	
11 Jan 2018			cnwrs1	TFS 36603 	STW fix locking issue
03 May 2019			jlgzm1	TFS44531 	STW use HH app to pack complete containers twice
21 Aug 2019			jlgka1 	TFS 46218 	JMT - Stop the getProspectivePackingParents  to findMore when it is coming from Web.
23/06/2023			navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
14 OCt 2024			jlier1  TFS 66302  TPT | Packing Multiple Containers on one Release Request By Type
============================================================================*/

vars

	ti : CM_TrackedItem;
	reserve : CM_ReserveDetail;
	opTerm : CM_OperatorTerminal;
	reason : String;
	totalRequested : Integer;
	foundTotal : Integer;
	findMore :Boolean;
	iter : Iterator;
	cargoType : CM_CargoType;
	startObject : CM_TrackedItem;
	allTis	: CM_TISet;
	lastAssignTrx		: CM_TITransaction;
	checkPackComplete  : Boolean;
begin

	if not self.isPackingType then
		return;
	endif;

	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	if self.myTerminal &lt;&gt; null then
		checkPackComplete:=self.myTerminal.getConfig(WebIncludePackComplete).Boolean; //jlier1 TFS 66302 14/10/24
	endif;
	// get the nominated parents
	findMore := false;
	foreach reserve in self.allReserveDetails discreteLock do	
		totalRequested := totalRequested + reserve.totalRequested; 
		reserve.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
		//foreach ti in reserve.allTrackedItems discreteLock do
		foreach ti in allTis discreteLock do //23/06/2023	navkc1	CR 58406 Task 58408
			foundTotal := foundTotal + 1;	// add anyway
			if not ti.isOnSite or ti.myPrimaryActualLocation = null then
				continue;
			endif;
			if not checkPackComplete then //TFS44531
				if ti.isPackingComplete then	//20 Dec 2018	- No longer a prospect
					continue;
				endif;
			endif;
			
			if isFromWeb then
				//jlier1 TFS 66302 14/10/24 if assigned in web continue so they can type in container again
				lastAssignTrx:=ti.allTransactions.getLastTransOfType(TRANS_TYPE_REL_REQ_ASSIGN,null);
				if lastAssignTrx &lt;&gt; null and lastAssignTrx.CM_RelRequestAssign.myBulkReleaseCode &lt;&gt; null and lastAssignTrx.CM_RelRequestAssign.myBulkReleaseCode = self.code and lastAssignTrx.isFromMobileApp then
					continue;
				endif;
			endif;
			
			tiArray.addExclusive( ti );
		endforeach;
		if foundTotal &lt; totalRequested then
			//didn't find enough.
			if not isFromWeb then
				findMore:= true;
			endif;
		endif;
	endforeach;
	
	if findMore and not isFromWeb then
		//check more generally
		opTerm := self.myOperatorTerminal;
		if opTerm &lt;&gt; null then
			iter := opTerm.allOnsiteTIsByCargoTypeId.createIterator;
			foreach reserve in self.allReserveDetails discreteLock  do
				if not reserve.isKindOf( CM_ReserveSelection ) then
					continue;
				endif;
				cargoType := reserve.CM_ReserveSelection.myCargoType;
				startObject := opTerm.allOnsiteTIsByCargoTypeId.getAtKeyGeq(cargoType.id, null);
				if startObject &lt;&gt; null then
					iter.startAtObject(startObject);
					while iter.next(ti) do
						if ti.cargoType &lt;&gt; cargoType.id then
							break;
						endif;
						if ti.isPackingComplete then	//20 Dec 2018	- No longer a prospect
							continue;
						endif;
//				foreach ti in opTerm.allOnsiteTIsByCargoTypeId do
						if self.allTrackedItemsReleased.includes(ti) then
							continue;
						endif;
						if not ti.allBulkReleasesAssigned.isEmpty then
							//can't be a parent on multiple releases
							continue;
						endif;
						if ti.testAgainstReserveSelection( reserve.CM_ReserveSelection, reason, true, null ) then
							tiArray.addExclusive( ti );				
						endif;
	//				endforeach;
					endwhile;
				endif;
			endforeach;
		endif;
	endif;

epilog
	delete iter;
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="isFromWeb" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getProspectiveParentCargo" id="b87bfc49-4f41-40b5-b9f6-71ee83c21887">
        <source>getProspectiveParentCargo(parentsArray : CM_TIArray io; isFromWeb : Boolean);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 28 June 2019
TFS#		: 45287
Function	:

*** Changes ***
Date		Name	TFS#		Description
21/08/2019	jlgka1 	TFS 46218 	JMT - Stop the getProspectivePackingParents  to findMore when it is coming from Web.
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
****************************************************/
vars
	trackedItem 	: CM_TrackedItem;
	reserve 		: CM_ReserveDetail;	
	allTis			: CM_TISet;
begin
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	if self.isPackingType then		
		self.getProspectivePackingParents( parentsArray, isFromWeb );
	else

		if not self.releaseByType then
			// Release by id
			// get the nominated parents
			foreach reserve in self.allReserveDetails do	
				reserve.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
				//foreach trackedItem in reserve.allTrackedItems do
				foreach trackedItem in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
					if self.allTrackedItemsReleased.includes(trackedItem) then
						continue;
					endif;
					if trackedItem.isContainer then
						parentsArray.add(trackedItem);						
					endif;
				endforeach;
			endforeach;
				
		else
			// release by type
			// get the prospective parents
			
			self.getByTypeProspects(parentsArray);	
		endif;	
	endif;		

epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="parentsArray" type="CM_TIArray" usage="io"/>
        <Parameter name="isFromWeb" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getRailWleToAssignTiTo" id="8509284f-bed5-477f-ae52-359b09c3afcb">
        <source>getRailWleToAssignTiTo( _reserveDetail : CM_ReserveDetail; _ti : CM_TrackedItem ) : CM_WorkListEntry;
/*

Purpose:			

Parameters:			Find a wle rail wle for a release that is using a TBA (Rail style of assigned director task)

Return Value:		

Date		Who		Reason
11 January 2017	cnwndl1	Initial creation	TFS 3192 / 2877
27 Apr 2023 jlier1 TFS 56773
*/

vars

	req : CM_Request;
	delReq : CM_DeliveryRequest;
	wle : CM_WorkListEntry;

begin

	if not self.isRailType then
		return null;
	endif;

	foreach req in self.allRequestsBeingActioned discreteLock do
		if _reserveDetail &lt;&gt; null and req.myReserveDetail &lt;&gt; _reserveDetail then
			continue;
		endif;
		if not req.isKindOf( CM_DeliveryRequest ) then
			continue;
		endif;
		delReq := req.CM_DeliveryRequest;
		foreach wle in delReq.allWorkListEntries discreteLock do
			if wle.status &lt;&gt; WLE_UNACTIONED then
				continue;
			endif;
			if wle.myTrackedItem &lt;&gt; null and not wle.myTrackedItem.isRRP then
				continue;
			endif;
			return wle;
		endforeach;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getReleaseByTypeDescr" id="215474d0-e893-4459-9c7c-2cb4ae57d373">
        <source>getReleaseByTypeDescr() : String;
/*
----------   ----------  --------------------------------------------------
Created:	10 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	str			: String;
begin
	
	str := self.getTotalRequested.String &amp; ' requested, ' &amp; self.getTotalReleased().String;
	if self.type = BR_TYPE_PACKING then
		str := str &amp; ' packed';
	else
		str := str &amp; ' released';
	endif;
	return str;
	
end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReleaseDetails" id="507e2571-70d2-4585-92e0-a839817196ef">
        <source>getReleaseDetails() : String;
// ---------------------------------------------------------------------------
// Created:     20 March 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	str		: String;
	reserveSelObj	: CM_ReserveDetail;
begin
	if self.releaseByType then
		reserveSelObj	:=	self.allReserveDetails.first().CM_ReserveSelection;
		str := 'ISO Type' &amp; Tab &amp; Tab &amp; self.getISOCode &amp; CrLf &amp;
		       'AVA Grade' &amp; Tab &amp; self.getAvailabilityGrades() &amp; CrLf &amp;
			   'Remarks' &amp; Tab &amp; reserveSelObj.remarks &amp; CrLf;
		
	endif;
	
	return str;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReleasedIDs" id="8be0f386-4c63-4f70-9328-092fa34fb379">
        <source>getReleasedIDs() :String;
//-----------------------------------------------------------------------
//	Created:	26 June 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	str	: String;
	ti	: CM_TrackedItem;
	
begin

	foreach ti in self.allTrackedItemsReleased do
	
		str := ti.id &amp; ' ' &amp; str;
	
	endforeach;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRemainingPackCont" id="c00d49f6-f904-4a72-8bb9-06bd6c9f8a71">
        <source>getRemainingPackCont(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jul 2024 navhl20	ChangeRequest 61368: EUP* | Adding Pack Reserve Child to Packing Work order Release Request

*/

vars
	ti			: CM_TrackedItem;
	totalReq,
	totalComp	: Integer;
	resDtl		: CM_ReserveDetail;
begin
	foreach resDtl in self.allReserveDetails do
		totalReq := totalReq + resDtl.totalRequested;
	endforeach;
	
	foreach ti in self.allTrackedItemsAssigned where ti.isKindOf(CM_Container) do
		if ti.isPackingComplete then //jlier1 #MTN-33178 11/11/24
			totalComp := totalComp + ti.totalQuantity;
		endif;
	endforeach;
	
	return totalReq - totalComp;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRemarks" id="a69d6883-56bb-49a7-8e4c-a498649804c0">
        <source>getRemarks() : String;
/*
----------   ----------  --------------------------------------------------
Created:	14 September 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	reserveDetail			: CM_ReserveDetail;
	remarks					: String;
begin
	if self.releaseByType then
		foreach reserveDetail in self.allReserveDetails do
//		reserveDetail := self.allReserveDetails.first;
			if reserveDetail &lt;&gt; null and reserveDetail.remarks &lt;&gt; null then
				if remarks = null then
					remarks := reserveDetail.remarks;
				else
					remarks := remarks &amp; '; ' &amp; reserveDetail.remarks;
				endif;
			endif;
		endforeach;
		foreach reserveDetail in self.allReservePackingChildren do
//		reserveDetail := self.allReserveDetails.first;
			if reserveDetail &lt;&gt; null and reserveDetail.remarks &lt;&gt; null then
				if remarks = null then
					remarks := reserveDetail.remarks;
				else
					remarks := remarks &amp; '; ' &amp; reserveDetail.remarks;
				endif;
			endif;
		endforeach;
	endif;
	if self.cargoRemarks &lt;&gt; null then
		remarks := remarks &amp; '; ' &amp; self.cargoRemarks;
	endif;
	
	return remarks;
	

end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReserveDetail" id="ea0c3f22-23a2-4bf1-9d95-5ce3beeb781a">
        <source>getReserveDetail() : CM_ReserveSelection;

vars

begin
	if self.allReserveDetails.size &gt; 0 and 
			self.allReserveDetails.first.isKindOf(CM_ReserveSelection) then
		return self.allReserveDetails.first.CM_ReserveSelection;
	endif;
	return null;
end;
</source>
        <ReturnType type="CM_ReserveSelection"/>
    </JadeMethod>
    <JadeMethod name="getReserveDetailFor" id="3ba3a609-be1a-4347-99ca-c5574751321b">
        <source>getReserveDetailFor( _ti : CM_TrackedItem ):CM_ReserveDetail;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2016	cnwndl1	Initial creation	TFS 2648 / 2001

*/

vars

	iter : Iterator;
	reserveDetail : CM_ReserveDetail;

begin

	iter := self.allReserveDetails.createIterator;
	while iter.next( reserveDetail) do
		//if reserveDetail.isTIAssigned( _ti ) then
		if _ti.allReserveDetails.includes( reserveDetail ) then
			return reserveDetail;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="getReserveDetailsForWorkOrder" id="5d207201-2c4e-4868-a11f-06ef8303172a">
        <source>getReserveDetailsForWorkOrder(_workorder : CM_WorkOrderTI; _details : ObjectArray input);
//
// Purpose:			Check the reserve details on this release to see if they have 
//					a TI matching the source ti list for the work order
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
// 24 Jan 2023	navma1  	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
// 23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
//
vars
	detail : CM_ReserveDetail;
	ti : CM_TrackedItem;
	pos : Integer;
	allTis	: CM_TISet;
	
begin
	if _workorder.mySource = null then   //24.01.2023 navma1 #56141 Task#56147
		return;
	endif;
	
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	foreach detail in self.allReserveDetails discreteLock do
		detail.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
		//foreach ti in detail.allTrackedItems discreteLock do
		foreach ti in allTis discreteLock do //23/06/2023	navkc1	CR 58406 Task 58408
			pos := _workorder.mySource.tiTextList.pos(ti.id, 1);
			if pos &gt; 0 then
				_details.addExclusive(detail);
				break;
			endif;
		endforeach;
	endforeach;
epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="_workorder" type="CM_WorkOrderTI"/>
        <Parameter name="_details" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getReserveTIforTI" id="4ecbf46a-3b40-4953-aed0-049253f53486">
        <source>getReserveTIforTI(_ti : CM_TrackedItem) : CM_ReserveTI;
/*

Date		Who		Reason
28 August 2013	cnwer1	Initial creation PAR 32330

*/

vars
	reserveDetail : CM_ReserveDetail;
	ti : CM_TrackedItem;
begin
	if self.releaseByType then
		return null;
	endif;
	
	if  _ti = null then
		return null;
	endif;
	
	
	foreach reserveDetail in self.allReserveDetails do
		if not reserveDetail.isKindOf(CM_ReserveTI) then
			continue;
		endif;
		
		ti :=reserveDetail.CM_ReserveTI.getTI;
		
		//epr par 32543
		if ti = null then
			continue;
		endif;
		
		//epr par 34154  18/11/14
		if ti.isOffSite then
			continue;
		endif;
		//epr par 34154  18/11/14
		if ti.hasBeenMerged then
			continue;
		endif;
		
		if ti= _ti then
			return reserveDetail.CM_ReserveTI;
		endif;
		
		if _ti.canSplitTotalQuantity then
			if ti.id = _ti.id then
				return reserveDetail.CM_ReserveTI;
			endif;	
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_ReserveTI"/>
    </JadeMethod>
    <JadeMethod name="getSummaryDescription" id="4a8be438-073c-4fd6-9019-318c4ff55f9b">
        <source>getSummaryDescription() : String;
/*
----------   ----------  --------------------------------------------------
Created:	29 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	str 				: String;
	reserveDetail		: CM_ReserveDetail;
begin
	str := self.code &amp; ': ' &amp; self.getTypeDescription() &amp; ' ';
	if self.releaseByType then
		str := str &amp; app.getErrorString(Release_by_type) &amp; CrLf;
		foreach reserveDetail in self.allReserveDetails do
			str := str &amp; reserveDetail.getDescription() &amp; CrLf;
		endforeach;
	else
		str := str &amp; app.getErrorString(Release_By_Id) &amp; CrLf &amp;
					self.allTrackedItemsAssigned.size.String &amp; ' item assigned';
		
	endif;
	
	return str;
end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTICategoryDetails" id="d2601b66-cdb5-4417-91df-7df864a9a6ef">
        <source>getTICategoryDetails(_includingBRItems : Boolean; _packed, _onsite, _total, _expected : Integer output; 
				_locations : String output);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/12/2012	cnwdap1	Initial creation PAR #30882 CCMS PNL 2244
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/
vars
	ti			: CM_TrackedItem;
	locString	: String;
	detail		: CM_ReserveDetail;
	isContainer	: Boolean;
	tiSet		: CM_TISet;

begin
	create tiSet transient;
	foreach ti in self.allTrackedItemsAssigned do
		tiSet.add(ti);
	endforeach;
	foreach ti in self.allTrackedItemsReleased do
		tiSet.add(ti);
	endforeach;
	foreach ti in tiSet do
		// is this a container for packing? If so, ignore it
		isContainer := false;
		foreach detail in self.allReserveDetails do
			//if detail.allTrackedItems.includes(ti) or detail.allTrackedItemsReleased.includes(ti) then
			if detail.includeTrackedItem(ti, false) or detail.allTrackedItemsReleased.includes(ti) then //23/06/2023	navkc1	CR 58406 Task 58408
				isContainer := true;
				break;
			endif;
		endforeach;
		if isContainer then
			continue;
		endif;
		
		if _includingBRItems or ti.myBookingRefItem = null then
			if ti.state &lt;&gt; TI_STATE_NOTIFIED then
				if ti.myParent = null and ti.myBookingRefItem &lt;&gt; null then
					_onsite := _onsite + 1;
					if ti.myPrimaryActualLocation &lt;&gt; null then
						locString := ti.myPrimaryActualLocation.getFullId;
					endif;
					if locString &lt;&gt; null then
						if _locations = null then
							_locations := locString;
						else
							_locations := _locations &amp; CrLf &amp; locString;
						endif;
					endif;
				else
					_packed := _packed + 1;
				endif;
				_total := _total + 1;
			endif;
		endif;
	endforeach;
	
	_expected := self.myBookingRefStock.getTotalQuantity;
epilog
	delete tiSet;
end;</source>
        <Parameter name="_includingBRItems" type="Boolean"/>
        <Parameter name="_packed" type="Integer" usage="output"/>
        <Parameter name="_onsite" type="Integer" usage="output"/>
        <Parameter name="_total" type="Integer" usage="output"/>
        <Parameter name="_expected" type="Integer" usage="output"/>
        <Parameter name="_locations" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTICommoditiesForReport" id="23e7404b-d612-4338-a243-5ecc14343924">
        <source>getTICommoditiesForReport() : String;
// ---------------------------------------------------------------------------
// Created:     16 February 2006	cnwhjg1
//
// Purpose:     Used in Rail Release Equipment requirement
// ----------   ----------  --------------------------------------------------
vars
	str : String;
	ti : CM_TrackedItem;
begin

	foreach ti in self.allTrackedItemsAssigned do 
		if not self.allTrackedItemsReleased.includes(ti) then 
			// is attached and has not been released so show in report
			str := str &amp; ti.commodity &amp; CrLf;
		endif;
	endforeach;
	
	if str &lt;&gt; null then 
		str := str[1:(str.length -1)]; // get ride of last CrLf
	endif;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTIISOTypes" id="70f9c87a-6895-4f04-8270-f71a08e16cc8">
        <source>getTIISOTypes() : String;
// ---------------------------------------------------------------------------
// Created:     20 February 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

	str, str2 : String;
	ti : CM_TrackedItem;
begin

	foreach ti in self.allTrackedItemsAssigned do 
		if not self.allTrackedItemsReleased.includes(ti) then 
		// is attached and has not been released so show in report
			str := str &amp; ti.getISOType &amp; CrLf;
		endif;
	endforeach;

	if str &lt;&gt; null then 
		str := str[1:(str.length -1)]; // get ride of last CrLf
	endif;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTIIdsForReport" id="9e3cb021-de71-4960-b801-4bafdf0961f0">
        <source>getTIIdsForReport() : String;
// ---------------------------------------------------------------------------
// Created:     11 January 2006	cnwhjg1
//
// Purpose:     Used in Rail Release Equipment requirement
// ----------   ----------  --------------------------------------------------
vars
	str : String;
	ti : CM_TrackedItem;
begin

	foreach ti in self.allTrackedItemsAssigned do 
		if not self.allTrackedItemsReleased.includes(ti) then 
			// is attached and has not been released so show in report
			str := str &amp; ti.id &amp; CrLf;
		endif;
	endforeach;
	
	if str &lt;&gt; null then 
		str := str[1:(str.length -1)]; // get ride of last CrLf
	endif;
	
	//return str;
	//Par12540  JRDScriptGenerator only has a filterAndSort of 100 chars so was returning an error for items larger than that.  21/09/2006
	return str[1:100];
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTotalAssigned" id="c1cb7a54-dac6-4fe6-9d16-33b5c099b8b8">
        <source>getTotalAssigned() : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	11 October 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
----------   ----------  --------------------------------------------------
*/
vars
	reserveDetail			: CM_ReserveDetail;
	totalAssigned			: Integer;
	
begin

	
	foreach reserveDetail in self.allReserveDetails do
		totalAssigned := totalAssigned + reserveDetail.getAllTrackedItemsSize(false); //23/06/2023	navkc1	CR 58406 Task 58408
	endforeach;

	return totalAssigned;
epilog
end;





</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalAssignedInLocation" id="92695c90-38ea-48ee-a616-a5420a77caba">
        <source>getTotalAssignedInLocation( _lc : CM_LocationsController ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 November 2015	cnwndl1	Initial creation	Par 37153

*/

vars

	ti : CM_TrackedItem;
	count : Integer;
	wagon : CM_Wagon;

begin
	if _lc = null then
		return 0;
	endif;

	if _lc.isWagon then	//26 Jan 2017	NDL	TFS 3198/2877
		wagon := _lc.CM_WagonController.myWagon;
		if wagon &lt;&gt; null then
			foreach ti in self.allTrackedItemsAssigned do
				if ti.myPrimaryActualLocation = null or not ti.myPrimaryActualLocation.isWagon then
					continue;
				endif;
				if ti.myPrimaryActualLocation.CM_WagonController.myWagon &lt;&gt; wagon then
					continue;
				endif;
				count := count + ti.totalQuantity.max(1);
			endforeach;
		endif;
	
	else
		foreach ti in self.allTrackedItemsAssigned do
			if ti.myPrimaryActualLocation &lt;&gt; _lc then
				continue;
			endif;
			count := count + ti.totalQuantity.max(1);
		endforeach;
	
	endif;
	
	return count;

epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalMaxToRelease" id="6897a289-5546-4921-8de6-f741c1855e45">
