    <JadeMethod name="canBeIncludedOnWOO" id="901186b0-9bdd-40a8-826c-1eec7eec9a3f">
        <source>canBeIncludedOnWOO(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Jul 2023	navma1	ChangeRequest 56738: EUP | Stop Including Work Order Jobs in Work order operation screen

*/

vars

begin
