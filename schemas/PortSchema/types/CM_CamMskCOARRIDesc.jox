    <JadeMethod name="create" id="b17ea9ba-7590-463f-ac37-36b88c3ff783">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------
//	Created:	03 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.name := "Maersk Coarri";
	self.type := EDIFileTypeCams_MaerskCoarri;

end;</source>
