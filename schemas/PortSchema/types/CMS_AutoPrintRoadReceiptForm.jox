<GUIClass name="CMS_AutoPrintRoadReceiptForm" id="3e78cc80-4ee6-434c-b184-b1293cd48bc8">
    <superclass name="CMS_MainForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="lbAutoPrint" id="0d80308b-86a3-47e1-a5aa-f821a718c849">
        <embedded/>
        <type name="Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="statusLine" id="58b618b8-5b06-4c29-92e0-f2bed20493f9">
        <embedded/>
        <type name="StatusLine"/>
    </ImplicitInverseRef>
    <JadeMethod name="doStatusLine" id="6a8af0da-5351-4b1f-be9c-99913ca8d7bd">
        <updating/>
        <source>doStatusLine(pRoadJob : CM_RoadJob) updating;
//--------------------------------------------------------------
//Created: 16 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if pRoadJob = null then
		self.statusLine.caption := 'Standing By...';
	else
		self.statusLine.caption := 'Printing Receipt for Road Job ' &amp; pRoadJob.jobNumber &amp; '...';
	endif;		
end;</source>
        <Parameter name="pRoadJob" type="CM_RoadJob"/>
    </JadeMethod>
    <JadeMethod name="load" id="96da7744-d9a7-434c-b43a-92bbfe802313">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
//--------------------------------------------------------------
//Created: 16 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	beginClassNotification(CM_RoadJob, false, EVENT_AUTO_PRINT_ROAD_RECEIPT, Response_Continuous, 0);
	self.doStatusLine(null);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="239e6a02-d283-4d17-b643-080e4423fe8f">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
//--------------------------------------------------------------
//Created: 16 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	endNotificationForSubscriber(self);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="ee464c62-46eb-43d3-949c-942f5a11b211">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//--------------------------------------------------------------
//Created: 16 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	roadJob : CM_RoadJob;
begin
	
	if theObject = null or not global.isValidObject(theObject) or not theObject.isKindOf(CM_RoadJob) then
		return;
	endif;
	
	if eventType = EVENT_AUTO_PRINT_ROAD_RECEIPT then
		roadJob := theObject.CM_RoadJob;
		if roadJob &lt;&gt; null then
			if not roadJob.isReceiptRequired then
				return;
			endif;
			app.myPassport.setMyTerminal(self.myTerminal);
	
			exclusiveLock(roadJob);		
			self.doStatusLine(roadJob);
//			roadJob.printJadeReceipt(1, false); // CCMS 1401
			app.myTrxCA.trxCreateRoadJobPrintReceipt(roadJob, 1, false, true, app.myPassport);			
			self.doStatusLine(null);
		endif;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
