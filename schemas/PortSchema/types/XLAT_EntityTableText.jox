    <JadeMethod name="getDisplayStringForAttribute" id="6d6748f0-017a-4a1d-a881-0bb2525ea5d9">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2022	navkc1	Initial creation	TFS #53916, new ETROW for Table Entities

*/

vars
	string 		: String;
begin
	
	if _attrName = ETRow_AllTableEntDefs then
		if self.myEntTableRow &lt;&gt; null and self.myEntTableRow.allEntTableDefs.size() &gt; 0 then
			string := self.myEntTableRow.allEntTableDefs.listString(" ", EntTableDef.XML_Attr_Name);
		endif;
		
		return string;		
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUniqueNumber" id="7c2001b1-fecf-4b57-be8a-27bb6b03cd58">
        <source>getUniqueNumber(_category : XLAT_Category; _constant: GlobalConstant): Integer protected;

// other global constant categories are Integer types, which provides the unique access key
// EntTableRows are String type, so we'll make up an Integer. EntTableRows are maintained 
// through their own form, and accessed through their own methods (not CM_Locale.zGetTranslation)
// so the key isn't required for access

vars
	lastEntTableText : XLAT_EntityTableText;
begin
	if self.myEntTableRow = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'self.myEntTableRow is null for ' &amp; self.String);
		return 0;
	endif;
	
	return self.myEntTableRow.number;

	/*
	cannot do this as we need to ensure the number is the same for
	all JMT clients regardless of order things are loaded so that
	they can swap translation files, and so same number is
	retained through upgrades, etc
	
	lastEntTableText := _category.allTranslatableText.last.XLAT_EntityTableText;
	if lastEntTableText = null then
		return 1;
	else
		return lastEntTableText.number + 1;	
	endif;
	*/
end;</source>
        <access>protected</access>
        <Parameter name="_category" type="XLAT_Category"/>
        <Parameter name="_constant" type="GlobalConstant"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initialiseEntTableText" id="aa96f93a-8d0c-44ba-8b97-cfafc6eb8ad8">
        <updating/>
        <source>initialiseEntTableText(	_root 					: CM_Root; 
						_constantCategoryName	: String; 
						_entTableRow			: EntTableRow) updating;

// specialised initialise() method for XLAT_EntityTableText, so myEntTableRow relationship can be set

vars
	category	: XLAT_Category;
	constant	: GlobalConstant;
	entTableRow	: EntTableRow;
begin
	if self.myEntTableRow &lt;&gt; _entTableRow then
		self.myEntTableRow := _entTableRow;
	endif;

	constant := rootSchema.getSchema(PortSchemaName).getConstantCategory(EntTableRows).getConstants[myEntTableRow.myEntTableRowHeader.constantName].GlobalConstant;
	category := _root.allXLAT_Categories[EntTableRows];

	self.initialise(category, constant, EntTableRows, _entTableRow.getHeadingUnaltered, _entTableRow.getShortHeadingUnaltered);
end;</source>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_constantCategoryName" type="String"/>
        <Parameter name="_entTableRow" type="EntTableRow"/>
    </JadeMethod>
    <JadeMethod name="vConstantValue" id="07cdda07-bc89-4234-98e7-f5fa7314048c">
        <methodInvocation>mapping</methodInvocation>
        <source>vConstantValue(set: Boolean; _value: String io) mapping;

vars

begin
	if set then
		// read-only
	else
		if myGlobalConstant &lt;&gt; null then
			_value := myGlobalConstant.valueAsString;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
