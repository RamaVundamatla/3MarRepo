								);
		elseif index = 10 then
			report.frmBay10.visible := true;	
			self.populateFrmBay( 	report.frmBay10,	//_bayFrame : CMUI_Frame;
								report.lblBayId10,	//_bayIdLbl : CMUI_Label input;
								report.lblColId10,	//_colIdLbl : CMUI_Label input;
								report.lblTierId10,	//_tierIdLbl : CMUI_Label input;
