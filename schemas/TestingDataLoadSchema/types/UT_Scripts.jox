    <JadeMethod name="resetData_53034" id="8d3804f0-49c2-4dc6-ab80-987a8505ec6e">
        <source>resetData_53034();
/*

Purpose:	Reset 37392		

Date		Who		Reason
10/03/2022	navmh5	Initial creation

*/

vars
	
	terminal				: CM_Terminal;
	vvr						: CM_VehicleVisitRecord;
	vehicle					: CM_Vehicle;
	passportTerm 			: CM_Terminal;
	releaseRequest			: CM_BulkRelease;
	cont					: CM_Container;
	operator				: CM_Operator;
	bs						: CM_BlockStack;
	voyage					: CM_Voyage;
	release					: CM_BulkRelease;
	carrier					: CM_Carrier;
	grade					: CM_MTGrade;
	
	vehicleArray			: StringArray;
	
	rego					: String;
	found					: Boolean;
	
begin
	
	app.initialize();
	 
	 terminal := app.myRoot.allTerminals["PNL"];
	 if terminal = null then
		return;
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", terminal.code);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	create vehicleArray transient;
	vehicleArray.add("TN3001");
	vehicleArray.add("TN5558");
	vehicleArray.add("TN3100");
	vehicleArray.add("BRENT");
	
	foreach rego in vehicleArray do
	
		/*found := false;
		foreach vvr in CM_VehicleVisitRecord.instances discreteLock where vvr.regNumber = rego and vvr.timeOut = null do
			found := true;
			break;
		endforeach;
	
		if found then
			self.ignoreTrxWarnings(true); 
			app.myTrxUA.trxUpdateVVRCancel(vvr, "Last Test Run Failed", app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
		endif;*/
		self.deleteVehicle(rego);

	endforeach;
	
	cont := self.getTrackedItem("HLBU1236058").CM_Container;
	if (cont &lt;&gt; null) then
		self.deleteTrackedItem(cont, false);
	endif;
	self.deleteReleaseRequest("74021690");
	
	operator := app.myRoot.allOperators["HLCL"];
	self.assertNotNull(operator);
	
	carrier := app.myRoot.allCarriers["OTHER"];
	self.assertNotNull(carrier);
	
	grade := app.myRoot.allAvailabilityGrades[103];
	self.assertNotNull(grade);
	
	self.opts.purge();
	self.opts.addAssoc("Number", 1);
	self.opts.addAssoc("ISOGroup", "2DRY");
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc("Grade", "103");
	self.opts.addAssoc("Terminal", "PNL");
	self.opts.addAssoc("Carrier", carrier);
	self.opts.addAssoc("Grade", grade);
	self.opts.addAssoc("DevliveryReasonCode", 3);
	self.opts.addAssoc("DeliveryReason", "Sent to Shipper");
	releaseRequest := self.addReleaseByTypeRequest("74021690", BR_TYPE_ROAD, TI_CargoType_Container, "221P");
	self.assertNotNull(releaseRequest);
		
	
	bs := self.getTerminalArea("BSGN01").CM_BlockStack;
	self.assertNotNull(bs);
	
	cont := self.addContainerAtLocation("HLBU1236058", operator, "221P", "MT", TI_IMEX_STATUS_STORAGE, bs.allLocationsControllers.first);
	self.assertNotNull(cont);
	
	voyage := self.getVoyage("MACEG115A");
	self.assertNotNull(voyage);
	
	release := self.getReleaseRequest("74021690");
	self.assertNotNull(release);
	
	self.opts.purge();
	self.opts.addAssoc("Total Weight", 1900);
	self.opts.addAssoc("DischargePort", "NZNSN");
	self.opts.addAssoc("Remarks", "Used by Test Case 53034");
	self.opts.addAssoc(UTTI_AvailabilityGrade, 103);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("ReleaseRequest", release);
	self.opts.addAssoc("Terminal", "PNL");
	self.updateTI(cont);
	
	
epilog

	app.myPassport.setMyTerminal(passportTerm);
	
	delete vehicleArray;

end;</source>
    </JadeMethod>
