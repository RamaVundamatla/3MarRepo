epilog

end;</source>
        <Parameter name="scroll" type="ScrollBar" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="e7df496f-55f8-4a1f-9a80-3e43725462ee">
        <updating/>
        <source>setupControls()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2018	jlgndl1	Initial creation	TFS 39950

*/

vars

begin

	self.doResizeControls(true);
	
	if self.myMobileGenericAgent.myTruck &lt;&gt; null then
		self.txtTruck.text := self.myMobileGenericAgent.myTruck.regNumber;
		self.txtTruck.enabled := false;
	else
		self.handleBtnTwo();
		return;
	endif;
	
	self.populateLocations();

epilog

end;</source>
    </JadeMethod>
