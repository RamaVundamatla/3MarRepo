        <source>addCMIFPayment( cashPayment : CM_CashPayment ) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	cmifInvoice : CMIF_CashFinalInvoice;

begin

	create cmifInvoice transient;
	cmifInvoice.setBaseDetails( cashPayment, self );
	
	///self.incrementBalanceAtToDate( cmifInvoice.cashValue );

epilog

end;</source>
