<Class name="Process">
    <JadeMethod name="getUserCode" id="b5b556f7-1465-466e-8941-4a70815f2f64">
        <source>getUserCode():String;

vars
	i:Integer;
begin
	i:=userCode.pos("_",1)-1;
	if i &lt; 3 then
		return userCode.toLower;
	else
		return userCode[1:i].toLower;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
