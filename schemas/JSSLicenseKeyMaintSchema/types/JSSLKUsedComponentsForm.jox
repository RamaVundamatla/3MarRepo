    <JadeMethod name="addProductComponents" id="91e34c23-b087-4121-bc37-805411e65a88">
        <updating/>
        <source>addProductComponents() updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Purpose:		Adds the selected product components to the currently selected
//				Customer.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCompany		: JSSLKCustomer;
	theComponent	: JSSLKComponent;
	allComponents	: JSSLKComponentArray;
	expiryDate		: Date;
	theListbox		: ListBox;
	listPointer		: Integer;
	listSize		: Integer;
	
begin
	if cmbCustomer.listIndex = JSS_NULL_INDEX then
		app.msgBox("Please select the Company to add the Product Component(s) to.", "Edit Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	theCompany		:=	cmbCustomer.listObject.JSSLKCustomer;
	theListbox		:=	lstProducts;
	
	if theListbox.listCount = 0 then
		app.msgBox("Please select the Product Component(s) to add to the selected Company.", "Edit Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	listSize	:=	theListbox.listCount;
	create allComponents transient;
	
	foreach listPointer in 1 to listSize do
		if theListbox.itemSelected[listPointer] then
			theComponent	:=	theListbox.itemObject[listPointer].JSSLKComponent;
			allComponents.add(theComponent);
		endif;
	endforeach;
	
	if not allComponents.isEmpty() then
		app.myTA.trxAddUsedComponents(theCompany, self.aObjectEdition, allComponents, expiryDate);
	endif;
	
	self.populateUsedProductComponents();
	self.selectUsedProductComponents();
	app.causeEvent(CUSTOMER_USEDCOMPONENT_CHANGE, true, JSSLKMaintenanceForm.EVENT_TAG_USERCOMPONENT);
	self.resynchObjectAndSetEdition(theCompany);
epilog
	delete allComponents;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnAdd_click" id="987462db-832e-4b1a-83a0-236763aa2a2e">
        <controlMethod name="JadeMask::click"/>
