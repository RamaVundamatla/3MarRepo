    <JadeMethod name="deleteMapping" id="733e5c19-7c05-4b62-81f8-9990ac67d7bc">
        <source>deleteMapping(_name :String);
// ---------------------------------------------------------------------------
// Created:     26 November 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	mapping	:CM_XTABMapping;
begin
	mapping := app.myRoot.allXTABMappingsByName[_name];
	
	if mapping &lt;&gt; null then
		app.myTrxDA.trxDeleteXTABMapping (mapping, app.myPassport);
	endif;	
epilog

end;</source>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
    <JadeMethod name="tCreateSnapshotData" id="953dd0e3-f305-4d83-bff2-21e0e7ee1bec">
        <updating/>
        <source>tCreateSnapshotData() updating;
// cnwmp6
// cnwjre1	test 36979
vars
	count			: Integer;
	outputFormat	: CM_OutputFormat_SS;
	data			: CM_SnapshotData;
	terminal		: CM_Terminal;
	ti				: CM_TrackedItem;
	iter			: Iterator;
	dos				: CM_DynamicObject_Snapshot;
begin
	terminal := self.getTerminal();
	// the snap shot summary selector is all onsite containers with id starting with "A"
	//  check that there actually are some and change the description (a max-length field) of at least one to be longer than 63 characters
	iter := terminal.allOnsiteTIsByCargoTypeId.createIterator;
	terminal.allOnsiteTIsByCargoTypeId.startKeyGeq(1, 'A', iter);
	
	while iter.next(ti) do
		if not ti.isKindOf(CM_Container) then
			break;
		endif;
		if ti.id[1:1] &lt;&gt; "A" then
			break;
		endif;
		count := count + 1;
		if count &lt; 4 then
			beginTransaction;
			ti.setPropertyValue("description", "A tracked item description that is more than 62 characters long so gets truncated");
			commitTransaction;
		endif;
	endwhile;
	self.assertTrueMsg(count &gt; 0, "There are no onsite containers with ids starting with 'A'");
	
	outputFormat := app.myRoot.allOutputFormats_SS.getAtKey("UT Snapshot 1");
	data := self.createSnapshotData(outputFormat);
	count := 0;
	foreach dos in data.allSnapshotData do
		if dos.getPropertyValue("description").String = "A TRACKED ITEM DESCRIPTION THAT IS MORE THAN 62 CHARACTERS LON" then
			count := count + 1;
		endif;
	endforeach;
	self.assertTrueMsg(count &gt; 0, "There are no snapshot results with truncated descriptions");

epilog
	delete iter;
end;
</source>
    </JadeMethod>
