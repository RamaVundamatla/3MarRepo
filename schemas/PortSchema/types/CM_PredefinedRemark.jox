    <JadeMethod name="setForCreate" id="72d339c5-bdb4-4dfa-aa5d-5feffa440b74">
        <updating/>
        <source>setForCreate(pProxyPredefinedRemark:CM_PredefinedRemark) updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	pProxyPredefinedRemark.raiseExceptionIfNotTransient(method);
	
	setForUpdate(pProxyPredefinedRemark);
	
	self.myRoot := app.myRoot;
end;</source>
        <Parameter name="pProxyPredefinedRemark" type="CM_PredefinedRemark"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7a456c36-160a-49ba-bf7a-2c9e6c9f6538">
        <updating/>
        <source>setForUpdate(pProxyPredefinedRemark:CM_PredefinedRemark) updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.code := pProxyPredefinedRemark.code.trimBlanks;
	self.description := pProxyPredefinedRemark.description;
end;</source>
        <Parameter name="pProxyPredefinedRemark" type="CM_PredefinedRemark"/>
    </JadeMethod>
    <JadeMethod name="setMyRoot" id="82f0995b-739d-41f5-980b-7d61feb1ad08">
