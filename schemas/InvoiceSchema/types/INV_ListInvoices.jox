    <JadeMethod name="doPrint" id="14270b55-1643-4c71-bbf6-124ee966673d">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
begin
	// CCMS 1264 Apr 2012 non-virtual qty and rate, recalculate for pre-posted print so shows most current values
	if self.myCurrentInvoice &lt;&gt; null
	//and self.myCurrentInvoice.status &lt;&gt; CM_Invoice.INVOICE_POSTED
	and not self.myCurrentInvoice.isPostedOrReversal	//04 Sep 2017	NDL	FS 6759
	then
		app.myTrxUA.trxInvoiceRecalculate( self.myCurrentInvoice, app.myPassport );	
	endif;

	self.doPrintTiDetails(true);
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintDefault" id="55f01768-a508-4c37-b782-cd587557004f">
        <source>doPrintDefault(preview : Boolean; _consolidate : Boolean; _oneLine : Boolean);
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	Invoice_Line_Spacing = 6;
	Invoice_Line_To_TI_IDs_Spacing = 3;
	Invoice_Remarks_Indent = 28;
	Invoice_TI_IDs_Indent = 28;
	Invoice_Description_Width = 405;

vars
	lineHeight:          Integer;
	il:                  INV_LetterInvoiceDefault; 
	str:                 String; 
	s:                   String;
	taxAmt,
	amt:                 Decimal[12,2];
	cash:				 Decimal[12,2];
	taxTotal,
	invStatTotal,
	txtHt:               Real;
	tiLines:             Integer;
	remarksLines:        Integer;
//	tmpInvLineStat : CM_InvoiceLineStatByNarQtyDict;
//	invLineStatDict:     CM_InvoiceLineStatByNarManDict;
//	invLineStatDictCol:     CM_InvoiceLineStatByNarManDict;
//	invLineStatXXXDict:  CM_InvLineStatByMnPrnOrNarDict;
	invLineStat:         CM_InvoiceLineStat;
	i, idx, adjustX:                   Integer;
	requiredHeight:      Real;
	actualHeight:        Real;
	endHeight:           Real;
	ht:                  Real;
	newHt:               Real;
	taxRate : Real; // CCMS 1172
	tmpJadeReport  : JadeReport;
	codes : StringArray; 
	rates  : RealArray; 
	amounts : RealArray;
	printSingleLineForDayType : Boolean;
	///docType		: Integer;
	currSymbol : Character;
	sortDict : ObjectArray; // TESTING - CM_InvoiceLineStatByNarDict;
	obj : Object;
	dpl : Integer;
begin

	currSymbol := app.myRoot.getInvoiceCurrencySymbol().Character;	// PAR 17016
	dpl := self.getRateEntryDecimalPlaces;	// TFS 36954 MPD 20 Feb 2018
	
	if not global.isValidObject(self.myCurrentInvoice) then
		app.msgBox("Please select something to print.", "Print Error", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	// ### CCMS 1253
	printSingleLineForDayType := self.myCurrentInvoice.invoiceType.printSingleLineForDayType;

	create codes transient;
	create rates transient;
	create amounts transient;
//	create invLineStatXXXDict transient;

	 // CCMS 1172
	if self.myCurrentInvoice.isZeroRatedTax then
		taxRate := 0;
	else
		taxRate := self.myCurrentInvoice.bank.taxPercentageRate;
	endif;

	/* PAR 30410 - the narration is stored on the invoice when it is created. The users can then edit and amend it. We do not want any changes overwritten by this call
beginTransaction;
	self.myCurrentInvoice.narration := self.myCurrentInvoice.invoiceType.generateNarration(self.myCurrentInvoice);
commitTransaction;
*/

	app.mousePointer := MP_HOURGLASS;

	create tmpJadeReport transient;
	tmpJadeReport.description := "Invoice " &amp; self.myCurrentInvoice.sequenceNum.String;
	// 17/01/2011 cnwmh5 #26743
	//docType := app.printer.getDefaultDocumentType();
	//app.printer.abort();
	app.setPrinterDocumentType(false);
	app.printer.setReport(tmpJadeReport);

	app.printer.suppressDialog := true;
	create il;
	il.lblAMOUNT.caption := il.lblAMOUNT.caption &amp; currSymbol;
	lineHeight := il.invoiceLineDesc.height.Integer;
	il.picLogoCompany.picture := app.getPicLogoPort();
	il.picLogoRem.picture := app.getPicLogoPort();
	///app.printer.documentType := docType;			// 17/01/2011 cnwmh5 #26743
	app.printer.setMargins(Print_Portrait,10,10,10,10);

	doPrintDefaultHeader(il);

	txtHt := il.txtCol1.height;
	il.txtCol1.text := self.myCurrentInvoice.narration;
	il.txtCol1.height := il.txtCol1.lineCount * txtHt;
	il.txtCol37.text := "";
	il.fOver.height := il.txtCol1.height + 10;
	
	app.printer.print(il.fOver);
	
/* WAS PAR 33175	create invLineStatDict transient;
	create invLineStatDict transient;
	invStatTotal := self.myCurrentInvoice.getInvoiceStats(invLineStatDict, null, false, false);
	// CCMS 1125 from here
	if _consolidate then
		invLineStatDictCol := self.myCurrentInvoice.getInvoiceStatsConsolidate(invLineStatDict);
		if _oneLine then
			tmpInvLineStat := self.myCurrentInvoice.getInvoiceStatsConsolidate2One(invLineStatDictCol);
			invLineStatDictCol.purge;
			tmpInvLineStat.copy(invLineStatDictCol);
		endif;
		invLineStatDictCol.copy(invLineStatXXXDict);
	else
		invLineStatDict.copy(invLineStatXXXDict);

	endif;
	// CCMS 1125 to here
	NOW */
	
	// SEE UT_Invoicing::tConsolidatedInvoiceQtyRate to test consolidation to one line
	create sortDict transient; // PAR 33175
	invStatTotal := self.myCurrentInvoice.getInvoiceConsolidation(sortDict,_consolidate,_oneLine); // PAR 33175

	// PAR 33175 foreach invLineStat in invLineStatXXXDict do
	foreach obj in sortDict do	// PAR 33175 
		invLineStat := obj.CM_InvoiceLineStat; // PAR 33175  
		
		
		if invLineStat.narrationMinMax &lt;&gt; null then
			il.invoiceLineDesc.caption := invLineStat.narration &amp; " " &amp; invLineStat.narrationMinMax;
		else
			il.invoiceLineDesc.caption := invLineStat.narration;
		endif;		
		// PAR 17363
		il.invoiceLineDesc.height := il.invoiceLineDesc.getTextHeightForWidth(invLineStat.narration,il.invoiceLineDesc.clientWidth());
		il.fInvoiceLine.height := il.invoiceLineDesc.height + 6;
		
		il.lblQuantity.caption := invLineStat.quantity.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
		il.lblUnit.caption := invLineStat.unitNarration;
//		il.lblRate.caption := invLineStat.rateForPrinting();						//need print all significant digits PAR4576 JC 11/04/2003
		//il.lblRate.caption := invLineStat.rate.asStringJMTWithPrecision($CM_RateMoney.decimalPlaces, false);
		il.lblRate.caption := invLineStat.rate.asStringJMTWithPrecision(dpl, false);	// TFS 36954 MPD 20 Feb 2018
		il.lblTotal.caption := invLineStat.total.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);	// GD May2001 xp1012
		
		
		// ########## PRINT INVOICE LINE
		if not app.printer.frameFits(il.fInvoiceLine) then
			app.printer.newPage;
			doPrintDefaultHeader(il);
			txtHt := il.txtCol1.height;
			il.txtCol1.text := "Continued...";
			il.txtCol1.height := il.txtCol1.lineCount * txtHt;
			il.txtCol37.text := "";
			il.fOver.height := il.txtCol1.height + 10;
			// printHeaderPOE overwrites the captions so we must reinstate them
			il.invoiceLineDesc.caption := invLineStat.narration;
			il.lblQuantity.caption := invLineStat.quantity.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
			//il.lblRate.caption := invLineStat.rate.userNumberFormat($CM_RateMoney);
//			il.lblRate.caption := invLineStat.rateForPrinting();						//need print all significant digits PAR4576 JC 11/04/2003
			//il.lblRate.caption := invLineStat.rate.asStringJMTWithPrecision($CM_RateMoney.decimalPlaces, false);
			il.lblRate.caption := invLineStat.rate.asStringJMTWithPrecision(dpl, false);	// TFS 36954 MPD 20 Feb 2018
			//il.lblTotal.caption := (invLineStat.quantity * invLineStat.rate).Decimal.userNumberFormat($CM_ChargeQuantity);
			il.lblTotal.caption := invLineStat.total.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);	// RJS 10/5/01

			app.printer.print(il.fOver);
		endif;
		app.printer.print(il.fInvoiceLine);

		// ########## DO WE NEED TO PRINT THE REMARKS or THE TRACKED ITEM LIST?????
		// ########## work out params, do not print yet.
		if printSingleLineForDayType then
			if invLineStat.quantity = invLineStat.allTrackedItems.size then
				tiLines := 0;
			endif;
		else
			tiLines := (invLineStat.allTrackedItems.size + 3) div 4;
		endif;
		remarksLines := invLineStat.narrationComments.size;
		if remarksLines = 0 and tiLines = 0 then
			requiredHeight := il.invoiceLineDesc.height + Invoice_Line_Spacing;
			endHeight := Invoice_Line_Spacing;
			actualHeight := -1;
		else
			// ensure that the description is not orphaned from its remarks or ti lines.
			if remarksLines = 0 then
				// next line will be a ti Line
				requiredHeight := il.invoiceLineDesc.height +
								  Invoice_Line_To_TI_IDs_Spacing +
								  lineHeight;
				endHeight := 0;
				actualHeight := il.invoiceLineDesc.height +
								Invoice_Line_To_TI_IDs_Spacing;
			else
				requiredHeight := il.invoiceLineDesc.height +
								  lineHeight;
				endHeight := 0;
				actualHeight := il.invoiceLineDesc.height;
			endif;
		endif;
		// ########## DO WE NEED TO PRINT THE REMARKS or THE TRACKED ITEM LIST?????
		if tiLines &gt; 0 then
			self.doPrintTIList(invLineStat, il, requiredHeight, actualHeight, endHeight);
		endif;
		// RESET FRAME
		il.invoiceLineDesc.height := lineHeight;
		il.fInvoiceLine.height := lineHeight + 6;
	endforeach;

	app.printer.print(il.fTitleSep);

	//the amount printed on the invoice is the one and only true total!
	amt := invStatTotal;

	il.txtCol1.text := "";
	il.txtCol1.height := txtHt;
	il.txtCol26.text := "";
	il.txtCol37.text := amt.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
	il.fOver.height := il.txtCol1.height + 10;
	app.printer.print(il.fOver);

	// cash payments
	cash := self.myCurrentInvoice.getCashPaid();
	if cash &lt;&gt; 0 then
		il.txtCol1.text := "";
		il.txtCol1.height := txtHt;
		il.txtCol26.text :=  "CASH RECEIVED";
		il.txtCol37.text := cash.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
		il.fOver.height := il.txtCol1.height + 10;
		app.printer.print(il.fOver);
	endif;
	
	if self.myCurrentInvoice.bank.parentCompany.addInvoiceTax then


		if self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean then
			self.myCurrentInvoice.getTaxForInvoice(true, amt, codes, rates, amounts);

			foreach idx in 1 to 4 do
				if idx &lt;= codes.size then
					//taxAmt := taxAmt + (amounts[idx] * (rates[idx] / 100));	// was
					taxTotal := taxTotal + (amounts[idx] * (rates[idx] / 100));	// 25978 Invoice total/export total mismatch, do explicit rounding
				endif;
			endforeach;
			taxAmt := taxTotal.jMTRoundedTo($CM_ChargeQuantity.decimalPlaces);		// 25978
			il.txtCol1.text := "";
			il.txtCol1.height := txtHt;
			il.txtCol26.text := self.myCurrentInvoice.bank.parentCompany.taxNumber;
			il.txtCol37.text := taxAmt.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
			il.fOver.height := il.txtCol1.height + 10;
			app.printer.print(il.fOver);
			
	
			foreach idx in 1 to 4 do
				if idx &lt;= codes.size then
					if idx = 1 then
						il.lblTaxRate1.caption := rates[idx].String &amp; " %";
						il.lblTaxAmount1.caption := amounts[idx].asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true) ;
						il.lblTaxTotal1.caption := (amounts[idx] * (rates[idx]/100)).asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true);
						il.lblTaxTotal1.visible := true;
						il.lblTaxRate1.visible := true;
						il.lblTaxAmount1.visible := true;
						il.lblTaxAmountLbl.visible := true;
						il.lblTaxRateLbl.visible := true;
						il.lblTaxTotalLbl.visible := true;
						adjustX := (il.lblTaxRate1.clientWidth * 3);
					elseif idx = 2 then
						il.lblTaxRate2.caption := rates[idx].String &amp; " %";
						il.lblTaxAmount2.caption := amounts[idx].asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true);
						il.lblTaxTotal2.caption := (amounts[idx] * (rates[idx]/100)).asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true);
						il.lblTaxAmount2.visible := true;
						il.lblTaxTotal2.visible := true;
						il.lblTaxRate2.visible := true;
						adjustX := (il.lblTaxRate1.clientWidth * 2);
					elseif idx = 3 then
						il.lblTaxRate3.caption := rates[idx].String &amp; " %";
						il.lblTaxAmount3.caption := amounts[idx].asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true);
						il.lblTaxTotal3.caption := (amounts[idx] * (rates[idx]/100)).asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true);
						il.lblTaxAmount3.visible := true;
						il.lblTaxRate3.visible := true;
						il.lblTaxTotal3.visible := true;
						adjustX := (il.lblTaxRate1.clientWidth * 1);
					elseif idx = 4 then
						il.lblTaxRate4.caption := rates[idx].String &amp; " %";
						il.lblTaxAmount4.caption := amounts[idx].asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true);
						il.lblTaxTotal4.caption := (amounts[idx] * (rates[idx]/100)).asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true);
						il.lblTaxAmount4.visible := true;
						il.lblTaxRate4.visible := true;
						il.lblTaxTotal4.visible := true;
						adjustX := 0;
					endif;
				endif;
			endforeach;
			il.frmTax.left := adjustX;
			app.printer.setPrintPosition((app.printer.getPrintPosition() - il.fOver.height - 20).Integer);
			app.printer.print(il.frmTax);	
		else
			taxAmt := (amt * (taxRate)/100.0);
			il.txtCol1.text := "";
			il.txtCol1.height := txtHt;
			il.txtCol26.text := "G.S.T.";
			il.txtCol37.text := taxAmt.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
			il.fOver.height := il.txtCol1.height + 10;
			app.printer.print(il.fOver);
		endif;
	
		il.txtCol1.text := "";
		il.txtCol1.height := txtHt;
		il.txtCol26.text := "TOTAL AMOUNT " &amp; currSymbol;
		il.txtCol37.text := (amt + taxAmt - cash).asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
		il.fOver.height := il.txtCol1.height + 10;
		app.printer.print(il.fOver);
	else
		il.txtCol1.text := "";
		il.txtCol1.height := txtHt;
		il.txtCol26.text := "TOTAL AMOUNT " &amp; currSymbol;
		il.txtCol37.text := (amt).asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
		il.fOver.height := il.txtCol1.height + 10;
		app.printer.print(il.fOver);
	endif;

	app.printer.print(il.fTitleSep);
	il.txtCol1.text := "";
	il.txtCol26.text := "";
	il.txtCol37.text := "";
	il.fOver.height := txtHt;
	app.printer.print(il.fOver);

	str := "";
	foreach s in self.myCurrentInvoice.bank.mailingAddress do
		str := str &amp; s &amp; CrLf;
	endforeach;
	il.lblTyp.caption := self.myCurrentInvoice.debtor.decfinName;
	il.lblRemInvNum.caption := self.myCurrentInvoice.sequenceNum.String;
	il.txtRemitCoyAddress.text := str;
	il.lblRemAcCode.caption := "";
	// An ampersand is taken as being a button shortcut, so double it up and it prints single
	il.lblAccountName.caption := self.myCurrentInvoice.debtor.remarks.replaceString("&amp;","&amp;&amp;");
	
	// CCMS 1057 AKB2002AUG from here
	if self.myCurrentInvoice.bank.allBankDetails &lt;&gt; null then
		if self.myCurrentInvoice.bank.allBankDetails.size &gt;= 1 then
			il.lblBankDetails1.caption := self.myCurrentInvoice.bank.allBankDetails[1];
		endif;
		if self.myCurrentInvoice.bank.allBankDetails.size &gt;= 2 then
			il.lblBankDetails2.caption := self.myCurrentInvoice.bank.allBankDetails[2];
		endif;
		if self.myCurrentInvoice.bank.allBankDetails.size &gt;= 3 then
			il.lblBankDetails3.caption := self.myCurrentInvoice.bank.allBankDetails[3];
		endif;
	endif;
	// CCMS 1057 AKB2002AUG to here
	



	if not app.printer.frameFits(il.fRemittance) then
		app.printer.newPage;
		app.printer.newPage;
		doPrintDefaultHeader(il);
		txtHt := il.txtCol1.height;
		il.txtCol1.text := "Continued...";
		il.txtCol1.height := il.txtCol1.lineCount * txtHt;
		il.txtCol37.text := "";
		il.fOver.height := il.txtCol1.height + 10;
		app.printer.print(il.fOver);
	endif;
	ht := il.fInvoiceLine.height;
	i := 0;
	while app.printer.frameFits(il.fInvoiceLine) do
		i := i + 1;
		newHt := ht * i;
		il.fInvoiceLine.height := newHt;
	endwhile;
	il.fInvoiceLine.height := ht * (i-1) - il.fRemittance.height;
	il.invoiceLineDesc.caption := "";
	il.lblQuantity.caption := "";
	il.lblRate.caption := "";
	il.lblUnit.caption := "";
	il.lblTotal.caption := "";
	app.printer.print(il.fInvoiceLine);

	app.printer.print(il.fRemittance);

epilog
	sortDict.purge();
	delete sortDict;
	
	delete codes;
	delete rates;
	delete amounts;
	app.printPreview(tmpJadeReport, true);
	app.printer.close;
	delete il;
//	invLineStatDict.purge;
//	delete invLineStatXXXDict; // CCMS 1125
//	delete invLineStatDictCol; // CCMS 1125
//	delete invLineStatDict;
	app.mousePointer := MP_DEFAULT;
end;</source>
        <Parameter name="preview" type="Boolean"/>
        <Parameter name="_consolidate" type="Boolean"/>
        <Parameter name="_oneLine" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrintDefaultHeader" id="723111ea-4927-4ed9-95bf-f7dd7d7111c8">
        <source>doPrintDefaultHeader(il : INV_LetterInvoiceDefault io);

vars
	str : String;
	s : String;

	currSymbol : Character;
begin
	currSymbol := app.myRoot.getInvoiceCurrencySymbol().Character;	// PAR 17016
	//currSymbol := self.myTerminal.getConfig(InvoiceCurrencySymbol).Integer.Character;
	//if currSymbol = null then
	//	currSymbol := "$";
	//	beginTransaction;
	//	self.myTerminal.setConfig(InvoiceCurrencySymbol,36);
	//	commitTransaction;
	//endif;
	
	// 23387 CCMS 1938 add debtor name
	str := "  " &amp; self.myCurrentInvoice.debtor.name &amp; CrLf;
	foreach s in self.myCurrentInvoice.debtor.billingAddress do
		str := str &amp; "  " &amp; s &amp; CrLf;
	endforeach;
	il.txtAddressee2.text := CrLf &amp; str;

	str := "";
	foreach s in self.myCurrentInvoice.bank.mailingAddress do
		str := str &amp; s &amp; CrLf;
	endforeach;
	il.txtCoyAddress1.text := str;

	il.lblAcCode.caption := self.myCurrentInvoice.debtor.decfinName;
	il.lblDate.caption := "";   //date posted!
	il.lblInvoiceNo.caption := self.myCurrentInvoice.sequenceNum.String;

	//PAR 2715 AJA 10/3/99 Cannot test timeStamp against null as null is midnight.
	//Must test using isValid method
	if self.myCurrentInvoice.postedDT.isValid then  // was:  &lt;&gt; null
		il.lblDate.caption := self.myCurrentInvoice.toDT.date.shortFormatJMT();
	elseif self.myCurrentInvoice.isVoided then
		il.lblDate.caption := "*** VOID ***";
	else
		il.lblDate.caption := "Not posted";
	endif;
	il.lblAcCode.caption := self.myCurrentInvoice.debtor.decfinName;
	/* AKB Oct2001. PAR 1044 WAS
	il.lblPoNumber.caption := debtor.purchaseOrderCode;
	NOW */
	if self.myCurrentInvoice.purchaseOrderNumber &lt;&gt; null then
		il.lblPoNumber.caption := self.myCurrentInvoice.purchaseOrderNumber;
	else
		il.lblPoNumber.caption := self.myCurrentInvoice.debtor.purchaseOrderCode;
	endif;

	app.printer.print(il.fTitle2);
	app.printer.print(il.fTitleSep);

	il.invoiceLineDesc.fontBold := true;
	il.lblQuantity.fontBold := true;
	il.lblRate.fontBold := true;
	il.lblUnit.caption := "Unit";
	il.lblUnit.fontBold := true;
	il.lblTotal.fontBold := true;
	il.invoiceLineDesc.caption := "Description";
	il.lblQuantity.caption := "Quantity";
	il.lblRate.caption := "Rate";
	il.lblTotal.caption := currSymbol;
	app.printer.print(il.fInvoiceLine);
	il.invoiceLineDesc.fontBold := false;
	il.lblQuantity.fontBold := false;
	il.lblRate.fontBold := false;
	il.lblTotal.fontBold := false;
	il.lblUnit.fontBold := false;

	app.printer.print(il.fTitleSep);

end;</source>
        <Parameter name="il" type="INV_LetterInvoiceDefault" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doPrintInvoice" id="36e97b56-e8a7-4a81-adf8-a523c68a1dbf">
        <source>doPrintInvoice(preview : Boolean; _consolidate : Boolean; _oneLine : Boolean);
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 31/12/2012	cnwdap1		PAR #30860 CCMS QNS 2236 Use CM_OracleFinancials for QNS
// 23/12/2019   cnwma1 	    ChangeRequest 47851: QTS - Integration with Oracle Fusion Cloud
// 31/08/2022	navpw1		TFS: 54564 (54383) - EUP - Inv Config - Debtor Currencies and Countries
vars
	finIO 		 	: CM_ExtFinanceIO;
	reportString 	: String;
	outputType	 	: Integer;
	filePath		: String;
	invoices		: ObjectArray;
	debtorTerminal 	: CM_DebtorTerminal; // ### TFS 54564 (54383) 31Aug2022 NAVPW1
	
begin
	if self.myCurrentInvoice = null then
		app.msgBox("Please select an invoice to print","Invoice Print Error",MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;

	finIO := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	
	// CCMS 1264 Apr 2012 non-virtual qty and rate, recalculate for pre-posted print so shows most current values
	//if self.myCurrentInvoice.status &lt;&gt; CM_Invoice.INVOICE_POSTED then
	if not self.myCurrentInvoice.isPostedOrReversal then	//04 Sep 2017	NDL	TFS 6759
		app.myTrxUA.trxInvoiceRecalculate( self.myCurrentInvoice, app.myPassport );	
	endif;
	
	//14 Nov 2012	NDL	Par 30689
	reportString := self.myTerminal.getConfig(DotMatrixInvoiceRep).String;
	if reportString.trimBlanks &lt;&gt; null and reportString.pos("?DOT", 1) &gt; 0 then
		app.printReportDotMatrix(reportString, self.myCurrentInvoice, false);
		return;
	endif;
	
	reportString := null; // ### TFS 54564 (54383) 31Aug2022 NAVPW1
	
	//get debtor terminal
	debtorTerminal := self.myTerminal.allDebtorTerminals[self.myCurrentInvoice.debtor]; // ### TFS 54564 (54383) 31Aug2022 NAVPW1
	
	// ### TFS 54564 (54383) 31Aug2022 NAVPW1
	//If debtor terminal is not null then get the default invoice JRW
	if debtorTerminal &lt;&gt; null then
		reportString := debtorTerminal.defaultInvoiceJRW;
	endif;
	// ### TFS 54564 (54383) 31Aug2022 NAVPW1
	
	//reportString := self.myTerminal.getConfig(InvInvoicePrintJRW).String; 	// PAR 36180
	
	//If we did not find a report for the debtor terminal then fallback on terminal config
	if reportString = null then													// ### TFS 54564 (54383) 31Aug2022 NAVPW1
		// PAR 36180
		reportString := self.myTerminal.getConfig(InvInvoicePrintJRW).String; 	// PAR 36180
	endif;																		// ### TFS 54564 (54383) 31Aug2022 NAVPW1
	
	if reportString.trimBlanks &lt;&gt; null then // PAR 36180
		create invoices transient;
		invoices.add(self.myCurrentInvoice);
		
		if app.createReportWriterManager().getReport(reportString) &lt;&gt; null then
			app.isReportWriter := true;
			app.sendItemsToReport(CM_JRWInvoice, invoices, reportString, preview, outputType, filePath);
			return;
		else
			app.msgBox(app.getErrorString1(Repor_does_not_exist_cm_jr_def,reportString),"Invoice Print",MsgBox_OK_Only);
		endif;
	endif;
	

	if finIO.class = CM_NAVPOE then
		self.doPrintPOE(true, _consolidate, _oneLine);
	elseif finIO.isKindOf(CM_Greentree) then
		self.doPrintWLG(true, _consolidate, _oneLine);
	elseif finIO.class = CM_AccPaccPro then
		self.doPrintSPT(true, _consolidate, _oneLine);
	elseif finIO.class = CM_OracleFinancials or  finIO.class = CM_QTSInterface then		//23.12.2019 cnwma1 TFS #47851
		self.doPrintOracleFinancial(true); 
	else
		self.doPrintDefault(true, _consolidate, _oneLine);
	endif;
	
epilog
	app.isReportWriter := false;		

delete invoices;
end;</source>
        <Parameter name="preview" type="Boolean"/>
        <Parameter name="_consolidate" type="Boolean"/>
        <Parameter name="_oneLine" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrintOracleFinancial" id="f9a647f3-9a13-42fd-b543-3809de8d618d">
        <source>doPrintOracleFinancial(_preview : Boolean);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/12/2012	cnwdap1	Initial creation PAR #30860 CCMS QNS 2236
02/04/2013	cnwdap1	PAR #31198 Strip GL code from the front of the narration
04/07/2013	cnwdap1	PAR #31833 Total frame now printed in a suitable position for Letter paper as well as A4
20/02/2018	jlgmd1	TFS 36954 SNO - Error in SCT2 Rate Table (Swap $CM_RateEntry.decimalPlaces for terminal config)

*/
constants
	Invoice_Line_Spacing = 6;
	Invoice_Line_To_TI_IDs_Spacing = 3;
	Invoice_Remarks_Indent = 28;
	Invoice_TI_IDs_Indent = 28;
	Invoice_Description_Width = 405;

vars
	lineHeight					: Integer;
	il							: INV_LetterInvoiceOracleFinance; 
	amt							: Decimal[12,2];
	invStatTotal				: Real;
	taxRate						: Real;
	invLineStatDict				: CM_InvoiceLineStatByNarManDict;
	invLineStatXXXDict			: CM_InvLineStatByMnPrnOrNarDict;
	invLineStat					: CM_InvoiceLineStat;
	tmpJadeReport  				: JadeReport;
	printSingleLineForDayType 	: Boolean;
	currSymbol 					: Character;
	page						: Integer;
	narration					: String;				// PAR #31198
	pos							: Integer;				// PAR #31198
	dpl							: Integer;				// TFS 36954 MPD 20 Feb 2018
	
begin
	currSymbol := app.myRoot.getInvoiceCurrencySymbol().Character;
	dpl := self.getRateEntryDecimalPlaces; // TFS 36954 MPD 20 Feb 2018
	
	if not global.isValidObject(self.myCurrentInvoice) then
		app.msgBox("Please select something to print.", "Print Error", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	// ### CCMS 1253
	printSingleLineForDayType := self.myCurrentInvoice.invoiceType.printSingleLineForDayType;

	create invLineStatXXXDict transient;

	 // CCMS 1172
	if self.myCurrentInvoice.isZeroRatedTax then
		taxRate := 0;
	else
		taxRate := self.myCurrentInvoice.bank.taxPercentageRate;
	endif;

	app.mousePointer := MP_HOURGLASS;

	create tmpJadeReport transient;
	tmpJadeReport.description := "Invoice " &amp; self.myCurrentInvoice.sequenceNum.String;
	app.setPrinterDocumentType(false);
	app.printer.setReport(tmpJadeReport);

	app.printer.suppressDialog := true;
	create il;
	//il.lblAMOUNT.caption := il.lblAMOUNT.caption &amp; currSymbol;
	lineHeight := il.lblInvLineDesc.height.Integer;
	page := page + 1;
	app.printer.setMargins(Print_Portrait,10,10,10,10);
	app.printer.setFooter(il.frmFooter);
	self.doSetupOracleFooter(il);

	self.doPrintOracleHeader(il, page);

	create invLineStatDict transient;
	invStatTotal := self.myCurrentInvoice.getInvoiceStatsByGL(invLineStatDict, null, false, false);
	invLineStatDict.copy(invLineStatXXXDict);

	foreach invLineStat in invLineStatXXXDict do
		pos := invLineStat.narration.pos("^", 1);					// PAR #31198
		if pos &lt;&gt; null then											// PAR #31198
			narration := invLineStat.narration[pos+1:end];			// PAR #31198
		else														// PAR #31198
			narration := invLineStat.narration;						// PAR #31198
		endif;														// PAR #31198
		if invLineStat.narrationMinMax &lt;&gt; null then
			//il.lblInvLineDesc.caption := invLineStat.narration &amp; " " &amp; invLineStat.narrationMinMax;	// PAR #31198
			il.lblInvLineDesc.caption := narration &amp; " " &amp; invLineStat.narrationMinMax;					// PAR #31198
		else
			//il.lblInvLineDesc.caption := invLineStat.narration;										// PAR #31198
			il.lblInvLineDesc.caption := narration;														// PAR #31198
		endif;		
		//il.lblInvLineDesc.height := il.lblInvLineDesc.getTextHeightForWidth(invLineStat.narration, il.lblInvLineDesc.clientWidth());	// PAR #31198
		il.lblInvLineDesc.height := il.lblInvLineDesc.getTextHeightForWidth(narration, il.lblInvLineDesc.clientWidth());				// PAR #31198
		il.fInvoiceLine.height := il.lblInvLineDesc.height + 6;
		
		il.lblQuantity.caption 	:= invLineStat.quantity.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
		//il.lblRate.caption 		:= invLineStat.rate.asStringJMTWithPrecision($CM_RateMoney.decimalPlaces, false);
		il.lblRate.caption 		:= invLineStat.rate.asStringJMTWithPrecision(dpl, false);	// TFS 36954 MPD 20 Feb 2018
		il.lblInvTotal.caption 	:= invLineStat.total.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
		
		// ########## PRINT INVOICE LINE
		if not app.printer.frameFits(il.frmFootSpacer) then
			//self.doPrintOracleFooter(il);
			app.printer.newPage;
			self.doSetupOracleFooter(il);
			
			page := page + 1;
			self.doPrintOracleHeader(il, page);
			il.lblInvLineDesc.caption := "Continued...";
			il.lblQuantity.caption := "";
			il.lblRate.caption := "";
			il.lblInvTotal.caption := "";

			app.printer.print(il.fInvoiceLine);
		endif;
		//il.lblInvLineDesc.caption := invLineStat.narration;			// PAR #31198
		il.lblInvLineDesc.caption 	:= narration;						// PAR #31198
		il.lblQuantity.caption 		:= invLineStat.quantity.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
		//il.lblRate.caption 			:= invLineStat.rate.asStringJMTWithPrecision($CM_RateMoney.decimalPlaces, false);
		il.lblRate.caption 			:= invLineStat.rate.asStringJMTWithPrecision(dpl, false);	// TFS 36954 MPD 20 Feb 2018
		il.lblInvTotal.caption 		:= invLineStat.total.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);	// RJS 10/5/01
		app.printer.print(il.fInvoiceLine);
	endforeach;

	//the amount printed on the invoice is the one and only true total!
	amt := invStatTotal;
	
	if not app.printer.frameFits(il.frmTotalSpacer) then
		//self.doPrintOracleFooter(il);
		app.printer.newPage;
		page := page + 1;
		self.doPrintOracleHeader(il, page);
		self.doSetupOracleFooter(il);
	endif;
	il.lblTotalWords.caption	:= amt.asCurrencyJMTWords2(); // PAR 32567
	il.lblTotalAmount.caption 	:= (amt).asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
	//app.printer.setPrintPosition(873);					// PAR #31833
	app.printer.setPrintPosition(807);						// PAR #31833
	app.printer.print(il.frmTotal);
	//self.doPrintOracleFooter(il);

epilog
	app.printPreview(tmpJadeReport, true);
	app.printer.close;
	delete il;
	invLineStatDict.purge;
	delete invLineStatXXXDict;
	delete invLineStatDict;
	app.mousePointer := MP_DEFAULT;
end;</source>
        <Parameter name="_preview" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrintOracleHeader" id="b08b4f8a-9ebc-45f4-92d4-2f9494d98c0e">
        <source>doPrintOracleHeader(_letter : INV_LetterInvoiceOracleFinance io; _page : Integer);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/12/2012	cnwdap1	Initial creation PAR #30860 CCMS QNS 2236
*/
vars
	businessUnit	: CM_Bank;
	debtor			: CM_Debtor;
	voyage			: CM_Voyage;
	oracle			: CM_OracleFinancials;

begin
	businessUnit := self.myCurrentInvoice.bank;
	debtor := self.myCurrentInvoice.debtor;
	if self.myCurrentInvoice.myVoyage &lt;&gt; null then
		voyage := self.myCurrentInvoice.myVoyage;
	elseif self.myCurrentInvoice.voyageCode &lt;&gt; null then
		voyage := self.myTerminal.allVoyagesByCode.getAtKeyGeq(self.myCurrentInvoice.voyageCode, null);
	elseif self.myCurrentInvoice.myTrackedItem &lt;&gt; null then
		voyage := self.myCurrentInvoice.myTrackedItem.myVoyage;
	endif;
	
	_letter.txtAddressee2.text 		:= debtor.decfinName &amp; CrLf &amp;
										debtor.name &amp; CrLf &amp;
										debtor.getBillingAddressString;
	_letter.txtCoyAddress1.text		:= businessUnit.mailingName &amp; CrLf &amp;
										businessUnit.getMailingAddressString;
	_letter.picLogoCompany.picture 	:= app.getPicLogoPort();
	_letter.txtPage_1.text			:= _page.String;
	
	if self.myCurrentInvoice.postedDT.isValid then  // was:  &lt;&gt; null
		_letter.lblInvoiceDate.caption := self.myCurrentInvoice.postedDT.date.shortFormatJMT() &amp; " " &amp; self.myCurrentInvoice.postedDT.time.shortFormatJMT();
	elseif self.myCurrentInvoice.isVoided then
		_letter.lblInvoiceDate.caption := "*** VOID ***";
	else
		_letter.lblInvoiceDate.caption := "Not posted";
	endif;
	
	_letter.lblVesselName.caption		:= null;
	_letter.lblVesselName.caption		:= self.myCurrentInvoice.vesselName;

	_letter.lblInvNarr.caption := self.myCurrentInvoice.narration; // PAR 32537

	if voyage &lt;&gt; null then
		if self.myCurrentInvoice.vesselName = null then
			_letter.lblVesselName.caption	:= voyage.vesselName;
		endif;
		_letter.lblVoyageCode.caption	:= voyage.code;
		_letter.lblArrivalDate.caption	:= voyage.arrivedDT.Date.shortFormatJMT();
		_letter.lblSailingDate.caption	:= voyage.departedDT.Date.shortFormatJMT();
		if voyage.myOperator &lt;&gt; null then
			_letter.lblOpDesc.caption	:= voyage.myOperator.description;
		else
			_letter.lblOpDesc.caption	:= null;
		endif;
	else
		_letter.lblVoyageCode.caption	:= null;
		_letter.lblArrivalDate.caption	:= null;
		_letter.lblSailingDate.caption	:= null;
		_letter.lblOpDesc.caption		:= null;
	endif;
	create oracle transient;
	//_letter.lblInvoiceNo.caption		:= self.myCurrentInvoice.sequenceNum.String;				// 07/03/2013 cnwar2 #31198
	_letter.lblInvoiceNo.caption		:= oracle.getExternalInvoiceNumber(self.myCurrentInvoice);	// 07/03/2013 cnwar2 #31198
	
	app.printer.print(_letter.frmHeader);

epilog
	delete oracle;
end;</source>
        <Parameter name="_letter" type="INV_LetterInvoiceOracleFinance" usage="io"/>
        <Parameter name="_page" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doPrintPOE" id="1427f212-ba39-43e9-ae1c-4f5fd9d51ef3">
        <source>doPrintPOE(preview : Boolean; _consolidate : Boolean; _oneLine : Boolean);
//
//17 Jun 2016	cnwrs1	TFS 2109 change the dict to one that has the narration and allows duplicates 
//
vars
	il:                  INV_LetterInvoicePOE; 
	str:                 String; 
	s:                   String;
	taxAmt,
	amt:                 Decimal[12,2];
	taxTotal,
	invStatTotal,
	txtHt:               Real;
//	tmpInvLineStat : CM_InvoiceLineStatByNarQtyDict;
//	invLineStatDict:     CM_InvoiceLineStatByNarManDict;
	invLineStatDict : CM_InvoiceLineStatByNarDict; // 21 Mar 2016	NDL	TFS 1682 - Change to dict to one that has narration and rate and allows dups
//	invLineStatDictCol:     CM_InvoiceLineStatByNarManDict;
//	invLineStatXXXDict:  CM_InvLineStatByMnPrnOrNarDict;
	invLineStat:         CM_InvoiceLineStat;
	adjustX, idx, i:                   Integer;
	ht:                  Real;
	newHt:               Real;
	taxRate 			: Real; // CCMS 1172
	tmpJadeReport  		: JadeReport;
	codes : StringArray; 
	rates  : RealArray; 
	amounts : RealArray;
	zeroTax : Boolean;
	firstPosAfterHeader : Real;
	spaceLeft : Real;
	gtrThanThreeLines : Boolean;
	sortDict : ObjectArray; // TESTING - CM_InvoiceLineStatByNarDict;
	obj : Object;
	
begin
	zeroTax :=  self.myCurrentInvoice.isZeroRatedTax; // PAR 25809
	 // CCMS 1172
	if zeroTax then
		taxRate := 0;
	else
		taxRate := self.myCurrentInvoice.bank.taxPercentageRate;
	endif;

	create codes transient;
	create rates transient;
	create amounts transient;

	app.mousePointer := MP_HOURGLASS;

	create tmpJadeReport transient;
	tmpJadeReport.description := "Invoice " &amp; self.myCurrentInvoice.sequenceNum.String;
	app.setPrinterDocumentType(false);
	
	app.printer.setReport(tmpJadeReport);

	app.printer.suppressDialog := true;
	
	create il;
	il.picLogoCompany.picture := app.getPicLogoPort();
	il.picLogoRem.picture := app.getPicLogoPort();
	app.printer.setMargins(Print_Portrait,10,10,10,10);

	doPrintPOEHeader(il,false);

	txtHt := il.txtCol1.height;
	il.txtCol1.text := self.myCurrentInvoice.narration;
	il.txtCol1.height := il.txtCol1.lineCount * txtHt;
	il.txtCol37.text := "";
	il.fOver.height := il.txtCol1.height + 10;
	app.printer.print(il.fOver);
	
	/* PAR 33175 WAS
	create invLineStatDict transient;
	invStatTotal := self.myCurrentInvoice.getInvoiceStats(invLineStatDict, null, false, false);
	if _consolidate then
		invLineStatDictCol := self.myCurrentInvoice.getInvoiceStatsConsolidate(invLineStatDict);
		if _oneLine then
			tmpInvLineStat := self.myCurrentInvoice.getInvoiceStatsConsolidate2One(invLineStatDictCol);
			invLineStatDictCol.purge;
			tmpInvLineStat.copy(invLineStatDictCol);
		endif;
		invLineStatDict.purge;
		invLineStatDictCol.copy(invLineStatDict);
	endif;
	NOW */
	
	// SEE UT_Invoicing::tConsolidatedInvoiceQtyRate to test consolidation to one line
	create sortDict transient; // PAR 33175
	invStatTotal := self.myCurrentInvoice.getInvoiceConsolidation(sortDict,_consolidate,_oneLine); // PAR 33175
	create invLineStatDict transient; // PAR 34736
	sortDict.copy(invLineStatDict); // Sort by narration
		
		
	firstPosAfterHeader := app.printer.getPrintPosition();			

	// PAR 33175 foreach invLineStat in invLineStatDict do	
	// PAR 34736 foreach obj in sortDict do	// PAR 33175 
	foreach invLineStat in invLineStatDict do	// PAR 34736 
		// PAR 34736 invLineStat := obj.CM_InvoiceLineStat; // PAR 33175  
		self.doPrintPOESetInvLine( il, invLineStat );	//17 Jan 2012	NDL	Par 28843
		
		if not app.printer.frameFits(il.fInvoiceLine) then
			spaceLeft := app.printer.pageHeight - app.printer.getPrintPosition();
			gtrThanThreeLines := spaceLeft &gt; ( txtHt * 3 );
			if gtrThanThreeLines then
				//17 Jan 2012	NDL	Par 28843
				if not app.printer.frameFits(il.fInvoiceLine) then
					// invoice text too big to even fit on one page, need to split it.
					self.doPrintPOESplitLine( il );	//17 Jan 2012	NDL	Par 28843
				endif;
			else
				app.printer.newPage;
				self.doPrintPOEClearInvLine( il, "Continued..." );	//17 Jan 2012	NDL	Par 28843 - need to clear and resize the frames
				doPrintPOEHeader(il,false);
				// printHeaderPOE overwrites the captions so we must reinstate them
				self.doPrintPOESetInvLine( il, invLineStat );	//17 Jan 2012	NDL	Par 28843
				app.printer.print(il.fOver);
				if not app.printer.frameFits(il.fInvoiceLine) then
					// invoice text too big to even fit on one page, need to split it.
					self.doPrintPOESplitLine( il );	//17 Jan 2012	NDL	Par 28843
				endif;
			endif;
		endif;
		
		app.printer.print(il.fInvoiceLine);
		
	endforeach;
	
	//17 Jan 2012	NDL	Par 28843
	spaceLeft := app.printer.pageHeight - app.printer.getPrintPosition();
	if spaceLeft &lt; 168 then
		//force a page thrpw so we get the totals one page, not spread around.
		il.txtCol1.height := txtHt;	//17 Jan 2012	NDL	Par 28843
		self.doPrintPOEClearInvLine( il, " " );	//17 Jan 2012	NDL	Par 28843
		app.printer.newPage;
		doPrintPOEHeader(il,true);
	endif;
			
	app.printer.print(il.fTitleSep);

	//amt := getTotalAmount(pd);
	//the amount printed on the invoice is the one and only true total!
	amt := invStatTotal;

	il.txtCol1.text := "";
	il.txtCol1.height := txtHt;
	il.txtCol26.text := "";
	il.txtCol37.text := amt.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
	il.fOver.height := il.txtCol1.height + 10;
	app.printer.print(il.fOver);

	
	if self.myCurrentInvoice.bank.parentCompany.addInvoiceTax then
		if not zeroTax  // PAR 25809
		and self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean then
			self.myCurrentInvoice.getTaxForInvoice(true, amt, codes, rates, amounts);
			
			foreach idx in 1 to 4 do
				if idx &lt;= codes.size then
					taxTotal := taxTotal + (amounts[idx] * (rates[idx] / 100));	// 25978 Invoice total/export total mismatch, do explicit rounding
				endif;
			endforeach;
			taxAmt := taxTotal.jMTRoundedTo($CM_ChargeQuantity.decimalPlaces);		// 25978
			il.txtCol1.text := "";
			il.txtCol1.height := txtHt;
			il.txtCol26.text := "G.S.T.";
			il.txtCol37.text := taxAmt.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
			il.fOver.height := il.txtCol1.height + 10;
			
			app.printer.print(il.fOver);
			if codes.size &gt; 1 then
	
				foreach idx in 1 to 4 do
					if idx &lt;= codes.size then
						if idx = 1 then
							il.lblTaxRate1.caption := rates[idx].String &amp; " %";
							il.lblTaxAmount1.caption := amounts[idx].asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true) ;
							il.lblTaxTotal1.caption := (amounts[idx] * (rates[idx]/100)).asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true);
							il.lblTaxTotal1.visible := true;
							il.lblTaxRate1.visible := true;
							il.lblTaxAmount1.visible := true;
							il.lblTaxAmountLbl.visible := true;
							il.lblTaxRateLbl.visible := true;
							il.lblTaxTotalLbl.visible := true;
							adjustX := (il.lblTaxRate1.clientWidth * 3);
						elseif idx = 2 then
							il.lblTaxRate2.caption := rates[idx].String &amp; " %";
							il.lblTaxAmount2.caption := amounts[idx].asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true);
							il.lblTaxTotal2.caption := (amounts[idx] * (rates[idx]/100)).asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true);
							il.lblTaxAmount2.visible := true;
							il.lblTaxTotal2.visible := true;
							il.lblTaxRate2.visible := true;
							adjustX := (il.lblTaxRate1.clientWidth * 2);
						elseif idx = 3 then
							il.lblTaxRate3.caption := rates[idx].String &amp; " %";
							il.lblTaxAmount3.caption := amounts[idx].asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true);
							il.lblTaxTotal3.caption := (amounts[idx] * (rates[idx]/100)).asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true);
							il.lblTaxAmount3.visible := true;
							il.lblTaxRate3.visible := true;
							il.lblTaxTotal3.visible := true;
							adjustX := (il.lblTaxRate1.clientWidth * 1);
						elseif idx = 4 then
							il.lblTaxRate4.caption := rates[idx].String &amp; " %";
							il.lblTaxAmount4.caption := amounts[idx].asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true);
							il.lblTaxTotal4.caption := (amounts[idx] * (rates[idx]/100)).asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true);
							il.lblTaxAmount4.visible := true;
							il.lblTaxRate4.visible := true;
							il.lblTaxTotal4.visible := true;
							adjustX := 0;
						endif;
					endif;
				endforeach;
			endif;
			
			il.frmTax.left := adjustX;
			app.printer.setPrintPosition((app.printer.getPrintPosition() - il.fOver.height - 20).Integer);
			app.printer.print(il.frmTax);	
		else
			taxAmt := (amt * (taxRate)/100.0);
			il.txtCol1.text := "";
			il.txtCol1.height := txtHt;
			il.txtCol26.text := "G.S.T.";
			il.txtCol37.text := taxAmt.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
			il.fOver.height := il.txtCol1.height + 10;
			app.printer.print(il.fOver);
		endif;
	endif;
	il.txtCol1.text := "";
	il.txtCol1.height := txtHt;
	il.txtCol26.text := "TOTAL AMOUNT "  ;
	il.txtCol37.text := (amt + taxAmt).asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
	il.fOver.height := il.txtCol1.height + 10;
	app.printer.print(il.fOver);
	 // PAR 25720 to here
	 
//	############
	app.printer.print(il.fTitleSep);
	il.txtCol1.text := "";
	il.txtCol26.text := "";
	il.txtCol37.text := "";
	il.fOver.height := txtHt;
	app.printer.print(il.fOver);

	str := "";
	foreach s in self.myCurrentInvoice.bank.physicalAddress do
		str := str &amp; s &amp; CrLf;
	endforeach;
	il.lblTyp.caption := self.myCurrentInvoice.debtor.decfinName;
	il.lblRemInvNum.caption := self.myCurrentInvoice.sequenceNum.String;
	il.txtRemitCoyAddress.text := str;
	il.lblRemAcCode.caption := "";
	
	// An ampersand is taken as being a button shortcut, so double it up and it prints single
	il.lblAccountName.caption := self.myCurrentInvoice.debtor.remarks.replaceString("&amp;","&amp;&amp;");
	
	// CCMS 1057 AKB2002AUG from here
	if self.myCurrentInvoice.bank.allBankDetails &lt;&gt; null then
		if self.myCurrentInvoice.bank.allBankDetails.size &gt;= 1 then
			il.lblBankDetails1.caption := self.myCurrentInvoice.bank.allBankDetails[1];
		endif;
		if self.myCurrentInvoice.bank.allBankDetails.size &gt;= 2 then
			il.lblBankDetails2.caption := self.myCurrentInvoice.bank.allBankDetails[2];
		endif;
		if self.myCurrentInvoice.bank.allBankDetails.size &gt;= 3 then
			il.lblBankDetails3.caption := self.myCurrentInvoice.bank.allBankDetails[3];
		endif;
	endif;
	// CCMS 1057 AKB2002AUG to here
	
	if not app.printer.frameFits(il.fRemittance) then
		il.txtCol1.height := txtHt;	//17 Jan 2012	NDL	Par 28843
		self.doPrintPOEClearInvLine( il, " " );	//17 Jan 2012	NDL	Par 28843
		app.printer.newPage;
		doPrintPOEHeader(il,true);
		txtHt := il.txtCol1.height;
		il.txtCol1.text := " ";
		il.txtCol1.height := il.txtCol1.lineCount * txtHt;
		il.txtCol37.text := "";
		il.fOver.height := il.txtCol1.height + 10;
		app.printer.print(il.fOver);
	endif;
	ht := il.fInvoiceLine.height;
	i := 0;
	while app.printer.frameFits(il.fInvoiceLine) do
		i := i + 1;
		newHt := ht * i;
		il.fInvoiceLine.height := newHt;
	endwhile;
	il.fInvoiceLine.height := ht * (i-1) - il.fRemittance.height;
	il.invoiceLineDesc.caption := "";
	il.lblQuantity.caption := "";
	il.lblRate.caption := "";
	il.lblTotal.caption := "";
	app.printer.print(il.fInvoiceLine);

	app.printer.print(il.fRemittance);

epilog
	sortDict.purge();
	delete sortDict;
	
	delete codes; // PAR 25720
	delete rates; // PAR 25720
	delete amounts; // PAR 25720
	app.printPreview(tmpJadeReport, true);
	app.printer.close;
	delete il;
//	invLineStatDict.purge;
//	delete invLineStatXXXDict; // CCMS 1125
//	delete invLineStatDictCol; // CCMS 1125
	delete invLineStatDict;
	app.mousePointer := MP_DEFAULT;
end;</source>
        <Parameter name="preview" type="Boolean"/>
        <Parameter name="_consolidate" type="Boolean"/>
        <Parameter name="_oneLine" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrintPOEClearInvLine" id="c4312970-8042-4ee2-bbf5-9f4726ae7cd7">
        <source>doPrintPOEClearInvLine( il : INV_LetterInvoicePOE io; strValue : String );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 January 2012	cnwndl1	Initial creation	Par 28843

*/

vars

begin

	il.txtCol1.text := "Continued...";
	il.txtCol37.text := "";
	il.fOver.height := il.txtCol1.height + 10;
	il.invoiceLineDesc.height := il.txtCol1.height;
	il.fInvoiceLine.height := il.invoiceLineDesc.height + 6;

epilog

end;</source>
        <Parameter name="il" type="INV_LetterInvoicePOE" usage="io"/>
        <Parameter name="strValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="doPrintPOEHeader" id="b7bc5670-c410-4591-97e6-c1b3686e8e92">
        <source>doPrintPOEHeader(il : INV_LetterInvoicePOE io; _forTotals : Boolean); //CM_LetterInvoice io);

vars
	str : String;
	s : String;

begin

	foreach s in self.myCurrentInvoice.debtor.billingAddress do
		str := str &amp; s &amp; CrLf;
	endforeach;
	il.txtAddressee2.text := str;

	str := "";
	foreach s in self.myCurrentInvoice.bank.mailingAddress do
		str := str &amp; s &amp; CrLf;
	endforeach;
	il.txtCoyAddress1.text := str;

	il.lblAcCode.caption := self.myCurrentInvoice.debtor.decfinName;
	il.lblDate.caption := "";   //date posted!
	il.lblInvoiceNo.caption := self.myCurrentInvoice.sequenceNum.String;

	//PAR 2715 AJA 10/3/99 Cannot test timeStamp against null as null is midnight.
	//Must test using isValid method
	if self.myCurrentInvoice.postedDT.isValid then  // was:  &lt;&gt; null
		il.lblDate.caption := self.myCurrentInvoice.toDT.date.shortFormatJMT();
	elseif self.myCurrentInvoice.isVoided then
		il.lblDate.caption := "*** VOID ***";
	else
		il.lblDate.caption := "Not posted";
	endif;
	il.lblAcCode.caption := self.myCurrentInvoice.debtor.decfinName;
	/* AKB Oct2001. PAR 1044 WAS
	il.lblPoNumber.caption := debtor.purchaseOrderCode;
	NOW */
	if self.myCurrentInvoice.purchaseOrderNumber &lt;&gt; null then
		il.lblPoNumber.caption := self.myCurrentInvoice.purchaseOrderNumber;
	else
		il.lblPoNumber.caption := self.myCurrentInvoice.debtor.purchaseOrderCode;
	endif;

	app.printer.print(il.fTitle2);
	app.printer.print(il.fTitleSep);

	il.invoiceLineDesc.fontBold := true;
	il.lblQuantity.fontBold := true;
	il.lblRate.fontBold := true;
	il.lblTotal.fontBold := true;
	if _forTotals then		//17 Jan 2012	NDL	Par 28843
		il.invoiceLineDesc.caption := " ";
		il.lblQuantity.caption := " ";
		il.lblRate.caption := " ";

	else
		il.invoiceLineDesc.caption := "Description";
		il.lblQuantity.caption := "Quantity";
		il.lblRate.caption := "Rate";
	endif;
	il.lblTotal.caption := "$";
	app.printer.print(il.fInvoiceLine);
	il.invoiceLineDesc.fontBold := false;
	il.lblQuantity.fontBold := false;
	il.lblRate.fontBold := false;
	il.lblTotal.fontBold := false;

	if not _forTotals then	//17 Jan 2012	NDL	Par 28843
		app.printer.print(il.fTitleSep);
	endif;

end;</source>
        <Parameter name="il" type="INV_LetterInvoicePOE" usage="io"/>
        <Parameter name="_forTotals" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrintPOESetInvLine" id="0512d388-ae57-4a4f-8b43-bdeb066f31b0">
        <source>doPrintPOESetInvLine( il : INV_LetterInvoicePOE io; invLineStat :  CM_InvoiceLineStat );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 January 2012	cnwndl1	Initial creation	Par 28843
20 Feb 2018	jlgmd1	TFS 36954 SNO - Error in SCT2 Rate Table (Swap $CM_RateEntry.decimalPlaces for terminal config)

*/

vars
	
	invLineNar : String;

begin

	invLineNar := invLineStat.narration;
	
	//uncomment this stuff for testing to build extra lines of narration.
/*	/*
	executeWhen JMTDevelopmentEnvironment;
	invLineNar := invLineStat.narration 	&amp; CrLf &amp; "A " &amp; CrLf &amp; "B " &amp; CrLf &amp; "C " &amp; CrLf &amp; "D " &amp; CrLf &amp; "E " &amp; CrLf &amp; "F " &amp; CrLf &amp; "G "
											&amp; CrLf &amp; "H " &amp; CrLf &amp; "I " &amp; CrLf &amp; "J " &amp; CrLf &amp; "K " &amp; CrLf &amp; "L " &amp; CrLf &amp; "M " &amp; CrLf &amp; "N "											
											&amp; CrLf &amp; "O " &amp; CrLf &amp; "P " &amp; CrLf &amp; "Q " &amp; CrLf &amp; "R " &amp; CrLf &amp; "S " &amp; CrLf &amp; "T " &amp; CrLf &amp; "U "
											&amp; CrLf &amp; "V " &amp; CrLf &amp; "W " &amp; CrLf &amp; "X " &amp; CrLf &amp; "Y " &amp; CrLf &amp; "Z "
											&amp; CrLf &amp; "A " &amp; CrLf &amp; "B " &amp; CrLf &amp; "C " &amp; CrLf &amp; "D " &amp; CrLf &amp; "E " &amp; CrLf &amp; "F " &amp; CrLf &amp; "G "
											&amp; CrLf &amp; "H " &amp; CrLf &amp; "I " &amp; CrLf &amp; "J " &amp; CrLf &amp; "K " &amp; CrLf &amp; "L " &amp; CrLf &amp; "M " &amp; CrLf &amp; "N "										
											&amp; CrLf &amp; "O " &amp; CrLf &amp; "P " &amp; CrLf &amp; "Q " &amp; CrLf &amp; "R " &amp; CrLf &amp; "S " &amp; CrLf &amp; "T " &amp; CrLf &amp; "U "
											&amp; CrLf &amp; "V " &amp; CrLf &amp; "W " &amp; CrLf &amp; "X " &amp; CrLf &amp; "Y " &amp; CrLf &amp; "Z "
											&amp; CrLf &amp; "A " &amp; CrLf &amp; "B " &amp; CrLf &amp; "C " &amp; CrLf &amp; "D " &amp; CrLf &amp; "E " &amp; CrLf &amp; "F " &amp; CrLf &amp; "G "
											&amp; CrLf &amp; "H " &amp; CrLf &amp; "I " &amp; CrLf &amp; "J " &amp; CrLf &amp; "K " &amp; CrLf &amp; "L " &amp; CrLf &amp; "M " &amp; CrLf &amp; "N ";										
											//&amp; CrLf &amp; "O ";// &amp; CrLf &amp; "P ";// &amp; CrLf &amp; "Q ";// &amp; CrLf &amp; "R ";// &amp; CrLf &amp; "S ";	// &amp; CrLf &amp; "T ";// &amp; CrLf &amp; "U ";
											//&amp; CrLf &amp; "V " &amp; CrLf &amp; "W " &amp; CrLf &amp; "X " &amp; CrLf &amp; "Y " &amp; CrLf &amp; "Z ";
	endExecuteWhen; */
	

	il.invoiceLineDesc.caption := invLineNar;
	il.invoiceLineDesc.height := il.invoiceLineDesc.getTextHeightForWidth(invLineNar,il.invoiceLineDesc.clientWidth());
	il.fInvoiceLine.height := il.invoiceLineDesc.height + 6;		
	il.lblQuantity.caption := invLineStat.quantity.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
	//il.lblRate.caption := invLineStat.rate.asStringJMTWithPrecision($CM_RateMoney.decimalPlaces, false);
	il.lblRate.caption := invLineStat.rate.asStringJMTWithPrecision(self.getRateEntryDecimalPlaces, false);	// TFS 36954 MPD 20 Feb 2018
	il.lblTotal.caption := invLineStat.total.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);

epilog

end;</source>
        <Parameter name="il" type="INV_LetterInvoicePOE" usage="io"/>
        <Parameter name="invLineStat" type="CM_InvoiceLineStat"/>
    </JadeMethod>
    <JadeMethod name="doPrintPOESplitLine" id="0ab9908c-b55c-4b4c-8c42-bb40b153f7e8">
        <source>doPrintPOESplitLine( il : INV_LetterInvoicePOE io );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 January 2012	cnwndl1	Initial creation	Par 28843

*/

vars

	maxAvailHeight : Real;
	fullNarration : String;
	label : Label;
	maxLineWidth : Integer;
	startAt : Integer;
	pos : Integer;
	checkString : String;
	checkHeight : Real;
	useString : String;
	nextFullNarration : String;
	searchString : String;

begin

	maxAvailHeight := app.printer.pageHeight - app.printer.getPrintPosition();
	
	label := il.invoiceLineDesc;
	fullNarration := label.caption;
	maxLineWidth := label.clientWidth(); 
	
	// find how much we can actually print on this page...
	startAt := 1;
	searchString := " ";
	while true do
		pos := fullNarration.pos( searchString, startAt );
		if pos &lt; 1 then
			if searchString = " " and startAt = 1 then
				searchString := CrLf;
				continue;
			else
				break;
			endif;
		endif;
		startAt := pos + 1;
		checkString := fullNarration[1:pos-1];
		checkHeight := label.getTextHeightForWidth(checkString,maxLineWidth) + 6;
		if checkHeight &gt; maxAvailHeight then
			break;
		endif;
		useString := checkString;
		nextFullNarration := "Continued..." &amp; CrLf &amp; fullNarration[pos+1:end];
	endwhile;
	
	//set up the first page and print it.
	il.invoiceLineDesc.caption := useString;
	il.invoiceLineDesc.height := il.invoiceLineDesc.getTextHeightForWidth(useString,maxLineWidth);
	il.fInvoiceLine.height := il.invoiceLineDesc.height + 6;		
	app.printer.print(il.fInvoiceLine);
	
	// set up the continuation page
	app.printer.newPage;
	self.doPrintPOEClearInvLine( il, " " );	
	doPrintPOEHeader(il,false);
	
	il.invoiceLineDesc.caption := nextFullNarration;
	il.invoiceLineDesc.height := il.invoiceLineDesc.getTextHeightForWidth(nextFullNarration,maxLineWidth);
	il.fInvoiceLine.height := il.invoiceLineDesc.height + 6;
	il.lblQuantity.caption := null;
	il.lblRate.caption := null;
	il.lblTotal.caption := null;
	
	if not app.printer.frameFits(il.fInvoiceLine) then
		// still too big to even fit on one page, need to split it.
		self.doPrintPOESplitLine( il );	//17 Jan 2012	NDL	Par 28843
	endif;
					
epilog

end;</source>
        <Parameter name="il" type="INV_LetterInvoicePOE" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doPrintSPT" id="72d421a1-db11-4a40-a673-cba840413eb7">
        <source>doPrintSPT(preview: Boolean; _consolidate : Boolean; _oneLine : Boolean);

constants
	Invoice_Line_Spacing = 6;
	Invoice_Line_To_TI_IDs_Spacing = 3;
	Invoice_Remarks_Indent = 28;
	Invoice_TI_IDs_Indent = 28;
	Invoice_Description_Width = 475;
vars
	tmpJadeReport  : JadeReport;
	il:                  INV_LetterInvoiceSPT; 
	pd:                  CMS_Progress;
	str:                 String;
	s:                   String;
	strDescriptionTIs:   String;
	taxAmt,
	amt:                 Decimal[12,2];
//	tmpInvLineStat : CM_InvoiceLineStatByNarQtyDict;
//	invLineStatDict:     CM_InvoiceLineStatByNarManDict;
//	invLineStatDictCol:     CM_InvoiceLineStatByNarManDict;
//	invLineStatXXXDict:  CM_InvLineStatByMnPrnOrNarDict;
	invLineStat:         CM_InvoiceLineStat;
	i:                   Integer;
	tiLines:             Integer;
	remarksLines:        Integer;
	lineHeight:          Integer;
	invStatTotal,
	requiredHeight:      Real;
	actualHeight:        Real;
	endHeight:           Real;
	doPrint:             Boolean;
	cmString:            CM_String;
	invoicePrintRemarks : Boolean;
	taxRate : Real; // CCMS 1172
	printSingleLineForDayType : Boolean;
	sortDict : ObjectArray; // TESTING - CM_InvoiceLineStatByNarDict;
	obj : Object;
	dpl : Integer;
begin

	// TFS 36954 MPD 20 Feb 2018
	dpl := self.getRateEntryDecimalPlaces;

	// ### CCMS 1253
	printSingleLineForDayType := self.myCurrentInvoice.invoiceType.printSingleLineForDayType;


	 // CCMS 1172
	if self.myCurrentInvoice.isZeroRatedTax then
		taxRate := 0;
	else
		taxRate := self.myCurrentInvoice.bank.parentCompany.taxPercentageRate;
	endif;

	app.mousePointer := MP_HOURGLASS;

	// CCMS 1074 AKB2002NOV 
	invoicePrintRemarks := self.myTerminal.getConfig(InvoicePrintRemarks).Boolean;

	create tmpJadeReport transient;
	tmpJadeReport.description := "Invoice " &amp; self.myCurrentInvoice.sequenceNum.String;
	app.printer.setReport(tmpJadeReport);

	app.printer.suppressDialog := true;

	create il;
	create pd;
	pd.show;
	pd.raiseExceptionOnAbort := false;
	pd.setAction("Printing Invoice " &amp; self.myCurrentInvoice.sequenceNum.String);
	app.printer.setMargins(Print_Portrait,0,4,0,0);

	pd.progress.partsInJob := self.myCurrentInvoice.invoiceLines.size;

	// setup header information
	foreach s in self.myCurrentInvoice.debtor.billingAddress do
		str := str &amp; s &amp; Lf;
	endforeach;
	// remove trailing linefeed
	il.lblDebtorDetails.caption := str[1 : str.length - 1];

	if self.myCurrentInvoice.postedDT.isValid then
		//il.lblDate.caption := postedDT.date.userFormat($CM_ShortDate);
		il.lblDate.caption := self.myCurrentInvoice.toDT.date.shortFormatJMT();
	elseif self.myCurrentInvoice.isVoided then
		il.lblDate.caption := "*** VOID ***";
	else
		il.lblDate.caption := "Not posted";
	endif;
	
	il.lblAccount.caption := self.myCurrentInvoice.debtor.decfinName;
	il.lblInvoiceNumber.caption := self.myCurrentInvoice.sequenceNum.String;
	il.lblJob.caption := "";
	// set header
	app.printer.setHeader(il.frHeader);

	// The first line on the first page is the narration for the invoice
	il.lblServiceDate.caption := "";
	il.lblRef.caption := "";
	il.lblDescription.caption := self.myCurrentInvoice.narration;
	il.lblDescription.width := Invoice_Description_Width;
	il.frInvoiceLine.height := il.lblDescription.height + Invoice_Line_Spacing;
	il.lblQuantity.caption := "";
	il.lblRate.caption := "";
	il.lblUnit.caption := "";
	il.lblAmount.caption := "";
	il.lblPON.caption := self.myCurrentInvoice.purchaseOrderNumber;
	if self.myCurrentInvoice.invoiceType.myInvTermsOfTrade &lt;&gt; null then
		il.lblPayTerms.caption := "Payment Terms : " &amp; self.myCurrentInvoice.invoiceType.myInvTermsOfTrade.description;
	else
		il.lblPayTerms.caption := null;
	endif;	
	app.printer.print(il.frInvoiceLine);

	// PAR 33175 create invLineStatDict transient;
	// PAR 33175 invStatTotal := self.myCurrentInvoice.getInvoiceStats(invLineStatDict, pd, false, true);
	if pd.aborted then
		pd.unloadForm;

		app.printer.abort;
		return;
	endif;

	/* PAR 33175 WAS
	// CCMS 1125 from here
	if _consolidate then
		invLineStatDictCol := self.myCurrentInvoice.getInvoiceStatsConsolidate(invLineStatDict);
		if _oneLine then
			tmpInvLineStat := self.myCurrentInvoice.getInvoiceStatsConsolidate2One(invLineStatDictCol);
			invLineStatDictCol.purge;
			tmpInvLineStat.copy(invLineStatDictCol);
		endif;
		create invLineStatXXXDict transient;
		invLineStatDictCol.copy(invLineStatXXXDict);
	else
		create invLineStatXXXDict transient;
		invLineStatDict.copy(invLineStatXXXDict);
	endif;
	// CCMS 1125 to here

	NOW */
	
	// SEE UT_Invoicing::tConsolidatedInvoiceQtyRate to test consolidation to one line
	create sortDict transient; // PAR 33175
	invStatTotal := self.myCurrentInvoice.getInvoiceConsolidation(sortDict,_consolidate,_oneLine);
	
	il.lblDescription.caption := "fg";
	lineHeight := il.lblDescription.height.Integer;
	il.lblDescription.caption := "";

	// print the lines
	// PAR 33175 foreach invLineStat in invLineStatXXXDict do
	foreach obj in sortDict do	// PAR 33175 
		invLineStat := obj.CM_InvoiceLineStat; // PAR 33175  
		
		il.lblServiceDate.caption := "";
		il.lblRef.caption := "";
//		il.lblQuantity.caption := invLineStat.quantity.userNumberFormat($CM_RateEntry); // AKB PAR 2627 27Mar2001 WAS
		il.lblQuantity.caption := invLineStat.quantity.asStringJMTWithPrecision($CM_InvoiceQuantity.decimalPlaces, true); // AKB PAR 2627 27Mar2001 NOW

		//il.lblRate.caption := invLineStat.rate.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true);
		il.lblRate.caption := invLineStat.rate.asStringJMTWithPrecision(dpl, true); // TFS 36954 MPD 20 Feb 2018
		il.lblUnit.caption := invLineStat.unitNarration;
		//il.lblAmount.caption := (invLineStat.quantity * invLineStat.rate).Decimal.userNumberFormat($CM_ChargeQuantity);
		il.lblAmount.caption := invLineStat.total.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true); //GD May2001 xp1012

		il.frRemarks.height := 0;
		il.frTrackedItems.height := 0;

		// ################## 
		// CCMS 1074
		if invoicePrintRemarks and invLineStat.remarks.trimBlanks &lt;&gt; null then // PAR 4460 JC 2003 FEB 
			il.lblDescription.caption := invLineStat.remarks;
		else
			il.lblDescription.caption := invLineStat.narration;
		endif;
		// PAR 17363
		il.lblDescription.height := il.lblDescription.getTextHeightForWidth(invLineStat.narration,il.lblDescription.clientWidth());
		il.frInvoiceLine.height := il.lblDescription.height + 6;

		// CCMS 1253. If we are printing 1 line per ti, do not list that TI ID
		if printSingleLineForDayType then
			if invLineStat.quantity = invLineStat.allTrackedItems.size then
				tiLines := 0;
			endif;
		else
			tiLines := (invLineStat.allTrackedItems.size + 3) div 4;
		endif;
		remarksLines := invLineStat.narrationComments.size;

//		il.lblDescription.caption := invLineStat.narration; PAR7466 removed
		il.lblDescription.width := Invoice_Description_Width;

		if remarksLines = 0 and tiLines = 0 then
			requiredHeight := il.lblDescription.height + Invoice_Line_Spacing;
			endHeight := Invoice_Line_Spacing;
			actualHeight := -1;
		else
			// ensure that the description is not orphaned from its remarks or ti lines.
			if remarksLines = 0 then
				// next line will be a ti Line
				requiredHeight := il.lblDescription.height +
								  Invoice_Line_To_TI_IDs_Spacing +
								  lineHeight;
				endHeight := 0;
				actualHeight := il.lblDescription.height +
								Invoice_Line_To_TI_IDs_Spacing;
			else
				requiredHeight := il.lblDescription.height +
								  lineHeight;
				endHeight := 0;
				actualHeight := il.lblDescription.height;
			endif;
		endif;

		if il.setFrameHeight(il.frInvoiceLine, requiredHeight, endHeight, actualHeight) then
			// newpage is needed
			app.printer.newPage;
		endif;

		app.printer.print(il.frInvoiceLine);

		if remarksLines &gt; 0 then
			i := 0;
			foreach s in invLineStat.narrationComments do
				i := i + 1;
				il.lblRemarks.caption := s;
				il.lblRemarks.width := Invoice_Description_Width - Invoice_Remarks_Indent;
				requiredHeight := il.lblRemarks.height;
				actualHeight := -1;
				if i = remarksLines then
					if tiLines &gt; 0 then
						endHeight := Invoice_Line_To_TI_IDs_Spacing;
					else
						endHeight := Invoice_Line_Spacing;
					endif;
				else
					endHeight := 0;
				endif;
				requiredHeight := requiredHeight + endHeight;
				if il.setFrameHeight(il.frRemarks, requiredHeight, endHeight, actualHeight) then
					// newpage is needed
					app.printer.newPage;
				endif;
				app.printer.print(il.frRemarks);
			endforeach;
		endif;

		strDescriptionTIs := "";
		if tiLines &gt; 0 then
			i := 0;
			foreach cmString in invLineStat.allTrackedItems do
				s := cmString.string;
				i := i + 1;
				doPrint := false;
				if i mod 4 = 1 then
					strDescriptionTIs := "  " &amp; s;
				else
					strDescriptionTIs := strDescriptionTIs &amp; ", " &amp; s;
				endif;

				if i = invLineStat.allTrackedItems.size then
					strDescriptionTIs := strDescriptionTIs &amp; ".";
					endHeight := Invoice_Line_Spacing;
					doPrint := true;
				elseif i mod 4 = 0 then
					strDescriptionTIs := strDescriptionTIs &amp; ",";
					endHeight := 0;
					doPrint := true;
				endif;

				if doPrint then
					il.lblTrackedItems.caption := strDescriptionTIs;
					il.lblTrackedItems.width := Invoice_Description_Width - Invoice_TI_IDs_Indent;
					strDescriptionTIs := "  ";

					requiredHeight := il.lblTrackedItems.height + endHeight;
					actualHeight := -1;
					if il.setFrameHeight(il.frTrackedItems, requiredHeight, endHeight, actualHeight) then
						// newpage is needed
						app.printer.newPage;
					endif;
					app.printer.print(il.frTrackedItems);

				endif;
			endforeach;
		endif;

	endforeach;

	//amt := getTotalAmount(pd);
	//the amount printed on the invoice is the one and only true total!
	amt := invStatTotal;

	if pd.aborted then
		app.printer.abort;
		return;
	endif;

	il.lblAmountSubTotal.caption := amt.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);

	if self.myCurrentInvoice.bank.parentCompany.addInvoiceTax then
		taxAmt := amt * (taxRate)/100.0;
		il.lblAmountTax.caption := taxAmt.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
		il.lblAmountTotal.caption := (amt + taxAmt).asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
//		il.lblAmountTax.caption := (amt * (taxRate)/100.0).userNumberFormat($CM_ChargeQuantity);
//		il.lblAmountTotal.caption := (amt * (100.0 + taxRate)/100.0).userNumberFormat($CM_ChargeQuantity);
	else
		il.lblAmountTax.caption := "";
		il.lblAmountTotal.caption := (amt).asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
	endif;
	
	if self.myCurrentInvoice.debtor.myTermsOfTrade &lt;&gt; null then
		il.lblPayTerms.caption := "Payment Terms : " &amp; self.myCurrentInvoice.debtor.myTermsOfTrade.description;
	elseif self.myCurrentInvoice.invoiceType.myInvTermsOfTrade &lt;&gt; null then
		il.lblPayTerms.caption := "Payment Terms : " &amp; self.myCurrentInvoice.invoiceType.myInvTermsOfTrade.description;
	else
		il.lblPayTerms.caption := null;
	endif;	
	
	app.printer.print(il.frTotalLines);

epilog

	app.printPreview(tmpJadeReport, true);
	app.printer.close;
	sortDict.purge();
	delete sortDict;
	
	delete pd;
	delete il;
//	delete invLineStatXXXDict;
//	delete invLineStatDictCol; // CCMS 1125
//	invLineStatDict.purge;
//	delete invLineStatDict;
	app.mousePointer := MP_DEFAULT;
end;</source>
        <Parameter name="preview" type="Boolean"/>
        <Parameter name="_consolidate" type="Boolean"/>
        <Parameter name="_oneLine" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrintTIList" id="f4a5fdcf-0d70-40a7-aa95-249f52602041">
        <source>doPrintTIList(_invLineStat:CM_InvoiceLineStat; _il: INV_LetterInvoiceDefault input; 	_requiredHeight :  Real;_actualHeight: Real; _endHeight: Real);
// ---------------------------------------------------------------------------
// Created:		07 June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	Invoice_Line_Spacing = 6;
	Invoice_Line_To_TI_IDs_Spacing = 3;
	Invoice_Remarks_Indent = 28;
	Invoice_TI_IDs_Indent = 28;
	Invoice_Description_Width = 405;
vars
	tmpJadeReport  : JadeReport;
	pd:                  CMS_Progress;
	str:                 String;
	s:                   String;
	strDescriptionTIs:   String;
	taxAmt,
	amt:                 Decimal[12,2];
	tmpInvLineStat : CM_InvoiceLineStatByNarQtyDict;
	invLineStatDict:     CM_InvoiceLineStatByNarManDict;
	invLineStatDictCol:     CM_InvoiceLineStatByNarManDict;
	invLineStatXXXDict:  CM_InvLineStatByMnPrnOrNarDict;
	invLineStat:         CM_InvoiceLineStat;
	i:                   Integer;
	remarksLines:        Integer;
	lineHeight:          Integer;
	invStatTotal,
	requiredHeight:      Real;
	actualHeight:        Real;
	endHeight:           Real;
	saveWidth:			 Real;
	doPrint:             Boolean;
	cmString:            CM_String;
	invoicePrintRemarks : Boolean;
	taxRate : Real; // CCMS 1172
	printSingleLineForDayType : Boolean;
begin
	requiredHeight := _requiredHeight;
	actualHeight := _actualHeight;
	endHeight := _endHeight;
	// ### CCMS 1253
	printSingleLineForDayType := self.myCurrentInvoice.invoiceType.printSingleLineForDayType;
	strDescriptionTIs := "";
	_il.lblQuantity.caption := "";
	_il.lblRate.caption := "";
	_il.lblUnit.caption := "";
	_il.lblTotal.caption := "";

	saveWidth:=_il.invoiceLineDesc.width;	// 24167 width is increased below for tracked item ids
		i := 0;
		foreach cmString in _invLineStat.allTrackedItems do
			s := cmString.string;
			i := i + 1;
			doPrint := false;
//			if i mod 4 = 1 then
			if i mod 3 = 1 then
				strDescriptionTIs := "  " &amp; s;
			else
				strDescriptionTIs := strDescriptionTIs &amp; ", " &amp; s;
			endif;

			if i = _invLineStat.allTrackedItems.size then
				strDescriptionTIs := strDescriptionTIs &amp; ".";
				endHeight := Invoice_Line_Spacing;
				doPrint := true;
//			elseif i mod 4 = 0 then
			elseif i mod 3 = 0 then
				strDescriptionTIs := strDescriptionTIs &amp; ",";
				endHeight := 0;
				doPrint := true;
			endif;

			if doPrint then
				_il.invoiceLineDesc.caption := strDescriptionTIs;
				_il.invoiceLineDesc.width := Invoice_Description_Width - Invoice_TI_IDs_Indent;
				strDescriptionTIs := "  ";

				requiredHeight := _il.invoiceLineDesc.height + endHeight;
				actualHeight := -1;
				if _il.setFrameHeight(_il.fInvoiceLine, requiredHeight, endHeight, actualHeight) then
					// newpage is needed
					app.printer.newPage;
				endif;
				app.printer.print(_il.fInvoiceLine);

			endif;
		endforeach;
	_il.invoiceLineDesc.width := saveWidth;	// 24167 restore to original so it doesn't overwrite any following quantity value
end;</source>
        <Parameter name="_invLineStat" type="CM_InvoiceLineStat"/>
        <Parameter name="_il" type="INV_LetterInvoiceDefault" usage="input"/>
        <Parameter name="_requiredHeight" type="Real"/>
        <Parameter name="_actualHeight" type="Real"/>
        <Parameter name="_endHeight" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doPrintTiDetails" id="93f2e745-5836-46fa-bb3e-87c012ad620e">
        <source>doPrintTiDetails(preview: Boolean);
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 12/07/2017	cnwma1	TFS #4702:JMT - Invoice Line Date/Time not being displayed in local timezone
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
30 Jun 2008	cnwkpd1	PAR #17361 - Rewokr epilog code to ensure transients are 
					tidied up in all cases

*/

constants
	After_IDs_Spacing = 3;
	After_Description_Spacing = 3;
	After_Total_Spacing = 30;
	Description_Width = 405;
	Invoice_Label_Width = 592;
vars
	il:                 INV_InvoiceTIDetails;
	pd:                 CMS_Progress;
//	str:                String;
//	s:                  String;
//	strDescriptionTIs:  String;
//	amt:                Decimal[12,2];
	invLineStatDict:    CM_InvoiceLineStatByNarManDict;
	invLineStat:        CM_InvoiceLineStat;
	i:                  Integer;
	invStatTotal,
	requiredHeight:     Real;
	actualHeight:       Real;
	endHeight:          Real;
	doPrint:            Boolean;
	stringThing:        CM_String;
	strWithObject:      CM_StringWithObject;
	//strWithObject:      CM_String;
	lblQty:             Label;
	lblContId:          Label;
	lblDate:            Label;
	tmpJadeReport  : JadeReport;
	tisPrinted : Boolean;
begin
	if self.myCurrentInvoice = null then
		app.msgBox("Please select an invoice to print!","Print Error",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	app.mousePointer := MP_HOURGLASS;

	create tmpJadeReport transient;
	tmpJadeReport.description := "Invoice";
	app.printer.setReport(tmpJadeReport);

	app.printer.suppressDialog := true;

	create il;
	il.picLogoCompany.picture := app.getPicLogoPort();
	il.picLogoJMT.picture := app.getPicLogoProduct();
	create pd;
	pd.show;
	pd.raiseExceptionOnAbort := false;
	pd.setAction("Printing Invoice " &amp; self.myCurrentInvoice.sequenceNum.String);
	app.printer.setMargins(Print_Landscape,0,4,0,0);

	pd.progress.partsInJob := self.myCurrentInvoice.invoiceLines.size;

	// setup header information
	il.lblDebtor.caption := self.myCurrentInvoice.debtor.name;

	if self.myCurrentInvoice.postedDT.isValid then
		il.lblInvoiceDate.caption := self.myCurrentInvoice.toDT.date.shortFormatJMT();
	else
		il.lblInvoiceDate.caption := "No Close Date!";
	endif;

	il.lblInvoice.caption := "Invoice No. " &amp; self.myCurrentInvoice.sequenceNum.String &amp; "  " &amp; self.myCurrentInvoice.invoiceType.getInvoiceString(self.myCurrentInvoice) &amp; ".";
	il.lblInvoice.width := Invoice_Label_Width;

	il.lblHdrDescription.caption := "Line Description";
	il.lblHdrQty_1.caption := "Qty";
	il.lblHdrContrId_1.caption := "Cargo Item";
	il.lblHdrDate_1.caption := "Date";
	il.lblHdrQty_2.caption := "Qty";
	il.lblHdrContrId_2.caption := "Cargo Item";
	il.lblHdrDate_2.caption := "Date";
	il.lblHdrQty_3.caption := "Qty";
	il.lblHdrContrId_3.caption := "Cargo Item";
	il.lblHdrDate_2.caption := "Date";
	il.lblHdrQty_4.caption := "Qty";
	il.lblHdrContrId_4.caption := "Cargo Item";
	il.lblHdrDate_4.caption := "Date";
	il.lblHdrQty_5.caption := "Qty";
	il.lblHdrContrId_5.caption := "Cargo Item";
	il.lblHdrDate_5.caption := "Date";

	// set header
	app.printer.setHeader(il.frHeader);

	// set footer
	il.lblTheUser.caption := app.getMyUserCode;
	app.printer.setFooter(il.frFooter);

	create invLineStatDict transient;
	invStatTotal := self.myCurrentInvoice.getInvoiceStats(invLineStatDict, pd, true, true);
	if pd.aborted then
		app.printer.abort;
		return;
	endif;
	//pd.unloadForm;

	// print the lines
	foreach invLineStat in invLineStatDict do
		// remove manual lines as not part of report
		foreach stringThing in invLineStat.allTrackedItems do
			if stringThing.CM_StringWithObject.object.CM_InvoiceLine.manual then
				invLineStat.allTrackedItems.remove(stringThing);
				delete stringThing;
			endif;
		endforeach;

		if invLineStat.allTrackedItems.size &gt; 0 then
			tisPrinted := true;
			il.lblQuantity_1.caption := "";
			il.lblContainerId_1.caption := "";
			il.lblDate_1.caption := "";
			il.lblQuantity_2.caption := "";
			il.lblContainerId_2.caption := "";
			il.lblDate_2.caption := "";
			il.lblQuantity_3.caption := "";
			il.lblContainerId_3.caption := "";
			il.lblDate_3.caption := "";
			il.lblQuantity_4.caption := "";
			il.lblContainerId_4.caption := "";
			il.lblDate_4.caption := "";
			il.lblQuantity_5.caption := "";
			il.lblContainerId_5.caption := "";
			il.lblDate_5.caption := "";
			il.lblDescription.caption := "";

			il.lblDescription.caption := invLineStat.narration;
			il.lblDescription.width := Description_Width;
			endHeight := After_Description_Spacing;
			requiredHeight := 2 * (il.lblDescription.height + endHeight);
			actualHeight := il.lblDescription.height + endHeight;
			if il.setFrameHeight(il.frDescription, requiredHeight, endHeight, actualHeight) then
				// newpage is needed
				app.printer.newPage;
			endif;
			app.printer.print(il.frDescription);

			if invLineStat.allTrackedItems.size &gt; 0 then
				i := 0;
				foreach stringThing in invLineStat.allTrackedItems do
					strWithObject := stringThing.CM_StringWithObject;
					i := i + 1;
					doPrint := false;
					if i mod 5 = 1 then
						lblQty    := il.lblQuantity_1;
						lblContId := il.lblContainerId_1;
						lblDate   := il.lblDate_1;
					elseif i mod 5 = 2 then
						lblQty    := il.lblQuantity_2;
						lblContId := il.lblContainerId_2;
						lblDate   := il.lblDate_2;
					elseif i mod 5 = 3 then
						lblQty    := il.lblQuantity_3;
						lblContId := il.lblContainerId_3;
						lblDate   := il.lblDate_3;
					elseif i mod 5 = 4 then
						lblQty    := il.lblQuantity_4;
						lblContId := il.lblContainerId_4;
						lblDate   := il.lblDate_4;
					elseif i mod 5 = 0 then
						lblQty    := il.lblQuantity_5;
						lblContId := il.lblContainerId_5;
						lblDate   := il.lblDate_5;
					endif;

					lblQty.caption := strWithObject.object.CM_InvoiceLine.quantity.String;
					lblContId.caption := strWithObject.string;
					//lblDate.caption := strWithObject.object.CM_InvoiceLine.getChargeTime.date.shortFormatJMT();         //12.7.2017 cnwma1 TFS #4702
					lblDate.caption := strWithObject.object.CM_InvoiceLine.getChargeTimeLocalTZ.date.shortFormatJMT();   //12.7.2017 cnwma1 TFS #4702

					if i = invLineStat.allTrackedItems.size then
						endHeight := After_IDs_Spacing;
						doPrint := true;
					elseif i mod 5 = 0 then
						endHeight := 0;
						doPrint := true;
					endif;

					if doPrint then
						requiredHeight := il.lblContainerId_1.height + endHeight;
						actualHeight := -1;
						if il.setFrameHeight(il.frDetails, requiredHeight, endHeight, actualHeight) then
							// newpage is needed
							app.printer.newPage;
						endif;
						app.printer.print(il.frDetails);

						il.lblQuantity_1.caption := "";
						il.lblContainerId_1.caption := "";
						il.lblDate_1.caption := "";
						il.lblQuantity_2.caption := "";
						il.lblContainerId_2.caption := "";
						il.lblDate_2.caption := "";
						il.lblQuantity_3.caption := "";
						il.lblContainerId_3.caption := "";
						il.lblDate_3.caption := "";
						il.lblQuantity_4.caption := "";
						il.lblContainerId_4.caption := "";
						il.lblDate_4.caption := "";
						il.lblQuantity_5.caption := "";
						il.lblContainerId_5.caption := "";
						il.lblDate_5.caption := "";
						il.lblDescription.caption := "";
					endif;
				endforeach;
			endif;

			il.lblTotalTiCount.caption := "Total Cargo Items = " &amp; invLineStat.allTrackedItems.size.String &amp; 
				",  Total Quantity = " &amp; invLineStat.quantity.String;
			
			il.lblTotalTiCount.width := Description_Width;
			requiredHeight := il.lblDescription.height + il.lblDescription.top + After_Total_Spacing;
			endHeight := requiredHeight - 25;
			actualHeight := -1;
			if il.setFrameHeight(il.frTotal, requiredHeight, endHeight, actualHeight) then
				// newpage is needed
				app.printer.newPage;
			endif;
			app.printer.print(il.frTotal);

		endif;

	endforeach;

	app.printer.close;
	if not tisPrinted then
		app.msgBox("No cargo items to print for. No printed output.", "Invoice Detail Print", MsgBox_OK_Only);
	endif;


epilog
	app.mousePointer := MP_DEFAULT;
	if self.myCurrentInvoice &lt;&gt; null and tisPrinted then
		app.printPreview(tmpJadeReport, true);
	endif;
	
	// PAR #17361 - made all the tidy up code unconditional
	delete pd;
	delete il;
	if invLineStatDict &lt;&gt; null then
		invLineStatDict.purge;
		delete invLineStatDict;
	endif;
end;</source>
        <Parameter name="preview" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPrintWLG" id="f396af25-c35b-4a2a-a75d-236d85a3d3b8">
        <source>doPrintWLG(preview: Boolean; _consolidate : Boolean; _oneLine : Boolean);

/*

Date		Who		Reason
30 Jun 2008	cnwkpd1	PAR #17361 - Tidy up epilog to ensure transients are cleared
					unconditionally

*/

constants
	Invoice_Line_Spacing = 6;
	Invoice_Line_To_TI_IDs_Spacing = 3;
	Invoice_Remarks_Indent = 28;
	Invoice_TI_IDs_Indent = 28;
	Invoice_Description_Width = 405;
vars
	tmpJadeReport  : JadeReport;
	il:                  INV_LetterInvoiceCP; 
	pd:                  CMS_Progress;
	str:                 String;
	s:                   String;
	strDescriptionTIs:   String;
	taxAmt,
	amt:                 Decimal[12,2];
 //	tmpInvLineStat : CM_InvoiceLineStatByNarQtyDict;
//	invLineStatDict:     CM_InvoiceLineStatByNarManDict;
//	invLineStatDictCol:     CM_InvoiceLineStatByNarManDict;
//	invLineStatXXXDict:  CM_InvLineStatByMnPrnOrNarDict;
	invLineStat:         CM_InvoiceLineStat;
	i:                   Integer;
	tiLines:             Integer;
	remarksLines:        Integer;
	lineHeight:          Integer;
	invStatTotal,
	requiredHeight:      Real;
	actualHeight:        Real;
	endHeight:           Real;
	doPrint:             Boolean;
	cmString:            CM_String;
	invoicePrintRemarks : Boolean;
	taxRate : Real; // CCMS 1172
	printSingleLineForDayType : Boolean;
	sortDict : ObjectArray; // TESTING - CM_InvoiceLineStatByNarDict;
	obj : Object;
	dpl : Integer;
begin

	// TFS 36954 MPD 20 Feb 2018
	dpl := self.getRateEntryDecimalPlaces;

	// ### CCMS 1253
	printSingleLineForDayType := self.myCurrentInvoice.invoiceType.printSingleLineForDayType;


	 // CCMS 1172
	if self.myCurrentInvoice.isZeroRatedTax then
		taxRate := 0;
	else
//		taxRate := self.myCurrentInvoice.bank.parentCompany.taxPercentageRate;
		taxRate :=  self.myCurrentInvoice.getTaxRateForInvoice();// PAR 25720
	endif;

	app.mousePointer := MP_HOURGLASS;

	// CCMS 1074 AKB2002NOV 
	invoicePrintRemarks := self.myTerminal.getConfig(InvoicePrintRemarks).Boolean;

	create tmpJadeReport transient;
	tmpJadeReport.description := "Invoice " &amp; self.myCurrentInvoice.sequenceNum.String;
	app.printer.setReport(tmpJadeReport);

	app.printer.suppressDialog := true;

	create il;
	create pd;
	pd.show;
	pd.raiseExceptionOnAbort := false;
	pd.setAction("Printing Invoice " &amp; self.myCurrentInvoice.sequenceNum.String);
	app.printer.setMargins(Print_Landscape,0,4,0,0);

	pd.progress.partsInJob := self.myCurrentInvoice.invoiceLines.size;

	// setup header information
	foreach s in self.myCurrentInvoice.debtor.billingAddress do
		str := str &amp; s &amp; Lf;
	endforeach;
	// remove trailing linefeed
	il.lblDebtorDetails.caption := str[1 : str.length - 1];

	if self.myCurrentInvoice.postedDT.isValid then
		//il.lblDate.caption := postedDT.date.userFormat($CM_ShortDate);
		il.lblDate.caption := self.myCurrentInvoice.toDT.date.shortFormatJMT();
	elseif self.myCurrentInvoice.isVoided then
		il.lblDate.caption := "*** VOID ***";
	else
		il.lblDate.caption := "Not posted";
	endif;
	
	//NFS GD Xpose 1128
	if self.myCurrentInvoice.termsOfTrade &lt;&gt; null then
		il.lblDuePrompt.caption := self.myCurrentInvoice.termsOfTrade;	
	endif;
		
	il.lblAccount.caption := self.myCurrentInvoice.debtor.decfinName;
	il.lblInvoiceNumber.caption := self.myCurrentInvoice.sequenceNum.String;
	il.lblJob.caption := self.myCurrentInvoice.purchaseOrderNumber; //PAR 16787 CCMS 1103
	// set header
	app.printer.setHeader(il.frHeader);

	// The first line on the first page is the narration for the invoice
	il.lblServiceDate.caption := "";
	il.lblRef.caption := "";
	il.lblDescription.caption := self.myCurrentInvoice.narration;
	il.lblDescription.width := Invoice_Description_Width;
	il.frInvoiceLine.height := il.lblDescription.height + Invoice_Line_Spacing;
	il.lblQuantity.caption := "";
	il.lblRate.caption := "";
	il.lblUnit.caption := "";
	il.lblAmount.caption := "";
	app.printer.print(il.frInvoiceLine);

	// PAR 33175 create invLineStatDict transient;
	// PAR 33175 invStatTotal := self.myCurrentInvoice.getInvoiceStats(invLineStatDict, pd, false, true);
	if pd.aborted then
		pd.unloadForm;

		app.printer.abort;
		return;
	endif;
	
	/* WAS PAR 33175
	// CCMS 1125 from here
	if _consolidate then
		invLineStatDictCol := self.myCurrentInvoice.getInvoiceStatsConsolidate(invLineStatDict);
		if _oneLine then
			tmpInvLineStat := self.myCurrentInvoice.getInvoiceStatsConsolidate2One(invLineStatDictCol);
			invLineStatDictCol.purge;
			tmpInvLineStat.copy(invLineStatDictCol);
		endif;
		create invLineStatXXXDict transient;
		invLineStatDictCol.copy(invLineStatXXXDict);
	else
		create invLineStatXXXDict transient;
		invLineStatDict.copy(invLineStatXXXDict);
	endif;
	// CCMS 1125 to here
	NOW */
	
	// SEE UT_Invoicing::tConsolidatedInvoiceQtyRate to test consolidation to one line
	create sortDict transient; // PAR 33175
	invStatTotal := self.myCurrentInvoice.getInvoiceConsolidation(sortDict,_consolidate,_oneLine);
	
	
	il.lblDescription.caption := "fg";
	lineHeight := il.lblDescription.height.Integer;
	il.lblDescription.caption := "";

	// print the lines
	// PAR 33175 foreach invLineStat in invLineStatXXXDict do
	foreach obj in sortDict do	// PAR 33175 
		
		invLineStat := obj.CM_InvoiceLineStat; // PAR 33175  

		il.lblServiceDate.caption := "";
		il.lblRef.caption := "";
//		il.lblQuantity.caption := invLineStat.quantity.userNumberFormat($CM_RateEntry); // AKB PAR 2627 27Mar2001 WAS
		il.lblQuantity.caption := invLineStat.quantity.asStringJMTWithPrecision($CM_InvoiceQuantity.decimalPlaces, true); // AKB PAR 2627 27Mar2001 NOW

		//il.lblRate.caption := invLineStat.rate.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true);
		il.lblRate.caption := invLineStat.rate.asStringJMTWithPrecision(dpl, true); // TFS 36954 MPD 20 Feb 2018
		il.lblUnit.caption := invLineStat.unitNarration;
		//il.lblAmount.caption := (invLineStat.quantity * invLineStat.rate).Decimal.userNumberFormat($CM_ChargeQuantity);
		il.lblAmount.caption := invLineStat.total.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true); //GD May2001 xp1012

		il.frRemarks.height := 0;
		il.frTrackedItems.height := 0;

		// ################## 
		// CCMS 1074
		if invoicePrintRemarks and invLineStat.remarks.trimBlanks &lt;&gt; null then // PAR 4460 JC 2003 FEB 
			il.lblDescription.caption := invLineStat.remarks;
		else
			il.lblDescription.caption := invLineStat.narration;
		endif;
		// PAR 17363
		il.lblDescription.height := il.lblDescription.getTextHeightForWidth(invLineStat.narration,il.lblDescription.clientWidth());
		il.frInvoiceLine.height := il.lblDescription.height + 6;

		// CCMS 1253. If we are printing 1 line per ti, do not list that TI ID
		if printSingleLineForDayType then
			if invLineStat.quantity = invLineStat.allTrackedItems.size then
				tiLines := 0;
			endif;
		else
			tiLines := (invLineStat.allTrackedItems.size + 3) div 4;
		endif;
		remarksLines := invLineStat.narrationComments.size;

//		il.lblDescription.caption := invLineStat.narration; PAR7466 removed
		il.lblDescription.width := Invoice_Description_Width;

		if remarksLines = 0 and tiLines = 0 then
			requiredHeight := il.lblDescription.height + Invoice_Line_Spacing;
			endHeight := Invoice_Line_Spacing;
			actualHeight := -1;
		else
			// ensure that the description is not orphaned from its remarks or ti lines.
			if remarksLines = 0 then
				// next line will be a ti Line
				requiredHeight := il.lblDescription.height +
								  Invoice_Line_To_TI_IDs_Spacing +
								  lineHeight;
				endHeight := 0;
				actualHeight := il.lblDescription.height +
								Invoice_Line_To_TI_IDs_Spacing;
			else
				requiredHeight := il.lblDescription.height +
								  lineHeight;
				endHeight := 0;
				actualHeight := il.lblDescription.height;
			endif;
		endif;

		if il.setFrameHeight(il.frInvoiceLine, requiredHeight, endHeight, actualHeight) then
			// newpage is needed
			app.printer.newPage;
		endif;

		app.printer.print(il.frInvoiceLine);

		if remarksLines &gt; 0 then
			i := 0;
			foreach s in invLineStat.narrationComments do
				i := i + 1;
				il.lblRemarks.caption := s;
				il.lblRemarks.width := Invoice_Description_Width - Invoice_Remarks_Indent;
				requiredHeight := il.lblRemarks.height;
				actualHeight := -1;
				if i = remarksLines then
					if tiLines &gt; 0 then
						endHeight := Invoice_Line_To_TI_IDs_Spacing;
					else
						endHeight := Invoice_Line_Spacing;
					endif;
				else
					endHeight := 0;
				endif;
				requiredHeight := requiredHeight + endHeight;
				if il.setFrameHeight(il.frRemarks, requiredHeight, endHeight, actualHeight) then
					// newpage is needed
					app.printer.newPage;
				endif;
				app.printer.print(il.frRemarks);
			endforeach;
		endif;

		strDescriptionTIs := "";
		if tiLines &gt; 0 then
			i := 0;
			foreach cmString in invLineStat.allTrackedItems do
				s := cmString.string;
				i := i + 1;
				doPrint := false;
				if i mod 4 = 1 then
					strDescriptionTIs := "  " &amp; s;
				else
					strDescriptionTIs := strDescriptionTIs &amp; ", " &amp; s;
				endif;

				if i = invLineStat.allTrackedItems.size then
					strDescriptionTIs := strDescriptionTIs &amp; ".";
					endHeight := Invoice_Line_Spacing;
					doPrint := true;
				elseif i mod 4 = 0 then
					strDescriptionTIs := strDescriptionTIs &amp; ",";
					endHeight := 0;
					doPrint := true;
				endif;

				if doPrint then
					il.lblTrackedItems.caption := strDescriptionTIs;
					il.lblTrackedItems.width := Invoice_Description_Width - Invoice_TI_IDs_Indent;
					strDescriptionTIs := "  ";

					requiredHeight := il.lblTrackedItems.height + endHeight;
					actualHeight := -1;
					if il.setFrameHeight(il.frTrackedItems, requiredHeight, endHeight, actualHeight) then
						// newpage is needed
						app.printer.newPage;
					endif;
					app.printer.print(il.frTrackedItems);

				endif;
			endforeach;
		endif;

	endforeach;

	//amt := getTotalAmount(pd);
	//the amount printed on the invoice is the one and only true total!
	amt := invStatTotal;

	if pd.aborted then
		app.printer.abort;
		return;
	endif;

	il.lblAmountSubTotal.caption := amt.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);

	if self.myCurrentInvoice.bank.parentCompany.addInvoiceTax then
		taxAmt := amt * (taxRate)/100.0;
		il.lblAmountTax.caption := taxAmt.asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
		il.lblAmountTotal.caption := (amt + taxAmt).asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
	else
		il.lblAmountTax.caption := "";
		il.lblAmountTotal.caption := (amt).asStringJMTWithPrecision($CM_ChargeQuantity.decimalPlaces, true);
	endif;

	app.printer.print(il.frTotalLines);

epilog

	sortDict.purge();
	delete sortDict;
	app.printPreview(tmpJadeReport, true);
	app.printer.close;
	delete pd;
	delete il;
//	delete invLineStatXXXDict;
//	delete invLineStatDictCol; // CCMS 1125
//	if invLineStatDict &lt;&gt; null then
//		invLineStatDict.purge;
//		delete invLineStatDict;
//	endif;
	app.mousePointer := MP_DEFAULT;
end;</source>
        <Parameter name="preview" type="Boolean"/>
        <Parameter name="_consolidate" type="Boolean"/>
        <Parameter name="_oneLine" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQuery" id="138e3653-a249-420d-ab25-04810e5a10bf">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
26 May 2008	cnwkpd1	PAR #16810 - Increase Jade table row limit in 6.2
30 Jun 2008	cnwkpd1	PAR #17361 - Error 1 exceptions were occurring because the Progress 
					dialog was not being deleted due to exceptions occurring in the epilog.
					Moved problem "finish" code into main method body.
27 November 2012	cnwer1	 PAR 30470	- general changes so it works when all business units selected				
04 Ap 2016	cnwdap1	PAR #35843 Make progress bar updates time based rather than object count based
02 Feb 2025	navrv30 JIRA 33828 MTN - When using multi-threading form showing two progress bars
28/7/2025 navsaa30 MTN-35313 | Pagination - Invoice List
*/

vars
	invName			: String;
	theTable 		: CM_DataTable;
	collInvoices	: CM_InvoiceBySeqNumDict;
//	param			: CMIF_InvoiceSelection;
	idx				: Integer;
	anInvoice		: CM_Invoice;
	bank			: CM_Bank;
//	theDebtor		: CM_Debtor;
	pd				: CMS_Progress;
//	dtFrom, dtTo : Date;
	lastUpdate		: Decimal [20];			// PAR #35843
	form : CM_BaseForm;
	prof : JadeProfiler;
	startTM			: Decimal[19,0];
	
begin

	on CM_ProgressException do haltProgress(exception);
	
	self.mousePointer := Window.MousePointer_HourGlass;
	// 05/09/2014 cnwar2 #34862 - only clear filter on initial load, not for every query
	//self.clearTableFilter();	// 30931

	//02 Feb 2025	navrv30 JIRA 33828 MTN - When using multi-threading form showing two progress bars
	//We do not need to create a progress bar here as we are doing it in the getDataAndDisplayRowsForColl
	/*create pd;
	pd.setBackground(self.backColor);
	pd.show;
	pd.setAction(app.getErrorString1(Loading_invoices,null));*/
	
	self.tblInfo.rows := 0;
	self.myCurrentInvoice := null;
	theTable := self.tblData;
	self.doQueryRemoveItem();
	if not app.myRoot.isPaginated then
		theTable.rows := theTable.fixedRows;   //navsaa30 #35313
	endif;
	self.tblData.clearAllSelected ();//added by cnwyl1 for PAR 12081

	create collInvoices transient;


//	dtFrom := self.mskDateFrom.getDate();
//	dtTo := self.mskDateTo.getDate(); // PAR 29579
	bank := self.cmbBank.listObject.CM_Bank;
//	theDebtor:=self.cmbDebtor.listObject.CM_Debtor;
	
//	create param transient;
//	param.status := self.cmbInvoiceStatus.itemData[cmbInvoiceStatus.listIndex];
//	param.myBank:=bank;
//	if self.cmbInvoiceType.listObject &lt;&gt; null then
//		param.invoiceTypeNumber := self.cmbInvoiceType.listObject.CM_InvoiceDesc.number;
//	endif;
//	if self.mode &lt;&gt;  INV_ListInvoices.Mode_MultiTerminal then
//		param.myTerminal:=self.myTerminal;
//	endif;
//	param.debtor := theDebtor;
	
	//19 May 2014	NDL	Par 34142

	if self.myCurrentWorkOrder &lt;&gt; null then // TFS 39349
		self.myCurrentWorkOrder.allInvoices.copy(collInvoices); // TFS 39349
	else
		invName := self.doQueryInvoicesUsingSelector( collInvoices );
	endif;
	
	//navra1 - TFS 63751/Task 63752 - 13th May 2024	- start
	if collInvoices &lt;&gt; null then
		/*form := self;				//navsaa30 #35313
		app.myRoot.startJadeProfiler(prof,method.getNiceName() ,40,true,'Anusha',startTM);*/
		self.tblData.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, collInvoices, true);   //navsaa30  28/7/2025 #35313
		//app.myRoot.stopJadeProfiler(prof,startTM);
	endif;	
	
	/*
	if collInvoices &lt;&gt; null then
		if not self.doMaxTableSizeCheck(collInvoices.size, null) then
			return;
		endif;
		
		pd.progress.partsInJob := collInvoices.size;
		
		foreach anInvoice in collInvoices reversed do // PAR 10616 added 'reversed', in case of table row limit, so see most recent
			idx := idx + 1;
			if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
				pd.setAction(app.getErrorString1(Loading_invoices,invName));
				pd.progress.partsDone := idx;
				lastUpdate := app.relativeMachineTime;													// PAR #35843
			endif;																						// PAR #35843
			
			if bank &lt;&gt; null and bank &lt;&gt; anInvoice.bank then // PAR 16382
				continue;
			endif;
			
			self.doQueryAddItem(anInvoice);
			
			if self.tblData.rows = JadeTableRowLimit then
				break;
			endif;
		endforeach;
	endif;
	*/
	//navra1 - TFS 63751/Task 63752 - 13th May 2024	- end
	
	self.setFiltersValue ();		// 32394 this line lost in 8.2.1 rewrite - needed to set up data for user notify code

	// PAR #17361 - moved from epilog
	if self.tblData.rows &gt; self.tblData.fixedRows then
		self.tblData.selectRow(2,false);
		self.tblData.row := 2;
		self.doTblDataRowColChange(self.tblData);
	endif;
	// cnwjre1 Mar 2013 restore hiding the query frame lost by not doing inheritMethod
	self.frmQuery.visible := (self.tblData.rows &lt;= self.tblData.fixedRows);
	if not self.frmQuery.visible then
		self.searcherShowHideControls (true);
	endif;
	
	self.applyColumnFilter( self.tblData );		// 05/09/2014 cnwar2 #34862 - reapply any column filters
epilog
	self.setMyCaption();
	// TFS 2059 07/2016 set status line selected count after query
	self.showSelectedCount(self.tblData.allSelectedObjects.size, self.tblData.rows-self.tblData.fixedRows);
//	delete param;
	//delete pd;
	delete collInvoices;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryAddItem" id="d0dbd901-e656-4cf5-baf4-b98e4dc8d749">
        <updating/>
        <source>doQueryAddItem(_theInvoice : CM_Invoice) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 30/11/2022  navmv20 		Task 55549: UI - Add colour to Invoice List combo box and status column
// 31/07/2025  navsaa30 	MTN-35313 MTN | Pagination - Invoice List
// 21/11/2025  navbk1       MTN-36681 MTN | In the Invoice List Form, the Macro table is not refreshing or updating correctly
vars
	theDataLine : String;
	idx,rowId,
	colNumber,
	col : Integer; //30/11/2022 navmv20 TFS 55549
	invStatus	: CM_InvoiceStatus; //30/11/2022 navmv20 TFS 55549
begin
		
	if not global.isValidObject(_theInvoice) then
		return;
	endif;
	if not app.myRoot.isPaginated then
		theDataLine := _theInvoice.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
		//idx := self.tblData.addItem(theDataLine);	 //navsaa30 #35313							//21.11.2025 navbk1 #36681
		idx := self.tblData.addItemObject(_theInvoice, theDataLine); 							//21.11.2025 navbk1 #36681
	else
		idx := self.tblData.addItemObject(_theInvoice,theDataLine); //navsaa30 #35313
		self.tblData.findObjectInRow(_theInvoice,idx);
	endif;
	
	if _theInvoice.isZeroRatedTax then
		self.tblData.accessedRow.backColor := CM_Invoice.ZeroTaxColour;
	else
		self.tblData.accessedRow.backColor := White;
	endif;	
	if _theInvoice.isVoided then
		colNumber := self.tblData.getColumnByRowName(ETRow_Status);
		if colNumber &gt; 0 and colNumber &lt;= self.tblData.columns then
			self.tblData.accessCell(idx,colNumber).backColor := Gray;
		endif;
	endif;
	// setup note for this item
	self.doNotableAdd(_theInvoice);
	
	self.doFilterVisibilityForNote( self.tblData, idx );	// 30931
	
	/* // ### TFS 59699 07AUG2023 NAVAB1
	//30/11/2022 navmv20 TFS 55549 - start
	col := self.tblData.CM_DataTable.getColumnByRowName(ETRow_Status);
	invStatus := _theInvoice.getInvoiceStatusObject(_theInvoice.status);
	self.tblData.accessCell(idx,col).backColor :=invStatus.getStatusColour();
	self.tblData.accessCell(idx,col).foreColor :=self.tblData.accessCell(idx,col).backColor.getInverseColour();
	//30/11/2022 navmv20 TFS 55549 - end
	*/
	if not app.myRoot.isPaginated then 
		self.setStatusColour(_theInvoice,idx); // ### TFS 59699 07AUG2023 NAVAB1  //navsaa30 #35313
	endif;
end;</source>
        <Parameter name="_theInvoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="doQueryInvoicesUsingSelector" id="93c5f63e-7606-4a36-96e4-62e438960d0d">
        <source>doQueryInvoicesUsingSelector( _collInvoices	: CM_InvoiceBySeqNumDict input ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2014	cnwndl1	Initial creation	Par 34142
23 Sep 2015	cnwdap1	PAR #36909 CCMS ADP 2537 Query By BOL - use right voyage combo, set up query parameters properly
			(voyage is only used to filter the BOL combo, not for enquiries)
14 Nov 2018	jlgrh7  TFS #41490 STWO - Invoice Start date range not fully applied in invoice list screen
03 Jun 2020 cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
24 Feb 2023	navmv20 TFS 56403 Task 56404: UI - Invoice List add Category
24 Feb 2023	navmv20 TFS 56403 Task 56460: Jade - Selector Category collection
29 Mar 2023	navmv20 Bug 57023: EUP - inconsistent search behaviour with external number
*/

vars
	qDef 			: CM_QueryDefinition;
	criteriaHolder  : CM_QueryCriteriaLineHolder;
	myEnqController : CM_EnqControllerInvoice;
	dtFrom 		    : Date;
	dtTo 			: Date;
	dateArray 		: DateArray;
	company,
	bank		 	: CM_Bank;
	dr 				: CM_Debtor;
	status 			: Integer;
	invType 		: CM_InvoiceDesc;
	voyage 			: CM_Voyage;
	ti 				: CM_TrackedItem;
	invName			: String;
	invCategory		: String; //24/02/2023	navmv20 TFS 56403 Task 56404
	site 			: Integer;
	cargoType       : Integer;
	aLine           : CM_InvoiceLine;
	pdtFrom 		: Date;	//11 Aug 2021	NDL	TFS 51702
	pdtTo 			: Date;	//11 Aug 2021	NDL	TFS 51702
	pdateArray 		: DateArray;	//11 Aug 2021	NDL	TFS 51702
	invCategoryInt  : Integer; //24/02/2023	navmv20 TFS 56403 Task 56404
	searchFor,      			//29/03/2023 navmv20 Bug 57023
	invByInvoiceNum, 			//29/03/2023 navmv20 Bug 57023
	invLineByNumber, 			//29/03/2023 navmv20 Bug 57023
	invByInvExtInvNum,			//29/03/2023 navmv20 Bug 57023
	invByInvExtNum	  : String; //29/03/2023 navmv20 Bug 57023

begin

	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.Invoicing_Query_Type,CM_QueryDefinition.Invoice_Query_Mode];
	
	//create the selector query object.
	create myEnqController;
	create myEnqController.allObjects as  CM_InvoiceBySeqNumDict transient;
	create criteriaHolder transient;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	
	
	//create the individual criteria query lines
	if self.mode &lt;&gt; INV_ListInvoices.Mode_MultiTerminal then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::myTerminal.name, CM_QReferenceLookup.Operator_Equal, self.myTerminal);
	endif;
	
	//epr par 34860 4/9/14 always add the bank its visible with all options
	bank := self.cmbBank.listObject.CM_Bank;
	if bank &lt;&gt; null then
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::bank.name, CM_QReferenceLookup.Operator_Equal, bank);
	endif;
	
	if self.btnQueryVoyage.value then
		self.textSearch.text := null; //03/04/2023 navmv20 Bug 57023
		voyage := self.cmbVoyage.listObject.CM_Voyage;
		if voyage = null then
			return null;
		endif;
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::voyageCode.name, CM_QStringLookup.Operator_Equal, voyage);
		invName := voyage.code;
		
	elseif self.btnQueryDebtor.value then
		self.textSearch.text := null; //03/04/2023 navmv20 Bug 57023
		dtFrom := self.mskDateFrom.getDate();
		dtTo := self.mskDateTo.getDate();
		
		if dtFrom.isValid and dtTo.isValid then
			//create dateArray transient; dateArray.add(dtFrom.cnEcAddDays( - 1)); dateArray.add(dtTo.cnEcAddDays(1));							//-TFS41490
			create dateArray transient; dateArray.add(dtFrom); dateArray.add(dtTo);																										//+TFS41490
			self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::fromDT.name, CM_QDateRange.Operator_Between, dateArray);
		elseif dtFrom.isValid then
			self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::fromDT.name, CM_QDateGreaterThan.Operator_GreaterThan, dtFrom.cnEcAddDays( - 1));
		elseif dtTo.isValid then
			self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::fromDT.name, CM_QDateLessThan.Operator_LessThan, dtTo.cnEcAddDays(1));
		endif;
		
		pdtFrom := self.mskPDateFrom.getDate();	//11 Aug 2021	NDL	TFS 51702
		pdtTo := self.mskPDateTo.getDate();	//11 Aug 2021	NDL	TFS 51702
		//11 Aug 2021	NDL	TFS 51702	
		if pdtFrom.isValid and pdtTo.isValid then
			create pdateArray transient; pdateArray.add(pdtFrom); pdateArray.add(pdtTo);																										//+TFS41490
			self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::postedDT.name, CM_QDateRange.Operator_Between, pdateArray);
		elseif pdtFrom.isValid then
			self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::postedDT.name, CM_QDateGreaterThan.Operator_GreaterThan, pdtFrom.cnEcAddDays( - 1));
		elseif pdtTo.isValid then
			self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::postedDT.name, CM_QDateLessThan.Operator_LessThan, pdtTo.cnEcAddDays(1));
		endif;
		
		dr := self.cmbDebtor.listObject.CM_Debtor;
		if dr &lt;&gt; null then
			self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getDebtor.name, CM_QReferenceLookup.Operator_Equal, dr);
		endif;
		
		if cmbInvoiceStatus.listIndex &gt; 0 then
			status := self.cmbInvoiceStatus.itemData[cmbInvoiceStatus.listIndex];
			if status &gt;= 0 then
				self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getInvStatus.name, CM_QIntegerLookupEqual.Operator_Equal, status);
			endif;
		endif;
		
		if cmbInvoiceType.listIndex &gt; 0 then
			invType := self.cmbInvoiceType.listObject.CM_InvoiceDesc;
			if invType &lt;&gt; null then
				self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getInvoiceType.name, CM_QReferenceLookup.Operator_Equal, invType);
			endif;
		endif;
		
		//24/02/2023 navmv20 TFS 56403 Task 56404 - start
		if self.cmbInvCategory.listIndex &gt; 0 then
			invCategoryInt := self.cmbInvCategory.itemData[self.cmbInvCategory.listIndex];
			if invCategoryInt &gt;= 0 then
				self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getCategoryInt.name,  CM_QIntegerLookupEqual.Operator_Equal, invCategoryInt);
			endif;
		endif;
		//24/02/2023 navmv20 TFS 56403 Task 56404 - end
		
	elseif self.btnQueryCargo_.value then
		self.textSearch.text := null; //03/04/2023 navmv20 Bug 57023
		if cmbCargoSite_.listIndex &gt; 0 then
			site := self.cmbCargoSite_.itemData[cmbCargoSite_.listIndex];
			if site &gt;= 0 then
				self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getCargoSite.name, CM_QIntegerLookupEqual.Operator_Equal, site);
			endif;
		endif;
		
		if cmbCargoType_.listIndex &gt; 0 then
			cargoType := self.cmbCargoType_.itemData[cmbCargoType_.listIndex];
			if cargoType &gt;= 0 then
				self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getCargoSite.name, CM_QIntegerLookupEqual.Operator_Equal, cargoType);
			endif;
		endif;
		
		voyage := self.cmbVoyage.listObject.CM_Voyage;
		if voyage = null then
			self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::voyageCode.name, CM_QStringLookup.Operator_Equal, voyage);
		endif;
		
		ti := self.cmbCargoID_.listObject.CM_TrackedItem;
		if ti = null then
			return null;
		endif;
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getCargoId.name, CM_QStringEquals.Operator_Equal, ti.id);
		
	elseif self.btnQueryInvoice.value then
		//29/03/2023 navmv20 Bug 57023 - START
		if self.cmbSearchFor.listIndex &gt; 0 then
			searchFor := self.cmbSearchFor.itemText[self.cmbSearchFor.listIndex];
		endif;
		
		invByInvoiceNum   := app.getErrorString(Invoice_invoice_number);
		invLineByNumber   := app.getErrorString(Invoice_line_number);
		invByInvExtInvNum := app.getErrorString(Inv_ext_inv_number);
		invByInvExtNum    := app.getErrorString(Inv_external_number);
		//29/03/2023 navmv20 Bug 57023 - END
		
		//if self.textSearch.text = null or ( not self.optExternal.value and not self.textSearch.text.isInteger) then //24/02/2023	navmv20 TFS 56403 Task 56460
		//if (self.textSearch.text = null and self.txtExternalNumber.text = null) or ( self.textSearch.text &lt;&gt; null
		//and not self.optExternal.value and not self.textSearch.text.isInteger) then //24/02/2023	navmv20 TFS 56403 Task 56460 //29/03/2023 navmv20 Bug 57023
		if self.textSearch.text = null or ( not (searchFor = invByInvExtInvNum or searchFor = invByInvExtNum)) and not self.textSearch.text.isInteger then  //29/03/2023 navmv20 Bug 57023
			return null;
		endif;
		//epr par 34860 4/9/14 can search for inv lines do this and return
		
		//if self.optSearchLine.value then //29/03/2023 navmv20 Bug 57023
		if searchFor = invLineByNumber then   //29/03/2023 navmv20 Bug 57023
			if bank = null then
				foreach company in self.myTerminal.companies where company.isBusinessUnit do
					aLine := company.invoiceLines[self.myTerminal,company,self.textSearch.text.Integer];
					if aLine &lt;&gt; null then
						break;
					endif;
				endforeach;
			else
				aLine := bank.invoiceLines[self.myTerminal,bank,self.textSearch.text.Integer];
			endif;
			
			if aLine &lt;&gt; null then
				//self.showInvoiceLinesForm(aLine); //13/04/2023 navmv20 Bug 57023
				self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::sequenceNum.name, CM_QIntegerEquals.Operator_Equal,  aLine.invoice.sequenceNum ); //13/04/2023 navmv20 Bug 57023
				//return aLine.sequenceNum.String; //13/04/2023 navmv20 Bug 57023
			else	//13/04/2023 navmv20 Bug 57023
				return null;	//13/04/2023 navmv20 Bug 57023
			endif;
			
			//return null; //13/04/2023 navmv20 Bug 57023
		//elseif self.optSearchInvoice.value then //29/03/2023 navmv20 Bug 57023
		elseif searchFor = invByInvoiceNum then   //29/03/2023 navmv20 Bug 57023
			if self.textSearch.text &lt;&gt; null then //24/02/2023 navmv20 TFS 56403 Task 56404
				self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::sequenceNum.name, CM_QIntegerEquals.Operator_Equal,  self.textSearch.text.Integer );
				invName := self.textSearch.text;
			endif; //24/02/2023	navmv20 TFS 56403 Task 56404
			
		//29/03/2023 navmv20 Bug 57023 - START
		elseif searchFor = invByInvExtNum then 
			//24/02/2023 navmv20 TFS 56403 Task 56460 - start
	       // if self.txtExternalNumber.text &lt;&gt; null then
		    if self.textSearch &lt;&gt; null then
				//self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::externalNumber.name, CM_QStringContains.Operator_Contains, self.txtExternalNumber.text);
				self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::externalNumber.name, CM_QStringContains.Operator_Contains, self.textSearch.text);
			endif;
			//24/02/2023 navmv20 TFS 56403 Task 56460 - end
			
		//elseif self.optExternal.value then	//14 Apr 2016	NDL	TFS 1849
		elseif searchFor = invByInvExtInvNum then
			//self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getExternalInvoiceNumber.name, CM_QStringContains.Operator_Contains,  self.textSearch.text );
			self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getExtInvNumberUpper.name, CM_QStringContains.Operator_Contains,  self.textSearch.text );
		//29/03/2023 navmv20 Bug 57023 - END
			invName := self.textSearch.text;
		endif;
		
	elseif self.btnQueryBOL.value then
		self.textSearch.text := null; //03/04/2023 navmv20 Bug 57023
		if cmbCargoSite_.listIndex &gt; 0 then
			site := self.cmbCargoSite_.itemData[cmbCargoSite_.listIndex];
			if site &gt;= 0 then
				self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getCargoSite.name, CM_QIntegerLookupEqual.Operator_Equal, site);
			endif;
		endif;
		
		//voyage := self.cmbVoyage.listObject.CM_Voyage;				// PAR #36909
		//self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::voyageCode.name, CM_QStringLookup.Operator_Equal, voyage);	// PAR #36909
		
		if self.cmbBOL.text = null and
		   self.cmbCnee.listObject = null then
			return null;
		endif;
		
		if self.cmbBOL.listIndex &gt; 0 then
			self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getTrackedItemBOL.name, CM_QStringEquals.Operator_Equal, self.cmbBOL.text);
		endif;
		//if self.cmbCnee.listIndex &gt; 0 then							// PAR #36909
		if self.cmbCnee.listObject &lt;&gt; null then							// PAR #36909
			self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::getTrackedItemBOL.name, CM_QReferenceLookup.Operator_Equal, self.cmbCnee.listObject);
		endif;
	elseif self.btnQueryVoyageGrpCode.value then  //03/06/2020 cnwma1 TFS #49400
		self.textSearch.text := null; //03/04/2023 navmv20 Bug 57023
		if self.txtVoyageGrpCode.text = null then
			return null;
		endif;
		self.doCreateCriteriaLine(qDef, criteriaHolder, CM_Invoice::voyageGroupCode.name, CM_QIntegerEquals.Operator_StartsWith,  self.txtVoyageGrpCode.text );
	endif;
	
	myEnqController.myContext := self; //30 May  2025 navrv30 MTN 34789
	// call the query
	myEnqController.doQuery( qDef );
	
	//populate the collection
	myEnqController.allObjects.CM_InvoiceBySeqNumDict.copy( _collInvoices );
	
	return invName;

epilog

	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
	endif;
	delete myEnqController;

	delete dateArray;
	delete pdateArray; //11 Aug 2021	NDL	TFS 51702

end;</source>
        <Parameter name="_collInvoices" type="CM_InvoiceBySeqNumDict" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doQueryRemoveItem" id="696af38b-adff-4f22-8525-03ebdebb15ee">
        <source>doQueryRemoveItem();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
	rowSt,rowEnd,idx : Integer;
begin
	rowSt := self.tblData.fixedRows + 1;
	rowEnd := self.tblData.rows;
	
	foreach idx in rowSt to rowEnd do
		anObject := self.tblData.accessRow(idx).itemObject;
		self.doNotableRemove(anObject);
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="doRecalculate" id="83a6250b-9130-467e-bfe1-302e052c96be">
        <updating/>
        <source>doRecalculate() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 11APR2024
ADO -  CR 63369 TASK 63502
*/

vars
	theReturn,num, numLines : Integer;
	strTxt : String;
	controller : CMIF_InvoiceLineReeval;
	recalcStr : String;
begin
	num := self.tblData.allSelectedObjects.size;
	if num = 0 then 
		app.msgBox("Please select an invoice to recalculate.","Error",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	create controller transient;
	self.getInvoiceLines(controller.allInvoiceLines);
	
	numLines := controller.allInvoiceLines.size;
	recalcStr := "Recalculate invoice amount and tax details?";
	if numLines &gt; 500 then
		recalcStr := recalcStr &amp; CrLf &amp; "There are " &amp; numLines.String &amp; " invoice lines, the recalculation may take some time";
	endif;
	if app.msgBox(recalcStr,"Confirm Recalculation",MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
		controller.reCalculate := true;
		
	endif;
	
	if not controller.reCalculate then
		return;
	endif;
	while true do
		app.myTrxUA.trxUpdateInvoiceLineReeval(controller, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Invoice Recalculate", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;


	strTxt := controller.numCalced.String &amp; " invoice lines were recalculated.";
	
	app.msgBox(strTxt, app.getErrorString(Finished),MsgBox_OK_Only);
epilog
	delete controller;	 
end;</source>
    </JadeMethod>
    <JadeMethod name="doReevaluate" id="34754e18-5acd-4e88-bcbc-2592c001e857">
        <updating/>
        <source>doReevaluate() updating;
// ---------------------------------------------------------------------------
// Created:		20 January 2006  By Andrew Bishop cnwab1
//
// Purpose:		CCMS 1005
//
// ---------------------------------------------------------------------------
// ### TFS CR 63369 TASK 63502 11APR2024 NAVAB1
/*
Date			Who		Reason
18 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels
*/
vars
	theReturn,num : Integer;
	invs : CM_InvoiceBySeqNumDict;
	inv : CM_Invoice;
	txtInv, strTxt : String;
	numEval, numMoved : Integer;
	controller : CMIF_InvoiceLineReeval;
	invLine : CM_InvoiceLine;
	logger	: CMIF_Logger;

begin
	num := self.tblData.allSelectedObjects.size;
	create invs transient;
	if num = 0 then 
		app.msgBox("Please select an invoice to re-evaluate.","Error",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	self.tblData.allSelectedObjects.copy(invs);
	create controller transient;
	
	foreach inv in invs do
		if txtInv = null then
			txtInv := inv.sequenceNum.String;
		else
			txtInv := txtInv &amp; ", " &amp; inv.sequenceNum.String;
		endif;
		
		foreach invLine in inv.invoiceLines where invLine.status = CM_InvoiceLine.STATUS_NORMAL do
			controller.allInvoiceLines.add(invLine);
		endforeach;
	endforeach;
	
	if num = 1 then
		if app.msgBox("Re-evaluate invoice "  &amp; txtInv &amp; "?","Confirm Re-evaluation",MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	elseif num &lt; 10 then
		if app.msgBox("Re-evaluate invoices:" &amp; Cr &amp; Cr &amp; txtInv &amp; "?","Confirm Re-evaluation",MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	else
		if app.msgBox("Re-evaluate " &amp; num.String &amp; " invoices?","Confirm Re-evaluation",MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	endif;
	
	create logger transient;
	app.setLogger(logger);
	
	controller.reEvaluate := true; // ### TFS DEFECT 63720 24APR2024 NAVAB1
	
	while true do
		app.myTrxUA.trxUpdateInvoiceLineReeval(controller, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Invoice Re-evaluate", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

	numEval := controller.numEval;
	numMoved := controller.numMoved;
	
	app.invLog("** Summary **", LogINFO.String);
	if numEval = 1 then
		strTxt := "1 invoice line was re-evaluated.";
	else
		strTxt := numEval.String &amp; " invoice lines were re-evaluated.";
	endif;
	app.invLog(strTxt, LogINFO.String);
	if numMoved = 1 then
		strTxt := "1 was moved to a different invoice.";
	else
		strTxt := numMoved.String &amp; " were moved to a different invoice";
	endif;
	app.invLog(strTxt, LogINFO.String);
	
	self.doShowReevaluateLogging(logger);
epilog
	delete controller;	 
	delete invs;
	if logger &lt;&gt; null then
		app.setLogger(null);	// this deletes the 'logger' instance
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResetSearch" id="51714acf-fb71-44ee-b24f-1dc62b09965e">
        <source>doResetSearch() ;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//03 Jun 2020 cnwma1 ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
//29 Mar 2023 navmv20 Bug 57023: EUP - inconsistent search behaviour with external number
//11 Sep 2023 navhl20 ChangeRequest 59376: CPL - Invoice Generation Clocking (avg 25 secs)
// ---------------------------------------------------------------------------

vars

begin
	self.cmbDebtor.listIndex 	    := -1;
	self.cmbVoyage.listIndex 		:= -1;
	self.cmbInvoiceStatus.listIndex := 1;
	self.cmbInvoiceType.listIndex   := 1;
	//self.chkArchive.value 		:= false;		//11.9.2023 navhl20 #59376
	self.textSearch.text            := null;
	self.cmbSearchFor.listIndex     := 1; 	//29/03/2023 navmv20 Bug 57023
	self.textSearch.dataType := TextBox.DataType_Numeric; //29/03/2023 navmv20 Bug 57023
	self.textSearch.maxLength := 9;	//29/03/2023 navmv20 Bug 57023
	self.cmbCargoID_.listIndex 	    := -1;
	self.cmbCargoSite_.listIndex 	:= 1;
	self.cmbCargoType_.listObject 	:= app.myPassport.getDefaultCargoType();
	self.cmbCargoVoyage_.listIndex  := -1;
	// 30931
	self.cmbBOL.listIndex 			:= -1;
	self.cmbCnee.listIndex 			:= -1;
	self.txtVoyageGrpCode.text 		:= null;	//03/06/2020 cnwma1 Tfs #49400
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="5600f81b-d1fe-43d5-a78f-c002d92ca14d">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		03 Nov 2017 By jlgrh7
//
// Purpose: TFS7253 JMT- Table not resizing on Invoice List screen
// ---------------------------------------------------------------------------
vars
	anObj : Object;
begin
	inheritMethod();
	if self.isA(INV_ListLines) then // --&gt; TFS 39618 - only show Status combo on Invoice List form
		self.frmStatus.visible := false;
	endif; // &lt;-- TFS 39618
	
	self.doResizeColumnWidths(self.tblInfo, true);
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveChangeStatus" id="aee9ee5d-64eb-4d8c-8844-f7f72ca75301">
        <updating/>
        <source>doSaveChangeStatus(_status : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 04/04/2018	jlgdap1		TFS 37560 PEL1 Prepend Invoice Status
// 12/04/2018	jlgmd1		TFS 37904 DQM Prevent Posting/Exporting and export of 'Void' lines and 'No invoice line' Invoices
// 22/07/2019	cnwma1		ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
// 18/08/2022	navpw1		TFS: 54564 (54381) (54382) - EUP - Inv Config - Debtor Currencies and Countries
// 31/03/2023	jlier1 		TFS 56856 POB - Finance One
// 14/08/2023	navkc1		Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
// 06/12/2023	navra1		TFS 54090 CR - 61386/Task - 61564
//  25/9/24 	jlier1 TFS  65949 NSW | Dynamic Integration Development 
vars
	doExport,
	runPackage,
	showWarning			: Boolean;
	finIOClass			: CM_ExtFinanceIO;
	createdTransient	: Boolean;
	extraMessage		: String;
	theStatus			: CMIF_InvoiceStatus;
	pxyInvoice,
	realInvoice			: CM_Invoice;
	theReturn			: Integer;
	idx					: Integer;
	invoices			: CM_InvoiceBySeqNumDict;
	statuses			: CMIF_Array;
	oa					: ObjectArray;
	debtorInvType		: CM_DebtorInvType;
	package				: CM_PackageInvoice;
	task				: CM_AutoTask;
	schedule			: CM_AutoSchedule;
	multiNarration		: String;	
	invLine				: CM_InvoiceLine;
	isASPAInterface,
	isPelindo1Interface	: Boolean;
	isPOBFinanceOneInterface : Boolean;
	allFailedInvoices : CM_InvoiceBySeqNumDict;
	financeOneMessage : String;
begin
	realInvoice := self.myCurrentInvoice;
	create invoices transient;
	create statuses transient;
	create oa transient;
	
	finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if finIOClass = null 
		or not global.isValidObject(finIOClass) then
			create finIOClass as CM_DefaultFinanceIO transient;
			createdTransient := true;
	endif;

	if finIOClass.isKindOf( CM_ASPAInterface ) then
		isASPAInterface := true;
	elseif finIOClass.isKindOf( CM_Pelindo1Interface ) then
		isPelindo1Interface := true;
	elseif finIOClass.isKindOf(CM_POBFinanceOneInterface) then //jlier1 TFS 56856 31/3/23
		isPOBFinanceOneInterface:=true;
	endif;
	
	
	if _status = CM_Invoice.INVOICE_PENDING 
	or _status = CM_Invoice.INVOICE_SUSPENSE					//Par 17895. Sep 2008
	or _status = CM_Invoice.INVOICE_VOID 	  				    // CCMS 1514
	or _status = CM_Invoice.INVOICE_POSTED 	   					// par 23341 Mar 2010
	or _status = CM_Invoice.INVOICE_PREPEND						// TFS 37560
	or _status = CM_Invoice.INVOICE_DISPUTED 					// TFS 37560
	or _status = CM_Invoice.INVOICE_APPROVED 					// TFS 39618
	or _status = CM_Invoice.INVOICE_APPROVEDRETURNED 			// TFS 39618
	or _status = CM_Invoice.INVOICE_PENDING_APPROVAL 			// TFS 39618
	or _status = CM_Invoice.INVOICE_POSTED_DRAFT 			 // ### JIRA 35468 29JUL2025 NAVAB1
	or _status = CM_Invoice.INVOICE_POSTED_PENDING then 	   	//navra1 - TFS 54090 CR - 61386/Task - 61564 - 6th Dec 2023
		if self.tblData.allSelectedObjects.size = 0 then
			app.msgBox(app.getErrorString(INV_Please_Select_An_Invoice), app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;

		self.copyInvsExcludingReturned( self.tblData.allSelectedObjects, invoices);
	
	else
		if realInvoice = null then
			app.msgBox(app.getErrorString(INV_Please_Select_An_Invoice), app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		invoices.add(realInvoice);
	endif;
	
	// 32853  jan 2014 add a warning if posting to the default debtor
	foreach realInvoice in invoices do
		if realInvoice.debtor.isRDT() then
			extraMessage := "NOTE: Invoice is for default debtor.";
			break;
		endif;
	endforeach;

	idx := invoices.size;

	if idx &gt; 1 then
		realInvoice := self.tblData.allSelectedObjects.first.CM_Invoice;
		if app.msgBox("Do you want to change the status of all " &amp; idx.String &amp; " invoices to " &amp; realInvoice.getStatusDescription(_status) &amp; "?  " &amp; extraMessage,
							app.getErrorString1(INV_ChangeStatus, realInvoice.getStatusDescription(_status)),
							MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_No  then
			return;
		endif;
		// PAR 13831
		self.myCurrentInvoice := null; // CCMS 1514
	else // CCMS 1514
		if app.msgBox(app.getErrorString(WARN_CHANGE_STATE)&amp; " Do you want to continue?  " &amp; extraMessage, app.getErrorString1(INV_ChangeStatus,
								realInvoice.getStatusDescription(_status)),
								MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No  then
			return;
		endif;
	endif;
	
	multiNarration := self.txtNarr.text;	//02 Sep 2015	NDL	Par 36684

	//jlier1 TFS 56856 31/3/23
	create allFailedInvoices transient;
	if isPOBFinanceOneInterface and _status = CM_Invoice.INVOICE_POSTED then
		//Do the export before hand 
		//the export needs to be in sequence order - which invoices is already
		foreach realInvoice in invoices discreteLock do
			finIOClass.export(realInvoice);
			if realInvoice.externalIntefaceStatus &lt;&gt; CM_EWSActivityFinanceOne.Status_Success then
				//do not update the realInvoice to posted
				allFailedInvoices.add(realInvoice);
				invoices.remove(realInvoice);
			endif;
		endforeach;
		financeOneMessage:=app.getErrorString2(Success_failure_inv_fin_one,invoices.size.String,allFailedInvoices.size.String);
		
		if invoices.size = 0 then
			app.msgBox(app.getErrorString(No_success_fin_one),app.getErrorString(Finance_one),MsgBox_OK_Only);
			//update the status		
			return;
		endif;
	endif;
	
	foreach realInvoice in invoices do
		pxyInvoice := app.createUpdateProxy(realInvoice).CM_Invoice;
		oa.add(pxyInvoice);		// keep for deleting at end of method
	
		create theStatus transient;
		if realInvoice.myInvoiceProcess.isKindOf(CM_InvoiceProcessInvoiceAPI) then							//navra1 - CR 61910/Task 62303 - 16th Feb 2024
			theStatus.runPackages := self.tblInvProperties.getValueByName(ETRow_RunPackage).Boolean;		//navra1 - CR 61910/Task 62303 - 16th Feb 2024
		endif;																								//navra1 - CR 61910/Task 62303 - 16th Feb 2024
		
		 // ### JIRA 35468 28JUL2025 NAVAB1
		if _status = CM_Invoice.INVOICE_POSTED_DRAFT then
			theStatus.runPackages := true;
		endif;
		
		
		theStatus.myInvoice := pxyInvoice;
		theStatus.newStatus := _status;
		if _status = CM_Invoice.INVOICE_POSTED or _status = CM_Invoice.INVOICE_POSTED_PENDING then		//navra1 - TFS 54090 CR - 61386/Task - 61564 - 6th Dec 2023
			// TFS 37904 - Show a warning if trying to post an invoice that only contains voided lines
			showWarning := true;
			foreach invLine in realInvoice.invoiceLines where invLine.status &lt;&gt; CM_InvoiceLine.STATUS_VOIDED do
				showWarning := false;
				break;
			endforeach;
			if showWarning then
				if app.msgBox(app.getErrorString(WARN_POST_VOID_LINES)&amp; " Do you want to continue?", app.getErrorString1(INV_ChangeStatus,
								realInvoice.getStatusDescription(_status)),
								MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No  then
					return;
				endif;
			endif;
			
			theStatus.myTermsOfTrade 	  := self.cmbTermsTrade.listObject.CM_InvoiceTermsOfTrade;
			theStatus.purchaseOrderNumber := self.tblInvProperties.getValueByName(ETRow_PurchaseOrderNumber).String;
			theStatus.debtorReference 	  := self.tblInvProperties.getValueByName(ETRow_DebtorReference).String;
			theStatus.myLocale			  := realInvoice.myLocale; //14/08/2023	navkc1	Bug 59803
			theStatus.myAlternativeAddress:= realInvoice.myAlternativeAddress; //14/08/2023	navkc1	Bug 59803
			theStatus.myBillingAddress 	  := realInvoice.myBillingAddress; //14/08/2023	navkc1	Bug 59803
			
			if multiNarration = null then
				theStatus.narration := realInvoice.narration;
			else
				theStatus.narration := multiNarration;
			endif;
			
			theStatus.toDT.setDate(self.tblInvProperties.getValueAsDate(ETRow_EndDate));
			theStatus.toDT.setTime('23:59:59.999'.Time);
			
			theStatus.invoiceDate.setDate(self.tblInvProperties.getValueAsDate(ETRow_InvoiceDate));				//navra1 - TFS 54090 CR - 61386/Task - 61564 - 21st Dec 2023
			theStatus.invoiceDate.setTime('00:00:00.000'.Time);													//navra1 - TFS 54090 CR - 61386/Task - 61564 - 21st Dec 2023
			
			if isASPAInterface then
				theStatus.isZeroRatedTax      := true;
				theStatus.doExport            := true;
			else
				theStatus.isZeroRatedTax 	  := self.tblInvProperties.getValueByName(ETRow_IsZeroRated).Boolean;
				//jlier1	 TFS 53286 20/4/22
				if self.tblInvProperties.isRowVisible(ETRow_Export) then
					theStatus.doExport			  := self.tblInvProperties.getValueByName(ETRow_Export).Boolean;
				else
					theStatus.doExport:=false;	
				endif;
			endif;
			doExport 					 	  := theStatus.doExport;				// TFS 1930
		endif;
		
		if _status = CM_Invoice.INVOICE_VOID or realInvoice.status = CM_Invoice.INVOICE_VOID then
			//epr par 36958 28/9/15
			if self.myTerminal.allInvoiceStatusReasons.size &gt; 0 and self.tblInvProperties.isRowVisible(ETRow_VoidReason) then
				theStatus.voidReason:= self.tblInvProperties.getValueByName(ETRow_VoidReason).asStringJMT;
				theStatus.voidReasonCode:=self.tblInvProperties.getValueByName(ETRow_VoidReasonCode).asStringJMT;
				
				if theStatus.voidReason = null then
					app.msgBox(app.getErrorString( Input_required_field_reason),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
					return;
				endif;
				if theStatus.voidReasonCode = null then
					app.msgBox(app.getErrorString( Input_required_field_reasonCde),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
					return;
				endif;
			endif;
		endif;
		//jlier1 TFS  65949 NSW | Dynamic Integration Development 25/9/24
		if _status = CM_Invoice.INVOICE_POSTED_CREDIT_PENDING and realInvoice.status = CM_Invoice.INVOICE_POSTED_CREDIT_ERROR then
			doExport:=true;
		endif;
		if _status = CM_Invoice.INVOICE_PENDING //then		//22.07.2019 cnwma1 TFS #45577 includes LINX PENDING APPROVAL
		or _status = CM_Invoice.INVOICE_PENDING_APPROVAL  // ### JIRA 35468 28JUL2025 NAVAB1
		or _status = CM_Invoice.INVOICE_POSTED_DRAFT then  // ### JIRA 35468 28JUL2025 NAVAB1
			theStatus.myBillingAddress	:= self.cmbDebtorAddressProp.listObject.CM_Address;
			theStatus.myAlternativeAddress := self.cmbDebtorAltAddrProp.listObject.CM_Address; // ### TFS 54564 (54381) 19Aug2022 NAVPW1
			
			// ### JIRA 33518 28NOV2024 NAVAB1
			theStatus.purchaseOrderNumber := realInvoice.purchaseOrderNumber;
			if multiNarration = null then
				theStatus.narration := realInvoice.narration;
			else
				theStatus.narration := multiNarration;
			endif;
			
			// ### JIRA 33629 09DEC2024 NAVAB1
			theStatus.toDT := realInvoice.toDT;
			theStatus.myTermsOfTrade 	  := null;
			theStatus.debtorReference 	  := realInvoice.debtorReference;
			theStatus.myLocale			  := realInvoice.myLocale;
			theStatus.invoiceDate := realInvoice.invoiceDate;
			theStatus.isZeroRatedTax      := realInvoice.isZeroRatedTax;
			theStatus.myCurrencyType := realInvoice.myCurrencyType;
		endif;
		
		statuses.add(theStatus);
		
	endforeach;
	runPackage := self.tblInvProperties.getValueByName(ETRow_RunPackage).Boolean;
	
	//11 Jul 2019	NDL TFS 44965 - local warnings, only to be raised on this form when going to pre-pend for pelindo so not in the trx layer.
	if _status = CM_Invoice.INVOICE_PREPEND then	
		if isPelindo1Interface then
			app.myPassport.clearErrorsWarnings();
			on Exception do self.handleCargoWeighedWarning( exception );
		
			foreach realInvoice in invoices do
				realInvoice.getCargoWeighedWarning();
			endforeach;
			
			on Exception do null;
			if app.myPassport.hasErrors then
				// shouldn't happen, only raising warnings in 'getWeightsWarningForPelindo1'
				app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				return;
				
			elseif not app.myPassport.allErrorWarnings.isEmpty then
				if app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings) = IDOK then
					//all good, user doesn't care, so just carry on
					app.myPassport.clearErrorsWarnings();
					app.setContinueCMExceptions(false);
				else
					//Nah bail
					return;
				endif;
			endif;
		endif;
	endif;
		
		/* moved into the foreach so works for bulk update
	if _status = CM_Invoice.INVOICE_PENDING then		//22.07.2019 cnwma1 TFS #45577 includes LINX PENDING APPROVAL
		theStatus.myBillingAddress	:= self.cmbDebtorAddressProp.listObject.CM_Address;
		theStatus.myAlternativeAddress := self.cmbDebtorAltAddrProp.listObject.CM_Address; // ### TFS 54564 (54381) 19Aug2022 NAVPW1
		
		// ### JIRA 33518 28NOV2024 NAVAB1
		theStatus.purchaseOrderNumber := realInvoice.purchaseOrderNumber;
		if multiNarration = null then
			theStatus.narration := realInvoice.narration;
		else
			theStatus.narration := multiNarration;
		endif;
		
		// ### JIRA 33629 09DEC2024 NAVAB1
		theStatus.toDT := realInvoice.toDT;
		theStatus.myTermsOfTrade 	  := null;
		theStatus.debtorReference 	  := realInvoice.debtorReference;
		theStatus.myLocale			  := realInvoice.myLocale;
		theStatus.invoiceDate := realInvoice.invoiceDate;
		theStatus.isZeroRatedTax      := realInvoice.isZeroRatedTax;
		theStatus.myCurrencyType := realInvoice.myCurrencyType;
	endif;
	*/
	if _status = CM_Invoice.INVOICE_POSTED or _status = CM_Invoice.INVOICE_POSTED_PENDING then		//navra1 - TFS 54090 CR - 61386/Task - 61564 - 6th Dec 2023
		//Set the alternative address on the CMIF status object
		theStatus.myCurrencyType := self.cmbCurrencyType.listObject.CM_CurrencyType; // ### TFS 54564 (54382) 22Aug2022 NAVPW1
	endif;
	
	while true do
		app.myTrxUA.trxUpdateInvoiceStatuses(statuses, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.frmInvProperties.visible := false;
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
	// TFS 1930 May 2016 export moved after the transaction so doesn't get done twice from a deadlock
	if doExport then						//navra1 - TFS 54090 CR - 61386/Task - 61564 - 4th Dec 2023
		foreach realInvoice in invoices do
			if realInvoice.status = CM_Invoice.INVOICE_POSTED or realInvoice.status = CM_Invoice.INVOICE_POSTED_PENDING or realInvoice.status = CM_Invoice.INVOICE_POSTED_CREDIT_PENDING  then		//navra1 - TFS 54090 CR - 61386/Task - 61564 - 4th Dec 2023
				finIOClass.export(realInvoice);
			endif;
		endforeach;
	endif;

	// CPL CCMS 2120 Nov 2011 run any associated invoice report package (MSC xml extract and email)
	if (_status = CM_Invoice.INVOICE_POSTED or _status = CM_Invoice.INVOICE_POSTED_PENDING) and										//navra1 - TFS 54090 CR - 61386/Task - 61564 - 6th Dec 2023
	   runPackage then
		app.mousePointer := MousePointer_HourGlass;
		foreach realInvoice in invoices do
			debtorInvType := realInvoice.debtor.allDebtorInvTypes[realInvoice.invoiceType];
			if debtorInvType &lt;&gt; null then
				foreach package in debtorInvType.allPackageInvoices do
					foreach task in package.allTasks do
						schedule := task.allAutoSchedules.first;
						app.runEventScheduleInvoice(schedule, realInvoice, null);
					endforeach;
				endforeach;
			endif;
		endforeach;
	endif;

	if financeOneMessage &lt;&gt; null then
		app.msgBox(financeOneMessage,app.getErrorString(Finance_one),MsgBox_OK_Only);
	endif;
	
epilog
	self.setEnableObjects();
	delete invoices;
	if oa &lt;&gt; null then
		oa.purge;
		delete oa;
	endif;
	if statuses &lt;&gt; null then
		statuses.purge;
		delete statuses;
	endif;
	if createdTransient then
		delete finIOClass;
	endif;
	delete allFailedInvoices;
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
