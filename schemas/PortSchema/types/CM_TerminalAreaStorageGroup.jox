    <JadeMethod name="includesArea" id="ebff53d0-549d-4f72-808b-bf0f795135d1">
        <source>includesArea(_termArea : CM_TerminalArea) : Boolean;
// return true if this storage group includes the entered terminal area
vars
	result	: Boolean;
	ta		: CM_TerminalArea;
begin
	foreach ta in self.allTerminalAreas do
		if ta = _termArea then
			result := true;
			break;
		endif;
	endforeach;

	return result;
end;
</source>
        <Parameter name="_termArea" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="058e6f52-f4de-4fee-b82e-0f993d6653f3">
        <source>initialise();
/*
Purpose:			
Date		Who		Reason
25 May 2015	cnwab1	Initial creation
*/

vars
	fsm : CM_FutureStorageMapping;
begin
	if not self.allFutureStorageMappings.isEmpty then
		return;
	endif;

	create fsm;
	fsm.setMyStorageGroup(self);
	
	fsm.initialise();
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="3e135b40-6417-4e95-bf27-4ae034c2d71e">
        <source>pxyCreateUpdateProxy() : SelfType;
// 28 May 2013	cnwjre1	CCMS DPH 2278 Storage Billing by Teminal Area
vars
	proxyTerminalAreaStorageGroup	: CM_TerminalAreaStorageGroup;
begin
	proxyTerminalAreaStorageGroup := inheritMethod();
	proxyTerminalAreaStorageGroup.code := self.code;
	proxyTerminalAreaStorageGroup.description := self.description;

	return proxyTerminalAreaStorageGroup;
end;
</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="7d26dc6e-618d-4a12-b316-c60decc8bcd8">
        <updating/>
        <source>setForCreate(_proxyTerminalAreaStorageGroup : CM_TerminalAreaStorageGroup; _passport : CM_Passport input) updating;
// 28 May 2013	cnwjre1	CCMS DPH 2278 Storage Billing by Teminal Area
begin
	_proxyTerminalAreaStorageGroup.raiseExceptionIfNotTransient(method);

	self.setForUpdate(_proxyTerminalAreaStorageGroup);

	self.initialise(); // PAR 36275
end;</source>
        <Parameter name="_proxyTerminalAreaStorageGroup" type="CM_TerminalAreaStorageGroup"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="dcbaea4b-d3c4-4e8d-88a3-e7bdb4ef56d8">
        <updating/>
        <source>setForUpdate(_proxyTerminalAreaStorageGroup : CM_TerminalAreaStorageGroup) updating;
// 28 May 2013	cnwjre1	CCMS DPH 2278 Storage Billing by Teminal Area
begin
	self.code := _proxyTerminalAreaStorageGroup.code;
	self.description := _proxyTerminalAreaStorageGroup.description;
	self.allTerminalAreas.clear();
	_proxyTerminalAreaStorageGroup.allTerminalAreas.copy(self.allTerminalAreas);
	self.myTerminal := _proxyTerminalAreaStorageGroup.myTerminal;
end;</source>
        <Parameter name="_proxyTerminalAreaStorageGroup" type="CM_TerminalAreaStorageGroup"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="02c7311f-2a16-4486-adbf-fcff3de03daa">
        <updating/>
        <source>setProxy(_code : String; _description : String; _terminalAreas : CM_TerminalAreaArray; _terminal : CM_Terminal) updating;
// 28 May 2013	cnwjre1	CCMS DPH 2278 Storage Billing by Teminal Area
vars

begin

	self.code			:=	_code;
	self.description	:=	_description;
	self.allTerminalAreas.clear();
	if _terminalAreas &lt;&gt; null then
		_terminalAreas.copy(self.allTerminalAreas);
	endif;
	self.myTerminal		:=	_terminal;

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_terminalAreas" type="CM_TerminalAreaArray"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="e7c080fd-8610-4917-8239-520edf89ba20">
        <source>validateForCreate();
// 28 May 2013	cnwjre1	CCMS DPH 2278 Storage Billing by Teminal Area
vars
	ta	: CM_TerminalArea;
	sg	: CM_TerminalAreaStorageGroup;
begin
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Storage Group Terminal", null, null);
		app.raiseCMException(Input_required_field_strGrpTrm, null, null); // cnwdb2	PAR 35364
	endif;
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Storage Group Code", null, null);
		app.raiseCMException(Input_required_field_strGrpDes, null, null); // cnwdb2	PAR 35364
	endif;
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Storage Group Description", null, null);
		app.raiseCMException(Input_required_field_strGrpCde, null, null); // cnwdb2	PAR 35364
	endif;

	// code must be unique within terminal
	if self.myTerminal.allTerminalAreaStorageGroups[self.code] &lt;&gt; null then
		 app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

	// each terminal area must be in at most one storage group, so for a new group no terminal area should already be in a group
	foreach ta in self.allTerminalAreas do
		foreach sg in ta.allTerminalAreaStorageGroups do
			app.raiseCMException2(Term_area_in_other_stg_group, ta.id, sg.code, null, null);
		endforeach;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="9c0b8133-f3e6-465a-8209-c05d6c6a62d7">
        <source>validateForDelete();
// 28 May 2013	cnwjre1	CCMS DPH 2278 Storage Billing by Teminal Area
vars

begin

end;
</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="aa28479f-9a26-4aa1-b087-680386dc0789">
        <source>validateForUpdate(_realStorageArea : CM_TerminalAreaStorageGroup);
// 28 May 2013	cnwjre1	CCMS DPH 2278 Storage Billing by Teminal Area
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
vars
	ta	: CM_TerminalArea;
	sg	: CM_TerminalAreaStorageGroup;
begin
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Storage Group Terminal", null, null);
		app.raiseCMException(Input_required_field_strGrpTrm, null, null); // cnwdb2	PAR 35364
	endif;
	if self.code = null then
		app.raiseCMException(Input_required_field_strGrpDes, null, null);
	endif;
	if self.description = null then
//		app.raiseCMException1(REQUIRED_FIELD, "Storage Group Description", null, null);
		app.raiseCMException(Input_required_field_strGrpDes, null, null); // cnwdb2	PAR 35364
	endif;
	// check for duplicate if code changes
	if self.code &lt;&gt; _realStorageArea.code then
		if self.myTerminal.allTerminalAreaStorageGroups[self.code] &lt;&gt; null then
			//app.raiseCMException2(DuplicateItem, 'Storage Group', self.code, null, null); //14.06.2022 navds20 53760
			// Storage Group already exists for %1 : Storage_group_already_exists
			app.raiseCMException1(Storage_group_already_exists, self.code, null, null); //14.06.2022 navds20 53760
		endif;
	endif;
	
	// each terminal area must be in at most one storage group so the group of each area must be self
	foreach ta in self.allTerminalAreas do
		foreach sg in ta.allTerminalAreaStorageGroups do
			if sg &lt;&gt; _realStorageArea then
				app.raiseCMException2(Term_area_in_other_stg_group, ta.id, sg.code, null, null);
			endif;
		endforeach;
	endforeach;

end;</source>
        <Parameter name="_realStorageArea" type="CM_TerminalAreaStorageGroup"/>
    </JadeMethod>
</Class>
