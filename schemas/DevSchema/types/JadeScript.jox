    <JadeMethod name="kpdTestTimeZoneHelper" id="4f043038-036e-4c76-a1b0-798fa2cb3018">
        <source>kpdTestTimeZoneHelper();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 February 2016	cnwkpd1	PAR #36286 - Changes for Unicode JADE

*/

constants
	MaxCount		= 1;
	
vars
	t : JMTTimeZoneHelper;
	returnVal : String;
	ts,
	ts1 : TimeStamp;
	local : String;
	zones : JadeXMLDocument;
	elem : JadeXMLElement;
	elements : JadeXMLElementArray;
	dest : String;
	p : JadeProfiler;
	i : Integer;
	
begin
	app.initialize();
	
	create t transient;
	t.usePresentationClient := false;
	
	returnVal := t.getSystemTimeZones().String;
	write returnVal;
	
	create zones transient;
	zones.parseString(returnVal);
	
	create elements transient;
	zones.findElementsByTagName("Id", elements);

	local := t.getSystemTimeZoneID().String;
	write "Local timezone is " &amp; local;

	write "Local time is " &amp; ts.formatAsYYYYMMDDHHMMSSMMM;
	
	create p transient;
	p.methodCount := 20;
	p.fileName := "E:\temp\kpdTestTimeZoneHelper.txt";
	p.start();
	
	foreach i in 1 to MaxCount do
		foreach elem in elements do
			ts1 := t.convertTime(ts, local.StringUtf8, elem.textData.StringUtf8);
			write elem.textData.padBlanks(40) &amp; ts1.formatAsYYYYMMDDHHMMSSMMM;
		endforeach;
	endforeach;
	
	p.report();
	
	write "Test exception " &amp; t.convertTime(ts, local.StringUtf8, "xxx".StringUtf8).formatAsYYYYMMDDHHMMSSMMM;
	
	ts1 := t.convertTimeToUtc(ts, local.StringUtf8);
	
	write "UTC time is " &amp; ts1.formatAsYYYYMMDDHHMMSSMMM;
	
	ts1 := t.convertTimeFromUtc(ts1, local.StringUtf8);
	
	write "Converted back to local is " &amp; ts1.formatAsYYYYMMDDHHMMSSMMM;
	
epilog

end;</source>
    </JadeMethod>
