<Class name="RadioTelemetryGuiAgentThin" id="6e99ae0c-95e7-44c7-bc99-cb73152b1b11">
    <superclass name="RadioTelemetryGuiAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This agent provides a thin client access to the database using a package.</text>
    <DbClassMap file="mbTransient"/>
    <ImplicitInverseRef name="myRTThinClientAgent" id="30447ed7-13f0-438e-a759-6757b6f3433e">
        <embedded/>
        <type name="MobileServerRTThin::RadioTelemetryThinClientAgent"/>
        <access>readonly</access>
        <text>This is a reference to the package agent class</text>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myStateObj" id="5d33bf6d-385b-4ff2-b364-c3e77a8d2ec9">
        <embedded/>
        <type name="MobileServerRTThin::DTO_StateInfo"/>
        <access>readonly</access>
        <subAccess>hidden</subAccess>
        <text>This is a reference to a package class which enables state to be transfered between the server and client. Creating one instance cuts down on transient creates</text>
    </ImplicitInverseRef>
    <JadeMethod name="acceptSpecificTask" id="1ab9061d-24ac-43ef-95dd-10ca79cca128">
        <source>acceptSpecificTask(_queueEntry : Object input;
				   _form : JMMobileClient_BaseForm input;
				   _errorString : String output;
				   _state : Integer output) : Boolean;
				   
/*

Purpose:			Attempt to accept the task for the passed in queue entry object


Return Value:		True if successful


Date		Who		Reason
14 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	packageQEntry	: MobileServerRTThin::DTO_RTQueueEntry;
	packageDTO 		: MobileServerRTThin::DTO_EnquiryGradingTasks;
	rtnValue		: Boolean;

begin
	create packageQEntry transient;
	packageQEntry.myRealQueueEntry := _queueEntry;
	
	create packageDTO transient;

	self.clearStateObject();
		
	rtnValue := self.myRTThinClientAgent.acceptSpecificTask(packageQEntry, packageDTO, self.myStateObj);

	_errorString	:= self.myStateObj.errorString;
	_state			:= self.myStateObj.guiState;
	
	if rtnValue then
		_form.loadFormFromThinClientObj(packageDTO);
	endif;

	return rtnValue;

	
epilog
	delete packageQEntry;
	delete packageDTO;

end;
</source>
        <Parameter name="_queueEntry" type="Object" usage="input"/>
        <Parameter name="_form" type="JMMobileClient_BaseForm" usage="input"/>
        <Parameter name="_errorString" type="String" usage="output"/>
        <Parameter name="_state" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="acceptTask" id="fa094881-dbbf-4682-a0ce-a377bd79b232">
        <source>acceptTask(_state : Integer output; _errorString : String output): Boolean;
// -------------------------------------------
// Created 12 January 2006 by cnwdvb1
// -------------------------------------------
vars

	rtnValue	: Boolean;

begin
	
	self.clearStateObject();
	
	rtnValue := self.myRTThinClientAgent.acceptTask(self.myStateObj);

	_errorString := self.myStateObj.errorString;
	_state := self.myStateObj.guiState;
	
	return rtnValue;

end;</source>
        <Parameter name="_state" type="Integer" usage="output"/>
        <Parameter name="_errorString" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="actionDirectorTask" id="a2162d22-2ef1-4a80-bead-7db678f4377a">
        <source>actionDirectorTask(	_tiId			: String;
					_form			: JMMobileClient_BaseForm input;
					_errorString	: String output;
					_state			: Integer output;	
					_warnings		: Boolean io): Boolean;
// -------------------------------------------
// Created 03 February 2006 by cnwdvb1
// -------------------------------------------
vars

	packageDTO 		: MobileServerRTThin::DTO_EnquiryGradingTasks;
	rtnValue		: Boolean;

begin
	
	create packageDTO transient;

	self.clearStateObject();
	
	self.myStateObj.warningsAcknowledged := _warnings;
	
	rtnValue := self.myRTThinClientAgent.actionDirectorTask(_tiId, packageDTO, self.myStateObj);

	_errorString	:= self.myStateObj.errorString;
	_state			:= self.myStateObj.guiState;
	_warnings		:= self.myStateObj.hasWarningsOnly;
	
	if rtnValue then
		_form.loadFormFromThinClientObj(packageDTO);
	endif;

	return rtnValue;

epilog
	delete packageDTO;
end;</source>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_form" type="JMMobileClient_BaseForm" usage="input"/>
        <Parameter name="_errorString" type="String" usage="output"/>
        <Parameter name="_state" type="Integer" usage="output"/>
        <Parameter name="_warnings" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changePassword" id="160a232b-ccb7-4cf7-a968-5f00686b9a40">
        <source>changePassword(	_userCode, _oldPass,
				_newPass, _newPass2	: String; 
				_errorString		: String output;
				_state				: Integer output;
				_warnings			: Boolean io): Boolean;
// -------------------------------------------
// Created 08 February 2006 by cnwdvb1
// -------------------------------------------
vars

	rtnValue	: Boolean;

begin

	self.clearStateObject();
	
	self.myStateObj.warningsAcknowledged := _warnings;
	
	rtnValue := self.myRTThinClientAgent.changePassword(_userCode, _oldPass, _newPass, _newPass2, self.myStateObj);

	_errorString	:= self.myStateObj.errorString;
	_state			:= self.myStateObj.guiState;
	_warnings 		:= self.myStateObj.hasWarningsOnly;
	
	return rtnValue;


end;</source>
