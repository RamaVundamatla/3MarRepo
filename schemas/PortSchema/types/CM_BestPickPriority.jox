    <JadeMethod name="doesTIMatch" id="fb2b0755-1883-4b73-84ff-47b73693ab6f">
        <source>doesTIMatch(_ti : CM_TrackedItem ) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation 35632

*/

vars
	criteria : CM_YACriteria;
	cmifAutoPlan : CMIF_YAAutoPlanNormal;
begin
	create cmifAutoPlan transient;
	cmifAutoPlan.attachTI(_ti);

	foreach criteria in self.allCriteria discreteLock do
		if not criteria.isCMIFAutoPlanDataMatch(cmifAutoPlan) then
			return false;
		endif;
	endforeach;
	
	return true;
epilog
	delete cmifAutoPlan;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getBestPickDateTypeDesc" id="f29c3d02-df6b-4450-bcc3-e15cbcefb033">
        <options>4</options>
        <source>getBestPickDateTypeDesc(_bestPickType : Integer) : String typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation 35632

*/

vars

begin
	if _bestPickType = CM_BestPickPriority.BestPickRecevialDT then
		return app.getErrorString(Receival_DT);
	elseif _bestPickType = CM_BestPickPriority.BestPickPTIDT then
		return app.getErrorString(Latest_PTI_DT);
	elseif _bestPickType = CM_BestPickPriority.BestPickSubterminalDT then
		return app.getErrorString(Latest_subterm_receive_DT);
	endif;
epilog

end;</source>
        <Parameter name="_bestPickType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBestPickDateTypeFromDesc" id="ff471d37-9f97-4c24-8205-f2fe1e002ca1">
        <options>4</options>
        <source>getBestPickDateTypeFromDesc(_desc : String) : Integer typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation 35632

*/

vars

begin
	if _desc = app.getErrorString(Receival_DT)  then
		return CM_BestPickPriority.BestPickRecevialDT;
	elseif _desc =  app.getErrorString(Latest_PTI_DT)  then
		return  CM_BestPickPriority.BestPickPTIDT;
	elseif  _desc =  app.getErrorString(Latest_subterm_receive_DT) then
		return  CM_BestPickPriority.BestPickSubterminalDT;
	endif;
epilog

end;</source>
        <Parameter name="_desc" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaText" id="cb8df777-af5a-4f85-901e-f5973fbcbb51">
        <source>getCriteriaText() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation 35632

*/

vars
	text	: String;
	criteria	: CM_YABestPickCriteria;
begin
	foreach criteria in self.allCriteria do
		text := text &amp; criteria.getListDisplay &amp; " ";
	endforeach;
	return text;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="361f1dd5-557c-4d44-a1ff-a527a9ff4d6a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation 35632

*/

vars

begin
	if _attrName = ETRow_Criteria then
		return self.getCriteriaText;
	elseif _attrName = ETRow_BestPickDateType then
		return CM_BestPickPriority@getBestPickDateTypeDesc(self.bestPickDateType);
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="persistCriteria" id="a78c2fca-57bd-459c-84bc-227aff988360">
        <updating/>
        <source>persistCriteria(_allTransientCriteriaObj : CMIF_Array; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation 35632

*/

vars
	cmifObject			: CMIF_Object;
	transientObj		: CMIF_YACriteriaPriority;
	proxyObj			: CM_YACriteriaPriority;
	realCPObj			: CM_YACriteriaPriority;
	
begin
	// Persist, update or delete the Criteria.
	foreach cmifObject in _allTransientCriteriaObj do
		transientObj	:=	cmifObject.CMIF_YACriteriaPriority;
		proxyObj		:=	transientObj.myProxy;
		realCPObj		:=	transientObj.myCriteriaPriority;
		proxyObj.CM_YABestPickCriteria.setMyBestPickCriteria(self);
		
		// Do "New" first, because the "changed" flag can be set if a new Criteria/Priority
		// is changed after it is added, but before it is saved to the database.
		if transientObj.isNew then
			app.myUtilityCA.utlCreateYACriteriaPriority(proxyObj, realCPObj, _passport);
		elseif transientObj.isChanged then
			app.myUtilityUA.utlUpdateYACriteriaPriority(realCPObj, proxyObj, _passport);
		elseif transientObj.isDeleted then
			if realCPObj &lt;&gt; null then
				app.myUtilityDA.utlDeleteYACriteriaPriority(realCPObj, _passport);
			endif;			
		endif;
	endforeach;

	self.validateCriteria();

epilog

end;</source>
        <Parameter name="_allTransientCriteriaObj" type="CMIF_Array"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a2cf6bbe-79ca-40f2-93d9-5882a2f85ef1">
        <updating/>
        <source>setForCreate(_proxyBestPickCriteria : CM_BestPickPriority input; _passport : CM_Passport) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation 35632

*/

vars

begin
	self.code:=_proxyBestPickCriteria.code;
	self.setForUpdate(_proxyBestPickCriteria, _passport);
	
	self.myTerminal:=_proxyBestPickCriteria.myTerminal;
epilog

end;</source>
        <Parameter name="_proxyBestPickCriteria" type="CM_BestPickPriority" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b3268dd0-005a-4a24-97c0-e75b72a002e7">
        <updating/>
        <source>setForUpdate(_proxyBestPickCriteria : CM_BestPickPriority input; _passport : CM_Passport) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation 35632

*/

vars

begin
	self.priority:=_proxyBestPickCriteria.priority;
	self.bestPickDateType:=_proxyBestPickCriteria.bestPickDateType;
epilog

end;</source>
        <Parameter name="_proxyBestPickCriteria" type="CM_BestPickPriority" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="0c94e21f-eb53-421c-8fc2-c11e5880e391">
        <updating/>
        <source>setProxy(_code : String; _priority : Integer; _bestPickDateType : Integer; _myTerminal : CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation 35632

*/

vars

begin	
	self.code :=_code;
	self.priority:=_priority;
	self.bestPickDateType:=_bestPickDateType;
	self.myTerminal:=_myTerminal;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_priority" type="Integer"/>
        <Parameter name="_bestPickDateType" type="Integer"/>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="validateCriteria" id="bbba9e86-4959-4476-969a-93aabfc3cbca">
        <source>validateCriteria();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation 35632

*/

vars
	criteria			: CM_YABestPickCriteria;
	criteriaType 		: CM_YACriteriaType;
	criteriaTypeColl	: ObjectSet;

begin
	create criteriaTypeColl transient;
	
	// Ensure there is only one criteria object for any criteria type
	foreach criteria in self.allCriteria do
		criteriaType := criteria.myYACriteriaType;
		if criteriaTypeColl.includes(criteriaType) then
			app.raiseCMException1(Err_YA_CriteriaWithSameType, criteriaType.description, null, null);	
		else
			criteriaTypeColl.add(criteriaType);
		endif;
	endforeach;

epilog
	delete criteriaTypeColl;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="eb26f6fb-ae4f-4452-8e00-d57208b591cb">
        <source>validateForCreate(_passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation 35632

*/

vars

begin
	if self.code = null then
		app.raiseCMException(Input_required_field_code,null,null);
	endif;
	
	if self.myTerminal = null then
		app.raiseCMException(Input_required_field_terminal,null,null);
	endif;
	
	self.validateForUpdate(_passport);
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="27246868-9529-49e0-9fa6-65fc3a020fd8">
        <source>validateForUpdate(_passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation 35632

*/

vars

begin
	if self.priority = 0 then
		app.raiseCMException(Input_require_field_priorit,null,null);
	endif;
	
	if self.bestPickDateType = 0 then
		app.raiseCMException(Input_requir_date_type_field,null,null);
	endif;
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
