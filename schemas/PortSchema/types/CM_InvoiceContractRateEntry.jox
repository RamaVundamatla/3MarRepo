    <JadeMethod name="auditId" id="389ccc94-422d-4c45-b6d0-3d094a67b6a0">
        <source>auditId(): String;
/*
Purpose:			

Date		Who		Reason
09 December 2022	navab1	TFS CR 55623 TASK 55785
*/

vars
	auditIdStr : String;
begin

	auditIdStr := self.myInvoiceContractRate.auditId;
	
	auditIdStr := "/" &amp; auditIdStr &amp; "/" &amp; self.fromTS.asStringJMT() &amp; "-" &amp; self.toTS.asStringJMT() &amp; "/" &amp; self.fromAmount.asStringJMT() &amp; "-" &amp; self.toAmount.asStringJMT();
	
	return auditIdStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
