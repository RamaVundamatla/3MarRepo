    <JadeMethod name="getCraneLabel" id="5d19814d-7fce-4dfe-9746-7309cdf6cd30">
        <source>getCraneLabel() : String;
// ---------------------------------------------------------------------------
// Created:		26 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aCrane : CM_Crane;
begin
	aCrane := self.getMyCrane();
	if aCrane = null then
		return self.crane;
	endif;
	
	
	if aCrane.isTwinLift then		//cnwmc5 - 28 July 2014 - PAR 34455
		return aCrane.code &amp; " (T/L)";
	else
		return aCrane.code;
	endif;
end;</source>
