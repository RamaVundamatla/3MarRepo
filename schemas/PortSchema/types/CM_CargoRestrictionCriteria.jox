    <JadeMethod name="getTableDisplayString" id="ae987c68-f69f-451e-a787-8d96f7a62377">
        <source>getTableDisplayString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2014	cnwndl1	Initial creation	Par 33439

*/

vars

begin

	return self.myTerminal.name &amp; Tab &amp; " " &amp; Tab &amp; self.getCriteriaSummary(", ");


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
