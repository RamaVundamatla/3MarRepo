    <JadeMethod name="getProgressString" id="8784d417-0b3d-413e-9296-f15778fe04d0">
        <source>getProgressString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2024 navhl20	ChangeRequest 61368: EUP* | Adding Pack Reserve Child to Packing Work order Release Request
29 Jul 2024 navhl20	Bug 65445: EUP - 1090 error when no reserve child on pack work orders
*/

vars
	required,
	completed	: Integer;
begin
	if self.getMyTerminal.isUseYardJobsForCargoWo and app.myPassport.isVASEnabled then	
		if self.myReserveDetail &lt;&gt; null and self.myReserveDetail.isKindOf(CM_ReserveSelection) then
			required 	:= self.myReserveDetail.CM_ReserveSelection.totalRequested;
		elseif self.myReleaseRequest &lt;&gt; null and self.myReleaseRequest.releaseByType then				//29.07.2024 navhl20 #65445
			required 	:= self.myReleaseRequest.getTotalPackRequested();
		else
			required	:= self.getWodTotalRequested(true).Integer;
		endif;
		completed		:= self.getTotalCompleted(true).Integer;
		return app.getErrorString2(N_of_n_Complete, completed.String, required.String);
	else
		return inheritMethod();
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReference" id="1de91037-6a11-4ab7-8709-3de2e9da775a">
        <source>getReference(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2023	navhl20	ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate

*/

vars

begin
	if self.myBookingRef &lt;&gt; null then
		return self.myBookingRef.bookingReference;
	endif;
	if self.myReleaseRequest &lt;&gt; null then
		return self.myReleaseRequest.code;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
