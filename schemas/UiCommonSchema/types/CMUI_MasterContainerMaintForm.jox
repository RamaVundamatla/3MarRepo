    <JadeMethod name="loadComboBoxCoolingType" id="14b4eacf-fc9a-4fb3-a532-224be395acdf">
        <source>loadComboBoxCoolingType();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2008	cnwrd1	Initial creation

*/

vars

begin
	self.cmbCoolingType.clear();
	self.cmbCoolingType.addItem(ContainerCooledNullStr);
	self.cmbCoolingType.addItem(ContainerAirCooledStr);
	self.cmbCoolingType.addItem(ContainerWaterCooledStr);
