    <JadeMethod name="isRootDebtorGroupRateEntry" id="d79cc54b-be90-4df9-b3b0-6d3797777cd8">
        <source>isRootDebtorGroupRateEntry():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwndl1	Initial creation	Par 30375

*/

vars

	debtorNode : CM_DebtorNode;
	rootDebtorGroup : CM_RootDebtorGroup;

begin

	debtorNode := self.getMyDebtorNode();
	if debtorNode = null or debtorNode.bank = null then
		return false;
	endif;
	
	rootDebtorGroup := debtorNode.bank.getRootDebtorGroup;
	if debtorNode = rootDebtorGroup then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="f212c3ae-6c98-4a68-a01e-25894ad12f7f">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwndl1	Initial creation	Par 30375

*/

vars

	pxyRateEntry : CM_RateEntry;
	subTermRate : CM_SubTerminalRate;
	pxySubTermRate : CM_SubTerminalRate;
	tidalClassRate : CM_TidalClassRate;
	pxyTidalClassRate : CM_TidalClassRate;

begin



	pxyRateEntry := inheritMethod();
	
	pxyRateEntry.myRateDerived := self.myRateDerived;
	
	//29 Jun 2018	NDL	TFS 39338
	foreach subTermRate in self.allRatesBySubTerminal do
		create pxySubTermRate transient;
		pxySubTermRate.setDetails( subTermRate.costPerUnit, subTermRate.mySubTerminal, pxyRateEntry );
	endforeach;
	foreach tidalClassRate in self.allRatesByTidalClass do
		create pxyTidalClassRate transient;
		pxyTidalClassRate.setDetails( tidalClassRate.costPerUnit, tidalClassRate.myTidalClass, pxyRateEntry );
	endforeach;
	
	return pxyRateEntry;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setCostPerUnit" id="728c2fd5-845a-44b9-b26b-63be6710fc9f">
        <updating/>
        <source>setCostPerUnit( _cpu : Decimal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwndl1	Initial creation	Par 30375

*/

vars

	child : CM_RateEntry;

begin

	if self.costPerUnit &lt;&gt; _cpu then
		self.costPerUnit := _cpu;
	endif;

epilog

end;</source>
        <Parameter name="_cpu" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="fd2da741-a939-4db3-846f-0d7dfe89fef5">
        <updating/>
        <source>setForCreate(_pxyRateEntry : CM_RateEntry) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//	May 2010	cnwjre1	23582 add expiry date and ignore option
// ---------------------------------------------------------------------------

vars
	realRate : CM_Rate;
begin

	if not _pxyRateEntry.rate.isTransient then
		realRate := _pxyRateEntry.rate;
	else
		create realRate as _pxyRateEntry.rate.class;
		realRate.setForCreate(_pxyRateEntry.rate);
	endif;
	
	self.rate := realRate;
	self.rate.doAuditRateHistory(_pxyRateEntry.allCostPerUnits, _pxyRateEntry.getRawCostPerUnit, _pxyRateEntry.startTimestamp, _pxyRateEntry.expiryTimestamp, _pxyRateEntry.ignoreThisEntry, self, false, CM_FinAuditRateHistory.Status_Create);	

	// From 753 the audit is also on the rate entry itself.
	self.doAuditRateHistory(_pxyRateEntry.allCostPerUnits, _pxyRateEntry.getRawCostPerUnit,  _pxyRateEntry.startTimestamp, _pxyRateEntry.expiryTimestamp, _pxyRateEntry.ignoreThisEntry,  self, false, CM_FinAuditRateHistory.Status_Create);	
	self.allCostPerUnits.clear;
	_pxyRateEntry.allCostPerUnits.copy(self.allCostPerUnits);

	//self.costPerUnit := _pxyRateEntry.costPerUnit;
	self.userId := _pxyRateEntry.userId;
	self.startTimestamp := _pxyRateEntry.startTimestamp;
	self.expiryTimestamp := _pxyRateEntry.expiryTimestamp;
	self.ignoreThisEntry := _pxyRateEntry.ignoreThisEntry;
		// cnwrns1 7/9/2012 to set the isRatePercentage
	self.rateIsPercentage := _pxyRateEntry.rateIsPercentage;
	self.costIsAmount := _pxyRateEntry.costIsAmount;
	
	//17 Sep 2012	NDL	Par 30375
	self.adjustmentToBase := _pxyRateEntry.adjustmentToBase;
	self.percentageOfBase := _pxyRateEntry.percentageOfBase;
	self.myRateDerived := _pxyRateEntry.myRateDerived;
	self.setCostPerUnit(_pxyRateEntry.getRawCostPerUnit );	//18 Sep 2012	NDL	Par 30375

	self.updateRatesByObject( _pxyRateEntry );	//29 Jun 2018	NDL	TFS 39338
	
end;</source>
        <Parameter name="_pxyRateEntry" type="CM_RateEntry"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="4d8f1a36-ecfc-4907-b793-20adfacd0ba3">
        <updating/>
        <source>setForUpdate(_pxyRateEntry : CM_RateEntry) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//	May 2010	cnwjre1	23582 add expiry date and ignore option
// ---------------------------------------------------------------------------

vars

begin
	//par 10907 cnwrs1 mer 2006
	self.rate.doAuditRateHistory(_pxyRateEntry.allCostPerUnits, _pxyRateEntry.getRawCostPerUnit, _pxyRateEntry.startTimestamp, _pxyRateEntry.expiryTimestamp, _pxyRateEntry.ignoreThisEntry, self, false, CM_FinAuditRateHistory.Status_Update);
	
	// From 753 the audit is also on the rate entry itself.
	self.doAuditRateHistory(_pxyRateEntry.allCostPerUnits,_pxyRateEntry.getRawCostPerUnit,_pxyRateEntry.startTimestamp, _pxyRateEntry.expiryTimestamp, _pxyRateEntry.ignoreThisEntry, self, false, CM_FinAuditRateHistory.Status_Update);	
	//self.costPerUnit := _pxyRateEntry.costPerUnit;
	self.rate := _pxyRateEntry.rate;
	self.userId := _pxyRateEntry.userId;
	self.startTimestamp := _pxyRateEntry.startTimestamp;
	self.expiryTimestamp := _pxyRateEntry.expiryTimestamp;
	self.ignoreThisEntry := _pxyRateEntry.ignoreThisEntry;
	// cnwrns1 7/9/2012 to set the isRatePercentage
	self.rateIsPercentage := _pxyRateEntry.rateIsPercentage;
	self.costIsAmount := _pxyRateEntry.costIsAmount;
	
	//17 Sep 2012	NDL	Par 30375
	self.adjustmentToBase := _pxyRateEntry.adjustmentToBase;
	self.percentageOfBase := _pxyRateEntry.percentageOfBase;
	self.myRateDerived := _pxyRateEntry.myRateDerived;
	self.setCostPerUnit(_pxyRateEntry.getRawCostPerUnit );	//18 Sep 2012	NDL	Par 30375

	self.allCostPerUnits.clear;
	_pxyRateEntry.allCostPerUnits.copy(self.allCostPerUnits);
	
	self.updateRatesByObject( _pxyRateEntry );	//29 Jun 2018	NDL	TFS 39338

end;</source>
        <Parameter name="_pxyRateEntry" type="CM_RateEntry"/>
    </JadeMethod>
    <JadeMethod name="setParentRate" id="e5469e71-6d10-4e24-9396-fa2b238105fd">
        <updating/>
        <source>setParentRate(	_adjustToBase : Decimal;
				_percentOfBase : Decimal;
				_rateDerived : CM_Rate ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwndl1	Initial creation	Par 30375

*/

vars

begin

	if _rateDerived = null then
		self.adjustmentToBase := 0;
		self.percentageOfBase := 0;
		
	else
		self.myRateDerived := _rateDerived;
		self.adjustmentToBase := _adjustToBase;
		self.percentageOfBase := _percentOfBase;
		if _adjustToBase &lt;&gt; 0 then
			self.setCostPerUnit( 0 );
		elseif _percentOfBase &lt;&gt; 0 then
			self.setCostPerUnit( 0 );
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="_adjustToBase" type="Decimal"/>
        <Parameter name="_percentOfBase" type="Decimal"/>
        <Parameter name="_rateDerived" type="CM_Rate"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="2150bc46-0c25-43c8-9d17-7ef2066bfe02">
        <updating/>
        <source>setProxy(	_cpus : DecimalArray;
			_cpu : Decimal;
			_rate : CM_Rate;
			_user : String;
			_start : TimeStamp;
			_expiry : TimeStamp;
			_ignoreEntry : Boolean;
			_adjustToBase : Decimal;
			_percentOfBase : Decimal;
			_parentRate : CM_Rate
			) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//	23582 add expiry and ignore
// ---------------------------------------------------------------------------

vars

begin
	//self.costPerUnit := _cpu;
	self.setCostPerUnit( _cpu );
	self.rate := _rate;
	self.userId := _user;
	self.startTimestamp := _start;
	self.expiryTimestamp := _expiry;
	self.ignoreThisEntry := _ignoreEntry;
	self.allCostPerUnits.clear;
	if _cpus &lt;&gt; null then
		_cpus.copy(self.allCostPerUnits);
	endif;
	
	//18 Sep 2012	NDL	Par 30375
	self.setParentRate( _adjustToBase, _percentOfBase, _parentRate );
	
end;</source>
        <Parameter name="_cpus" type="DecimalArray"/>
        <Parameter name="_cpu" type="Decimal"/>
        <Parameter name="_rate" type="CM_Rate"/>
        <Parameter name="_user" type="String"/>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_expiry" type="TimeStamp"/>
        <Parameter name="_ignoreEntry" type="Boolean"/>
        <Parameter name="_adjustToBase" type="Decimal"/>
        <Parameter name="_percentOfBase" type="Decimal"/>
        <Parameter name="_parentRate" type="CM_Rate"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromCSV" id="2ccadb3c-c9cb-4d58-90de-613d05470b35">
        <updating/>
        <source>setProxyFromCSV(_cpuPointer:Integer; _cpu, _ocpu:Decimal; _rateObj:CM_Rate; _userCode:String; _startTS:TimeStamp; _expiryTS : TimeStamp;
			_adjustToBase : Decimal;
			_percentOfBase : Decimal;
			_parentRateEntry : CM_RateEntry) updating;
// --------------------------------------------------------------------------------
// Created:		11 December 2008 by cnwdad1
//
// Purpose:		Updates the receiver with data loaded from an extracted CSV file.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//	May 2010	cnwjre1		23582 add expiry, ignore
// 17/10/2012 	cnwmh5		#30549 - Add original cost per unit for handling multi lines
// --------------------------------------------------------------------------------
begin
	self.rate			:=	_rateObj;
	self.userId			:=	_userCode;
	self.startTimestamp	:=	_startTS;
	self.expiryTimestamp := _expiryTS;
	self.ignoreThisEntry := false;
	
	//self.costPerUnit	:=	_cpu;
	//self.setCostPerUnit( _cpu );
	self.setCostPerUnit(_ocpu);											// 17/10/2012 cnmwh5 #30549
	// 23055 June 2010 cnwjre1, set the allCostPerUnit as well, otherwise miss changes in auditing
	if _cpuPointer &gt; 0 and
	   _cpuPointer &lt;= self.allCostPerUnits.size then
		self.allCostPerUnits[_cpuPointer]	:=	_cpu;
	endif;
	
	//18 Sep 2012	NDL	Par 30375
	self.adjustmentToBase := _adjustToBase;
	self.percentageOfBase := _percentOfBase;
	
end;</source>
        <Parameter name="_cpuPointer" type="Integer"/>
        <Parameter name="_cpu" type="Decimal"/>
        <Parameter name="_ocpu" type="Decimal"/>
        <Parameter name="_rateObj" type="CM_Rate"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_expiryTS" type="TimeStamp"/>
        <Parameter name="_adjustToBase" type="Decimal"/>
        <Parameter name="_percentOfBase" type="Decimal"/>
        <Parameter name="_parentRateEntry" type="CM_RateEntry"/>
    </JadeMethod>
    <JadeMethod name="setProxyWithPercentage" id="df3b11d1-2e9d-4ebf-9a11-08808fdcb99e">
        <updating/>
        <source>setProxyWithPercentage(_cpus : DecimalArray; _cpu : Decimal; _rate : CM_Rate; _user : String; _start : TimeStamp; _expiry : TimeStamp; _ignoreEntry : Boolean; _isPercentage : Boolean; _isAmount : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		September 2012 by Rania Iskander cnwrns1
//
// Purpose:		
//	23582 add expiry and ignore
// ---------------------------------------------------------------------------

vars

begin
	//self.costPerUnit := _cpu;
	self.setCostPerUnit( _cpu );
	self.rate := _rate;
	self.userId := _user;
	self.startTimestamp := _start;
	self.expiryTimestamp := _expiry;
	self.ignoreThisEntry := _ignoreEntry;
	self.allCostPerUnits.clear;
	self.rateIsPercentage := _isPercentage;
	self.costIsAmount := _isAmount;
	if _cpus &lt;&gt; null then
		_cpus.copy(self.allCostPerUnits);
	endif;
end;</source>
        <Parameter name="_cpus" type="DecimalArray"/>
        <Parameter name="_cpu" type="Decimal"/>
        <Parameter name="_rate" type="CM_Rate"/>
        <Parameter name="_user" type="String"/>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_expiry" type="TimeStamp"/>
        <Parameter name="_ignoreEntry" type="Boolean"/>
        <Parameter name="_isPercentage" type="Boolean"/>
        <Parameter name="_isAmount" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateRatesByObject" id="d02f6e3b-aab8-4d1f-8632-59f9fb70126f">
        <updating/>
        <source>updateRatesByObject(_pxyRateEntry : CM_RateEntry) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2018	jlgndl1	Initial creation	TFS 39338

*/

vars

	subTermRate : CM_SubTerminalRate;
	pxySubTermRate : CM_SubTerminalRate;
	tidalClassRate : CM_TidalClassRate;
	pxyTidalClassRate : CM_TidalClassRate;

begin

	foreach pxySubTermRate in _pxyRateEntry.allRatesBySubTerminal do
		subTermRate := self.getObjectRateForObject( pxySubTermRate.mySubTerminal ).CM_SubTerminalRate;
		if subTermRate = null then
			create subTermRate persistent;
		endif;
		subTermRate.setDetails( pxySubTermRate.costPerUnit, pxySubTermRate.mySubTerminal, self );
	endforeach;
	foreach pxyTidalClassRate in _pxyRateEntry.allRatesByTidalClass do
		tidalClassRate := self.getObjectRateForObject( pxyTidalClassRate.myTidalClass ).CM_TidalClassRate;
		if tidalClassRate = null then
			create tidalClassRate persistent;
		endif;
		tidalClassRate.setDetails( pxyTidalClassRate.costPerUnit, pxyTidalClassRate.myTidalClass, self );
	endforeach;

epilog

end;</source>
        <Parameter name="_pxyRateEntry" type="CM_RateEntry"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="a87a6fc1-b1e3-4b9f-8419-0f6acb5225f2">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	realRate : CM_Rate;
begin
	//if self.getRawCostPerUnit &gt; 999999.999999 then
	if self.getRawCostPerUnit &gt; 9999999999.999999 then	//18 May 2018	NDL	TFS 38528
		app.raiseCMException1(VB_NUMBER_TOO_BIG," " &amp; app.getErrorString(Rate_large_keep_below_millio),null,null);
	endif;
	
	if self.rate.isTransient then
	elseif self.rate.rateEntries[self.startTimestamp] &lt;&gt; null then
		app.raiseCMException2(Rate_start_date_time_alrea_exi, rate.service.name , self.startTimestamp.asStringJMT(),null,null); // PAR 22074
	
	endif;
	if not self.allCostPerUnits.isEmpty() and self.getRawCostPerUnit &lt;&gt; self.allCostPerUnits[1] then
		app.raiseCMException1(First_rate_stored_correct, rate.service.name , null, null); // PAR 22074
	endif;
	// 23582
	if self.expiryTimestamp &lt;&gt; null and
	   self.expiryTimestamp &lt; self.startTimestamp then
		app.raiseCMException2(Expiry_later_than_start, self.expiryTimestamp.asStringJMT , self.startTimestamp.asStringJMT(), null, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="12cabde0-2add-4561-a53d-cf873d7ae51e">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//16/10/2023 navmv20 Bug 60896: FR | 54089 - Invoice Contracts - Rate audit trail

vars
	service : CM_Service; //16/10/2023 navmv20 Bug 60896
begin
	app.raiseCMWarning2(CONFIRM_REMOVE,"Rate Entry " &amp; self.getDerivedCostPerUnit( app.getChargeRateEffectiveDate ).String, self.rate.getCode(),null,null,self);
	//16/10/2023 navmv20 Bug 60896: - start
	if not app.isJMTUnitTest then
		service := self.rate.service;
		if service &lt;&gt; null and service.charges.isNotEmpty then
			app.raiseCMWarning1(Cannot_delete_been_used_invoic,self.auditId(),null,null,null);
		endif;
	endif;
	//16/10/2023 navmv20 Bug 60896: - end

end;</source>
    </JadeMethod>
