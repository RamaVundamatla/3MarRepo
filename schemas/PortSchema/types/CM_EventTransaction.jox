    <JadeMethod name="getAmountDisplay" id="2e95b0f1-d12a-4c7c-ab91-9bba1fe9a137">
        <source>getAmountDisplay() : String;
/*

Date		Who		Reason
14 September 2015	cnwer1	Initial creation PAR

*/

vars

begin
	if self.myEventType &lt;&gt; null and  self.myEventType.amountDecimalPlaces  &gt; 0 then
		return self.amount.asStringJMTWithPrecision(self.myEventType.amountDecimalPlaces,true);
	else
		return self.amount.Integer.asStringJMT;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="6250b834-7955-4d51-b9c0-4e5b15261f72">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

	txt,
	tmpStr,str	: String;

begin
	
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	tmpStr := null;
	str    := null;
	if self.myDebtor &lt;&gt; null then
		tmpStr := self.myDebtor.name;
		txt := txt &amp; app.getErrorString(INV_Debtor) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	str    :=null;
	if self.myTerminal &lt;&gt; null then
		tmpStr := self.myTerminal.code;
		txt := txt &amp; app.getErrorString(Terminal) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	str    :=null;
	if self.myEventType &lt;&gt; null then
		tmpStr := self.getTypeName;
		txt := txt &amp; app.getErrorString(Event_type) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	return txt;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
