    </PrimAttribute>
    <PrimAttribute name="shiftDescription" id="0749e392-5a41-473e-95f0-be9c816e7968">
        <length>101</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="shiftEndTS" id="5e40ab4d-0750-43d4-bd41-ce6629fabeea">
        <length>31</length>
        <embedded/>
