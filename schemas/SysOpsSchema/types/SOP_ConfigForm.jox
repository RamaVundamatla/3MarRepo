    <JadeMethod name="doOutputConfig" id="1b8cf4be-6f42-467a-84e6-c1a18c86a445">
        <source>doOutputConfig() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2009	cnwjk3	Initial creation

*/

vars
	file		: File;
	objArray	: ObjectArray; 
	fileSave 	: CMDFileSave;
begin
	create file transient;
	create objArray transient;
	create fileSave transient;
	file.mode := File.Mode_Output; // 1/3/16  cnwns1 PAR 36286 unicode version
	fileSave.defaultExt := '.xml';
	fileSave.fileMustExist := false;
	fileSave.fileName := 'outputConfig_' &amp; app.myRoot.client &amp; '.xml';
	fileSave.initDir := app.getTempDir();
	
	if fileSave.open() = 0 then
		file.openOutput(fileSave.fileName);
		app.myRoot.outputConfig(file, objArray, false, false, true);
		file.close();
	endif;
epilog
	delete file;
	delete objArray;
	delete fileSave;
end;</source>
        <access>protected</access>
    </JadeMethod>
