    <JadeMethod name="deleteCurrentJobEntry" id="456107f0-ee07-4ae1-9cc0-cb12ab776418">
        <updating/>
        <source>deleteCurrentJobEntry() updating, protected;
//--------------------------------------------------------------
//Created: 26 February 2002 By: cnwgd1
//nds TFS 2867 17/01/17PKT - Bulk Process
//--------------------------------------------------------------
//Confirm deletion of the current WLE for the RoadJob
//We have to do a number of things here..
//If the job is a receipt of a TI, we have to MOVE the TI to the LOGICAL delete
//area of the system, &amp; adjust the roadJob etc accordingly,
//If the job is a release, we simply amend the request etc.
vars
	result		: Integer;
	wleArray 	: CM_WLEArray;
	wleTable 	: CM_DataTable;
	wle			: CM_WorkListEntry;
	reason 		: String; // cnwrd1 par 22624 3.5.2010
	extraInfo	: String;	//18 Feb 2011	NDL Par 27046
	id			: String;	//18 Feb 2011	NDL Par 27046
	tiId		: String;	//18 Feb 2011	NDL Par 27046
begin
  	app.mousePointer := MousePointer_HourGlass;
  	
	create wleArray transient;
	
	wleTable:=self.mnuTableContext.userObject.CM_DataTable;
	if wleTable = null then
		return;
	endif;
	
	//nds TFS 2867 17/01/17PKT - Bulk Process
	self.getAllWLEsInTableSelected(wleArray,wleTable,false );

	//18 Feb 2011	NDL Par 27046
	extraInfo := " " &amp; app.getErrorString(Relative_To) &amp; ":";	
	foreach wle in wleArray do
		id := wle.id;
		tiId := wle.getDisplayStringForAttribute(ETRow_CargoDetails,false);
		if id = tiId then
			extraInfo := extraInfo &amp; CrLf &amp; "- " &amp; id;
		else
			extraInfo := extraInfo &amp; CrLf &amp; "- " &amp; id &amp; " " &amp; tiId;
		endif;
	endforeach;
	
	reason := self.getDeleteReason( extraInfo );	 // cnwrd1 par 22624 3.5.2010
	
	if reason = null then  // no reason must have canceled.
		return;
	endif;

	foreach wle in wleArray discreteLock do
		while true do
			app.myTrxDA.trxDeleteJobEntry(wle, reason, app.myPassport); // cnwrd1 par 22624 3.5.2010
			if app.myPassport.trxCompletedOK then
				break;
			else
				result := app.showErrorWarningDialog('Road Ops', app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
	endforeach;

epilog
	delete wleArray;
	app.mousePointer := MousePointer_Default;  	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayExtraInfoForObj" id="b70506ed-4fc2-477e-80da-768be56121c7">
        <source>displayExtraInfoForObj(_obj : CM_Object)protected;
//--------------------------------------------------------------
//Created: 18 March 2003 By: cnwgd1
//22/11/2017 				 cnwma1 TFS #7692 QNS - System buffering
//--------------------------------------------------------------
vars
	wle 		: CM_WorkListEntry;
	strArray	: HugeStringArray;
	dataContainer : CM_DataContainer;
	useNew : Boolean;
begin
	
	if not self.dkbMacro.visible then   //21.11/2017 7828  cnwma1 
		return;
	endif;
	
	self.tblMacro.clear();
	self.tblMacro.rows := 0;
	

	create dataContainer transient;
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;
				
	if _obj &lt;&gt; null and _obj.isKindOf(CM_Object) then 
			_obj.CM_Object.getExtraInfo(dataContainer);
			self.showExtraInformation(dataContainer, self.tblMacro, true, false, 4, 1, 1, 1, 1);
			self.doResizeColumnWidths(self.tblMacro, true);
	endif;

epilog
	if dataContainer &lt;&gt; null then
		delete dataContainer;
	endif;
	delete strArray;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
