    <JadeMethod name="getAllTIsForLength" id="bd2d3c30-ed50-4456-a002-f7e890a393f0">
        <source>getAllTIsForLength(_length : Integer ; _tiSet : Collection input);
/*

Date		Who		Reason
13 July 2015	cnwer1	Initial creation PAR

*/

vars
	ti : CM_TrackedItem;
begin
	if _tiSet = null then
		return;
	endif;
	
	foreach ti in self.allTIs where ti.isKindOf(CM_Container) do
		if _length = NULL_INTEGER then
			if not ti.is20 and not ti.isForty then
				_tiSet.add(ti);
			endif;
		elseif ti.getActualLength = _length then
			_tiSet.add(ti);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_length" type="Integer"/>
        <Parameter name="_tiSet" type="Collection" usage="input"/>
    </JadeMethod>
