    <JadeMethod name="deleteBulkRelease" id="0a11f065-d7f4-4d8d-b8cf-47cfed973da3">
        <updating/>
        <source>deleteBulkRelease() updating;
//AJA 10/8/00: NFS 3577: Allow users to clear out the offsite dicbulkReleaseonary
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	iter : Iterator;
	size : String;
	bulkRelease : CM_BulkRelease;
    array : ObjectArray;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting BulkRelease Items..."); 
	if self.abortStatus = true then
		return;
	endif;

	create array transient;
//	iter := app.getMyTerminal().allBulkReleaseByStatusByCode.createIterator; // AKB2005MAY
//	size := app.getMyTerminal().allBulkReleaseByStatusByCode.size.userNumberFormat($CNEC_NO_DECIMALS); // AKB2005MAY
	iter := app.getMyTerminalDO_NOT_USE().allBulkReleaseByTypeByStByCd.createIterator;
	size := app.getMyTerminalDO_NOT_USE().allBulkReleaseByTypeByStByCd.size.userNumberFormat($CNEC_NO_DECIMALS);
	
	
	count := 0;
	self.monitor("Checking " &amp; size &amp; " BulkReleases for items to delete...");
	if self.abortStatus = true then
		return;
	endif;
	lastCommit := app.relativeMachineTime();
	
	while iter.next(bulkRelease) do
		count := count + 1;
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("BulkReleases checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". BulkReleases to erase: " &amp; array.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;
		if bulkRelease.status = BR_COMPLETE then
			array.add(bulkRelease);
		endif;
	endwhile;

	self.monitor("There are " &amp; array.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := array.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := array.createIterator;
	count :=  0;
	lastCommit := app.relativeMachineTime();

	beginTransaction;
	on Exception do self.tiEraseExceptionHandler(exception);
	while iter.next(bulkRelease) do
//		if count mod 1000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//Commit every 50 items
			self.monitor("BulkReleases deleted: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		bulkRelease.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " BulkReleases erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete iter;
	delete array;
	on Exception do null;

end;</source>
    </JadeMethod>
    <JadeMethod name="deleteCamTaskHistory" id="0b42fc2f-7352-4259-a843-76fe0675d604">
        <updating/>
        <source>deleteCamTaskHistory() updating;
//
//17 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask
//12 June 2012	cnwrs1		make work for all terminals
//
vars
	camTaskHistory : CM_CamTaskHistory;
	camProtocol : CM_CamProtocol;
	object : Object;
//	objectArray : ObjectArray;
	terminal : CM_Terminal;
begin
	foreach terminal in app.myRoot.allTerminals do
		app.myPassport.setMyTerminal(terminal);
		foreach camProtocol in terminal.camProtocols do
	/*		if camProtocol.camTask &lt;&gt; null then	//17 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask
				beginTransaction;
				camProtocol.camTask.erase(NORMAL_ERASE);
				camProtocol.setCamTask(null);
				commitTransaction;
			endif;*/
			foreach camTaskHistory in camProtocol.taskHistoryByProtocolSeq  do
				beginTransaction;
				camProtocol.taskHistoryByProtocolSeq.remove(camTaskHistory);
				delete camTaskHistory;
				commitTransaction;
			endforeach;
			beginTransaction;
			camProtocol.lastRunDateTime := null;
	
	/*		if camProtocol.camTask &lt;&gt; null then	//17 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask
				camProtocol.camTask.erase(NORMAL_ERASE);
			endif;
			camProtocol.setCamTask(null);*/	//17 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask
//			create objectArray transient;
//			CM_CamTask.allInstances(objectArray, 0, true);
//			foreach object in objectArray do
//				delete object;
//			endforeach;
//			delete objectArray;
			commitTransaction;
		endforeach;
	endforeach;
epilog
//	delete objectArray;		// PAR #27874
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteDataDumpExtractHistory" id="e98c3dd7-ecdf-43b2-bafd-3c14cc5433c1">
        <updating/>
        <source>deleteDataDumpExtractHistory() updating;
//AJA 10/8/00: NFS 3577: Allow users to clear out the offsite dicdataDumpExtractHistoryonary
//12 June 2012	cnwrs1		make work for all terminals
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	iter : Iterator;
	size : String;
	dataDumpExtractHistory : CM_DataDumpExtractHistory;
    array : ObjectArray;
	terminal : CM_Terminal;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting DataDumpExtractHistory Items..."); 
	if self.abortStatus = true then
		return;
	endif;

	create array transient;
	foreach terminal in app.myRoot.allTerminals do
		app.myPassport.setMyTerminal(terminal);
		array.clear;
		iter := CM_DataDumpExtractDef.firstInstance.allDataDumpExtractHistory.createIterator;
	
		size := CM_DataDumpExtractDef.firstInstance.allDataDumpExtractHistory.size.userNumberFormat($CNEC_NO_DECIMALS);
		count := 0;
		self.monitor("Checking " &amp; size &amp; " DataDumpExtractHistory for items to delete...");
		if self.abortStatus = true then
			return;
		endif;
		
		while iter.next(dataDumpExtractHistory) do
			count := count + 1;
//			if count mod 10000 = 0 then
			now := app.relativeMachineTime();
			if now - lastCommit &gt; MaxTransactionTime then
				lastCommit := app.relativeMachineTime();
				self.monitor("DataDumpExtractHistory checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
					&amp; ". DataDumpExtractHistory to erase: " &amp; array.size.userNumberFormat($CNEC_NO_DECIMALS));
				if self.abortStatus = true then
					return;							//Exits here can just go straight back
				endif;
			endif;
			array.add(dataDumpExtractHistory);
		endwhile;
	
		self.monitor("There are " &amp; array.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
		if self.abortStatus = true then
			return;
		endif;
	
		size := array.size.userNumberFormat($CNEC_NO_DECIMALS);
		iter := array.createIterator;
		count :=  0;
		lastCommit := app.relativeMachineTime();
	
		beginTransaction;
		on Exception do self.tiEraseExceptionHandler(exception);
		while iter.next(dataDumpExtractHistory) do
//			if count mod 1000 = 0 then
			now := app.relativeMachineTime();
			if now - lastCommit &gt; MaxTransactionTime then
				lastCommit := app.relativeMachineTime();
				commitTransaction;		//Commit every 50 items
				self.monitor("DataDumpExtractHistory deleted: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
				if self.abortStatus = true then
					return;
				endif;
				beginTransaction;
			endif;
			if not process.isInTransactionState then
				beginTransaction;
			endif;
			dataDumpExtractHistory.erase(NORMAL_ERASE);
			if process.isInTransactionState then
				count := count + 1;
			endif;
		endwhile;
		commitTransaction;
		//abortTransaction;
		self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " DataDumpExtractHistory erased ");
		if self.abortStatus = true then
			return;
		endif;
	endforeach;
epilog
	delete iter;
	delete array;
	on Exception do null;

end;</source>
    </JadeMethod>
    <JadeMethod name="deleteDiscrepancies" id="001c48e8-4eab-40d7-9797-f045c237ac50">
        <updating/>
        <source>deleteDiscrepancies(_setTime : TimeStamp) updating;

constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	disc : CM_Discrepancy;
	iter : Iterator;
	size : String;
    dict, discArray : CM_DiscrepancyArray;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting Discrepancies..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
    create discArray transient;

	CM_TIDiscrepancy.allInstances(discArray,0,true); 
	size := discArray.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " Discrepancies for items to delete...");
	if self.abortStatus = true then
		return;
	endif;

	foreach disc in discArray do

		count := count + 1;
//		if count mod 10000  = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("Discrepancies checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". Discrepancies to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		if disc.date &lt; _setTime then
			dict.add(disc);
		elseif not global.isValidObject(disc.CM_TIDiscrepancy.trackedItem) or disc.CM_TIDiscrepancy.trackedItem = null then
			dict.add(disc);
		endif;
	endforeach;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;
	lastCommit := app.relativeMachineTime();

	beginTransaction;
	on Exception do self.tiEraseExceptionHandler(exception);
	while iter.next(disc) do
//		if count mod 1000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//commit every 1000 items
			self.monitor("Erased Discrepancies: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
//		app.writeLog("Deleting "&amp;disc.userNumberFormat($CNEC_NO_DECIMALS)&amp;" "&amp;disc.String,0); 
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		disc.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " Discrepancies erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete iter;
	delete dict;
	on Exception do null;
	delete discArray;
end;</source>
        <Parameter name="_setTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="deleteEventTransactions" id="82dc9a71-1db4-46f8-8027-7df953d36bdc">
        <updating/>
        <source>deleteEventTransactions(_setTime : TimeStamp) updating;

constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	eventTransaction : CM_EventTransaction;
	iter : Iterator;
	size : String;
    dict, objArray : ObjectArray;
    obj: Object;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting eventTransaction..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
    create objArray transient;

	CM_EventTransaction.allInstances(objArray,0,true); 
	size := objArray.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " eventTransaction for items to delete...");
	if self.abortStatus = true then
		return;
	endif;

	foreach obj in objArray do
		eventTransaction := obj.CM_EventTransaction;
		count := count + 1;
//		if count mod 100000  = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("eventTransaction checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". eventTransaction to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		if eventTransaction.createdTime = null then
			dict.add(eventTransaction);
		elseif eventTransaction.createdTime &lt; _setTime then			//No point in checking further
			dict.add(eventTransaction);
		endif;
	endforeach;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;
	lastCommit := app.relativeMachineTime();

	beginTransaction;
	on Exception do self.tiEraseExceptionHandler(exception);
	while iter.next(eventTransaction) do
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//commit every 1000 items
			self.monitor("Erased eventTransaction: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
//		app.writeLog("Deleting "&amp;vehicleVisitRecord.String&amp;" "&amp;vehicleVisitRecord.String,0); 
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		eventTransaction.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	if process.isInTransactionState then
		commitTransaction;
	endif;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " eventTransaction erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete dict;
	on Exception do null;
	delete objArray;
	delete iter;			// PAR #26678
end;</source>
        <Parameter name="_setTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="deleteGarbageTIs" id="c0322d7a-e076-4115-a883-d55d77b503d2">
        <updating/>
        <source>deleteGarbageTIs(_setTime : TimeStamp; _flags : Integer) updating;

constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count,number : Integer;
	iter : Iterator;
	size : Integer;
	ti,child : CM_TrackedItem;
    dict, tiArray : CM_TIArray;
    eraseOffsite, eraseDeleted, eraseOnship : Boolean;
	nullVoy: CM_Voyage;
	snapShot: CM_SnapShot;
	children : CM_TISet;//PAR 22954
	bank : CM_Bank;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	bank := CM_Bank.firstInstance;
	self.monitor(method.name&amp;' '&amp;"Getting TIs..."); 
	if self.abortStatus = true then
		return;
	endif;

	if _flags.bitAnd(ERASE_OFFSITE) &gt; 0 then
		eraseOffsite := true;
	endif;

	if _flags.bitAnd(ERASE_DELETED) &gt; 0 then
		eraseDeleted := true;
	endif;

	if _flags.bitAnd(ERASE_ONSHIP) &gt; 0 then
		eraseOnship := true;
	endif;

	create dict transient;
    create tiArray transient;

	CM_TrackedItem.allInstances(tiArray,0,true); 
	size := tiArray.size;
	if self.abortStatus = true then
		return;
	endif;
	
	create children transient;
	
	count := 0;
	lastCommit := app.relativeMachineTime();
	beginTransaction;
	foreach ti in tiArray do
//		break;
//		if ti.hazards &lt;&gt; null then
//			delete ti.hazards;
//			ti.hazards := null;
//		endif;
		count := count + 1;
//		if count mod 1000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//Commit every 50 items
			self.monitor("Checking for invalid voyages: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
		if not global.isValidObject(ti.companyOid) then
			ti.setPropertyValue("companyOid", bank);
		endif;
		if not global.isValidObject(ti.myTerminal) then
			ti.setPropertyValue("myTerminal", null);
		endif;
		if not global.isValidObject(ti.myVoyage) then
			if ti.state &lt;&gt; TI_STATE_ONSHIP and
			   ti.state &lt;&gt; TI_STATE_EDI then
				   if ti.myTerminal &lt;&gt; null then
						nullVoy := ti.myTerminal.getNullVoyage();
						if nullVoy &lt;&gt; null then
						//ti.getAllChildren(children);//PAR 22954
						//foreach child in children do//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
						foreach child in ti.allChildren do
							child.setMyVoyage(nullVoy, app.myPassport);
						endforeach;
						ti.setMyVoyage(nullVoy, app.myPassport);
					endif;
				endif;
				if not ti.isKindOf(CM_TILC) then
					ti.changeState(TI_STATE_DELETED, app.myPassport);
					number := number + 1;
				endif;
			endif;
		endif;
		ti.snapShots.rebuild;
	endforeach;
	commitTransaction;
	self.monitor("Fixed " &amp; number.userNumberFormat($CNEC_NO_DECIMALS) &amp; " TIs with invalid voyages...");

	count := 0;
	self.monitor("Checking " &amp; size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " TIs for items to delete...");
	if self.abortStatus = true then
		return;
	endif;
	lastCommit := app.relativeMachineTime();

	dict.clear;
	foreach ti in tiArray do
		count := count + 1;
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("TIs checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size.userNumberFormat($CNEC_NO_DECIMALS)
				&amp; ". TIs to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;
		if ti.myTerminal = null or 
		   not global.isValidObject(ti.myTerminal) then
			dict.add(ti);
			continue;
		endif;
		if not ti.isChild then
			if ti.state = TI_STATE_DELETED then
				if eraseDeleted and ti.deletedDT &lt; _setTime then
					dict.add(ti);
				endif;
			elseif ti.site = TI_SITE_OFFSITE then
				if eraseOffsite and ti.releasedDT &lt; _setTime then
					dict.add(ti);
				endif;
			elseif ti.state = TI_STATE_ONSHIP or
			       ti.state = TI_STATE_EDI then
				if eraseOnship then
				   	nullVoy := ti.myTerminal.getNullVoyage();
					if ti.myVoyage = nullVoy then
						dict.add(ti);
					elseif ti.myVoyage = null then
						dict.add(ti);
					elseif not global.isValidObject(ti.myVoyage) then
						dict.add(ti);
					endif;
				endif;
			endif;
		endif;
//		if dict.size &gt; 1000 then
//			break;		//Debug !!!
//		endif;
	endforeach;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size;
	iter := dict.createIterator;
	count :=  0;

	lastCommit := app.relativeMachineTime();
	beginTransaction;
	on Exception do self.tiEraseExceptionHandler(exception);
	while iter.next(ti) do
//		if count mod 1000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//Commit every 50 items
			self.monitor("Erased TIs deleted: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
		if global.isValidObject(ti) then
			if not process.isInTransactionState then
				beginTransaction;
			endif;
			ti.erase(NORMAL_ERASE);
			commitTransaction;
			beginTransaction;
			if global.isValidObject(ti) then
				if global.isValidObject(ti) then
					self.monitor("Erase of "&amp;ti.id&amp;' '&amp;ti.String&amp;' failed.');
			if self.abortStatus = true then
				commitTransaction;
				return;
			endif;
				endif;
			endif;
		endif;
		self.btnStop.doWindowEvents(0);			//Check the cancel button
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	tiArray.clear;
	CM_TrackedItem.allInstances(tiArray,0,true); 
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " TI's were to be erased, and erased "&amp;(size-tiArray.size).userNumberFormat($CNEC_NO_DECIMALS));
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete iter;
	delete dict;
	delete tiArray;
	delete children;//PAR 22954
	on Exception do null;
end;</source>
        <Parameter name="_setTime" type="TimeStamp"/>
        <Parameter name="_flags" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="deleteInfoEDISent" id="40ed7f2e-a28f-46c0-8174-c67567637d52">
        <updating/>
        <source>deleteInfoEDISent(_setTime : TimeStamp) updating;

constants
	MaxTransactionTime = 20000;	// 20 seconds
vars
	lastCommit : Decimal[20];
	now : Decimal[20];
	count : Integer;
	infoEDISent : CM_InfoEDISent;
	iter : Iterator;
	size : String;
    dict, objArray : ObjectArray;
    obj: Object;
begin
	lastCommit := app.relativeMachineTime();
	app.myPassport.clearErrorsWarnings();
	self.monitor(method.name&amp;' '&amp;"Getting infoEDISent..."); 
	if self.abortStatus = true then
		return;
	endif;

	create dict transient;
    create objArray transient;

	CM_InfoEDISent.allInstances(objArray,0,true); 
	size := objArray.size.userNumberFormat($CNEC_NO_DECIMALS);
	count := 0;
	self.monitor("Checking " &amp; size &amp; " infoEDISent for items to delete...");
	if self.abortStatus = true then
		return;
	endif;

	foreach obj in objArray do
		infoEDISent := obj.CM_InfoEDISent;
		count := count + 1;
//		if count mod 100000  = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			self.monitor("infoEDISent checked: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size
				&amp; ". infoEDISent to erase: " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS));
			if self.abortStatus = true then
				return;							//Exits here can just go straight back
			endif;
		endif;

		if infoEDISent.dateTime = null then
			dict.add(infoEDISent);
		elseif infoEDISent.dateTime &lt; _setTime then			//No point in checking further
			dict.add(infoEDISent);
		endif;
	endforeach;

	self.monitor("There are " &amp; dict.size.userNumberFormat($CNEC_NO_DECIMALS) &amp; " items to delete"); 
	if self.abortStatus = true then
		return;
	endif;

	size := dict.size.userNumberFormat($CNEC_NO_DECIMALS);
	iter := dict.createIterator;
	count :=  0;

	lastCommit := app.relativeMachineTime();
	beginTransaction;
	on Exception do self.tiEraseExceptionHandler(exception);
	while iter.next(infoEDISent) do
//		if count mod 10000 = 0 then
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			lastCommit := app.relativeMachineTime();
			commitTransaction;		//commit every 1000 items
			self.monitor("Erased infoEDISent: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " of " &amp; size);
			if self.abortStatus = true then
				return;
			endif;
			beginTransaction;
		endif;
//		app.writeLog("Deleting "&amp;infoEDISent.String&amp;" "&amp;infoEDISent.String,0); 
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		infoEDISent.erase(NORMAL_ERASE);
		if process.isInTransactionState then
			count := count + 1;
		endif;
	endwhile;
	commitTransaction;
	//abortTransaction;
	self.monitor("Task Complete: " &amp; count.userNumberFormat($CNEC_NO_DECIMALS) &amp; " infoEDISent erased ");
	if self.abortStatus = true then
		return;
	endif;
epilog
	delete dict;
	on Exception do null;
	delete objArray;
	delete iter;			// PAR #26678
end;</source>
        <Parameter name="_setTime" type="TimeStamp"/>
    </JadeMethod>
