    <JadeMethod name="setIsRotatedByPixels" id="bcd7206b-9226-4b82-bc47-da558786b57e">
        <updating/>
        <source>setIsRotatedByPixels() updating;
/*
Purpose:			
Date		Who		Reason
21 April 2011	cnwab1	Initial creation
*/

vars
	x1,x2,y1, y2, lenW, lenH : Integer;
begin
	x1 := self.myLayout.myPolygonPixels[1].x;
	x2 := self.myLayout.myPolygonPixels[2].x;
	y1 := self.myLayout.myPolygonPixels[2].y;
	y2 := self.myLayout.myPolygonPixels[3].y;
	
	lenW := x2 - x1;
	lenH := y2-y1;
		
	if (lenH &gt; lenW) then // higher than the width
		if self.isOOTLLocn then
			self.orientation := ROROLocn_OOTL_PS;
		else
			self.orientation := ROROLocn_PortStarboard;
		endif;
	else
		if self.isOOTLLocn then
			self.orientation := ROROLocn_OOTL_AF;
		else
			self.orientation := ROROLocn_AftForward;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setItemsAndSplit" id="d71e7c0b-0948-45fc-b7fe-41cff456f7d4">
        <source>setItemsAndSplit(_grouping : String; _items, _split : Integer output) : Boolean;
/*
Purpose:		CCMS 1009 28479	
Date		Who		Reason
31 October 2011	cnwab1	Initial creation
*/
//07 Jan 2013	cnwrs1	Par 30863	EDI RORO Deck Plan and Stowage Advice rotation 1X1
vars

begin
	if _grouping = "1X1" then
		_items := 1;
		_split := 1;
		return true;
	elseif _grouping = "1X3" then
		_items := 3;
		_split := 1;
		return true;
	elseif _grouping = "2X3" then
		_items := 6;
		_split := 2;
		return true;
	elseif _grouping = "1X5" then
		_items := 5;
		_split := 1;
		return true;
	elseif _grouping = "2X5" then
		_items := 10;
		_split := 2;
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_grouping" type="String"/>
