    </JadeMethod>
    <JadeMethod name="setProxyWorkOrderTasks" id="922c08c2-c4e5-4ccd-9ac9-472c4d7874b0">
        <source>setProxyWorkOrderTasks(	_listObject 			  : Object; 
						_listIndex 				  : Integer; 
						_workOrder 				  : CM_WorkOrder;
						_reqByDT, 
						_startDT 				  : TimeStamp;
						_autoQueueTask 			  : Boolean;
						_forUpdate 				  : Boolean;
						_createSupplimentaryToDos : Boolean;
						_workOrderMode 			  : Integer				// TFS 38560
						);

/*

Purpose:			Creates and sets the proxy work order tasks

Parameters:			

Return Value:		


Date		Who		Reason
24/08/2009	cnwmd1	Initial creation
07/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
18/05/2018	jlgdap1	TFS 38560 Voyage Work Orders
29/09/2021  navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
24/01/2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	pxyWODtl 		  : CM_WorkOrderDtl;
	task 			  : CM_ToDoTaskDesc;
	usesWorkOrderTIID : Boolean;
	taskId 	 		  : Integer;
	
begin

	task := self.getToDoTask(_listObject, _listIndex, usesWorkOrderTIID, taskId);
	
	if usesWorkOrderTIID then
		if _createSupplimentaryToDos then
			create pxyWODtl as CM_WodMove transient;
			_workOrder.setProxyWorkOrderTask(pxyWODtl, _reqByDT, _startDT,_autoQueueTask,  taskId, task);			//24.01.2023 navma1 #56141 Task#56147
		endif;
		
		create pxyWODtl as CM_WodToDo transient;
		_workOrder.setProxyWorkOrderTask( pxyWODtl, _reqByDT, _startDT, _autoQueueTask,taskId, task);				//24.01.2023 navma1 #56141 Task#56147
		
		if _createSupplimentaryToDos then
			create pxyWODtl as CM_WodMove transient;
			_workOrder.setProxyWorkOrderTask(pxyWODtl, _reqByDT, _startDT, _autoQueueTask, taskId, task);			//24.01.2023 navma1 #56141 Task#56147
		endif;
	else//Either Move/Pack/Unpack
		if _workOrderMode = WorkOrderMode_Cargo then
			if taskId = WO_TASK_MOVE then
				create pxyWODtl as CM_WodMove transient;
				_workOrder.setProxyWorkOrderTask(pxyWODtl, _reqByDT, _startDT,_autoQueueTask, taskId, task);						//24.01.2023 navma1 #56141 Task#56147
			elseif taskId = WO_TASK_PACK then
				if _workOrder.hasPackTask() then
					// only 1 per work order
					app.msgBox(app.getErrorString1(Work_order_already_task, 'Pack'), "Task Warning", MsgBox_OK_Only);				//29.09.2021 navma1 #51925 Pending
				elseif _workOrder.hasUnpackTask() then
					app.msgBox(app.getErrorString1(Work_order_already_task, 'Unpack'), "Task Warning", MsgBox_OK_Only);				//29.09.2021 navma1 #51925 Pending
				else
					create pxyWODtl as CM_WodPack transient;
					_workOrder.setProxyWorkOrderTask(pxyWODtl, _reqByDT, _startDT, _autoQueueTask, taskId, task);					//24.01.2023 navma1 #56141 Task#56147
				endif;
			elseif taskId = WO_TASK_UNPACK then
				if _workOrder.hasUnpackTask() then
					// only 1 per work order
					app.msgBox(app.getErrorString1(Work_order_already_task, 'Unpack'), "Task Warning", MsgBox_OK_Only);				//29.09.2021 navma1 #51925 Pending
				elseif _workOrder.hasPackTask() then
					app.msgBox(app.getErrorString1(Work_order_already_task, 'Pack'), "Task Warning", MsgBox_OK_Only);				//29.09.2021 navma1 #51925 Pending				
				else
					create pxyWODtl as CM_WodUnpack transient;
					_workOrder.setProxyWorkOrderTask(pxyWODtl, _reqByDT, _startDT,_autoQueueTask,  taskId, task);
				endif;
				
			elseif taskId = WO_TASK_EXPORTRETURN then																				// TFS 38501
				create pxyWODtl as CM_WodExportReturn transient;																	// TFS 38501
				_workOrder.setProxyWorkOrderTask(pxyWODtl, _reqByDT, _startDT, _autoQueueTask, taskId, task);						// TFS 38501
			elseif taskId = WO_TASK_CHANGEVOYAGE then																				// TFS 38501
				create pxyWODtl as CM_WodNullVoyage transient;																		// TFS 38501
				_workOrder.setProxyWorkOrderTask(pxyWODtl, _reqByDT, _startDT, _autoQueueTask, taskId, task);						// TFS 38501
			elseif taskId = WO_TASK_RECEIVE then																					// TFS 38501
				create pxyWODtl as CM_WodReceive transient;																			// TFS 38501
				_workOrder.setProxyWorkOrderTask(pxyWODtl, _reqByDT, _startDT, _autoQueueTask, taskId, task);						// TFS 38501
			elseif taskId = WO_TASK_RELEASE then																					// TFS 38501
				create pxyWODtl as CM_WodRelease transient;																			// TFS 38501
				_workOrder.setProxyWorkOrderTask(pxyWODtl, _reqByDT, _startDT, _autoQueueTask, taskId, task);						// TFS 38501
			elseif taskId = WO_TASK_RELEASEEXTENSION then	//12 Mar 2019	NDL	TFS 43405																			
				create pxyWODtl as CM_WodReleaseExtension transient;																			
				_workOrder.setProxyWorkOrderTask(pxyWODtl, _reqByDT, _startDT, _autoQueueTask, taskId, task);
			else
				app.raiseUnexpectedProgramError(self.class.name, method.name, "Unexpected Task Type");
			endif;
		
		// TFS 38560 Voyage Work Orders
		elseif _workOrderMode = WorkOrderMode_Voyage then
			if taskId = WO_TASK_SHIFTMOVEMENT then
				create pxyWODtl as CM_WodShiftMovement transient;
				_workOrder.setProxyWorkOrderTask(pxyWODtl, _reqByDT, _startDT, _autoQueueTask, taskId, task);
			elseif taskId = WO_TASK_CARGOREQUEST then
				create pxyWODtl as CM_WodCargoRequest transient;
				_workOrder.setProxyWorkOrderTask(pxyWODtl, _reqByDT, _startDT, _autoQueueTask, taskId, task);
			elseif taskId = WO_TASK_TIMECHANGE then
				create pxyWODtl as CM_WodTimeChange transient;
				_workOrder.setProxyWorkOrderTask(pxyWODtl, _reqByDT, _startDT, _autoQueueTask, taskId, task);
			elseif taskId = WO_TASK_EXTENSION then
				create pxyWODtl as CM_WodExtension transient;
				_workOrder.setProxyWorkOrderTask(pxyWODtl, _reqByDT, _startDT, _autoQueueTask, taskId, task);
			elseif taskId = WO_TASK_WATER then
				create pxyWODtl as CM_WodWaterRequest transient;
				_workOrder.setProxyWorkOrderTask(pxyWODtl, _reqByDT, _startDT, _autoQueueTask, taskId, task );
			elseif taskId = WO_TASK_HMSCANCEL then
				create pxyWODtl as CM_WodHMSRequestCancel transient;
				_workOrder.setProxyWorkOrderTask(pxyWODtl, _reqByDT, _startDT, _autoQueueTask, taskId, task );
			else
				app.raiseUnexpectedProgramError(self.class.name, method.name, "Unexpected Task Type");
			endif;
		else
			app.raiseUnexpectedProgramError(self.class.name, method.name, "Unexpected Work Order Mode");
		endif;
		// TFS 38560 end
	endif;
	
epilog

end;</source>
        <Parameter name="_listObject" type="Object"/>
        <Parameter name="_listIndex" type="Integer"/>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
        <Parameter name="_reqByDT" type="TimeStamp"/>
        <Parameter name="_startDT" type="TimeStamp"/>
        <Parameter name="_autoQueueTask" type="Boolean"/>
        <Parameter name="_forUpdate" type="Boolean"/>
        <Parameter name="_createSupplimentaryToDos" type="Boolean"/>
        <Parameter name="_workOrderMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSourceLocns" id="4ead163a-4d97-4e84-bb01-dfc0d01dc54b">
        <source>setSourceLocns(_table : CM_EntryTable input; _srcLocnCmb : ComboBox input; _operator : CM_Operator);
// -----------------------------------------------------------------------------
// Created:		12 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	tmpCodeGroup : CM_CodesByCodeDict;
begin
	if _operator &lt;&gt; null then
		tmpCodeGroup := _operator.getAllSrcLocn();
	endif;

	_table.setValueByControlName(_srcLocnCmb.name, null);
	self.comboBoxSrcLocn(_srcLocnCmb, null, tmpCodeGroup);

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
