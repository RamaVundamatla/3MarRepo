/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwdap1	Initial creation

*/

vars
	labelLeft	: Real;

begin
	// text boxes are all invisible, so can be ignored
	// put button on the right hand side, check box on the left hand side, 
	// and stretch the label to fit in between these two
	self.btnIsOverDim.move(_fieldGeneric.width-self.btnIsOverDim.width, 0, self.btnIsOverDim.width, _fieldGeneric.height);
	self.chkIsOverDim.move(_fieldGeneric.myLabel.width + _fieldGeneric.HORIZONTAL_SPACING, 2, 21, self.chkIsOverDim.height);
	labelLeft := self.chkIsOverDim.left + self.chkIsOverDim.width + _fieldGeneric.HORIZONTAL_SPACING - 5;
	self.lblIsOverDim.move(labelLeft, 0, self.btnIsOverDim.left - labelLeft - 5, _fieldGeneric.height);
	self.lblIsOverDim.borderStyle := self.lblIsOverDim.BorderStyle_None;
	self.lblIsOverDim.alignment := self.lblIsOverDim.Alignment_Right_Middle;
epilog

end;</source>
