    <JadeMethod name="unload" id="c177faf5-cf87-4a99-86f7-d7660cae1137">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();

//	delete self.myCurrentDrawingController;
//	self.allDockBars.purge;

	self.clearupMenuParams();
	
	if self.clearupSelectorQuery then
		if self.mySelectorEnquiryController &lt;&gt; null then
			delete self.mySelectorEnquiryController.allObjects;
			delete self.mySelectorEnquiryController.myCriteriaLineHolder;
		endif;
		delete self.mySelectorEnquiryController;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="900ee04a-5119-4d36-8609-be5e3e23090f">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin

	if eventType = EVENT_CODE_COLOUR_CHANGE then
		self.frmColLegendTIs.redisplayViewModeCodes();
		// need to redraw to update colours of displayed TIs
		self.redraw();
		return;
	endif;
	
	if eventType = EVENT_DrawingAttrControllerAdd then
//		self.frmColLegendTIs.addRow();
	endif;

	inheritMethod(eventType, theObject, eventTag, userInfo);

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="viewForMode" id="b470002b-9765-44af-adab-ddae5e342675">
        <updating/>
        <source>viewForMode(_theIndex : Integer; _redraw : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 September 2003 by cnwrs2
//
// Purpose:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	ydc : YRD_ContainerDrawingController;
	anObj : Object;
	oldYDCMode : Integer;
begin

	if _theIndex &lt;= VIEW_TEMPERATURE or 
	   _theIndex = VIEW_WEIGHT or 
	   _theIndex = VIEW_TRAIN or 
	   _theIndex = VIEW_DESTPORT or 
	   _theIndex = VIEW_LOADPORT or 
	   _theIndex = VIEW_DWELL_DAYS or	//20 Jul 2011	NDL	Par 27890
	   _theIndex = VIEW_MTGRADE	//29 Jul 2011	NDL	Par 27890
	   then

		self.enableCargoToolButtons(true);

		ydc := self.myCurrentDrawingController;
		if ydc.viewMode = _theIndex then
			return;
		endif;
		self.frmStatusLine.myFrameCaption.caption := ydc.setViewMode(_theIndex);
		
		if _redraw then // PAR 27005 noticed that it was drawing twice  on initial show - doQuery  calls this method and setDisplayMode, both call drawSelf
			ydc.drawSelf(false);
		endif;
		
		if _theIndex = VIEW_IMPORT or 
		   _theIndex = VIEW_EXPORT then
		else
			self.setCaptionForModesGetView(_theIndex);
			self.doNotesForLegendStartStop(_theIndex,ydc);
		endif;
				
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid _index (' &amp; _theIndex.String &amp; ')');
	endif;
	

end;</source>
        <access>protected</access>
        <Parameter name="_theIndex" type="Integer"/>
        <Parameter name="_redraw" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xmlToolbar" id="00e0add5-79aa-4e20-94f2-4bfabf466929">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>xmlToolbar(set: Boolean; _value: Boolean io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		This means HIDE the toolbars
//
// ---------------------------------------------------------------------------

vars

begin
	if set then
		if not _value then
			self.mnuGridHideToolbar.caption := self.MNU_TOOLBAR_HIDE;
			self.mnuWorkDisplayHideTB.caption := self.MNU_TOOLBAR_HIDE;
		else
			self.showHideToolbars(true);
			self.mnuGridHideToolbar.caption := self.MNU_TOOLBAR_SHOW;
			self.mnuWorkDisplayHideTB.caption := self.MNU_TOOLBAR_SHOW;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
</GUIClass>
