        <source>doBaseFormSave() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 August 2008	cnwrd1	Initial creation

*/

vars

begin

	if self.doSave() then
		self.allDamageInstancesByPos.purge();
		self.unloadForm();
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnDamageClick" id="1448ff24-8d4b-4da5-9298-4ce686d10a92">
