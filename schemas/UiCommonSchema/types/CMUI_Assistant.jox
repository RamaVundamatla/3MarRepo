    <JadeMethod name="displayEntryHazard" id="ce549110-cac8-457b-b80a-d6ea6d61d5bc">
        <source>displayEntryHazard(pHazard : CM_HazardClass; pSelected : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     31 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pHazard &lt;&gt; null then
		if pSelected then	  
			return TableCheckBox_Selected &amp; Tab &amp; pHazard.code &amp; Tab &amp; pHazard.description;  
		else	
