    <JadeMethod name="auditCreateTALocationsTrx" id="8faf0595-5ef2-4253-a0bd-6bf8a1cc54c4">
        <updating/>
        <source>auditCreateTALocationsTrx(_subject : CM_TerminalAreaMaster; 
						_locations :CM_LCSet; _locType, _locMode :Integer; _details :String) updating;
// ---------------------------------------------------------------------------
// Created:     02 March 2011 by cnwcs5 CCMS CPL 2027/PAR 27126
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	audit 		: CM_AuditObject;
	config		: CM_AuditConfig;
begin

	if self.auditDisabled or 
		_subject = null or 
		_subject.isTransient or 
		_subject.isKindOf(CM_AuditObject) then write _subject;
		return;
	endif;
	
	if not self.getAuditConfigForClass( _subject, _subject.class, config) then
return;
	endif;
	
	audit := self.createAuditTALocation(_subject, AuditCreated, config, _locations, _locType, _locMode, _details);
end;</source>
        <Parameter name="_subject" type="CM_TerminalAreaMaster"/>
        <Parameter name="_locations" type="CM_LCSet"/>
        <Parameter name="_locType" type="Integer"/>
        <Parameter name="_locMode" type="Integer"/>
        <Parameter name="_details" type="String"/>
    </JadeMethod>
    <JadeMethod name="auditCreateTrx" id="766586c6-709d-4de9-adf8-ceb5faddaf36">
        <updating/>
        <source>auditCreateTrx(subject : CM_Object; auditText : String; _extraInfo : String) updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	anAudit 		: CM_AuditObject;
	tmpAuditConfig	: CM_AuditConfig;
	doProcess 		: Boolean;

begin

	if self.auditDisabled or
	   auditText = null or
	   subject = null or subject.isTransient or subject.isKindOf(CM_AuditObject)
	then
		return;
	endif;
	
	if not self.getAuditConfigForClass( subject, subject.class, tmpAuditConfig) then
		return;
	endif;
	
	if isBackGroundProcess then
		createAuditRequest(subject, auditText, null, null, BGP_AuditRequest.Create, _extraInfo);
		return;
	else
		anAudit := self.createAuditObject(subject, AuditCreated, tmpAuditConfig, _extraInfo);
		anAudit.setAuditText(auditText);
		anAudit.setPostAuditText(null);
	endif;

end;</source>
        <Parameter name="subject" type="CM_Object"/>
        <Parameter name="auditText" type="String"/>
        <Parameter name="_extraInfo" type="String"/>
    </JadeMethod>
    <JadeMethod name="auditDeleteTrx" id="9999b56b-cc2a-4c2d-ad85-848bbfe8261f">
        <updating/>
        <source>auditDeleteTrx(subject : CM_Object; auditText : String; _extraInfo : String) updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	anAudit 		: CM_AuditObject;
	tmpAuditConfig	: CM_AuditConfig;

begin
	if self.auditDisabled or
	   auditText = null or
	   subject = null or subject.isTransient or subject.isKindOf(CM_AuditObject)
	then
		return;
	endif;
	
	if not self.getAuditConfigForClass( subject, subject.class, tmpAuditConfig) then
		return;
	endif;
	
	if isBackGroundProcess then
		self.createAuditRequest(subject, auditText, null, null, BGP_AuditRequest.Delete, _extraInfo);
		return;
	else
		anAudit := self.createAuditObject(subject, AuditDeleted, tmpAuditConfig, _extraInfo);
		anAudit.setAuditText(auditText);
		anAudit.setPostAuditText(null);
	endif;
end;</source>
