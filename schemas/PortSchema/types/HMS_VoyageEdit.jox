<Class name="HMS_VoyageEdit" id="f4e9532f-16fe-4be4-ab8f-6e5c438f1b6b">
    <superclass name="HMS_Transaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="hmsTrans"/>
    <JadeMethod name="createPropertyChanges" id="0975ffce-e1f3-4995-b987-9c97281e7003">
        <updating/>
        <source>createPropertyChanges(_cmifTrans: CMIF_HMS_TransactionController) updating, protected;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	workingVoyage : CMIF_HMS_WorkingVoyage;
 	tmpProxy : HMS_Object;
begin
	inheritMethod(_cmifTrans);
	workingVoyage := _cmifTrans.myWorkingVoyage;
	tmpProxy := _cmifTrans.myProxyHMSObject;
	if workingVoyage &lt;&gt; null then
		self.myHMSVoyageData.createPropertyChanges(self, workingVoyage);
	elseif HMS_VoyageData.hasInstance(tmpProxy) then
		self.myHMSVoyageData.createPropertyChangesFromProxy(self, tmpProxy.HMS_VoyageData);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifTrans" type="CMIF_HMS_TransactionController"/>
    </JadeMethod>
    <JadeMethod name="setTypeDetails" id="200cd5fe-fa88-46a7-9693-a789b16d32ee">
        <updating/>
        <source>setTypeDetails() updating, protected;
//--------------------------------------------------------------
//Created: 25 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
  	// Set type and typeString
	type:=TRANS_TYPE_HMSVoyageEdit;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validate" id="a826c932-a9bd-4291-8cfc-8b414314bb83">
        <source>validate(_transController: CMIF_HMS_TransactionController): Boolean;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	rtnValue : Boolean;
begin
	rtnValue := inheritMethod(_transController);
	if (not rtnValue) then
		return rtnValue;
	endif;
	
	if _transController.myWorkingVoyage = null
	and _transController.myProxyHMSObject = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'Voyage', 'Null', null, null);
		return false;
	endif;
	return rtnValue;		
end;</source>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
