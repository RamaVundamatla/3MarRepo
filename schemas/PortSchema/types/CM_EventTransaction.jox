    <JadeMethod name="getDescription" id="ec5aa401-9630-4cc7-b6f0-0489b1341542">
        <source>getDescription(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2009	cnwndl1	Initial creation

*/

vars
	mess : String;
begin
 // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	if self.myEventType &lt;&gt; null then
		mess :=  self.myEventType.description;
	endif;
	if self.myToDoTask &lt;&gt; null then
		mess := mess &amp; " (" &amp; app.getErrorString(Todo_task) &amp; " - " &amp;  self.myToDoTask.toDoTaskDescDesc &amp; ")";
	endif;
	return mess;
epilog

end;</source>
        <ReturnType type="String"/>
