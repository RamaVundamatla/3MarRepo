    <JadeMethod name="btnConflicts_click" id="d2fdbb2f-b6a3-4494-8525-d0c67d0bebdb">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnConflicts_click(btn: Button input) updating;
//--------------------------------------------------
// Created:	13 October 2005 By: cnwgd1
//--------------------------------------------------
vars

	conflictManager : CMIF_HMS_ConflictsManager;
begin
	//epr par 16420
	create conflictManager transient; 
	//will get deleted by the unload of the conflicts report form
	
	conflictManager.fromDT.setDate(self.tblSearch.getValueAsDate(ETRow_FromDate));
	conflictManager.fromDT.setTime(self.tblSearch.getValueByName(ETRow_FromTime).Time);
	conflictManager.endDT.setDate(self.tblSearch.getValueAsDate(ETRow_ToDate));
	conflictManager.endDT.setTime(self.tblSearch.getValueByName(ETRow_ToTime).Time);

	self.myAssistant.showConflictsReport(conflictManager, self.myTerminal, self.myHarbour);
end;</source>
