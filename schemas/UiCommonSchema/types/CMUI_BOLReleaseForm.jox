    <JadeMethod name="create" id="c808e631-fec1-4e83-9bf6-3338ee1a4fc1">
        <updating/>
        <source>create() updating;
//-----------------------------------------
// Created: February 2006 By: cnwgd1
//-----------------------------------------
begin
	self.permissionView  := PmGCReleaseEnqView;
	self.permissionMaint := PmGCReleaseEnqMaint; // TFS 2734
	self.helpFileName := HelpFile_GeneralCargo;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayBulkReleasesForBOL" id="9babc1a5-6097-45a5-be34-ea2c1b9f7533">
        <updating/>
        <source>displayBulkReleasesForBOL() updating;
//--------------------------------------------------
// Created:	7 April 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpRelease : CM_BulkRelease;
	tmpTI : CM_TrackedItem;
	bulkRel : CM_BulkRelease; // cnwrd1 26.5.09 ccms 1804
begin

	self.tblReleases.rows := self.tblReleases.fixedRows;
	self.tblReleases.clearAllSelected();

	if self.myCurrentBOL = null then
		return;
	endif;
	
	foreach tmpTI in self.myCurrentBOL.allTrackedItems do
		bulkRel := tmpTI.allBulkReleasesReleased.first;// cnwrd1 26.5.09 ccms 1804
		if bulkRel &lt;&gt; null then
			self.addReleaseToTable(bulkRel);
		endif;
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="displayBulkReleasesForVoyage" id="1e5587f4-e765-4bb4-b0b3-037488252bde">
        <updating/>
        <source>displayBulkReleasesForVoyage() updating;
//--------------------------------------------------
// Created:	7 April 2006 By: cnwgd1
//--------------------------------------------------
vars
	release 	: CM_BulkRelease;
	ti			: CM_TrackedItem;
	dict 		: CM_TIByCargoTypeIdRelseDict;
	releaseSet	: CM_BulkReleaseSet;
	tbl			: CM_DataTable;
	rowStr		: String;
begin
	tbl := self.tblReleases;
	tbl.rows := tbl.fixedRows;
	tbl.clearAllSelected();
	if self.myCurrentVoyage = null then
		return;
	endif;
	
	//tmpDict := self.myCurrentVoyage.allBulkReleases;
	dict := self.myCurrentVoyage.allOffsiteTIsByCargoTypeId;
	create releaseSet transient;
	
	foreach ti in dict discreteLock do
		//release := ti.myBulkReleaseReleased;// cnwrd1 26.5.09 ccms 1804
		release := ti.allBulkReleasesReleased.first; // cnwrd1 26.5.09 ccms 1804
		if release = null or releaseSet.includes(release) then
			continue;
		endif;
		releaseSet.add(release);
		rowStr := release.getAttributeStringForDefArray(tbl.allTblDataEntRows);
		tbl.accessRow(tbl.addItem(rowStr)).itemObject := release;
		self.addNotableObject(release);

		if release.status &lt;&gt; BR_COMPLETE then
			tbl.accessedRow.backColor := Gray;
		endif;
	endforeach;
	
epilog
	delete releaseSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayTableDataRowColour" id="9df3a895-911a-4a33-87ef-02adf1457388">
        <source>displayTableDataRowColour();

// 12/2/2009 cnwsh3 PAR18889 CCMS SFW1039 Changed to colour code cargo attached to a BOLs with stops.
vars
	obj 		: Object;
	theBackColour,
	numRows,
	row			: Integer;
	tmpTI 		: CM_TrackedItem;
	tbl			: CM_DataTable;

begin
	//th2 removed mad GD code- replaced with good code
	tbl := self.tblData;
	numRows := tbl.rows;

	foreach row in tbl.fixedRows + 1 to numRows do
		theBackColour := null;
		obj := tbl.accessRow(row).itemObject;
		if CM_TrackedItem.hasInstance(obj) then
			tmpTI := obj.CM_TrackedItem;
			if tmpTI.site = TI_SITE_OFFSITE then
				theBackColour := Gray;
			elseif tmpTI.hasStops or tmpTI.hasBOLStops or tmpTI.hasChildStops or tmpTI.hasChildBOLStops or tmpTI.hasCargoGroupStops then //PAR18889 CCMS SFW1039 Also highlight if there are stops on the BOL.		//cnwmc5 - 2 May 2014 - PAR 34074
				theBackColour := Red;
			elseif tmpTI.site &lt;&gt; TI_SITE_ONSITE then
				theBackColour := LightBlue;		
			endif;
		endif;
		
		if theBackColour = null then
			if row mod 2 = 0 then
				theBackColour := self.colorRow1;
			else
				theBackColour := self.colorRow2;
			endif;
		endif;
		tbl.accessRow(row).backColor := theBackColour;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="displayTrackedItemsForBOL" id="3d68ab21-92e7-42ae-890d-078f6aa12618">
        <source>displayTrackedItemsForBOL();
//--------------------------------------------------
// Created:	10 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpUser : CM_User;
	tmpTI : CM_TrackedItem;
	obj : CM_Object;
	failedDAC  :CM_DataAccessController;
begin
	self.tblData.rows := self.tblData.fixedRows;
	self.tblData.clearAllSelected();
	
	tmpUser := app.myPassport.myUser;
	
	if self.myCurrentBOL &lt;&gt; null then
		foreach tmpTI in self.myCurrentBOL.allTrackedItemsOrig do
			if self.optViewUnrelease.value and tmpTI.site = TI_SITE_OFFSITE then
				continue;
			endif;
			
			if tmpTI.canUserAccessSelf(tmpUser, failedDAC, app.myPassport) then
				obj := tmpTI;
				self.addItemObjectToTable(obj, self.tblData);
			endif;
		endforeach;
	endif;

	self.displayTableDataRowColour();	
end;</source>
    </JadeMethod>
    <JadeMethod name="displayTrackedItemsForVoyage" id="e7420310-a866-45c2-9108-e1048114a4c5">
        <source>displayTrackedItemsForVoyage();
//--------------------------------------------------
// Created:	10 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpUser : CM_User;
	tmpTI : CM_TrackedItem;
	obj : CM_Object;
	qtyOnSite,
	qtyOnShip,
	qtyOffSite : Integer;
	failedDAC  :CM_DataAccessController;
begin
	self.tblData.rows := self.tblData.fixedRows;
	self.tblData.clearAllSelected();
	
	tmpUser := app.myPassport.myUser;
	
	if self.myCurrentVoyage &lt;&gt; null then
		foreach tmpTI in self.myCurrentVoyage.allOnsiteTIsByIdCargoType do
			qtyOnSite := qtyOnSite + tmpTI.totalQuantity;		
			if tmpTI.myTiMaster &lt;&gt; null then
			// don't show the split TIs
				continue;
			endif;
			if tmpTI.canUserAccessSelf(tmpUser, failedDAC, app.myPassport) then
				obj := tmpTI;
				self.addItemObjectToTable(obj, self.tblData);
			endif;
		endforeach;
		foreach tmpTI in self.myCurrentVoyage.allOnshipTIsByIdCargoType do
			qtyOnShip := qtyOnShip + tmpTI.totalQuantity;					
			if tmpTI.myTiMaster &lt;&gt; null then
				// don't show the split TIs
				continue;
			endif;		
			if tmpTI.canUserAccessSelf(tmpUser, failedDAC, app.myPassport) then
				obj := tmpTI;
				self.addItemObjectToTable(obj, self.tblData);
			endif;
		endforeach;
		if self.optViewAll.value then
			foreach tmpTI in self.myCurrentVoyage.allOffsiteTIsByIdCargoType do
				qtyOffSite := qtyOffSite + tmpTI.totalQuantity;					
				if tmpTI.myTiMaster &lt;&gt; null then
					// don't show the split TIs
					continue;
				endif;
				if tmpTI.canUserAccessSelf(tmpUser, failedDAC, app.myPassport) then
					obj := tmpTI;
					self.addItemObjectToTable(obj, self.tblData);
				endif;
			endforeach;
		endif;
	endif;

	self.txtTotalQty.text := (qtyOnShip + qtyOffSite + qtyOnSite).String;
	self.txtNumDelivered.text := qtyOffSite.String;
	self.txtNumRemaining.text := (qtyOnShip + qtyOnSite).String;						
	
	self.displayTableDataRowColour();	
end;</source>
    </JadeMethod>
    <JadeMethod name="doAddRelease" id="a6e0da03-7b9f-450e-bddd-9c1370775892">
        <source>doAddRelease(_obj : CM_Object);
//--------------------------------------------------
// Created:	10 February 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	if _obj &lt;&gt; null then
		self.myAssistant.showBOLReleaseEntryForm(_obj, self.myMasterMenuAction);
	elseif self.myCurrentBOL &lt;&gt; null then
		self.myAssistant.showBOLReleaseEntryForm(self.myCurrentBOL, self.myMasterMenuAction);	
	else
		self.myAssistant.showBOLReleaseEntryForm(self.myCurrentVoyage, self.myMasterMenuAction);	
	endif;
	
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
