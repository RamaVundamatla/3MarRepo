    <JadeMethod name="utlDeleteCountry" id="318ef70f-eda4-49e4-8ac2-c5a9c8527179">
        <source>utlDeleteCountry(pCountry:CM_Country io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	itemAudit : CM_UpdateTransactionAuditAgent;
	region	  : CM_CountryRegion;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valCountry(pCountry);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(pCountry);
		
		//03/08/2023	navkc1	CR 59552   Task 59554
		region := pCountry.myCountryRegion;
		if region &lt;&gt; null then
			create itemAudit transient;
			itemAudit.audUpdateGeneric(region, true);
		endif;
	endif;

	if _passport.noErrors then
		pCountry.erase(NORMAL_ERASE);
		if region &lt;&gt; null then
			itemAudit.audUpdateGeneric(region, false);
		endif;
	endif;

epilog
	delete itemAudit;
	return;

end;</source>
        <Parameter name="pCountry" type="CM_Country" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteCountryRegion" id="d157c1e1-d665-4e8a-83cd-18e9d5a31e35">
        <source>utlDeleteCountryRegion(_pCountryRegion : CM_CountryRegion io; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/08/2023	navkc1	CR 59552   Task 59554: Jade CustDocs - Country Region TRX

*/

vars
	itemAudit				: CM_UpdateTransactionAuditAgent;
	country					: CM_Country;
	allCountries			: CM_CountryByCodeDict;
	allAudits				: ObjectArray;
	index					: Integer;
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	
	app.myValDA.valCountryRegion(_pCountryRegion);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	create allAudits transient;
	create allCountries transient;
	
	_pCountryRegion.allCountries.copy(allCountries);
	
	foreach country in allCountries do
		create itemAudit transient;
		itemAudit.audUpdateGeneric(country, true);
		allAudits.add(itemAudit);
	endforeach;
	
	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_pCountryRegion);
		_pCountryRegion.erase(NORMAL_ERASE);
		
		foreach country in allCountries do
			index += 1;
			itemAudit := allAudits[index].CM_UpdateTransactionAuditAgent;
			itemAudit.audUpdateGeneric(country, false);
			delete itemAudit;
		endforeach;
	endif;
epilog
	delete allAudits;
	delete allCountries;
end;</source>
        <Parameter name="_pCountryRegion" type="CM_CountryRegion" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteCustDocDetail" id="1257f685-b309-4928-9d5f-63047b5e8c81">
        <source>utlDeleteCustDocDetail(_obj : CM_CustomDocumentDetail io; _passport : CM_Passport input);
// ##### CR 56094  TASK 59616 NAVAB1 08AUG2023
vars
	theTerminal : CM_Terminal;
	custDoc : CM_CustomDocument;
	ti		: CM_TrackedItem;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	// note that validation agent locks object
	app.myValDA.valCustDocDetail(_obj);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	if _passport.noErrors then
		// only requierd if class is audited
		self.myDeleteAuditAgent.audDeleteGeneric(_obj);
	endif;

	if _passport.noErrors then
		// This should be :
		//_obj.erase(NORMAL_ERASE);
		// but is as below so test exceptions can be generated.
		custDoc := _obj.myParentCustomDocument;
		theTerminal := custDoc.myTerminal;
		ti := _obj.myTrackedItem;	//23/02/2023	navkc1 CR 62580 Task 62581
		_obj.erase(NORMAL_ERASE);
		custDoc.causeEvent(theTerminal.getTerminalEvent(Event_CustDocDetailDelete), true, _obj);	
		ti.updateNoteForTransport();	//23/02/2023	navkc1 CR 62580 Task 62581
	endif;

end;</source>
        <Parameter name="_obj" type="CM_CustomDocumentDetail" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteCustDocHeader" id="dbb7d65b-0b6c-49f9-ad49-dadb7516ab1e">
