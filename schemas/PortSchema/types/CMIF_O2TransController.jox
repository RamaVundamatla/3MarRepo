    <JadeMethod name="setTransactionDetails" id="6e749173-16a4-43d2-bcbf-e3a5f807be1f">
        <updating/>
        <source>setTransactionDetails(_txn : CM_O2ReadingTransaction input) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/12/2025	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration

vars

