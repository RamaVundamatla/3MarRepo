    <JadeMethod name="cnwdad1_Test_Currency" id="05d7e4ec-e46c-4148-a49b-bef36cb05fc8">
        <source>cnwdad1_Test_Currency();
// -----------------------------------------------------------------------------
// Created:		29 September 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
constants
	VALUE_TO_CONVERT	: Real = 235.45;
	EXCHANGE_RATE		: Real = 83.25;
	
vars
	currencyObj	: CnEcCurrency;
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	create currencyObj transient;
	currencyObj.updateMe(VALUE_TO_CONVERT, EXCHANGE_RATE, null, null);
	write "Currency Conversion: $" &amp; currencyObj.amount.String &amp; " at the rate of " &amp; EXCHANGE_RATE.String &amp; ".";
	write currencyObj.getConvertedAmount();
epilog
	delete currencyObj;
	
	write "Currency conversion completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_CurrencyFormat" id="23e5c8a8-f3da-425a-8bff-c93940c50992">
        <source>cnwdad1_Test_CurrencyFormat();
// -----------------------------------------------------------------------------
// Created:		24 October 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
constants
	VALUE_TO_CONVERT	: Real = 15;
	
vars
	value		: Decimal[12,2];
	theFormat	: CurrencyFormat;
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	value		:=	12345678.91 * -1;
	
	create theFormat transient;
	
	theFormat.defineCurrencyFormat(	2,			// Decimal places (zero will cause decimal rounding)
									".",		// Decimal separator
									"***",		// Thousands separator
									CurrencyFormat.PosCurrLeadingSymbol,
									CurrencyFormat.NegCurrLeadingSignSymbol,
									true,
									"$");
	
	write value;
	write value.userCurrencyFormat(theFormat);
epilog
	delete theFormat;
	
	write "Currency format completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_CurrencyWords" id="edb8640b-fe2b-4c57-bf81-73848b9896c4">
        <source>cnwdad1_Test_CurrencyWords();
// -----------------------------------------------------------------------------
// Created:		14 November 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
constants
	VALUE_TO_CONVERT	: Real = 15;
	
vars
	currencyObj		: CnEcCurrency;
	wholeAmount		: String;
	decimalAmount	: String;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	
	create currencyObj transient;
	currencyObj.setAmount(1000.01);
	write "Currency to Words: $" &amp; currencyObj.amount.String;
	write currencyObj.amountInWords("Dollars", "Cents");
	currencyObj.setAmount(1000.10);
	write "Currency to Words: $" &amp; currencyObj.amount.String;
	write currencyObj.amountInWords("Dollars", "Cents");
epilog
	delete currencyObj;
	
	write "Currency words completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_Date" id="95c3db99-8daa-473c-8e13-b11b1d2d7ef7">
        <source>cnwdad1_Test_Date();
// -----------------------------------------------------------------------------
// Created:		29 September 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	dateObj		: CnEcDate;
	today		: Date;
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	
	write "Date Value";
	write "==========";
	create dateObj transient;
	dateObj.updateMe(today);
	write "Start Date   : " &amp; dateObj.dateClient.shortFormat();
	dateObj.addMonths(6);
	write "Plus 6 months: " &amp; dateObj.dateClient.shortFormat();
	
	write CrLf &amp; "Primitive:";
	write today.String &amp; " + 5 days is " &amp; today.cnEcAddDays(5).String;
	write today.String &amp; " - 5 days is " &amp; today.cnEcAddDays(-5).String;
	write today.String &amp; " + 5 months is " &amp; today.cnEcAddMonths(5).String;
	write today.String &amp; " - 5 months is " &amp; today.cnEcAddMonths(-5).String;
	write today.String &amp; " + 5 years is " &amp; today.cnEcAddYears(5).String;
	write today.String &amp; " - 5 years is " &amp; today.cnEcAddYears(-5).String;
	
	write "ANSI Format=" &amp; today.cnEcGetAnsiFormat();
	write "Current age for 10/07/1962: " &amp; "10/07/1962".Date.cnEcCurrentAge();
	write "Days in month for " &amp; today.shortFormat() &amp; ": " &amp; today.cnEcDaysInMonth().String;
	write "Days in year for " &amp; today.shortFormat() &amp; ": " &amp; today.cnEcDaysInYear().String;
	write "Century for " &amp; today.shortFormat() &amp; ": " &amp; today.cnEcGetCentury().String;
	write "Last Monday for " &amp; today.shortFormat() &amp; ": " &amp; today.cnEcGetLastMonday().shortFormat();
	write "Last Sunday for " &amp; today.shortFormat() &amp; ": " &amp; today.cnEcGetLastSunday().shortFormat();
	write "Next Monday for " &amp; today.shortFormat() &amp; ": " &amp; today.cnEcGetNextMonday().shortFormat();
	write "Next Sunday for " &amp; today.shortFormat() &amp; ": " &amp; today.cnEcGetNextSunday().shortFormat();
	write "Previous week day for " &amp; today.shortFormat() &amp; ": " &amp; today.cnEcGetPreviousWeekDay().shortFormat();
	write "Next week day for " &amp; today.shortFormat() &amp; ": " &amp; today.cnEcGetNextWeekDay().shortFormat();
	write "Week number for " &amp; today.shortFormat() &amp; ": " &amp; today.cnEcGetWeek().String;
	write today.String &amp; " is in the future: " &amp; today.cnEcIsInFuture().cnEcGetYesNo();
	write "Is " &amp; today.shortFormat() &amp; " in a leap year: " &amp; today.cnEcIsLeapYear().cnEcGetYesNo();
	write "Easter Sunday this year is on: " &amp; today.year().cnEcGetEasterSundayForYear().shortFormat();

	write today.String &amp; " is in the " &amp; today.cnEcWeekOfMonth().cnEcOrdinalWord() &amp; " week of the month." &amp; CrLf;
	
	write today.dayName() &amp; " " &amp; today.shortFormat() &amp; " is a week day: " &amp; today.cnEcIsWeekDay().cnEcGetYesNo();
	today	:=	today.cnEcAddDays(1);
	write today.dayName() &amp; " " &amp; today.shortFormat() &amp; " is a week day: " &amp; today.cnEcIsWeekDay().cnEcGetYesNo();
	today	:=	today.cnEcAddDays(1);
	write today.dayName() &amp; " " &amp; today.shortFormat() &amp; " is a week day: " &amp; today.cnEcIsWeekDay().cnEcGetYesNo();
	today	:=	today.cnEcAddDays(1);
	write today.dayName() &amp; " " &amp; today.shortFormat() &amp; " is a week day: " &amp; today.cnEcIsWeekDay().cnEcGetYesNo();
	today	:=	today.cnEcAddDays(1);
	write today.dayName() &amp; " " &amp; today.shortFormat() &amp; " is a week day: " &amp; today.cnEcIsWeekDay().cnEcGetYesNo();
	today	:=	today.cnEcAddDays(1);
	write today.dayName() &amp; " " &amp; today.shortFormat() &amp; " is a week day: " &amp; today.cnEcIsWeekDay().cnEcGetYesNo();
	today	:=	today.cnEcAddDays(1);
	write today.dayName() &amp; " " &amp; today.shortFormat() &amp; " is a week day: " &amp; today.cnEcIsWeekDay().cnEcGetYesNo();
epilog
	delete dateObj;
	
	write CrLf &amp; "Date test completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_DecimalWholeFrac" id="f008d4b6-84a5-4f64-8bd9-e9622a74a3cc">
        <source>cnwdad1_Test_DecimalWholeFrac();
// -----------------------------------------------------------------------------
// Created:		20 January 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
constants
	VALUE_TO_CONVERT	: Real = 15;
	
vars
	value1		: Decimal[12,4];
	value2		: Decimal[12];
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	value1		:=	1234.5678;
	value2		:=	1234;
	
	write "1. Value: " &amp; value1.String;
	write "1. Whole value: " &amp; value1.cnEcWholeValue().String;
	write "1. Fraction Value: " &amp; value1.cnEcFractionValue().String;
	write "2. Value: " &amp; value2.String;
	write "2. Whole value: " &amp; value2.cnEcWholeValue().String;
	write "2. Fraction Value: " &amp; value2.cnEcFractionValue().String;
epilog
	write "Decimal fractions completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_DocumentModel" id="80c2eebc-58fa-41bf-b8d0-c9cce19c52c2">
        <source>cnwdad1_Test_DocumentModel();
// --------------------------------------------------------------------------------
// Created:		22 August 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	docResponse		: String;
	startTime		: Integer;
	parameterObj	: CnEcDocParameter;
	theSchema		: Schema;
	
begin
	startTime	:=	app.clock();
	theSchema	:=	rootSchema.getSchema("BaseSchema");
	
	create parameterObj transient;
	parameterObj.mySchemaTop			:=	theSchema;
	parameterObj.mySchemaBottom			:=	theSchema;
	parameterObj.isIncludeClassText		:=	true;
	parameterObj.isIncludeSource		:=	false;
	parameterObj.isIncludeJadeClasses	:=	false;
	parameterObj.baseDirectory			:=	"d:\ClassDoc";
	
	docResponse	:=	global.cnEcDocumentModel(parameterObj);
	
	if docResponse = null then
		write "Model documented.";
	else
		write docResponse;
	endif;
epilog
	delete parameterObj;
	write "Model documentation completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
