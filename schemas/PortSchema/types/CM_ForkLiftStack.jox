    <JadeMethod name="setStaggerHeights" id="69b217b4-2b48-48b9-ab55-e4704f3e0812">
        <updating/>
        <source>setStaggerHeights(stagger : String) updating;
// ---------------------------------------------------------------------------
// Created:     2001 By Andrew Bishop cnwab1
//
// Purpose:     Expects a perfect comma seperated list of column stagger heights, in containers
//				self.checkStaggerHeights get rid of unwanted characters
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	desc: StringArray;
	pos: Integer;
	i : Integer;
	listString : String;
	
begin
	listString := stagger;
	self.checkStaggerHeights(listString);	
	self.staggerHeights.clear;
//	create desc transient;
	// Get rid of the commas, replace with a token
	listString.replaceChar("," , "/");
	// populate a string array splitting by the token
	desc := listString.getTokens;

	// put the string values into an Integer array
	foreach pos in 1 to desc.size do
		if desc[pos].isInteger then
			i := i + 1;
			if desc[pos].Integer &gt; self.heightOfStack then // XPOSE 1765
				self.staggerHeights[i] :=  self.heightOfStack;
			else
				self.staggerHeights[i] := desc[pos].Integer;	
			endif;
		endif;
	endforeach;
epilog
	delete desc;
end;</source>
        <Parameter name="stagger" type="String"/>
    </JadeMethod>
    <JadeMethod name="testHeightAccess" id="3fc8c345-fc46-4af8-9bde-b990a793df89">
        <source>testHeightAccess(_autoMovePlan: CMIF_AutoMovePlan input; _lc : CM_LocationsController): Boolean;
// ---------------------------------------------------------------------------
// Created:		29 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	lHeight	: Real;
	pTI: CM_TrackedItem;
begin
	pTI := _autoMovePlan.myTrackedItem;
	if pTI.isAttributeTrue(TI_Attrib_RequiresPower) then
		lHeight := self.maxHeightPower;
		if lHeight &gt; 0	// 31/03/2011 cnwar2 #27309
		and not _lc.canAccessHeight(lHeight, _autoMovePlan.moveMode) then
			return false;
		endif;
	endif;
	if (not pTI.isFull) then
		lHeight := self.maxHeightMT;
		if lHeight &gt; 0	// 31/03/2011 cnwar2 #27309
		and not _lc.canAccessHeight(lHeight, _autoMovePlan.moveMode) then
			return false;
		endif;
	else
		lHeight := self.maxHeightFull;
		if lHeight &gt; 0	// 31/03/2011 cnwar2 #27309
		and not _lc.canAccessHeight(lHeight, _autoMovePlan.moveMode) then
			return false;
		endif;
	endif;
	return true;

end;</source>
        <Parameter name="_autoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testOverstowBack" id="0a7d2857-082f-493a-95e5-bc37c5ce610d">
        <source>testOverstowBack(	_cmifAutoPlan				: CMIF_AutoMovePlan input;
					_originalTI,
					_toMoveTI 			: CM_TrackedItem;
					_sourceLocn,
					_targetLocn			: CM_StackController;
					_left,
					_isOriginal40,
					_isToMove40,
					_checkSource		: Boolean) : Boolean protected;

// cnwdvb1 21 July 2003 

vars

	startRow,
	startCol,
	lRow,
	lLeft,
	rowAccessHeight,
	lORow,
	lOCol					: Integer;
	lcToTest				: CM_LocationsController;
	
begin

	if self.accessBack and _cmifAutoPlan.getController = null then
		//_cmifAutoPlan.addLogEntry('Testing from back', IsForLogging); //- cnwmd1, Par 20524
		_cmifAutoPlan.addLogEntry(app.getErrorString(Testing_from_back), IsForLogging, Testing_from_back);
		if not self.accessFront then
			startRow := self.allGridRows.size;
		else
			// Changed to try from middle rather than block rows.
			//	startRow	:= _sourceLocn.myGridRow.row;
			startRow	:= (self.allGridRows.size / 2).Integer;
		endif;
		startCol	:= _sourceLocn.myGridColumn.column;
	    foreach lRow in 1 to startRow reversed do
		  	if _left then
	      		if not self.testOverstowLeft(_cmifAutoPlan, TA_ACCESS_BACK, lRow, startCol, _originalTI, _toMoveTI, _sourceLocn, _targetLocn,
	      						 _isOriginal40, _isToMove40, _checkSource) then
	      			self.testOverstowRight(_cmifAutoPlan, TA_ACCESS_BACK, lRow, startCol, _originalTI, _toMoveTI, _sourceLocn, _targetLocn,
	      						 _isOriginal40, _isToMove40, _checkSource);
	      		endif;
	    	else
	    		if not self.testOverstowRight(_cmifAutoPlan, TA_ACCESS_BACK, lRow, startCol, _originalTI, _toMoveTI, _sourceLocn, _targetLocn,
	      						 _isOriginal40, _isToMove40, _checkSource) then
	      			self.testOverstowLeft(_cmifAutoPlan, TA_ACCESS_BACK, lRow, startCol, _originalTI, _toMoveTI, _sourceLocn, _targetLocn,
	      						 _isOriginal40, _isToMove40, _checkSource);
	      		endif;
			endif;
			if _cmifAutoPlan.getController &lt;&gt; null then
				break;
			endif;
		endforeach;
	endif;
epilog
	return _cmifAutoPlan.getController &lt;&gt; null;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifAutoPlan" type="CMIF_AutoMovePlan" usage="input"/>
        <Parameter name="_originalTI" type="CM_TrackedItem"/>
        <Parameter name="_toMoveTI" type="CM_TrackedItem"/>
        <Parameter name="_sourceLocn" type="CM_StackController"/>
        <Parameter name="_targetLocn" type="CM_StackController"/>
        <Parameter name="_left" type="Boolean"/>
        <Parameter name="_isOriginal40" type="Boolean"/>
        <Parameter name="_isToMove40" type="Boolean"/>
        <Parameter name="_checkSource" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testOverstowFront" id="a851d644-b888-4028-a28f-fe61c416993c">
        <source>testOverstowFront(	_cmifAutoPlan		: CMIF_AutoMovePlan input;
					_originalTI,
					_toMoveTI 			: CM_TrackedItem;
					_sourceLocn,
					_targetLocn			: CM_StackController;
					_left,
					_isOriginal40,
					_isToMove40,
					_checkSource		: Boolean) : Boolean protected;

// cnwdvb1 21 July 2003 

vars

	startRow, 
	startCol,
	lRow,
	lLeft,
	rowAccessHeight,
	lORow,
	lOCol					: Integer;
	lcToTest				: CM_LocationsController;

begin

	// Can we access from the front and have found something.
	if self.accessFront and _cmifAutoPlan.getController = null then
		//_cmifAutoPlan.addLogEntry('Testing from front', IsForLogging); //- cnwmd1, Par 20524
		_cmifAutoPlan.addLogEntry(app.getErrorString(Testing_from_front), IsForLogging, Testing_from_front);
		if not self.accessBack then
			startRow := 1;
		else
			// Changed to try from middle rather than block rows.
			//	startRow	:= _sourceLocn.myGridRow.row;
			startRow	:= (self.allGridRows.size / 2).Integer;
		endif;
		startCol := _sourceLocn.myGridColumn.column;
	    foreach lRow in startRow to self.numberOfRows do  // note ordinals are zero based
			// Are we starting from the left or right.
	      	if _left then
	      		if not self.testOverstowLeft(_cmifAutoPlan, TA_ACCESS_FRONT, lRow, startCol, _originalTI, _toMoveTI, _sourceLocn, _targetLocn,
	      						 _isOriginal40, _isToMove40, _checkSource) then
	      			self.testOverstowRight(_cmifAutoPlan, TA_ACCESS_FRONT, lRow, startCol, _originalTI, _toMoveTI, _sourceLocn, _targetLocn,
	      						 _isOriginal40, _isToMove40, _checkSource);
	      		endif;
	    	else
	    		if not self.testOverstowRight(_cmifAutoPlan, TA_ACCESS_FRONT, lRow, startCol, _originalTI, _toMoveTI, _sourceLocn, _targetLocn,
	      						 _isOriginal40, _isToMove40, _checkSource) then
	      			self.testOverstowLeft(_cmifAutoPlan, TA_ACCESS_FRONT, lRow, startCol, _originalTI, _toMoveTI, _sourceLocn, _targetLocn,
	      						 _isOriginal40, _isToMove40, _checkSource);
	      		endif;
			endif;
			if _cmifAutoPlan.getController &lt;&gt; null then
				break;
			endif;
		endforeach;
	endif;
//	STACK_ALONG_ROW STACK_UP_STACK
epilog
	return _cmifAutoPlan.getController &lt;&gt; null;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifAutoPlan" type="CMIF_AutoMovePlan" usage="input"/>
        <Parameter name="_originalTI" type="CM_TrackedItem"/>
        <Parameter name="_toMoveTI" type="CM_TrackedItem"/>
        <Parameter name="_sourceLocn" type="CM_StackController"/>
        <Parameter name="_targetLocn" type="CM_StackController"/>
        <Parameter name="_left" type="Boolean"/>
        <Parameter name="_isOriginal40" type="Boolean"/>
        <Parameter name="_isToMove40" type="Boolean"/>
        <Parameter name="_checkSource" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testOverstowLeft" id="ed278caa-2d9b-4a91-b292-3665c92c8606">
        <source>testOverstowLeft(_cmifAutoPlan 			: CMIF_AutoMovePlan input;
				 _access, _startRow,
				 _startCol				: Integer;
				 _originalTI,
				 _toMoveTI 				: CM_TrackedItem;
				 _sourceLocn,
			 	 _targetLocn			: CM_StackController;
			 	 _isOriginal40,
				 _isToMove40,
				 _checkSource 			: Boolean) : Boolean protected;

// cnwdvb1 29 July 2003 

vars

	lcToTest		: CM_LocationsController;
	rowAccessHeight,
	theRow, theCol	: Integer;
	fullId			: String;

begin

	foreach lcToTest in self.allGridRows[_startRow].allControllersByColumn reversed
	where lcToTest.CM_GridController.myGridColumn.column &lt; _startCol do
		fullId := lcToTest.getFullId();
  		//_cmifAutoPlan.addLogEntry('Testing ' &amp; fullId &amp; ' from left', IsForLogging); //- cnwmd1, Par 20524
		_cmifAutoPlan.addLogEntry(app.getErrorString1(Testing_from_left, fullId), IsForLogging, Testing_from_left);
		if not (lcToTest.isKindOf(CM_StackController)) then
		//_cmifAutoPlan.addLogEntry('Location ' &amp; fullId &amp; ' is a gap controller', IsForLogging); //- cnwmd1, Par 20524
		_cmifAutoPlan.addLogEntry(app.getErrorString1(Location_controller, fullId), IsForLogging, Location_controller);
			continue;
		endif;
		// How high can we go.
		
		rowAccessHeight := self.testOverstowLCAvailability(lcToTest.CM_StackController);
		_cmifAutoPlan.iteration := rowAccessHeight;
   		if (lcToTest.numTIs + lcToTest.numQueuedTIs + lcToTest.numPlannedTIs) &gt;= rowAccessHeight then	
		//_cmifAutoPlan.addLogEntry('Location ' &amp; fullId &amp; ' has not passed row access height of ' &amp; rowAccessHeight.String, IsForLogging); //- cnwmd1, Par 20524
		_cmifAutoPlan.addLogEntry(app.getErrorString2(Locatio_passed_access_height, fullId, rowAccessHeight.String), IsForLogging, Locatio_passed_access_height);
			continue;
		endif;
					
		if _checkSource then
			// not in front the source or the target, or any overstow 40s, thank you very much..
			lcToTest.CM_StackController.getMyRowColOrdinal( theRow, theCol);
			if _cmifAutoPlan.allSourceOrdinalCols.includes(theCol) then
				//_cmifAutoPlan.addLogEntry('Location ' &amp; fullId &amp; ' has failed ordinal columns test', IsForLogging); // PAR 17386 //- cnwmd1, Par 20524
				_cmifAutoPlan.addLogEntry(app.getErrorString1(Locati_failed_ordina_column_te, fullId), IsForLogging, Locati_failed_ordina_column_te);
				continue;
			endif;
					
			if _isToMove40 and lcToTest.CM_StackController.testMyNextController(CM_StackController) then
		 		lcToTest.CM_StackController.myNextController.CM_StackController.getMyRowColOrdinal( theRow, theCol);
				if _cmifAutoPlan.allSourceOrdinalCols.includes(theCol) then
					//_cmifAutoPlan.addLogEntry('Location ' &amp; fullId &amp; ' has failed ordinal columns test for containers greater than 20', IsForLogging); // PAR 17386 //- cnwmd1, Par 20524
					_cmifAutoPlan.addLogEntry(app.getErrorString1(Locat_faile_ordin_colum_test_c, fullId), IsForLogging, Locat_faile_ordin_colum_test_c); // PAR 17386
					continue;
				endif;
	  		endif;
	  	endif;
					
		if lcToTest.CM_StackController.testIsControllerSuitable(_cmifAutoPlan, _isOriginal40,_isToMove40, _sourceLocn, _targetLocn, _access) then		
			lcToTest.testOverstowMoveLocation(_cmifAutoPlan);
			if _cmifAutoPlan.getController &lt;&gt; null then  //found a space
				//_cmifAutoPlan.addLogEntry(_cmifAutoPlan.getController.CM_StackController.getFullId &amp; " is suitable", IsForLogging); //- cnwmd1, Par 20524
				_cmifAutoPlan.addLogEntry(app.getErrorString1(Is_Suitable_Param, _cmifAutoPlan.getController.CM_StackController.getFullId), IsForLogging, Is_Suitable_Param);
			   	return true;
    		else
				//_cmifAutoPlan.addLogEntry('Location ' &amp; fullId &amp; ' has not been found suitable during testOverStowMoveLocation', IsForLogging); //- cnwmd1, Par 20524
				_cmifAutoPlan.addLogEntry(app.getErrorString1(Locat_been_found_suita_durin_t,fullId), IsForLogging, Locat_been_found_suita_durin_t);
			endif;
		else
			//_cmifAutoPlan.addLogEntry('Location ' &amp; fullId &amp; ' has not been found suitable during testIsControllerSuitable', IsForLogging); //- cnwmd1, Par 20524
			_cmifAutoPlan.addLogEntry(app.getErrorString1(Locat_nobn_found_suita_durin_t, fullId), IsForLogging, Locat_nobn_found_suita_durin_t);
		endif;
	endforeach;			
epilog
	return _cmifAutoPlan.getController &lt;&gt; null;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifAutoPlan" type="CMIF_AutoMovePlan" usage="input"/>
        <Parameter name="_access" type="Integer"/>
        <Parameter name="_startRow" type="Integer"/>
        <Parameter name="_startCol" type="Integer"/>
        <Parameter name="_originalTI" type="CM_TrackedItem"/>
        <Parameter name="_toMoveTI" type="CM_TrackedItem"/>
        <Parameter name="_sourceLocn" type="CM_StackController"/>
        <Parameter name="_targetLocn" type="CM_StackController"/>
        <Parameter name="_isOriginal40" type="Boolean"/>
        <Parameter name="_isToMove40" type="Boolean"/>
        <Parameter name="_checkSource" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testOverstowRight" id="ab5e8e5d-8115-4b83-83ef-b38ee47419da">
        <source>testOverstowRight(_cmifAutoPlan 			: CMIF_AutoMovePlan input;
				 _access, _row, _col	: Integer;
				 _originalTI,
				 _toMoveTI 				: CM_TrackedItem;
				 _sourceLocn,
			 	 _targetLocn			: CM_StackController;
			 	 _isOriginal40,
				 _isToMove40,
				 _checkSource 			: Boolean) : Boolean protected;

// cnwdvb1 29 July 2003 

vars

	lcToTest		: CM_LocationsController;
	rowAccessHeight,
	theRow, theCol	: Integer;
	fullId			: String;

begin

  	foreach lcToTest in self.allGridRows[_row].allControllersByColumn 
	where lcToTest.CM_GridController.myGridColumn.column &gt; _col do
		fullId := lcToTest.getFullId;
		//_cmifAutoPlan.addLogEntry('Testing ' &amp; fullId &amp; ' from Right', IsForLogging); //- cnwmd1, Par 20524
		_cmifAutoPlan.addLogEntry(app.getErrorString1(Testing_from_right, fullId), IsForLogging, Testing_from_right);
		if not (lcToTest.isKindOf(CM_StackController)) then
			//_cmifAutoPlan.addLogEntry('Location ' &amp; fullId &amp; ' is a gap controller', IsForLogging); //- cnwmd1, Par 20524
			_cmifAutoPlan.addLogEntry(app.getErrorString1(Location_controller_is_gap, fullId), IsForLogging, Location_controller_is_gap);
			continue;
		endif;
		// How high can we go.
		rowAccessHeight := self.testOverstowLCAvailability(lcToTest.CM_StackController);
		_cmifAutoPlan.iteration := rowAccessHeight;
   		if (lcToTest.numTIs + lcToTest.numQueuedTIs + lcToTest.numPlannedTIs) &gt;= rowAccessHeight then	
			//_cmifAutoPlan.addLogEntry('Location ' &amp; fullId &amp; ' has not passed row access height of ' &amp; rowAccessHeight.String, IsForLogging); //- cnwmd1, Par 20524
			_cmifAutoPlan.addLogEntry(app.getErrorString2(Locat_not_pssed_access_height, fullId, rowAccessHeight.String), IsForLogging, Locat_not_pssed_access_height);
			continue;
		endif;
					
		if _checkSource then
			// not in front the source or the target, or any overstow 40s, thank you very much..
			lcToTest.CM_StackController.getMyRowColOrdinal( theRow, theCol);
			if _cmifAutoPlan.allSourceOrdinalCols.includes(theCol) then
				//_cmifAutoPlan.addLogEntry('Location ' &amp; fullId &amp; ' has failed ordinal columns test', IsForLogging);// PAR 17386 //- cnwmd1, Par 20524
				_cmifAutoPlan.addLogEntry(app.getErrorString1(Lac_failed_ordina_col_test, fullId), IsForLogging, Lac_failed_ordina_col_test);
				continue;
			endif;
					
			if _isToMove40 and lcToTest.CM_StackController.testMyNextController(CM_StackController) then
		 		lcToTest.CM_StackController.myNextController.CM_StackController.getMyRowColOrdinal( theRow, theCol);
				if _cmifAutoPlan.allSourceOrdinalCols.includes(theCol) then
					//_cmifAutoPlan.addLogEntry('Location ' &amp; fullId &amp; ' has failed ordinal columns test for 40', IsForLogging);// PAR 17386 //- cnwmd1, Par 20524
					_cmifAutoPlan.addLogEntry(app.getErrorString1(Locati_fail_ordina_column_ts40, fullId), IsForLogging, Locati_fail_ordina_column_ts40);
					continue;
				endif;
	  		endif;
	  	endif;
					
		if lcToTest.CM_StackController.testIsControllerSuitable(_cmifAutoPlan,_isOriginal40,_isToMove40, _sourceLocn, _targetLocn, _access) then		
			lcToTest.testOverstowMoveLocation(_cmifAutoPlan);
			if _cmifAutoPlan.getController &lt;&gt; null then  //found a space
				//_cmifAutoPlan.addLogEntry(_cmifAutoPlan.getController.CM_StackController.getFullId &amp; " is suitable", IsForLogging); //- cnwmd1, Par 20524
				_cmifAutoPlan.addLogEntry(app.getErrorString1(Is_Suitable_param, _cmifAutoPlan.getController.CM_StackController.getFullId), IsForLogging, Is_Suitable_param);
			   	return true;
    		else
				//_cmifAutoPlan.addLogEntry('Location ' &amp; fullId &amp; ' has not been found suitable during testOverStowMoveLocation', IsForLogging); //- cnwmd1, Par 20524
				_cmifAutoPlan.addLogEntry(app.getErrorString1(Loc_bn_found_suita_durin_test, fullId), IsForLogging, Loc_bn_found_suita_durin_test);
			endif;
		else
			//_cmifAutoPlan.addLogEntry('Location ' &amp; fullId &amp; ' has not been found suitable during testIsControllerSuitable', IsForLogging); //- cnwmd1, Par 20524
			_cmifAutoPlan.addLogEntry(app.getErrorString1(Loc_been_fnd_suia_IsCntlerSuit, fullId), IsForLogging, Loc_been_fnd_suia_IsCntlerSuit);
		endif;
	endforeach;			
epilog

	return _cmifAutoPlan.getController &lt;&gt; null;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifAutoPlan" type="CMIF_AutoMovePlan" usage="input"/>
        <Parameter name="_access" type="Integer"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_originalTI" type="CM_TrackedItem"/>
        <Parameter name="_toMoveTI" type="CM_TrackedItem"/>
        <Parameter name="_sourceLocn" type="CM_StackController"/>
        <Parameter name="_targetLocn" type="CM_StackController"/>
        <Parameter name="_isOriginal40" type="Boolean"/>
        <Parameter name="_isToMove40" type="Boolean"/>
        <Parameter name="_checkSource" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testPowerPointsAvail" id="06594e5a-c0b8-4abb-8ae4-36e49c191637">
        <source>testPowerPointsAvail(_autoMovePlan: CMIF_AutoMovePlan input; _lc: CM_LocationsController): Boolean;
// ---------------------------------------------------------------------------
// Created:		29 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	locnId	:	String;
	lPowerPoints	: ObjectArray;
	lGap	: Object;
	lPowerDamaged	: Integer;

begin

	// cnwrd1 31313 18.4.13 now gbs lc's can have their own power, if so no need to check here.
	if _lc.hasPower then
		// TFS 41973 return false;
		return true;// TFS 41973 
	endif;


	create lPowerPoints transient;
	_lc.getPowerPoints(lPowerPoints);
	
	locnId := _lc.getFullId(); //cnwrd1 par 28295 12.10.2011
	//----------------
	//TI does require power
	//----------------
	if lPowerPoints.isEmpty then
		//No power!
		//autoMovePlan.addVerboseLogEntry(locnId &amp; " has no Power available.", IsWarning);
		_autoMovePlan.addVerboseLogEntry(app.getErrorString1(Power_available,locnId), IsWarning, Power_available);//cnwrd1 par 28295 12.10.2011
		return false;
	endif;
	lPowerDamaged := 0;
	foreach lGap in lPowerPoints do
		if lGap.CM_GapController.powerDamaged = true then
			lPowerDamaged := lPowerDamaged + 1;
			//autoMovePlan.addVerboseLogEntry(locnId &amp; ": Power at " &amp; lGap.CM_GapController.getID &amp; " is damaged.", IsWarning);
		endif;
	endforeach;
	if lPowerDamaged = lPowerPoints.size then
		//autoMovePlan.addVerboseLogEntry(locnId &amp; ": All Power Points for " &amp; self.id.String &amp;  " are damaged.", IsWarning);
		_autoMovePlan.addVerboseLogEntry(app.getErrorString1(Power_damaged,locnId), IsWarning, Power_damaged); //cnwrd1 par 28295 12.10.2011
		return false;
	endif;

	return inheritMethod(_autoMovePlan, _lc);

epilog
	delete lPowerPoints;
end;</source>
        <Parameter name="_autoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testPowerPointsAvailYA" id="d4e2b5c4-4055-4f66-a560-d43c43160405">
        <source>testPowerPointsAvailYA(_yaAgent: CM_YAAutoplanAgent input; _lc: CM_LocationsController): Boolean;
// ---------------------------------------------------------------------------
// Created:		29 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	locnId	:	String;
	lPowerPoints	: ObjectArray;
	lGap	: Object;
	lPowerDamaged	: Integer;	
	yc : CM_YardController;
begin

	yc := _lc.CM_YardController;
	locnId := yc.getFullId();
	
	// cnwrd1 31313 18.4.13 now gbs lc's can have their own power, if so no need to check here.
	if yc.hasPower then
		return false;
	endif;
	
	
	create lPowerPoints transient;
	self.getPowerPoints(lPowerPoints);
	//----------------
	//TI does require power
	//----------------
	if lPowerPoints.isEmpty then
		//No power!
		_yaAgent.addLogEntry(AP_Log_YA_Default,locnId &amp; " has no Power available.", true);
		return true;
	endif;
	lPowerDamaged := 0;
	foreach lGap in lPowerPoints do
		if lGap.CM_GapController.powerDamaged = true then
			lPowerDamaged := lPowerDamaged + 1;
			_yaAgent.addLogEntry(AP_Log_YA_Default,locnId &amp; ": Power at " &amp; lGap.CM_GapController.getID &amp; " is damaged.", true);
		endif;
	endforeach;
	if lPowerDamaged = lPowerPoints.size then
		_yaAgent.addLogEntry(AP_Log_YA_Default,locnId &amp; ": All Power Points for " &amp; self.id.String &amp;  " are damaged.", true);
		return true;
	endif;

	return inheritMethod(_yaAgent, _lc);

epilog
	delete lPowerPoints;		// PAR #27874
	
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testRestrictedAccess" id="ac04ef7c-3926-4d3e-9a7d-3a64af6e7433">
        <source>testRestrictedAccess(): Boolean;
// ---------------------------------------------------------------------------
// Created:		29 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if not self.useSideAccessRules then
		return false;
	endif;
	
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="596e31d3-388f-4938-b9a7-f8948594116b">
        <source>validate() protected;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	result,tmpInteger : Integer;
	maxHeight	: Real;

begin
	inheritMethod();
	// the max height, in FEET, that an individual OD container can be is set in this constant, so it makes sense that this 
	// constant mulitplied by the height of the area is the highest that  we can go
	maxHeight := self.heightOfStack.Real * HEIGHT_FULL_HIGH_CUBE; // in feet // WAS HEIGHT_FULL_OD PAR 4089 AKB2002OCT; 

	// Round this up
	tmpInteger := maxHeight.Integer; // PAR 4402 AKB2002DEC
	if maxHeight &gt; tmpInteger.Real then // PAR 4402 AKB2002DEC
		maxHeight := maxHeight + .5; // PAR 4402 AKB2002DEC
	endif; // PAR 4402 AKB2002DEC
	if self.maxHeightFull &gt; maxHeight then
		app.raiseCMException2(ERR_INVALID_VALUE, "Max Height Fulls", "Enter between 1 &amp; " &amp; maxHeight.String 
								&amp; " (" &amp; maxHeight.asFeetInches &amp; ") (" &amp; maxHeight.asWords &amp; ")", null, null);
	endif;
	if self.maxHeightMT &gt; maxHeight then
		app.raiseCMException2(ERR_INVALID_VALUE, "Max Height Empty", "Enter between 1 &amp; " &amp; maxHeight.String 
								&amp; " (" &amp; maxHeight.asFeetInches &amp; ") (" &amp; maxHeight.asWords &amp; ")", null, null);
	endif;
	if self.maxHeightPower &gt; maxHeight then
		app.raiseCMException2(ERR_INVALID_VALUE, "Max Height Power", "Enter between 1 &amp; " &amp; maxHeight.String 
								&amp; " (" &amp; maxHeight.asFeetInches &amp; ") (" &amp; maxHeight.asWords &amp; ")", null, null);
	endif;
	

end;</source>
        <access>protected</access>
    </JadeMethod>
