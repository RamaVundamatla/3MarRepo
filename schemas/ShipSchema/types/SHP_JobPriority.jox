    <JadeMethod name="doLstPriorityClick" id="e3adecae-fdbc-4048-ac50-988f55c1afcd">
        <updating/>
        <source>doLstPriorityClick(listbox: CM_QueueListBox input) updating;
// ---------------------------------------------------------------------------
// Created:		05 April 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	isEnabled : Boolean;
begin
	//changed by cnwyl1 for par 12216
	//it was...
	/*isEnabled := listbox.itemLevel[listbox.listIndex] = self.LevelCrane;
	self.btnNew.enabled := isEnabled;
	isEnabled := listbox.itemLevel[listbox.listIndex] = self.LevelPriority;
	self.btnDelete.enabled := isEnabled;*/

	if listbox.itemExpanded[listbox.listIndex] = true then
		listbox.itemExpanded[listbox.listIndex] := false;
	else
		listbox.itemExpanded[listbox.listIndex] := true;
	endif;
	isEnabled := listbox.itemLevel[listbox.listIndex] = self.LevelCrane;
	self.btnNew.enabled := isEnabled;
	isEnabled := listbox.itemLevel[listbox.listIndex] = self.LevelPriority;
	self.btnDelete.enabled := isEnabled;

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNew.enabled := false;
		self.btnDelete.enabled := false;

	endif;

end;</source>
        <Parameter name="listbox" type="CM_QueueListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLstPriorityDblClick" id="848ca4d5-d5a0-417e-b7c7-24a21f525a6b">
        <updating/>
        <source>doLstPriorityDblClick(listbox: CM_QueueListBox input) updating;
// ---------------------------------------------------------------------------
// Created:		05 April 2006  By Andrew Bishop cnwab1
