<Class name="WS_TerminalAreaType" id="81449a62-c796-4393-a87e-5f8e7a9fdce7">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Represents a type of a yard area i.e. Block Stack, Straddle Stack. </text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="description" id="2779e581-3086-4ebf-ab49-9c2b6bc86ad8">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Description of this Area Type ex. 1 = Block Stack,29 = RTG Area</text>
    </PrimAttribute>
    <PrimAttribute name="id" id="c4f0d815-4773-4bc0-9acc-20701a7f32ab">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>code of Area Type. ex: 1,2,3</text>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="237eaaf4-5ffd-4330-8bc4-4d939a315d80">
        <updating/>
        <source>setProxyFromObject(_object: CM_TerminalAreaType) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 September 2008	cnwkao1	Initial creation

*/

vars

begin
	inheritMethod(_object);
	self.id				:= _object.type;
	self.description	:= _object.description;
	
epilog

end;</source>
        <Parameter name="_object" type="CM_TerminalAreaType"/>
    </JadeMethod>
</Class>
