    <JadeMethod name="doSearch" id="29e2c6fb-1c9a-4ddb-a4b5-335b716f5e98">
        <updating/>
        <source>doSearch() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
23 April 2010	cnwer1	Initial creation
12 July 2018	jlgmd1	TFS #39292 - POL - Discharge job leaving details on screen

*/

vars
	searchTextFirst	: String;
	searchTextSecond : String;
	strArray : StringArray;
	row : Integer;
	obj : Object;
	ti : CM_TrackedItem;
	reselectDTO : DTO_RTQueueEntry;
begin
	
	if not self.autoSearchDirector
	and self.frmMove.visible
	and self.frmDirector.visible
	then
		// this combo is ok  - 13 Nov 2017	NDL TFS 7427
	elseif (self.txtSearch.text = null or self.txtSearch.text = app.getErrorString(Search)) then	// TFS 39292
		return;
	endif;
	
	self.tblTasks.tag := null;	//01 Apr 2011	NDL	Par 27291
	
	if self.frmMove.visible and self.frmDirector.visible then
		self.doSearchDirectorTasks();
		return;
	endif;
	
	/*
	Suggested fix for PAR 27761
	 - move code below above doSearchDirectorTasks.
	 - if doing director task will need to determine different if twin or not
	 - change doSearchDirectorTasks to take  (searchTextFirst, searchTextSecond, isTwinSearch) as parameters
	 - also need to change tblDirector so can select 2 rows (if select a 3rd then deselect 1st selected) - tblTasks does this already.
	*/
	
	//01 Apr 2011	NDL	Par 27291	allow for performing two searches at once
	searchTextFirst := self.txtSearch.text.toUpper;
	if self.btnTandem.visible then
		if self.btnTandem.value then
			if searchTextFirst.pos(' ',1) &gt; 1 then
				create strArray transient;
				searchTextFirst.getTokensForDelimiter(" ", strArray);
				searchTextFirst := strArray[1];
				if strArray.size &gt; 1 then
					searchTextSecond := strArray[2];
				endif;
				self.txtSearch.text := searchTextFirst &amp; " " &amp; searchTextSecond;
			else
				//25 June 2012	NDL	Par 29737
				create strArray transient;
				foreach row in 1 to self.tblTasks.rows do
					if self.tblTasks.accessCell(row,1).fontBold then
						obj := self.tblTasks.accessRow(row).itemObject;
						if obj &lt;&gt; null and obj.isKindOf(DTO_RTQueueEntry) then 
							ti := obj.DTO_RTQueueEntry.getTI();
							if ti &lt;&gt; null then
								strArray.add(ti.id);
								reselectDTO := obj.DTO_RTQueueEntry;
							endif;
						endif;
					endif;
				endforeach;
				if strArray.size = 1 then
					searchTextSecond := strArray[1];
				else
					reselectDTO := null;
				endif;
				
			endif;
		endif;
	endif; 
	
	//need config so I know when to look on ship to allow users to discharge
	if self.btnVoyDischarge.value then
	//	self.doSearchVoyageDischarge;
		self.doSearchVoyageDischarge( searchTextFirst, searchTextSecond );	//06 Apr 2011	NDL	Par 27349
		
		//17 Feb 2011	NDL	Par 27036
		if self.tblTasks.rows &gt; self.tblTasks.fixedRows then
			//epr par 31240 31/05/13
			self.tblTasks.setFocus;	
		endif;
	
		return;
	endif;
	
	//epr par 29418 26/4/12 - some refactoring of this method 
	if self.isEnquiryMode  then
		self.doSearchEnquiry(searchTextFirst,searchTextSecond);
	else
		self.doSearchTasks(searchTextFirst,searchTextSecond);
		//25 June 2012	NDL	Par 29737
		if reselectDTO &lt;&gt; null then
			foreach row in 1 to self.tblTasks.rows do
				if self.tblTasks.accessCell(row,1).fontBold then
					obj := self.tblTasks.accessRow(row).itemObject;
					if obj = reselectDTO then
						self.tblTasks.accessRow(row).selected := true;
						break;
					endif;
				endif;
			endforeach;
		endif;
		
	endif;
	
epilog
	//01 Apr 2011	NDL	Par 27291
	delete strArray;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSearchDirectorTasks" id="f758142e-16a8-4c04-b871-523b0114aa6d">
        <updating/>
        <source>doSearchDirectorTasks() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 Apr 2010	cnwer1	Initial creation
20 Sep 2010 cnwer1	PAR 25542 
*/

vars
	id : String;
	firstFoundRow,
	row : Integer;
	ti 		: CM_TrackedItem;
	dtoEntry,
	dtoTwinEntry: DTO_RTQueueEntry;
	dtoEntryArray 	: DTO_RTQueueEntryArray;
begin
	id:=self.txtSearch.text.toUpper;
	
	//13 Nov 2017	NDL	TFS 7427
	if not self.autoSearchDirector then
		if id &lt;&gt; null then
			self.setupFrmMove();

		else
			create dtoEntryArray transient;
			app.myVMAgent.findWorkingDTORTEntries(dtoEntryArray,self.tblTasks);
			
			if dtoEntryArray.isEmpty then
				if self.myMachine.currentQueueTask &lt;&gt; null then
					dtoEntry:=app.myVMAgent.findDTOEntryByRTQueueEntry(app.myVMAgent.myMachine.currentQueueTask.myEntry);
				endif;
			else
				if dtoEntryArray.size &gt; 0 then
					dtoEntry:=dtoEntryArray[1];
				endif;
				if dtoEntryArray.size &gt; 1 then
					dtoTwinEntry:=dtoEntryArray[2];
				endif;
			endif;
			
			if dtoEntry &lt;&gt; null then
				self.setupFrmDirector(dtoEntry, dtoTwinEntry, true);
			endif;
			
			return;
			
		endif;
	endif;
	
	if self.tblDirector.rows = self.tblDirector.fixedRows then
		self.checkIDForDirectorTask(id); //cnwrd1 par 27812 2.8.2011
		return;
	endif;
	self.tblDirector.row:=1;
	row := 2;
	while row &lt;= self.tblDirector.rows do
		
		ti :=self.tblDirector.accessRow(row).itemObject.CM_TrackedItem;
		if ti = null then
			row := row + 1;
			continue;
		endif;
		if id.length &lt;= ti.id.length then
		//epr par 25004 14/7/10
			if not ti.id.pos(id,1) &gt; 0 then
				self.tblDirector.accessRow(row).visible:=false;
			else
				if firstFoundRow = 0 then
					firstFoundRow:=row;
				endif;
				self.tblDirector.accessRow(row).visible:=true;
			endif;
		
		endif;
		row := row + 1;
	endwhile;

	if firstFoundRow &lt;&gt; 0 then
		self.tblDirector.row:=firstFoundRow;
		self.tblDirector.click(self.tblDirector);
	else
		self.checkIDForDirectorTask(id); //cnwrd1 par 27812 2.8.2011
		self.myMoveTableDetails.addDataForEntRowName(ETRow_CargoID,null);			
	endif;
epilog

	delete dtoEntryArray;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSearchEnquiry" id="e4dab9b4-1961-4b4c-a2ca-eee835eb9def">
        <updating/>
        <source>doSearchEnquiry(_searchText1, _searchText2 : String) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 Apr 2012	cnwer1	Initial creation CCMS MES 1035
06 Jan 2014 cnwer1	par 31915 added machine to enable search by more than one cargo type 
*/

vars
	searchTIs		: CM_TISet;
	allFoundNonRTTIs: CM_TIArray;
	rowCount, maxSearchResults : Integer;
	rtConfig			: CM_RTVehicleConfig;
begin
	create searchTIs transient;
	//self.getSessionAgent().doSearchItem(self.txtSearch.text, false,true,false , searchTIs );
	self.getSessionAgent().doSearchItem(_searchText1, false,true,false ,0, self.myMachine,searchTIs );//02 Dec 2010	NDL Par 26417
	
	if searchTIs.size = 0 then
		self.txtSearch.setFocus;  //cnwrd1 11.1.11 par 26715
		self.displayVMTableRow(self.tblTasks,1,false); //cnwrd1 17.1.11 par 26715
		self.addInfoDisplay(app.getErrorString(No_Matchin_cargo_found_onsite));
		return;
	endif;
	
	self.addInfoDisplay(app.getErrorString1(Found_matching_cargo,searchTIs.size.asStringJMT));
	
		
	self.clearTableData(self.tblTasks);
	
	if _searchText2 &lt;&gt; null then
		self.getSessionAgent().doSearchItem(_searchText2, false,true,false ,0,self.myMachine, searchTIs );
	endif;
	
	create allFoundNonRTTIs transient;
	searchTIs.copy(allFoundNonRTTIs);
	
	rtConfig := self.myVMAgent.getMyRTVehicleConfig();
	maxSearchResults:=rtConfig.maxNumberSearchResults ;
	if maxSearchResults &gt; 0 and allFoundNonRTTIs.size &gt; maxSearchResults then
		while allFoundNonRTTIs.size &gt; maxSearchResults do
			allFoundNonRTTIs.remove(allFoundNonRTTIs.last);
		endwhile;
	endif;
	
	self.loadEnquiryCargo(self.tblTasks,allFoundNonRTTIs);
	self.txtSearch.setFocus;  //cnwrd1 11.1.11 par 26715
	self.displayVMTableRow(self.tblTasks,1,_searchText2 &lt;&gt; null); //cnwrd1 17.1.11 par 26715
	
	if self.tblTasks.rows &gt; self.tblTasks.fixedRows then	 // 21 Dec 2010	NDL	Par 26617
		rowCount := self.tblTasks.fixedRows + 1;
		self.displayVMTableRow(self.tblTasks, rowCount, false);
		self.tblTasks.setFocus;	 // 21 Dec 2010	NDL	Par 26617	
		
		if _searchText2 &lt;&gt; null and self.tblTasks.rows  = 3 then
			self.displayVMTableRow(self.tblTasks, 3, true);
		endif;
	endif;
epilog
	delete allFoundNonRTTIs;
	delete searchTIs;
end;</source>
        <access>protected</access>
        <Parameter name="_searchText1" type="String"/>
        <Parameter name="_searchText2" type="String"/>
    </JadeMethod>
    <JadeMethod name="doSearchTasks" id="fc57286d-dd52-4648-9edf-8c158f197070">
        <updating/>
        <source>doSearchTasks(_searchText1, _searchText2 : String) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2012	cnwer1	Initial creation CCMS MES 1035


*/

vars
	rtConfig			: CM_RTVehicleConfig;
	machine 			: CM_Machine;
	allFoundRTQEntries 	: CM_RTQueueEntryArray;
	queue 				: CM_RadioTelemetryQueue;
	rowCount : Integer;
begin
	rtConfig := self.myVMAgent.getMyRTVehicleConfig();
	machine:= self.myMachine;
	
	create allFoundRTQEntries transient;
	//check primary queue first
	machine.myPrimaryQueue.findEntryForTIorRegNum(_searchText1, _searchText2,self.myMachine,rtConfig.maxNumberSearchResults,allFoundRTQEntries);
	
	//if showing secondary queues check secondary
	if rtConfig.showSecondaryQueues then
		foreach queue in self.myMachine.allQueues do
			if queue = machine.myPrimaryQueue then
				continue;
			endif;
			queue.findEntryForTIorRegNum(_searchText1, _searchText2,self.myMachine,rtConfig.maxNumberSearchResults,allFoundRTQEntries);
		endforeach;
	endif;

	if  allFoundRTQEntries.isEmpty then
		self.txtSearch.setFocus;  //cnwrd1 11.1.11 par 26715
		self.displayVMTableRow(self.tblTasks,1,false); //cnwrd1 17.1.11 par 26715
		self.addInfoDisplay(app.getErrorString1(Found_matchin_queued_cargo,0.asStringJMT));
		return;
	endif;
	
	self.clearTableData(self.tblTasks);
	self.addInfoDisplay(app.getErrorString1(Found_matchin_queued_cargo,allFoundRTQEntries.size.asStringJMT));
	app.myVMAgent.loadTableFromRTQueueEntries(self.tblTasks,allFoundRTQEntries);

	if self.tblTasks.rows &gt; self.tblTasks.fixedRows then	 // 21 Dec 2010	NDL	Par 26617
		rowCount := self.tblTasks.fixedRows + 1;
		self.displayVMTableRow(self.tblTasks, rowCount, false);
		self.tblTasks.setFocus;	 // 21 Dec 2010	NDL	Par 26617  
		if _searchText2 &lt;&gt; null and self.tblTasks.rows  = 3 then
			self.displayVMTableRow(self.tblTasks, 3, true);
		endif;
	endif;
epilog
	delete allFoundRTQEntries;
	
end;</source>
        <access>protected</access>
        <Parameter name="_searchText1" type="String"/>
        <Parameter name="_searchText2" type="String"/>
    </JadeMethod>
    <JadeMethod name="doSearchVoyageDischarge" id="ea130ffd-0130-4bd7-996a-4f238f5de2a1">
        <updating/>
        <source>doSearchVoyageDischarge( _searchTextFirst : String; _searchTextSecond : String)  : Boolean protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 April 2011	cnwndl1	Initial creation	Par 27349

*/

vars

	ti : CM_TrackedItem;
	allFoundTIs : CM_TIArray;
	allValidTIs1 : CM_TISet;
	allValidTIs2 : CM_TISet;
	nextRow : Integer;
	currentLocation : CM_LocationsController;
	voyage : CM_Voyage;
	job : CM_VoyageJob;
	wle : CM_WorkListEntry;
			
begin

	self.clearTableData(self.tblTasks);
	
	create allValidTIs1 transient;
	create allValidTIs2 transient;
	create allFoundTIs transient;
	
	self.myMachine.isValidOnQueueVoyageTIID(_searchTextFirst,allValidTIs1);
	if _searchTextSecond &lt;&gt; null then
		self.myMachine.isValidOnQueueVoyageTIID(_searchTextSecond,allValidTIs2);
	endif;
	
	if allValidTIs1.size &gt; 0 then
		
		foreach ti in allValidTIs1 do
			if not allFoundTIs.includes(ti) then
				allFoundTIs.add(ti);
			endif;
		endforeach;
			
		self.loadEnquiryCargo(self.tblTasks,allFoundTIs);
		
		if not allFoundTIs.isEmpty then
			self.tblTasks.row := self.tblTasks.fixedRows + 1;
			self.tblTasks.click(self.tblTasks);
		endif;
		
		if _searchTextSecond &lt;&gt; null then
		
			nextRow := self.tblTasks.rows + 1;
			allFoundTIs.clear();
			
			foreach ti in allValidTIs2 do
				if not allFoundTIs.includes(ti) then
					allFoundTIs.add(ti);
				endif;
			endforeach;
			
			if not allFoundTIs.isEmpty then
				self.addEnquiryCargo( allFoundTIs, self.tblTasks );
				self.tblTasks.row := nextRow;
				self.tblTasks.click(self.tblTasks);
			endif;
		
		endif;
	
		return true;
		
	endif;
	
	return false;
	
epilog

	delete allFoundTIs;
	delete allValidTIs1;
	delete allValidTIs2;

end;</source>
        <access>protected</access>
        <Parameter name="_searchTextFirst" type="String"/>
        <Parameter name="_searchTextSecond" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSendErrorMessages" id="031a9f8c-47a2-41e9-8a1f-01ca7cc87a92">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_VehicleMountedDetails::doSendErrorMessages"/>
        </interfaceImplements>
        <source>doSendErrorMessages() : Integer;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2010	cnwer1	Initial creation

*/

vars
	err : CM_Error;
begin
	
	if not self.myTerminal.getConfig(SetConnectedTIToHeld).Boolean then
		//epr par 36103 30/4/15
		err :=app.myPassport.allErrors.first;	
		if err &lt;&gt; null and err.errorCode = MACH_LIFT_POWER then
			self.doDisconnectPower(err.myUserObject.CM_TrackedItem);
			if app.ackTIConnectError then
				delete err;
			endif;
			return IDOK;
		endif;
	endif;
	
	return app.showErrorWarningDialog(app.getErrorString(Error),app.myPassport,ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doShowGFX" id="26ec33e2-1182-46ae-8fa1-4b4aaf7cd493">
        <updating/>
        <source>doShowGFX(_lc : CM_LocationsController; _ti : CM_TrackedItem; _strLocation : String ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2010	cnwjk3	Initial creation

*/

vars
	isLandscape 	: Boolean;
begin

	self.hideGFXFrames();
	
	// We add the buttons in explicitly here, but we are using the current isLandscape property of the drawing controller
	// class.  We don't actually know if the current machine or target area supports the current setting, but we need to add
	// the buttons in before the drawing controller performs its various calculations for centering on the location of interest.
	// We then check further down in this method to see if the isLandscape changed.  If so, then we need to re-add the 
	// buttons and re-calculate.  It's a chicken and egg thing I'm afraid.
	isLandscape := self.myDrawingController.isLandscape;
	self.addGfxButtons();
	
	
	if _strLocation = null then 
		self.myDrawingController.gotoLocationByID(_lc, _ti, self.getConfiguredDefaultView(), not self.isZoomChanged);
	else
		// going by string allows us to use the stack height if it is present. this is needed for the gridded side/face view
		self.myDrawingController.gotoLocationByString(_strLocation, _ti, self.getConfiguredDefaultView(), not self.isZoomChanged);
	endif;
	
	if self.myDrawingController.isLandscape &lt;&gt; isLandscape then
		self.addGfxButtons();
		if _strLocation = null then 
			self.myDrawingController.gotoLocationByID(_lc, _ti, self.getConfiguredDefaultView(), not self.isZoomChanged);
		else
			// going by string allows us to use the stack height if it is present. this is needed for the gridded side/face view
			self.myDrawingController.gotoLocationByString(_strLocation, _ti, self.getConfiguredDefaultView(), not self.isZoomChanged);
		endif;
	endif;
	self.showGfxButtons(true);
	
	self.hideTaskFrames();
	
	self.showGFXFrames();
	if not app.isOnDevice then
		self.doResize();
	endif;

	self.btnGraphic.caption:=app.getErrorString(Details);
	self.updateCaption();
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_strLocation" type="String"/>
    </JadeMethod>
    <JadeMethod name="doShowGFXForSelectedTask" id="1a94dc5d-b0c0-46d8-98ae-f283e32f1f8e">
        <updating/>
        <source>doShowGFXForSelectedTask() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2010	cnwer1	Initial creation
07 July 2010 	cnwer1  PAR 24902
*/

vars
	ti 	: CM_TrackedItem ;
	lc : CM_LocationsController;
	rtQueueEntry : CM_RTQueueEntry;
	dtoEntry : DTO_RTQueueEntry;
	height 	: Integer;
	invalidObject : Boolean;
	theItemObject : Object;
	lcString 	  : String;
	allSelectedRows  : StringArray;
	edition,
	selectedRow : Integer;
begin
	
	invalidObject:=false;
	
	//on Exception do app.handleDeletedObject(exception,dtoEntry,invalidObject);
	if app.myVMAgent.showingTaskList then
		//epr par 24902 6/7/10
		if self.tblTasks.row &lt; 2 then
			return;
		endif;
		//Get selected dtoEntry get source lc 1/7/10 par 24580
		if self.tblTasks.accessedRow = null then
			return;
		endif;		
		//05 Sep 2014	NDL	Par 34730 - last access might have been a deselect
		allSelectedRows := self.tblTasks.tag.getTokens();
		selectedRow := allSelectedRows.first.Integer;
		if selectedRow &lt;= self.tblTasks.rows and selectedRow &gt; 0 then
			theItemObject := self.tblTasks.accessRow(selectedRow).itemObject;
		endif;
	
		
	else//if self.frmGetTask.visible then
		//epr par 24902 6/7/10
		if self.tblGetNext.columns &lt; 2 then
			return;
		endif;
		theItemObject := self.tblGetNext.accessColumn(2).itemObject;
	endif;
	
	if theItemObject = null then
		if self.isGFXViewVisible then
			self.hideGFXFrames();
			
			self.goToTaskFrame();
		endif;
		return;
	endif;
	
	
	if theItemObject &lt;&gt;  null then
		if theItemObject.isKindOf(DTO_RTQueueEntry) then
			dtoEntry:=theItemObject.DTO_RTQueueEntry;
			//epr par 37041 19/11/15
			on Exception  do app.handleDeletedObject(exception,rtQueueEntry,invalidObject);
			rtQueueEntry:=dtoEntry.myRealQueueEntry.CM_RTQueueEntry;
			edition:=rtQueueEntry.edition;
			if invalidObject then
				return;
			endif;
			if  self.isSettingDown then
			
				lc :=dtoEntry.getLocationTarget;
			else
				lc :=dtoEntry.getLocationSource;
			endif;
			ti:=dtoEntry.getTI;
		elseif theItemObject.isKindOf(CM_TrackedItem) then
			ti:=theItemObject.CM_TrackedItem;
			lcString:=ti.locationId;
			lc:=ti.myPrimaryActualLocation;
		endif;
	endif;
	
	//if director task this would be null so return 
	if not self.canLCGFXDisplay(lc) then
		lc:=null;
	endif;

	if lc = null then
		if self.isGFXViewVisible then
			self.hideGFXFrames();
			self.resizeForNoGraphics();
			self.goToTaskFrame();
		endif;
		return;
	endif;
	
	self.doShowGFX(lc, ti, lcString);
	self.frmMove.visible:=true;
	self.frmMoveEntry.visible:=true;
	self.frmTaskTable.visible:=false;
	self.frmGetTask.visible:=false;
	self.setupFrmMoveFields(theItemObject,null);
	self.grpNextPrev.visible:= app.myVMAgent.showingTaskList ; //epr par 35036 8/10/14
epilog

	delete allSelectedRows;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowTaskList" id="82b2f0e8-3dbe-4cb2-9ce0-77575270c4a9">
        <updating/>
        <source>doShowTaskList(showingTaskList : Boolean ) updating;
/*

Date		Who		Reason
04 December 2013	cnwer1	Initial creation PAR 33423

*/

vars
	allTasks : CM_RTQueueTaskArray;
begin
	if self.hasWorkingTask() then
		return;	
	endif;
	
    self.addInfoDisplay(null);
	app.myVMAgent.setShowingTaskList(showingTaskList);
	self.btnAccept.caption:=app.myVMAgent.getMoveTaskStr;
	self.showVoyageDischargeButton();
	//self.txtSearch.visible:=showingTaskList;
	self.setFramesVisible();
	if showingTaskList then
		
		//epr 2/7/10  par 24699
		if self.myMachine.allCurrentQueueTasks.size &gt; 0 then
			create allTasks transient;
			self.myMachine.allCurrentQueueTasks.copy(allTasks);
			app.myVMAgent.doCancelTasks(allTasks,false,false,null);
		endif;
	
		self.loadTable(self.tblTasks);	
		self.btnTaskMode.caption:=app.getErrorString(Get_mode);
		
		if self.myMachine.isTandemLift then
			self.btnTandem.caption := app.getErrorString(Tandem);
		elseif self.myMachine.isTwinLift then
			self.btnTandem.caption := app.getErrorString(CM_Twin);
		endif;
	else
		self.loadTable(self.tblGetNext);
		self.btnTaskMode.caption:=app.getErrorString(List_mode);
	endif;
	
	//self.setupFrmTop(showingTaskList);
	
epilog
	delete allTasks;
end;
</source>
        <Parameter name="showingTaskList" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSwapTandem" id="79b8a92c-be56-4584-84c7-976b081977e7">
        <updating/>
        <source>doSwapTandem() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2010	cnwer1	Initial creation

*/

vars
	firstDTO,
	secondDTO		: DTO_RTQueueEntry;
begin
	
	firstDTO:=self.tblMoveInfo.accessColumn(2).itemObject.DTO_RTQueueEntry;
	secondDTO:=self.tblMoveInfo.accessColumn(3).itemObject.DTO_RTQueueEntry;
	
	
	app.myVMAgent.doSwapTandemTasks(firstDTO,secondDTO);
	
	self.setupFrmMove;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSwapTwin" id="b5d73f12-34ec-411b-88ba-9a3a895a4e80">
        <updating/>
        <source>doSwapTwin() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2010	cnwer1	Initial creation

*/

vars
	firstLoc,
	twinEntRowName,
	twinLoc 		: String;
	view : EntTableView;
	entRow : EntTableRow;
	targetRow : Integer;
begin

	self.myMoveTableDetails.setDataColumn(3);
	firstLoc:=  self.getSetdownLocID;
	
	if self.myMachine.isTandemLift then
		self.doSwapTandem;
		return;
	else
		twinEntRowName:=ETRow_TwinTargetID;
	endif;
	// epr par 34603 CCMS 2404 4/8/14
	twinLoc:= self.getSetdownTwinLocID();
	
	if app.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen  then
		
		self.myMoveTableDetails.setDataColumn(3);
		self.myMoveTableDetails.addDataForEntRowName(ETRow_TargetID,twinLoc);
		self.myMoveTableDetails.setDataColumn(5);
		self.myMoveTableDetails.addDataForEntRowName(ETRow_TargetID,firstLoc);
		//epr par 34589 22/7/14
		view := self.myVMAgent.getMyRTVehicleConfig().myVisibleTaskFields;
		if view &lt;&gt; null then
			entRow:=view.myEntTableDef.getEntTableRow(ETRow_ModifiedTarget);
			//epr par 34705 11/8/14
			if entRow &lt;&gt; null then
				targetRow:=self.myMoveTableDetails.findRowWithEntRow(entRow);
				if targetRow &gt; 0 then
					firstLoc:=self.tblMoveEntry.accessCell(targetRow,3).text;	
					if firstLoc &lt;&gt; null and self.tblMoveEntry.columns &gt;=5 then
						twinLoc:=self.tblMoveEntry.accessCell(targetRow,5).text;
					endif;
					self.tblMoveEntry.accessCell(targetRow,3).text:=twinLoc;
					self.tblMoveEntry.accessCell(targetRow,5).text:=firstLoc;
				endif;
			endif;
			entRow:=view.myEntTableDef.getEntTableRow(ETRow_TargetLocation);
			if entRow &lt;&gt; null then
				targetRow:=self.myMoveTableDetails.findRowWithEntRow(entRow);
				if targetRow &gt; 0 then
					firstLoc:=self.tblMoveEntry.accessCell(targetRow,3).text;	
					if firstLoc &lt;&gt; null and self.tblMoveEntry.columns &gt;=5 then
						twinLoc:=self.tblMoveEntry.accessCell(targetRow,5).text;
					endif;
					self.tblMoveEntry.accessCell(targetRow,3).text:=twinLoc;
					self.tblMoveEntry.accessCell(targetRow,5).text:=firstLoc;
				endif;
			endif;
		endif;
	else
	
		self.myMoveTableDetails.addDataForEntRowName(ETRow_TargetID,twinLoc);
	
		self.myMoveTableDetails.addDataForEntRowName(twinEntRowName,firstLoc);
	endif;	
epilog
	self.myMoveTableDetails.setDataColumn(DataColumn);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSwitchView" id="a5568cc8-a580-4f19-8fb1-dc1c5a938c7a">
        <updating/>
        <source>doSwitchView() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2010	cnwjk3	Initial creation

*/

vars
	foundNextMode	: Boolean;
	nextMode,
	configMode,
	controllerMode : Integer;
begin
	// Get the current mode from the drawing controller and convert it to the config equivalent
	configMode := self.controllerViewToConfigView(self.myDrawingController.drawMode);
	// set the default mode to switch to if all else fails
	nextMode := self.configViewToControllerView(app.myVMAgent.getMyRTVehicleConfig.defaultGraphicView); 
	if configMode = CM_RTVehicleConfig.VIEW_TOP then
		// Try face view 
		if app.myVMAgent.getMyRTVehicleConfig.canDisplayFaceView() then
			if self.myDrawingController.myDisplayBuilder.canDisplayFace() then	
				nextMode := self.configViewToControllerView(CM_RTVehicleConfig.VIEW_FACE);	
				//28/11/2011 cnwdz2 28691
				if self.myDrawingController.isDrawForkLiftStack(self.myDrawingController.myTargetLocation) then	
					//17/06/2011 cnwdz2	27732
					if self.myDrawingController.canDrawForkLiftStackTop() then
						foundNextMode := true;		
					elseif self.myDrawingController.canDrawForkLiftStackBottom() then
						self.myDrawingController.setLookForkLiftStackFromBottom(true);
						self.myDrawingController.setHighlightLCs(null, nextMode); 
						self.myDrawingController.setDrawMode(nextMode);
						self.updateCaption();
						return;					
					endif;		
				else
					foundNextMode := true;
				endif;
			endif;
		endif;
			
		// Try end view
		if not foundNextMode and app.myVMAgent.getMyRTVehicleConfig.canDisplayEndView() then
			if self.myDrawingController.myDisplayBuilder.canDisplayEnd() then			
				nextMode := self.configViewToControllerView(CM_RTVehicleConfig.VIEW_END);
				foundNextMode := true;
			endif;		
		endif;
	
	elseif configMode = CM_RTVehicleConfig.VIEW_FACE then
		//20/04/2011 cnwdz2 27313 start
		if self.myDrawingController.isDrawForkLiftStack(self.myDrawingController.myTargetLocation) then			
			if self.myDrawingController.lookForkLiftStackFromBottom then			
				self.myDrawingController.setLookForkLiftStackFromBottom(false);
			elseif self.myDrawingController.canDrawForkLiftStackBottom() then
				self.myDrawingController.setLookForkLiftStackFromBottom(true);
				nextMode := self.configViewToControllerView(CM_RTVehicleConfig.VIEW_FACE);
				self.myDrawingController.setHighlightLCs(null, nextMode); 
				self.myDrawingController.setDrawMode(nextMode);
				self.updateCaption();
				return;
			endif;
		endif;
		//20/04/2011 cnwdz2 27313 end
		
		// Try end view
		if app.myVMAgent.getMyRTVehicleConfig.canDisplayEndView() then
			if self.myDrawingController.myDisplayBuilder.canDisplayEnd() then			
				nextMode := self.configViewToControllerView(CM_RTVehicleConfig.VIEW_END);
				foundNextMode := true;
			endif;		
		endif;
		
		// Try top-down view
		if not foundNextMode and app.myVMAgent.getMyRTVehicleConfig.canDisplayTopDownView() then				
			if self.myDrawingController.myDisplayBuilder.canDisplayTopDown() then			
				nextMode := self.configViewToControllerView(CM_RTVehicleConfig.VIEW_TOP);
				foundNextMode := true;
			endif;		
		endif;
		
	elseif configMode = CM_RTVehicleConfig.VIEW_END then

		// Try top-down view
		if not foundNextMode and app.myVMAgent.getMyRTVehicleConfig.canDisplayTopDownView() then
			if self.myDrawingController.myDisplayBuilder.canDisplayTopDown() then			
				nextMode := self.configViewToControllerView(CM_RTVehicleConfig.VIEW_TOP);
				foundNextMode := true;
			endif;		
		endif;

		// Try face view
		if not foundNextMode and app.myVMAgent.getMyRTVehicleConfig.canDisplayFaceView() then
			if self.myDrawingController.myDisplayBuilder.canDisplayFace() then			
				nextMode := self.configViewToControllerView(CM_RTVehicleConfig.VIEW_FACE);
				foundNextMode := true;
			endif;
		endif;		
		
	endif;
	
	if nextMode &lt;&gt; self.myDrawingController.drawMode then
		if self.myDrawingController.isLandscape then
			if not self.myDrawingController.myDisplayBuilder.canDisplayLandscape(nextMode) then
				// We are currently in landscape view, but the next drawing mode doesn't support landscape
				// so we need to reposition the buttons accordingly
				self.resizeForGfxButtonsPortrait();
			endif;
		
		else
			if not self.myDrawingController.myDisplayBuilder.canDisplayPortrait(nextMode) and not self.isForceLandscapeButtons() then
				// We are currently in portrait view, but the next drawing mode doesn't support portrait
				// so we need to reposition the buttons accordingly
				self.resizeForGfxButtonsLandscape();
			endif;		
		endif;
	
		// Another mode is supported for the current type of area that we are viewing, so let's do it
		self.myDrawingController.setHighlightLCs(null, nextMode);  // passing null will force a refresh of how LCs are keyed in...
		self.myDrawingController.setDrawMode(nextMode);
		self.updateCaption();
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTableHighlightTarget" id="304cdcf4-0296-4a79-897a-027383c56364">
        <updating/>
        <source>doTableHighlightTarget(_table : Table input) protected, updating;
/*

Date		Who		Reason
13 February 2014	cnwer1	Initial creation PAR 33401

*/

vars
	targetRow : Integer;
	view : EntTableView;
	entRow : EntTableRow;
	targetCell : JadeTableCell;
	screenMode : CM_RTScreenConfig;
	dataColumn: Integer;
begin
	//epr par 34591 21/7/14
	dataColumn:=2;
	if self.hasControlChangedTarget or self.hasControlChangedTwinTarget then
		screenMode:=self.myVMAgent.getMyScreenMode;
		view := self.myVMAgent.getMyRTVehicleConfig().myVisibleTaskFields;
		if view &lt;&gt; null then
			if self.hasControlChangedTarget then
				entRow:=view.myEntTableDef.getEntTableRow(ETRow_TargetLocation);
				targetRow:=view.allEntTableRows.indexOf(entRow);
				if _table = self.tblMoveEntry then
					dataColumn:=self.DataColumn;	
				endif;
				if targetRow &gt; 0 then
					targetCell:=_table.accessCell(targetRow,dataColumn );
					targetCell.foreColor:=screenMode.tableSelectColour;
				endif;
				entRow:=view.myEntTableDef.getEntTableRow(ETRow_ModifiedTarget);
				//epr par 34591 21/7/14
				if _table = self.tblMoveEntry then
					targetRow:=self.myMoveTableDetails.findRowWithEntRow(entRow);
				else
					targetRow:=view.allEntTableRows.indexOf(entRow);
				endif;
				if targetRow &gt; 0 then
					targetCell:=_table.accessCell(targetRow,dataColumn );
					targetCell.foreColor:=screenMode.tableSelectColour;
				endif;
			endif;
			if self.hasControlChangedTwinTarget and _table.columns &gt; 2 then
				dataColumn:=self.DataColumn;
				if _table = self.tblMoveEntry then
					//dataColumn:=;	
				endif;
				entRow:=view.myEntTableDef.getEntTableRow(ETRow_TargetLocation);
				targetRow:=view.allEntTableRows.indexOf(entRow);
				if self.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen then
					if _table = self.tblMoveEntry then
						dataColumn:=5;
					endif;
				endif;
					//epr par 34591 21/7/14
	
				if targetRow &gt; 0 then
					targetCell:=_table.accessCell(targetRow,dataColumn );
					targetCell.foreColor:=screenMode.tableSelectColour;
				endif;
				entRow:=view.myEntTableDef.getEntTableRow(ETRow_ModifiedTarget);
				//epr par 34591 21/7/14
				if _table = self.tblMoveEntry then
					targetRow:=self.myMoveTableDetails.findRowWithEntRow(entRow);
				else
					targetRow:=view.allEntTableRows.indexOf(entRow);
				endif;
				if targetRow &gt; 0 then
					targetCell:=_table.accessCell(targetRow,dataColumn );
					targetCell.foreColor:=screenMode.tableSelectColour;
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doZoomIn" id="a982061c-5b1d-4b21-9e6a-ed66c2d24384">
