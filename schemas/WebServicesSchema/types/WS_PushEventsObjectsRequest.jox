<Class name="WS_PushEventsObjectsRequest" id="1c32de4a-7d76-4b0a-8070-032234710ef1">
    <superclass name="WS_Request"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <PrimAttribute name="className" id="2dd5a29a-76ab-422a-bcf2-e1b7edd7acc9">
        <length>101</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Class name of objects to return.</text>
    </PrimAttribute>
    <PrimAttribute name="includeSubclasses" id="5d207441-57d4-4aa4-9d1d-1144640c4497">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
        <text>Set to true to include objects from the subclasses of the passed in className in the objects returned.</text>
    </PrimAttribute>
    <PrimAttribute name="maxResults" id="7487eedc-c3da-4c6f-ac4c-2af88243c6e6">
        <embedded/>
        <type name="Integer64"/>
        <access>readonly</access>
        <text>Maximum number of results to return.  Zero means no maximum.</text>
    </PrimAttribute>
    <PrimAttribute name="startFrom" id="d3cddd5d-a5f2-43be-aef2-5e037a0cee80">
        <embedded/>
        <type name="Integer64"/>
        <access>readonly</access>
        <text>Object in the instances of the passed in className to start from. To be used when paging to restrict the number of returned objects.</text>
    </PrimAttribute>
</Class>
