    <JadeMethod name="setLaneId" id="acb315df-c405-4765-a375-3f10933e6324">
        <updating/>
        <source>setLaneId(_id : String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwjk3	Initial creation

*/

vars

begin
	if not self.myRoRoLaneArea.allLanesById.includesKey(_id) then
