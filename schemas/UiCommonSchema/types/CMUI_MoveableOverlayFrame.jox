    <JadeMethod name="create" id="128044c4-156c-4c33-8c40-d5b2f4957552">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.bevelInnerWidth := 0;
	self.bevelOuterWidth := 0;
	self.borderStyle := Frame.BorderStyle_None;
	self.boundaryBrush := 0;
	self.boundaryWidth := 0;
	self.caption := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="f8c955ae-cbdc-426a-b90f-e8fb38b16ca8">
        <controlMethod name="CMUI_MoveableFrame::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     06 January 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.myMoveableFrame.mouseDown(self.myMoveableFrame, button, shift, x, y);
	self.inDragMode := true;
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
