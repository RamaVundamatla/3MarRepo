    <JadeMethod name="doResizeColumnWidths" id="41143205-b723-4b85-974d-f2a10cc1f215">
        <source>doResizeColumnWidths(table : Table input; allowForScrollBar : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:		04 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
// Purpose:		Resizes columns based on their original size
// ---------------------------------------------------------------------------

constants
	TableBorderWidth = 2;
	
vars
	totalWidth : Integer;
	colWidth : Integer;
	col : Integer;
	tblWidth : Integer;
	jCol : JadeTableColumn;
	scrollWidth : Integer;
	
begin
	if allowForScrollBar then
		scrollWidth := app.getVerticalScrollbarWidth;
	else
		scrollWidth := 0;
	endif;
	
	totalWidth := table.width.truncated - scrollWidth - TableBorderWidth;
	colWidth := (totalWidth / table.columns).truncated;

	foreach col in table.fixedColumns + 1 to table.columns do
		jCol := table.accessColumn(col);

		if not jCol.visible then
			// Ignore invisible columns
			continue;
		endif;
		
		jCol.width := colWidth;
		
		tblWidth := tblWidth + jCol.width;
	endforeach;
	
	// Apply any rounding error difference to the last column
	jCol := table.accessColumn(table.columns);
	jCol.width := jCol.width + totalWidth - tblWidth;
end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="allowForScrollBar" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectAll" id="de6b82f9-9e79-42ed-bf28-9523acece02c">
