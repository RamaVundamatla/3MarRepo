    <JadeMethod name="doButtonRightClick" id="912ee943-d312-42b4-9191-8dfc6994f6e4">
        <updating/>
        <source>doButtonRightClick()updating;
/*
	Created on 04 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	app.mousePointer	:=	Busy;
	self.doCloseForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
