    <JadeMethod name="zGetTranslatableTextEdition" id="f6e569ad-ba97-4587-95ee-076754ffa2e7">
        <source>zGetTranslatableTextEdition(_table : CM_TextTranslationTable):Integer protected;

vars
	table : CM_TextTranslationTable;
begin
	table := _table;
	return table.accessRow(table.row).JadeTableRow.decimals;	// use JadeTableRow::decimals property to store the object edition
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_TextTranslationTable"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zInitialiseProgressMonitor" id="cf8da449-0b82-45c0-8590-88bc0bde88f3">
        <updating/>
        <source>zInitialiseProgressMonitor(_partsDone, _partsInJob : Integer; _message : String) updating, protected;

// set cursor = hourglass, and start/show progress bar
// MUST call corresponding zFinaliseProgressMonitor in epilog

begin
	app.mousePointer := MousePointer_HourGlass;				

	if self.myProgress = null then
		create self.myProgress transient;
		self.myProgress.myParent := self;
	endif;
	
	modalDialogReturnValue := ModalDialogReturn_Null;	
	modalDialogShow(null, 'Cancel', null, null, _message,  'Please Wait....');
	pbProgressBar.visible := true;

	self.myProgress.updateProgress(myProgress.message, _partsInJob, _partsDone);
end;</source>
        <access>protected</access>
        <Parameter name="_partsDone" type="Integer"/>
        <Parameter name="_partsInJob" type="Integer"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
    <JadeMethod name="zUpdateProgressMonitor" id="4b938316-74f4-4c74-8661-411648a03d9d">
        <updating/>
        <source>zUpdateProgressMonitor(_partsDone : Integer) : Boolean protected, updating;

vars

begin
	if self.myProgress &lt;&gt; null then
		return self.myProgress.updateProgress(self.myProgress.message, self.myProgress.partsInJob, _partsDone);
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_partsDone" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
