    <JadeMethod name="initForm" id="80252af3-7b48-4b55-9585-4ca2c6df12ce">
        <updating/>
        <source>initForm() updating;
//06 August 2009	cnwdw1	
//
vars

begin

	
	self.showDataOnStartup 	:= false;
	self.chkShowAllCargo.value := true;
	self.toolbarStyle := ToolbarStyle_None;
	
	self.tblExpected.allowDragSelect := true;
	self.tblUnreconciled.allowDragSelect := true;
	
	self.tblExpected.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblExpected.multiSelect := CM_BaseTable.MultiSelect_Simple;	
	self.setColorsForTable(self.tblExpected);
	
	self.tblActual.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblActual.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.setColorsForTable(self.tblActual);

	self.tblUnreconciled.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblUnreconciled.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.setColorsForTable(self.tblUnreconciled);
	
	self.frmMain.borderStyle := Form.BorderStyle_None;
	self.sptLeft.borderStyle := Form.BorderStyle_None;
	self.sptRight.borderStyle := Form.BorderStyle_None;
	self.tblExpected.borderStyle := Form.BorderStyle_None;
	self.tblActual.borderStyle := Form.BorderStyle_None;
	self.tblUnreconciled.borderStyle := Form.BorderStyle_None;
	self.tblExpectedMacro.borderStyle := Form.BorderStyle_None;
	self.tblActualMacro.borderStyle := Form.BorderStyle_None;
	self.tblUnreconMacro.borderStyle := Form.BorderStyle_None;
	
	if self.sptLeftRatioSaved &lt;&gt; 0 then
		self.sptLeft.setLeftToRightRatio(self.sptLeftRatioSaved);
	else
		self.sptLeft.setLeftToRightRatio(33);
	endif;
	if self.sptRightRatioSaved &lt;&gt; 0 then
		self.sptRight.setLeftToRightRatio(self.sptRightRatioSaved);
	else
		self.sptRight.setLeftToRightRatio(50);
	endif;	

end;</source>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="a0f35192-7a1b-4596-88d7-c11619ed62b0">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
vars
	xml: String;
begin

	inheritMethod(_userWindow);

	xml := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.tblExpected.XMLTag_Table &amp; self.tblExpected.name);
	if xml &lt;&gt; null then
		self.xmlStrTblExpected := global.formatAsXMLPrefix(self.tblExpected.XMLTag_Table &amp; self.tblExpected.name) &amp; 
								  xml &amp;
								  global.formatAsXMLSuffix(self.tblExpected.XMLTag_Table &amp; self.tblExpected.name);
	endif;

	xml := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.tblActual.XMLTag_Table &amp; self.tblActual.name);
	if xml &lt;&gt; null then
		self.xmlStrTblActual := global.formatAsXMLPrefix(self.tblActual.XMLTag_Table &amp; self.tblActual.name) &amp; 
								  xml &amp;
								  global.formatAsXMLSuffix(self.tblActual.XMLTag_Table &amp; self.tblActual.name);
	endif;

	xml := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.tblUnreconciled.XMLTag_Table &amp; self.tblUnreconciled.name);
	if xml &lt;&gt; null then
		self.xmlStrTblUnreconciled := global.formatAsXMLPrefix(self.tblUnreconciled.XMLTag_Table &amp; self.tblUnreconciled.name) &amp; 
								  xml &amp;
								  global.formatAsXMLSuffix(self.tblUnreconciled.XMLTag_Table &amp; self.tblUnreconciled.name);
	endif;
	
	xml := _userWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_Splitter &amp; ' name="sptLeft"');
	if xml &lt;&gt; null then
		xml := xml.cnEcGetTagValueOfName(XMLTag_Ratio);
		if xml &lt;&gt; null then
			self.sptLeftRatioSaved := xml.Integer;
		endif;
	endif;
	xml := _userWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_Splitter &amp; ' name="sptRight"');
	if xml &lt;&gt; null then
		xml := xml.cnEcGetTagValueOfName(XMLTag_Ratio);
		if xml &lt;&gt; null then
			self.sptRightRatioSaved := xml.Integer;
		endif;
	endif;

	
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
