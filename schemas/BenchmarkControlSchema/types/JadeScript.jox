		//ff.fileName:="\\" &amp; m.hostName &amp; "\c$\Users\cnwjbl36\AppData\Local\Microsoft\Windows\WER\ReportQueue";
		//f.fileName:="\\" &amp; m.hostName &amp; "\c$\cardinal\bin\jblautorun.exe";
		f.fileName:="\\" &amp; m.hostName &amp; "\c$\cardinal\bin\jblworker.exe";
