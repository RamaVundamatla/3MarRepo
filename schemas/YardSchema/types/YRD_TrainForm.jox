    <JadeMethod name="btnMoveWagon_click" id="fa54fce0-42d3-4056-9f38-62716298f7fc">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnMoveWagon_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2022	navhl20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars
	form : YRD_WagonMoveForm;
	wagon : CM_Wagon;
begin
	wagon := self.tblWagons.allSelectedObjects.first.CM_Wagon;
	if wagon = null then
		app.msgBox(app.getErrorString(Please_select_wagon), app.getErrorString(No_Wagon_selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	form := app.loadForm(YRD_WagonMoveForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WagonMoveForm;
	if form = null then
		return;
	endif;
	form.setCollection(self.tblWagons.allSelectedObjects,null,self.moveModeForm);  //should change the mode once statusbar added
	form.show();
epilog

end;</source>
