end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getGMTTimestamp" id="5c9a28f2-5eae-4f13-b42b-a426e1d6795f">
        <source>getGMTTimestamp():TimeStamp;
// --------------------------------------------------------------------------------
// Created:		17 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	timestampGMT	: TimeStamp;
	
begin
	return timestampGMT.cnGMT;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
