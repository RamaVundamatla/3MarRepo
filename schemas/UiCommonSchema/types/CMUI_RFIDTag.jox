    <JadeMethod name="addPreGateAlert" id="75f2364d-25cd-44ab-9f1c-0e2fa2be8fb8">
        <source>addPreGateAlert(_descr : String) protected;
/*
----------   ----------  --------------------------------------------------
Created:	06 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
begin
	
	app.myPassport.createAlert(SEVERE_ERROR, 
								_descr,
								EVENT_AT_PreGateAlert,
								self.myJob);	
	beginTransaction;
	app.commitAlert();
	commitTransaction;
	
	
end;


</source>
        <access>protected</access>
        <Parameter name="_descr" type="String"/>
    </JadeMethod>
    <JadeMethod name="beginNotifications" id="451b8f55-5682-4a6b-8b18-92c8bd0ee4bc">
        <updating/>
        <source>beginNotifications() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	06 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	app.beginRFIDTagNoteWindowsPC(Event_RFIDTagRead, self, self.myTerminal);
	
	self.beginNotification(global, self.myTerminal.getTerminalEvent(Event_RFIDTagFree), Response_Continuous, null);
	self.beginNotification(global, self.myTerminal.getTerminalEvent(Event_RFIDTagInUse), Response_Continuous, null);
	

end;


</source>
        <access>protected</access>
    </JadeMethod>
