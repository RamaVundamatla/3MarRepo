    <JadeMethod name="emptyRecord" id="ab7c1f86-643a-4ca1-b8f3-3b4e5d8250f0">
        <source>emptyRecord(_record: String):Boolean;
//
//11 Jul 2014	cnwrs1	Par 34566 CCMS 2346 Suzano - Viagram Prenote file 
//
constants
	TIID_Length : Integer = 2;
vars
//	length,
//	endPos,
//	startPos	: Integer;
//	value,
	strRec		: String;
begin
//	strRec := _record.replaceString(",", "").trimBlanks;
	strRec := _record.replaceString( CNEC_COMMA, null ).trimBlanks;
	
	if strRec = null or 					//no information
	(strRec.length &lt; TIID_Length) then		//not enough information
		return true;
	else
		return false;
	endif;

/*	over kill
	startPos := 1;
	endPos := 1;

	while startPos &lt; (strRec.length) do
		endPos := strRec.pos("," , startPos) - 1;
		if endPos = 0 then
			return true;
		endif;
		if endPos &gt; startPos then
			length := (endPos+1)- startPos;	
		endif;
		
		value := strRec[startPos:length];
		if value.trimBlanks &lt;&gt; null then
			return false;
		endif; 
		startPos := endPos + 2;
	endwhile;
	return true;

*/
end;</source>
        <Parameter name="_record" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
