	if combobox.listIndex &gt; 0 and self.myProxyBookingRef &lt;&gt; null then								// PAR #31155
		self.myProxyBookingRef.setMyOperator(combobox.itemObject[combobox.listIndex].CM_Operator);	// PAR #31155
	endif;																							// PAR #31155
epilog

end;</source>
