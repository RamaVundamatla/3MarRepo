<GUIClass name="Label">
    <JadeMethod name="controlNamePrefix" id="4635a8de-29ba-42a3-84ef-16fddc4c354d">
        <source>controlNamePrefix(): String;
// --------------------------------------------------------------------------------
// Created:		05 May 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "lbl";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssDate" id="08548a51-af78-481d-aab8-0b6ac42f196b">
        <source>jssDate():Date;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the text value of the receiver's caption as a Date value.
//
// Parameters:	None
//
// Returns:		Date - the trimmed caption cast to a Date value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.caption.trimBlanks.Date;
end;</source>
        <text>___________________________________________________________________________

