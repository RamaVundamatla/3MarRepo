    <JadeMethod name="getEquipments" id="f014924e-6b75-489a-a72a-2b51617ea4ae">
        <updating/>
        <source>getEquipments(_ediDataPrenote: CM_EDIData; _xlOperator: CM_Operator): String updating, protected;
//----------------------------------------------------------------
//	Created:	29 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ediTI		: CM_EDITrackedItem;
	str			: String;
begin

	str := str &amp; '&lt;Equipments&gt;' &amp; CrLf;
	
	
	foreach ediTI in _ediDataPrenote.allEDITrackedItems do
		str := str &amp; self.getTIDetails(ediTI.CM_EDIPrenoteTI, _xlOperator);
	endforeach;	
					
	

	str := str &amp; '&lt;/Equipments&gt;' &amp; CrLf;
	
	return str;

end;</source>
        <access>protected</access>
        <Parameter name="_ediDataPrenote" type="CM_EDIData"/>
        <Parameter name="_xlOperator" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGoodsItems" id="3856eb3d-3a15-4d58-8b94-976b80eb060d">
        <source>getGoodsItems(): String protected;
//----------------------------------------------------------------
//	Created:	29 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str			: String;
begin

	str := str &amp; '&lt;GoodsItems&gt;' &amp; CrLf;
		str := str &amp; '&lt;GoodsItem&gt;' &amp; CrLf;
			str := str &amp; '&lt;FreightDescription&gt;Dry GOODS&lt;/FreightDescription&gt;' &amp; CrLf;
		str := str &amp; '&lt;/GoodsItem&gt;' &amp; CrLf;
	str := str &amp; '&lt;/GoodsItems&gt;' &amp; CrLf;
	
	return str;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMessageBody" id="a4d194c1-e0ea-441b-b6bb-b954ff376fe1">
        <updating/>
        <source>getMessageBody(_ediDataPrenote: CM_EDIData): String updating, protected;
//----------------------------------------------------------------
//	Created:	29 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str		: String;
begin


	str := str &amp; '&lt;MessageBody&gt;' &amp; CrLf;
	str := str &amp; '&lt;PreAdvice&gt;' &amp; CrLf;
	str := str &amp; '&lt;CustReferenceNo&gt;' &amp; '' &amp; '&lt;/CustReferenceNo&gt;' &amp; CrLf;
	str := str &amp; '&lt;FSBReference&gt;' &amp; '' &amp; '&lt;/FSBReference&gt;' &amp; CrLf;

	str := str &amp; self.getTransportDetails(null);
	str := str &amp; self.getGoodsItems;
	str := str &amp; self.getEquipments(_ediDataPrenote, null);
	str := str &amp; self.getDGRecords(_ediDataPrenote);
	
//	foreach ediTI in ediDataPrenote.allEDITrackedItems do
//		self.extractTI(_ediFile, ediTI.CM_EDIPrenoteTI, null, xlOperator);
//	endforeach;

	str := str &amp; '&lt;/PreAdvice&gt;' &amp; CrLf;
	str := str &amp; '&lt;/MessageBody&gt;' &amp; CrLf;


	return str;
end;</source>
        <access>protected</access>
        <Parameter name="_ediDataPrenote" type="CM_EDIData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMessageHeader" id="30bac5ac-dbe7-49aa-95e7-36d46b416128">
        <source>getMessageHeader(_sequenceNum: Integer): String protected;
//----------------------------------------------------------------
//	Created:	29 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	now		: TimeStamp;
	str		: String;
	strTime	: String;
	
begin
	strTime := now.date.shortYearEDI() &amp; now.time.shortFormatEDI();

	str := str &amp; '&lt;MessageHeader&gt;' &amp; CrLf;
		str := str &amp; '&lt;SenderID&gt;' &amp; app.getMyTerminalConfigDO_NOT_USE(PortDestCode).String &amp; '&lt;/SenderID&gt;' &amp; CrLf;
		str := str &amp; '&lt;RecipientID&gt;' &amp; 'TRLEDI' &amp; '&lt;/RecipientID&gt;' &amp; CrLf;
		str := str &amp; '&lt;Prepared&gt;' &amp; strTime &amp; '&lt;/Prepared&gt;' &amp; CrLf;
		str := str &amp; '&lt;MessageReference&gt;' &amp; _sequenceNum.String &amp; '&lt;/MessageReference&gt;' &amp; CrLf;
		str := str &amp; '&lt;MessageType&gt;' &amp; 'preadv' &amp; '&lt;/MessageType&gt;' &amp; CrLf;
		str := str &amp; '&lt;MessageVersion&gt;' &amp; '101' &amp; '&lt;/MessageVersion&gt;' &amp; CrLf;
	str := str &amp; '&lt;/MessageHeader&gt;' &amp; CrLf;
	return str;

end;</source>
        <access>protected</access>
        <Parameter name="_sequenceNum" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTIDetails" id="9b245625-a187-407e-ab90-566dfa177414">
        <source>getTIDetails(_ediTI: CM_EDIPrenoteTI; _xlOperator: CM_Operator): String protected;
//----------------------------------------------------------------
//	Created:	29 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str			: String;
begin

	str := str &amp; '&lt;Equipment&gt;' &amp; CrLf;
	str := str &amp; '&lt;EquipmentIDQual&gt;CN&lt;/EquipmentIDQual&gt;' &amp; CrLf;
	str := str &amp; '&lt;EquipmentID&gt;' &amp; _ediTI.id &amp; '&lt;/EquipmentID&gt;' &amp; CrLf;
	str := str &amp; '&lt;EquipmentSize&gt;' &amp; _ediTI.isoType[1:2] &amp; '&lt;/EquipmentSize&gt;' &amp; CrLf;
	str := str &amp; '&lt;Measurements&gt;' &amp; CrLf;
		str := str &amp; '&lt;Measurement Property="DECLARED WEIGHT"&gt;' &amp; CrLf;
			str := str &amp; '&lt;Value&gt;' &amp; _ediTI.weight.asStringWeightJMT() &amp; '&lt;/Value&gt;' &amp; CrLf;
			str := str &amp; '&lt;Unit&gt;KGM&lt;/Unit&gt;' &amp; CrLf;
		str := str &amp; '&lt;/Measurement&gt;' &amp; CrLf;
	str := str &amp; '&lt;/Measurements&gt;' &amp; CrLf;
	str := str &amp; '&lt;AssocWagon&gt;' &amp; _ediTI.wagonNumber &amp; '&lt;/AssocWagon&gt;' &amp; CrLf;
	str := str &amp; '&lt;BookingRefNo&gt;' &amp; _ediTI.bookingRef &amp; '&lt;/BookingRefNo&gt;' &amp; CrLf;
//	str := str &amp; '&lt;OrderNo&gt;' &amp; '' &amp; '&lt;/OrderNo&gt;' &amp; CrLf;
	if _ediTI.sealNum &lt;&gt; null then
		str := str &amp; '&lt;SealNo&gt;' &amp; _ediTI.sealNum &amp; '&lt;/SealNo&gt;' &amp; CrLf;
	endif;
	if _ediTI.temperature &gt; NULL_TEMPERATURE then
		str := str &amp; '&lt;Temperature1&gt;' &amp; _ediTI.temperatureAbsolute.String &amp; '&lt;/Temperature1&gt;' &amp; CrLf;
		str := str &amp; '&lt;TemperatureSign1&gt;' &amp; _ediTI.temperatureSign.String &amp; '&lt;/TemperatureSign1&gt;' &amp; CrLf;
	endif;
//	str := str &amp; '&lt;TimeOffPower1&gt;' &amp; _ediTI.id &amp; '&lt;/TimeOffPower1&gt;' &amp; CrLf;
//	str := str &amp; '&lt;DateTimeRemoved1&gt;' &amp; _ediTI.id &amp; '&lt;/DateTimeRemoved1&gt;' &amp; CrLf;
//	str := str &amp; '&lt;OverGaugeInd&gt;' &amp; _ediTI.id &amp; '&lt;/OverGaugeInd&gt;' &amp; CrLf;
//	str := str &amp; '&lt;UnderBondInd&gt;' &amp; _ediTI.id &amp; '&lt;/UnderBondInd&gt;' &amp; CrLf;
	str := str &amp; '&lt;/Equipment&gt;' &amp; CrLf;
		
	return str;	

end;</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDIPrenoteTI"/>
        <Parameter name="_xlOperator" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTransportDetails" id="3b6c1f72-6879-4d5c-a069-20d8cc2941f8">
        <source>getTransportDetails(_departTime: String): String protected;
//----------------------------------------------------------------
//	Created:	29 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str			: String;
begin

	str := str &amp; '&lt;TransportDetails&gt;' &amp; CrLf;
