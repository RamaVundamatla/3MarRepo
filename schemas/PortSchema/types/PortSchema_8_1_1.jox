    <JadeMethod name="fixSystemSealTypes" id="0589f346-447d-456a-a228-cb0587dc208f">
        <source>fixSystemSealTypes();
/*

Purpose:			Check and fix the system Seal Types if required.  This method needs to be
					run before convertRemainingSealData, and should only do something if a database
					is upgraded to 8.1.1 without applying all the 7.9.2 hotfixes.
					Cloned from JadeScript::par28761, which was deployed in a 7.9.2 hotfix

Parameters:			None

Return Value:		None

Date		Who		Reason
20 Dec 2011	cnwkpd1	PAR #28863 - Fix upgrade issues for System Seal Types

*/
vars
	isoContainerCargoType 	: CM_CargoType;
	sealType 				: CM_SealType;
	allSystemSealTypes 		: CM_SealTypeSet;
	
	proxySealType 			: CM_SealType;
	loadState 				: Boolean;
	updatedAllCargoTypes	: CM_CargoTypeSet;

begin
	isoContainerCargoType := app.myRoot.allCargoTypesById.getAtKey(TI_CargoType_Container);
	
	if isoContainerCargoType &lt;&gt; null and isoContainerCargoType.allSealTypes.isEmpty then
		// probably means the upgrade handler cleared them all out...
		app.writeLog( method.qualifiedName &amp; ' - Adding ISO Container to all system seal types', LogINFO);
		
		// get a collection of the system seal types.
		create allSystemSealTypes transient;
		sealType := app.myRoot.getSealType( SealType_Operator );
		if sealType &lt;&gt; null then
			allSystemSealTypes.add( sealType );
		endif;
		sealType := app.myRoot.getSealType( SealType_Customs );
		if sealType &lt;&gt; null then
			allSystemSealTypes.add( sealType );
		endif;
		sealType := app.myRoot.getSealType( SealType_Shipper );
		if sealType &lt;&gt; null then
			allSystemSealTypes.add( sealType );
		endif;
		sealType := app.myRoot.getSealType( SealType_Vent );
		if sealType &lt;&gt; null then
			allSystemSealTypes.add( sealType );
		endif;
		
		//create a collection to use for updating the cargo types
		create updatedAllCargoTypes transient;
		
		foreach sealType in allSystemSealTypes do
		
			updatedAllCargoTypes.clear();
			
			app.cmsBeginLoad( loadState );
			proxySealType := sealType.pxyCreateUpdateProxy();
			app.cmsEndLoad( loadState );
			
			if not sealType.allCargoTypes.isEmpty then
				// keep any that are still set up for NON system related cargo types...
				sealType.allCargoTypes.copy( updatedAllCargoTypes );
			endif;
			updatedAllCargoTypes.add( isoContainerCargoType ); // Add Container
			
			proxySealType.setProxy(	sealType.sealType,	//_sealType: String;
									sealType.description,	//_description: String;
									updatedAllCargoTypes,	//_allCargoTypes: CM_CargoTypeSet;
									sealType.allowMultipleSealNums,	//_allowMultipleSealNums: Boolean;
									sealType.notAvailableForEntry,	//_notAvailableForEntry: Boolean;
									sealType.showSealOnCheck,	//_showSealOnCheck: Boolean;
									sealType.savePreviousSeal,	//_savePrevSeal : Boolean
									sealType.useForTrucks		//_useForTrucks : Boolean;
									);
	
			app.myTrxUA.trxUpdateSealType( proxySealType, app.myPassport );
			
			delete proxySealType;
	
		endforeach;
		
	else
		app.writeLog( method.qualifiedName &amp; ' - System seal types already include ISO Container', LogINFO);

	endif;

epilog
	app.cmsEndLoad( loadState );
	delete allSystemSealTypes;
	delete updatedAllCargoTypes;
	delete proxySealType;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="fixTerminalJobSheets" id="c748d535-19ea-4036-8a0f-8b4e95db98ff">
        <source>fixTerminalJobSheets();

/*

