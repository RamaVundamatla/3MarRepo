vars

begin
	return self.mySound;
end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="af820a89-7174-40b5-bdee-773b5934ab31">
        <updating/>
        <source>setValue(pValue: Any) updating;
// ---------------------------------------------------------------------------
// Created:     23 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpValue	: Sound;
	
begin

	tmpValue := pValue.Sound;
	if self.mySound &lt;&gt; tmpValue then
		self.mySound := tmpValue;
	endif;
	
end;</source>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
