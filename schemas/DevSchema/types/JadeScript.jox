    <JadeMethod name="rh_FindInvoiceLine" id="eea6c465-e22b-465d-b5da-61d84a534f2a">
        <source>rh_FindInvoiceLine();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 September 2017	jlgrh7	Initial creation

*/

vars
	invoice : CM_Invoice;
	invoiceLine : CM_InvoiceLine;
	oidStringArray : StringArray;
	oidString : String;
begin
	create oidStringArray transient;
	invoice := "2216.7517".asOid.CM_Invoice;
	foreach invoiceLine in invoice.invoiceLines do
		if invoiceLine.trackedItem &lt;&gt; null and invoiceLine.trackedItem.state = 1 then
			if not oidStringArray.includes(invoiceLine.getOidAsString) then 
				oidStringArray.add(invoiceLine.getOidAsString);
			endif;
		endif;
	endforeach;
	
	
epilog
	delete oidStringArray;
end;</source>
