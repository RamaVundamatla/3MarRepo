    <JadeMethod name="displayExtraInfo" id="69a707f1-dad6-4362-8d4b-8fb0dad5c02c">
        <source>displayExtraInfo()protected;
//--------------------------------------------------
// Created:	15 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	dataContainer : CM_DataContainer;
	wle 		: CM_WorkListEntry;
	strArray	: HugeStringArray;
	invalid : Boolean;
	str : String;
begin
	if self.myCurrentVoyage = null then
		return;
	endif;
	on Exception do app.handleDeletedObject(exception, self.myCurrentVoyage, invalid);
	str := self.myCurrentVoyage.code;
	if invalid then
		return;
	endif;
	
	self.tblInfo.rows := 0;
	if self.myCurrentVoyage = null then
		return;
	endif;
	
	create dataContainer transient;
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;

	if self.myCurrentVoyage.myHMSVoyageData &lt;&gt; null then
		self.myCurrentVoyage.myHMSVoyageData.getExtraInfo(dataContainer);	
	else			
		self.myCurrentVoyage.getExtraInfo(dataContainer);
	endif;
	

	self.tblInfo.userObject	:=	self.myCurrentVoyage; // this is used to redraw this info
	self.showExtraInformation(dataContainer, self.tblInfo, true,false,4,1,4,1,1);
	
//	self.tblInfo.fitColumnWidths();
	self.doResizeColumnWidths(self.tblInfo, true);
	
epilog
	delete dataContainer;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayVoyages" id="cc311b4f-e7be-4533-ab8a-6e1bb92fafdb">
        <updating/>
        <source>displayVoyages()updating, protected;
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------
// 31/03/2016	cnwdap1		PAR #35843 Make monitor time-based rather than object count based
// 03/06/2020   cnwma1	    ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// 04 Apr 2022  navhl20     TFS 53352 EUP - Voyage External Reference Field Usability - UI
// 08 June 2022 navhl20		Bug 53799: EUP - Voyage External reference search in Voyage Enquiry
// ----------	--------	----------------------------------------------------
vars
	rowIdx       : Integer;
	tmpVoyage    : CM_Voyage;
	voyages		 : CM_VoyageArray;			//08 June 2022 navhl20 #53799
	passport     : CM_Passport;
	iter 	     : Iterator;
	tmpDict   	 : Dictionary;
	term 		 : CM_Terminal;
	saveSelected : CM_Voyage;
	cnt,
	partsInJob,
	partsDone    : Integer;
	cmifMonitor	 : CMIF_Monitor;	
	lastUpdate 	 : Decimal [20];								// PAR #35843
begin
	app.mousePointer  	   := self.MousePointer_HourGlass;				
	passport 		  	   := app.myPassport;
	self.tblData.rows 	   := self.tblData.fixedRows;
	self.tblInfo.rows      := 0;
	self.picVessel.picture := null;
	self.tblData.clearAllSelected();
	saveSelected := self.myCurrentVoyage;
	cmifMonitor  := passport.myCMIFMonitor;
	
	if cmifMonitor &lt;&gt; null then
		delete cmifMonitor;
	endif;
	create cmifMonitor transient;
	cmifMonitor.myParent := self;
	passport.setMyCMIFMonitor(cmifMonitor);

	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null, 'Cancel' , null, null, 'Loading Voyages',  'Please Wait....');
	self.pbProgressBar.visible := true;
			
	self.colColour := self.tblData.getColumnByRowName(ETRow_Colour);
	
	foreach term in self.allSelectedTerminals do
		if self.filterCode &lt;&gt; null or self.filterGroupCode &lt;&gt; null or self.filterExtCode &lt;&gt; null or self.filterExtRef &lt;&gt; null then			//08 June 2022 navhl20 #53799
			create voyages transient;												//08 June 2022 navhl20 #53799
			if self.filterCode &lt;&gt; null then
				// Filtering by code, use terminal.allVoyagesByCode dict
				// dates will be checked in self.includeObject();
				
				// check active voyages
				tmpDict := term.allVoyagesByCode;
	//			tmpVoyage := tmpDict[self.filterCode].CM_Voyage;		
	//			if tmpVoyage &lt;&gt; null then
	//				self.tblDataDisplayRow(tmpVoyage);
	//				return;
	//			endif;
				
				// Check archived voayges
				//tmpVoyage := term.allVoyagesArchived[self.filterCode].CM_Voyage;	
				tmpVoyage := term.lookupVoyage ( self.filterCode, null, false);	
				if tmpVoyage &lt;&gt; null then
					//self.tblDataDisplayRow(tmpVoyage);						//13 June 2022 navhl20 #53799
					voyages.addExclusive(tmpVoyage);							//13 June 2022 navhl20 #53799
					//return;													//13 June 2022 navhl20 #53799
				endif;			
				
				// voyage not found
				// show all active voyages that start with the entered code
				iter := tmpDict.createIterator();
				tmpDict.startKeyGeq(self.filterCode, null, iter);	

				partsInJob := tmpDict.size + term.allVoyagesArchived.size;
				cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone);
							
				while iter.next(tmpVoyage) do
					partsDone := partsDone+1;
					cnt := cnt + 1;				
					if self.filterCode &lt;&gt; null 
					and self.filterCode &lt;&gt; "*" then
						if (not tmpVoyage.code.startsWith(self.filterCode)) then
							break;
						endif;
					endif;
					if self.includeVoyage(tmpVoyage, passport) then
						//self.tblDataDisplayRow(tmpVoyage);						//13 June 2022 navhl20 #53799
						voyages.addExclusive(tmpVoyage);							//13 June 2022 navhl20 #53799
					endif;
					//if cnt = 100 then																			// PAR #35843
					if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
						if (not cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone)) then
							break;
						endif;
						cnt := 0;
						lastUpdate := app.relativeMachineTime;													// PAR #35843
					endif;				
				endwhile;
				
				// show all archived voyages that start with the entered code
				delete iter;
				tmpDict := term.allVoyagesArchived;
				iter := tmpDict.createIterator();
				tmpDict.startKeyGeq(self.filterCode, null, iter);	
					
				while iter.next(tmpVoyage) do
					partsDone := partsDone+1;
					cnt := cnt + 1;			
					if self.filterCode &lt;&gt; null 
					and self.filterCode &lt;&gt; "*" then
						if (not tmpVoyage.code.startsWith(self.filterCode)) then
							break;
						endif;
					endif;
					if self.includeVoyage(tmpVoyage, passport) then
						//self.tblDataDisplayRow(tmpVoyage);						//13 June 2022 navhl20 #53799
						voyages.addExclusive(tmpVoyage);							//13 June 2022 navhl20 #53799
					endif;
					//if cnt = 100 then																			// PAR #35843
					if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
						if (not cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone)) then
							break;
						endif;
						cnt := 0;
						lastUpdate := app.relativeMachineTime;													// PAR #35843
					endif;							
				endwhile;	
			endif;
		
		 if self.filterGroupCode &lt;&gt; null then    //03/06/2020 cnwma1 Tfs #49400
		
			tmpDict := term.allVoyagesByVoyageGroupCode;
			
			// voyage not found
			// show all active voyages that start with the entered code
			iter := tmpDict.createIterator();
			tmpDict.startKeyGeq(self.filterGroupCode, iter);	

			partsInJob := tmpDict.size + term.allVoyagesArchived.size;
			cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone);
			
			if voyages.size = 0 and (self.filterCode = null or self.filterExtCode = null or self.filterExtRef = null) then					//13 June 2022 navhl20 #53799
				while iter.next(tmpVoyage) do
					partsDone := partsDone+1;
					cnt := cnt + 1;				
					if self.filterGroupCode &lt;&gt; null 
					and self.filterGroupCode &lt;&gt; "*" then
						if (not tmpVoyage.voyageGroupCode.startsWith(self.filterGroupCode)) then
							break;
						endif;
					endif;
					if self.includeVoyage(tmpVoyage, passport) then
						//self.tblDataDisplayRow(tmpVoyage);						//13 June 2022 navhl20 #53799
						voyages.addExclusive(tmpVoyage);							//13 June 2022 navhl20 #53799
					endif;
					//if cnt = 100 then																			
					if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	
						if not cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone) then
							break;
						endif;
						cnt := 0;
						lastUpdate := app.relativeMachineTime;													
					endif;				
				endwhile;
				
				// show all archived voyages that start with the entered code
				delete iter;
				tmpDict := term.allVoyagesArchived;
				iter := tmpDict.createIterator();
				tmpDict.startKeyGeq(self.filterGroupCode, null, iter);	
					
				while iter.next(tmpVoyage) do
					partsDone := partsDone+1;
					cnt := cnt + 1;			
					if self.filterGroupCode &lt;&gt; null 
					and self.filterGroupCode &lt;&gt; "*" then
						if (not tmpVoyage.voyageGroupCode.startsWith(self.filterGroupCode)) then
							break;
						endif;
					endif;
					if self.includeVoyage(tmpVoyage, passport) then
						//self.tblDataDisplayRow(tmpVoyage);						//13 June 2022 navhl20 #53799
						voyages.addExclusive(tmpVoyage);							//13 June 2022 navhl20 #53799
					endif;
					//if cnt = 100 then																			
					if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	
						if (not cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone)) then
							break;
						endif;
						cnt := 0;
						lastUpdate := app.relativeMachineTime;												
					endif;							
				endwhile;
			//Start 08 June 2022 navhl20 #53799
			else
				foreach tmpVoyage in voyages do
					if self.includeVoyage(tmpVoyage, passport) then
						voyages.addExclusive(tmpVoyage);
					endif;
					if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	
						if (not cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone)) then
							break;
						endif;
						cnt := 0;
						lastUpdate := app.relativeMachineTime;												
					endif;
				endforeach;
			//End 08 June 2022 navhl20 #53799
			endif;
		endif;
			
		//Start 04 Apr 2022 navhl20 TFS 53352
		//elseif self.filterExtCode &lt;&gt; null then									//08 June 2022 navhl20 #53799
			if self.filterExtCode &lt;&gt; null then
				tmpDict := term.allVoyagesByExternalCode;
				
				// voyage not found
				// show all active voyages that start with the entered code
				iter := tmpDict.createIterator();
				tmpDict.startKeyGeq(self.filterExtCode, iter);	

				partsInJob := tmpDict.size + term.allVoyagesArchived.size;
				cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone);
					
				if voyages.size = 0 and (self.filterCode = null or self.filterGroupCode = null or self.filterExtRef = null) then						//13 June 2022 navhl20 #53799 
					while iter.next(tmpVoyage) do
						partsDone := partsDone+1;
						cnt := cnt + 1;				
						if self.filterExtCode &lt;&gt; null 
						and self.filterExtCode &lt;&gt; "*" then
							if (not tmpVoyage.voyageCodeExternal.startsWith(self.filterExtCode)) then
								break;
							endif;
						endif;
						if self.includeVoyage(tmpVoyage, passport) then
							//self.tblDataDisplayRow(tmpVoyage);					//08 June 2022 navhl20 #53799			
							voyages.addExclusive(tmpVoyage);						//08 June 2022 navhl20 #53799
						endif;
						//if cnt = 100 then																			
						if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	
							if not cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone) then
								break;
							endif;
							cnt := 0;
							lastUpdate := app.relativeMachineTime;													
						endif;				
					endwhile;
					
					// show all archived voyages that start with the entered code
					delete iter;
					tmpDict := term.allVoyagesArchived;
					iter := tmpDict.createIterator();
					tmpDict.startKeyGeq(self.filterExtCode, null, iter);	
						
					while iter.next(tmpVoyage) do
						partsDone := partsDone+1;
						cnt := cnt + 1;			
						if self.filterExtCode &lt;&gt; null 
						and self.filterExtCode &lt;&gt; "*" then
							if (not tmpVoyage.voyageCodeExternal.startsWith(self.filterExtCode)) then
								break;
							endif;
						endif;
						if self.includeVoyage(tmpVoyage, passport) then
							//self.tblDataDisplayRow(tmpVoyage);									//08 June 2022 navhl20 #53799
							voyages.addExclusive(tmpVoyage);									//08 June 2022 navhl20 #53799
						endif;
						//if cnt = 100 then																			
						if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	
							if (not cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone)) then
								break;
							endif;
							cnt := 0;
							lastUpdate := app.relativeMachineTime;												
						endif;							
					endwhile;
				//Start 08 June 2022 navhl20 #53799
				else
					foreach tmpVoyage in voyages do
						if self.includeVoyage(tmpVoyage, passport) then
							voyages.addExclusive(tmpVoyage);
						endif;
						if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	
							if (not cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone)) then
								break;
							endif;
							cnt := 0;
							lastUpdate := app.relativeMachineTime;												
						endif;
					endforeach;
				//End 08 June 2022 navhl20 #53799
				endif;
			endif;
			if self.filterExtRef &lt;&gt; null then
				tmpDict := term.allVoyagesByCode;
				
				// voyage not found
				// show all active voyages that start with the entered code
				iter := tmpDict.createIterator();

				partsInJob := tmpDict.size + term.allVoyagesArchived.size;
				cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone);
				
				if voyages.size = 0 and (self.filterCode = null or self.filterGroupCode = null or self.filterExtCode = null) then	//08 June 2022 navhl20 #53799
					while iter.next(tmpVoyage) do
						partsDone := partsDone+1;
						cnt := cnt + 1;				
						if self.includeVoyage(tmpVoyage, passport) then
							//self.tblDataDisplayRow(tmpVoyage);					//08 June 2022 navhl20 #53799
							voyages.addExclusive(tmpVoyage);					//08 June 2022 navhl20 #53799
						endif;
						//if cnt = 100 then																			
						if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	
							if not cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone) then
								break;
							endif;
							cnt := 0;
							lastUpdate := app.relativeMachineTime;													
						endif;				
					endwhile;
					
					// show all archived voyages that start with the entered code
					delete iter;
					tmpDict := term.allVoyagesArchived;
					iter := tmpDict.createIterator();	
						
					while iter.next(tmpVoyage) do
						partsDone := partsDone+1;
						cnt := cnt + 1;			
						if self.includeVoyage(tmpVoyage, passport) then
							//self.tblDataDisplayRow(tmpVoyage);						//08 June 2022 navhl20 #53799
							voyages.addExclusive(tmpVoyage);							//08 June 2022 navhl20 #53799
						endif;
						//if cnt = 100 then																			
						if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	
							if (not cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone)) then
								break;
							endif;
							cnt := 0;
							lastUpdate := app.relativeMachineTime;												
						endif;							
					endwhile;
				else
					//Start 08 June 2022 navhl20 #53799
					foreach tmpVoyage in voyages do
						if self.includeVoyage(tmpVoyage, passport) then
							voyages.addExclusive(tmpVoyage);
						endif;
						if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	
							if (not cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone)) then
								break;
							endif;
							cnt := 0;
							lastUpdate := app.relativeMachineTime;												
						endif;
					endforeach;
				endif;
			endif;
			foreach tmpVoyage in voyages do
				self.tblDataDisplayRow(tmpVoyage);
			endforeach;
		//End 08 June 2022 navhl20 #53799
		//End 04 Apr 2022 navhl20 TFS 53352
		
		else
		//	if self.filterStatus = Voyage_Status_Archived then
		//		cmifMonitor.updateProgress(cmifMonitor.message, term.allVoyagesArchived.size, 0);			
		//		self.displayVoyagesForDict(term.allVoyagesArchived);
		///	else
				if self.filterArchivedVoyages and self.filterStatuses.includes( Voyage_Status_Archived ) then
					cmifMonitor.updateProgress(cmifMonitor.message, term.allVoyagesArchived.size+term.allVoyagesByCode.size, 0);										
					self.displayVoyagesForDict(term.allVoyagesArchived);
				else
					cmifMonitor.updateProgress(cmifMonitor.message, term.allVoyagesByCode.size, 0);																
				endif;
				self.displayVoyagesForDict(term.allVoyagesByCode);						
		//	endif;
		endif;
	
	endforeach;

epilog	
	if saveSelected &lt;&gt; null then
		if self.tblData.findObjectInRow(saveSelected, rowIdx) then
			self.tblData.selectRow(rowIdx, false);
			self.setSelectedVoyage(saveSelected);
		else
			self.setSelectedVoyage(null);														
		endif;
	else
		self.setSelectedVoyage(null);								
	endif;
	delete iter;
	delete voyages;
	self.statusLine.caption := (self.tblData.rows-self.tblData.fixedRows).String &amp; ' rows found.';
	self.tblData.colourRows(self.colorRow1, self.colorRow2);
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;					
	app.mousePointer := self.MousePointer_Default;									
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayVoyagesForDict" id="c594bd49-0e16-48ab-a371-733d57d7fde2">
        <source>displayVoyagesForDict(_voyageDict : Dictionary)protected;
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------
// 31/03/2016	cnwdap1		PAR #35843 Make monitor time-based rather than object count based
vars
	tmpVoyage : CM_Voyage;
	passport : CM_Passport;
	iter : Iterator;
	monitor : CMIF_Monitor;
	cnt,
	partsInJob,
	partsDone : Integer;	
	lastUpdate : Decimal [20];						// PAR #35843
begin
	if _voyageDict = null then
		return;
	endif;
	
	passport := app.myPassport;

	monitor := passport.myCMIFMonitor;
	if monitor &lt;&gt; null then
		partsInJob := monitor.partsInJob;
	endif;	
		
	iter := _voyageDict.createIterator();

	while iter.next(tmpVoyage) do
		partsDone := partsDone+1;
		cnt := cnt + 1;	
		if self.includeVoyage(tmpVoyage, passport) then
			self.tblDataDisplayRow(tmpVoyage);
		endif;
		if monitor &lt;&gt; null then
			//if cnt = 100 then																			// PAR #35843
			if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
				if (not monitor.updateProgress(monitor.message, partsInJob, partsDone)) then
					break;
				endif;
				cnt := 0;
				lastUpdate := app.relativeMachineTime;													// PAR #35843
			endif;
		endif;					
	endwhile;
																
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_voyageDict" type="Dictionary"/>
    </JadeMethod>
    <JadeMethod name="dkbExtraInfo_userResize" id="002ead15-6587-46c9-8802-a1b7cd65be0c">
        <controlMethod name="JadeDockBar::userResize"/>
        <methodInvocation>event</methodInvocation>
