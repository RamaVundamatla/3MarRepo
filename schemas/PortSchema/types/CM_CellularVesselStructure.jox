    <JadeMethod name="pxyCreateUpdateProxy" id="4a533292-1d7b-4899-a882-5ef9da021cb3">
        <source>pxyCreateUpdateProxy(): SelfType ; //serverExecution;
// ---------------------------------------------------------------------------
// Created:     09 February 2002 by cnwrs1
//
// Purpose:     Create a proxy copy of ourself and proxy Holds, Bays, Cells and Tiers. Link all these together and pass back the proxy vessel!
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxyVessel:CM_CellularVesselStructure;
	pxyBayDefn,realBayDefn,previousBayDefn:CM_BayDefn;
	aHold,pHold : CM_Hold;	
	aHatch, pHatch : CM_HatchLid;
	completedOK		: Boolean;
begin

	proxyVessel := inheritMethod();

	// RJS - need to add other references here, including collections
	// self.ports is inversed and this is the auto end so no need
	// to copy to the proxy

	foreach aHold in self.allHolds do
		pHold := aHold.pxyCreateUpdateProxy();
		
		pHold.CM_VesselHold.setProxy(proxyVessel,pHold.ordinalHold);
	endforeach;

	foreach realBayDefn in self.allBaysByLabel do

		pxyBayDefn := realBayDefn.pxyCreateUpdateProxy;
		pxyBayDefn.setMyVessel(proxyVessel);

		// ############################
		// HATCH LIDS - these have been proxied in CM_BAY attach to our vessel
		foreach pHatch in pxyBayDefn.allHatchLids do
			pHatch.CM_HatchLidVessel.setMyVessel(proxyVessel);
		endforeach;
		
		// use the ordinal of the real hold to get the proxy hold
		if realBayDefn.myHold &lt;&gt; null then
			pHold := proxyVessel.allHolds[realBayDefn.myHold.ordinalHold];
			// set the proxy bay into the proxy hold
			pxyBayDefn.setMyHold(pHold);
		endif;
	endforeach;

	proxyVessel.updateBayLinks();
	
	// link up our proxy bays to each other
	foreach pxyBayDefn in proxyVessel.allBaysByOrdinal do
		pxyBayDefn.updateSlotLinks();
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyVessel;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyVessel;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="6794a082-5221-454c-b3db-25061dc64a56">
        <updating/>
        <source>setForCreate(_proxyVessel:CM_CellularVesselStructure; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pxyBayDefn,realBayDefn,previousBayDefn:CM_Bay;
	pxyLid, realLid : CM_HatchLid;
	idx : Integer;
	proxyHold,aHold,pHold : CM_Hold;
	passport : CM_Passport;
begin
	_proxyVessel.raiseExceptionIfNotTransient(method);
	passport := app.myPassport;	
	self.isImported := _proxyVessel.isImported;
	self.bridgeAfterBay := _proxyVessel.bridgeAfterBay;
	self.use40Id := _proxyVessel.use40Id;
	self.isoHalfHeights := _proxyVessel.isoHalfHeights;	
	self.useBayCellTierNumbering := _proxyVessel.useBayCellTierNumbering;
	self.setType(_proxyVessel.type);	// PAR 21745 CCMS MES 1031
	self.setMyRoot();
	self.numSlotsExpected := _proxyVessel.numSlotsExpected; // PAR 32286

	// the proxy vessel has its own proxy holds. Use them to create real holds for this real vessel
	foreach proxyHold in _proxyVessel.allHolds do
		if self.allHolds[proxyHold.ordinalHold] = null then
			create aHold as CM_VesselHold;
			aHold.CM_VesselHold.setProxy(self,proxyHold.ordinalHold);
		endif;
	endforeach;

	foreach pxyBayDefn in _proxyVessel.allBaysByLabel do
		app.myUtilityCA.utlCreateBay(pxyBayDefn,realBayDefn,self, passport);
		
		if app.myPassport.hasErrors then
			return;
		endif;
	endforeach;

	self.updateBayLinks();

	// create the same hatchlids and links to bays etc that the proxy has.
	self.allHatchlids.purge;
	if _proxyVessel.allHatchlids.isEmpty = false then
		foreach pxyLid in _proxyVessel.allHatchlids do
			if pxyLid.isKindOf(CM_HatchLidVessel) then
				app.myUtilityCA.utlCreateHatchLid(pxyLid,realLid,self,passport);

				if app.myPassport.hasErrors then
					return;
				endif;			
			endif;
		endforeach;
	endif;

end;</source>
        <Parameter name="_proxyVessel" type="CM_CellularVesselStructure"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1a8b477c-2e81-4b73-aaee-58fccdf85161">
        <updating/>
        <source>setForUpdate(_proxyVessel:CM_CellularVesselStructure; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs1
// ---------------------------------------------------------------------------
vars
	pxyBayDefn,realBayDefn,previousBayDefn:CM_Bay;
	pxyLid, realLid : CM_HatchLid;
	delLids : ObjectArray;
	idx, numHolds, numPxyHolds  : Integer;
	proxyHold,aHold,pHold : CM_Hold;
	isDelete,isUpdate : Boolean;
begin
	inheritMethod(_proxyVessel, _passport);
	
	self.bridgeAfterBay := _proxyVessel.bridgeAfterBay;
	self.use40Id := _proxyVessel.use40Id;
	self.useBayCellTierNumbering := _proxyVessel.useBayCellTierNumbering;
	self.isoHalfHeights := _proxyVessel.isoHalfHeights;	
	self.numSlotsExpected := _proxyVessel.numSlotsExpected; // PAR 32286
	self.definitionSource := _proxyVessel.definitionSource;		// jlgmd1 04/02/21 TFS 49052 MACS3 Vessel Library API
	self.definitionVersion := _proxyVessel.definitionVersion;	// jlgmd1 04/02/21 TFS 49052 MACS3 Vessel Library API
	self.isImported := _proxyVessel.isImported;					// jlgmd1 04/02/21 TFS 49052 MACS3 Vessel Library API
	
	// the proxy vessel has its own proxy holds. Use them to create real holds for this real vessel
	numHolds := self.allHolds.size;
	numPxyHolds := _proxyVessel.allHolds.size;
	
	// Decrease the number of holds.
	if numHolds &gt; numPxyHolds then
		foreach idx in numPxyHolds + 1 to numHolds do
			aHold := self.allHolds[idx];
			if aHold.allBays.isEmpty then
				delete aHold;
			endif;
		endforeach;
	endif;
	// increase the number of holds
	foreach proxyHold in _proxyVessel.allHolds do
		if self.allHolds[proxyHold.ordinalHold] = null then
			create aHold as CM_VesselHold;
			aHold.CM_VesselHold.setProxy(self,proxyHold.ordinalHold);
		endif;
	endforeach;
	
	// DELETE bays
	foreach realBayDefn in self.allBaysByLabel do		//cnwas3 par 21579 moved before the updating takes place
		isDelete := (realBayDefn.pxyGetProxyObject = null);
		if isDelete then
			app.myUtilityDA.utlDeleteBay(realBayDefn,_passport);
		endif;
	endforeach;
	// update each of the bays through the TRX Util layer
	// do reversed in case user is inserting bays (otherwise get key already in dict error
	// when setting the ordinal value
	
	foreach realBayDefn in self.allBaysByLabel do		//cnwas3 par 21579
		realBayDefn.setOrdinalBayOff( CM_Bay.BayOrdinalOffset );	//03 Feb 2012 NDL Par 28640
	endforeach;
	
	foreach pxyBayDefn in _proxyVessel.allBaysByLabel reversed do
		isUpdate := (pxyBayDefn.pxyIsProxy);
		if isUpdate then // UPDATE		
			app.myUtilityUA.utlUpdateBay(true,pxyBayDefn,_passport); //cnwas3 par 21579 added _skipEditionCheck paramter
		endif;
	endforeach;
	
	// Create new insert bays through the TRX Util layer
	foreach pxyBayDefn in _proxyVessel.allBaysByLabel do
		isUpdate := (pxyBayDefn.pxyIsProxy);
	
		if not isUpdate then // create
			app.myUtilityCA.utlCreateBay(pxyBayDefn,realBayDefn,self,_passport);
		endif;
	endforeach;

	self.updateBayLinks();
	// PAR 8541. Having re linked the bays, now re link the slots in the bays. This was being done as par tof the bay update above
	foreach realBayDefn in self.allBaysByOrdinal do
		realBayDefn.updateSlotLinks();
		realBayDefn.setSequenceNums();
	endforeach;


	foreach realBayDefn in self.allBaysByOrdinal do
		if realBayDefn.fortyFootOnly then
			realBayDefn.setProxyBaySlots40();
		endif;
	endforeach;

	// the LIDS to be deleted will have no proxy link
	create delLids transient;
	foreach realLid in self.allHatchlids do
		if realLid.pxyGetProxyObject = null then
			delLids.add(realLid);
		endif;
	endforeach;
	delLids.purge();

	if _proxyVessel.allHatchlids.isEmpty = false then
		foreach pxyLid in _proxyVessel.allHatchlids do
			if pxyLid.isKindOf(CM_HatchLidVessel) then
				realLid := pxyLid.pxyGetRealObject();
				if realLid = null then
					app.myUtilityCA.utlCreateHatchLid(pxyLid,realLid,self,_passport);
					if not app.myPassport.noErrors then
						break;
					endif;
				else
					realLid.setForUpdate(pxyLid,_passport);	
				endif;
			endif;
		endforeach;
	endif;
	
	self.numSlotsDefined := self.getTEUCapacity(); // PAR 32286
	self.updateObjectEdition(self.myVessel); // PAR 32286 update VESSEL table
	
epilog
	delete delLids;
end;</source>
        <Parameter name="_proxyVessel" type="CM_CellularVesselStructure"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setNumberSlotsDefined" id="763edc46-0199-41bb-9e94-e050c287b25d">
        <updating/>
        <source>setNumberSlotsDefined() updating;
// ---------------------------------------------------------------------------
// Created:     04 February 2014 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.numSlotsDefined := self.getTEUCapacity(); // PAR 32286
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setOutboardSlots" id="c3ff41ed-1ac5-47a8-8d5c-b83a4fbe9354">
        <updating/>
        <source>setOutboardSlots() updating;
// ---------------------------------------------------------------------------
// Created:		02 May 2001 by cnwdwq1 
//
// Purpose:     redundant ? was this part of a previous fix, if still unreferenced after 7 then delete
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	bayDefn : CM_BayDefn;
begin
