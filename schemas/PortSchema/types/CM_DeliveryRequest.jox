    <JadeMethod name="getDataForDefSpecial" id="92410586-0e3b-4c49-b624-7932f740f065">
        <source>getDataForDefSpecial(_attrName: String; _heading: String; _headings: StringArray input; _data: HugeStringArray input): Boolean protected;
// ---------------------------------------------------------------------------
// Created:     13 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpAvail 		: CM_MTGrade;
	tmpAvailCode	: Integer;
	tmpAvailDesc	: String;
	operator		: CM_Operator;
	code			: CM_MTGradeCode;
	canDisplay		: Boolean;
	
begin
	if _attrName = ETRow_DeliveryReason then
		_headings.add(_heading);
		_data.add(self.reasonCodeDescr);
		return true;
		
	elseif _attrName = ETRow_Id then
		_headings.add(_heading);
		_data.add(self.getIdsAsString);
		return true;
	
	elseif _attrName = ETRow_IdMask then
		_headings.add(_heading);
		_data.add(self.getIdsAsString);
		return true;
	elseif _attrName = ETRow_AllMTGrades then
			operator := app.myRoot.allOperators[self.operatorCode];
			//FD for par 2724 Show Availability Grade in this thumnail Table
			
			foreach tmpAvailCode in  self.allAvailabilityGrades do
				tmpAvail := app.myRoot.allAvailabilityGrades[tmpAvailCode];
				if tmpAvail &lt;&gt; null then
					tmpAvail.getTranslationForOperator(tmpAvail, operator, self.myOperatorGroup, code, canDisplay);
					if code &lt;&gt; null then
						tmpAvailDesc := tmpAvailDesc &amp; code.description &amp; ',';
					elseif canDisplay then
						tmpAvailDesc := tmpAvailDesc  &amp; tmpAvail.description &amp; ',';
					endif;
				endif;
			endforeach;
			if tmpAvailDesc.length &gt; 1 then
				tmpAvailDesc := tmpAvailDesc[1: tmpAvailDesc.length - 1];
			endif;
			_headings.add(_heading);
			_data.add(tmpAvailDesc);
			return true;
	elseif _attrName = ETRow_PowerRequirements then
		if self.needCOU and self.needGenerator then
			_headings.add(_heading);
			_data.add(POWER_BOTH);
				return true;
		elseif self.needCOU then
			_headings.add(_heading);
			_data.add(POWER_COU);
			return true;
		elseif self.needGenerator then
			_headings.add(_heading);
			_data.add(POWER_GEN);
			return true;
		else
			_headings.add(_heading);
			_data.add(POWER_NONE);
			return true;
		endif;
	
	endif;

	return inheritMethod(_attrName, _heading, _headings, _data);

end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDataForFailedReqTbl" id="e450fb2f-1dd5-479d-a3de-e1f6353e26ec">
        <source>getDataForFailedReqTbl(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 January 2012	cnwndl1	Initial creation	Par 28953

*/

vars

	imex	: CM_IMEXStatus;

begin

	if _attrName = ETRow_ReleaseNo then
		if self.myJob &lt;&gt; null then
			return self.myJob.jobId;
		endif;
		return null;
	elseif _attrName = ETRow_MyBookingRefStock then
		return null;
	elseif _attrName = ETRow_CargoType then
		if self.myCargoType &lt;&gt; null then
			return self.myCargoType.description;
		endif;
		return null;		
	elseif _attrName = ETRow_RequestDate then
		return self.creationTime.Date.asStringJMT;		
	elseif _attrName = ETRow_EstimatedRequiredDate then
		return null;		
	elseif _attrName = ETRow_CarrierCode then
		if self.myJob &lt;&gt; null and self.myJob.isKindOf(CM_RoadJob)then
			return self.myJob.CM_RoadJob.carrierId;
		endif;
		return null;		
	elseif _attrName = ETRow_IsoTypeGroup then
		return self.isoGroup;		
	elseif _attrName = ETRow_EmptyReleaseItemDescr then
		return null;		
	elseif _attrName = ETRow_QuantityRemaining then
		return null;		
	elseif _attrName = ETRow_RequestsBeingActioned then
		return null;		
	elseif _attrName = ETRow_DeliveredToDate then
		return null;		
	elseif _attrName = ETRow_DeliveryReason then
		return null;		
	elseif _attrName = ETRow_ImexStatusString then
		if self.imexStatus &lt;&gt; TI_IMEX_STATUS_NULL then
			imex:= app.myRoot.allImexStatuses[self.imexStatus];
			if imex &lt;&gt; null then
				return imex.description;
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_PackLocation then
		return null;		
	elseif _attrName = ETRow_TotalPacked then
		return null;		
	elseif _attrName = ETRow_VoyageArrival then
		return null;		
	elseif _attrName = ETRow_BookingConfirmation then
		return null;		
	elseif _attrName = ETRow_DeliveryReleaseNumber then
		return null;		
	elseif _attrName = ETRow_PackProduct then
		return null;		
	elseif _attrName = ETRow_PackQuantity then
		return null;		
	elseif _attrName = ETRow_MyPinNo then
		return null;		
	elseif _attrName = ETRow_BusinessUnit then
		return null;		
	elseif _attrName = ETRow_RequestedCountFromOps then
		return null;		
	elseif _attrName = ETRow_Destination then
		return null;		
	elseif _attrName = ETRow_TrainAssignedID then
		return null;	
	elseif _attrName = ETRow_InterTerminalRelease or
		   _attrName = ETRow_InterTerminalReleaseStr then
		if self.myTransferToTerminal &lt;&gt; null then
			return true.getYes;
		endif;
		return null;	
	elseif _attrName = ETRow_CustomsAgent then
		return null;
	elseif _attrName = ETRow_CustomsAssistance or 
		   _attrName = ETRow_CustomsAssistanceStr then
		return null;
	elseif _attrName = ETRow_ReleaseByTypeStr then
		return null;
	elseif _attrName = ETRow_ReleaseByType then
		return null;
	elseif _attrName = ETRow_LoadPort then
		return null;
	else
		return self.getDisplayStringForAttribute( _attrName, _short );
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="33e4675f-f6f8-4538-84f0-30b38bc12845">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 01 April 2003 By: cnwgd1
//--------------------------------------------------------------
// 21/02/2010	cnwcs5	par22193 - include iso type group
// 04/11/2020   cnwma1	ChangeRequest 50112: ASPA - GCI Stevedores
// 20/06/2022	navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP
// 05/06/2023   navma1  ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
// 06 Feb 2025	navah1 	Bug 33226: MTN - Invalid Properties when opening Satellite View
vars

	operator		: CM_Operator;
	tmpAvail		: CM_MTGrade;
	tmpAvailCode	: Integer;
	code			: CM_MTGradeCode;
	rtnDesc			: String;
	canDisplay		: Boolean;
	dischPort		: CM_Port;
	str				: String;
	opObj			: CM_Operator;		// TFS 53362
	steveObj		: CM_Stevedore;		// TFS 53362
	root			: CM_Root;
	gte				: CMGTE_Entity;
begin

	if _attrName = ETRow_IsoType then
		return self.isoType; 
	elseif _attrName = ETRow_IsoGroup then	
		return self.isoGroup;				
	elseif _attrName = ETRow_CargoDetails or
		   _attrName = ETRow_Id then		
		return self.getId;
	elseif _attrName = ETRow_AllMTGrades or
		_attrName = ETRow_AvailabilityGradeCode then
			root     := app.myRoot;
			operator := root.allOperators[self.operatorCode];
			
			foreach tmpAvailCode in  self.allAvailabilityGrades do
				tmpAvail := root.allAvailabilityGrades[tmpAvailCode];
				if tmpAvail &lt;&gt; null then
					tmpAvail.getTranslationForOperator(tmpAvail, operator, self.myOperatorGroup, code, canDisplay);
					if code &lt;&gt; null then
						rtnDesc := rtnDesc &amp; code.description &amp; ',';
					elseif canDisplay then
						rtnDesc := rtnDesc  &amp; tmpAvail.description.String &amp; ',';
					endif;
				endif;
			endforeach;
			if rtnDesc.length &gt; 1 then
				rtnDesc := rtnDesc[1: rtnDesc.length - 1];
			endif;
			return rtnDesc;
	elseif _attrName = ETRow_OperatorCode or
		   _attrName = ETRow_MyOperator then
		if self.operatorCode = null
		and self.myOperatorGroup &lt;&gt; null then
			return self.myOperatorGroup.code &amp; "'";		
		else
			root := app.myRoot;
			if _attrName = ETRow_MyOperator and root.getConfig(ComboByNameOperator).Boolean then
				opObj := root.allOperators[self.operatorCode];
				if opObj &lt;&gt; null then
					return opObj.description;
				endif;
			endif;
			// TFS 53362 end
			return self.operatorCode;		
		endif;
	elseif _attrName = ETRow_MySubTerminal then
		if self.mySubTerminalSource &lt;&gt; null then
			return self.mySubTerminalSource.code;
		endif;
		return null;
	elseif _attrName = ETRow_DischargePort then		// 26/05/2010 cnwar2 #23886
		if self.myReserveDetail &lt;&gt; null then
			dischPort := self.myReserveDetail.myReserveHeader.myDischargePort;
			if dischPort &lt;&gt; null then
				return dischPort.code;
			endif;
		endif;
		return null;

	elseif _attrName = ETRow_HiLowCube or
		   _attrName = ETRow_HiLowCubeStr then
		return self.canBeHiLoCube.getYesNo();
	elseif _attrName = ETRow_CargoTypeDescr then	
		if self.myCargoType &lt;&gt; null then
			return self.myCargoType.description;
		endif;
		return null;		
	elseif _attrName = ETRow_VehicleBookingSlots then		// 19/12/2014 cnwar2 #35424
		if self.myReserveDetail &lt;&gt; null then
			return self.myReserveDetail.myReserveHeader.getVBTimeslotsAsString();
		endif;
		return null;
	elseif _attrName = ETRow_Commodity then
		return self.commodity;
	elseif _attrName = ETRow_StatusDesc then
		return null;
	elseif _attrName = ETRow_Stevedore then	   //04.11.2020 cnwma1 TFS #50112
		gte :=  self.myGateEntity;
		if gte &lt;&gt; null and gte.isCMGTE_Release then
			// TFS 53362 start
			root := app.myRoot;
			if root.getConfig(ComboByNameStevedore).Boolean then
				steveObj := root.allStevedores[gte.CMGTE_Release.stevedoreCode];
				if steveObj &lt;&gt; null then
					return steveObj.description;
				endif;
			endif;
			// TFS 53362 end of this bit
			return gte.CMGTE_Release.stevedoreCode;
		endif;
		return null;
	elseif _attrName = ETRow_CreationDateTime then						// 06.02.2025 navah1 #33226  
		return self.systemToLocalTime(self.createdTime).asStringJMT();
	// 13 Mar 2019	NDL	TFS 43688	- Delivery Request showing in Satellite View
	elseif _attrName = ETRow_VoyageInward
	or _attrName = ETRow_PoolParty
	or _attrName = ETRow_NeedsReview
	or _attrName = ETRow_HeavyRatedString
	or _attrName = ETRow_ExpiryTimeStamp
	or _attrName = ETRow_MtReleaseStr
	or _attrName = ETRow_CleanString
	or _attrName = ETRow_DoISOGroupCheckStr
	or _attrName = ETRow_BlockEDIUpdates
	or _attrName = ETRow_AllowCargoOnMultiRelStr 
	or _attrName = ETRow_LineNumberHdr									// 06.02.2025 navah1 #33226 
	then
		return "N/A";

	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDoorDirectionDescription" id="d50ab13b-7d0e-4f95-b901-96f7fe2d66c9">
        <source>getDoorDirectionDescription(_targetLocation: CM_LocationsController; _ti: CM_TrackedItem): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Mar 2024	navbs1	Bug 63212: POL - Door direction in Vehicle app is wrong

*/

vars

	doorDir 		: Integer;
	isoTypeGroup	: CM_ISOTypeGroup;
	str				: String;
	
begin
	
	if _ti &lt;&gt; null and not _ti.isContainer then
		return  null;
	endif;
	
	if self.myJob &lt;&gt; null and self.myJob.isYardInternalJob() then
		return null;
	endif;
	
	if _targetLocation &lt;&gt; null and _ti &lt;&gt; null then
		isoTypeGroup := _ti.getISOTypeGroup();
		if isoTypeGroup &lt;&gt; null then
			str := _targetLocation.getDoorDirectionWording(isoTypeGroup);
			if str &lt;&gt; null then
				return str;
			endif;
		endif;
	endif;

	doorDir := self.doorsDirection;
	if doorDir = TI_DOORSDIRN_FWD then
		return app.getErrorString(CM_Fwd);
	elseif doorDir = TI_DOORSDIRN_AFT then
		return app.getErrorString(CM_Aft);
	else
		return null;
	endif;
	
epilog 

end;</source>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="752cc89f-d761-444e-ab93-d523f192543a">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*
Date		Who		Reason
16/10/2024	navpw1	JIRA MTN-33053: Added Any Amount if we are using Any Id, Any Amount and VAS is enabled

*/

vars
	block			: CM_DataContainerBlock;
	operCodes,
	str				: String;
	totRequested	: String;
	reserveDetail	: CM_ReserveDetail;
	
begin
	inheritMethod(_dataContainer);
	
	str := self.getIdsAsString.trimBlanks;
	str.replaceChar(Cr," ");
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Additional_Information), DC_Label, 1, null);
	block.addNewItem(str, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_RequestedAvailability_Grade), DC_Label, 1, null);
	block.addNewItem(self.getAvailabilityGrades &amp; Cr, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Clean), DC_Label, 1, null);
	block.addNewItem(app.getYesNo(self.clean), DC_Data, 1, null);
	
/*
	block := _dataContainer.addNewBlock;//cnwrd1 -- 22.12.09
	block.addNewItem(app.getErrorString(CM_ISO_Group_Check), DC_Label, 1, null);
	block.addNewItem(app.getYesNo(self.doISOGroupCheck), DC_Data, 1, null);
	*/
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_ISO_Type), DC_Label, 1, null);
	block.addNewItem(self.isoType, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;  //cnwrd1 ++ 22.12.09
	block.addNewItem(app.getErrorString(ISO_Group), DC_Label, 1, null);
	block.addNewItem(self.isoGroup, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Heavy_Rated), DC_Label, 1, null);
	block.addNewItem(app.getYesNo(self.heavyRated), DC_Data, 1, null);
	
	str := null;
	if self.myOperatorGroup &lt;&gt; null then
		operCodes := self.myOperatorGroup.getAllOperatorCodes();
		str := self.myOperatorGroup.code &amp; ':  ' &amp; self.myOperatorGroup.description;
	endif;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Operator_Group), DC_Label, 1, null);
	block.addNewItem(str, DC_Data, 1, null);
	
	if self.operatorCode &lt;&gt; null then
		operCodes := operCodes &amp; self.operatorCode;
	endif;
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_All_Operators), DC_Label, 1, null);
	block.addNewItem(operCodes, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Total_Requested), DC_Label, 1, null);
	// ### JIRA: MTN-33053 16Oct2024 NAVPW1
	if app.myPassport.isVASEnabled and self.isAnyId and self.isAnyAmount then
		//Grab the total from the release request
		reserveDetail := self.myReserveDetail;
		
		if reserveDetail &lt;&gt; null and not reserveDetail.byTypeByWeight then
			totRequested := reserveDetail.totalRequested.asStringJMT();
			
		else
			totRequested := app.getErrorString(AnyAmount);
			
		endif;
		
	else
		totRequested := self.totalRequested.asStringJMT();
	endif;
	// ### JIRA: MTN-33053 16Oct2024 NAVPW1
	block.addNewItem(totRequested, DC_Data, 1, null);
	
// cnwdad1 19/10/2009 - PAR #21381.
	if self.mySubTerminalSource &lt;&gt; null then
		block := _dataContainer.addNewBlock();
		block.addNewItem(app.getString(SubTerminal_GC), DC_Label, 1, null);
		block.addNewItem(self.mySubTerminalSource.code, DC_Data, 1, null);
	endif;
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getFirstLocationByAmount" id="56629a78-dfff-440d-b31a-a74961968573">
        <updating/>
        <source>getFirstLocationByAmount(_amount: Decimal output; _location: CM_LocationsController output) updating;
/*
Purpose:			

Date		Who		Reason
28 December 2023	navab1	CR 58499 TASK 61455
26/08/2024	navkc1 CR 63588 Task 63589: FR | 53729 - Delivery Dispatch screen - First Warehouse and Number of Warehouse CHANGES
19/11/2024	navkc1 JIRA Bug MTN-33448: First Warehouse location is not considering the cargo group
*/

vars
	bal : CMEVT_LocationActivity;
	ya : CM_YardAllocation;
	yablk : CM_YABlock;
	yrdlc, toplc : CM_YardController;
	ti : CM_TrackedItem;
	lcqty, topqty : Decimal[23,4];
	reserveDetail : CM_ReserveDetail;
	today,
	arrivalDate,
	oldestDate	: Date;
	cmifLcnCont 	  : CMIF_FirstLocationController;
	firstLocation,
	cmifLocation 	  : CMIF_FirstLocation;
	locationStr,
	locationsStr,
	tasStr			: String;
	reserveCargoGroup : CM_CargoGroup;
	reserveCargoType  : CM_CargoType;
	reserveSubType	  : CM_Product;
	reserveVoyage	  : CM_Voyage;
	reason,
	reserveComm,
	reserveOperatorCode,
	reserveMarkNum	  : String;
	reserveSel		  : CM_ReserveSelection;
	oldestArrival	 : Boolean; //18/12/2024	navkc1 JIRA Bug MTN-33686
	
begin
	// get YA for release request
	app.testAutoplanDeliveryRequest(self.myTerminal, self);
	if app.myYAAgent &lt;&gt; null then
		ya := app.myYAAgent.myCurrentAllocation;
	endif;
	if ya &lt;&gt; null then
		reserveDetail := self.myReserveDetail; //26/08/2024	navkc1 CR 63588 Task 63589
		
		//20/11/2024	navkc1 JIRA Bug MTN-33448
		if reserveDetail &lt;&gt; null and reserveDetail.isReserveSelection() then
			reserveSel := reserveDetail.CM_ReserveSelection;
			oldestArrival := reserveDetail.locnByOldestTransportArrival; //18/12/2024	navkc1 JIRA Bug MTN-33686
		endif;
		
		create cmifLcnCont transient; //26/08/2024	navkc1 CR 63588 Task 63589
		
		reserveCargoType := self.myCargoType; 				//19/11/2024	navkc1 JIRA Bug MTN-33448
		reserveOperatorCode := self.operatorCode; 			//19/11/2024	navkc1 JIRA Bug MTN-33448
		if reserveDetail &lt;&gt; null then						//19/11/2024	navkc1 JIRA Bug MTN-33448
			reserveCargoGroup := reserveDetail.myCargoGroup; 
		endif;
		reserveSubType := self.getCargoSubType(); 			//19/11/2024	navkc1 JIRA Bug MTN-33448
		reserveComm := self.commodity; 						//19/11/2024	navkc1 JIRA Bug MTN-33448
		reserveVoyage := self.getVoyage(); 					//19/11/2024	navkc1 JIRA Bug MTN-33448
		reserveMarkNum := self.markNumber;					//19/11/2024	navkc1 JIRA Bug MTN-33448
		
		// go through the locations
		foreach yablk in ya.allYABlocksIn discreteLock do
			foreach yrdlc in yablk.allYardControllers discreteLock do
				
				//18/12/2024	navkc1 JIRA Bug MTN-33686 - Reset oldest date when going to next lcoation;
				if oldestArrival then
					oldestDate := today;
				endif;
				
				create cmifLocation transient;	//26/08/2024	navkc1 CR 63588 Task 63589
				cmifLocation.myLocationController := yrdlc; //26/08/2024	navkc1 CR 63588 Task 63589
				
				lcqty := 0;
				// if location actiovity is turned on  use it
				if yrdlc.allLocationActivity.isNotEmpty() then
					bal := yrdlc.getPreviousLocationBalance(null);
					
					if bal &lt;&gt; null 
					and bal.getCargoType &lt;&gt; null then
						if bal.getCargoType.isBulkByQuantity() then
							lcqty := bal.quantity;
						else
							lcqty := bal.weight;
						endif;
					endif;
				endif;
				
				// if no location activity look at the actual TIs
				if lcqty = 0 then
				
					lcqty := 0;
					foreach ti in yrdlc.allTrackedItems discreteLock do
						//20/11/2024	navkc1 JIRA Bug MTN-33448
						if reserveSel &lt;&gt; null then
							if not ti.testAgainstReserveSelection(reserveSel, reason, false, null) then
								continue;
							endif;
						else
							if not self.includeCargo(reserveCargoType, reserveOperatorCode, reserveCargoGroup, reserveSubType, reserveComm, reserveVoyage, reserveMarkNum, ti) then
								continue;
							endif;
							//19/11/2024	navkc1 JIRA Bug MTN-33448
							//if ti.myCargoType = self.myCargoType
							//and ti.myOperator.code = self.operatorCode then
								if self.myCargoType.isBulkByQuantity then
									lcqty += ti.totalQuantity;
								else
									lcqty += ti.totalWeight;
								endif;
							//endif;
						endif;
					endforeach;
				endif;
				
				//26/08/2024	navkc1 CR 63588 Task 63589
				if reserveDetail &lt;&gt; null and reserveDetail.locnByOldestTransportArrival then
					foreach ti in yrdlc.allTrackedItems discreteLock do
						//20/11/2024	navkc1 JIRA Bug MTN-33448
						if reserveSel &lt;&gt; null then
							if not ti.testAgainstReserveSelection(reserveSel, reason, false, null) then
								continue;
							endif;
						else
							//20/11/2024	navkc1 JIRA Bug MTN-33448
							if not self.includeCargo(reserveCargoType, reserveOperatorCode, reserveCargoGroup, reserveSubType, reserveComm, reserveVoyage, reserveMarkNum, ti) then
								continue;
							endif;
						endif;
						arrivalDate := ti.getTransportArrivalDate();
						//18/12/2024	navkc1 JIRA Bug MTN-33686
						if oldestArrival then
							if arrivalDate &lt; oldestDate then
								oldestDate := arrivalDate;
							endif;
						endif;
					endforeach;
				endif;
				
				if lcqty &gt; 0 
				and lcqty &gt; topqty then
					toplc := yrdlc;
					topqty := lcqty;
				endif;
				
				//26/08/2024	navkc1 CR 63588 Task 63589
				cmifLocation.largestAmount := lcqty;
				cmifLocation.oldestArrival := oldestDate;
				cmifLocation.myTerminalArea := yrdlc.myTerminalArea; //17/01/2025	navkc1 JIRA Bug MTN-33814
				cmifLcnCont.allFirstLocations.add(cmifLocation);
		
			endforeach;
		endforeach;
		
		firstLocation := cmifLcnCont.allFirstLocations.first(); //26/08/2024	navkc1 CR 63588 Task 63589
		
		//26/08/2024	navkc1 CR 63588 Task 63589
		// This gets return to the JOB
		if firstLocation &lt;&gt; null then
			_amount := firstLocation.largestAmount;
			_location := firstLocation.myLocationController;
		endif;
		
		// Set the locations string to the REQUEST
		cmifLcnCont.getLocationsString(locationStr, locationsStr, tasStr);
		
		self.plannedLocation := locationStr;
		self.plannedLocations := locationsStr;
		self.plannedTerminalAreas := tasStr;
		
	endif;
	
epilog
	//26/08/2024	navkc1 CR 63588 Task 63589
	if cmifLcnCont &lt;&gt; null then
		cmifLcnCont.allFirstLocations.purge();
		delete cmifLcnCont;
	endif;
end;</source>
        <Parameter name="_amount" type="Decimal" usage="output"/>
        <Parameter name="_location" type="CM_LocationsController" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getFirstLocationForAnyId" id="90e01558-b8f5-4b58-87e2-b921234abd14">
        <source>getFirstLocationForAnyId():CM_LocationsController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2014	cnwndl1	Initial creation	Par 34675

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;

begin

	if self.myOriginatingBulkRelease &lt;&gt; null then
		iter := self.myOriginatingBulkRelease.allTrackedItemsAssigned.createIterator;
		while iter.next( ti ) do
			if not ti.isTiAvailableForAnyIdSelection() then
				continue;
			endif;
			return ti.myPrimaryActualLocation;
		endwhile;
		delete iter;
	endif;

	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
