<Class name="CM_LDScanReader" id="25965c10-a4b0-4ecb-ad83-efa71f2fb9ed">
    <superclass name="CM_LaneDevice"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <ImplicitInverseRef name="myScanReader" id="45a5dccf-3644-4b19-8fd3-10f5fdcd95be">
        <embedded/>
        <type name="CM_ScanReaderObj"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="81035678-9e73-45f9-ab61-b64a8119db4c">
        <updating/>
        <source>create() updating;
/*

Purpose:			Creates a Scan Reader and sets the default type to help us find it

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
04 May 2022	navpw1	Initial creation TFS: 52773

*/

begin
	self.type := CM_LaneDevice.Type_ScanReader;

end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="bdf0882f-30c3-4da6-aa05-0bca0f8e1fec">
        <source>getAuditText(): String;
/*

Purpose:			Gets the Audit Text for this object

Parameters:			NONE

Return Value:		String	Returns the Audit text

Date		Who		Reason
04 May 2022	navpw1	Initial creation TFS: 52773

*/

vars
	txt			: String;
	invalidObj 	: Boolean;
	
begin
	txt := inheritMethod();
	
	if self.myScanReader = null then													
		txt &amp;= self.formatAuditText("Scan Reader", app.getErrorString (Unknown));
		
	else
		on Exception do app.handleDeletedObject(exception, self.myScanReader, invalidObj);
		txt &amp;= " " &amp; self.formatAuditText("Scan Reader", self.myScanReader.name);
		
	endif;																			

	return txt;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasDevice" id="f862fc2c-8a12-4a35-9d92-514642afd91a">
        <source>hasDevice(): Boolean;
/*

Purpose:			Tells us whether this object is associated to a device

Parameters:			NONE

Return Value:		Boolean	Returns whether this object is associated to a device

Date		Who		Reason
04 May 2022	navpw1	Initial creation TFS: 52773

*/

begin
	return self.myScanReader &lt;&gt; null;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isScanReader" id="931dc27b-723f-4e62-91bd-42dd043a6339">
        <source>isScanReader(): Boolean;
/*

Purpose:			Tells us if object is a scan reader. Default is true

Parameters:			NONE

Return Value:		Boolean	Returns whether object is a scan reader. Default is true

Date		Who		Reason
04 May 2022	navpw1	Initial creation TFS: 52773

*/

begin
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="c346e618-ab63-408d-be6b-da6e5dff18ff">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			Creates an update proxy for CM_LDScanReader

Parameters:			NONE

Return Value:		SelfType	Returns a new CM_LDScanReader Proxy based on the real object

Date		Who		Reason
04 May 2022	navpw1	Initial creation TFS: 52773

*/

vars
	proxy			: SelfType;
	completedOK		: Boolean;
	
begin
	proxy := inheritMethod();

	proxy.myScanReader := self.myScanReader;
	
	completedOK := true;			
	return proxy;
	
epilog
	if not completedOK then			
		delete proxy;
		
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b4ad15cf-43b3-4f81-898e-ced2ad4d636c">
        <updating/>
        <source>setForUpdate(_proxy: CM_LDScanReader) updating;
/*

Purpose:			Sets our real CM_LDScanReader properties from the proxy

Parameters:			_proxy	CM_LDScanReader	

Return Value:		NONE

Date		Who		Reason
04 May 2022	navpw1	Initial creation TFS: 52773

*/

begin
	self.myScanReader := _proxy.myScanReader;
	
	inheritMethod(_proxy);

end;</source>
        <Parameter name="_proxy" type="CM_LDScanReader"/>
    </JadeMethod>
    <JadeMethod name="setScanReader" id="d6632d42-6b38-46ab-b3d2-8d26fef2281e">
        <updating/>
        <source>setScanReader(_myScanReader : CM_ScanReaderObj) updating;
/*

Purpose:			Associates the Lane Device with a CM_ScanReaderObj

Parameters:			_myScanReader	CM_ScanReaderObj	The scan reader to associate with the lane device

Return Value:		NONE

Date		Who		Reason
04 May 2022	navpw1	Initial creation TFS: 52773

*/

begin
	if self.myScanReader &lt;&gt; _myScanReader then
		self.myScanReader := _myScanReader;
		
	endif;

end;</source>
        <Parameter name="_myScanReader" type="CM_ScanReaderObj"/>
    </JadeMethod>
    <JadeMethod name="validate" id="17dd2dcc-5fa8-4e82-a568-d57bf165a595">
        <source>validate(_passport: CM_Passport input) protected;
/*

Purpose:			Validates whether we can create a new lane device

Parameters:			_passport	CM_Passport	Passport to use for validation and errors

Return Value:		NONE

Date		Who		Reason
04 May 2022	navpw1	Initial creation TFS: 52773

*/

begin
	inheritMethod(_passport);

	if self.myScanReader = null then
		app.raiseUnexpectedProgramError(self.class.name, method.name, 'Scan Reader required');
		
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
