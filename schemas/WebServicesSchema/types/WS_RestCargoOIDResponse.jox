<Class name="WS_RestCargoOIDResponse" id="13a04865-0204-4b8e-a6c5-629bc4835f93">
    <superclass name="WS_RestCargoResponse"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="oid" id="c18c6141-639c-41b7-8bec-90adc8ea43e1">
        <type name="String"/>
        <access>readonly</access>
        <text>The JADE object identifier (OID).</text>
