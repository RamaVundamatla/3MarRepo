        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
//--------------------------------------------------
// Created:	27 May 2004 By: cnwgd1
//--------------------------------------------------
vars

begin

	if (not	self.hasSavedChanges) then
		self.doDeleteClones();
	endif;
	
	self.endNotificationForSubscriber(self);

	inheritMethod();
end;</source>
