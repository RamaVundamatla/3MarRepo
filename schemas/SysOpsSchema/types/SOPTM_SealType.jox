    <JadeMethod name="initShtMultiSelect" id="75f0d188-988d-4b82-9129-2c4f738f3f0a">
        <source>initShtMultiSelect();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
					cnwml2 	PAR23715 SFW CCMS 1131
17 March 2023		jlizm1	TFS 57098 EUP Seal numbers on trucks

