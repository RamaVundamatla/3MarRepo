    <JadeMethod name="doSetup" id="d2f6b1da-78a8-46c2-a349-676e435583ca">
        <source>doSetup(_isPeriod : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
18 October 2022	navhl20	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
04 Aug 2023		navlw1	Bug 59654: [59655] MTN - Fix Vehicle booking Query screen
*/

vars

begin	
	if self.lblSlotType.top &lt;&gt; self.lblEndDate.top and not _isPeriod then
		self.cmbStatus.top := self.cmbSource.top;
		self.lblStatus.top := self.lblSource.top;
		self.cmbSource.top := self.txtExtRef.top;
		self.lblSource.top := self.lblExtRef.top;
		self.txtExtRef.top := self.txtVbsId.top;
		self.lblExtRef.top := self.lblVbsId.top;
		self.txtVbsId.top := self.cmbSlotType.top;
		self.lblVbsId.top := self.lblSlotType.top;
		self.cmbSlotType.top := self.mskEndDate.top;
		self.lblSlotType.top := self.lblEndDate.top;
	elseif _isPeriod then
		self.cmbSlotType.top := self.mskEndDate.top + self.mskEndDate.height + 10;
		self.lblSlotType.top := self.lblEndDate.top + self.lblEndDate.height + 10;
		self.txtVbsId.top := self.cmbSlotType.top + self.cmbSlotType.height + 10;
		self.lblVbsId.top := self.lblSlotType.top + self.lblSlotType.height + 10;
		self.txtExtRef.top := self.txtVbsId.top + self.txtVbsId.height + 10;
		self.lblExtRef.top := self.lblVbsId.top + self.lblVbsId.height + 10;
		self.cmbSource.top := self.txtExtRef.top + self.txtExtRef.height + 10;
		self.lblSource.top := self.lblExtRef.top + self.lblExtRef.height + 10;
		self.cmbStatus.top := self.cmbSource.top + self.cmbSource.height + 10;
		self.lblStatus.top := self.lblSource.top + self.lblSource.height + 10;
		self.txtRemarks.top := self.cmbStatus.top + self.cmbStatus.height + 10;
		self.lblRemarks.top := self.lblStatus.top + self.lblStatus.height + 10;
	endif;
epilog

end;</source>
        <Parameter name="_isPeriod" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSetupDateFilter" id="381b4665-901d-4185-862c-1dd931e69780">
        <updating/>
        <source>doSetupDateFilter() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2022	navhl20	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen

*/

vars
	combobox :	CMUI_ComboBox;
begin
	combobox := self.cmbType;
	if combobox.text = By_Day then
		self.cmbMonth.visible := false;
		self.lblEndDate.visible := false;
		self.mskEndDate.visible := false;
		self.mskStartDate.visible := true;
		self.lblStartDate.caption := "Select Date";
		self.doSetup(false);
	elseif combobox.text = By_Month then
		self.cmbMonth.visible := true;
		self.mskStartDate.visible := false;
		self.lblEndDate.visible := false;
		self.mskEndDate.visible := false;
		self.cmbMonth.left := self.mskStartDate.left;
		self.cmbMonth.top := self.mskStartDate.top;
		self.lblStartDate.caption := "Select Month";
		self.doSetup(false);
	elseif combobox.text = By_Period then
		self.cmbMonth.visible := false;
		self.mskStartDate.visible := true;
		self.lblEndDate.visible := true;
		self.mskEndDate.visible := true;
		self.lblStartDate.caption := "From Date";
		self.doSetup(true);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowBooking" id="0840926a-2de0-4b6e-b879-ac10a7b3c0ee">
        <source>doShowBooking(_booking : CM_BookingRef);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Aug 2023	navlw1	Bug 60046:[60047] FR | 53429 - VBS MTN - Enquiry Screen issues

