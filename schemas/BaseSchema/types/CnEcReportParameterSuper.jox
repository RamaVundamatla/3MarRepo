    <JadeMethod name="isValidParameterNameLength" id="87ca65b5-91de-45a3-b1bc-9cdec0e20e96">
        <updating/>
        <source>isValidParameterNameLength(pParameterName:String):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		29 August 2000 by cnwdad1
//
// Purpose:		Validates the name of a Report Parameter to ensure that the length
//				of the name does not exceed the maximum allowable name length.
//
// Parameters:	pParameterName (String) - The parameter name whose length to validate.
//
// Returns:		True if the name length is valid, otherwise false.  Note that if the
//				length of the name is not valid, then the value of the inherited
//				"aErrorMessage" form property will have been set with the appropriate
//				error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theProperty		: Property;
	theAttribute	: PrimAttribute;
	maximumLength	: Integer;

begin
	theProperty	:=	CnEcReportParameterSuper.getProperty(CnEcReportParameterSuper::aParameterName.name);

	if theProperty = null then
		self.setErrorMessage(	"System Schema Error - The following expected attribute was not found:" &amp;
								CrLf &amp; CrLf &amp; self.name &amp; "::" &amp; CnEcReportParameterSuper::aParameterName.name);
		return false;
	else
		theAttribute	:=	theProperty.PrimAttribute;
		maximumLength	:=	theAttribute.length - 1;

		if pParameterName.length &gt; maximumLength then
			self.setErrorMessage(	"The name of this parameter (" &amp; pParameterName &amp; ") is too long." &amp;
									CrLf &amp; CrLf &amp;
									"The maximum allowable length for a parameter name is " &amp;
									maximumLength.String &amp; " characters.");
			return false;
		endif;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="pParameterName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
