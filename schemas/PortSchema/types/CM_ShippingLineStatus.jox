    <JadeMethod name="validateForCreate" id="46107403-e295-482a-b1f4-dabfa84ecd73">
        <source>validateForCreate();
//08/08/2023	navkc1	CR 59580	Task 59586: Jade - CustDocs Shipping Line Status TRX
vars
	shipLineStatus : CM_ShippingLineStatus;
begin
	
	if self.code = null then
		app.raiseCMException(NoShipLineStatusCodeEntered, null ,null);
	endif;
	
	shipLineStatus := self.myTerminal.allShippingLineStatus[self.code];
	if shipLineStatus &lt;&gt; null then
		app.raiseCMException1(ShipLineStatusCodeInUsed, self.code, null, null);
	endif;
	
	self.validateForUpdate();
epilog

end;</source>
    </JadeMethod>
