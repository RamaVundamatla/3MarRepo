<Class name="HMS_Delay">
    <JadeMethod name="importPLXMLReference" id="bf316efa-adcf-4918-99a1-3becff7bad6d">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = HMS_Delay::myRoot.name then
		return app.myRoot;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
