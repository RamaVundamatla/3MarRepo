    <JadeMethod name="populatePxyFromReserveDetail" id="88a4f12a-9a2b-4472-80b4-af69d52bbcef">
        <updating/>
        <source>populatePxyFromReserveDetail(_resDetail: CM_ReserveDetail) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Nov 2022	navhl20	ChangeRequest 54979: EUP - Cargo Work Orders Enhancements
02 Feb 2023 navdp20 ChangeRequest 56969:[56288] EUP - [Framework] Constructing methods to populate booking, bill of lading, and release request conversion
19 Jul 2023 jlizm1	TFS 58461 Change release mark number to string
*/

vars
	ti  : CM_TrackedItem;
begin
	inheritMethod(_resDetail);
	self.isoType 			:= _resDetail.getISOCode;									//02.02.2023 navdp20 TFS #56969[56288]
	self.isoTypeGroup   	:= _resDetail.getISOGroupCode;          					//02.02.2023 navdp20 TFS #56969[56288]
	
	if _resDetail.isKindOf(CM_ReserveSelection) then									//03.03.2023 navhl20 TFS #56969[56288]
		self.clean      	:= _resDetail.CM_ReserveSelection.clean;
		self.colour 		:= _resDetail.CM_ReserveSelection.colour;
		self.density 		:= _resDetail.CM_ReserveSelection.densitySelection;
		self.description 	:= _resDetail.CM_ReserveSelection.descriptionSelection;
		self.height 		:= _resDetail.CM_ReserveSelection.heightSelection;
		self.length 		:= _resDetail.CM_ReserveSelection.lengthSelection;
		self.markNumber		:= _resDetail.CM_ReserveSelection.markNumber;
		self.myProduct 		:= _resDetail.CM_ReserveSelection.myProduct;
		self.volume 		:= _resDetail.CM_ReserveSelection.volumeSelection;
		self.width 			:= _resDetail.CM_ReserveSelection.widthSelection;
	else
		ti 					:= _resDetail.CM_ReserveTI.getTI();
		self.populatePxyFromTI(ti);
	endif;
epilog

end;</source>
        <Parameter name="_resDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="populatePxyFromTI" id="fed35e30-9406-4d62-abb3-6c510c3440b5">
        <updating/>
        <source>populatePxyFromTI(_ti : CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Nov 2022	navhl20	ChangeRequest 54979: EUP - Transport Mode change - PortSchema Changes
08 Dec 2022 jlika1 	TFS 55586 - HS Code User Defined EDI
31 Jan 2024	navpw1	TFS: 59411 (61855) - Added a check which sets the product on the booking ref item if the cargo type requires a sub type
02 Jul 2024	navpw1	TFS: 64888 - Fixed 1090 caused by _ti.getISOTypeObject() returning null in production environments

*/

vars
	isoTypeObj : CM_ISOType;
	
begin
	if _ti = null then
		return;
	endif;
	self.cargoType 			:= 	_ti.cargoType;
	// ### TFS 59411 (61855) 31Jan2024 NAVPW1
	if _ti.myCargoType.isSubCargoTypeRequired then
		self.myProduct		:= _ti.myProduct;
	endif;
	// ### TFS 59411 (61855) 31Jan2024 NAVPW1
	self.commodity 			:=	_ti.commodity;
	self.density			:=	_ti.density;
	self.description		:=	_ti.description;
	self.earliestReceivalTS	:=	_ti.earliestReceivalTS;
	self.height				:=	_ti.height;
	self.id					:=	_ti.id;
	isoTypeObj := _ti.getISOTypeObject();
	if isoTypeObj &lt;&gt; null then
		self.isoType		:=	isoTypeObj.code;
	endif;
	self.isoTypeGroup		:=	_ti.isoTypeGroup;
	self.length				:=	_ti.length;
	self.markNumber			:=	_ti.markNumber;
	self.purchaseOrder		:=	_ti.purchaseOrder;
	self.rawEDIData			:=	_ti.rawEDIData;
	self.remarks			:=	_ti.remarks;
	self.serviceOrder		:=	_ti.serviceOrder;
	self.volume				:=	_ti.volume;
	self.weight				:=	_ti.weight;
	self.width				:= 	_ti.width;	
	self.hsCode				:=	_ti.hsCode;
	
	if _ti.quantity = null then
		self.quantity := 1;
	else
		self.quantity			:=	_ti.quantity;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setForCreate_CMIF" id="97b6e90b-ecbc-41d5-afac-3f3a20887e4b">
        <updating/>
        <source>setForCreate_CMIF(pProxyBookingRefItem : CMIF_BookingRefItem; pBookingRef : CM_BookingRef) updating;

vars
	commodity : CM_Commodity;
begin
	
	inheritMethod(pProxyBookingRefItem, pBookingRef);
	//epr TFS 1480 5/2/16
	self.updateBRefItemConainerDetails(pProxyBookingRefItem);
	
	
end;
</source>
        <Parameter name="pProxyBookingRefItem" type="CMIF_BookingRefItem"/>
        <Parameter name="pBookingRef" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="cbfa6d49-0ac7-4f6e-aab9-49b769ae6c62">
        <updating/>
        <source>setForUpdate(_proxyBookingRefItem: CM_BookingRefItem; _bookingRef: CM_BookingRef) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2008	cnwer1	Initial creation
07/11/2022 	navrk21 Bug 55167: MTN - Booking Item not saving CO2, O2 and Curtains In/Out unless a commodity is specified
*/

vars
	commodity : CM_Commodity;
begin
	inheritMethod(_proxyBookingRefItem, _bookingRef);
	//11/12/2009 cnwdz2 par21830 ----start
	commodity := self.getCommodityObj();
	//if _proxyBookingRefItem.isKindOf(CM_BRefItemContainer) and self.myISOType &lt;&gt; null and self.myISOType.isReefer then // par 17185 aer 10/10/2008
	//if _proxyBookingRefItem.isKindOf(CM_BRefItemContainer) and commodity &lt;&gt; null and commodity.hasTemp then															//07.11.2022 navrk21 TFS 55167
	if _proxyBookingRefItem.isKindOf(CM_BRefItemContainer) and (commodity &lt;&gt; null and commodity.hasTemp) or (self.myISOType &lt;&gt; null and self.myISOType.isReefer) then	//07.11.2022 navrk21 TFS 55167
	//11/12/2009 cnwdz2 par21830 ----- end
		self.setHumidity(_proxyBookingRefItem.CM_BRefItemContainer.getHumidity());
		self.setTemperature(_proxyBookingRefItem.CM_BRefItemContainer.getTemperature());
		self.setVentilation(_proxyBookingRefItem.CM_BRefItemContainer.getVentilation());
		self.setVentilationUnits(_proxyBookingRefItem.CM_BRefItemContainer.getVentilationUnits());
		self.setCarbonDioxide(_proxyBookingRefItem.CM_BRefItemContainer.getCarbonDioxide());
		self.setOxygen(_proxyBookingRefItem.CM_BRefItemContainer.getOxygen());
		self.setCurtainsIn(_proxyBookingRefItem.CM_BRefItemContainer.getCurtainsIn());
	else
		self.setHumidity(NULL_HUMIDITY);
		self.setTemperature(NULL_TEMPERATURE);
		self.setVentilation(NULL_VENTILATION); //par19252 cnwrs1 may 2009
		self.setVentilationUnits(null);
		self.setCarbonDioxide(NULL_CARBON_DIOXIDE);	// CCMS 1654 - slw 16/09/2008
		self.setOxygen(NULL_OXYGEN);	// CCMS 1654 - slw 16/09/2008
		self.setCurtainsIn(false);
	endif;
epilog

end;</source>
        <Parameter name="_proxyBookingRefItem" type="CM_BookingRefItem"/>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate_CMIF" id="b8cd8c2d-3f6d-40bb-9247-fa050aac145f">
        <updating/>
        <source>setForUpdate_CMIF(_cmifBRItem : CMIF_BookingRefItem; pBookingRef : CM_BookingRef) updating;
/*
	Created on 17 January 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	
	inheritMethod(_cmifBRItem, pBookingRef);
	//epr TFS 1480 5/2/16
	self.updateBRefItemConainerDetails(_cmifBRItem);

	
end;</source>
        <Parameter name="_cmifBRItem" type="CMIF_BookingRefItem"/>
        <Parameter name="pBookingRef" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="f095b6f1-de7b-4625-9448-0eeb43270cea">
        <updating/>
        <source>setProxy(	_cargoType: Integer;
			_commodity: String; 
			_description: String;
			_remarks : String;
			_hazards: CM_HazardByCodeDict;
			_isoType: String;
			_quantity: Integer;
			_weight: Decimal; //par19252 cnwrs1 may 2009
			_maxToRelease: Integer;
			_grade: Integer;
			_humidity: Decimal;
			_temperature: Real;
			_ventilation: Decimal; //par19252 cnwrs1 may 2009
			_ventilationUnits: Integer;
			_carbonDioxide: Decimal;
			_oxygen: Decimal;
			_curtainsIn: Boolean;
			_isClean : Boolean;
			_heavyRated : Boolean;
			_specialStow : CM_SpecialStow;
			_isoGroup : String;
			_inspected : Boolean;														//+cnwml2 PAR20173 SFW CCMS 1091
			_specialLift : CM_SpecialLiftByCodeDict;							//+cnwml2 PAR20173 SFW CCMS 1091
			_purchaseOrder : String;											// PAR #33193
			_serviceOrder : String;												// PAR #33193
			_matchMode : Integer												//navra1 - CR 63764/Task 64227 - 22nd May 2024
			)updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
25 November 2008	cnwer1	Initial creation
26 May 2009			cnwjo3	add specialStow for CCMS 1079
04 March 2014		cnwdap1	PAR #33193 CCMS DPH 2285 New purchaseOrder and serviceOrder fields
*/

vars

begin
	self.setHumidity(_humidity);
	self.setTemperature(_temperature);
	self.setVentilation(_ventilation);
	self.setVentilationUnits(_ventilationUnits);
	self.setCarbonDioxide(_carbonDioxide);
	self.setOxygen(_oxygen);
	self.setCurtainsIn(_curtainsIn);
	self.isoTypeGroup		:= _isoGroup;							//+cnwml2 PAR20173 SFW CCMS 1091

	inheritMethod(_cargoType, _commodity, _description, _remarks, _hazards, _isoType, _quantity, _weight, _maxToRelease, _grade, _humidity, _temperature, _ventilation, _ventilationUnits, _carbonDioxide, _oxygen, _curtainsIn,_isClean,_heavyRated,_specialStow, _isoGroup, _inspected, _specialLift, _purchaseOrder, _serviceOrder, _matchMode);				//navra1 - CR 63764/Task 64227 - 23rd May 2024

epilog

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_hazards" type="CM_HazardByCodeDict"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_maxToRelease" type="Integer"/>
        <Parameter name="_grade" type="Integer"/>
        <Parameter name="_humidity" type="Decimal"/>
        <Parameter name="_temperature" type="Real"/>
        <Parameter name="_ventilation" type="Decimal"/>
        <Parameter name="_ventilationUnits" type="Integer"/>
        <Parameter name="_carbonDioxide" type="Decimal"/>
        <Parameter name="_oxygen" type="Decimal"/>
        <Parameter name="_curtainsIn" type="Boolean"/>
        <Parameter name="_isClean" type="Boolean"/>
        <Parameter name="_heavyRated" type="Boolean"/>
        <Parameter name="_specialStow" type="CM_SpecialStow"/>
        <Parameter name="_isoGroup" type="String"/>
        <Parameter name="_inspected" type="Boolean"/>
        <Parameter name="_specialLift" type="CM_SpecialLiftByCodeDict"/>
        <Parameter name="_purchaseOrder" type="String"/>
        <Parameter name="_serviceOrder" type="String"/>
        <Parameter name="_matchMode" type="Integer"/>
    </JadeMethod>
