    <JadeMethod name="resetDistances" id="79ec96e3-b9fb-4751-ba43-a3dff2726ddd">
        <source>resetDistances() protected;

vars

	distance,
	difference : Real;
	

begin
	
	self.tblSelectData.top := (self.tblSelection.top + self.tblSelection.height + 5);
	self.txtDetail.top := (self.tblSelection.top + self.tblSelection.height + 5);
	
	difference := self.tblActionData.top - (self.tblSelectData.top + self.tblSelectData.height);
	difference := difference - 13;
	self.tblSelectData.height	:= self.tblSelectData.height + difference;
	self.txtDetail.height		:= self.txtDetail.height + difference;
	
	if self.selection = NONUMBER or
		self.selection = LOT then
//		self.tblSelection.setDistanceFromBottom(120);
		self.btnFindT.enabled := true;
	else
//		self.tblSelection.setDistanceFromBottom(150);
		self.btnFindT.enabled := false;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="selectAll" id="a262621d-1e2f-4091-9aa1-e26e35ca3dcf">
        <updating/>
        <source>selectAll(_all : Boolean)updating, protected;

vars

	cell 	: JadeTableCell;
	row		: Integer;		

begin

	foreach row in 2 to self.tblSelectData.rows do
		cell := self.tblSelectData.accessCell(row, 1);
		cell.text := _all.Integer.String;
	endforeach;
	if self.selection = DOCKET then
//		self.getAvailableLocations();
	endif;
	
	//par #18033 cnwrd1 30.9.08
	if self.selection = LOT then
		if _all then
			if self.tblSelectData.rows &gt; 1 then
				self.mySOHLocation := self.tblSelectData.accessRow( 2 ).itemObject.CM_SOHLocation;
			endif;
		else
			self.mySOHLocation := null;
		endif;
			
		self.getAvailableLocations();
	endif;
		

end;</source>
        <access>protected</access>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setButtons" id="1ead7bd0-e1a4-4213-b291-2fbf7a92c0a6">
        <updating/>
        <source>setButtons(_value : Boolean) protected, updating;

vars

begin

	self.btnSaveBase.enabled		:= _value;
	self.btnNextT.enabled		:= _value;
	self.btnSelectAllT.enabled	:= _value;
	self.btnSelectNoneT.enabled	:= _value;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSaveBase.enabled		:= false;
		self.btnNextT.enabled		:= false;
		self.btnSelectAllT.enabled	:= false;
		self.btnSelectNoneT.enabled	:= false;

	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="0da89c68-c2f2-4314-b66a-7c50c32e5448">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_colorControl);
	
	self.setColorsForEntryTable(self.tblActionData);
	self.setColorsForEntryTable(self.tblSelection);
	self.setColorsForTable(self.tblSelectData);

	self.txtDetail.backColor	:= self.colorControlBack;

