    <JadeMethod name="getVesselTypeServiceTimeRate" id="4c158efc-c384-49c8-a3fd-d313f5d6b003">
        <source>getVesselTypeServiceTimeRate(_service : CM_Service; _ts : TimeStamp) : CM_RateEntry;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/03/2018	jlgdap1		Initial creation TFS 37794 PEL1 Vessel Rates
// 23 Oct 2024	navlw1		JIRA-33107: Invoice Logging Use Levels
// 25 Feb 2025	navah1		Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	serviceRate : CM_VesselTypeRate;
	rateEntry : CM_RateEntry;
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	serviceRate := self.allServiceRates[_service];
	if serviceRate &lt;&gt; null then
		rateEntry := serviceRate.getTimeRate(_service.bank, _ts);
		if canLogExtra then	//28.02.2025 navah1	#34141
			if rateEntry &lt;&gt; null then
				app.invLog("Rate for " &amp; _service.name &amp; " derived from vessel type '" &amp; self.description &amp; "' found", LogTRACE.String);
			else
				app.invLog("Rate for " &amp; _service.name &amp; " derived from vessel type '" &amp; self.description &amp; "' NOT found", LogTRACE.String);
			endif;
		endif;
		return rateEntry;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_service" type="CM_Service"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="CM_RateEntry"/>
    </JadeMethod>
