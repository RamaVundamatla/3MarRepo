    <JadeMethod name="getDisplayStringForAttribute" id="2ee6e8c3-5136-4d14-b4f5-80d3261650d1">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
04 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	if _attrName = ETRow_NotAvailable then
		return self.isUnavailable.asStringJMT;
	else
		

		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="ce02ca91-bbf5-477e-9ee9-ec618eeb9d98">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			


Return Value:		


Date			Who		Reason
21 August 2007	cnwer1	Initial creation - PAR#xxxx
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy

*/
vars
	tmpFaultStatus : CM_FaultStatus;
	completedOK		: Boolean;
begin
	tmpFaultStatus:= inheritMethod();

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tmpFaultStatus;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tmpFaultStatus;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b705d26b-b3df-4a91-b282-38c67ad8e5ba">
        <updating/>
        <source>setForCreate(_pxyFaultStatus : CM_FaultStatus) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
30 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.setForUpdate(_pxyFaultStatus);
	self.myRoot:=app.myRoot;

epilog

end;</source>
        <Parameter name="_pxyFaultStatus" type="CM_FaultStatus"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="044a5571-744f-4aa1-96d1-050b474b5df5">
        <updating/>
        <source>setForUpdate(_pxyFaultStatus : CM_FaultStatus) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
30 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.code:=_pxyFaultStatus.code;
	self.description:=_pxyFaultStatus.description;
	self.isDefault:=_pxyFaultStatus.isDefault;
	self.isUnavailable:=_pxyFaultStatus.isUnavailable;

epilog

end;</source>
        <Parameter name="_pxyFaultStatus" type="CM_FaultStatus"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="0c7d6d97-96b6-424f-814c-69b805d83692">
        <updating/>
        <source>setProxy(	_code,
			_description : String;
			_isUnavailable,
			_isDefault : Boolean) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
21 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.code:=_code;
	self.description :=_description;
	self.isUnavailable :=_isUnavailable;
	self.isDefault:=_isDefault;

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_isUnavailable" type="Boolean"/>
        <Parameter name="_isDefault" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="074bf504-c584-4a07-a7b2-d78a65a62177">
        <source>validateForCreate();
/*

Purpose:			


Return Value:		


Date			Who		Reason
30 August 2007	cnwer1	Initial creation - PAR#xxxx
22 October 2008	consw1	Par 18262 - correct duplicates validation
*/
vars

begin	
	self.validateForUpdate();

	if app.myRoot.allFaultStatuses[self.code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
		return;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="de7c50ae-f778-457c-879e-92cc201c23b5">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jul 2020 cnwma1  Bug 49710: SNO -- Error 1090 when searching under the Fault Enquiry screen

*/

vars

begin
	
	if self.allFaults.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.code,app.getErrorString(Faults) , null, null);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="8dafcece-3b89-4c9a-86fa-d8b6c6dba7a5">
        <source>validateForUpdate();
/*

Purpose:			


Return Value:		


Date			Who		Reason
30 August 2007	cnwer1	Initial creation - PAR#xxxx
22 October 2008	consw1	Par 18262 - correct duplicates validation
*/
vars

begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Code', null, null);
		app.raiseCMException(Input_required_field_code, null, null); // cnwdb2	PAR 35364
		return;
	endif;

	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Description', null, null);
		app.raiseCMException(Input_required_field_Desc, null, null); // cnwdb2	PAR 35364


		return;
	endif;
	
	//PAR17450 - cnwsh3 Does one already exist with this code?
//	if app.myRoot.allFaultStatuses[self.code] &lt;&gt; null then
//		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
//		return;
//	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
