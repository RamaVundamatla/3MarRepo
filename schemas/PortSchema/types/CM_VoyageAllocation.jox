    <JadeMethod name="getIs45" id="279d8041-d0d9-47f5-b4b6-0f243093e5b4">
        <source>getIs45() : Boolean;
// ---------------------------------------------------------------------------
// Created:     15 March 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	criteria : CM_YACriteria;
begin

	criteria := self.getCriteriaOfTypeValue(YACriteriaType_IsFortyFive);
	if criteria &lt;&gt; null then

		if criteria.myYAData.CM_YADataBoolean.getValueAsBoolean() then 
			return true;
		endif;
	endif;

	criteria := self.getCriteriaOfTypeValue(YACriteriaType_ISO);
	if criteria &lt;&gt; null then
		if  criteria.myYAData.CM_YADataObjects.allObjects.first().CM_ISOType.is45ftLong() then
			return true;
		endif;
	endif;

	criteria := self.getCriteriaOfTypeValue(YACriteriaType_ISOGroup);
	if criteria &lt;&gt; null then
		if  criteria.myYAData.CM_YADataObjects.allObjects.first().CM_ISOTypeGroup.is45ftLong() then
			return true;
		endif;
	endif;
	
	return  false;

epilog

end;</source>
