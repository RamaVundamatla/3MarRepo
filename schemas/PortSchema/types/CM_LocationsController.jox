    <JadeMethod name="valMoveToForHazTIAutoplan" id="c444dffc-6ea5-42df-9beb-a88ec62926f3">
        <source>valMoveToForHazTIAutoplan(_tiBeingMoved	: CM_TrackedItem; _yaAgent : CM_YAAutoplanAgent input) : Boolean;
							
/*
----------   ----------  --------------------------------------------------
Created:	27 November 2006 By cnwth2

Purpose:	self is the to location

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	hazTiToCheck		: CM_TrackedItem;
	notAllowedSameArea	: Boolean;
	lc					: CM_LocationsController;
	obj					: Object;
	ruleType			: Integer;
	reasonWhyNot		: String;
	termArea			: CM_TerminalArea;
begin
	
	if not _tiBeingMoved.isHazardous then
		return true;
	endif;
	
	//10 Oct 2012	NDL	Par 30497
	termArea := self.myTerminalArea;
	if termArea &lt;&gt; null and (termArea.type = TA_TYPE_RECTRANS or termArea.type = TA_TYPE_RELTRANS) then
		return true;
	endif;
	
	ruleType := self.getHazardSegregationRuleType();
	
	foreach hazTiToCheck in termArea.allHazardousTIs where hazTiToCheck &lt;&gt; _tiBeingMoved do
		if not _tiBeingMoved.valHazCanCoexistSameTAAutoplan(hazTiToCheck, ruleType) then
			foreach lc in termArea.allLocationsControllers discreteLock do
				_yaAgent.addToFailedLocations(lc);
				
			endforeach;
			//cnwjo3 par 22493
			_yaAgent.addLogEntry(AP_Log_YA_Default,"Terminal Area '" &amp; termArea.getID() &amp; "' does not allow tracked items '" &amp; _tiBeingMoved.id &amp; "' and '" &amp; hazTiToCheck.id &amp; "' to exist in same terminal area because of Hazard Segreation (" &amp; hazTiToCheck.getHazardsAsString &amp; "," &amp; _tiBeingMoved.getHazardsAsString() &amp; ")", true);
			return false;
		endif;
	endforeach;

	// ACTUAL
	foreach hazTiToCheck in self.allHazardousTIs where hazTiToCheck &lt;&gt; _tiBeingMoved do
		if not _tiBeingMoved.valHazCanCoexistAtLocAutoplan(hazTiToCheck, hazTiToCheck.myPrimaryActualLocation, self, ruleType) then // PAR 16155 pass in LC
			_yaAgent.addLogEntry(AP_Log_YA_Default,self.getFullId &amp; " Hazardous conflict with tracked item " &amp; hazTiToCheck.id, true);
			return false;
		endif;
	endforeach;

	// PAR 16097
	// QUEUED
	foreach hazTiToCheck in self.allHazardousTIsQueued where hazTiToCheck &lt;&gt; _tiBeingMoved do
		if not _tiBeingMoved.valHazCanCoexistAtLocAutoplan(hazTiToCheck, self, hazTiToCheck.myPrimaryQueuedLocation, ruleType) then // PAR 16155 pass in LC
			_yaAgent.addLogEntry(AP_Log_YA_Default,self.getFullId &amp; " Hazardous conflict with QUEUED tracked item " &amp; hazTiToCheck.id, true);
			return false;
		endif;
	endforeach;
	// PLANNED
	foreach hazTiToCheck in self.allHazardousTIsPlanned where hazTiToCheck &lt;&gt; _tiBeingMoved do
		if not _tiBeingMoved.valHazCanCoexistAtLocAutoplan(hazTiToCheck, self,hazTiToCheck.myPrimaryPlannedLocation,  ruleType) then // PAR 16155 pass in LC
			_yaAgent.addLogEntry(AP_Log_YA_Default,self.getFullId &amp; " Hazardous conflict with PLANNED tracked item " &amp; hazTiToCheck.id, true);
			return false;
		endif;
	endforeach;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_tiBeingMoved" type="CM_TrackedItem"/>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
