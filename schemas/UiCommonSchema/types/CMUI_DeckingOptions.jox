    <JadeMethod name="markAtIndex" id="2a93603c-25f1-4bd9-85bd-3251e85057b5">
        <updating/>
        <source>markAtIndex(_index: Integer) updating;
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	markIndex	: Integer;
	oldMarker,
	newMarker	: CM_YALocationCell;
begin
	oldMarker := self.myMarkerLocnCell;
	
	if oldMarker &lt;&gt; null then
		markIndex := self.lstDeckingLocns.findObject(oldMarker);
		self.lstDeckingLocns.itemBackColor[markIndex] := White;
	endif;

	if _index &lt; 1 
	or markIndex = _index then
		//treat as undo
		self.myMarkerLocnCell := null;
		return;
	endif;

	newMarker := self.lstDeckingLocns.itemObject[_index].CM_YALocationCell;

	self.myMarkerLocnCell := newMarker;
	
	self.lstDeckingLocns.itemBackColor[_index] := Red;
	
end;</source>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="markerIndex" id="4d75c406-b7bb-416a-93ae-68efaaa01039">
        <methodInvocation>mapping</methodInvocation>
        <source>markerIndex(set: Boolean; _value: Integer io) mapping;
//----------------------------------------------------------------
//	Created:	24 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if set then
		return;
	else
		_value := self.lstDeckingLocns.findObject(self.myMarkerLocnCell);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="moveSelectionToMarker" id="a3c34fee-efc5-42e1-b21f-4bd817eef853">
        <updating/>
        <source>moveSelectionToMarker() updating;
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	blnSelected		: Boolean;
	tmpArray		: CM_YALocationCellArray;
	idx,targetIndex	: Integer;
	targetObject,
	yaLocnCell		: CM_YALocationCell;
begin

	targetIndex := self.markerIndex;	//our target

	if targetIndex &lt; 1 
	or targetIndex &gt; self.lstDeckingLocns.listCount then
		app.msgBox("Marker not set.  Please reset.", "Error", MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;

	create tmpArray transient;
	
	idx := 0;

	foreach idx in 1 to self.lstDeckingLocns.itemSelected.size do
		blnSelected := self.lstDeckingLocns.itemSelected[idx];
		if blnSelected then
			if targetIndex = idx then
				app.msgBox("Marker cannot be with the selection.  Please reset.", "Error", MsgBox_OK_Only + MsgBox_Information_Icon);
				return;
			endif;
			yaLocnCell := self.lstDeckingLocns.itemObject[idx].CM_YALocationCell;
			tmpArray.add(yaLocnCell);
		endif;
	endforeach;
	
	if tmpArray.isEmpty then
		app.msgBox("Nothing selected to move.  Please reselect.", "Error", MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	//OK to move
	foreach yaLocnCell in tmpArray do
		idx := self.lstDeckingLocns.findObject(yaLocnCell);
		self.lstDeckingLocns.removeItem(idx);

		//need to keep checking the index as we go as it keeps moving
		targetIndex := self.lstDeckingLocns.findObject(self.myMarkerLocnCell);
		
		self.addItemToListAt(targetIndex, yaLocnCell);
		
		if not self.customOrderHasChanged then
			self.setCustomOrderHasChanged(true);
		endif;
	endforeach;
	
	
epilog
	if tmpArray &lt;&gt; null then
		tmpArray.clear;
		delete tmpArray;	
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="removeItemFromTable" id="c4bd9a32-cdeb-427f-9d90-4e004f5b9f67">
        <source>removeItemFromTable(_rule: CM_YADeckingRule; _tbl: CM_Table input);
//----------------------------------------------------------------
//	Created:	09 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	intRow		: Integer;
	idx			: Integer;
begin

	foreach intRow in _tbl.fixedRows to _tbl.rows do
		if _tbl.accessRow(intRow).itemObject = _rule then
			idx := intRow;
		endif;
	endforeach;

	if idx &lt;&gt; null then
		_tbl.removeItem(idx);
	endif;

end;</source>
        <Parameter name="_rule" type="CM_YADeckingRule"/>
        <Parameter name="_tbl" type="CM_Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="saveCustomOrder" id="1f393393-cb13-492f-abfd-ccea1b8bb241">
        <updating/>
        <source>saveCustomOrder() updating;
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	
begin
	if self.customDeckingForIn then
		self.startupOptionIn := DeckingRule_Custom;
		self.startupOptionOut := null;
		self.setCmbOptionValue();
		self.setArrayFromList(self.myProxyDeckingOptions.allYALocationCellsIn);
		
	else
		self.startupOptionIn := null;
		self.startupOptionOut := DeckingRule_Custom;
		self.setCmbOptionValue();
		self.setArrayFromList(self.myProxyDeckingOptions.allYALocationCellsOut);
		
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setArrayFromList" id="be43f419-ae1d-4e05-a79d-fc6a05c7bf99">
        <source>setArrayFromList(_tmpArray: CM_YALocationCellArray input);
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx			: Integer;
	locnCell,
	baseLocnCell: CM_YALocationCell;
begin

	_tmpArray.clear;
	
	if self.chkShowHeights.value then
		//take straight from list
		foreach idx in 1 to self.lstDeckingLocns.listCount do
			_tmpArray.add(self.lstDeckingLocns.itemObject[idx].CM_YALocationCell);
		endforeach;
	else
		//have to put in heights
		foreach idx in 1 to self.lstDeckingLocns.listCount do
			baseLocnCell := self.lstDeckingLocns.itemObject[idx].CM_YALocationCell;
			if self.customDeckingForIn then	
				foreach locnCell in baseLocnCell.myYardController.allYAYardLocationCells do
					_tmpArray.add(locnCell);
				endforeach;
			else			
				foreach locnCell in baseLocnCell.myYardController.allYAYardLocationCells reversed do
					_tmpArray.add(locnCell);
				endforeach;
			endif;
		endforeach;
	endif;
end;</source>
        <Parameter name="_tmpArray" type="CM_YALocationCellArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCmbOptionValue" id="7cda5af7-8ec7-470e-9e19-630aae0d060d">
        <updating/>
        <source>setCmbOptionValue() updating;
//----------------------------------------------------------------
//	Created:	24 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx		: Integer;
	cmb		: CMUI_ComboBox;
	option	: Integer;
	cmbTxt	: String;
begin

	//only one can be set when initiated with setInitializeWithObject
	if self.startupOptionIn &lt;&gt; null then
		cmb := self.cmbInOptions;
		option := self.startupOptionIn;
		
	elseif self.startupOptionOut &lt;&gt; null then
		cmb := self.cmbOutOptions;
		option := self.startupOptionOut;
	
	else
		//no start options use the myDeckingOptions
		return;
	endif;

	foreach idx in 1 to cmb.listCount do
		cmbTxt := cmb.itemText[idx][1:2].trimBlanks;
		if cmbTxt = option.String then
			cmb.listIndex := idx;		
			break;
		endif;			
	endforeach;		
	
	if self.startupOptionIn = DeckingRule_Custom then
		self.clearTable(self.tblInOptions);
		self.doAddInRuleToTable();	
	elseif self.startupOptionOut =  DeckingRule_Custom then
		self.chkOutUseRevOfIn.value := false;	//over ride
		self.clearTable(self.tblOutOptions);
		self.doAddOutRuleToTable();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setCustomOrderHasChanged" id="4eaf270a-b600-4f4c-9075-d9d4400f2cd0">
        <updating/>
        <source>setCustomOrderHasChanged(_changed: Boolean) updating;
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.customOrderHasChanged := _changed;

end;</source>
        <Parameter name="_changed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setInitializeWithObject" id="e23e9bc8-6511-4a35-9266-7d40b793a89b">
        <updating/>
        <source>setInitializeWithObject(_pxyDeckingOptions: CM_YADeckingOptions; _startUpOption: Integer; _isInOption: Boolean) updating;
//----------------------------------------------------------------
//	Created:	21 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.myProxyDeckingOptions := _pxyDeckingOptions;
		
	if _startUpOption = DeckingRule_Null then
		//use the current area
		self.startupOptionIn := null;
		self.startupOptionOut := null;
		return;
	endif;
	
	if _isInOption then
		self.startupOptionIn := _startUpOption;
		self.startupOptionOut := null;
	else
		self.startupOptionIn := null;
		self.startupOptionOut := _startUpOption;
	endif;
			
end;</source>
        <Parameter name="_pxyDeckingOptions" type="CM_YADeckingOptions"/>
        <Parameter name="_startUpOption" type="Integer"/>
        <Parameter name="_isInOption" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setOutControlsForReverseOfIn" id="43d48c61-7d38-42a8-83e7-999feee40e88">
        <source>setOutControlsForReverseOfIn();
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	disable		: Boolean;
begin

	disable :=	self.chkOutUseRevOfIn.value;

	self.disableOutOptions(disable);

	//re-enable this - should only be disabled when doing custom ordering
	self.chkOutUseRevOfIn.enabled := true;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setSizes" id="55080fb4-75cc-4d75-ace1-f9d4503b8147">
        <updating/>
        <source>setSizes() updating;
//----------------------------------------------------------------
//	Created:	21 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
//	self.height := 480;
//	self.width := 500;
	self.frmInOptions.width := self.width - 15;
	self.frmInOptions.height := (self.height* 0.38);	
	self.tblInOptions.height := 80;
	
	self.frmOutOptions.top := (self.height* 0.46);
	self.frmOutOptions.width := self.width - 15;
	self.frmOutOptions.height := (self.height* 0.44);	
	self.tblOutOptions.height := 80;
	
end;</source>
    </JadeMethod>
