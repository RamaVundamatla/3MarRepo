    <JadeMethod name="pxyCreateUpdateProxy" id="ce65117c-3642-426e-9ec3-df679c4e003e">
        <source>pxyCreateUpdateProxy(): SelfType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/09/2015	cnwdap1		Initial creation PAR #36909 CCMS ADP 2537 Minimum Charge changes
//
vars
	proxy : SelfType;
	completedOK : Boolean;
	proxyMin : CM_InvoiceLineDesc;
begin
	proxy := inheritMethod();
	
	// set references
	proxy.bank 							:= self.bank;
	proxy.group 						:= self.group;
	proxy.invoiceType 					:= self.invoiceType;
	proxy.minimumChargeInvoiceLineType 	:= self.minimumChargeInvoiceLineType;
	proxy.myCalculationType 			:= self.myCalculationType;
	proxy.myDebtorType 					:= self.myDebtorType;
	
	completedOK := true;
	return proxy;

epilog
	if not completedOK then
		delete proxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
