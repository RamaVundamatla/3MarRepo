<GUIClass name="CMUI_InvoiceSSAllocMapping" id="710111df-9d1e-49d8-a335-e016afe86856">
    <superclass name="CMUI_InvoiceCargoAllocMapping"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="mySnapShotBroker" id="4a6e3117-71a4-401d-84b6-4f512cc988c9">
        <embedded/>
        <type name="CM_SnapShotServiceBroker"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="displayInvoiceLineTypes" id="dad00dd2-d6cb-43a3-8479-3dea0b42dfdb">
        <source>displayInvoiceLineTypes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2019	jlgndl1	Initial creation

*/

vars

	idx : Integer;
	anILD : CM_InvoiceLineDesc;
	bank : CM_Bank;
begin
	// 35872 use transaction map bank, or default terminal bank
	// allocation is passed into CMUI_InvoiceCargoAllocMapping but not to CMUI_InvoiceFutureStorageMaps
	if self.myAllocation &lt;&gt; null then
		bank := self.myAllocation.CM_InvoiceAllocation.myServiceBroker.CM_SnapShotServiceBroker.myTransactionMap.myBank;
	else
		bank := self.myTerminal.getDefaultCompanyBank();
	endif;
	self.tblData.rows := 0;
	self.tblData.selectMode := Table.SelectMode_Multiple;
	self.tblData.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblData.selectionType := 1;
	self.tblData.fixedColumns := 0;
	self.tblData.columns := 1;
	
	foreach anILD in bank.invoiceLineDescriptors 
		where not anILD.isNotAvailableForEntry 
		and anILD.isCargoCalcType do // ### TFS 51219 28MAY2021 NAVAB1
		
		idx := self.tblData.addItemObject(anILD, anILD.narration);
	endforeach;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayQuantityMap" id="50dada7a-7f50-4d80-b904-c31077196e14">
        <source>displayQuantityMap();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2019	jlgndl1	Initial creation

*/

vars
	obj : Object;
	realQM : CM_QuantityMap;
	theReturn, mapType, row : Integer;
	gt : CM_TranMapInvoiceLineGroupType;
	map : CM_TranMapInvoiceLineMapping;
	toprow : Integer;
	mapping : CM_TranMapInvoiceLineMapping;
	ild : CM_InvoiceLineDesc;
begin

	if self.myAllocation = null then
		return;
	endif;
	realQM := self.myAllocation.CM_InvoiceAllocation.myQuantityMap;
	
	if realQM &lt;&gt; null then
		self.cmbQuantityType.listObject := realQM.myCalculationType;
		self.chkChargeZero.value := realQM.chargeZero;
		self.optSingle.value := (realQM.mappingType = CM_QuantityMap.MapType_Single);
	endif;
	
	self.cmbQuantityType.listIndex := self.cmbQuantityType.findObject(realQM.mySnapShotQuantityType);

	if not updateMode then
		self.txtFrom.text := "0";
		self.txtTo.text := CM_QuantityRangeMap.MAX_RANGE.Integer.String;
		self.chkMaximum.value := true;
	else
		self.chkMaximum.value := false;
	endif;
	toprow := 0; // TFS 7496
	if self.myCurrentQuantityRangeMap &lt;&gt; null then
		foreach row in 1 to self.tblData.rows do
			self.tblData.accessRow(row);
	
// TFS 40620			if self.myCurrentQuantityRangeMap.allInvoiceLineMaps.includes(self.tblData.accessedRow.itemObject.CM_InvoiceLineDesc) then
			
			ild := self.tblData.accessedRow.itemObject.CM_InvoiceLineDesc; // TFS 40620
			foreach mapping in self.myCurrentQuantityRangeMap.allTMInvoiceLineMappings do : innerloop // TFS 40620
				if ild = mapping.myTMInvoiceLineDesc then // TFS 40620
					self.tblData.selectRow(row,true);
					if toprow = 0 then // TFS 7496
						toprow := row; // TFS 7496
					endif;
					break innerloop;
				endif;
			endforeach;
		endforeach;
		if toprow &gt; 0 then // TFS 7496
			self.tblData.topRow := toprow; // TFS 7496
		endif; // TFS 7496
		self.txtFrom.text := self.myCurrentQuantityRangeMap.rangeStart.String;
		self.txtTo.text := self.myCurrentQuantityRangeMap.rangeEnd.String;
		
		// Set the grouping from the first, they are all the same
		foreach map in self.myCurrentQuantityRangeMap.allTMInvoiceLineMappings discreteLock do
			if map.myTMInvoiceLineGroupType.isTypeAll then
				self.optGroupAll.value := true;
			elseif map.myTMInvoiceLineGroupType.isTypeHigh then
				self.optGroupGreatest.value := true;
			elseif map.myTMInvoiceLineGroupType.isTypeLow then
				self.optGroupLeast.value := true;
			endif;
			
			break;
			
		endforeach;
	endif;
	
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboQuantityType" id="ae5a9df5-4c16-47ac-bedb-50149e18e16e">
        <source>doBuildComboQuantityType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2019	jlgndl1	Initial creation

*/

vars

	indx	: Integer;
	field : CM_XTABField;

begin
	
	self.cmbQuantityType.clear;
	self.cmbQuantityType.sorted := true; 

	foreach field in self.mySnapShotBroker.mySnapShotDefinition.allFields do
		indx := self.cmbQuantityType.addItemObject(field.heading, field);
	endforeach;	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doNew" id="2cff6fbc-e860-43b9-b67e-ff2d45d2a278">
        <updating/>
        <source>doNew() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2019	jlgndl1	Initial creation

*/

vars

begin

	self.updateMode := false;
	
	self.txtFrom.text := "";
	self.txtTo.text := "";
	self.chkMaximum.value := false;
	
	self.tblData.deselectAll();

	if self.myAllocation &lt;&gt; null then
		self.lblDescription.caption := self.myAllocation.CM_InvoiceAllocation.getDisplayDescriptionString &amp; " " &amp; app.getErrorString(InvCargoAllocMapNEW);
	endif;
	self.setForNew(); 
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="cd5909dc-d970-4301-8759-43ef581686ec">
        <updating/>
        <source>doSave(_close: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2019	jlgndl1	Initial creation	tFS 43153

*/

vars

	invoiceAlloc : CM_InvoiceAllocation;
	qm : CM_QuantityMap;
	proxyQM : CM_QuantityMap;
	qrm : CM_QuantityRangeMap;
	proxyQRM : CM_QuantityRangeMap;
	load : Boolean;
	mapType : Integer;
	bu : CM_Bank;
	gt : CM_TranMapInvoiceLineGroupType;
	theReturn : Integer;

begin

	bu := self.mySnapShotBroker.getBank();

	invoiceAlloc := self.myAllocation;
	if invoiceAlloc = null then
		app.msgBox( "No Allocation found!", app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	qm := invoiceAlloc.myQuantityMap;
	if qm = null then
		app.msgBox( "No Quantity Map found!", app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	qrm := self.myCurrentQuantityRangeMap;
	
	if optSingle.value then
		mapType := CM_QuantityMap.MapType_Single;
	else
		mapType := CM_QuantityMap.MapType_Escalate;
	endif;
	
	if self.optGroupAll.value then
		gt := bu.getInvLineGroupByType(TranMapInvLineGroupTypeAll);
	elseif self.optGroupGreatest.value then
		gt := bu.getInvLineGroupByType(TranMapInvLineGroupTypeHigh);
	elseif self.optGroupLeast.value then
		gt := bu.getInvLineGroupByType(TranMapInvLineGroupTypeLow);
	endif;
	
	app.cmsBeginLoad(load);
	proxyQM := qm.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);

	if self.updateMode then
		app.cmsBeginLoad(load);
		proxyQRM := qrm.pxyCreateUpdateProxy();
		app.cmsEndLoad(load);
	else
		create proxyQRM transient;
	endif;
	
	proxyQM.setProxy( self.mySnapShotBroker, self.chkChargeZero.value, mapType, null, null );
	proxyQM.setAllocationDetails( invoiceAlloc, self.cmbQuantityType.listObject.CM_XTABField );
	proxyQRM.setProxy( qm, txtFrom.text.Integer, txtTo.text.Integer, 0);
	proxyQRM.setProxyInvoiceLineTypes( self.tblData.allSelectedObjects, gt );
	
	while true do
		app.myTrxUA.trxUpdateInvoiceSSAllocMap( updateMode, proxyQM, proxyQRM, self.mySnapShotBroker ); 
		if app.myPassport.trxCompletedOK then
			global.beep;
			if _close then
				self.unloadForm();
			endif;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Allocation),  app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
epilog

	delete proxyQRM;
	delete proxyQM;

end;</source>
        <Parameter name="_close" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForNew" id="7dac6a9c-e628-4999-bf2e-6275cc46297a">
        <source>setForNew();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2019	jlgndl1	Initial creation

*/

vars
	qm : CM_QuantityMap;
	qrm : CM_QuantityRangeMap;
	
begin
	if self.updateMode then
		return;
	endif;
	
	self.chkChargeZero.value := false;
	self.optSingle.value := false;
	self.txtFrom.text := "0";
	self.txtTo.text := CM_QuantityRangeMap.MAX_RANGE.Integer.String;
	self.chkMaximum.value := true;
	self.optGroupAll.value := true;
	self.optSingle.value := true; 
		
	qm := self.myAllocation.CM_InvoiceAllocation.myQuantityMap;
	if qm &lt;&gt; null then
		qrm := qm.allQuantityRanges.last;
		
		if qrm &lt;&gt; null and qrm.rangeEnd &lt; CM_QuantityRangeMap.MAX_RANGE then
				self.txtFrom.text := (qrm.rangeEnd + 1).String;

		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="656657ab-f4f6-43e4-86fe-e54574479aa4">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2019	jlgndl1	Initial creation	TFS 43153

*/

vars

begin
	
	if self.myAllocation &lt;&gt; null then
		self.mySnapShotBroker := self.myAllocation.CM_InvoiceAllocation.myServiceBroker.CM_SnapShotServiceBroker;
	endif;

	inheritMethod();
	
	self.caption := app.getErrorString( Snapshot_allocation_mapping );
	
	if self.myAllocation &lt;&gt; null then
		self.lblDescription.caption := self.myAllocation.CM_InvoiceAllocation.getDisplayDescriptionString;
		if updateMode then
			self.lblDescription.caption := self.lblDescription.caption&amp; " " &amp; app.getErrorString(InvCargoAllocMapUPDATE);
		else
			self.lblDescription.caption := self.lblDescription.caption&amp; " " &amp; app.getErrorString(InvCargoAllocMapNEW);
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="fd183bfe-a53f-4293-a46f-ecf1cccf4113">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 February 2019 15:52:05.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023217, locale);
end;</source>
    </JadeMethod>
</GUIClass>
