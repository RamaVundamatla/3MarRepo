    <JadeMethod name="trxUpdateVBSAndPrenote" id="34621bb1-6944-45a8-9b46-be876110b745">
        <updating/>
        <source>trxUpdateVBSAndPrenote(_refCust : String; 
						_refInt : String; 
						_remark : String; 
						_idArray : StringArray; 
						_terminal : CM_Terminal; 
						_vbsSlotType : CM_VehicleBookingTimeSlotType;
						_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2023	navsp1	Initial creation TFS 57805 
25 July 2023    navsp1  ChangeRequest 59314: EUP - Manifest Road - VBS Slot Matching
*/

vars
	vbsTerminal 	: CM_VehicleBookingTerminal;
	vbsTS,
	pxyVBSTS		: CM_VehicleBookingTimeSlot;
	prenoteArray	: CM_TISet;
	idStr			: String;
	ti				: CM_TrackedItem;
		
begin	
	
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	vbsTerminal		:= _terminal.myVehicleBookingTerminal;	
	
	if _refCust &lt;&gt; null then
		vbsTS := vbsTerminal.allVBTimeslotsByExtRef.getAtKey(_refCust);
	elseif _refInt &lt;&gt; null then
		vbsTS := vbsTerminal.allVBTimeslotsById.getAtKey(_refInt);
	endif;
	if vbsTS &lt;&gt; null then				
		
		if _idArray.size &gt; 0 then
			create prenoteArray transient;
			foreach idStr in _idArray do
				ti := _terminal.lookupTrackedItem(idStr, null, TI_STATE_NOTIFIED, null, false);
				if ti &lt;&gt; null and not prenoteArray.includes(ti) then
					prenoteArray.add(ti);
				endif;
			endforeach;
		endif;
		
		beginTransaction;
		
		pxyVBSTS := vbsTS.pxyCreateUpdateProxy();		
		if _remark &lt;&gt; null then			
			pxyVBSTS.setRemarks(_remark);			
		endif;
		
		if _vbsSlotType &lt;&gt; null then						//25.Jul.2023 navsp1 TFS 59314			
			pxyVBSTS.setVBTimeSlotType(_vbsSlotType);
		else
			pxyVBSTS.setVBTimeSlotType(vbsTS.myVBTimeSlotType);
		endif;
		
		app.myUtilityUA.utlUpdateVehicleBookingAdv(pxyVBSTS, null, null, prenoteArray, _passport);

	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
	delete pxyVBSTS;
	delete prenoteArray;
end;</source>
        <Parameter name="_refCust" type="String"/>
        <Parameter name="_refInt" type="String"/>
        <Parameter name="_remark" type="String"/>
        <Parameter name="_idArray" type="StringArray"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_vbsSlotType" type="CM_VehicleBookingTimeSlotType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
