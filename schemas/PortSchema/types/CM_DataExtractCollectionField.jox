    <JadeMethod name="buildExtractTransientMethod" id="a8eb4124-fbd6-4941-90dc-9232c5fe29ef">
        <executionLocation>server</executionLocation>
        <source>buildExtractTransientMethod(_dict : CM_DataExtractTransMethodDict input) serverExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2011	#cnwdz2	 

*/

vars
	childField : CM_DataExtractField;
	transientMethod : JadeMethod;
	errorCode       : Integer;
	errorPosition   : Integer;
	errorLength	    : Integer;
	generatedMethod : CM_DataExtractTransientMethod;
	classNumber     : Integer;
begin
	foreach childField in self.allChildFields do 
		transientMethod := process.createTransientMethod(CM_DataExtractClass.ExtractFieldValueMethodName, CM_DataExtractField, currentSchema , childField.getPropertyMethodSource, false, null, errorCode, errorPosition, errorLength);
		if errorCode &lt;&gt; null then
			app.raiseCMException3(ERR_DataExtractTransCreateFail, errorCode.String, childFieldClass.name&amp;"::"&amp;childField.name, childField.getPropertyMethodSource,null, null);			
			return;			
		endif;
		
		create generatedMethod transient;
		classNumber := self.childFieldClass.number;
		generatedMethod.initProperties(classNumber, childField.name, transientMethod);
		if _dict.includesKey(classNumber, childField.name) then
			return;
		endif;
		_dict.add(generatedMethod);
	endforeach;

epilog

end;</source>
        <Parameter name="_dict" type="CM_DataExtractTransMethodDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createPersistentField" id="3e3ae517-46a3-40d3-9d20-6bf536273205">
        <source>createPersistentField(): CM_DataExtractField;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	#cnwdz2	 

*/

vars
	field : CM_DataExtractCollectionField;
begin
	create field persistent;
	field.setForCreate(self);
	
	return field;
epilog

end;</source>
        <ReturnType type="CM_DataExtractField"/>
    </JadeMethod>
    <JadeMethod name="createTransientFieldWithName" id="ac11e5be-987c-49bf-bf18-97355cef1cf8">
        <source>createTransientFieldWithName(_fieldName: String): CM_DataExtractField;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	#cnwdz2	 

*/

vars
