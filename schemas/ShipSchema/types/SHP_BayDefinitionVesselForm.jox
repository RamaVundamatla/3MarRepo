    <JadeMethod name="btnMACS3_click" id="ed92a163-10b9-497e-b006-6315bddb62ee">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnMACS3_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/04/2020	jlgdap1		Initial creation TFS 49003 MTN API Inline Agent
//
vars
	cmifMonitor		: CMIF_Monitor;
	result			: Integer;
	isOk			: Boolean;
begin
	// This shouldn't be possible... but you never know
	if self.myCurrentCellularVessel = null then
		return;
	endif;
	
	if app.myPassport.myCMIFMonitor = null then
		create cmifMonitor transient;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;
	
	cmifMonitor := app.myPassport.myCMIFMonitor;
	cmifMonitor.myParent := self;
	cmifMonitor.message := "This may take a few minutes...";
	self.modalDialogShow(null, null, null, null, "Querying MACS3 for Vessel information", null);	// TODO: Make this a translatable string
	
	self.pbProgressBar.visible := false;
	self.updateProgress(cmifMonitor);
	app.mousePointer := Window.MousePointer_HourGlass;
	
	app.myPassport.setWarningsIgnored(false);

	// make a call to MACS3
	self.myAssistant.doMACS3VPSProcessCall(CM_MACS3ConsumerAgent.MethodProdMetaData, self.myCurrentCellularVessel.myVessel);
	
	if self.myCurrentCellularVessel.definitionVersion &gt; 0 then
		self.lblModalMessage.caption := "IMO Found";
		cmifMonitor.updateProgress("Downloading/Populating data" &amp; CrLf &amp; "This may take a few minutes...", 0, 0);
		self.updateProgress(cmifMonitor);
		
		//self.myAssistant.doMACS3VPSProcessCall(CM_MACS3ConsumerAgent.MethodVesselProfiles, self.myCurrentCellularVessel.myVessel);
		isOk := self.myAssistant.doMACS3VPSProcessCall(CM_MACS3ConsumerAgent.MethodVesselVersions, self.myCurrentCellularVessel.myVessel);
	endif;
	
	if isOk then
		self.fldVessel.topSheet := self.shtVesselDetails;	// go back to the Vessel Details tab
		self.fldVessel.setFocus();
	endif;

epilog
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	app.mousePointer := Window.MousePointer_Default;

	delete cmifMonitor;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
