<CollClass name="CM_TIByCargoTypeIdDict" id="a9d12c08-71c6-408d-bd0d-44464a27897e">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CM_TrackedItem"/>
    <superclass name="CM_TIDictByCargoTypeId"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="tiDicts"/>
    <MemberKey>
        <property name="CM_TrackedItem::cargoType"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_TrackedItem::id"/>
    </MemberKey>
    <JadeMethod name="getNextItem" id="293f0a7e-dbfb-48da-b6e2-265ef8a335f5">
        <source>getNextItem(_tiSet : Collection input; _cargoType : Integer; _id : String) : CM_TrackedItem;

// Created by cnwdvb1 on 18 April 2007
// 14/07/2025	naviv1	35226	MTN - Usage of Iterator.getCurrentKeys  
vars

	ti 			: CM_TrackedItem;
	iter		: Iterator;
	tmpCargoType: Integer;
	tmpId		: String;

begin

	ti := self[_cargoType, _id];
	
	if ti = null then
		return null;
	endif;
	
	if not _tiSet.includes(ti) then
		return ti;
	endif;
	
	iter := self.createIterator();
	
	iter.startAtObject(ti);
	
	while iter.next(ti) do
		iter.getCurrentKeys(tmpCargoType,tmpId); //MTN-35226
		if tmpCargoType &lt;&gt; _cargoType or tmpId &lt;&gt; _id then
			return null;
		endif;
		
		if not _tiSet.includes(ti) then
			return ti;
		endif;
	endwhile;
	return null;
epilog
	delete iter;
end;</source>
        <Parameter name="_tiSet" type="Collection" usage="input"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
</CollClass>
