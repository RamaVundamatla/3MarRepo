    <JadeMethod name="getPolishCustomsConsigneeXML" id="f5ad3146-6760-4944-a9c8-1ad48dd17d73">
        <source>getPolishCustomsConsigneeXML(_carNum, _bolWeight : Decimal): String;
//
// cnwrs1 dec 2007 may be of use
//
vars
	str, str2 : String;
	ediWWLFileType : CM_EDIFileTypeWWLCar;
	info : StringArray;
begin
	ediWWLFileType := CM_EDIFileTypeWWLCar.firstInstance;
	if ediWWLFileType = null or // this should not happen
	   self.rawEDIData = null then
		return null;
	endif;
	create info transient;
	ediWWLFileType.getRecordInfo(self.rawEDIData, info);
	str2 := info[16].trimBlanks;
	str2.removeCommas();
	str2.cnReplaceChar('&amp;', null);
	str2.cnReplaceChar('&lt;', null);
	str2.cnReplaceChar('&gt;', null);
	str2.cnReplaceChar('?', null);
	str := '&lt;DeklaracjaSkrocona NrWlasny="'&amp;self.id&amp;'" LiczbaOpakowan="'&amp;_carNum.String&amp;'" MasaBrutto="'&amp;_bolWeight.asStringWeightJMT()&amp;'" OpisTowaru="AUTO"&gt;'&amp;CrLf;
	str := str &amp; '&lt;UC UCDeklaracji="PL322080"&gt;';
	str := str &amp; '&lt;Lokalizacja Opis="DCT"/&gt;';
	str := str &amp; '&lt;/UC&gt;'&amp;CrLf;
	str := str &amp; '&lt;Przedstawiajacy Nazwa="'&amp;str2&amp;'"'; //consignee name
	str := str &amp; ' UlicaNumer="'&amp;info[17]&amp;'" KodPocztowy="'&amp;info[18]&amp;'" Miejscowosc="'&amp;info[19]&amp;'" Kraj="'&amp;info[15]&amp;'"'; //consignor address
	str := str &amp; ' TIN="'&amp;self.bol&amp;'" /&gt;'&amp;CrLf; //consignee number but use the bol number 
	str := str &amp; '&lt;Transport PozId="1" Rodzaj="5" Znaki="" Kraj=""/&gt;';
	return str;
epilog
	delete info;
end;
</source>
        <Parameter name="_carNum" type="Decimal"/>
        <Parameter name="_bolWeight" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPolishCustomsConsignorXML" id="ebdbee0b-ed87-40c9-a321-a83ead652335">
        <source>getPolishCustomsConsignorXML(_carNum: Integer; _bolWeight : Decimal): String;
//
// Dec 2007 cnwrs1
//
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	str : String; 
	//str2 : String;
	ediWWLFileType : CM_EDIFileTypeWWLCar;
	info : StringArray;
begin
	ediWWLFileType := CM_EDIFileTypeWWLCar.firstInstance;
	if ediWWLFileType = null then // this should not happen
//	   self.rawEDIData = null then
		return null;
	endif;
//	create info transient;
//	ediWWLFileType.getRecordInfo(self.rawEDIData, info);
//	str2 := info[13];
//	str2.removeCommas();
//	str2.cnReplaceChar('&amp;', null);
//	str2.cnReplaceChar('&lt;', null);
//	str2.cnReplaceChar('&gt;', null);
//	str2.cnReplaceChar('?', null);
	str := '&lt;DeklaracjaSkrocona NrWlasny="'&amp;self.bol&amp;'" LiczbaOpakowan="'&amp;_carNum.String&amp;'" MasaBrutto="'&amp;_bolWeight.asStringWeightJMT()&amp;'" OpisTowaru="AUTO"&gt;'&amp;CrLf;
	str := str &amp; '&lt;UC UCDeklaracji="PL322080"&gt;';
	str := str &amp; '&lt;Lokalizacja Opis="DCT"/&gt;';
	str := str &amp; '&lt;/UC&gt;'&amp;CrLf;
	str := str &amp; '&lt;Przedstawiajacy Nazwa="DCT"'; //consignor name
	str := str &amp; ' UlicaNumer="Sucharskiego7" KodPocztowy="80-601" Miejscowosc="Gdansk" Kraj="PL"'; //consignor address
	str := str &amp; ' TIN="PL5851409625" /&gt;'&amp;CrLf;  
	str := str &amp; '&lt;Transport PozId="1" Rodzaj="1" Znaki="'&amp;self.myEDIData.CM_EDIDataBayPlan.vesselName&amp;'" Kraj=""/&gt;';
	return str;
epilog
	delete info;
end;
</source>
        <Parameter name="_carNum" type="Integer"/>
        <Parameter name="_bolWeight" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
