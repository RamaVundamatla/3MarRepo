    <JadeMethod name="showAttachments" id="45626094-d5f9-4801-989a-686ceaaa8435">
        <source>showAttachments(pAllAttachments : CMIF_InOutAttachmentArray; pTable : CM_EntryTable input; pAddAttachRow : Integer);
// ---------------------------------------------------------------------------
// Created:     15 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx,
	tmpRow			: Integer;
	intFaceAttach	: CMIF_InOutAttachment;
	
begin

	// clear any existing attachment(s)
	pTable.rows := pAddAttachRow;

	idx := 0;
	foreach intFaceAttach in pAllAttachments do
		idx := idx + 1;
		tmpRow := pTable.addAttribute('ATTACH' &amp; idx.String, 'Attachment (' &amp; idx.String &amp; ')', Table.InputType_None, 0, true);
		pTable.setValue(tmpRow, intFaceAttach.id);
	endforeach;

end;</source>
        <Parameter name="pAllAttachments" type="CMIF_InOutAttachmentArray"/>
        <Parameter name="pTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAddAttachRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showAuditsOnThumbnail" id="47bd56cf-ccdd-437d-912a-b69454f6e6fc">
        <source>showAuditsOnThumbnail(pDict : CM_AuditObjectDictByTimestamp; pTable : Table);
// ---------------------------------------------------------------------------
// Created:     10 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	audit	: CM_AuditObject;
	
begin

	pTable.addItem('');
	pTable.addItem('Audit Details');
	
	foreach audit in pDict do
		pTable.addItem(audit.typeCode &amp; Tab &amp; audit.userCode &amp; ' ' &amp; audit.timestamp.date.shortFormatJMT() &amp; ' '&amp;audit.timestamp.time.shortFormatJMT());
	endforeach;
	
	pTable.addItem('');
	
end;</source>
        <Parameter name="pDict" type="CM_AuditObjectDictByTimestamp"/>
        <Parameter name="pTable" type="Table"/>
    </JadeMethod>
    <JadeMethod name="showAutoPlanLog" id="95946f7e-bf72-4a98-894d-ee6c1ad1e3a9">
        <source>showAutoPlanLog( 	_yardAllocationAgent : CM_YAAutoplanAgent;
					_sysAlert : CM_SystemAlert;
					_result : CM_TestAutoPlanResult;
					_information : CM_Information
					);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 March 2012	cnwndl1	Initial creation

*/

vars

	apLogForm : CMUI_TestAutoPlanLogForm;
	localLoggingArray : StringArray512;
	strs : CM_Strings;
	str : String;
	rawStr : String;
	array : HugeStringArray;
	strArray : StringArray512;

begin

	if _yardAllocationAgent &lt;&gt; null then	
		localLoggingArray := _yardAllocationAgent.getLoggingArray(true);
		if localLoggingArray = null then
			return;
		endif;
		create apLogForm;
		if _yardAllocationAgent.myCurrentCMIFYAAutoPlan &lt;&gt; null then
			apLogForm.myTrackedItem := _yardAllocationAgent.myCurrentCMIFYAAutoPlan.getMyTrackedItem;
		endif;
		localLoggingArray.copy(apLogForm.myLog);
		apLogForm.show();
		
	elseif _sysAlert &lt;&gt; null then	
		strs := _sysAlert.logDetails;
		create array transient;
		strs.getStrings(array);
		if array.isEmpty then
			return;
		endif;
		create apLogForm;
		if _sysAlert.myTrackedItem &lt;&gt; null then
			apLogForm.myTrackedItem := _sysAlert.myTrackedItem;
		else
			apLogForm.myLinkedObject := _sysAlert.getLinkedTo;
			apLogForm.details := _sysAlert.details[1:60];
		endif;
		foreach rawStr in array do
			apLogForm.myLog.add(rawStr[18:end].trimBlanks); // first 17 chars are date and time...
		endforeach;
		apLogForm.show();
		
	elseif _information &lt;&gt; null then	
		create strArray transient;
		_information.getInformationLines(strArray);
		if strArray.isEmpty then
			return;
		endif;
		create apLogForm;
		apLogForm.myTrackedItem := _information.myTrackedItem;
		strArray.copy(apLogForm.myLog);
		apLogForm.show();
	
	elseif _result &lt;&gt; null then	
		create apLogForm;
		apLogForm.myResult := _result;
		apLogForm.show();
	
	endif;

epilog

	delete array;
	delete strArray;

end;</source>
        <Parameter name="_yardAllocationAgent" type="CM_YAAutoplanAgent"/>
        <Parameter name="_sysAlert" type="CM_SystemAlert"/>
        <Parameter name="_result" type="CM_TestAutoPlanResult"/>
        <Parameter name="_information" type="CM_Information"/>
    </JadeMethod>
    <JadeMethod name="showAutoVolumeCalcForm" id="0189224a-101f-4d39-a72f-cfd3fe00b28e">
        <source>showAutoVolumeCalcForm(_tiArray : CM_TIArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2017	cnwma1	TFS #5695:STWO - Re-Calculate Volumes on Forms and EDI

*/

vars

	form : CMUI_AutoCalculateForm;
	msg : String;

begin

	if _tiArray.isEmpty then
		msg := app.getErrorString(No_Cargo_selected);
	endif;
	if msg &lt;&gt; null then
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	endif;

	form := app.loadForm(CMUI_AutoCalculateForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_AutoCalculateForm;
	if form = null then
		return;
	endif;	
	
	if form.setMyTrackedItem(_tiArray) then
		form.showModal();
	endif;

epilog

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showAutoVoyageConfig" id="52ddd4c0-da19-4f3e-a7ec-a03d830b47a3">
        <updating/>
        <source>showAutoVoyageConfig(_masterMenuAction : CMUI_MenuAction) updating;
// ### TFS BUG 65730 22AUG2024 NAVAB1 move this button to terminal config
vars
	theForm		: Form;
	theClass 	: Class;
	assistClass : Class;
	jrw 		: Schema;
	menuAction	: CMUI_MenuAction;
begin
	jrw 		:= rootSchema.getSchema("ShipSchema");
	theClass 	:= jrw.getClass("SHP_AutoVoyageConfig");
	assistClass := jrw.getClass("SHP_Assistant");
	
	theForm := app.loadForm(theClass, assistClass, false, false, true, self.myTerminal, _masterMenuAction);
	if theForm = null then
		return;
	endif;
	
	if _masterMenuAction &lt;&gt; null then
		menuAction := _masterMenuAction;
		menuAction.setPropertyValue("myFormWhenMaster", theForm);
	endif;
	
	theForm.show;
epilog

end;
</source>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showBOLReleaseEntryForm" id="f80b94cb-7118-483e-af21-08c6227dbbac">
        <source>showBOLReleaseEntryForm(_obj : CM_Object; _menuAction : CMUI_MenuAction);
//--------------------------------------------------
// Created:	28 October 2003 By: cnwgd1
//--------------------------------------------------
vars
	tmpForm	: CMUI_ReleaseEntryForm;
begin
	//th2 PAR 13700 - now non-modal, and allow only one copy of the window at a time
	tmpForm := app.getForm(CMUI_ReleaseEntryForm.name).CMUI_ReleaseEntryForm;
	if tmpForm &lt;&gt; null then
		if tmpForm.windowState = Form.WindowState_Minimized then
			tmpForm.windowState := Form.WindowState_Normal;
		endif;
		tmpForm.zOrder(1);
		return;
	endif;
	
	tmpForm := app.loadForm(CMUI_ReleaseEntryForm, CMUI_Assistant, false, false, false, self.myTerminal, _menuAction).CMUI_ReleaseEntryForm;
	
	if tmpForm = null then
		return;
	endif;
	
	tmpForm.myInitObject := _obj;
	tmpForm.show();
	
end;







</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showBayDefinitionForm" id="38f3a680-5759-4f57-9c1c-88f680f80de6">
        <source>showBayDefinitionForm(_cellularVoyage: CM_Voyage; _masterMenuAction: CMUI_MenuAction; _doMode: Boolean);
//--------------------------------------------------
// Created:	29 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	formCls,
	assistCls	: Class;
	bayDefFrm : CM_BaseForm;
	menuAction : CMUI_MenuAction;
	subSys : CMUI_SubSystem;
	term : CM_Terminal;
begin

	subSys := app.myController.allSubSystems['ShipSchema'];
	
	if subSys &lt;&gt; null then
		subSys.getFormDetails('SHP_BayDefinitionVoyageForm', formCls, assistCls);
	endif;

	if formCls = null then
		return;
	endif;
	
	if _cellularVoyage &lt;&gt; null then
		term := _cellularVoyage.myTerminal;
	else
		term := app.getMyTerminalDO_NOT_USE();
	endif;

	bayDefFrm := app.loadForm(formCls, assistCls, false, false, false, term, _masterMenuAction).CM_BaseForm;

	if bayDefFrm = null then
		return;
	endif;	
	
	if _cellularVoyage &lt;&gt; null then
		bayDefFrm.showWithObjectMode(_cellularVoyage, false);
	else
		bayDefFrm.show();
	endif;

end;</source>
        <Parameter name="_cellularVoyage" type="CM_Voyage"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_doMode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showBerthUsageForm" id="0b06d0cc-c33d-4b7e-99b4-f6b861da4f2b">
        <source>showBerthUsageForm(_berth : HMS_Berth; _masterMenuAction : CMUI_MenuAction; _terminal : CM_Terminal);
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
vars
