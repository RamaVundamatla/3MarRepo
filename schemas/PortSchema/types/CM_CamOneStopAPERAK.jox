    <JadeMethod name="includeTransaction" id="e2c7821e-4970-4f4f-acff-3e31859acb2c">
        <source>includeTransaction(_transaction: CM_Transaction; _camsTS: TimeStamp; _startTS: TimeStamp; _endTS: TimeStamp; _camProtocol: CM_CamProtocol; _camGroup: CM_CamGroup; _camAgent: CM_CamControllerAgent; _logExcluded: Boolean; _event : CM_EventTransaction): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/09/2016	cnwndl1	Initial creation
12/03/2020	jlgdap1	TFS 48785 SNO COARRI Issue - new parameter for CM_CamProtocolDesc includeTransaction
*/

vars

begin

	_camAgent.logReasonForExclusion (_transaction, 'Transaction not valid. Only "EDI File Received" events are valid for ' &amp; self.name );
	return false;
	
epilog

end;</source>
