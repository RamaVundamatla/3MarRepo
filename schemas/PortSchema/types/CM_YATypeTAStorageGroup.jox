    <JadeMethod name="isCMIFDataMatch" id="664d9c0d-a5bf-4fe4-8dd7-366e24d648d6">
        <source>isCMIFDataMatch(_cmifAutoPlan : CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2023	navmv20 TFS 56216 Task 56217: Jade - New YA Criteria

*/
vars

begin

	return _cmifAutoPlan.isTAStorageGroup_Match(_yaData);
	
end;</source>
