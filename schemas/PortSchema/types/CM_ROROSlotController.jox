    <JadeMethod name="isOOTL" id="a8d2284c-2d0f-4f19-9ca3-cb0ae1f4062c">
        <source>isOOTL() : Boolean;
// ---------------------------------------------------------------------------
// Created:     15 July 2013 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	slotDefn : CM_ROROSlotDefn;
	locnDefn : CM_ROROLocnDefn;
begin
	
	slotDefn := self.mySlotDefn;
	if slotDefn = null then
		return false;
	endif;
	
	locnDefn := slotDefn.myROROLocnDen;
	
	if locnDefn = null then
		return false;
	endif;
	
	// OOTL location will not be visible because the request is complete
	return locnDefn.isOOTL();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
