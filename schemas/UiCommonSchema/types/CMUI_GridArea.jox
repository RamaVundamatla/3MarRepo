    <JadeMethod name="getObjectLabel" id="7d7dd425-ea09-4d0c-95ea-9c5950c055ae">
        <source>getObjectLabel(_theX1, _theX2, _theY1, _theYOffset : Integer) : CM_Object;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTA : CM_TerminalArea;
	anObject : CM_Object;
	removeObj, idx : CM_Object;
	theX, theY : Integer;
	iter01 : Iterator;
begin
	iter01 := self.allPointLabels.createIterator;
	
	while iter01.next(anObject) do
		if global.isValidObject(anObject) then
			theX := iter01.getCurrentKey(1).Integer;
			theY := iter01.getCurrentKey(2).Integer;
			if _theY1 &gt;= theY and _theY1 &lt;= theY + _theYOffset then
				if _theX1 = null and _theX2 = null then
					return anObject;
				elseif theX &gt;= _theX1 and theX &lt;= _theX2 then
				endif;			
			endif;
		endif;
	endwhile;
	return null;
epilog
	delete iter01;
end;</source>
        <Parameter name="_theX1" type="Integer"/>
        <Parameter name="_theX2" type="Integer"/>
        <Parameter name="_theY1" type="Integer"/>
        <Parameter name="_theYOffset" type="Integer"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
