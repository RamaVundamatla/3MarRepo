    <JadeMethod name="durationDisplay" id="ebf0627e-16f7-41d5-ac03-f54a4b45a326">
        <source>durationDisplay(tsInt : TimeStampInterval): String;

/*
Date			Who		Reason
12 July 2016	cnwar2	Initial creation

*/
vars
	totalMinutes, i : Integer;
	d, h, m	 		: String;
	
begin
	totalMinutes := (tsInt.getMilliseconds()/1000) div 60;
	
	i := (totalMinutes div (24*60));
	if i = 0 then
		d := "";
	else
		d := i.String &amp; "d ";
	endif;
	totalMinutes := totalMinutes mod (24*60);
	i := (totalMinutes div (60));
	if i = 0 then
		h := "";
	else
		h := i.String &amp; "h ";
	endif;
	totalMinutes := totalMinutes mod 60;
	m := totalMinutes.String;
		
	return d &amp; h &amp; m &amp; "m";
end;</source>
        <Parameter name="tsInt" type="TimeStampInterval"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDurationInMinutes" id="bca809e1-1bce-4b87-8a93-f205d4c147d4">
        <source>getDurationInMinutes(_endTS : TimeStamp) : Integer;

/*
Date			Who		Reason
12 July 2016	cnwar2	Initial creation

*/
vars
	endTime, 
	startTime, ts1, ts2	: TimeStamp;
	duration 			: TimeStampInterval;
	totalMinutes		: Integer;
	timezone			: DEV_SupportTimezone;
	
begin	
	timezone 	 := myContact.myTimezone;	

	if self.endTS.isValid then
		endTime := endTS;
	else
		endTime := app.actualTimeServer();
	endif;
	if _endTS &lt; endTime then
		endTime := _endTS;
	endif;
	
	if timezone.getNextStartOfBusinessHours(startTS) &lt; timezone.getNextEndOfBusinessHours(startTS) then
		// currently out of hours - use beginning of next working hours as startTime
		startTime := timezone.getNextStartOfBusinessHours(startTS);
		if startTime &gt; endTime then
			return 0;
		endif;
	else
		startTime := startTS;
	endif;
	
	
	ts1 := startTime;
	while ts1 &lt; endTime do
		ts2 := timezone.getNextEndOfBusinessHours(ts1);
		if ts2 &gt;= endTime then
			duration := duration + (endTime - ts1);
			break;
		else
			duration := duration + (ts2 - ts1);
			ts1		 := timezone.getNextStartOfBusinessHours(ts2);
		endif;
	endwhile;
		
	return (duration.getMilliseconds()/1000) div 60;
end;</source>
        <Parameter name="_endTS" type="TimeStamp"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDurationStr" id="2eaaacc3-ee8a-4959-96bf-958396ab1fcc">
        <updating/>
        <source>getDurationStr(_logging : String io): String updating;

/*
Date			Who		Reason
11 July 2016	cnwar2	Initial creation

*/
vars
	endTime, 
	startTime, ts1, ts2	: TimeStamp;
	duration 			: TimeStampInterval;
	totalMinutes		: Integer;
	timezone			: DEV_SupportTimezone;
	
begin
	_logging := "-------------------------" &amp; CrLf;
	
	timezone 	 := myContact.myTimezone;
	_logging := _logging &amp; "State: " &amp; self.type &amp; CrLf;
	
	if self.endTS.isValid then
		endTime := endTS;
	else
		endTime := app.actualTimeServer();
	endif;
	
	// 1. if startTS is out of hours, use next business hours start - if this after endTS or currentTS, return 0
	// if startTS within business hours, get next business hours end - if this after endTS or currentTS, return duration as normal
	// worst case scenario: get time between startTS and close of business hours, then if business hour start before endTS
	// get time between business hour start and next business hour end
		
	if timezone.getNextStartOfBusinessHours(startTS) &lt; timezone.getNextEndOfBusinessHours(startTS) then
		// currently out of hours - use beginning of next working hours as startTime
		startTime := timezone.getNextStartOfBusinessHours(startTS);
		if startTime &gt; endTime then
			return "0m";
		endif;
		_logging  := _logging &amp; "State start time (out of hours): " &amp; self.startTS.String &amp; CrLf;
		_logging  := _logging &amp; "Local business hours start: " &amp; startTime.String &amp; CrLf;
	else
		startTime := startTS;
		_logging  := _logging &amp; "State start time: " &amp; self.startTS.String &amp; CrLf;
	endif;
	
	ts1 := startTime;
	while ts1 &lt; endTime do
		ts2 := timezone.getNextEndOfBusinessHours(ts1);
		if ts2 &gt;= endTime then
			duration := duration + (endTime - ts1);
			_logging  := _logging &amp; "State end time: " &amp; endTime.String &amp; CrLf;
			_logging  := _logging &amp; "Duration: " &amp; self.durationDisplay(endTime - ts1) &amp; CrLf;			
			_logging  := _logging &amp; "Total state duration: " &amp; self.durationDisplay(duration) &amp; CrLf;
			break;
		else
			_logging  := _logging &amp; "Local business hours end: " &amp; ts2.String &amp; CrLf;
			_logging  := _logging &amp; "Duration: " &amp; self.durationDisplay(ts2 - ts1) &amp; CrLf;
			duration := duration + (ts2 - ts1);
			ts1		 := timezone.getNextStartOfBusinessHours(ts2);
			if ts1 &lt; endTime then
				_logging  := _logging &amp; "Local business hours start: " &amp; ts1.String &amp; CrLf;
			else
				_logging  := _logging &amp; "State end time: " &amp; endTime.String &amp; CrLf;
				_logging  := _logging &amp; "Total state duration: " &amp; self.durationDisplay(duration) &amp; CrLf;
			endif;
		endif;
	endwhile;
		
	return self.durationDisplay(duration);
end;</source>
        <Parameter name="_logging" type="String" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
