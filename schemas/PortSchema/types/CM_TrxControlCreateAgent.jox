    <JadeMethod name="trxCreateCashReceipts" id="a50ebaad-2619-48fe-ada0-dd1f57ee16c8">
        <updating/>
        <source>trxCreateCashReceipts(	_allPxyCashReceipts 	: ObjectArray input;
						_allNewCashReceipts 	: ObjectArray input;
						_allPxyCashPays 		: ObjectArray input;
						_allRealCashPays		: ObjectArray input;
						_allExtraChargeInvLines : ObjectArray;
						_passport 				: CM_Passport input
						) updating;
/*

Purpose:			Create a series of cash receipts plus associated cash payments for duty doc payment.
					The receipts are all for the same duty doc where the payment can be split over multiple
					payments methods.  Each proxy receipt has the partial value and payment method.
					The first receipt is considered the 'master' and has links to the others via get/setDDOtherReceipts.

Parameters:			

Return Value:		

Date		Who		Reason
28 Feb 2013	cnwndl1	Initial creation	Par 30901
21 Oct 2019 cnwma1 Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
*/

vars

	pxyObj,
	obj					: Object;
	pxyCashReceipt,
	firstPxyCashReceipt,
	firstCashReceipt,
	newCashReceipt      : CM_CashReceipt;
	pxyCashPay,
	newCashPayment 		: CM_CashPayment;
	drTerm 				: CM_DebtorTerminal;
	debtor 				: CM_Debtor;
	invoiceLine 		: CM_InvoiceLine;
	bank 				: CM_Bank;
	newInvoiceType 		: CM_InvoiceDesc;
	newInvoice			: CM_Invoice;
	invCashCharge		: Decimal[23,6];	//21.10.2019 cnwma1 TFS #47081
	paymentType			: Integer;			//10 Oct 2018	NDL	TFS 41281
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	
	// Start the transaction
	beginTransaction;

	// Perform the operation
	if _allPxyCashReceipts &lt;&gt; null and not _allPxyCashReceipts.isEmpty then
		foreach pxyObj in _allPxyCashReceipts do
			if not _passport.noErrors then
				return;
			endif;
			pxyCashReceipt := pxyObj.CM_CashReceipt;
			if pxyCashReceipt &lt;&gt; null and pxyCashReceipt.cashValue &gt; 0 then
				app.myUtilityCA.utlCreateCashReceipt(pxyCashReceipt, newCashReceipt,"", _passport); // PAR 36165
			endif;
			
			if newCashReceipt &lt;&gt; null then
				_allNewCashReceipts.add(newCashReceipt);
				if firstCashReceipt = null then
					firstCashReceipt := newCashReceipt;
				endif;
			endif;
		endforeach;
		//03 Feb 2014 NDL	Par 33181
		foreach obj in _allNewCashReceipts do
			newCashReceipt := obj.CM_CashReceipt;
			newCashReceipt.setDDOtherReceipts( _allNewCashReceipts );
		endforeach;
	endif;
	
	if not _allExtraChargeInvLines.isEmpty then
		//we need to take these real invoiceLines and move them to a new invoice
		firstPxyCashReceipt := _allPxyCashReceipts.first.CM_CashReceipt;
		drTerm 				:= firstPxyCashReceipt.myDebtorTerminal;
		debtor 				:= drTerm.myDebtor;
		invCashCharge 		:= 0;
		
		
		foreach obj in _allExtraChargeInvLines do
			invoiceLine := obj.CM_InvoiceLine;
			//10 Oct 2018	NDL	TFS 41281
			paymentType := 0;
			if invoiceLine.invoiceLineDesc &lt;&gt; null then
				paymentType := invoiceLine.invoiceLineDesc.getPaymentType( debtor );
			endif;
			if newInvoice = null then
				bank := invoiceLine.bank;
				//newInvoiceType := drTerm.myTerminal.getConfig(CashInvoiceType).CM_InvoiceDesc;
				newInvoiceType := drTerm.myTerminal.getCashInvoiceType( bank );	//08 Jan 2019	NDL	TFS 40010 
				if newInvoiceType = null then
					app.raiseCMException1( Need_cash_config_first, "Cash Invoice Type", null, null); 
					return;
				endif;
				create newInvoice;
				newInvoice.initialise(bank, newInvoiceType, debtor, null, false, paymentType);
			endif;
			invoiceLine.moveLineToInvoice(newInvoice);
			invCashCharge := invCashCharge + invoiceLine.lineTotal;
		endforeach;
		
		create pxyCashPay transient; // will be deleted by the caller.......
		pxyCashPay.setProxy(	invCashCharge,			//_cashValue : Decimal;
								0,						//_taxAmount : Decimal;
								app.actualTimeServer,	//_dateTime : TimeStamp;
								null,					//_proformaDesc : String;
								false,					//_manual : Boolean;
								0,						//_status : Integer;
								false,					//_voided : Boolean;	
								drTerm,					//_myDebtorTerminal : CM_DebtorTerminal;
								null,					//_myTrackedItem : CM_TrackedItem;
								newInvoice,				//_myInvoice : CM_Invoice;
								null,					//_vvr : CM_VehicleVisitRecord;
								app.getMyUser			//_myUser : CM_User;
								);
		_allPxyCashPays.add( pxyCashPay );
		
	endif;
	
	if _allPxyCashPays &lt;&gt; null and not _allPxyCashPays.isEmpty then
		foreach pxyObj in _allPxyCashPays do
			if not _passport.noErrors then
				return;
			endif;
			pxyCashPay := pxyObj.CM_CashPayment;
			// 33885 set payment link to first receipt
			if firstCashReceipt &lt;&gt; null then
				pxyCashPay.setCashReceipt(firstCashReceipt);		// populates receipt.allCashPayments
			endif;
			newCashPayment:=pxyCashPay.pxyGetRealObject.CM_CashPayment;
			if newCashPayment = null then
				newCashPayment := app.myUtilityCA.utlCreateCashPayment(pxyCashPay, _passport);
			else
				app.myUtilityUA.utlUpdateCashPayment(pxyCashPay,_passport);
			endif;
			
			if newCashPayment &lt;&gt; null then
				_allRealCashPays.add(newCashPayment);
			endif;
		endforeach;
	endif;
	
epilog
	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_allPxyCashReceipts" type="ObjectArray" usage="input"/>
        <Parameter name="_allNewCashReceipts" type="ObjectArray" usage="input"/>
        <Parameter name="_allPxyCashPays" type="ObjectArray" usage="input"/>
        <Parameter name="_allRealCashPays" type="ObjectArray" usage="input"/>
        <Parameter name="_allExtraChargeInvLines" type="ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
