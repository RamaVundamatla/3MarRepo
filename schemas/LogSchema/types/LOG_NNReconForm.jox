    <JadeMethod name="doSearch" id="fac51ba8-2b01-4d71-aaa7-16db15e705f4">
        <updating/>
        <source>doSearch() updating;
// ---------------------------------------------------------------------------
// Created:     04 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	voy				: CM_Voyage;
	operator		: CM_Operator;
	lot				: CM_LogLot;
	sohLocationSet 	: CM_SOHLocationSet;
	sohLoc			: CM_SOHLocation;
	loadStateSet : Boolean;
begin
	
	voy := self.myFiltLogVoyage;
	if voy = null then
		return;
	endif;
	create sohLocationSet transient;
	operator := self.myFiltOperator;
	lot := self.myFiltLogLot;
	app.cmsBeginLoad(loadStateSet);
	voy.myLogVoyageStructure.getAllAssignedSOHLocations(sohLocationSet, lot, operator);
	app.cmsEndLoad(loadStateSet);

	self.tblLocations.rows := self.tblLocations.fixedRows;
	
	foreach sohLoc in sohLocationSet do
		if sohLoc.numTIs &gt; 0 then
			self.addTblLocationsRow(sohLoc, Row_Unchecked);
		endif;
	endforeach;
	
	tblLocations.colourRows(self.colorRow1, self.colorRow2);
	self.loadNNReconDetails();
	self.btnSelectAllT.caption := app.getErrorString(SelectAll);
	self.doUpdateOptionClick();	
	
epilog
	delete sohLocationSet;
	app.cmsEndLoad(loadStateSet);
end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdate" id="26a75bef-367e-4fd7-8caf-1cb899bd953d">
        <updating/>
        <source>doUpdate() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     02 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	nnLog				: CMIF_LogNNReconDtl;
	nnUpdateMode		: Integer;
	passport			: CM_Passport;
	result				: Integer;

begin
		// Sep 2011 28082 don't allow save for closed etc voyages
	if self.myFiltLogVoyage &lt;&gt; null and
	   self.myFiltLogVoyage.isClosedStatus() then
		app.msgBox("This voyage status is " &amp; self.myFiltLogVoyage.statusDescription &amp; "," &amp; CrLf &amp; "no updates are allowed.", "Error", 0);
		return false;
	endif;

	nnLog := self.myCurrentCMIFNNReconDtl;
	if nnLog = null then
		app.msgBox('Please select a location to reconcile first','Please select a row', 0);
		return false;
	endif;	
	
	if self.updateMode = null then
		app.msgBox('You must select an update option', 'Please select an option first', 0);
		return false;
	endif;
	app.mousePointer := MousePointer_HourGlass;	
	self.populateIntFaceNNLog(nnLog);

	// we organising while loop to mantain possible blue warnings for a user. #26532 10/12/2010
	passport := app.myPassport;
	
	while true do
	
		app.myTrxUA.trxUpdateLogNNReconDtl(nnLog, passport);
	
		if passport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;

		else
			result := app.showErrorWarningDialog('No-Number Reconciliation', passport, ErrWarnMode_Update);
			if passport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				passport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(passport);	// copies errors to this form and shows in err/warnings window
			return false;
			
		endif;
		break;
		
	endwhile;
	
	self.doSearch();
	self.btnSelectAllT.caption := $Deselect_All;	
	self.btnSelectAllT.click(self.btnSelectAllT);
	
	return true;
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateOptionClick" id="8af95c3d-dfdb-4c6d-96b0-e2bfcce5fe00">
        <updating/>
        <source>doUpdateOptionClick()updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	self.loadEntCombos();
	if self.optLoad.value then
		self.initTblData(ETDef_LoadResidue);
		self.updateMode := CMIF_LogNNReconDtl.Mode_LoadResidue;
	elseif self.optReject.value then
		self.initTblData(ETDef_RejectResidue);
		self.updateMode := CMIF_LogNNReconDtl.Mode_RejectResidue;
	elseif self.optReturn.value then
		self.initTblData(ETDef_ReturnResidue);
		self.updateMode := CMIF_LogNNReconDtl.Mode_ReturnResidue;	
	elseif self.optSwap.value then
		self.tblData.enabled := false;
		self.updateMode := CMIF_LogNNReconDtl.Mode_SwapNN;
	elseif self.optKeep.value then
		self.tblData.enabled := false;
		self.updateMode := CMIF_LogNNReconDtl.Mode_RetainOnVoyageNN;
	elseif self.optOffload.value then
		self.tblData.enabled := false;				
		self.updateMode := CMIF_LogNNReconDtl.Mode_OffLoadNN;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getMatchSpecsErrorStr" id="c6899516-4639-4fef-826c-c5da8428b8db">
        <source>getMatchSpecsErrorStr(_bol : CM_BOLOut; _sohLoc : CM_SOHLocation) : String protected;

vars
	errStr	: String;
begin

	if _bol.myVoyage = self.myFiltLogVoyage and
	   _bol.myExtension &lt;&gt; null and
	   _bol.myExtension.isKindOf(CM_BOLExtLogOut) and
	   _bol.myExtension.CM_BOLExtLogOut.myLogVoyageStructIfInError &lt;&gt; null then
		// do nothing as error will already be reported
	else
		errStr := 'Row ' &amp; _sohLoc.myLocationsController.ident &amp; ', Docket ' &amp;  _bol.number;
		if _bol.myVoyage = null then
			errStr := errStr &amp; ' on unknown voyage';
		else
			errStr := errStr &amp; ' on ' &amp; _bol.myVoyage.code;
		endif;
	endif;
	
	return errStr;

end;
</source>
        <access>protected</access>
        <Parameter name="_bol" type="CM_BOLOut"/>
        <Parameter name="_sohLoc" type="CM_SOHLocation"/>
        <ReturnType type="String"/>
    </JadeMethod>
