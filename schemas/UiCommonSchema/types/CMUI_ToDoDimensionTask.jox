    <JadeMethod name="setupForm" id="0ac4c23a-8168-4267-9a08-bfd885212a71">
        <updating/>
        <source>setupForm() updating;
//27 November 2009	cnwml2
// 09/03/2010	cnwdap1	PAR #22592 Display length/width/height with no decimals
// 09/03/2010	cnwcs5	par 22602
vars

	measureType : CM_MeasurementType;

begin

	inheritMethod();
	//self.setCaption("Complete Requires Dimension Check");
	
//	self.lblTitle.caption := "Enter new dimensions for " &amp; self.myTrackedItem.id;
	self.lblTitle.caption	:= app.getErrorString1 (Enter_New_Dimensions, self.myTrackedItem.id);	// par 22602
	
	self.setupMeasurementControls();	//24 Oct 2013	NDL	Par 32646
	
	if self.myTrackedItem.myCargoType.id = TI_CargoType_Container then
		
		self.txtFront.visible := true;
		self.lblFront.visible := true;
		self.txtBack.visible := true;
		self.lblBack.visible := true;
		self.txtLeft.visible := true;
		self.lblLeft.visible := true;
		self.txtRight.visible := true;
		self.lblRight.visible := true;
		
		if self.myTrackedItem.CM_Container.overLengthFront &lt;&gt; null then
			//self.txtFront.text := self.myTrackedItem.CM_Container.overLengthFront.cnEcStripDecimalZeros.asStringJMT();
			//self.txtFront.text := self.myTrackedItem.CM_Container.overLengthFront.asStringMeasurementJMT();
			measureType := self.myTrackedItem.getDefaultMeasurementForType(Type_Length);
			if measureType &lt;&gt; null then
				self.txtFront.setValues( measureType.convertMeasurementForDisplay(self.myTrackedItem.CM_Container.overLengthFront) &amp; Space &amp; measureType.shortName);			
			endif;
		endif;
		
		if self.myTrackedItem.CM_Container.overLengthRear &lt;&gt; null then
			//self.txtBack.text := self.myTrackedItem.CM_Container.overLengthRear.cnEcStripDecimalZeros.asStringJMT;
			//self.txtBack.text := self.myTrackedItem.CM_Container.overLengthRear.asStringMeasurementJMT;
			measureType := self.myTrackedItem.getDefaultMeasurementForType(Type_Length);
			if measureType &lt;&gt; null then
				self.txtBack.setValues( measureType.convertMeasurementForDisplay(self.myTrackedItem.CM_Container.overLengthRear) &amp; Space &amp; measureType.shortName);			
			endif;
		endif;
		
		if self.myTrackedItem.CM_Container.overWidthLeft &lt;&gt; null then
			//self.txtLeft.text := self.myTrackedItem.CM_Container.overWidthLeft.cnEcStripDecimalZeros.asStringJMT;
			//self.txtLeft.text := self.myTrackedItem.CM_Container.overWidthLeft.asStringMeasurementJMT;
			measureType := self.myTrackedItem.getDefaultMeasurementForType(Type_Width);
			if measureType &lt;&gt; null then
				self.txtLeft.setValues( measureType.convertMeasurementForDisplay(self.myTrackedItem.CM_Container.overWidthLeft) &amp; Space &amp; measureType.shortName);			
			endif;
		endif;
		
		if self.myTrackedItem.CM_Container.overWidthRight &lt;&gt; null then
			//self.txtRight.text := self.myTrackedItem.CM_Container.overWidthRight.cnEcStripDecimalZeros.asStringJMT;
			//self.txtRight.text := self.myTrackedItem.CM_Container.overWidthRight.asStringMeasurementJMT;
			measureType := self.myTrackedItem.getDefaultMeasurementForType(Type_Width);
			if measureType &lt;&gt; null then
				self.txtRight.setValues( measureType.convertMeasurementForDisplay(self.myTrackedItem.CM_Container.overWidthRight) &amp; Space &amp; measureType.shortName);			
			endif;
		endif;
		
		if self.myTrackedItem.CM_Container.overHeight&lt;&gt; null then
			//self.txtHeight.text := self.myTrackedItem.CM_Container.overHeight.cnEcStripDecimalZeros.asStringJMT;
			//self.txtHeight.text := self.myTrackedItem.CM_Container.overHeight.asStringMeasurementJMT;
			measureType := self.myTrackedItem.getDefaultMeasurementForType(Type_Height);
			if measureType &lt;&gt; null then
				self.txtHeight.setValues( measureType.convertMeasurementForDisplay(self.myTrackedItem.CM_Container.overHeight) &amp; Space &amp; measureType.shortName);			
			endif;
		endif;
		
		self.txtLength.visible := false;
		self.lblLength.visible := false;
		self.txtWidth.visible := false;
		self.lblWidth.visible := false;
		self.txtVolume.visible := false;
		self.lblVolume.visible := false;
		
		self.height := 207;
	else
		self.txtLength.visible := true;
		self.lblLength.visible := true;
		self.txtWidth.visible := true;
		self.lblWidth.visible := true;
		self.txtVolume.visible := true;
		self.txtVolume.visible := true;
		self.txtHeight.left	:= self.txtVolume.left;	// par 22602
		self.lblHeight.left	:= self.lblVolume.left;	// par 22603
		self.txtLength.left	:= self.txtVolume.left;	// par 22602
		self.lblLength.left	:= self.lblVolume.left;	// par 22603
		self.txtWidth.left	:= self.txtVolume.left;	// par 22602
		self.lblWidth.left	:= self.lblVolume.left;	// par 22602
		
		
		if self.myTrackedItem.length &lt;&gt; null then
			//self.txtLength.text := self.myTrackedItem.length.cnEcStripDecimalZeros.asStringJMT;
			//self.txtLength.text := self.myTrackedItem.length.asStringMeasurementJMT;
			measureType := self.myTrackedItem.getDefaultMeasurementForType(Type_Length);
			if measureType &lt;&gt; null then
				self.txtLength.setValues( measureType.convertMeasurementForDisplay(self.myTrackedItem.length) &amp; Space &amp; measureType.shortName);			
			endif;
		endif;
		
		if self.myTrackedItem.width &lt;&gt; null then
			//self.txtWidth.text := self.myTrackedItem.width.cnEcStripDecimalZeros.asStringJMT;
			//self.txtWidth.text := self.myTrackedItem.width.asStringMeasurementJMT;
			measureType := self.myTrackedItem.getDefaultMeasurementForType(Type_Width);
			if measureType &lt;&gt; null then
				self.txtWidth.setValues( measureType.convertMeasurementForDisplay(self.myTrackedItem.width) &amp; Space &amp; measureType.shortName);			
			endif;
		endif;
		
		if self.myTrackedItem.height &lt;&gt; null then
			//self.txtHeight.text := self.myTrackedItem.height.cnEcStripDecimalZeros.asStringJMT;
			//self.txtHeight.text := self.myTrackedItem.height.asStringMeasurementJMT;
			measureType := self.myTrackedItem.getDefaultMeasurementForType(Type_Height);
			if measureType &lt;&gt; null then
				self.txtHeight.setValues( measureType.convertMeasurementForDisplay(self.myTrackedItem.height) &amp; Space &amp; measureType.shortName);			
			endif;
		endif;
		
		if self.myTrackedItem.getMyTotalVolume &lt;&gt; null then
			//self.txtVolume.text := self.myTrackedItem.getMyTotalVolume.cnEcStripDecimalZeros.asStringJMT;
			measureType := self.myTrackedItem.getDefaultMeasurementForType(Type_Volume);
			if measureType &lt;&gt; null then
				self.txtVolume.setValues( measureType.convertMeasurementForDisplay(self.myTrackedItem.getMyTotalVolume) &amp; Space &amp; measureType.shortName);			
			endif;
		endif;
		
		self.txtFront.visible := false;
		self.lblFront.visible := false;
		self.txtBack.visible := false;
		self.lblBack.visible :=	false;
		self.txtLeft.visible := false;
		self.lblLeft.visible := false;
		self.txtRight.visible := false;
		self.lblRight.visible := false;
		
		self.height := 250;
		self.width 	:= 375;	// par 22602
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupMeasurementControls" id="bd2a3305-6abb-4083-9ae7-1cd81fb9e039">
        <source>setupMeasurementControls();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2013	cnwndl1	Initial creation	Par 32646

*/

vars

begin

	self.txtBack.setup(Type_Length, self.backColor);						
	self.txtBack.tabKey := J_key_Tab;										
	self.txtBack.rowHeight[1] := (self.txtBack.height - 1).Integer;
	
	self.txtFront.setup(Type_Length, self.backColor);						
	self.txtFront.tabKey := J_key_Tab;										
	self.txtFront.rowHeight[1] := (self.txtFront.height - 1).Integer;

	self.txtRight.setup(Type_Width, self.backColor);						
	self.txtRight.tabKey := J_key_Tab;										
	self.txtRight.rowHeight[1] := (self.txtRight.height - 1).Integer;
	
	self.txtLeft.setup(Type_Width, self.backColor);						
	self.txtLeft.tabKey := J_key_Tab;										
	self.txtLeft.rowHeight[1] := (self.txtLeft.height - 1).Integer;
	
	self.txtHeight.setup(Type_Height, self.backColor);						
	self.txtHeight.tabKey := J_key_Tab;										
	self.txtHeight.rowHeight[1] := (self.txtHeight.height - 1).Integer;
	
	self.txtLength.setup(Type_Length, self.backColor);						
	self.txtLength.tabKey := J_key_Tab;										
	self.txtLength.rowHeight[1] := (self.txtLength.height - 1).Integer;
	
	self.txtWidth.setup(Type_Width, self.backColor);						
	self.txtWidth.tabKey := J_key_Tab;										
	self.txtWidth.rowHeight[1] := (self.txtWidth.height - 1).Integer;
	
	self.txtVolume.setup(Type_Volume, self.backColor);						
	self.txtVolume.tabKey := J_key_Tab;										
	self.txtVolume.rowHeight[1] := (self.txtVolume.height - 1).Integer;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="89560258-4fa6-4612-99be-25070e013a27">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013531, locale);
	lblBack.translateCaption(Xlat_0013532, locale);
	lblFront.translateCaption(Xlat_0013533, locale);
	lblHeight.translateCaption(Xlat_0013534, locale);
	lblLeft.translateCaption(Xlat_0013535, locale);
	lblLength.translateCaption(Xlat_0013536, locale);
	lblRight.translateCaption(Xlat_0013537, locale);
	lblTitle.translateCaption(Xlat_0013538, locale);
	lblVolume.translateCaption(Xlat_0013539, locale);
	lblWidth.translateCaption(Xlat_0013540, locale);
end;</source>
    </JadeMethod>
</GUIClass>
