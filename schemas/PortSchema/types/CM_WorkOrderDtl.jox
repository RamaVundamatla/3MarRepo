    <JadeMethod name="canAccessOnWeb" id="8bb051f0-c6bb-4db6-8048-5bcff2e19691">
        <source>canAccessOnWeb() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Jan 2020	jlger1	Initial creation TFS 48179
24 Jan 2023	navma1 	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	user : CM_User;
begin
	user := app.getMyUser;	//24.01.2023 navma1 #56141 Task#56147
	
	if user &lt;&gt; null and user.allDataAccessControllers[CM_ConsigneeConsignor.name] &lt;&gt; null then	
		if not self.canAccessConsigneeConsignor(user) then											
			return false;																									
		endif;																										
	endif;	
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
