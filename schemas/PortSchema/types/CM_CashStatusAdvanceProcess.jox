    <JadeMethod name="getTerminalCode" id="1f438df8-1c9c-4519-ac6a-eaa379ed06e3">
        <source>getTerminalCode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 12th June 2024

*/
vars
	invalid : Boolean;
	code : String;

begin
	on Exception do app.handleDeletedObject(exception, self.myCashReceipt, invalid);	
	
	if self.myCashReceipt &lt;&gt; null then
		code := self.myCashReceipt.myTerminal.code;	
	endif;
	
	if invalid then 
		return null;
	endif;
	
	return code;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
