    <JadeMethod name="comboBoxRTGsLane" id="665d6f1c-4e0b-4f83-9525-6461dc37fcee">
        <source>comboBoxRTGsLane(_lane : CM_RTGLane; _cmb : CMUI_ComboBox input; _rtgArea : CM_RTGArea);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 August 2009	cnwer1	Initial creation

*/

vars
	iter : Iterator;
	rtgArea : CM_RTGArea;
	ta 		: CM_TerminalArea;
	tmpStr : String;
begin
	_cmb.clear;
	_cmb.sorted:=false;
	iter:=_lane.allTAsByTypeId.createIterator;
	while iter.next(ta) do
		rtgArea:=ta.CM_RTGArea;
		if rtgArea = _rtgArea then
			continue;
		endif;
		tmpStr:=rtgArea.id;
		_cmb.addItemObject(tmpStr, rtgArea);
	endwhile;
	
epilog
	delete iter;

end;</source>
        <Parameter name="_lane" type="CM_RTGLane"/>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_rtgArea" type="CM_RTGArea"/>
