    <JadeMethod name="create" id="3e8e9e66-46b2-4dd3-b35b-171c7c0f91a2">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 November 2017	jlgab1	Initial creation
04/05/2023	navkc1	Bug 57484: EUP - Cargo Allocation Transaction Map Permissions

*/

vars

begin
	// 04/05/2023	navkc1	Bug 57484
	self.permissionView  := PmAdmInvCargoLineMappingView;
	self.permissionMaint := PmAdmInvCargoLineMappingMaint;
	
	self.helpFileName := HelpFile_Invoicing;

epilog

