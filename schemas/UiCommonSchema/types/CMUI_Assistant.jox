    <JadeMethod name="comboBoxROROVesselStructure" id="ac656d1d-06f5-4e81-b656-c60c0bf5fece">
        <source>comboBoxROROVesselStructure(_cmb : CMUI_ComboBox input; 
							_selectedROROVesselStruct : CM_VesselStructuralElements);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwer1	Initial creation

*/

vars
	tmpTerm : CM_Terminal;
	tmpUser	: CM_User;
	tmpUserT	: CM_UserTerminal;
	showVesselByName : Boolean;
	roroVesselStructure : CM_VesselStructuralElements;
	iter 		: Iterator;
	vessel		: CM_Vessel;
begin
	_cmb.clear;
	

	// hacky way of getting the terminal because the config is set per terminal 
	tmpTerm := app.getMyTerminalDO_NOT_USE();
	if tmpTerm = null then
		tmpUser := app.getMyUser();
		if tmpUser &lt;&gt; null then
			tmpUserT := tmpUser.allUserTerminals.first;
			if tmpUserT &lt;&gt; null then
				tmpTerm := tmpUserT.getRealTerminal;
			endif;
		endif;
	endif;
	
	if tmpTerm &lt;&gt; null then
		showVesselByName:= tmpTerm.getConfig(VesselComboByName).Boolean;
	endif;
	
	
	iter:=CM_VesselStructuralElements.instances.createIterator;
	while iter.next(roroVesselStructure) do
		vessel:=roroVesselStructure.myVessel;
		//vesselDict.add(vessel);
		if showVesselByName then	
			_cmb.addItemObject( vessel.name &amp;  " - (" &amp; vessel.code &amp; ")" ,roroVesselStructure); 
		else
			_cmb.addItemObject( vessel.code &amp; " -  ("  &amp; vessel.name &amp; ")",roroVesselStructure); 
		endif;
	endwhile;

	/*
	iter:=app.myRoot.allVesselROROStructures.createIterator;
	while iter.next(roroVesselStructure) do
		vessel:=roroVesselStructure.myVessel;
		if showVesselByName then	
			_cmb.addItemObject( vessel.name &amp;  " - (" &amp; vessel.code &amp; ")" ,roroVesselStructure); 
		else
			_cmb.addItemObject( vessel.code &amp; " -  ("  &amp; vessel.name &amp; ")",roroVesselStructure); 
		endif;
	endwhile;*/
	
	
	if _selectedROROVesselStruct &lt;&gt; null then
		_cmb.listIndex:=_cmb.findObject(_selectedROROVesselStruct);
	endif;


epilog
	delete iter;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_selectedROROVesselStruct" type="CM_VesselStructuralElements"/>
    </JadeMethod>
    <JadeMethod name="comboBoxROROVoyage" id="a75fb20c-89e2-4ba6-9b51-2b1dbb0dcbdd">
        <source>comboBoxROROVoyage( _cmb : CMUI_ComboBox input;
					_terminal : CM_Terminal;
					_selectedVoyage : CM_Voyage);
/*

Purpose:		Add only RORO Voyages which have a roro voyage structure	

Parameters:			

Return Value:		


Date		Who		Reason
13 December 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
tmpTerm : CM_Terminal;
	roroVoyageStructure : CM_ROROVoyageStructure;
	iter 		: Iterator;
	voyage		: CM_Voyage;
	failedDAC  :CM_DataAccessController;
begin
	_cmb.clear;
	
	tmpTerm := _terminal;

	
	iter:=tmpTerm.allVoyagesByCode.createIterator;
	while iter.next(voyage) do
		
		roroVoyageStructure:=voyage.myROROStructure;
		
		if roroVoyageStructure = null then
			continue;
		endif;
		
		if voyage.isCancelled then  //jlier1 TFS51963 5/10/21
			continue;
		endif;
		
		if not voyage.canUserAccessSelf(null, failedDAC, app.myPassport) then
			continue;
		endif;
		
	
		_cmb.addItemObject( voyage.code.trimBlanks,voyage); 
		
	endwhile;
	
	
	if _selectedVoyage &lt;&gt; null then
		_cmb.listIndex:=_cmb.findObject(_selectedVoyage);
	endif;


epilog
	delete iter;

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_selectedVoyage" type="CM_Voyage"/>
    </JadeMethod>
