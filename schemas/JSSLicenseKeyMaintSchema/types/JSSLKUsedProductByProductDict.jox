    <JadeMethod name="findUsedComponent" id="65317ded-d809-407f-869a-6d1bb74b153f">
        <source>findUsedComponent(pTheComponent:JSSLKComponent):JSSLKUsedComponent;
// --------------------------------------------------------------------------------
// Created:		27 January 2003 by cnwdad1
//
// Purpose:		Scans for a Used Component in the receiver which has a reference to
//				the specified Product Component, and return a reference to that
//				Used Product instance.
//
// Parameters:	pTheComponent - The Product Component to scan for.
//
// Returns:		A reference to a Used Component of the Product Component is found,
//				otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theProduct			: JSSLKProduct;
	theUsedProduct		: JSSLKUsedProduct;
	theUsedComponent	: JSSLKUsedComponent;
	
begin
	theProduct		:=	pTheComponent.myProduct;
	theUsedProduct	:=	self.findUsedProduct(theProduct);
	
	if theUsedProduct &lt;&gt; null then
		foreach theUsedComponent in theUsedProduct.allUsedComponents do
			if theUsedComponent.myComponent = pTheComponent then
				return theUsedComponent;
			endif;
		endforeach;
	endif;
	
	return null;
end;</source>
        <Parameter name="pTheComponent" type="JSSLKComponent"/>
        <ReturnType type="JSSLKUsedComponent"/>
    </JadeMethod>
    <JadeMethod name="findUsedProduct" id="7b21717a-e97f-4c88-bd0e-fbae7755739b">
        <source>findUsedProduct(pTheProduct:JSSLKProduct):JSSLKUsedProduct;
// --------------------------------------------------------------------------------
// Created:		27 January 2003 by cnwdad1
//
// Purpose:		Scans for a Used Product in the receiver which has a reference to
//				the specified Product, and return a reference to that Used Product
//				instance.
//
// Parameters:	pTheProduct - The Product to scan for.
//
// Returns:		A reference to a Used Product if the Product is found, otherwise
//				false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// --------------------------------------------------------------------------------
vars
	theUsedProduct	: JSSLKUsedProduct;
	
begin
	foreach theUsedProduct in self do
		if theUsedProduct.myProduct = pTheProduct then
			return theUsedProduct;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="pTheProduct" type="JSSLKProduct"/>
        <ReturnType type="JSSLKUsedProduct"/>
    </JadeMethod>
</CollClass>
