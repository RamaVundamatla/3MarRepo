    <JadeMethod name="doDefaults" id="2070280e-8aab-4abd-b241-f4e1e731f9a4">
        <source>doDefaults() protected;

vars
	listPointer	: Integer;

begin
	self.applyColour();

	listPointer := 1;
	
	while listPointer &lt;= lstUnavailClasses.listCount do
		if lstUnavailClasses.itemForeColor[listPointer] = Red then
			lstAvailClasses.addItem(lstUnavailClasses.itemText[listPointer]);
			lstUnavailClasses.removeItem(listPointer);
			listPointer := listPointer - 1;
		endif;
		
		listPointer := listPointer + 1;
	endwhile;
	
	btnMakeAvail.enabled := false;
	
	if lstUnavailClasses.listCount &gt; 0 then
		btnUpdate.enabled := true;
	else
		btnUpdate.enabled := false;		
	endif;

	listPointer := 1;
	
	while listPointer &lt;= lstAvailClasses.listCount do
		if lstAvailClasses.itemForeColor[listPointer] = Red  then
			lstUnavailClasses.addItem(lstAvailClasses.itemText[listPointer]);
			lstAvailClasses.removeItem(listPointer);
			listPointer := listPointer - 1;
		endif;
		
		listPointer := listPointer + 1;
	endwhile;
	
	btnMakeUnavail.enabled := false;
	
	if lstUnavailClasses.listCount &gt; 0 then
		btnUpdate.enabled := true;
	else
		btnUpdate.enabled := false;		
	endif;

	self.applyColour();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="7b7b3df5-895a-4ef1-94f6-79a196bf8fbd">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	app.mousePointer	:=	Busy;
	inheritMethod();
	self.loadForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadForm" id="343b8c9b-8ce0-4d5a-9449-bc66b7968f1b">
        <updating/>
        <source>loadForm()updating, protected;

vars
	classObj		: Class;
	subclassesObj	: ClassColl;
	baseRootObj		: CnEcBaseRoot;

begin
    self.centreWindow();
	baseRootObj	:= app.myBaseRoot;
	classObj	:= app.myCnEcXmlSchema.getClass("Object");
	lblSchemaName.caption := "Class Veto for schema: " &amp; app.myCnEcXmlSchema.name; 

	create subclassesObj transient;
	classObj.allLocalSubclasses(subclassesObj);
	
	if not subclassesObj.includes(classObj) then
		subclassesObj.add(classObj);
	endif;
	
	classObj := app.myCnEcXmlSchema.getClass("Class");
	
	if not subclassesObj.includes(classObj) then
		subclassesObj.add(classObj);
	endif;
	
	if baseRootObj.getAllXmlExcludedClasses() &lt;&gt; null then
		foreach classObj in subclassesObj do
			if baseRootObj.getAllXmlExcludedClasses().includes(classObj.name) then
			//if baseRoot.allXmlExcludedClasses.includes(classObj.name) then
				lstUnavailClasses.addItem(classObj.name);
			else
				lstAvailClasses.addItem(classObj.name);
			endif;
		endforeach;
	else
		foreach classObj in subclassesObj do
			lstAvailClasses.addItem(classObj.name);
		endforeach;		
	endif;
	
	self.applyColour();  
epilog
	delete subclassesObj;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstAvailClasses_click" id="7c1a94d9-9a1f-46d1-b289-ad4fbf349fb2">
