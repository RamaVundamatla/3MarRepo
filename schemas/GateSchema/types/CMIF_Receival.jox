        <source>setUserDetails(pObject: Object) updating;
//----------------------------------------------------------------
//	Created:	05 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(pObject);

	if GTE_Sheet.hasInstance(pObject) then
		self.isFromPrenote := pObject.GTE_Sheet.isPopulatedFromPrenote;
	endif;
	
end;</source>
