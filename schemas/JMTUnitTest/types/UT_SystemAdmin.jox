uAkXinl7CPLAqhSTrE0T6RGkGZhIwIVD/u2d7n8x4d0xOprffWkR0JONfD1kFdFg
i4xwV6kZP5p7cT81Vo/20j9paci299439p8vu0V+OuPqt8CnRc7QxU0P3Ilja3pd
n7VT2MMr1eDg/O9rB5L19szkw8f2A+ZGnfZW7QKBgQCvRSx5dxXRyymsDiJ4bA+s
yzlmCH8X+SWx9LcLCn2vGE+dU++ClZbayTTgJEJ7sDMqqxbRPy9JBoqb9UNPrKeE
74KqBZyPt+pCBJbSaO1jFqsarSOItAJ9Rspouu0jf8j0GSr+roM2l/8ECRFFo17w
DJbB/fi/3JYaJBIkqXjr3QKBgEdiWksh9N18MfQlQUAykH7uCRPB1M/r7wDfSjbP
P7lUvgfpM+wKgRICsIjBd/mhegj/kUY3U0P+YrR6sWL4J4xl18XreqLMbBq4ZKja
ngdFg1zhE1OeabUwbesKOYFBkKEERvk9UZV3y1I4qqPA0Y6FthHF6eMlcsyZYCLV
BAwBAoGBAOwe1OiJ1ZLIJGU5z2Z8E2mCCjHamnfIHC3/qnwez9H5xYwhlC8+Srff
bXkfHDUZ3OK0l1IFH3vOT3SogMnurm6uJ24tSFXLgnSUG8Kcv7R9VtXTVWXgoda7
CPQRJBt9Jk+TfnLZOXWZZKiMyXonGP6Aw86PE2T1DpVYlZjYCXmU
-----END RSA PRIVATE KEY-----";
vars
	pxySFTPEnt		: CM_SFTPEntity;
	realSFTPEnt,
	existingSFTPEnt	: CM_FTPEntity;
	camProtocol		: CM_CamProtocol;
	taskHistory		: CM_CamTaskHistory;
	now				: TimeStamp;
	baseDir,
	camDirStr,
	ediDirStr,
	contents		: String;
	camsFolder		: FileFolder;
	dummyFile		: File;
	
	// Save existing CAM settings
	resetProtocol,
	emailEnabled	: Boolean;
	protocolDesc	: CM_CamProtocolDesc;
	ftpEnt			: CM_FTPEntity;
	oldLoggingLevel	: Integer;
	
	bgpRequest		: BGP_EdiFTPGet;
	
	testNum			: Integer;
	testTitle,
	sftpName,
	sftpUser,
	sftpPass,
	sftpKey,
	sftpKeyPhrase	: String;
begin	
	oldLoggingLevel := app.logLevel; //Moved here as inside loop causes us to lose the old log level
/*	if not app.isSFTPEnabled then
		self.assertTrueMsg(false, "SFTP is not enabled, not running test");
		return;	// belts and braces
	endif; */

		// Update
	foreach testNum in 1 to 5 step 1 do
		if testNum = 1 then
			testTitle		:= "1. Private Key + Username";
			sftpName		:= ID&amp;"_KeyOnly";
			sftpUser		:= USERNAME;
			sftpPass		:= null;
			sftpKey			:= PRIVATE_KEY;
			sftpKeyPhrase	:= null;
		elseif testNum = 2 then
			testTitle		:= "2. Encrypted Private Key + Passphrase + Username";
			sftpName		:= ID&amp;"_KeyPass";
			sftpUser		:= USERNAME;
			sftpPass		:= null;
			sftpKey			:= ENC_PRIVATE_KEY;
			sftpKeyPhrase	:= app.pwEnCode( KEY_PASSPHRASE );	//06 Sep 2021	NDL	TFS 51165
		elseif testNum = 3 then
			testTitle		:= "3. Username + Password";
			sftpName		:= ID&amp;"_UserPass";
			sftpUser		:= USERNAME;
			sftpPass		:= app.pwEnCode( PASSWORD ); //30 Aug 2921	NDL	TFS 51632
			sftpKey			:= null;
			sftpKeyPhrase	:= null;
		elseif testNum = 4 then
			testTitle		:= "4. Username + Password + Enc Private Key + Key Passphrase";
			sftpName		:= ID&amp;"_All";
			sftpUser		:= USERNAME;
			sftpPass		:= app.pwEnCode( PASSWORD ); //30 Aug 2921	NDL	TFS 51632
			sftpKey			:= ENC_PRIVATE_KEY;
			sftpKeyPhrase	:= app.pwEnCode( KEY_PASSPHRASE );
		elseif testNum = 5 then
			testTitle		:= "5. Private Key without Username (invalid)";
			sftpName		:= ID&amp;"_Invalid";
			sftpUser		:= null;
			sftpPass		:= null;
			sftpKey			:= PRIVATE_KEY;
			sftpKeyPhrase	:= null;
		else
			self.assertTrueMsg(false, "Invalid Test Number specified (" &amp; testNum.String &amp; ")");
		endif;
	
		self.logMessage("Running test: " &amp; testTitle);
	
		// Clean up from last time
		existingSFTPEnt := app.myRoot.allFTPEntities.getAtKey(sftpName);
		if existingSFTPEnt &lt;&gt; null then
			// 'Remove' any associated CAMS Protocols
			beginTransaction;
			foreach camProtocol in existingSFTPEnt.allCamProtocols do
				camProtocol.setPropertyValue(CM_CamProtocol::myFTPEntity.name, null);
			endforeach;
			commitTransaction;
			
			app.myTrxDA.trxDeleteSFTPEntity(existingSFTPEnt.CM_SFTPEntity, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
		endif;

		// Including any transients from the previous loop
		delete pxySFTPEnt;
		delete taskHistory;
		delete camsFolder;
		delete dummyFile;
		
		if testNum = 1 then			
			// Create a new SFTP Entity
			create pxySFTPEnt transient;
			
			
			pxySFTPEnt.setProxy(DEST,				/* Destination Directory */
								sftpName,			/* Entity Name/Id */
								sftpPass,			/* Password */			// should this be "" instead ?
								SERVER_IP,			/* Server Name */
								SRC,				/* Source Directory */
								sftpUser,			/* Username */
								false,				/* Passive Mode (NA, doesn't apply to SFTP) */
								false,				/* Use Proxy (NA, (our implementation) doesn't use this) */
								0,					/* Mode (NA, doesn't apply to SFTP) */
								0,					/* Server GMT Bias (NA, (our implementation) doesn't use this) */
								0,					/* Server Type (NA, doesn't apply to SFTP) */
								0,					/* Port. 0 = 22 */
								0,					/* Timeout */
								false,				/* Single File Copy (NA, doesn't apply to SFTP) */
								false, 				/* Save Undeleted Files List (NA, doesn't apply to SFTP) */
								sftpKeyPhrase,		/* Private Key Passphrase */
								sftpKey,			/* Private Key */
								null);				/* Public Key (NA, (our implementation) doesn't use this) */
			
			app.myTrxCA.trxCreateSFTPEntity(pxySFTPEnt, realSFTPEnt, app.myPassport);
		else
			// Update our existing SFTP Entity
			self.assertNotNull(realSFTPEnt);
			
			beginLoad;
			pxySFTPEnt := realSFTPEnt.pxyCreateUpdateProxy().CM_SFTPEntity;
			endLoad;
			
			pxySFTPEnt.setProxy(DEST,				/* Destination Directory */
								sftpName,			/* Entity Name/Id */
								sftpPass,			/* Password */			// should this be "" instead ?
								SERVER_NAME,		/* Server Name */
								SRC,				/* Source Directory */
								sftpUser,			/* Username */
								false,				/* Passive Mode (NA, doesn't apply to SFTP) */
								false,				/* Use Proxy (NA, (our implementation) doesn't use this) */
								0,					/* Mode (NA, doesn't apply to SFTP) */
								0,					/* Server GMT Bias (NA, (our implementation) doesn't use this) */
								0,					/* Server Type (NA, doesn't apply to SFTP) */
								0,					/* Port. 0 = 22 */
								0,					/* Timeout */
								false,				/* Single File Copy (NA, doesn't apply to SFTP) */
								false, 				/* Save Undeleted Files List (NA, doesn't apply to SFTP) */
								sftpKeyPhrase,		/* Private Key Passphrase */
								sftpKey,			/* Private Key */
								null);				/* Public Key (NA, (our implementation) doesn't use this) */
								
			app.myTrxUA.trxUpdateSFTPEntity(pxySFTPEnt, app.myPassport);
		endif;
		
		// Check for errors
		if testNum &lt;&gt; 5 then
			self.assertNoTrxErrorsOrWarnings();
		else
			self.assertTrxError(Input_required_field_Required);
			self.logMessage(app.myPassport.getAllErrorsWarningsAsString());
			continue;	// Update successfully failed, next test
		endif;
		
		self.assertEqual(realSFTPEnt.destinationDirectory, DEST);
		self.assertEqual(realSFTPEnt.password, sftpPass);
		
		if testNum = 1 then
			self.assertEqual(realSFTPEnt.serverName, SERVER_IP);
		else
			self.assertEqual(realSFTPEnt.serverName, SERVER_NAME);
		endif;		
		
		self.assertEqual(realSFTPEnt.sourceDirectory, SRC);
		self.assertEqual(realSFTPEnt.userId, sftpUser);
		self.assertEqual(realSFTPEnt.CM_SFTPEntity.passPhrase, sftpKeyPhrase);
		self.assertEqual(realSFTPEnt.CM_SFTPEntity.privateKey, sftpKey);
		self.assertNull(realSFTPEnt.CM_SFTPEntity.publicKey);	// Not used, so should always be null
		
		// Run (Send file to SFTP)
		self.logMessage("################ SEND FILE (" &amp; testTitle &amp; ") ################");
		// NB. We're not testing CAMS here, so we might fudge some stuff
		baseDir := self.getMyTerminal().getConfig_FileDirectory(CamsFileDirectory).String.trimRight();
		camProtocol := self.getMyTerminal().camProtocols.first;
		self.assertNotNullMsg(camProtocol, "Need a (any) CAM protocol to continue");
		self.logMessage("Using CAM Protocol: " &amp; camProtocol.code &amp; "/" &amp; camProtocol.description);
		
		// Create our dummy File to upload
		camDirStr := baseDir &amp; '\' &amp; camProtocol.getProtocolSubDirectoryName() &amp; "\";
		create camsFolder transient;
		camsFolder.fileName := camDirStr;
		camsFolder.usePresentationFileSystem := false;
		if not camsFolder.isAvailable then
			camsFolder.make();
		endif;
		
		create dummyFile transient;
		dummyFile.mode := File.Mode_IO;
		dummyFile.kind := File.Kind_ANSI;
		dummyFile.usePresentationFileSystem := false;
		dummyFile.fileName := camsFolder.fileName &amp; DUMMY_FILE_NAME;
		if dummyFile.isAvailable then
			self.logMessage("Removing previous " &amp; DUMMY_FILE_NAME &amp; " from CAMS folder");
			dummyFile.purge();
		endif;
		
		dummyFile.writeLine(EXPECTED_CONTENTS);
		dummyFile.close();
		self.assertTrue(dummyFile.isAvailable);
		self.logMessage("Created dummy file: " &amp; dummyFile.fileName);
		
		// Change any settings to what we need it to be
		emailEnabled := camProtocol.isEmailEnabled;
		protocolDesc := camProtocol.protocolDesc;
		ftpEnt := camProtocol.myFTPEntity;
		
		beginTransaction;
		camProtocol.setIsEmailEnabled(false);
		camProtocol.setPropertyValue(CM_CamProtocol::protocolDesc.name, null);
		camProtocol.setPropertyValue(CM_CamProtocol::myFTPEntity.name, realSFTPEnt);
		commitTransaction;
		resetProtocol := true;
		
		create taskHistory transient;
		taskHistory.set(now, now, now, false, camProtocol, -1, -1, DUMMY_FILE_NAME, CAM_COMPLETESTATUS, null);
		
		// SEND the file!
		self.assertTrueMsg(camProtocol.isEmailEnabled = false and camProtocol.isUserDefinedReport = false and camProtocol.myFTPEntity = realSFTPEnt, "(Dummy) CAM Protocol not in a state to be able to send SFTP files");
		app.changeLogLevel(LogTRACE);	// Enable tracing to see WTF is going on if anything breaks
		camProtocol.sendAction(camDirStr, taskHistory,0);
		
		// Anything else to assert here ?
		self.assertNoTrxErrorsOrWarnings();
		self.logMessage("################ SEND FILE (OK) ################");
		
		// Reset cam protocol back to what it was
		beginTransaction;
			camProtocol.setIsEmailEnabled(emailEnabled);
			camProtocol.setPropertyValue(CM_CamProtocol::protocolDesc.name, protocolDesc);
			camProtocol.setPropertyValue(CM_CamProtocol::myFTPEntity.name, ftpEnt);
		commitTransaction;
		resetProtocol := false;
						
		
		// Run (Get file from SFTP)
		 self.logMessage("################ GET FILE ################");
		
		// Clean up from last time
		/*ediDirStr := self.getMyTerminal().getConfig_FileDirectory(EDIFileDirectory).String.trimRight();
		dummyFile.fileName := ediDirStr &amp; "\" &amp; DUMMY_FILE_NAME;
		if dummyFile.isAvailable then
			self.logMessage("Removing previous " &amp; DUMMY_FILE_NAME &amp; " from EDI folder");
			dummyFile.purge();
		endif;
		dummyFile.close();
		
		
		create bgpRequest transient;
		// fudge a bgp request
		bgpRequest.setPropertyValue(BGP_Request::myTerminal.name, self.getMyTerminal());
		bgpRequest.myFTPEntity := realSFTPEnt;
		bgpRequest.processEdiFtpGet();
			
		// Anything else to assert here ?
		self.assertNoTrxErrorsOrWarnings();
		
		// Wait for the user notification to go through
		// This wont happen until our process dies :(
		return;
		
		// Check the file we sent earlier is now back on disk in the EDI folder
		dummyFile.open();
		self.assertTrueMsg(dummyFile.isAvailable, "Downloaded SFTP file not found. Expected " &amp; dummyFile.fileName &amp; " to exist in c_misc\UT\EDI folder.");
		self.assertTrueMsg(dummyFile.fileLength &gt; 0, "FileSize = 0; Downloaded SFTP file is empty! It should contain *something*");
		
		contents := dummyFile.readLine();
		self.assertTrueMsg(contents = EXPECTED_CONTENTS, "Transferd file contents do not match! (Expected: ["&amp;EXPECTED_CONTENTS&amp;"], Actual: ["&amp;contents&amp;"]");*/
		
		// No point in running this part of the test if we can't actually verify anything
		self.logMessage(Tab &amp; "not run due to the files being fetched asynchronously and unable to verify if there were errors or not.");
		
		self.logMessage("################ GET FILE (OK) ################");
	
	endforeach;
	
	// Delete
	self.assertNotNull(realSFTPEnt);
	self.logMessage("Deleting " &amp; realSFTPEnt.id);
	
	app.myTrxDA.trxDeleteSFTPEntity(realSFTPEnt.CM_SFTPEntity, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	realSFTPEnt := null;

epilog
	app.changeLogLevel(oldLoggingLevel);
	
	if resetProtocol then
		beginTransaction;
		camProtocol.setIsEmailEnabled(emailEnabled);
		camProtocol.setPropertyValue(CM_CamProtocol::protocolDesc.name, protocolDesc);
		camProtocol.setPropertyValue(CM_CamProtocol::myFTPEntity.name, ftpEnt);
		commitTransaction;
	endif;

	delete pxySFTPEnt;
	delete taskHistory;
	delete camsFolder;
	delete dummyFile;
	delete bgpRequest;
end;</source>
    </JadeMethod>
    <JadeMethod name="tSftpTfs51800" id="bc614cac-f731-4a5a-bdf3-e631569e9e7a">
        <source>tSftpTfs51800();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2021	navndl1	Initial creation	TFS 51800

*/

vars

	request : CMIF_SFTPRequest;
	inputStr : String;
	returnString : String;

begin

	create request transient;
	
	//new example
	inputStr := "-r--r--r-- 1 PARTNER.USER.150 PARTNER.USER.150         709 Aug 10 08:03 MAEU_NZNSN_COPARN_33_20210810080304450.EDI";
	returnString := request.getTextFromDateOnwards( inputStr );
	self.assertTrueMsg(returnString &lt;&gt; null, "Test 1, no fileName returned");
	self.assertTrueMsg(returnString[1:6] = "Aug 10", "Test 1 first part of string incorrect");
	
	//old examples
	inputStr := "drwxrwx---   1 admin    users           0  Jun 08 2020 CAMS";
	returnString := request.getTextFromDateOnwards( inputStr );
	self.assertTrueMsg(returnString &lt;&gt; null, "Test 2, no fileName returned");
	self.assertTrueMsg(returnString[1:6] = "Jun 08", "Test 2 first part of string incorrect");
	
	
	inputStr := "-rwxrwx---   1 admin    users         437  Dec 06 2019 COD00790.txt";
	returnString := request.getTextFromDateOnwards( inputStr );
	self.assertTrueMsg(returnString &lt;&gt; null, "Test 3, no fileName returned");
	self.assertTrueMsg(returnString[1:6] = "Dec 06", "Test 3 first part of string incorrect");
	
	
	inputStr := "-rwxrwx---   1 admin    users          14 Aug 19 00:59 sftpdummyfile.txt";
	returnString := request.getTextFromDateOnwards( inputStr );
	self.assertTrueMsg(returnString &lt;&gt; null, "Test 4, no fileName returned");
	self.assertTrueMsg(returnString[1:6] = "Aug 19", "Test 4 first part of string incorrect");
	

epilog

	delete request;

end;</source>
    </JadeMethod>
    <JadeMethod name="tShipPortGroup" id="63bf51bf-2d5b-4ada-ae8b-b9c791c33e8c">
        <source>tShipPortGroup();

/*

Purpose:		Create / Delete / Update Ship Port Group

Date			Who		Reason
15/05/2015		cnwmh5	Initial creation

*/
constants

	ShipPortGroupCode			: String = "UTMH";
	ShipPortGroupDesc			: String = "Michael's Ship Port Group";
	
vars

	shipPortGroup				: CM_ShipPortGroup;
	shippingLine				: CM_ShippingLine;
	obj							: Object;
	proxyShipPort				: CM_ShipPort;
	proxyShipPortGroup 			: CM_ShipPortGroup;
	lineGroupDebtor				: CM_LineGroupDebtor;	
	proxyLineGroupDebtor 		: CM_LineGroupDebtor;
	port						: CM_Port;
	
	shipPorts					: ObjectArray;
	lineGroupDebtors			: ObjectArray;
	selectedPorts				: ObjectArray;
	selectedDebtors				: ObjectArray;
	
begin

	shippingLine := app.myRoot.allShippingLines[self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString()];
	self.assertNotNull(shippingLine);
	
	shipPortGroup := shippingLine.shipPortGroups[ShipPortGroupCode].CM_ShipPortGroup;
	if shipPortGroup &lt;&gt; null then
		app.myTrxDA.trxDeleteShipPortGroup(shipPortGroup, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;	

	create selectedPorts transient;
	selectedPorts.add(app.myRoot.allPorts["NZKBZ"]);
	selectedPorts.add(app.myRoot.allPorts["NZKTF"]);
	selectedPorts.add(app.myRoot.allPorts["NZKTG"]);
	self.assertEqual(selectedPorts.size, 3);
	
	create shipPorts transient;
	foreach obj in selectedPorts do
		create proxyShipPort transient;
		proxyShipPort.setProxy(obj.CM_Port);
		shipPorts.add(proxyShipPort);
	endforeach;
	self.assertEqual(shipPorts.size, 3);
	
	create selectedDebtors transient;
	selectedDebtors.add(app.myRoot.allDebtors["ABCONR"]);
	self.assertEqual(selectedDebtors.size, 1);
	
	create proxyShipPortGroup as CM_ShipPortGroup transient;
	
	create lineGroupDebtors transient;
	foreach obj in selectedDebtors do
		lineGroupDebtor := null;
		create proxyLineGroupDebtor transient;
		proxyLineGroupDebtor.setProxy(shippingLine.code, ShipPortGroupCode, obj.CM_DebtorNode);
		
		lineGroupDebtors.add(proxyLineGroupDebtor);
	endforeach;
	
	proxyShipPortGroup.setProxy(ShipPortGroupCode, ShipPortGroupDesc, lineGroupDebtors, shipPorts, shippingLine);
	app.myTrxCA.trxCreateShipPortGroup(proxyShipPortGroup, shipPortGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(shipPortGroup);
	
	delete proxyShipPortGroup;
	beginLoad;
	proxyShipPortGroup := shipPortGroup.pxyCreateUpdateProxy();
	endLoad;
	
	port := app.myRoot.allPorts["NZTRG"].CM_Port;
	self.assertNotNull(port);
	create proxyShipPort transient;
	proxyShipPort.setProxy(port.CM_Port);
	proxyShipPortGroup.shipPorts.add(proxyShipPort);
	app.myTrxUA.trxUpdateShipPortGroup(proxyShipPortGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(shipPortGroup.shipPorts.size, 4);
	
	delete proxyShipPortGroup;
	beginLoad;
	proxyShipPortGroup := shipPortGroup.pxyCreateUpdateProxy();
	endLoad;
	proxyShipPortGroup.shipPorts.purge();
	app.myTrxUA.trxUpdateShipPortGroup(proxyShipPortGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(shipPortGroup.shipPorts.size, 0);
	
epilog

	shipPorts.purge();
	delete shipPorts;
	lineGroupDebtors.purge();
	delete lineGroupDebtors;
	delete selectedPorts;
	delete selectedDebtors;
	delete proxyShipPortGroup;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tShippingAgent" id="2a8f6aee-3704-4786-b9ab-de74150a0fa8">
        <source>tShippingAgent();
/*
Date		Who		Reason
15/05/2014	cnwma1	Initial creation

*/

vars
	shippingAgent : CM_ShippingAgent;
begin
	
	shippingAgent :=self.addShippingAgent("UTSA","Unit Test Shipping Agent",false);
	self.assertNotNull(shippingAgent);
	
	//Update Shipping Agent
	self.updateShippingAgent(shippingAgent);
	self.assertEqual(shippingAgent.description,"Unit Test Shipping Agent_UP");
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tShippingLine" id="ed7101bd-f800-4bf7-bce1-15649d1b0a56">
        <source>tShippingLine();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/03/2014	cnwma1	Initial creation
09-06-2022	navtnr20	53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
*/
constants
	ShippingLineID	 : String = "MASL";
	ShippingLineDesc : String = "Unit Test Shipping Line ";
	
vars
	shippingLine		: CM_ShippingLine;
	shippingLineDesc	: String;
	shippingLineColor	: Integer;////09-06-2022	navtnr20 53195
	
begin
	
	// Delete Shipping Line 
	self.deleteShippingLine(ShippingLineID);
	
	//Create Shipping Line
	shippingLine := self.addShippingLine(ShippingLineID,ShippingLineDesc,false);
	self.assertNotNull(shippingLine);
	
	// update ShippingLine
	shippingLineDesc := shippingLine.description &amp; "_UP_UT";
	shippingLineColor := Green;
	self.opts.purge();
	self.opts.addAssoc("ShippingLineDesc", shippingLineDesc);
	self.opts.addAssoc("ShippingLineColor", shippingLineColor.String);	//09-06-2022	navtnr20 53195
	self.updateShippingLine(shippingLine);
	self.assertEqual(shippingLine.description, shippingLineDesc);
	self.assertEqual(shippingLine.colour, shippingLineColor);		//09-06-2022	navtnr20 53195
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tSortingMethod" id="6bbf03ab-4c81-4dbf-ab77-6aef6ce99acb">
        <source>tSortingMethod();
/*

Purpose:			Tests that a Sorting Method can be created, updated and deleted

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
07 June 2023	navpw1	Initial creation TFS: 57813 (58438)

*/

constants
	SortingMethodCode			: String = self.TFS57813;
	SortingMethodDesc			: String = "UT" &amp; self.TFS57813;
	SortingMethodIsNotAvai		: Boolean = true;
	UpdSortingMethodCode		: String = "Upd";
	UpdSortingMethodDesc		: String = "UPDUT" &amp; self.TFS57813;
	UpdSortingMethodIsNotAvai	: Boolean = true;
	
vars
	pxySortingMethod,
	realSortingMethod : CM_SortingMethod;
	
begin
	realSortingMethod := app.myRoot.allSortingMethods[SortingMethodCode];
	if realSortingMethod &lt;&gt; null then
		app.myTrxDA.trxDeleteSortingMethod(realSortingMethod, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	realSortingMethod := app.myRoot.allSortingMethods[UpdSortingMethodCode];
	if realSortingMethod &lt;&gt; null then
		app.myTrxDA.trxDeleteSortingMethod(realSortingMethod, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	/* 
		Test 1
		Create Sorting Method 
	*/
	
	create pxySortingMethod transient;
	pxySortingMethod.setProxy(SortingMethodCode, SortingMethodDesc, SortingMethodIsNotAvai);
	
	app.myTrxCA.trxCreateSortingMethod(pxySortingMethod, realSortingMethod, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertTrueMsg(realSortingMethod &lt;&gt; null, "Sorting Method (" &amp; SortingMethodCode &amp; ") has not been created/is null");
	self.assertTrueMsg(realSortingMethod.code = SortingMethodCode, "Field: " &amp; CM_SortingMethod::code.name &amp; " | Expected: '" &amp; SortingMethodCode &amp; "' | Actual: '" &amp; realSortingMethod.code &amp; "'");
	self.assertTrueMsg(realSortingMethod.description = SortingMethodDesc, "Field: " &amp; CM_SortingMethod::description.name &amp; " | Expected: '" &amp; SortingMethodDesc &amp; "' | Actual: '" &amp; realSortingMethod.description &amp; "'");
	self.assertTrueMsg(realSortingMethod.isNotAvailableForEntry = SortingMethodIsNotAvai, "Field: " &amp; CM_SortingMethod::isNotAvailableForEntry.name &amp; " | Expected: '" &amp; SortingMethodIsNotAvai.String &amp; "' | Actual: '" &amp; realSortingMethod.isNotAvailableForEntry.asStringJMT() &amp; "'");
	
	delete pxySortingMethod;
	
	/* 
		Test 2
		Updating Sorting Method 
	*/
	
	realSortingMethod := app.myRoot.allSortingMethods[SortingMethodCode];
	pxySortingMethod := app.createUpdateProxy(realSortingMethod).CM_SortingMethod;
	
	pxySortingMethod.setProxy(UpdSortingMethodCode, UpdSortingMethodDesc, UpdSortingMethodIsNotAvai);
	
	app.myTrxUA.trxUpdateSortingMethod(pxySortingMethod, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	realSortingMethod := app.myRoot.allSortingMethods[UpdSortingMethodCode];
	
	self.assertTrueMsg(realSortingMethod &lt;&gt; null, "Sorting Method (" &amp; UpdSortingMethodCode &amp; ") has not been created/is null");
	self.assertTrueMsg(realSortingMethod.code = UpdSortingMethodCode, "Field: " &amp; CM_SortingMethod::code.name &amp; " | Expected: '" &amp; UpdSortingMethodCode &amp; "' | Actual: '" &amp; realSortingMethod.code &amp; "'");
	self.assertTrueMsg(realSortingMethod.description = UpdSortingMethodDesc, "Field: " &amp; CM_SortingMethod::description.name &amp; " | Expected: '" &amp; UpdSortingMethodDesc &amp; "' | Actual: '" &amp; realSortingMethod.description &amp; "'");
	self.assertTrueMsg(realSortingMethod.isNotAvailableForEntry = UpdSortingMethodIsNotAvai, "Field: " &amp; CM_SortingMethod::isNotAvailableForEntry.name &amp; " | Expected: '" &amp; UpdSortingMethodIsNotAvai.String &amp; "' | Actual: '" &amp; realSortingMethod.isNotAvailableForEntry.asStringJMT() &amp; "'");
	
	delete pxySortingMethod;
	
	/* 
		Test 3
		Deleting Sorting Method 
	*/
	
	realSortingMethod := app.myRoot.allSortingMethods[UpdSortingMethodCode];
	
	app.myTrxDA.trxDeleteSortingMethod(realSortingMethod, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	realSortingMethod := app.myRoot.allSortingMethods[UpdSortingMethodCode];
	
	self.assertTrueMsg(realSortingMethod = null, "Sorting Method (" &amp; UpdSortingMethodCode &amp; ") has not been deleted");
	
epilog
	delete pxySortingMethod;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tStevedore" id="62e67037-aca3-4f93-bee2-dc7f5716d169">
        <source>tStevedore();

/*

Purpose:		Create / Update / Delete Stevedore

Date			Who		Reason
28/02/2014		cnwmh5	Initial creation

