    <JadeMethod name="matchesSearchCriteria" id="3b33e2df-8b61-4f97-aa79-7efbff3f3252">
        <source>matchesSearchCriteria(_search : CMIF_SearchEventRequest) : Boolean;
//--------------------------------------------------
// Created:	06 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	len,
	cnt : Integer;
	address,
	delimiter : String;
begin
	if _search = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null _search');
		return false;
	endif;

	if _search.fromDate.isValid then
		if self.systemToLocalTime(self.enteredDT).date &lt; _search.fromDate then	// 5/5/16 cnwmp6 TFS 488 - Multi timezone support
			return false;
		endif;
	endif;

	if _search.toDate.isValid then
		if self.systemToLocalTime(self.enteredDT).date &gt; _search.toDate then	// 5/5/16 cnwmp6 TFS 488 - Multi timezone support
			return false;
		endif;
	endif;	
		
	if _search.myOrganisation &lt;&gt; null then
		if self.myOrganisation &lt;&gt; _search.myOrganisation then
			return false;
		endif;
	endif;

	if _search.reference &lt;&gt; null then
		len := _search.reference.length;
		if self.reference[1:len].toUpper() &lt;&gt; _search.reference.toUpper() then
			return false;
		endif;
	endif;

	if _search.status &gt; EventRequestStatusAny then
		if self.status &lt;&gt; _search.status then
			return false;
		endif;
	endif;

	if _search.myUser &lt;&gt; null then
		if self.myUser &lt;&gt; _search.myUser then
			return false;
		endif;
	endif;

	if _search.emailAddresses &lt;&gt; null then
		len := _search.emailAddresses.length;
		while true do
			cnt := cnt+1;
			address := _search.emailAddresses.getDelimitedToken(cnt, ';', delimiter);
			if self.allEmailAddresses.includes(address) then
				return true;
			endif;
			if cnt &gt; len then
				break;
			endif;
		endwhile;
		return false;
	endif;	
	
	if _search.type &lt;&gt; null then
		if self.type &lt;&gt; _search.type then
			return false;
		endif;
		
	endif;
	
	return true;
		
end;</source>
        <Parameter name="_search" type="CMIF_SearchEventRequest"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="dcea999d-3f94-4cd2-b2c3-1ca4fda8b6e3">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy : SelfType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myOrganisation := self.myOrganisation;
	proxy.myTerminal := self.myTerminal;
	proxy.myUser := self.myUser;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="sendEmail" id="856fe3fc-8e46-428d-9ad8-75bd663127a4">
        <updating/>
        <source>sendEmail(_passport : CM_Passport input)updating;
//--------------------------------------------------
// Created:	17 May 2005 By: cnwgd1
//--------------------------------------------------
// 14/12/2010	cnwcs5	ccms mes 1112 / par 24464
vars
	checkCanBeProcessed	: Boolean;
	alertDescription,
	toAddress,
	fromAddress,
	ccAddresses,
	bccAddresses,
	sendSubject,
	sendMessage				: String;
	allAttachedFilePaths	: HugeStringArray;
	blob					: Binary;
	blobFileName			: String;
	sourceOfEmail			: Integer;
	updateCallbackObj		: Object;
begin

	if self.myEventRequestEmail &lt;&gt; null then
	//if _eventReqEmail &lt;&gt; null then
//		if (not _eventReqEmail.allRunTimes.isEmpty) then
			// Has no run times therefore the auto app will handle when to send it
			self.statusInformation := app.getErrorString(Email_Queued);
			return;
	//	endif;
	endif;
	
	toAddress := self.allEmailAddresses.first;

	if toAddress = null then
		toAddress := app.myRoot.getConfig(AutoSupportEmailAddress).String;
	endif;	
	fromAddress := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	ccAddresses := self.getEmailAddresses(toAddress);
	
	// Wild guess to try and stop invalid cc address at Otago.
	if ccAddresses = ";" then
		ccAddresses := null;
	endif;
	
	alertDescription 	:= self.typeString;
	sourceOfEmail 		:= EmailSource_System;
	sendSubject			:= self.getSendSubject();
	sendMessage 		:= self.getSendMessage();
												
	app.myUtilityCA.utlCreateEmailSendRequest(checkCanBeProcessed,
											 alertDescription,
											 toAddress, 
											 fromAddress, 
											 ccAddresses, 
											 bccAddresses, 
											 sendSubject, 
											 sendMessage, 
											 allAttachedFilePaths,
											 null, 
											 blob, 
											 blobFileName, 
											 sourceOfEmail, 
											 updateCallbackObj,
											 _passport);
											 												
//	14/12/2010	cnwcs5	ccms mes 1112 / par 24464 - start
	if self.status = EventRequestCargoDeleted then
		// don't change status if cargo deleted - need status to stay as it was
		return;
	endif;
//	14/12/2010	cnwcs5	ccms mes 1112 / par 24464 - end
	self.updateStatusAndStatusInfo(EventRequestEmailed, app.getErrorString(Email_Sent_To_BGP));
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
