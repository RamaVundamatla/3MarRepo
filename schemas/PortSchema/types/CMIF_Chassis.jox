    <JadeMethod name="getCargoType" id="c31d707e-636f-48ad-9556-2d8ee6fcfb76">
        <source>getCargoType() : Integer;
// ---------------------------------------------------------------------------
// Created:     15 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ct : CM_CargoType;
	tmpCT : Integer;
begin

	tmpCT := self.cargoType;
	
	if tmpCT = 0 then 
		// they must have enetered a chassis ID that is not in the fleet file
		// use first trailer type for now
		foreach ct in app.myRoot.allCargoTypesById discreteLock do
			if ct.isTrailer() then
				tmpCT := ct.id;
				break;
			endif;
		endforeach;
	endif;

	return tmpCT;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTIMasterTILCTI" id="a8ef9c87-fe3f-4ef7-9107-bde0c4ac15e8">
        <updating/>
        <source>setTIMasterTILCTI(_tiMasterTILC : CM_TIMasterTILC) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 24 May 2007
//
//----------------------------------------------------------------------

vars

begin
	if _tiMasterTILC &lt;&gt; null then
		self.myTIMasterTILC := _tiMasterTILC;
	endif;
epilog

end;</source>
        <Parameter name="_tiMasterTILC" type="CM_TIMasterTILC"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="50ae04ae-be16-4751-8872-4fd3ddc9134b">
        <updating/>
        <source>validateForCreate(_passport: CM_Passport input): Boolean updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 15 May 2007
//
//----------------------------------------------------------------------

vars
	ti 			: CM_TrackedItem;
	theCargoType: CM_CargoType;
	tiUpdCntrl	: CMIF_TIUpdateController; 
	subItemError : Boolean;
begin
	if self.myProxyTrackedItem &lt;&gt; null then
		self.eraseProxyTrackedItem();
	endif;

	theCargoType := app.myRoot.allCargoTypesById[self.cargoType];
	
	self.myProxyTrackedItem := self.myTerminal.createTI(theCargoType, true); // Use MASTER TI

	//Should be in validation agent methinks
	//ti := app.getMyTerminal().allOnsiteTIsByIdCargoType[self.id, self.cargoType];
	ti := self.myTerminal.allOnsiteTIsByIdCargoType[self.id, self.cargoType];
	if ti &lt;&gt; null then
		app.raiseCMException1(ERR_ALREADY_ONSITE, self.id,  null, null);
		return _passport.noErrors;
	endif;

	subItemError := self.validateForSubItemDuplicates();

	if (not subItemError) then
		self.validateSubItems(_passport);
	endif;
	
	tiUpdCntrl := app.createTIUpdateControl(TI_UPDMODE_RECEIPT, null, self.myUserObject);
	self.myProxyTrackedItem.setPxyFromCMIF_Chassis(self, _passport);
	self.myProxyTrackedItem.validateTrackedItem(tiUpdCntrl, _passport);	
	
epilog
	return _passport.noErrors;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
