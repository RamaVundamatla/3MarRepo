    <JadeMethod name="getNumberOfSortColumns" id="18fdf45a-f9e1-4dd0-8334-db39164321d7">
        <source>getNumberOfSortColumns(): Integer protected;
// ---------------------------------------------------------------------------
// Created:     12 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/10/2009	cnwcs5		par 21171 - sorting issues
// ---------------------------------------------------------------------------
vars
	value	:Integer;
begin
	value := self.allTblDataSortColumns.size;
	
	if self.hasGroups then
		value := value + self.NumGroupSortColumns;	// par 21171
	endif;

	return value;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSortGroupingCompareValues" id="29496098-2987-48b9-bd4d-e98b72e29b17">
        <source>getSortGroupingCompareValues(_rowIdx : Integer) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwmh5	Initial creation
02 May 2025	jlizm1	MTN 34589 Invalid table row error

*/

vars

	idx : Integer;

	str	: String;
	
begin
	if _rowIdx = 0 then
		return null;
	endif;
	
	// get the details for the sort and grouping columns
	foreach idx in 1 to self.sortColumn.size do
		if idx &lt;&gt; 2 and self.sortColumn[idx] &lt;&gt; 0 then
			str := str &amp; self.getCellText(_rowIdx, sortColumn[idx]);
		endif;		
	endforeach;

	return str;
	
epilog

end;</source>
        <Parameter name="_rowIdx" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLStrForColItems" id="c5661d9f-43b3-4236-bd03-472ad2ffcf22">
        <source>getXMLStrForColItems(): String;
// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwcs5
// Purpose:     par 21171 - sorting issues
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entRow  : EntTableRow;
	tmpStr : String;
begin
	if not self.hasGroups then
		return inheritMethod();
	endif;
	
	foreach entRow in self.allTblDataEntRows do
		if entRow = self.getGroupingETRow then
			// we don't expect it to be here but ican cause problems if it is
			// we add it when we need it(addGroupingColumn)
			continue;
		endif;
		tmpStr := tmpStr &amp; global.formatAsXML(XMLTag_Column, entRow.name);
	endforeach;

	return tmpStr;
epilog

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLStrForColSort" id="87c709dd-f1c7-4ad2-975f-dc14dac77adb">
        <source>getXMLStrForColSort(): String;
// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwcs5
// Purpose:     Par 21171 - sorting issues
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str,sortStr 	: String;
	idx, sortCol	: Integer;
	etRow			: EntTableRow;
begin
	if not self.hasGroups then
		return inheritMethod;
	endif;
	
	foreach str in self.allTblDataSortColumns do
		idx 	:= idx + 1;
		etRow	:= self.getEntRowColumnByRowName (str, sortCol);
		
		if etRow = null or sortCol = 0 then
			continue;	// should not happen :-)
		endif;
		
		//str := str &amp; Tab &amp; sortCol.String &amp; Tab &amp; self.allTblDataSortDescending[idx].String; //- cnwmd1, Par 21589
		str := str &amp; Tab &amp; sortCol.String &amp; Tab &amp; (not self.allTblDataSortDescending[idx]).String; //+ cnwmd1, CCMS 1067, Par 21589
		
		if sortStr &lt;&gt; null then
			sortStr := sortStr &amp; ',' &amp; str;
		else
			sortStr := str;
		endif;
		
		if idx = (self.MaxJadeSortColumns - self.NumGroupSortColumns) then	
			// Jade max sort order
			break;
		endif;
	endforeach;
	
	return sortStr;
epilog
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <ExternalMethod name="groupHeadingDisplay" id="264046f5-355c-423b-815d-2136a3e2635f">
        <entrypoint>CallControlEvent</entrypoint>
        <library name="jadpmap"/>
        <source>groupHeadingDisplay(_table :CM_GroupingTable; _any :Any):String is "CallControlEvent" in "jadpmap";
