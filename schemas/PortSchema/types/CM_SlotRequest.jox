    <JadeMethod name="getAutoLoadPlanCommodityCode" id="6ea6f43a-c30d-4532-b25f-23944dcd6ba7">
        <source>getAutoLoadPlanCommodityCode() : String;
// ---------------------------------------------------------------------------
// Created:		29 May 2008 By Andrew Bishop cnwab1
//
// Purpose:	
//
// ---------------------------------------------------------------------------





// ANY CHANGES HERE MUST BE MIRRORED IN THE SAME METHOD ON CM_CONTAINER






vars
	commGrp : CM_CommodityGroup;
begin
	if self.isSpecialStow() then
		commGrp := self.getAttrCommodityGroup(); // PAR 23920
		if commGrp &lt;&gt; null then // PAR 23920
			return commGrp.code; // PAR 16604 // this is comm group
		endif;
	endif;
	
	if self.getAttrFantainer() then
		return "#FAN";
	elseif self.getAttrCrib() then
		return "#CRIB";
	elseif self.getAttrFrame() then	//05 Feb 2018	NDL	TF S36752
		return "#FRAME";
	elseif self.getAttrFlatRack() then
		return "#FLAT";
	elseif self.getAttrOpenTop() then
		return "#OPEN";
	elseif self.getAttrTank() then
		return "#TANK";
	endif;
	
	return null;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBayId" id="ec2ac490-6546-498a-b232-39bac3bb4be7">
        <source>getBayId(_ti : CM_TrackedItem) : String;
// ---------------------------------------------------------------------------
// Created:    Converted from C++. Returns the id of the bay. 
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	structure : CM_CellularVoyageStructure;
	bayVoyage : CM_BayVoyage;
	is40 : Boolean;
begin

	bayVoyage := self.mySlotController.myBayVoyage;
	if bayVoyage = null then
		return null;
	endif;
	structure := bayVoyage.myCellularVoyageStructure;
	
	if structure.use40Id then
		if _ti &lt;&gt; null then
			sharedLock(_ti);
			if _ti.isAttributeTrue(TI_Attrib_IsForty) then
				is40 := bayVoyage.canHandle4045();
			endif;
		endif;
	endif;

	if is40 then
		return bayVoyage.idBay40.trimBlanks;
	else
		return bayVoyage.id.trimBlanks;
	endif;
epilog
	if _ti &lt;&gt; null then
		unlock(_ti);
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
