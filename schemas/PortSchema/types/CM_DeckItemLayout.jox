    <JadeMethod name="showAllCoveredPolygons" id="012fff26-c0ab-4cf7-9cc9-69bb7151b03f">
        <source>showAllCoveredPolygons();
/*
Purpose:			
Date		Who		Reason
01 September 2011	cnwab1	Initial creation
*/

vars

item  : CM_Graphic;

begin
	foreach item in self.allCoveredPolygons discreteLock do
		item.CM_DeckItemLayout.allCoveringPolygons.remove(self);
	endforeach;

	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showAllHiddenAndChangeType" id="1fe1bd21-05d1-4b57-8584-232aa3e86c27">
        <updating/>
        <source>showAllHiddenAndChangeType() updating;
/*
Purpose:	The EDI Stowage creation sets the graphic type to be DeckItemLayoutType_CCLoad, but it should be a type of DeckItemLayoutType_Locn. So remove existing locns hidden under my covered graphics, then set my new type.


The LocnDefn	 for a load CC OOTL is created on the load layer. When the container is actually moved to the voyage we move this locnDefn to the OOTL Layer.
Whilst the locnDefn is on the LoadLayer, we do not want it to be hiding any standard container positions (this is done by the graphic for teh load CC) because it might clash (in the dictionary) with an actual OOTL in the same position.

When the actual OOTL is moved from the voyage we hide the locnDefn graphic and show all the standard container positions that were under it.
When the load container is moved to the voyage we then move the locnDefn to the OOTL layer and hide any standard container positions under it.
Date		Who		Reason
21 July 2011	cnwab1	Initial creation
*/

vars
	oldCoveringPolygon, 
	newCoveringPolygon, coveredLocn : CM_DeckItemLayout;
	graphic : CM_Graphic;
begin
	if not self.isOnLayerLoad() then
		return;
	endif;

	if self.allCoveredPolygons.isEmpty() then
		return;
	endif;
	
	if self.type &lt;&gt; DeckItemLayoutType_CCLoad then
		return;
	endif;
	
	if self.myDeckItem = null then
		return;
	endif;

	self.showAllCoveredPolygons();
	
	self.setType(DeckItemLayoutType_Locn);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showContainerPositionUnderGC" id="718734f1-ef2d-48d5-92fc-aed70a4f852b">
        <updating/>
        <source>showContainerPositionUnderGC(_gcLayout : CM_DeckItemLayout) updating;
/*
Purpose:			
Date		Who		Reason
21 July 2011	cnwab1	Initial creation
*/

vars

begin
	if self.allCoveringPolygons.includes(_gcLayout) then
		self.allCoveringPolygons.remove(_gcLayout);
	endif;
epilog

end;</source>
        <Parameter name="_gcLayout" type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="typeName" id="227fcd80-3edf-477a-9e2c-e91b9737da32">
        <source>typeName() : String;
/*
Date		    Who			Reason
05 May 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

begin
	if self.myDeckItem &lt;&gt; null then
		return self.myDeckItem.typeName() &amp; " (" &amp; app.getErrorString(Graphic).toUpper() &amp; ")"; 
	else
		return app.getErrorString(Graphic).toUpper();
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
