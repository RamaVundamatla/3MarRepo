    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="restwebservice"/>
    <ImplicitInverseRef name="amounts" id="9336680e-351b-4a23-8341-4f39476a2188">
        <embedded/>
        <type name="WS_ReleaseDetailAmountsObj"/>
    </ImplicitInverseRef>
