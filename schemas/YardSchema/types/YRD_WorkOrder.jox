		self.grpOrderTimes.enabled := false;
		self.grpOrientationMI.enabled := false;
		self.grpOrientationSM.enabled := false;
		self.grpPackAttr.enabled := false;
		self.grpPackItems.enabled := false;
		self.grpPermit.enabled := false;
		self.grpReceiveDetails.enabled := false;
		self.grpShiftMovement.enabled := false;
		self.grpTaskAction.enabled := false;
		self.grpTaskDetails.enabled := false;
		self.grpTasks.enabled := false;
		self.grpTimeChange.enabled := false;
		self.grpToDo.enabled := false;
		self.grpUnPackDetails.enabled := false;
		self.grpVisitDetails.enabled := false;
		self.grpVoyageDetails.enabled := false;
		self.grpWaterRequest.enabled := false;
