    <JadeMethod name="enableFields" id="1a5d32f2-e409-4758-95db-dce02b8fec46">
        <source>enableFields(_enabled : Boolean) protected;
// ---------------------------------------------------------------------------

//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//2/10/2017  jlgns1 TFS 6865 PKT - Weighbridge Connection Issue
// ---------------------------------------------------------------------------

vars
	enable : Boolean;

begin 
	enable := _enabled;
	
	if not app.myPassport.myUser.canDo(self.myTerminal, self.permissionMaint) then
		enable := false;
		self.enableFieldsAfterQuery(false);
	endif;
		
	
	if 	self.myBulkGateAgent.gateAndLaneSet 						//TFS 6865
	and ( ( self.mySerialWeightIntController &lt;&gt; null and self.mySerialWeightIntController.hasValidConnection )
		or (  self.myOtherWeightIntController &lt;&gt; null and self.myOtherWeightIntController.myConnection &lt;&gt; null )	//19 Jul 2021	NDL	TFS 51575
		)
	then	//TFS 6865 
		self.cmbGateLanes.enabled 	:= false;
		self.cmbGate.enabled 		:= false;	
	else
		self.cmbGateLanes.enabled 	:= enable;
		self.cmbGate.enabled 		:= enable;
	endif;

	self.txtSearchDays.enabled := true;
	
	self.txtRegno.enabled := enable;

	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
