    <JadeMethod name="isDirectDelivery" id="349b35bb-ab44-4d25-955b-a2174162074a">
        <source>isDirectDelivery(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2013	cnwndl1	Initial creation

*/

vars

	invalidObj : Boolean;

begin

	if self.status = WLE_COMPLETED then
		return false;
	endif;

	if self.myTrackedItem &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, self.myTrackedItem, invalidObj );
		return self.myTrackedItem.directDelivery;
	endif;

	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
