        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCurrentCapacity" id="94801b3b-9bf0-4202-b421-d9b1d5315757">
        <source>getCurrentCapacity(): Integer;
// JLGAB1 TFS 49959
vars
	minMax : CM_TerminalAreaProductMinMax;
	
begin

	minMax := self.getMinMaxForFirstTI();
	//jlier1 TFS 52052 25/3/22
	if minMax = null then
		minMax:=self.myGroup.allProductMinMax.first;
	endif;
	if minMax &lt;&gt; null then
		if minMax.maxQuantity &gt; 0 then
			// capacity is per column, each column is an LC so need to multiply by number of columns
			return minMax.maxQuantity * self.myGroup.allLocations.size();
		elseif minMax.maxWeight &gt; 0 then
			// capacity is per column, each column is an LC so need to multiply by number of columns
			return minMax.maxWeight * self.myGroup.allLocations.size();
		elseif minMax.maxVolume &gt; 0 then
			// capacity is per column, each column is an LC so need to multiply by number of columns
			return minMax.maxVolume.Integer * self.myGroup.allLocations.size();
		endif;
	endif;

	return self.myTerminalArea.getMaxCapacity();
	
	
	
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
