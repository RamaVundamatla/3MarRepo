    <JadeMethod name="getPreviousPortInRotation" id="323cf2b0-6f18-42b8-bd00-91fcdd891203">
        <source>getPreviousPortInRotation() : CM_Port;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 20 August 2010
//
// Implemented version: JMT 7.8.3
// Date  		User  		Change
// 20/08/2010	cnwsh3		CCMS1063 PAR25508 - Required for reporting views when created.
//							Return the previous port to the terminal's default port in the port rotation list.
// 21/11/2018	jlgdap1		TFS 42024 PEL1 Incorrect Ports in Voyage Request
// 10/12/2018   cnwma1		Bug 42434: PEL1 - CM_JRWVoyages PreviousPortofCall incorrect
// 1/10/2021	jlier1	TFS 51963 
//----------------------------------------------------------------------
vars
	thisTerminalsPort,
	currentPort,
	previousPort 	: CM_Port;
	portRotation 	: CM_PortRotation;
	found 			: Boolean;
	wod 			: CM_WodVoyageRequest;			// TFS 42024

begin
	if not self.isDefaultVoyageProcess then
		wod := self.getWorkOrderForVoyageRequest();							// TFS 42024
		if wod &lt;&gt; null and wod.portCode1 &lt;&gt; null then						// TFS 42024
			//return app.myRoot.allPorts[wod.portCode1];					// TFS 42024  //10.12.2018 cnwma1 Bug #42434
			return app.myRoot.allPorts[wod.portCode5];						// TFS 42024  //10.12.2018 cnwma1 Bug #42434
		endif;																// TFS 42024
	endif;																	// TFS 42024
	
	if self.allPortRotations.isEmpty() then
		return null;
	endif;

	thisTerminalsPort := self.myTerminal.getDefaultPort();

	foreach portRotation in self.allPortRotations do
		//Get the port in the port rotation
		currentPort := portRotation.myPort;
		
		//am I the same as our default port?
		if currentPort = thisTerminalsPort then
			found := true;
			break;
		endif;
		
		//We didn't hit the default port but we could be the port before the default.
		previousPort := currentPort;
	endforeach;
	
	//Didn't find the default port so there is no previous port to it.
	if not found then
		previousPort := null;
	endif;
	
	return previousPort;
		
epilog
end;</source>
        <ReturnType type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="getProcessTerminal" id="cd205646-ae86-43e1-80ee-7384e4bbedc2">
