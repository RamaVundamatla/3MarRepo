vars

begin
	self.name := SOP_TableMaintForm.Table_VesselCategory;
	self.permissionView	 := PmHMSVesselCategoryView;
	self.permissionMaint := PmHMSVesselCategoryMaint;
	self.myDataClass := HMS_VesselCategory;
end;</source>
    </JadeMethod>
