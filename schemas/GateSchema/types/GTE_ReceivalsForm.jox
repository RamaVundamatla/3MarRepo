    <JadeMethod name="doTblExtraDblClick" id="f17155f6-22c6-44c5-9903-5acdd393b60f">
        <updating/>
        <source>doTblExtraDblClick(table: CM_EntryTable input) updating;
// ---------------------------------------------------------------------------
// Created:     04 January 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin


	if table.row = table.getRowByName(ETRow_EmailOptions) then
		self.doEmailOptionsDblClick();
	else
		if self.allAttachments &lt;&gt; null then
			self.myAssistant.GTE_Assistant.receival_tblExtraDblClick(table.CM_EntryTable, self.allAttachments,self.getCargoDocketId);
		endif;
	endif;
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCargoDocketId" id="2fbea200-8bd5-4b48-a15c-a5035f5d71d6">
        <source>getCargoDocketId() : Integer;
// ---------------------------------------------------------------------------
// Created:     21 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cmb			: ComboBox;
	tmpObj		: Object;

begin

	cmb := self.getControlByName('cmbTiType').ComboBox;
	if cmb = null then
		return TI_CargoType_Null;
	endif;

	if cmb.listObject = null then
		return TI_CargoType_Null;
	endif;

	tmpObj := cmb.listObject;
	
	if tmpObj.isKindOf(CM_CargoType) then
		return tmpObj.CM_CargoType.id;
	elseif tmpObj.isKindOf(CM_BOLType) then
		return tmpObj.CM_BOLType.id;
	endif;

	return TI_CargoType_Null;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFormControl" id="28e7e91c-de32-4742-8608-2fbf44f0c0ab">
        <source>getFormControl(pName : String) : Control;
// ---------------------------------------------------------------------------
// Created:     03 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	num,
	idx		: Integer;
	cntrl	: Control;
	
begin

	num := self.controlCount;
	
	foreach idx in 1 to num do
		cntrl := self.controls(idx);
		if cntrl.name = pName then
			return cntrl;
		endif;
	endforeach;
	
	return null;

end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="Control"/>
    </JadeMethod>
    <JadeMethod name="goToErrorItem" id="881db8e5-444c-4c13-9248-948cfbb2d1d0">
        <source>goToErrorItem(pError: CM_Error);
// ---------------------------------------------------------------------------
// Created:     08 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	navObject	: CMUI_NavigatorObject;
	theWindow	: Window;
	theField	: String;
	fieldFound	: Boolean;
	tbl			: CM_EntryTable;
	idx			: Integer;
	cntrl		: Control;
	
begin

	theWindow := self;
	theField  := pError.fieldName;

	if theField = 'id' then
		theField := 'idTextBox';
	elseif theField = 'operator' then
		theField := 'operatorCode';
	elseif theField = 'status' then
		theField := 'statusString';
	elseif theField = 'temperature' then
		// As tempC field is shown even if tempF being used this should get user back to correct area.
		theField := 'carriageTempC';
	elseif theField = 'weight' then
	  theField := 'weightTotal';	
	elseif theField = 'voyage' then
		theField := 'voyageCode';
	endif;
	
	if tblMain.goToRowByName(theField) then
		tblMain.setFocus;
		fieldFound := true;
	else
		if tblExtra.goToRowByName(theField) then
			tblExtra.setFocus;
			fieldFound := true;
		endif;
	endif;

end;</source>
        <Parameter name="pError" type="CM_Error"/>
    </JadeMethod>
    <JadeMethod name="handleExtraTableTabbing" id="04638cc5-9e14-4ccd-b27d-e8b482052f53">
