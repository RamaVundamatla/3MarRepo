    <JadeMethod name="updateTableElapsedTimes" id="d47015c7-dda6-4620-9bd6-7ed77455a4dd">
        <updating/>
        <source>updateTableElapsedTimes() protected, updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	row : Integer;
	time : String;
	timeCell : JadeTableCell;
begin
	foreach row in self.tblJobs.fixedRows + 1  to self.tblJobs.rows do
		timeCell:=self.tblJobs.accessCell(row,self.colNoTime);
		if timeCell &lt;&gt; null then
			time:=timeCell.text;
			timeCell.text:=(time.Integer + 1).String;
			if time.Integer &gt; self.configElapsedTime then
				timeCell.fontBold:=true;
				timeCell.foreColor:=Red;
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="userNotify" id="ee8210e4-8e69-4da3-a7f5-eee88861cc3a">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	app.mousePointer	:=	Busy;
	if eventType = Event_Delete_Queue_Entry  or  eventType = Event_Add_Queue_Entry    then
		self.loadTaskTable();
	elseif eventType = EVENT_MACH_BROADCAST_MSG then
		app.msgBox(userInfo.String,"Message from RT Control",MsgBox_OK_Only);
	elseif eventType = EVENT_MACHQUEUE_ALTERED then
		self.doControlChangedQueue(userInfo.String);
	elseif eventType = EVENT_RESET_MEDIATOR then
		self.doControlResetSession(userInfo.String);
	else
		return;
	endif;
	
epilog
	app.mousePointer	:=	Idle;



end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
