begin

	self.splitter1.top 	:= self.frmToolbar.height;
	inheritMethod();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doRevertToDirectorTask" id="e5c69205-1589-48c9-ad14-48efcf05ac87">
        <source>doRevertToDirectorTask() protected;
// -------------------------------------------
// Created 06 November 2003 by cnwdvb1
// -------------------------------------------
vars

	result : Integer;
begin

	if self.myCurrentTask &lt;&gt; null and self.myCurrentTask.isDirectorWithAssignedTI then
		
		while true do
			app.myTrxUA.trxCancelAssignedTIDirector(self.myCurrentTask,self.myCurrentTask.myMachine, app.myPassport );
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				break;
			else
				result := app.showErrorWarningDialog('Revert To Director Task', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
			   		result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				else
					break;
				endif;
			endif;
		endwhile;
	endif;
	

//old code - 
/*
	if self.myCurrentTask &lt;&gt; null and self.myCurrentTask.taskType = TASK_DIRECTOR then
		
		while true do
			app.myTrxUA.trxUpdateRevertDirectorTask(self.myCurrentTask.myEntry, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				break;
			else
				result := app.showErrorWarningDialog('Revert To Director Task', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
			   		result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				else
					break;
				endif;
			endif;
		endwhile;
	endif;
	*/
epilog 
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowContextMenu" id="84f8cc6e-0f15-4fbd-ab71-ffa689b75462">
        <updating/>
        <source>doShowContextMenu(pMenu : MenuItem; cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     11 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	x1 : Real;
	y1 : Real;

begin
	x1 := x;
	y1 := y;
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if cntrl.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := cntrl.positionTop();
	    endif;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	if pMenu = self.mnuTask then

		if not self.doShowHideMenuItems() then
			return false;
		endif;

	endif;
	
	if pMenu = self.mnuMachine then
		self.setMachineStatusMenu();
		self.mnuInspectMachine.visible:=app.isAllowedToInspect();
	endif;
	
	
	// TFS 52945 NAVCS2 22/03/2022
	if not self.canMaintainRTQueue then
		self.mnuTaskMoveOverstow.visible := false;
		self.mnuTaskShowOverstow.visible := false;
		self.mnuTaskAmendSource.visible := false;
		self.mnuTaskAmendICTarget.visible := false;
		self.mnuTaskEditRequest.visible := false;
		self.mnuTaskAmendTarget.visible := false;
		self.mnuAutoPlan.visible := false;
		self.mnuTaskStatus.visible := false;
		self.mnuTaskDeleteEntry.visible := false;
		self.mnuTaskOverideHalt.visible := false;
		self.mnuMoveToShip.visible := false;
		self.mnuChgRTMoveMethod.visible := false;
		self.mnuMoveTask.visible := false;
		self.mnuTaskRemoveMachine.visible := false;
		self.mnuTaskAllocate.visible := false;
		self.mnuSwitchIMV.visible := false;
		self.mnuWeigh.visible := false;
		self.mnuMachineDetails.visible := true;
		
	endif;

	self.popupMenu(pMenu, x1.Integer, y1.Integer);
	
	return false;                  // cancel further processing
end;</source>
        <Parameter name="pMenu" type="MenuItem"/>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowHeldReason" id="98f0698e-4536-4117-a8b8-8462f89aaab7">
        <source>doShowHeldReason();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/11/2012	cnwdap1	Initial creation PAR #30762 CCMS QNS 2233
*/
vars
	wle 	: CM_WorkListEntry;
	ti		: CM_TrackedItem;
	reason	: String;

begin
	if self.myCurrentEntry = null then
		return;
	endif;
	
	wle := self.myCurrentEntry.myWorkListEntry;
	if wle = null then
		return;
	endif;
	ti := wle.myTrackedItem;
	if ti = null then
		if not self.myCurrentEntry.allTasks.isEmpty and self.myCurrentEntry.allTasks.first.taskType = TASK_DIRECTOR then
			//app.msgBox(app.getErrorString(Queue_Entry_Manually_Held), app.getErrorString(HoldType), MsgBox_OK_Only);
			//22 Apr 2015	NDL	Par 36014
			if self.myCurrentEntry.allTasks.first.requiresSystemHold(true, null, reason) then
				app.msgBox(reason, app.getErrorString(HoldType), MsgBox_OK_Only);
			endif;
		endif;
		return;
	endif;
	if ti.isHeldRTQueueStatus(true, null, reason) then
		app.msgBox(reason, app.getErrorString(HoldType), MsgBox_OK_Only);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowHideMenuItems" id="99a7a9bb-037d-4a2c-8404-03f359237893">
        <source>doShowHideMenuItems() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 March 2010	cnwer1	Initial creation
15 July 2010	cnwdap1	PAR #25021 review use of isImport/isExport for tranships
//15 May 2014	cnwrs1	Par 34154 - handle invalid object for ti
*/

vars
	ti : CM_TrackedItem;
	controller1,
	controller2 	 : CM_LocationsController;
	overstowed,
	overstowedAtMoveTime,
	invalidTask,
	invalidEntry		: Boolean;
	sideAccessDirection : Integer;
	invalidTI : Boolean;
	request : CM_Request;
begin


	self.mnuMoveToShip.enabled := false;
	self.mnuTaskShowGrid.visible := false;		// PAR 21532 CCMS SFW 1025
	self.mnuTaskShowOverstow.visible := false;	// PAR 21532 CCMS SFW 1025
	self.mnuTaskMoveOverstow.visible := false;	// PAR 21532 CCMS SFW 1025
	self.mnuQueryDirectorPlan.visible:=false;  //jlier1 1/10/25 MTN-35633
	
	
	self.mnuInspectTask.visible:=app.isAllowedToInspect;
	
	on Exception do app.handleDeletedObject(exception, self.myCurrentTask, invalidTask);		// PAR #16738
	on Exception do app.handleDeletedObject(exception, self.myCurrentEntry, invalidEntry);
	
	if  self.myCurrentTask = null or 
		self.myCurrentEntry = null then
		return false;
	endif;
	
	ti := self.myCurrentTask.ti;
	if invalidTask then
		return false;
	endif;
	if self.myCurrentTask.taskType = TASK_DIRECTOR then
		self.mnuTaskAmendSource.enabled := self.myCurrentTask.myEntry.getPreviousRelatedEntry() = null; //epr par 31716 11/6/13
		self.mnuTaskEditRequest.enabled := true;		// May 2011 29097
		if self.myCurrentTask.status = TASK_COMPLETE then
			self.mnuTaskRevertDirector.enabled := true;
		else
			self.mnuTaskRevertDirector.enabled := false;
		endif;
		if self.myCurrentTask.machine &lt;&gt; null then
			self.mnuTaskTestTI.enabled	:= true;	
		else
			self.mnuTaskTestTI.enabled	:= false;
		endif;
		self.mnuTaskStatusComplete.enabled := false;	// 21/07/2010 cnwmh5 #24386
		request:=self.myCurrentTask.myEntry.getMyRequest;
		if request &lt;&gt; null and request.isKindOf(CM_DeliveryRequest) or request.isKindOf(CM_YardMoveRequest) then
			self.mnuQueryDirectorPlan.visible:= self.myCurrentTask.status &lt;&gt; TASK_COMPLETE; //jlier1 1/10/25 MTN-35633
		endif;
	elseif 	self.myCurrentTask.taskType = TASK_SETDOWN and
	self.myCurrentTask.status = TASK_COMPLETE then
		controller1 := ti.getPrimaryLocation(REAL_MODE);
		controller2 := ti.getPrimaryLocation(QUEUE_MODE);
		if controller1 &lt;&gt; null and controller1.myTerminalArea &lt;&gt; null and controller1.myTerminalArea.isA(CM_CraneTransferArea) and
		controller2 &lt;&gt; null and controller2.isA(CM_SlotController) then
			//if ti.isExport or ti.isRehandle then							// PAR #25021
			if ti.isExport or ti.isTranshipOutbound or ti.isRehandle then	// PAR #25021
				self.mnuMoveToShip.enabled := true;
			endif;
		endif;
	elseif self.myCurrentTask.taskType = TASK_MOVE then
		self.mnuTaskStatusComplete.enabled := false;	// cnwrd1 par 30335 6.9.2012
	else
		self.mnuTaskAmendSource.enabled := false;
		self.mnuTaskEditRequest.enabled := false;		// May 2011 29097
		self.mnuTaskRevertDirector.enabled	:= false;
		self.mnuTaskTestTI.enabled			:= false;
		self.mnuTaskStatusComplete.enabled := true;		// 21/07/2010 cnwmh5 #24386
	endif;
	//epr par 32440 12/3/15
	self.mnuTaskAmendTarget.enabled := true;	
	//cnwas3 par 25707 - disable amend source/target location menu entries for multiple selected queues
	if self.tblQEntries.allSelectedObjects.size() &gt; 1 then
		self.mnuTaskEditRequest.enabled := false;		// May 2011 29097
		self.mnuTaskAmendICTarget.visible := false;
	else
		self.mnuTaskAmendICTarget.visible := self.canAmendTaskICTarget();
	endif;
	
	if self.myCurrentTask.taskType = TASK_PICKUP and self.myCurrentTask.status = TASK_UNACTIONED then
		self.mnuWeigh.enabled := true;
	else
		self.mnuWeigh.enabled := false;
	endif;
	
	sideAccessDirection:=null;
	self.myCurrentTask.isOverStowedRTQueue(overstowed,overstowedAtMoveTime,sideAccessDirection);
	if overstowedAtMoveTime then
		self.mnuTaskShowOverstow.visible := true;
		self.mnuTaskMoveOverstow.visible := true;
	endif;
	if ti &lt;&gt; null then		// PAR 21532 CCMS SFW 1025
		on Exception do app.handleDeletedObject(exception, ti, invalidTI);
		if ti.myPrimaryActualLocation  &lt;&gt; null and
			ti.myPrimaryActualLocation.isKindOf(CM_GridController) then
			self.mnuTaskShowGrid.visible := true;
		endif;
		
	endif;
	
	if self.myCurrentTask.isDirectorWithAssignedTI then  //cnwrd1 par 28628 29.11.11
		self.mnuTaskRevertDirector.enabled := true;
	else
		self.mnuTaskRevertDirector.enabled := false;
	endif;
	
	self.mnuTaskEnqContainer.visible:=	ti &lt;&gt; null;
		
	self.buildAllocateMenu();
	self.buildIMVSwitchMenu();//cnwrd1 par 23362 22.4.2010
	self.buildRTMoveMethodMenu();
	self.buildTaskSwitchJobMenu(); //cnwrd1 ccms 1303
	
	self.mnuAlerts.enabled := self.myCurrentEntry.alerts.size &gt; 0;
	
	
	
	if invalidEntry then
		return false;
	endif;
	self.mnuTaskOverideHalt.checked := not (self.myCurrentEntry.overRideFlags = null);
	
		
	if self.myCurrentTask.taskType = TASK_PICKUP and self.myCurrentTask.isPlanOnPickupNoTarget then
		self.mnuAutoPlan.visible := true;
	else
		self.mnuAutoPlan.visible := false;
	endif;

	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowMachineIconLegend" id="1a6947cc-d084-4108-8fb4-daabbe242dd5">
        <updating/>
        <source>doShowMachineIconLegend() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2011	#cnwdz2	 27747

*/

vars
	invalidForm : Boolean;
begin
	on Exception do app.handleDeletedObject( exception, self.myLegendForm, invalidForm);
	if self.myLegendForm = null then
		create self.myLegendForm transient;
	endif;
	
	self.myLegendForm.edition();
	if invalidForm then
		create self.myLegendForm transient;
	endif;
	
	if self.myLegendForm.windowState = Form.WindowState_Minimized then
		self.myLegendForm.windowState := Form.WindowState_Normal;
		self.myLegendForm.setFocus;
	endif;
	self.myLegendForm.centreWindow;
	self.myLegendForm.show;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowMnuQueue" id="65d6b514-c3f1-4664-9a4e-e19bf3c809e8">
        <source>doShowMnuQueue(pX, pY : Integer);
// ---------------------------------------------------------------------------
// Created:     11 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  -------------------------------------------------------------
// 20/11/2012	cnwdap1		PAR #30762 CCMS QNS 2233 Only enable the queue suspend/resume
// 							menu if the item selected is a queue
// --------------------------------------------------------------------------------------
vars
	theQueue	: CM_RadioTelemetryQueue;
	theEntry	: CM_RTQueueEntry;
	theObj		: Object;
	menu		: MenuItem;
	machine		: CM_Machine;
	cta 		: CM_CraneTransferArea;
begin
	self.mnuQueueCTA.visible:=false;
	self.mnuQueueCTA.userObject:=null;
	self.mnuQueueBroadcastMsg.visible := false;
	self.mnuQueueEdit.visible := false;
	self.mnuQueueSuspend.visible := false;								// PAR #30762
	self.mnuQueueResume.visible := false;								// PAR #30762
	
	theObj := lstQueues.listObject;
	if theObj = null then
		return;
	endif;
	
	
	if theObj.isKindOf(CM_RadioTelemetryQueue) then
		theQueue := theObj.CM_RadioTelemetryQueue;
		self.mnuQueueBroadcastMsg.visible := true;
		self.mnuQueueEdit.visible := not theObj.isKindOf(CM_MasterQueue);
		self.mnuQueueSuspend.visible := (theQueue.status &lt;&gt; QSTATUS_HELD);
		self.mnuQueueResume.visible := (theQueue.status = QSTATUS_HELD);
		self.loadMachineSubMenu(theQueue);
		self.mnuInspectQueue.visible:=app.isAllowedToInspect;
		if theObj.isKindOf(CM_VoyageCraneQueue) then
			cta:=theObj.CM_VoyageCraneQueue.crane.transferArea;
			if cta &lt;&gt; null then
				self.mnuQueueCTA.visible:=true;
				self.mnuQueueCTA.userObject:=cta;
			endif;
		endif;
		
	elseif theObj.isKindOf(CM_RTQueueEntry) then
		theEntry := theObj.CM_RTQueueEntry;
		
		self.loadMachineSubMenu(theEntry.myQueue);
	else
		return;
	endif;

	self.popupMenu(mnuQueue, pX, pY);
	
end;</source>
        <Parameter name="pX" type="Integer"/>
        <Parameter name="pY" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSingleTaskComplete" id="7b746457-9a2f-4c65-b4b8-b871ec5ee6e6">
        <source>doSingleTaskComplete(	_task 		: CM_RTQueueTask input;
						_completeAll,
						_completePickupAndSetdown: Boolean;
						_taskMachine,
						_imv : CM_Machine input;
						_moveQuantity: Integer;
						_moveWeight : Decimal) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 February 2011	cnwer1	Initial creation
10/03/2011			cnwmh5	PAR #27142 - Change where handleDeletedObject is armed
*/

vars
	
	theEntry 	: CM_RTQueueEntry;
	invalidObj 	: Boolean;
	edition,
	result 		: Integer;
begin

	if not checkCurrentObjects() then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	on Exception do app.handleDeletedObject(exception,_task,invalidObj);

	edition:=_task.edition;
	
	if invalidObj then 
		return;
	endif;
	
	// Task can be deleted during process.
	while true do
		app.myTrxUA.trxCompleteRTQueueEntry(_task,_completeAll,_completePickupAndSetdown,_taskMachine,_imv,_moveQuantity, _moveWeight, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Complete RT Entry', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			else
				break;
			endif;
		endif;
	endwhile;
		
	
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="_task" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_completeAll" type="Boolean"/>
        <Parameter name="_completePickupAndSetdown" type="Boolean"/>
        <Parameter name="_taskMachine" type="CM_Machine" usage="input"/>
        <Parameter name="_imv" type="CM_Machine" usage="input"/>
        <Parameter name="_moveQuantity" type="Integer"/>
        <Parameter name="_moveWeight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="doStartEntryRefreshTimer" id="ea367fd4-ea54-421a-ac32-9950e995a09f">
        <updating/>
        <source>doStartEntryRefreshTimer() updating, protected;
//
// 14 Sep 2016	cnwrs1			FTS 2629 PAR #38163 JMT going slow
//
constants
	MinimumDelay = 100;
vars
	delay : Integer;
begin
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;self.refreshEntityTimerStarted.String;
	if not self.refreshEntityTimerStarted then
		// Make the delay at least twice the time it last took to refresh the tables, with a pre-defined minimum
		delay := self.lastEntityRefreshTimeElapsed * 2;
		delay := delay.max(MinimumDelay);
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;delay.String;
		
		self.beginTimer(delay, Timer_OneShot, self.Timer_EntryRefresh);
		self.refreshEntityTimerStarted := true;
	endif;
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doStartRefreshTimer" id="e654b66f-c905-4629-a104-3dac6d1281c9">
        <updating/>
        <source>doStartRefreshTimer() updating, protected;
//
// 14 Sep 2016	cnwrs1			FTS 2629 PAR #38163 JMT going slow
//
constants
	MinimumDelay = 2000;
vars
	delay : Integer;
begin
	if not self.refreshTimerStarted then
		// Make the delay at least twice the time it last took to refresh the tables, with a pre-defined minimum
		delay := self.lastRefreshTimeElapsed * 2;
		delay := delay.max(MinimumDelay);
		
		self.beginTimer(delay, Timer_OneShot, self.Timer_Refresh);
		self.refreshTimerStarted := true;
	endif;
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTaskJobSwitch" id="b96e3d1e-c927-481b-867b-d2f3ff0d4aca">
        <source>doTaskJobSwitch( _newJob : CM_Job);

/*

Purpose:		a voyage allocation loading task is being moved to a new (matching) job, which should have space.	

Parameters:			

Return Value:		


Date		Who		Reason
29 November 2012	cnwrd1	Initial creation

*/

vars
	task			: CM_RTQueueTask;
	theNewJob,
	theOldJob		: CM_Job;
	invalidObj		: Boolean;
	lResult,
	result			: Integer;
	/*lCaption	: String;
	mnuChild	: MenuItem;
	mnuIndex 	: Integer;
	count		: Integer;
	obj			: Object;
	task		: CM_RTQueueTask;
	aJob		: CM_Job;
	theVoyageJob,
	aVoyageJob 			: CM_VoyageJob;
	aVoyageRequest 		: CM_VoyageRequest;
	aVoyageAllocation 	: CM_VoyageAllocation;
	theVoyage 			: CM_Voyage;
	theVoyageJobs		: CM_JobSet;
	aRequest 			: CM_Request;*/
begin
	
	task := self.myCurrentTask;	
	
	if task = null then
		return;
	endif;
	
	theNewJob := _newJob;
	theOldJob := task.myEntry.myJob;
	
	
	/*
	in the trx we want to 
	find the next 'clear' wle on the new job
	switch that with the tasks wle via the release
	update the jobs ti collections
	sort out any task/target/queue issues
	*/
	
		
	on Exception do app.handleDeletedObject(exception,task,invalidObj);	
	
	// ask for confirmation?
	lResult := app.msgBox(app.getErrorString3(Shift_cargo_item_from_voyag_vo, task.ti.id,theOldJob.id ,theNewJob.id), app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon); 
	
	
	if lResult = MsgBox_Return_Yes then
	
		app.mousePointer := MousePointer_HourGlass;
		
			
		// Task can be deleted during process.
		while true do
			app.myTrxUA.trxUpdateTaskSwitchJobs( task,null, theOldJob,theNewJob,  app.myPassport) ; //cnwrd1 par 34038
			if app.myPassport.trxCompletedOK then
				break;
			else
				result := app.showErrorWarningDialog('Change task Job', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
					result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				else
					break;
				endif;
			endif;
		endwhile;
	endif;	
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_newJob" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="doTaskStatus" id="f31fe4f3-1e40-419f-b82b-bb1abd26b071">
        <updating/>
        <source>doTaskStatus(_newStatus : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     17 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/03/2011	cnwmh5		PAR #27142 - Change where handleDeltedObject is armed
// ---------------------------------------------------------------------------
vars
	theTask		: CM_RTQueueTask;
	lResult		: Integer;	
	result		: Integer;
	obj			: Object;
	objArray	: ObjectArray;
	invalidObj	: Boolean;
	str			: String;
	stillRequiresHold : Boolean;
	reason : String;
begin

	if not checkCurrentObjects() then
		return;
	endif;
		
	on Exception do app.handleDeletedObject(exception,theTask,invalidObj);	
	theTask:=self.myCurrentTask;
	
	//21 April 2015	NDL	Par 36014
	if theTask.status = TASK_SYS_HELD then
		//23 Feb 2016	NDL	Par 37572
		stillRequiresHold := theTask.requiresSystemHold(false, null, reason);
		if stillRequiresHold then
			app.msgBox(app.getErrorString2(ERR_TASK_STATUS_CHANGE, theTask.statusString, theTask.getStatusStr(_newStatus)), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	endif;
	
	lResult := app.msgBox(app.getErrorString3(ConfirmChange, "task status", theTask.statusString,theTask.getStatusStr(_newStatus)), app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon); 
	if lResult = MsgBox_Return_Yes then
	
		app.mousePointer := MousePointer_HourGlass;
		
		on Exception do app.handleDeletedObject(exception,theTask,invalidObj);
		
		create objArray transient;
		self.tblQEntries.allSelectedObjects.copy(objArray);
		
		
		foreach obj in objArray do
			invalidObj := false;  //cnwjo3 par 25669
			
			theTask := obj.CM_RTQueueTask;
			str := theTask.queueId;  //cnwjo3 par 25669 cause exception if invalid object
			if invalidObj then  //cnwjo3 par 25669
				continue;
			endif;
			
			// Task can be deleted during process.
			while true do
				app.myTrxUA.trxUpdateQueueTaskStatus(theTask, _newStatus, app.myPassport);
				if app.myPassport.trxCompletedOK then
					break;
				else
					result := app.showErrorWarningDialog('Change task status', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
						result = IDOK then
						// there must have just been warnings that the user has acknoledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					else
						break;
					endif;
				endif;
			endwhile;
		endforeach;
	endif;	
	
epilog
	
	delete objArray;
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTestATrackedItem" id="62a72ad4-858c-406c-8cf0-25be43e1359f">
        <updating/>
        <source>doTestATrackedItem() protected, updating;
// -------------------------------------------
// Created 10 November 2003 by cnwdvb1
// -------------------------------------------
vars

	myForm : CMUI_TestTi;

begin

	create myForm;
	myForm.type := GetData_TestTi;
	myForm.myCaller := self;
	myForm.centreWindow;
	if self.myCurrentTask &lt;&gt; null then
		if self.myCurrentTask.taskType = TASK_DIRECTOR and self.myCurrentTask.machine &lt;&gt; null then
			self.myTaskWhenSubFormOpened := self.myCurrentTask;
			myForm.setInitialValues(self.myCurrentTask);
			myForm.show;
		endif;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTransactionLoopCompleted" id="2b89c796-89bc-4008-8caa-4015c27efa63">
        <source>doTransactionLoopCompleted(_errorMessage :String) :Boolean;
// adm 110609 Par 18942
vars
	result :Integer;
begin
	if app.myPassport.trxCompletedOK then
		return true;
	else
		result := app.showErrorWarningDialog(_errorMessage, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
		if app.myPassport.noErrors and
			result = IDOK then
			// there must have just been warnings that the user has acknowledged so ..
			app.myPassport.warningsAcknowledged	:= true;
			return false;
		else
			return true;
		endif;
	endif;
end;</source>
        <Parameter name="_errorMessage" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUnload" id="58344f9d-7933-4e7d-be83-1c6b5cfb1996">
        <source>doUnload() protected;
// -------------------------------------------
// Created 08 April 2004 by cnwdvb1
// -------------------------------------------
// 14 Sep 2016	cnwrs1			FTS 2629 PAR #38163 JMT going slow
vars

begin
	self.allEventLists.purge();
//	on Exception do null global;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUserNotify" id="f382bd53-9793-4704-b8ae-92d9f218e64a">
        <updating/>
        <source>doUserNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, protected;
// -------------------------------------------
// Created 18 September 2003 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
20 May 2009	cnwkpd1	PAR #18769 - Remove isValidObject calls for performance
01/12/2009	cnwmh5	PAR #21315 - Add test to check whether queue is null and
					if so then return
02 Dec 2009 cnwer1	PAR 21815 - changes so deleting queue entry does not refresh the whole form
12 Mar 2010	cnwkpd1	PAR #23167 - Still more changes to prevent whole form from refreshing when a 
					Queue Entry is deleted
17 Mar 2011 cnwer1	PAR #26986  - noticed a refresh issue if you had selected an entry in the table and that
								was deleted the table entry was not being removed
12 Apr 2011	cnwjre1	PAR 26339	add exception handler for origQueue
// 14 Sep 2016	cnwrs1			TFS 2629 PAR #38163 JMT going slow
16 Sep 2016	cnwdap1	TFS 2629 ITS / RTQ notification issues
16 Sep 2020	jlgdap1	TFS 49316 MTN Machine Idle Time
03/10/2022 	navds21 TFS 50083 MTN - Machine Delay Idle Time
14 Jan 2026 navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
*/

vars
	lObj,
	userInfoObject 			: Object;
	previousIdx,
	idx, 
	lParentPos,
	orgParent,
	lEntries, 
	lLevel, 
	me						: Integer;
	str 					: String;
	event					: Integer;
	queue,
	origQueue,
	selectedQueue,
	lParentObj				: CM_RadioTelemetryQueue;
	machine 				: CM_Machine;
	myListObj				: Object;
	isExpanded,
	invalidObject,
	invalidQueueObj,
	invalidListObj,
	userInfoTypeOfObject 	: Boolean;
	state, 
	objEdition				: Integer;
	machineRemovedFromQueue, 
	had14022ex 				: Boolean;
	note 					: CM_EventList;
	row, 
	colour 					: Integer;						// TFS 49316
	mach 					: CM_Machine;					// TFS 49316
	queueDisplayStr, 
	bubbleHelpStr 			: String;	// TFS 49316
begin
	on Exception do app.handleDeletedObject(exception, theObject, invalidObject);			
	on Exception do app.handleDeletedObject(exception, myListObj, invalidListObj);
	on Exception do app.handleDeletedObject(exception, origQueue, invalidQueueObj);
	
	//epr par 21815 2/12/09 removed exception handler for invalidUserInfo - when that and theObject are the exception would be caught in incorret exception handler
	
	if userInfo.isKindOf(Object) then
		userInfoObject := userInfo.Object;
		userInfoTypeOfObject := true;
	endif;
	
	if self.tblMachines.dragMode = DragMode_Drag then
		return;
	endif;

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	//epr par 21815 2/12/09
	//if event = RTQueueEntry_Update_Event  then									// TFS 2629
	if event = RTQueueEntry_Update_Event or event = RTQueueEntry_Alert_Event then	// TFS 2629
		objEdition := theObject.edition;
		if invalidObject then
			return;
		endif;
	endif;
	
	self.deselectRTQueueEntry( theObject );	//17 July 2014	NDL	Par 25646
		
	
	// Get list object for later reset.
	myListObj := self.lstQueues.listObject;
	if myListObj &lt;&gt; null and myListObj.isKindOf(CM_RadioTelemetryQueue) then
		selectedQueue := myListObj.CM_RadioTelemetryQueue;
		
	endif;
	
	if event = RTQueue_Create_Event then
		// Lets redraw everything.
		//self.loadQueues(false);
		self.doStartRefreshTimer();	//PAR #38163
		
	elseif event = RTQueueEntry_Delete_Event or event = RTQueue_Delete_Event then
		
		// PAR #23167 - Tidy up to resolver performance issue when reloading form after deletes
		
		// Find the object in the listbox.
		idx := self.lstQueues.findObject(theObject);
		// If we can't find it then quit.
		if not idx &gt; 0 then
			//self.loadQueues(true);  //cnwrd1 par 25507 19.8.2010 - if we cant find it, we dont have it, its deleted, so do nothing not refresh!
			return;
		endif;
		// Where is our parent living.
		lParentPos := self.lstQueues.getParentIndex(idx);
		
		// What is our parent object.
		if lParentPos &gt; 0 then
			lObj := self.lstQueues.itemObject[lParentPos];
		endif;
		// Remove deleted entry.
		if idx &gt; 0 then
			self.lstQueues.removeItem(idx);
		endif;
	
		// Are we dealing with a queue entry.
		if event = RTQueueEntry_Delete_Event then
			// Do we have a valid object.
			if global.isValidObject(lObj) then
				// Make sure it is a queue.
				if lObj.isKindOf(CM_RadioTelemetryQueue) then
					lParentObj := lObj.CM_RadioTelemetryQueue;
					// What a we currently looking at.
					if selectedQueue &lt;&gt; null  and selectedQueue.includesQueue(lParentObj.CM_RadioTelemetryQueue) or
						myListObj = theObject then  //epr 17/3/2011 - par 26986  fixed up refresh issue found aswell
						// Remove our task from table and update machine.
						self.showRefreshTask(theObject.CM_RTQueueEntry, State_Delete,true);
						self.showMachinesForQueue(self.lstQueues.listObject.CM_RadioTelemetryQueue, false);
						
						//epr 30671 9/11/12 the rt queue entry was the selected listObject set to the parent listObject
						if myListObj = theObject then 
							self.lstQueues.listObject := lParentObj;
						endif;
					endif;
					//epr 17/3/2011 -  par 26986  fixed up refresh issue found aswell not sure how invalidListObj is set myListObj is only set from  self.lstQueues.listObject and never referenced to be
					// able to raise an exception lstQueues.listObject may be null if it was a rtQueueEntry and that itemRow has been removed
					
					if invalidListObj then //or self.lstQueues.listObject  = null then
						// We are looking at deleted object. Redraw parent items.
						self.lstQueues.listObject := lParentObj;
						self.showQueueThumbnail(lParentObj);
					endif;
					
					// Change parent display.
					if lParentPos &gt; 0 and lParentObj &lt;&gt; null then
						//str := lParentObj.CM_RadioTelemetryQueue.getQueueDisplay();				// TFS 49316
						str := lParentObj.CM_RadioTelemetryQueue.getQueueDisplay(colour);			// TFS 49316
						self.lstQueues.itemText[lParentPos] := str;
						if colour = self.myTerminal.getConfig(IdleTimeColour).Integer then			// TFS 49316
							self.lstQueues.itemBackColor[lParentPos] := colour;						// TFS 49316
						else
							self.lstQueues.itemBackColor[lParentPos] := self.lstQueues.backColor;	// TFS 49316
						endif;																		// TFS 49316
					endif;
				endif;
			endif;
		endif;

	//elseif event = RTQueueEntry_Update_Event or event = RTQueue_Update_Event then										// TFS 2629
	elseif event = RTQueueEntry_Update_Event or event = RTQueueEntry_Alert_Event or event = RTQueue_Update_Event then	// TFS 2629
		
		// We have to update this queue.
		if theObject.isKindOf(CM_RadioTelemetryQueue) then
			//self.loadQueues(true);
			self.doStartRefreshTimer();	//PAR #38163
		else 
			// Find entry in listbox.
			me := self.lstQueues.findObject(theObject);
			// If entry was found check if there is a userObject if so it is probably a drag and drop so do screen update imediatley PAR #38163.
			if me &gt; 0 and userInfoTypeOfObject then
				self.loadQueueEntry(theObject, userInfo);	//PAR #38163
			else
				if self.allEventLists[theObject, event] = null then
					create note transient;
					note.object := theObject.CM_Object;
					note.eventNo := event;
					if userInfoTypeOfObject then
						note.userInfo := userInfoObject;
					endif;
					self.allEventLists.add(note);
				endif;	
				self.doStartEntryRefreshTimer();	//PAR #38163
				//self.loadQueueEntry(theObject, userInfo);	//PAR #38163
			endif;
		endif;
	
	elseif event = RTMachine_Update_Event then
		queue := null;
		myListObj := self.lstQueues.listObject;
	
		if myListObj &lt;&gt; null then
			if myListObj.isKindOf(CM_RadioTelemetryQueue) then
				queue := myListObj.CM_RadioTelemetryQueue;
			else
				queue := myListObj.CM_RTQueueEntry.myQueue;
			endif;
		endif;

		//cnwjo3 par 25713
		if userInfo &lt;&gt; null and userInfo.isKindOf(CM_RadioTelemetryQueue) then
			if queue = userInfo.CM_RadioTelemetryQueue then
				machineRemovedFromQueue := true;
			endif;
		endif;
		
		if queue &lt;&gt; null and theObject.isKindOf(CM_Machine) then 
			machine := theObject.CM_Machine;
			if machineRemovedFromQueue or self.allViewedMachines.includes(machine) or machine.allQueues.includes(queue) or machine.myPrimaryQueue = queue then
				self.showMachinesForQueue(queue, true);
				me := self.lstQueues.findObject(queue);									// TFS 49316
				if me &gt; 0 then															// TFS 49316
					self.lstQueues.itemText[me] := queue.getQueueDisplay(colour);		// TFS 49316
					if colour = self.myTerminal.getConfig(IdleTimeColour).Integer then	// TFS 49316
						self.lstQueues.itemBackColor[me] := colour;						// TFS 49316
					elseif colour = self.myTerminal.getConfig(DelayTimeColour).Integer then //03.10.2022 navds21 TFS 50083
						self.lstQueues.itemBackColor[me] := colour;							//03.10.2022 navds21 TFS 50083
					else																// TFS 49316
						self.lstQueues.itemBackColor[me] := self.lstQueues.backColor;	// TFS 49316
					endif;																// TFS 49316
				endif;																	// TFS 49316
			endif;
		endif;
		
	// TFS 49316 handle machine idle specific notification events
	// TFS 50083 and machine setdown delay specific notification events
	elseif event = Event_MachineIdle or event = Event_MachineIdleStop 
	or event = Event_MachineDelay or event = Event_MachineDelayStop then	// TFS 50083
		// machine has just gone idle
		if theObject = null or not theObject.isKindOf(CM_Machine) then
			return;
		endif;
		
		machine := theObject.CM_Machine;
		foreach row in self.tblMachines.fixedRows + 1 to self.tblMachines.rows do
			mach := self.tblMachines.accessRow(row).itemObject.CM_Machine;
			if mach = machine then
				queue := machine.myPrimaryQueue;
				colour := self.getTblMachineDisplayString(machine, queue, queueDisplayStr, bubbleHelpStr);
				self.tblMachines.accessCell(row, 1).text := queueDisplayStr &amp; Tab &amp; bubbleHelpStr;
				self.tblMachines.accessedCell.backColor := colour;
				me := self.lstQueues.findObject(queue);
				if me &gt; 0 then
					self.lstQueues.itemText[me] := queue.getQueueDisplay(colour);
					if colour = self.myTerminal.getConfig(IdleTimeColour).Integer then
						self.lstQueues.itemBackColor[me] := colour;
					elseif colour = self.myTerminal.getConfig(DelayTimeColour).Integer then		// TFS 50083
						self.lstQueues.itemBackColor[me] := colour;								// TFS 50083
					else
						self.lstQueues.itemBackColor[me] := self.lstQueues.backColor;
					endif;
				endif;
				break;
			endif;
		endforeach;
	// TFS 49316 end
	
	endif;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
