    <JadeMethod name="defaultAmountPerItem" id="8261ef81-cfe0-41ed-a378-7a1d40e86fd3">
        <source>defaultAmountPerItem( _clearIfNotSet : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2014	cnwndl1	Initial creation

*/

vars

	subCargoType : CM_Product;
	cargoType : CM_CargoType;
	measureType : CM_MeasurementType;
	value : Decimal [12,3];

begin

	measureType := app.getDefaultMeasurementForType(Type_Weight);

	subCargoType := self.cmbNewProduct.listObject.CM_Product;
	if subCargoType &lt;&gt; null then
		if self.myTrackedItem.isBulkByVolume then
			measureType := app.getDefaultMeasurementForType(Type_Volume);
			if subCargoType.getMyVolume &lt;&gt; null and subCargoType.getMyVolume.myMeasurementType &lt;&gt; null then
				measureType := subCargoType.getMyVolume.myMeasurementType;
				value := subCargoType.getMyVolume.getRawValue;
				if value &gt; 0 and measureType &lt;&gt; null then	
					self.tblAmountPerItem.setValues( app.convertMeasurementForDisplay(measureType.shortName, value) &amp; Space &amp; measureType.shortName);
					return;
				endif;
			endif;
			
		elseif self.myTrackedItem.isBulkByWeight then
			if subCargoType.getMyWeight &lt;&gt; null and subCargoType.getMyWeight.myMeasurementType &lt;&gt; null then
				measureType := subCargoType.getMyWeight.myMeasurementType;
				value := subCargoType.getMyWeight.getRawValue;
				if value &gt; 0 and measureType &lt;&gt; null then	
					self.tblAmountPerItem.setValues( app.convertMeasurementForDisplay(measureType.shortName, value) &amp; Space &amp; measureType.shortName);
					return;
				endif;
			endif;
			
		endif;
	endif;
	
	cargoType := self.cmbNewCargoType.listObject.CM_CargoType;
	if cargoType &lt;&gt; null then
		if self.myTrackedItem.isBulkByVolume then
			measureType := app.getDefaultMeasurementForType(Type_Volume);
			if cargoType.mySystemProductType &lt;&gt; null then
				if cargoType.mySystemProductType.getMyVolume &lt;&gt; null and cargoType.mySystemProductType.getMyVolume.myMeasurementType &lt;&gt; null then
					measureType := cargoType.mySystemProductType.getMyVolume.myMeasurementType;
					value := cargoType.mySystemProductType.getMyVolume.getRawValue;
					if value &gt; 0 and measureType &lt;&gt; null then	
						self.tblAmountPerItem.setValues( app.convertMeasurementForDisplay(measureType.shortName, value) &amp; Space &amp; measureType.shortName);
						return;
					endif;
				endif;
			else
				measureType := cargoType.myVolumeMeasurementType;
				if cargoType.defaultVolume &gt; 0 and measureType &lt;&gt; null then
					value := cargoType.defaultVolume;
					if value &gt; 0 and measureType &lt;&gt; null then	
						self.tblAmountPerItem.setValues( app.convertMeasurementForDisplay(measureType.shortName, value) &amp; Space &amp; measureType.shortName);
						return;
					endif;
				endif;
			endif;
			
		elseif self.myTrackedItem.isBulkByWeight then
			if cargoType.mySystemProductType &lt;&gt; null then
				if cargoType.mySystemProductType.getMyWeight &lt;&gt; null and cargoType.mySystemProductType.getMyWeight.myMeasurementType &lt;&gt; null then
					measureType := cargoType.mySystemProductType.getMyWeight.myMeasurementType;
					value := cargoType.mySystemProductType.getMyWeight.getRawValue;
					if value &gt; 0 and measureType &lt;&gt; null then	
						self.tblAmountPerItem.setValues( app.convertMeasurementForDisplay(measureType.shortName, value) &amp; Space &amp; measureType.shortName);
						return;
					endif;
				endif;
			else
				measureType := cargoType.myWeightMeasurementType;
				if cargoType.defaultWeight &gt; 0 and measureType &lt;&gt; null then
					value := cargoType.defaultWeight;
					if value &gt; 0 and measureType &lt;&gt; null then	
						self.tblAmountPerItem.setValues( app.convertMeasurementForDisplay(measureType.shortName, value) &amp; Space &amp; measureType.shortName);
						return;
					endif;
				endif;
			endif;
			
		endif;
		
	endif;
	
	if _clearIfNotSet then
		if measureType &lt;&gt; null then
			self.tblAmountPerItem.setValues( app.convertMeasurementForDisplay(measureType.shortName, 0.00) &amp; Space &amp; measureType.shortName);
		endif;
	endif;
	

epilog

	self.populateNewItems();

end;</source>
        <Parameter name="_clearIfNotSet" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="1136b4f7-9af5-485e-84ae-a7d85395d2f3">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

begin

	if not self.doPackageBulk() then
		return;
	endif;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPackageBulk" id="daba7522-09ac-4037-8b6e-5d0e98830a83">
        <updating/>
        <source>doPackageBulk():Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars
	itemNettWeight 	: Decimal[14,4];
	pkgingWeight 	: Decimal[14,4];
	allTiIds : StringArray;
	quantityPerId : Integer;
	operator : CM_Operator;
	cargoType : CM_CargoType;
	product : CM_Product;
	location : CM_LocationsController;
	
	theReturn : Integer;
	txnController : CMIF_TITransactionController;
	newTITxn : CM_TITransaction;
begin

	create allTiIds transient;
	if not self.validate( allTiIds, quantityPerId, itemNettWeight, location ) then
		return false;
	endif;
	
	pkgingWeight := self.tblPkgingWeight.getConvertedValue();
	operator := self.cmbOperator.listObject.CM_Operator;
	product := self.cmbNewProduct.listObject.CM_Product;
	cargoType := self.cmbNewCargoType.listObject.CM_CargoType;

	while true do 
	
		app.myTrxUA.trxPackageBulk(	self.myTrackedItem.CM_Bulk,	//_sourceTi : CM_Bulk;
									allTiIds,	//_newTiIds : StringArray;
									quantityPerId,	//_quantityPerId : Integer;
									itemNettWeight,	// _itemNettWeight : Decimal;
									cargoType,	//_cargoType : CargoType;
									product,	//_product : CM_Product;
									operator,	//_operator : CM_Operator;
									pkgingWeight,	// _pkgingWeight : Decimal;
									location,	//_lc : CM_LocationsController
									app.myPassport	//_passport : CM_Passport input
									);
	
		
		if not app.myPassport.trxCompletedOK then	
			theReturn := app.showErrorWarningDialog(app.getErrorString(Split_breakbulk), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
		
	endwhile; 
	
	//02 Oct 2017	NDL	TFS 5744
	if self.myTrackedItem &lt;&gt; null then
		if app.msgBox(app.getErrorString( Packaging_complete ), app.getErrorString(Complete), MsgBox_Yes_No ) = MsgBox_Return_Yes then
			
			create txnController transient;
			txnController.type := TRANS_TYPE_PACKAGE_COMPLETED;
			txnController.noCharge := false; 
			txnController.myTerminal := self.myTerminal;
			txnController.myTrackedItem := self.myTrackedItem;
			
			app.myTrxCA.trxCreateTITransaction(txnController, newTITxn, app.myPassport);
			
		endif;
	endif;
	
	return true;

epilog

	delete allTiIds;
	delete txnController;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="c942c134-6f49-4ec4-9b74-82090c5f7eb5">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

begin

	self.grpMain.top := 1;
	self.grpMain.left := 1;

	self.width := self.grpMain.width + 20;
	self.height := self.grpMain.height + 80;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getWeightMovedKgs" id="8602fa4e-2f93-4284-905a-654303a1124f">
        <source>getWeightMovedKgs() : Decimal;
/*

Date		Who		Reason
19 March 2014	cnwer1	Initial creation PAR

*/

vars
	ct : CM_CargoType;
	kgValue, volume  : Decimal[14,4];

begin
	if self.myTrackedItem = null then
		return null;
	endif;
	
	ct:=self.myTrackedItem.myCargoType;
	if ct.isTrackByWeight then
		kgValue:=self.tblAmountPerItem.getConvertedValue();
		
	else
		volume:=self.tblAmountPerItem.getConvertedValue();
		kgValue:= volume * self.myTrackedItem.getDensity;

	endif;
	
	if kgValue = null then
		return self.myTrackedItem.totalWeight;
	endif;
	return kgValue;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
