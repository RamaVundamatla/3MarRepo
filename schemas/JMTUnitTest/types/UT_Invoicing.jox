						self.assertEqualMsg(invLine.lineTotal, 280.Decimal, "Cargo inv 7 total pass " &amp; _pass.String);
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStoreFree4", "Cargo inv 7 ILD pass " &amp; _pass.String);
					endif;
				endforeach;
			endif;
			if transCount = 2 then
				self.assertEqualMsg(invCount, 7, "Cargo second storage invoice lines pass " &amp; _pass.String);
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(transCount, 2, "Cargo storage transactions pass " &amp; _pass.String);
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_pass" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateEscalatingCharges5b" id="0234e867-57f1-4971-8cbb-944b494bc7d2">
        <source>validateEscalatingCharges5b(_ti : CM_TrackedItem; _pass : Integer);

vars
	transCount,
	invCount	: Integer;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
begin
	foreach trans in _ti.allTransactions do
		if trans.isKindOf(CM_Storage) then
			transCount := transCount + 1;
			if transCount = 2 then
				invCount := 0;
				foreach invLine in trans.allInvoiceLines do
					invCount := invCount + 1;
					if invCount = 1 then
						self.assertEqualMsg(invLine.quantity, 5.Real, "Cargo inv 1 quantity pass " &amp; _pass.String);
						self.assertEqualMsg(invLine.lineTotal, 100.Decimal, "Cargo inv 1 total pass " &amp; _pass.String);
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStoreFree2", "Cargo inv 1 ILD pass " &amp; _pass.String);
					elseif invCount = 2 then
						self.assertEqualMsg(invLine.quantity, 10.Real, "Cargo inv 2 quantity pass " &amp; _pass.String);
						self.assertEqualMsg(invLine.lineTotal, 150.Decimal, "Cargo inv 2 total pass " &amp; _pass.String);
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStoreFree3", "Cargo inv 2 ILD pass " &amp; _pass.String);
					elseif invCount = 3 then
						self.assertEqualMsg(invLine.quantity, 10.Real, "Cargo inv 3 quantity pass " &amp; _pass.String);
						self.assertEqualMsg(invLine.lineTotal, 200.Decimal, "Cargo inv 3 total pass " &amp; _pass.String);
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStoreFree4", "Cargo inv 3 ILD pass " &amp; _pass.String);
					elseif invCount = 4 then
						self.assertEqualMsg(invLine.quantity, 10.Real, "Cargo inv 4 quantity pass " &amp; _pass.String);
						self.assertEqualMsg(invLine.lineTotal, 180.Decimal, "Cargo inv 4 total pass " &amp; _pass.String);
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStoreFree4", "Cargo inv 4 ILD pass " &amp; _pass.String);
					elseif invCount = 5 then
						self.assertEqualMsg(invLine.quantity, 10.Real, "Cargo inv 5 quantity pass " &amp; _pass.String);
						self.assertEqualMsg(invLine.lineTotal, 160.Decimal, "Cargo inv 5 total pass " &amp; _pass.String);
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStoreFree4", "Cargo inv 5 ILD pass " &amp; _pass.String);
					elseif invCount = 6 then
						self.assertEqualMsg(invLine.quantity, 10.Real, "Cargo inv 6 quantity pass " &amp; _pass.String);
						self.assertEqualMsg(invLine.lineTotal, 140.Decimal, "Cargo inv 6 total pass " &amp; _pass.String);
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStoreFree4", "Cargo inv 6 ILD pass " &amp; _pass.String);
					elseif invCount = 7 then
						self.assertEqualMsg(invLine.quantity, 5.Real, "Cargo inv 7 quantity pass " &amp; _pass.String);
						self.assertEqualMsg(invLine.lineTotal, 120.Decimal, "Cargo inv 7 total pass " &amp; _pass.String);
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStoreFree4", "Cargo inv 7 ILD pass " &amp; _pass.String);
					endif;
				endforeach;
			endif;
			if transCount = 2 then
				self.assertEqualMsg(invCount, 7, "Cargo second storage invoice lines pass " &amp; _pass.String);
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(transCount, 2, "Cargo storage transactions pass " &amp; _pass.String);
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
