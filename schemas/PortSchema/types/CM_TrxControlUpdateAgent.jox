    <JadeMethod name="trxMachineRejectTasks" id="191c7a4e-eb36-4a4d-a092-aea872da915e">
        <updating/>
        <source>trxMachineRejectTasks(	_machine : CM_Machine input;
						_rtQueueTasks :  CM_RTQueueTaskArray input;				
						_addToRejectList : Boolean;
						_passport : CM_Passport input) updating;
/*

Date		Who		Reason
09 May 2017	cnwer1	Initial creation TFS TFS 995 moved from MobileServerSchema::CM_TrxControlRTAgent::trxCancelTasks

*/

vars
	invalidTask : Boolean;
	rtEntry : CM_RTQueueEntry;
	rtQueueTask : CM_RTQueueTask;
	ed 			: Integer;
	allRTQueueTasks :   CM_RTQueueTaskArray;
begin
 // Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, _passport); //epr par 14718
	on Exception do app.handleDeletedObject(exception, rtQueueTask, invalidTask); //epr par 34879
	
	
	self.raiseExceptionIfNull(_machine,app.getErrorString(Machine));
	
	if app.myPassport.hasErrors then
		return;
	endif;	
	
	allRTQueueTasks:=_rtQueueTasks;
	if _rtQueueTasks = null then
		allRTQueueTasks:=_machine.allCurrentQueueTasks;
	endif;
	foreach rtQueueTask in allRTQueueTasks do
		//epr par 34879 11/9/14
		ed:=rtQueueTask.edition;
		if invalidTask then
			invalidTask:=false;
			continue;
		endif;
		app.myValUA.valMachineRejectTask(_machine,rtQueueTask,_addToRejectList);
		
		if app.myPassport.hasErrors then
			return;
		endif;
	endforeach;
	
	
	app.setContinueCMExceptions(false);

	beginTransaction;
	
	app.myUtilityUA.utlMachineRejectTasks(_rtQueueTasks,_machine ,_addToRejectList,_passport); 

epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_rtQueueTasks" type="CM_RTQueueTaskArray" usage="input"/>
        <Parameter name="_addToRejectList" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
