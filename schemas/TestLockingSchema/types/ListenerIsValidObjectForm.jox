<GUIClass name="ListenerIsValidObjectForm" id="4ec93466-890f-4315-9c68-80daac79cd44">
    <superclass name="Form"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="lstLog" id="46028aec-1baa-449e-b32a-d7fb597b315f">
        <embedded/>
        <type name="ListBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="load" id="28e38fa5-4fa6-4989-b9b8-a1fe627f52f3">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars

begin
	self.beginClassNotification(ParentClass, false, Any_System_Event, Response_Continuous, null);
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="logMsg" id="24647a74-6897-48a4-88b1-2f597fba95c4">
        <source>logMsg(_msg: String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars

begin
	self.lstLog.addItemAt(_msg, 1);
	inheritMethod(_msg);
	

epilog

end;</source>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="9a684972-4295-498f-b3e4-8718944f7c1d">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 March 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	invalid			: Boolean;
	s				: String;
	
begin
	if eventType = Object_Delete_Event then
		self.logMsg(method.qualifiedName &amp; " Object_Delete_Event " &amp; theObject.String);
		
	else
		if eventType = Object_Create_Event then
			s := "Object_Create_Event";
		else
			s := "Object_Update_Event";
		endif;
		
		if app.isValidObject(theObject) then
			self.logMsg(method.qualifiedName &amp; " " &amp; s &amp; " " &amp; theObject.ParentClass.getDescriptionIsValidObj());
		endif;
	
	endif;
	
	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</GUIClass>
