    <JadeMethod name="utlUpdateEDIFileForWeb" id="4726fcb5-5980-480e-9e15-00f4c1090b68">
        <updating/>
        <source>utlUpdateEDIFileForWeb(_ediFile: CM_EDIFile input; _originalMessage, _response: String; _responseTime: TimeStamp; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
21 August 2023		navmd1	Initial creation TFS 59024

*/

vars

begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_ediFile, 'EDI File');
	
	app.setContinueCMExceptions(true);
	
	if _ediFile = null then	
		app.raiseCMException1(ERR_INVALID_VALUE, 'ediFile (null)', 'ediFile', null);
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	exclusiveLock(_ediFile);
	
	if _passport.noErrors then
		// EDI Files are not currently audited
		//self.myUpdateAuditAgent.audUpdateGeneric(_ediFile, true);
	endif;
	
	if _passport.noErrors then
		_ediFile.setOriginalFileDataString(_originalMessage);
		_ediFile.setWebResString(_response);
		_ediFile.responseTimestamp := _responseTime;
	endif;
	
	if _passport.noErrors then
		// EDI Files are not currently audited
		//self.myUpdateAuditAgent.audUpdateGeneric(_ediFile, false);
		self.updateObjectEdition(_ediFile.ediData);
	endif;
epilog

end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_originalMessage" type="String"/>
        <Parameter name="_response" type="String"/>
        <Parameter name="_responseTime" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEDIFileFormat" id="bb2dbef9-05a9-447b-a462-9fc816abfbf2">
        <updating/>
        <source>utlUpdateEDIFileFormat(_pxyEDIFileFormat : CM_FileFormatEDI; _passport : CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	17 November 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	realEDIFileFormat	: CM_FileFormatEDI;
	expectedEdition		: Integer;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(false);

	if _pxyEDIFileFormat = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'the proxy object is null');
		return;
	endif;
	
	_pxyEDIFileFormat.pxyGetRealObjectAndEdition(realEDIFileFormat, expectedEdition);
	
	if realEDIFileFormat = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_FileFormatEDI.name, null, null);
		return;
	endif;

	_pxyEDIFileFormat.validateForUpdate();
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realEDIFileFormat);

	if _passport.noErrors and realEDIFileFormat.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'country', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realEDIFileFormat, true);
	endif;
	
	if _passport.noErrors then
		realEDIFileFormat.setForUpdateUser(_pxyEDIFileFormat.name, _pxyEDIFileFormat.description, _pxyEDIFileFormat.noLongerUsed, _pxyEDIFileFormat.myOperator);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realEDIFileFormat, false);
	endif;
	
end;</source>
        <Parameter name="_pxyEDIFileFormat" type="CM_FileFormatEDI"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEDIFileName" id="b0231909-0718-476f-9664-6f3ff898c67b">
        <updating/>
        <source>utlUpdateEDIFileName(_ediFile: CM_EDIFile input; _fileName: String; _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	25 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
12 Oct 2016	cnwkpd1	TFS 2815 - JADE 7.1.08 causeEvent changes
	
*/

vars

begin
	self.initialiseActivity();


	app.setContinueCMExceptions(true);

	
	if _ediFile = null then	
		app.raiseCMException1(ERR_INVALID_VALUE, 'ediFile (null)', 'ediFile', null);
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(_ediFile);
	
	if _passport.noErrors then
		_ediFile.setFileName(_fileName);
	endif;
	
	if _passport.noErrors then
//		_ediFile.ediData.causeEvent(Object_Update_Event, false, _ediFile.ediData);
		self.updateObjectEdition(_ediFile.ediData);
	endif;
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEDIFileStatus" id="b9dfd4ec-c47d-4ee1-9734-2574e72bd9bb">
        <updating/>
        <source>utlUpdateEDIFileStatus(_ediFile: CM_EDIFile input; _status: Integer; _passport: CM_Passport input)updating;
//----------------------------------------------------------------
//	Created:	30 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 16 Aug 2016	cnwrs1	TFS 2534 Par 38135 - dead locking between edidata process and edidata deletion
// 14 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
vars
	ediData : CM_EDIData;
	ediConfig : CM_EDIConfig;
begin
	ediData := _ediFile.ediData;
	ediConfig := _ediFile.ediData.ediConfig;
	if ediConfig &lt;&gt; null then
		if not tryLock(ediConfig, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
			self.exclusiveLock(ediConfig);
		endif;
	endif;
	self.exclusiveLock(_ediFile);
	self.exclusiveLock(ediData);
	_ediFile.setFileStatus(_status);
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEDIFileTypeUser" id="cc0c1f8d-3ddd-4663-9b4e-1cfcd3098e95">
        <updating/>
        <source>utlUpdateEDIFileTypeUser(_pxyFileTypeUser		: CM_EDIFileTypeUser;
						 _passport				: CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	realFileTypeUser		: CM_EDIFileTypeUser;
	expectedEdition			: Integer;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	app.myValUA.valEDIFileTypeUser(_pxyFileTypeUser, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	_pxyFileTypeUser.pxyGetRealObjectAndEdition(realFileTypeUser, expectedEdition);
	
	if realFileTypeUser = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_EDIFileTypeUser.name, null, null);
		return;
	endif;

	exclusiveLock(realFileTypeUser);

	if _passport.noErrors and realFileTypeUser.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'User defined EDI File Type', null, null);
		return;
	endif;
		
	realFileTypeUser.setForUpdate(_pxyFileTypeUser);
		
end;</source>
        <Parameter name="_pxyFileTypeUser" type="CM_EDIFileTypeUser"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEDIIssue" id="b2e94351-1436-4ce7-9683-998ac69f55b0">
        <updating/>
        <source>utlUpdateEDIIssue(_pxyObject : CM_EDIIssue; _passport : CM_Passport input) updating;
// ##### CR 64617 TASK 65065 NAVAB1 09JUL2024
vars
	realObject		: CM_EDIIssue;
	expectedEdition	: Integer;
	theTerminal : CM_Terminal;
begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_pxyObject, 'EDIIssue');

	app.setContinueCMExceptions(true);
	
	app.myValUA.valEDIIssue(_pxyObject);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	realObject := self.getRealObjectAndEditionCheck(_pxyObject, 'EDIIssue', _passport).CM_EDIIssue;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
	endif;

	if _passport.noErrors then
		// do updates
		realObject.setForUpdate(_pxyObject);
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
	endif;
	if _passport.noErrors then
		theTerminal := realObject.myTerminal;
		app.myEventManager.createSingleObjInfoNoteEvt(theTerminal,theTerminal.getTerminalEvent(Event_EDIIssueUpdate),realObject);	
	endif;

end;</source>
        <Parameter name="_pxyObject" type="CM_EDIIssue"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
