    <JadeMethod name="doesReceiptTransportModeExist" id="5298d7db-516d-4942-b5d2-df1433e5a6ff">
        <source>doesReceiptTransportModeExist(_receiptTransportMode: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
6 April 2023	navra1	Initial creation for 57263

*/

vars

begin
	//since the receipt transport mode would be TI_TRANSMODE_SHIP_STR for a BOL edi file
	if _receiptTransportMode.toUpper().compareEql(TI_TRANSMODE_SHIP_STR.toUpper(), true, false, null) then
		return true;
	endif;
	
	
	return false;

epilog

end;</source>
        <Parameter name="_receiptTransportMode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDataTypeFromDefName" id="f3735906-59ca-46e6-b97e-061a4d71613f">
        <source>getDataTypeFromDefName(_name: String): Integer;
//
// cnwrs1 CCMS 1008 1036 cnwrs1 Jan 2010
//
vars

begin
	if _name = ETDef_EDITIBOLHdr then
		return EDIDataType_BOLHdr;
	elseif _name = ETDef_EDITIBOLDtl then
		return EDIDataType_BOLDtl;
	endif;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStrForDefName" id="f44565a9-fc7c-48a2-8837-92c5d77b6005">
        <source>getDisplayStrForDefName(_name: String): String;
//
// cnwrs1 CCMS 1008 1036 cnwrs1 Jan 2010
//
vars

begin
	if _name = ETDef_EDITIBOLHdr then
		return app.getErrorString(BOL_header);
	elseif _name = ETDef_EDITIBOLDtl then
		return app.getErrorString(BOL_details);
	endif;
end;
</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDIChildDataTypes" id="41d82967-cd7a-4a40-9694-7f4126040f81">
        <source>getEDIChildDataTypes(_types: IntegerArray input);
//
// cnwrs1 CCMS 1008 1036 cnwrs1 Jan 2010
//
vars

begin
	_types.add(EDIDataType_BOLHdr);
	_types.add(EDIDataType_BOLDtl);
epilog
end;</source>
