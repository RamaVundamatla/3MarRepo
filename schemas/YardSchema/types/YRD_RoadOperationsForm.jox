	toolbar.addButton(self.btnProcessRoad, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	
	toolbar.addButton(self.btnMoveIt, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnEventTrans, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	
	toolbar.addButton(self.btnHideCompleted, CMUI_Toolbar.Control_Alignment_Left);	// par 29653 October 2012
	
	toolbar.addButton(self.btnShowProblem, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnHandheldOnly, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	if self.myTerminal.isVehicleBookingEnabled then
		self.btnVehicleBook.visible := true;
		self.btnVehicleBook.enabled := true;
		toolbar.addButton(self.btnVehicleBook, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	else
		self.btnVehicleBook.visible := false;
		self.btnVehicleBook.enabled := false;
	endif;
	
	//27/03/2025	navkc1 JIRA Story MTN-34156
	toolbar.addButton(self.btnNotifications, CMUI_Toolbar.Control_Alignment_Right);
	self.btnNotifications.visible := true;
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
	toolbar.alignContainer := Frame.AlignContainer_Top; // this will make the dkcMain line up its top*/
	
	btnMoveIt.enabled		:= false;	// 14/09/2009 cnwcs5
	btnProcessRoad.enabled	:= false;	// 14/09/2009 cnwcs5
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addWorkListEntry" id="e4b86e24-7265-4f83-aed8-16850c4b422c">
        <updating/>
        <source>addWorkListEntry(_deliveryRequest : CM_DeliveryRequest input) updating, protected;
//--------------------------------------------------
// Created:	24 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	result : Integer;
begin
	if _deliveryRequest = null then
		app.msgBox('Please select a release by type from the list to add a work list entry to.', 'Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);	
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;			
		
	while true do
		app.myTrxUA.trxUpdateReleaseWLEQty(_deliveryRequest, 1, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Add work list entry', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	
epilog 
	app.mousePointer := MousePointer_Default;			
end;</source>
        <access>protected</access>
        <Parameter name="_deliveryRequest" type="CM_DeliveryRequest" usage="input"/>
    </JadeMethod>
    <JadeMethod name="assignTIToReleaseRequest" id="6323a0d9-3948-4600-9a5c-008655c95e64">
        <source>assignTIToReleaseRequest(_ti : CM_TrackedItem; _moveMode : Integer) protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 Sep 2006	cnwer1	Initial creation - PAR#xxxx
19 may 2014	cnwer1	PAR 34107
*/
vars
	result : Integer;
	moveController : CMIF_MoveController;
	wle : CM_WorkListEntry;
	unknownChassisLC : CM_TILCRow;
begin
	
	if app.myMoveController = null then
		if _ti &lt;&gt; null then
			create moveController transient;
		else
			return;
		endif;
	else
		moveController := app.myMoveController;
		// TFS 42878 jlgzm1 28/08/2019
		if moveController.myWorkListEntry &lt;&gt; null then
			moveController.isDirectReleaseMove := true;
		endif;
	endif;
	
	wle :=self.myCurrentWLE;
	
	if wle = null then
		return;
	else
		sharedLock(wle);
	endif;
	
	moveController.setMyToPrimaryLocation(wle.getRoadReleaseLC());
	moveController.setMyWorkListEntry(wle);

	if _ti &lt;&gt; null then
		moveController.setMyTrackedItem(_ti);
		
		if wle.isChassisToRelease then
			unknownChassisLC:=wle.job.CM_RoadJob.myVehicle.myUnknownChassis; 
			if unknownChassisLC &lt;&gt; null and
				unknownChassisLC.allTrackedItems.size &gt; 0 then
				
				moveController.setMoveMode(REAL_MODE);	
			endif;
		else
			
			if _moveMode = NO_MODE then
				moveController.setMyToPrimaryLocation(null);
			else
				moveController.setMoveMode(_moveMode);
			endif;
		endif;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);	
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog('Assign To Release', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
epilog
	if wle &lt;&gt; null then
		unlock(wle);
	endif;
	app.myDraggedTrackedItem := null;
	if moveController &lt;&gt; null and moveController &lt;&gt;  app.myMoveController then
		delete moveController;
	endif;		
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_moveMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="assignToTBA" id="d1bf44d7-26f8-4253-9e2b-d89159fdad52">
        <updating/>
        <source>assignToTBA() updating, protected;
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
//This only gets enabled when there is a TBA under the mouse. This will:
//1) Queue move the TI to the TBA's current location.
//2) Add the ti move to a Queue.

// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	wle, 
	proxyWLE : CM_WorkListEntry;
	rtnValue : Boolean;
	theReturn : Integer;
begin

	app.mousePointer := MousePointer_HourGlass;

	if self.myCurrentWLE &lt;&gt; null then
		wle := self.myCurrentWLE;
	else
		return;
	endif;
	
	//Belts and Braces - Menu item should not be visible if ti is null
	if wle.myTrackedItem = null then	
		return;
	endif;
	
	proxyWLE := app.createUpdateProxy(wle).CM_WorkListEntry;

	while true do

		app.myTrxUA.trxUpdateTIMatchAndQueueToTBA(proxyWLE, app.myPassport);	
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog('Assign To Intended TBA', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
epilog
	delete proxyWLE;
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="beginTimerForRefresh" id="1243f90f-c54e-42df-9fde-57cc4ebec60e">
        <updating/>
        <source>beginTimerForRefresh() updating, protected;
//--------------------------------------------------

//moved from CM_RoadOpsForm 3/8/06
//--------------------------------------------------
vars

begin

	if (not self.timerRefreshActive) then
		self.timerRefreshActive := true;
		self.beginTimer(60000, Timer_OneShot, Timer_Refresh);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
