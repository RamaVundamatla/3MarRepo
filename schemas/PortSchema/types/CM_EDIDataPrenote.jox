    <JadeMethod name="getReceiptTransportMode" id="d84d9397-8a48-4417-8e92-8ccc01e33f98">
        <source>getReceiptTransportMode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars
	ediTi: CM_EDITrackedItem;
begin
	foreach ediTi in self.allEDITrackedItems do
		if ediTi.isKindOf(CM_EDIPrenoteTI) then
			return ediTi.CM_EDIPrenoteTI.transportMode;
		endif;
	endforeach;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStatusFromEDITrackedItems" id="79a95c33-1244-4334-95f5-df63931d06e7">
        <source>getStatusFromEDITrackedItems(_verifyOnly : Boolean) : Integer;
/*
Date		Who		Reason
//18 Nov 2015	cnwrs1	Par 36852 - when skip processing the staus should reflect that
// 10 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 28 Nov 2017	jlgrs1	TFS 5705A - SNO - EDIDataBooking Prenote release Req
// 11 Apr 2018	jjnlrs1	TFS 37746 - SNO dont create prenote if the container is on site
// 19 Se; 2018	jlgrh7 TFS 39839	POL - [Fwd: ##RE-8414## : Error in prenoting PONU2919363]	
*/
vars
	ediTI : CM_EDITrackedItem;
	newStatus, oldStatus, total, skipped, 
	dbLoaded, verified, warnings, errors, 
	todo : Integer;
begin
	if not self.canGetStatusFromEDITrackedItem then
		app.raiseUnexpectedProgramError (self.class.name, method.name, "Method called for invalid EDI data type");
		return null;
	endif;
	
	total		:= self.allEDITrackedItems.size;
	newStatus 	:= CM_EDIFile.EDI_STATUS_UNPROCESSED;
	
	if total &gt; 0 then
		// it is a shame we have to go through all the EDI TIs but 
		// generally (MSK) there is only 1 per file
		foreach ediTI in self.allEDITrackedItems discreteLock do
			if not ediTI.isKindOf(CM_EDIPrenoteTI) then
				total := total - 1;
				continue;
			endif;
			oldStatus := ediTI.status;
			
			if oldStatus = CM_EDITrackedItem.EDI_STATUS_UNPROCESSED then
				todo := todo + 1;
				
			elseif oldStatus = CM_EDITrackedItem.EDI_STATUS_DBLOADED then
				dbLoaded := dbLoaded + 1;
				
			elseif oldStatus = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING then
				// we are ignoring this one
				total := total - 1;
			
			elseif oldStatus = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
				skipped := skipped + 1;
				
			elseif oldStatus = CM_EDITrackedItem.EDI_STATUS_VERIFIED then
				verified := verified + 1;
				
			elseif oldStatus = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then
				if _verifyOnly then
					warnings := warnings + 1;
				else
					dbLoaded := dbLoaded + 1;
				endif;
				
			elseif oldStatus = CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS or 
				oldStatus = CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS or
				//will only have DBLOADING if we've had an unexpected error, not connected to ediTI
				oldStatus = CM_EDIFile.EDI_STATUS_DBLOADING or //tfs41915, 
				oldStatus = CM_EDIFile.EDI_STATUS_LOCKERROR then				//+TFS39839
				errors := errors + 1;				
			endif;
		endforeach;
	
		if todo = total then
			// nothing processed
			if todo &gt; 0 then
				newStatus := CM_EDIFile.EDI_STATUS_LOADED;
			else
				// probably ignored everything
				if _verifyOnly then
					newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
				else
					newStatus := CM_EDIFile.EDI_STATUS_DBLOADED;
				endif;
			endif;
		elseif dbLoaded = total then 
			// everything loaded
			if _verifyOnly then
				newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
			else
				newStatus := CM_EDIFile.EDI_STATUS_DBLOADED;
			endif;
		elseif dbLoaded &gt; 0 then
			// file is partially loaded
			if skipped + dbLoaded = total then
				// all either loaded or skipped
				newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X;
			else
				// some skipped, some loaded, some yet to be loaded
				newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL;
			endif;
		else	
			// nothing loaded
			if _verifyOnly then
				if skipped &gt; 0 then
					if skipped = total then
						// everything has been skipped
						newStatus := CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X;
					elseif skipped + verified = total then
						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
					elseif skipped + verified + warnings = total then
						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS;
					else
						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS;
					endif;
				else
					// still some stuff that has not loaded
					if errors &gt; 0 then
						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS;
					elseif warnings &gt; 0 then
						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS;
					else
						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
					endif;
				endif;
			else	//dbloaded
				if skipped &gt; 0 then
					if skipped = total then
						// everything has been skipped
						newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X;
//					elseif skipped + verified = total then
//						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
//					elseif skipped + verified + warnings = total then
//						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS;
					else
						newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS;
					endif;
				else
					// still some stuff that has not loaded
//					if errors &gt; 0 then
						newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS;
//					elseif warnings &gt; 0 then
//						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS;
//					else
//						newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
//					endif;
				endif;
			endif;
		endif;
	endif;
	
	return newStatus;
epilog

end;</source>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTIProperties" id="0dd3ca3b-c43e-45f7-b35e-98f4dadbca9c">
        <source>getTIProperties(_propArray: ObjectArray io);

vars
	popColl: PropertyNDict;
	property: Property;
begin
	inheritMethod(_propArray);
	popColl := CM_EDIPrenoteTI.getProperties;
	foreach property in popColl do
		_propArray.add(property);
	endforeach;

end;</source>
        <Parameter name="_propArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getVesselName" id="7f1423be-f5a8-4900-b8e7-5f927d4a93dd">
        <source>getVesselName(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars
	vCode: String;
	terminal: CM_Terminal;
	voyage: CM_Voyage;
begin
	vCode := self.getVoyageCode;
	terminal := self.getMyTerminal;
	if vCode &lt;&gt; null and terminal &lt;&gt; null then
		voyage := terminal.lookupVoyage(vCode, null, false);
		if voyage &lt;&gt; null then
			return voyage.vesselName;
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageCode" id="c381831f-6d48-438d-a835-3c9b4db8a208">
        <source>getVoyageCode(): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 November 2015	cnwer1	Initial creation

*/

vars

	ediTI : CM_EDITrackedItem;
	voyCode : String;
begin
	
	foreach ediTI in self.allEDITrackedItems  do
		
		voyCode:= ediTI.getVoyageCode();
		if voyCode &lt;&gt; null then
			return voyCode;
		endif;
	endforeach;
	
	
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageETA" id="268f60dc-657e-406d-b9e9-0e07fd8688e5">
        <source>getVoyageETA(): Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
*/

vars
	vCode: String;
	terminal: CM_Terminal;
	voyage: CM_Voyage;
begin
	vCode := self.getVoyageCode;
	terminal := self.getMyTerminal;
	if vCode &lt;&gt; null and terminal &lt;&gt; null then
		voyage := terminal.lookupVoyage(vCode, null, false);
		if voyage &lt;&gt; null then
			return voyage.estimatedArrivalDT.date;
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="isComposite" id="98095da2-dfba-4e3e-92d9-1becb18a2d50">
