    <JadeMethod name="setupForm" id="b47ad419-47e0-4394-876f-f34809169303">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	faultType : CM_FaultType;
	faultResponse : CM_FaultResponse;
	machine : CM_Machine;
	faultStatus : CM_FaultStatus;
	enteredBy, reportedBy : CM_User;
	resolutionDetails,
	additionalDetails,
	question : String;
	whenReported : TimeStamp;
	failureCondtion : String;
begin
	self.showToolbar := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	inheritMethod();

	//initialise variables
	faultType:=null;
	faultResponse:=null;
	machine:=null;
	faultStatus :=null;
	enteredBy:=null;
	reportedBy :=null;
	resolutionDetails := null;
	additionalDetails :=null;
	failureCondtion:=null;
	self.setupReadOnlyFields();
	//we are editing load the current details
	if self.myFault  &lt;&gt; null then
		faultType:=self.myFault.myFaultType;
		faultResponse:=self.myFault.myFaultResponse;
		machine:=self.myFault.myMachine;
		faultStatus:=self.myFault.myFaultStatus;
		if faultResponse &lt;&gt; null then
			self.txtQuestion.text:=faultResponse.question; 	
			enteredBy:=self.myFault.myEnteredByUser;
			failureCondtion:=faultResponse.response;
		else
			enteredBy:=app.myPassport.myUser;
		endif;
		reportedBy:=self.myFault.myReportedByUser;
		whenReported:= self.systemToLocalTime(self.myFault.reportedTS);	// cnwmp6 TFS 488 - Multi timezone changes 13/4/16
		self.txtAdditional.text:=self.myFault.additionalDetails;
		self.txtResolution.text:=self.myFault.resolutionDetails;
		
		
		
	else
		faultStatus:=app.myRoot.getDefaultFaultStatus;
		enteredBy:=app.myPassport.myUser;
		whenReported := self.systemToLocalTime(app.actualTimeServer);	// cnwmp6 TFS 488 - Multi timezone changes 13/4/16
	endif;
	
	
	self.txtReportedDate.setDate(whenReported.date);
	self.txtReportedTime.setTime(whenReported.time);
	
	self.myAssistant.comboBoxFaultType(cmbFaultType,faultType,false);
	self.myAssistant.comboBoxFaultStatus(self.cmbFaultStatus,faultStatus);
	self.cmbMachine.myTerminal:=self.myTerminal;
	self.myAssistant.comboBoxUserInternal(self.cmbEnteredBy,enteredBy);
	self.myAssistant.comboBoxUserInternal(self.cmbReportedBy,reportedBy);
	self.myAssistant.comboBoxFaultFailureCondition(self.cmbResponse,failureCondtion);
	self.cmbMachine.setObject(machine);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupReadOnlyFields" id="9118119a-b2c7-44cf-997c-e76f2f05ec5f">
        <source>setupReadOnlyFields();
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.cmbEnteredBy.enabled:=false;
	self.grpResponse.enabled:=false;
	//self.txtQuestion.readOnly:=true;
	//self.cmbResponse.enabled:=false;
	if self.myFault &lt;&gt; null and not app.isSpecial() then
		self.txtReportedDate.enabled:=self.myFault.myFaultResponse = null;
		self.txtReportedTime.enabled:=self.myFault.myFaultResponse = null;
		self.cmbMachine.enabled:=self.myFault.myFaultResponse = null;
		self.cmbReportedBy.enabled:=self.myFault.myFaultResponse = null;
		self.cmbFaultType.enabled:=self.myFault.myFaultResponse = null;
		self.txtQuestion.enabled:=self.myFault.myFaultResponse = null;
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="5c7f151d-8fcc-4b5c-8937-93657eaf1bbc">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007007, locale);
	grpResponse.translateCaption(Xlat_0007008, locale);
	lbResDetails.translateCaption(Xlat_0007009, locale);
	lblAddDetails.translateCaption(Xlat_0007010, locale);
	lblEnteredBy.translateCaption(Xlat_0007011, locale);
	lblFaultQuesti_1.translateCaption(Xlat_0007012, locale);
	lblFaultQuestion.translateCaption(Xlat_0007013, locale);
	lblFaultStatus.translateCaption(Xlat_0007014, locale);
	lblFaultType.translateCaption(Xlat_0007015, locale);
	lblMachine.translateCaption(Xlat_0007016, locale);
	lblReportedBy.translateCaption(Xlat_0007017, locale);
	lblWhenReported.translateCaption(Xlat_0007018, locale);
	mnuContext.translateCaption(Xlat_0007019, locale);
	mnuCopy.translateCaption(Xlat_0007020, locale);
	mnuCut.translateCaption(Xlat_0007021, locale);
	mnuPaste.translateCaption(Xlat_0007022, locale);
	mnuRedo.translateCaption(Xlat_0007023, locale);
	mnuSelectAll.translateCaption(Xlat_0007024, locale);
	mnuUndo.translateCaption(Xlat_0007025, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtAdditional_contextMenu" id="9144b4da-15ad-483c-8419-90aab1a73d9a">
        <controlMethod name="JadeTextEdit::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtAdditional_contextMenu(textedit: JadeTextEdit input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
16 October 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	xLeft,yTop : Real;
	
begin
	xLeft := x;
	yTop := y;
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
	mnuContext.userObject:=textedit;
	self.popupMenu(mnuContext,xLeft.Integer, yTop.Integer);
	
	return true;


epilog

end;</source>
        <Parameter name="textedit" type="JadeTextEdit" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
