    <JadeMethod name="setForCreate" id="8d20efe3-de8e-4e9e-9abd-cd1d5f4b7821">
        <updating/>
        <source>setForCreate(_cargoId : String; _moveResult : String) updating;
/*

Purpose:			Sets properties on our Class

Parameters:			_cargoId	String	The cargo id of the piece of cargo
					_moveResult	String	The result of the move, whether it was successful or failed

Return Value:		

Date		Who		Reason
12 January 2022	navpw1	Initial creation TFS: 52572

*/

begin
	self.cargoId 	:= _cargoId;
	self.moveResult := _moveResult;

end;</source>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_moveResult" type="String"/>
    </JadeMethod>
</Class>
