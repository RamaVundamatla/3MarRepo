    <JadeMethod name="validateForDelete" id="028df136-c69c-43c4-ad47-6b2169d37cdb">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     27 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.allBOLByTypeNumber.size &gt; 0 then	//par 21807 Jan 2010
		app.raiseCMException2(ObjectStillHasEntries, 'Operator ' &amp; self.myOperator.code &amp; 
							' at terminal ' &amp; self.myTerminal.code, "bills of lading", null, null);
	endif;

	if self.allBookingRefsByRef.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, 'Operator ' &amp; self.myOperator.code &amp; 
							' at terminal ' &amp; self.myTerminal.code, "booking refs", null, null);
	endif;

	if self.allBulkReleases.size &gt; 0 then	//par 21807 Jan 2010
		app.raiseCMException2(ObjectStillHasEntries, 'Operator ' &amp; self.myOperator.code &amp; 
							' at terminal ' &amp; self.myTerminal.code, "release requests", null, null);
	endif;

	
		// DVB check whether operator still has cargo
	if (not self.allDeletedTIsByCargoTypeId.isEmpty()) or	//par 21807 Jan 2010
	(not self.allOnsiteTIsByCargoTypeId.isEmpty()) or
	(not self.allNotifiedTIsByCargoTypeId.isEmpty()) or
	(not self.allOffsiteTIsByCargoTypeId.isEmpty()) or	//30 Nov 2012	NDL	Par 30778
	(not self.allRRPTIsByCargoTypeId.isEmpty()) or	//16 Mar 2020	NDL	tSF 47004
	(not self.allTbaTIsByCargoTypeId.isEmpty()) then
		app.raiseCMException2(ObjectStillHasEntries, 'Operator Terminal ' &amp;'('&amp; self.myTerminal.code &amp;')', 'Tracked Items', null, null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="8bce144c-c7a3-48f9-9013-ab4b6f584ff3">
        <source>validateForUpdate();

/*
Date		Who		Reason
05 June 2009	cnwar2	Initial creation

*/
vars
	recCutoff 	: CM_ReceivalCutoffOpTerm;
	cutOffTerm 	: CM_ReceivalCutoffTermDef; //08/04/2025	navkc1 JIRA Story MTN-34470
begin
	foreach recCutoff in self.allReceivalCutoffOpTerms do
		cutOffTerm := recCutoff.myReceivalCutoffTermDef; //08/04/2025	navkc1 JIRA Story MTN-34470
		
		//08/04/2025	navkc1 JIRA Story MTN-34470
		if cutOffTerm = null then
			app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class().name, method.name, "cutOffTerm should not be null", CM_ReceivalCutoffOpTerm::myReceivalCutoffTermDef.name, recCutoff);
			continue;
		endif;
		
		if recCutoff.defaultEarliestReceival &lt;&gt; 0
		and recCutoff.defaultCutoff &lt;&gt; 0
		and recCutoff.defaultEarliestReceival &lt;= recCutoff.defaultCutoff then
			//app.raiseCMException2(Must_greater_than, 'Default Earliest Receival', 'Default Cutoff', null, null);
			//app.raiseCMException(EarlyReceiveGreaterCutOff, null, null); //04/03/2025	navkc1 JIRA Story MTN-34227
			app.raiseCMException1(EarlyReceiveGreaterCutOff, cutOffTerm.code &amp; '(' &amp; self.myTerminal.code &amp; ')', null, null); //08/04/2025	navkc1 JIRA Story MTN-34470
			//break; //08/04/2025	navkc1 JIRA Story MTN-34470
			continue;
		endif;
		
		//04/03/2025	navkc1 JIRA Story MTN-34227
		if recCutoff.defaultCutoffPN &lt;&gt; null
		and recCutoff.defaultEarliestReceivalPN &lt;&gt; null
		and recCutoff.defaultEarliestReceivalPN &lt;= recCutoff.defaultCutoffPN then
			//app.raiseCMException2(Must_greater_than, 'Earliest Date Time Pre Note', 'Cut Off Date Time Pre Note', null, null);
			//app.raiseCMException(EarlyReceivePNGreaterCutOffPN, null, null); //04/03/2025	navkc1 JIRA Story MTN-34227
			app.raiseCMException1(EarlyReceivePNGreaterCutOffPN, cutOffTerm.code &amp; '(' &amp; self.myTerminal.code &amp; ')', null, null); //08/04/2025	navkc1 JIRA Story MTN-34470
			//break; //08/04/2025	navkc1 JIRA Story MTN-34470
			continue;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
</Class>
