	return self.EDI_Bundle_CUSTOM;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExampleXML" id="676fbfed-64f6-4a53-b8c3-a2a587765af5">
        <source>getExampleXML():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2015	cnwndl1	Initial creation	Par 36608
10 Jul 2018	NDL	TFS 39186

*/

vars

	tagset : String;
	rules : String;
	exampleXML : String;
	exampleXML2 : String;
	
	cargoBaseId : String;
	cargoGroupAssignBaseId : String;
	cargoGroupBaseId : String;
	location : String;
	cargoType : String;
	operatorCode : String;
	remarks1 : String;	//21 Sep 2015	NDL	Par 36338
	remarks2 : String;	//21 Sep 2015	NDL	Par 36338
	

begin

	tagset :=
'XML recognised tags :'  &amp; CrLf &amp;
'&lt;' &amp; TagCargoGroupAssignments &amp; '&gt;' &amp; Tab &amp; 'Indicates the EDI message type to JMT and contains the complete XML data set' &amp; CrLf &amp;
'&lt;' &amp; TagCargoGroupAssignment &amp; '&gt;' &amp; Tab &amp; 'Represents one complete Cargo Group Assignment object.  Multiples are permitted in the &lt;' &amp; TagCargoGroupAssignments &amp; '&gt; tag set' &amp; CrLf &amp;
'&lt;' &amp; TagAction &amp; '&gt;' &amp; Tab &amp; '"' &amp; CM_EDICargoGroupAssign.EDI_ACTION_ADD &amp; '" for Add or "' &amp; CM_EDICargoGroupAssign.EDI_ACTION_DELETE &amp; '" for Delete or "' &amp; CM_EDICargoGroupAssign.EDI_ACTION_MODIFY &amp; '" for Modify. Represents the action to be taken for the identified Cargo Group Assignment object.  One permitted per &lt;' &amp; TagCargoGroupAssignment &amp; '&gt; tag set.  Default value if not present is "A"' &amp; CrLf &amp;
'&lt;' &amp; TagCargoGroupAssignmentId &amp; '&gt;' &amp; Tab &amp; 'The id of the Cargo Group Assignment object.  One required in a &lt;' &amp; TagCargoGroupAssignment &amp; '&gt; tag set' &amp; CrLf &amp;
'&lt;' &amp; TagSelectableCargoIds &amp; '&gt;' &amp; Tab &amp; 'Contains a collection of &lt;' &amp; TagCargoId &amp; '&gt; tag sets that represent cargo associated with the Cargo Group Assignment that are NOT pre-assigned to a specific Cargo Group.  One permitted in a &lt;' &amp; TagCargoGroupAssignment &amp; '&gt; tag set' &amp; CrLf &amp;
'&lt;' &amp; TagCargoId &amp; '&gt;' &amp; Tab &amp; 'Represents one available Cargo object.  Multiples permitted in a &lt;' &amp; TagSelectableCargoIds &amp; '&gt; tag set and multiples permitted in a &lt;' &amp; TagPreAssignedCargoIds &amp; '&gt; tag set' &amp; CrLf &amp; 
'&lt;' &amp; TagCargoGroup &amp; '&gt;' &amp; Tab &amp; 'Represents one Cargo Group object.  Multiples permitted in a &lt;' &amp; TagCargoGroupAssignment &amp; '&gt; tag set' &amp; CrLf &amp; 
'&lt;' &amp; TagCargoGroupId &amp; '&gt;' &amp; Tab &amp; 'The id of the Cargo Group.  One required in a &lt;' &amp; TagCargoGroup &amp; '&gt; tag set' &amp; CrLf &amp;
'&lt;' &amp; TagCargoGroupRemarks &amp; '&gt;' &amp; Tab &amp; 'Remarks information for a Cargo Group.  One permitted in a &lt;' &amp; TagCargoGroup &amp; '&gt; tag set' &amp; CrLf &amp;
'&lt;' &amp; TagDefaultLocation &amp; '&gt;' &amp; Tab &amp; 'The default location used in the Hand Held when assigning the first cargo item to a Cargo Group.  One permitted in a &lt;' &amp; TagCargoGroup &amp; '&gt; tag set' &amp; CrLf &amp;
'&lt;' &amp; TagMinWeight &amp; '&gt;' &amp; Tab &amp; 'The minimum weight (kgs) value for a Cargo Group.  One permitted in a &lt;' &amp; TagCargoGroup &amp; '&gt; tag set. Not used in Pre-assigned Cargo Groups' &amp; CrLf &amp;
'&lt;' &amp; TagMaxWeight &amp; '&gt;' &amp; Tab &amp; 'The maximum weight (kgs) value for a Cargo Group.  One permitted in a &lt;' &amp; TagCargoGroup &amp; '&gt; tag set. Not used in Pre-assigned Cargo Groups' &amp; CrLf &amp;
'&lt;' &amp; TagCargoType &amp; '&gt;' &amp; Tab &amp; 'The cargo type of the Cargo Group object (not its members).  One permitted in a &lt;' &amp; TagCargoGroup &amp; '&gt; tag set.  A default value will be derived if it is not present' &amp; CrLf &amp;
'&lt;' &amp; TagOperator &amp; '&gt;' &amp; Tab &amp; 'The operator associated with the Cargo Group.  One required in a &lt;' &amp; TagCargoGroup &amp; '&gt; tag set that is for an Add' &amp; CrLf &amp;
'&lt;' &amp; TagPreAssignedCargoIds &amp; '&gt;' &amp; Tab &amp; 'Contains a collection of &lt;' &amp; TagCargoId &amp; '&gt; tag sets that represent the cargo pre-assigned to this Cargo Group.  One permitted in a &lt;' &amp; TagCargoGroupAssignment &amp; '&gt; tag set' &amp; CrLf &amp;
'';

write tagset;

rules :=
'Rules :'  &amp; CrLf &amp;
'Cargo Group Assignment Ids must be unique per terminal.' &amp; CrLf &amp;
'Cargo Group Ids must be unique per terminal.' &amp; CrLf &amp;
'Cargo Ids may be included in the &lt;' &amp; TagSelectableCargoIds &amp; '&gt; of a Cargo Group Assignment OR in the &lt;' &amp; TagPreAssignedCargoIds &amp; '&gt; of a specific Cargo Group, but NOT both.  I.e. A Cargo Group Assignment may contain ALL Pre-Assigned or ALL selectable Cargo Groups' &amp; CrLf &amp;
'Cargo Ids that are in the &lt;' &amp; TagPreAssignedCargoIds &amp; '&gt; of a specific Cargo Group, will not be permitted to be associated with a different Cargo Group via the Hand Held Cargo Group Assignment form' &amp; CrLf &amp;
'Modify provides for the adding of a Cargo Group to an existing Cargo Group Assignment' &amp; CrLf;

write rules;

	cargoBaseId := "BOX";
	cargoGroupAssignBaseId := "STW_WO_";
	cargoGroupBaseId := "PB";
	location := "WareHouse1";
	cargoType := "Cargo Group for PB";
	operatorCode := "MSC";
	remarks1 := "Some remarks";
	remarks2 := "Some other remarks";

exampleXML :=
'Example :'  &amp; CrLf &amp;
'&lt;?xml version="1.0" encoding="ISO-8859-1"?&gt;' &amp; CrLf &amp;
'&lt;' &amp; TagCargoGroupAssignments &amp; '&gt;
	&lt;' &amp; TagCargoGroupAssignment &amp; '&gt;
		&lt;' &amp; TagAction &amp; '&gt;' &amp; CM_EDICargoGroupAssign.EDI_ACTION_ADD &amp; '&lt;/' &amp; TagAction &amp; '&gt;
		&lt;' &amp; TagCargoGroupAssignmentId &amp; '&gt;' &amp; cargoGroupAssignBaseId &amp; '1&lt;/' &amp; TagCargoGroupAssignmentId &amp; '&gt;
		&lt;' &amp; TagSelectableCargoIds &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '01&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '02&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '03&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '04&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '05&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '06&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '07&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '08&lt;/' &amp; TagCargoId &amp; '&gt;
		&lt;/' &amp; TagSelectableCargoIds &amp; '&gt;
		&lt;' &amp; TagCargoGroup &amp; '&gt;
			&lt;' &amp; TagCargoGroupId &amp; '&gt;' &amp; cargoGroupBaseId &amp; '1&lt;/' &amp; TagCargoGroupId &amp; '&gt;
			&lt;' &amp; TagCargoGroupRemarks &amp; '&gt;' &amp; remarks1 &amp; '&lt;/' &amp; TagCargoGroupRemarks &amp; '&gt;
			&lt;' &amp; TagDefaultLocation &amp; '&gt;' &amp; location &amp; '&lt;/' &amp; TagDefaultLocation &amp; '&gt;
			&lt;' &amp; TagMinWeight &amp; '&gt;3500&lt;/' &amp; TagMinWeight &amp; '&gt;
			&lt;' &amp; TagMaxWeight &amp; '&gt;5500&lt;/' &amp; TagMaxWeight &amp; '&gt;
			&lt;' &amp; TagCargoType &amp; '&gt;' &amp; cargoType &amp; '&lt;/' &amp; TagCargoType &amp; '&gt;
			&lt;' &amp; TagOperator &amp; '&gt;' &amp; operatorCode &amp; '&lt;/' &amp; TagOperator &amp; '&gt;
		&lt;/' &amp; TagCargoGroup &amp; '&gt;
		&lt;' &amp; TagCargoGroup &amp; '&gt;
			&lt;' &amp; TagCargoGroupId &amp; '&gt;' &amp; cargoGroupBaseId &amp; '2&lt;/' &amp; TagCargoGroupId &amp; '&gt;
			&lt;' &amp; TagCargoGroupRemarks &amp; '&gt;' &amp; remarks2 &amp; '&lt;/' &amp; TagCargoGroupRemarks &amp; '&gt;
			&lt;' &amp; TagDefaultLocation &amp; '&gt;' &amp; location &amp; '&lt;/' &amp; TagDefaultLocation &amp; '&gt;
			&lt;' &amp; TagMinWeight &amp; '&gt;3500&lt;/' &amp; TagMinWeight &amp; '&gt;
			&lt;' &amp; TagMaxWeight &amp; '&gt;5500&lt;/' &amp; TagMaxWeight &amp; '&gt;
			&lt;' &amp; TagCargoType &amp; '&gt;' &amp; cargoType &amp; '&lt;/' &amp; TagCargoType &amp; '&gt;
			&lt;' &amp; TagOperator &amp; '&gt;' &amp; operatorCode &amp; '&lt;/' &amp; TagOperator &amp; '&gt;
		&lt;/' &amp; TagCargoGroup &amp; '&gt;
	&lt;/' &amp; TagCargoGroupAssignment &amp; '&gt;
	&lt;' &amp; TagCargoGroupAssignment &amp; '&gt;
		&lt;' &amp; TagAction &amp; '&gt;' &amp; CM_EDICargoGroupAssign.EDI_ACTION_ADD &amp; '&lt;/' &amp; TagAction &amp; '&gt;
		&lt;' &amp; TagCargoGroupAssignmentId &amp; '&gt;' &amp; cargoGroupAssignBaseId &amp; '2&lt;/' &amp; TagCargoGroupAssignmentId &amp; '&gt;
		&lt;' &amp; TagCargoGroup &amp; '&gt;
			&lt;' &amp; TagCargoGroupId &amp; '&gt;' &amp; cargoGroupBaseId &amp; '3&lt;/' &amp; TagCargoGroupId &amp; '&gt;
			&lt;' &amp; TagDefaultLocation &amp; '&gt;' &amp; location &amp; '&lt;/' &amp; TagDefaultLocation &amp; '&gt;
			&lt;' &amp; TagCargoType &amp; '&gt;' &amp; cargoType &amp; '&lt;/' &amp; TagCargoType &amp; '&gt;
			&lt;' &amp; TagOperator &amp; '&gt;' &amp; operatorCode &amp; '&lt;/' &amp; TagOperator &amp; '&gt;
			&lt;' &amp; TagPreAssignedCargoIds &amp; '&gt;
				&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '09&lt;/' &amp; TagCargoId &amp; '&gt;
				&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '10&lt;/' &amp; TagCargoId &amp; '&gt;
				&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '11&lt;/' &amp; TagCargoId &amp; '&gt;
				&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '12&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;/' &amp; TagPreAssignedCargoIds &amp; '&gt;
		&lt;/' &amp; TagCargoGroup &amp; '&gt;
		&lt;' &amp; TagCargoGroup &amp; '&gt;
			&lt;' &amp; TagCargoGroupId &amp; '&gt;' &amp; cargoGroupBaseId &amp; '4&lt;/' &amp; TagCargoGroupId &amp; '&gt;
			&lt;' &amp; TagDefaultLocation &amp; '&gt;' &amp; location &amp; '&lt;/' &amp; TagDefaultLocation &amp; '&gt;
			&lt;' &amp; TagCargoType &amp; '&gt;' &amp; cargoType &amp; '&lt;/' &amp; TagCargoType &amp; '&gt;
			&lt;' &amp; TagOperator &amp; '&gt;' &amp; operatorCode &amp; '&lt;/' &amp; TagOperator &amp; '&gt;
			&lt;' &amp; TagPreAssignedCargoIds &amp; '&gt;
				&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '13&lt;/' &amp; TagCargoId &amp; '&gt;
				&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '14&lt;/' &amp; TagCargoId &amp; '&gt;
				&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '15&lt;/' &amp; TagCargoId &amp; '&gt;
				&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '16&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;/' &amp; TagPreAssignedCargoIds &amp; '&gt;
		&lt;/' &amp; TagCargoGroup &amp; '&gt;
	&lt;/' &amp; TagCargoGroupAssignment &amp; '&gt;
	&lt;' &amp; TagCargoGroupAssignment &amp; '&gt;
		&lt;' &amp; TagAction &amp; '&gt;' &amp; CM_EDICargoGroupAssign.EDI_ACTION_ADD &amp; '&lt;/' &amp; TagAction &amp; '&gt;
		&lt;' &amp; TagCargoGroupAssignmentId &amp; '&gt;' &amp; cargoGroupAssignBaseId &amp; '3&lt;/' &amp; TagCargoGroupAssignmentId &amp; '&gt;
		&lt;' &amp; TagSelectableCargoIds &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '17&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '18&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '19&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '20&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '21&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '22&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '23&lt;/' &amp; TagCargoId &amp; '&gt;
			&lt;' &amp; TagCargoId &amp; '&gt;' &amp; cargoBaseId &amp; '24&lt;/' &amp; TagCargoId &amp; '&gt;
		&lt;/' &amp; TagSelectableCargoIds &amp; '&gt;
		&lt;' &amp; TagCargoGroup &amp; '&gt;
			&lt;' &amp; TagCargoGroupId &amp; '&gt;' &amp; cargoGroupBaseId &amp; '5&lt;/' &amp; TagCargoGroupId &amp; '&gt;
			&lt;' &amp; TagDefaultLocation &amp; '&gt;' &amp; location &amp; '&lt;/' &amp; TagDefaultLocation &amp; '&gt;
			&lt;' &amp; TagMinWeight &amp; '&gt;3500&lt;/' &amp; TagMinWeight &amp; '&gt;
			&lt;' &amp; TagMaxWeight &amp; '&gt;5500&lt;/' &amp; TagMaxWeight &amp; '&gt;
			&lt;' &amp; TagCargoType &amp; '&gt;' &amp; cargoType &amp; '&lt;/' &amp; TagCargoType &amp; '&gt;
			&lt;' &amp; TagOperator &amp; '&gt;' &amp; operatorCode &amp; '&lt;/' &amp; TagOperator &amp; '&gt;
		&lt;/' &amp; TagCargoGroup &amp; '&gt;
		&lt;' &amp; TagCargoGroup &amp; '&gt;
			&lt;' &amp; TagCargoGroupId &amp; '&gt;' &amp; cargoGroupBaseId &amp; '6&lt;/' &amp; TagCargoGroupId &amp; '&gt;
			&lt;' &amp; TagDefaultLocation &amp; '&gt;' &amp; location &amp; '&lt;/' &amp; TagDefaultLocation &amp; '&gt;
			&lt;' &amp; TagMinWeight &amp; '&gt;3500&lt;/' &amp; TagMinWeight &amp; '&gt;
			&lt;' &amp; TagMaxWeight &amp; '&gt;5500&lt;/' &amp; TagMaxWeight &amp; '&gt;
			&lt;' &amp; TagCargoType &amp; '&gt;' &amp; cargoType &amp; '&lt;/' &amp; TagCargoType &amp; '&gt;
			&lt;' &amp; TagOperator &amp; '&gt;' &amp; operatorCode &amp; '&lt;/' &amp; TagOperator &amp; '&gt;
		&lt;/' &amp; TagCargoGroup &amp; '&gt;
	&lt;/' &amp; TagCargoGroupAssignment &amp; '&gt;
	&lt;' &amp; TagCargoGroupAssignment &amp; '&gt;
		&lt;' &amp; TagAction &amp; '&gt;' &amp; CM_EDICargoGroupAssign.EDI_ACTION_DELETE &amp; '&lt;/' &amp; TagAction &amp; '&gt;
		&lt;' &amp; TagCargoGroupAssignmentId &amp; '&gt;' &amp; cargoGroupAssignBaseId &amp; '4&lt;/' &amp; TagCargoGroupAssignmentId &amp; '&gt;
	&lt;/' &amp; TagCargoGroupAssignment &amp; '&gt;
&lt;/' &amp; TagCargoGroupAssignments &amp; '&gt;';

	write exampleXML;
	
	exampleXML2 :=
'Example2 :'  &amp; CrLf &amp;
'&lt;?xml version="1.0" encoding="ISO-8859-1"?&gt;' &amp; CrLf &amp;
'&lt;' &amp; TagCargoGroupAssignments &amp; '&gt;
	&lt;' &amp; TagCargoGroupAssignment &amp; '&gt;
		&lt;' &amp; TagAction &amp; '&gt;' &amp; CM_EDICargoGroupAssign.EDI_ACTION_MODIFY &amp; '&lt;/' &amp; TagAction &amp; '&gt;
		&lt;' &amp; TagCargoGroupAssignmentId &amp; '&gt;' &amp; cargoGroupAssignBaseId &amp; '1&lt;/' &amp; TagCargoGroupAssignmentId &amp; '&gt;
		&lt;' &amp; TagCargoGroup &amp; '&gt;
			&lt;' &amp; TagCargoGroupId &amp; '&gt;' &amp; cargoGroupBaseId &amp; '7&lt;/' &amp; TagCargoGroupId &amp; '&gt;
			&lt;' &amp; TagCargoGroupRemarks &amp; '&gt;' &amp; remarks1 &amp; '&lt;/' &amp; TagCargoGroupRemarks &amp; '&gt;
			&lt;' &amp; TagDefaultLocation &amp; '&gt;' &amp; location &amp; '&lt;/' &amp; TagDefaultLocation &amp; '&gt;
			&lt;' &amp; TagMinWeight &amp; '&gt;3500&lt;/' &amp; TagMinWeight &amp; '&gt;
			&lt;' &amp; TagMaxWeight &amp; '&gt;5500&lt;/' &amp; TagMaxWeight &amp; '&gt;
			&lt;' &amp; TagCargoType &amp; '&gt;' &amp; cargoType &amp; '&lt;/' &amp; TagCargoType &amp; '&gt;
			&lt;' &amp; TagOperator &amp; '&gt;' &amp; operatorCode &amp; '&lt;/' &amp; TagOperator &amp; '&gt;
		&lt;/' &amp; TagCargoGroup &amp; '&gt;
		&lt;' &amp; TagCargoGroup &amp; '&gt;
			&lt;' &amp; TagCargoGroupId &amp; '&gt;' &amp; cargoGroupBaseId &amp; '8&lt;/' &amp; TagCargoGroupId &amp; '&gt;
			&lt;' &amp; TagCargoGroupRemarks &amp; '&gt;' &amp; remarks2 &amp; '&lt;/' &amp; TagCargoGroupRemarks &amp; '&gt;
			&lt;' &amp; TagDefaultLocation &amp; '&gt;' &amp; location &amp; '&lt;/' &amp; TagDefaultLocation &amp; '&gt;
			&lt;' &amp; TagMinWeight &amp; '&gt;3500&lt;/' &amp; TagMinWeight &amp; '&gt;
			&lt;' &amp; TagMaxWeight &amp; '&gt;5500&lt;/' &amp; TagMaxWeight &amp; '&gt;
			&lt;' &amp; TagCargoType &amp; '&gt;' &amp; cargoType &amp; '&lt;/' &amp; TagCargoType &amp; '&gt;
			&lt;' &amp; TagOperator &amp; '&gt;' &amp; operatorCode &amp; '&lt;/' &amp; TagOperator &amp; '&gt;
		&lt;/' &amp; TagCargoGroup &amp; '&gt;
	&lt;/' &amp; TagCargoGroupAssignment &amp; '&gt;
&lt;/' &amp; TagCargoGroupAssignments &amp; '&gt;';

	write exampleXML2;

epilog

	return exampleXML;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="0f9b1e1c-2519-4a18-a851-eef325fa711b">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2015	cnwndl1	Initial creation	Par 36608

*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	message : String;
	xmlDoc : CM_XMLDocument;
	rootElement : JadeXMLElement;
	xmlElements : JadeXMLElementArray;
	xmlElement : JadeXMLElement;
	xmlSubElement : JadeXMLElement;
	xmlIdElement : JadeXMLElement;
	str : String;
	theXMLStr : String;
	
	cgaId : String;
	action : String;
	xmlElementsIds : JadeXMLElementArray;
	idsStrArray : StringArray;
	xmlElementsCGs : JadeXMLElementArray;
	index : Integer;
	xmlElementCG : JadeXMLElement;
	subIndex : Integer;
	
	ediCGA : CM_EDICargoGroupAssign;
	ediCG : CM_EDICargoGroupNotified;
	cgId : String;
	remarks : String;
	location : String;
	minWeight : String;
	maxWeight : String;
	cargoType : String;
	operator : String;
	assignedCargoIds : StringArray;
	
begin	
	create xmlDoc transient;			
	//epr TFS 1834 15/4/16
	message := _ediFile.getRawDataString();
	
	if app.myPassport.myCMIFMonitor &lt;&gt; null then
		app.myPassport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", 4, 3, "Loading EDI file Step 3 of 3.");
	endif;
	
	theXMLStr := message.extractXML();
    if theXMLStr &lt;&gt; null then
	
		xmlDoc.parseString(theXMLStr);
		if xmlDoc.rootElement.tagName = self.TagCargoGroupAssignments then
			rootElement := xmlDoc.rootElement;
		else
			rootElement := xmlDoc.rootElement.getElementByTagName(self.TagCargoGroupAssignments);
		endif;
		
		if rootElement &lt;&gt; null then
		
			create xmlElements transient;
			rootElement.getAllElementsByTagName(self.TagCargoGroupAssignment, xmlElements);
			
			create xmlElementsIds transient;
			create xmlElementsCGs transient;
			create idsStrArray transient;
			create assignedCargoIds transient;
			
			
			foreach xmlElement in xmlElements do
			
				index := index + 1;
			
				idsStrArray.clear();
				xmlElementsCGs.clear();
				xmlElementsIds.clear();
				subIndex := 0;
				
				
				xmlSubElement := null;
				cgaId := null;
				xmlSubElement := xmlElement.getElementByTagName(self.TagCargoGroupAssignmentId);
				if xmlSubElement &lt;&gt; null then
					cgaId := xmlSubElement.textData.trimBlanks;
					if cgaId = null then
						addFileErrors(self.TagCargoGroupAssignment &amp; " [item " &amp; index.String &amp; " in the file] has an empty &lt;" &amp; self.TagCargoGroupAssignmentId &amp; "&gt; tag set", 1, _ediFile);
						return;
					endif;
				else
					addFileErrors(self.TagCargoGroupAssignment&amp; " [item " &amp; index.String &amp; " in the file] missing a &lt;" &amp; self.TagCargoGroupAssignmentId &amp; "&gt; tag set", 1, _ediFile);
					return;
				endif;
				
				xmlSubElement := null;
				xmlSubElement := xmlElement.getElementByTagName(self.TagAction);
				if xmlSubElement &lt;&gt; null then
					action := xmlSubElement.textData.trimBlanks.toUpper;
					if action &lt;&gt; CM_EDICargoGroupAssign.EDI_ACTION_ADD
					and action &lt;&gt; CM_EDICargoGroupAssign.EDI_ACTION_DELETE
					and action &lt;&gt; CM_EDICargoGroupAssign.EDI_ACTION_MODIFY	//10 Jul 2018	NDL	TFS 39186
					then
						addFileErrors( self.TagCargoGroupAssignment &amp; " '" &amp; cgaId &amp; "' invalid &lt;" &amp; self.TagAction &amp; "&gt; must be '"
										&amp; CM_EDICargoGroupAssign.EDI_ACTION_ADD &amp; "' or '" &amp; CM_EDICargoGroupAssign.EDI_ACTION_DELETE
										&amp; "' or '" &amp; CM_EDICargoGroupAssign.EDI_ACTION_MODIFY &amp; "'", 1, _ediFile);
						return;
					endif;
				else
					action := CM_EDICargoGroupAssign.EDI_ACTION_ADD;
				endif;
				
				xmlSubElement := null;
				xmlSubElement := xmlElement.getElementByTagName(self.TagSelectableCargoIds);
				if xmlSubElement &lt;&gt; null then
					xmlSubElement.getAllElementsByTagName(self.TagCargoId, xmlElementsIds);
					if not xmlElementsIds.isEmpty then
						foreach xmlIdElement in xmlElementsIds do
							str := xmlIdElement.textData.trimBlanks;
							if str &lt;&gt; null and not idsStrArray.includes( str )then
								idsStrArray.add( str );
							endif;
						endforeach;
					endif;
				endif;
				
				xmlElement.getAllElementsByTagName(self.TagCargoGroup, xmlElementsCGs);
				if not xmlElementsCGs.isEmpty then
				
					create ediCGA;
					ediCGA.setMyEDIData( _ediFile.ediData );
					ediCGA.messageMode := action;
					ediCGA.setId(cgaId);
					if not idsStrArray.isEmpty then
						idsStrArray.copy( ediCGA.allCargoIds );
					endif;
					
					foreach xmlElementCG in xmlElementsCGs do
						subIndex := subIndex +1;
						
						cgId := null;
						remarks := null;
						location := null;
						minWeight := null;
						maxWeight := null;
						cargoType := null;
						operator := null;
						assignedCargoIds.clear();
						
						xmlSubElement := null;
						xmlSubElement := xmlElementCG.getElementByTagName(self.TagCargoGroupId);
						if xmlSubElement &lt;&gt; null then
							cgId := xmlSubElement.textData.trimBlanks;
							if cgId = null then
								addFileErrors(self.TagCargoGroup &amp; " [" &amp; subIndex.String &amp; " within " &amp; self.TagCargoGroupAssignment &amp; " '" &amp; cgaId &amp; "'] has an empty &lt;" &amp; self.TagCargoGroupId &amp; "&gt; tag set", 1, _ediFile);
								return;
							endif;
						else
							addFileErrors( self.TagCargoGroup &amp; " [" &amp; subIndex.String &amp; " within " &amp; TagCargoGroupAssignment &amp; " '" &amp; cgaId &amp; "'] missing &lt;" &amp; self.TagCargoGroupId &amp; "&gt; tag set", 1, _ediFile);
							return;
						endif;
						
						xmlSubElement := null;
						xmlSubElement := xmlElementCG.getElementByTagName(self.TagCargoGroupRemarks);
						if xmlSubElement &lt;&gt; null then
							remarks := xmlSubElement.textData.trimBlanks;
						endif;
						
						xmlSubElement := null;
						xmlSubElement := xmlElementCG.getElementByTagName(self.TagDefaultLocation);
						if xmlSubElement &lt;&gt; null then
							location := xmlSubElement.textData.trimBlanks;
						endif;
						
						xmlSubElement := null;
						xmlSubElement := xmlElementCG.getElementByTagName(self.TagMinWeight);
						if xmlSubElement &lt;&gt; null then
							minWeight := xmlSubElement.textData.trimBlanks;
						endif;
						
						xmlSubElement := null;
						xmlSubElement := xmlElementCG.getElementByTagName(self.TagMaxWeight);
						if xmlSubElement &lt;&gt; null then
							maxWeight := xmlSubElement.textData.trimBlanks;
						endif;
						
						xmlSubElement := null;
						xmlSubElement := xmlElementCG.getElementByTagName(self.TagCargoType);
						if xmlSubElement &lt;&gt; null then
							cargoType := xmlSubElement.textData.trimBlanks;
						endif;
						
						xmlSubElement := null;
						xmlSubElement := xmlElementCG.getElementByTagName(self.TagOperator);
						if xmlSubElement &lt;&gt; null then
							operator := xmlSubElement.textData.trimBlanks;
						endif;
						
						if action &lt;&gt; CM_EDICargoGroupNotified.EDI_ACTION_MODIFY then	//10 Jul 2018	NDL	TFS 39186 - May not pre-assign during a modify
							xmlSubElement := null;
							xmlSubElement := xmlElementCG.getElementByTagName(self.TagPreAssignedCargoIds);
							if xmlSubElement &lt;&gt; null then
								xmlSubElement.getAllElementsByTagName(self.TagCargoId, xmlElementsIds);
								if not xmlElementsIds.isEmpty then
									foreach xmlIdElement in xmlElementsIds do
										str := xmlIdElement.textData.trimBlanks;
										if str &lt;&gt; null and not assignedCargoIds.includes( str )then
											assignedCargoIds.add( str );
										endif;
									endforeach;
								endif;
							endif;
						endif;
						
						if idsStrArray.isEmpty and assignedCargoIds.isEmpty then
							if action = CM_EDICargoGroupNotified.EDI_ACTION_MODIFY then	//10 Jul 2018	NDL	TFS 39186
								//Don't care, modify only allows the add of new 'Cargo Group'(s) to an existing Cargo Group assignment
							else
								addFileErrors( self.TagCargoGroup &amp; " '" &amp; cgId &amp; "' [within " &amp; TagCargoGroupAssignment &amp; " '" &amp; cgaId &amp; "'] has no pre-assigned or selectable cargo", 1, _ediFile);
								return;
							endif;
						endif;
						
						create ediCG;
						ediCG.setMyEDIData( _ediFile.ediData );
						ediCG.setId(cgId);
						if not assignedCargoIds.isEmpty then
							assignedCargoIds.copy( ediCG.allPreAssignedCargoIds );
						endif;
						ediCG.remarks := remarks;
						ediCG.defaultLocation := location;
						if minWeight.isDecimal then
							ediCG.minWeight := minWeight.Decimal;
						endif;
						if maxWeight.isDecimal then
							ediCG.maxWeight := maxWeight.Decimal;
						endif;
						ediCG.cargoTypeDescr := cargoType;
						ediCG.operatorCode := operator;
						ediCG.myParent := ediCGA;
						
					endforeach;
					
				elseif action = CM_EDICargoGroupAssign.EDI_ACTION_DELETE then
					create ediCGA;
					ediCGA.setMyEDIData( _ediFile.ediData );
					ediCGA.messageMode := action;
					ediCGA.setId(cgaId);
				
				else
					addFileErrors(self.TagCargoGroupAssignment &amp; " [" &amp; index.String &amp; " in the file] must include at least one &lt;" &amp; self.TagCargoGroup &amp; "&gt;", 1, _ediFile);
					return;
					
				endif;
				
			endforeach;
		

		endif;
	endif;
	
epilog
	delete xmlDoc;
	delete xmlElements;
	delete xmlElementsIds;
	delete idsStrArray;
	delete xmlElementsCGs;
	delete assignedCargoIds;
	
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="rawDataToHSA" id="81173bb5-3ca1-4599-b092-ed8fadf42631">
        <source>rawDataToHSA(_ediFile: CM_EDIFile; _theLines: HugeStringArray input);
/*
Purpose:	TFS 40378		
Date				Who			Reason
AUGUST 2018		CNWAB1		Initial creation
*/


vars
	ediFile : CM_EDIFile;
	fileLine : String;
	pos : Integer;
	str : String;
	
begin

	_theLines.clear;
	fileLine := self.rawDataToString(_ediFile);
	if fileLine = null then
		self.compressedDataToHSD(_ediFile, _theLines);
		
	else
		//may have one Cr if it includes an &lt;?xml statement
		pos := fileLine.pos(Cr, 1);
		if pos &gt; 0 and pos &lt; fileLine.length then
			str := fileLine[1:pos];
			fileLine := fileLine[pos+1:end];
			_theLines.add(str);
		endif;

		while fileLine.length &gt; 0 do
			if fileLine.length &gt; 2047 then
				str := fileLine[1:2047];
				fileLine := fileLine[2048:end];
			else
				str := fileLine;
				fileLine := null;
			endif;
			_theLines.add(str);
		endwhile;
		
	endif; 
epilog

end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <Parameter name="_theLines" type="HugeStringArray" usage="input"/>
    </JadeMethod>
</Class>
