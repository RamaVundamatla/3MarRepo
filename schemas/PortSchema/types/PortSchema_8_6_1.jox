	self.setCargoTypeCanGeneratePINs(pControllerObj);			// TFS 41570
	self.changeLockKeeperKPIname(pControllerObj); // jlgka1 TFS 43817
	self.removeTeklogixAuditConfig(pControllerObj);	//05 Apr 2019	NDL	TFS 44152
	self.setBGPMonthlyRecurUnitAndValue(pControllerObj); // jlgka1 TFS 43863
	self.setupMvmntPilotDetails(pControllerObj); // TFS 44438
	self.deleteMvmtPilotDetlsOrphans(pControllerObj); // TFS 45059
	self.createStevedoreDebtorType(pControllerObj);		// TFS 44554 jlgdap1 05/06/2019 
	self.setNewTransResyncPerm(pControllerObj);			// TFS 44554 jlgdap1 11/06/2019 
	self.setWeighBridgePermissions(pControllerObj); //09 Jul 2019	NDL	TFS 44965
	self.setNoConsolidateRoadExit(pControllerObj);	// 15 Jul 2019 jlgndl1 TFS 45300
	self.convertToUseStorageConfig(pControllerObj);	// 23 Jul 2019 jlgndl1 TFS 45574
	self.aSPAfinancialInstance();					//22.07.2019 cnwma1 TFS #45577
	self.setCashPaymentToMerged(pControllerObj); // 05 Aug 2019 jlgdi1 TFS 45301
	self.convertOperatorCarriers(pControllerObj);	// 21 Aug 2019 jlgdap1 TFS 45836
	self.setupCashCreditSequNum(pControllerObj); // TFS 45872
	self.setQueryPerformanceRatings(pControllerObj);	// 05 Sep 2019 jlgndl1 TFS 45891
	self.updatePermissionViewType(pControllerObj);		// 01 Oct 2019 TFS 45802
	self.updateLicenseModules(pControllerObj);	//08 Oct 2019	NDL	TFS 46169
	self.createBOLCalcTypes(pControllerObj);	//31 Oct 2019	NDL	TFS 47100
	self.createBOLDebtorTypes(pControllerObj);	//31 Oct 2019	NDL	TFS 47100
	self.setSpecialStowConfigs(pControllerObj);	//05 Nov 2019 jlgdap1 TFS 46405
	self.updateDrawingAttributes3(pControllerObj);	//05 Nov 2019 jlgdap1 TFS 46405
	self.updateEDIActionActionTypes(pControllerObj);//31/10/2019	JLGNS1	ChangeRequest 46721
	self.updateQueryProperties(pControllerObj); //18/12/19 jlers TFS 47132
epilog

end;</source>
