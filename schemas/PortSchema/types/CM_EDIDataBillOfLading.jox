    <JadeMethod name="setMessageDetails" id="0c5e004a-caba-4be4-9a5f-0571447a0dde">
        <updating/>
        <source>setMessageDetails(_bolNumber, _vesselName, _voyageCode, _operatorCode, _portCode : String; _quantity : Integer) updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 29 September 2008
//
// Implemented version: 7.6.3
// 
//----------------------------------------------------------------------
vars

begin
	self.billOfLading	:= _bolNumber;
	self.vesselName 	:= _vesselName;
	self.voyageCode		:= _voyageCode;
	self.portCode		:= _portCode;
	self.operatorCode	:= _operatorCode;
	self.quantityOnBill := _quantity;
epilog
end;</source>
