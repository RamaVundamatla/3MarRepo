<Class name="CM_WOChangeVoyageRequest" id="951acd54-3083-4756-8c5e-ba53bb5f4e8e">
    <superclass name="CM_WORequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="createWLE" id="490d4672-f4a8-4259-b6c8-91721bb4b0f2">
        <source>createWLE() : CM_WorkListEntry;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema

*/

vars

	wle	: CM_WOChangeVoyageWLE;

begin

	create wle;
	wle.setForCreate(self.myJob, self);
	wle.causeEvent(wle.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), false, wle);	

	return wle;
epilog

end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="createWLEs" id="60cfb87c-658d-4a8d-aa58-2c9c9cbae44a">
        <updating/>
        <source>createWLEs() updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema

*/

vars

	i,
	numReq,
	numTIs		:	Integer;
	aWLE		:	CM_WorkListEntry;
	theTI		: 	CM_TrackedItem;
	iter		: 	Iterator;
begin
	//------------
	//Create the appropriate WLEs
	// 1 for each ti on the job and extra up to totalRequested
	//------------
	
	numTIs := self.myJob.CM_WOChangeVoyageJob.allTrackedItems.size;
	
	numReq := self.totalRequested;
	i := 1;		
	
	if numReq &lt; numTIs then
		numReq := numTIs;
	endif;
	
	iter := self.myJob.CM_WOChangeVoyageJob.allTrackedItems.createIterator;

	// step through all real ti's on the job 
	//then continue untill we have all we need
	
	while iter.next(theTI) do
	// create WLE , create pack  on ti link that to the wle			
		aWLE := self.createWLE();
		aWLE.setMyTrackedItem( theTI); // set the tracked item
		i := i+1;	
	endwhile;
		
	while true do
		if i &gt; numReq then
			//If total requested = 0 then we always create 1
			break;
		endif;

		//create 'empty' WLE's will fill them later
		aWLE := self.createWLE();
		i := i+1;		
	endwhile;

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="typeString" id="eaacbd24-47fb-4e54-9a62-d875c5096735">
        <source>typeString(): String;

/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
