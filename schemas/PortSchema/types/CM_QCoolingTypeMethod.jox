    <JadeMethod name="translateToSearchValueForWeb" id="91b40822-0cd2-4e2e-b1b8-50a2ca1dc967">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	int : Integer;
	rtnValue, str : String;
	intArray : IntegerArray;
	strArray : StringArray;

begin
	if _value.isKindOf(Integer) then
		return app.coolingTypeENumToString(_value.Integer, false);
		
	elseif _value.isKindOf(String) then
		if _sending then
			return _value.String;
		else
			if _value.String.cnContains("|") then
				create strArray transient;
				create intArray transient;
				rtnValue := _value.String;
				rtnValue.getTokensForDelimiter("|", strArray);
				foreach str in strArray do
					intArray.add(app.coolingTypeStringToENum(str));
				endforeach;
				return intArray;
			endif;
			
			return app.coolingTypeStringToENum(_value.String);
		endif;
		
	elseif _value.isKindOf(IntegerArray) then
		foreach int in _value.IntegerArray do
			rtnValue := rtnValue &amp; app.coolingTypeENumToString(int, false) &amp; CNEC_COMMA &amp; Space;
		endforeach;
		rtnValue := rtnValue[1:rtnValue.length-2];
		return rtnValue;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
