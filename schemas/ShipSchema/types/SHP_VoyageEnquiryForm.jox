// ---------------------------------------------------------------------------
// Created:     05/08/08 by cnwaer1
//
// Purpose:     Voyage booking change - for CCMS SFW 1037
// ---------------------------------------------------------------------------
vars

begin
	self.myAssistant.showBookingReferenceForm(self.myCurrentVoyage, self.myMasterMenuAction, self.myTerminal);
end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnCargoForecast_click" id="1831eaeb-05a8-471c-9908-64ed51b436cc">
        <controlMethod name="CMUI_Button::click"/>
