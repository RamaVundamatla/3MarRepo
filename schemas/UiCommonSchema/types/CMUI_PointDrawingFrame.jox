    </JadeMethod>
    <JadeMethod name="convertPolygon" id="168e8ad6-b5ff-44fe-8d52-c113697a3a63">
        <updating/>
        <source>convertPolygon(_theGraphic : CM_LayoutGraphic input; _thePointArray : PointArray input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	thePoint, frstPoint,fromPoint, toPoint : Point;
	idx,x1,x2,y1,y2, theLeft, theTop : Integer;
	theObject : Object;
	thePointArray : PointArray;

begin
	fromPoint := _theGraphic.pointsPolygon[1];
	foreach idx in 2 to _theGraphic.pointsPolygon.size do
		toPoint := _theGraphic.pointsPolygon[idx];
		_thePointArray.add(fromPoint);
		_thePointArray.add(toPoint);
		fromPoint := toPoint;
	endforeach;
	toPoint := _theGraphic.pointsPolygon[1];
	_thePointArray.add(fromPoint);
	_thePointArray.add(toPoint);

end;</source>
        <Parameter name="_theGraphic" type="CM_LayoutGraphic" usage="input"/>
        <Parameter name="_thePointArray" type="PointArray" usage="input"/>
    </JadeMethod>
