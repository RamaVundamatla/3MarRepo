    <JadeMethod name="getVoyageCode" id="0f59fa07-e600-47f2-856f-c89224f57a8f">
        <source>getVoyageCode(): String;
/*

Date		Who		Reason
16 October 2015	cnwer1	Initial creation PAR 37090

*/

vars
	ediTI : CM_EDITrackedItem;
begin
	if self.allEDITrackedItems.size &gt; 0 then
		foreach ediTI in self.allEDITrackedItems discreteLock do
			return ediTI.getVoyageCode;
		endforeach;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
