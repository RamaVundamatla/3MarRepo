    <JadeMethod name="doMnuFormContextMenu" id="6faa0ff2-9b46-46a7-936d-d9f242c93393">
        <updating/>
        <source>doMnuFormContextMenu( conwin : Window input; mouse : Boolean; x : Integer; y : Integer ) : Boolean updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
17 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	tmpMenu		: MenuItem;
	
begin
	// cnwrl1 17/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - start of coding
	self.mnuSummarise.visible	:= false;	// default this menu level to invisible, makes sub-menu invisible.
	if self.bAllowSummaryDefn then
		self.mnuSummarise.visible			:= true;
		// the summarise selected is only enabled if something is actually selected.
		self.mnuSummariseSelected.visible	:= not self.tblData.allSelectedObjects.isEmpty;
	endif;
	tmpMenu	:= self.zCloneMenu( self.mnuTblVCloneDataTbl, self.mnuSummarise, false );
	self.zCloneMenu( tmpMenu, self.mnuSummariseAll, true );
	self.zCloneMenu( tmpMenu, self.mnuSummariseSelected, true );
	// cnwrl1 17/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - end of coding
	
	return inheritMethod( conwin, mouse, x, y );
	
epilog
	
end;
</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
