    <JadeMethod name="btnClose_click" id="312d7c52-9a2f-46f8-978d-38e6271f4739">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		22 July 2001 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	unloadForm();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnUpdate_click" id="3d4a3b8f-08d7-41bc-af92-0b91a314867f">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdate_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		22 July 2001 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.doFormUpdate();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="61003907-a3d8-4ac9-8302-0c5100ce7210">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 July 2001 by cnwdad2
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dbAdminObj	: CnEcDatabaseAdmin;

begin
	inheritMethod();
	
	self.refreshBackupDetails();
	
	dbAdminObj	:=	app.myBaseRoot.myDatabaseAdmin;
	
	if dbAdminObj &lt;&gt; null then
		beginNotification(dbAdminObj, Any_System_Event, Response_Continuous, 0);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="a34e2f99-a6f2-4ad8-b5e4-93a56363fd7d">
        <updating/>
        <source>doFormUpdate(): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 July 2001 by cnwdad2
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	baseAgentObj		: CnEcBaseSchemaAgent;
	dbAdminObj			: CnEcDatabaseAdmin;
	backupDirectory		: String;
	isSystemFiles		: Boolean;
	isQuiesce			: Boolean;
	isVerify			: Boolean;
	isCompress			: Boolean;
	isOverwrite			: Boolean;
	
begin
	if self.doFormValidate() then
		backupDirectory		:=	txtDirectory.cnEcString();
		isSystemFiles		:=	chkIsSystemFiles.value;
		isQuiesce			:=	chkIsQuiesce.value;
		isVerify			:=	chkIsVerify.value;
		isCompress			:=	chkIsCompress.value;
		isOverwrite			:=	chkIsOverwrite.value;
		
		dbAdminObj			:=	app.myBaseRoot.myDatabaseAdmin;
		baseAgentObj		:=	app.myBaseAgent;
		
		self.aError	:=	baseAgentObj.trxDatabaseAdminUpdate(dbAdminObj,
															self.aObjectEdition,
															backupDirectory,
															isSystemFiles,
															isVerify,
															isCompress,
															isOverwrite,
															isQuiesce);
	endif;
epilog
	return self.showError();
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="refreshBackupDetails" id="d4df319e-674a-4355-ba13-1ca5d530ea2b">
        <updating/>
        <source>refreshBackupDetails() updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 July 2001 by cnwdad2
//
// Purpose:		Refreshes the form details.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dbAdminObj	: CnEcDatabaseAdmin;
	
begin
	dbAdminObj	:=	app.myBaseRoot.myDatabaseAdmin;
	
	if dbAdminObj = null then
		txtDirectory.text		:=	null;
		chkIsSystemFiles.value	:=	false;
		chkIsQuiesce.value		:=	false;
		chkIsVerify.value		:=	false;
		chkIsCompress.value		:=	false;
		chkIsOverwrite.value	:=	false;
	else
		txtDirectory.text		:=	dbAdminObj.backupDirectory;
		chkIsSystemFiles.value	:=	dbAdminObj.isIncludeSystemFiles;
		chkIsQuiesce.value		:=	dbAdminObj.isQuiesce;
		chkIsVerify.value		:=	dbAdminObj.isVerifyFiles;
		chkIsCompress.value		:=	dbAdminObj.isCompressFiles;
		chkIsOverwrite.value	:=	dbAdminObj.isOverwriteFiles;
	endif;

	self.resynchObjectAndSetEdition(dbAdminObj);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="startBackup" id="f4e23c61-0aeb-4027-a7ca-b111ef1a21bc">
        <executionLocation>server</executionLocation>
        <source>startBackup() protected, serverExecution;
// --------------------------------------------------------------------------------
// Created:		22 July 2001 by cnwdad2
//
// Purpose:		Initiates the backup.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.startApplication(BaseSchema.name, "BaseBackupApp");
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="aba70662-fcb8-458a-9c6d-df7d3c1466bf">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		22 July 2001 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.refreshBackupDetails();
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</GUIClass>
