end;</source>
    </JadeMethod>
    <JadeMethod name="cleanUpLogResultsDetails" id="3122d916-010d-42f1-855f-cdd8dc022494">
        <source>cleanUpLogResultsDetails();

/*

Purpose:	Clean up the Log Result details

			This will not delete the last 4 runs that were done and will delete the
			previous 4 runs as this takes a while to run.

Date		Who		Reason
15/05/2012	cnwmh5	Initial creation
13 Aug 2012	cnwkpd1	Add audit.dat file into the compact run
22/03/2013	cnwmh5  Add posting of open invoices
11/06/2015	cnwmh5	Remove compact (now run daily via unit test) and change to new details classes

*/
constants
	NumberToKeep				: Integer = 4;
	NumberToDelete				: Integer = 6;        //4;
vars

	root						: UM_Root;
	testRun						: UM_TestRun;
	cleanUpDetails				: UM_CleanUpDetails;
	
	iter						: Iterator;

	count						: Integer;
	ts							: TimeStamp;
	tempTS						: TimeStamp;
	systemID					: String;
	startTS						: TimeStamp;
	endTS						: TimeStamp;
	
begin

	app.initialize();
	
	// check to see if the root exists
	root := UM_Root.firstInstance;
	if root = null then
		app.writeLog("Unable to find UM_Root.  Exiting Application.", LogINFO);
		return;
	endif;
	
	// set up required variables
	startTS := app.cnGetServerTime();
	systemID := CM_Version.VERSION;
	
	// 22/03/2013 cnwmh5 - Post Open Invoices
	self.postXNumOpenInvoicesB4Date();			
	app.writeLog("Deleting " &amp; NumberToDelete.String &amp; " Log Result run(s) before " &amp; ts.date.String, LogINFO);
	
	// Find the last Sunday run based on today's date
	while ts.date.dayOfWeek() &lt;= 5 do
		ts.setDate(ts.date.addDays(-1));
	endwhile;
	ts.setTime("23:59:59".Time);
		
	// Find the first one that we want to delete
	count := 1;
	iter := root.allTestRuns.createIterator;
	root.allTestRuns.startKeyLeq(ts, iter);
	while iter.back(testRun) do
		//if testRun.startTimestamp.date.dayOfWeek() = 7 then
			if testRun.startTimestamp.date &lt; ts.date then
				ts := testRun.startTimestamp;
				count := count + 1;
			endif;
		//endif;	
		if count = NumberToKeep then
			break;
		endif;
	endwhile;

	// Delete the records
	count := 1;
	iter.next(testRun);
	while iter.back(testRun) do
		//if testRun.startTimestamp.date.dayOfWeek() = 7 then
			if testRun.startTimestamp.date &lt; ts.date then
				ts := testRun.startTimestamp;
				count := count + 1;
			endif;
			if count &gt; NumberToDelete then
				break;
			endif;
			tempTS := testRun.startTimestamp;
			app.writeLog("Deleting testRun (" &amp; testRun.startTimestamp.String &amp; ").  Please wait...", LogINFO);
			beginTransaction;
			delete testRun;
			commitTransaction;
			app.writeLog("Finished deleting testRun (" &amp; tempTS.String &amp; ").", LogINFO);
		//endif;	
	endwhile;
	endTS := app.cnGetServerTime();
	beginTransaction;
	create cleanUpDetails persistent;
	///cleanUpDetails.createRecord(startTS, endTS, count, "Delete", 0, 0);	
	cleanUpDetails.updateDetails(startTS, endTS, count, UM_CleanUpDetails.TaskDescriptionDeleteCMLookup, null);
	commitTransaction;
	
epilog

	delete iter;
	
	
	terminate;

end;</source>
    </JadeMethod>
    <JadeMethod name="cmd_AfterAutomatedRunChecks" id="1964303a-4989-42bd-8c90-813375a0f189">
        <updating/>
        <source>cmd_AfterAutomatedRunChecks() updating;

/*

Purpose:		

Date			Who		Reason
15 June 2016	cnwmh5	Initial creation

*/

vars

begin

	app.initialize();
	app.writeLog("Starting After Automated Run Checks", LogINFO);
	self.afterAutomatedRunChecks(self.getThinClientCommandLine());

epilog

	terminate;

end;</source>
    </JadeMethod>
    <JadeMethod name="cmd_Main" id="bbb1f9b0-4971-4439-8a53-eb97a52875da">
        <updating/>
        <source>cmd_Main() updating;
//29 April 2009	cnwdw1	
// 04/04/2011	cnwmh5	Add initialize and terminate
vars

begin
	app.initialize();
	app.writeLog("Starting Unit Test Run", LogINFO);
	self.main(self.getThinClientCommandLine());
epilog
	app.writeLog("Ending Unit Test Run", LogINFO);
	self.allCategories.purge();			// 13/09/2012 cnwmc5    transient leak issue
	self.allTerminalActiveCargoMaps.clear();				// 20/03/2013 cnwmh5
	delete self.allCategories;						// 13/09/2012 cnwmc5    transient leak issue
	delete self.myMobileAgent;						// 13/09/2012 cnwmc5    transient leak issue
	terminate;
end;</source>
    </JadeMethod>
    <JadeMethod name="cmd_Main_Auto" id="b9ea1385-f36b-4e9b-aaca-53745645fe56">
        <updating/>
        <source>cmd_Main_Auto() updating;

/*

Purpose:		Automatic overnight job	

Date		Who		Reason
29 March 2011	cnwmh5	Initial creation

*/

constants
	UT_SECTION_NAME = "UnitTest_Run";
vars

	runDaysOfWeekArray		: StringArray;
	runTimesArray			: StringArray;
	
	millisecsTillNextRun	: Integer;
	runDaysOfTheWeek		: String;
	runTimes				: String;
	currentTimeStamp		: TimeStamp;
	nextScheduledRun		: TimeStamp;
	
begin

	app.initialize();

	// get the days to run and times to run
	create runDaysOfWeekArray transient;
	runDaysOfTheWeek := app.getProfileString(app.getIniFileNameAppServer(), UT_SECTION_NAME, "RunDaysOfTheWeek", null);
	runDaysOfTheWeek.getTokensForDelimiter(",", runDaysOfWeekArray);
	create runTimesArray transient;
	runTimes := app.getProfileString(app.getIniFileNameAppServer(), UT_SECTION_NAME, "RunTimes", null);
	runTimes.getTokensForDelimiter(",", runTimesArray);
	
	// if either are empty then don't do anything
	if runDaysOfWeekArray.isEmpty() or runTimesArray.isEmpty() then
		self.writeLog(Tab &amp; 'Empty details', LogINFO);
		terminate;
	endif;
		
	// get the current day of the week
	currentTimeStamp := app.actualTimeServer();
	self.writeLog(Tab &amp; 'Current Date: ' &amp; currentTimeStamp.String &amp; Tab &amp; currentTimeStamp.date.dayName, LogINFO);
	
	nextScheduledRun := app.getTSForNextScheduledRun(currentTimeStamp, runDaysOfWeekArray, runTimesArray);
	
	self.writeLog(Tab &amp; 'Next Scheduled Run Date is ' &amp; nextScheduledRun.String &amp; Tab &amp; nextScheduledRun.date.dayName, LogINFO);
		
	// get the number of seconds till the next run
	millisecsTillNextRun := (nextScheduledRun.getDifferenceInSeconds(currentTimeStamp) * 1000).Integer;
		
	// begin the timer to watch what goes on
	beginTimer(millisecsTillNextRun, Timer_OneShot, 911);
		
epilog

	delete runTimesArray;
	delete runDaysOfWeekArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="convertScannedCargoId" id="b566b6c2-afc2-4654-8c48-ea7752e1744c">
        <source>convertScannedCargoId( _term : CM_Terminal; _textBox : TextBox input; _isAlternateId : Boolean; _passedCmif : CMIF_IDConversion input ):String;
/*

Purpose:			

Parameters:			Scanned Vehicle VIN numbers sometimes contain extra characters
					as prefixes or suffixs, depending upon the manufacture.
					The displayed VIN number is always 17 characters, and for Oman is used as teh cargo id.
					
					Use _textBox by itself, to take the value directly from the text box, convert it and set
					back into the text box. 
					
					Supply the cmif to use, already populated to ( reset the optionally supplied texbox, or )
					to just return the converted string value.

Return Value:		

Date		Who		Reason
05 July 2016	cnwndl1	Initial creation	TFS 2275 / 2216

*/

vars

	cmif : CMIF_IDConversion;
	rawText : String;
	processedText : String;
	doDeleteCmif : Boolean;
	root : CM_Root;
	
begin

	if _passedCmif &lt;&gt; null and _passedCmif.scannedValue &lt;&gt; null then
		rawText := _passedCmif.scannedValue;
	elseif _textBox &lt;&gt; null then
		rawText := _textBox.text;
	endif;
	
	if rawText = null then
		return null;
	endif;

	if _passedCmif &lt;&gt; null then
		// if there is a passed in version then use it because it may have other context attributes
		// that are also populated that help the comversion.
		doDeleteCmif := false;
		cmif := _passedCmif;
		if cmif.myTerminal = null then
			cmif.myTerminal := _term;
		endif;
		if cmif.scannedValue = null then
			cmif.scannedValue := rawText;
		endif;
		if not cmif.isAlternateId then
			cmif.isAlternateId := _isAlternateId;
		endif;
	
	else
		doDeleteCmif := true;
		create cmif transient;
		cmif.myTerminal := _term;
		cmif.scannedValue := rawText;
		cmif.isAlternateId := _isAlternateId;
		cmif.callerName := "UT";	//18 Aug 2016	NDL	TFS 2567
		
	endif;
	
	root := app.myRoot;
	// default behaviour for the hook code is to call root::doConvertCargoId
	processedText :=  app.myHookAgent.runHookLinkPublic(HookType_CargoIdConversion,
														root,
														root,
														cmif
														).String;
		

	if _textBox &lt;&gt; null then
		_textBox.text := processedText;
	endif;
	
	return processedText;

epilog

	if doDeleteCmif then
		delete cmif;
	endif;

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_textBox" type="TextBox" usage="input"/>
        <Parameter name="_isAlternateId" type="Boolean"/>
        <Parameter name="_passedCmif" type="CMIF_IDConversion" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
