    <JadeMethod name="validateMe" id="69c11b54-de03-493b-9293-78d402a7a2ae">
        <source>validateMe() protected;
// ---------------------------------------------------------------------------
// Created:     21 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
//16/07/2018 	jlgns1	Bug 39380: STWO - Transaction incorrectly classified as OVERTIME
vars

	year : Integer;
	nullTime : Time;
	
begin
	
	//epr par 34982 2/10/14
	if not self.date.isValid then
		app.raiseCMException(ERR_DATETIME_FORMAT,null,null);
		return;
	endif;
	
	year	:=	self.date.year;
	
	
	if self.myCalendarYear.year &lt;&gt; year then 
		app.raiseCMException2(ERR_FIELD_YEAR ,year.String, 'Year ' &amp; self.myCalendarYear.year.String, 'Year', null);	
	elseif self.date = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Calendar Code', null, null);
		app.raiseCMException(Input_required_field_CalCode, null, null); // cnwdb2	PAR 35364


	endif;
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Calendar Description', null, null);
		app.raiseCMException(Input_required_field_CalDesc, null, null); // cnwdb2	PAR 35364


	endif;
	if self.myCalendarYear = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Year', null, null);
		app.raiseCMException(Input_required_field_year, null, null);

	endif;
	if self.myCalendar = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Calendar', null, null);
		app.raiseCMException(Input_required_field_calender, null, null);
	endif;
	
	nullTime := "00:00:00".Time;
	if self.startTime &lt;&gt; nullTime and self.endTime &lt;&gt; nullTime then
		if startTime &gt;= endTime then										//	Bug 39380
			app.raiseCMException1(EndBeforeStart, null, null, null);
		endif;
	endif;
		
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
