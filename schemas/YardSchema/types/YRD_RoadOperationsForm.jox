    <JadeMethod name="getAllSelectedTIs" id="1e7e6796-8356-4e47-9414-b6a71cfda724">
        <updating/>
        <source>getAllSelectedTIs( _allTIs : ObjectArray input;_includeBulkVisitWLEs :Boolean) updating;
/*

Date		Who		Reason
06 May 2016	cnwer1	Initial creation PAR
//nds TFS 2867 17/01/17 PKT - Bulk Process
*/

vars
	wleTable : CM_DataTable;
	wleArray : CM_WLEArray;
	wle : CM_WorkListEntry;

begin
	wleTable := self.myCurrentTable;
	if wleTable = null then
		return;
	endif;
	
	create wleArray transient;
	
	self.getAllWLEsInTableSelected(wleArray,wleTable ,_includeBulkVisitWLEs);//nds TFS 2867 17/01/17 PKT - Bulk Process
	
	foreach wle in wleArray do
		if wle.myTrackedItem &lt;&gt; null then
			_allTIs.add(wle.myTrackedItem);
		endif;
	endforeach;
epilog
	delete wleArray;

end;</source>
        <Parameter name="_allTIs" type="ObjectArray" usage="input"/>
        <Parameter name="_includeBulkVisitWLEs" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllWLEsInTable" id="2a905b2e-232c-44d6-89ea-348221d6793a">
        <updating/>
        <source>getAllWLEsInTable(	_wleArray : CM_WLEArray input;
					_wleTable	: CM_DataTable input;
					_includeBulkVisitWLEs :Boolean) updating;
//-----------------------------------------

//nds TFS 2867 17/01/17 PKT - Bulk Process
//-----------------------------------------
vars	
	obj			:Object;
	wle 		:CM_WorkListEntry;
	invalidWLE	:Boolean;
	idx, rows 	:Integer;
begin
	on Exception do app.handleDeletedObject (exception, wle, invalidWLE);
	
	beginLoad;
	
	rows := _wleTable.rows;
	
	foreach idx in 2 to rows do
		invalidWLE 	:= false;	// for next time
		obj 		:= _wleTable.accessRow(idx).itemObject;
		
		if obj = null then
			continue;
		endif;
		
		if not CM_WorkListEntry.hasInstance (obj) then
			// probably a terminal area heading
			continue;
		endif;
		
		wle := obj.CM_WorkListEntry;	// won't cause exception
		
		self.sharedLock(wle);	

		if invalidWLE then
			// an exception occurred doing the lock
			continue;
		endif;
		
		if not _includeBulkVisitWLEs and wle.isBulkGateVisit() then	//nds TFS 2867 17/01/17 PKT - Bulk Process
			continue;												//nds TFS 2867 17/01/17 PKT - Bulk Process
		endif;														//nds TFS 2867 17/01/17 PKT - Bulk Process
		
		if (not _wleArray.includes(wle)) then			
			_wleArray.add(wle);
		endif;
	endforeach;
epilog
	endLoad;
end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
        <Parameter name="_wleTable" type="CM_DataTable" usage="input"/>
        <Parameter name="_includeBulkVisitWLEs" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllWLEsInTableSelected" id="8889e7bf-df8a-4ed1-81a5-b36fe46d5b49">
        <source>getAllWLEsInTableSelected(	_wleArray : CM_WLEArray input;
							_wleTable	: CM_DataTable input;
							_includeBulkVisitWLEs :Boolean);
//--------------------------------------------------------------
//nds TFS 2867 17/01/17 PKT - Bulk Process
//--------------------------------------------------------------
vars
	obj 		: Object;
	wle			: CM_WorkListEntry;
	invalidWLE	: Boolean;
begin
	on Exception do app.handleDeletedObject (exception, wle, invalidWLE);
	
	beginLoad;
	
	foreach obj in _wleTable.allSelectedObjects do
		invalidWLE := false;	
		
		if CM_WorkListEntry.hasInstance(obj) then
			wle := obj.CM_WorkListEntry;	// won't cause exception
		endif;	
		
		if wle = null then
			continue;
		endif;
		
		self.sharedLock(wle);
		
		if invalidWLE then
			// an exception occurred doing the lock
			continue;
		endif;
		
		if not _includeBulkVisitWLEs and wle.isBulkGateVisit() then	//nds TFS 2867 17/01/17 PKT - Bulk Process
			continue;												//nds TFS 2867 17/01/17 PKT - Bulk Process
		endif;														//nds TFS 2867 17/01/17 PKT - Bulk Process
		
		_wleArray.add(wle);
	endforeach;
epilog
	endLoad;
end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
        <Parameter name="_wleTable" type="CM_DataTable" usage="input"/>
        <Parameter name="_includeBulkVisitWLEs" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDeleteReason" id="c3f02559-2a0a-400c-8f35-e51ed56b661e">
        <source>getDeleteReason( _extraInfo : String ) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2010	cnwrd1	Initial creation
// cnwrd1 par 22624 3.5.2010
//18 Feb 2011	NDL Par 27046 - added _extraInfo
*/

vars

	inputBox	: CMUI_InputBox;
	numHours	: Integer;
	errorSet	: CM_ErrorSet;
	theError	: CM_Error;
	result 		: String;
begin

	app.mousePointer := MousePointer_Default;
	
	create inputBox transient;
	create errorSet transient;
	
	inputBox.init(	app.getErrorString( Cancellation ),app.getErrorString( Road_cancellati_reason) &amp; _extraInfo,
					'', 30, TextBox.DataType_AlphaNumeric, TextBox.Case_None, false, false);
	
	//inputBox.btnCancel.visible := false;
	inputBox.myTerminal := self.myTerminal;
	//inputBox.btnOk.left := inputBox.btnCancel.left;
	inputBox.showModal;
	if inputBox.modalResult &lt;&gt; IDOK then
		return '';
	endif;
	
	result := inputBox.txtInput.text.String;

	app.mousePointer := MousePointer_HourGlass;
	return result;
epilog

end;</source>
        <Parameter name="_extraInfo" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayMode" id="bc63d165-9a2f-4588-87dc-73e90d22d757">
        <source>getDisplayMode() : Integer;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
