    <JadeMethod name="tSideViewTest" id="6ac74a28-8ba2-4d2b-bf05-2acb6237838c">
        <updating/>
        <source>tSideViewTest() updating;
// cnwmp6
/*

Purpose:			Requires the Terminal to have an exisiting workpoint called 'WP1'

					trxDeleteRORORequests					Done
					trxUpdateVoyageJob						Done
					trxUpdateVoyageJobRemarks				Done
					trxUpdateVoyageJobsNumber				Done
					trxUpdateVoyageJobNumber				Done
					trxUpdateWpOperatingHrs					Done
					trxDeleteWPOperatingHours				

Date				Who		Reason
02 August 2013		cnwmc5	Initial creation
17/02/2014			cnwmh5	Liven up and add the above trx's

*/
constants
	
	VOYAGE 				: String = 'SIDE0000001';
	VESSEL 				: String = 'SIDE0000001';
	WP					: String = 'SIDE_WP1';
	BS					: String = 'SIDE_BS1';
	
vars
	voyage 				: CM_Voyage;
	wp					: CM_WorkPoint;
	
	voyageDeck1,
	voyageDeck1S		: CM_DeckVoyage;
	
	voyageJob			: CM_VoyageJob;
	voyageJob2			: CM_VoyageJob;
	
	slotsJob1,
	slotsJob2,
	slotsJob3,
	sobSlots,
	altSOBSlots			: CM_LCArray;
	slot				: CM_ROROSlotController;
	
	theEditions			: CM_ObjectByOidEditionDict;
	theJobs 			: CM_VoyageJobByJobNumDict;
	theJobs2			: CM_VoyageJobByJobNumDict;
	wpOpHours			: CM_WorkPointOperatingHours;
	
	lcSet				: CM_LCSet;
	
	pxyJob				: CM_VoyageJob;
	job200				: CM_Job;
	job					: CM_Job;
	bs 					: CM_BlockStack;
	req 				: CM_Request;
	wle 				: CM_WorkListEntry;
	location 			: CM_LocationsController;
	port				: CM_Port;
	cargo				: CM_Container;
	
	count				: Integer;
	tiId				: String;
	
	roroLCs,
	altROROLCs			: CM_LCArray;
	realAllocGen2,
	realAllocGen4		: CM_VoyageAllocation;
	
	tmpOptionsUsed 		: IntegerArray;
	allJobs 			: CM_JobArray;
	jobSheet			: CM_VoyageJobSheet;
	controller			: CMIF_ShipPlanningController;
	
	planIfStops,
	planFromRowEnds,
	useWeights,
	planAccrossTermArea,
	planAccrossTermAreaCol,
	ignoreWarnings,
	planTwinLift		: Boolean;
	
	height,
	numRowSep,
	weightAve,
	weightPC			: Integer;
	
	jobNum				: String;
	isBulkEdit			: Boolean;
	jobNumber			: Integer;
	countNum			: Integer;
	remarks				: String;
	
begin
	
	//Setup voyage and vessel
	self.deleteVoyage(VOYAGE);
	self.deleteVessel(VESSEL);
	self.deleteTerminalArea(BS);
	
	//self.addVesselConRORO(VESSEL, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	//self.addVoyageWithConRORO(VOYAGE, VESSEL, self.getProfileSetting(UT_Profile.P_OPERATOR).asString,  self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, 
	//	null, 0, false, true);
	voyage := self.createVesselVoyage(VOYAGE, VESSEL, null);
	self.assertNotNull(voyage);
	
	//Setup the workpoint
	wp := self.getWorkpoint(WP);
	if wp = null then
		wp := self.addWorkPoint(WP, false);
	endif;
	self.assertNotNull(wp);
	
	//Create blockstack
	bs := self.addBlockStack(BS, 1000, null);
	self.assertNotNull(bs);
	
	//Get the decks required
	voyageDeck1 := voyage.myROROStructure.allDecksByCode["D1"];
	self.assertNotNull(voyageDeck1);
	
	voyageDeck1S := voyage.myROROStructure.allDecksByCode["D1"].allSubDecks[1];
	self.assertNotNull(voyageDeck1S);
	
	//Add cargo to the voyage
	self.createCargoOnship2(voyage);
	
	/*
	******************
		DISCHARGE
	******************
	*/	
	//Setup Colour Coding on Deck 1 (40ft conts)	
	self.doDLRSOBCCSlots(voyageDeck1, false, DISCHARGE_MOVETYPE, "1");
	self.doDLRSOBCCSlots(voyageDeck1, false, DLR_MOVETYPE, "2");
	self.doDLRSOBCCSlots(voyageDeck1, false, SOB_MOVETYPE, "3");
	
	//Setup Colour Coding on Sub Deck 1 (20ft conts)
	self.doDLRSOBCCSlots(voyageDeck1S, true, DISCHARGE_MOVETYPE, "1");
	self.doDLRSOBCCSlots(voyageDeck1S, true, DLR_MOVETYPE, "2");
	self.doDLRSOBCCSlots(voyageDeck1S, true, SOB_MOVETYPE, "3");
	
	//Create SOB links
	create sobSlots transient;
	create altSOBSlots transient;
	create theEditions transient;
	create lcSet transient;
	
	//Get the 40ft slots for SOB
	foreach slot in voyageDeck1.allROROSlotControllers do
		if slot.ident = "AUTOLOCN323"
		or slot.ident = "AUTOLOCN343"
		or slot.ident = "AUTOLOCN373"
		or slot.ident = "AUTOLOCN393"
		or slot.ident = "AUTOLOCN413"
		or slot.ident = "AUTOLOCN443"
		or slot.ident = "AUTOLOCN463"
		or slot.ident = "AUTOLOCN483" then
			self.getJobROROControllerByID(voyage.code, voyageDeck1.code, null, slot.ident, sobSlots, false, 1);
		endif;
	endforeach;
	
	//Get the 20ft slots for SOB and the alt slots
	foreach slot in voyageDeck1S.allROROSlotControllers do
		if slot.ident = "AUTOLOCN103"
		or slot.ident = "AUTOLOCN123"
		or slot.ident = "AUTOLOCN133"
		or slot.ident = "AUTOLOCN143"
		or slot.ident = "AUTOLOCN183"
		or slot.ident = "AUTOLOCN193"
		or slot.ident = "AUTOLOCN233"
		or slot.ident = "AUTOLOCN243"
		or slot.ident = "AUTOLOCN283"
		or slot.ident = "AUTOLOCN293"
		or slot.ident = "AUTOLOCN333"
		or slot.ident = "AUTOLOCN343" then
			self.getJobROROControllerByID(voyage.code, voyageDeck1.code, voyageDeck1S.code, slot.ident, sobSlots, false, 1);
		endif;
		
		if slot.ident.length &gt; 10
		and (slot.ident[1:10] = "AUTOLOCN37"
		or slot.ident[1:10] = "AUTOLOCN44"
		or slot.ident[1:10] = "AUTOLOCN51"
		or slot.ident[1:10] = "AUTOLOCN58"
		or slot.ident[1:10] = "AUTOLOCN42"
		or slot.ident[1:10] = "AUTOLOCN49"
		or slot.ident = "AUTOLOCN561"
		or slot.ident = "AUTOLOCN562") then
			self.getJobROROControllerByID(voyage.code, voyageDeck1.code, voyageDeck1S.code, slot.ident, altSOBSlots, false, 1);
		endif;
	endforeach;
	
	self.assertNotNull(sobSlots);
	
	//Remove SOB CC
	sobSlots.copyNoDuplicates(lcSet);
	app.myTrxDA.trxDeleteRORORequests(lcSet, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//Add new SOB CC with links
	sobSlots.copyNoDuplicates(theEditions);
	altSOBSlots.copyNoDuplicates(theEditions);
	app.myTrxUA.doRORORequestDLRSoB(sobSlots, altSOBSlots, false, SOB_MOVETYPE, theEditions, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//Setup Jobs on Deck 1 (40ft conts)
	create slotsJob1 transient;
	create slotsJob2 transient;
	foreach slot in voyageDeck1.allROROSlotControllers do
		if slot.ident.length &gt; 10
		and (slot.ident[1:10] = "AUTOLOCN17"
		or slot.ident[1:10] = "AUTOLOCN19"
		or slot.ident[1:10] = "AUTOLOCN22"
		or slot.ident[1:10] = "AUTOLOCN24"
		or slot.ident[1:10] = "AUTOLOCN27"
		or slot.ident[1:10] = "AUTOLOCN29") then
			slotsJob1.add(slot);
		endif;
		
		if slot.ident.length &gt; 10
		and (slot.ident[1:10] = "AUTOLOCN32"
		or slot.ident[1:10] = "AUTOLOCN34"
		or slot.ident[1:10] = "AUTOLOCN37"
		or slot.ident[1:10] = "AUTOLOCN39"
		or slot.ident[1:10] = "AUTOLOCN41"
		or slot.ident[1:10] = "AUTOLOCN44"
		or slot.ident[1:10] = "AUTOLOCN46"
		or slot.ident[1:10] = "AUTOLOCN48") then
			slotsJob2.add(slot);
		endif;
		
		
		
	endforeach;
	
	voyageJob := self.addVoyageROROJob(voyage, voyageDeck1, wp.code, slotsJob1, true);
	assertTrue(voyageJob &lt;&gt; null);
	voyageJob := self.addVoyageROROJob(voyage, voyageDeck1, wp.code, slotsJob2, true);
	assertTrue(voyageJob &lt;&gt; null);
		
	//Setup Jobs on Sub Deck 1 (20ft conts)
	slotsJob1.clear();
	slotsJob2.clear();
	foreach slot in voyageDeck1S.allROROSlotControllers do
		if slot.ident.length &gt; 10
		and (slot.ident[1:10] = "AUTOLOCN11"
		or slot.ident[1:10] = "AUTOLOCN16"
		or slot.ident[1:10] = "AUTOLOCN17"
		or slot.ident[1:10] = "AUTOLOCN21"
		or slot.ident[1:10] = "AUTOLOCN22"
		or slot.ident[1:10] = "AUTOLOCN26"
		or slot.ident[1:10] = "AUTOLOCN27"
		or slot.ident[1:10] = "AUTOLOCN31"
		or slot.ident[1:10] = "AUTOLOCN32") then
			slotsJob1.add(slot);
		endif;
		
		if slot.ident.length &gt; 10
		and (slot.ident[1:10] = "AUTOLOCN10"
		or slot.ident[1:10] = "AUTOLOCN12"
		or slot.ident[1:10] = "AUTOLOCN13"
		or slot.ident[1:10] = "AUTOLOCN14"
		or slot.ident[1:10] = "AUTOLOCN18"
		or slot.ident[1:10] = "AUTOLOCN19"
		or slot.ident[1:10] = "AUTOLOCN23"
		or slot.ident[1:10] = "AUTOLOCN24"
		or slot.ident[1:10] = "AUTOLOCN28"
		or slot.ident[1:10] = "AUTOLOCN29"
		or slot.ident[1:10] = "AUTOLOCN33"
		or slot.ident[1:10] = "AUTOLOCN34") then
			slotsJob2.add(slot);
		endif;
	endforeach;
	
	voyageJob := self.addVoyageROROJob(voyage, voyageDeck1S, wp.code, slotsJob1, true);
	assertTrue(voyageJob &lt;&gt; null);
	voyageJob := self.addVoyageROROJob(voyage, voyageDeck1S, wp.code, slotsJob2, true);
	assertTrue(voyageJob &lt;&gt; null);
	
	//Plan cargo	
	location := bs.allLocationsControllers.first;

	foreach job in voyage.allVoyageJobs  discreteLock do
		if job.id = "201"
		or job.id = "205" then
			foreach req in job.allRequests discreteLock do
				if req.isSOB then
					continue;
				endif;
				
				foreach wle in req.allWorkListEntries discreteLock do
					self.movePlannedWLE(wle.myTrackedItem, location, wle);
				endforeach;
			endforeach;
		endif;
	endforeach;
	
	self.expectTrxError(Cargo_that_locat_colou_codedee);
	self.expectTrxError(WarningPileHeightExceed2);
	self.expectTrxError(SystemAlertCreated);
	
	//Move containers in required jobs
	foreach job in voyage.allVoyageJobs  discreteLock do
		if job.CM_VoyageJob.isHatchLidJob() then
			continue;
		endif;
		
		if job.CM_VoyageJob.status = JOB_COMPLETE then
			continue;
		endif;
		
		if job.id = "201"
		or job.id = "205" then
			self.moveCargoForVoyageJob(job, REAL_MODE);
		endif;
	endforeach;
	
	/*
	*************
		LOAD
	*************
	*/
	//Setup Colour Coding on Deck 1 - 20's
	create roroLCs transient;
	create altROROLCs transient;
	
	foreach slot in voyageDeck1.allROROSlotControllers do
		if (slot.ident.length = 10 
		and (slot.ident[1:9] = "AUTOLOCN1"
		or slot.ident[1:9] = "AUTOLOCN2"
		or slot.ident[1:9] = "AUTOLOCN6"
		or slot.ident[1:9] = "AUTOLOCN7"))
		or (slot.ident.length &gt; 10 
		and (slot.ident[1:10] = "AUTOLOCN11"
		or slot.ident[1:10] = "AUTOLOCN12"
		or slot.ident[1:10] = "AUTOLOCN16"
		or slot.ident[1:10] = "AUTOLOCN17"
		or slot.ident[1:10] = "AUTOLOCN21"
		or slot.ident[1:10] = "AUTOLOCN22"
		or slot.ident[1:10] = "AUTOLOCN26"
		or slot.ident[1:10] = "AUTOLOCN27"
		or slot.ident[1:10] = "AUTOLOCN31"
		or slot.ident[1:10] = "AUTOLOCN32"
		or slot.ident[1:10] = "AUTOLOCN36"
		or slot.ident[1:10] = "AUTOLOCN37"
		or slot.ident[1:10] = "AUTOLOCN38"
		or slot.ident[1:10] = "AUTOLOCN39"
		or slot.ident[1:10] = "AUTOLOCN40"
		or slot.ident[1:10] = "AUTOLOCN41")) then
			self.getJobROROControllerByID(voyage.code, voyageDeck1.code, null, slot.ident, roroLCs, false, 1);
		endif;
	endforeach;
	
	self.assertNotNull(roroLCs);
	realAllocGen2 := self.addVoyageAllocation(voyage, "NZAKL", "GEN2", null, TI_CargoType_Container, false, false);
	self.addLCsToROROAllocation(true, realAllocGen2, roroLCs, altROROLCs, 1);
	
	//Setup Colour Coding on Deck 1 - 40's
	roroLCs.clear();
	
	foreach slot in voyageDeck1.allROROSlotControllers do
		if (slot.ident.length = 10 
		and (slot.ident[1:9] = "AUTOLOCN4"
		or slot.ident[1:9] = "AUTOLOCN9"))
		or (slot.ident.length &gt; 10 
		and (slot.ident[1:10] = "AUTOLOCN14"
		or slot.ident[1:10] = "AUTOLOCN19"
		or slot.ident[1:10] = "AUTOLOCN24"
		or slot.ident[1:10] = "AUTOLOCN29"
		or slot.ident[1:10] = "AUTOLOCN34"
		or slot.ident[1:10] = "AUTOLOCN44"
		or slot.ident[1:10] = "AUTOLOCN46"
		or slot.ident[1:10] = "AUTOLOCN48")) then
			self.getJobROROControllerByID(voyage.code, voyageDeck1.code, null, slot.ident, roroLCs, false, 1);
		endif;
	endforeach;
	
	self.assertNotNull(roroLCs);
	realAllocGen4 := self.addVoyageAllocation(voyage, "NZAKL", "GEN4", null, TI_CargoType_Container, false, false);
	self.addLCsToROROAllocation(true, realAllocGen4, roroLCs, altROROLCs, 1);
	
	//Setup Colour Coding on Sub Deck 1 - 20's
	roroLCs.clear();
	
	foreach slot in voyageDeck1.allROROSlotControllers do
		if (slot.ident.length = 10 
		and (slot.ident[1:9] = "AUTOLOCN3"
		or slot.ident[1:9] = "AUTOLOCN4"
		or slot.ident[1:9] = "AUTOLOCN5"))
		or (slot.ident.length &gt; 10 
		and (slot.ident[1:10] = "AUTOLOCN10"
		or slot.ident[1:10] = "AUTOLOCN11"
		or slot.ident[1:10] = "AUTOLOCN12"
		or slot.ident[1:10] = "AUTOLOCN13"
		or slot.ident[1:10] = "AUTOLOCN14"
		or slot.ident[1:10] = "AUTOLOCN16"
		or slot.ident[1:10] = "AUTOLOCN17")) then
			self.getJobROROControllerByID(voyage.code, voyageDeck1.code, voyageDeck1S.code, slot.ident, roroLCs, false, 1);
		endif;
	endforeach;
	
	self.assertNotNull(roroLCs);
	self.addLCsToROROAllocation(true, realAllocGen2, roroLCs, altROROLCs, 1);
	
	//Setup Colour Coding on Sub Deck 1 - 40's
	roroLCs.clear();
	
	foreach slot in voyageDeck1.allROROSlotControllers do
		if (slot.ident.length = 10 
		and (slot.ident[1:9] = "AUTOLOCN2"
		or slot.ident[1:9] = "AUTOLOCN7"
		or slot.ident[1:9] = "AUTOLOCN9"))
		or (slot.ident.length &gt; 10 
		and (slot.ident[1:10] = "AUTOLOCN19"
		or slot.ident[1:10] = "AUTOLOCN22"
		or slot.ident[1:10] = "AUTOLOCN24"
		or slot.ident[1:10] = "AUTOLOCN27"
		or slot.ident[1:10] = "AUTOLOCN29"
		or slot.ident[1:10] = "AUTOLOCN32"
		or slot.ident[1:10] = "AUTOLOCN34")) then
			self.getJobROROControllerByID(voyage.code, voyageDeck1.code, voyageDeck1S.code, slot.ident, roroLCs, false, 1);
		endif;
	endforeach;
	
	self.assertNotNull(roroLCs);
	self.addLCsToROROAllocation(true, realAllocGen4, roroLCs, altROROLCs, 1);
	
	//Setup Jobs on Deck 1 (mix of 20's and 40's)
	slotsJob1.clear();
	slotsJob2.clear();
	create slotsJob3 transient;
	
	foreach slot in voyageDeck1.allROROSlotControllers do
		if (slot.ident.length = 10 
		and (slot.ident[1:9] = "AUTOLOCN6"
		or slot.ident[1:9] = "AUTOLOCN7"
		or slot.ident[1:9] = "AUTOLOCN9"))
		or (slot.ident.length &gt; 10 
		and (slot.ident[1:10] = "AUTOLOCN21"
		or slot.ident[1:10] = "AUTOLOCN22"
		or slot.ident[1:10] = "AUTOLOCN24"
		or slot.ident[1:10] = "AUTOLOCN36"
		or slot.ident[1:10] = "AUTOLOCN37"
		or slot.ident[1:10] = "AUTOLOCN44")) then
			slotsJob1.add(slot);
		endif;
		
		if slot.ident.length &gt; 10
		and (slot.ident[1:10] = "AUTOLOCN11"
		or slot.ident[1:10] = "AUTOLOCN12"
		or slot.ident[1:10] = "AUTOLOCN14"
		or slot.ident[1:10] = "AUTOLOCN26"
		or slot.ident[1:10] = "AUTOLOCN27"
		or slot.ident[1:10] = "AUTOLOCN29"
		or slot.ident[1:10] = "AUTOLOCN38"
		or slot.ident[1:10] = "AUTOLOCN39"
		or slot.ident[1:10] = "AUTOLOCN46") then
			slotsJob2.add(slot);
		endif;
		
		if slot.ident.length &gt; 10
		and (slot.ident[1:10] = "AUTOLOCN40"
		or slot.ident[1:10] = "AUTOLOCN41"
		or slot.ident[1:10] = "AUTOLOCN48") then
			slotsJob3.add(slot);
		endif;
	endforeach;
	
	voyageJob := self.addVoyageROROJob(voyage, voyageDeck1, wp.code, slotsJob1, false);
	assertTrue(voyageJob &lt;&gt; null);
	voyageJob := self.addVoyageROROJob(voyage, voyageDeck1, wp.code, slotsJob2, false);
	assertTrue(voyageJob &lt;&gt; null);
	voyageJob := self.addVoyageROROJob(voyage, voyageDeck1, wp.code, slotsJob3, false);
	assertTrue(voyageJob &lt;&gt; null);
	
	//Setup Jobs on Sub Deck 1 (mix of 20's and 40's)
	slotsJob1.clear();
	slotsJob2.clear();
	slotsJob3.clear();
	
	foreach slot in voyageDeck1S.allROROSlotControllers do
		if (slot.ident.length = 10 
		and (slot.ident[1:9] = "AUTOLOCN4"
		or slot.ident[1:9] = "AUTOLOCN7"))
		or (slot.ident.length &gt; 10 
		and (slot.ident[1:10] = "AUTOLOCN13"
		or slot.ident[1:10] = "AUTOLOCN16"
		or slot.ident[1:10] = "AUTOLOCN24"
		or slot.ident[1:10] = "AUTOLOCN27")) then
			slotsJob1.add(slot);
		endif;
		
		if (slot.ident.length = 10 
		and (slot.ident[1:9] = "AUTOLOCN5"
		or slot.ident[1:9] = "AUTOLOCN9"))
		or (slot.ident.length &gt; 10 
		and (slot.ident[1:10] = "AUTOLOCN14"
		or slot.ident[1:10] = "AUTOLOCN17"
		or slot.ident[1:10] = "AUTOLOCN29"
		or slot.ident[1:10] = "AUTOLOCN32")) then
			slotsJob2.add(slot);
		endif;
		
		if slot.ident.length &gt; 10
		and (slot.ident[1:10] = "AUTOLOCN10"
		or slot.ident[1:10] = "AUTOLOCN34") then
			slotsJob3.add(slot);
		endif;
	endforeach;
	
	voyageJob := self.addVoyageROROJob(voyage, voyageDeck1S, wp.code, slotsJob1, false);
	assertTrue(voyageJob &lt;&gt; null);
	voyageJob := self.addVoyageROROJob(voyage, voyageDeck1S, wp.code, slotsJob2, false);
	assertTrue(voyageJob &lt;&gt; null);
	voyageJob := self.addVoyageROROJob(voyage, voyageDeck1S, wp.code, slotsJob3, false);
	assertTrue(voyageJob &lt;&gt; null);
	
	//Create required containers onsite
	port := app.myRoot.allPorts["NZAKL"];
	
	count := 1;
	while count &lt; 37 do
		tiId := "SIDE2000" &amp; count.String;
		cargo := self.addContainerAtLocnDisch(tiId, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
		self.deleteStops(cargo);
		self.assertNotNull(cargo);
		count := count + 1;
	endwhile;
	
	count := 1;
	while count &lt; 25 do
		tiId := "SIDE4000" &amp; count.String;
		cargo := self.addContainerAtLocnDisch(tiId, "4200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
		self.deleteStops(cargo);
		self.assertNotNull(cargo);
		count := count + 1;
	endwhile;
	
	self.assertNoTrxErrorsOrWarnings();
	
	//Plan onsite conts to jobs on Deck 1 and jobs on Sub Deck 1 (mix of 20's and 40's)
	create tmpOptionsUsed transient;
	create allJobs transient;
	create controller transient;
	
	jobSheet := voyage.allJobSheets.first;

	foreach job in voyage.allVoyageJobs  discreteLock do
		if job.CM_VoyageJob.isDischarge then
			continue;
		endif;
		
		if job.id = "209"
		or job.id = "211"
		or job.id = "215"
		or job.id = "217" then
			allJobs.add(job);
		endif;
	endforeach;

	planAccrossTermArea := true;
	ignoreWarnings := true;
	
	controller.init(self.getTerminal,
					3, 
					allJobs, 
					jobSheet,
					voyage,
					planIfStops,
					tmpOptionsUsed, 
					height, 
					planFromRowEnds,
					numRowSep,
					null,
					useWeights,
					weightAve,
					weightPC,
					true,
					planAccrossTermAreaCol,
					true,
					planTwinLift);
					
	controller.initQuery();
	controller.doQuery(null);	
	
	//Move containers in required jobs
	self.expectTrxError(Ship_line_Ports_discrepency);
	
	foreach job in voyage.allVoyageJobs  discreteLock do	
		if job.CM_VoyageJob.status = JOB_COMPLETE then
			continue;
		endif;
		
		if job.id = "211"
		or job.id = "217" then
			self.moveCargoForVoyageJob(job, REAL_MODE);
		endif;
	endforeach;
	
	//Make sure everything completed OK
	self.assertNoTrxErrorsOrWarnings();
	
	// 17/02/2014 cnwmh5 - additional trx call
	create theJobs transient;
	foreach job in voyage.allVoyageJobs do
		if not job.isKindOf(CM_VoyageDeckJob) then
			continue;
		endif;
		jobNum := job.getJobNum();
		if jobNum = 213.String or jobNum = 215.String then
			beginLoad;
			pxyJob := job.CM_VoyageJob.pxyCreateUpdateProxy();
			endLoad;
			isBulkEdit := true;
			jobNumber := (jobNum.Integer + 700).Integer;
			theJobs.add(pxyJob);
			pxyJob.setProxyJobNum(jobNumber.String, isBulkEdit);
		elseif jobNum = 200.String then
			job200 := job;
		endif;
	endforeach;
	self.assertNotNull(job200);
	
	// update job's remarks	
	app.myTrxUA.trxUpdateVoyageJobRemarks(job200.CM_VoyageJob, class.name &amp; '::' &amp; method.name, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(job200.getRemarks(), class.name &amp; '::' &amp; method.name);
	
	// 17/02/2014 cnwmh5 - additional trx call
	// update voyage job number
	beginLoad;
	pxyJob := job200.CM_VoyageJob.pxyCreateUpdateProxy();
	endLoad;
	pxyJob.setProxyJobNum(911.String, false);
	app.myTrxUA.trxUpdateVoyageJobNumber(pxyJob, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(job200.getJobNum(), 911.String);	
	self.assertEqual(theJobs.size, 2);
	delete pxyJob;
	
	// 17/02/2014 cnwmh5 - additional trx call
	// get the required jobs
	app.myTrxUA.trxUpdateVoyageJobsNumber(theJobs, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	foreach job in theJobs do
		delete job;
	endforeach;
	theJobs.purge();
	
	countNum := 0;
	foreach job in voyage.allVoyageJobs do
		jobNumber := job.CM_VoyageJob.getJobNum().Integer;
		if jobNumber = 911 or jobNumber = 913 or jobNumber = 915 then
			countNum := countNum + 1;
			if jobNumber = 915 then
				voyageJob := job.CM_VoyageJob;
			elseif jobNumber = 913 then
				voyageJob2 := job.CM_VoyageJob;
			endif;
		endif;
	endforeach;
	self.assertEqual(countNum, 3);
	
	// Update voyage job
	self.opts.purge();
	self.opts.addAssoc("Remarks", class.name &amp; "::" &amp; method.name);
	self.updateVoyageJob(voyageJob);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(voyageJob.remarks, class.name &amp; "::" &amp; method.name);
	
	// add / update / delete work point operating hours
	self.addWPOpHrs(voyage, voyageJob.CM_VoyageJob, 5000);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(wp.allCraneOpHrsExchange.size, 1);
	
	self.addWPOpHrs(voyage, voyageJob2.CM_VoyageJob, 5000);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(wp.allCraneOpHrsExchange.size, 2);
	
	// update work point operating hours
	self.opts.purge();
	self.opts.addAssoc("Remarks", " Update: " &amp; app.cnGetServerTime().Date.String);
	remarks := wp.allCraneOpHrsExchange.first.remarks &amp; self.opts.str("Remarks");
	self.updateWPOpHrs(wp.allCraneOpHrsExchange.first);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(wp.allCraneOpHrsExchange.first.remarks, remarks);
	
	// delete work point operating hours
	wpOpHours := wp.allCraneOpHrsExchange.first;
	self.deleteWPOperatingHours(wpOpHours);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(wp.allCraneOpHrsExchange.size, 1);
	wpOpHours := wp.allCraneOpHrsExchange.first;
	self.deleteWPOperatingHours(wpOpHours);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(wp.allCraneOpHrsExchange.size, 0);
	
epilog

	endLoad;

	delete slotsJob1;
	delete slotsJob2;
	delete slotsJob3;
	delete sobSlots;
	delete altSOBSlots;
	delete theEditions;
	delete lcSet;
	delete roroLCs;
	delete altROROLCs;	
	delete tmpOptionsUsed;
	delete allJobs;
	delete controller;
	delete pxyJob;
	delete theJobs2;
	if theJobs &lt;&gt; null then
		foreach job in theJobs do
			delete job;
		endforeach;
	endif;
	delete theJobs;
	
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;WorkPointDeleteIssue&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
