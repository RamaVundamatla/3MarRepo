    <JadeMethod name="doClickDelete" id="19512787-6e46-4c53-967e-c43cd202f26c">
        <updating/>
        <source>doClickDelete()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2018	jlgndl1	Initial creation

*/

vars

	rate : CM_Object;

begin

	rate := self.tblRates.accessRow( self.tblRates.row ).itemObject.CM_Object;
	if rate &lt;&gt; null then
		app.myTrxDA.trxDeleteCMObject( rate, app.myPassport );
	endif;
	
	self.populateRatesTable();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickSave" id="78ba0522-e415-4220-be33-523517c68e4f">
        <updating/>
        <source>doClickSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 March 2018	jlgndl1	Initial creation
14 May 2018		jlgmd1	TFS #38607 Cannot edit rates for a work point second time

*/

vars

	pxyRate : CM_WorkPointCargoRates;
	realRate : CM_WorkPointCargoRates;
	load : Boolean;
	
	dailyHoursWorkable : Decimal[4,2];
	jobType : Integer;
	cargoType : CM_CargoType;
	product : CM_Product;
	workPoint : CM_WorkPoint;
	targetRatePHQuantity : Integer;
	targetRatePHVolume : Decimal[16,4];
	targetRatePHWeight : Decimal[16,4];
	transferType : Integer;
	
	retValue : Integer;

begin

	if self.mode = Mode_Add then
		create pxyRate transient;
	elseif self.mode = Mode_Update then
		realRate := self.tblRates.accessRow( self.tblRates.row ).itemObject.CM_WorkPointCargoRates;
		app.cmsBeginLoad(load);
		pxyRate := realRate.pxyCreateUpdateProxy();
		app.cmsEndLoad(load);
	else
		return;
	endif;
	
	dailyHoursWorkable := self.txtDailyHours.text.asDecimalJMT;
	jobType := self.cmbJobType.itemData[self.cmbJobType.listIndex];
	cargoType := self.cmbCargoType.listObject.CM_CargoType;
	product := self.cmbProduct.listObject.CM_Product;
	workPoint := self.myWorkPoint;
	
	if self.txtTargetQuantity.visible then
		targetRatePHQuantity := self.txtTargetQuantity.text.Integer;
	else
		targetRatePHQuantity := 0;
	endif;
	if self.tblTargetVolume.visible then
		targetRatePHVolume := self.tblTargetVolume.getConvertedValue;
	else
		targetRatePHVolume := 0;
	endif;
	if self.tblTargetWeight.visible then
		targetRatePHWeight := self.tblTargetWeight.getConvertedValue;
	else
		targetRatePHWeight := 0;
	endif;
	transferType := self.cmbTransferType.itemData[self.cmbTransferType.listIndex];

	
	pxyRate.setProxy(	dailyHoursWorkable,	//_dailyHoursWorkable : Decimal;
						jobType,	//_jobType : Integer;
						cargoType,	//_myCargoType : CM_CargoType;
						product,	//_myProduct : CM_Product;
						workPoint,	//_myWorkPoint : CM_WorkPoint;
						targetRatePHQuantity,	//_targetRatePHQuantity : Integer;
						targetRatePHVolume,	//_targetRatePHVolume : Decimal;
						targetRatePHWeight,	//_targetRatePHWeight : Decimal;
						transferType	//_transferType : Integer
						);

	while true do
	
		if self.mode = self.Mode_Add then
			app.myTrxCA.trxCreateWorkPointRate(pxyRate, realRate, app.myPassport);
		elseif self.mode = self.Mode_Update then
			app.myTrxUA.trxUpdateWorkPointRate(pxyRate, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			self.populateRatesTable();
			break;
		else
			retValue := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and retValue = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
	
	endwhile;
	
epilog

	app.cmsEndLoad(load);
	delete pxyRate;		// TFS 38607 jlgmd1 14/05/2018

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickUpdate" id="c40ea211-3c7b-4442-9499-57aa698ab86e">
        <updating/>
        <source>doClickUpdate() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2018	jlgndl1	Initial creation

*/

vars

begin

	self.frmDetail.enabled := true;
	self.mode := Mode_Update;
	self.setupButtons();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRatesTblMouseDown" id="3bc81686-619a-4e04-b97f-c13df9b7c335">
        <source>doRatesTblMouseDown();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2018	jlgndl1	Initial creation

*/

vars
	
	rate : CM_WorkPointCargoRates;

begin

	self.frmDetail.enabled := false;
	rate := self.tblRates.accessRow( self.tblRates.row ).itemObject.CM_WorkPointCargoRates;
	
	if rate &lt;&gt; null then
	
		self.txtDailyHours.text := rate.dailyHoursWorkable.String;
		self.cmbJobType.listIndex := self.cmbJobType.findStringExact( 1, rate.getJobTypeStr );
		self.cmbCargoType.setObject( rate.myCargoType );
		if rate.myProduct &lt;&gt; null then
			self.rePopulateProducts();
			self.cmbProduct.setObject( rate.myProduct );
		endif;
		self.setWeightVolQtyForCargoType();
		if rate.targetRatePHQuantity &gt; 0 then
			self.txtTargetQuantity.text := rate.targetRatePHQuantity.String;
		elseif rate.targetRatePHVolume &gt; 0 then
			self.tblTargetVolume.setValue( rate.targetRatePHVolume );
		elseif rate.targetRatePHWeight &gt; 0 then
			self.tblTargetWeight.setValue( rate.targetRatePHWeight );
		endif;
		self.cmbTransferType.listIndex := self.cmbTransferType.findStringExact( 1, rate.getTransferTypeStr );
		
	else
		self.clearDetails();
	
	endif; 
	
	self.setupButtons();

epilog

end;</source>
    </JadeMethod>
