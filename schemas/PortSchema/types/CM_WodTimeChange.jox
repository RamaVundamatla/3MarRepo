    <JadeMethod name="actionItems" id="b72f7ca8-9aff-4fd9-951d-cb9ebc866a7c">
        <updating/>
        <source>actionItems(_woActionIF: CMIF_WorkOrderAction; _passport: CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 14/06/2018	jlgdap1		TFS 39165 PEL1 Voyage Work Order Transactions
// 11 Oct 2021 	jlier1			TFS 51963 removed inaportnet
vars
workOrder, pxyWorkOrder : CM_WorkOrder;
	workOrderId : String;
	invalid : Boolean;
	elapsed : TimeStampInterval;
	toDateTime : TimeStamp;
	woDtl : CM_WorkOrderDtl;
	voyage : CM_Voyage;
begin
	on Exception do app.handleDeletedObject(exception, workOrder, invalid);
	
	// update the work order's required date/time
	workOrder := self.myWorkOrderToUpdate;
	if workOrder &lt;&gt; null then
		workOrderId := workOrder.id;
	endif;
	if workOrderId = null or invalid then
		self.setIsComplete;
		return;
	endif;
	
	voyage := self.getMyVoyageObject();
	
	if workOrder.requiredByDT &lt;&gt; self.occursOnDT then
	
		pxyWorkOrder := app.createUpdateProxy(workOrder).CM_WorkOrderVoyage;
		pxyWorkOrder.setRequiredByDT(self.occursOnDT);
		app.myUtilityUA.utlUpdateWorkOrder(pxyWorkOrder, false,_passport);
		// and update the work order details on the work order as well
		foreach woDtl in workOrder.allWoDtls do
			woDtl.setRequiredByDT(self.occursOnDT);
		endforeach;
		
		
		// if no errors, update the HMS resource used time as well
		woDtl := workOrder.allWoDtls.first;
		if woDtl &lt;&gt; null and _passport.noErrors then
			self.myHMSResourceUsedToUpdate := woDtl.CM_WorkOrderVoyageDtl.myResourceUsed;
			if self.myHMSResourceUsedToUpdate &lt;&gt; null then
				if self.myHMSResourceUsedToUpdate.toDateTime &lt;&gt; null then
					elapsed := self.myHMSResourceUsedToUpdate.toDateTime - self.myHMSResourceUsedToUpdate.fromDateTime;
					toDateTime := self.occursOnDT + elapsed;
				else
					toDateTime := null;
				endif;
				self.myHMSResourceUsedToUpdate.setDetailsFromWorkOrder(self.occursOnDT, toDateTime);
			endif;
		endif;
	
	endif;
	
	if _passport.noErrors then
		self.setIsComplete;
		// create the appropriate transaction for billing purposes
		//self.createHMSResource(WO_TASK_VOY_TIMECHANGE);			// TFS 39165
		self.createWorkOrderTransaction(TRANS_TYPE_WO_TIMECHANGE);		// TFS 39165
	endif;
	
epilog
	delete pxyWorkOrder;
end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="canCancel" id="6642f7c4-f905-47d2-8dc5-4c75ae961aac">
        <source>canCancel(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 October 2018	jlger1	Initial creation

*/

vars

begin
	if self.occursOnDT &lt;&gt; null and occursOnDT &lt;= app.actualTimeServer then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
