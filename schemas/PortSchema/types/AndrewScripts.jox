    <JadeMethod name="abAdhocCAMS" id="8ebb7201-c5dd-403e-b694-f64bdf443fcc">
        <source>abAdhocCAMS();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2019	jlgdi1	Initial creation
*/

constants
	CAMProtocol : String = "Load Confirmation API";
	Terminal1	: String = 'BISH';
		
	StartDate	: Date = '01/11/2023'.Date;
	EndDate1	: Date = '30/11/2023'.Date;
	StartTime	: Time = '18:19:00:000'.Time;
	EndTime		: Time = '18:30:00:000'.Time;
	
vars
	camProtocol		: CM_CamProtocol;
	runDateTime		: TimeStamp;
	startDateTime	: TimeStamp;
	endDateTime		: TimeStamp;
	valDate			: Date;
	valTime			: Time;
	terminal		: CM_Terminal;
	camsController : CM_CamControllerAgent;
	
begin
	app.initialize();
	// setup start and end dates/time and protocol to use
	valDate := StartDate;
	valTime := StartTime;
	startDateTime.setDate(valDate);
	startDateTime.setTime(valTime);
	if not startDateTime.isValid() then
		write 'startDateTime is not valid';
		return;
	endif;
	
	valDate := EndDate1;
	valTime := EndTime;
	endDateTime.setDate(valDate);
	endDateTime.setTime(valTime);
	if not endDateTime.isValid() then
		write 'endDateTime is not valid';
		return;
	endif;
	
	runDateTime := app.actualTimeServer;
	app.hideDebug	:= false;			// false implies do not hide debugging - helps with display messages
	terminal		:= app.myRoot.allTerminals[Terminal1];
	if terminal = null then
		app.writeStatement('Can not find required terminal ' &amp; Terminal1);
		return;
	endif;
	app.myPassport.setMyTerminal(terminal);
	
	camProtocol := terminal.camProtocols[CAMProtocol];
	if camProtocol = null then
		app.writeStatement("Cannot find required cam protocol description");
		return;
	endif;
	
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	
	on Exception do null global;
	
	app.setPassBackExceptions(true, true);
	create camsController transient;
	camsController.setMyTerminal(terminal);
	camsController.adhocTask(camProtocol, startDateTime, endDateTime, runDateTime, true, true);	//this does runs the adhoc cams
	
epilog
	delete camsController;
end;</source>
    </JadeMethod>
    <JadeMethod name="abBGPFutureActorDebug" id="d4d7bb13-f3d1-4f41-b407-fb5f7a444d62">
        <source>abBGPFutureActorDebug();
/*
Purpose - 	// ### TFS BUG 64680 17JUNE024 NAVAB1
Who - NAVAB1
Date - 17JUNE2024
*/


vars

	selectedObjects : ObjectSet;
	obj : Object;
	isFutureStorage : Boolean;
	futureHandler	: CM_OfflineFutureActorHandler;
	invalidObj 	: Boolean;
begin
	app.initialize();
	on Exception do app.handleDeletedObject(exception,obj,invalidObj);
	create futureHandler transient;
	obj := "11313.350698".asOid.CM_FutureStorageProcess;
	beginTransaction;
	obj.CM_FutureStorageProcess.setPropertyValue("isCOOResync",true);
	commitTransaction;
	futureHandler.processOfflineFutureActorTrx(obj.CM_OfflineFutureActor);
epilog
	delete futureHandler;	
end;

</source>
    </JadeMethod>
    <JadeMethod name="abCreateAuditConfigs" id="4db92808-9f8a-4e10-b02e-8b5011888662">
        <source>abCreateAuditConfigs();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2024	navab1	Initial creation

*/


vars
	root : CM_Root;
	schema : Schema;
	auditConfig : CM_AuditConfig;
	cmObjectClass : Class;
	
	classColl : ClassColl;
	class : Class;
	iterClass : Iterator;
	
	dummyObj : CM_Object;
	transObj : CM_Object;
	canHaveAudits: Boolean;
	auditClass: Class;
	
	iterAuditConfig : Iterator;

begin
	app.initialize();
	
	root := CM_Root.firstInstance;
	
	schema := currentSchema;
	while schema.name &lt;&gt; "PortSchema" do
		schema := schema.superschema;
	endwhile;
	cmObjectClass := CM_Object;
	
	classColl := schema.getAllClasses(false);
	iterClass := classColl.createIterator;
	
	beginTransaction;
	
		// We Audit the fact that we're enabling/disabling CM_AuditConfigs
		// But We might not have one yet, so lets do that first up
		auditConfig := root.allAuditConfigs[ CM_AuditConfig.name ];
		if auditConfig = null then
			//its not there add it.	
			root.createAuditConfig( CM_AuditConfig );	
		endif;
	
	while iterClass.next( class ) do
	
	if class= CM_CustomDocument then
	write "";
endif;

		if not class.inheritsFrom( CM_Object ) then
			//only interested in classes under CM_Object
			continue;
		endif;
		
		if class.abstract or class.transient then
			continue;
		endif;
		
		if class = CM_AvailableForRelease then
			continue;
		endif;
		
		//check to see whether its supposed to be available
		dummyObj := class.firstInstance.CM_Object;
		
		if dummyObj = null or dummyObj.class = CM_Object then
			create transObj as class transient;
			dummyObj := transObj;
		endif;
						
		canHaveAudits := dummyObj@canHaveAudits;
		auditClass := dummyObj@auditClass;
		
		delete transObj;
		
		if not canHaveAudits or auditClass = null then
			//this class is not audited.
			continue;
		endif;
		
		//If we get to here the class should be able to be audited.
		//check that the audit config has been created
		auditConfig := root.allAuditConfigs[ auditClass.name ];
		if auditConfig = null then
			//its not there add it.	
			auditConfig := root.createAuditConfig( auditClass );
			if not auditConfig.canBeUserDisabled then
				app.myUtilityUA.updAuditConfigSetIsEnable( true, auditConfig, app.myPassport);
			endif;
		endif;
		
	endwhile;
	
	//And one special case - "CM_Edit" / 'Tracked Item Edit' Creates audits against CM_Tracked Item that
	//replicate the values in the 'Edits' created via the Container Enquiry Form.
	auditConfig := root.allAuditConfigs[ CM_Edit.name ];
	if auditConfig = null then
		//its not there add it.	
		root.createAuditConfig( CM_Edit );	
	endif;
	
	//clean up any CM_AuditConfig objects for classes that have been deleted and have no associated audits.
	//i.e. at th etime of writing there was a "CM_TIMasterGroup"
	iterAuditConfig := root.allAuditConfigs.createIterator;
	while iterAuditConfig.next( auditConfig ) do
		class := schema.getClass( auditConfig.className );
		if class = null and auditConfig.allAuditObjects.isEmpty then
			delete auditConfig;
		endif;
	endwhile;
	
	commitTransaction;

epilog

	delete classColl;
	delete iterClass;
	delete iterAuditConfig;
end;</source>
    </JadeMethod>
    <JadeMethod name="abNextCalcType" id="acfb7bc6-fdcb-4390-bab5-74e61552b38a">
        <source>abNextCalcType();
vars
	labels : StringArray;
	values : IntegerArray;
	tot, idx : Integer;
	theCode : String;
	aCT, pxyCalculationType : CM_CalculationType;

begin

	app.initialize();				// removed call to initialize as it breaks initializeRoot if no default printer is set		// jlgmd1 10/01/2020
	create labels transient;
	create values transient;
	
	app.getAllInvoiceCalcTypes(true,true,labels,values,"CARGO");
	// set an internal flag to allow creation of internal 'CCT'-prefixed calculation type instances
	
	tot := 	values.size;
	foreach idx in 1 to tot do
		theCode := "CCT" &amp; values[idx].padLeadingWith("0",2);
		
		aCT := app.myRoot.allCalculationTypesByCode[theCode];
		if aCT &lt;&gt; null then
			write "CARGO," &amp; values[idx].String &amp; "," &amp; theCode &amp;"," &amp; labels[idx].String;
		endif;
	endforeach;
	
	app.getAllInvoiceCalcTypes(true,true,labels,values,"EVENT");
	
	tot := 	values.size;
	foreach idx in 1 to tot do
		theCode := "ECT" &amp; values[idx].padLeadingWith("0",2);
		
		aCT := app.myRoot.allCalculationTypesByCode[theCode];
		if aCT &lt;&gt; null then
			write "EVENT,"  &amp; values[idx].String &amp; "," &amp; theCode &amp;"," &amp; labels[idx].String;
		endif;
	endforeach;
	
	
	app.getAllInvoiceCalcTypes(true,true,labels,values,"WORKORDER");
	
	tot := 	values.size;
	foreach idx in 1 to tot do
		theCode := "WO" &amp; values[idx].padLeadingWith("0",2);
		
		aCT := app.myRoot.allCalculationTypesByCode[theCode];
		if aCT &lt;&gt; null then
			write "WO,"  &amp; values[idx].String &amp; "," &amp; theCode &amp;"," &amp; labels[idx].String;
		endif;
	endforeach;

	//30 Oct 2019	NDL	TFS 47100
	app.getAllInvoiceCalcTypes(true,true,labels,values,"BOL");
	
	tot := 	values.size;
	foreach idx in 1 to tot do
		theCode := "BOL" &amp; values[idx].padLeadingWith("0",2);
		
		aCT := app.myRoot.allCalculationTypesByCode[theCode];
		if aCT &lt;&gt; null then
			write "BOL,"  &amp; values[idx].String &amp; "," &amp; theCode &amp;"," &amp; labels[idx].String;
		endif;
	endforeach; 
	
	

	app.getAllInvoiceCalcTypes(true,true,labels,values,"INVENTORY");
	
	tot := 	values.size;
	foreach idx in 1 to tot do
		theCode := "INV" &amp; values[idx].padLeadingWith("0",2);
		
		aCT := app.myRoot.allCalculationTypesByCode[theCode];
		if aCT &lt;&gt; null then
			write "INVENTORY,"  &amp; values[idx].String &amp; "," &amp; theCode &amp;"," &amp; labels[idx].String;
		endif;
	endforeach; 
	
	app.getAllInvoiceCalcTypes(true,true,labels,values,"VTMIS");
	
	tot := 	values.size;
	foreach idx in 1 to tot do
		theCode := "HMS" &amp; values[idx].padLeadingWith("0",2);
		
		write "VTMIS,"  &amp; values[idx].String &amp; "," &amp; theCode &amp;"," &amp; labels[idx].String;
	endforeach; 
	
epilog
	delete labels;
	delete values;
end;</source>
    </JadeMethod>
    <JadeMethod name="abRemoveUnwantedStorageExpiry" id="cf740dd1-4c23-42f4-9bcb-bd59c81c1b57">
        <source>abRemoveUnwantedStorageExpiry();
/*
Purpose:	AN onsite TI should  only have multiple storage expiry details if it has had a chnage of ownership, otherwise the TI should always have 1 storage expiry detail

Date		Who		Reason
07 June 2024	navab1	CR 64297 TASK 64299
*/

vars
	root : CM_Root;
	term : CM_Terminal;
	ti : CM_TrackedItem;
	stoexp, stoExpDel : CM_StorageExpiryDetail;
	objToDelete : ObjectSet;
	deleteMode : Boolean;
begin
	deleteMode := false;
	
	
	
	root := CM_Root.firstInstance;
	create objToDelete transient;
	
	foreach term in root.allTerminals discreteLock do
		foreach ti in term.allOnsiteTIsByCargoTypeId discreteLock do
			if ti.allOwnershipChangeDetails.isEmpty
			and ti.allStorageExpiryDetails.size &gt; 1 then
				stoexp:= ti.allStorageExpiryDetails.first;
				write term.code &amp; ", " &amp; ti.id &amp; ", " &amp; ti.allStorageExpiryDetails.size.String &amp; ", " &amp; stoexp.createdTime.String;
				
				foreach stoExpDel in ti.allStorageExpiryDetails discreteLock do
					if stoExpDel = stoexp then
						continue;
					endif;
					if deleteMode then
						objToDelete.add(stoExpDel);
					endif;
				endforeach;
			endif;
		
		endforeach;
	
	endforeach;
	
	beginTransaction;
	
	objToDelete.purge();
	commitTransaction;
	delete objToDelete;
end;</source>
    </JadeMethod>
    <JadeMethod name="abScript" id="e1a6b243-0f39-4320-9266-24d048197893">
        <source>abScript();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2018	jlgab1	Initial creation

*/
vars

	errCode	: Integer;
	errTxt	: String;
	count, count2, completed, theSize   : Integer;
	iter,
	iter1   : Iterator;
	setAll,
    setErrors			: CM_ObjectSetActual;
	ewsAct : CM_ExternalWebServiceActivity;
	ewsActivities : CM_EWSActivityByDateTime;
r : CM_Root;
t : CM_Terminal;
	now : Date;

begin
	now := now.addDays(2);
	r := CM_Root.firstInstance();
	t := r.allTerminals["NAV1"];

	create ewsActivities transient;
	

	iter := app.myRoot.allEWSOpsviewActivities.createIterator();
	while iter.next(ewsAct) do
		if ewsAct.status &lt;&gt; BGP_OpsViewWSRequest.EWS_STATUS_DELETED 
		and ewsAct.status &lt;&gt; BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_SUCCESS  then
			continue;
		endif;

		if ewsAct.myTerminal &lt;&gt; null 
		and ewsAct.myTerminal &lt;&gt; t then
			continue;
		endif;
		
		if ewsAct.created.date &gt; now then
			continue;
		endif;
		ewsActivities.add(ewsAct);
	endwhile;	
ewsActivities.inspect;
end;</source>
    </JadeMethod>
