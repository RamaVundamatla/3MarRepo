    <JadeMethod name="utlUpdateWebSiteConfig" id="695b020e-f886-4925-8714-124ab8df8d9c">
        <updating/>
        <source>utlUpdateWebSiteConfig(_proxyWebSiteConfig : CM_WebSiteConfig; _realWebSiteConfig : CM_WebSiteConfig output; _passport : CM_Passport input) updating;
// -------------------------------------------
// Created 24 November 2004 by cnwdvb1
// -------------------------------------------
vars

	isEdit	: Boolean;

begin

	app.setContinueCMExceptions(true);
	
	self.raiseExceptionIfNull(_proxyWebSiteConfig, 'WebSiteConfig');
	_proxyWebSiteConfig.raiseExceptionIfNotTransient(method);
		
	_realWebSiteConfig := _proxyWebSiteConfig.pxyGetRealObject();
	
	app.myValUA.valWebSiteConfig(_proxyWebSiteConfig, _realWebSiteConfig);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	if _realWebSiteConfig = null then
		create _realWebSiteConfig persistent;
	else
		self.exclusiveLock(_realWebSiteConfig);
	endif;
	
	_realWebSiteConfig.setForUpdate(_proxyWebSiteConfig);


end;</source>
        <Parameter name="_proxyWebSiteConfig" type="CM_WebSiteConfig"/>
        <Parameter name="_realWebSiteConfig" type="CM_WebSiteConfig" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWebSiteConfigDir" id="b27ee0cb-2b2e-4a6f-b606-28432be01fda">
        <updating/>
        <source>utlUpdateWebSiteConfigDir(_directoryPath:String; _realWebSiteConfig:CM_WebSiteConfig input; _passport:CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		25 October 2005 by cnwdad1
//
// Purpose:		Updates the directoryPath attribute of the specified Web Site Config.
//
// Parameters:	_directoryPath - The name of the Web Site Config's directory path.
//				_realWebSiteConfig - A reference to the Web Site Config to update.
//				_passport - A reference to the session's user passport object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.setContinueCMExceptions(true);
	self.raiseExceptionIfNull(_realWebSiteConfig, 'WebSiteConfig');
	app.myValUA.valWebSiteConfigDir(_directoryPath, _realWebSiteConfig);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	self.exclusiveLock(_realWebSiteConfig);
	
	_realWebSiteConfig.setDirectoryPath(_directoryPath);
end;</source>
        <Parameter name="_directoryPath" type="String"/>
        <Parameter name="_realWebSiteConfig" type="CM_WebSiteConfig" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateWeighAuthority" id="808c4cc4-4a75-469e-be99-921488e42396">
        <updating/>
        <source>utlUpdateWeighAuthority(_pxyWeighAuthority : CM_WeighAuthority; _authTerms : ObjectArray; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/06/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars
	realWeighAuthority : CM_WeighAuthority;
	expectedEdition : Integer;
	authTerm : CM_WeighAuthTerminal;
	found : Boolean;
	obj : Object;

begin
	self.initialiseActivity();

	_pxyWeighAuthority.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyWeighAuthority.pxyGetRealObjectAndEdition(realWeighAuthority, expectedEdition);
	
	if realWeighAuthority = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_WeighAuthority.name, null, null);
		return;
	endif;

	app.myValUA.valWeighAuthority(_pxyWeighAuthority, realWeighAuthority);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realWeighAuthority);

	if _passport.noErrors and realWeighAuthority.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Weigh Authority', null, null);
		return;
	endif;
	
	// check for deletion of any authority-terminal links
	foreach authTerm in realWeighAuthority.allWeighAuthTerminals do
		found := false;
		foreach obj in _authTerms do
			if obj.CM_WeighAuthTerminal.myTerminal = authTerm.myTerminal then
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			if not authTerm.allVGMDetails.isEmpty then
				app.raiseCMException2(Cant_Remove_WeighAuthTerm, realWeighAuthority.certifiedName &amp; Space &amp; realWeighAuthority.authorisedName, authTerm.myTerminal.code, null, null);
			endif;
		endif;
	endforeach;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realWeighAuthority, true);
	endif;
	
	if _passport.noErrors then
		realWeighAuthority.setForUpdate(_pxyWeighAuthority, _authTerms);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realWeighAuthority, false);
	endif;

epilog

end;</source>
        <Parameter name="_pxyWeighAuthority" type="CM_WeighAuthority"/>
        <Parameter name="_authTerms" type="ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
