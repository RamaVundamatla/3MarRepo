<CollClass name="CM_ExtActivityByRequestDict" id="ca55afe3-c970-48ca-86f2-f03de73df6de">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CM_ActivityHistoryExtInterface"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="activityHistoryExtInterface"/>
    <MemberKey>
        <property name="CM_ActivityHistoryExtInterface::requestName"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_ActivityHistory::dateTime"/>
    </MemberKey>
    <JadeMethod name="hasSuccessfullWSDL15" id="7de807ef-e936-4e43-9154-aa7f545c14ad">
        <source>hasSuccessfullWSDL15():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2019	jlgndl1	Initial creation	TFS 44788	Checks to see if we include a
													successfull Pelindo SAP WSDL 1.5 message

*/

vars

	iter : Iterator;
	activity : CM_ActivityHistoryExtInterface;
	wsdl15Name : String;
	str : String;

begin

	if self.isEmpty then
		return false;
	endif;
	
	wsdl15Name := CM_SAPWSConsumerAgent::preBillPaidInvoiceRequest_SI.name;

	iter := self.createIterator;
	while iter.next( activity ) do
		if activity.requestName = wsdl15Name then 
			if activity.success then
				return true;
			endif;
		endif;
	endwhile;
	
	return false;
	
	//Does nothing, just a ref to make it easier to find.
	str := BGP_SAPWSRequest.WSDL15;

epilog

	delete iter;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
