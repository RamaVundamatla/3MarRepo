<Class name="JadeScript">
    <JadeMethod name="abortHandler" id="f22438ad-f75c-407a-81d3-e18e522d129b">
        <source>abortHandler(_exception : Exception) : Integer;

vars

begin
	write method.name &amp; " " &amp; _exception.errorCode.String;		// yes
	
	return Ex_Abort_Action;
end;
</source>
        <Parameter name="_exception" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="abortLockHandler" id="a88b6a63-a8d7-4d4e-afc1-4b627cc9a50b">
        <source>abortLockHandler(_exception : Exception) : Integer;

vars

begin
	write method.name &amp; " " &amp; _exception.errorCode.String;		// 
	
	//return Ex_Abort_Action;
	return Ex_Pass_Back;
end;
</source>
        <Parameter name="_exception" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="abortTest" id="4fb9b3b0-63b8-4c65-a71f-11460d730ba1">
        <source>abortTest();

vars
	i, j : Integer;
	lockClass	: LockClass;
begin
	write method.name &amp; " start";		// yes
	on Exception do abortHandler(exception);
	on LockException do abortLockHandler(exception);
	//i := (j / 0).Integer;

	lockClass := LockClass.firstInstance;
	self.exclusiveLock(lockClass);
	write method.name &amp; " locked";			// no
epilog
	write method.name &amp; " epilog";		// yes
end;
</source>
    </JadeMethod>
    <JadeMethod name="doLock" id="a5c27470-b452-4970-b02e-2106d174e756">
        <source>doLock();

vars
	lockClass	: LockClass;
begin
	beginTransaction;
	lockClass := LockClass.firstInstance;
	if lockClass = null then
		create lockClass persistent;
		lockClass.code := "TEST";
	endif;
	write "LOCKING";
	self.exclusiveLock(lockClass);
	process.sleep(30000);
	commitTransaction;
	write "END";
end;
</source>
    </JadeMethod>
    <JadeMethod name="test" id="c554e606-bcfa-47a0-9d59-2fffd0efebe7">
        <source>test(): Integer;
vars
    result : Integer;
begin
	write method.name &amp; Tab &amp; "arming exception handler";
    on Exception do xHandler(exception);
	
	if true then
		write method.name &amp; Tab &amp; "about to return (25 / 0)";
		return (25 / 0).Integer;
	endif;
	
	write method.name &amp; Tab &amp; "about to return 999";
    return 999;
	
epilog
	write method.name &amp; Tab &amp; "in epilog";
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="testAbortAction" id="cb9ff721-7d22-4889-985f-4dcb6029e645">
        <source>testAbortAction();

vars

begin
	self.abortTest();
end;
</source>
    </JadeMethod>
    <JadeMethod name="testForeach" id="b6494122-4ab7-4a9f-9db9-cfce8b7677f1">
        <source>testForeach();

vars
	a,
	b			: Integer;
	coll		: ObjectArray;
	obj			: Object;
	test		: ObjectArray;
	
begin
	write method.name &amp; Tab &amp; "arming exception handler";
    on Exception do xHandler(exception);
	
	write method.name &amp; Tab &amp; "about to test foreach on null collection";
	foreach obj in coll do
		write method.name &amp; Tab &amp; "inside bad foreach statement 1";
	endforeach;
	write method.name &amp; Tab &amp; "after bad foreach statement 1 endforeach;";
	
	create coll transient;
	create test transient;
	coll.add(test);
	coll.add(null);
	coll.add(test);
	
	write method.name &amp; Tab &amp; "about to test foreach with bad where";
	foreach obj in coll where obj.edition() = 1 do
		write method.name &amp; Tab &amp; "inside bad foreach statement 2 with obj " &amp; obj.String;
	endforeach;
	write method.name &amp; Tab &amp; "after bad foreach statement 2 endforeach;";
	
		
epilog
	write method.name &amp; Tab &amp; "in epilog";

end;
</source>
    </JadeMethod>
    <JadeMethod name="testIfThenElse" id="d3bf6d3b-0133-446b-87ee-e97f2017a690">
        <source>testIfThenElse();

vars
	a,
	b			: Integer;
	
begin
	write method.name &amp; Tab &amp; "arming exception handler";
    on Exception do xHandler(exception);
	
	write method.name &amp; Tab &amp; "about to test if";
	if (a / b) &gt; 0 or true then
		write method.name &amp; Tab &amp; "inside bad if statement";
	endif;
	write method.name &amp; Tab &amp; "after bad if statement endif;";
	
	write method.name &amp; Tab &amp; "about to test elseif";
	if false then
		write method.name &amp; Tab &amp; "inside false if statement";
	elseif (a / b) &gt; 0 or true then
		write method.name &amp; Tab &amp; "inside bad if statement";
	endif;
	write method.name &amp; Tab &amp; "after bad elseif statement endif;";
	
	
epilog
	write method.name &amp; Tab &amp; "in epilog";

end;</source>
    </JadeMethod>
    <JadeMethod name="testNormal" id="fc4d9cec-0cce-4f10-8eaf-aa064f992053">
        <source>testNormal();

vars
	a,
	b			: Integer;
	
begin
	write method.name &amp; Tab &amp; "arming exception handler";
    on Exception do xHandler(exception);
	
	write method.name &amp; Tab &amp; "about to divide by zero";
	b := a div 0;
	write method.name &amp; Tab &amp; "after divide by zero";
	
epilog
	write method.name &amp; Tab &amp; "in epilog";
	
end;</source>
    </JadeMethod>
    <JadeMethod name="testReturn" id="d601e956-74e9-4409-8273-11c2f166e495">
        <source>testReturn();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 March 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars

begin
	write method.name &amp; Tab &amp; test.String;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="testWhile" id="0200e1ed-8b61-46ab-9ad9-cb2822ecd37d">
        <source>testWhile();

vars
	a,
	b			: Integer;
	coll		: ObjectArray;
	obj			: Object;
	test		: ObjectArray;
	iter		: Iterator;
	
begin
	write method.name &amp; Tab &amp; "arming exception handler";
    on Exception do xHandler(exception);
	
	b := 3;
	write method.name &amp; Tab &amp; "about to test while";
	while (a div b) &lt; 100 and b &gt; -3 do
		write method.name &amp; Tab &amp; "inside while, b = " &amp; b.String;
		b := b - 1;
	endwhile;
	write method.name &amp; Tab &amp; "after endwhile;";
	
	create coll transient;
	create test transient;
	coll.add(test);
	coll.add(null);
	coll.add(test);
	
	iter := coll.createIterator();
	write method.name &amp; Tab &amp; "about to test while iter";
	while iter.next(obj) and obj.edition() = 1 do
		write method.name &amp; Tab &amp; "inside while statement with obj " &amp; obj.String;
	endwhile;
	write method.name &amp; Tab &amp; "after endwhile iter";
	
		
epilog
	write method.name &amp; Tab &amp; "in epilog";

end;
</source>
    </JadeMethod>
    <JadeMethod name="xHandler" id="058ca421-be49-4ba8-87eb-af18bcd679f0">
        <source>xHandler(e : Exception) : Integer;
begin
	write method.name &amp; Tab &amp; e.errorCode.String &amp; " returning Ex_Resume_Next";
    return Ex_Resume_Next;
end;

</source>
        <Parameter name="e" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
