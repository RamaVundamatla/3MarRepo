    <JadeMethod name="validateInvoiceLinesForMove" id="b80fe2f8-944f-4523-9478-90393a04cf7a">
        <source>validateInvoiceLinesForMove();
// ---------------------------------------------------------------------------
// Created:		23 January 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	anInvoiceLine : CM_InvoiceLine;
begin
	
	foreach anInvoiceLine in self.allInvoiceLines do
		if anInvoiceLine.status = CM_InvoiceLine.STATUS_VOIDED then
			app.raiseCMException2(Err_CannotMoveInvoiceLine, " " &amp; anInvoiceLine.sequenceNum.String,"This invoice line is void.",null, null);
		
		endif;
		//if anInvoiceLine.invoice.status = CM_Invoice.INVOICE_POSTED then
		if anInvoiceLine.invoice.isPostedOrReversal then	//04 Sep 2017	NDL	TFS 6759	
			app.raiseCMException2(Err_CannotMoveInvoiceLine, " " &amp; anInvoiceLine.sequenceNum.String,"Invoice " 
									&amp; anInvoiceLine.invoice.sequenceNum.String &amp; " has been posted.",null, null);
		
		endif;
	endforeach;
end;</source>
    </JadeMethod>
</Class>
