    <JadeMethod name="getDisplayStringForAttribute" id="0bb0c9cb-21d5-4c61-a74c-a7b249f6ddea">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
----------   ----------  --------------------------------------------------
Created:	24 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _attrName = ETRow_ConditionCode then
		return self.code;
	elseif _attrName = ETRow_ConditionDescr then
		return self.description;
	elseif _attrName = ETRow_ConditionColour then
		return null;
	elseif _attrName = ETRow_IsActive then
		return self.isActive.String;
	elseif _attrName = ETRow_AllowedYardArea or
	   _attrName = ETRow_AllowedVehicle or
	   _attrName = ETRow_AllowedWagon or
	   _attrName = ETRow_AllowedLocation or	//28 Jul 2015	NDL	Par 36660
	   _attrName = ETRow_AllowedBay then
		return self.allowedSameArea.String;
		
	elseif _attrName = ETRow_ProxHorzontal then
		return self.proximityHorizontal.String;
	elseif _attrName = ETRow_ProxVertical then
		return self.proximityVertical.String;
	elseif _attrName = ETRow_ProxDepth then
		return self.proximityDepth.String;
	
	endif;
	
	
	
	return inheritMethod(_attrName, _short);


end;


</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isLargerFootprintThan" id="f44482b0-7834-4ed1-b1b2-f492bf075e48">
        <source>isLargerFootprintThan(_segCondition : CM_SegregationCondition) : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	24 November 2006 By cnwth2

Purpose:	returns true if the condition passed in has a larger footprint then self


Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	area			: Integer;
begin
	if (not _segCondition.allowedSameArea) then
		return true;//whole area so this is as big as it gets
	endif;
	
	return (self.proximityHorizontal * self.proximityVertical) &gt;= (_segCondition.proximityHorizontal * _segCondition.proximityVertical);
	
end;


</source>
        <Parameter name="_segCondition" type="CM_SegregationCondition"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="proximityInViolation" id="31025804-d974-466d-96bc-5b92f4d8fa4a">
        <source>proximityInViolation(_vertProx,
					_horzProx,
					_depthProx 	: Integer;
					_doLog 		: Boolean) : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	27 November 2006 By cnwth2

Purpose:	return whether the proximity values passed in are SMALLER than selfs
			proximity rules (i.e. WITHIN selfs specified segregation boundary 

			
Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	failedVert,
	failedHorz,
	failedDepth			: Boolean;
begin
	if _vertProx &lt;= self.proximityVertical then
		if _doLog then
			app.myPassport.myActivityCapture.logDiagnostic('Failed vertical proximity check (' &amp; _vertProx.String &amp; ' is &lt;= than ' &amp; self.proximityVertical.String);
		endif;
		failedVert := true;
	else
		if _doLog then
			app.myPassport.myActivityCapture.logDiagnostic('Passed vertical proximity check (' &amp; _vertProx.String &amp; ' is &gt; than ' &amp; self.proximityVertical.String);
		endif;
		return false;
	endif;
	
	if _horzProx &lt;= self.proximityHorizontal then
		if _doLog then
			app.myPassport.myActivityCapture.logDiagnostic('Failed horizontal proximity check (' &amp; _horzProx.String &amp; ' is &lt;= than ' &amp; self.proximityHorizontal.String);
		endif;
		failedHorz := true;
	else
		if _doLog then
			app.myPassport.myActivityCapture.logDiagnostic('Passed horizontal proximity check (' &amp; _horzProx.String &amp; ' is &gt; than ' &amp; self.proximityHorizontal.String);
		endif;
		return false;
	endif;
	
	if failedVert and failedHorz then
		return true;
	endif;
	
	if _depthProx &lt;= self.proximityDepth then//on ship moves only
		if _doLog then
			app.myPassport.myActivityCapture.logDiagnostic('Failed depth proximity check (' &amp; _depthProx.String &amp; ' is &lt;= than ' &amp; self.proximityDepth.String);
		endif;
		return (failedVert and failedHorz and true);
	else
		if _doLog then
			app.myPassport.myActivityCapture.logDiagnostic('Passed depth proximity check (' &amp; _depthProx.String &amp; ' is &gt; than ' &amp; self.proximityDepth.String);
		endif;
		//this would be unusual, but possible.
		return false; 
	endif;
	
	
end;


</source>
        <Parameter name="_vertProx" type="Integer"/>
        <Parameter name="_horzProx" type="Integer"/>
        <Parameter name="_depthProx" type="Integer"/>
        <Parameter name="_doLog" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
