    <JadeMethod name="utlUpdateLogDocketData" id="f6d8b785-71e6-421e-b6f4-7c32945366f0">
        <updating/>
        <source>utlUpdateLogDocketData(_logDocketData : CM_LogDocketData; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2014	cnwmc5	Initial creation

*/

vars
	realLogDocketData	: CM_LogDocketData;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValUA.valLogDocketData(_logDocketData);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	realLogDocketData := _passport.myTerminal.allLogDocketDataByOidString[_logDocketData.docketNumberWeigh];
	
	if realLogDocketData = null then
		app.raiseCMException2(Does_not_exist_cannot_update, app.getErrorString(Docket), _logDocketData.docketNumber, null, null);
		return;
	endif;
	
	realLogDocketData.setForUpdate(_logDocketData);
	
	if _passport.noErrors then
		app.myEventManager.createSingleObjInfoNoteEvt(_logDocketData.myTerminal,_logDocketData.myTerminal.getTerminalEvent(EVENT_WEIGHBRIDGE_REMOVE),  _logDocketData);
	endif;
	
epilog
	
end;</source>
        <Parameter name="_logDocketData" type="CM_LogDocketData"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
