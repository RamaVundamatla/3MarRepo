    <JadeMethod name="doControlEvent" id="73d20ec0-9a25-4408-9180-fbd15b778298">
        <updating/>
        <source>doControlEvent(_control: Control) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2016	cnwndl1	Initial creation	TFS 2995/2638

*/

vars
	
begin
	inheritMethod(_control);
	if _control = self.mltFields.myAddSelectedBtn or
	   _control = self.mltFields.myAddAllBtn or		
	   _control = self.mltFields.myRemoveSelectedBtn or
	   _control = self.mltFields.myRemoveAllBtn then
		   
		// do nothing extra at the moment
	endif;	
epilog
	
end;</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="3c9d87d6-6237-4cc9-af2b-b85effab2a4a">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2016	cnwndl1	Initial creation	TFS 2995/2638

*/

vars

begin
	if self.saveData() then
		inheritMethod();
