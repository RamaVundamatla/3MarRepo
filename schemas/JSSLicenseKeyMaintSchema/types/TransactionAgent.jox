    <JadeMethod name="trxDeleteProduct" id="cceec5ed-05c6-4344-aade-7cadb5fd1fbc">
        <source>trxDeleteProduct(pTheProduct:JSSLKProduct io);
// --------------------------------------------------------------------------------
// Created:		23 January 2003 by cnwdad2
//
// Purpose:		Deletes the specified Product object.
//
// Parameters:	pTheProduct - The Product to delete.
//
// Returns:		Nothing
