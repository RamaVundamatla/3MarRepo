    <JadeMethod name="includeTransaction" id="5707d444-97eb-4d29-91ea-d4dadbc2692e">
        <source>includeTransaction(_transaction: CM_Transaction; _camsTS: TimeStamp; _startTS: TimeStamp; _endTS: TimeStamp; _camProtocol: CM_CamProtocol; _camGroup: CM_CamGroup; _camAgent: CM_CamControllerAgent; _logExcluded: Boolean; _event: CM_EventTransaction): Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 10 July 2023
TFS#		: 58636
Function	:

*** Changes ***
Date			Name		TFS#		Description
28/07/2023		jlika1		59068		EUP - Goods Receipt - Move Transaction area triggers. In Goods receipt we should only be check for nototype for the destination location.
29/11/2023		navcs2		Bug 61442:	EUP | Goods Receipt for Move Transactions
26/03/2024		navcs2		ChangeRequest 60397: EUP | FR 54085 - Load Confirmation / Goods Receipt - Multiple Move transaction criteria, Event Only Trigger
31/06/2024		navcs2		Defect 64388 EUP - Some Move transactions not included in the Goods Receipt CAMS message
****************************************************/

vars
	sourceLocation 		: CM_LocationsController;
	targetLocation 		: CM_LocationsController;
	moveTrxCriteria		: CM_CamsMoveTATypeCritieria;
	terminalArea 		: CM_TerminalArea;
	terminalAreaType 	: Integer;
	targetReturnValue	: Boolean;	
	sourceReturnValue	: Boolean;
	returnValue			: Boolean;
	loopValue			: Boolean;		// 31/06/2024 navcs2 Defect 64388
begin
	// 29/11/2023 navcs2 Bug 61442 Start
	if  (_transaction.isCargoTrx() and _transaction.CM_TITransaction.isCM_Move()) and not _transaction.CM_Move.isRealMove then  // 02/05/2024 navcs2 ChangeRequest 60397
		_camAgent.logReasonForExclusion (_transaction, 'Transaction is not a Real Move transaction ' &amp; _camProtocol.protocolDesc.name &amp; ' protocol' );
		return false;
	endif;
	// 29/11/2023 navcs2 Bug 61442 End
	
	foreach moveTrxCriteria in _camProtocol.allMoveTrxCriteria do
		if _camProtocol.allMoveTrxCriteria &lt;&gt; null and (_transaction.isCargoTrx() and _transaction.CM_TITransaction.isCM_Move())  then		// 02/05/2024 navcs2 ChangeRequest 60397	
			sourceLocation := _transaction.CM_Move.getSourceLocationsController(); // returned null when it is Nowhere
			
			if sourceLocation &lt;&gt; null then
				sourceReturnValue := self.checkSpecialLocation(sourceLocation);		
				
				terminalArea := sourceLocation.getMyTerminalArea();
				
				if terminalArea &lt;&gt; null then
					terminalAreaType := terminalArea.type;
				endif;
				
				if terminalAreaType &lt;&gt; null then
					if (terminalAreaType = moveTrxCriteria.fromTaType or moveTrxCriteria.fromTaType = CM_CamsMoveTATypeCritieria.AnyArea) then			
						sourceReturnValue := true;
					elseif not sourceReturnValue then
						sourceReturnValue := false;		
					endif;
				endif;
			endif;		
			
			targetLocation := _transaction.CM_Move.getTargetLocationsController(); // returned null when it is Nowhere
			if targetLocation &lt;&gt; null then
				targetReturnValue := self.checkSpecialLocation(targetLocation);
				
				if sourceReturnValue and targetReturnValue then // location matched already no need to go further
					loopValue := true;				// 31/06/2024 navcs2 Defect 64388
					returnValue := true;			// 31/06/2024 navcs2 Defect 64388
					break;							// 31/06/2024 navcs2 Defect 64388
				endif;
				
				terminalArea := targetLocation.getMyTerminalArea();		
				if terminalArea &lt;&gt; null then
					terminalAreaType := terminalArea.type;
				endif;
				
				if terminalAreaType &lt;&gt; null then
					if (terminalAreaType = moveTrxCriteria.toTAType or moveTrxCriteria.toTAType = CM_CamsMoveTATypeCritieria.AnyArea) 
					and terminalAreaType &lt;&gt; moveTrxCriteria.notToTAType then
						targetReturnValue := true;				
					elseif not targetReturnValue and terminalAreaType = moveTrxCriteria.notToTAType then
						targetReturnValue := false;		
					endif;	
				endif;
			endif;
			
			if sourceReturnValue and targetReturnValue then // this is a matched so include the transaction
				loopValue := true;			// 31/06/2024 navcs2 Defect 64388
				returnValue := true;		// 31/06/2024 navcs2 Defect 64388
				break;						// 31/06/2024 navcs2 Defect 64388
			else			
				loopValue := true;			// 31/06/2024 navcs2 Defect 64388
				returnValue := false;		// 31/06/2024 navcs2 Defect 64388
			endif;
		endif;
	endforeach;
	
	if loopValue then																													// 31/06/2024 navcs2 Defect 64388
		if not returnValue then																											// 31/06/2024 navcs2 Defect 64388
			_camAgent.logReasonForExclusion (_transaction, 'Transaction source location is not a valid Move transaction criteria ' &amp; _camProtocol.protocolDesc.name &amp; ' protocol' );		// 26/03/2024 navcs2 ChangeRequest 60397
		endif;																															// 31/06/2024 navcs2 Defect 64388
		return returnValue;																												// 31/06/2024 navcs2 Defect 64388
	else																																// 31/06/2024 navcs2 Defect 64388
		return inheritMethod(_transaction, _camsTS, _startTS, _endTS, _camProtocol, _camGroup, _camAgent, _logExcluded, _event);		// 31/06/2024 navcs2 Defect 64388
	endif;																																// 31/06/2024 navcs2 Defect 64388

epilog

end;</source>
        <Parameter name="_transaction" type="CM_Transaction"/>
        <Parameter name="_camsTS" type="TimeStamp"/>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camGroup" type="CM_CamGroup"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_logExcluded" type="Boolean"/>
        <Parameter name="_event" type="CM_EventTransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isGoodsReceipt" id="2c18e8d2-e18a-4667-a23d-895075ad0031">
        <source>isGoodsReceipt(): Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 07 July 2023
TFS#		: 58636
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="outputFile" id="35b9197e-214f-4f8b-8359-01ada93c3eb4">
        <updating/>
        <source>outputFile(_protocol: CM_CamProtocol input; _camAgent: CM_CamControllerAgent; _camFile: CM_CamFile input; _runDateTime: TimeStamp; _camTaskHistory: CM_CamTaskHistory input; _unhSeqNumber: Integer io; _seqNumber: Integer; _terminal: CM_Terminal; _contextObj: Object; _transactions: CM_TITransactionSet) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 26 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description
26 Jul 2023		jlika1		55938		EUP Load Confirmation Message
17 Aug 2023		navmd1					Make Dmast match Wmast (source compare cleanup)
25 Sep 2023		navdap1		60365 		EUP | FR 53853 - Goods Receipt Message Grouping
09 Sep 2024		navmd1		60588		Move transforms to one place
14 Aug 2024		navmd1		61725		Change jsonHelper to JMTJadeJson to output ISO8601 dates
****************************************************/

vars
	jsonHelper		: JMTJadeJson;	
	goodsReceipt	: CMIF_JsonGoodsReceiptEUP;
	str 			: String;
	strLine 		: String;
	object			: Object;
	controller		: CM_CamControllerAgent;
	tmpStringArray	: HugeStringArray;
begin
	create jsonHelper transient;
	create tmpStringArray transient;
	controller := _camAgent;
	
	foreach object in _camAgent.allJsonGoodsReceipt do
		//if object.isKindOf(CMIF_JsonGoodsReceiptEUP) then															// TFS 60365
		// TFS 60365 _contextObj is nul in ad-hoc runs, otherwise it's the goods receipt object we're processing	// TFS 60365
		if object.isKindOf(CMIF_JsonGoodsReceiptEUP) and (object = _contextObj or _contextObj = null) then			// TFS 60365
			goodsReceipt := object.CMIF_JsonGoodsReceiptEUP;
			_camFile.incrementMessageCount();
			str := jsonHelper.generateJson(goodsReceipt, JadeJson.Format_Json_Microsoft);
			if str &lt;&gt; null then
				tmpStringArray.clear();
				self.addMessage(tmpStringArray, str, controller);
				str := tmpStringArray.concatenate("");
				str := str.replace(CM_CamProtocol.JSON_Output_Delimeter.unicodeToString, "");
			endif;
			
			if strLine &lt;&gt; null then
				strLine &amp;= Cr &amp; str;	//add a Cr in betwen each message, except before the first one
			else
				strLine := str;
			endif;
		endif;
	endforeach;

	_camTaskHistory.setRawDataString(strLine);
epilog
	delete jsonHelper;
	delete tmpStringArray;
end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_contextObj" type="Object"/>
        <Parameter name="_transactions" type="CM_TITransactionSet"/>
    </JadeMethod>
    <JadeMethod name="processEvent" id="dfff110e-96cb-478f-a081-c4c6de96c76b">
        <updating/>
        <source>processEvent(_transaction: CM_EventTransaction; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input; _camFile: CM_CamFile input) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 26 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description
04/06/2024		navlw1		63178		EUP* | FR - 53853 GoodsReceipt Missing Fields 
06/05/2025		navhn30     34603 		EUP FR | 53853 Good Receipt effective Quantity and Weight not correct after Ship Discrepancy
****************************************************/

vars
	voyage 			: CM_Voyage;
	train			: CM_Train;
	transaction 	: CM_TITransaction;
	trackedItem		: CM_TrackedItem;
	vehichleVisit	: CM_VehicleVisitRecord;
	startTs,
	endTs			: TimeStamp;
	event 			: CM_EventTransaction;
	count			: Integer;

begin
	if _transaction.isKindOf(CMEVT_VoyageEvent) then
		voyage := _transaction.getMyVoyage();
		
		if voyage = null then
			_camAgent.logReasonForExclusion(_transaction, 'Null Voyage, skipping this transaction');
			return;
		endif;
		//jlier1 Tfs 60112 20/9/23
	/*	foreach transaction in voyage.allTITransactionsByDTType do
			if transaction.isKindOf(CM_ReceiveShip) then
				self.processTransaction(transaction, _camProtocol, _camAgent, _camFile);
			endif;
		endforeach;*/
		foreach trackedItem in voyage.allOnsiteTIsByIdCargoType do			//06.05.25	 navhn30 	MTN-34603
			self.processTI(_transaction, trackedItem, _camProtocol, _camAgent, _camFile, null, null);			
		endforeach;
	endif;
	
	if _transaction.isKindOf(CMEVT_TrainTransaction) then
		train := _transaction.getTrain();
		
		if train = null then
			_camAgent.logReasonForExclusion(_transaction, 'Train is null, skipping this transaction');
			return;
		endif;
		
		// start #63178
		startTs := null;
		endTs 	:= null;
		foreach event in train.allWagonTransactions do
			if event.type = EVT_WagonJobStart then
				if startTs = null or startTs &gt; event.dateTime then
					startTs := event.dateTime;
				endif;
			elseif event.type = EVT_WagonJobStop then
				if endTs = null or endTs &lt; event.dateTime then
					endTs := event.dateTime;
				endif;
			endif;
		endforeach;
		// end #63178
		foreach trackedItem in train.allTIsReceived do
			self.processTI(_transaction, trackedItem, _camProtocol, _camAgent, _camFile, startTs, endTs);			
		endforeach;
	endif;

	if _transaction.isKindOf(CMEVT_TruckEvent) then
		vehichleVisit := _transaction.getVehicleVisit();

		if vehichleVisit = null then
			_camAgent.logReasonForExclusion(_transaction, 'Vehicle visit is null, skipping this transaction');
			return;
		endif;
		
		// start #63178
		startTs := null;
		endTs 	:= null;
	
		foreach event in vehichleVisit.allEventTransactions do				
			if event.type = EVT_TruckJobStart then
				if startTs = null or startTs &gt; event.dateTime then
					startTs := event.dateTime;
				endif;
			elseif event.type = EVT_TruckJobStop then
				if endTs = null or endTs &lt; event.dateTime then
					endTs := event.dateTime;
				endif;
			endif;												
		endforeach;
		// end #63178
		foreach trackedItem in vehichleVisit.allReceivedTrackedItems do			
			self.processTI(_transaction, trackedItem, _camProtocol, _camAgent, _camFile, startTs, endTs);			
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_transaction" type="CM_EventTransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processTI" id="5775b75a-156a-4b0d-829e-09f993968a5d">
        <updating/>
        <source>processTI(_transaction: CM_Transaction;_theTI: CM_TrackedItem input; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input; _camFile: CM_CamFile input; _startDate, _endDate : TimeStamp)  updating, protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 21 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description
21/07/2023		jlika1 		TFS 59230 	Unable to do Adhoc Run for "EUP Goods Receipt Activity" with early start date
24/07/2023		jlika1		55938		EUP | Load Confirmation Protocol
30/08/2023		jlika1		60139		MTN - Load Confirmation - TransportationMode and TransportType are displaying as Road and Truck in the CAMS message for the Ship Release Request
19/09/2023		jlika1		60337		EUP | FR EDI - EUP CAMS protocols: Translations based on Receiver
6/10/2023		navra1		60396		EUP | FR 54085 - Load Confirmation - Field Mapping
10/10/2023		navra1		60663 		EUP | FR - 53853 GoodsReceipt - Cargo For Other Operators Included In GoodsReceipt
13/03/2024		navhn30		62423		ChangeRequest 62423: EUP | CAMS protocol TYPE - Fixed Values
04/06/2024		navlw1		63178		EUP* | FR - 53853 GoodsReceipt Missing Fields 
11 Mar 2025 	naviv1  	MTN-34287 	 EUP FR | Expected and Effective amounts are incorrect for cargo received via ship
21 Apr 2025 	navhn30		MTN-34603	EUP FR | 53853 Good Receipt effective Quantity and Weight not correct after Ship Discrepancy
****************************************************/
constants
	GoodsReceipt = "GoodsReceipt";

vars
	manifest				: String;
	tiGoodsReceipt			: CMIF_JsonGoodsReceiptEUP;
	transport				: CMIF_JsonTransportFullEUP;
	transportExist			: CMIF_JsonTransportFullEUP;
	voyage					: CM_Voyage;
	header					: CMIF_JsonHeaderEUP;
	headerReference			: CMIF_JsonHeaderReferenceEUP;
	camProtocol				: CM_CamProtocol;
	transportMode			: String;	
	operatorTI				: CM_Operator;
	operatorEDI				: CM_Operator;
	goodsReceipt			: CMIF_JsonGoodsReceiptEUP;
	ediFile					: CM_EDIFile;
	valuePair				: CM_NameValuePair;
	invalid					: Boolean;
	guid					: String;
	tiManifest				: String;
	vehicleVisit 			: CM_VehicleVisitRecord;
	foundMatch				: Boolean;
	transVoyageCode			: String;
	tiWagon	  				: CM_Wagon;
	isForLoadConfirmation	: Boolean;			//navra1 - TFS 60396 - 6th Oct 2023 - renamed isFromRelReq
	object					: Object;
	debtor					: CM_Debtor;
	count					: Integer;
	result					: JadeRegexResult;
	voyageNumber			: String;
	isForEvent				: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, _theTI, invalid);
	isForLoadConfirmation := false;		//navra1 - TFS 60396 - 6th Oct 2023
	isForEvent := false;				//navhn30  MTN-34603	21.04.25
	_theTI.edition;
	if invalid then
		_camAgent.logReasonForExclusion(_transaction, 'TI no longer valid, skipping this transaction');
		return;
	endif;
	
	if _camProtocol.allTrainEventTypes.size &lt;&gt; null then	//navhn30   MTN-34603	21.04.25
		isForEvent := true;
	endif;
	
	//navra1 - TFS 60663 - 11th Oct 2023 - start
	if _theTI.myOperator &lt;&gt; null then
		if _camProtocol.camGroup.operators = null or not _camProtocol.camGroup.operators.includes(_theTI.myOperator) then
			_camAgent.logReasonForExclusion(_transaction, 'TI operator is not included in the CAM Group, skipping this transaction');
			return;
		endif;
	endif;
	//navra1 - TFS 60663 - 11th Oct 2023 - end
	
	operatorTI := _theTI.myOperator;	
	transportMode := app.transModeToString(_theTI.receiptTransportMode);
	voyage := _theTI.myVoyage;	
	camProtocol := _camProtocol;
	vehicleVisit := _theTI.getVehicleVisit();
	tiWagon := _theTI.getMyWagonReceive();
	// In Tracked Item Manifest is composed of Manifest Number | Guid
	tiManifest := _theTI.manifestNumber;
	if tiManifest &lt;&gt; null then
		//pos := 1;
		//manifest := tiManifest.scanUntil("|", pos);					//05.Feb.24 navsp1 TFS 61071
		//guid := tiManifest[pos+1:end];								//05.Feb.24 navsp1 TFS 61071 - Attribute has three values
		
		count := JadeRegex@split(tiManifest, "(\|)", true, result);		//05.Feb.24 navsp1 TFS 61071
		if count &gt; 1 then
			manifest := result.at(1).value;
			guid	 := result.at(2).value;
		endif;
		
	else
		manifest := tiManifest; //Cargo created from JMT got a null Manifest
	endif;
	
	object := _camAgent.allJsonGoodsReceipt[manifest];
	
	tiGoodsReceipt := object.CMIF_JsonGoodsReceiptEUP;
	
	if tiGoodsReceipt &lt;&gt; null and tiGoodsReceipt.header.number = manifest then // already exist
		//Check if there is an EDI File if there is get the Operator used from the EDI File otherwise continue using the TI Operator
		ediFile := tiGoodsReceipt.header.getEDIFileByManifest(manifest, guid, _theTI.myTerminal);
		if ediFile &lt;&gt; null then
			operatorEDI := _theTI.myTerminal.myRoot.allOperators[ediFile.ediData.operatorCode];			
			
			debtor := app.myRoot.myRootCompany.allDebtorsByCode[ediFile.fileSenderCode];
			if operatorEDI = null and debtor &lt;&gt; null then
				operatorEDI := debtor.operators.first;				
			endif;
			
			if operatorEDI &lt;&gt; null and operatorEDI.code &lt;&gt; operatorTI.code then
				operatorTI := operatorEDI;
			endif;
		endif;
		//Check if transport already exist
		transportMode := app.transModeToString(_theTI.receiptTransportMode);
		
		if transportMode = TI_TRANSMODE_SHIP_STR then
			foreach transportExist in tiGoodsReceipt.transports do
				voyageNumber := voyage.inwardCode; //JIRA-34287
				if voyageNumber = null then
					voyageNumber := voyage.inwardCodeAuto; //JIRA-34287
				endif;
				if voyage &lt;&gt; null and transportExist.vesselInfo &lt;&gt; null and transportExist.vesselInfo.voyageNumber = voyageNumber then //JIRA-34287 -- modified condition to use voyageNumber 
					transport := transportExist;
					break;
				endif;
				//not exist check the translater code
				transVoyageCode := operatorTI.getXlationForeignCode(voyageNumber, XLATION_TYPE_VOYAGETERMINAL , foundMatch); //JIRA-34287 -- modified condition to use voyageNumber 
				if operatorTI &lt;&gt; null and transportExist.vesselInfo &lt;&gt; null and transportExist.vesselInfo.voyageNumber = transVoyageCode then
					transport := transportExist;
					break;
				endif;
			endforeach;
		elseif transportMode = TI_TRANSMODE_ROAD_STR then			
			foreach transportExist in tiGoodsReceipt.transports do
				if vehicleVisit &lt;&gt; null and transportExist.truckInfo &lt;&gt; null and transportExist.truckInfo.licensePlate = vehicleVisit.regNumber then
					transport := transportExist;
					break;
				endif;
			endforeach;
		elseif transportMode = TI_TRANSMODE_RAIL_STR then			
			foreach transportExist in tiGoodsReceipt.transports do
				if tiWagon &lt;&gt; null and transportExist.trainInfo &lt;&gt; null and transportExist.trainInfo.wagonNumber = tiWagon.id then
					transport := transportExist;
					break;
				endif;
			endforeach;
		endif;
		
		if transport &lt;&gt; null then
		   if _transaction.isKindOf(CM_TITransaction) then
			 transport.createGoodFromTI(_theTI, operatorTI, isForLoadConfirmation,_transaction.CM_TITransaction,isForEvent);	// 21.04.25	navhn30	MTN-34603	//navra1 - TFS 60396 - 6th Oct 2023
		   else
			 transport.createGoodFromTI(_theTI, operatorTI, isForLoadConfirmation,null,isForEvent);	// 21.04.25	navhn30	MTN-34603	//navra1 - TFS 60396 - 6th Oct 2023
		   endif;
		else
		
			create transport transient;
			transport.setFromTI(_theTI, voyage, operatorTI, transportMode, isForLoadConfirmation, _startDate, _endDate); // #63178
			
			if _transaction.isKindOf(CM_TITransaction) then
				transport.createTransportObjects(transportMode, voyage, _theTI, operatorTI, _transaction.CM_TITransaction, vehicleVisit, tiWagon, isForLoadConfirmation,isForEvent);	//navhn30  MTN-34603	21.04.25		//navra1 - TFS 60396 - 6th Oct 2023
			else
				transport.createTransportObjects(transportMode, voyage, _theTI, operatorTI, null, vehicleVisit, tiWagon, isForLoadConfirmation,isForEvent);	//navhn30  MTN-34603	21.04.25	//navra1 - TFS 60396 - 6th Oct 2023
			endif;

			tiGoodsReceipt.transports.add(transport);
		endif;
	else// Not Exist
		create header transient;
		header.setFromTI(_theTI, _camAgent);
		header.type := GoodsReceipt;						// 13.03.24		navhn30		TFS #62423
		
		//Check if there is an EDI File if there is get the Operator used from the EDI File otherwise continue using the TI Operator
		ediFile := header.getEDIFileByManifest(manifest, guid, _theTI.myTerminal);
		if ediFile &lt;&gt; null then
			operatorEDI := _theTI.myTerminal.myRoot.allOperators[ediFile.ediData.operatorCode];			
			
			debtor := app.myRoot.myRootCompany.allDebtorsByCode[ediFile.fileSenderCode];
			if operatorEDI = null and debtor &lt;&gt; null then
				operatorEDI := debtor.operators.first;				
			endif;
			
			if operatorEDI &lt;&gt; null and operatorEDI.code &lt;&gt; operatorTI.code then
				operatorTI := operatorEDI;
			endif;
		endif;
		
		if ediFile &lt;&gt; null then
			foreach valuePair in ediFile.allHeaderReferences do
				create headerReference transient;			
				headerReference.setHeaderReferences(valuePair.name, valuePair.value);
				header.headerReferences.add(headerReference);			
			endforeach;
			
			if ediFile.fileSenderCode &lt;&gt; null then
				header.setReceiver(ediFile.fileSenderCode);			
			endif;
		endif;
		
		header.setNumber(manifest);			

		create transport transient;
		transport.setFromTI(_theTI, voyage,operatorTI, transportMode, isForLoadConfirmation, _startDate, _endDate);		//navra1 - TFS 60396 - 6th Oct 2023

		if _transaction.isKindOf(CM_TITransaction) then
			transport.createTransportObjects(transportMode, voyage, _theTI, operatorTI, _transaction.CM_TITransaction, vehicleVisit, tiWagon, isForLoadConfirmation,isForEvent);	//navhn30  MTN-34603	21.04.25	//navra1 - TFS 60396 - 6th Oct 2023
		else
			transport.createTransportObjects(transportMode, voyage, _theTI, operatorTI, null, vehicleVisit, tiWagon, isForLoadConfirmation,isForEvent);//navhn30  MTN-34603	21.04.25	//navra1 - TFS 60396 - 6th Oct 2023
		endif;			
		
		create goodsReceipt transient;
		goodsReceipt.setValue(header, transport);
		
		_camAgent.allJsonGoodsReceipt.putAtKey(manifest, goodsReceipt);
	endif;	
	
epilog
	delete result;
end;</source>
        <access>protected</access>
        <Parameter name="_transaction" type="CM_Transaction"/>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_startDate" type="TimeStamp"/>
        <Parameter name="_endDate" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="processTransaction" id="222a29e5-446f-44cd-9c86-db82a93af850">
        <updating/>
        <source>processTransaction(_transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input; _camFile: CM_CamFile input) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 21 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description
04/06/2024		navlw1		63178		EUP* | FR - 53853 GoodsReceipt Missing Fields 
****************************************************/


vars
	theTI 			: CM_TrackedItem;
	transaction		: CM_TITransaction;
begin
	transaction := _transaction;
	theTI := transaction.myTrackedItem;
	
	self.processTI(transaction, theTI, _camProtocol, _camAgent, _camFile, null, null); // #63178
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
</Class>
