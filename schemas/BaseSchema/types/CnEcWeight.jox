    <JadeMethod name="convertBaseToTarget" id="dee6af86-041f-4b47-8c5e-5b9100b2aa7f">
        <source>convertBaseToTarget(pMeasure: Real; pUnitTo: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		26 May 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitTo = self.CARATS_METRIC then
		convertedMeasure	:=	pMeasure / 0.0002;

	elseif pUnitTo = self.GRAINS then
		convertedMeasure	:=	pMeasure / 0.00006479891;
		
	elseif pUnitTo = self.GRAMS then
		convertedMeasure	:=	pMeasure / 0.001;

	elseif pUnitTo = self.HUNDREDWEIGHTS_LONG then
		convertedMeasure	:=	pMeasure / 50.80234544;

	elseif pUnitTo = self.HUNDREDWEIGHTS_SHORT then
		convertedMeasure	:=	pMeasure / 45.359237;

	elseif pUnitTo = self.KILOGRAMS then
		convertedMeasure	:=	pMeasure;

	elseif pUnitTo = self.OUNCES then
		convertedMeasure	:=	pMeasure / 0.028349523125;

	elseif pUnitTo = self.OUNCES_TROY then
		convertedMeasure	:=	pMeasure / 0.0311034768;

	elseif pUnitTo = self.POUNDS then
		convertedMeasure	:=	pMeasure / 0.45359237;

	elseif pUnitTo = self.SLUGS then
		convertedMeasure	:=	pMeasure / 14.593903;

	elseif pUnitTo = self.STONES then
		convertedMeasure	:=	pMeasure / 6.35029318;

	elseif pUnitTo = self.TONNES then
		convertedMeasure	:=	pMeasure / 1000;

	elseif pUnitTo = self.TONS_UK then
		convertedMeasure	:=	pMeasure / 1016.0469088;

	elseif pUnitTo = self.TONS_US then
		convertedMeasure	:=	pMeasure / 907.18474;
	
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12004, "[" &amp; pUnitTo.String &amp; "] is an unknown unit of weight to convert to.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertToBaseUnit" id="ddf1feb1-1df1-4af6-8b17-a733b0a6a64b">
        <source>convertToBaseUnit(pUnitFrom: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		26 May 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitFrom = self.CARATS_METRIC then
		convertedMeasure	:=	self.measure * 0.0002;

	elseif pUnitFrom = self.GRAINS then
		convertedMeasure	:=	self.measure * 0.00006479891;
		
	elseif pUnitFrom = self.GRAMS then
		convertedMeasure	:=	self.measure * 0.001;

	elseif pUnitFrom = self.HUNDREDWEIGHTS_LONG then
		convertedMeasure	:=	self.measure * 50.80234544;

	elseif pUnitFrom = self.HUNDREDWEIGHTS_SHORT then
		convertedMeasure	:=	self.measure * 45.359237;

	elseif pUnitFrom = self.KILOGRAMS then
		convertedMeasure	:=	self.measure;

	elseif pUnitFrom = self.OUNCES then
		convertedMeasure	:=	self.measure * 0.028349523125;

	elseif pUnitFrom = self.OUNCES_TROY then
		convertedMeasure	:=	self.measure * 0.0311034768;

	elseif pUnitFrom = self.POUNDS then
		convertedMeasure	:=	self.measure * 0.45359237;

	elseif pUnitFrom = self.SLUGS then
		convertedMeasure	:=	self.measure * 14.593903;

	elseif pUnitFrom = self.STONES then
		convertedMeasure	:=	self.measure * 6.35029318;

	elseif pUnitFrom = self.TONNES then
		convertedMeasure	:=	self.measure * 1000;

	elseif pUnitFrom = self.TONS_UK then
		convertedMeasure	:=	self.measure * 1016.0469088;

	elseif pUnitFrom = self.TONS_US then
		convertedMeasure	:=	self.measure * 907.18474;

	else
		CnEcBaseSchemaException.raise_(CNEC_X_12003, "[" &amp; pUnitFrom.String &amp; "] is an unknown unit of weight to convert from.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pUnitFrom" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getAllUnits" id="72a48332-c256-4fe9-b584-b31e0c85df40">
        <source>getAllUnits(pAllUnits: IntegerArray input);
// --------------------------------------------------------------------------------
// Created:		10 May 2008 by Darrell
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pAllUnits.add(self.CARATS_METRIC);
	pAllUnits.add(self.GRAINS);
	pAllUnits.add(self.GRAMS);
	pAllUnits.add(self.HUNDREDWEIGHTS_LONG);
	pAllUnits.add(self.HUNDREDWEIGHTS_SHORT);
	pAllUnits.add(self.KILOGRAMS);
	pAllUnits.add(self.OUNCES);
	pAllUnits.add(self.OUNCES_TROY);
	pAllUnits.add(self.POUNDS);
	pAllUnits.add(self.SLUGS);
	pAllUnits.add(self.STONES);
	pAllUnits.add(self.TONNES);
	pAllUnits.add(self.TONS_UK);
	pAllUnits.add(self.TONS_US);
end;</source>
        <Parameter name="pAllUnits" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getUnitName" id="bf35fa20-a8bf-4fd7-b151-7519ee0152a1">
        <source>getUnitName(pUnit: Integer): String;
// --------------------------------------------------------------------------------
// Created:		09 May 2008 by Darrell
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pUnit = self.CARATS_METRIC then
		return "Carats (Metric)";
	elseif pUnit = self.GRAINS then
		return "Grains";
	elseif pUnit = self.GRAMS then
		return "Grams";
	elseif pUnit = self.HUNDREDWEIGHTS_LONG then
		return "Hundredweights Long (UK)";
	elseif pUnit = self.HUNDREDWEIGHTS_SHORT then
		return "Hundredweights Long (US)";
	elseif pUnit = self.KILOGRAMS then
		return "Kilograms";
	elseif pUnit = self.OUNCES then
		return "Ounces";
	elseif pUnit = self.OUNCES_TROY then
		return "Ounces (Troy)";
	elseif pUnit = self.POUNDS then
		return "Pounds";
	elseif pUnit = self.SLUGS then
		return "Slugs";
	elseif pUnit = self.STONES then
		return "Stones";
	elseif pUnit = self.TONNES then
		return "Tonnes";
	elseif pUnit = self.TONS_UK then
		return "Tons (UK)";
	elseif pUnit = self.TONS_US then
		return "Tons (US)";
	else
		CnEcBaseSchemaException.raise_(CNEC_X_12003, "[" &amp; pUnit.String &amp; "] is an unknown unit of Weight to convert from.");
		return null;
	endif;
end;</source>
        <Parameter name="pUnit" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
