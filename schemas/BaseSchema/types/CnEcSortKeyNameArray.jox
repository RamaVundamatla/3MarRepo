    <DbClassMap file="basemap"/>
    <JadeMethod name="addKey" id="302aba19-0bc5-47f0-96d3-a4a250b60654">
        <lockReceiver/>
        <updating/>
        <source>addKey(pKeyName:String; pIsDescending:Boolean; pIsCaseSensitive:Boolean) lockReceiver, updating;
// --------------------------------------------------------------------------------
// Created:		13 March 2001 by cnwdad1
//
// Purpose:		Adds a sort key name object to the receiver.
//
// Parameters:	pKeyName - The name/value of the key.
//				pIsDescending - True if sorting in descending order.
//				pIsCaseSensitive - True if sorting is case-sensitive.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sortKeyObj	: CnEcSortKeyName;
	
begin
	if self.isTransient() then
		create sortKeyObj transient;
	else
		create sortKeyObj persistent;
	endif;
	
	sortKeyObj.initializeMe(pKeyName, pIsDescending, pIsCaseSensitive);
	self.add(sortKeyObj);
end;</source>
        <Parameter name="pKeyName" type="String"/>
        <Parameter name="pIsDescending" type="Boolean"/>
        <Parameter name="pIsCaseSensitive" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addKeyAt" id="770b7143-2758-44ae-aae1-cd54feacaa08">
        <lockReceiver/>
        <updating/>
        <source>addKeyAt(pIndex:Integer; pKeyName:String; pIsDescending:Boolean; pIsCaseSensitive:Boolean) lockReceiver, updating;
// --------------------------------------------------------------------------------
// Created:		13 March 2001 by cnwdad1
//
// Purpose:		Inserts a sort key name object into the receiver.
//
// Parameters:	pIndex - The array index at which to insert the key name.
//				pKeyName - The name/value of the key.
//				pIsDescending - True if sorting in descending order.
//				pIsCaseSensitive - True if sorting is case-sensitive.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sortKeyObj	: CnEcSortKeyName;
	
begin
	if self.isTransient() then
		create sortKeyObj transient;
	else
		create sortKeyObj persistent;
	endif;
	
	sortKeyObj.initializeMe(pKeyName, pIsDescending, pIsCaseSensitive);
	self.atPut(pIndex, sortKeyObj);
end;</source>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pKeyName" type="String"/>
        <Parameter name="pIsDescending" type="Boolean"/>
        <Parameter name="pIsCaseSensitive" type="Boolean"/>
    </JadeMethod>
</CollClass>
