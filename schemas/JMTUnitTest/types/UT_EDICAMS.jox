    <JadeMethod name="zCompareXML" id="6401624f-abf4-454e-a1e2-bd9000491921">
        <source>zCompareXML( actual : JadeXMLDocument; expected : JadeXMLDocument; ignoreValueList : StringArray) protected;
// ---------------------------------------------------------------------------
// Created:	08 April 2015 By Graeme Black cnwgb1
// Status: 	
// Purpose:	
// ---------------------------------------------------------------------------
vars
actualElement : JadeXMLElement;
actualElements : JadeXMLElementArray;
expectedElement : JadeXMLElement;
expectedElements : JadeXMLElementArray;
count: Integer;

begin

	create actualElements transient;
	create expectedElements transient;
	actual.getElementsByTagNameNS('*', '*', actualElements );
	expected.getElementsByTagNameNS('*', '*', expectedElements );
	assertEqualMsg(actualElements.size, expectedElements.size, "Count of Elements not Correct");
	count := 1;
	foreach actualElement in actualElements do
		assertEqualMsg(actualElement.tagName, expectedElements[count].tagName, "Element Mismatch");
		if not ignoreValueList.includes( actualElement.tagName ) then
			assertEqualMsg(actualElement.text, expectedElements[count].text, "Element Value Mismatch for " &amp; actualElement.tagName);
		endif;
		count := count +1;
	endforeach;
epilog
	delete actualElements;
	delete expectedElements;
end;</source>
        <access>protected</access>
        <Parameter name="actual" type="JadeXMLDocument"/>
        <Parameter name="expected" type="JadeXMLDocument"/>
        <Parameter name="ignoreValueList" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="zGetBGMDocumentType" id="5e212878-4fa3-49ad-b920-e6618a3394fd">
        <source>zGetBGMDocumentType(_infoLine : StringArray512;
					_bgmIdentifier : String;
					_camProtocol : CM_CamProtocol) : String;
/*
Purpose: Returns the Document Type in the BGM message in CODECO CAM protocol
		 ex. BGM+34+123+9'
		 9 is the document type which means Original (whole new message)

Parameters:			

Return Value:		

Date		Who		TFS		Reason
06 Nov 2019	jlgdi1	46578	Initial creation
*/

constants
	NEXT_POSITION = 1;
	LINE_TERMINATOR = 1;
	
vars
	line : String;
	terminatorPos : Integer;
	value : String;
	length : Integer;
	trimLine : String;
	
begin
	foreach line in _infoLine do
		if line.startsWith(_bgmIdentifier) then 
			trimLine := line.trimRight().removeCrLfs();
			terminatorPos := trimLine.reversePos(_camProtocol.elementSeparator);
			length := trimLine.length - terminatorPos - LINE_TERMINATOR;
			value := trimLine[terminatorPos + NEXT_POSITION:length];
			break;
		endif;
	endforeach;
	
	return value;
end;</source>
        <Parameter name="_infoLine" type="StringArray512"/>
        <Parameter name="_bgmIdentifier" type="String"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="zGetXMLAttribute" id="aad142b7-8772-4a1c-8268-8af30d953b85">
        <source>zGetXMLAttribute(_infoLine : StringArray512; _lineIdentifier : String) : String;
/*
Purpose: Returns specific XML Attribute (XML Element) based on decalred identifier
		 ex. 'FTX+AAI'

Parameters:			

Return Value:		

Date		Who		TFS		Reason
06 Nov 2019	jlgdi1	46578	Initial creation
*/

vars
	line : String;
	
begin
	foreach line in _infoLine do
		if line.startsWith(_lineIdentifier) then 
			return line.trimRight().removeCrLfs();
			break;
		endif;
	endforeach;
	
	return "";
end;</source>
        <Parameter name="_infoLine" type="StringArray512"/>
        <Parameter name="_lineIdentifier" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="zGetXlatedForeignCode" id="fcd5054b-d8df-43f3-a835-47ecd1826592">
        <source>zGetXlatedForeignCode(_operatorCode : String; _code : String io; _codeType : Integer; _terminal: CM_Terminal) : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2025	navpw1	Initial creation JIRA: MTN-30307

*/

vars
	operator 		: CM_Operator;
	foreignCode 	: String;
	matchFound 		: Boolean;
	
begin
	if _code.trimBlanks &lt;&gt; null then
		operator := app.myRoot.allOperators[_operatorCode];
		
		if operator &lt;&gt; null then
			foreignCode := operator.getXlationForeignCode (_code, _codeType, matchFound);	// par 31259
		else //par15042 oct 2007 cnwrs1
			foreignCode := _code.trimBlanks;
		endif;
	endif;
	
	return foreignCode;	

end;</source>
        <access>protected</access>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_code" type="String" usage="io"/>
        <Parameter name="_codeType" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="zLoadSuzanoPulpManifest" id="f9d58ec6-8d7a-4d19-9fda-4261fe65ec90">
        <source>zLoadSuzanoPulpManifest();
//
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
//
constants
	USER_DEF_NAME : String = "SuzanoManifest";
	VoyageName		: String = "UTS200";
	VesselName1		: String = "UTSBOAT";
	CamGroup 		= "UT34561";
	CamProtocol 	= "UT_SUZRECEIVE_34561";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
	OperatorCode = "SUZ";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediTI : CM_EDITrackedItem;
	operator : CM_Operator;
begin
	passportObj	:=	app.myPassport;
	
	operator := self.getOperator("SUZ");
	self.deleteEDIInwardXlation(VoyageName, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteVoyage(VoyageName);
	voyage	:= self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(VesselName1);
	vessel	:= self.getVessel(VesselName1);
	self.assertIsDeleted(vessel);
	
	vessel := self.addVesselCellular(VesselName1, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, "Add vessel failed");
	voyage := self.addVoyageWithContainerStructur(VoyageName, VesselName1, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.createEDIXlation("0001253T14", VoyageName, XLATION_TYPE_VOYAGETERMINAL, true, operator, null);

	ediText :=
'
&lt;?xml version="1.0" encoding="utf-8"?&gt;
&lt;Viagem xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns="http://CECOL.suzano.com.br/LE/PackingList"&gt;
  &lt;ID&gt;PL0001523T1420140724163106&lt;/ID&gt;
  &lt;Means_Transp&gt;01&lt;/Means_Transp&gt;
  &lt;Shipping_ID&gt;0001253T14&lt;/Shipping_ID&gt;
  &lt;Bill_Lading&gt;WFLH14BGN0106B&lt;/Bill_Lading&gt;
  &lt;Dest_Plant&gt;4103&lt;/Dest_Plant&gt;
  &lt;Delivery_Date&gt;20140709&lt;/Delivery_Date&gt;
  &lt;Ship_CO_Name /&gt;
  &lt;CNPJ_Transp /&gt;
  &lt;Transp_Code /&gt;
  &lt;Driver_Name /&gt;
  &lt;CPF_Driver /&gt;
  &lt;RG_Driver /&gt;
  &lt;PackList&gt;
    &lt;NFNum /&gt;
    &lt;DocNum&gt;0000000000&lt;/DocNum&gt;
    &lt;DateNF&gt;00021130&lt;/DateNF&gt;
