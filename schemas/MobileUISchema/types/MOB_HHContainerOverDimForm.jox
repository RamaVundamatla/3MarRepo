    <JadeMethod name="displayDimensions" id="8e8730f1-1f99-4d5d-82ba-9db986b66e28">
        <updating/>
        <source>displayDimensions() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/02/2010	cnwdap1	Initial creation
04/03/2010	cnwdap1	PAR #22741 Correct call to getToDoTaskForCargoCheck - was using myCargoCheckItem.name
*/
vars
	container	: CM_Container;
	taskCode	: Integer;
	task		: CM_ToDoTask;
	prod : CM_Product;
begin
	if self.myTrackedItem &lt;&gt; null and CM_Container.hasInstance(self.myTrackedItem) then
		container				:= self.myTrackedItem.CM_Container;
		//cnwrd1 ccms 1321 imperial measurements
		prod := container.getProductForMeasurementConv();
		self.txtLeft.text		:= self.myMobileDataAgent.getMeasureConvertedForDisplay(prod,Type_Length,container.overWidthLeft);
		self.txtRight.text		:= self.myMobileDataAgent.getMeasureConvertedForDisplay(prod,Type_Length,container.overWidthRight); 
		self.txtBack.text		:= self.myMobileDataAgent.getMeasureConvertedForDisplay(prod,Type_Length,container.overLengthRear);
		self.txtFront.text		:= self.myMobileDataAgent.getMeasureConvertedForDisplay(prod,Type_Length,container.overLengthFront);
		self.txtHeight.text		:= self.myMobileDataAgent.getMeasureConvertedForDisplay(prod,Type_Length,container.overHeight);
		
		// check for a to do task
		// 37244 but not from to-do task completion
		if self.myToDoTaskDesc = null then
			taskCode := self.myMobileGenericAgent.getToDoTaskForCargoCheck(self.context, self.myCargoCheckItem.requiredExtraInfo, self.myTerminal);
			if taskCode &lt;&gt; null then
				// does the tracked item have a to do task that matches this description?
				foreach task in self.myTrackedItem.allToDoTasksToDo do
					if task.toDoTaskDesc.code = taskCode then
						chkAddToDo.value := true;
					endif;
				endforeach;
			endif;
		endif;			
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="602f9c5a-11f8-46a6-9472-3bd7983279f0">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604
04 Feb 2016			NDL		Par 37513
*/

vars

	cTop : Real;
	cHeight : Real;
	cLeft : Real;
	stdHeight : Real;
	stdWidth : Real;
	tabIndex : Integer;
	thirdWidth : Real;
	labelWidth :Real;
	textBoxWidth : Real;

begin

	self.setResizeableMarginAndFontSize();
	
	stdHeight := self.getStdControlHeight;
	stdWidth := self.clientWidth - (self.resizedMargin * 2);
	thirdWidth := ( stdWidth - (self.resizedMargin * 2)) / 3;
	labelWidth := thirdWidth;
	textBoxWidth := thirdWidth;
	if textBoxWidth &gt; ( stdHeight * 5 ) then
		textBoxWidth := stdHeight * 5;
	endif;
	
	
	cTop := self.resizedMargin;
	tabIndex := 4000;
	
	cLeft := self.resizedMargin;
	if _initialSetup then
		self.lblLeft.setAndIncrementTabIndex( tabIndex );
		self.lblLeft.visible := true;
	endif;
	self.lblLeft.move( 	cLeft,
						cTop,
						labelWidth,
						stdHeight );
						
	cLeft := self.lblLeft.left + self.lblLeft.width + self.resizedMargin;
	if _initialSetup then
		self.txtLeft.setAndIncrementTabIndex( tabIndex );
		self.txtLeft.visible := true;
	endif;
	self.txtLeft.move( 	cLeft,
						cTop,
						textBoxWidth,
						stdHeight );
						
	cTop := cTop + self.lblLeft.height + self.resizedMargin;
	cLeft := self.resizedMargin;
	if _initialSetup then
		self.lblRight.setAndIncrementTabIndex( tabIndex );
		self.lblRight.visible := true;
	endif;
	self.lblRight.move( cLeft,
						cTop,
						labelWidth,
						stdHeight );
						
	cLeft := self.lblRight.left + self.lblRight.width + self.resizedMargin;
	if _initialSetup then
		self.txtRight.setAndIncrementTabIndex( tabIndex );
		self.txtRight.visible := true;
	endif;
	self.txtRight.move( cLeft,
						cTop,
						textBoxWidth,
						stdHeight );
						
	cTop := cTop + self.lblRight.height + self.resizedMargin;
	cLeft := self.resizedMargin;
	if _initialSetup then
		self.lblBack.setAndIncrementTabIndex( tabIndex );
		self.lblBack.visible := true;
	endif;
	self.lblBack.move( 	cLeft,
						cTop,
						labelWidth,
						stdHeight );
						
	cLeft := self.txtLeft.left;
	if _initialSetup then
		self.txtBack.setAndIncrementTabIndex( tabIndex );
		self.txtBack.visible := true;
	endif;
	self.txtBack.move( 	cLeft,
						cTop,
						textBoxWidth,
						stdHeight );
						
	cTop := cTop + self.lblBack.height + self.resizedMargin;
	cLeft := self.resizedMargin;
	if _initialSetup then
		self.lblFront.setAndIncrementTabIndex( tabIndex );
		self.lblFront.visible := true;
	endif;
	self.lblFront.move( cLeft,
						cTop,
						labelWidth,
						stdHeight );
						
	cLeft := self.txtRight.left;
	if _initialSetup then
		self.txtFront.setAndIncrementTabIndex( tabIndex );
		self.txtFront.visible := true;
	endif;
	self.txtFront.move( cLeft,
						cTop,
						textBoxWidth,
						stdHeight );
						
	cTop := cTop + self.lblFront.height + self.resizedMargin;
	cLeft := self.resizedMargin;
	if _initialSetup then
		self.lblHeight.setAndIncrementTabIndex( tabIndex );
		self.lblHeight.visible := true;
	endif;
	self.lblHeight.move( 	cLeft,
						cTop,
						labelWidth,
						stdHeight );
						
	cLeft := self.txtBack.left;
	if _initialSetup then
		self.txtHeight.setAndIncrementTabIndex( tabIndex );
		self.txtHeight.visible := true;
	endif;
	self.txtHeight.move( 	cLeft,
						cTop,
						textBoxWidth,
						stdHeight );

	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="442feb52-cda0-49a5-8c77-a0d2dddadf38">
        <updating/>
        <source>doSave() : Boolean updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/02/2010	cnwdap1	Initial creation
04/03/2010	cnwdap1	PAR #22741 New parameter for updateGenCargoDimensions so we know whether to add or remove the to do task
*/
vars
	sessionAgent	: CM_MobileAgent;
	errors			: String;
	toDoTaskCode	: Integer;
	addingToDo		: Boolean;
	prod : CM_Product;
	addCompRemTodo	: Integer;	// 1 = add, 2 = complete, 3 = remove 16 Mar 2016	NDL TFS 1673

begin
	app.mousePointer := self.MousePointer_HourGlass;
	
	sessionAgent := self.getSessionAgent;
	if sessionAgent.getMyProxyObject = null then
		return false;
	endif;
	
	// 37244 this code from cargo check, not from to-do task completion
	if self.myToDoTaskDesc = null then
		toDoTaskCode 	:= self.myMobileGenericAgent.getToDoTaskForCargoCheck(CARGO_CHECK_CONTEXT_GATE_REC, EXTRA_INFO_DIMENSION, self.myTerminal);
	//	addingToDo		:= self.chkAddToDo.value;
		//16 Mar 2016	NDL TFS 1673
		if self.chkAddToDo.value then
			addCompRemTodo := 1;
		else
			addCompRemTodo := 3;
		endif;
	else
		//16 Mar 2016	NDL TFS 1673
		addCompRemTodo := 2;
	endif;
	
	//cnwrd1 ccms 1321 imperial measurements
	prod := sessionAgent.getMyProxyObject.CM_TrackedItem.getProductForMeasurementConv();
	if sessionAgent.updateContainerDimensions(	self.myMobileDataAgent.getMeasureConvertedForStorage(prod,Type_Width,self.txtLeft.text),
												self.myMobileDataAgent.getMeasureConvertedForStorage(prod,Type_Width,self.txtRight.text),
												self.myMobileDataAgent.getMeasureConvertedForStorage(prod,Type_Length,self.txtBack.text),
												self.myMobileDataAgent.getMeasureConvertedForStorage(prod,Type_Length,self.txtFront.text),
												self.myMobileDataAgent.getMeasureConvertedForStorage(prod,Type_Height,self.txtHeight.text),
												toDoTaskCode,
												addCompRemTodo	) then
												
		if errors &lt;&gt; null then
			self.msgBox(errors, "Error", MsgBox_OK_Only, false);
			return false;
		endif;
		
		return true;
	else
		return false;
	endif;
	
epilog
	app.mousePointer := self.MousePointer_Default;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="fa385140-016e-4a47-a475-97334dc101af">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 February 2010	cnwdap1	Initial creation
*/
vars

begin
	if self.doSave() then
		if self.myToDoTaskDesc = null then
			self.doBackButtonClick();
		else
			self.getSessionAgent().setMyProxy( null ); // delete the proxy TI
			self.unloadForm();			// 37244
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="3829192a-7d2b-493c-9150-3744dd3cca19">
        <updating/>
        <source>handleBtnTwo() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 February 2010	cnwdap1	Initial creation
*/
vars

begin
	// 37244 from to-do task completion
	if self.myToDoTaskDesc = null then
		self.doBackButtonClick();
	else
		self.getSessionAgent().setMyProxy( null ); // delete any proxy TI
		self.unloadForm();
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resizeControlsToOriginalValues" id="390dce55-8aed-4cb1-a60d-b2d9e16415b6">
        <updating/>
        <source>resizeControlsToOriginalValues() updating, protected;
// from 37244 resize controls to original size/location when screen is small enough
vars
	
begin
	self.lblBack.move(1, 51, 59, 23);
	self.lblFront.move(116, 51, 62, 23);
	self.lblHeight.move(21, 86, 80, 23);
	self.lblLeft.move(1, 16, 59, 23);
	self.lblRight.move(116, 16, 62, 23);
	
	self.txtBack.move(62, 51, 50, 23);
	self.txtFront.move(180, 51, 50, 23);
	self.txtHeight.move(102, 86, 50, 23);
	self.txtLeft.move(62, 16, 50, 23);
	self.txtRight.move(180, 16, 50, 23);

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTrackedItem" id="fdd1ec27-6a0a-44c1-949a-5bf7d62c4ef5">
        <updating/>
        <source>setTrackedItem(_value : CM_TrackedItem) updating;
//  37244 set myTrackedItem directly without affecting anything else
vars

begin
	self.myTrackedItem := _value;
end;
</source>
        <Parameter name="_value" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="43ce4da1-0901-463c-aadf-b68b39721a8a">
        <updating/>
        <source>setupForm() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 February 2010	cnwdap1	Initial creation
*/
vars

begin
	// 37244 from to-do task completion has already been setup
	if self.myTrackedItem = null then
		self.myTrackedItem := self.myMobileGenericAgent.myNextTiToAction;
	endif;
	app.myMobileAgent.setMyProxy( self.myTrackedItem );
	app.myMobileAgent.setMySelectedTI(self.myTrackedItem);
	
	inheritMethod();
	
	if self.myMobileGenericAgent.stringField1 &lt;&gt; null then
		self.context := self.myMobileGenericAgent.stringField1[1:2].Integer;
		self.myCargoCheckItem := self.myMobileGenericAgent.stringField1[3:end].asOid.CM_CargoCheckItem;
		self.myMobileGenericAgent.setStringField1(null);
	endif;

	// 37244 from to-do task completion
	if self.myToDoTaskDesc = null then
		self.setupCmdButtons( 2, app.getErrorString(Save), BACK_BUTTON, null, null, null );
	else
		self.setupCmdButtons( 2, app.getErrorString(Save), app.getErrorString(Back), null, null, null );
	endif;
	self.setupInputs();
	self.displayDimensions();
	// from 37244, was missing so not setting the label and button font correctly
	self.doResizeControls(true);
	self.txtLeft.setFocus();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupInputs" id="64ef2f87-bf7f-4487-ae1f-2ba789d7770b">
        <updating/>
        <source>setupInputs() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/02/2010	cnwdap1	Initial creation
31/03/2010	cnwdap1	PAR #22741 To Do check expanded for all contexts
*/
vars
	cargoCheck				: CM_CargoCheck;
	cargoCheckItem, item	: CM_CargoCheckItem;
	prod : CM_Product;

begin
	self.lblLeft.visible 	:= true;
	self.txtLeft.visible 	:= true;
	self.lblRight.visible 	:= true;
	self.txtRight.visible 	:= true;
	self.lblBack.visible 	:= true;
	self.txtBack.visible 	:= true;
	self.lblFront.visible 	:= true;
	self.txtFront.visible 	:= true;
	self.lblHeight.visible 	:= true;
	self.txtHeight.visible 	:= true;
	
	//cnwrd1 ccms 1321 imperial measurements
	if self.myTrackedItem &lt;&gt; null then
		prod := self.myTrackedItem.getProductForMeasurementConv();
	endif;
	self.lblBack.setCaptionForMeasurementLabel( self.myMobileDataAgent.getMeasureLabelUnit(prod,Type_Length) );
	self.lblFront.setCaptionForMeasurementLabel( self.myMobileDataAgent.getMeasureLabelUnit(prod,Type_Length) );
	self.lblHeight.setCaptionForMeasurementLabel( self.myMobileDataAgent.getMeasureLabelUnit(prod,Type_Length) );
	self.lblLeft.setCaptionForMeasurementLabel( self.myMobileDataAgent.getMeasureLabelUnit(prod,Type_Length) );
	self.lblRight.setCaptionForMeasurementLabel( self.myMobileDataAgent.getMeasureLabelUnit(prod,Type_Length) );
	
	//self.lblBack.setCaptionForMeasurementType( 'length');
	// to do task checkbox is only visible if the cargo check item has a to do task associated with it
	// 37244 not if from to-do task completion
	if self.myToDoTaskDesc &lt;&gt; null then
		if self.myTrackedItem &lt;&gt; null then
			self.caption := self.caption &amp; " " &amp; self.myTrackedItem.id;
		endif;
	else
		//cargoCheck := self.myTerminal.allCargoChecks[CARGO_CHECK_CONTEXT_GATE_REC];	// PAR #22741
		cargoCheck := self.myMobileGenericAgent.getEquipCheckContextFromState();		// PAR #22741
		if cargoCheck &lt;&gt; null then
			foreach item in cargoCheck.allCargoCheckItems discreteLock where item.requiredExtraInfo = EXTRA_INFO_DIMENSION do	//31 May 2012	NDL Par 29038
				if item.myToDoTaskDesc &lt;&gt; null then
					self.chkAddToDo.visible	:= true;
				endif;
			endforeach;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d905487f-8617-4b17-982b-7173513b7140">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014725, locale);
	chkAddToDo.translateCaption(Xlat_0014408, locale);
	lblBack.translateCaption(Xlat_0014409, locale);
	lblFront.translateCaption(Xlat_0014410, locale);
	lblHeight.translateCaption(Xlat_0014411, locale);
	lblLeft.translateCaption(Xlat_0014412, locale);
	lblRight.translateCaption(Xlat_0014413, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
