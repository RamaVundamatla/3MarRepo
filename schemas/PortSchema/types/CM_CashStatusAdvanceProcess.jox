    <JadeMethod name="getDisplay" id="5c2b1ec8-db3a-4e37-9b1f-26f541c2a738">
        <source>getDisplay(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/09/2018	jlgdap1		Initial creation TFS 40202 PEL1 Estimation SAP Integration
//
vars
	invalid : Boolean;
	detail : String;

begin
	on Exception do app.handleDeletedObject(exception, self.myCashReceipt, invalid);
	
	detail := "Cash Receipt Status Process";
	detail := detail &amp; Tab &amp; 
						self.actionTimeStamp.asStringJMT &amp; Tab &amp; 
						self.myCashReceipt.myTerminal.code &amp; Tab &amp; 
						self.myCashReceipt.sequenceNum.String &amp; Tab &amp;
						self.myCashReceipt.getDescription &amp; Tab &amp; 
						"" &amp; Tab &amp; 
						self.myCashReceipt.myDebtorTerminal.myDebtor.name &amp; Tab &amp; 
						self.myCashReceipt.effectiveDate.asStringJMT &amp; Tab;
	
	if invalid then 
		return null;
	endif;
	
	return detail;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationString" id="2b709fb7-9c31-439f-8091-140c4a01a61d">
