    <JadeMethod name="addToolbarControls" id="62ff3bbf-1e6d-4196-9f7e-040694b18554">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 January 2026	jlier1	Initial creation 36572

*/

vars
	toolbar : CMUI_Toolbar;
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnSearchCargo, CMUI_Toolbar.Control_Alignment_Left); // TFS 46054
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
	self.frmMain.top:=toolbar.height;
	self.frmMain.height:=self.height - toolbar.height;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnSearchCargo_click" id="93b91eb2-4725-4e6a-9123-82fb2d952544">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSearchCargo_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2026	jlier1	Initial creation

*/

vars
	form   : CMUI_CargoSearchFormModal;
	cargoLocation : CM_LocationsController;
	cargoTA : CM_TerminalArea;
begin
	form := app.loadForm(CMUI_CargoSearchFormModal, 
							CMUI_Assistant, 
							false, 
							false,
							true, 
							self.myTerminal,
							null).CMUI_CargoSearchFormModal;	

	if form = null then
		return;
	endif;
	form.setParentForm(self);
	form.setCargoType(self.cmbCargoTypeInvP.listObject.CM_CargoType);
	form.cmbType.enabled := true;
	
	form.setMyOperator(self.cmbCargoOper.listObject.CM_Operator);
	form.txtCargoID.setValue( self.tblInvLineProps.getValueByName(ETRow_CargoId).String);
	cargoLocation := self.cmbCargoLoc.listObject.CM_LocationsController;
	if cargoLocation &lt;&gt; null then
		cargoTA := cargoLocation.getMyTerminalArea;
		if cargoTA &lt;&gt; null then
			form.setMyTerminalArea(cargoTA);
		endif;
	endif;
	
	form.setColumnsAndControlWidth(3, 175);

	form.showModal();
	


epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbCargoLoc_displayEntry" id="a806a9c5-467b-4bfd-902d-85d458c3b6ae">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoLoc_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2026	jlier1	Initial creation

*/

vars

begin
	if obj = null or not obj.isKindOf( CM_LocationsController ) then
		return null;
	endif;
	
	return obj.CM_LocationsController.getFullId();
epilog

end;</source>
