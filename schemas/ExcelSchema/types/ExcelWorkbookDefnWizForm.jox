    <JadeMethod name="unload" id="ed498a2d-db68-4bba-88ab-8f08a1df4ad8">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

/*****************************************************
	Written by	:	cnwgrp1		06 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	on Exception do app.defaultExceptionHandler(exception);
	if not normalUnload then
		myDA.setIntCurrentWizardStep(9);
	endif;
	
	myDA.allOpenForms.remove(self);
	setMyDataDA(null);
	
	myDA.doFinished(self);
epilog

end;</source>
    </JadeMethod>
