        <source>getTableColumFilters(_table: Table; _allFilterColumns: CM_ColumnFilterDict io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

begin

	if self.allColumnFilters = null then
		create self.allColumnFilters transient;  // this is a non exclusive collection.
	endif;
	
	if self.allColumnFilters.isEmpty then
		return;
	endif;
	
	self.allColumnFilters.cloneFiltersForTable( _table, _allFilterColumns );

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_allFilterColumns" type="CM_ColumnFilterDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="8180ee35-99c6-448f-b002-6396452b2999">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 March 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	theXML		: String;

begin
	
	theXML := inheritMethod();
	
	theXML := theXML &amp; self.tblFailed.getXmlStrForColumns(true);
	theXML := theXML &amp; self.tblSelectedCargo.getXmlStrForColumns(true);
	theXML := theXML &amp; self.tblWouldPlan.getXmlStrForColumns(true);
	
	return theXML;

epilog

end;</source>
        <ReturnType type="String"/>
