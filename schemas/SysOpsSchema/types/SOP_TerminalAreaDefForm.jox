end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCmbLaneGroupClick" id="d752d5aa-558f-4762-b58d-01d3d6353aec">
        <source>doCmbLaneGroupClick(combobox : ComboBox);
// ---------------------------------------------------------------------------
// Created:		01 February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	taGroup		: CM_TerminalAreaGroup;
	ta			: CM_TerminalArea;
	laneGrouping, newLaneID, numRows, numLanes : Integer;
	tmpStr : String;
begin
	//constituent terminal areas  of a terminal area group must be same size
	taGroup := combobox.listObject.CM_TerminalAreaGroup;
	if taGroup = null then
		self.tblMain.enableRowByName(ETRow_Rows);
	else
		ta := taGroup.allTAsByTypeId.first;
		if (not CM_GridArea.hasInstance(ta)) then
			return;
		else
			self.tblMain.setValueByName(ETRow_Rows, ta.CM_GridArea.allGridRows.size.String);
		endif;
		
		self.doBuildComboNextPrevLane();
		
	endif;
	
end;</source>
        <Parameter name="combobox" type="ComboBox"/>
    </JadeMethod>
    <JadeMethod name="doComboTATypeSelect" id="68e090f2-803a-40f3-9693-e618315a664a">
        <updating/>
        <source>doComboTATypeSelect() updating, protected;

/*

Date		Who		Reason
09/07/2008	cnwkpd1	PAR #17407 - Default Stock Controlled and Auto Yard Allocation to true 
					for Irregular Block Areas
10/06/2013	cnwmh5	#31769 - Move where ti initializes tblGateLanes and add code for generating lanes for cta areas
03/06/2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars
	viewName	 		: String;
	taType 				: CM_TerminalAreaType;
	isSaveToBeEnabled	: Boolean;
	entRowTransient 	: EntTableRowTransient;
	entTableView 		: EntTableView;
	entRow 				: Object;
	entTableDef			: EntTableDef;
	
begin
	self.sptThumbEdit.hideRightControl(true);
	self.clearDesignArea();
	self.enableRows();
	
	isSaveToBeEnabled 	:= true;
	//epr TFS 1918 29/4/16
	taType 				:= self.cmbTAType.listObject.CM_TerminalAreaType;
	if taType = null then
		return;
	endif;
	
	//taType 				:= self.getTAStringToType(cmbTAType.text.String.trimBlanks);
	
	self.shtDefDesign.visible 		:= true;
	self.shtDefDesign.enabled 		:= false;
	self.shtTerminalAreas.visible	:= false;
	self.shtTerminalAreas.caption	:= app.getErrorString (TerminalAreas);
	self.listsTermAreas.resetButtonsVisible;
	self.shtAutoPlan.visible		:= not taType.isGantryLaneAreaType; //epr par 20741 17/3/10
	self.btnFlipHori.enabled 		:= self.shtDefDesign.enabled;	
	self.btnFlipVertical.enabled 	:= self.shtDefDesign.enabled;	
		
	self.createCMIFTerminalArea(taType);
	self.terminalAreaType := taType.type;
	self.tblMain.showRowByName(ETRow_AutoRestrictionsEnabled, false);
	
	if self.myProxyObject = null or (not self.myProxyObject.isKindOf(taType.getTAClassToCreate)) then
		//th2 - need to create a myProxyObject even when adding new to act as a place holder for various
		//functions that require an instance to work with
		self.createMyProxyObjForNew(taType);
	endif;
	
	// cnwjk3 CCMS 1032 15/12/2008
	self.btnDoorFwd.visible := taType.type = TA_TYPE_STRADDLE_STACK;
	self.btnDoorAft.visible := taType.type = TA_TYPE_STRADDLE_STACK;
	self.btnDoorFwd.enabled := taType.type = TA_TYPE_STRADDLE_STACK;
	self.btnDoorAft.enabled := taType.type = TA_TYPE_STRADDLE_STACK;		
	
	// following lines force a refresh of the table to paint checkbox values when first loaded
	// JADE Support Contact Reference = 19297
	self.fldDefinition.topSheet.setFocus;
	self.tblMain.setFocus;
	
	self.shtDefDesign.enabled := taType.isGridAreaType;
	if taType.isGridAreaType then
		self.shtDefDesign.caption := "New " &amp; cmbTAType.text.String.trimBlanks;
	endif;
	viewName		:= taType.getTADefintionViewName;
	entTableDef		:= app.myController.getEntTableDef(ETDef_TAMain);
	entTableView	:= entTableDef.allEntTableViews[viewName];
	self.tblMain.setEntTableFromView(entTableDef,entTableView,null, 'entTableDefSetupWarning');
	self.tblMain.setValueByName(ETRow_StockControlled, self.myTerminal.getConfig(DefTAStockControlled).Boolean);
	foreach entRow in self.tblMain.allEntRowTransients do
		entRowTransient := entRow.EntTableRowTransient;
		self.tblMain.setValueByName(entRowTransient.name, taType.getTADefaultsForAttribute(entRowTransient.name));
	endforeach;	
	
	self.tblMain.disableRowByName(ETRow_RailTransferArea);
	
	self.cmbTAType.listIndex:=self.cmbTAType.findString(0,taType.description);
	self.tblMain.adjustHeight(800);
	
	self.initTableGateLanes(self.tblGateLanes, taType.type); // cnwjk3 ccms 1018 18/11/09			// 10/06/2013 cnwmh5 #31769 Move from below	
	
	//04 Aug 2017	NDL	TFS 5679
	if taType.isLogicalDeleteArea then
		self.tblMain.showRowByName(ETRow_DoCreateLogicalDelTrx,false);	
	else
		self.tblMain.hideRowByName(ETRow_DoCreateLogicalDelTrx,false);	
	endif;
	
	//07 Jun 2018	NDL	TFS 38897
	if taType.type = TA_TYPE_RELTRANS then
		self.populateCmbTrxType( null );
		self.tblMain.showRowByName(ETRow_AutoRelease, false);
		self.tblMain.showRowByName(ETRow_TrxTypeOnRelease, false);
	else
		self.tblMain.hideRowByName(ETRow_AutoRelease, false);
		self.tblMain.hideRowByName(ETRow_TrxTypeOnRelease, false);
		self.cmbTrxType.listIndex := -1;
	endif;
	
	if taType.isGantryAreaType then
		
		self.doBuildComboNextPrevLane(); //epr par 22854 9/3/10
		self.cmbSideICPos.listIndex:=self.cmbSideICPos.findString(0,self.tblMain.getValueByName(ETRow_SideInterchangePos).String);
		self.initExtraTable( taType );	//11 Sep 2020	NDL	TFS 49984
		self.displayStackHeights(null);		//11 Sep 2020	NDL	TFS 49984
		
	elseif  taType.isGantryLaneAreaType then
		self.setDefaultTAsForGantryLane(taType);
	//elseif taType.type = TA_TYPE_BULK or taType.type = TA_TYPE_BLOCK_STACK then	// R Barr 3/11/2006 Comalco
	elseif taType.type = TA_TYPE_BULK or taType.type = TA_TYPE_BLOCK_STACK or taType.type = TA_TYPE_IRREGULAR_BLOCK_AREA or		//20 Jun 2016	NDL	TFS 1752
	taType.type = TA_TYPE_GEN_CARGO_ALLOC_ROW then					// TFS 49453
		//epr CCMS 1366 3/4/14 setup product min maxs
		self.initExtraTable( taType );
		self.displayProductMinMax(null);
	endif;
	
	if taType.type = TA_TYPE_YARD_INTERCHANGE then
		self.shtGateLanes.visible	:= true;
		self.setDefaultTAsForInterchange(null);
	elseif  taType.type = TA_TYPE_CRANE_TRANS then							// 10/06/2013 cnwmh5 #31769
		self.shtGateLanes.visible	:= true;
		self.myProxyObject.CM_CraneTransferArea.pxyUpdateLaneCount(tblMain.getValueByName(ETRow_NumLanes).Integer);
		self.loadLanesForCTA(self.myProxyObject.CM_CraneTransferArea);
	elseif taType.type = TA_TYPE_WORKPOINT_INTERCHANGE then
		self.shtGateLanes.visible	:= true;
	elseif  taType.type =  TA_TYPE_RORO_LANE_AREA then		// cnwjk3 ccms 1018 18/11/09
		self.shtGateLanes.visible	:= true;					// cnwjk3 ccms 1018 18/11/09
		self.shtGateLanes.caption := app.getErrorString(XLAT_Caption_Lanes);
		self.setDefaultRoRoLabels(self.myProxyObject.CM_RoRoLaneArea);		
		self.setControlsForRoRoLaneTable();
	else
		self.shtGateLanes.visible	:= false;
	endif;
	
	if taType.canAssociateInterchangeAreas then
		self.setDefaultICAreas();
	endif;
	
	//epr par 21448 18/3/10
	self.listsTermAreas.readOnly:=false;
	//self.initTableGateLanes(self.tblGateLanes, taType.type); // cnwjk3 ccms 1018 18/11/09
	
	self.setCMIFFromTable();
	self.frmToolbar.updateControls();
	self.btnFlipHori.enabled := self.shtDefDesign.enabled;	
	self.btnFlipVertical.enabled := self.shtDefDesign.enabled;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doControlEvent" id="f855da0f-64ba-4a3f-ba2a-3da73a724c59">
        <updating/>
        <source>doControlEvent(_control: Control) updating;

vars

begin

	if  _control = self.listsTermAreas.myAddSelectedBtn or  _control = self.listsTermAreas.myRemoveSelectedBtn  then
		
		self.doBuildDefaultInterchangeCombo(self.cmbInterchange.listObject.CM_InterchangeArea);
	else
		inheritMethod(_control);
	endif;
end;</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doCopy" id="327aafdb-77c6-4621-8e8c-4bd68fd3af92">
        <source>doCopy();
/*
Purpose:			
Date		Who		Reason
25 October 2013	cnwab1	Initial creation
*/

vars

begin

	// PAR 32844
	self.frmBlkArea.myDrawingController.allCopiedItems.clear();
	self.frmBlkArea.myDrawingController.allSelectedObjects.copyNoDups(self.frmBlkArea.myDrawingController.allCopiedItems );
	self.mnuPaste.userObject := self.frmBlkArea.myDrawingController.allCopiedItems.first;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDeckingOptions" id="dc892745-a65b-4fe9-af3a-e9f6d63aa0c5">
        <source>doDeckingOptions();
// 03 February 2009	cnwwc2	

vars
	terminalArea, proxyTerminalArea : CM_TerminalArea;
	theForm : CMUI_DeckingRulesForm;

begin

	if self.myCurrentObject = null then
		app.msgBox(app.getErrorString(DeckingRulesNoItemSelected), 'Error', MsgBox_Stop_Icon  + MsgBox_OK_Only);
		return;
	endif;
	
	//terminalArea := self.tblData.accessedRow.itemObject.CM_TerminalArea;
	terminalArea := self.myCurrentObject.CM_TerminalArea;
	
	if (not terminalArea.isDeckable) then
		app.msgBox( app.getErrorString2(DeckingOptionsDontApplyToTA, terminalArea.id, terminalArea.myType.description), 'Error', MsgBox_Stop_Icon  + MsgBox_OK_Only);
		return;
	endif;

	if terminalArea &lt;&gt; null then
	
		if self.myCurrentObject.CM_TerminalArea.type = TA_TYPE_RORO_LANE_AREA then
			theForm := app.loadForm(CMUI_DeckingRoRoRulesForm, CMUI_Assistant, false, false, false, 
					terminalArea.myTerminal, null).CMUI_DeckingRulesForm;
			
			if theForm = null then
				return;
			endif;	
			proxyTerminalArea := app.createUpdateProxy(terminalArea).CM_TerminalArea;	
			theForm.onCreate(proxyTerminalArea.myYADeckingOptions, null, terminalArea);
			theForm.setParentForm(self);
			theForm.showModal();

		else
			theForm := app.loadForm(CMUI_DeckingRulesForm, CMUI_Assistant, false, false, false, 
					terminalArea.myTerminal, null).CMUI_DeckingRulesForm;
			
			if theForm = null then
				return;
			endif;	
			proxyTerminalArea := app.createUpdateProxy(terminalArea).CM_TerminalArea;	
			theForm.onCreate(proxyTerminalArea.myYADeckingOptions, null, terminalArea);
			theForm.setParentForm(self);
			theForm.showModal();
		endif;
	endif;
	
epilog
	delete proxyTerminalArea;		
end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="fa63af58-536e-4460-815c-be80aaddeb3c">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rtnValue	: Boolean;
	toDelete	: CM_TerminalAreaMaster;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	toDelete := self.myCurrentObject.CM_TerminalAreaMaster;

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteTerminalArea(toDelete, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Terminal Areas', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
	return true;
		
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDirectionChange" id="64da051f-c9e7-4b19-b997-d3d5accf39da">
        <source>doDirectionChange( _column : String; _combobox : ComboBox) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwjk3	Initial creation

*/

vars
	leftLabel,
	rightLabel,
	direction 	: String;
	col,
	col2 		: Integer;
	roroLC		: CM_RoRoController;
begin
	direction := _combobox.text;
	self.tblGateLanes.getEntRowColumnByRowName(_column, col);
	self.tblGateLanes.accessCell(self.tblGateLanes.row, col).text := direction;

	// Get the value of the left and right lane labels
	leftLabel := self.tblMain.getValueByName(ETRow_LeftLabel).String;
	rightLabel := self.tblMain.getValueByName(ETRow_RightLabel).String;

	
	// Update the integer behind the string with the correct value.  This helps us out when we need
	// to update the combos and cell text in response to a change of label names.
	
	// Numbering direction 
	self.tblGateLanes.getEntRowColumnByRowName(ETRow_NumberingDirection, col2);
	if col = col2 then
		roroLC := self.tblGateLanes.accessRow(self.tblGateLanes.row).itemObject.CM_RoRoController;
		if roroLC &lt;&gt; null then
			roroLC.updateNumberingDirectionData(direction, leftLabel, rightLabel);
		endif;
	endif;
	
	// Parking direction 
	self.tblGateLanes.getEntRowColumnByRowName(ETRow_ParkDirection, col2);
	if col = col2 then
		roroLC := self.tblGateLanes.accessRow(self.tblGateLanes.row).itemObject.CM_RoRoController;
		if roroLC &lt;&gt; null then
			roroLC.updateParkDirectionData(direction, leftLabel, rightLabel);
		endif;
	endif;

	// Access direction 
	self.tblGateLanes.getEntRowColumnByRowName(ETRow_AccessDirection, col2);
	if col = col2 then
		roroLC := self.tblGateLanes.accessRow(self.tblGateLanes.row).itemObject.CM_RoRoController;
		if roroLC &lt;&gt; null then
			roroLC.updateAccessDirectionData(direction, leftLabel, rightLabel);
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_column" type="String"/>
        <Parameter name="_combobox" type="ComboBox"/>
    </JadeMethod>
    <JadeMethod name="doDirectionClick" id="879f239f-aa46-4fc5-b77a-c8c8db9944b6">
        <source>doDirectionClick(_column : String; _combobox : ComboBox input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2009	cnwjk3	Initial creation

*/

vars
	direction 	: String;
	col 		: Integer; 
	jCell		: JadeTableCell;
	index		: Integer;
begin
	direction := _combobox.text;
	self.tblGateLanes.getEntRowColumnByRowName(_column, col);
	
	// Get the text in the cell
	jCell := self.tblGateLanes.accessCell(self.tblGateLanes.row, col);
	direction := jCell.text;
	
	// Set the combo selection to match the text in the cell
	index := _combobox.findString(1, direction);
	if index &gt; 0 then
		_combobox.listIndex := index;
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_column" type="String"/>
        <Parameter name="_combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDrawBlockArea" id="99219bb1-2068-47bf-806f-9361edc4ceaf">
        <updating/>
        <source>doDrawBlockArea(terminalArea : CM_TerminalArea; _forUpdate : Boolean) updating, protected;
vars
	i : Integer;
	blockArea		: CM_IrregularBlockArea;
	controls : CnEcControlArray;
	control : Control;
begin
	self.clearDesignArea();

	if _forUpdate then
		self.setTABlockArea(true);
		blockArea := self.myProxyObject.CM_IrregularBlockArea;
	else
		blockArea := self.myCurrentObject.CM_IrregularBlockArea;
	endif;
	
	self.frmBlkArea.visible := true;
	self.frmBlkArea.enabled := true;
	self.frmBlkArea.init(blockArea, true, self.mode, self);
	self.shtDefDesign.enabled := true;
	frmBlkArea.drawSelf();
	
	self.frmTBICAreas.visible:= false;
	self.btnAssocIC.visible:=false;
	
	
	self.btnSaveGCIC.visible := true;
	self.btnSaveGCIC.enabled := false;
	self.btnAssocIC4GC.visible:=true;
	self.btnAssocIC4GC.value:=false;
	self.btnAssocIC4GC.enabled:=_forUpdate;
	self.cmbTBICAreasGC.visible := true;
	self.cmbTBICAreasGC.enabled:=false;
	self.frmTBICAreas.enabled:=_forUpdate;
	self.frmTBICAreas.visible:=true;

	self.frmTBBlockDesign.positionToolbarControls;
	
end;</source>
        <access>protected</access>
        <Parameter name="terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_forUpdate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDrawDesignArea" id="93ff1520-140e-4434-950d-588b4a5f52da">
        <updating/>
        <source>doDrawDesignArea(terminalArea : CM_TerminalArea; _forUpdate : Boolean) updating, protected;

vars

begin

	self.frmToolbarDesign.visible := false;
	self.frmTBBlockDesign.visible := false;
	self.frmMain.visible := false;
	self.frmBlkArea.visible := false;
	if terminalArea.isKindOf(CM_GridArea) then
		self.frmToolbarDesign.visible := true;
		self.frmMain.visible := true;
		doDrawGridArea(_forUpdate);
	elseif terminalArea.isKindOf(CM_IrregularBlockArea) then
		self.frmTBBlockDesign.visible := true;			
		self.frmBlkArea.visible := true;
		doDrawBlockArea(terminalArea, _forUpdate);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_forUpdate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDrawGridArea" id="19460b18-0945-4fcf-9c3c-353daf275598">
        <updating/>
        <source>doDrawGridArea(_forUpdate : Boolean) updating, protected;

vars
	sopGridArea		: SOP_GridArea;
	gridArea		: CM_GridArea;
begin
	create sopGridArea transient;
	if self.myCurrentSOPGridArea &lt;&gt; null then
		sopGridArea.setZoomFactorTo(self.myCurrentSOPGridArea.scaleXFactor);
	endif;
	delete self.myCurrentSOPGridArea;
	
	self.clearDesignArea();
	self.myCurrentSOPGridArea := sopGridArea;
	if _forUpdate then
		gridArea := self.myProxyObject.CM_GridArea;
	else
		gridArea := self.myCurrentObject.CM_GridArea;
	endif;

	self.btnSaveGCIC.visible := false; // PAR 32308
	self.btnAssocIC4GC.visible:=false; // PAR 32308
	self.cmbTBICAreasGC.visible := false; // PAR 32308
	self.frmTBICAreas.visible:=false; // PAR 32308
	
	
	self.myCurrentSOPGridArea.setForDraw(gridArea, self.myAssistant, self);
	self.frmMain.addGridAreaAndFrame(self.myCurrentSOPGridArea, self.frmGrdArea);
	self.frmMain.drawSelf();
	shtDefDesign.enabled := true;
	self.btnFlipHori.enabled := self.shtDefDesign.enabled;	
	self.btnFlipVertical.enabled := self.shtDefDesign.enabled;	

	//ccms 1100
	self.frmTBICAreas.visible:=not  gridArea.isKindOf(CM_RTGArea);
	self.btnAssocIC.visible:=self.frmTBICAreas.visible;
	self.btnAssocIC.value:=false;
	self.btnAssocIC.enabled:=_forUpdate;
	self.frmTBICAreas.enabled:=_forUpdate;
	if _forUpdate and self.frmTBICAreas.visible then
		self.cmbTBICAreas.enabled:=false;
	endif;

	self.frmToolbarDesign.positionToolbarControls;
end;</source>
        <access>protected</access>
        <Parameter name="_forUpdate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFldDefinitionClick" id="b6dd7a78-fb22-4eef-819f-782cce48357a">
        <updating/>
        <source>doFldDefinitionClick(folder : Folder) updating;
// ---------------------------------------------------------------------------
// Created:		04 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 04/06/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
vars
	taType 		: CM_TerminalAreaType;
begin

	taType := getTAStringToType(tblMain.getValueByName(ETRow_Type).String);
	if taType &lt;&gt; null then // PAR 16896
		if folder.topSheet = shtDefDesign and (self.mode = Mode_Add or self.mode = Mode_Update) then
			self.btnSaveBase.enabled := true;
			self.buildOrAdjustAreaSize(true);
		endif;
	endif;
	
	if self.redrawGrid then
		self.doRedrawGrid();
	endif;
	
	
	if folder.topSheet &lt;&gt; self.shtDefData then
		self.sptThumbEdit.hideRightControl(true);
	else
		
		if taType &lt;&gt; null and 
		// 34353 add block stack
		   (taType.type = TA_TYPE_BULK or taType.type = TA_TYPE_BLOCK_STACK
		   or taType.type = TA_TYPE_IRREGULAR_BLOCK_AREA	//22 Jun 2016	NDL	TFS 1752
		   or taType.type = TA_TYPE_GEN_CARGO_ALLOC_ROW)		// TFS 49453
		   or taType.allowsGriddedStackHeightCrit()	//21 Sep 2020	NDL	TFS 49984
		    or taType.isGantryAreaType() 	//21 Sep 2020	NDL	TFS 49984
		   then
			self.sptThumbEdit.showRightControl(60, true);
			self.resize;	//24 Sep 2020	NDL	TFS 49984
		else
			self.sptThumbEdit.hideRightControl(true);
		endif;
	endif;
epilog
	
end;</source>
        <Parameter name="folder" type="Folder"/>
    </JadeMethod>
    <JadeMethod name="doFlipHorizontal" id="c9633bea-9afb-4399-8055-ade82e6bbe8d">
        <updating/>
        <source>doFlipHorizontal() updating;
// ---------------------------------------------------------------------------
// Created:		August 2001 By Andrew Bishop cnwab1
//
// Purpose:		FLIP Display Horizontal. 
// ---------------------------------------------------------------------------
vars

begin
	if self.flipHorizontal = false then
		self.flipHorizontal := true;
		self.btnFlipHori.caption := "Normal &amp;H";
		self.btnFlipHori.bubbleHelp := "Normal H";
	else
		self.flipHorizontal := false;
		self.btnFlipHori.caption := "Reversed &amp;H";
		self.btnFlipHori.bubbleHelp := "Reversed H";
	endif;		
	self.populateDesign();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doFlipVertical" id="0ac48c28-79b8-44b2-b43a-56ef8502bd5a">
        <updating/>
        <source>doFlipVertical() updating;
// ---------------------------------------------------------------------------
// Created:		August 2001 By Andrew Bishop cnwab1
//
// Purpose:		FLIP Display Vertical. Re use of existing buttons to flip display
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.flipVertical = false then
		self.flipVertical				:= true;
		self.btnFlipVertical.caption	:= "Normal &amp;V";
		self.btnFlipVertical.bubbleHelp	:= "Normal V";
	else
		self.flipVertical				:= false;
		self.btnFlipVertical.caption	:= "Reversed &amp;V";
		self.btnFlipVertical.bubbleHelp := "Reversed V";
	endif;		
	self.populateDesign();


end;</source>
    </JadeMethod>
    <JadeMethod name="doGetQuantity" id="6fe13cfc-fcca-4a3d-93af-8fc5fae0645f">
        <updating/>
        <source>doGetQuantity() updating;
/*
Purpose:			
Date				Who			Reason
Sept 2013		CNWAB1		Initial creation
*/


vars
	maxQty : Integer;
	lForm : CMUI_GetData;
	obj : Object;
	shelf : CM_RackShelfController;
begin

	create lForm;
	lForm.centreWindow;
	app.mousePointer := MousePointer_Default;

	obj := self.frmBlkArea.myDrawingController.allSelectedObjects.first;
	if obj.isKindOf(CM_RackShelfController) then
		maxQty := obj.CM_RackShelfController.defaultCapacity;
	elseif obj.isKindOf(CM_IrregularBlockController) then
		shelf := obj.CM_IrregularBlockController.allSubLocations.first();
		if shelf &lt;&gt; null then
			maxQty := shelf.defaultCapacity;
		endif;
	endif;
	
	if maxQty = 0 then
		maxQty := 1;
	endif;
	
	lForm.lblTextCaption := app.getErrorString(Quantity).cnEcFirstToUpper &amp; ":";
	lForm.txtData.text := maxQty.String;
	lForm.txtData.maxLength := 6;	//22 Jul 2020	NDL	TFS 49775
	lForm.txtData.dataType := TextBox.DataType_Numeric;
	lForm.txtData.decimals := 0;		
	lForm.myCaller := self;
	lForm.formCaption := app.getErrorString(Quantity);
	lForm.type := self.GetData_Capacity;
	lForm.doResize;
	lForm.show;
	
	// ### CALLED BACK is getData()
	
epilog
	mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doGetWeight" id="1af623f2-9263-4496-8e29-d50e86132b7d">
        <updating/>
        <source>doGetWeight() updating;
/*
Purpose:			
Date				Who			Reason
Sept 2013		CNWAB1		Initial creation
*/


vars
	maxQty : Real;
	lForm : CMUI_GetData;
	obj : Object;
	shelf : CM_RackShelfController;
	weight : CM_MeasurementType;
	weightType : String;

begin

	weight := app.getDefaultMeasurementForType(Type_Weight);


	create lForm;
	lForm.centreWindow;
	app.mousePointer := MousePointer_Default;

	obj := self.frmBlkArea.myDrawingController.allSelectedObjects.first;
	if obj.isKindOf(CM_RackShelfController) then
		maxQty := obj.CM_RackShelfController.maximumWeight;
	elseif obj.isKindOf(CM_IrregularBlockController) then
		shelf := obj.CM_IrregularBlockController.allSubLocations.first();
		if shelf &lt;&gt; null then
			maxQty := shelf.maximumWeight;
		endif;
	endif;
	
	if maxQty = 0 then
		maxQty := 1;
	endif;
	
	lForm.lblTextCaption := app.getErrorString(Weight).cnEcFirstToUpper &amp; ":";
	lForm.msrWeight.visible := true;
	lForm.msrWeight.setup(Type_Weight, self.backColor);
	lForm.msrWeight.tabKey := J_key_Tab;
	
	if weight &lt;&gt; null then																					
		weightType := weight.shortName;																		
		lForm.msrWeight.setValues(app.convertMeasurementForDisplay(weightType, maxQty) &amp; Space &amp; weightType);	
	endif;
	
	
	lForm.txtData.visible := false;
	lForm.bigSize := false;
	lForm.myCaller := self;
	lForm.formCaption := app.getErrorString(Weight);
	lForm.type := self.GetData_Weight;
	lForm.doResize;
	lForm.show;
	
	// ### CALLED BACK is getData()
	
epilog
	mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doLocationSelected" id="26f84e77-db4c-415f-aa39-620aa85517d0">
        <source>doLocationSelected(_location : CM_LocationsController);
//01 July 2008	cnwdw1	
// The user has selected/deselected a location on the design form
vars

begin
	if _location &lt;&gt; null then
		self.btnBlockNew.enabled := false;
		self.btnBlockEdit.enabled := true;
		self.btnBlockDelete.enabled := true;
	else
		self.btnBlockNew.enabled := true;
		self.btnBlockEdit.enabled := false;
		self.btnBlockDelete.enabled := false;
	endif;
end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="doPaste" id="7bdc2934-e759-4eeb-a760-ea23b7bf17fb">
        <updating/>
        <source>doPaste()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2013	cnwndl1	Initial creation	Par 32308

*/

vars

	sourceConts : CM_LCSet;
	lc : CM_LocationsController;
	firstSourceLC : CM_IrregularBlockController;
	sourceLC : CM_IrregularBlockController;
	targetRegion : PointArray;
	offSetPoint : Point;
	targetName : String;
	locationProxy : CM_IrregularBlockController;
	sourceShelf : CM_IrregularBlockController;
	shelfProxy : CM_RackShelfController;
	blockArea : CM_IrregularBlockArea;

begin

	blockArea := self.myProxyObject.CM_IrregularBlockArea;
	if blockArea = null then
		return;
	endif;
	
	create sourceConts transient;
//	self.frmBlkArea.myDrawingController.allSelectedObjects.copy( sourceConts );
	self.frmBlkArea.myDrawingController.allCopiedItems.copy( sourceConts );
	
	create targetRegion transient;
	self.frmBlkArea.myDrawingController.getSelectedRegion(targetRegion);
	
	firstSourceLC := self.mnuPaste.userObject.CM_IrregularBlockController;
	if firstSourceLC = null then
		return;
	endif;
	offSetPoint.setX( targetRegion[1].x - firstSourceLC.region[1].x );
	offSetPoint.setY( targetRegion[1].y - firstSourceLC.region[1].y );
	
	foreach lc in sourceConts do
		sourceLC := lc.CM_IrregularBlockController;
		targetRegion.clear();
		sourceLC.region.copy(targetRegion);
		targetRegion[1].setX( sourceLC.region[1].x + offSetPoint.x );
		targetRegion[1].setY( sourceLC.region[1].y + offSetPoint.y );
		targetRegion[2].setX( sourceLC.region[2].x + offSetPoint.x );
		targetRegion[2].setY( sourceLC.region[2].y + offSetPoint.y );
		
		if not doPasteValidation( targetRegion, blockArea ) then
			//overlaps or is outside area
			continue;
		endif;
		
		targetName := blockArea.getIncrementedLocationName( sourceLC.getID );
		
		create locationProxy transient;
		locationProxy.setProxy(	blockArea,
								targetName,
								targetRegion,
								sourceLC.getColour,	//_colour : Integer;
								sourceLC.defaultCapacity,	//_defaultCapacity : Integer;
								sourceLC.locationType,	//_locationType : Integer;
								sourceLC.maximumWeight,	//_maximumWeight : Real;
								sourceLC.getInterChangeArea	//_myICArea : CM_InterchangeArea
								);
								
		if sourceLC.locationType = GC_RackLocation then
			foreach sourceShelf in sourceLC.allSubLocations do
				create shelfProxy transient;
				shelfProxy.setDefaultProxy( sourceShelf.locationOrdinal, locationProxy, sourceLC ); 
				shelfProxy.setProxy(	null,	//blockAreaProxy : CM_IrregularBlockArea;
										shelfProxy.ident,	//id: String;
										shelfProxy.region,	//region: PointArray;
										sourceShelf.getColour,	//_colour : Integer;
										sourceShelf.defaultCapacity,	//_defaultCapacity : Integer;
										GC_ShelfLocation,	//_locationType : Integer;
										sourceShelf.maximumWeight,	//_maximumWeight : Real;
										sourceShelf.getInterChangeArea	//_myICArea : CM_InterchangeArea
										);
			endforeach;
		endif;
		
		self.frmBlkArea.myDrawingController.addLocation(locationProxy, false); // PAR 32836
		
	endforeach;
	
	self.frmBlkArea.myDrawingController.refreshLocations();

epilog

	delete sourceConts;
	delete targetRegion;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doPasteValidation" id="f0e656e7-5d18-4847-abb0-18f7e3869ac9">
        <source>doPasteValidation( targetRegion : PointArray; blockArea : CM_IrregularBlockArea ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2013	cnwndl1	Initial creation	Par 32308

*/

vars

	location : CM_LocationsController;
	topLeftRect1 : Point;
	bottomRightRect1 : Point;
	topLeftRect2 : Point;
	bottomRightRect2 : Point;

begin

	if targetRegion[1].x &lt; 1
	or targetRegion[1].y &lt; 1
	or targetRegion[2].x &gt; blockArea.columns
	or targetRegion[2].y &gt; blockArea.rows
	then
		// pattern would draw this one outside the area, skip it
		return false;
	endif;
	
	topLeftRect2 := targetRegion[1];
	bottomRightRect2 := targetRegion[2];
	
	foreach location in blockArea.allLocationsControllers do
		topLeftRect1 := location.CM_IrregularBlockController.region.first();
		bottomRightRect1 := location.CM_IrregularBlockController.region.last();
		if not ( 	topLeftRect2.rightOf(bottomRightRect1)
					or topLeftRect2.below(bottomRightRect1)
					or bottomRightRect2.leftOf(topLeftRect1)
					or bottomRightRect2.above(topLeftRect1) 	) then
			//This one would be overlapped
			return false;
		endif;
	endforeach;
	
	return true;

epilog

end;</source>
        <Parameter name="targetRegion" type="PointArray"/>
        <Parameter name="blockArea" type="CM_IrregularBlockArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPreEditValidation" id="a27cf7ba-bd3f-4abf-8954-0fe089bfc9be">
        <updating/>
        <source>doPreEditValidation(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 September 2009	cnwer1	Initial creation

*/

vars

begin
	if self.myCurrentObject &lt;&gt; null then
		if self.cmbTAType.listObject.CM_TerminalAreaType &lt;&gt; null and
			self.cmbTAType.listObject.CM_TerminalAreaType.isGantryInterchangeArea then
			 
			 app.msgBox(app.getErrorString2(GANTRY_IC_MAINT,self.cmbTAType.listObject.CM_TerminalAreaType.description,self.myCurrentObject.CM_GantryInterchangeArea.allAssociatedTerminalAreas.first.id),app.getErrorString(Error),MsgBox_OK_Only);
			 return false;
		endif;
	endif;

	return inheritMethod();
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
