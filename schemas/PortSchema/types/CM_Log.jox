	if self.myOperator &lt;&gt; null and self.myOperator.getLogSpecies(self.speciesCode) = null then
		app.raiseCMException2(ERR_FIELD_SPECIES_CODE, self.speciesCode, 'Species code', 'reasonCode', pControl.myUserObject);
	endif;

end;</source>
