    <JadeMethod name="setSelectedDocketDefs" id="7c315280-f89d-47ff-a7bb-936fab6df983">
        <updating/>
        <source>setSelectedDocketDefs() updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx,
	numRows	: Integer;
	
begin

	self.allSelectedDocketLogDefs.clear;

	numRows := tblSelectData.rows;
	
	foreach idx in 2 to numRows do
		if tblSelectData.accessCell(idx, 1).text = '1' then
			self.allSelectedDocketLogDefs.add(tblSelectData.accessRow(idx).itemObject.CMIF_DocketLogDef);
		endif;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setSelectionData" id="8a3d8a74-19a8-498d-bb88-c34207063a92">
        <updating/>
        <source>setSelectionData() protected, updating;

vars
	def		: CMIF_DocketLogDef;
	display	: String;
	idx		: Integer;


begin

	// Set splitter to half and half.
	splitContainer.showLeftControl(50, true);
	self.tblSelectData.rows := self.tblSelectData.fixedRows;
	// If we have something to display then build table.
	if self.allDocketLogDef.size &gt; 0 then
											  
		if self.selection = LOGSPECS then
//			self.tblSelectData.columns := 10;
			self.tblSelectData.showColumnByColName(ETRow_BgpPic);
//			self.tblSelectData.accessColumn(1).inputType := Table.InputType_CheckBox;
//			display := '....' &amp; Tab &amp; display;
		else
			self.tblSelectData.hideColumnByColName(ETRow_BgpPic);
//			self.tblSelectData.columns := 9;
		endif;

		if self.selection = LOGSPECS then
	//		self.tblSelectData.accessColumn(1).inputType := Table.InputType_CheckBox;
	//		self.tblSelectData.accessCell(1,1).inputType := Table.InputType_TextBox;
	//		self.tblSelectData.accessCell(1,1).text := '....';
		endif;
		
		foreach def in allDocketLogDef do
			display := def.displayLogs(self.tblSelectData.allTblDataEntRows);
			idx := self.tblSelectData.addItem(display);
			self.tblSelectData.accessRow(idx).itemObject := def;
		endforeach;
		self.selectdocketLocation(2);
		self.tblSelectData.tabStop := true;
	else
		self.tblSelectData.tabStop := false;
		self.txtDetails.text := null;
	endif;

	// 17/09/2008 cnwar2 #17957 (CCMS1095)
	if self.selection = LOGLOCATDOCKET then
		self.tblSelectData.showColumnByColName(ETRow_SelectedDocket);
		self.tblSelectData.showColumnByColName(ETRow_Docket);
	else
		self.tblSelectData.hideColumnByColName(ETRow_SelectedDocket);
		self.tblSelectData.hideColumnByColName(ETRow_Docket);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
