    <JadeMethod name="importFromXMLDocReference" id="b3449d7d-7fe8-4671-ab38-4708a0570e50">
        <updating/>
        <source>importFromXMLDocReference(_property: Property; _xmlElement: JadeXMLElement input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 April 2011	cnwer1	Initial creation

*/

vars
	allSubDeckElements : JadeXMLElementArray;
	subDeckElement 	: JadeXMLElement;
	subDeck			: CM_DeckVesselSub;
	allDeckItemElements : JadeXMLElementArray;
begin
	
	if _property = CM_DeckVessel::allSubDecks then
		create allSubDeckElements transient;
		_xmlElement.getAllElementsByTagName(CM_DeckVesselSub.name,allSubDeckElements);
		foreach subDeckElement in allSubDeckElements do
			create subDeck transient;
			subDeck.setMyParentDeck(self);
			subDeck.importFromXMLDoc(subDeckElement);
		endforeach;
	else
		inheritMethod(_property, _xmlElement);
	endif;
epilog
	delete allSubDeckElements;
	delete allDeckItemElements;
end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="ba0a6603-03e9-4bb1-94ef-d50f36339808">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
13 April 2011	cnwer1	Initial creation CCMS 1031
// 20/04/2011	cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
//						trying to create the proxy
*/

vars
	pxyDeckVessel : CM_DeckVessel;
	completedOK		: Boolean;
begin
	pxyDeckVessel:= inheritMethod();
	pxyDeckVessel.myROROStructure:=self.myROROStructure;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyDeckVessel;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyDeckVessel;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0eed3c21-0812-4e84-b5c6-a71bab6b3884">
        <updating/>
        <source>setForCreate(_proxyDeck: CM_DeckVessel input; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	lastDeck : CM_Deck;
	newOrdinal : Integer;
begin
	self.myROROStructure:=_proxyDeck.myROROStructure;

	if self.myROROStructure  &lt;&gt; null then
		lastDeck:= self.myROROStructure.allDecks.last;
		if lastDeck = null then
			self.ordinal:=1;
		else
			self.ordinal:=lastDeck.ordinal+1;
		endif;
	
	endif;
	
	inheritMethod(_proxyDeck, _passport);

epilog
	
end;</source>
        <Parameter name="_proxyDeck" type="CM_DeckVessel" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateImport" id="8a88203c-e71b-4712-84f3-3ed1812b1184">
        <updating/>
        <source>setForCreateImport(_proxyDeck: CM_DeckVessel input; 
					_passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 April 2011	cnwer1	Initial creation

*/

vars
	pxySubDeck : CM_DeckVessel;
	realDeck 	: CM_DeckVesselSub;
	lastDeck   : CM_Deck;
begin
	

	if self.myROROStructure  &lt;&gt; null then
		lastDeck:= self.myROROStructure.allDecks.last;
		if lastDeck = null then
			self.ordinal:=1;
		else
			self.ordinal:=lastDeck.ordinal+1;
		endif;
	
	endif;


	inheritMethod(_proxyDeck, _passport);

	if _passport.hasErrors then
		return;
	endif;
	
	foreach pxySubDeck in _proxyDeck.allSubDecks do
		create realDeck persistent;
		realDeck.setMyParentDeck(self);
		realDeck.setForCreateImport(pxySubDeck.CM_DeckVesselSub,_passport);
		
		if _passport.hasErrors then
			return;
		endif;
	
	endforeach;
	
	
	
	// PAR 28848
	self.setLabelsOnAllLanes();
	self.setLabelsOnAllLocations();

	if 	self.myROROStructure &lt;&gt; null then
		if _proxyDeck.pxyGetRealObject = null then
			app.myEventManager.createSingleObjInfoNoteEvt(self.myROROStructure, EVENT_VESSEL_DECK_CREATE, self);		
		else
			app.myEventManager.createSingleObjInfoNoteEvt(self.myROROStructure, EVENT_VESSEL_DECK_UPDATE, self);	
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_proxyDeck" type="CM_DeckVessel" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a5e7d5c7-5801-4d5b-a197-0f00c40b1492">
        <updating/>
