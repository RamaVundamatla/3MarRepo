    <JadeMethod name="displayUnpack" id="104b66fc-ea19-42b9-bc74-83193b33c12d">
        <source>displayUnpack(_wodtl : CM_WodUnpack) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 Aug 2009	cnwmd1	Initial creation
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars
	ta : CM_TerminalArea;
begin
	self.shtUnpack.showMySheet();
	
