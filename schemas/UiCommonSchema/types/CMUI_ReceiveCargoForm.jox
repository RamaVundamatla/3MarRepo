    <JadeMethod name="loadCombos" id="53e23012-1859-432f-a4be-e124570bda92">
        <source>loadCombos() protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/07/2009	cnwdap1	Initial creation
13/10/2009	cnwdap1	PAR #20950 Correct the defaulting of the Transport Mode combo
19/02/2010	cnwdap1	PAR #21707 Default commodity to the defauly for the cargo type if we have a cargo type
18/05/2010 	cnwdap1	PAR #23645 CCMS 1116 Tranship changes
11/08/2011	cnwdap1	PAR #27972 Bulk release type no longer translatable, replaced by string constants
12/08/2013	cnwdap1	PAR #32123 Added Colour list table
12/09/2013	cnwdap1	PAR #32215 Added Vehicle Make, Vehicle Model and Vehicle Type combos
27/11/2014  cnwma1  PAR #35299 Cannot set Non Container Cargo to Remain on Board in Gate
13/05/2015  cnwma1  PAR #36217 Load Port not Copied from BOL
23/09/2015  cnwma1  PAR #36893 Getting error while doing the Road Gate Operations (Receival of Full and Empty Containers)
15/03/2016	cnwdap1	PAR #37606 "Not available for entry" customs agent and iso type
31/08/17	jlgns1	6735 POL - [Fwd: ##5431## : 8.5.1.090 Not saving VGM authorised details]
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores 
02/05/2022	jlizm1	TFS 53084 GPHA revceival/release of tranship cargo 
20 may 2022	navgm20 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
16 Aug 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
19/12/2022	jlika1	TFS 55584 - HS Code Combobox Usage
21 Feb 2023 navtnr20	TFS CR 55648 Task 55663: UI - Contract Id
14/11/2023	jlika1	TFS 61131 61013 CUX | Cargo Priority - Prenotes and Add Cargo Forms
01/10/2025	navdap1	MTN-36141 AAT | Rotabox Creation (EDI/API/Manual)
*/
vars
	assistant 			: CMUI_Assistant;
	defaultCargoType	: Integer;
	itemRef				: CM_BookingRefItem;
	idx					: Integer;
	//logType				: CM_CargoType;
	removeType			: CM_CargoType;//cnwas3 PAR 20965
	defaultedCargoType	: CM_CargoType;
	imex				: CM_IMEXStatus;
	obj : CM_Object;
	isBoxcar : Boolean;
	isoType				: CM_ISOType;								// PAR #37606
	customsAgent		: CM_CustomsAgent;							// PAR #37606
	
begin
	assistant := self.myAssistant;
	if self.myParentForm &lt;&gt; null and self.myParentForm.class.name = "YRD_LocationEnquiryFrm" then
		obj := self.myParentForm.getPropertyValue("myStartupObject").CM_Object;
		if obj &lt;&gt; null and obj.isKindOf( CM_BoxcarWagonController ) then
			isBoxcar := true;
		endif;
	endif;
	if isBoxcar then
		defaultCargoType := null;
	elseif not self.isGeneralCargo then
		//defaultCargoType := app.myPassport.getDefaultCargoBOLTypeId();  //23/09/2015 cnwma1 PAR #36893
		defaultCargoType := TI_CargoType_Container; 				      //23/09/2015 cnwma1 PAR #36893
	endif;
	// epr par 34945 17/10/14 including general cargo &amp; bol items just results in 1086 exceptions so ignore
	assistant.comboBoxCargoBolType(cmbType.getEmbeddedControl.ComboBox, defaultCargoType, true, false, true, true);
	// MTN-36141 Load Contents Cargo Type combo as well
	assistant.comboBoxCargoBolType(self.cmbContentsCargoType.getEmbeddedControl.ComboBox, null, true, false, true, true);

	// remove LOG from the combo - old gate will still be used for these
	removeType := app.myRoot.allCargoTypesById[TI_CargoType_Log];
	idx := cmbType.getEmbeddedControl.ComboBox.findObject(removeType);
	if idx &gt; null then
		cmbType.getEmbeddedControl.ComboBox.removeItem(idx);
	endif;
	// MTN-36141 And remove LOG from Contents Cargo Type as well
	idx := self.cmbContentsCargoType.getEmbeddedControl.ComboBox.findObject(removeType);
	if idx &gt; null then
		self.cmbContentsCargoType.getEmbeddedControl.ComboBox.removeItem(idx);
	endif;
	
	// only remove ISO container for general cargo
// TFS 6536	if self.isGeneralCargo and not self.isOnshipForm then
	if self.isGeneralCargo and not (self.isOnshipForm or self.isOnsiteForm) then // TFS 6536 added onsite
		removeType := app.myRoot.allCargoTypesById[TI_CargoType_Container];//cnwas3 PAR 20965 begin
		if not removeType.isDynamicallyCreated then  // PAR 36449
			idx := cmbType.getEmbeddedControl.ComboBox.findObject(removeType);//cnecgetduplicate
			if idx &gt; null then
				cmbType.getEmbeddedControl.ComboBox.removeItem(idx);
			endif;																//cnwas3 PAR 20965 end
		endif;
		cmbType.getEmbeddedControl.ComboBox.listObject := null;
		cmbType.getEmbeddedControl.ComboBox.listIndex := -1;
	endif;
	// MTN-36141 Remove Container from Contents Cargo Type combo - we never want Container to be in this list
	removeType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	if not removeType.isDynamicallyCreated then
		idx := self.cmbContentsCargoType.getEmbeddedControl.ComboBox.findObject(removeType);
		if idx &gt; null then
			self.cmbContentsCargoType.getEmbeddedControl.ComboBox.removeItem(idx);
		endif;
	endif;

	//if we've come from the rail form, we have a cargo type - set it now
	if self.isRailPreNoteForm and self.myCargoType &lt;&gt; null then
		cmbType.setForObject(self.myCargoType);
	endif;
	
	// Booking Ref Items
	if self.myProxyTrackedItem &lt;&gt; null and self.myProxyTrackedItem.myBookingRef &lt;&gt; null then
		foreach itemRef in self.myProxyTrackedItem.myBookingRef.allBookingRefItems discreteLock do
			cmbBRItem.addItemObject(itemRef.myCargoType.description, itemRef);
			if itemRef.myCargoType.description = self.myProxyTrackedItem.myCargoType.description then
				cmbBRItem.setForObject(itemRef);
			endif;
		endforeach;
	endif;
	
	// ISO Types
	//cmbISOType.listCollection(app.myRoot.allISOTypes, true, 0);							// PAR #37606
	foreach isoType in app.myRoot.allISOTypes discreteLock do								// PAR #37606
		if isoType.isNotAvailableForEntry then												// PAR #37606
			continue;																		// PAR #37606
		endif;																				// PAR #37606
		self.cmbISOType.addItemObject(isoType.code &amp; Tab &amp; isoType.description, isoType);	// PAR #37606
	endforeach;																				// PAR #37606
	
	// IMEX Statuses - PAR #23645 CCMS 1116 take Tranship out as an option
	//cmbImexStatus.listCollection(app.myRoot.allImexStatuses, true, 0);
	// 28029 Nov 2011 take out Remain on Board as well
	foreach imex in app.myRoot.allImexStatuses where imex.code &lt;&gt; TI_IMEX_STATUS_TRANSHIP do
		//epr CCMS 1386 changes for Remain on board the truck cargo	
		if 	imex.code = TI_IMEX_STATUS_REMAINONBOARD then
			if not (self.isFlexiGateForm  ) then   // 27/11/2014 cnwma1 PAR#35299
				 continue;
			endif;
		endif;
		idx := cmbImexStatus.addItemObject(imex.description, imex);
		
		//16 Aug 2021	NDL	TFS 51771
		if imex.code = TI_IMEX_STATUS_REMAINONBOARD then
			self.hideROBforExportPN( idx );
		endif;
		
	endforeach;
	
	if app.myRoot.allowTranshipInterModal then								// TFS 53084
		if self.isPreNoteForm or self.isFlexiGateForm then					// TFS 53084
			imex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_TRANSHIP];	// TFS 53084
			if imex &lt;&gt; null then											// TFS 53084
				cmbImexStatus.addItemObject(imex.description, imex);		// TFS 53084
			endif;
		endif;
	endif;
	
	// Voyage
	assistant.comboBoxVoyageCurrent(cmbVoyageCode,
									null,
									true,
									false,
									false,
									true,
									true,
									false,
									true,
									false,
									true);
	
	//Operator
	//cmbOperator.listCollection(app.myRoot.allOperators, true, 0);
	
	// Destination Port
	self.cmbDestPort.myAssistant := assistant;
	// Discharge port	
	self.cmbDischargePort.myAssistant := assistant;
	// Load port	
	self.cmbLoadPortCombo.myAssistant := assistant;						// 13/05/2015 cnwma1 PAR #36217
	//Tranship ports
	self.cmbTranshipPort.myAssistant := assistant;
	//Port of Origin
	self.cmbPortOfOriginCombo.myAssistant := assistant;	//jlika1 59741
	
	// load Optional Ports List
	assistant.listTableDischarge(self.lstOptionalPorts, null, null);
	
	//epr TFS 6535 29/8/17 
	assistant.comboBoxConsignor(cmbConsignee.getEmbeddedControl.ComboBox,null,CONSIGNEE);
	assistant.comboBoxConsignor(cmbConsignor.getEmbeddedControl.ComboBox,null,CONSIGNOR);
	assistant.comboBoxConsignor(cmbFreightFwdr.getEmbeddedControl.ComboBox,null,FREIGHT_FORWARDER);
		
	// Commodities
	defaultedCargoType := self.cmbType.getObject().CM_CargoType;
	if defaultedCargoType &lt;&gt; null then
		cmbCommodity.listCollection(defaultedCargoType.allCommodities, true, 0);
	else
		cmbCommodity.listCollection(app.myRoot.allCommodities, true, 0);
	endif;
	
	// Hazards 
	self.lstHazardList.loadHazardObjects;
	self.myAssistant.resetHazardListTable(self.lstHazardList);
	
	// Special Stow 
	self.myAssistant.comboSpecialStow(cmbSpecialStow.getEmbeddedControl.ComboBox);
	// Shipping LIne
	self.myAssistant.comboBoxShippingLine(self.cmbShippingLine.getEmbeddedControl.ComboBox, null);	//20 may 2022 navgm20 TFS 53204
	// Country of Origin
	self.myAssistant.comboBoxCountry(self.cmbCtryOfOrigin.getEmbeddedControl.ComboBox, null);	// 16.08.2022 navak20 TFS 54441
	
	// Special Lift
	assistant.listTableSpecialLift(lstSpecialLift);

	// Availability Grade
	assistant.comboBoxMTGrade(cmbMTGrade.getEmbeddedControl.ComboBox, null);
	
	// Cooling Types 
	self.doBuildCoolingTypes(cmbCoolingType.getEmbeddedControl.ComboBox);
	
	// Voltage Types
	self.doBuildVoltageTypes(cmbVoltageType.getEmbeddedControl.ComboBox);
	
	// Stops
	assistant.listTableStopsTable(self.lstAllStops, self.myTerminal, true);
	
	// ToDo Tasks
	assistant.listTableToDoTasks(self.lstToDoTasks, self.myTerminal);
	
	// Customs Agent
	//assistant.comboBoxCustomsAgent(cmbCustomsAgent.getEmbeddedControl.ComboBox, null);				// PAR #37606
	foreach customsAgent in app.myRoot.allCustomsAgents discreteLock do									// PAR #37606
		if customsAgent.isNotAvailableForEntry then														// PAR #37606
			continue;																					// PAR #37606
		endif;																							// PAR #37606
		self.cmbCustomsAgent.addItemObject(customsAgent.code &amp; Tab &amp; customsAgent.name, customsAgent);	// PAR #37606
	endforeach;																							// PAR #37606
	
	// Transport Mode
	if self.isMakeLCLForm or self.isOnshipForm or self.transportMode = TI_TRANSMODE_SHIP_STR then // par 22556 10.3.2010 cnwrd1
		assistant.comboBoxTransportModes(cmbTransportMode.getEmbeddedControl.ComboBox, null); 
	else
		assistant.comboBoxTransportModesNoShip(cmbTransportMode.getEmbeddedControl.ComboBox, null); 
	endif;// par 22556 10.3.2010 cnwrd1 
	
	// select road and disable if coming from flexi-gate
	// select rail and disable if coming from rail form
	// select ship and disable if coming from onship cargo
	self.cmbTransportMode.setForText(TI_TRANSMODE_ROAD_STR);
	if self.isFlexiGateForm then
		self.cmbTransportMode.enabled := false;
	elseif self.isRailPreNoteForm then
		self.cmbTransportMode.setForText(TI_TRANSMODE_RAIL_STR);
		self.cmbTransportMode.enabled := false;
	elseif self.isOnshipForm then
		self.cmbTransportMode.setForText(TI_TRANSMODE_SHIP_STR);
		self.cmbTransportMode.enabled := false;
	elseif self.transportMode &lt;&gt; null and not self.transportMode.isOneOf(app.getErrorString(Road_rail), app.getErrorString(View_Additions)) then
		self.cmbTransportMode.setValue(self.transportMode);
	else
		// if all else fails, default to road
		//self.cmbTransportMode.setForText(app.getErrorString(BR_TYPE_DESCR_ROAD));	// PAR #27972
		self.cmbTransportMode.setForText(TI_TRANSMODE_ROAD_STR);					// PAR #27972
	endif;

	// Carrier
	cmbCarrier.listCollection(app.myRoot.allCarriers, true, 0);//+cnwas3 par 24344
	// Sub-Terminal
	assistant.comboBoxSubTerminal(cmbSubTerminal.getEmbeddedControl.ComboBox, null, self.myTerminal);
	
	// SubCargo Type (leave till Cargo Type chosen)
	
	// Business Unit
	assistant.comboBoxBusinessUnit(cmbBusUnit.getEmbeddedControl.ComboBox, null);
	
	// Attachments - default to blank entry
	if self.isVVRUpdatable() then
		cmbAttachments.addItem("** New **");
		cmbAttachments.listIndex := 1;
	endif;

	// Colour												// PAR #32123
	assistant.listTableColour(self.lstColourList);			// PAR #32123
	
	self.cmbVehicleMake.listCollection(app.myDutyDocRoot.allVehicleMakes, true, 1);		// PAR #32215
	self.cmbVehicleModel.listCollection(app.myDutyDocRoot.allVehicleModels, true, 1);	// PAR #32215
	self.cmbVehicleType.listCollection(app.myDutyDocRoot.allVehicleTypes, true, 1);		// PAR #32215
	
	assistant.comboBoxWagonClass(self.cmbWagonClass.getEmbeddedControl.ComboBox, null );	//12 May 2014	NDL	Par 33615
	//TFS 6735 jlgns1 31/08/2017 
	//assistant.listWeighAuthorityCoys( self.cmbWeightAuth.getEmbeddedControl.ComboBox, self.myTerminal );
	
	assistant.comboBoxStevedore(self.cmbStevedore.getEmbeddedControl.ComboBox,null); //02.10.2020 cnwma1 TFS #50112
	self.loadHSCodeCombo();

	 // ### TFS BUG 57332 29MAR2023 NAVAB1 self.loadInvContract();	//21.02.2023 navtnr20 TFS CR 55648 Task 55663
	
	assistant.comboBoxSortingMethods(self.cmbSortingMethod.getEmbeddedControl.ComboBox, null);	// ### TFS 57812 (58439) 15Jun2023 NAVPW1
	
	assistant.comboBoxCustomerPriority(self.cmbCustPriority.getEmbeddedControl.ComboBox, null);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadGeneratorAndTrailerCombos" id="07fe6789-5267-4051-ad70-65076db81075">
        <updating/>
        <source>loadGeneratorAndTrailerCombos(_cargoType : CM_CargoType) updating, protected;
/*
Date		Who		Reason
16 September 2009	cnwdap1	Initial creation
06 Dec 2012			cnwcs5	par 39852 - add isNotAvailableForEntry 
*/
vars
	trailerType : CM_TILCType;
	generatorType : CM_GeneratorType;
begin
	if _cargoType &lt;&gt; null then
		if _cargoType.isTrailer then
			trailerType := self.cmbTrailerType.getObject().CM_TILCType;
			
			self.cmbTrailerType.listCollection(_cargoType.allTILCTypes, true, 1);
			
			self.cmbTrailerType.setForObject(trailerType);
			
		elseif _cargoType.id = TI_CargoType_Generator  then
			generatorType := self.cmbGeneratorType.getObject().CM_GeneratorType;
			
			self.cmbGeneratorType.listCollection(app.myRoot.allGeneratorTypes, true, 1);
			
			self.cmbGeneratorType.setForObject(generatorType);
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="loadHSCodeCombo" id="31d62972-870c-49c4-9563-10b28dafa101">
        <source>loadHSCodeCombo();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 19 December 2022
TFS#		: 55584
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	hsCode : CM_HarmonizedSystem;
begin
	self.cmbHSCode.clear();
	
	self.cmbHSCode.addItem("");
	
	foreach hsCode in app.myRoot.allHSCodesActive do
			self.cmbHSCode.addItemObject(hsCode.getDisplayString(), hsCode);		
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="lstAllStops_displayRow" id="64d9cafe-7b12-4c6b-a94a-5beb87fe48d6">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstAllStops_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 July 2009	cnwdap1	Initial creation

*/

vars
	selected	: Boolean;
	
begin
	selected := table.CMUI_ListTable.allSelectedObjects.includes(obj);
	return self.myAssistant.displayEntryStopsTableList(obj.CM_StopsTable, selected, true);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="lstAllStops_lostFocus" id="56afd8c3-f855-445b-bcba-d7d322cc9f9d">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstAllStops_lostFocus(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 July 2009	cnwdap1	Initial creation

*/

vars

begin
	self.lstStops.hasLostFocus(self.lstStops);
epilog

