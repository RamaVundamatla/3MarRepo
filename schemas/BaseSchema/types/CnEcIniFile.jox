    <JadeMethod name="createSection" id="a6ee7eae-bb3b-4dea-ba73-c7db1450e40e">
        <source>createSection(pSectionName:String):CnEcIniSection;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		Create a new section in the initialization file.
//
// Parameters:	pSectionName - The name of the new section.
//
// Returns:		The new section object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iniSectionObj	: CnEcIniSection;

begin
	on Exception do cnEcIniExceptionHandler(exception);

	create iniSectionObj transient;
	iniSectionObj.set(pSectionName);
	iniSectionObj.setIniFile(self);
	return iniSectionObj;
end;</source>
        <Parameter name="pSectionName" type="String"/>
        <ReturnType type="CnEcIniSection"/>
    </JadeMethod>
    <JadeMethod name="deleteIniSection" id="6010ef45-9842-47d5-808b-85e7fc208ee1">
        <source>deleteIniSection(pSectionName:String);
// --------------------------------------------------------------------------------
// Created:		01 February 2000 by cnwdad1
//
// Purpose:		Delete a section from the initialization file.
//
// Parameters:	pSectionName - The name of the section to delete.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iniSectionObj	: CnEcIniSection;

begin
	iniSectionObj	:=	self.allIniSections[pSectionName];

	if iniSectionObj &lt;&gt; null then
		if app.setProfileString(self.fileName, pSectionName, ProfileRemoveSection, "") then
			delete iniSectionObj;
		endif;
	endif;
end;</source>
        <Parameter name="pSectionName" type="String"/>
    </JadeMethod>
    <JadeMethod name="getKeyValue" id="9db19c23-ec85-468e-99bd-7fbbdbd23db9">
        <source>getKeyValue(pSectionName:String; pKeyName:String; pDefaultValue:String):String;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		Returns the value of an initialization  section key.
//
// Parameters:	pSectionName - The name of the section containing the key.
//				pKeyName - The name of the key who's value to return.
//				pDefaultValue - The default value to use if the key does not exist.
//
// Returns:		The value of the section key.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return app.getProfileString(self.fileName, pSectionName, pKeyName, pDefaultValue);
end;</source>
        <Parameter name="pSectionName" type="String"/>
        <Parameter name="pKeyName" type="String"/>
        <Parameter name="pDefaultValue" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="set" id="1a3677f8-6247-48cb-b8ab-2102b20cd82c">
        <updating/>
        <source>set(pFileName:String) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		Sets the name of the initialization file.
//
// Parameters:	pFileName - The name of the file.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.fileName &lt;&gt; pFileName then
		self.fileName	:=	pFileName;
	endif;
end;</source>
        <Parameter name="pFileName" type="String"/>
    </JadeMethod>
</Class>
