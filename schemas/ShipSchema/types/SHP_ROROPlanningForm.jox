    </JadeMethod>
    <JadeMethod name="createLoadColCodeGC" id="7fea31f8-6da3-44a9-8cec-81e20e78fd27">
        <updating/>
        <source>createLoadColCodeGC(_sides : Integer) updating;
/*
Purpose:			
Date		Who		Reason
29 July 2011	cnwab1	Initial creation
*/

vars
	x1,y1 : Decimal[12,2];
	theReturn : Integer;
begin
		// Cargo Position (top left) in metres
		x1 := (((self.origMouseX/self.scaleFactor)/ROROStructurePixelsPerMetre) - (ROROStructureRearLine /ROROStructurePixelsPerMetre));
		y1 := (-1 *  ((ROROStructureCentreLine/ROROStructurePixelsPerMetre) - ((self.origMouseY/self.scaleFactor) /ROROStructurePixelsPerMetre)));


		while true do
			app.myTrxCA.trxCreateROROGCLoadCC(null, _sides, x1,y1, self.myCurrentDeck, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(SHP_Load_Colour_Coding) &amp; " " &amp; app.getErrorString(GeneralCargo), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;

epilog

end;</source>
        <Parameter name="_sides" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createLoadColCodeOOTL" id="8fdcf677-c6d0-4a9f-9c98-93993f670123">
        <updating/>
        <source>createLoadColCodeOOTL(_is40 : Boolean) updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	x1,y1 : Decimal[12,2];
	theReturn : Integer;
begin
		// Cargo Position (top left) in metres
		x1 := (((self.origMouseX/self.scaleFactor)/ROROStructurePixelsPerMetre) - (ROROStructureRearLine /ROROStructurePixelsPerMetre));
		y1 := (-1 *  ((ROROStructureCentreLine/ROROStructurePixelsPerMetre) - ((self.origMouseY/self.scaleFactor) /ROROStructurePixelsPerMetre)));


		while true do
			app.myTrxCA.trxCreateROROOOTLLoadCC(null, _is40, true, x1,y1, self.myCurrentDeck, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(SHP_Load_Colour_Coding) &amp; " " &amp; app.getErrorString(Ootl).toUpper, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;

epilog

end;</source>
        <Parameter name="_is40" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createPhotoThumbnail" id="65871b74-43c4-4363-92f1-e34930fa9a25">
        <updating/>
        <source>createPhotoThumbnail(_content : Binary; _top : Real; _left : Real; _width : Real; _height : Real ):Frame updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	#cnwdz2	 par21808

*/

vars
	frame : Frame;
	thumbnail : Picture;
begin
	//create frame transient;
	
	frame := self.frmForDeckPic.cloneSelf(true);
	/*
	frame.borderStyle := Frame.BorderStyle_None;
	frame.alignChildren := Frame.AlignChildren_All;
	frame.alignContainer := Frame.AlignContainer_None;
	frame.autoRedraw := true;
	frame.bevelInner := Frame.Bevel_None;
	frame.bevelInnerWidth := 0;
	frame.bevelOuter := Frame.Bevel_None;
	frame.bevelOuterWidth := 0;
	frame.ignoreSkin := true;
	frame.boundaryColor := self.frmPhotoThumb.backColor;
	frame.boundaryWidth := 2;
	frame.boundaryBrush := Frame.BoundaryBrush_Solid;
	frame.backColor := self.frmPhotoThumb.backColor;
	frame.transparent := false;
	*/
	self.addControl(frame);
	frame.backColor := self.frmPhotoThumb.backColor;
	frame.autoRedraw := true;
	frame.boundaryWidth := 2;
	frame.left := _left;
	frame.top := _top;
	frame.width := _width;
	frame.height := _height;
	frame.drawPictureAt(_content,1,1);
	frame.setEventMapping('click', 'doDeckClick');
	
	
	/*
	create thumbnail transient;
	thumbnail.parent := frame;
	thumbnail.borderStyle := Picture.BorderStyle_None;
	thumbnail.stretch := Picture.Stretch_ControlTo;
	thumbnail.transparent := false;
	thumbnail.picture := _content;
	self.addControl(thumbnail);
	thumbnail.setEventMapping('click', 'doDeckClick');
	*/
	

	return frame;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_content" type="Binary"/>
        <Parameter name="_top" type="Real"/>
        <Parameter name="_left" type="Real"/>
        <Parameter name="_width" type="Real"/>
        <Parameter name="_height" type="Real"/>
        <ReturnType type="Frame"/>
    </JadeMethod>
    <JadeMethod name="createQuickCargo" id="cc613dba-c8f3-4575-b435-7a6b7639113b">
        <source>createQuickCargo(_where : CM_DeckItem; _fill : Boolean);
/*
Purpose:			
Date		Who		Reason
10 June 2011	cnwab1	Initial creation
*/

vars
	is40 : Boolean;
	obj : Object;
begin
	is40 := app.msgBox(app.getErrorString1(Create_footers,"40"),app.getErrorString(Create_quick_roro_containers),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes;
		
	foreach obj in self.myROROPlanDrawController.allSelectedObjects do
		if obj.isKindOf(CM_ROROLocnDefnVoyage) then
			if not self.myCurrentRORO.createQuickCargo(obj.CM_ROROLocnDefnVoyage, is40, _fill, "", "GENL") then
				app.msgBox(app.getErrorString(Cargo_not_created),app.getErrorString(No_new_cargo), MsgBox_OK_Only);
			endif;
	
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_where" type="CM_DeckItem"/>
        <Parameter name="_fill" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createQuickCargoGC" id="cbbba3b3-3755-4537-bb4e-8580ecb6b684">
        <updating/>
        <source>createQuickCargoGC(menuItem: MenuItem input) updating;
/*
Purpose:			
Date		Who		Reason
08 July 2011	cnwab1	Initial creation
*/

vars

	x1,y1 : Decimal[12,2];
	ct : CM_CargoType;
begin
	ct	:= self.myTerminal.getFirstNonSystemCargoType().CM_CargoType;
	
	if menuItem.userObject.isKindOf(CM_ROROGCDefnVoyage) then
		if not self.myCurrentRORO.createQuickCargoGC(menuItem.userObject.CM_ROROGCDefnVoyage,ct,0,0,null, 1) then
			app.msgBox(app.getErrorString(GeneralCargo) &amp; " " &amp; app.getErrorString(Cargo_not_created),app.getErrorString(No_new) &amp; " " &amp; app.getErrorString(CMQF_GeneralCargo), MsgBox_OK_Only + MsgBox_Information_Icon);
			app.myPassport.inspect;
		endif;
	else
		// Cargo Position (top left) in metres
		x1 := (((self.origMouseX/self.scaleFactor)/ROROStructurePixelsPerMetre) - (ROROStructureRearLine /ROROStructurePixelsPerMetre));
		y1 := (-1 *  ((ROROStructureCentreLine/ROROStructurePixelsPerMetre) - ((self.origMouseY/self.scaleFactor) /ROROStructurePixelsPerMetre)));
					
		
		if not self.myCurrentRORO.createQuickCargoGC(null,ct,x1,y1,self.myCurrentDeck, 1) then
			app.msgBox(app.getErrorString(GeneralCargo) &amp; " " &amp; app.getErrorString(Cargo_not_created),app.getErrorString(No_new) &amp; " " &amp; app.getErrorString(CMQF_GeneralCargo), MsgBox_OK_Only + MsgBox_Information_Icon);
			app.myPassport.inspect;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createQuickCargoLane" id="3df79126-12da-48df-98c7-c741e1b38eba">
        <updating/>
        <source>createQuickCargoLane(menuItem: MenuItem input) updating;
/*
Purpose:			
Date				Who			Reason
NOVEMBER 2011		CNWAB1		Initial creation
*/


vars

	x1,y1 : Decimal[12,2];
	ct : CM_CargoType;
	newDefnID : String;
	newDefnPoints : DecimalArray;
begin

	if menuItem.helpKeyword = "CM_ROROEquipment" then
		create newDefnPoints transient;
		// Cargo Position (top left) in metres
		x1 := (((self.origMouseX/self.scaleFactor)/ROROStructurePixelsPerMetre) - (ROROStructureRearLine /ROROStructurePixelsPerMetre));
		y1 := (-1 *  ((ROROStructureCentreLine/ROROStructurePixelsPerMetre) - ((self.origMouseY/self.scaleFactor) /ROROStructurePixelsPerMetre)));
	
		newDefnPoints.add(x1); newDefnPoints.add(y1);
		newDefnPoints.add(x1 + 20); newDefnPoints.add(y1);
		newDefnPoints.add(x1 + 20); newDefnPoints.add(y1 + 10);
		newDefnPoints.add(x1); newDefnPoints.add(y1 + 10);
		newDefnPoints.add(x1); newDefnPoints.add(y1);
		newDefnID := self.myCurrentDeck.getLabelForNewGCLocation();
		
		if app.myTrxCA.trxCreateROROCargoLocation(newDefnID,  CM_ROROEquipment, 23000, newDefnPoints, self.myCurrentDeck, 10, false, app.myPassport) = null then
				app.myPassport.inspect;
		endif;	
	else
		ct	:= self.myTerminal.getFirstNonSystemCargoType().CM_CargoType;
		
		if menuItem.userObject.isKindOf(CM_ROROLanePositionDefn) then
			if not self.myCurrentRORO.createQuickCargoLane(menuItem.userObject.CM_ROROLanePositionDefn,ct,0,0,null, 1) then
				app.msgBox(app.getErrorString(GeneralCargo) &amp; " " &amp; app.getErrorString(Cargo_not_created),app.getErrorString(No_new) &amp; " " &amp; app.getErrorString(CMQF_GeneralCargo), MsgBox_OK_Only + MsgBox_Information_Icon);
				app.myPassport.inspect;
			endif;
		elseif menuItem.userObject.isKindOf(CM_ROROLaneDefnVoyage) then
			if not self.myCurrentRORO.createQuickCargoLane(menuItem.userObject.CM_ROROLaneDefnVoyage,ct,0,0,null, 1) then
				app.msgBox(app.getErrorString(GeneralCargo) &amp; " " &amp; app.getErrorString(Cargo_not_created),app.getErrorString(No_new) &amp; " " &amp; app.getErrorString(CMQF_GeneralCargo), MsgBox_OK_Only + MsgBox_Information_Icon);
				app.myPassport.inspect;
			endif;
		endif;
	endif;
epilog
delete newDefnPoints;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createQuickCargoOOTL" id="36227229-f92a-45fd-8c90-bf2985146f52">
        <updating/>
        <source>createQuickCargoOOTL(menuItem: MenuItem input) updating;
/*
Purpose:			
