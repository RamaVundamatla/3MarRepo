<Class name="CM_AutoWarningAgent" id="e71b0c26-0bbf-4cac-9786-d0500ffd7f40">
    <superclass name="CM_Agent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="allCMIFLastRanInfos" id="af039ca7-8d70-45d6-a749-b4ef92dbde6d">
        <kind>parent</kind>
        <updateMode>automatic</updateMode>
        <type name="CMIF_BGPLastRanInfoDict"/>
        <access>readonly</access>
        <Inverse name="CMIF_BGPLastRanInfo::myAutoWarningAgent"/>
    </ExplicitInverseRef>
    <JadeMethod name="actionEvent" id="28dec6c3-6fab-4061-a3de-6bf6e2a2b96b">
        <updating/>
        <source>actionEvent(_eventType: Integer; _theObject: Object; _userInfo : Any) updating;
// -------------------------------------------
// Created 15 February 2006 by cnwdvb1
// -------------------------------------------
vars

	info	: CMIF_BGPLastRanInfo;
		
begin

	// A task has been completed. Lets update the timestamp.
	if _eventType = BGP_Object.BGP_RequestCompleted then
		info := self.getCMIFInfo(_userInfo.String);
		info.updateLastRanTs();
	endif;

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="delete" id="c33ee0c7-f545-43ab-ad48-fede1ca04010">
        <updating/>
        <source>delete() updating;
// -------------------------------------------
// Created 15 February 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	self.endNotificationForSubscriber(self);

end;</source>
    </JadeMethod>
    <JadeMethod name="getCMIFInfo" id="bc476c9a-b5cf-497c-9cdb-d7a4e4173f50">
        <updating/>
        <source>getCMIFInfo(_className : String) : CMIF_BGPLastRanInfo protected, updating;
// -------------------------------------------
// Created 15 February 2006 by cnwdvb1
// -------------------------------------------
vars

	info		: CMIF_BGPLastRanInfo;
begin

	
	// Get the appropriate cmif.
	info := self.allCMIFLastRanInfos[_className];
	
	if info = null then
		app.remoteErrorWarningToAlert('INFO &gt;&gt; Could not locate run time information for ' &amp; _className, null, null, null, true, true);
		return null;
	endif;
	
	return info;


end;</source>
        <access>protected</access>
        <Parameter name="_className" type="String"/>
        <ReturnType type="CMIF_BGPLastRanInfo"/>
    </JadeMethod>
    <JadeMethod name="initCMIFInfo" id="eced593b-900b-4cec-bfd8-fb0c211674b8">
        <updating/>
        <source>initCMIFInfo(_className, _niceName : String; _numberOfMinutes, _alertFrequency : Integer; _webSiteConfigName : String) : CMIF_BGPLastRanInfo protected, updating;
// -------------------------------------------
// Created 15 February 2006 by cnwdvb1
// -------------------------------------------
vars

	info		: CMIF_BGPLastRanInfo;
begin

	
	// Initialize an info object for this class.
	create info transient;
	info.initializeInfo(_className, _niceName, _numberOfMinutes, _alertFrequency, _webSiteConfigName, self);
		
	return info;


end;</source>
        <access>protected</access>
        <Parameter name="_className" type="String"/>
        <Parameter name="_niceName" type="String"/>
        <Parameter name="_numberOfMinutes" type="Integer"/>
        <Parameter name="_alertFrequency" type="Integer"/>
        <Parameter name="_webSiteConfigName" type="String"/>
        <ReturnType type="CMIF_BGPLastRanInfo"/>
    </JadeMethod>
    <JadeMethod name="initializeAgent" id="42969a9b-c00d-4be0-affa-983ae749cdb6">
        <updating/>
        <source>initializeAgent(_allAutoRequests : CM_AutoWarningRequestArray) updating;
// -------------------------------------------
// Created 15 February 2006 by cnwdvb1
// -------------------------------------------
vars

	niceName	: String;
	tmpClass	: Class;
	numMinutesBetweenAlerts,
	numMinutes	: Integer;
	request		: CM_AutoWarningRequest;
	isWeb		: Boolean;
	
begin

	// Run through all requested classes
	foreach request in _allAutoRequests do
		
		isWeb := request.className = CM_WebSiteConfig.name;
		
		// Get the number of hours.
		numMinutes := request.minutesBeforeAlert;
		
		tmpClass := self.getClass(request.className);
		if tmpClass = null then
			// Class has not been correctly setup.
			app.remoteErrorWarningToAlert('INFO &gt;&gt; Error initializing Auto Warning Agent ' &amp; 
			' could not locate ' &amp; request.className, null, null, null, true, true);
			continue;
		endif;
		
		if numMinutes = 0 then
			// Class has not been correctly setup.
			app.remoteErrorWarningToAlert('INFO &gt;&gt; Error initializing Auto Warning Agent ' &amp; 
			' number of minutes must be greater than 0 ' &amp; request.className, null, null, null, true, true);
			continue;
		endif;
			
		numMinutesBetweenAlerts := request.alertFrequency;
		
		if numMinutesBetweenAlerts = 0 then
			// Class has not been correctly setup.
			app.remoteErrorWarningToAlert('INFO &gt;&gt; Error initializing Auto Warning Agent ' &amp; 
			' number of minutes between alerts must be greater than 0 ' &amp; request.className, null, null, null, true, true);
			continue;
		endif;
		
		// No notes for web.
		if not isWeb then
			// Start the notification listening.
			self.beginClassNotification(tmpClass, false, BGP_Object.BGP_RequestCompleted, Response_Continuous, null);
		endif;
		// Initialize and info object.
		niceName := tmpClass.text.cnEcGetTagValueOfName('display');
		self.initCMIFInfo(request.className, niceName, numMinutes, request.alertFrequency, request.webSiteConfigName);
	endforeach;

end;</source>
        <Parameter name="_allAutoRequests" type="CM_AutoWarningRequestArray"/>
    </JadeMethod>
    <JadeMethod name="sendAlert" id="17c08c44-4c46-42f2-8aa2-5eace2e4ef0f">
        <source>sendAlert(_info : CMIF_BGPLastRanInfo input; _addresses : String; _now : TimeStamp) protected;
// -------------------------------------------
// Created 16 February 2006 by cnwdvb1
// -------------------------------------------
constants

	Subject = 'JMT Auto Task Failure';
	
vars

	email	: BGP_EmailSendRequest;
	fromAddress,
	address,
	details,
	message	: String;

begin

	if _addresses = null then
		return;
	endif;
	
	// Get the message.
	details := _info.getDetails();
	message := _now.shortCurrentLocaleFormat() &amp; CrLf &amp; details;
	
	fromAddress := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	
	app.remoteErrorWarningToAlert(details, null, null, null, true, true);
	// Send the email.

	// Update last alerted stuff.
	_info.lastAlertedTs	:= _now;
	_info.isAlerted		:= true;
		
	app.myTrxCA.trxCreateEmailSendRequest(	'Send Text Alert',
											_addresses,
											fromAddress,
											null, 
											null,
											Subject,
											message,
											null,
											null,
											null,
											null,
											EmailSource_System,
											null,
											app.myPassport);
											
	if not app.myPassport.trxCompletedOK then
		app.remoteErrorWarningToAlert('Could not send email', 
		null,  app.myPassport.allErrors, null, false, true);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_info" type="CMIF_BGPLastRanInfo" usage="input"/>
        <Parameter name="_addresses" type="String"/>
        <Parameter name="_now" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="sendAlertForAllErrors" id="d84b2eef-771f-4586-9f13-4e6d9ea1eb49">
        <source>sendAlertForAllErrors(_cellAddress, _cellNumbers : String);
// -------------------------------------------
// Created 16 February 2006 by cnwdvb1
// -------------------------------------------
vars

	info		: CMIF_BGPLastRanInfo;
	now			: TimeStamp;
	huge		: HugeStringArray;
	str,
	addresses	: String;

begin

	// Whats the time Wolfie.
	now := app.actualTimeServer();
	
	// Run through all info objects.
	foreach info in self.allCMIFLastRanInfos do
		// Is this info out of time.
		if info.isOutOfScope(now) then
		
			// Have the users already been told. Lets wait.
			if info.isAlerted and (info.lastAlertedTs.cnEcAddMinutes(info.alertFrequency) &gt; now) then
				continue;
			endif;
			
			// Need to parse the addresses.
			if huge = null then
				create huge transient;
				_cellNumbers.parseCSV(huge);
				foreach str in huge do
					addresses := addresses &amp; ';' &amp; str &amp; _cellAddress;					
				endforeach;
				if addresses.length &gt; 1 then
					addresses := addresses[2:end];													
				endif;
			endif;
			
			// Send the alerts.
			self.sendAlert(info, addresses, now);
		endif;
	endforeach;

epilog
	delete huge;
end;</source>
        <Parameter name="_cellAddress" type="String"/>
        <Parameter name="_cellNumbers" type="String"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="5b677df8-3936-45b9-b001-68db5f471458">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// -------------------------------------------
// Created 15 February 2006 by cnwdvb1
// -------------------------------------------
vars

	errCode			: Integer;
	errTxt			: String;

begin

	on Exception do app.alertExceptionHandler(exception, null, method.name, errCode, errTxt, true, false);
	on LockException do app.alertLockExceptionHandler(exception);
	
	self.actionEvent(eventType, theObject, userInfo);

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="writeDetails" id="c2bf5586-c40c-4305-8e19-25623fb6b0c6">
        <source>writeDetails();
// -------------------------------------------
// Created 16 February 2006 by cnwdvb1
// -------------------------------------------
vars

	dtl : CMIF_BGPLastRanInfo;
begin

	foreach dtl in self.allCMIFLastRanInfos do
		dtl.getDetails();
	endforeach;

end;</source>
    </JadeMethod>
</Class>
