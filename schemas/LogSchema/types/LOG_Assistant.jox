    <JadeMethod name="comboBoxVessel" id="8a440b10-5ffa-4692-9059-fafcf708814b">
        <source>comboBoxVessel(pCmb: ComboBox input; pVessel: CM_Vessel);
//--------------------------------------------------------------
//Created: 08 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	pCmb.listCollection(self.allLogVessels, false, 0);

	if pVessel &lt;&gt; null and
	   self.allLogVessels.includes(pVessel) then
		pCmb.text := self.displayEntryVessel(pVessel);
	   	pCmb.listObject := pVessel;
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
