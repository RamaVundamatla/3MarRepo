	_request : CMIF_SAPDataKinerjaReq;
	kinjItem : CMIF_SAPDataKinerjaItem;
begin
	//self.doSetupConsumerInstance(SAP19_HTTP_Port);
	create _request transient;
	create createdObjects transient;
	create realRequest transient;
