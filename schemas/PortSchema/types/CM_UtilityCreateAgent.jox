    <JadeMethod name="utlCreateCustomsReferences" id="89c2a720-12a0-470b-a22e-feecad6f2114">
        <source>utlCreateCustomsReferences(_pxyCustomsReferenceDict: CM_CustomsReferenceDict input; _passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
03 March 2023		navpw1	Initial creation TFS: 55215
27 February 2024	navcs2	Defect 62587: CUX | POST/CustomsStatus Method Does not create any Transaction
26 March 2024		navlw1 	ChangeRequest 62959: CUX FR | Tk 62917 - EDBIC Make Customs references editable
31 Mar 2025			navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	customsReference,
	realCustomsReference	: CM_CustomsReference;
	trackedItem				: CM_TrackedItem;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	//Validate all objects in the dictionary
	foreach customsReference in _pxyCustomsReferenceDict do
		// navlw1 #63566
		app.myValCA.valCustomsReference(customsReference);
	endforeach;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	//Foreach object we need to create, create it
	foreach customsReference in _pxyCustomsReferenceDict do
		create realCustomsReference persistent;
		realCustomsReference.setForCreate(customsReference);
		trackedItem := customsReference.myTrackedItem;
		
		trackedItem.addCustomsReference(realCustomsReference);
	endforeach;
epilog
	
end;</source>
        <Parameter name="_pxyCustomsReferenceDict" type="CM_CustomsReferenceDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
