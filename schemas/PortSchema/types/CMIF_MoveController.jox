    <JadeMethod name="setForCreateUnplan" id="e9393daa-04f3-4c77-82dc-e31ee0ea1584">
        <updating/>
        <source>setForCreateUnplan(_theTI : CM_TrackedItem; _theWLE : CM_WorkListEntry; _theRequest : CM_Request; _isLoad : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.setMoveMode(PLANNING_MODE);
	self.setMyTrackedItem(_theTI);
	self.isFullyUnplan := true;
	self.setMyWorkListEntry(_theWLE);
	
	if _theRequest.isKindOf(CM_SlotRequest) then
		self.mySlotRequest := _theRequest.CM_SlotRequest;
	elseif _theRequest.isKindOf(CM_VoyageRequest) then
		self.myVoyageRequest := _theRequest.CM_VoyageRequest;
	endif;
	
	_theTI.setFMUnplanIndex(_isLoad,self);

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theWLE" type="CM_WorkListEntry"/>
        <Parameter name="_theRequest" type="CM_Request"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForDirectRelease" id="a5fa91a2-c56f-4d7c-b18a-8d73b605ac43">
        <updating/>
        <source>setForDirectRelease() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2018	jlgndl1	Initial creation	TFS 38897

*/

vars

	ta : CM_TerminalArea;

begin

	if self.moveMode &lt;&gt; REAL_MODE then
		return;
	endif;

	/*
	If we are moving cargo in instant mode to a 'Direct Release' area that is set up
	to automatically release immediately, then we need to set the target to null i.e. off-site at this
	point in time, but we also need to keep a track of where we were going so we can
	include any extra transactions we need to process later.
	*/
	
	if self.myToPrimaryLocation &lt;&gt; null then
	
		ta := self.myToPrimaryLocation.getMyTerminalArea;
		
		if ta &lt;&gt; null
		and ta.isBlockStack
		and ta.type = TA_TYPE_RELTRANS
		and ta.CM_BlockStack.autoRelease 
		then
			self.myDirectReleaseArea := ta.CM_BlockStack;
			self.myToPrimaryLocation := null;
		endif;
		
	endif;

epilog

end;</source>
    </JadeMethod>
