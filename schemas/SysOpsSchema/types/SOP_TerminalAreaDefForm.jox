    <JadeMethod name="tblMain_queryRowColChg" id="2a7deb97-b7e0-4029-ad85-d6fcb1df48f7">
        <controlMethod name="CM_EntryTable::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMain_queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2009	cnwer1	Initial creation

*/

vars

begin
	// from 30458 cnwjre1 Oct 2012, only need this in edit (gets exception otherwise)
	if self.mode = 0 then
		return true;
	endif;

	if terminalAreaType = TA_TYPE_RTG or  terminalAreaType = TA_TYPE_RMG then
		if tblMain.getRowByName(ETRow_Bays) = tblMain.row  or
			tblMain.getRowByName(ETRow_Height) = tblMain.row  then
			//need to change the lane grouping combo
			
			self.buildOrAdjustAreaSize(true);
		endif;
		if tblMain.getRowByName(ETRow_Rows) = tblMain.row then
			self.buildOrAdjustAreaSize(true);
			self.doBuildComboLaneGrouping();
		endif;
	endif;

	return true;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testForDeckingUpdates" id="3470ad59-6936-435d-9065-affab95c660c">
        <source>testForDeckingUpdates(_pxyTA: CM_TerminalArea): Integer;
//----------------------------------------------------------------
//	Created:	17 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	retVal			: Integer;
begin
	//only want to return something valid if an update is required - invalid return value (&lt;0) will mean an update to decking options
	//can be avoided further on if necessary

	if self.deckingOptionsHaveChanged(_pxyTA) then
		retVal := app.msgBox(app.getErrorString(ApplyDeckingToAll) &amp; CrLf &amp; 
						"("&amp; app.getErrorString(NoForTAOnly) &amp; ")", self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		
		if retVal = MsgBox_Return_Yes then
			return DeckingLevel_YA;
		else
			return DeckingLevel_TA;
		endif;
		
	endif;
	
	return DeckingLevel_Null;
	
end;</source>
        <Parameter name="_pxyTA" type="CM_TerminalArea"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="toolbarShowCaptions" id="7d424ec2-0854-473b-bfe4-969650cb5342">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
//
//18 Jan 2017	cnwrs1	TFS 3137 - resize the find/trplace form when show captions is on
//
vars
	currentHeight : Real;
	newHeight : Real;
	heightDiff : Real;
begin
	currentHeight := self.frmToolbar.height;
	inheritMethod(_showCaptions);
	newHeight := self.frmToolbar.height;
	heightDiff := newHeight - currentHeight;
	
	self.frmTBExtra.showCaptions := self.frmToolbar.showCaptions;
	self.tblExtra.top := self.tblExtra.top + heightDiff;
	self.tblExtraList.top := self.tblExtraList.top + heightDiff;
	self.tblExtraList.height := self.tblExtraList.height - heightDiff;
	self.frmDetailsBottom.top := self.frmDetailsBottom.top + heightDiff;
	self.doResize;
end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2b53ceb1-ce1a-41f4-a425-c6cc2d121334">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 January 2024 12:58:02.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007119, locale);
	btnAssocIC.translateBubbleHelp(Xlat_0014265, locale);
	btnAssocIC.translateCaption(Xlat_0014266, locale);
