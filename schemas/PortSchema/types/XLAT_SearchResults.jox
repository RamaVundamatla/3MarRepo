<Class name="XLAT_SearchResults" id="c7574953-8c35-43b1-8846-ee819fe3967d">
    <superclass name="XLAT_TranslationEnties"/>
    <transient/>
    <final/>
    <transientAllowed/>
    <DbClassMap file="translation"/>
    <ImplicitInverseRef name="allTranslatableText" id="7a76ebdf-4dde-44c5-8f3f-200856ebfa6b">
        <memberTypeInverse/>
        <type name="XLAT_TranslatableTextByNumber"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myAgent" id="644420d8-1861-4396-99cb-a877e807cf0b">
        <kind>child</kind>
        <embedded/>
        <type name="CM_TranslationAgent"/>
        <access>readonly</access>
        <Inverse name="CM_TranslationAgent::allSearchResults"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myCategory" id="75d608e6-133b-45a6-bd94-a1326974f83a">
        <embedded/>
        <type name="XLAT_Category"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="clear" id="47a7be49-781e-45aa-9cce-cd9a2e7bd599">
        <source>clear();

vars

begin
	allTranslatableText.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="update" id="e800cc00-9dd2-4ed7-ac4a-369614e85ad9">
        <updating/>
        <source>update(_agent : CM_TranslationAgent; _category : XLAT_Category; _clearResults : Boolean) updating;

vars

begin
	if _category = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "No Translation Categories");
	endif;
	if self.myCategory &lt;&gt; _category then
		self.myCategory := _category;
	endif;
	if self.myAgent &lt;&gt; _agent then
		self.myAgent := _agent;
	endif;
	if _clearResults then
		self.clear();
	endif;
end;</source>
        <Parameter name="_agent" type="CM_TranslationAgent"/>
        <Parameter name="_category" type="XLAT_Category"/>
        <Parameter name="_clearResults" type="Boolean"/>
    </JadeMethod>
</Class>
