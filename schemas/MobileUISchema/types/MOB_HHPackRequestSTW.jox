    <JadeMethod name="doResizeControls" id="85029ac4-cf8f-481b-a615-575528928af3">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth;
	cHeight := stdHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.lblRequest.setAndIncrementTabIndex( tabIndex );
		self.lblRequest.visible := true;
	endif;
	self.lblRequest.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight ); 
								
	cTop := cTop + self.lblRequest.height;
	
	if _initialSetup then
		self.lblPackLoadTarg.setAndIncrementTabIndex( tabIndex );
		self.lblPackLoadTarg.visible := true;
	endif;
	self.lblPackLoadTarg.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight );
								
	cTop := cTop + self.lblPackLoadTarg.height;
	if _initialSetup then
		self.cmbTruck.setAndIncrementTabIndex( tabIndex );
		self.cmbTruck.visible := true;
	endif;
	self.cmbTruck.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight );
							 
	//place wagon in same posi as truck, but hide it, we wont show both
	if _initialSetup then
		self.cmbWagon.setAndIncrementTabIndex( tabIndex );
		self.cmbWagon.visible := false;
	endif;
	self.cmbWagon.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight );
							 						 						 
	cTop := cTop + self.cmbTruck.height + ( self.resizedMargin );
	if _initialSetup then
		self.cmbTrailer.setAndIncrementTabIndex( tabIndex );
		self.cmbTrailer.visible := true;
	endif;
	self.cmbTrailer.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight );
							 
	cTop := cTop + self.cmbTrailer.height + ( self.resizedMargin );
	if _initialSetup then
		self.cmbParent.setAndIncrementTabIndex( tabIndex );
		self.cmbParent.visible := true;
	endif;
	self.cmbParent.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight ); 
							 
	if self.cmbParent.visible then
		cTop := cTop + self.cmbParent.height + ( self.resizedMargin );
	endif;
	
	cWidth := stdWidth - self.getSearchButtonSpace();
	if _initialSetup then
		self.txtParentId.setAndIncrementTabIndex( tabIndex );
		self.txtParentId.visible := false;
	endif;
	self.txtParentId.move( self.resizedMargin,
						 cTop,
						 cWidth,
						 stdHeight );
						 
	cWidth := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.setAndIncrementTabIndex( tabIndex );
		self.btnPartCargoId.visible := false;
	endif;
	self.btnPartCargoId.move( self.txtParentId.left + self.txtParentId.width + self.resizedMargin,
						 cTop,
						 cWidth,
						 cHeight );
						 
	if self.txtParentId.visible then
		cTop := cTop + self.txtParentId.height + self.resizedMargin;
	endif;
	cWidth := stdWidth;
	if _initialSetup then
		self.lblCargoType.visible := true;
		self.lblCargoType.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblCargoType.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight ); 
							 
	cTop := cTop + self.lblCargoType.height + self.resizedMargin;
	if _initialSetup then
		self.lblCargoDesc.visible := true;
		self.lblCargoDesc.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblCargoDesc.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight );
	
								
	cTop := cTop + self.lblCargoDesc.height;
	if _initialSetup then
		self.cmbRelItems.setAndIncrementTabIndex( tabIndex );
		self.cmbRelItems.visible := true;
		self.cmbRelItems.enabled := false;
	endif;
	self.cmbRelItems.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight ); 
								
	cTop := cTop + self.cmbRelItems.height + self.resizedMargin;
	if _initialSetup then
		self.cmbSourceArea.setAndIncrementTabIndex( tabIndex );
		self.cmbSourceArea.visible := true;
	endif;
	self.cmbSourceArea.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight ); 
							 
	inheritMethod(_initialSetup);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findRequest" id="7e324152-9227-4b2c-8829-7d45e2a4bce2">
        <updating/>
        <source>findRequest() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2018	jlgndl1	Initial creation	TFS 38083

*/

vars


	term : CM_Terminal;
	
	truckArray : CM_VehicleArray;
	truck : CM_Vehicle;
	newIndex : Integer;
	ti : CM_TrackedItem;
	
	allPreStaged : Boolean;
	tiSet : CM_TISet;
	firstStagingLC : CM_LocationsController;
	sourceIndex : Integer;
	outStandingItemCount : Integer;
	stagedItemCount : Integer;
	
begin

	self.cmbTruck.clear();
	self.cmbParent.clear();
	self.cmbTrailer.clear();
	self.cmbWagon.clear();	
	
	self.cmbTruck.visible := true;	
	self.cmbParent.visible := true;	
	self.cmbTrailer.visible := true;	
	self.cmbWagon.visible := false;	
	
	self.cmbTruck.enabled := true;
	self.cmbParent.enabled := true;
	self.cmbTrailer.enabled := true;
	self.cmbWagon.enabled := false;	

	self.requestedItemCount := 0;
	
	if self.myBulkRelease.isRailType then
		self.setupForRailRelease();
		return;	
	endif;
			
	create truckArray transient;
	if self.myBulkRelease.isRoadType then
		self.getTrucksFromBulkRelease( self.myBulkRelease, truckArray );
	endif;
	
	if truckArray.size = 1 then
		create tiSet transient;
		outStandingItemCount := self.myBulkRelease.getTotalOutstanding;
		stagedItemCount := self.myBulkRelease.getTotalStaged(tiSet, firstStagingLC);
		if outStandingItemCount &gt; 0 and outStandingItemCount = stagedItemCount then
			if firstStagingLC &lt;&gt; null then
				sourceIndex := self.cmbSourceArea.findObject(firstStagingLC);
				if sourceIndex &gt; 0 then
					self.cmbSourceArea.listIndex := sourceIndex;
				endif;
			endif;
			allPreStaged := true;
		endif;
	endif;
	
	foreach truck in truckArray do
		newIndex := self.cmbTruck.addItem( truck.regNumber );
		self.cmbTruck.itemObject[newIndex] := truck; 
	endforeach;
	
	foreach truck in truckArray do
		foreach ti in truck.locationsController.allTrackedItems do
			if ti.isROB then
				if ti.isChassis then
					newIndex := self.cmbTrailer.addItem( ti.id );
					self.cmbTrailer.itemObject[newIndex] := ti; 
				else
					newIndex := self.cmbParent.addItem( ti.id );
					self.cmbParent.itemObject[newIndex] := ti; 
				endif;
			endif;
		endforeach; 
	endforeach;
	
	self.getProspectiveParentCargo();
			
	if self.cmbTruck.listCount &lt; 1 then
		self.cmbTruck.addItem( app.getErrorString(No_associated_truck) );
		self.cmbTruck.enabled := false;
		self.cmbTruck.listIndex := 1;	
	else
		self.cmbTruck.addItemAt( app.getErrorString(Associated_truck),1 );
		self.cmbTruck.listIndex := 1;
	endif;
	
	if self.cmbTrailer.listCount &lt; 1 then
		self.cmbTrailer.addItem( app.getErrorString(No_associated_trailers) );
		self.cmbTrailer.enabled := false;
		self.cmbTrailer.listIndex := 1;	
	else
		self.cmbTrailer.addItemAt( app.getErrorString(Associated_trailers),1 );
		self.cmbTrailer.listIndex := 1;
	endif;
	
	if self.cmbParent.listCount &lt; 1 then
		self.cmbParent.addItem( app.getErrorString(No_associated_parents) );
		self.cmbParent.enabled := false;
		self.cmbParent.listIndex := 1;
	else
		self.cmbParent.addItemAt( app.getErrorString(Associated_parents),1 );
		self.cmbParent.listIndex := 1;
	endif;
	
	if self.myBulkRelease.isPackingType then
		self.requestedItemCount := self.myBulkRelease.getTotalOutstanding;
		self.lblRequest.caption := self.myBulkRelease.code &amp; "    " &amp; app.releaseRequestTypeEnumToString( self.myBulkRelease.type ) &amp; " ["
		&amp; self.myBulkRelease.allReservePackingChildren.size.String &amp; " " &amp; app.getErrorString(INV_Items) &amp; "]";
	else
		self.requestedItemCount := self.myBulkRelease.allTrackedItemsAssigned.size;
		self.lblRequest.caption := self.myBulkRelease.code &amp; "    " &amp; app.releaseRequestTypeEnumToString( self.myBulkRelease.type ) &amp; " ["
		&amp; self.myBulkRelease.allReserveDetails.size.String &amp; " " &amp; app.getErrorString(INV_Items) &amp; "]";
	endif;
	
	self.setMyWagon( null );	
	self.setMyTrackedItem( null );
	if allPreStaged then
		truck := truckArray.first;
		self.cmbTruck.listIndex := self.cmbTruck.findObject(truck);
		self.setMyTruck( truck );
	else
		self.setMyTruck( null );
	endif;
	
	self.cmbParent.visible := cmbParent.enabled;  // so the resize re-positions the lblCargoDesc and Type fields. (Not enough room...)
	
	self.txtParentId.visible := ( not self.cmbParent.enabled ) and ( not self.cmbTrailer.enabled ) and ( self.myBulkRelease &lt;&gt; null );
	if self.btnPartCargoId.visible &lt;&gt; self.txtParentId.visible then
		self.btnPartCargoId.visible := self.txtParentId.visible;
	endif;
	
	//18 Dec 2015	NDL	Par 37288
	self.autoSelectSourceArea();
	
	if self.cmbParent.visible then
		if self.cmbParent.listCount = 2 then
			if not self.cmbTruck.enabled and not self.cmbTrailer.enabled then
				//there is only one container to select and nothing else.  Select it.
				self.cmbParent.listIndex := 2;
				self.cmbParent.click( self.cmbParent );
			endif;
		endif;
	endif;
	
	self.doResizeControls(false);
	
epilog

	delete truckArray;
	delete tiSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="getByTypePropsects" id="c4c6760f-3cc3-4016-ab9c-4b6f6d6eefd4">
        <source>getByTypePropsects() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

	ti : CM_TrackedItem;
	reserve : CM_ReserveDetail;
	opTerm : CM_OperatorTerminal;
	newIndex : Integer;
	reason : String;	
	iter : Iterator;
	reserveDetailSetTrail : CM_ReserveDetailSet;
	reserveDetailSetCont : CM_ReserveDetailSet;
	startObject : CM_TrackedItem;
	cargoType : CM_CargoType;
	validTrailerCargoTypes : CM_CargoTypeSet;

begin

	opTerm := self.myBulkRelease.myOperatorTerminal;
	if opTerm = null then
		return;
	endif;
	
	// get a list of all of the valid trailer cargo types.
	create validTrailerCargoTypes transient;
	foreach cargoType in app.myRoot.allCargoTypesById do
		if cargoType.productType = ProductType_Trailer then
			validTrailerCargoTypes.add(cargoType);
		endif;
	endforeach;
	
	// we are only interested in reserve details that are for Containers or for Trailers
	create reserveDetailSetTrail transient;
	create reserveDetailSetCont transient;
	
	foreach reserve in self.myBulkRelease.allReserveDetails do
		if not reserve.isKindOf( CM_ReserveSelection ) then
			continue;
		endif;
		if reserve.CM_ReserveSelection.myCargoType = null then
			continue;
		endif;
		if reserve.CM_ReserveSelection.myCargoType.id = TI_CargoType_Container then
			reserveDetailSetCont.add(reserve);
			continue;
		endif;
		if validTrailerCargoTypes.isEmpty then
			continue;
		endif;
		if validTrailerCargoTypes.includes( reserve.CM_ReserveSelection.myCargoType ) then
			reserveDetailSetTrail.add(reserve);
			continue;
		endif;
	endforeach;
			
	if reserveDetailSetCont.isEmpty and  reserveDetailSetTrail.isEmpty then
		return;
	endif;
	
	if not reserveDetailSetCont.isEmpty then
		iter := opTerm.allOnsiteTIsByCargoTypeId.createIterator;
		startObject := opTerm.allOnsiteTIsByCargoTypeId.getAtKeyGeq( TI_CargoType_Container, null);
		if startObject &lt;&gt; null and startObject.isContainer then
			iter.startAtObject(startObject);
			while iter.next(ti) do
				if not ti.isContainer then
					break;
				endif;
				foreach reserve in reserveDetailSetCont do
					// find any containers that meet at least one of the reserve details.
					if ti.testAgainstReserveSelection( reserve.CM_ReserveSelection, reason, true, null ) then
						newIndex := self.cmbParent.addItem( ti.id );
						self.cmbParent.itemObject[newIndex] := ti; 
						break;
					endif;
				endforeach;
			endwhile;
		endif;
		delete iter;
	endif;
	
	if not reserveDetailSetTrail.isEmpty then
		foreach cargoType in validTrailerCargoTypes do
			iter := opTerm.allOnsiteTIsByCargoTypeId.createIterator;
			startObject := opTerm.allOnsiteTIsByCargoTypeId.getAtKeyGeq( cargoType.id, null);
			if startObject &lt;&gt; null and startObject.cargoType = cargoType.id then
				iter.startAtObject(startObject);
				while iter.next(ti) do
					if ti.cargoType &lt;&gt; cargoType.id then
						break;
					endif;
					foreach reserve in reserveDetailSetCont where reserve.CM_ReserveSelection.myCargoType = cargoType do
						// find any trailers that meet at least one of the reserve details.
						if ti.testAgainstReserveSelection( reserve.CM_ReserveSelection, reason, true, null ) then
							newIndex := self.cmbTrailer.addItem( ti.id );
							self.cmbTrailer.itemObject[newIndex] := ti;  
							break;
						endif;
					endforeach;
				endwhile;
			endif;
			delete iter;
		endforeach;
	endif;
				
epilog

	delete reserveDetailSetTrail;
	delete reserveDetailSetCont;
	delete iter;
	delete validTrailerCargoTypes;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getProspectiveParentCargo" id="7857eaa8-00c6-437c-82f5-f39f6d7c275e">
        <updating/>
        <source>getProspectiveParentCargo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Name	TFS#		Description
============================================================================
13 Apr 2018	jlgndl1	TFS 38083	Initial creation
21 Aug 2019	jlgka1 	TFS 46218 	JMT - Stop the getProspectivePackingParents  to findMore when it is coming from Web.
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
============================================================================*/

vars
	ti 	 	 : CM_TrackedItem;
	reserve  : CM_ReserveDetail;
	newIndex : Integer;
	tiArray  : CM_TIArray;	
	allTis	 : CM_TISet;
begin

	if self.myBulkRelease = null then
		return;
	endif;
	
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	if self.myBulkRelease.isPackingType then
		create tiArray transient;
		self.myBulkRelease.getProspectivePackingParents( tiArray, false );
		
		foreach ti in tiArray do
			newIndex := self.cmbParent.addItem( ti.id );
			self.cmbParent.itemObject[newIndex] := ti; 
		endforeach;
	
	else

		if not self.myBulkRelease.releaseByType then
			// Release by id
			// get the nominated parents
			foreach reserve in self.myBulkRelease.allReserveDetails do	
				reserve.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
				//foreach ti in reserve.allTrackedItems do
				foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
					if self.myBulkRelease.allTrackedItemsReleased.includes(ti) then
						continue;
					endif;
					if ti.isChassis then
						newIndex := self.cmbTrailer.addItem( ti.id );
						self.cmbTrailer.itemObject[newIndex] := ti; 
					elseif ti.isContainer then
						newIndex := self.cmbParent.addItem( ti.id );
						self.cmbParent.itemObject[newIndex] := ti; 
					endif;
				endforeach;
			endforeach;
				
		else
			// release by type
			// get the prospective parents	
			self.getByTypePropsects();
			
		endif;
	
	endif;

epilog

	delete tiArray;
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
    </JadeMethod>
    <JadeMethod name="getReserveSelection" id="83d02916-b318-4020-a1f1-27ab37fb5fa0">
        <source>getReserveSelection():CM_ReserveSelection;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

	index : Integer;
	obj : Object;

begin

	index := self.cmbRelItems.listIndex;
	if index &gt; 0 then
		obj := self.cmbRelItems.itemObject[index];
		if obj &lt;&gt; null and CM_ReserveSelection.hasInstance(obj) then
			return obj.CM_ReserveSelection;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_ReserveSelection"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="b4a9dc86-d913-4ab6-b28d-d8ee176a6f5e">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

	reserveSelection :CM_ReserveSelection;
	msg : String;

begin

	reserveSelection := self.getReserveSelection;
	if reserveSelection &lt;&gt; null then
		if reserveSelection.isPackingChild then
			if reserveSelection.isFullyPacked then
				msg := app.getErrorString1(Fully_packed,reserveSelection.getDescription);
				if self.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
					return;
				endif;
			endif;
		elseif not reserveSelection.isPackingParent and not reserveSelection.isPackingChild then
			if reserveSelection.isFullyLoaded then
				msg := app.getErrorString1(Fully_satisfied,reserveSelection.getDescription);
				if self.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
					return;
				endif;
			endif;
		endif;
	endif;
	
	if self.myWagon &lt;&gt; null then
	
		self.myMobileGenericAgent.setMyLocationsController(	self.myWagon.allLocationsControllersArray.first );
		self.myMobileGenericAgent.setMyBulkRelease( self.myBulkRelease );
		self.myMobileGenericAgent.setMyReserveDetail( reserveSelection );
		self.myMobileGenericAgent.setMyYardLocation( self.cmbSourceArea.listObject.CM_LocationsController );
		if self.stwRuleNum &gt; 0 then
			self.myMobileGenericAgent.setStringField1( self.stwRuleNum.String );
		endif;
		self.gotoForm( MOB_HHBRLocLoaderAllCargoSTW, false );
		
	elseif self.myTrailer &lt;&gt; null then
	
		self.myMobileGenericAgent.setTruck( null );
		self.myMobileGenericAgent.setMyLocationsController(	self.myTrailer.CM_TILC.allLCs.first );
		self.myMobileGenericAgent.setMyBulkRelease( self.myBulkRelease );
		self.myMobileGenericAgent.setMyReserveDetail( reserveSelection );
		self.myMobileGenericAgent.setMyYardLocation( self.cmbSourceArea.listObject.CM_LocationsController );
		if self.stwRuleNum &gt; 0 then
			self.myMobileGenericAgent.setStringField1( self.stwRuleNum.String );
		endif;
		self.gotoForm( MOB_HHBRLocLoaderAllCargoSTW, false );
		
	elseif self.myTrackedItem &lt;&gt; null then
	
		self.myMobileGenericAgent.setPackContainerDetails(	null,	//_stockBookingRef : CM_BookingRef;
																null,	//_stockBookingRefItem : CM_BookingRefItem;
																null,	//_exportBookingRef : CM_BookingRef;
																null,	//_exportBookingRefItem : CM_BookingRefItem;
																self.myTrackedItem	//_trackedItem : CM_TrackedItem
																);	
		self.myMobileGenericAgent.setMyBulkRelease( self.myBulkRelease );
		self.myMobileGenericAgent.setMyReserveDetail( reserveSelection );
		self.myMobileGenericAgent.setMyYardLocation( self.cmbSourceArea.listObject.CM_LocationsController );
		if self.stwRuleNum &gt; 0 then
			self.myMobileGenericAgent.setStringField1( self.stwRuleNum.String );
		endif;
		self.myMobileGenericAgent.setTruck( self.myTruck );
		self.gotoForm( MOB_HHPackContainerUpdForm, false );
	
	elseif self.myTruck &lt;&gt; null then

		self.myMobileGenericAgent.setMyLocationsController(	self.myTruck.locationsController );
		self.myMobileGenericAgent.setMyBulkRelease( self.myBulkRelease );
		self.myMobileGenericAgent.setMyReserveDetail( reserveSelection );
		self.myMobileGenericAgent.setMyYardLocation( self.cmbSourceArea.listObject.CM_LocationsController );
		if self.stwRuleNum &gt; 0 then
			self.myMobileGenericAgent.setStringField1( self.stwRuleNum.String );
		endif;
		self.gotoForm( MOB_HHBRLocLoaderAllCargoSTW, false );
			
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="d1468836-0322-474d-be1f-b5edbc99ce26">
        <updating/>
        <source>handleBtnTwo() updating, protected;
