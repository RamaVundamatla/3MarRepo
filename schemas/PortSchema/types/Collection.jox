<CollClass name="Collection">
    <JadeMethod name="copyNoDups" id="bb962f36-4d4f-402d-a422-f014d24c88b3">
        <source>copyNoDups(_coll : Collection input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2012	cnwer1	Initial creation SFW 1295

*/

vars
	obj	: Any;
	hadDuplicate : Boolean;
begin
	
	foreach obj in self do
		if not _coll.includes(obj) then
			_coll.add( obj );
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_coll" type="Collection" usage="input"/>
    </JadeMethod>
    <ExternalMethod name="fastcopy" id="9fb2ac9f-cddc-4171-bffe-a1d70c13dd76">
        <entrypoint>collCopy</entrypoint>
