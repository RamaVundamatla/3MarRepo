    <JadeMethod name="cloneMySelfSuper" id="0651f47d-679f-4b5d-abfb-ae14a46800fe">
        <source>cloneMySelfSuper(_newDeck : CM_Deck; _copy : Boolean) : CM_Deck;
/*
Purpose:			
Date				Who			Reason
MAY 2011		CNWAB1		Initial creation
	// ### IF COPY then transient, else persistant as these methods are used to copy decks and copy whole vessels. The copy vessel is persistant
*/

vars
	newDeck 					: CM_Deck;
	aRamp, newRamp 				: CM_RORORampInternal;
	aLift, newLift 				: CM_ROROLift;
	aMachinery, newMachinery 	: CM_ROROEquipment;
	aGenItem,newGenItem 		: CM_ROROGeneralArea;
	aDeckItem, newDeckItem 		: CM_DeckItem;
	newDeckLayout 				: CM_DeckLayout;
	newLayer 					: CM_DeckLayerLayout;
begin

	newDeck := _newDeck;
	
	// ### The clone of the layer also clones the LaneDefn, LocnDefn and SlotDefn
	// ### IF COPY then transient, else persistant as these methods are used to copy decks and copy whole vessels. The copy vessel is persistant
	newDeckLayout := self.myDeckLayout.cloneMySelf(newDeck, _copy);
	
	// PAR 29881 - Noticed during testing
	// Create all the voyage layers. We used to create these layers as and when we needed them. 
	// But this means handling new layers as they are created in the RORO Planning screen
	// because most of these layers are non structural and are not on the vessel.
	newDeckLayout.setForCeateNonStructuralLayers(); 
	
	foreach aLift in self.allLifts discreteLock do
		newLift := aLift.cloneMySelf(newDeck, _copy);
	endforeach;
	
	foreach aMachinery in self.allMachinery discreteLock do
		newMachinery := aMachinery.cloneMySelf(newDeck, _copy);
	endforeach;
	
	foreach aGenItem in self.allGeneralItems discreteLock do
		newGenItem := aGenItem.cloneMySelf(newDeck, _copy);
	endforeach;
	
	foreach aRamp in self.allRamps discreteLock do
		newRamp := aRamp.cloneMySelf(newDeck, _copy);
	endforeach;
	
	
	return newDeck;
epilog

end;</source>
        <Parameter name="_newDeck" type="CM_Deck"/>
        <Parameter name="_copy" type="Boolean"/>
        <ReturnType type="CM_Deck"/>
    </JadeMethod>
