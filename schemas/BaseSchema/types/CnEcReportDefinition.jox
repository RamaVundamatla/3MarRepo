    <JadeMethod name="cnEcGetExtractString" id="826d2722-8fa1-4804-921d-4593ddcb543c">
        <source>cnEcGetExtractString(): String;
// --------------------------------------------------------------------------------
// Created:		17 February 2001 by cnwdad1
//
// Purpose:		Build an extract string for the receiver's details, and return it.
//				The extract string is used when report definitions and their
//				parameters are extracted to a file, in CSV format.
//
// Parameters:	None
//
// Returns:		The extract string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dataString	: String;
	
begin
	dataString	:=	CNEC_DOUBLE_QUOTE &amp;
					self.reportName &amp;
					CNEC_CSV_SEPARATOR &amp;
					self.myReportCategory.categoryName &amp;
					CNEC_CSV_SEPARATOR &amp;
					self.copies.String &amp;
					CNEC_CSV_SEPARATOR &amp;
					self.formName &amp;
					CNEC_CSV_SEPARATOR &amp;
					self.isLocalAllowed.String &amp;
					CNEC_CSV_SEPARATOR &amp;
					self.marginBottom.String &amp;
					CNEC_CSV_SEPARATOR &amp;
					self.marginLeft.String &amp;
					CNEC_CSV_SEPARATOR &amp;
					self.marginRight.String &amp;
					CNEC_CSV_SEPARATOR &amp;
					self.marginTop.String &amp;
					CNEC_CSV_SEPARATOR &amp;
					self.orientation.String &amp;
					CNEC_CSV_SEPARATOR &amp;
					self.paperSize.String &amp;
					CNEC_CSV_SEPARATOR &amp;
					self.printerName &amp;
					CNEC_CSV_SEPARATOR &amp;
					self.reportDescription &amp;
					CNEC_DOUBLE_QUOTE;
epilog
	return dataString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createAllReportParameters" id="a088c78c-7677-42ad-9235-6a21af536023">
        <updating/>
        <source>createAllReportParameters(pParameterArray:CnEcReportParameterArray) updating, protected;
// --------------------------------------------------------------------------------
// Created:		07 August 2000 by cnwdad1
//
// Purpose:		Recreates all report parameters from the values of a transient
//				parameter array.
//
// Parameters:	pParameterArray (CnEcReportParameterArray) - The array of transient
//				parameters.
//
// Returns:		Nothing
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
// 17/02/2001 cnwdad1	 Added a check for the parameter array being null.
// --------------------------------------------------------------------------------
vars
	reportParameter	: CnEcReportParameter;
	
begin
	self.allReportParameters.purge();
	
	if pParameterArray = null then
		return;
	endif;
	
	foreach reportParameter in pParameterArray do
		self.createReportParameter(	reportParameter.parameterName,
									reportParameter.displayValue,
									reportParameter.sequence,
									reportParameter.parameterType,
									reportParameter.hasValueList);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pParameterArray" type="CnEcReportParameterArray"/>
    </JadeMethod>
    <JadeMethod name="createReportParameter" id="824e931b-bec1-4f20-b205-3c2ab6ebf007">
        <source>createReportParameter(	pParameterName:String;
						pDisplayValue:String;
						pSequence:Integer;
						pParameterType:String;
						pHasValueList:Boolean):CnEcReportParameter;
// --------------------------------------------------------------------------------
// Created:		27 July 2000 by cnwdad1
//
// Purpose:		Create a report parameter object and return it.
//
// Parameters:	pParameterName - The name of the parameter.
//				pDisplayValue - The value displayed for the parameter.
//				pSequence - The parameter's sequence number.
//				pParameterType - The Type of the parameter's value, i.e. String, Class etc.
//				pHasValueList - True if the parameter has a list of values.
//
// Returns:		The new report parameter object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theReportParameter	: CnEcReportParameter;

begin
	create theReportParameter;
	theReportParameter.initializeMe(self, pParameterName, pDisplayValue, pSequence, pParameterType, pHasValueList);
	return theReportParameter;
end;</source>
        <Parameter name="pParameterName" type="String"/>
        <Parameter name="pDisplayValue" type="String"/>
        <Parameter name="pSequence" type="Integer"/>
        <Parameter name="pParameterType" type="String"/>
        <Parameter name="pHasValueList" type="Boolean"/>
        <ReturnType type="CnEcReportParameter"/>
    </JadeMethod>
    <JadeMethod name="getPaperHeightAndWidth" id="6ba12ac3-755c-4370-8002-9a3e06d431bd">
        <source>getPaperHeightAndWidth(pPaperHeight:Integer output; pPaperWidth:Integer output);
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Returns the paper width and height for the report's sheet size.
//
// Parameters:	pPaperHeight - The paper height.
//				pPaperWidth - The paper width.
//
// Returns:		The paper dimensions as output parameters.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (self.paperSize = Print_Letter) then
		pPaperWidth		:=	(8.5 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(11 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_LetterSmall) then
		pPaperWidth		:=	(8.5 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(11 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_Tabloid) then
		pPaperWidth		:=	(11 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(17 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_Ledger) then
		pPaperWidth		:=	(17 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(11 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_Legal) then
		pPaperWidth		:=	(8.5 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(14 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_Statement) then
		pPaperWidth		:=	(5.5 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(8.5 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_Executive) then
		pPaperWidth		:=	(7.25 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(10.5 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_A3) then
		pPaperWidth		:=	297;
		pPaperHeight	:=	420;

	elseif (self.paperSize = Print_A4) then
		pPaperWidth		:=	210;
		pPaperHeight	:=	297;

	elseif (self.paperSize = Print_A4Small) then
		pPaperWidth		:=	210;
		pPaperHeight	:=	297;

	elseif (self.paperSize = Print_A5) then
		pPaperWidth		:=	148;
		pPaperHeight	:=	210;

	elseif (self.paperSize = Print_B4) then
		pPaperWidth		:=	250;
		pPaperHeight	:=	354;

	elseif (self.paperSize = Print_B5) then
		pPaperWidth		:=	182;
		pPaperHeight	:=	257;

	elseif (self.paperSize = Print_Folio) then
		pPaperWidth		:=	(8.5 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(13 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_Quarto) then
		pPaperWidth		:=	215;
		pPaperHeight	:=	275;

	elseif (self.paperSize = Print_10X14) then
		pPaperWidth		:=	(10 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(14 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_11X17) then
		pPaperWidth		:=	(11 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(17 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_Note) then
		pPaperWidth		:=	(8.5 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(11 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_Env_9) then
		pPaperWidth		:=	(3.875 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(8.875 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_Env_10) then
		pPaperWidth		:=	(4.125 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(9.5 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_Env_11) then
		pPaperWidth		:=	(4.5 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(10.375 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_Env_12) then
		pPaperWidth		:=	(4.75 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(11 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_Env_14) then
		pPaperWidth		:=	(5 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(11.5 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_CSheet) then
		pPaperWidth		:=	(17 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(22 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_DSheet) then
		pPaperWidth		:=	(22 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(34 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_ESheet) then
		pPaperWidth		:=	(34 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(44 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_Env_DL) then
		pPaperWidth		:=	110;
		pPaperHeight	:=	220;

	elseif (self.paperSize = Print_Env_C5) then
		pPaperWidth		:=	162;
		pPaperHeight	:=	229;

	elseif (self.paperSize = Print_Env_C3) then
		pPaperWidth		:=	324;
		pPaperHeight	:=	458;

	elseif (self.paperSize = Print_Env_C4) then
		pPaperWidth		:=	229;
		pPaperHeight	:=	324;

	elseif (self.paperSize = Print_Env_C6) then
		pPaperWidth		:=	114;
		pPaperHeight	:=	162;

	elseif (self.paperSize = Print_Env_C65) then
		pPaperWidth		:=	114;
		pPaperHeight	:=	229;

	elseif (self.paperSize = Print_Env_B4) then
		pPaperWidth		:=	250;
		pPaperHeight	:=	353;
	elseif (self.paperSize = Print_Env_B5) then
		pPaperWidth		:=	176;
		pPaperHeight	:=	250;
	elseif (self.paperSize = Print_Env_B6) then
		pPaperWidth		:=	176;
		pPaperHeight	:=	125;
	elseif (self.paperSize = Print_Env_Italy) then
		pPaperWidth		:=	110;
		pPaperHeight	:=	230;
	elseif (self.paperSize = Print_Env_Monarch) then
		pPaperWidth		:=	(3.875 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(7.5 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_Env_Personal) then
		pPaperWidth		:=	(3.625 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(6.5 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_Fanfold_US) then
		pPaperWidth		:=	(14.875 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(11 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_Fanfold_Std_German) then
		pPaperWidth		:=	(8.5 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(12 * CNEC_MM_PER_INCH).rounded;

	elseif (self.paperSize = Print_Fanfold_Lgl_German) then
		pPaperWidth		:=	(8.5 * CNEC_MM_PER_INCH).rounded;
		pPaperHeight	:=	(13 * CNEC_MM_PER_INCH).rounded;

	endif;
end;</source>
        <Parameter name="pPaperHeight" type="Integer" usage="output"/>
        <Parameter name="pPaperWidth" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getReportParameter" id="7442e693-6d9e-492a-8822-b0f3da711d28">
        <source>getReportParameter(pParameterName:String):CnEcReportParameter;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Get the report parameter object with the specified name and return it.
//
// Parameters:	pParameterName - The name of the report parameter.
//
// Returns:		The report parameter object, or null if the name is not found.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.allReportParameters[pParameterName];
end;</source>
        <Parameter name="pParameterName" type="String"/>
        <ReturnType type="CnEcReportParameter"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="28d7c99e-0661-4c03-b2ee-b3a9994238aa">
        <updating/>
        <source>initializeMe(	pReportName:String;
				pReportCategory:CnEcReportCategory;
				pReportDescription:String;
				pFormName:String;
				pPrinterName:String;
				pCopies:Integer;
				pIsLocalAllowed:Boolean;
				pPaperSize:Integer;
				pOrientation:Integer;
				pMarginTop:Integer;
				pMarginBottom:Integer;
				pMarginLeft:Integer;
				pMarginRight:Integer;
				pParameterArray:CnEcReportParameterArray;
				pBaseRoot:CnEcBaseRoot) updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Initialize the receiver's property values.
//
// Parameters:	Matching property parameters.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// First, set any properties...

	self.reportDescription	:=	pReportDescription;
	self.formName			:=	pFormName;
	self.printerName		:=	pPrinterName;
	self.copies				:=	pCopies;
	self.isLocalAllowed		:=	pIsLocalAllowed;
	self.paperSize			:=	pPaperSize;
	self.orientation		:=	pOrientation;
	self.marginTop			:=	pMarginTop;
	self.marginBottom		:=	pMarginBottom;
	self.marginLeft			:=	pMarginLeft;
	self.marginRight		:=	pMarginRight;
	
	self.createAllReportParameters(pParameterArray);

	// Next, set any key properties...

	self.reportName			:=	pReportName;

	// Finally, set any references...

	self.myReportCategory	:=	pReportCategory;
	self.myBaseRoot			:=	pBaseRoot;
end;</source>
        <Parameter name="pReportName" type="String"/>
        <Parameter name="pReportCategory" type="CnEcReportCategory"/>
        <Parameter name="pReportDescription" type="String"/>
        <Parameter name="pFormName" type="String"/>
        <Parameter name="pPrinterName" type="String"/>
        <Parameter name="pCopies" type="Integer"/>
        <Parameter name="pIsLocalAllowed" type="Boolean"/>
        <Parameter name="pPaperSize" type="Integer"/>
        <Parameter name="pOrientation" type="Integer"/>
        <Parameter name="pMarginTop" type="Integer"/>
        <Parameter name="pMarginBottom" type="Integer"/>
        <Parameter name="pMarginLeft" type="Integer"/>
        <Parameter name="pMarginRight" type="Integer"/>
        <Parameter name="pParameterArray" type="CnEcReportParameterArray"/>
        <Parameter name="pBaseRoot" type="CnEcBaseRoot"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="95e53d85-45e1-4090-945f-c8cb33dcb36a">
        <updating/>
        <source>updateMe(	pReportName:String;
			pReportCategory:CnEcReportCategory;
			pReportDescription:String;
			pFormName:String;
			pPrinterName:String;
			pCopies:Integer;
			pIsLocalAllowed:Boolean;
			pPaperSize:Integer;
			pOrientation:Integer;
			pMarginTop:Integer;
			pMarginBottom:Integer;
			pMarginLeft:Integer;
			pMarginRight:Integer;
			pParameterArray:CnEcReportParameterArray) updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2000 by cnwdad1
//
// Purpose:		Update the receiver's property values.
//
// Parameters:	Matching property parameters.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// First, set any properties...

	self.reportDescription	:=	pReportDescription;
	self.formName			:=	pFormName;
	self.printerName		:=	pPrinterName;
	self.copies				:=	pCopies;
	self.isLocalAllowed		:=	pIsLocalAllowed;
	self.paperSize			:=	pPaperSize;
	self.orientation		:=	pOrientation;
	self.marginTop			:=	pMarginTop;
	self.marginBottom		:=	pMarginBottom;
	self.marginLeft			:=	pMarginLeft;
	self.marginRight		:=	pMarginRight;
	
	self.createAllReportParameters(pParameterArray);

	// Next, set any key properties...

	self.reportName			:=	pReportName;

	// Finally, set any references...

	self.myReportCategory	:=	pReportCategory;
end;</source>
        <Parameter name="pReportName" type="String"/>
        <Parameter name="pReportCategory" type="CnEcReportCategory"/>
        <Parameter name="pReportDescription" type="String"/>
        <Parameter name="pFormName" type="String"/>
        <Parameter name="pPrinterName" type="String"/>
        <Parameter name="pCopies" type="Integer"/>
        <Parameter name="pIsLocalAllowed" type="Boolean"/>
        <Parameter name="pPaperSize" type="Integer"/>
        <Parameter name="pOrientation" type="Integer"/>
        <Parameter name="pMarginTop" type="Integer"/>
        <Parameter name="pMarginBottom" type="Integer"/>
        <Parameter name="pMarginLeft" type="Integer"/>
        <Parameter name="pMarginRight" type="Integer"/>
        <Parameter name="pParameterArray" type="CnEcReportParameterArray"/>
    </JadeMethod>
</Class>
