    <JadeMethod name="btnSend_click" id="0136c9df-29a4-4a08-9e0b-9d4691ac05de">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSend_click(btn: Button input) updating;
//----------------------------------------------------------------
//	Created:	26 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	err			: CM_Error;
	controller	: Object;
	objectArray	: ObjectArray;
//	answer		: Integer;
	found		: Boolean;
begin

	create objectArray transient;
	BGP_Controller.allInstances(objectArray, 100, true);
	foreach controller in objectArray do
		if controller.BGP_Controller.allRequestClassesToProcess.includes("BGP_EmailRequest") and controller.BGP_Controller.isRunning() then
			app.msgBox("There is at least one controller available to process this request.",
						"Email Tester", MsgBox_OK_Only + MsgBox_Information_Icon);
			found := true;
			break;
		endif;
	endforeach;

	if not found then
		//didn't find a running controller
		app.msgBox("A process request could not be initiated for Email.  Make sure a Background Process to action Email tasks exists and is running.",
			"Email Tester", MsgBox_OK_Only + MsgBox_Information_Icon);
		self.txtMessage.text := "No Email BGP found";	
		return;
	endif;

	app.myTrxCA.trxCreateEmailSendRequest('Test',
											self.txtTo.text, 
										  self.txtFrom.text,
										  null,
										  null,
										  self.txtSubject.text,
										  self.txtMessage.text,
										  null,
										  null,
										  null,
										  null,
										  null,
										  self,
										  app.myPassport);

	if not app.myPassport.trxCompletedOK then	
		self.txtMessage.text := "";							 
		foreach err in app.myPassport.allErrorWarnings do
			self.txtMessage.text := err.text;
		endforeach;
	else
		self.txtMessage.text := "Call completed OK";							 
		
	endif;
epilog
delete objectArray;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
