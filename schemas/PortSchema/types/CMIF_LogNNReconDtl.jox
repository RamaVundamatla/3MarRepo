        <source>logGrade(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     30 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	proLog	: CM_ProductLog;
begin
	if set then
		app.raiseSetVirtualError(Class.name, method.name);
	else
		proLog := self.myProductLog;
		if proLog &lt;&gt; null and
			proLog.myLogGrade &lt;&gt; null then
			_value := proLog.myLogGrade.code;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
