    <JadeMethod name="deleteTableObject" id="1c5ac5fb-6cb2-4dba-94bf-feb0f7dfe041">
        <updating/>
        <source>deleteTableObject()updating;
/*
	Created on 11 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	tbl 			: CM_MobTable;
	selObject 		: Object;
	row,
	result 			: Integer;
	
begin
	tbl := self.getMainTable();
	
	if tbl = null then
		app.msgBox(app.getErrorString(Function_Key_Not_Used), '', MsgBox_OK_Only);
		return;
	endif;
	
	if not tbl.selected then
		app.msgBox(app.getErrorString(Remove_Nothing_Selected), '', MsgBox_OK_Only);
		return;
	endif;
	
	selObject := tbl.getFirstSelectedObject();
	
	if selObject = null then
		app.msgBox(app.getErrorString(Remove_Nothing_Selected), '', MsgBox_OK_Only);
		return;
	endif;
	
	result := app.msgBox(app.getErrorString(Remove_item_from_table), '', MsgBox_Yes_No);
	
	if result = MsgBox_Return_Yes then
		self.deleteObjectFromTable(selObject);
	endif;
end;</source>
    </JadeMethod>
