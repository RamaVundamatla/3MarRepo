    <JadeMethod name="showReportOptions" id="42ac0c70-b84e-4397-a6d8-8ad70c692f44">
        <source>showReportOptions(_dataTable : CM_DataTable; _reportDescription : String; _hdrString : String; _optUsePrintOutTable : Boolean);
//--------------------------------------------------
// Created:	14 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	form : CMUI_ReportInitiator;
begin
	
	if _dataTable = null then
		return;
	endif;
	
	create form;
	form.setMyTerminal(self.myTerminal);
	form.setCaption(form.caption &amp; ' ' &amp; _reportDescription);
	form.myDataTable := _dataTable;
	form.reportDescription := _reportDescription[1:60];
	form.hdrString := _hdrString;
	form.optUsePrintOutTable := _optUsePrintOutTable;
	form.centreWindow;
	form.showModal;

end;</source>
        <Parameter name="_dataTable" type="CM_DataTable"/>
        <Parameter name="_reportDescription" type="String"/>
        <Parameter name="_hdrString" type="String"/>
        <Parameter name="_optUsePrintOutTable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showRequestEditForm" id="d9484b24-1dfb-4177-afa3-070d8f6daf64">
        <source>showRequestEditForm(_deliveryRequest : CM_DeliveryRequest input; wles : CM_WLEArray input; _currentWLE : CM_WorkListEntry input);
/*

Date		Who		Reason
06 June 2014	cnwer1	Initial creation PAR 34254

*/

vars
	editForm	: CMUI_RequestEditForm;
	trailerRequestForm : CMUI_RequestEditTrailerForm;
begin
	
	if _deliveryRequest = null then
		return;
	endif;
	
	if _deliveryRequest.myCargoType &lt;&gt; null then
	
		if _deliveryRequest.myCargoType.id = TI_CargoType_Container then
		
			editForm := app.loadForm(CMUI_RequestEditForm, CMUI_Assistant, false, false, true, self.myTerminal,null).CMUI_RequestEditForm;
			editForm.centreWindow;
			editForm.myDeliveryRequest := _deliveryRequest;
			editForm.myCurrentWLE := _currentWLE;
			if wles &lt;&gt; null then
				wles.copy ( editForm.allWLEs); // cnwrd1 par 31069 22.2.2013
			endif;
			editForm.show;
		elseif _deliveryRequest.myCargoType.isTrailer then
			trailerRequestForm := app.loadForm(CMUI_RequestEditTrailerForm, CMUI_Assistant, false, false, true, self.myTerminal,null).CMUI_RequestEditTrailerForm;
			trailerRequestForm.centreWindow;
			trailerRequestForm.myDeliveryRequest := _deliveryRequest;
			trailerRequestForm.show;
		else
			//epr par 34406 24/6/14
			if _currentWLE &lt;&gt; null then
				self.showRemarksForm(_currentWLE);
			else
				self.showRemarksForm(_deliveryRequest);
			endif;
		endif;
	else
		self.showRemarksForm(_deliveryRequest);
	endif;
epilog

end;</source>
        <Parameter name="_deliveryRequest" type="CM_DeliveryRequest" usage="input"/>
        <Parameter name="wles" type="CM_WLEArray" usage="input"/>
        <Parameter name="_currentWLE" type="CM_WorkListEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showResourceTypeUsageForTxn" id="16c09f4b-7589-42b3-96ac-217f961d2130">
        <source>showResourceTypeUsageForTxn( _transaction 		: CM_TITransaction;
							_masterMenuAction 	: CMUI_MenuAction;
							_toDoTaskDesc 		: CM_ToDoTaskDesc;
							_ti : CM_TrackedItem;
							_proxyUsageSet 		: CM_ResourceTypeUsageSet io;
							_addMode 			: Boolean;	// 11/01/2011 cnwar2 #26691
							_woJob				: CM_WorkOrderJob
							): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwndl1	Initial creation	CCMS MES 1006
15 Jul 2024 navbs1  CR 64901 Task 64903: UI - Show Cargo Ids in To Do Complete Thin Client

*/

vars

	form : CMUI_ResourceTypeUsageForm;
	transaction : CM_TITransaction;
	originalEdition : Integer;
	result : Integer;
	
begin

	form := app.loadForm(CMUI_ResourceTypeUsageForm, CMUI_Assistant, false, false, true, app.myPassport.myTerminal, _masterMenuAction).CMUI_ResourceTypeUsageForm;
	if form = null then
		return false;
	endif;
	
	if _transaction &lt;&gt; null then
		originalEdition := _transaction.edition;	//get the edition before we allow the user to update the resources...
	endif;

	form.setMyTransaction( _transaction, _toDoTaskDesc, _ti );
	
	// 11/01/2011 cnwar2 #26691 - load screen ready to add new resource
	if _addMode then
		form.grpResource.enabled := true;
		form.chkVoid.enabled 	 := false;
		form.cmbResourceType.setFocus();
	else
		form.grpResource.enabled := false;
	endif;	
	
	form.setMyWOJob(_woJob); 	//15.07.2024  navbs1  CR 64901 Task 64903
	form.showModal();
		
/*	if form.modalResult = IDCANCEL then	// 09 Mar 2010	NDL	Par 22820
		// user cancelled from form.
		return true;
	else */
	//06 Dec 2012	NDL	Par 30850 - User wants it back to how it was originally written..
	if form.modalResult &lt;&gt; IDOK then
		return false;
	endif;
	
	
	//single transaction - updating multiple resources.
	if _transaction &lt;&gt; null then
		transaction := _transaction;
		while true do		
			app.myTrxUA.trxUpdateResourceTypeUsageSet( transaction, originalEdition, form.allNewProxyResourceTypeUsages, form.allUpdProxyResourceTypeUsages, form.allRealResourceTypeUsagesToDel, app.myPassport);
			if app.myPassport.trxCompletedOK then
				return true;
			else
				result := app.showErrorWarningDialog(app.getErrorString(Resource_usage), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and result = IDOK then
					// there must have just been warnings that the user has acknowledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return false;
			endif;
		endwhile;
	endif;
	
	//multiple transactions and multiple resources.
	if _toDoTaskDesc &lt;&gt; null and _proxyUsageSet &lt;&gt; null then
		if not form.allNewProxyResourceTypeUsages.isEmpty then
			form.allNewProxyResourceTypeUsages.copy(_proxyUsageSet);
		endif;
	endif;

	return true;
	
epilog

	delete form;
	
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_proxyUsageSet" type="CM_ResourceTypeUsageSet" usage="io"/>
        <Parameter name="_addMode" type="Boolean"/>
        <Parameter name="_woJob" type="CM_WorkOrderJob"/>
        <ReturnType type="Boolean"/>
