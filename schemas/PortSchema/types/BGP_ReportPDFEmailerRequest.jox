<Class name="BGP_ReportPDFEmailerRequest" id="4e7ddd53-98f6-4c27-97ff-9f60e5f149f4">
    <superclass name="BGP_ReportRequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Report PDF Emailer&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ExplicitInverseRef name="myEmailTemplate" id="f70dfe31-9906-4286-b779-e2f469e4ecf8">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_EmailTemplate"/>
        <access>readonly</access>
