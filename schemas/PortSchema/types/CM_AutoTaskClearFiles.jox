        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getEntryTableViewName" id="2f8d252b-4936-41cc-b3d0-676c55852f34">
        <source>getEntryTableViewName(): String;
// -------------------------------------------
// Created 17 December 2003 by cnwdvb1
// -------------------------------------------
vars

begin
	return 'bgpAutoViewClearFiles';


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForRow" id="7e4a907e-77c1-4fc7-98ac-b3efc5d7cce1">
        <source>getValueForRow(_rowName: String; _obj : Object output): Any;
// -------------------------------------------
// Created 17 December 2003 by cnwdvb1
// -------------------------------------------
vars
	
begin
	if _rowName = ETRow_BgpAutoDirectoryPath  then
		return self.directoryPath.String;
	elseif _rowName = ETRow_BgpAutoFileMask then
		return self.fileMask;
	elseif _rowName = ETRow_BgpAutoDeleteFile then
		return self.isToDelete.Integer;
	elseif _rowName = ETRow_BgpAutoNoOfDaysOldFiles then
		return self.numberOfDaysOld.String;
	elseif _rowName = ETRow_BgpApplyToSubfolders  then
		return self.applyToSubfolders.Boolean;
	
	endif;
	return inheritMethod(_rowName, _obj);

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="48771cc0-3c73-495e-82a0-a0afae824291">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskClearFiles) updating;
// -------------------------------------------
// Created 17 December 2003 by cnwdvb1
// -------------------------------------------
vars
	
begin
	inheritMethod(_pxyAutoTask);
	self.directoryPath := _pxyAutoTask.directoryPath;
	self.fileMask := _pxyAutoTask.fileMask;
	self.isToDelete := _pxyAutoTask.isToDelete;
	self.numberOfDaysOld := _pxyAutoTask.numberOfDaysOld;
    self.applyToSubfolders := _pxyAutoTask.applyToSubfolders; //cnwgb1 31012 27.05.2015
	self.requestClassName := BGP_ClearFilesRequest.name;


end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskClearFiles"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="73aa9eb4-0a78-4240-8245-39c4432c28bf">
        <updating/>
        <source>setForUpdate(_pxyAutoTask: CM_AutoTaskClearFiles) updating;
// -------------------------------------------
// Created 17 December 2003 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(_pxyAutoTask);
	self.directoryPath := _pxyAutoTask.directoryPath;
	self.fileMask := _pxyAutoTask.fileMask;
	self.isToDelete	:= _pxyAutoTask.isToDelete;
	self.numberOfDaysOld := _pxyAutoTask.numberOfDaysOld;
    self.applyToSubfolders := _pxyAutoTask.applyToSubfolders; //cnwgb1 31012 27.05.2015    


end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskClearFiles"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="8cba03fe-7d8e-45f1-b1aa-71511117fe4c">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;
// -------------------------------------------
// Created 17 December 2003 by cnwdvb1
// -------------------------------------------
vars

begin
	if _rowName = ETRow_BgpAutoDirectoryPath then
		self.directoryPath := _value.String;
	elseif _rowName = ETRow_BgpAutoFileMask then
		self.fileMask := _value.String;
	elseif _rowName = ETRow_BgpAutoDeleteFile then
		self.isToDelete := _value.Integer.Boolean;
	elseif _rowName = ETRow_BgpAutoNoOfDaysOldFiles then
		self.numberOfDaysOld := _value.Integer;
	elseif _rowName = ETRow_BgpApplyToSubfolders then
		self.applyToSubfolders := _value.Boolean;
	else
		inheritMethod(_rowName, _value);
	endif;
end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="739d6487-578e-4b53-9c7f-5c4cd1520223">
        <source>validate();
// -------------------------------------------
// Created 17 December 2003 by cnwdvb1
// 18 Aug 2022	 navrk21	 Bug 52517: MTN - Clear Files BGP task allows users to clear entire hard drive if misconfigured
// -------------------------------------------
vars

begin
	inheritMethod();
	
	//09 May 2019	NDL	TFS 44666
	if self.fileMask.trimBlanks = null then
		app.raiseCMException(Value_require_file_mask, ETRow_BgpAutoFileMask, null);
	endif;
	// Start 18.08.2022 navrk21 TFS 52517
	if self.directoryPath.trimBlanks = null then	
		app.raiseCMException(Input_required_field_dirctPath, ETRow_BgpAutoDirectoryPath, null);			
	endif;
	// End 18.08.2022 navrk21 TFS 52517
end;</source>
    </JadeMethod>
</Class>
