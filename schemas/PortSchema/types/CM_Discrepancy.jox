<Class name="CM_Discrepancy" id="f54d6300-0974-4a09-ba09-ef86bd692e62">
    <superclass name="CM_Object"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>Responsible for recording data about a single discrepancy in the system.
Basically records text?</text>
    <PrimAttribute name="date" id="f4cb5691-725c-423e-a4dc-bf96af19fccb">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="internalText" id="a8e7452b-2edf-4bd8-9eef-755105f8011a">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="terminal" id="5247874c-d85e-4097-84f1-bb8b24785d47">
        <embedded/>
        <type name="CM_Terminal"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="text" id="d98d2f36-1061-4892-959b-d58e01acda68">
        <length>500</length>
        <embedded/>
        <virtual/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="erase" id="31252794-0186-4f21-83f1-e622eaee1e7f">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
vars
	term			: CM_Terminal;
	termDict		: CM_TerminalByCodeDict;
begin
	termDict := app.myRoot.allTerminals;
	
	exclusiveLock(self);
	//CNWHT2 - to get rid of app.getMyTerminal
	//removeDiscrep call does nothing if not found on terminal
	foreach term in termDict do 
		if not isTransient then
			term.removeDiscrepancy(self);
		endif;
	endforeach;
	
	inheritMethod(_eraseLevel);
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setInternalText" id="0e4c19d5-92a9-4e8a-b5b0-db15323824ee">
        <updating/>
        <source>setInternalText(_text : String) updating;
// ---------------------------------------------------------------------------
// Created:     26 March 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.internalText := _text;
end;</source>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
    <JadeMethod name="text" id="b5ea3b85-eb83-4caa-8c64-85cff367ed46">
        <methodInvocation>mapping</methodInvocation>
        <source>text(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     12 February 2001 by cnwdwq1
//
// Purpose: 
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	_value := self.internalText[1:499];
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
