    <JadeMethod name="setForUpdate" id="08c86202-617c-40f2-b410-05cf5aa0526f">
        <updating/>
        <source>setForUpdate(_pxyEvent: CMEVT_TrainTransaction) updating;
/*

Date		Who		Reason
11 Dec 2014	cnwer1	Initial creation PAR
23/07/2019 	JLGNS1	ChangeRequest 45575: ASPA - Train Events
08/06/2020  cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
*/

vars

begin
	inheritMethod(_pxyEvent);
	
	self.dateTimeEnd 		:= _pxyEvent.dateTimeEnd;		//ChangeRequest 45575
	self.remarks 			:= _pxyEvent.remarks;			//ChangeRequest 45575
	self.unitDescription 	:= _pxyEvent.unitDescription;	//ChangeRequest 45575
	self.myDebtor           := _pxyEvent.myDebtor;          //03/06/2020 cnwma1 TFS #49400
	if self.myTrain &lt;&gt; null then
		if self.pxyGetProxyObject &lt;&gt; null then	
			self.myTrain.causeEvent(EventTransaction_Update_Event,false,self);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_pxyEvent" type="CMEVT_TrainTransaction"/>
    </JadeMethod>
    <JadeMethod name="setMyTrain" id="44285396-a1b2-478f-aff8-ecdd81578d4e">
        <updating/>
        <source>setMyTrain(_train : CM_Train) updating;
/*

Date		Who		Reason
10 December 2014	cnwer1	Initial creation PAR

*/

vars

begin
	self.myTrain:=_train;
	if not self.isTransient and self.myTrain &lt;&gt; null then
		self.myTrain.causeEvent(EventTransaction_Create_Event,false,self);
	endif;
epilog

end;</source>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
