    <JadeMethod name="shouldAuditProperty" id="c6f315b2-168d-4c75-b1b5-91e6b5507290">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwma1	Initial creation

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_MoveServiceBroker::commodityMap.name or
		propName = CM_MoveServiceBroker::myChildQuantityMap.name or
		propName = CM_MoveServiceBroker::moveFrom.name or
		propName = CM_MoveServiceBroker::moveTo.name  
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog
end;
</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="fbc64c34-b5b0-4b0f-96c3-f3de07787684">
        <source>validateForCreate();
// TFS 2016 validate duplicate move entries
vars

begin
	if self.commodityMap.moveMap[self.moveFrom, self.moveTo] &lt;&gt; null then
		app.raiseCMException1(Move_map_exists,self.moveFrom &amp; " - " &amp; self.moveTo, null, null);
	endif;

end;
</source>
    </JadeMethod>
</Class>
