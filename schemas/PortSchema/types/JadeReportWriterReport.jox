<Class name="JadeReportWriterReport">
    <JadeMethod name="reportsOn" id="e1848d58-b648-4c78-a5e0-413b0ac623c2">
        <source>reportsOn(_path : String) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2019	jlger1	Initial creation

*/

vars
	result	: Boolean;
	pathLength	: Integer;
	queryPath	: String;
	featureColl	: MemberKeyDictionary;
	feature	: Object;
begin
	if _path = null then
		return false;
	endif;	
	
	if self.persistentReport = null then
		return false;
	endif;
	pathLength := _path.length;
	featureColl := self.persistentReport.getPropertyValue("allFeatures").MemberKeyDictionary;
	foreach feature in featureColl do
		queryPath := feature.getPropertyValue("queryPath").String;
		if queryPath.length &gt;= pathLength and
		   queryPath[1:pathLength] = _path then
			result := true;
			break;
		endif;
	endforeach;
		
		
		
	return result;
epilog

end;</source>
        <Parameter name="_path" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
