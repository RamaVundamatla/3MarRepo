<Class name="CMQF_DailyMovements">
    <JadeMethod name="setFromAgent" id="ccf010ec-8669-46dd-94ae-ebf3181de7ff">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 October 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod(_agent);

	
	if _agent.state &lt;&gt; _agent.STATE_TEMPLATE_SAVE and 
	   _agent.state &lt;&gt; _agent.STATE_TEMPLATE_EDIT then
		self.startDateTime.setDate(self.startDate);//start date already set
		self.startDateTime.setTime("00:00:00:000".Time);//start of day
	endif;
	
	if _agent.state &lt;&gt; _agent.STATE_TEMPLATE_SAVE and 
	   _agent.state &lt;&gt; _agent.STATE_TEMPLATE_EDIT then
		self.endDateTime.setDate(self.endDate);//end date already set
		self.endDateTime.setTime("23:59:59:999".Time);//end of day
	endif;
	
	
end;


</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
