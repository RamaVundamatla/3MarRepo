// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	str : String;
begin
	if self.xmlStrTblData &lt;&gt; null then
		str := self.xmlStrTblData;
	else
		str := self.tblData.getXmlStrForColumns(true);
	endif;
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
