    <JadeMethod name="uGateInReefOffPowerDuringTrans" id="ac35ad2f-ef7e-4208-8f27-216011ea4140">
        <source>uGateInReefOffPowerDuringTrans();

/*

Purpose:		Gate in a reefer off power during transit

Date			Who		Reason
21/07/2015		cnwmh5	Initial creation

*/
constants

	ContainerId					: String = "UTMDH2107A0";
	VehicleId					: String = "UTMHT7";
	
vars

	container					: CM_Container;
	vvr							: CM_VehicleVisitRecord;
	gbs							: CM_ForkLiftStack;
	ya							: CM_YardAllocation;
	
	locations 					: CM_LCArray;
	
	ts							: TimeStamp;

begin

	self.disableAllYA(true);

	container := self.getTrackedItem(ContainerId).CM_Container;
	self.deleteTrackedItem(container, false);
	
	self.deleteVehicle(VehicleId);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Trans_Power_Date_Time_Blank);
	
	self.opts.purge();
	self.opts.addAssoc("TransitOnPowerDateTime", ts);
	self.opts.addAssoc("CarriageTempC", -5);
	vvr := self.gateInContainer(VehicleId, ContainerId, "2231", "UTOP", "CHBF", self.singleGate);
	
	self.deleteVehicle(VehicleId);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Trans_Power_Date_Time_Required);
	
	self.opts.purge();
	self.opts.addAssoc("OnPowerDuringTransit", true);
	self.opts.addAssoc("CarriageTempC", -5);
	
	vvr := self.gateInContainer(VehicleId, ContainerId, "2231", "UTOP", "CHBF", self.singleGate);
		
	self.deleteVehicle(VehicleId);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Transit_DT_Must_After_Pack_DT);
	
	ts := app.actualTimeAppServer;
	ts.setTime("10:00:00".Time);
	
	self.opts.purge();
	self.opts.addAssoc("PackDate", ts.date.addDays(-1).String);
	self.opts.addAssoc("PackTime", ts.time.String);
	self.opts.addAssoc("TransitOnPowerDateTime", ts.addDays(-2));
	self.opts.addAssoc("OnPowerDuringTransit", true);
	self.opts.addAssoc("CarriageTempC", -5);
	self.opts.addAssoc("ExpectErrors", self.expectedTrxErrors.size &gt; 0);	
	vvr := self.gateInContainer(VehicleId, ContainerId, "2231", "UTOP", "CHBF", self.singleGate);
	
	self.deleteVehicle(VehicleId);
	
	self.opts.purge();
	self.opts.addAssoc("WITHPOWER", true);
	gbs := self.addForkLiftStack("MDHGBG", 5, 5, 4);
	
	create locations transient;
	locations.add(gbs.allGridControllersByRowColumn[1, 4]);
	
	self.deleteYA("MDH2231UTOPCHBF");
	ya := self.addYAMDH("MDH2231UTOPCHBF", YACriteriaType_ISO, "2231", YACriteriaType_OperatorItem, "UTOP", 
		YACriteriaType_Commodity, "CHBF", locations, null);
	self.assertNotNull(ya);
	
	self.opts.purge();
	self.opts.addAssoc("PackDate", ts.date.addDays(-1).String);
	self.opts.addAssoc("PackTime", ts.time.String);
	self.opts.addAssoc("AllowableTimeOffPower", 20);
	self.opts.addAssoc("CarriageTempC", -5);
	vvr := self.gateInContainer(VehicleId, ContainerId, "2231", "UTOP", "CHBF", self.singleGate);
	self.assertNotNull(vvr);
	container := self.getTrackedItem(ContainerId).CM_Container;
	self.assertNotNull(container);
	
	self.workVehicle(vvr);
	
	
	ts := ts.addMinutes(5);
	//ts := app.cnGetServerTime().addMinutes(5);
	self.updateTIConnection(container, true, true, ts, null);
	self.assertEqual(container.getRemainingTimeOffPower(), -0.06.Decimal);
	
epilog
	
	self.disableAllYA(false);
	
	delete locations;

end;</source>
    </JadeMethod>
    <JadeMethod name="uGateOutPerformace" id="849b8753-96d5-4402-95d3-15b1c698487a">
        <source>uGateOutPerformace();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2021	navndl1	Initial creation	TFS 51443
16 Feb 2024	navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit

*/

constants

	CONT1 : String = "PERF7654321";
	CONT2 : String = "PERF2345678";
	TRUCK : String = "PERFTRUK";
	
vars

	ti : CM_Container;
	vvr : CM_VehicleVisitRecord;
	pxyVVR : CM_VehicleVisitRecord; 
	gateEntity : CMGTE_Entity;
	gateName : String;
//	myProfiler : JadeProfiler;

begin

//	myProfiler := process.profiler;

	self.setTerminalConfig(DeferredCharging, true);

	self.deleteContainer( CONT1 );
	self.deleteContainer( CONT2 );
	self.deleteVehicle( TRUCK );
	
	gateName := self.getTerminal.getDefaultGate_IN().name;
	
	ti := self.addContainer(CONT2, operator, "2200", "MT", TI_IMEX_STATUS_STORAGE).CM_Container;
	self.move(ti, bs.myLocationsController);
	
	//create vvr
	vvr := self.addVehicleVisitRecord( TRUCK, "", null, gateName);
	//create inward
	gateEntity := self.createGateEntity(vvr, "CONT", CONT1, "2200", operator.code, "MT", 1);
	//create outward and pass the vvr to it so we get both jobs on one visit.
	self.opts.addAssoc("VVR", vvr);
	self.gateOutContainer( TRUCK, "", null, ti, true, gateName , null);
	
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
		
	self.moveVehicleToYard(vvr.vehicle);
	
	self.workVehicle(vvr);
	
/*	if myProfiler.isProfiling then
		myProfiler.reset;
		myProfiler.stop;
	endif;

	myProfiler.reportMethodSize := false;
	myProfiler.reportActualTime := true;
	myProfiler.reportCacheStatistics := false;
	myProfiler.reportLoadTime := false;
	myProfiler.reportTotalTime := true;
	myProfiler.reportStatistics := false;
	myProfiler.methodCount := 6000;
	
	myProfiler.start; */
	
	//app.myTrxDA.trxRoadExit( vvr.myRoadJob, app.myPassport);			//16.02.2024 navnk30 #62414
	app.myTrxDA.trxRoadExit( vvr.myRoadJob, null, app.myPassport);		//16.02.2024 navnk30 #62414
		

epilog

/*	if myProfiler &lt;&gt; null and myProfiler.isProfiling then
		myProfiler.stop;
		myProfiler.report;
	endif; */

	delete pxyVVR;

end;</source>
    </JadeMethod>
    <JadeMethod name="uReceiveByVolume" id="3d66d478-0464-494f-b3ac-fa70a0ba74a6">
        <updating/>
        <source>uReceiveByVolume() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
