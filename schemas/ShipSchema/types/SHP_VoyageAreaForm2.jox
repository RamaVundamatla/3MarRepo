    <JadeMethod name="setupForm" id="b75d3f48-19fd-42eb-a3ef-e95d060b0e70">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	terminal : CM_Terminal;

begin
	// cnwrl1 236/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	// The user can access the summarise functionality only if they have at least view security role.
	self.bAllowSummaryDefn	:= app.myCurrentUserCan( self.myTerminal, PmSummaryDefView );
	
	self.setMyTerminal(app.getMyTerminalDO_NOT_USE); //+ cnwmd1, Par 20643
	
	self.positionScale := 10;
	self.picCargo.ignoreSkin := true;
	self.picCargo.borderStyle := Frame.BorderStyle_None;
	self.btnTranship.bubbleHelp := "Make Tranship";
	
	// do this to ensure that frmToolbar2 sits below
	// frmToolbar on the form
	self.frmToolbar2.alignContainer := Frame.AlignContainer_None; 
	self.frmToolbar.alignContainer := Frame.AlignContainer_Top; 
	self.frmToolbar2.top := 20;
	self.frmToolbar2.alignContainer := Frame.AlignContainer_Top; 

	create self.myBayDrawingController transient;
	self.myCurrentDrawingController := self.myBayDrawingController;
	
	create self.myConfig as CMIF_ConfigUserVoyagePlanning transient;
	self.myConfig.setFromPersistentData(app.getMyUser);
	self.myBayDrawingController.setConfig(self.myConfig.CMIF_ConfigUserVoyagePlanning);

	self.myDrawingFrame := self.frmScrollBackgrd;

	self.showToolbar := true;
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.frmBay.enableEvent("mouseMove", false);

	self.doInitialiseSDF();
	self.myBayDrawingController.zeroFilleSeqNum := self.myTerminal.getConfig(ShipRemoveLeadingZeros).Boolean;

	inheritMethod();

	self.setupFormInit();

	self.mnuWorkDisplayMain.visible := true;
	self.doMnuWorkDisplayViewVisible(false);

	self.setupBtnPens();
	self.setupSelectVoyageFrame();
	self.setupVoyageCombo(self.cmbVoyage, false);
	self.setupVoyageCombo(self.cmbBayVoyage, true);
	self.setupFrmVoyGlobalMode();
	
	self.cmbVoyage.filterIgnore := true; // ### DEFECT 56557 17FEB2023 NAVAB1
	self.cmbBayVoyage.filterIgnore := true; // ### DEFECT 56557 17FEB2023 NAVAB1
	self.cmbVoyage.style := ComboBox.Style_DropDownList; // ### DEFECT 56557 17FEB2023 NAVAB1
	self.cmbBayVoyage.style := ComboBox.Style_DropDownList; // ### DEFECT 56557 17FEB2023 NAVAB1

/*
	if self.myBayDrawingController.myConfig.shipSelectByHolds then
		self.showHoldSelector();
		self.mnuGridLayout.visible := true;
		self.mnuWorkDisplayLayout.visible := true;
	else
		self.showSelectBays(0,0);
		self.mnuGridLayout.visible := false;
		self.mnuWorkDisplayLayout.visible := false;
	endif;
*/
	self.isSelectorCapable := true;
	
	terminal := self.myTerminal;
	self.isSameTwinSeqReq := terminal.getConfig(SameSeqNumberTwinLift).Boolean;
	self.allocateCraneLane:= terminal.getConfig(AllocateCraneLane).Boolean;
	
	//self.isCCPButtonActivated := false;
	app.addPlanningForm(self); // PAR 27749	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupFormInit" id="faba190c-d9da-4e67-bea7-5284bbda5a03">
        <updating/>
        <source>setupFormInit() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// Purpose:		
// ---------------------------------------------------------------------------
// 12/10/2009	cnwmh5		PAR 21297		Remove the hardcoding of the width 
//											and don't centre the window so that
//											the window restores to its previous 
//											value	
// 20/11/2018 jlgrh7 TFS #41374 POL - [Fwd: ##RE-9144## : Lori 837R - Archive with active jobe]
// ---------------------------------------------------------------------------
vars
	mnuChild : MenuItem;
	regKeys : IntegerArray;
	tmpStr : String;
begin
	
	self.moveModeForm := PLANNING_MODE;

	// FORM SETTINGS
	tmpStr := $VoyagePlanning;
	tmpStr := tmpStr.cnEcRemoveSubstring("&amp;");
	self.setCaption(tmpStr);
	self.mnuWorkMain.caption := $VoyagePlanning;
	self.setNavigatorHeading(self.caption); // NAVIGATOR
	self.myBayDrawingController.drawHoldVertical := false;
	self.mnuGridHideMacro.visible := true;
	self.myDrawingFrame.visible := true;
	///self.width := 775;			// 12/10/2009 mhill #21297 - Remove hardcoding of width
	///self.centreWindow();			// 12/10/2009 mhill #21297 - Remove
	self.fldBtns.top := 3000;
	self.mnuGridSelectCargo.caption := "&amp;Select Cargo For Discharge...";

	// ######### BUILD COMBOS
	self.doCmbCargoTypeBuild();
	self.doCmbCommodityBuild();
	
	// ######### SUNDRY CONTROLS
	self.frmBay.borderStyle := BorderStyle_None;
	self.frmStatusLine.doMenuMoveClick(CMUI_GridAreaStatusLine.MENU_MOVE_PLAN);
	if not self.myTerminal.getConfig(ShipImportTaskOptions).Boolean then
		self.btnImportTasks.visible := false;
		self.btnCustomsEDI.visible := false;
		self.mnuOnshipTasks.visible := false;
		self.chkImportTasks.visible := false;
		self.chkCustomsEDI.visible := false;
	endif;

	// ####### SPLITTERS
	if self.myTerminal.getConfig(ShowCargoPicture).Boolean then
		//self.sptBottom.setLeftToRightRatioAndResize(85);
		self.dkbCargoPic.visible := true;
	else
		self.dkbCargoPic.visible := false;
	endif;

	// ### INHERITED MENUS
	self.setDisplayMenuForProposed();
	self.mnuWorkMain.visible := true;
	self.mnuWorkMain.enabled := true;
	self.mnuWorkRemarks.visible := true;
	self.mnuWorkRemarks1.caption := "Voyage Remarks";
	self.mnuWorkRemarks2.caption := "Bay Remarks";
	self.btnSelBayTwin.bubbleHelp := self.BTN_SHOW_TWIN;
	
	self.mnuGridFlipH.visible := true;
	self.mnuGridFlipH.caption := "Flip Bay Horizontal/Vertical"; //self.doBtnToolBarBubbleHelp(self.BTN_HOLDDRAWMODE);
	self.mnuGridFlipV.visible := true;
	self.mnuGridFlipV.caption := "Flip Ship Port/Starboard"; //self.doBtnToolBarBubbleHelp(VIEW_FLIP_H);

	self.doEnableVoyage(false);

	self.enableDisableLargeOptions();	// 23/11/17 MAP TFS7494
	
	app.mousePointer := Window.MousePointer_Default;

	self.beginNotification(self, EVENT_PLANNING_GET_NEXT_IN_SEQ, Response_Continuous, null);
	self.beginClassNotification(CM_Voyage, false, self.myTerminal.getTerminalEvent(EVENT_VOYAGE_BERTHING_CHANGED), Response_Continuous, null);
	self.beginClassNotification(CM_Voyage, false, self.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_UPDATE), Response_Continuous, null);									//+TFS41374

	// All key strokes are turned off by default. This turns them back on and includes the H key. H for Help.
	create regKeys transient;
	regKeys.add(CMUI_Key_F4);
	regKeys.add(CMUI_Key_F12);
	regKeys.add(CMUI_Key_F9); // Magnify
	regKeys.add(CMUI_Key_Esc);
	self.addRegisteredKeys(regKeys);

	self.backColor := self.myDrawingFrame.backColor;
	
	self.myBayDrawingController.showHoldID := self.myConfig.CMIF_ConfigUserVoyagePlanning.shipShowHoldId;
/*
	if self.myConfig.CMIF_ConfigUserVoyagePlanning.shipSelectByHolds then
		self.selectMode := self.SelectModeHold;
		self.mnuBaySelHolds.checked := true;
	elseif self.myConfig.CMIF_ConfigUserVoyagePlanning.shipSelectByBayMulti then
		self.mnuBaySelMulti.checked :=true;
		self.selectMode := self.SelectModeMulti;
	else
		self.selectMode := self.SelectModeOne;
		self.mnuBaySelOne.checked := true;
		self.myConfig.CMIF_ConfigUserVoyagePlanning.shipSelectByBayOne := true;
		app.myTrxUA.trxUpdateUserConfig(app.getMyUser, self.myConfig, app.myPassport);
	endif;
	*/
epilog
	delete regKeys;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupFrmVoyGlobalMode" id="e7d32cc4-2279-4f5f-bb25-ff5245c9c084">
        <source>setupFrmVoyGlobalMode();
//----------------------------------------------------------------
//	Created:	06 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
constants
	FrameHeight	: Real = 100;
begin
/*
	self.frmVoyGlobalMode.height := FrameHeight;
	
	self.lblGlobalView.move(5, 0, 150, 20);
	self.lblGlobalView.fontBold := true;
	
	self.optActualView.move(7, 23, 150, 20);
	self.optProposedView.move(7, 45, 150, 20);
	
	self.btnGlobViewQuit.top := FrameHeight - 35; 
	self.btnGlobViewOK.top := self.btnGlobViewQuit.top;
	self.btnGlobViewOK.left := self.btnGlobViewQuit.left - (self.btnGlobViewOK.width + 3);
	self.btnGlobViewOK.caption := "&amp;View";
	self.btnGlobViewQuit.caption := "&amp;Close";
	
	*/
	
	self.frmVoyGlobalMode.height := 160;
