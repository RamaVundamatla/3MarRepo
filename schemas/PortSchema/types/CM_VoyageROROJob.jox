    <JadeMethod name="getJobCrane" id="56aaceec-d007-49ec-ba6f-f6989a01bf30">
        <source>getJobCrane(): CM_Crane;
//25 November 2011	cnwdw1	
// 28738
vars

	js : CM_VoyageJobSheet;
	iter : Iterator;
	crane : CM_Crane;

	
begin

	//return self.myTerminal.machines[self.craneId].CM_Crane;
	//13 June 2012	NDL	Par 29690
	if self.craneId &lt;&gt; null then
		return self.myTerminal.machines[self.craneId].CM_Crane;
	else
		iter := self.myVoyage.allJobSheets.createIterator;
	
		while iter.next( js ) do
			crane := js.getMyCrane;
			if crane &lt;&gt; null then
				return crane;
			endif;
		endwhile;
	endif;
	
	return null;
	
epilog

	delete iter;
	
end;</source>
        <ReturnType type="CM_Crane"/>
    </JadeMethod>
    <JadeMethod name="getJobWorkPoint" id="6936e7ae-6f3d-4d22-b9bb-3ea995617690">
        <source>getJobWorkPoint():CM_WorkPoint;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 June 2012	cnwndl1	Initial creation	Par 29690

*/

vars

	js : CM_VoyageJobSheet;
	iter : Iterator;
	wp : CM_WorkPoint;

begin

	if self.craneId &lt;&gt; null then
		return self.myTerminal.allWorkPointsByCode[self.craneId].CM_WorkPoint;
	else
		if not self.myVoyage.allJobSheets.isEmpty then
			iter := self.myVoyage.allJobSheets.createIterator;
		
			while iter.next( js ) do
				wp := js.getMyWorkPoint;
				if wp &lt;&gt; null then
					return wp;
				endif;
			endwhile;
			
		endif;
	endif;
	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="CM_WorkPoint"/>
    </JadeMethod>
