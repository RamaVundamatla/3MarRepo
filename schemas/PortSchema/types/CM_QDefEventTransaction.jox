    <JadeMethod name="createProperties" id="992238f1-dccd-44a1-8325-607fc4230338">
        <source>createProperties();
/*  CCMS 1262 CM_EventTransaction properties for selector queries

*** Changes ***
Date		Name		TFS#		Description
==========	========	=========	====================================================================
25/09/2018	jlgka1		TFS 40200 	Add User with list to use CM_QStrUserProperty.
03/06/2020  cnwma1 		ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
*/
vars
	qProp		: CM_QueryProperty;
begin
	inheritMethod();		// 'Terminal', myTerminal
	
	// CM_EventTransaction properties
	create qProp as CM_QDateProperty persistent;
	qProp.set('Transaction Date', CM_EventTransaction::dateTime.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	create qProp as CM_QRefEventTypeProperty persistent;
	qProp.set('Transaction Type', CM_EventTransaction::myEventType.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);

	create qProp as CM_QRefDebtorMethod persistent;
	qProp.set('Debtor', CM_EventTransaction::getDebtorForSelector.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	create qProp as CM_QStringMethod persistent;
	qProp.set('Invoice Number', CM_EventTransaction::getInvoiceNumber.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);

	create qProp as CM_QBooleanProperty persistent;
	qProp.set('Is No Charge', CM_EventTransaction::noCharge.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	create qProp as CM_QStringProperty persistent;
	qProp.set('User Code', CM_EventTransaction::userCode.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	// jlgka1 TFS 40200 28/09/2018 --&gt;
	create qProp as CM_QStrUserMethod persistent;
	qProp.set('User List', CM_EventTransaction::getUserCode.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	// jlgka1 TFS 40200 28/09/2018 &lt;--
	
	create qProp as CM_QRefVoyageMethod persistent;
	qProp.set('Voyage', CM_EventTransaction::getVoyage.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
	
	create qProp as CM_QStringMethod persistent;
	qProp.set('Voyage Group Code', CM_EventTransaction::getVoyageGroupCode.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);
end;</source>
    </JadeMethod>
    <JadeMethod name="getSelectorVisibleColumns" id="fe53382f-f7e2-437c-940f-315f65b4f755">
        <source>getSelectorVisibleColumns(_sa : StringArray input);
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries - hard-coded list equivalent to CM_CargoBOLType allSelectorVisibleColumns
vars
	qProp	: CM_QueryProperty;
begin
	_sa.clear();

	qProp := self.allQueryProperties[CM_EventTransaction::dateTime.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CM_EventTransaction::myEventType.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CM_EventTransaction::getDebtorForSelector.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CM_EventTransaction::getInvoiceNumber.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CM_EventTransaction::userCode.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CM_EventTransaction::noCharge.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;
	qProp := self.allQueryProperties[CM_EventTransaction::getVoyage.name];
	if qProp &lt;&gt; null then
		_sa.add(qProp.propertyName);
	endif;

end;
</source>
        <Parameter name="_sa" type="StringArray" usage="input"/>
    </JadeMethod>
</Class>
