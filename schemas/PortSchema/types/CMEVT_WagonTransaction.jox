//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 05 Dec 2024 navma1	 navma1 MTN-33567 MTN - Charges Are Not Created When adding Events
// ---------------------------------------------------------------------------

vars
	theTrain : CM_Train;
begin
	theTrain := self.myTrain;
	if theTrain = null and self.myWagon &lt;&gt; null then	  //05.12.2024 navma1 #MTN-33567
		theTrain := self.myWagon.myTrainInwards;
