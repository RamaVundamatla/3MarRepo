<CollClass name="PatchDictionaryByPatchRelease" id="cad0dd99-3464-4b0f-b02e-982da610371c">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="Patch"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="HotFixesCommonSchema"/>
    <MemberKey>
        <property name="Patch::patchNo"/>
    </MemberKey>
    <MemberKey>
        <keyPath>
            <ExplicitInverseRef name="Patch::myRootHotFixes"/>
        </keyPath>
        <property name="RootHotFixes::releaseVersionNo"/>
    </MemberKey>
</CollClass>
