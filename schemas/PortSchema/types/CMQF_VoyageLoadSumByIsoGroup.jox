<Class name="CMQF_VoyageLoadSumByIsoGroup" id="df80ec84-fe14-4779-ac72-18262a27d46a">
    <superclass name="CMQF_VoyageSummary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="filterForLoaded" id="5537b241-95b5-43bc-8082-a84730fb3be9">
        <updating/>
        <source>filterForLoaded(_voySummaryDict : CMIF_VoyageSumLoadByValueDict input; _passport : CM_Passport) protected, updating;
// ---------------------------------------------------------------------------
// Created:     11 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tiDict 				: CM_TIByCargoTypeIdDict;
	ti					: CM_TrackedItem;
	iter				: Iterator;
	breakOut			: Boolean;
	querySelf			: CMQF_VoyageLoadSumByIsoGroup;
	summaryObj			: CMIF_VoyageSummary;
	loadPortCode		: String;
	terminal			: CM_Terminal;
begin

	querySelf := self;
	if self.getMyVoyage = null then
		app.raiseCMException1(ERR_INVALID_VOYAGE, 'NULL', null, null);
		return;
	endif;
	tiDict := self.getMyVoyage.allOnshipTIsByCargoTypeId;
	iter := tiDict.createIterator;
	tiDict.startKeyGeq(TI_CargoType_Container, null, iter);
	//assume this is always run for a single terminal
	foreach terminal in self.allTerminals do
		self.allFilterLoadPorts.add(terminal.getConfig(PortDestCode).String.trimBlanks);
	endforeach;
		
	while iter.next(ti) do
		if ti.cargoType &lt;&gt; TI_CargoType_Container then
			break;
		endif;
		
		if ti.isChild then
			continue;
		endif;
		
		if not querySelf.checkStatusIncludesObject(ti, _passport, breakOut) then	
//		if not querySelf.includesObject(ti, _passport, breakOut) then
			continue;
		endif;
		
//		if breakOut then
//			return;
//		endif;
		
		summaryObj := querySelf.getSummaryObject(_voySummaryDict, ti);
		
		if summaryObj &lt;&gt; null then
			summaryObj.totalSelfForLoadSumByIsoGroup(ti.CM_Container);
		endif;
		
//		if querySelf.useTotalSummaryObject then
//			summaryObj := querySelf.getSummaryObjectTotal(_voySummaryDict, ti);
//			if summaryObj &lt;&gt; null then
//				summaryObj.totalSelf(ti.CM_Container);
//			endif;
//		endif;
	endwhile;
	
	
epilog
	delete iter;	
end;</source>
        <access>protected</access>
        <Parameter name="_voySummaryDict" type="CMIF_VoyageSumLoadByValueDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="01d716e0-dc29-416c-824e-0033dbbb8db9">
        <updating/>
        <source>filterObjects(_collection : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	voySummaryDict		: CMIF_VoyageSumLoadByValueDict;


begin
	if not _collection.isKindOf(CMIF_VoyageSumLoadByValueDict) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid collection type for query method');
		return;
	endif;

	voySummaryDict := _collection.CMIF_VoyageSumLoadByValueDict;
	self.createPreDefinedSummaryObj(voySummaryDict);
	self.initFields();


//	if self.myVoyage = null then
//		self.filterForDateRange(voySummaryDict, _passport);
//	elseif self.actualProposedOption = self.MODE_OPT_PROPOSED then
//		self.filterForProposed(voySummaryDict, _passport);
//	else
		self.filterForLoaded(voySummaryDict, _passport);	 
//	endif; 


end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getSummaryObject" id="55261494-14d5-40a6-a636-465d4f439217">
        <source>getSummaryObject(_voySummaryDict : CMIF_VoyageSumLoadByValueDict input; 
					_ti : CM_TrackedItem) : CMIF_VoyageSummary;
// ---------------------------------------------------------------------------
// Created:     01 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	summaryObj			: CMIF_VoyageSummary;
	key1,
	key2,
	key3				: String;
	
		
begin
//	if _predefinedKey1 &lt;&gt; null then
//		key1 := _predefinedKey1;
//	else
//		key1 := self.getKeyFromTI(self.orderKey1, _ti);
//	endif;
	
//	if _predefinedKey2 &lt;&gt; null then
//		key2 := _predefinedKey2;
//	else
//		key2 := self.getKeyFromTI(self.orderKey2, _ti);
//	endif;
	
//		key3 := self.getKeyFromTI(self.orderKey3, _ti);
//	endi
	
	key1 := _ti.operatorCode.trimBlanks;
	
	key2 := _ti.isoTypeGroup;

	key3 := _ti.dischargePort.trimBlanks;

	
//	elseif _orderKey = self.ORDERED_BY_LOADPORT then
//		if _ti.loadPort.trimBlanks = null then
//			return 'No Load Port';
//		else
//			return _ti.loadPort.trimBlanks;		
//		endif;
		
	
	summaryObj := _voySummaryDict[key1, key2, key3];
		
	if summaryObj = null then
		create summaryObj transient;
		summaryObj.keyValue1 := key1;
		summaryObj.keyValue2 := key2;
		summaryObj.keyValue3 := key3;
		_voySummaryDict.add(summaryObj);
	endif;

	return summaryObj;

end;</source>
        <Parameter name="_voySummaryDict" type="CMIF_VoyageSumLoadByValueDict" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CMIF_VoyageSummary"/>
    </JadeMethod>
    <JadeMethod name="initFields" id="d3946f07-98b6-404f-8a85-3775308ed83e">
        <updating/>
        <source>initFields() updating;
// ---------------------------------------------------------------------------
// Created:     06 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
		
	self.doFilterLoadPorts := true;
end;</source>
    </JadeMethod>
</Class>
