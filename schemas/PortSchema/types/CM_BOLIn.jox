    <JadeMethod name="removeTIs" id="bdc219d4-ea1b-445e-a415-c8c37f3f992e">
        <updating/>
        <source>removeTIs(_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 28 August 2002 By: cnwgd1
//22.Aug.2023 navsp1 TFS Bug 59872, Restrict deleting the TI if it assigned to multiple Work Orders
//--------------------------------------------------------------
vars
	ti 			: CM_TrackedItem;
begin
	if self.bolType = BOLType_Log
	or ((self.bolType = BOLType_GeneralDocket or self.bolType = BOLType_GeneralBillOfLading) and self.transportMode = TI_TRANSMODE_SHIP) then
		foreach ti in self.allTrackedItems do			
			if ti.isAssignedToMultipleWO(null) then
				continue;
			endif;
			ti.erase(NORMAL_ERASE);
		endforeach;
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCusCarDetails" id="4d342776-5c2a-405c-8aeb-a61d94e11bfe">
        <updating/>
        <source>setCusCarDetails(_number 	: String;
					_voyage : CM_Voyage;
					_operator : CM_Operator) updating;
/*
----------   ----------  --------------------------------------------------
Created:	29 September 2006 By cnwth2

Purpose:	This was written as a means to bypass creating an udate controller,
			to set a transient proxy BOL, to in turn set details on the persistent 
			object. Validation already been done so just need to set persistent data here

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
29 Nov 2013  cnwkpd1	 PAR #33107 - Docket number changes corrupting dictionary keys

*/

vars

begin
//	self.number 		:= _number;
	self.setNumber(_number);			// PAR #33107
	self.bolType 		:= BOLType_GeneralBillOfLading;
	self.myTerminal 	:= app.getMyTerminalDO_NOT_USE();
	self.myVoyage		:= _voyage;
	self.myOperator		:= _operator;
	self.transportMode	:= TI_TRANSMODE_SHIP;
	
end;


</source>
        <Parameter name="_number" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="459fa95a-5613-446a-a9d9-2465b8a2722e">
        <updating/>
        <source>setForCreate(_pxyBOL: CM_BOL; _passport: CM_Passport input) updating;
// 27/01/2010 cnwjre1, to get voyage set for on-ship cargo BOL creation
vars

begin
	self.myVoyage := _pxyBOL.CM_BOLIn.myVoyage;

	inheritMethod(_pxyBOL, _passport);
	
	//05 May 2014	NDL	Par 34034
	if not self.isTransient then
		if _passport.noErrors then
			self.checkForCargoWithBolNumOnly( _passport );
		endif;
	endif;
	
end;
</source>
        <Parameter name="_pxyBOL" type="CM_BOL"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="0e7a20c4-a9bf-4654-930d-6ec4d286fae5">
        <updating/>
        <source>setForUpdate(_pxyBOL: CM_BOL; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     23 September 2002 by cnwrs2
// ---------------------------------------------------------------------------
vars
	
begin
	self.myVoyage := _pxyBOL.CM_BOLIn.myVoyage;

	inheritMethod(_pxyBOL, _passport);

	//05 May 2014	NDL	Par 34034
	if not self.isTransient then
		if _passport.noErrors then
			self.checkForCargoWithBolNumOnly( _passport );
		endif;
	endif;
	
	if _passport.noErrors then
		self.updateTIsFromBOL(_passport);		
	endif;
end;</source>
        <Parameter name="_pxyBOL" type="CM_BOL"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateBookingRefItems" id="28f05a2a-242c-4dfd-b0de-244b160bf435">
        <updating/>
        <source>setForUpdateBookingRefItems(_proxyBOL : CM_BOL;
							_allNewBOLDtlProxies : CM_ObjectArrayActual input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2008	cnwer1	Initial creation

*/

vars
	pxyBOLDtl,
	realBOLDtl,
	newBOLDtl: CM_BOLDtl;
	deleteBOLDtls : CM_BOLDtlSet;
begin
	//all current booking ref items
	create deleteBOLDtls transient;
	 self.allBOLDtls.copy(deleteBOLDtls);
	foreach pxyBOLDtl in _proxyBOL.allBOLDtls do
		realBOLDtl := app.myProxyManager.getRealObject(pxyBOLDtl).CM_BOLDtl;
	
		if realBOLDtl = null then
			//create it 
			create realBOLDtl persistent;
			newBOLDtl.setForCreate(pxyBOLDtl, self);
			app.myProxyManager.createProxyLink(newBOLDtl, pxyBOLDtl);
			_allNewBOLDtlProxies.add(pxyBOLDtl);
			
			//newBookingRefItem.setCutoffTS();				// 18/06/2009 cnwar2 #20036
			//newBookingRefItem.setEarliestReceivalTS();		// 18/06/2009 cnwar2 #20036
		else
			//update it remove from delete set
			realBOLDtl.setForUpdate(pxyBOLDtl,self);
			deleteBOLDtls.removeIfPresent(realBOLDtl);
			
			//realBookingRefItem.setCutoffTS();				// 12/06/2009 cnwar2 CCMS1040/#19796
			//realBookingRefItem.setEarliestReceivalTS();		// 12/06/2009 cnwar2 CCMS1040/#19796
		endif;
				
	endforeach;
	
	foreach realBOLDtl in deleteBOLDtls do
		realBOLDtl.validateForDelete();
	endforeach;
	deleteBOLDtls.purge;
	
epilog
	delete deleteBOLDtls;

end;</source>
        <Parameter name="_proxyBOL" type="CM_BOL"/>
        <Parameter name="_allNewBOLDtlProxies" type="CM_ObjectArrayActual" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateGeneralDocket" id="3bef0460-1ffb-455b-8f07-c2ba6303f2d8">
        <updating/>
        <source>setForUpdateGeneralDocket(_pxyBOL : CM_BOLIn;  _cmifBOLIn: CMIF_BOLIn; _passport : CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	11 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	savePlannedLC	: CM_LocationsController;
	tiUpdateCntrl	: CMIF_TIUpdateController;
	weightChanged 	: Boolean;
	theTIs			: CM_TISet;
begin

	self.raiseExceptionIfTransient(method);
	_pxyBOL.raiseExceptionIfNotProxy(method);
	
	if self.weightNet &lt;&gt; _pxyBOL.weightNet then
		weightChanged := true;
	endif;

	self.setFromProxy(_pxyBOL, _passport);

	//always 'unarchive' or 'unrepack' the status if they create or update
	self.status			:= BOL_STATUS_NORMAL;

	create theTIs transient;

	self.setTIsForUpdateGeneralCargo(_cmifBOLIn, _passport);

	if _pxyBOL.myExtension &lt;&gt; null then
		if self.myExtension = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Persistent ext does not exist for ' &amp; self.String);
			return;
		elseif _pxyBOL.myExtension.class &lt;&gt; self.myExtension.class then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Persistent ext class (' &amp;
				self.myExtension.class.name &amp; ') not same as proxy ext class (' &amp;
				_pxyBOL.myExtension.class.name &amp; ')');
			return;
		endif;
		self.myExtension.setForUpdate(_pxyBOL.myExtension);
		if weightChanged then
			tiUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
			self.myExtension.setWeightForLogs(tiUpdateCntrl, _passport);
		endif;
	else
		if self.myExtension &lt;&gt; null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Transient ext does not exist for ' &amp; self.String);
			return;
		endif;
	endif;

epilog
	if tiUpdateCntrl &lt;&gt; null then
		delete tiUpdateCntrl;
	endif;
	delete theTIs;
end;</source>
        <Parameter name="_pxyBOL" type="CM_BOLIn"/>
        <Parameter name="_cmifBOLIn" type="CMIF_BOLIn"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromProxy" id="6c3d0b21-e27e-4d0e-a113-bed05a5b619f">
        <updating/>
        <source>setFromProxy(_pxyBOL: CM_BOLIn; _passport : CM_Passport input) updating, protected;
//--------------------------------------------------------------
//Created: 23 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	pxyDocketError, 
	persistentDocketError : CM_DocketError;
	
begin

	inheritMethod(_pxyBOL, _passport);

	self.setLoggingOrganisation(_pxyBOL.getLoggingOrganisation());//#cnwdz2	 CCMS 1108 par22177 

	self.loggingOperation		:= _pxyBOL.loggingOperation;
	self.opid 					:= _pxyBOL.opid;
	self.unloadPoint			:= _pxyBOL.unloadPoint;
	self.myVoyage 				:= _pxyBOL.myVoyage;
	
	
	// #24817 - this code manages docket errors corectly
	if _pxyBOL.allDocketErrors.isEmpty then	// it means no docket errors from UI screen
		self.allDocketErrors.purge();
		
	else	// it means there is a docket error either created or updated
	
		pxyDocketError := _pxyBOL.allDocketErrors.first;	//getting an existing proxy docket error

		if not self.allDocketErrors.isEmpty() then	// real docket exists already - this is UPDATE
			persistentDocketError := self.allDocketErrors.first;
		else										//real docket was empty - this is CREATION
			create persistentDocketError as CM_DocketError persistent;
			persistentDocketError.setMyBol(self);
		endif;	
		
		//Now, real docket error exists - can update it 
		persistentDocketError.setMyDocketErrorType(pxyDocketError.myDocketErrorType);
		persistentDocketError.setForUpdate(pxyDocketError);
		
	endif;
	
	// CCMS1089. Docket Correction - Log Docket has been matched today. We can edit it today still.
	// origLocationControllerId and origTerminalAreaId &lt;&gt; null after matching Log Docket
	if _pxyBOL.isMatchedTodayForDocketCorrect() then
		self.origLocationControllerId	:= _pxyBOL.origLocationControllerId;
		self.origTerminalAreaId			:= _pxyBOL.origTerminalAreaId;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_pxyBOL" type="CM_BOLIn"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
