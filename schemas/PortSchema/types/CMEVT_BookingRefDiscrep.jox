    <JadeMethod name="hasDiscrepancies" id="d805fd1f-85f3-46fe-be2a-aa44300c3228">
        <source>hasDiscrepancies():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars

	bookingRefDiscrepFieldValue : CM_BookingRefDiscrepFieldValue;
	
begin

	foreach bookingRefDiscrepFieldValue in self.allBookingRefDiscrepFieldVs do
		if bookingRefDiscrepFieldValue.isDiscrepancy then
			return true;
		endif;
	endforeach;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesAttributeWithValueOf" id="e122f897-9a6f-46b8-99c8-b1ff6234d609">
        <source>includesAttributeWithValueOf( _attrName : String; value : String ) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars

	entTableDef : EntTableDef;
	entTableRow : EntTableRow;
	heading : String;
	bookingRefDiscrepFieldValue : CM_BookingRefDiscrepFieldValue;
	
begin

	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_BookingRefDiscrep];
	entTableRow := entTableDef.getEntTableRow(_attrName);
	if entTableRow = null then
		return false;
	endif;
	heading := entTableRow.getHeading(null,null,app.myCurrentLocale);
	if heading = null then
		return false;
	endif;

	bookingRefDiscrepFieldValue := self.allBookingRefDiscrepFieldVs.getAtKey(heading);
	if bookingRefDiscrepFieldValue = null then
		return false;
	endif;
	
	if bookingRefDiscrepFieldValue.bookingRefFieldValue = value 
	or bookingRefDiscrepFieldValue.tiFieldValue = value
	then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="value" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
