    <JadeMethod name="actionEventRequestEmail" id="bec9ac30-9005-498e-aded-32af334dc2cd">
        <updating/>
        <source>actionEventRequestEmail(_bgpEmailDict : BGP_EmailReqByUserAddressDict input; _eventReqEmail : CM_EventRequestEmail; _passport : CM_Passport input)updating;
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _eventReqEmail = null then
		return;
	elseif _bgpEmailDict = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null _bgpEmailDict');	
		return;
	endif;
	
	if _eventReqEmail.type = EventRequestTypeNotify then
		self.actionEventRequestNotify(_bgpEmailDict, _eventReqEmail, _passport);
	
	elseif _eventReqEmail.type = EventRequestTypeStops then
		self.actionEventRequestStops(_bgpEmailDict, _eventReqEmail, _passport);	
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Type not handled');	
		return;
	endif;
end;</source>
        <Parameter name="_bgpEmailDict" type="BGP_EmailReqByUserAddressDict" usage="input"/>
        <Parameter name="_eventReqEmail" type="CM_EventRequestEmail"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionEventRequestNotify" id="7e22b272-66e1-488e-95e0-08db11836e30">
        <updating/>
        <source>actionEventRequestNotify(_bgpEmailDict : BGP_EmailReqByUserAddressDict input; _eventReqEmail : CM_EventRequestEmail; _passport : CM_Passport input)updating, protected;
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	iter : Iterator;
begin
	
	iter := self.allEventRequestsNotify.createIterator();
	self.allEventRequestsNotify.startKeyGeq(EventRequestMatched, null, iter);
	self.actionEventRequestSend(_bgpEmailDict, _eventReqEmail, iter, _passport);
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_bgpEmailDict" type="BGP_EmailReqByUserAddressDict" usage="input"/>
        <Parameter name="_eventReqEmail" type="CM_EventRequestEmail"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionEventRequestSend" id="59a8d5f5-5d69-4244-85bb-13f68113e616">
        <updating/>
        <source>actionEventRequestSend(_bgpEmailDict : BGP_EmailReqByUserAddressDict input;
					 _eventReqEmail : CM_EventRequestEmail; _iter : Iterator input;
					 _passport : CM_Passport input)updating, protected;
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	bgpEmail : BGP_EmailSendRequest;
	alertDesc,
	keyAddress,
	fromAddress,
	address,	
	ccAddress,
	reqMessage,
	message	: String;
	tmpEventRequestTI : CM_EventRequestTI;
	tmpTerm : CM_Terminal;
begin
	
	if _iter = null then
		return;
	
	elseif _eventReqEmail.allRunTimes.isEmpty then
		return;		
	
	elseif _bgpEmailDict = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null _bgpEmailDict');	
		return;		
	endif;
	
	tmpTerm := _passport.myTerminal;
	fromAddress := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	
	while _iter.next(tmpEventRequestTI) do
		if tmpEventRequestTI.status &gt; EventRequestActioned then
			// into the email already sent
			break;
		elseif tmpEventRequestTI.status = EventRequestMatched and tmpEventRequestTI.actionFailedReason = null then
			continue;
		endif;

		if (not _eventReqEmail.checkSendEmailOld(tmpEventRequestTI.statusDT)) then
			continue; 
		endif;
		
		reqMessage := tmpEventRequestTI.getSendMessage();

		foreach address in tmpEventRequestTI.allEmailAddresses do
			keyAddress := address[1:50];
			if keyAddress = null then //par15256 Nov 2007
				continue;
			endif;
			bgpEmail := _bgpEmailDict.getAtKey(keyAddress);
			if bgpEmail = null then
				create bgpEmail;
				bgpEmail.setEmailRequest(keyAddress,
										  tmpEventRequestTI.typeString,
										  address, 
										  fromAddress, 
										  null, 
										  null, 
										  tmpEventRequestTI.typeString,
										  reqMessage,
										  self,
										  tmpTerm,
										  null,
										  null,
										  null,
										  null,
										  EmailSource_System);
				_bgpEmailDict.add(bgpEmail);										  
			else
				bgpEmail.addTextToSendMessage(reqMessage);										 
			endif;
		endforeach;
		
		tmpEventRequestTI.updateStatusAndStatusInfo(EventRequestEmailed, app.getErrorString(Email_Sent_To_BGP));

	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="_bgpEmailDict" type="BGP_EmailReqByUserAddressDict" usage="input"/>
        <Parameter name="_eventReqEmail" type="CM_EventRequestEmail"/>
        <Parameter name="_iter" type="Iterator" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
