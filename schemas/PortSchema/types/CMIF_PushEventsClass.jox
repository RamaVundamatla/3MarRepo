<Class name="CMIF_PushEventsClass" id="228ba618-e5b5-4a27-8e88-b12d3f28083d">
    <superclass name="CMIF_Object"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="allPushEventsFeatures" id="613c2ec9-d4bb-45a5-8729-31153c03a44a">
        <kind>parent</kind>
        <type name="CMIF_PushEventsFeatureDict"/>
        <access>readonly</access>
        <Inverse name="CMIF_PushEventsFeature::myPushEventsClass"/>
    </ExplicitInverseRef>
    <PrimAttribute name="className" id="5d7276b7-c7b8-4aa2-85ab-a22fa9d9071f">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="buildFromDataDumpClass" id="e1ba706b-f192-4eb1-a47d-708f0797ac8e">
        <updating/>
        <source>buildFromDataDumpClass(_ddClass : CM_DataDumpClass;
					   _subClassName : String) updating;
/*

Purpose:			Populate the receiver from the passed in Data Dump class definition, in the context of the
					passed in (sub)class name

Parameters:			CM_DataDumpClass to copy, and relevant subclass to build from

Return Value:		None

Date		Who		Reason
20 Feb 2017	cnwkpd1	TFS 3369 - Push Events application
15 Mar 2017	cnwkpd1	Added explicit check for applies to subclass

*/

vars
	ddFeature		: CM_DataDumpFeature;
	peFeature		: CMIF_PushEventsFeature;
	featureSubClass,
	appliesToClass	: Class;
	feature			: Feature;
	
begin
	app.writeLog(method.qualifiedName &amp; ' ' &amp; self.String &amp; ' created for class ' &amp; _subClassName, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053

	appliesToClass := currentSchema.getClass(_subClassName);

	self.className := _subClassName;
	
	foreach ddFeature in _ddClass.allDataDumpFeatures discreteLock do
		
		// Skip any features that do not apply to the passed in subclass
		if ddFeature.subClassName &lt;&gt; null then
			
			featureSubClass := currentSchema.getClass(ddFeature.subClassName);
			if not appliesToClass.inheritsFrom(featureSubClass) then
				continue;
			endif;
			
			feature := _ddClass.getFeatureForClass(appliesToClass, ddFeature.featureName);
			if feature = null then
				continue;
			endif;
		endif;
		
		create peFeature transient;
		peFeature.buildFromDataDumpFeature(ddFeature, _subClassName);
		
		self.allPushEventsFeatures.add(peFeature);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_ddClass" type="CM_DataDumpClass"/>
        <Parameter name="_subClassName" type="String"/>
    </JadeMethod>
</Class>
