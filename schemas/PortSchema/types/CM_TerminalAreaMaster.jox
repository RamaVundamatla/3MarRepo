        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="dda6033c-a480-4af3-9564-272244f2397d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     15 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if _attrName = ETRow_Type then
		return self.typeString;
	elseif _attrName = ETRow_Code or
		_attrName = ETRow_Id  then
		return self.id;
	elseif _attrName = ETRow_TerminalAreaOid then
		// ccms 1016 - new road ops form groups by terminal area	
		return self.getOidStringForObject (self);	// apparently faster than getOidString
	elseif _attrName = ETRow_Comment then
		return self.comment;
	elseif _attrName = ETRow_MaxCapacity then	// 19/02/2014 cnwar2 #33403
		return null;
	
	elseif _attrName = ETRow_DoCreateLogicalDelTrx then	//04 Aug 2017	NDL	TFS 5679
		return false.String;
		
	endif;
	return inheritMethod(_attrName, _short);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
