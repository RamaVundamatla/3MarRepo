    <JadeMethod name="isTPPRevenue" id="bc78e90a-205e-4f2b-80b5-2d4f66e81ad9">
        <source>isTPPRevenue() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2019	jlger1	Initial creation

*/

vars
	glCodeObj 	: CM_GLCode;
	glCode : String;
	invType : CM_InvoiceDesc;
begin
	
	if self.invoice.paymentType = PaymentType_AutoCollection then
		if not isWSDL13Successful() then
			app.writeLog(method.qualifiedName() &amp; " Auto collection invoice line " &amp; self.sequenceNum.String &amp; " has not had WSDL 1.3 sent", LogINFO);
			return false;
		endif;
	elseif self.invoice.paymentType = PaymentType_PostPay then
		if not isWSDL17Successful() then
			app.writeLog(method.qualifiedName() &amp; " Post pay invoice line " &amp; self.sequenceNum.String &amp; " has not had WSDL 1.7 sent", LogINFO);
			return false;
		endif;
	elseif self.invoice.paymentType = PaymentType_PrePay then
		if not isWSDL112Successful() then
			app.writeLog(method.qualifiedName() &amp; " Pre pay invoice line " &amp; self.sequenceNum.String &amp; " has not had WSDL 1.12 sent", LogINFO);
			return false;
		endif;
	else
		return false;
		app.writeLog(method.qualifiedName() &amp; " Invoice line " &amp; self.sequenceNum.String &amp; " has wrong payment type", LogINFO);
	endif;

	invType:=self.getInvoiceType;
	if invType = null then
		return true;
	endif;
	if invType.description.toUpper() &lt;&gt; "NOTA KAPAL"  then
		return true;
	endif;
	glCodeObj:=self.getGLCode;
	if glCodeObj &lt;&gt; null then
		glCode:=glCodeObj.code;
	endif;
	
	if glCode = "2131070000.001" or
		glCode = "6255000000.001" then
		app.writeLog(method.qualifiedName() &amp; " Invoice line " &amp; self.sequenceNum.String &amp; " has GL code to be omitted", LogINFO);
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTransactionOfType" id="e1666a41-3833-4f71-b1e3-8d89948b0f24">
