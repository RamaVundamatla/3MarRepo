    <JadeMethod name="moveAftWithForward" id="463007c8-5358-414c-aa62-a08b9e39c9aa">
        <source>moveAftWithForward(_rotate : Boolean) : Boolean;
/*
Purpose:	 // PAR 28879		
Date		Who		Reason
14 October 2011	cnwab1	Initial creation
*/
//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
//
vars
	allStateData : CM_StateDataDict;
	locnGap, locnLength, locnWidth : Decimal[12,2];
	newPoints: PointArray;
	newPoint : Point;
	locnDefn : CM_ROROLocnDefnVoyage;
begin
	if self.myRequest = null then
		return false;
	endif;
	
	// PAR 28920
	if not self.myRequest.myROROController.isContainerLC() then
		return false;
	endif;
	
	locnDefn := self.myRequest.myROROController.CM_ROROSlotController.mySlotDefn.myROROLocnDen.CM_ROROLocnDefnVoyage;
	
	if not locnDefn.isOOTL() then
		return false;
	endif;
		
	if locnDefn.myAdjacentSlotAft = null then
		return false;  // is a 20 OOTL
	endif;
	
	allStateData := self.getStateData();
	if allStateData = null then
		return false;
	endif;
	
	global.getExtraData(allStateData,RoRoLocationGap,locnGap);
	global.getExtraData(allStateData,RoRoLocationWidth,locnWidth);
	global.getExtraData(allStateData,RoRoLocationLength,locnLength);

	locnGap := locnGap * ROROStructurePixelsPerMetre;
	locnWidth := (locnWidth * ROROStructurePixelsPerMetre) - 1;
	locnLength := (locnLength * ROROStructurePixelsPerMetre) - 1; 
	
	create newPoints transient;

	// PAR 28886
	// PAR 29807 adjust by 1 pixel
	if locnDefn.isVerticalOrientation() then
		newPoint.set(self.myPolygonPixels[1].x ,(self.myPolygonPixels[1].y - locnGap - locnLength).Integer - 1 );
		newPoints.add(newPoint);
		newPoint.set(self.myPolygonPixels[2].x ,(self.myPolygonPixels[1].y - locnGap - locnLength).Integer - 1);
		newPoints.add(newPoint);
		newPoint.set(self.myPolygonPixels[2].x ,(self.myPolygonPixels[1].y - locnGap).Integer - 1);
		newPoints.add(newPoint);
		newPoint.set(self.myPolygonPixels[1].x ,(self.myPolygonPixels[1].y - locnGap).Integer  - 1);
		newPoints.add(newPoint);
		newPoint.set(self.myPolygonPixels[1].x ,(self.myPolygonPixels[1].y - locnGap - locnLength).Integer -1  ); // PAR 29990
		newPoints.add(newPoint);
	else
		newPoint.set((self.myPolygonPixels[1].x - locnGap - locnLength).Integer - 1  ,self.myPolygonPixels[1].y); 
		newPoints.add(newPoint);
		newPoint.set((self.myPolygonPixels[1].x - locnGap).Integer - 1 , self.myPolygonPixels[1].y);
		newPoints.add(newPoint);
		newPoint.set((self.myPolygonPixels[4].x - locnGap).Integer - 1 , self.myPolygonPixels[4].y);
		newPoints.add(newPoint);
		newPoint.set((self.myPolygonPixels[4].x - locnGap - locnLength).Integer - 1 , self.myPolygonPixels[4].y);
		newPoints.add(newPoint);
		newPoint.set((self.myPolygonPixels[1].x - locnGap - locnLength).Integer - 1 ,self.myPolygonPixels[1].y);
		newPoints.add(newPoint);
	endif;
	
	// Move the aft 20 slot to be in line with this forward 20 foot slot.
	locnDefn.myAdjacentSlotAft .myLayout.setPointsPolygon(newPoints);
	locnDefn.myAdjacentSlotAft.setPointsOnRequests(self.myRequest.isLoad);
	 
	 return true;
epilog
	delete newPoints;
end;</source>
        <Parameter name="_rotate" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveForwardWithAft" id="9fc105f5-2e43-437c-ba17-516fd0e96aa8">
        <source>moveForwardWithAft(_rotate : Boolean) : Boolean;
/*
Purpose:			 // PAR 28879
Date		Who		Reason
14 October 2011	cnwab1	Initial creation
*/
//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
//
vars
	allStateData : CM_StateDataDict;
	locnGap, locnLength, locnWidth : Decimal[12,2];
	newPoints: PointArray;
	newPoint : Point;
	locnDefn : CM_ROROLocnDefnVoyage;
begin
	if self.myRequest = null then
		return false;
	endif;
	
	
	if not self.myRequest.myROROController.isContainerLC() then
		return false;
	endif;

	locnDefn := self.myRequest.myROROController.CM_ROROSlotController.mySlotDefn.myROROLocnDen.CM_ROROLocnDefnVoyage;
	
	if not locnDefn.isOOTL() then
		return false;
	endif;
		
	if locnDefn.myAdjacentSlotFwd = null then
		return false;  // is a 20 OOTL
	endif;
	
	allStateData := self.getStateData();
	if allStateData = null then
		return false;
	endif;


	global.getExtraData(allStateData,RoRoLocationGap,locnGap);
	global.getExtraData(allStateData,RoRoLocationWidth,locnWidth);
	global.getExtraData(allStateData,RoRoLocationLength,locnLength);

	locnGap := locnGap * ROROStructurePixelsPerMetre;
	locnWidth := (locnWidth * ROROStructurePixelsPerMetre) - 1;
	locnLength := (locnLength * ROROStructurePixelsPerMetre) - 1; 
	
	create newPoints transient;

	// PAR 28886
	// PAR 29807 adjust by 1 pixel
	if locnDefn.isVerticalOrientation() then
		newPoint.set(self.myPolygonPixels[1].x ,(self.myPolygonPixels[3].y + locnGap).Integer + 1); // PAR 29807 + 1
		newPoints.add(newPoint);
		newPoint.set(self.myPolygonPixels[2].x ,(self.myPolygonPixels[3].y + locnGap).Integer + 1);
		newPoints.add(newPoint);
		
		newPoint.set(self.myPolygonPixels[2].x, (self.myPolygonPixels[3].y + locnGap + locnLength).Integer + 1);
		newPoints.add(newPoint);
		newPoint.set(self.myPolygonPixels[1].x, (self.myPolygonPixels[3].y + locnGap + locnLength).Integer + 1);
		newPoints.add(newPoint);
		newPoint.set(self.myPolygonPixels[1].x ,(self.myPolygonPixels[3].y + locnGap).Integer + 1); // PAR 29807 + 1
		newPoints.add(newPoint);
	
	else
		newPoint.set((self.myPolygonPixels[2].x + locnGap).Integer + 1 ,self.myPolygonPixels[1].y); // PAR 29807 + 1
		newPoints.add(newPoint);
		newPoint.set((self.myPolygonPixels[2].x + locnGap + locnLength).Integer + 1, self.myPolygonPixels[1].y);
		newPoints.add(newPoint);
		newPoint.set((self.myPolygonPixels[3].x + locnGap + locnLength).Integer + 1, self.myPolygonPixels[4].y);
		newPoints.add(newPoint);
		newPoint.set((self.myPolygonPixels[3].x + locnGap).Integer + 1, self.myPolygonPixels[4].y);
		newPoints.add(newPoint);
		newPoint.set((self.myPolygonPixels[2].x + locnGap).Integer + 1 ,self.myPolygonPixels[1].y); // PAR 29807 + 1
		newPoints.add(newPoint);
	endif;
	
	// Move the aft 20 slot to be in line with this forward 20 foot slot.
	 locnDefn.myAdjacentSlotFwd.myLayout.setPointsPolygon(newPoints);
	locnDefn.myAdjacentSlotFwd.setPointsOnRequests(self.myRequest.isLoad);
	 
	 return true;
epilog
	delete newPoints;
end;</source>
        <Parameter name="_rotate" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendDeleteNotes" id="7fa05477-1a86-47d4-badf-7a56334eb2b8">
        <updating/>
        <source>sendDeleteNotes() updating;
/*
Purpose:			
Date		Who		Reason
29 August 2011	cnwab1	Initial creation
*/

vars
	layer : CM_DeckLayerLayout;
	item  : CM_Graphic;
begin


	// COLOUR CODING LAYER
//	31053 self.causeEvent(EVENT_RORO_ITEM_DELETE,false,self.myDeckLayer);

	// PAR 29051 - Performance, each request delete  send 2 notes, once with the cargo layer. 
	// 					This is OK if deleting a GC request cos we need to redraw the container positions that were underneath, 
	//					but with request for container positions this is not necessary
	
	if self.isGCDefnLayout() or self.isOOTLDefn() then
		// COLOUR CODING LAYER
		
		self.causeEvent(EVENT_RORO_ITEM_DELETE,false,self.myDeckLayer); // 31053 moved to here
		
		
		// CARGO LAYER
		layer := self.myDeckLayer.myDeckLayout.getCargoLayer();
		if layer &lt;&gt; null then
			self.causeEvent(EVENT_RORO_ITEM_DELETE,false,layer);
			// 28878 covered containers - in progress - not registered for 
			//foreach item in self.allCoveredPolygons discreteLock do
			//	layer.causeEvent(EVENT_RORO_ITEM_UPDATE, false, item);
			//endforeach;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFromDefn" id="764ade02-bd37-45ba-b043-c4a685ee4459">
        <updating/>
        <source>setFromDefn(_itemDefn : CM_DeckItem input) updating;
/*
Purpose:			
Date		Who		Reason
24 June 2011	cnwab1	Initial creation
*/

vars
	thePoints : PointArray;
	theDefnToUse : CM_DeckItem;
begin
	self.code := _itemDefn.code;
	self.description := _itemDefn.description;
//	self.drawFillColour := _itemDefn.myLayout.drawFillColour; set by request
	self.drawFillStyle := Frame.DrawFillStyle_Solid; // _itemDefn.myLayout.drawFillStyle;
	self.drawLineColour := _itemDefn.myLayout.drawLineColour;
	self.drawLineStyle := _itemDefn.myLayout.drawLineStyle;
	self.drawWidth := _itemDefn.myLayout.drawWidth;
	self.isVisible := true;
	self.myDeckItem := null; 

	create thePoints transient;
	
	
	if self.myRequest.isLoad then
		theDefnToUse := _itemDefn.getParentDefn(); // If a lane position we need to fit to the parent lane area
		
		if theDefnToUse = null then
			theDefnToUse := _itemDefn;
		endif;
		
		
		theDefnToUse.myLayout.myPolygonPixels.copy(thePoints);
		
		theDefnToUse.getProxyPolyPreUpdate(thePoints, self.myRequest.isLoad);
	else
		_itemDefn.myLayout.myPolygonPixels.copy(thePoints);
	
	endif;
	
	self.setPointsPolygon(thePoints);
	
epilog
	delete thePoints;
end;</source>
        <Parameter name="_itemDefn" type="CM_DeckItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromRequest" id="84093b98-f875-42da-ab1b-3a76b4baff56">
        <updating/>
        <source>setFromRequest(_req : CM_RORORequest) updating;
/*
Purpose:			
Date		Who		Reason
27 June 2011	cnwab1	Initial creation
*/

vars

begin

	if _req.isReqSlot() then // PAR 28932
		self.drawFillColour := White; // PAR 28900 
	else
		self.drawFillColour := _req.getAllocationColour(); // PAR 28932
	endif;
	
	if _req.isDischarge then
		self.type := DeckItemLayoutType_CCDischarge;
	else
		self.type := DeckItemLayoutType_CCLoad;
	endif;
epilog

end;</source>
        <Parameter name="_req" type="CM_RORORequest"/>
    </JadeMethod>
    <JadeMethod name="setPointsPolygon" id="eac8a9eb-3eb0-4234-aef4-7005fa9231ae">
        <updating/>
        <source>setPointsPolygon(_newPoints: PointArray) updating;
/*
Purpose:			
Date		Who		Reason
29 July 2011	cnwab1	Initial creation
*/

vars
	req : CM_RORORequest;
	deckItem : CM_DeckItem;
begin 
	inheritMethod(_newPoints);

//	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. ' &amp; self.String &amp; ' self.type: ' &amp; self.type.String);

	// NOTE Discharge CC is moved by the actual cargo
	if self.type = DeckItemLayoutType_CCLoad then
		req := self.myRequest;
		if req &lt;&gt; null then
			deckItem := req.myROROController.getDefn();
			if deckItem &lt;&gt; null then
				if deckItem.isLocnGC() then
					// Get the GC Def and update its polygon as well
					deckItem.myLayout.setPointsPolygon(_newPoints);
					deckItem.myDeck.myDeckLayout.hideContainerPositionsUnderGC(self); // PAR 27749
					deckItem.myDeck.myDeckLayout.hideContainerPositionsUnderGC(deckItem.myLayout); // PAR 27749
				elseif deckItem.isLocnLanePosition() then
					deckItem.myLayout.setPointsPolygon(_newPoints);
					deckItem.myDeck.myDeckLayout.hideContainerPositionsUnderGC(self); // PAR 27749
					deckItem.myDeck.myDeckLayout.hideContainerPositionsUnderGC(deckItem.myLayout); // PAR 27749
				elseif deckItem.isLocnContainer() and deckItem.isOOTL() then // PAR 28879
					deckItem.myLayout.setPointsPolygon(_newPoints);
					deckItem.setPointsOnRequests(req.isLoad);
					if not deckItem.myLayout.isOnLayerLoad() then // PAR 30231
						if not deckItem.hasAlreadyCovered(true, DeckItemLayoutType_CCLoad) then
							deckItem.myDeck.myDeckLayout.hideContainerPositionsUnderGC(deckItem.myLayout); // PAR 27749
						endif;
					endif;
				endif;
			endif;
		endif;
	elseif self.type = DeckItemLayoutType_CCDischarge then
		self.myDeckLayer.myDeckLayout.hideContainerPositionsUnderGC(self); // PAR 27749
	endif;
epilog

end;</source>
        <Parameter name="_newPoints" type="PointArray"/>
    </JadeMethod>
    <JadeMethod name="setProxyPreUpdate" id="6900a822-1036-486c-b92b-d83e194df749">
        <source>setProxyPreUpdate(_newPoints: PointArray);
/*
Purpose:			
Date		Who		Reason
30 November 2011	cnwab1	Initial creation
*/

vars

	req : CM_RORORequest;
	deckItem : CM_DeckItem;
	aPoint : Point;
begin


	// NOTE Discharge CC is moved by the actual cargo
	if self.type = DeckItemLayoutType_CCLoad then
		req := self.myRequest;
		if req &lt;&gt; null then
			if req.myROROController.isKindOf(CM_ROROLanePositionController) then
				deckItem := req.myROROController.CM_ROROLanePositionController.myLaneController.getDefn();
			else
				deckItem := req.myROROController.getDefn();
			endif;
			if deckItem &lt;&gt; null and deckItem.isLocnLane() then
				if _newPoints[1].x &lt; deckItem.myLayout.myPolygonPixels[1].x then
					aPoint.set(deckItem.myLayout.myPolygonPixels[1].x, deckItem.myLayout.myPolygonPixels[1].y);
					_newPoints[1] := aPoint;
					aPoint.set(deckItem.myLayout.myPolygonPixels[5].x, deckItem.myLayout.myPolygonPixels[5].y);
					_newPoints[5] := aPoint;
					aPoint.set(deckItem.myLayout.myPolygonPixels[4].x, deckItem.myLayout.myPolygonPixels[4].y);
					_newPoints[4] := aPoint;
				endif;
				if _newPoints[2].x &gt; deckItem.myLayout.myPolygonPixels[2].x then
					aPoint.set(deckItem.myLayout.myPolygonPixels[2].x, deckItem.myLayout.myPolygonPixels[2].y);
					_newPoints[2] := aPoint;
					aPoint.set(deckItem.myLayout.myPolygonPixels[3].x, deckItem.myLayout.myPolygonPixels[3].y);
					_newPoints[3] := aPoint;
				endif;
				if _newPoints[1].x &gt; deckItem.myLayout.myPolygonPixels[2].x then
					aPoint.set(deckItem.myLayout.myPolygonPixels[2].x - 10, deckItem.myLayout.myPolygonPixels[2].y);
					_newPoints[1] := aPoint;
					_newPoints[5] := aPoint;
					aPoint.set(deckItem.myLayout.myPolygonPixels[2].x - 10, deckItem.myLayout.myPolygonPixels[4].y);
					_newPoints[4] := aPoint;
				endif;
			
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_newPoints" type="PointArray"/>
    </JadeMethod>
</Class>
