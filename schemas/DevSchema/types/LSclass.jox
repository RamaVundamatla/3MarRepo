    <JadeMethod name="addConstant" id="c42230e1-217d-484c-8fb1-99c8180d1954">
        <source>addConstant(_constantName, _controlName, _controlProperty, _text, _commentedOutTextStartOfLine, _commentedOutTextEndOfLine : String; 
		_isCommentedOut, _addToDisplayDict : Boolean; _constantNumber : Integer) : LSconstant;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 March 2019	jlgns1	Initial creation

*/

vars
	lsConstant				: LSconstant;
	controlName : String;
begin
		if _controlName = "self" then
			controlName  := self.name ;
		else 
			controlName := _controlName;
		endif;


			create lsConstant transient;
			lsConstant.schemaName := self.mySchema.name;
			lsConstant.formName := 	self.name;
			lsConstant.controlName := controlName;
			lsConstant.controlProperty := _controlProperty;
			lsConstant.name :=  _constantName;
			lsConstant.commentedOutTextStartOfLine := _commentedOutTextStartOfLine;
			lsConstant.isCommentedOut := _isCommentedOut;
			lsConstant.number := _constantNumber;
			lsConstant.text := _text;
			lsConstant.commentedOutTextEndOfLine := _commentedOutTextEndOfLine;
			lsConstant.dontGenerate := not _isCommentedOut;
					
			self.allConstants.add(lsConstant);
		
			self.mySchema.allConstants.add(lsConstant);
		


	return lsConstant;

epilog

end;</source>
        <Parameter name="_constantName" type="String"/>
        <Parameter name="_controlName" type="String"/>
        <Parameter name="_controlProperty" type="String"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_commentedOutTextStartOfLine" type="String"/>
        <Parameter name="_commentedOutTextEndOfLine" type="String"/>
        <Parameter name="_isCommentedOut" type="Boolean"/>
        <Parameter name="_addToDisplayDict" type="Boolean"/>
        <Parameter name="_constantNumber" type="Integer"/>
        <ReturnType type="LSconstant"/>
    </JadeMethod>
    <JadeMethod name="checkMethodSourceCorrect" id="e1d3f476-7ad5-4380-86a9-5ab2279eb320">
        <source>checkMethodSourceCorrect(_source : String) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2011	cnwmh5	Initial creation

*/

vars

	str					: String;
	
	sourceArray			: StringArray;
	
	index 				: Integer;
	inheritMethodFound	: Boolean;
	
begin
	
	create sourceArray transient;
	sourceArray := _source.cnGetTokens(CrLf);
	
	foreach index in 1 to sourceArray.size do
	
		// while not inheritMethod build the string up.
		if not inheritMethodFound then
			str := str &amp; sourceArray[index] &amp; CrLf;
			if sourceArray[index].pos('inheritMethod', 1) &gt; 0 then
				inheritMethodFound := true;
				continue;
			endif;
		endif;
	
	endforeach;
	
	return str;
	
epilog

	delete sourceArray;

end;</source>
        <Parameter name="_source" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="copyToRequiredPlaceInCode" id="6adbe175-7640-4c75-8572-bcff4f444a18">
        <source>copyToRequiredPlaceInCode(_src : String) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwmh5	Initial creation

*/

vars
	
	str 			: String;
	pos				: Integer;
	line			: String;
	inheritFound	: Boolean;
	pos1			: Integer;
	posComma		: Integer;
	posBubble		: Integer;
	posCaption		: Integer;
	attrib			: String;
	
begin

	inheritFound := false;
	pos := 1;
	while true do
	
		pos1 := 0;
		posComma := 0;
	
		line := _src.cnGetToken(pos, CrLf);
		if line = 'end;' then
			break;
		endif;
		if pos = 0 then
			str := str &amp; line;
			break;
		endif;
		
		// inherit not found update string
		if not inheritFound then
			str := str &amp; line &amp; CrLf;
			if line.cnContains("inheritMethod") then
				inheritFound := true;
			endif;
			continue;
		endif;
		
		if line.cnContains(".translateCaption") or line.cnContains(".translateBubbleHelp")then
			pos1 := line.pos("(", 1);
			posComma := line.pos(",", 1);
		endif;
		
		if pos1 = 0 then
			str := str &amp; line &amp; CrLf;
			continue;
		endif;
		
		if posComma = 0 then
			continue;
		endif;
		
		attrib := line[pos1+1:posComma-1-pos1];
		if allConstForMethFix[attrib] = null then
			str := str &amp; line &amp; CrLf;
		endif;		
	
	endwhile;

	return str;
	
epilog
	
end;</source>
        <Parameter name="_src" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="delete" id="425f0aa2-7e20-40eb-868b-134794d37edb">
        <updating/>
        <source>delete() updating;

/*

Purpose:		

Date			Who		Reason
16/03/2015		cnwmh5	Initial creation

*/

vars
	
begin
	
	self.allConstForMethFix.purge();
	self.allConstants.purge();
	self.allMethods.purge();
	self.allSubClasses.purge();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getLSmethod" id="81240340-263e-4151-b69e-bffe0ed8353d">
        <updating/>
        <source>getLSmethod(_method:Method):LSmethod updating;

vars
	lsmeth : LSmethod;
begin
	lsmeth := allMethods[_method.name];
	if lsmeth = null then
		create lsmeth transient;
		lsmeth.myMethod := _method;
		lsmeth.myClass := self;
		lsmeth.name := lsmeth.myMethod.name;	// this way round gets 1090 if name is mis-spelled
	endif;
	return lsmeth;
end;</source>
        <Parameter name="_method" type="Method"/>
        <ReturnType type="LSmethod"/>
    </JadeMethod>
    <JadeMethod name="getLSmethodRef" id="ef18a92d-3776-4963-b2f2-01742a96ebd9">
        <updating/>
        <source>getLSmethodRef(_method:Method; _lsTs : LStranslatableString):LSmethodRef updating;

vars
	lsmeth : LSmethod;
begin
	lsmeth := allMethods[_method.name];
	if lsmeth = null then
		create lsmeth as LSmethodRef transient;
		lsmeth.myMethod := _method;
		lsmeth.myClass := self;
		lsmeth.name := lsmeth.myMethod.name;	// this way round gets 1090 if name is mis-spelled
	endif;
	if not lsmeth.LSmethodRef.allLStranslatableStrings.includes(_lsTs) then
		lsmeth.LSmethodRef.allLStranslatableStrings.add(_lsTs);
	endif;
	return lsmeth.LSmethodRef;
end;</source>
        <Parameter name="_method" type="Method"/>
        <Parameter name="_lsTs" type="LStranslatableString"/>
        <ReturnType type="LSmethodRef"/>
    </JadeMethod>
    <JadeMethod name="scmHeaderForTSMigration" id="bcb36faa-566c-4835-b1a1-878092afbbdc">
        <source>scmHeaderForTSMigration():String;

vars
	str 		: String;
	lsMethod	: LSmethod;

begin
	str := name &amp; " partialDefinition" &amp; CrLf;
	str := str &amp; Tab &amp; "(" &amp; CrLf;
	str := str &amp; Tab &amp; "jadeMethodDefinitions" &amp; CrLf;

	foreach lsMethod in allMethods do
		str := str &amp; Tab &amp; Tab &amp; lsMethod.myMethod.makeHeader &amp; ";" &amp; CrLf ; // method signature
	endforeach;
	str := str &amp; Tab &amp; ")";

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="scmTypeSourceBeforeTSMigration" id="f284e3eb-25eb-4b9a-83a8-03c70012c129">
        <source>scmTypeSourceBeforeTSMigration():String;

vars
	str			: String;
	lsMethod	: LSmethod;
	methodSource: String;

begin
	str := Tab &amp; name &amp; "(" &amp; CrLf;
	str := str &amp; Tab &amp; "jadeMethodSources" &amp; CrLf;

	foreach lsMethod in allMethods do
	
		methodSource := lsMethod.myMethod.getSource;

		if methodSource = null then
			continue;
		endif;

		str := str &amp; lsMethod.name &amp; CrLf;
		str := str &amp; "{" &amp; CrLf;
		str := str &amp; methodSource &amp; CrLf;
		str := str &amp; "}" &amp; CrLf;
	endforeach;
	str := str &amp; Tab &amp; ")";
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="scmTypeSourceForTSMigration" id="fcaa07a0-81c9-495f-8046-7cfef7dc02d5">
        <source>scmTypeSourceForTSMigration():String;

vars
	str			: String;
	lsMethod	: LSmethod;
	methodSource: String;

begin
	str := Tab &amp; name &amp; "(" &amp; CrLf;
	str := str &amp; Tab &amp; "jadeMethodSources" &amp; CrLf;

	foreach lsMethod in allMethods do
	
		methodSource := lsMethod.LSmethodRef.getNewSource;

		if methodSource = null then
			continue;
		endif;

		str := str &amp; lsMethod.name &amp; CrLf;
		str := str &amp; "{" &amp; CrLf;
		str := str &amp; methodSource &amp; CrLf;
		str := str &amp; "}" &amp; CrLf;
	endforeach;
	str := str &amp; Tab &amp; ")";
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="vDisplayEntity" id="b1a81ffe-5aba-47a2-9dd3-98fae17addc2">
        <methodInvocation>mapping</methodInvocation>
        <source>vDisplayEntity(set: Boolean; _value: String io) mapping;

vars

begin
	if set then
		// read-only
	else
		_value := mySchema.name &amp;'::' &amp; name;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="zScmTypeSource" id="240d7588-009d-4253-9ebf-51b17f7ccc65">
        <source>zScmTypeSource():String;

// 30/01/2012 	cnwmh5	Change so generates method for each class everytime and writes commented out lines correctly
vars
	meth : Method;
	tmpConst	: Constant;
	lsConstant : LSconstant;
	str : String;
	date : Date;
	tmpName,
	src : String;
	endPos : Integer;
	writeComment	: Boolean;
	time : Time;
begin
	// Start of the translateForm() method source.
	str := Tab &amp; myClass.name &amp; " (" &amp; CrLf &amp;
		   Tab &amp; "jadeMethodSources" &amp; CrLf &amp;
		   "translateForm" &amp; CrLf &amp;
		   "{" &amp; CrLf;
	
	meth := myClass.getMethod("translateForm");
	///if meth = null then
		//
		// Using new format of translateForm method for MobileUISchema
		//
		if self.mySchema.name = MobileUISchemaName then
			str := str &amp; "translateForm(locale : CM_Locale) updating;" &amp; CrLf &amp;
			   Tab &amp; "// This method implements user-defined locale-based text translation for forms." &amp; CrLf &amp;
			   Tab &amp; "// Created on " &amp; date.String &amp; " " &amp; time.String &amp; "." &amp; CrLf &amp;
			   "vars" &amp; CrLf &amp;
			   Tab &amp;  CrLf &amp;
			   "begin" &amp; CrLf &amp;
			   Tab &amp; "// Determine the locale for translations." &amp; CrLf &amp;
			   Tab &amp; "inheritMethod(locale);" &amp; CrLf &amp;
			   Tab &amp; "" &amp; CrLf &amp;
			   Tab &amp; "// The following code invokes text translation for controls defined on this form." &amp; CrLf;
		else
			str := str &amp; "translateForm() updating;" &amp; CrLf &amp;
			   Tab &amp; "// This method implements user-defined locale-based text translation for forms." &amp; CrLf &amp;
			   Tab &amp; "// Created on " &amp; date.String &amp; " " &amp; time.String &amp; "." &amp; CrLf &amp;
			   "vars" &amp; CrLf &amp;
			   Tab &amp; "locale : CM_Locale;" &amp; CrLf &amp;
			   "begin" &amp; CrLf &amp;
			   Tab &amp; "// Determine the locale for translations." &amp; CrLf &amp;
			   Tab &amp; "locale := app.myCurrentLocale;" &amp; CrLf &amp;
			   Tab &amp; "if locale = null then" &amp; CrLf &amp;
			   Tab &amp; Tab &amp; 'locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);' &amp; CrLf &amp;
			   Tab &amp; Tab &amp; '// if no locale the bail out at this point' &amp; CrLf &amp;
			   Tab &amp; Tab &amp; 'if locale = null then' &amp; CrLf &amp;
			   Tab &amp; Tab &amp; Tab &amp; 'return;' &amp; CrLf &amp;
			   Tab &amp; Tab &amp; 'endif;' &amp; CrLf &amp;
			   Tab &amp; "endif;" &amp; CrLf &amp;
			   Tab &amp; "// The inheritMethod call invokes text translation for controls defined on superforms." &amp; CrLf &amp;
			   Tab &amp; "inheritMethod;" &amp; CrLf &amp;
			   Tab &amp; "" &amp; CrLf &amp;
			   Tab &amp; "// The following code invokes text translation for controls defined on this form." &amp; CrLf;
		endif;
/*	
		str := str &amp; "translateForm(_locale : CM_Locale) updating;" &amp; CrLf &amp;
			   Tab &amp; "// This method implements user-defined locale-based text translation for forms." &amp; CrLf &amp;
			   Tab &amp; "// Created on " &amp; date.String &amp; "." &amp; CrLf &amp;
			   "vars" &amp; CrLf &amp;
			   //Tab &amp; "locale : CM_Locale;" &amp; CrLf &amp;
			   Tab &amp;
			   "begin" &amp; CrLf &amp;
			   Tab &amp; "// Determine the locale for translations." &amp; CrLf &amp;
			   //Tab &amp; "locale := app.myCurrentLocale;" &amp; CrLf &amp;
			   //Tab &amp; "if locale = null then" &amp; CrLf &amp;
			   //Tab &amp; Tab &amp; 'locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);' &amp; CrLf &amp;
			   Tab &amp; Tab &amp; '// if no locale the bail out at this point' &amp; CrLf &amp;
			   Tab &amp; Tab &amp; 'return;' &amp; CrLf &amp;
			   Tab &amp; "endif;" &amp; CrLf &amp;
			   Tab &amp; "// The inheritMethod call invokes text translation for controls defined on superforms." &amp; CrLf &amp;
			   Tab &amp; "inheritMethod;" &amp; CrLf &amp;
			   Tab &amp; "" &amp; CrLf &amp;
			   Tab &amp; "// The following code invokes text translation for controls defined on this form." &amp; CrLf;
*/
/*
	else
		src := meth.getSource;
		
		// 1 off replacements - can remove once method source has been updated once
		//src := src.replaceString('translateForm() updating;', 'translateForm(_locale : CM_Locale) updating;');
		//src := src.replaceString(Tab &amp; 'locale : CM_Locale;', '');
		//src := src.replaceString('locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false)', 'return');
		///src := src.replaceString(', locale);', ', _locale);');
		
		//endPos := src.reversePos("end");
		//str := str &amp; src[1 : endPos - 1] &amp; CrLf &amp;
		//	   Tab &amp; "// Added on " &amp; date.String &amp; "." &amp; CrLf;
		str := str &amp; self.copyToRequiredPlaceInCode(src) &amp; CrLf;
	endif;
*/
			   
	// collate lines for each control on the form that requires translation
	writeComment := true;
	foreach lsConstant in self.allConstants do

		////if lsConstant.number = 0 then								// 10/11/2015 cnwmh5
	////		continue;	
////		endif;
	
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; Tab &amp; lsConstant.name &amp; Tab &amp; lsConstant.formName &amp; Tab &amp; lsConstant.controlName);
	
		if lsConstant.formName = lsConstant.controlName then
			tmpName := 'self';
		else
			tmpName := lsConstant.controlName;
		endif;
		
		if lsConstant.isCommentedOut then
			if lsConstant.commentedOutTextStartOfLine &lt;&gt; null then
				str := str &amp; lsConstant.commentedOutTextStartOfLine;
			else
				str := str &amp; "//";
			endif;
		endif;
		if lsConstant.name &lt;&gt; null then
			if lsConstant.controlProperty = "caption" then
				///if writeComment then
				///	str := str &amp; Tab &amp; "// Added on " &amp; date.String &amp; "." &amp; CrLf;
				///	writeComment := false;
				///endif;
				str := str &amp; Tab &amp; tmpName &amp; ".translateCaption(" &amp; lsConstant.name &amp; ", locale);";
			elseif lsConstant.controlProperty = "bubbleHelp" then
				///if writeComment then
				///	str := str &amp; Tab &amp; "// Added on " &amp; date.String &amp; "." &amp; CrLf;
				///	writeComment := false;
				///endif;
				str := str &amp; Tab &amp; tmpName &amp; ".translateBubbleHelp(" &amp; lsConstant.name &amp; ", locale);";
			endif;
		endif;
		
		if lsConstant.commentedOutTextEndOfLine &lt;&gt; null then
			str := str &amp; Tab &amp; Tab &amp; lsConstant.commentedOutTextEndOfLine &amp; CrLf;
		else
			str := str &amp; CrLf;
		endif;
		
	endforeach;

	str := str &amp; "end;" &amp; CrLf &amp;
		   "}" &amp; CrLf &amp;
		   Tab &amp; ")";
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
