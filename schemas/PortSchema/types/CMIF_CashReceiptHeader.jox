    <JadeMethod name="addDetailToHeader" id="789350b4-bf09-4fad-9fd7-e1ce64512027">
        <updating/>
        <source>addDetailToHeader(_detail: CMIF_CashReceiptReporting input) updating;
/*

Date		Who		Reason
17 August 2015	cnwer1	Initial creation PAR 36778

*/

vars

begin
	if _detail = null then
		return;
	endif;
	
	self.allDetails.add(_detail);

epilog

end;</source>
        <Parameter name="_detail" type="CMIF_CashReceiptReporting" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createJRWTransient" id="261e3fdc-4a60-4aea-bb21-ba7a39470f9a">
        <source>createJRWTransient() : CM_JRWInvoice;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2018	jlger1	Initial creation 38530

*/

vars
	jrwInv		: CM_JRWInvoice;
	termDict 	: CM_TerminalByCodeDict;
begin
	jrwInv := app.myQAFilter.createJRWTransient(CM_JRWInvoice).CM_JRWInvoice;

	create termDict transient;
	termDict.add(self.myTerminal);
	jrwInv.setAllTerminals(termDict);
	jrwInv.allCashReceiptReporting.add(self);
	// 36533 also populate CM_JRWInvoice myDebtor and customs agent
	jrwInv.myDebtor := self.myDebtor;
	
	return jrwInv;
epilog
	delete termDict;
end;</source>
        <ReturnType type="CM_JRWInvoice"/>
    </JadeMethod>
    <JadeMethod name="delete" id="b8a285bb-3fb1-4998-aad2-f0b620d59268">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2018	jlger1	Initial creation

*/

vars

begin
	self.allDetails.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getEffectiveDateLocalTZ" id="7dae18dc-6040-4d2e-9b35-58488fbf94e1">
        <source>getEffectiveDateLocalTZ() : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2016	cnwns1	Initial creation
// 02 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	sysTS :TimeStamp;
begin
	sysTS.cnEcSetDateAndTime(self.effectiveDate,TimeStartOfDay);
	return self.systemToLocalTime(sysTS).date();
	
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getRateFromProFormaRemarks" id="28d87f58-d1ce-4b63-8177-1a8a5638bd75">
        <source>getRateFromProFormaRemarks( _str : String ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2018	jlgndl1	Initial creation	TFS 40286

*/

vars

	cashReceipt : CM_CashReceipt;
	iter : Iterator;
	proformaDetails : CM_ProformaDetails;
	remarks : String;
	found : Boolean;
	startPos : Integer;
	trimmedRemarks : String;
	returnVal : Decimal[23,6];

begin

	if _str = null then
		return "No search string entered!";
	endif;
	
	if _str &lt;&gt; CM_Invoice.MinCharge
	and _str &lt;&gt; CM_Invoice.DebtorSurchargeRate
	and _str &lt;&gt; CM_Invoice.CargoSurchargeRate
	then
		return "Search string must be one of '" &amp; CM_Invoice.MinCharge &amp; "', '" &amp; CM_Invoice.DebtorSurchargeRate &amp; "' or '" &amp; CM_Invoice.CargoSurchargeRate &amp; "'.";
	endif;

//	if self.myCashInvoice = null then
//		return "No cash invoice associated with this CMIF_CashReceiptHeader!";
//	endif;
	
//	cashReceipt := self.myCashInvoice.myCashReceipt;
	cashReceipt := self.myCashReceipt;
	if cashReceipt = null then
		return "No cash receipt associated with this CMIF_CashReceiptHeader!";
	endif;
	
	if cashReceipt.allProformaDetails.isEmpty then
		return "No pro forma details on the cash receipt!";
	endif;
	
	iter := cashReceipt.allProformaDetails.createIterator;
	while iter.next( proformaDetails ) do
		remarks := proformaDetails.remarks;
		if remarks = null then
			continue;
		endif;
		startPos := remarks.pos( _str, 1 );
		if startPos &gt; 0 then
			found := true;
			break;
		endif;
	endwhile;
	
	if not found then
		return "No pro forma details found with remarks containing '" &amp; _str &amp; "'!";
	endif;
	
	trimmedRemarks := remarks[ ( startPos + _str.length ) : end ].trimBlanks; // chop the leading stuff
	returnVal := trimmedRemarks.Decimal; // Jade is smart enough to dump all the remaining crap when casting to Decimal
	
	return returnVal.String;
	
epilog

end;</source>
        <Parameter name="_str" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="glt_getEffectiveDateLocalTZ" id="443c70d2-7748-4d28-bdc9-008adecd0441">
        <source>glt_getEffectiveDateLocalTZ() : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2016	cnwns1	Initial creation
