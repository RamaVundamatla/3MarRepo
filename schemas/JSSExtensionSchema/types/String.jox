<PrimType name="String">
    <Constant name="JSS_URL_ENCODE_DLL" id="b8dd2f44-b16b-43b7-9b3e-3943cfb5d84c">
        <source>2</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="JSS_URL_ENCODE_JADE" id="7daac225-ec96-4e60-bdc9-881c185fe5bf">
