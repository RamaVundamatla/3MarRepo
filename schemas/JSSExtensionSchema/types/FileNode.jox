    <JadeMethod name="jssGetAttributes" id="760afeec-bb77-46ed-91fd-0574c0f2c34a">
        <source>jssGetAttributes(): String;
// -----------------------------------------------------------------------------
// Created:		18 January 2002 by cnwdad1
//
// Purpose:		Returns a string of the files File System attributes.
//
// Parameters:	None
//
// Returns:		String - A string of one-character attributes.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	attributes	: String;
	fileResult	: Integer;

begin
	if app.isUnicode() then
		fileResult	:=	call jssGetFileAttributesW(self.fileName);
	else
		fileResult	:=	call jssGetFileAttributesA(self.fileName);
	endif;
epilog
	return attributes;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
