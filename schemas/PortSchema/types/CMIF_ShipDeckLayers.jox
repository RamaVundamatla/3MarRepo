    <JadeMethod name="setForCreate" id="7a900b3e-0d84-454c-925a-80d06986c28d">
        <updating/>
        <source>setForCreate(_pxyMe : CMIF_ShipDeckLayers) updating;
// ---------------------------------------------------------------------------
// Created:     22 December 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.code := _pxyMe.code;
	self.description := _pxyMe.description;
	self.remarks := _pxyMe.remarks;
	self.visible := true;
	
	self.myDeck := _pxyMe.myDeck;
	
epilog

end;</source>
        <Parameter name="_pxyMe" type="CMIF_ShipDeckLayers"/>
    </JadeMethod>
