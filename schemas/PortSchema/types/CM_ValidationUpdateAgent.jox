    <JadeMethod name="valReticketTI" id="04c4b320-4503-46ac-98db-01c50e961739">
        <source>valReticketTI(_reticketTISet	: CMIF_TIReticketSet;
			_errorReticketSet,
			_validReticketSet 	: CMIF_TIReticketSet input;
			_cargoType 			: Integer;
			_terminal 			: CM_Terminal;
			_taType				: Integer;
			_newLocation		: CM_LocationsController);
// ---------------------------------------------------------------------------
// Created:     18 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	reticketTI		: CMIF_TIReticket;
	tmpTI,
	ti				: CM_TrackedItem;
	invalid			: Boolean;
	oldIdDict		: CMIF_TIReticketByOldIdDict;
	newIdDict		: CMIF_TIReticketByNewIdDict;
	lcArray			: CM_LCSet;
	tmpRoot			: CM_Root;
	oldId,
	newId			: String;
	
begin
	if _terminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', null, null);
		app.raiseCMException(Input_required_field_terminal, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if _reticketTISet = null then	
	//	app.raiseCMException1(REQUIRED_FIELD, 'CMIF_TIReticketSet', null, null);
		app.raiseCMException(Input_required_field_cmifRetic, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if _newLocation &lt;&gt; null then
		create lcArray transient;
		_terminal.getLocationsForType(_taType, false, lcArray);
		if (not lcArray.includes(_newLocation)) then
			app.raiseCMException1(Err_InvalidLocation, _newLocation.getID, null, null);
			return;
		endif;
	endif;
	
	create oldIdDict transient;
	create newIdDict transient;
	
	tmpRoot := app.myRoot;
	
	//check that the old IDs correspond to existing Tracked Items
	//and check that the new IDs DON'T correspond to a tracked item
	//separtate out into errorSet and valid set
	foreach reticketTI in _reticketTISet do
		invalid := false;
		
		oldId := reticketTI.oldId.trimBlanks;
		newId := reticketTI.newId.trimBlanks;
		
		if newId.pos(' ', 1) &gt; 0 then
			invalid := true;
		//	reticketTI.errorDescription := 'The item with old ID ' &amp; oldId &amp; ' has an invalid new ID (' &amp; 
		//							newId &amp; ') - it cannot have spaces';
			reticketTI.errorDescription := app.getErrorString2(Item_ID_has_spaces, oldId, newId);	//13 Sep 2012	NDL	Par 30366
			reticketTI.errorCode := Item_ID_has_spaces;	//13 Sep 2012	NDL	Par 30366
			_errorReticketSet.add(reticketTI);
			continue;
		endif;
		
		tmpTI := _terminal.lookupTrackedItem(oldId, _cargoType, TI_STATE_NORMAL, null, false);

		if tmpTI = null then //ti not found
			invalid := true;
			//reticketTI.errorDescription := 'The item with old ID ' &amp; oldId &amp; ' could not be found';
			reticketTI.errorDescription := app.getErrorString1(Item_with_OLDID_not_found, oldId);	//13 Sep 2012	NDL	Par 30366
			reticketTI.errorCode := Item_with_OLDID_not_found;	//13 Sep 2012	NDL	Par 30366
			_errorReticketSet.add(reticketTI);
		else
			if _newLocation &lt;&gt; null then
				if _newLocation.allTrackedItems.includes(tmpTI) then
					invalid := true;
					//reticketTI.errorDescription := 'The item ' &amp; tmpTI.id &amp; ' exists in location ' &amp; _newLocation.getID();
					reticketTI.errorDescription := app.getErrorString2(Item_exists_location, tmpTI.id, _newLocation.getID() );	//13 Sep 2012	NDL	Par 30366
					reticketTI.errorCode := Item_exists_location;	//13 Sep 2012	NDL	Par 30366
					_errorReticketSet.add(reticketTI);
				endif;
			endif;

			//tmpTI := _terminal.lookupTrackedItem(reticketTI.newId, _cargoType, TI_STATE_NORMAL, TI_SITE_ONSITE, null, false);
			tmpTI := tmpRoot.lookupTrackedItem(newId, _cargoType, TI_STATE_NORMAL, null, false, _terminal, true);
			
			if tmpTI &lt;&gt; null then //ti exists, so no way jose
				invalid := true;
				//reticketTI.errorDescription := 'Item with new ID ' &amp; newId &amp; ' already exists';
				reticketTI.errorDescription := app.getErrorString1(New_ID_already_exists, newId );	//13 Sep 2012	NDL	Par 30366
				reticketTI.errorCode := New_ID_already_exists;	//13 Sep 2012	NDL	Par 30366
				_errorReticketSet.add(reticketTI);
			endif;
		endif;
		if oldIdDict.includesKey(oldId) then
			//reticketTI.errorDescription := 'Old ID ' &amp; oldId &amp; ' is duplicated in the list';
			reticketTI.errorDescription := app.getErrorString1(OLDID_Duplicated_list, oldId );	//13 Sep 2012	NDL	Par 30366
			reticketTI.errorCode := OLDID_Duplicated_list;	//13 Sep 2012	NDL	Par 30366
			if (not invalid) then
				_errorReticketSet.add(reticketTI);
			endif;
			invalid := true;
		endif;
		if newIdDict.includesKey(newId) then
			//eticketTI.errorDescription := 'New ID ' &amp; newId &amp; ' is duplicated in the list';
			reticketTI.errorDescription := app.getErrorString1(NEWID_Duplicated_list, newId );	//13 Sep 2012	NDL	Par 30366
			reticketTI.errorCode := NEWID_Duplicated_list;	//13 Sep 2012	NDL	Par 30366
			if (not invalid) then
				_errorReticketSet.add(reticketTI);
			endif;
			invalid := true;
		endif;
		if (not invalid) then
//			if _validReticketDict.includesKey(reticketTI.oldID
			// check that the old or new key is not duplicated
			_validReticketSet.add(reticketTI);
			oldIdDict.add(reticketTI);
			newIdDict.add(reticketTI);
		endif;
	endforeach;	

epilog
	delete oldIdDict;
	delete newIdDict;
	delete lcArray;

	
end;</source>
        <Parameter name="_reticketTISet" type="CMIF_TIReticketSet"/>
        <Parameter name="_errorReticketSet" type="CMIF_TIReticketSet" usage="input"/>
        <Parameter name="_validReticketSet" type="CMIF_TIReticketSet" usage="input"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_taType" type="Integer"/>
        <Parameter name="_newLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="valRoadProcess" id="20946dc5-4bfa-4fff-bbed-a8fdfb7f6cef">
        <source>valRoadProcess( pExistingRoadProcess, pProxyRoadProcess : CM_RoadProcess );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

begin

	self.raiseExceptionIfNull(pProxyRoadProcess, 'Road Process Proxy');
	self.raiseExceptionIfNull(pExistingRoadProcess, "Road Process Existing");
	pProxyRoadProcess.raiseExceptionIfNotProxy(method);
	pProxyRoadProcess.validateForUpdate;
	
epilog

end;</source>
        <Parameter name="pExistingRoadProcess" type="CM_RoadProcess"/>
        <Parameter name="pProxyRoadProcess" type="CM_RoadProcess"/>
    </JadeMethod>
    <JadeMethod name="valRootConfig" id="907d1f7d-43d1-4fb5-9c96-072d56e72f58">
        <source>valRootConfig(realRoot: CM_Root; _config: CMIF_ConfigRoot);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
21 September 2022	navam1	Initial creation - 54854 - MTN - SSO - System Config allows you to set up Single Sign On Provider without Application / Directory
25 Aug  2025 navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client
*/

begin
	
	if _config.ssoProvider &lt;&gt; null and _config.ssoProvider = CMIF_SSOHelper.SSO_Provider_Microsoft then
		if _config.ssoAzureClientId = null then
			app.raiseCMException1(Input_required_ssoClientId, null, null, null);
		endif;
		
		if _config.ssoAzureTenantId = null then
			app.raiseCMException1(Input_required_ssoTenantId, null, null, null);
		endif;
	elseif _config.ssoProvider &lt;&gt; null and _config.ssoProvider = CMIF_SSOHelper.SSO_Provider_Okta then  // MTN-35151 - navec1 - Okta SSO
		if _config.ssoOktaClientId = null then
			app.raiseCMException1(Input_required_ssoOktaClientId, null, null, null);
		endif;		
		if _config.ssoOktaDomain = null then
			app.raiseCMException1(Input_required_ssoOktaDomain, null, null, null);
		endif;
		if _config.ssoOktaIssuerURI = null then
			app.raiseCMException1(Input_require_okta_issuer, null, null, null);
		endif;
		if _config.ssoOktaAudience = null then
			app.raiseCMException1(Input_require_okta_audienc, null, null, null);
		endif;
	endif;

	_config.validateConfig();
epilog

end;</source>
