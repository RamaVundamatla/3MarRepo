    <JadeMethod name="pxyCreateUpdateProxy" id="acf4a128-665f-441c-852c-551937c0d1be">
        <source>pxyCreateUpdateProxy() : SelfType;
// ---------------------------------------------------------------------------
// Created:     19 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxy	: CM_Object;
begin


	// Must be in load, lock or transaction state to create a proxy object.
	// Use the createUpdateProxy wrapper on app to guarantee this.
	if (not process.isInTransactionState) and 
	   (not process.isInLoadState) and 
	   (not process.isInLockState) then
		app.raiseCMException2(PxyCreateNotLoadLockTranState, self.class.name, method.name, null, null);
		return null;
	endif;

//	if process.isDoug then
//		app.writeStatement("Create update proxy for" &amp; self.String);
//		app.writeCurrentStack();
//	endif;
	
	// Share lock ourself to ensure we have our latest edition and that no
	// updates occur while we're creating our proxy. The proxy link object
	// saves the edition for comparison during updates.
	// Lock will be released at commit/abort transaction, endLoad or endLock.
	// This is why we insist on being in one of these three states above.
	sharedLock(self);
	if app.myProxyManager.allReals.includesKey(self) then
		//Hmm... will puke as proxy already exists
		app.raiseCMException1(ProxyAlreadyExists, self.getName(), null, null);
		return null;
	endif;	
	proxy := self.cloneSelf(true).CM_Object;
	app.myProxyManager.createProxyLink(self, proxy);
	
	return proxy;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="pxyGetProxyObject" id="0bc2b9b1-d91c-4823-86d2-b72d4ead0a2c">
