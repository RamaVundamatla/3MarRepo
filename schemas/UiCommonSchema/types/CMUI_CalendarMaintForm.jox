    <JadeMethod name="unload" id="fbb96b1c-2683-4980-8f0f-d4cc729c902b">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 October 2010	cnwndl1	Initial creation
10/03/2011	cnwmht	PAR #27142 - Change where handler armed
*/

vars

	invalidObject : Boolean;

begin
	
	if self.myProxyCalendar &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, self.myProxyCalendar, invalidObject );
		delete self.myProxyCalendar;
	endif;
	
	self.endClassNotification(CM_Calendar, false, EVENT_Calendar_Update);
	self.endClassNotification(CM_DayType, false, Object_Create_Event);
	self.endClassNotification(CM_DayType, false, Object_Delete_Event);
	
	
	inheritMethod();

epilog

end;</source>
