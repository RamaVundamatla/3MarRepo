    <JadeMethod name="doFilterTable" id="c3b1a462-2e2c-4327-8beb-a828b7ae0b68">
        <updating/>
        <source>doFilterTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 June 2021	navmd1	Initial creation TFS 51320
05 Nov 2024		navhn30	Bug MTN-19346: CUX - UNDG System Administration Filter
*/

vars
	filterText		: String;
	rowIdx,
	colIdx,
	start			: Integer;
	row 			: JadeTableRow;
	cell			: JadeTableCell;
	cellText		: String;
	methodStartTime	: TimeStamp;
	
	rowsToKeep		: CM_ObjectArray;
	obj				: Object;
	tableFilter		: CMUI_ToolbarFrameTableFilter;
begin	
	//25/06/2024	navkc1 CR 64823 Task 64824
	tableFilter := self.frmTableFilter;
	//filterText := self.txtFilterBox.text.trimWhiteSpace().toUpper();
	filterText := tableFilter.txtFilterBox.text.trimWhiteSpace().toUpper();
	tableFilter.txtFilterBox.foreColor := getSystemColor(Color_WindowText);
	
	// Reset
	//self.txtFilterBox.foreColor := getSystemColor(Color_WindowText);
	rowsToKeep := self.myCurrentTableItem.filteredObjects;
	rowsToKeep.clear();
	
	// No filter query ? reset.
	if filterText = "" then
		self.cmbTable.closeup(cmbTable);
		//self.txtFilterBox.setFocus();
		tableFilter.txtFilterBox.setFocus(); //25/06/2024	navkc1 CR 64823 Task 64824
		return;
	endif;
	
	start := self.tblData.fixedRows + 1;
	/*foreach rowIdx in start to self.tblData.rows do	: rowLoop
		obj := self.tblData.accessRow(rowIdx).itemObject;
		
		//self.tblData.selectRow(rowIdx, false);
		foreach colIdx in 1 to self.tblData.columns do
			cell := self.tblData.accessCell(rowIdx, colIdx);
			cellText := cell.text.toUpper;
			if cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then
				rowsToKeep.add(obj);
				continue rowLoop;	// Keep the row
			endif;
		endforeach;

	endforeach;*/
	
	//25/06/2024	navkc1 CR 64823 Task 64824
	foreach rowIdx in start to self.tblData.rows do : rowLoop
		row := self.tblData.accessRow(rowIdx);
		if not row.visible then
			continue;
		endif;
		obj := row.itemObject;
		if obj &lt;&gt; null then
			rowsToKeep.add(obj);
		endif;
	endforeach;
	
	// No matches found
	if rowsToKeep.size = 0 then
		//self.txtFilterBox.foreColor := Red;
		//self.txtFilterBox.bubbleHelp := app.getErrorString(UiNo_Items_Found);
		tableFilter.txtFilterBox.foreColor := Red;	//25/06/2024	navkc1 CR 64823 Task 64824
		tableFilter.txtFilterBox.bubbleHelp := app.getErrorString(UiNo_Items_Found);	//25/06/2024	navkc1 CR 64823 Task 64824
	endif;
	
	//self.doCurrentTableChange(true);		//04.11.24		navhn30		MTN-19346
	self.staMain.caption := app.getErrorString1(Num_Rows_Found,tableFilter.numOfRowVisible.String); //04.11.24		navhn30		MTN-19346
	//self.txtFilterBox.setFocus();
	tableFilter.txtFilterBox.setFocus();
	
epilog
		
end;</source>
    </JadeMethod>
    <JadeMethod name="doHandleNotification" id="0420988c-6545-465f-8e63-b24852201789">
        <updating/>
        <source>doHandleNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	05 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	event		: Integer;
	rfidTag		: CM_RFIDTag;
begin
	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if event = Event_RFIDSerialOnly then
		self.tblInput1.setValueByName(ETRow_SerialNumber, userInfo.String);
	endif;


end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doImport" id="78bf7a78-3ff4-446f-b078-c9122b2f1876">
        <updating/>
        <source>doImport() : Boolean updating;

vars
	trxResult		: Boolean;
	warningsResult	: Integer;
	tempStr			: String;			// cnwrl1 06/07/2010 PAR 24606
	
	impFile			: File;				//cnwmc5 - 15 May 2014 - PAR 34156
begin
	if self.myCurrentTableItem = null then
		return false;
	endif;
	
	tempStr	:= app.getString( Load_entries_into_table, self.myCurrentTableItem.name, 'System Codes Reference' );

	// cnwrl1 23/07/2010 PAR 25126 - end of coding
	if app.msgBox( tempStr, app.getString( Update_Caption ),
					MsgBox_Yes_No + MsgBox_Question_Mark_Icon ) = MsgBox_Return_No then
		return false;
	endif;	
	// cnwrl1 06/07/2010 PAR 24606 - end of coding
	
	create impFile transient;							//cnwmc5 - 15 May 2014 - PAR 34156
	impFile.kind := File.Kind_Unknown_Text; 			// 1/3/16  cnwns1 PAR 36286 unicode version
	self.myCurrentTableItem.getImportFile(impFile);		//cnwmc5 - 15 May 2014 - PAR 34156
	if impFile.fileName = null then	// cancelled		//cnwmc5 - 15 May 2014 - PAR 34156
		return true;									//cnwmc5 - 15 May 2014 - PAR 34156
	endif;												//cnwmc5 - 15 May 2014 - PAR 34156
	
	while true do

		trxResult := self.myCurrentTableItem.doImport(impFile);		//cnwmc5 - 15 May 2014 - PAR 34156
		
		if trxResult then
			self.clearErrorWarnings();
			self.doCurrentTableChange(self.isFirstActivateComplete);
			break;
		endif;

		warningsResult := app.showErrorWarningDialog(self.myCurrentTableItem.name, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
		
		if app.myPassport.noErrors and
		   warningsResult = IDOK then
			// there must have just been warnings that the user has acknoledged so ..
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;

		break;

	endwhile;
	
	return trxResult;
	
epilog
	delete impFile;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
