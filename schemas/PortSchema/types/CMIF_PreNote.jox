        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="vgmMail" id="81cb8957-8d6b-47eb-a25c-70ee8f54dd7c">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="vgmPhone" id="a3fa513e-0871-4fae-ab2f-dacd07e6418f">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="vgmTelefax" id="dd59ac65-9935-46ed-a333-da36b38aca33">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="vgmTelephone" id="1ce17575-8d73-4f21-a2e5-0ee100921cb2">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="wagon" id="ec1a4479-49b6-4445-9c11-9379da47f27d">
        <length>21</length>
        <embedded/>
        <type name="String"/>
        <text>cnwsh3 02/07/2008 PAR17395
Was length 8 but now length 20 to maintain consistency with the actual CM_Wagon.id field.
NOTE:
EDI Wagons (CM_EDIPrenoteTI and CM_EDIBookingTI) have wagonNumber attributes of 30 which,
at the time of an EDI load is ok.  We use the verifyEDITIs to check there won't be a problem
and the user can make a manual change at that point to reduce the field length.</text>
    </PrimAttribute>
    <JadeMethod name="actionForCreate" id="fe79887d-348a-4405-a4db-c6bc0bafcd71">
        <updating/>
        <source>actionForCreate(pProxy: CM_Object io; _passport : CM_Passport input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     16 February 2001 by cnwrs2
//
// Purpose:     
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 06/06/2017	cnwdap1		TFS 4434 SNO COPARN Prenotes and VGM updates
// 29/06/2017	cnwdap1		TFS 4492 SNO VERMAS Changes
// 06/12/20189	jlgdap1		TFS 47334 JMT Refactor Seal Transactions (continued)
// 02/05/2022	jlizm1		TFS 53084 GPHA revceival/release of tranship cargo
// 29/03/2023	navkc1		CR# 56430 Task 56435 Jade - Tracked Item Methods
// 05/02/2023	navkc1 		Bug 62302: CUX | Can't mark onboard or child cargo as 'overlanded'
// 19/03/2024	navdap1		TFS 62686 CUX | FR 61749 |  Cannot create multiple prenotes via API
// 22/04/2024	naviv1		TFS 63619 : CUX | FR - POST and PUT /Cargo not saving Customs References for Onboard Cargo
// 25/05/2024 	naviv1		TFS 64243 : CUX | POST &amp; PUT /Cargo APIs - Edit Transaction not created when customs reference data updated via API
// 07/08/2024	navdap1		TFS 65549 CUX - Updating Trailer via PUT /cargo Changes Onboard Cargo to Child Cargo
// 16 May 2025 	navhn30 	MTN-34850: TPT - Instructions are not populated after DB Loading a UDF
// ---------------------------------------------------------------------------
vars
	txnParams		: CMIF_TITransactionController;
	toDoTaskDesc	: CM_ToDoTaskDesc;
	childTI,
	ti				: CM_TrackedItem;						// TFS 4434
	updController	: CMIF_TIUpdateController;				// TFS 4434
	childId			: String;
	cmifTI			: CMIF_TIObject;
	mafi			: CM_TILC;					// TFS 62686
	children		: CM_TISet;					// TFS 62686
	child 			: CM_TrackedItem;			// TFS 62686
	moveController	: CMIF_MoveController;		// TFS 62686
	allChildren		: CM_TISet;				// TFS 63619
	beforeEditStr,
	afterEditStr	: String;
	trackedItem		: CM_TrackedItem;
	instructions	: CM_InstructionsIssued;
	instructionType : CM_InstructionType;
	
begin
	
	if self.updateVGMOnly then																			// TFS 4434
		// we should have an onsite TI - if we can find one, just update its VGM details				// TFS 4434
		ti := self.myTerminal.allOnsiteTIsByIdCargoType[self.id, self.cargoType];						// TFS 4434
		if ti &lt;&gt; null then																				// TFS 4434
			updController := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode(), null);	// TFS 4434
			ti.setIsWeightCertified(self.isWeightCertified, updController, _passport);					// TFS 4434
			//ti.setWeightCertifiedName(self.weightCertifiedName, updController, _passport);			// TFS 4434	// TFS 4492
			//ti.setWeightCertifiedReference(self.weightCertifiedReference, updController, _passport);	// TFS 4434	// TFS 4492
			ti.setMyVGMDetails(	self.weightCertifiedReference, self.weightCertifiedName,							// TFS 4492
								self.vgmAuthSignature, self.vgmCommsType, self.vgmDocumentDetails,					// TFS 4492
								self.vgmEDITransmission, self.vgmElectronicMail, self.vgmMail,						// TFS 4492
								self.vgmPhone, self.vgmTelefax, self.vgmTelephone, 									// TFS 4492
								self.vgmDocsIssuedDT, self.vgmDeterminationDT, updController	);					// TFS 4492
			ti.setTotalWeightWithoutTrans(self.weightTotal);											// TFS 4434
			return _passport.noErrors();																// TFS 4434
		endif;																							// TFS 4434
	endif;		
	
	
	// TFS 4434
	
	//Create the persistent TI, using the proxy TI we already validated
	// COU and Attachments have been added to proxy as part of validation

	instructionType := self.myTerminal.allInstructionTypes[self.instructionsType];	// 16.05.2025	navhn30	 MTN-34850 START
	if instructionType &lt;&gt; null then
		create instructions transient;
		instructions.setProxy(self.instructionsInternal, self.instructionsExternal,instructionType, self.myProxyTrackedItem);
	endif;																			// 16.05.2025	navhn30	 MTN-34850	END
	
	self.myPersistentTrackedItem := self.myTerminal.createTrackedItem(self.myProxyTrackedItem, _passport);	
	

	if (not _passport.noErrors) then
		return false;//N.B. epilog
	endif;
	
	if self.imExStatus &lt;&gt; null and self.imExStatus.code = TI_IMEX_STATUS_TRANSHIP then				// TFS 53084
		self.myPersistentTrackedItem.setTransitStatus(TI_TransitStatusInterModal, true, _passport);	// TFS 53084
	endif;
	
	//th2 CCMS#1452 - ability to add stops and todo tasks from prenote screen
	if self.doSetStops then
		self.myPersistentTrackedItem.createStops(self.allStops, false, false, _passport); //par15193 cnwrs1 oct 2007  //par 19389 cnwrs1 June 2009
	endif;
	
	if self.doSetToDoTasks then
		foreach toDoTaskDesc in self.allToDoTasks do
			self.myPersistentTrackedItem.addToDoTask(toDoTaskDesc.description, _passport);
		endforeach;
	endif;
	
	if transportMode.trimBlanks = TI_TRANSMODE_ROAD_STR then
		//Issue a road entry PIN number
		if not noPinRequired then // dh 17/6/2008 added this 'if' -  par 17083 - no pins required on some cargo
			//epr TFS 2011 7/6/16
			self.myPersistentTrackedItem.generatePIN( self.myEmailDefaults,false,_passport);
			if self.myPersistentTrackedItem.myPinNo &lt;&gt; null then
				self.pinNo :=self.myPersistentTrackedItem.myPinNo.pinNo;
			endif;
		endif;
			
	elseif transportMode.trimBlanks = TI_TRANSMODE_RAIL_STR then
		//rs 16July 2002 par 1982 the default rail carrier is not being set in rail prenote
		if self.myPersistentTrackedItem.carrier = null then
			self.myPersistentTrackedItem.setCarrier(_passport.myTerminal.getConfig(DefRailCarrier).String);
		endif;
		//Move it to the rail wagon
		//moveToRail();
		self.moveToRailNew(_passport);
	elseif transportMode.trimBlanks =  TI_TRANSMODE_SHIP_STR then
		//Move it to the ship stowage location. All on-ship items
		//start as transits, and will be changed if marked up on colour code
		if not self.isKindOf(CMIF_OnshipCargo) then //epr par 34881 11/9/14
			self.myPersistentTrackedItem.setImExStatus(TI_IMEX_STATUS_REMAINONBOARD);
		endif;
		
		// 25/01/2010 CCMS 1071 General Cargo OnshipCargo is already on the ship
		if self.isBOLItem() then // PAR 28400 isKindOf(CMIF_OnshipCargo) then
			self.myPersistentTrackedItem.setImExStatus(TI_IMEX_STATUS_IMPORT);
		endif;
		//epr TFS 2308 11/7/16
		if not self.isChild then
			self.moveToShip(_passport);
		endif;
	endif;

	if _passport.noErrors and self.damaged then
		// Create damaged transaction.
		create txnParams transient;
		txnParams.type			:= TRANS_TYPE_DAMAGED;
		txnParams.noCharge		:= true;
		
		self.myPersistentTrackedItem.createTransaction(txnParams, _passport);
		delete txnParams; //29/03/2023	navkc1	CR# 56430 TASK 56435
	endif;

	// ccms1035 -- Mohammad 15/11/2006 
	if _passport.noErrors() then
		//cnwyl1 for par13959
		//it was...
		//if app.myPassport.myTerminal.getConfig(AutoPlanPreNotifications).Boolean then
		if app.myPassport.myTerminal.isAutoPlanPreNotifications() and self.cargoType = TI_CargoType_Container then   //SFW1030 04/08/2008
			self.testYardAllocations(); 
		endif;
	endif;
	
	if _passport.noErrors() then																	// TFS 47334
		self.myPersistentTrackedItem.createSealCheckTranForAllSeals(SEAL_CHECK_RECORDED, null);		// TFS 47334
	endif;																							// TFS 47334
	
	//29/03/2023	navkc1	CR# 56430 TASK 56435 - Create overlanded transaction
	if _passport.noErrors() and self.isOverlanded() then
		create txnParams transient;
		txnParams.type := TRANS_TYPE_OVERLANDED;
		ti := self.myPersistentTrackedItem; //05/02/2023	navkc1 Bug 62302
		ti.createTransaction(txnParams, _passport);
		delete txnParams;
	endif;

	//Start - 22.04.2024 naviv1	#63619
	if _passport.noErrors and not self.allCustomsReferences.isEmpty then		
		//Start - 25.05.2024 naviv1 #64243
		trackedItem := self.myPersistentTrackedItem;
		beforeEditStr := trackedItem.getCustomsReferenceAuditString();	
		if beforeEditStr = null then							
			beforeEditStr := "null";							
		endif;	
		//End - 25.05.2024 naviv1 #64243
		
		self.myPersistentTrackedItem.saveCustomsReferences(self.allCustomsReferences,_passport);		//29.04.2024 naviv1	#63619
		
		//Start - 25.05.2024 naviv1 #64243
		afterEditStr := trackedItem.getCustomsReferenceAuditString();
		if afterEditStr = null then
			afterEditStr := "null";
		endif;
		
		if _passport.noErrors and beforeEditStr &lt;&gt; afterEditStr then
			trackedItem.createEditForCustomsReferences(beforeEditStr,afterEditStr,_passport);
		endif;
		//End - 25.05.2024 naviv1 #64243
	endif;
	
	if _passport.noErrors and not self.allSubItems.isEmpty then 				
		// TFS 63619 If MoveTIToParentTrailer is true, then children are on board, not actual children
		create allChildren transient;
		if self.myTerminal.getConfig(MoveTIToParentTrailer).Boolean and self.myPersistentTrackedItem.isChassis then
			self.myPersistentTrackedItem.CM_TILC.allLCs.first.allTrackedItems.copy(allChildren);
		else
			self.myPersistentTrackedItem.allChildren.copy(allChildren);
		endif;
		//foreach childTI in self.myPersistentTrackedItem.allChildren do 
		foreach childTI in allChildren do 
		// TFS 63619 end
			childId := childTI.id;
			foreach cmifTI in self.allSubItems do : cmif
				if cmifTI.getID() &lt;&gt; childId then 
					continue;
				endif;
				
				//Start - 25.05.2024 naviv1 #64243
				trackedItem := childTI;
				beforeEditStr := trackedItem.getCustomsReferenceAuditString();	
				if beforeEditStr = null then							
					beforeEditStr := "null";							
				endif;	
				//End - 25.05.2024 naviv1 #64243
				
				childTI.saveCustomsReferences(cmifTI.CMIF_PreNote.allCustomsReferences,_passport);		//29.04.2024 naviv1	#63619
				
				//Start - 25.05.2024 naviv1 #64243
				afterEditStr := trackedItem.getCustomsReferenceAuditString();
				if afterEditStr = null then
					afterEditStr := "null";
				endif;
				
				if _passport.noErrors and beforeEditStr &lt;&gt; afterEditStr then
					trackedItem.createEditForCustomsReferences(beforeEditStr,afterEditStr,_passport);
				endif;
				//End - 25.05.2024 naviv1 #64243
				
			endforeach;
		endforeach;		
	endif;
	//End - 22.04.2024 naviv1	#63619
	
	//05/02/2023	navkc1 Bug 62302 - Loop persistent child cargo
	if ti &lt;&gt; null then
		foreach childTI in ti.allChildren discreteLock do
			childId := childTI.id;
			// Find the cargo in CMIF, check is it overlanded
			foreach cmifTI in self.allSubItems do : cmif
				if cmifTI.getID() &lt;&gt; childId or not cmifTI.isOverlanded() then
					continue;
				endif;
				
				// Create Overlanded transaction
				create txnParams transient;
				txnParams.type := TRANS_TYPE_OVERLANDED;
				childTI.createTransaction(txnParams, _passport);
				delete txnParams;
				
				break cmif;
				
			endforeach;
		endforeach;
	endif;
	
	// TFS 62686 If I'm a MAFI and I have children, remove the children and move them to my first location controller
	if _passport.noErrors and (self.myPersistentTrackedItem.isMAFI or self.myPersistentTrackedItem.isTrailer) then		// TFS 65549
		mafi := self.myPersistentTrackedItem.CM_TILC;
		create children transient;
		create moveController transient;
		moveController.setMyToPrimaryLocation(mafi.allLCs.first);
		moveController.isForcedMove := true;
		mafi.allChildren.copy(children);
		foreach child in children do
			mafi.detachChild(child);
			moveController.setMyTrackedItem(child);
			moveController.myToPrimaryLocation.CM_TILCController.validateMoveTo(moveController);
			child.setMyLocationsPublic(moveController);
		endforeach;
	endif;
	// TFS 62686 end
	
epilog
	delete updController;							// TFS 4434
	delete children;				// TFS 62686
	delete moveController;			// TFS 62686
	delete txnParams; //29/03/2023	navkc1	CR# 56430 TASK 56435
	delete allChildren;				// TFS 63619
	delete txnParams;
	return _passport.noErrors;
end;</source>
        <Parameter name="pProxy" type="CM_Object" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="actionForUpdate" id="4bef5a97-4f77-4075-aa9f-7c0e9542d66e">
        <updating/>
        <source>actionForUpdate(pProxy: CM_Object io;
				pAuditAgent : CM_UpdateTransactionAuditAgent io;
				_isCheckEdition : Boolean;
				_passport : CM_Passport input): Boolean updating;
/* ---------------------------------------------------------------------------
Created:     14 February 2001 by cnwrs2

Purpose:     

Changed On  By  	TFS		Reason
----------   -----	-----	--------------------------------------------------
15/12/2015	cnwgb1			par 37172 Modify Action in EDI
06/06/2017	cnwdap1	4434 	SNO COPARN Prenotes and VGM Updates
29/06/2017	cnwdap1	4492 	SNO VERMAS Changes
21/11/2018  jlgrh7	41319 	MSL - weight non upgraded by COPARN
28 Nov 2019	jlgdi1	47738	Update the voyage of the TrackedItem if doesn't match with the voyage in CMIF_Prenote
							For VGM Update Only, replaced the method realTI.isNotified with realTI.isOnSite() to make it right.
22/04/2024	naviv1	63619 	CUX | FR - POST and PUT /Cargo not saving Customs References for Onboard Cargo
25/05/2024 	naviv1	64243	CUX | POST &amp; PUT /Cargo APIs - Edit Transaction not created when customs reference data updated via API
16 May 2025 navhn30 MTN-34850: TPT - Instructions are not populated after DB Loading a UDF
03 Jun 2025	navhn30	MTN-34997: TPT - Instructions removed on cargo when stops are removed
---------------------------------------------------------------------------*/
vars
	subItem							: CMIF_TIObject;
	nullObject						: CM_Object;
	txnParams						: CMIF_TITransactionController;
	expectedEdition					: Integer;
	realTI,childTI					: CM_TrackedItem;
	toDoTaskDesc					: CM_ToDoTaskDesc;
	tiUpdateCntrlr 					: CMIF_TIUpdateController;
	childId							: String;
	cmifTI							: CMIF_TIObject;
	beforeEditStr,
	afterEditStr					: String;
	trackedItem						: CM_TrackedItem;
	instructions					: CM_InstructionsIssued;
	instructionType 				: CM_InstructionType;

begin

	self.myOriginalProxyTI.raiseExceptionIfNotProxy(method);
	self.myOriginalProxyTI.pxyGetRealObjectAndEdition(realTI, expectedEdition);

	if realTI = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, null);
		return false;
	endif;

	exclusiveLock(realTI);

	if _passport.noErrors() and _isCheckEdition and realTI.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'tracked item', null, null);
		return false;
	endif;
	
	if _passport.noErrors() then
		pAuditAgent.CM_UpdateTransactionAuditAgent.audUpdateGeneric(realTI, true);
	endif;
	
	// TFS 4434 Only update VGM details if this is a COPARN prenote update of an onsite cargo item		// TFS 4434
	if self.updateVGMOnly and realTI.isOnSite() then													// TFS 4434
		tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode, null);		// TFS 4434
		realTI.setIsWeightCertified(self.isWeightCertified, tiUpdateCntrlr, _passport);					// TFS 4434
		//realTI.setWeightCertifiedName(self.weightCertifiedName, tiUpdateCntrlr, _passport);			// TFS 4434	// TFS 4492
		//realTI.setWeightCertifiedReference(self.weightCertifiedReference, tiUpdateCntrlr, _passport);	// TFS 4434	// TFS 4492
		realTI.setMyVGMDetails(	self.weightCertifiedReference, self.weightCertifiedName, 							// TFS 4492
								self.vgmAuthSignature, self.vgmCommsType, self.vgmDocumentDetails,					// TFS 4492
								self.vgmEDITransmission, self.vgmElectronicMail, self.vgmMail,						// TFS 4492
								self.vgmPhone, self.vgmTelefax, self.vgmTelephone,									// TFS 4492
								self.vgmDocsIssuedDT, self.vgmDeterminationDT, tiUpdateCntrlr	);					// TFS 4492
		realTI.setTotalWeightWithoutTrans (self.weightTotal);												//+TFS41319
		
		return _passport.noErrors();																	// TFS 4434
	endif;																								// TFS 4434

	// Create children &amp; COUs, attach them to us.
	foreach subItem in allSubItems do
		if not subItem.isNew and not subItem.actionForUpdate(nullObject, pAuditAgent, _isCheckEdition, _passport) then
			break;
		endif;
	endforeach;
	
	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode, null);
    if self.action = CM_EDITrackedItem.EDI_ACTION_MODIFY then  //PAR 37172 cnwgb1 15.12.2015
        tiUpdateCntrlr.isModifying := true;
    endif;
	
/*	Removed - 13 Mar 2020	NDL	TFS 48750
	if self.myProxyTrackedItem.voyageCode &lt;&gt; self.voyageCode then 
		self.myProxyTrackedItem.setVoyageCode(self.voyageCode, app.myPassport);
	endif; */
	
	instructionType := self.myTerminal.allInstructionTypes[self.instructionsType];	// 16.05.2025	navhn30	 MTN-34850 START
	if instructionType &lt;&gt; null then	
		if self.myProxyTrackedItem.myInstructions = null then						// 03.06.2025	navhn30	 MTN-34997
			create instructions transient;
			instructions.setProxy(self.instructionsInternal, self.instructionsExternal,instructionType, self.myProxyTrackedItem);
		else
			self.myProxyTrackedItem.myInstructions.setProxy(self.instructionsInternal, self.instructionsExternal,instructionType, self.myProxyTrackedItem);
		endif;
	endif;																			// 16.05.2025	navhn30	 MTN-34850	END
	
	if _passport.noErrors then
		if realTI.cargoType &lt;&gt; self.myProxyTrackedItem.cargoType then
			realTI.causeEvent(_passport.myTerminal.getTerminalEvent(TIEvent_PreNote_Delete), false, realTI);
			realTI.erase(NORMAL_ERASE);
			//Create the persistent TI, using the proxy TI we already validated
			realTI := self.myTerminal.createTrackedItem(self.myProxyTrackedItem, _passport);
			realTI.causeEvent(_passport.myTerminal.getTerminalEvent(TIEvent_PreNote_Add), false, realTI);
		else
			realTI.setForUpdate(self.myProxyTrackedItem, tiUpdateCntrlr, null, _isCheckEdition, _passport); //cnwrd1 28.8.09 par 20545
		endif;
	endif;

	
	if _passport.noErrors and self.damaged then
		// Create damaged transaction.
		create txnParams transient;
		txnParams.type			:= TRANS_TYPE_DAMAGED;
		txnParams.noCharge		:= true;
		
		realTI.createTransaction(txnParams, _passport);
	endif;
	
	if not _passport.noErrors then
		return false;
	endif;
	
	self.myPersistentTrackedItem := realTI;
	
	//+cnwml2 MSL CCMS 1012
	self.myPersistentTrackedItem.setExpectedArrivalDate(self.expectedArrivalDate);
	self.myPersistentTrackedItem.setExpectedArrivalTime(self.expectedArrivalTime);
	
	if self.doSetToDoTasks then
		self.myPersistentTrackedItem.allToDoTasksToDo.purge();
		foreach toDoTaskDesc in self.allToDoTasks do
			self.myPersistentTrackedItem.addToDoTask(toDoTaskDesc.description, _passport);
		endforeach;
	endif;
	
	if transportMode.trimBlanks = TI_TRANSMODE_ROAD_STR then
		if not noPinRequired then // dh 17/6/2008 added this 'if' -  par 17083 - no pins required on some cargo
			//epr TFS 2011 7/6/16
			self.myPersistentTrackedItem.generatePIN( self.myEmailDefaults,false,_passport);
			if self.myPersistentTrackedItem.myPinNo &lt;&gt; null then
				self.pinNo :=self.myPersistentTrackedItem.myPinNo.pinNo;
			endif;
		endif;
	elseif transportMode.trimBlanks = TI_TRANSMODE_RAIL_STR then
		//May need to move it to a new wagon
		//moveToRail();
		if self.myMasterObject = null then // Don't move children around, they belong with their parents cnwgb1 PAR 23419
			self.moveToRailNew(_passport);
		endif;
	endif;
	
	//Start - 22.04.2024 naviv1 #63619
	if _passport.noErrors and not self.allCustomsReferences.isEmpty then
		//Start - 25.05.2024 naviv1 #64243
		trackedItem := self.myPersistentTrackedItem;
		beforeEditStr := trackedItem.getCustomsReferenceAuditString();	
		if beforeEditStr = null then							
			beforeEditStr := "null";							
		endif;	
		//End - 25.05.2024 naviv1 #64243
		self.myPersistentTrackedItem.saveCustomsReferences(self.allCustomsReferences,_passport);		//29.04.2024 naviv1 #63619
		
		//Start - 25.05.2024 naviv1 #64243
		afterEditStr := trackedItem.getCustomsReferenceAuditString();
		if afterEditStr = null then
			afterEditStr := "null";
		endif;
		
		if _passport.noErrors and beforeEditStr &lt;&gt; afterEditStr then
			trackedItem.createEditForCustomsReferences(beforeEditStr,afterEditStr,_passport);
		endif;
		//End - 25.05.2024 naviv1 #64243
	endif;
	
	if _passport.noErrors and not self.allSubItems.isEmpty then 
		foreach childTI in self.myPersistentTrackedItem.allChildren do 
			childId := childTI.id;
			foreach cmifTI in self.allSubItems do : cmif
				if cmifTI.getID() &lt;&gt; childId then 
					continue;
				endif;
				//Start - 25.05.2024 naviv1 #64243
				trackedItem := childTI;
				beforeEditStr := trackedItem.getCustomsReferenceAuditString();	
				if beforeEditStr = null then							
					beforeEditStr := "null";							
				endif;	
				//End - 25.05.2024 naviv1 #64243
				
				childTI.saveCustomsReferences(cmifTI.CMIF_PreNote.allCustomsReferences,_passport);		//29.04.2024 naviv1	#63619
				
				//Start - 25.05.2024 naviv1 #64243
				afterEditStr := trackedItem.getCustomsReferenceAuditString();
				if afterEditStr = null then
					afterEditStr := "null";
				endif;
				
				if _passport.noErrors and beforeEditStr &lt;&gt; afterEditStr then
					trackedItem.createEditForCustomsReferences(beforeEditStr,afterEditStr,_passport);
				endif;
				//End - 25.05.2024 naviv1 #64243
			endforeach;
		endforeach;		
	endif;
	//End - 22.04.2024 naviv1 #63619
epilog
	delete tiUpdateCntrlr;
	delete txnParams;
	return _passport.noErrors;

end;</source>
        <Parameter name="pProxy" type="CM_Object" usage="io"/>
        <Parameter name="pAuditAgent" type="CM_UpdateTransactionAuditAgent" usage="io"/>
        <Parameter name="_isCheckEdition" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
