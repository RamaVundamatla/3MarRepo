    <JadeMethod name="hasChangedCuscarRules" id="b799a896-0ffb-4828-aa67-6e6befc9819d">
        <source>hasChangedCuscarRules() : Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#	Description
============================================================================
16 Apr 2014	cnwrd1			Initial creation
20 May 2019	jlgka1	42732	PNL - CUSCAR (Bayplan - Style).
============================================================================*/

begin
	if optBayPlan.value = true or 
		optShipManifest.value = true or
		self.cmbChildCargoTyp.listIndex &gt; 0  or //cnwrd1 par 34193		
		self.tblActionsCuscar.rows &gt; self.tblActionsCuscar.fixedRows // jlgka1 TFS 42732		
		then 
		return true;
	else
		return false;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasChangedIFCSUMRules" id="3a4f9e63-6dd9-45d1-a5b6-7a018212f9a7">
        <source>hasChangedIFCSUMRules() : Boolean protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
/****Changes

Date		Name	TFS#			Description
============================================================================
09/09/2016	cnwdap1					Initial creation TFS 2566
2/11/2018	jlgka1	39187, 39185	Added the option button and checkboxes 
									to trigger changes.
02/02/2023	jlika1	56385			POB - IFCSUM Tranship										
14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
28 Aug 2023	jlirs1	TFS 59170 (57770) IFCSUM Breakbulk and Mixed Cargo BOP
============================================================================*/
begin
	return	self.optSGP.value or
			self.optPCI.value or
			self.optBGM.value or
			self.optTDT.value or
			self.chkGIDMEA.value or
			self.chkCreateForGID.value or
			self.chkPIAComm.value or
			self.chkUseDischargeAsDestination.value or
			self.chkEQDTranshipCargo.value or
			self.cmbIFCSUMISOType.listIndex &gt; 0 or
			self.cmbIFCSUMCargoType.listIndex &gt; 0 or		//14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
			self.chkUseSystemids.value or					//28 Aug 2023	jlirs1	TFS 59170 (57770) IFCSUM Breakbulk and Mixed Cargo BOP
			self.tblActionsIFCSUMDet.rows &gt; self.tblActionsIFCSUMDet.fixedRows or
			self.tblActionIFCSUMHS.rows &gt; self.tblActionIFCSUMHS.fixedRows or
			self.tblActionsIFCSUM.rows &gt; self.tblActionsIFCSUM.fixedRows;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
