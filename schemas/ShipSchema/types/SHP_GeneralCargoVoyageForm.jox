    <JadeMethod name="addItemObjectToTable" id="455b5720-38f4-459a-956c-0fe6cfba43e8">
        <source>addItemObjectToTable(_obj : CM_Object io; _table : CM_DataTable input);
//--------------------------------------------------
// Created:	07 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	rowIdx,
	backColour : Integer;
	str : String;
begin
	
	if _obj = null 
	or _table = null then
		return;
	endif;	
	
	on Exception do self.handleExceptionObject(exception, _obj);
	_obj.fetchLatest();
	if _obj = null then
		return;
	endif;	

	str := _obj.getAttributeStringForDefArray(_table.allTblDataEntRows);
	rowIdx := _table.addItemObject(_obj, str);

	if rowIdx mod 2 = 0 then
		backColour := self.colorRow1;
	else
		backColour := self.colorRow2;
	endif;
	_table.accessedRow.backColor := backColour;	
	
	self.addNotableObject(_obj);
	
end;</source>
        <Parameter name="_obj" type="CM_Object" usage="io"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addNotableObject" id="e1c8fdb1-6dcc-4527-9084-6ab80b2cbf98">
        <source>addNotableObject(_obj : CM_Object);
//--------------------------------------------------
// Created:	07 February 2006 By: cnwgd1
//--------------------------------------------------
vars
begin
	if _obj = null then
		return;
	endif;
	
	if (not global.isValidObject(_obj)) then
		return;
	endif;
	
	if self.allNotableObjects.includes(_obj) then
		return;
	endif;
	
	self.allNotableObjects.add(_obj);
	if CM_Voyage.hasInstance(_obj) then
		self.beginNotification(_obj, VoyageBOLIn_Create_Event, Response_Continuous, null);
	else
		beginNotification(_obj, Object_Update_Event, Response_Continuous, null);
		beginNotification(_obj, Object_Delete_Event, Response_Continuous, null);
	endif;

	if CM_BOL.hasInstance(_obj) then
		self.beginNotification(_obj, self.myTerminal.getTerminalEvent(BOL_Update_Event), Response_Continuous, 0);
	endif;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="975723bf-40b5-4924-9aee-bc95b5c6a61a">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	01 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	toolbar		: CMUI_Toolbar;
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);			
	toolbar.addButton(self.btnReportOptions, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShowSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);													
	toolbar.addButton(self.btnVoyageDefin, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSelectAll, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveIt, CMUI_Toolbar.Control_Alignment_Left);		
	toolbar.addButton(self.btnCreateCargo, CMUI_Toolbar.Control_Alignment_Left);	
	
	//JPC Added 17/05/2006
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnImportTasks, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnCustomsEDI, CMUI_Toolbar.Control_Alignment_Left);
	
	// cnwrl1 17/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - start of coding
	if self.bAllowSummaryDefn then
		toolbar.addSeperator( CMUI_Toolbar.Control_Alignment_Left );
		toolbar.addButton( self.btnSummariseAll, CMUI_Toolbar.Control_Alignment_Left );
	endif;
	// cnwrl1 17/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - end of coding
	
	// DVB added 14/02/2006
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmImportExport, CMUI_Toolbar.Control_Alignment_Left);

//	toolbar.addButton(self.btnImport, CMUI_Toolbar.Control_Alignment_Left);	
//	toolbar.addButton(self.btnExport, CMUI_Toolbar.Control_Alignment_Left);	
			
//	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

	//============================================================
	// Now setup the second toolbar
	//============================================================
	toolbar := self.frmToolbar2;

	toolbar.addFrame(self.frmToolbarRetro, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.positionToolbarControls();

	//=======================================
	// now setup searchToolbar
	//=======================================
	toolbar := self.frmSearchToolbar;

	toolbar.addButton(self.btnSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnClearSearch, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnCloseSearch, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;	
	
	self.setToolbarSearch();	

end;</source>
        <access>protected</access>
    </JadeMethod>
