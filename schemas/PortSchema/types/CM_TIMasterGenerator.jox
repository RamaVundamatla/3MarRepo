    <JadeMethod name="convertFromEDIFleetTi" id="c2d56532-01b5-48eb-b40b-6ebcaee6c896">
        <updating/>
        <source>convertFromEDIFleetTi( _ediFleet : CM_EDIFleetTI; _operator : CM_Operator) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2008	cnwrd1	Initial creation

*/

vars
	genType : CM_GeneratorType;
begin
	inheritMethod( _ediFleet , _operator );


	self.isoType := _ediFleet.isoType;
	
	genType := app.myRoot.allGeneratorTypes[_ediFleet.generatorType];
	
	if genType = null then
		genType := app.myRoot.allGeneratorTypes.first;
	endif;

	self.myGeneratorType :=  genType;
	
	
epilog

end;</source>
        <Parameter name="_ediFleet" type="CM_EDIFleetTI"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
