    <JadeMethod name="getSlotOverMe" id="f8439a87-5f72-485a-a742-314be52df7ce">
        <source>getSlotOverMe() : CM_ROROSlotController;
/*
Purpose:			Returns the slot above this RORO slot

Parameters:			

Return Value:		

Date		Who		Reason
19/12/2011	cnwdap1	Initial creation PAR #26619 CCMS POL 2098
*/
vars
	slotDefinition	: CM_ROROSlotDefnVoyage;
	locnDefinition	: CM_ROROLocnDefn;
	checkOrdinal	: Integer;

begin
	locnDefinition := self.mySlotDefn.myROROLocnDen;
	checkOrdinal := self.mySlotDefn.ordinal + 1;
	
	slotDefinition := locnDefinition.allROROSlotDefnByOrdinal[locnDefinition.ordinal, checkOrdinal].CM_ROROSlotDefnVoyage;
	if slotDefinition &lt;&gt; null then
		return slotDefinition.mySlotController;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_ROROSlotController"/>
    </JadeMethod>
    <JadeMethod name="getSlotUnderneathMe" id="c79814d7-40e3-43a1-ae47-89e017d7323e">
        <source>getSlotUnderneathMe() : CM_ROROSlotController;
/*
Purpose:			Get the RORO slot controller underneath this slot controller (if tehre is one)

Parameters:			None

Return Value:		CM_ROROSlotController underneath this slot controller

Date		Who		Reason
08/12/2011	cnwdap1	Initial creation PAR #26619 CCMS SFW 1260
*/
vars
	slotDefinition	: CM_ROROSlotDefnVoyage;
	locnDefinition	: CM_ROROLocnDefn;
	checkOrdinal	: Integer;

begin
	locnDefinition := self.mySlotDefn.myROROLocnDen;
	checkOrdinal := self.mySlotDefn.ordinal - 1;
	if checkOrdinal = null then
		return null;
	endif;
	
	slotDefinition := locnDefinition.allROROSlotDefnByOrdinal[locnDefinition.ordinal, checkOrdinal].CM_ROROSlotDefnVoyage;
	if slotDefinition &lt;&gt; null then
		return slotDefinition.mySlotController;
	endif;
epilog

end;</source>
        <ReturnType type="CM_ROROSlotController"/>
    </JadeMethod>
    <JadeMethod name="getSpannedToLCs" id="dbd681fc-ffbc-4a93-8211-c3046317e53e">
        <source>getSpannedToLCs(_control: CMIF_MoveController input): Boolean;
/*
Purpose:	Work out how many LCs this cargo requires		
Date				Who			Reason
JANUARY 2012		CNWAB1		Initial creation
*/

vars
	units : Real;
	tArray : CM_LCArray;
	lc : CM_ROROSlotController;
	count : Integer;
	aftSlot : CM_ROROSlotDefnVoyage;
begin
	// if we have already set multiple locations for this TI then get out, break bulk can take up more than one slot
	if _control.allToLocations.size &gt; 1 then
		if _control.myTrackedItem &lt;&gt; null then
			if _control.myTrackedItem.isKindOf(CM_Cargo) then
				return true;
			endif;
		endif;
	endif;

	inheritMethod(_control);		//Clears toSecondaryLocations coll (no return)

	//Determine the # of spaces this TI will take up
	if _control.myTrackedItem.is30() then // PAR 32225
		units := 4;  // PAR 32225 for RORO Slots treat 30s as  40s
	else
		units := _control.myTrackedItem.getLengthInUnits();
	endif;
	if units &lt;= 2 then
		//---------------
		//This controller will carry it off (2 * 10' units = my size. i.e. 1 * 20' unit)
		//---------------
		return true;
	endif;
	//---------------
	//Convert to 20' scale
	//---------------
	units := units div 2;
	//---------------
	//Because each of me is a 20' unit, I need 1 for each 2 units returned from the call
	//as they are 10' units as well
	//---------------
	aftSlot := self.mySlotDefn.CM_ROROSlotDefnVoyage.getAftSlotDefn().CM_ROROSlotDefnVoyage;
	
	if aftSlot = null then 
		//There is NO next LC (slot)!

		return false;
	endif;

	create tArray transient;
	lc := aftSlot.mySlotController;
	count := 1;
	while true do
		if lc = null then
			break;
		endif;
		count := count +1;
		tArray.add(lc);
		if count = units then
			break;
		endif;	
		aftSlot := aftSlot.getAftSlotDefn().CM_ROROSlotDefnVoyage;
		if aftSlot = null then
			lc := null;
			return false;
 		else
			lc := aftSlot.mySlotController;
		endif;
	endwhile;	
	//--------------------
	//Return whether there are enough positions
	//--------------------
	if (tArray.size + 1) &lt;&gt; units then
		//Subtract 1 for the current lc where we started from (its NOT in the array returned)
		return false;
	endif;
	//Set the array
	_control.setMyToSecondaryLocations(tArray);
	return true;
epilog
	delete tArray;
end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
