    <JadeMethod name="close_click" id="49d6d416-6f32-4758-9c0d-a3f6c6586c34">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>close_click(btn: Button input) updating;

vars

begin
	self.unloadForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findNextTI_click" id="1d8c1a12-a386-4fb1-ae37-1052b07ba1b9">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>findNextTI_click(btn: Button input) updating;

vars
	i : Integer;
	x : Integer;
begin
	x := reefers.listIndex+1;
	if x &lt; 1 then
		x := 1;
	endif;
	
	foreach i in x to reefers.listCount do
		if anyPartofTI.value = false then
			if reefers.itemText[i][1:tiFind.text.length] = tiFind.text then
				reefers.listIndex := i;
				reefers_click(self.reefers);
				return;
			endif;
		else
			if reefers.itemText[i].pos(tiFind.text,1) &gt; 0 then
				reefers.listIndex := i;
				reefers_click(self.reefers);
				return;
			endif;
		endif;
	endforeach;
	
	app.msgBox("There are no more instances of " &amp; tiFind.text,"",0);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findTI_click" id="1a9141de-3ece-4c60-aa9a-55220f2c716d">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>findTI_click(btn: Button input) updating;

vars
	i : Integer;
begin
	foreach i in 1 to reefers.listCount do
		if anyPartofTI.value = false then
			if reefers.itemText[i][1:tiFind.text.length] = tiFind.text then
				reefers.listIndex := i;
				reefers_click(self.reefers);
				return;
			endif;
		else
			if reefers.itemText[i].pos(tiFind.text,1) &gt; 0 then
				reefers.listIndex := i;
				reefers_click(self.reefers);
				return;
			endif;
		endif;
	endforeach;
	
	app.msgBox(tiFind.text &amp; " was not found","",0);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllContainers" id="2956e727-7bbe-4b89-843b-eb1a69dc6a73">
        <updating/>
        <source>getAllContainers() updating;

vars
	ti			: Yrk_Container;
begin
	oidContainerArray.clear;
	
	foreach ti in Yrk_Container.instances do
		oidContainerArray.add(ti.getOidAsString);
		reefers.addItem(ti.id.String);
		app.doWindowEvents(0);
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="a9d391d9-16d6-40b3-9535-bc3dd3804a83">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

vars

begin
	self.centreWindow;
	getAllContainers;
	write process.isNavdap1.String;
end;</source>
    </JadeMethod>
    <JadeMethod name="reefers_click" id="6cb1dbf6-c61d-4ed4-94d4-47f4b0e0c730">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>reefers_click(listbox: ListBox input) updating;

vars
	ti : Yrk_Container;
begin
	ti := oidContainerArray[listbox.listIndex].String.asOid.Yrk_Container;
	
	txtID.text := ti.id.String;
	txtLocId.text := ti.locationID.String;
	txtNewTemp.text := ti.tempSupply.String;
	tempRange.caption := ti.tempMin.String &amp; " to " &amp; ti.tempMax.String &amp; " C";
	
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="reefers_dblClick" id="2eb8e059-1280-4e14-a444-45a579ee443d">
        <controlMethod name="ListBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>reefers_dblClick(listbox: ListBox input) updating;

vars
	ti : Yrk_Container;
begin
	ti := oidContainerArray[listbox.listIndex].String.asOid.Yrk_Container;
	
	txtID.text := ti.id.String;
	txtLocId.text := ti.locationID.String;
	txtNewTemp.text := ti.tempSupply.String;
	tempRange.caption := ti.tempMin.String &amp; " to " &amp; ti.tempMax.String &amp; " C";	

	ti.inspect;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="send_click" id="3417cbc1-2775-4403-87f3-3822a4c08ba4">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>send_click(btn: Button input) updating;

vars
	ti : Yrk_Container;
begin
	if reefers.listIndex &gt; 0 then
		ti := oidContainerArray[reefers.listIndex].String.asOid.Yrk_Container;
		beginTransaction;
			ti.setTempSupply(txtNewTemp.text.Real);
		commitTransaction;
		parentForm.sendOnlyOne(ti);
	else
		if process.isNavdap1 then
			parentForm.sendOnlyOneNoTI(self.txtID.text, self.txtNewTemp.text.Real);
		endif;
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
</GUIClass>
