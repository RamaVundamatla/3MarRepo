    <JadeMethod name="aTrxSample" id="a7b8a85d-d733-40c6-ba62-03de6e44f7e3">
        <updating/>
        <source>aTrxSample(_obj : CM_TrxTestObject io; _controller : CM_TrxTestController; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     15 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

		// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	app.myUtilityDA.aUtlSample(_obj, _controller, _passport);

epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_obj" type="CM_TrxTestObject" usage="io"/>
        <Parameter name="_controller" type="CM_TrxTestController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDeleteTerminalBRXrefObjects" id="450494c0-55a3-42e8-af56-07d9fa1a77fb">
        <updating/>
        <source>doDeleteTerminalBRXrefObjects(_terminal : CM_Terminal;
							  _brXref : CM_TerminalTIsByBR input;
							  _passport : CM_Passport input) updating, protected;

/*

Purpose:			Delete the children of the passed in Booking Reference cross reference, in multiple
					database transactions if required to prevent locking contention

Parameters:			Terminal cross reference is for, cross reference parent

Return Value:		None


Date		Who		Reason
28 Aug 2009	cnwkpd1	PAR #20398 - Add Booking Reference cross reference functionality

*/

constants
	MaxTransactionTime	= 2000;
	
vars
	lastCommit,
	now				: Decimal[20];
	xrefObject		: CM_TrackedItemBRXref;
	
	iter			: Iterator;

	totalToProcess,
	processedCount	: Integer;
	cmifMonitor 	: CMIF_Monitor;
	
begin
	// Mark header as incomplete, so enquiry forms will stop using it
	_brXref.setXrefComplete(false);

	app.writeLog("Deleting children of Booking Ref cross reference for Terminal " &amp; _terminal.displayForXlation(false), LogINFO);

	// Commit header change first
	_passport.doDeferredUpdates();
	app.cmsCommitTransaction(_passport);
	
	cmifMonitor := _passport.myCMIFMonitor;
	if cmifMonitor &lt;&gt; null then
		// Get the total number of objects to process
		totalToProcess := _brXref.allTIXrefsByTI.size();
	endif;
	
	lastCommit := app.relativeMachineTime();
	beginTransaction;
	
	// Now process all the child objects
	iter := _brXref.allTIXrefsByTI.createIterator();
	
	while iter.next(xrefObject) do
	
		// Check for commit first
		now := app.relativeMachineTime();
		if now - lastCommit &gt; MaxTransactionTime then
			_passport.doDeferredUpdates();
			app.cmsCommitTransaction(_passport);
				
			// Check for cancel outside transaction state
			if cmifMonitor &lt;&gt; null then
				if not cmifMonitor.updateProgress(cmifMonitor.message, totalToProcess, processedCount) then
					app.writeLog("Delete of Booking Ref cross reference for Terminal " &amp; _terminal.displayForXlation(false) &amp; " cancelled", LogINFO);
					app.raiseCMException(VB_USER_CANCELED_TRANS, null, null);
					return;
				endif;
			endif;
				
			lastCommit := app.relativeMachineTime();
			beginTransaction;
		endif;
		
		delete xrefObject;
		processedCount := processedCount + 1;
		
	endwhile;
	
	app.writeLog("Delete of " &amp; processedCount.String &amp; " children complete", LogINFO);
	
	
epilog
	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_brXref" type="CM_TerminalTIsByBR" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDeleteYardInternalJobs" id="be764c1d-9adb-465b-8d21-6b82e38cf61b">
        <updating/>
        <source>doDeleteYardInternalJobs( _yardJobSet:CM_YardJobSet; _passport : CM_Passport input): Boolean updating;

/*

Purpose:			
Refactored from trxDeleteYardInternalJob due to exception issues .

Parameters:			

Return Value:		


Date		Who		Reason
11 Sep 2009	cnwrd1	Initial creation
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	alertCreated	: Boolean;
	yardJob			: CM_YardJob;
	wle				: CM_WorkListEntry;
	control			: CMIF_MoveController;
	wleSet			: CM_WLESet;
	invalid 		: Boolean;
	
begin

	create control transient;
	create wleSet transient;
	control.setMoveMode(QUEUE_MODE);
	control.isForcedMove := true;
	control.isSystemMove := true;
	
	on Exception do app.handleDeletedObject(exception, wle, invalid);
	
	foreach yardJob in _yardJobSet do
//		self.initialiseActivityWithPassport(_passport, method);	
		exclusiveLock(yardJob);	
		wleSet.clear();
		yardJob.workListEntries.copy(wleSet);
		beginTransaction;
		foreach wle in wleSet do
			// Safe guard. Things can get pretty tricky.
//			if not global.isValidObject(wle) then
//				continue;
//			endif;
			if wle.myTrackedItem &lt;&gt; null then
				exclusiveLock(wle.myTrackedItem);
				control.setMyToPrimaryLocation(null);
				control.setMyWorkListEntry(wle);
				control.setMyTrackedItem(wle.myTrackedItem);
				app.myUtilityUA.utlUpdateMoveTIUndo(control, _passport);
			else		
				wle.unQueueWLE(_passport);
			endif;	
		endforeach;
		//app.myUtilityDA.utlDeleteYardInternalJob(yardJob, _passport); 
	//	if global.isValidObject(yardJob) then // have exclusive lock...
		yardJob.erase(NORMAL_ERASE);
	//	endif;
		if _passport.hasErrors then
			alertCreated := true;
			app.convertErrorsWarningsToAlert('Job ' &amp; yardJob.jobId &amp; ' could not be deleted', _passport.allErrorWarnings);
			app.cmsAbortTransaction();
		else
			app.cmsCommitTransaction(_passport);
		endif;
	endforeach;
	
	return alertCreated;
	
epilog

	delete control;
	delete wleSet;
end;</source>
        <Parameter name="_yardJobSet" type="CM_YardJobSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="trxCleanupSeaManifest" id="4afe73aa-88ef-4437-b388-860443ec12cc">
        <updating/>
        <source>trxCleanupSeaManifest(_ediData : CM_EDIDataTransManifest; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2023	jlirs1	Initial creation TFS 59324 (58026) EUP

*/

vars

begin
