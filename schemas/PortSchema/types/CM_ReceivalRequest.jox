    <JadeMethod name="getAttrHazardousList" id="fd2230ad-c758-4f16-bad3-2714d1db358c">
        <source>getAttrHazardousList(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2017	cnwrh7	Initial creation for TFS4725

*/

vars
	criteria 		: CM_YACriteria;	
	value			: String;				
	length			: Integer;			
begin
	criteria := self.getAttrByType(YACriteriaType_Hazardous);
	if criteria &lt;&gt; null then
			// get the critiera into an array
		value := criteria.myYAData.getDataValue().String;
		return value;
	endif;
	return "";
epilog

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBooking" id="4952bb33-c64f-43a3-8e80-d2749e85f223">
