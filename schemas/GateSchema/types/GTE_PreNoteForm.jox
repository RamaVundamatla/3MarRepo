    <JadeMethod name="cmbCountryOfOrigin_lostFocus" id="3f4f7192-86f3-4bef-9376-0b52ea8bc144">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCountryOfOrigin_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Aug 2022 navtnr20 ChangeRequest 54441: EUP - Additional Field - Country of Origin

*/

vars

begin
	if combobox.listObject &lt;&gt; null then
		self.tblSearch.setValueByName(ETRow_CountryOfOrigin, combobox.listObject.CM_Country.code);

	elseif combobox.text = Any_String then
		self.tblSearch.setValueByName(ETRow_CountryOfOrigin, Any_String);
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
