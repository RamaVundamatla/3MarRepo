    <JadeMethod name="doBtnPropSaveClick" id="762e9e94-f571-435c-9821-1de2053ffc5c">
        <updating/>
        <source>doBtnPropSaveClick() updating;
// ---------------------------------------------------------------------------
// Created:     21 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.updateMode = self.UpdateMode_Copy then
		self.doCopy();
	else
		//epr par 34982 2/10/14
		if not self.doSave() then
			return;
		endif;
	endif;
	
	self.frmProperties.visible := false;
	self.lstData.enabled := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCopy" id="28de00f7-9159-4ba6-a72a-ce66594b8f4e">
        <updating/>
        <source>doCopy()updating;
// ---------------------------------------------------------------------------
// Created:     25 January 2005	cnwhjg1
//
// Purpose:     Create a copy of calendar of date that has been selected
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	aCalendarDate,
	pxyCalendarDate	:	CM_CalendarDate;
	aCalendar,
	pxyCalendar		:	CM_Calendar;
	aCalendarYear,
	pxyCalendarYear	:	CM_CalendarYear;
	newDate			: 	Date;	
	ls				: 	Boolean;
	theReturn 		:	Integer;
begin

	if self.modePropertyNew = self.MODEPROPERTY_DATE then
		app.cmsBeginLoad(ls);
		pxyCalendarDate := app.createUpdateProxy(self.myCurrentDate).CM_CalendarDate;
		app.cmsEndLoad(ls);
	elseif self.modePropertyNew = self.MODEPROPERTY_YEAR then
		app.cmsBeginLoad(ls);
		pxyCalendarYear := app.createUpdateProxy(self.myCurrentYear).CM_CalendarYear;
		app.cmsEndLoad(ls);
	else
		app.cmsBeginLoad(ls);
		pxyCalendar := app.createUpdateProxy(self.myCurrentCalendar).CM_Calendar;
		app.cmsEndLoad(ls);		
	endif;	
	
	// ### SET PROXY CALENDAR DATE
	if self.modePropertyNew = self.MODEPROPERTY_DATE then
		newDate := self.getDateForCopy(self.myCurrentYear, self.myCurrentDate);
	
		pxyCalendarDate.setProxy(newDate, self.tblCalendar.getValueByName(ETRow_DescriptionDate).String, 
								self.myCurrentCalendar, self.myCurrentYear, 0);	

	// ### SET PROXY CALENDAR
	elseif self.modePropertyNew = self.MODEPROPERTY_YEAR then
	
		pxyCalendarYear.setProxy(self.tblCalendar.getValueByName(ETRow_Year).Integer, self.cmbCalendarCode.myObject.CM_Calendar);	
	
	else
		pxyCalendar.setProxy(	self.tblCalendar.getValueByName(ETRow_Code).String,
								self.tblCalendar.getValueByName(ETRow_DescriptionCalendar).String,
								pxyCalendar.hasEndTime,	//_hasEndTime : Boolean;
								pxyCalendar.hasTime,	//_hasTime : Boolean;
								pxyCalendar.myDayType,	//_myDayType : CM_DayType;
								pxyCalendar.myHookCode,	//_myHookCode : CM_HookCode;
								pxyCalendar.myHookLink,	//_myHookLink : CM_HookLink;
								pxyCalendar.allTerminals	//_allTerminals : CM_TerminalByCodeDict
								);
	endif;

	while true do
		if self.modePropertyNew = self.MODEPROPERTY_DATE then
			// ### TRX NEW DATE
				app.myTrxCA.trxCreateCalendarDate(pxyCalendarDate, aCalendarDate, app.myPassport);
		elseif self.modePropertyNew = self.MODEPROPERTY_YEAR then
		
				app.myTrxCA.trxCreateCalendarYear(pxyCalendarYear, aCalendarYear, app.myPassport, true);
		else
			// ### TRX NEW cALENDAR
				app.myTrxCA.trxCreateCalendar(pxyCalendar,aCalendar,app.myPassport, true);
		endif;

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Calendar", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	self.frmProperties.visible := false;
	self.lstData.enabled := true;
	
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	delete pxyCalendarYear;
	delete pxyCalendar;
	delete pxyCalendarDate;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="fcfd78af-1932-4989-8888-140fde2e1505">
        <updating/>
        <source>doDelete() updating;
// ---------------------------------------------------------------------------
// Created:     25 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

//	anObject : Object;
	anDate : CM_CalendarDate;
	anCalendar : CM_Calendar;
	anYear : CM_CalendarYear;
	theReturn, idx : Integer;
	label : String;
begin
	if self.modePropertyUpdate = self.MODEPROPERTY_DATE then
		anDate := self.myCurrentDate;
		if anDate = null then
			global.beep;
			app.msgBox("Please select a date.", app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		if app.msgBox(app.getErrorString1(Lit_Confirm_Delete, self.myCurrentDate.date.String),app.getErrorString(Confirm_Delete),
						MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	elseif self.modePropertyUpdate = self.MODEPROPERTY_YEAR then
		anYear := self.myCurrentYear;
		if anYear = null then
			global.beep;
			app.msgBox("Please select a Year.", app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		if app.msgBox("Are you sure that you want to delete " &amp; anYear.year.String
					 &amp; Cr &amp; Cr &amp; app.getErrorString(SOP_This_Will_Delete2), app.getErrorString(Confirm_Delete),
						MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	elseif self.modePropertyUpdate = self.MODEPROPERTY_CALENDAR then
		anCalendar := self.myCurrentCalendar;
		if anCalendar = null then
			global.beep;
			app.msgBox("Please select a Calendar.", app.getErrorString(INV_Delete_Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		if app.msgBox("Are you sure that you want to delete " &amp; anCalendar.code
					 &amp; Cr &amp; Cr &amp; app.getErrorString(SOP_This_Will_Delete1), app.getErrorString(Confirm_Delete),
						MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	endif;

	while true do
		if self.modePropertyUpdate = self.MODEPROPERTY_DATE then
		 	app.myTrxDA.trxDeleteCalendarDate(anDate, app.myPassport);
		elseif self.modePropertyUpdate = self.MODEPROPERTY_YEAR then 
		 	app.myTrxDA.trxDeleteCalendarYear(anYear, app.myPassport);
		 elseif self.modePropertyUpdate = self.MODEPROPERTY_CALENDAR then
		 	app.myTrxDA.trxDeleteCalendar(anCalendar, app.myPassport);
		 endif;
		 
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			return ;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(SOP_Calendar_Delete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return ;
		endif;
		break;
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="doLstDataClick" id="9f22e4e7-3969-4b81-b3e8-d18d4c5d10eb">
        <updating/>
        <source>doLstDataClick(listbox: ListBox input) updating;
// ---------------------------------------------------------------------------
// Created:     24 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	anObject : Object;
begin
	inheritMethod(listbox);

	if listbox.listIndex &lt;= 0 then
		self.modePropertyUpdate := null;	
		self.myCurrentDate := null;
		self.myCurrentYear := null;
		self.myCurrentCalendar:= null;	
		return;
	endif;

	anObject := listbox.itemObject[listbox.listIndex];
	self.modePropertyNew := null;

	if anObject = null 
	or anObject.isKindOf(CM_Root) then
		self.modePropertyUpdate := null;	
		self.myCurrentDate := null;
		self.myCurrentYear := null;
		self.myCurrentCalendar:= null;
	elseif anObject.isKindOf(CM_CalendarDate) then
		self.modePropertyUpdate := self.MODEPROPERTY_DATE;
		self.myCurrentDate := anObject.CM_CalendarDate;
		self.myCurrentYear := self.myCurrentDate.myCalendarYear;
		self.myCurrentCalendar := self.myCurrentDate.myCalendar;
	elseif anObject.isKindOf(CM_CalendarYear) then
		self.modePropertyUpdate := self.MODEPROPERTY_YEAR;
		self.myCurrentDate := null;
		self.myCurrentYear := anObject.CM_CalendarYear;
		self.myCurrentCalendar := self.myCurrentYear.myCalendar;
	elseif anObject.isKindOf(CM_Calendar) then
		self.modePropertyUpdate := self.MODEPROPERTY_CALENDAR;
		self.myCurrentDate := null;
		self.myCurrentYear := null;
		self.myCurrentCalendar:= anObject.CM_Calendar;
	endif;

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLstDataContextMenu" id="8aa063ba-16ab-4d78-b993-72d453a39736">
        <updating/>
        <source>doLstDataContextMenu(listbox: ListBox input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     25 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	self.mnuInspect.visible := app.isAllowedToInspect();
	
	self.mnuMain.visible := self.mnuInspect.visible;
	
	return self.showContextMenu(self.mnuMain, listbox, conwin, mouse, x, y);

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
