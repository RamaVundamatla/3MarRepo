<Class name="CM_AutoTaskEDITerminal" id="9010b9fa-d0ce-4e04-952d-d63dd89b4e26">
    <superclass name="CM_AutoTask"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Run EDI Terminal&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <CompAttribute name="allEDIDataTypes" id="b4d49b98-88e0-4ae9-83cc-53b46e53fe45">
        <type name="IntegerArray"/>
        <access>readonly</access>
    </CompAttribute>
    <PrimAttribute name="deleteOldData" id="ebc1ce9b-9a1c-42d6-9b3f-9cb59813403e">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="processEventRequestStops" id="5c5009ec-4770-4054-b64a-f69d8aa6b10d">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="processNewFiles" id="56b31d6f-4acd-4446-b2d3-b2891a8968bf">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getEDIDataTypesDisplay" id="0e5f51cd-de07-46cb-a4f4-ff02d4bdf609">
        <source>getEDIDataTypesDisplay():String;
/*
Date		Who		Reason
06 Aug 2012	cnwcs5	Initial creation - par 	30136
*/
vars
	dataType	:Integer;
	result		:String;
	agent		:CM_EDIControllerAgent;
begin
	create agent transient;
	
	foreach dataType in self.allEDIDataTypes do
		if result &lt;&gt; null then
			result := result &amp; ', ';
		endif;
		
		result := result &amp; agent.getEDIDisplayStrForType (dataType);
	endforeach;
	
	return result;
epilog
	delete agent;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEntryTableViewName" id="38c2f42f-0c3c-4b8b-86e0-ff56154a2b18">
        <source>getEntryTableViewName(): String;

// cnwdvb1 22 January 2003 

vars

begin
	return 'bgpAutoViewEdi';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForRow" id="71f30258-d0b6-4728-a7f3-d63b35f14aef">
        <source>getValueForRow(_rowName: String; _obj: Object output): Any;
/*
Date		Who		Reason
06 Aug 2012	cnwcs5	Initial creation - par 30136
*/
vars

begin
	if _rowName = ETRow_BgpEDIDeleteOldEDIData then 
		return self.deleteOldData; 
		
	elseif _rowName = ETRow_BgpEDIProcessEvReqStops then
		return self.processEventRequestStops;
		
	elseif _rowName = ETRow_BgpEDIProcessNewFiles then
		return self.processNewFiles; 
		
	elseif _rowName = ETRow_BgpEDIReprocessFiles then
		_obj := self.allEDIDataTypes;
		
		return self.getEDIDataTypesDisplay;
	else
		return inheritMethod(_rowName, _obj);
	endif;
epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0c4ef090-8c14-4c46-849e-e34c1b5a2c95">
        <updating/>
        <source>setForCreate(_proxy: CM_AutoTaskEDITerminal) updating;

// cnwdvb1 22 January 2003 

// 02 Aug 2012	cnwcs5	par 30136 - EDI BGP Spilt

vars

begin
	inheritMethod(_proxy);
	
	self.requestClassName 			:= BGP_EdiRequest.name;
	self.deleteOldData				:= _proxy.deleteOldData;			// par 30136 Aug 2012
	self.processEventRequestStops	:= _proxy.processEventRequestStops;	// par 30136 Aug 2012
	self.processNewFiles			:= _proxy.processNewFiles;			// par 30136 Aug 2012
	
	self.allEDIDataTypes.clear;											// par 30136 Aug 2012
	
	_proxy.allEDIDataTypes.copy (self.allEDIDataTypes);					// par 30136 Aug 2012
end;</source>
        <Parameter name="_proxy" type="CM_AutoTaskEDITerminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b12e5e2e-6af3-4d51-8762-132383d24096">
        <updating/>
        <source>setForUpdate(_proxy: CM_AutoTaskEDITerminal) updating;
/*
Date		Who		Reason
06 Aug 2012	cnwcs5	Initial creation - par 30136
*/
vars

begin
	inheritMethod(_proxy);
	
	self.deleteOldData				:= _proxy.deleteOldData;			
	self.processEventRequestStops	:= _proxy.processEventRequestStops;	
	self.processNewFiles			:= _proxy.processNewFiles;		
	
	self.allEDIDataTypes.clear;										
	
	_proxy.allEDIDataTypes.copy (self.allEDIDataTypes);				
end;</source>
        <Parameter name="_proxy" type="CM_AutoTaskEDITerminal"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="ebf39339-5191-49d7-891e-23e60a299716">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;
/*
Date		Who		Reason
06 Aug 2012	cnwcs5	Initial creation - par 30136
*/
vars

begin 
	if _rowName = ETRow_BgpEDIDeleteOldEDIData then 
		self.deleteOldData	:= _value.Boolean;
		
	elseif _rowName = ETRow_BgpEDIProcessEvReqStops then
		self.processEventRequestStops	:= _value.Boolean;
		
	elseif _rowName = ETRow_BgpEDIProcessNewFiles then
		self.processNewFiles	:= _value.Boolean;
		
	elseif _rowName = ETRow_BgpEDIReprocessFiles then
		self.allEDIDataTypes.clear;
		
		_value.IntegerArray.copy (self.allEDIDataTypes);
	else
		inheritMethod(_rowName, _value);
	endif;
epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="2ecd2788-4f86-4715-a2e0-0df74379026e">
        <source>validate();

// cnwdvb1 22 January 2003 

// 02 Aug 2012	cnwcs5	par 30136 - check they have selected something to process
// 12/12/2014  cnwdb2	PAR 35364

vars

begin
	inheritMethod();
	
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', ETRow_BgpAutoTerminals, null);
		app.raiseCMException(Input_required_field_terminal, ETRow_BgpAutoTerminals, null); // cnwdb2	PAR 35364		
	endif;

	if not self.deleteOldData and
		not self.processEventRequestStops and
		not self.processNewFiles and
		self.allEDIDataTypes.isEmpty then
		// this task is not going to do anything
		
		app.raiseCMException(EDI_BGP_Error1, null, null);
	endif;
end;</source>
    </JadeMethod>
</Class>
