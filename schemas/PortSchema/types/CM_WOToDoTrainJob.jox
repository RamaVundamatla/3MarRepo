    <JadeMethod name="getDisplayStringForAttribute" id="0521690e-48ad-4349-ab6c-f69def4ab006">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2023 navhl20 ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS

*/

vars

begin
	if _attrName = ETRow_Train then
		return self.allTrains.listString(Comma,CM_Train::code.name);
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
