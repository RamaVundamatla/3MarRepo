    <JadeMethod name="checkAccessPortsGroups" id="b5f19e18-a6b0-4d5c-84e6-95ce2bb3730c">
        <updating/>
        <source>checkAccessPortsGroups() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Apr 2013	cnwpjs1	Initial creation  //31408

*/

vars

	shipLine	: CM_ShippingLine;

begin
	allowAccessPortsGroups := true; // TFS 4257

	
	/* TFS 4257
	// see if any shipping lines are using port groups
	allowAccessPortsGroups:= app.myRoot.allPortGroups.size &gt; 0;

	foreach shipLine in app.myRoot.allShippingLines do
		if shipLine.shipPortGroups.isNotEmpty then 
			allowAccessPortsGroups := true;
			return;
		endif;
	endforeach;

	allowAccessPortsGroups := false;
*/

epilog

end;</source>
    </JadeMethod>
