    <JadeMethod name="setRequiresExportOperatorNo" id="7fc9fa99-678a-4ec7-866b-d60428434eb9">
        <updating/>
        <source>setRequiresExportOperatorNo(_value : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 November 2008	cnwrd1	Initial creation

*/

vars

begin
