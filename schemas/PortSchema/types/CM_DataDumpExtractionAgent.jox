    <JadeMethod name="isTerminalFilteredClass" id="d44dd19f-bf42-402d-817d-b51040d5bb3f">
        <updating/>
        <source>isTerminalFilteredClass(_transSpecClass: CM_DataDumpTransSpecClass) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 July 2003 by cnwsb1
//
// Purpose:		Used to quickly identify classes that are filtered by terminal
//
// Performance:	Using alias because it is quicker than checking if a sub-class
// ---------------------------------------------------------------------------
vars
	alias : String;
	isFilteredClass : Boolean;
	
begin
	if self.myExtractDefTerminal = null then
		// All terminals are being extracted
		return false;
	endif;
	
	alias := _transSpecClass.myTransExtractClass.myDataDumpClass.classAlias;

	isFilteredClass :=
			alias = DdAliasTransactions or
			alias = DdAliasVoyage or
			alias = DdAliasTrackedItem or
			alias = DdAliasTempReading;
			
	if isFilteredClass then
		self.log("Filtering by terminal " &amp; self.myExtractDefTerminal.name &amp;
				" for class " &amp; _transSpecClass.getClassId);
	endif;

	return isFilteredClass;
end;</source>
        <access>protected</access>
        <Parameter name="_transSpecClass" type="CM_DataDumpTransSpecClass"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
