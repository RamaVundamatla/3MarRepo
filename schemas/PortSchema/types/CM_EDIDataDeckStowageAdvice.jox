    <JadeMethod name="getDataTypeFromDefName" id="bec5fb4d-92bf-41f7-95d4-2bcac45c72c2">
        <source>getDataTypeFromDefName(_name: String): Integer;
// ---------------------------------------------------------------------------
// Created:     12 October 2011 cnwgb1 
// Purpose:     CCMS 1009 RORO Stowage Advice  
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if _name = ETDef_EDITIVoyageHeader then
		return EDIDataType_VoyageHeader;
	elseif _name = ETDef_EDITILayout then
		return EDIDataType_Layout;
	elseif _name = ETDef_EDITILayoutPoint then
		return EDIDataType_LayoutPoint;
	elseif _name = ETDef_EDITIStowAdvice then
		return EDIDataType_StowAdvice;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
