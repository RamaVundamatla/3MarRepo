    <JadeMethod name="setDescriptionAndFlags" id="bd466425-dfad-4a2d-bed6-91a51eb7181e">
        <updating/>
        <source>setDescriptionAndFlags(_description: String; _rail, _road, _subCarrier: Boolean) updating;
/*

Purpose:			Allow updating the description without setting the entire proxy

Parameters:			

Return Value:		

Date				Who		Reason
05 September 2022	navmd1	Initial creation TFS 54664

*/

vars

begin
	self.description := _description[1:CM_Carrier::description.length-1];
	self.isRail := _rail;
	self.isRoad := _road;
	self.isSubCarrier := _subCarrier;
epilog

