    <JadeMethod name="actionForApproved" id="cd2ca4d6-a1b7-42eb-883f-2f51991be9ec">
        <updating/>
        <source>actionForApproved(_voyage: CM_Voyage input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/08/2018	jlger1	Initial creation
03/12/2018	jlgdap1	TFS 42325 PEL1 Wrong Berth getting updated on the IMSR
13/12/2018  jlger1	TFS 42396 - Voyages at private berth don't update departure 
*/

vars
	cargoRequest : CM_WodCargoRequest;
	voyage : CM_Voyage;
	movement : HMS_Movement;
	departMovement : HMS_Movement;
	lengthOfTime : Decimal[6,2];
	arrivalTime : TimeStamp;
	newDepartTime : TimeStamp;
	hmsData : HMS_VoyageData;					// TFS 42325
	berthRequiresLengthOfTime : Boolean;
begin
	inheritMethod(_voyage);
	
	voyage := self.getMyVoyageObject;
	if voyage = null then
		return;
	endif;
	berthRequiresLengthOfTime:=	self.requiresLengthOfTime;
//18 Sep 2018	NDL	TFS 40893 - No update again... , 24 Sep 2018 NDL Now they bloody want it again
	if berthRequiresLengthOfTime then
		voyage.setTotalTimeInPort(self.getMyParent.CM_WorkOrderVoyage.lengthOfTime);
	endif;
	movement := voyage.getMovementArrival;
	if movement &lt;&gt; null then
		if self.myBerth &lt;&gt; null then
			movement.setMyBerth(self.myBerth);
		endif;
		
// TFS 41538			if  self.requiredByDT.isValid then
//	TFS 41538			movement.setOccursOnDT(self.requiredByDT);
// TFS 41538			endif;
		
		voyage.myHMSVoyageData.validateMe( app.myPassport);
		if app.myPassport.hasErrors then
			return;
		endif;
	endif;
	
	if berthRequiresLengthOfTime then
		//12 Sep 2018	NDL	TFS 40811
		departMovement := voyage.getMovementDeparture;
		if departMovement &lt;&gt; null then
		
			lengthOfTime := self.getMyParent.CM_WorkOrderVoyage.lengthOfTime;
			arrivalTime := voyage.arrivedDT;
			
			newDepartTime := arrivalTime + lengthOfTime.daysAsTimeStampInterval();
			if newDepartTime.isValid() then
				departMovement.setOccursOnDT( newDepartTime ); 
				voyage.setDepartureDT( newDepartTime );
			
				voyage.myHMSVoyageData.validateMe( app.myPassport);
				if app.myPassport.hasErrors then
					return;
				endif;
			
			endif;
			
		endif;
	endif;
	
	hmsData := voyage.myHMSVoyageData;														// TFS 42325
	if hmsData &lt;&gt; null and self.myBerth &lt;&gt; null and self.myBerth &lt;&gt; hmsData.getMyBerth then	// TFS 42325
		hmsData.setMyBerth(self.myBerth);													// TFS 42325
	endif;																					// TFS 42325
		

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionForCancelled" id="c64f566e-0c80-4473-81b8-f20fb947f9b5">
        <updating/>
        <source>actionForCancelled(_voyage: CM_Voyage input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2018	jlger1	Initial creation

*/

vars
	cargoRequest : CM_WodCargoRequest;
	status : CM_VoyageStatus;
begin
	
	foreach cargoRequest in self.allCargoDetails discreteLock do
		cargoRequest.actionForCancelled(self.getMyVoyageObject);
	endforeach;	
	
	
	//epr TFS 42055 25/11/18
	if _voyage.myVoyageProcess.isMTNWOProcess then	 //jlier1 TFS 51963 1/10/21
		status := app.myRoot.allVoyageStatuses[Voyage_Status_CargoReqPending];		
	else
		return;
	endif;
		
	_voyage.setStatusFromObject(status);
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionForNotApproved" id="3f6d8c24-de91-41f9-8169-c7ba503c6167">
        <source>actionForNotApproved(_voyage: CM_Voyage input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 October 2018	jlger1	Initial creation

*/

vars
	status : CM_VoyageStatus;
begin
	if _voyage.myVoyageProcess.isMTNWOProcess then	 //jlier1 TFS 51963 1/10/21
		status := app.myRoot.allVoyageStatuses[Voyage_Status_CargoReqRejected];		// TFS 38215
	else
		return;
	endif;
		
	_voyage.setStatusFromObject(status);
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionItems" id="60bc598e-950b-4719-924e-52987bbc6691">
        <updating/>
        <source>actionItems(_woActionIF: CMIF_WorkOrderAction; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2018	jlgndl1	Initial creation	TFS 40127

*/

vars

	voyage : CM_Voyage;
	movement : HMS_VoyageMovement;
	harbour : HMS_Harbour;
	cargoRequest : CM_WodCargoRequest;
begin
	foreach cargoRequest in self.allCargoDetails discreteLock do
		cargoRequest.actionItems(null,app.myPassport);
	endforeach;
	
	
	
	if _passport.noErrors then
		voyage := self.getMyVoyageObject();
		if voyage &lt;&gt; null then
			movement := voyage.getMovementArrival();
		endif;
		if movement &lt;&gt; null then	
			harbour := self.getMyTerminal.myHarbour;
			app.myUtilityCA.utlAddHMSResources(self.allMarineServiceDetails, null, harbour, movement.HMS_VoyageMovement, _passport);		
		endif;
	endif;
	
	if _passport.noErrors then
	
		self.setIsComplete();
		self.createWorkOrderTransaction(self.getWOTransactionType());		// TFS 39165
	endif;
	

epilog

end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="canAccessConsigneeConsignor" id="0d1faeb0-c638-4dc0-a448-cbce0f4ccb52">
        <source>canAccessConsigneeConsignor(_user: CM_User): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/12/2018	jlgdap1		Initial creation TFS 42219 PEL1 Consignee Access Issues
//
vars
	cargoRequest : CM_WodCargoRequest;

begin
	foreach cargoRequest in self.allCargoDetails discreteLock do
		if cargoRequest.canAccessConsigneeConsignor(_user) then
			return true;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canCancel" id="ce9525d7-a1a5-4b4d-b06d-7b0a6cd7a0d0">
        <source>canCancel(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2018	jlger1	Initial creation

*/

vars
	cargoRequest : CM_WodCargoRequest;
begin
	
	foreach cargoRequest in self.allCargoDetails discreteLock do
		if not cargoRequest.canCancel then
			return false;
		endif;
	endforeach;
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
