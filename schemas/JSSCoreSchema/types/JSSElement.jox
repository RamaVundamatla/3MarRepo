    <DbClassMap file="jsscore_transient"/>
    <PrimAttribute name="binaryValue" id="14da2d19-bccc-43d7-a600-215fd25fd08a">
        <type name="Binary"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="stringValue" id="cb95bcff-edf2-4a06-b006-0c17a3c3d6fa">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getBinaryValue" id="c18899e8-487b-43b6-a49f-2b4286c538e1">
        <source>getBinaryValue() : Binary;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 by cnwdad1
//
// Purpose:		Returns the receiver's binary value.
//
// Parameters:	None
// Returns:		The binary value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.binaryValue;
end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getStringValue" id="b0cd884c-90b8-4377-862d-98f4fef19591">
        <source>getStringValue() : String;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 cnwdad1
//
// Purpose:		Returns the receiver's string value.
//
// Parameters:	None
// Returns:		The string value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.stringValue;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setBinaryValue" id="21d2f54b-577e-4165-bca4-6c0c402e52d3">
        <updating/>
        <source>setBinaryValue(pValue: Binary) updating;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 cnwdad1
//
// Purpose:		Sets the receiver's binary value.
//
// Parameters:	pValue - The binary value.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.binaryValue &lt;&gt; pValue then 
		self.binaryValue := pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setStringValue" id="7ae0bb04-cc8c-4a82-a8b0-6d81dbaedeb4">
        <updating/>
        <source>setStringValue(pValue: String) updating;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 -  setStringValue
// By:			cnwdad1
//
// Purpose:		Sets the receiver's string value.
//
// Parameters:	pValue - The string value.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.stringValue &lt;&gt; pValue then 
		self.stringValue := pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="String"/>
    </JadeMethod>
</Class>
