    <JadeMethod name="doClickBillOfMaterialOpts" id="c802fdf2-37b5-47cf-9921-f6b45c1f071b">
        <source>doClickBillOfMaterialOpts();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 

*/

vars

	useRecipe : Boolean;
	useManual : Boolean;

begin

	useRecipe := self.optRecipe.value;
	useManual := self.optManual.value;
	
	self.cmbRecipe.visible := useRecipe;
	
	self.txtFactor.text := "1";
	
	if useRecipe then
		self.populateTblComponents( self.cmbRecipe.listObject.CM_Recipe );
		self.grpManualSel.visible := false;
		self.grpManualAmountOut.visible := false;
		self.grpRecipe.visible := true;
		
	elseif useManual then
		self.populateTblComponents( null );
		self.cmbRecipe.listIndex := -1;
		self.grpManualSel.parent := self.grpComponents;
		self.grpManualSel.left := self.grpRecipe.left;
		self.grpManualSel.top := self.grpRecipe.top;
		self.grpManualSel.visible := true;
		self.grpManualSel.parentAspect := 9;
		
		self.grpManualAmountOut.visible := false;
		self.grpManualAmountOut.parent := self.grpComponents;
		self.grpManualAmountOut.left := self.grpRecipe.left;
		self.grpManualAmountOut.top := ( self.grpRecipe.top + self.grpRecipe.height ) - self.grpManualAmountOut.height;
		self.grpManualAmountOut.visible := true;
		self.grpManualAmountOut.parentAspect := 9;
		
		self.grpRecipe.visible := false;
		
		self.txtManualQuantity.left := self.tblManualAmount.left;
		self.txtManualQuantity.visible := true;
		self.tblManualAmount.visible := false;
		
		self.showManualBlendingSelection();
		
	else
		self.grpManualSel.visible := false;
		self.grpManualAmountOut.visible := false;
		self.grpRecipe.visible := false;
		self.populateTblComponents( null );
		
	endif;
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickBtnAddManual" id="0f454ded-45fe-41c6-aa57-2e673692327c">
        <source>doClickBtnAddManual();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	cargoType : CM_CargoType;
	product : CM_Product;
	quanity : Integer;
	volume : Decimal[14,4];
	weight : Decimal[14,4];
	msg : String;
	cmif : CMIF_BlendingComponent;
	rowString : String;
	rowIndex : Integer;
	textColor : Integer;

begin

	cargoType := self.cmbInCargoType.listObject.CM_CargoType;
	product := self.cmbInProduct.listObject.CM_Product;
	
	if cargoType = null then
		msg := "Must select a Cargo Type";
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		self.cmbInCargoType.setFocus();
		return;
		
	elseif not cargoType.allProducts.isEmpty and product = null then
		msg := "Must select a Sub Cargo Type";
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		self.cmbInProduct.setFocus();
		return;
		
	endif;
	
	quanity := 0;
	volume := 0;
	weight := 0;
	
	if cargoType.isTrackByVolume then
		volume := self.tblManualAmount.getConvertedValue;	
	elseif cargoType.isTrackByWeight then
		weight := self.tblManualAmount.getConvertedValue;	
	else
		quanity := self.txtManualQuantity.text.asIntegerJMT;
	endif;
	
	if quanity = 0 and volume = 0 and weight = 0 then
		msg := "Must enter an amount";
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		if self.tblManualAmount.visible then
			self.tblManualAmount.setFocus();
		else
			self.txtManualQuantity.setFocus();
		endif;
		return;
	endif;
	
	//OK we have everything we need for this one
	create cmif transient;
	cmif.setManual(	cargoType,	//_myCargoType : CM_CargoType; 
					product,	//_myProduct : CM_Product;
					quanity,	//_quantity : Integer; 
					volume,	//_volume : Decimal;
					weight,	//_weight : Decimal;
					self.cargoIDs.size	//_cargoIdCount : Integer
					);
	self.allCMIFs.add( cmif );
	
	rowString := cmif.getRowString( textColor );
	rowIndex := self.tblComponents.addItem( rowString );
	self.tblComponents.accessRow( rowIndex ).itemObject := cmif;
	self.tblComponents.accessRow( rowIndex ).foreColor := textColor;
	
	self.showCmifDetails( null ); //clear the fileds

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickBtnCargoId" id="b2d19410-e9dc-4e18-bd35-a32813eeba51">
        <source>doClickBtnCargoId();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	str	: String;
	form : CMUI_EnterCargoIds;
	index : Integer;
	
	rowIndex : Integer;
	cmif : CMIF_BlendingComponent;
	textColour : Integer;

begin

	create form;
	form.centreWindow;
	form.setMyTerminal(self.myTerminal);
	self.cargoIDs.copy(form.ids);
	form.myCargoType := self.cmbOutCargoType.listObject.CM_CargoType;
	
	form.showModal;
	
	if form.modalResult = ModalResultOK then
		self.cargoIDs.clear;
		foreach str in form.ids do
			if str.trimBlanks = null then
				continue;
			endif;
			self.cargoIDs.add(str);
		endforeach;
		//check that an id has been entered
		str := null;
		if self.cargoIDs.size &gt; 1 then
			foreach index in 1 to self.cargoIDs.size do
				if str = null then
					str := self.cargoIDs[index];
				else
					str := str &amp; ", " &amp; self.cargoIDs[index];
				endif;
			endforeach;
		endif;
		
		self.txtMultiCargoIds.text := str;
		self.txtMultiCargoIds.visible := str &lt;&gt; null;
		
		self.txtCargoId.visible := not self.txtMultiCargoIds.visible;
		self.txtCargoId.text := self.cargoIDs.first;
		
		foreach rowIndex in 1 to self.tblComponents.rows do
			cmif := self.tblComponents.accessRow(rowIndex).itemObject.CMIF_BlendingComponent;
			if cmif &lt;&gt; null then
				cmif.setOutputCargoIdCount( self.cargoIDs.size );
				self.tblComponents.setCellText( rowIndex, 1, cmif.getRowString( textColour ) );
				self.tblComponents.accessRow( rowIndex ).foreColor := textColour;
			endif;
		endforeach;
		
	endif;
	
	self.txtCargoId.setFocus();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickBtnDelManual" id="55b77991-806e-48b6-88a2-4c812bb0a554">
        <source>doClickBtnDelManual();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	cmif : CMIF_BlendingComponent;
	rowIndex : Integer;

begin

	cmif := self.mnuRemoveComp.userObject.CMIF_BlendingComponent;
	if cmif &lt;&gt; null then
		self.allCMIFs.remove( cmif );
		self.tblComponents.findObjectInRow( cmif, rowIndex );
		if rowIndex &gt; self.tblComponents.fixedRows and rowIndex &lt;= self.tblComponents.rows then
			self.tblComponents.removeItem( rowIndex );
		endif;
		delete cmif;
	endif;
	
	showCmifDetails( null );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickOutputCargoOptions" id="6ae99d04-3026-44f2-9071-d553e14c077e">
        <source>doClickOutputCargoOptions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars
	
	useExisting : Boolean;

begin

	useExisting := self.optExistingTI.value;
	
	self.btnFindOutTi.enabled := useExisting;
	self.txtCargoId.enabled := not useExisting;
	self.cmbOutCargoType.enabled := not useExisting;
	self.cmbOutProduct.enabled := not useExisting;
	self.cmbOutOperator.enabled := not useExisting;
	self.cmbOutTermArea.enabled := not useExisting;
	self.cmbOutLocation.enabled := not useExisting;
	
	if useExisting then
		self.btnCargoId.visible := false;
		self.cargoIDs.clear();
		if self.myOutputTrackedItem &lt;&gt; null then
			self.txtCargoId.text := self.myOutputTrackedItem.id;
			self.cmbOutCargoType.setObject( self.myOutputTrackedItem.myCargoType );
			self.doSelectOutCargoType();
			if self.myOutputTrackedItem.myProduct &lt;&gt; null then
				self.cmbOutProduct.setObject( self.myOutputTrackedItem.myProduct );
				self.doSelectOutProduct( self.myOutputTrackedItem.myProduct );
			endif;
			self.cmbOutOperator.setObject( self.myOutputTrackedItem.myOperator );
			self.cmbOutTermArea.listIndex := self.cmbOutTermArea.findObject( self.myOutputTrackedItem.myTerminalArea );
			self.doSelectTerminalArea();
			self.cmbOutLocation.listIndex := self.cmbOutLocation.findObject( self.myOutputTrackedItem.myPrimaryActualLocation );
			
		elseif self.myOutputCargoType &lt;&gt; null then
			self.cmbOutCargoType.setObject( self.myOutputCargoType );
			self.doSelectOutCargoType();
			self.cmbOutOperator.listIndex := -1;
			self.doSelectTerminalArea();
			
		endif;
	else
		self.btnCargoId.visible := true;
		self.txtCargoId.text := null;
		self.cmbOutCargoType.listIndex := -1;
		self.doSelectOutCargoType();
		self.cmbOutOperator.listIndex := -1;
		self.cmbOutTermArea.listIndex := -1;
		self.doSelectTerminalArea();
		self.cmbOutLocation.listIndex := -1;
		
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFindExistingCargoItem" id="190e27e0-7d18-45e5-8474-a934b99f787f">
        <source>doFindExistingCargoItem();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	form : CMUI_CargoSearchFormModal;
	tiPreSearch : CM_TrackedItem;
	
begin

	tiPreSearch := self.myOutputTrackedItem;
	
	form := app.loadForm(CMUI_CargoSearchFormModal, 
							CMUI_Assistant, 
							false, 
							false,
							true, 
							self.myTerminal,
							null).CMUI_CargoSearchFormModal;	

	form.setColumnsAndControlWidth(3, 175);
	form.setParentForm( self );
	form.setCargoType( self.myOutputCargoType );
	form.blendAction := ACTION_BLEND_PARENT;
	
	form.showModal;
	
	if tiPreSearch &lt;&gt; self.myOutputTrackedItem then
		self.doClickOutputCargoOptions();
		self.doClickBillOfMaterialOpts();
	endif;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doFindInputCargo" id="26526ada-bef2-421b-814a-32e6c6774da4">
        <source>doFindInputCargo( _cmif : CMIF_BlendingComponent );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navndl1	Initial creation	TFS	TFS 51243

*/

vars

	form : CMUI_CargoSearchFormModal;
	rowIndex : Integer;
	cmif : CMIF_BlendingComponent;
	textColour : Integer;
	
begin

	form := app.loadForm(CMUI_CargoSearchFormModal, 
							CMUI_Assistant, 
							false, 
							false,
							true, 
							self.myTerminal,
							null).CMUI_CargoSearchFormModal;	

	form.setColumnsAndControlWidth(3, 175);
	form.setParentForm( self );
	form.setCargoType( _cmif.myCargoType );
	form.setProduct( _cmif.myProduct );
	form.setCMIFBlendingComponent( _cmif );
	form.blendAction := ACTION_BLEND_CHILD;
	
	form.showModal;
	
	foreach rowIndex in 1 to self.tblComponents.rows do
		cmif := self.tblComponents.accessRow(rowIndex).itemObject.CMIF_BlendingComponent;
		if cmif &lt;&gt; null and cmif = _cmif then
			self.tblComponents.setCellText( rowIndex, 1, cmif.getRowString( textColour ) );
			self.tblComponents.accessRow( rowIndex ).foreColor := textColour;
			break;
		endif;
	endforeach;
	
	self.tblComponents.accessRow( rowIndex ).selected := false;
	
	if self.optManual.value then
		self.showCmifDetails(null);
	endif;
	
	
	
epilog
	
end;</source>
        <Parameter name="_cmif" type="CMIF_BlendingComponent"/>
    </JadeMethod>
    <JadeMethod name="doInitialPopulate" id="05f00b92-4f2b-48ec-a934-0b645f6f7bb9">
        <source>doInitialPopulate()protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	cargoTypes : CM_CargoTypeSet;
	cargoType : CM_CargoType;
	cmbIndex : Integer;
	realCargoType : CM_CargoType;
	headings : String;

begin

	self.cmbOutCargoType.clear();
	create cargoTypes transient;
	
	foreach cargoType in app.myRoot.allCargoTypesById discreteLock do
		if cargoType.isBreakBulk or cargoType.isBulk then
			cargoTypes.addNoDuplicates( cargoType, false );
		endif;	
	endforeach;
	
	self.cmbOutCargoType.listCollection( cargoTypes, false, 0 );
	self.cmbOutCargoType.setInitialised(true);
	
	self.cmbOutTermArea.listCollection( self.myTerminal.allTerminalAreas, false, 0 );
	
	self.tblComponents.rows := 1;
	self.tblComponents.fixedRows := 1;
	self.tblComponents.columns := 5;
	self.tblComponents.fixedColumns := 0;
	self.tblComponents.selectMode := Table.SelectMode_CurrentRow;
	self.tblComponents.selectionType := self.tblComponents.SelectionType_Row;
	self.tblComponents.multiSelect := self.tblComponents.MultiSelect_None;

	headings := CMIF_BlendingComponent@getRowHeadingString;
	self.tblComponents.setCellText(1,1,headings);
	
	self.doClickOutputCargoOptions();
	self.doClickBillOfMaterialOpts();
	
	self.tblComponents.leftColumn := 1;

epilog

	delete cargoTypes;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOK" id="d8e98b74-274d-406a-ac88-2122d3a36dec">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	agent : CMIF_BlendingAgent;
	theResult : Integer;

begin

	create agent transient;

	if not self.doValidation( agent ) then
		return;
	endif;
	
	while true do
	
		app.myTrxCA.trxPerformBlending( agent, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			if self.myParentForm = null then //15 Jun 2021	NDL - post demo request from Bish.
				//started from menu, don't close just clear the fields ready for another.
				self.clearAfterBlend();
			else
				self.unloadForm;
			endif;
			break;
		else
			theResult := app.showErrorWarningDialog('Blending', app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile; 
	
epilog

	delete agent;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectInCargoType" id="c4403212-86da-492c-b98d-534716b1381f">
        <source>doSelectInCargoType( _cargoType : CM_CargoType );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	self.cmbInProduct.clear();
	
	self.txtManualQuantity.visible := false;
	self.tblManualAmount.visible := false;
	
	self.cmbInProduct.enabled := false;
	self.lblSubCargoTypeIn.enabled := false;
	
	if _cargoType = null then 
		self.txtManualQuantity.visible := true;
		return;
		
	endif;
	
	if not _cargoType.allProducts.isEmpty then
		self.cmbInProduct.enabled := true;
		self.lblSubCargoTypeIn.enabled := true;
		
	endif;
	
	//populate the products
	self.cmbInProduct.setCargoType( _cargoType );
	
	if _cargoType.isTrackByVolume  or _cargoType.isTrackByWeight then
		self.tblManualAmount.visible := true;
		self.tblManualAmount.setupFromCargoType( _cargoType, self.cmbInProduct.listObject.CM_Product, self.backColor );
		
	else
		self.txtManualQuantity.visible := true;
		
	endif;
		
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="doSelectInProduct" id="bf26ec7e-0123-4283-8b16-8a965108ab1a">
        <source>doSelectInProduct( _product : CM_Product );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	if _product &lt;&gt; null then
		if _product.myCargoType.isTrackByVolume  or _product.myCargoType.isTrackByWeight then
			self.tblManualAmount.visible := true;
			self.tblManualAmount.setupFromCargoType( _product.myCargoType, _product, self.backColor );
		endif;	
	endif;

epilog

end;</source>
        <Parameter name="_product" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="doSelectOutCargoType" id="064eb43a-e49f-434b-89e2-c181d275fc26">
        <source>doSelectOutCargoType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	selectedRecipe : CM_Recipe;
	recipe : CM_Recipe;
	cargoType : CM_CargoType;
	index : Integer;
	selectedProduct : CM_Product;
	product : CM_Product;

begin

	selectedRecipe := self.cmbRecipe.listObject.CM_Recipe;
	selectedProduct := self.cmbOutProduct.listObject.CM_Product;
	
	self.cmbRecipe.clear();
	self.cmbOutProduct.clear();
	
	cargoType := self.cmbOutCargoType.listObject.CM_CargoType;
	self.cmbOutProduct.setCargoType( cargoType );
	if cargoType = null or cargoType.allProducts.isEmpty then
		self.cmbOutProduct.enabled := false;
	endif;
	
	if cargoType = null then
		selectedRecipe := null;
		selectedProduct := null;
	endif;
	
	self.cmbOutProduct.enabled := cargoType &lt;&gt; null and not cargoType.allProducts.isEmpty and not self.optExistingTI.value;
	
	if selectedProduct &lt;&gt; null and  cargoType.allProducts.includes( selectedProduct ) then
		self.cmbOutProduct.listIndex := self.cmbOutProduct.findObject( selectedProduct );
	endif;
	if self.cmbOutProduct.listIndex &lt; 1 and  self.cmbOutProduct.listCount = 1 then
		 self.cmbOutProduct.listIndex := 1;
	endif;
	
	product := self.cmbOutProduct.listObject.CM_Product;
	if product &lt;&gt; null then
		self.doSelectOutProduct( product );
	else
		self.setManualOutAmountTables( cargoType, null );
	endif;
	
	if cargoType &lt;&gt; null then
		foreach recipe in cargoType.allRecipes discreteLock do
			index := self.cmbRecipe.addItem( recipe.code &amp; " - " &amp; recipe.description );
			self.cmbRecipe.itemObject[index] := recipe;
		endforeach;
	endif;
	
	if optRecipe.value then
		if selectedRecipe &lt;&gt; null then
			if selectedProduct &lt;&gt; null and self.cmbOutProduct.listIndex &gt; 0 then
				//we have a product and it was successfully reselected
				if selectedRecipe.myProduct = null or selectedRecipe.myProduct = selectedProduct then
					self.cmbRecipe.listIndex := self.cmbRecipe.findObject( selectedRecipe );
				endif;
			else
				self.cmbRecipe.listIndex := self.cmbRecipe.findObject( selectedRecipe );
			endif;
		endif;
		
		if self.cmbRecipe.listIndex &lt; 1 and  self.cmbRecipe.listCount = 1 then
			selectedProduct := self.cmbOutProduct.listObject.CM_Product;
			selectedRecipe := self.cmbRecipe.listObject.CM_Recipe;
			if selectedProduct = null or selectedRecipe.myProduct = null or selectedRecipe.myProduct = selectedProduct then
				self.cmbRecipe.listIndex := 1;
			endif;
		endif;
	
	endif;
	
	self.doSelectRecipe();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectOutProduct" id="55f10786-a0c4-4e36-afa3-16ea4f679303">
        <source>doSelectOutProduct( _product : CM_Product );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	self.setManualOutAmountTables( null, _product );

epilog

end;</source>
        <Parameter name="_product" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="doSelectRecipe" id="1e20a5e0-3b4a-4ecf-a370-e04900978686">
        <source>doSelectRecipe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	recipe : CM_Recipe;
	canFactor : Boolean;

begin

	if not optRecipe.value then
		self.cmbRecipe.visible := false;
		self.cmbRecipe.listIndex := -1;
	endif;
	
	recipe := self.cmbRecipe.listObject.CM_Recipe;
	if recipe &lt;&gt; null then
		canFactor := recipe.canFactor;
		self.txtInstructions.text := recipe.instructions;
	
		self.txtMakes.text := app.getErrorString(Makes) &amp; " " &amp; recipe.getAmountString(1) &amp; " [ " &amp; recipe.getOtherAmountsString(1) &amp; " ]";
		if canFactor then
			self.txtMakes.text := self.txtMakes.text &amp; CrLf &amp; app.getErrorString(Recipe_scaled);
			self.lblMultipleBy.visible := true;
			self.txtFactor.visible := true;
			self.txtFactor.text := "1 ";
			self.lblResultsIn.visible := true;
			self.lblResultsIn.caption := app.getErrorString1( Will_result_output, recipe.getAmountString( self.txtFactor.text.asDecimalJMT ) );
		else
			self.lblMultipleBy.visible := false;
			self.txtFactor.visible := false;
			self.lblResultsIn.visible := false;
		endif;
	else
		self.txtFactor.text := null;
		self.txtMakes.text := null;
		self.txtInstructions.text := null;
		self.lblResultsIn.caption := null;
		
		self.lblMultipleBy.visible := false;
		self.txtFactor.visible := false;
		self.lblResultsIn.visible := false;
	endif;
	
	self.populateTblComponents( recipe );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectTerminalArea" id="91ae9318-b218-4a11-abbd-d65879173893">
        <source>doSelectTerminalArea();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	selectedTA : CM_TerminalArea;
	selectedLC : CM_LocationsController;
	locationControllerArray : ObjectArray;
	obj : Object;
	lc : CM_LocationsController;
	index : Integer;


begin

	selectedTA := self.cmbOutTermArea.listObject.CM_TerminalArea;
	selectedLC := self.cmbOutLocation.listObject.CM_LocationsController;
	
	self.cmbOutLocation.clear();
	
	if selectedTA = null then
		return;
	endif;
	
	create locationControllerArray transient;
	selectedTA.getAllLocationsControllers( locationControllerArray );
	
	foreach obj in locationControllerArray discreteLock do
		lc := obj.CM_LocationsController;
		index := self.cmbOutLocation.addItem( lc.getFullId );
		self.cmbOutLocation.itemObject[index] := lc;
	endforeach;
	
	if locationControllerArray.size = 1 then
		self.cmbOutLocation.listIndex := 1;
	elseif selectedLC &lt;&gt; null then
		self.cmbOutLocation.listIndex := self.cmbOutLocation.findObject( selectedLC );
	endif;

epilog

	delete locationControllerArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="doValidation" id="fb1a781a-b317-40d0-b01e-7d17b267a0ad">
        <source>doValidation( _agent : CMIF_BlendingAgent input) :Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	usingRecipe : Boolean;
	creatingNewCargo : Boolean;
	obj : Object;
	cmif : CMIF_BlendingComponent;
	msg : String;

begin

	usingRecipe := self.optRecipe.value;
	creatingNewCargo := self.optCreateTI.value;
	
	_agent.myTerminal := self.myTerminal;
	
	_agent.doUseRecipe := usingRecipe;
	_agent.doCreateNewCargoItem := creatingNewCargo;
	_agent.factor := 1;

	if creatingNewCargo then
		if self.cargoIDs.size &gt; 1 then
			self.cargoIDs.copy( _agent.newParentIdArray );
		else
			_agent.newParentIdArray.add( self.txtCargoId.text );
		endif;
		_agent.myNewCargoType := self.cmbOutCargoType.listObject.CM_CargoType;
		_agent.myNewProduct := self.cmbOutProduct.listObject.CM_Product;
		_agent.myNewOperator := self.cmbOutOperator.listObject.CM_Operator;
		_agent.myNewLocation := self.cmbOutLocation.listObject.CM_LocationsController;
		if not _agent.validateCreatingNewCargo( false ) then
			return false;
		endif;
	else
		_agent.myExistingParentCargo := self.myOutputTrackedItem;
		if not _agent.validateUseExistingCargo( false ) then
			return false;
		endif;
	endif;
	
	if usingRecipe then
		_agent.myRecipe := self.cmbRecipe.listObject.CM_Recipe;
		if self.txtFactor.text.asDecimalJMT &lt;&gt; 1 and self.txtFactor.text.asDecimalJMT &lt;&gt; 0 then
			_agent.factor := self.txtFactor.text.asDecimalJMT;
			if not _agent.validateUsingRecipe( false ) then
				return false;
			endif;
		endif;
		
		_agent.totalQuantity := ( _agent.myRecipe.defaultQuantity * _agent.factor ).Integer;
		_agent.totalVolume := ( _agent.myRecipe.defaultVolume * _agent.factor ); 
		_agent.totalWeight := ( _agent.myRecipe.defaultWeight * _agent.factor ); 
	
	else
		_agent.totalQuantity := self.txtManualQtyOut.text.asIntegerJMT;
		_agent.totalVolume := self.tblManualVolOut.getConvertedValue;
		_agent.totalWeight := self.tblManualWeightOut.getConvertedValue;
	
	endif;
	
	if not _agent.validateAmounts( false ) then
		return false;
	endif;
	
	self.allCMIFs.copy( _agent.allBlendingComponents );
	if not _agent.validateSufficientCompCargo( false ) then
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_agent" type="CMIF_BlendingAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mnuFindComp_click" id="4ecc7b57-0c64-408c-b37a-7334141dfa23">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuFindComp_click(menuItem: MenuItem input) updating;
/*

