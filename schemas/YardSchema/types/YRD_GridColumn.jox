<Class name="YRD_GridColumn" id="c4a82b48-1bf2-4799-a022-9a7707b86911">
    <superclass name="CMUI_GridColumn"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="Yard"/>
    <PrimAttribute name="maxWidth" id="d9fc72bd-08cb-45a9-b544-f6539de181c6">
        <embedded/>
        <virtual/>
        <type name="Real"/>
        <access>readonly</access>
        <text>
This is the max width of points in this column 
in 10 ft units</text>
    </PrimAttribute>
    <JadeMethod name="drawSelf" id="843ad611-ae06-43a8-9c30-ec0e0d172364">
        <updating/>
        <source>drawSelf(pFrame: CMUI_Frame) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	TopTextMargin	: Integer = 10;
	
vars
	lX 		: Real;
	caption : String;
begin

	if self.x1 = self.x2 then // zero width - possibly a gap
		return;
	endif;
	if self.label[1:1] &lt;&gt; "_" then
		caption := self.label;
	endif;
	lX := (self.x1 + ((self.x2 - self.x1) / 2)) - ((self.label.length * 7) / 2); // all this puts the label in the middle
	pFrame.drawTextAt(caption, lX + 1, TopTextMargin + 1, White);
	pFrame.drawTextAt(caption, lX, TopTextMargin, Black);
end;</source>
        <Parameter name="pFrame" type="CMUI_Frame"/>
    </JadeMethod>
    <JadeMethod name="hasAllTowers" id="21ab9fad-7661-4778-acca-76eaa3e272a0">
        <source>hasAllTowers() : Boolean;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	aGridPoint : CMUI_GridPoint;
begin
	foreach aGridPoint in self.allGridPointsByRow do
		if aGridPoint.myLocationsController.isKindOf(CM_StackController) then
			if aGridPoint.myLocationsController.CM_StackController.availability = 0 or aGridPoint.myLocationsController.CM_StackController.availability = 2 then
				continue;
			endif;
			return false;
		endif;
	endforeach;
	return true;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="maxWidth" id="58888330-c7b9-4a4d-9377-b92fb691416c">
        <methodInvocation>mapping</methodInvocation>
        <source>maxWidth(set: Boolean; _value: Real io) mapping;
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpGridPoint	: CMUI_GridPoint;
	
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	foreach tmpGridPoint in self.allGridPointsByRow do
		if tmpGridPoint.myLocationsController.isKindOf(CM_GapController) then
			_value := _value.max(tmpGridPoint.YRD_GridPoint.width / 6);
		
		elseif tmpGridPoint.myLocationsController.isKindOf(CM_TowerController) then
			_value := _value.max(tmpGridPoint.YRD_GridPoint.width / 2);
		
		else
			_value := _value.max(tmpGridPoint.YRD_GridPoint.width);
		endif;
	endforeach;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="45b84eed-0314-4e15-b9be-759fc4c81f9b">
        <updating/>
        <source>setForCreate(pGridCol : CM_GridColumn; pGridArea : YRD_GridArea) updating;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.label	:= pGridCol.label;
	self.column	:= pGridCol.column;

	self.myGridArea	:= pGridArea;

end;</source>
        <Parameter name="pGridCol" type="CM_GridColumn"/>
        <Parameter name="pGridArea" type="YRD_GridArea"/>
    </JadeMethod>
    <JadeMethod name="setForCreateArray" id="0c7a0486-6a1a-4591-81c4-c78c99508e44">
        <updating/>
        <source>setForCreateArray(_array : StringArray; _theGridArea : YRD_GridArea) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. _array[1] " &amp; _array[1] &amp; " _array[2] " &amp; _array[2]);
	self.column		:= _array[2].Integer;
	self.label		:= _array[3];
	self.myGridArea	:= _theGridArea;

end;</source>
        <Parameter name="_array" type="StringArray"/>
        <Parameter name="_theGridArea" type="YRD_GridArea"/>
    </JadeMethod>
    <JadeMethod name="setForCreateXML" id="10500bdf-96e9-4799-b15a-237b53bfd76a">
        <updating/>
        <source>setForCreateXML(_theGridArea : YRD_GridArea; _label : String; _column : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin

	self.label	:= _label;
	self.column		:= _column;
	self.myGridArea	:= _theGridArea;

end;</source>
        <Parameter name="_theGridArea" type="YRD_GridArea"/>
        <Parameter name="_label" type="String"/>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
</Class>
