    <JadeMethod name="putSearchingValue" id="bf757946-3aa4-4e48-9fea-8f5de1df0185">
        <source>putSearchingValue( _criteriaLine : CM_SelectorCriteriaLine input; _value : Any );
// ----------------------------------------------------------------------
// Created 08 may 2008 by cnwvu1
//
// Purpose:	Puts searching values from DTO criteriaLine (RT screen)
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	_valueTranslated : Any;
	
begin
	
	_valueTranslated := _criteriaLine.myQueryProperty.translateStringToSearchValue( _value, _criteriaLine );
	_criteriaLine.myQueryOperator.setSearchValue( _valueTranslated );
	
end;
</source>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine" usage="input"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
