    <JadeMethod name="setProxiesFromTable" id="c0481a60-6d79-44c5-a612-4cea1598c7c9">
        <updating/>
        <source>setProxiesFromTable(_pxyTermHdr : CM_TerminologyDef input) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     16 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	userExpression,
	hdrName				: String;
	termType			: CM_TerminologyType;
	
	termTypeExp			: CM_TerminologyTypeExpression;
	pxyExp				: CM_TerminologyExpression;
	
	termTypeDtl			: CM_TerminologyTypeDtl;
	pxyTermDtl			: CM_TerminologyDtl;
	
begin
	
	if _pxyTermHdr = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy terminology header is null');
		return false;
	endif;
	
	termType := self.cmbTermType.listObject.CM_TerminologyType;
	
	if termType = null then
		app.msgBox('You must select a terminology type before continuing', 'No terminology type selected', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	hdrName := self.tblHdrEntry.getValueByName(ETRow_TermHdrName).String;
	if hdrName = null then //validate now as it is used as a key
		app.msgBox('You must header name before continuing', 'No terminology header name entered', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	_pxyTermHdr.setProxy(hdrName, termType);
	foreach termTypeExp in termType.allTerminologyTypeExpressions do
		pxyExp := _pxyTermHdr.allTerminologyExpressions[_pxyTermHdr.name, termTypeExp.expressionType];
		if pxyExp = null then
			create pxyExp transient;
		endif;
		userExpression := self.tblHdrEntry.getValueByName(termTypeExp.expressionDescr).String;
		
		if userExpression = null then
			app.msgBox('You must enter an alternate term for the ' &amp; termTypeExp.expressionDescr &amp; ' expression.', 'No expression entered', MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
		
		pxyExp.set(termTypeExp, _pxyTermHdr, userExpression);
	endforeach;
	
	if _pxyTermHdr.allTerminologyDtls.isEmpty then
		foreach termTypeDtl in termType.allTerminologyTypeDtls do
			create pxyTermDtl transient;
			pxyTermDtl.set(termTypeDtl, _pxyTermHdr, termTypeDtl.systemEntRowHeading, termTypeDtl.systemEntRowShortHeading);
		endforeach;
	endif;
	
	_pxyTermHdr.processUserHeadings();
	
	return true;
	
end;</source>
        <access>protected</access>
        <Parameter name="_pxyTermHdr" type="CM_TerminologyDef" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="79beac05-3985-4a93-bf91-4c6bde95eee4">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     09 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();
	//not using tblThumb
	self.tblThumb.stretchToParent := false;
	self.tblThumb.left := 0;
	self.tblThumb.top := 0;
	self.tblThumb.width := 0;
	self.tblThumb.height := 0;
	
	self.tblHdrEntry.zOrder(1);
	self.initEntryTable(self.tblHdrEntry, ETDef_TermHdrEnt);
	self.tblHdrEntry.visible := true;
	self.initTblTerminologyHdr();
	self.doRefresh();
	self.setNavigatorHeading('Terminology Maintenance');
	self.beginClassNotification(CM_TerminologyDef, false, Object_Create_Event, Response_Continuous, null);
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="1aa372a6-1973-46ea-be05-934bb5e78570">
        <updating/>
        <source>showThumbnailData(_termHdr : CM_TerminologyDef) updating;
// ---------------------------------------------------------------------------
// Created:     11 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tbl							: CM_EntryTable;
	termDtl						: CM_TerminologyDtl;
	termExp						: CM_TerminologyExpression;

begin
	
	self.populateTblTerminologyHdr(_termHdr);
	
	if _termHdr = null then
		return;
	endif;
	
	self.initEntryTable(self.tblHdrEntry, ETDef_TermHdrEnt);
	
	tbl := self.tblHdrEntry;
	
	if self.cmbTermType.listCount &gt; 1 then
		self.cmbTermType.listObject := _termHdr.myTerminologyType;
	endif;
	
	if _termHdr.myTerminologyType &lt;&gt; null then
		tbl.setValueByName(ETRow_TermType, _termHdr.myTerminologyType.name);
	endif;
	
	tbl.setValueByName(ETRow_TermHdrName, _termHdr.name);
	
	foreach termExp in _termHdr.allTerminologyExpressions do
		// -1 added to length call as this seems to return the length of the attribute plus one
		tbl.addAttribute(termExp.expressionDescr, termExp.getExpressionTypeHeading(), Table.InputType_TextBox, CM_TerminologyExpression::userExpression.length -1 , true);
		tbl.setValueByName(termExp.expressionDescr, termExp.userExpression);
	endforeach;
	
	tbl.resetSize();
	tbl.optimiseHeadingColumn();
	
end;</source>
        <Parameter name="_termHdr" type="CM_TerminologyDef"/>
    </JadeMethod>
    <JadeMethod name="tblHdrEntry_dblClick" id="b5292e86-7116-420b-8c77-d5de31a56a67">
        <controlMethod name="CM_EntryTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblHdrEntry_dblClick(table: CM_EntryTable input) updating;
//----------------------------------------------------------------
//	Created:	08 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " "  );

	table.accessCell(table.row, table.column);
	
	// table.inspect;                                                          // 5/11/2015 cnwmk3

epilog

end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7eb8398a-e3f7-41fe-aebe-26f04fb5d701">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008206, locale);
	shtHdrEntry.translateCaption(Xlat_0001066, locale);
	shtTermHdrs.translateCaption(Xlat_0001067, locale);
end;</source>
    </JadeMethod>
</GUIClass>
