epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="2127bcb7-cece-422c-a5b9-52a9037308ca">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2022	navds20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	theForm	: SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_DamageRepairReason);
	
	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_DamageRepairReason);
	theForm.shtTblInput1.visible := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="995b8317-e468-4f4d-9e09-082897c14420">
        <updating/>
        <source>showThumbnail(_damageRepairReason : CM_RepairReason) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2022	navds20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.tblInput1.clearValues();
	
	theForm.tblInput1.setValueByName(ETRow_Code, _damageRepairReason.code);
	theForm.tblInput1.setValueByName(ETRow_Description, _damageRepairReason.description);
	theForm.tblInput1.setValueByName(ETRow_IsNotAvailableForEntry, _damageRepairReason.isNotAvalableForEntry);
epilog

end;</source>
        <Parameter name="_damageRepairReason" type="CM_RepairReason"/>
    </JadeMethod>
</Class>
