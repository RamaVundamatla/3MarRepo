    <JadeMethod name="resetCodeGroupType" id="0d2400d9-3990-4924-83bf-f25bc8b47dfe">
        <source>resetCodeGroupType(pConstant : Constant; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     06 June 2002 by cnwsb1
//
// Purpose:     This is used as a "callBack" method from "resetCodeGroupTypes".
//				There are no references to this method BUT it is still called
//
// Parameters:  The constant which should be of type CM_CodeGroupTypes
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	text,
	descr,
	groupClassName	: String;
	groupClass		: Class;
	proxyCodeGroupType,
	realCodeGroupType	: CM_CodeGroupType;
	
begin
	if pConstant.valueAsInteger &lt;=CodeGroup_Null or
	   pConstant.valueAsInteger &gt; CodeGroup_MaxNumber then
	   	return;
	endif;

	text := pConstant.text;
	
	descr := text.cnEcGetTagValueOfName('Descr');
	groupClassName := text.cnEcGetTagValueOfName('GroupClass');
	if descr = null and pConstant.valueAsInteger = CodeGroup_MaxNumber then
		// A Code group type is not created.
		return;
	endif;
	if descr = null or groupClassName = null then
		app.raiseUnexpectedProgramError(groupClass.name, method.name,
				'Invalid format for text for code group type constant (' &amp; pConstant.name &amp; ')');
		return;
	endif;

	groupClass := currentSchema.getClass(groupClassName);
	if groupClass = null then
		app.raiseUnexpectedProgramError(groupClass.name, method.name,
				'Class (' &amp; groupClassName &amp; ') not found for (' &amp; pConstant.name &amp; ')');
		return;
	endif;

	realCodeGroupType := self.allCodeGroupTypes[pConstant.valueAsInteger];

	if realCodeGroupType = null then
		// treat as a create
		create proxyCodeGroupType transient;
		proxyCodeGroupType.setProxyFromXML(pConstant.valueAsInteger, text, self);
		app.myUtilityCA.utlCreateCodeGroupType(proxyCodeGroupType, realCodeGroupType, _passport);
	else
		proxyCodeGroupType := app.createUpdateProxy(realCodeGroupType).CM_CodeGroupType;
		proxyCodeGroupType.setProxyFromXML(pConstant.valueAsInteger, text, self);
		app.myUtilityUA.utlUpdateCodeGroupType(proxyCodeGroupType, _passport);
	endif;

epilog
	delete proxyCodeGroupType;
	
end;</source>
        <Parameter name="pConstant" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
