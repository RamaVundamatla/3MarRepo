vars

	moveController	: CMIF_MoveController;
begin

	create moveController transient;
	
	delete app.myMoveController;
	app.myMoveController := moveController;
	moveController.setMyToPrimaryLocation(_theLocation);

	moveController.setMoveMode(self.moveModeForm);	
epilog

end;</source>
        <Parameter name="_theLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setMoveMode" id="d324bd5d-e7b2-4751-af3d-0c02c194cc7e">
        <updating/>
        <source>setMoveMode(_mode: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     26 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	cdc : YRD_RoRoLaneDrawingController;
	anObj : Object;

begin
	inheritMethod(_mode);

	foreach anObj in self.allDrawingControllers do
		cdc := anObj.YRD_RoRoLaneDrawingController;
		cdc.moveMode := _mode;
	endforeach;
end;</source>
