    <JadeMethod name="getStorageTimes" id="c597921a-53f8-460a-a9c0-4bb0cf5fb380">
        <source>getStorageTimes(finish: TimeStamp; start: TimeStamp; ti: CM_TrackedItem; arrDateTimes: TimeStampArray input);

vars
	prodGroupMap : CM_ProductGroupMap;
	prodMap : CM_ProductMap;
	tism:             CM_TIServiceMap;
	imexsm:           CM_ImexServiceMap;
	cns:              CM_ContentsMap;
	commodityMap:     CM_CommodityMap;
	sb:               CM_ServiceBroker;
	invoiceLineDesc:  CM_InvoiceLineDesc;
	iter:             Iterator;
	theDebtor : CM_Debtor;
	aSBController : CMIF_ServiceBroker;

begin
	arrDateTimes.clear;

	// does the invoice line description specify one transaction per financial period?
	tism := getTIServiceMap(ti);
	prodGroupMap := tism.getProductGroupMap(ti);
	prodMap := prodGroupMap.getProductMap(ti);
	imexsm := prodMap.getImexServiceMap(ti);
	cns := imexsm.getContentsMap(ti);
	commodityMap := cns.getCommodityMap(ti);
	sb := commodityMap.allTransServiceBrokersByType[TRANS_TYPE_STORAGE];
	if sb = null then
		// get the default if no entry for CM_Storage
		sb := commodityMap.getDefaultServiceBroker();
	endif;

	if   app.myRoot.canDo(Mod_Invoicing) // Invoice License
	and self.terminal.getConfig(FinancialsEnabled).Boolean then
		create aSBController transient;
		aSBController.myTrackedItem  := ti;
		sb.getInvoiceLineDesc(aSBController);
		
		invoiceLineDesc := aSBController.allInvoiceLineTypes.first;
	
		if invoiceLineDesc &lt;&gt; null and invoiceLineDesc.bOneLinePerFinancialPeriod then
	
			if ti.myOperator &lt;&gt; null then // CCMS 1125 
				theDebtor := ti.myOperator.debtor; // CCMS 1125 
			endif; 
			self.getPeriodEndDates(theDebtor, start, finish, arrDateTimes); // CCMS 1125 
	
		endif;
	endif;
	// ### TFS CR 58263 TASK 58264 15JAN2024 NAVAB1 arrDateTimes.add(finish);

epilog
	delete aSBController;
	delete iter;
end;</source>
        <Parameter name="finish" type="TimeStamp"/>
        <Parameter name="start" type="TimeStamp"/>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="arrDateTimes" type="TimeStampArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTIServiceMap" id="b90f1ea3-9a4a-4a75-b073-c84b373d0326">
        <source>getTIServiceMap(ti : CM_TrackedItem) : CM_TIServiceMap;
//	10 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
//  18 Oct 2024 navlw1	JIRA-33107: Invoice Logging Use Levels
vars
	tiMap 			: CM_TIServiceMap;
	cargoType		: CM_CargoType;
	canLogExtra		: Boolean;
begin
	canLogExtra	:= app.canLogExtraDetail();						//10.10.2022 navma1 #52967
	cargoType	:= ti.myCargoType;								//10.10.2022 navma1 #52967
	
	if canLogExtra then							 			    //10.10.2022 navma1 #52967
		app.invLog("Cargo transaction map " &amp; self.currentTransactionMap.name, LogTRACE.String);
		if cargoType &lt;&gt; null then // ### TFS CR 55624 TASK 55700 26JAN2023 NAVAB1
			// ### TFS CR 55624 TASK 55700 26JAN2023 NAVAB1
			app.invLog("Cargo Type is " &amp; cargoType.description, LogTRACE.String);
		endif;
	endif;
	
	tiMap := self.currentTransactionMap.allTIServices[cargoType];
	if tiMap &lt;&gt; null and
	   cargoType &lt;&gt; null then
		if canLogExtra then							  			 //10.10.2022 navma1 #52967
			app.invLog("Service map found for cargo type " &amp; cargoType.description, LogTRACE.String);
		endif;
	endif;
	
	if tiMap = null then
		if cargoType &lt;&gt; null then // has a cargo type that is not mapped so get default
			tiMap := currentTransactionMap.tiServiceMap[CM_TIServiceMap.DEFAULT_TI_MAP];
			if canLogExtra then							  			 //10.10.2022 navma1 #52967
				app.invLog("Service map for DEFAULT", LogINFO.String);
			endif;
		else
			tiMap := currentTransactionMap.tiServiceMap[ti.class.name];
			if tiMap &lt;&gt; null then
				if canLogExtra then							  			 //10.10.2022 navma1 #52967
					app.invLog("Service map found for " &amp; ti.class.name, LogINFO.String);
				endif;
			endif;
			if tiMap = null then
				tiMap := currentTransactionMap.tiServiceMap[CM_TIServiceMap.DEFAULT_TI_MAP];
				if canLogExtra then							  			 //10.10.2022 navma1 #52967
					app.invLog("Service map for DEFAULT", LogINFO.String);
				endif;
			endif;
		endif;
	endif;
	return tiMap;

end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_TIServiceMap"/>
    </JadeMethod>
    <JadeMethod name="getTerminalCode" id="c436795e-ee4a-404e-9257-f6d8248953fd">
