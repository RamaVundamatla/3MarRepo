        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="identity" id="a1fec0b4-3515-4fa7-9f1f-6f57357d6bdc">
        <source>identity(): String;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lLabel : String;
begin
	lLabel := self.class.name;
	lLabel := lLabel &amp; " " &amp; self.getMyPreviousController(CM_StackController).CM_StackController.myTerminalArea.id.trimBlanks;
	lLabel := lLabel &amp; " " &amp; self.getMyPreviousController(CM_StackController).CM_StackController.getID.trimBlanks;
	lLabel := lLabel &amp; " " &amp; "G";
	
	return lLabel;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="inUse" id="72667ec4-5755-49a3-bce0-bc31b37054fc">
        <source>inUse() : Boolean;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		NOTE This replaces isAvailable
//				Can I use this gap. It exists but can only be used if the width is not zero.
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if self.width = 0 then
		return false;
	endif;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
