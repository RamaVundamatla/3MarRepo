    <JadeMethod name="getDelayHours" id="e5061355-f211-43d2-8f82-1c46eed421b7">
        <source>getDelayHours():Decimal;
// ---------------------------------------------------------------------------
// Created:     05 August 2014 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// PAR 34360
// ---------------------------------------------------------------------------

vars
	aKPI		:CM_KPI;
	result	:Decimal [23, 8];
begin
	foreach aKPI in self.myVoyage.allVoyageKPIEntities discreteLock where aKPI.type = KPI_Type_VoyageCraneShift  do
		
		result := result + aKPI.CM_KPIVoyageCraneShift.hoursDelay;	
	endforeach;
	
	return result.roundedTo (2);
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
