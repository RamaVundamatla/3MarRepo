    <JadeMethod name="isStorageDetailMatch" id="c21a6511-6e40-40f2-adcf-d71f0fa60070">
        <source>isStorageDetailMatch(_criteria: CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
// CCMS 1295 free storage days
vars

begin
	//epr TFS 37176 21/2/18
	//return _criteria.myYAData.CM_YADataBoolean.doesValueMatch( _ti.isHazardous);
	
	if _tiTrx &lt;&gt; null and _tiTrx.myTrackedItem &lt;&gt; null then	//13 Nov 2019	NDL	TFS 47344
		return _criteria.myYAData.CM_YADataBoolean.doesValueMatch( _tiTrx.myTrackedItem.isHazardous );// is Hazardous not kept on the generic transaction
	else
		return _criteria.myYAData.CM_YADataBoolean.doesValueMatch( _ti.isHazardous );
	endif;

end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVoyageAllocationCT" id="8d01a306-f166-426b-b3bd-bb82dc0f7b4a">
