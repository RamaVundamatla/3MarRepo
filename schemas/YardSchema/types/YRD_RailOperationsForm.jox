    <JadeMethod name="doTblInfoDblClick" id="df6529fa-b378-4e98-9a78-7341f2a1f72a">
        <updating/>
        <source>doTblInfoDblClick(table: Table input) updating;
/*
Purpose:			

Date		Who		Reason
4.5.2023 navmk20 TFS 57853
*/

vars
	anObject : Object;
begin
	if table.row &gt; 0 and table.column &gt; 0 then
		anObject := table.accessCell(table.row,table.column).itemObject;
		if anObject &lt;&gt; null then
			if anObject.isKindOf(CM_Wagon) then
				self.showWagonMaintForm(anObject.CM_Wagon,0,0);
			elseif anObject.isKindOf(CM_Train) then
				self.myAssistant.YRD_Assistant.showTrainMaintenance(anObject.CM_Train, self.myMasterMenuAction, null, self);
				
			else
				anObject.inspect;
			endif;
		endif;
	endif;

epilog
end;</source>
