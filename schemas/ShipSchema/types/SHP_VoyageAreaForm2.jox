    <JadeMethod name="showHideSequenceToolbar" id="a9e61a63-0823-424d-9bc0-d30a64453a1f">
        <source>showHideSequenceToolbar(_show : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
begin

	// always purge regardless of which way switching
	// to ensure we have a clean start
	self.customSeqObjPurge();

	self.lblSeqNum.visible := _show;
	self.txtSeqNum.visible := _show;

	self.btnTwinLiftCrane.visible := _show;
	
	if _show then
		self.frmToolbar2.showSeperator(self.seperatorSequence);
	
		if self.displayMode = ShpDisplayMode_ColCodeDisch then
			self.btnSeqDisP2ST2B.visible := _show;
			self.btnSeqDisS2PT2B.visible := _show;
			self.btnSeqDisT2BP2S.visible := _show;
			self.btnSeqDisT2BS2P.visible := _show;
			self.btnSeqLoadP2SB2T.visible := not _show; // PAR 8766 added
			self.btnSeqLoadS2PB2T.visible := not _show; // PAR 8766 added
			self.btnSeqLoadB2TP2S.visible := not _show; // PAR 8766 added
			self.btnSeqLoadB2TS2P.visible := not _show; // PAR 8766 added
		else
			self.btnSeqLoadP2SB2T.visible := _show;
			self.btnSeqLoadS2PB2T.visible := _show;
			self.btnSeqLoadB2TP2S.visible := _show;
			self.btnSeqLoadB2TS2P.visible := _show;
			self.btnSeqDisP2ST2B.visible := not _show; // PAR 8766 added
			self.btnSeqDisS2PT2B.visible := not _show; // PAR 8766 added
			self.btnSeqDisT2BP2S.visible := not _show; // PAR 8766 added
			self.btnSeqDisT2BS2P.visible := not _show; // PAR 8766 added
		endif;

		self.frmToolbarSeqNum.width := self.txtSeqNum.left + self.txtSeqNum.width + 2;
		self.frmToolbarSeqNum.visible := true;
		
		self.frmToolbarCombos.width := 0;
		
		self.btnSaveBase.visible	:= true;
		self.setToolbarCombosWidth();
	else
		self.frmToolbar2.hideSeperator(self.seperatorSequence);

		// hide them all in-case get out of sync
		self.btnSeqDisP2ST2B.visible := _show;
		self.btnSeqDisS2PT2B.visible := _show;
		self.btnSeqDisT2BP2S.visible := _show;
		self.btnSeqDisT2BS2P.visible := _show;
		self.btnSeqLoadP2SB2T.visible := _show;
		self.btnSeqLoadS2PB2T.visible := _show;
		self.btnSeqLoadB2TP2S.visible := _show;
		self.btnSeqLoadB2TS2P.visible := _show;

		self.frmToolbarSeqNum.visible := false;
		self.frmToolbarSeqNum.width := 0;

		self.btnSaveBase.visible	:= true;
	endif;

	self.frmToolSeqApply.visible := _show;
	
end;</source>
        <access>protected</access>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showHideTipsFrame" id="0e6a3cb6-2d4c-41d2-9070-d0d705da3059">
        <source>showHideTipsFrame() protected;
// ---------------------------------------------------------------------------
