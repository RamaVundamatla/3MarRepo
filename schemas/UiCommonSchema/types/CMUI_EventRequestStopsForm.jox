    </JadeMethod>
    <JadeMethod name="lstTableDisplayRow" id="a956414a-561b-4dc9-9511-132997619eec">
        <updating/>
        <source>lstTableDisplayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	selected	: Boolean;
begin

	selected := table.CMUI_ListTable.allSelectedObjects.includes(obj);
	
	if obj.isKindOf(CM_StopsTable) then
	
		return self.myAssistant.displayEntryStopsTableList(obj.CM_StopsTable, selected, true);
	elseif obj.isKindOf(CM_ToDoTaskDesc) then
		
		return self.myAssistant.displayEntryToDoTaskList(obj.CM_ToDoTaskDesc,selected);
	elseif obj.isKindOf(CM_MTGrade) then
		return self.myAssistant.displayEntryMTGradeList(obj.CM_MTGrade,selected);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setCMIFSearchEventRequest" id="40ef22a6-4adb-4b9e-8a36-180ee7368f86">
        <source>setCMIFSearchEventRequest(_propName: String; strValue: String; _obj: CMIF_SearchEventRequest input; _tbl: CM_EntryTable): Boolean;
//--------------------------------------------------
// Created:	06 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if inheritMethod(_propName, strValue, _obj, _tbl) then
		return true;
	elseif _propName = ETRow_Reference then
		_obj.reference := strValue;
	elseif _propName = ETRow_Event then
		if self.cmbUpdateType.listData = EventRequestTypeStops then
			self.lstTable.allSelectedObjects.copy(_obj.allStopTables);
		else
	
			self.lstTable.allSelectedObjects.copy(_obj.allUpdateFields);
			
		endif;
		return true;
	elseif _propName = ETRow_Type or _propName = ETRow_UpdateType then
		_obj.type := self.cmbUpdateType.listData;
		return true;
	else
		return false;
	endif;
end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="strValue" type="String"/>
        <Parameter name="_obj" type="CMIF_SearchEventRequest" usage="input"/>
        <Parameter name="_tbl" type="CM_EntryTable"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="491e4913-cb27-4b1c-9ba3-862938d063e4">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
// 14/12/2010	cnwcs5	ccms mes 1112 / par 24464
vars

begin
	inheritMethod();
	self.beginClassNotification(CM_EventRequestStops, false, Object_Create_Event, Response_Continuous, null);
	self.beginClassNotification(CM_EventRequestStops, false, Object_Update_Event, Response_Continuous, null);
	self.beginClassNotification(CM_EventRequestStops, false, Object_Delete_Event, Response_Continuous, null);
	self.eventRequestType := EventRequestTypeStopsStr;	
	self.tblData.myDataClass := CM_EventRequestStops;	
	
	// show activate menu items
	self.mnuSep1.visible			:= true;
	self.mnuActivateRequest.visible	:= true;
end;</source>
    </JadeMethod>
    <JadeMethod name="showEventRequestModal" id="f0f408c6-3d45-44a5-af63-b584bb30a2b1">
        <updating/>
        <source>showEventRequestModal(_mode: Integer) updating;
/*

Date		Who		Reason
01 May 2014	cnwer1	Initial creation PAR

*/

vars
	str : String;
	form : CMUI_CargoUpdateRequestForm;
begin
	
	if self.mode = _mode then
		return;
	endif;

	if _mode &lt; self.Mode_View
	or _mode &gt; self.Mode_Update then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Invalid_Mode));
		return;
	elseif _mode = self.Mode_Add then
		str := app.getErrorString(Add);
	elseif _mode = self.Mode_Update then
		if self.tblData.allSelectedObjects.size &gt; 1 then
			app.msgBox(app.getErrorString(Please_Select_One_Item), app.getErrorString(Select_Item), MsgBox_Stop_Icon  + MsgBox_OK_Only);
			return;
		elseif self.myCurrentEventRequest = null then
			app.msgBox(app.getErrorString(Cannot_Perform_Edit), app.getErrorString(No_Current_Item), MsgBox_Stop_Icon  + MsgBox_OK_Only);
			return;
		endif;
		str := app.getErrorString(Update);
	endif;	
	
	str.firstCharToUpper();
	self.mode := _mode;
	

	form:=app.loadForm(CMUI_CargoUpdateRequestForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_CargoUpdateRequestForm;
	
	if form &lt;&gt; null then
	
		if _mode = self.Mode_Update then 
			form.myCurrentEventRequest := self.myCurrentEventRequest.CM_EventRequestStops;
		endif;
	
		form.centreWindow;
		form.show;
	endif;

epilog
	self.mode := self.Mode_View;

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="6affc94a-2020-4a38-95a0-87f87760e6f2">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007437, locale);
end;</source>
    </JadeMethod>
</GUIClass>
