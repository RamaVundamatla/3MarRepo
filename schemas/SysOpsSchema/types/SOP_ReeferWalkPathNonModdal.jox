<GUIClass name="SOP_ReeferWalkPathNonModdal" id="b61d4c40-8a65-47a0-a38f-a50baea1b3c2">
    <superclass name="SOP_ReeferWalkPathForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>'Moddal' with 2 d's to work around the GenTranslate stuff expecting the Modal version to be subclassed, not the other way around</text>
    <JadeMethod name="translateForm" id="6140b546-5450-4f1d-9780-4731aafc226c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 August 2020 10:35:10.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024013, locale);
end;</source>
    </JadeMethod>
</GUIClass>
