    <JadeMethod name="doSetHeaderRow" id="9066c51d-3411-49f3-8b64-eac8a2b2c136">
        <source>doSetHeaderRow();
/*

Date		    Who			Reason
31 January 2011	cnwas3	  par 26840

*/

vars
	table : CM_DataTable;
begin
	table := self.tblCCAllocation;
	
	if table.fixedRows = 2 then
		table.removeItem(1);
		table.fixedRows := 1;
	endif;
	
	if self.isExport then		
		
		table.addItemAt(Tab &amp;  Tab &amp; "Exports" &amp; Tab &amp; Tab &amp; "Actual Cargo" &amp; Tab  &amp; Tab &amp; Tab &amp; Tab &amp; "Colour Coding" &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; "Planned",1);
		table.fixedRows := 2;
		
		table.accessCell(1,1).mergeCells := Table.MergeCells_Merge;
		table.accessCell(1,1).alignment := Table.Alignment_Center_Middle;
		
		table.accessCell(1,3).mergeCells := Table.MergeCells_Merge;
		table.accessCell(1,3).alignment := Table.Alignment_Center_Middle;
		
		table.accessCell(1,5).mergeCells := Table.MergeCells_Merge;
		table.accessCell(1,5).alignment := Table.Alignment_Center_Middle;
		
		table.accessCell(1,9).mergeCells := Table.MergeCells_Merge;
		table.accessCell(1,9).alignment := Table.Alignment_Center_Middle;
		
		table.accessCell(1,13).mergeCells := Table.MergeCells_Merge;
		table.accessCell(1,13).alignment := Table.Alignment_Center_Middle;		
		
		table.accessRow(2).alignment:=Table.Alignment_Center_Middle;
		table.accessCell(2,2).alignment := Table.Alignment_Center_Middle;
	else		
		//discharge case goes here, if need be
		table.accessRow(1).alignment:=Table.Alignment_Center_Middle;
		table.accessCell(1,2).alignment := Table.Alignment_Center_Middle;
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSystemNotification" id="77b15d63-539d-4e74-968c-a97c23c4ae6b">
        <updating/>
        <source>doSystemNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*

Date		Who		Reason
08 Feb 2011	cnwas3	  par 26840a
01 Mar 2011	cnwkpd1	PAR #27032 - Load Colour Code performance
17/06/2011		cnwas3 par 26840b - cleaned up and enhanced performance
*/

vars
	ti 				: CM_TrackedItem;
	theRow 			: Integer;
	dataTbl			: CM_DataTable;
	ts 				: TimeStamp;
	loadStateSet	: Boolean;
	invalidTI		: Boolean;
	
begin
	
	if theObject = null or 
		(not self.visible) or 
		(not theObject.isKindOf(CM_TrackedItem)) then
			return;
	endif;
			
	self.doQueueRefresh();
	
epilog


end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initTblCCAllocation" id="d2d7dda0-f2f1-4750-b6fa-da51ddbb7283">
        <updating/>
        <source>initTblCCAllocation(_theEntDef: String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 January 2010	cnwas3	Initial creation

*/

vars
	entTableView	: EntTableView;
	entTableDef		: EntTableDef;
	theTable		: CM_DataTable;
	selectedCol 	: Integer;
begin
	theTable := self.tblCCAllocation;
	theTable.userInputEnabled := true;
	theTable.inputType := Table.InputType_None;	
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;

	theTable.defaultRowHeight := 20;
	theTable.rows := theTable.fixedRows;
	//theTable.cnEcResizeContents();
	
	entTableDef := app.myController.getEntTableDef(_theEntDef);
	if entTableDef &lt;&gt; null then
		theTable.setTblDataEntRowsFromDef(entTableDef);
	endif;
	//theTable.width := self.dkbCCPallette.width-20;
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;
	//selectedCol := theTable.getColumnByRowName(ETRow_Selected);
	//theTable.accessColumn(selectedCol).fontName := "Wingdings";
	theTable.sortColumn[1] := 2;	
	theTable.sortAscending := true;	
	
	self.doSetHeaderRow();//cnwas3 par 26840
	self.displayCCTable();
	theTable.alignment := Table.Alignment_Right_Middle;
	theTable.accessColumn(2).alignment := Table.Alignment_Left_Middle;
	theTable.accessColumn(1).width := 25;	
	
	
	selectedCol := theTable.getColumnByRowName(ETRow_Projected);
	if selectedCol &gt; 0 then
		theTable.accessColumn(selectedCol).inputType := Table.InputType_TextNumeric;
		theTable.accessColumn(selectedCol).alignment := Table.Alignment_Center_Middle;
	endif;
	

end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
