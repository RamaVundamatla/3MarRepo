    <JadeMethod name="doResize" id="d78db004-b6cc-4b04-8bf7-6513b0832b73">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     19 November 2002		cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
//11/07/2018 	jlgns1	Bug 39368: STWO - Report Profile Issue
vars
	
begin
	inheritMethod();

	//self.setTblCriteriaHeight();
	//self.tblCriteria.height := (self.btnJRWConfigT.top - 10 - self.tblCriteria.top);
	//changed by cnwyl1
	self.tblCriteria.adjustHeight(1000);								//Bug 39368
	//self.tblCriteria.height := self.height - 250;//added by cnwyl1	//Bug 39368
	self.tblParamData.height := self.tblParamData.parent.height - self.VerticalSpacing;
	self.tblParamEnt.height := self.tblParamEnt.parent.height - 50;
	
	self.lblSelector.width := self.tblCriteria.width;
	self.lblSelector.height := self.tblCriteria.height;
	self.lblSelector.top := self.tblReportDtl.height + 150;
	
	self.tblCriteria.top := self.tblReportDtl.top +  self.tblReportDtl.height + 9;//added by cnwyl1	//Bug 39368

	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="2aeaf8d0-3e91-4b5a-bad8-f493eefba7e0">
        <updating/>
        <source>doSave(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		13 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	rtnValue		: Boolean;
	cmifMonitor		: CMIF_Monitor;
begin

	if app.myPassport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;

	self.modalDialogShow(null, null, null, null, "Saving Report", null);
	self.pbProgressBar.visible := true;
   	self.updateProgress(cmifMonitor);	
	/*self.lblModalMessage.caption := "Saving Report";
	self.btnModalDefault.visible := false;
	self.frmModalDialog.visible := true;*/
	
	
	self.addSystemTypeToCombo();
	
	if self.isEditingSystemReport then
		rtnValue := self.doSaveSystemReport();
	else
		rtnValue := self.doSaveUserReport();
	endif;
	
	if (not rtnValue) then
		self.removeSystemTypeFromCombo();
	endif;
	
	return rtnValue;
epilog
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveSystemReport" id="b1f6daae-ce12-4c72-90dc-bfec1c71f478">
        <updating/>
        <source>doSaveSystemReport() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	pxyReportSystem,
	newReport 					: CM_QryReportSystem;
	menuRoot					: CM_MenuRoot;
	tbl							: CMUI_ListTable;
	row,
	numRows						: Integer;
	jrwRep						: CMUI_JRWEntityRepresentation;
	allReportFormats			: IntegerArray;
	reportAvailability			: Integer;
	canReportBeRunInBackground	: Boolean;
	reportProcessType			: Integer;
	reportDescription			: String;
	paramTbl		: CM_DataTable;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	//will force agent to interpret date fields in template format (ie Run Date + n etc.
	
	create  allReportFormats transient;
	if self.myProxyObject = null then
		create self.myProxyObject as CM_QryReportSystem transient;
	endif;
	
	pxyReportSystem := self.myProxyObject.CM_QryReportSystem;
	// 35875 allow dev to change description
	if app.isDevelopmentSystemMain() then
		reportDescription := self.tblReportDtl.getValueByName(ETRow_ReportDescription).String;
		pxyReportSystem.setReportDescription(reportDescription);
	endif;
	
	//th2 for PAR 12742
	pxyReportSystem.allQueryReportParams.clear();
	paramTbl := self.tblParamData;
	numRows := paramTbl.rows;
	foreach row in paramTbl.fixedRows + 1 to numRows do
		if CM_QueryReportParam.hasInstance(paramTbl.accessRow(row).itemObject) then
			pxyReportSystem.allQueryReportParams.add(paramTbl.accessedRow.itemObject.CM_QueryReportParam);
		endif;
	endforeach;
	
	if pxyReportSystem.myFilterObject = null then//this should never happen
		pxyReportSystem.setMyFilterObject(pxyReportSystem.createFilter());
	endif;
	
	// Looks like some internal reports have no filter.
	// Par 12847 - 13/11/2006
	if pxyReportSystem.myFilterObject &lt;&gt; null then
		pxyReportSystem.myFilterObject.setFromAgent(self.myReportAgent);
		pxyReportSystem.myFilterObject.initFields();
	endif;
	
	//checkbox selected designs
	tbl := self.tblDesigns;
	numRows := tbl.rows;
	pxyReportSystem.jrwReportName.clear();
	foreach row in 1 to numRows do
		jrwRep := tbl.accessRow(row).itemObject.CMUI_JRWEntityRepresentation;
		if jrwRep = null then
			continue;
		endif;
		if tbl.getCellText(row, 1) = '1' then
			pxyReportSystem.jrwReportName.add(jrwRep.name);
		endif;
	endforeach;

	if pxyReportSystem.jrwReportName.isEmpty and (not pxyReportSystem.isFormBasedReport) then
		app.msgBox('You must select at least one design to run against this report', 'Nothing Selected...', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	self.getSelectedFormats(allReportFormats);
	
	if allReportFormats.isEmpty() then
		app.msgBox('You must select at least one Report Format','Insufficient input', MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;

	if self.cmbRptAvail.listIndex &gt; 0 then
		reportAvailability := self.cmbRptAvail.itemData[self.cmbRptAvail.listIndex];
	endif;
	
//	canReportBeRunInBackground := self.tblReportDtl.getValueByName((ETRow_IsAvailableInBackground)).Boolean;
	if self.cmbBackground.listIndex &gt; 0 then
		reportProcessType := self.cmbBackground.itemData[self.cmbBackground.listIndex];
	endif;
	
	// This is setting the proxy!!
//	pxyReportSystem.setRptAvailabilityAndFormats(reportAvailability, canReportBeRunInBackground, allReportFormats);
	pxyReportSystem.setRptAvailabilityAndFormats(reportAvailability, reportProcessType, allReportFormats);
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if self.mode = Mode_Add then //something has gone terribly wrong
			app.raiseUnexpectedProgramError(class.name, method.name, 'Form is in Add Mode for updating a system report');
			return false;
		elseif self.mode = self.Mode_Update then
			app.myTrxUA.trxUpdateQryReportSystem(pxyReportSystem, app.myPassport);		
		endif;
	
		if app.myPassport.trxCompletedOK then
			return true;
		else
			theResult := app.showErrorWarningDialog('User Report Update', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
epilog
	delete allReportFormats;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveUserReport" id="abac8c8a-d3c2-412f-8f24-bf3e9b436ad8">
        <updating/>
        <source>doSaveUserReport() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	pxyReportUser,
	newReport 		: CM_QryReportUser;
	menuRoot		: CM_MenuRoot;
	paramTbl		: CM_DataTable;
	numRows,
	row				: Integer;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	menuRoot := app.myRoot.myReportMenuRoot;
	//will force agent to interpret date fields in template format (ie Run Date + n etc.)
	
	if self.myProxyObject = null then
		create self.myProxyObject as CM_QryReportUser transient;
	endif;
	
	pxyReportUser := self.myProxyObject.CM_QryReportUser;
	self.myReportAgent.initQryReportForBuilder(pxyReportUser);
	
	//th2 for PAR 12742
	pxyReportUser.allQueryReportParams.clear();
	paramTbl := self.tblParamData;
	numRows := paramTbl.rows;
	foreach row in paramTbl.fixedRows + 1 to numRows do
		if CM_QueryReportParam.hasInstance(paramTbl.accessRow(row).itemObject) then
			pxyReportUser.allQueryReportParams.add(paramTbl.accessedRow.itemObject.CM_QueryReportParam);
		endif;
	endforeach;

	if (not self.setPxyReportFromTable(pxyReportUser)) then
		return false;
	endif;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateQryReportUser(pxyReportUser, newReport, menuRoot, app.myPassport);
			self.myCurrentObject := newReport;
		elseif self.mode = self.Mode_Update then
			app.myTrxUA.trxUpdateQryReportUser(pxyReportUser, app.myPassport);		
		endif;
	
		if app.myPassport.trxCompletedOK then
			return true;
		else
			theResult := app.showErrorWarningDialog('User Report Update', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblCriteriaClick" id="d065d931-19f3-48ba-aab8-a3e1b8795135">
        <updating/>
        <source>doTblCriteriaClick(_table : Table input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _table.row &lt;= _table.fixedRows then
		return;
	endif;
	
	if _table.column = self.Column_Include then
		//don't let them not include a system defined criteria - but they can choose
		//it to be not visible if they want
		if self.isEditingSystemReport then
			_table.accessCell(_table.row, self.Column_Include).text := '1';
			app.msgBox('You cannot choose to exclude criteria from system defined reports.','Not Allowed', MsgBox_Exclamation_Mark_Icon);
		else
			_table.accessCell(_table.row, self.Column_Visible).text := _table.accessCell(_table.row, self.Column_Include).text;
		endif;
		
	elseif _table.column = self.Column_Visible then
		if self.isEditingSystemReport then
			_table.accessCell(_table.row, self.Column_Visible).text := '1';
			app.msgBox('You cannot choose to hide criteria in system defined reports.','Not Allowed', MsgBox_Exclamation_Mark_Icon);
		else
			if (_table.accessCell(_table.row, self.Column_Visible).text) = '1' then
				_table.accessCell(_table.row, self.Column_Include).text := '1';
			endif;
		endif;
	endif;
	

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDesignsGotFocus" id="af55929e-16eb-4a09-8f0f-e55a28007641">
        <updating/>
        <source>doTblDesignsGotFocus() updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 June 2004	cnwth2
//
// Purpose:     
//			 
// Note: This method is also now called from lstFormats_gotFocus
// ----------   ----------  --------------------------------------------------
//11/07/2018 	jlgns1	Bug 39368: STWO - Report Profile Issue
vars
	tbl			: CM_EntryTable;
begin
	tbl := self.tblReportDtl;	
	

	if tbl.row &lt;&gt; tbl.getRowByName(ETRow_JrwReport) and		//Bug 39368
	tbl.row &lt;&gt; tbl.getRowByName(ETRow_ReportFormat) then	//Bug 39368
		return;												//Bug 39368
	endif;													//Bug 39368
	tbl.doWindowEvents(0);									//Bug 39368	
	tbl.accessRow(tbl.row).height := 120;					//Bug 39368
															//Bug 39368
	tbl.adjustHeight(self.height);							//Bug 39368
	self.lblSelector.top :=  tbl.top + tbl.height + 10;		//Bug 39368
	self.tblCriteria.top := self.lblSelector.top;			//Bug 39368
	
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTblDesignsLostFocus" id="9135355a-c34c-40e3-8f50-e57cf84bf73a">
        <updating/>
        <source>doTblDesignsLostFocus() updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 June 2004	cnwth2
//
// Purpose:     
//			 
//	Note: This method is also now called from lstFormats_lostFocus
// ----------   ----------  --------------------------------------------------
//11/07/2018 	jlgns1	Bug 39368: STWO - Report Profile Issue

vars
	tbl : CM_EntryTable;
	
begin
	tbl := self.tblReportDtl;

	
	self.myAssistant.listTableLostFocus(tbl, self.saveRowHeight, self.tblDesigns, 'name', false);
	
	tbl.doWindowEvents(0);								//Bug 39368	
	tbl.adjustHeight(self.height);						//Bug 39368		
	self.tblCriteria.top := tbl.top + tbl.height + 10;	//Bug 39368
	self.lblSelector.top := self.tblCriteria.top;		//Bug 39368
	
	
	self.setTblCriteriaHeight();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTblParamDataRowColChange" id="528eecbb-e4bb-4672-aec7-190dda0d1732">
        <source>doTblParamDataRowColChange(_tbl : CM_DataTable input) protected;
// ---------------------------------------------------------------------------
// Created:     20 August 2003	cnwth2
//
// Purpose:     
// 06 Oct 2025	navah1	MTN-36161: NSWP | Implement Date String Parsing and Conversion Logic	
// 30 Oct 2025 	navah1  MTN-36162: NSWP | Handle Existing Date Parameters Stored and Ensure Legacy Report Support		 
// ----------   ----------  --------------------------------------------------
vars
	str				: String;
	qryParam		: CM_QueryReportParam;
	entDef			: EntTableDef;
	entRow			: EntTableRow;
	entView			: EntTableView;
	entryTbl		: CM_EntryTable;
begin
	entryTbl := self.tblParamEnt;
	entDef := self.tblParamEnt.myEntTableDef;
	if entDef = null then
		return;
	endif;
	
	qryParam := _tbl.accessRow(_tbl.row).itemObject.CM_QueryReportParam;
	
	if qryParam = null then //show default view
		entryTbl.showHideRowsByViewName('default', CM_EntryTable.ShowHideRows, false);
		entryTbl.setValueByName(ETRow_ParamName, null);
		entryTbl.setValueByName(ETRow_DisplayName, null);
		entryTbl.setValueByName(ETRow_IsVisible, true.cnEcGetTableCheckBoxValue);//default param to visible
		entryTbl.setValueByName(ETRow_ParamType, null);
		return;
	endif;
	
	entView := entDef.allEntTableViews[qryParam.getViewNameForType(qryParam.type)];
	
	if entView = null then
		return;
	endif;
	
	entryTbl.showHideRowsByView(entView, CM_EntryTable.ShowHideRows, false);
	entryTbl.setValueByName(ETRow_ParamName, qryParam.paramName);
	entryTbl.setValueByName(ETRow_DisplayName, qryParam.displayName);
	entryTbl.setValueByName(ETRow_IsVisible, qryParam.isVisible);
	entryTbl.setValueByName(ETRow_ParamType, qryParam.getTypeDescription());
	
	if qryParam.type = Binary.number then
		self.tblParamEnt.setValueByName(ETRow_DefaultValBinary, qryParam.defaultValueBinary);
	elseif qryParam.type = Boolean.number then
		self.tblParamEnt.setValueByName(ETRow_DefaultValBoolean, qryParam.defaultValueBoolean);
	elseif qryParam.type = Character.number then
		self.tblParamEnt.setValueByName(ETRow_DefaultValChar, qryParam.defaultValueChar);
	elseif qryParam.type = Date.number then
		//self.tblParamEnt.setValueByName(ETRow_DefaultValDate, qryParam.defaultValueDate);  //06.10.2025 navah1 #36161
		self.tblParamEnt.setValueByName(ETRow_DefaultValDate, qryParam.getTemplateDate());	 //06.10.2025 navah1 #36161
		self.cmbDefaultValDate.text := qryParam.getTemplateDate();							 //30.10.2025 navah1 #36162 
	elseif qryParam.type = Decimal.number then
		self.tblParamEnt.setValueByName(ETRow_DefaultValDecimal, qryParam.defaultValueDecimal);
	elseif qryParam.type = Integer.number then
		self.tblParamEnt.setValueByName(ETRow_DefaultValInteger, qryParam.defaultValueInteger);
	elseif qryParam.type = String.number then
		self.tblParamEnt.setValueByName(ETRow_DefaultValString, qryParam.defaultValueString);
	elseif qryParam.type = Time.number then
		self.tblParamEnt.setValueByName(ETRow_DefaultValTime, qryParam.defaultValueTime);
	endif;
	
	/*
	foreach entRow in entView.allEntTableRows do
		entryTbl.setValueByName(entRow.name, qryParam.getDisplayStringForAttribute(entRow.name));
	endforeach;
	*/
	self.cmbParamType.text := qryParam.getTypeDescription();

epilog
	entryTbl.adjustHeight(200);
	
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblParamEntRowColChange" id="14832f5d-a209-4353-a3f5-2fe8db3d1c57">
        <source>doTblParamEntRowColChange() protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2003	cnwth2
//
// Purpose:     Expand out the row id for picture
//			 
// ----------   ----------  --------------------------------------------------
vars
	tbl				: CM_EntryTable;
	row				: Integer;
begin
	
	tbl := self.tblParamEnt;
	row := tbl.row;
	if row = tbl.getRowByName(ETRow_DefaultValBinary) then
		tbl.accessRow(row).height := self.RowHeight_Expanded;
	else
		tbl.accessRow(tbl.getRowByName(ETRow_DefaultValBinary)).height := self.RowHeight_Normal;	
	endif;
	
	tbl.adjustHeight(200);
	//verify the selected param type is binary
	//if self.cmbParamType.itemData[self.cmbParamType.listIndex] &lt;&gt; Binary.number then
	//	return;
	//endif;	
	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
