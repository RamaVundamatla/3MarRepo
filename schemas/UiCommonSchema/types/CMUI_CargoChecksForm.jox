    <JadeMethod name="updateDamages" id="388d28a4-6869-408e-a016-b9dc1b8123d1">
        <updating/>
        <source>updateDamages( _toDoTaskDesc : CM_ToDoTaskDesc; _toDoTaskCode : Integer; _addingToDo : Boolean; _terminal : CM_Terminal ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2014	cnwndl1	Initial creation
17 Jan 2024 jlika1	Pass Terminal from the Caller Form.
20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
13 Nov 2024	jlizm1	MTN 33161 Damage check details being lost when incomplete
05 Feb 2025	navnk30	JIRA 33887: MTN | Road Gate In Checks throws error for damage check that is Inappropriate.
*/

vars
	advDmgForGTE,
	load : Boolean;
	cmifUpdateController : CMIF_Object;
	damageInterface : IF_DamageDetails;
	proxyTi : CM_TrackedItem;
	proxyGTE : CMGTE_Receival;
	errors : String;
	result : Integer;
	damage	: CM_DamageInstance;
begin

	if self.myGTEReceival &lt;&gt; null then
		advDmgForGTE := app.getMyUser().canDo(self.myTerminal, PmAdmDamageCodeAdvancedView);		//05.02.2025 navnk30 JIRA 33887
		if advDmgForGTE then																		//05.02.2025 navnk30 JIRA 33887
			proxyGTE := self.myGTEReceival.pxyGetProxyObject();
			if proxyGTE = null then
				proxyGTE := self.myGTEReceival.pxyCreateUpdateProxy();
			endif;
			damageInterface := proxyGTE;
		else
			create proxyGTE transient;  // just a dummy one to collect damage on.		
			proxyGTE.setMyTerminal(_terminal);
			damageInterface := proxyGTE.IF_DamageDetails;
		endif;
	elseif self.myTrackedItem &lt;&gt; null then
		proxyTi := self.myTrackedItem.pxyGetProxyObject();
		if proxyTi = null then
			app.cmsBeginLoad(load);
			proxyTi := self.myTrackedItem.pxyCreateUpdateProxy();
			app.cmsEndLoad(load);
		endif;
		damageInterface := proxyTi.IF_DamageDetails;
		if self.effectiveDT.isValid then						//20.02.2024 navhl20 #62525
			proxyTi.zSetPxyDamagedDT(self.effectiveDT);
		endif;
	endif;
	
	if damageInterface = null then
		return false;
	endif;
	
	app.myPassport.clearErrorsWarnings();
	if not self.tblDamages.validateDamageDetails(damageInterface) then
		app.myPassport.setWarningsIgnored(false);
		result := app.showErrorWarningDialog(app.getString(Complete_TDTask), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
	endif;
	app.myPassport.clearErrorsWarnings();
	if result &lt;&gt; IDOK then
		return false;
	endif;
	
	if not advDmgForGTE then							//05.02.2025 navnk30 JIRA 33887
		self.tblDamages.setProxyFromTable(damageInterface, errors, null);
	endif;

	foreach damage in damageInterface.getDamageInstances do		//20.02.2024 navhl20 #62525
		if self.effectiveDT.isValid then
			damage.setDamageDT(self.effectiveDT);
		endif;
	endforeach;
	
	while true do	
	
		if proxyGTE &lt;&gt; null then
			app.myTrxUA.trxUpdateGTEDamageToDo( self.myGTEReceival, proxyGTE, damageInterface, _toDoTaskDesc, _addingToDo, app.myPassport);
		
		elseif proxyTi &lt;&gt; null then
			if _addingToDo and _toDoTaskCode &lt;&gt; null and app.myPassport.noErrors() then					
				app.myTrxUA.trxUpdateTIDamageToDo(proxyTi, _toDoTaskCode, 1, app.myPassport);
			endif;												
			
			if app.myPassport.noErrors() then
				cmifUpdateController := damageInterface.getDamageCMIFController;
				damageInterface.updateDamageDetails(cmifUpdateController,app.myPassport);
			endif;
			
		endif;
		
		if app.myPassport.trxCompletedOK then
			return true;
		else
			
			//don't repeat the warnings we have already OK'd from previous updates.
			if self.onlyHasExistingWarnings( app.myPassport ) then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
				
			result := app.showErrorWarningDialog( damageInterface.getObjectDamageDesc, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
		
	endwhile; 
	
	return false;

epilog

	delete proxyTi;
	delete proxyGTE;
	delete cmifUpdateController;

end;</source>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_toDoTaskCode" type="Integer"/>
        <Parameter name="_addingToDo" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateDimensions" id="cd8c48cc-aa8a-44dd-8f6d-0da304a30783">
        <updating/>
        <source>updateDimensions( _toDoTaskCode : Integer; _addingToDo : Boolean ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2014	cnwndl1	Initial creation

*/

vars

	left : Decimal [16,4];
	right : Decimal [16,4];
	front : Decimal [16,4];
	back : Decimal [16,4];
	height : Decimal [16,4];
	width : Decimal [16,4];
	length : Decimal [16,4];

begin

	if self.myTrackedItem &lt;&gt; null then
		if self.myTrackedItem.isContainer then
			left := self.tblLeft.getConvertedValue;
			right := self.tblRight.getConvertedValue;
			front := self.tblFront.getConvertedValue;
			back := self.tblBack.getConvertedValue;
			height := self.tblHeight.getConvertedValue;
			return self.updateContainerDimensions(	left, right, back, front, height, _toDoTaskCode, _addingToDo	);
		else
			width := self.tblWidth.getConvertedValue;
			length := self.tblLength.getConvertedValue;
			height := self.tblHeight.getConvertedValue;
			return self.updateCargoDimensions(	width, length, height, _toDoTaskCode, _addingToDo	);
		endif;
		
	elseif self.myGTEReceival &lt;&gt; null then
		if self.myGTEReceival.isKindOf( CMGTE_Container ) then
			left := self.tblLeft.getConvertedValue;
			right := self.tblRight.getConvertedValue;
			front := self.tblFront.getConvertedValue;
			back := self.tblBack.getConvertedValue;
			height := self.tblHeight.getConvertedValue;
			return self.updateContainerDimensions(	left, right, back, front, height, _toDoTaskCode, _addingToDo	);
		else
			width := self.tblWidth.getConvertedValue;
			length := self.tblLength.getConvertedValue;
			height := self.tblHeight.getConvertedValue;
			return self.updateCargoDimensions(	width, length, height, _toDoTaskCode, _addingToDo	);
		endif;
		
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_toDoTaskCode" type="Integer"/>
        <Parameter name="_addingToDo" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateGTEProxy" id="dc29fd18-ca0f-4c1e-ac1f-1caa9c75ca3b">
        <source>updateGTEProxy( prxyGTE : CMGTE_Receival input ):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS#	Reason
23 May 2014	cnwndl1			Initial creation
19 Nov 2019	jlgdi1	47311	Fix infinite loop where a cargo does not have any error or warning in the previous 
							cargo validation but encountered cargo check violation error message
*/

vars
	vvr : CM_VehicleVisitRecord;
	result : Integer;

begin
	app.myPassport.clearErrorsWarnings();

	// The Proxy is updated, so now update the database
	while true do
		vvr := self.myGTEReceival.myVehicleVisitRecord;
		app.myTrxUA.trxUpdateInOutFlexiGateEntity(vvr, prxyGTE, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			return true;
		else
			//don't repeat the warnings we have already OK'd from previous updates
			if not self.allGTEWarningsToIgnore.isEmpty() then // if GTEWarningsToIgnore is empty, does not make sense to compare it.
				if self.onlyHasExistingWarnings( app.myPassport ) then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog('Gate Entity Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;
end;</source>
        <access>protected</access>
        <Parameter name="prxyGTE" type="CMGTE_Receival" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateHazardToDo" id="bceebc5b-66df-458e-83e1-583f1d2c8e2e">
        <source>updateHazardToDo(_toDoTaskCode : Integer; _addingToDo : Boolean) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 30/01/2018	jlgdap1		Initial creation TFS 36611 PEN Cannot Check Hazard
// 06/03/2023	jlika1		TFS 56882 - CUX - Transaction for hazardous symbol check in gate checker app.
vars
	load 		: Boolean;
	pxyGTE 		: CMGTE_Receival;
	toDoTask 	: CM_ToDoTaskDesc;
	toDoTasks 	: CM_ToDoTaskDescByCode;	
begin
	if not _addingToDo then
		return true;
	endif;
	
	if self.myTrackedItem &lt;&gt; null then				
		app.myTrxUA.trxCreateHazardsCheckTrans(self.myTrackedItem, app.myPassport);
		
		return self.updateTrackedItemAddToDoTask( _toDoTaskCode );
		
	elseif self.myGTEReceival &lt;&gt; null then
		app.cmsBeginLoad(load);
		pxyGTE := self.myGTEReceival.pxyCreateUpdateProxy;
		app.cmsEndLoad(load);
		
		toDoTask := app.myRoot.allToDoTaskDescriptions.getAtKey( _toDoTaskCode );
		if toDoTask &lt;&gt; null and not pxyGTE.allToDoTasks.includes(toDoTask) then
			create toDoTasks transient;
			toDoTasks.add(toDoTask);
			pxyGTE.setPxyToDoTasks( toDoTasks );
			delete toDoTasks;
		endif;
		
		return self.updateGTEProxy( pxyGTE ); 
		
	endif;

epilog	
	delete pxyGTE;	
end;</source>
        <Parameter name="_toDoTaskCode" type="Integer"/>
        <Parameter name="_addingToDo" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updatePhoto" id="52dc817a-969f-428a-bf45-bb9d2e2e2173">
        <updating/>
        <source>updatePhoto() : Boolean updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 30 January 2024
TFS#		: 62155
Function	:

*** Changes ***
Date			Name		TFS#		Description
21 Nov 2025	    navsp1	    MTN-36650   Integrate DotNet Image Library for Automatic Thumbnail Generation in Thin Client
****************************************************/

vars
	newPhoto,
	proxyPhoto 	: CM_Photo;	
	pxyTI		: CM_TrackedItem;
	pxyGTE		: CMGTE_Receival;
	load 		: Boolean;
begin
	if self.myTrackedItem &lt;&gt; null then				
		create proxyPhoto transient;
		proxyPhoto.setDescription(self.txtDescription.text);
		proxyPhoto.setMyParent(self.myTrackedItem);
		
		proxyPhoto.setPhotoContent(self.originalPhoto); 
		//proxyPhoto.setThumbnailContent(self.photoPreview.picture);                //MTN-36650	- automatically create in PortSchema::CM_Photo::setForUpdate
		
		app.myTrxCA.trxCreateCargoPhoto(proxyPhoto, newPhoto, app.myPassport);
			
		if not app.myPassport.trxCompletedOK then					
			app.msgBox(app.getErrorString(Error_occurre_please_again) ,app.getErrorString(Error), MsgBox_OK_Only);
			return false;
		endif;
		
		return true;
		
	elseif self.myGTEReceival &lt;&gt; null then
		app.cmsBeginLoad(load);
		pxyGTE := self.myGTEReceival.pxyCreateUpdateProxy;
		app.cmsEndLoad(load);
		
		create proxyPhoto transient;
		proxyPhoto.setDescription(self.txtDescription.text);		
		proxyPhoto.setPhotoContent(self.originalPhoto); 
		proxyPhoto.setMyGTEEntity(pxyGTE);		
		//proxyPhoto.setThumbnailContent(self.photoPreview.picture);	            //MTN-36650	- automatically create in PortSchema::CM_Photo::setForUpdate	
		
		return self.updateGTEProxy( pxyGTE ); 
	endif;
	
	return false;
epilog	
	delete pxyGTE;
	delete pxyTI;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateSeals" id="2d1bc11b-5192-43f3-9eeb-83cff4d854e3">
        <source>updateSeals():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2014	cnwndl1	Initial creation

*/

vars

	startPos : Integer;
	endPos : Integer;
	mess : String;

begin

	startPos := tblSeals.fixedRows + 1;
	endPos := tblSeals.rows;
	if startPos &gt; tblSeals.rows then
		//no data to process
		return true;
	endif;

	if sealCheckType = SEAL_CHECK_NONE then // 1
		// should never get here, OK button is disabled in this mode.
		mess := app.getErrorString1(Seal_check_mode, app.sealCheckTypeEnumToString(SEAL_CHECK_NONE) );
		app.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only);
		return true;

	elseif self.sealCheckType = SEAL_CHECK_VIEW then	// 2
		if self.processSealViewChecks(startPos, endPos) then
			return true;
		endif;		
	
	elseif self.sealCheckType = SEAL_CHECK_FULL then	// 3
		if self.processSealFullChecks(startPos, endPos) then
			return true;
		endif;			
	
	elseif self.sealCheckType = SEAL_CHECK_STRICT then	//4
		if self.processSealStrictChecks(startPos, endPos) then
			return true;
		endif;
	
	else
		mess := app.getErrorString(Invalid_seal_check_type) &amp; " [" &amp; self.sealCheckType.String &amp; "]" &amp; CrLf &amp; app.getErrorString(Pleas_ensur_that_seals_check_v);
		app.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only);
		return true;
		
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateSpecialLifts" id="6dd42930-5327-4554-afeb-919ff924e569">
        <source>updateSpecialLifts( _toDoTaskCode : Integer; _addingToDo : Boolean ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2014	cnwndl1	Initial creation
30 Jul 2024 navbs1  Bug 65302: SNO - Special lift ERD is not stored into the Database when entered in Road Gate
02 Sep 2024 jlier1  BUG 65940 - 1086 exception
*/

vars

	specialLift : CM_SpecialLift;
	specialLifts : CM_SpecialLiftByCodeDict;
	updateRequired :Boolean;
	prxyTI : CM_TrackedItem;
	index : Integer;
	load : Boolean;
	prxyGTE : CMGTE_Receival;
	toDoTasks : CM_ToDoTaskDescByCode;
	toDoTask : CM_ToDoTaskDesc;

begin

	create specialLifts transient;
	foreach index in 1 to self.tblSpecialLifts.rows do
		if self.tblSpecialLifts.rowChecked(index) then
			specialLift :=  self.tblSpecialLifts.accessRow(index).itemObject.CM_SpecialLift;
			if specialLift &lt;&gt; null and not specialLifts.includes(specialLift) then
				specialLifts.add(specialLift);
			endif;
		endif;
	endforeach;
	
	if _addingToDo then
		updateRequired := true;
	endif;
	
	if not updateRequired then
		if self.myTrackedItem &lt;&gt; null then
			if specialLifts.size &lt;&gt; self.myTrackedItem.allSpecialLifts.size then
				updateRequired := true;
			endif;
		elseif self.myGTEReceival &lt;&gt; null then
			if specialLifts.size &lt;&gt; self.myGTEReceival.allSpecialLifts.size then
				updateRequired := true;
			endif;
		endif;
	endif;
	if not updateRequired then
		if self.myTrackedItem &lt;&gt; null then
			foreach specialLift in specialLifts do
				if not self.myTrackedItem.allSpecialLifts.includes(specialLift) then
					updateRequired := true;
					break;
				endif;
			endforeach;
		elseif self.myGTEReceival &lt;&gt; null then
			foreach specialLift in specialLifts do
				if not self.myGTEReceival.allSpecialLifts.includes(specialLift) then
					updateRequired := true;
					break;
				endif;
			endforeach;
		endif;
	endif;
	if not updateRequired then
		if self.myTrackedItem &lt;&gt; null then
			foreach specialLift in self.myTrackedItem.allSpecialLifts do
				if not specialLifts.includes(specialLift) then
					updateRequired := true;
					break;
				endif;
			endforeach;
		elseif self.myGTEReceival &lt;&gt; null then
			foreach specialLift in self.myGTEReceival.allSpecialLifts do
				if not specialLifts.includes(specialLift) then
					updateRequired := true;
					break;
				endif;
			endforeach;
		endif;
	endif;
	if not updateRequired then
		// no updating to do.
		return true;
	endif;
		
	/*30.07.2024 navbs1 #65302
	if self.myTrackedItem &lt;&gt; null then
	
		if _addingToDo then
			if not self.updateTrackedItemAddToDoTask( _toDoTaskCode ) then
				return false;
			endif;
		endif;
		
		app.cmsBeginLoad(load);
		prxyTI := self.myTrackedItem.pxyCreateUpdateProxy.CM_Container;
		app.cmsEndLoad(load);
		
		prxyTI.zSetPxySpecialLifts( specialLifts );
		
		return self.updateTrackedItem( prxyTI );
		
	elseif self.myGTEReceival &lt;&gt; null then
		app.cmsBeginLoad(load);
		prxyGTE := self.myGTEReceival.pxyCreateUpdateProxy;
		app.cmsEndLoad(load);
		
		prxyGTE.setPxySpecialLifts( specialLifts );
		
		
		if _addingToDo and _toDoTaskCode &lt;&gt; null then
			toDoTask := app.myRoot.allToDoTaskDescriptions.getAtKey( _toDoTaskCode );
			if toDoTask &lt;&gt; null and not prxyGTE.allToDoTasks.includes(toDoTask) then
				create toDoTasks transient;
				toDoTasks.add(toDoTask);
				prxyGTE.setPxyToDoTasks( toDoTasks );
				delete toDoTasks;
			endif;
		endif;
			
		return self.updateGTEProxy( prxyGTE ); 
		
	endif;*/
	
	if self.myGTEReceival &lt;&gt; null then		//30.07.2024 navbs1 #65302
		app.cmsBeginLoad(load);
		prxyGTE := self.myGTEReceival.pxyCreateUpdateProxy;
		app.cmsEndLoad(load);
		
		prxyGTE.setPxySpecialLifts( specialLifts );
		
		
		if _addingToDo and _toDoTaskCode &lt;&gt; null then
			toDoTask := app.myRoot.allToDoTaskDescriptions.getAtKey( _toDoTaskCode );
			if toDoTask &lt;&gt; null and not prxyGTE.allToDoTasks.includes(toDoTask) then
				create toDoTasks transient;
				toDoTasks.add(toDoTask);
				prxyGTE.setPxyToDoTasks( toDoTasks );
				delete toDoTasks;
			endif;
		endif;
			
		return self.updateGTEProxy( prxyGTE );
		
	elseif self.myTrackedItem &lt;&gt; null then
	
		if _addingToDo then
			if not self.updateTrackedItemAddToDoTask( _toDoTaskCode ) then
				return false;
			endif;
		endif;
		
		app.cmsBeginLoad(load);
		prxyTI := self.myTrackedItem.pxyCreateUpdateProxy;
		app.cmsEndLoad(load);
		
		prxyTI.zSetPxySpecialLifts( specialLifts );
		
		return self.updateTrackedItem( prxyTI );
	endif;
	
	return false;

epilog

	delete specialLifts;
	delete prxyTI;
	delete prxyGTE;
	delete toDoTasks;

end;</source>
        <Parameter name="_toDoTaskCode" type="Integer"/>
        <Parameter name="_addingToDo" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateTICargoCheckSettings" id="4756adfb-2311-4537-a5fc-7d70b03d9efe">
        <source>updateTICargoCheckSettings(_value : String );
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/05/2014	cnwndl1	Initial creation	Par 34076
*/

vars

	setting		: CM_TICargoChecks;

begin

	setting := self.allCargoCheckItemSelections[self.myTrackedItem, self.myGTEReceival , self.myCurrentCheckItem];
	if setting = null then
		create setting transient;
		setting.setForUpdateCreate(self.myTrackedItem, self.myGTEReceival, null, self.myCurrentCheckItem, _value);
		self.allCargoCheckItemSelections.add(setting);
	endif;
	setting.setSelection( _value );

epilog

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateTemperature" id="3d5054ff-48c4-46e7-ba70-cedacdbaebcd">
        <updating/>
        <source>updateTemperature(_temperature : Real; _isCelcius : Boolean; _toDoTaskCode : Integer; _addingToDo : Boolean) : Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 22/04/2015	cnwdap1		Initial creation PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
// 27/09/2021	navdap1		TFS 52081 MTN Cannot Add Reading for a Reefer for a time other than Now
// 20/02/2024	navhl20		ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
// 16/01/2026	navdap1		MTN-36569 CPL | Reeefer Runner Integration
vars
	ti : CM_TrackedItem;
	pxyTI : CM_TrackedItem;
	pxyGTE : CMGTE_Receival;
	deleteProxy : Boolean;
	tempParams : CMIF_TempReading;
	temp : Real;
	load : Boolean;
	toDoTask : CM_ToDoTaskDesc;
	toDoTasks : CM_ToDoTaskDescByCode;
	
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	tempTemp : Real;	//01 Sep 2021	NDL	TFS 51874
	dateTime	: TimeStamp;
begin
	// create a temperature reading for the tracked item represented here
	if self.myTrackedItem &lt;&gt; null then
		ti := self.myTrackedItem;
	elseif self.myGTEReceival &lt;&gt; null then
		ti := self.myGTEReceival.myTrackedItem;
	endif;
	
	if ti &lt;&gt; null then
		if ti.isTransient then
			pxyTI := ti;
		else	
			pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
			deleteProxy := true;
		endif;
		
		if _addingToDo then
			if not self.updateTrackedItemAddToDoTask( _toDoTaskCode ) then
				return false;
			endif;
		endif;
		
		create tempParams transient;
	/*	tempParams.isRefConReading := false;
		tempParams.isRefConAlarm := false;
		tempParams.refConRawData := null;
		tempParams.dateTime := app.actualTimeServer;
		tempParams.noCharge := ti.noChargeForTemperature(false, tempParams.dateTime);
		tempParams.userId := app.getMyUserCode;
		tempParams.myTerminal := self.myTerminal;
		tempParams.myTrackedItem := pxyTI; */
		if _isCelcius then
		//	tempParams.temperature := _temperature;
			tempTemp := _temperature;	//01 Sep 2021	NDL	TFS 51874
		else
		//	tempParams.temperature := app.temperatureConversion(false, _temperature);
			tempTemp := app.temperatureConversion(false, _temperature);	//01 Sep 2021	NDL	TFS 51874
		endif;
		
		if self.effectiveDT.isValid then				//20.02.2024 navhl20 #62525
			dateTime := self.effectiveDT;
		else
			dateTime := app.actualTimeServer;
		endif;
		
		//01 Sep 2021	NDL	TFS 51874 - Use common code instead of 14 different variant copies....
		tempParams.initialise( 	pxyTI,	//_reefer : CM_TrackedItem;
								false,	//_defaultNoChargeValue : Boolean;
								dateTime,	//_dateTime : TimeStamp;	// TFS 52081	//20.02.2024 navhl20 #62525
								tempTemp	//_temperature : Real
								);
		
		//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxCA.trxCreateReeferReadings(tempParams, null, null, null, null, null, app.myPassport);		// MTN-36569
		
			if app.myPassport.trxCompletedOK then
				return true;
			else
				theResult := app.showErrorWarningDialog('Temp Reading', app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return false;
			
		endwhile;
		
	else
		// update the gate receival instead
		if _isCelcius then
			temp := _temperature;
		else
			temp := app.temperatureConversion(false, _temperature);
		endif;
		
		app.cmsBeginLoad(load);
		pxyGTE := self.myGTEReceival.pxyCreateUpdateProxy;
		app.cmsEndLoad(load);
		
		pxyGTE.setReceivalTemperature(temp);
		
		if _addingToDo and _toDoTaskCode &lt;&gt; null then
			toDoTask := app.myRoot.allToDoTaskDescriptions.getAtKey( _toDoTaskCode );
			if toDoTask &lt;&gt; null and not pxyGTE.allToDoTasks.includes(toDoTask) then
				create toDoTasks transient;
				toDoTasks.add(toDoTask);
				pxyGTE.setPxyToDoTasks( toDoTasks );
				delete toDoTasks;
			endif;
		endif;

		return self.updateGTEProxy( pxyGTE ); 
	endif;
	
epilog
	if deleteProxy then
		delete pxyTI;
	endif;
	delete pxyGTE;
	delete toDoTasks;
end;</source>
        <Parameter name="_temperature" type="Real"/>
        <Parameter name="_isCelcius" type="Boolean"/>
        <Parameter name="_toDoTaskCode" type="Integer"/>
        <Parameter name="_addingToDo" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateToDoTasks" id="dd301fb4-2292-4118-84ac-02e1bd6e3ba0">
        <source>updateToDoTasks( _toDoTasksToAdd : CM_ToDoTaskDescByCode input ):Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/05/2014	cnwndl1	Initial creation
*/
vars
	toDoTask : CM_ToDoTaskDesc;
	requiresUpdate : Boolean;
	load : Boolean;
	result : Integer;
	prxyGTE : CMGTE_Receival;
	toDoTasks : CM_ToDoTaskDescByCode;

begin

	if self.myTrackedItem &lt;&gt; null then
	
		create toDoTasks transient;
		foreach toDoTask in _toDoTasksToAdd do
			if not self.myTrackedItem.allToDoTasksToDo.includesToDoDesc( toDoTask.code ) then
				toDoTasks.add(toDoTask);
				requiresUpdate := true;
			endif;
		endforeach;
		
		if not requiresUpdate then
			//nothing to add
			return true;
		endif;
		
		foreach toDoTask in toDoTasks do
		
			if not self.updateTrackedItemAddToDoTask( toDoTask.code ) then
				return false;
			endif;
			
		endforeach;
		
		return true;
		
	elseif self.myGTEReceival &lt;&gt; null then
	
		app.cmsBeginLoad(load);
		prxyGTE := self.myGTEReceival.pxyCreateUpdateProxy;
		app.cmsEndLoad(load);
		
		create toDoTasks transient;
		foreach toDoTask in _toDoTasksToAdd do
			if not prxyGTE.allToDoTasks.includes(toDoTask) then
				toDoTasks.add(toDoTask);
				requiresUpdate := true;
			endif;
		endforeach;
		
		if not requiresUpdate then
			//nothing to add
			return true;
		endif;
		
		prxyGTE.setPxyToDoTasks( toDoTasks );
		delete toDoTasks;
		
		return self.updateGTEProxy( prxyGTE );  
		
	endif;
	
	return false;

epilog

	delete toDoTasks;
	delete prxyGTE;

end;</source>
        <Parameter name="_toDoTasksToAdd" type="CM_ToDoTaskDescByCode" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateTrackedItem" id="e7f74457-0306-4e9e-81b6-33537aad6b60">
        <source>updateTrackedItem( prxyTI : CM_TrackedItem input ):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2014	cnwndl1	Initial creation
20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
*/

vars

	mode : Integer;
	result : Integer;
	date	: String;

begin

	app.myPassport.clearErrorsWarnings();
		
	if self.myTrackedItem.isNotified then
		mode := TI_UPDMODE_RECEIPT;
	else
		mode := TI_UPDMODE_NORMAL;
	endif;

	// The Proxy is updated, so now update the database
	while true do
		if self.effectiveDT.isValid then													//20.02.2024 navhl20 #62525
			date := self.effectiveDT.String;
		endif;
		app.myTrxUA.trxUpdateTrackedItem(prxyTI, date, mode, null, app.myPassport);			//20.02.2024 navhl20 #62525
		
		if app.myPassport.trxCompletedOK then
			return true;
		else
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog('Tracked Item Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="prxyTI" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateTrackedItemAddToDoTask" id="1a26dc0b-de4a-4eb4-b947-1f5c9a6d2ae6">
        <source>updateTrackedItemAddToDoTask(  _toDoTaskCode : Integer ):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2014	cnwndl1	Initial creation

*/

vars

	result : Integer;

begin

	if self.myTrackedItem = null then
		return false;
	endif;

	while true do
		app.myTrxUA.trxUpdateTIToDoTaskAdd(self.myTrackedItem, _toDoTaskCode, app.myPassport);

		if app.myPassport.trxCompletedOK() then
			app.myPassport.clearErrorsWarnings();
			return true;
			
		else
			result := app.showErrorWarningDialog(app.getErrorString(Cargo_item_update), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			app.myPassport.clearErrorsWarnings();
			return false;
			
		endif;
	endwhile;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_toDoTaskCode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateWeight" id="03e4327d-644f-4154-b4db-83eb730c3f53">
        <source>updateWeight( _toDoTaskCode : Integer; _addingToDo : Boolean):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2014	cnwndl1	Initial creation

*/

vars
	
	weight : Decimal [16,4];
	certified : Boolean;
	load : Boolean;
	prxyTI : CM_TrackedItem;
	controller : CMIF_TIUpdateController;
	prxyGTE : CMGTE_Receival;
	toDoTask : CM_ToDoTaskDesc;
	toDoTasks : CM_ToDoTaskDescByCode;

begin

	weight := self.tblWeight.getConvertedValue();
	certified := self.chkIsCertified.value;
	
	if self.myTrackedItem &lt;&gt; null then
	
		if _addingToDo then
			if not self.updateTrackedItemAddToDoTask( _toDoTaskCode ) then
				return false;
			endif;
		endif;
	
		app.cmsBeginLoad(load);
		prxyTI := self.myTrackedItem.pxyCreateUpdateProxy;
		app.cmsEndLoad(load);
		
		controller := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.myPassport.userCode, null);
		prxyTI.setTotalWeightAndCertified(weight, prxyTI.weightCargo, prxyTI.weightTare, certified, controller, app.myPassport);
		
		return self.updateTrackedItem( prxyTI );
		
	elseif self.myGTEReceival &lt;&gt; null then
	
		app.cmsBeginLoad(load);
		prxyGTE := self.myGTEReceival.pxyCreateUpdateProxy;
		app.cmsEndLoad(load);
		
		prxyGTE.setTotalWeightAndCertified(weight, certified);
		
		if _addingToDo and _toDoTaskCode &lt;&gt; null then
			toDoTask := app.myRoot.allToDoTaskDescriptions.getAtKey( _toDoTaskCode );
			if toDoTask &lt;&gt; null and not prxyGTE.allToDoTasks.includes(toDoTask) then
				create toDoTasks transient;
				toDoTasks.add(toDoTask);
				prxyGTE.setPxyToDoTasks( toDoTasks );
				delete toDoTasks;
			endif;
		endif;

		return self.updateGTEProxy( prxyGTE ); 
		
	endif;
	
	return false;
	
epilog
	delete controller;
	delete prxyTI;
	delete prxyGTE;
	delete toDoTasks;
end;</source>
        <Parameter name="_toDoTaskCode" type="Integer"/>
        <Parameter name="_addingToDo" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
