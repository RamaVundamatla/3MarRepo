    <JadeMethod name="convertSailingPackages" id="b074e32a-bf50-4583-9ecc-9c3a0ae43e09">
        <source>convertSailingPackages();
/*
Date		Who		Reason
29 March 2012	cnwcs5	Initial creation - CCMS POL 2144 / Par 29312 - Extract Baplie by Operator
*/
vars
	package		:CM_Package;
begin
	app.writeLog( method.qualifiedName &amp; 'Upgrading sailing package data from 7.9.2 to 8.1.1', LogINFO);
	beginTransaction;
	
	foreach package in app.myRoot.allPackages do
		if not package.isKindOf (CM_PackageSailing) then
			continue;
		endif;
		// cargo operator has been stored in an extension object
		// now we want to put it in a real property
		package.convertExtensionObjectValue (Obj_Extn_myCargoOperator, CM_PackageSailing::myCargoOperator);
	endforeach;

	commitTransaction;
	app.writeLog( method.qualifiedName &amp; 'Completed upgrade of sailing package data from 7.9.2 to 8.1.1', LogINFO);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="convertVoyageCutoffs" id="5ec10b25-6ab2-4026-95eb-975b7c719092">
        <source>convertVoyageCutoffs();
/*
Date		Who		Reason
15/03/2012	cnwcs5	Initial creation - par 29257 EDI Booking Cutoff
*/
vars
	terminal	:CM_Terminal;
	cutoff		:CM_ReceivalCutoffTermDef;
begin
	app.writeLog( method.qualifiedName &amp; 'Upgrading voyage cutoff data from 7.9.2 to 8.1.1', LogINFO);
	beginTransaction;
	
	foreach terminal in app.myRoot.allTerminals do
		foreach cutoff in terminal.allReceivalCutoffDefs do
			// criteria type and all EDI data types have been stored in an extension object
			// now we want to put them in real properties
			
			cutoff.convertExtensionObjectValue (Obj_Extn_criteriaType, CM_ReceivalCutoffTermDef::criteriaType);
			cutoff.convertExtensionObjectValue (Obj_Extn_allEDIDataTypes, CM_ReceivalCutoffTermDef::allEDIDataTypes);
			
		endforeach;
	endforeach;
	commitTransaction;
	app.writeLog( method.qualifiedName &amp; 'Completed upgrade of voyage cutoff data from 7.9.2 to 8.1.1', LogINFO);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="fixEDICargoTIImCodes" id="1d7d6547-cde0-4c53-a31f-d3e7c094318e">
        <source>fixEDICargoTIImCodes();
//
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
//
vars
	obj : Object;
	objArray : ObjectArray;
begin
	create objArray transient;
	CM_EDICargoTI.allInstances(objArray, 0, true);
	foreach obj in objArray do
		beginTransaction;
		obj.CM_EDICargoTI.fixupImcodes();
		commitTransaction;
	endforeach;
epilog
	delete objArray;
end;
</source>
