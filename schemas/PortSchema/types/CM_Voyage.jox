    <JadeMethod name="getAllocationWithSameCriteria" id="5b4ad898-8c7a-4e18-a242-b0cd18a8786a">
        <source>getAllocationWithSameCriteria(_voyageAllocTemplate : CM_VoyageAllocation) : CM_VoyageAllocation;
// ---------------------------------------------------------------------------
// Created:     08 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	yardAllocation		: CM_YardAllocation;
	realAlloc			: CM_VoyageAllocation;
	voyageController	: CM_VoyageController;
	yaDict				: CM_YAByPriorityDict;
begin
	
	foreach yardAllocation in self.allVoyageAllocations  discreteLock do
		if yardAllocation.isSameCriteria(_voyageAllocTemplate) then
			return yardAllocation.CM_VoyageAllocation;
		endif;
	endforeach;

	return null;

epilog

end;</source>
        <Parameter name="_voyageAllocTemplate" type="CM_VoyageAllocation"/>
        <ReturnType type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="getArchivedDTLocalTZ" id="47586c80-8e9b-416b-835e-f22be11d97c0">
        <source>getArchivedDTLocalTZ() : TimeStamp;
