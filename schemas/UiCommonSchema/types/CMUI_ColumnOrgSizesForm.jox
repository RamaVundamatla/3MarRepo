    </JadeMethod>
    <JadeMethod name="doClearAllFilters" id="a0bed9fb-23fa-49fa-a337-93928afa5e0d">
        <updating/>
        <source>doClearAllFilters() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2011	cnwndl1	Initial creation	par 28889

*/

vars

begin

	self.allFilterColumns.replaceAllFiltersForTable( self.myDataTable, null );
	self.refreshCmbFilterColour();
	self.cmbColumnFilter.click( self.cmbColumnFilter );
	self.columnFiltersUpdated := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doExportCSV" id="c52d41e6-de3e-4631-bc0a-18f9b5170cc8">
        <updating/>
        <source>doExportCSV() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars

begin

	app.mousePointer := MousePointer_HourGlass;
	
	if self.myDataTable = null then
		return;
	endif;

	if self.myDataTable.rows &lt;= self.myDataTable.fixedRows then
		app.raiseCMException(ERR_NoDataToExtract, 'Table Data', self.myDataTable);
		return;
	endif;
	
	self.myDataTable.outputAsCSV(null);
	
	self.doCancel();

epilog

	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doFilterBtnSelection" id="9b9b7301-7975-4492-b2fe-a237b1476e4f">
        <updating/>
        <source>doFilterBtnSelection( _clear : Boolean ) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

	index : Integer;
	startRow : Integer;
	endRow : Integer;

begin

	startRow := self.tblFilterValues.fixedRows + 1;
	endRow := self.tblFilterValues.rows;

	if endRow &gt;= startRow then
		foreach index in startRow to endRow do
			if _clear then
				self.tblFilterValues.setCellText(index, 1, "0");
			else
				self.tblFilterValues.setCellText(index, 1, "1");
			endif;
		endforeach;
	endif;
	
	self.selectFilterUpdated := true;
	self.enabledFilterButtons();

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLocalFilterSave" id="42486a63-c44d-4def-aed4-331217031ff6">
        <updating/>
        <source>doLocalFilterSave():Boolean protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2011	cnwndl1	Initial creation
11/03/2015			cnwmh5	Tranisent leak
*/

vars

	column : Integer;
	entableRowHeading : String;
	
	filterStrings : StringArray;
	allSelected : Boolean;
	startRow : Integer;
	endRow : Integer;
	
	index : Integer;
	valuesStartRow : Integer;
	valuesEndRow : Integer;
	
	noneSelected : Boolean;
	str : String;
	msg : String;

begin

	if self.cmbColumnFilter.text.trimBlanks = null then
		return true;
	endif;

	entableRowHeading := self.cmbColumnFilter.text;
	column := self.myDataTable.getColumnByHeading( self.cmbColumnFilter.text );
	if column = 0 and self.cmbColumnFilter.listIndex &gt; 0 then
		// mybe its using teh short description...
		column := self.myDataTable.allTblDataEntRows.indexOf( self.cmbColumnFilter.itemObject[ self.cmbColumnFilter.listIndex ].EntTableRow );
	endif;
	
	if column = 0 then
		app.mousePointer :=	Idle;
		app.msgBox("Unknown column, filter not saved!","Error",MsgBox_OK_Only);
		return true;
	endif;

	valuesStartRow := self.tblFilterValues.fixedRows + 1;
	valuesEndRow := self.tblFilterValues.rows;
	
	create filterStrings transient;
	allSelected := true;
	noneSelected := true;
	startRow := self.myDataTable.fixedRows + 1;
	endRow := self.myDataTable.rows;

	if self.optTableData.value then
		if endRow &gt;= startRow then
			foreach index in valuesStartRow to valuesEndRow do
				if self.tblFilterValues.getCellText(index, 1) = "1" then
					//selected item
					noneSelected := false;
					str := self.tblFilterValues.getCellText(index, 2);
					filterStrings.add(str);
				else
					//unselected item
					allSelected := false;
				endif;
			endforeach;
		endif;
		
		if noneSelected then
			app.mousePointer :=	Idle;
			msg := "You must select at least one item to include!";
			app.msgBox( msg, "Warning", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
		
	elseif self.optUserData.value then
		allSelected := false;
		str := self.txtFilter.text.trimBlanks;
		if str = null then
			filterStrings.add('"null"');
		else
			filterStrings.add(str);
		endif;
	
	endif;
	
	if allSelected then
		filterStrings.clear();
	endif;

	self.allFilterColumns.updateColumnFilter( self.myDataTable, column, entableRowHeading, filterStrings, self.optUserData.value);
	self.columnFiltersUpdated := true;
	self.refreshCmbFilterColour();
	
	self.selectFilterUpdated := false;
	
	return true;

epilog

	app.mousePointer :=	Idle;
	
	delete filterStrings;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="01f56dec-1d6a-4f18-aa30-0cc4e0b26108">
        <updating/>
        <source>doOK() updating;
//--------------------------------------------------
// Created:	08 September 2005 By: cnwgd1
//--------------------------------------------------
begin

	if not self.validateFilterSelections() then	//04 Jan 2012 NDl	Par 28889
		return;
	endif;
	
	if self.doSave() then
		// visible columns have changed
		// return IDOK so the form handles re-display
		self.modalResult	:=	IDOK;
	else
		// No change to visible columns
		// return IDCANCEL so the data is not re-displayed
		self.modalResult	:=	IDCANCEL;	
	endif;

	self.unloadForm();
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="6823c0a4-e36b-4615-b8c2-f96010afe89c">
        <updating/>
        <source>doPrint() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars

	form : Form;
	formCaption : String;

begin

	app.mousePointer := MousePointer_HourGlass;
	
	if self.myDataTable = null then
		return;
	endif;

	form := self.myDataTable.form;
	if form &lt;&gt; null then
		formCaption := form.caption;
	endif;

	self.doPrintOutTable(self.myDataTable, formCaption, true, true, true, self.printOrientation = Print_Portrait);
	
	self.doCancel();

epilog

	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doRemoveFilter" id="0317f0b9-4132-41ee-89e3-c55da4d9f2f7">
        <updating/>
        <source>doRemoveFilter() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2011	cnwndl1	Initial creation

*/

vars

begin

	self.optTableData.value := true;
	self.btnSelectAll.click( self.btnSelectAll );
	self.btnUpdFilter.click( self.btnRemFilter );
	self.selectFilterUpdated := false;
	self.cmbColumnFilter.click( self.cmbColumnFilter );

epilog

end;</source>
