    <JadeMethod name="delete" id="88ce9322-83f6-45b9-8b8d-4fce5338205a">
        <updating/>
        <source>delete() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06 Oct 2020	jlgdap1		Initial creation TFS 49227 MTN Navis API - nReefer API
//
vars

begin
	delete self.type;
	delete self.validation;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setField" id="62f52c65-ef05-495d-8876-2196d9be9d7d">
        <updating/>
        <source>setField(_entRow : EntTableRow) : Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2020	jlgrr1	Initial creation
06 oct 2020	jlgdap1	TFS 49227 MTN Navis API - nReefer API
*/
vars
	inputType : String;
	lovKey : String;

begin
	self.fieldId := _entRow.name;
	self.longLabel := _entRow.getHeadingUnaltered;
	self.shortLabel := _entRow.shortHeading;
	
	if _entRow.inputType = Table.InputType_TextBox or _entRow.inputType = Table.InputType_TextNumeric or _entRow.inputType = Table.InputType_SignedNumeric then
		inputType := WS_NWidgetDefinition.TextWidget;
	elseif _entRow.inputType = Table.InputType_None then
		inputType := WS_NWidgetDefinition.LabelWidget;
	elseif _entRow.inputType = Table.InputType_CheckBox then
		inputType := WS_NWidgetDefinition.CheckboxWidget;
	endif;
	lovKey := _entRow.controlName;
	
	if inputType &lt;&gt; null or lovKey &lt;&gt; null then
		create self.type transient;
		self.type.setDetails(_entRow);
	endif;
	
	create self.validation transient;
	if not self.validation.setDetails(_entRow) then
		delete self.validation;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_entRow" type="EntTableRow"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
