    <JadeMethod name="create" id="115f2366-e8da-44d0-997a-e18add2db5a3">
        <updating/>
        <source>create() updating;
//
//25 May 2017	cnwrs1	TFS 4470
//31 Jan 2018	cnwma1  ChangeRequest 36628: Create new CAMS file type for SMDG 2.13 COARRI
//
vars

begin
	//self.name := "STANDARD COARRI"; 	    //31.1.2018 cnwma1 ChangeRequest #36628
	self.name := "STANDARD COARRI SMDG162"; //31.1.2018 cnwma1 ChangeRequest #36628
	self.type := EDIFileTypeCams_StandardCoarri;
epilog

end;</source>
    </JadeMethod>
