    <JadeMethod name="setupForm" id="4c3eaa7b-9149-43e8-b14f-9e368a9c89a5">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2012	cnwjre1	Initial creation

*/

vars
	mapName	: String;
begin
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	mapName := self.myTranMapForm.getCurrentMapName();
	self.caption := self.myTranMapForm.myCurrentBank.code &amp; "  " &amp; mapName &amp; "  " &amp; self.caption;		// 35872

	inheritMethod();
	
	self.doComboInvoiceLinesBuild();
	self.doComboGroupingBuild();
	self.doComboTransferTypeBuild();	// 22/3/18 MAP TFS37555
	self.doComboVesselCategoryBuild();	// 18/6/18 MAP TFS38899
	// ### TFS BUG 66001 19SEP2024 NAVAB1 - self.doComboCargoTypeBuild(null,null, false); // ### TFS CR 65331 TASK 65332 07AUG2024 NAVAB1
	self.openWithSavedSettings();	
	
	self.showMappingFrame(); // PAR 34917 make modal
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showMappingFrame" id="64c8cc98-4500-4468-b0d7-50e0cfa808a1">
        <updating/>
        <source>showMappingFrame() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin

	self.getMappingHeaders();
	
	if self.myTranMapForm.myCurrentMapTM &lt;&gt; null then
		self.btnLinesNew.visible := true;
		self.btnLinesDelete.visible := true;
	else
		self.btnLinesNew.visible := true;
		self.btnLinesDelete.visible := true;
	endif;
	self.frmToolbar.positionToolbarControls();

	self.loadMappingHeadings();
	self.loadMappings();
	self.doComboInvoiceLinesBuild();

	self.myTranMapForm.lstData.enabled := false;
	self.myTranMapForm.frmToolbar.enabled := false;
	self.recolourTable(self.tblLines);

end;</source>
    </JadeMethod>
