    <JadeMethod name="trxDeleteSystemAlert" id="d1a95ded-1b92-4e23-b8c6-6958fa50e350">
        <updating/>
        <source>trxDeleteSystemAlert(_allAlerts : CM_SystemAlertByDateTime io; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2002 By David Barr
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// 14/05/2012	cnwcs5	par 29450 - split into &gt; 1 transaction
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	MAX_TRX_TIME = 1;						// par 29450 May 2012
vars
	alert			:CM_SystemAlert;		// par 29450 May 2012
	gotException	:Boolean;				// par 29450 May 2012
	nextCommitTS	:TimeStamp;				// par 29450 May 2012
	count, trxCount, delCount	:Integer;	// par 29450 May 2012
	msg				:String;				// par 29450 May 2012
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	on Exception do app.handleDeletedObject (exception, alert, gotException);
	
	if app.isBackGroundApp then
		msg := _allAlerts.size.String &amp; ' alerts to be deleted.';
		
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
	endif;
	// Start the transaction
	beginTransaction;
	// if we get a JMT error we want to be able to ignore the event that caused it and carry on
	// if we don't set this to true the exception handler will abort the transaction :-(
	app.setContinueCMExceptions(true);
	
	nextCommitTS	:=	app.actualTimeServer().addSeconds (MAX_TRX_TIME);// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	foreach alert in _allAlerts do
		if app.actualTimeServer &gt; nextCommitTS then// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			// time to commit this transaction and start a new one	
			app.cmsCommitTransaction(_passport);
			
			nextCommitTS := app.actualTimeServer().addSeconds (MAX_TRX_TIME);// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			// update number of items deleted
			delCount	:= delCount + count;
			// reset count of deletes for current transaction
			count		:= 0;
			
			beginTransaction;	
			// increment # of transactions
			trxCount 	:= trxCount + 1;
		endif;
		// lock the alert b4 we delete it		
		self.exclusiveLock (alert);
		
		if gotException then
			// someone got there before us - already deleted
			gotException := false;
			// not strictly necessary
			continue;
		endif;			
		
		app.myUtilityDA.utlDeleteSystemAlert (alert, _passport);
		
		if _passport.hasErrors then
			// got errors trying to process this event
			if app.isBackGroundApp then
				// write entry to log and continue with next one
				msg := alert.String &amp; ' could not be deleted ' &amp; _passport.getAllErrorsWarningsAsString;
				
				app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				
				// need to clear these for next time we check the passport
				_passport.clearErrorsWarnings;
				// if the last trx was aborted then ebegintransaction again
				if not process.isInTransactionState then
					// the current transaction was aborted - log the number of deleted that were rolled back
					msg := count.String &amp; ' deletes were rolled back in same transaction.';
					
					app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				
					beginTransaction;
					// don't increase of transactions
					// reset running count of deletes for current transaction
					count := 0;
				endif;
				// carry on - there will be others to deleted
				continue;
			else
				// bail out on first error
				break;
			endif;
		endif;
		// update running count of deletes for this transaction
		count := count + 1;
	endforeach;
	// update number of items deleted
	delCount := delCount + count;
	
	if _passport.noErrors() and (not process.isInTransactionState()) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
	
	if app.isBackGroundApp then
		msg := 'A total of ' &amp; delCount.String &amp; ' alerts deleted in ' &amp; trxCount.String &amp; ' transactions.';
		
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
	endif;	
end;</source>
        <Parameter name="_allAlerts" type="CM_SystemAlertByDateTime" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteTI" id="f96b61b9-c45e-4ca8-a35a-72ac42853024">
        <updating/>
        <source>trxDeleteTI(pTI : CM_TrackedItem; _confirmDelete: Boolean;  _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
// ---------------------------------------------------------------------------
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if pTI = null then
		app.raiseCMException1(ERR_DEL_NULLOBJECT, 'tracked item', null, null);
		return;
	endif;

	// Start the transaction
	beginTransaction;

	app.myUtilityDA.utlDeleteTI(pTI, _confirmDelete, _passport);
		
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="_confirmDelete" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
