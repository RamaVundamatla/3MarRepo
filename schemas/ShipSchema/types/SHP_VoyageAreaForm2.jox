    <JadeMethod name="doMnuGridAutoplan" id="86d144f9-6c8f-442a-9310-3146b344edb8">
        <updating/>
        <source>doMnuGridAutoplan(_wles : CM_WLEArray input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2007 By Andrew Bishop cnwab1
//
// Purpose:		// PAR 15368
//
// ---------------------------------------------------------------------------
vars
	aVoyageJob : CM_VoyageJob;
	result : Integer;
	aRequest : CM_Request;
	wlesWithWarnings, theWLEs : CM_WLEArray; 
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	theWLEs := _wles;
	create wlesWithWarnings transient;	
	
	while true do
		app.myTrxUA.trxUpdateWLEsAutoplan(theWLEs, wlesWithWarnings, PLANNING_MODE, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			if app.myPassport.allErrorWarnings.size = 1 and app.myPassport.returnCode = INFO_NO_AUTOPLAN then
				//do show it here, ask Q below.
				result := 1;				
			else
				result := app.showErrorWarningDialog('Voyage Auto-Planning', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			endif;
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// only reprocess the wles that had warnings.
				theWLEs.clear;
				wlesWithWarnings.copy(theWLEs);
				wlesWithWarnings.clear;	
				continue;
			endif;
		endif;
		break;
	endwhile;	

	if app.myPassport.returnCode = INFO_NO_AUTOPLAN then
		if app.msgBox(app.getErrorString(app.myPassport.returnCode), "Information",
					 MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
			app.showSystemAlertsWindow(self.myMasterMenuAction, self.myTerminal, null);			
		endif;
	endif;
epilog
	delete wlesWithWarnings;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_wles" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuGridAutoplanBayClick" id="24a5ddeb-1b5f-4d87-ad35-94bb4cd166eb">
        <updating/>
        <source>doMnuGridAutoplanBayClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aBayVoyage : CM_BayVoyage;
	aRequest : CM_Request;
	theWLEs : CM_WLEArray; 
	theJobs : CM_JobArray;
	theJobType : Integer;
	aJob : CM_Job;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	if self.displayMode = ShpDisplayMode_ColCodeDisch then
		theJobType := JOB_TYPE_DISCHARGE;
	else
		return;
	endif;
	
	if menuItem.userObject &lt;&gt; null then
		if menuItem.userObject.isKindOf(CM_BayVoyage) then
			aBayVoyage := menuItem.userObject.CM_BayVoyage;
			create theWLEs transient;
			create theJobs transient;
			
			aBayVoyage.getAllJobs(theJobType,JOB_UNACTIONED,theJobs);
			
			foreach aJob in theJobs do
				foreach aRequest in aJob.allRequests do
					aRequest.allWorkListEntries.copy(theWLEs);
				endforeach;
			endforeach;

			self.doMnuGridAutoplan(theWLEs);// PAR 15368
	
		endif;
	endif;
epilog
	delete theWLEs;
	delete theJobs;
	
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuGridAutoplanJobClick" id="953fdf74-32d4-44f4-ac8a-c4d92ac04c97">
        <updating/>
        <source>doMnuGridAutoplanJobClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		to auto plan DISCHARGE all items in a given job.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aVoyageJob : CM_VoyageJob;
	result : Integer;
	aRequest : CM_Request;
	wlesWithWarnings, theWLEs : CM_WLEArray; 
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	if menuItem.userObject &lt;&gt; null then
		if menuItem.userObject.isKindOf(CM_VoyageJob) then
			aVoyageJob := menuItem.userObject.CM_VoyageJob;
			
			if aVoyageJob.jobType &lt;&gt; JOB_TYPE_DISCHARGE then
				return;
			endif;
			
			create theWLEs transient;
			
			foreach aRequest in aVoyageJob.allRequests do
				aRequest.allWorkListEntries.copy(theWLEs);
			endforeach;
					
			self.doMnuGridAutoplan(theWLEs); // PAR 15368
		endif;
	endif;
epilog
	delete theWLEs;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuGridAutoplanSlotClick" id="8e0b6c60-90b1-4bf8-9577-939312c3309e">
        <updating/>
        <source>doMnuGridAutoplanSlotClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		to autoplan DISCHARGE a discharge slot request
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aSlotRequest : CM_SlotRequest;
	aWLE : CM_WorkListEntry;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	if menuItem.userObject &lt;&gt; null then
		if menuItem.userObject.isKindOf(CM_SlotRequest) then
			aSlotRequest := menuItem.userObject.CM_SlotRequest;
			if aSlotRequest.moveType &lt;&gt; DISCHARGE_MOVETYPE then
				return;
			endif;
			
			aWLE := aSlotRequest.allWorkListEntries.first;
			
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxUA.trxUpdateWLEAutoplan(aWLE, PLANNING_MODE, app.myPassport);
			
					if app.myPassport.trxCompletedOK then
						if app.myPassport.returnCode = INFO_NO_AUTOPLAN then
							if app.msgBox(app.getErrorString(app.myPassport.returnCode), 
															'Auto Plan Slot Request',
															MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
								app.showSystemAlertsWindow(self.myMasterMenuAction, self.myTerminal, null);
							endif;
						endif;
					break;
				else
					theResult := app.showErrorWarningDialog('Auto Plan Slot Request', app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				return;
				
			endwhile;
	
		endif;
	endif;
epilog
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuGridBigFontClick" id="58846b25-2f97-4910-8a9c-e268ca36d0e2">
        <updating/>
        <source>doMnuGridBigFontClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     05 July 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(menuItem);
	if self.myConfig &lt;&gt; null then
		self.myConfig.CMIF_ConfigUserVoyagePlanning.shipMacroUseBigFont := menuItem.checked;
