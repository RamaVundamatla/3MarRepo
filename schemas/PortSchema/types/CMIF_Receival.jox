    <JadeMethod name="create" id="ee5f93cf-402f-48a2-acef-e751244a7bca">
        <updating/>
        <source>create() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/12/2008	cnwkpd1	PAR #18681 - Allow PreNote update through RIA Web Application
10/04/2013	cnwdap1	PAR #31411 Default remaining time off power to NULL_ALLOWABLE_TIME_OFF_POWER
*/

vars

begin
	self.setCarbonDioxide( NULL_CARBON_DIOXIDE );
	self.setOxygen( NULL_OXYGEN );
	self.setHumidity( NULL_HUMIDITY ); //par18451 nov 2008 cnwrs1
	self.ventilation := NULL_VENTILATION; //par18451 nov 2008 cnwrs1
	self.carriageTempC := NULL_TEMPERATURE;
	self.carriageTempF := app.temperatureConversion(true, NULL_TEMPERATURE); 		//NULL_TEMPERATURE; 	//cnwmc5 - 2 September 2014 - PAR 34846
	//26/05/2009 cnwdz2 par19748
	self.packTempC :=  NULL_TEMPERATURE; 
	self.packTempF := app.temperatureConversion(true, NULL_TEMPERATURE); 		//NULL_TEMPERATURE; 	//cnwmc5 - 2 September 2014 - PAR 34846
	self.packTime  := NULL_TIME;
	//self.allowableTimeOffPower := NULL_INTEGER; 					//- cnwas3, Par 26199
	self.allowableTimeOffPower := NULL_ALLOWABLE_TIME_OFF_POWER; 	//+ cnwas3, Par 26199
	self.remainingTimeOffPower := NULL_ALLOWABLE_TIME_OFF_POWER; 	// PAR #31411
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createProxySeals" id="cfd3613e-5f93-40c6-9330-10f1bde74ff0">
        <updating/>
        <source>createProxySeals(_allSeals: CM_SealTIBySealTypeDict) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 September 2010	cnwndl1	Initial creation
11/04/2011	cnwmh5		PAR #27347 - Change code to use app.cmsBeginLoad and add app.cmsEndLoad
*/

vars

	sealType : CM_SealType;
	sealTi : CM_SealTI;
	pxySealTi : CM_SealTI;
	loadState	: Boolean;
	
begin

	self.allSeals.purge();
	
	if _allSeals &lt;&gt; null and not _allSeals.isEmpty then			// 11/04/2011 cnwmh5 #27347
		app.cmsBeginLoad(loadState);
	endif;

	foreach sealTi in _allSeals do
		pxySealTi := sealTi.pxyCreateUpdateProxy.CM_SealTI;
	endforeach;

epilog
	app.cmsEndLoad(loadState);					// 11/04/2011 cnwmh5 #27347
end;</source>
        <Parameter name="_allSeals" type="CM_SealTIBySealTypeDict"/>
    </JadeMethod>
    <JadeMethod name="createSealsFromTi" id="c211b571-6858-4b16-848a-75486d81ec30">
        <updating/>
        <source>createSealsFromTi( _ti : CM_TrackedItem ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2010	cnwndl1	Initial creation	Par 26355

*/

vars
	sealTi : CM_SealTI;
	sealType : CM_SealType;
begin

	if not _ti.allSeals.isEmpty then
		foreach sealTi in _ti.allSeals do
			sealType := app.myRoot.getSealType( sealTi.sealType );
			if sealType &lt;&gt; null then
				self.setSealNumberValueDirect(	sealType,	//_sealType : CM_SealType;
												sealTi.getSealValueAsString,	//_sealNumValue : String;
												sealTi.sealedDT	//pDateTime : TimeStamp
												);
			endif;
		endforeach;
		
	else
		self.setSealNum( _ti.getSealNum );
		self.setSealNumCustoms( _ti.getSealNumCustomsFirst );
		self.setSealNumShippers( _ti.getSealNumShipper );
		
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="defaultDetailsFromParentItem" id="c5940da4-48fe-4e46-adfb-f8a16c794dbc">
        <updating/>
        <source>defaultDetailsFromParentItem(_parent : CMIF_TIObject) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2009	cnwdap1	Initial creation */
// 03 Oct 2017	jlgrs1	TFS 7245 - POL hazard details being cleared during EDI update
// 05 Jun 2018	jlgrs1	TFS 39018 SNO Cargo Operator in COPRAR
// 02 Oct 2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
vars
	str		: String;
	lift	: CM_SpecialLift;
	int		: Integer;
	task	: CM_ToDoTaskDesc;

begin
	inheritMethod(_parent);
	
	self.voyageCode 		:= _parent.CMIF_Receival.voyageCode;
	self.destinationPort 	:= _parent.CMIF_Receival.destinationPort;
	self.dischargePort 		:= _parent.CMIF_Receival.dischargePort;
	self.myTranshipToPort 	:= _parent.CMIF_Receival.myTranshipToPort;

	self.allDischargePorts.clear;
	foreach str in _parent.CMIF_Receival.allDischargePorts do
		self.allDischargePorts.add(str);
	endforeach;
	
	self.consignorCode 		:= _parent.CMIF_Receival.consignorCode;
	self.consigneeCode 		:= _parent.CMIF_Receival.consigneeCode;
	self.customsAgentCode 	:= _parent.CMIF_Receival.customsAgentCode;
	self.releaseCarrierCode := _parent.CMIF_Receival.releaseCarrierCode;
	self.imExStatus 		:= _parent.CMIF_Receival.imExStatus;
	self.receiptTransportMode := _parent.CMIF_Receival.receiptTransportMode;
	self.specialStow 		:= _parent.CMIF_Receival.specialStow;
	self.stevedoreCode      := _parent.CMIF_Receival.stevedoreCode;            //02.10.2020 cnwma1 TFS #50112
	if self.operatorCode = null then
		self.operatorCode	:= _parent.CMIF_Receival.operatorCode;
	endif;
	
// TFS 47488	_parent.CMIF_Receival.allTIHazards.copy(self.allTIHazards);
	_parent.CMIF_Receival.allTIHazards.copyNoDuplicates(self.allTIHazards, false);// TFS 47488
//	self.allHazards.clear;
//	foreach str in _parent.CMIF_Receival.allHazards do
//		self.allHazards.add(str);
//	endforeach;
	
	self.allSpecialLifts.clear;
	foreach lift in _parent.CMIF_Receival.allSpecialLifts do
		self.allSpecialLifts.add(lift);
	endforeach;
	
	self.allStops.clear;
	foreach int in _parent.CMIF_Receival.allStops do
		self.allStops.add(int);
	endforeach;
	
	self.allToDoTasks.clear;
	foreach task in _parent.CMIF_Receival.allToDoTasks do
		self.allToDoTasks.add(task);
	endforeach;
	
	self.myCustomerPriority := _parent.CMIF_Receival.myCustomerPriority;
	
	//20 Sep 2010	NDL	Par 25608
	// 36884 cnwjre1 Oct 2015 this has already been done for the parent - doing it again here gets a duplicate proxy error so don't
	////self.createProxySeals( _parent.CMIF_Receival.allSeals );
	
epilog

end;</source>
        <Parameter name="_parent" type="CMIF_TIObject"/>
    </JadeMethod>
    <JadeMethod name="delete" id="118ed6b5-b0fe-41b1-8d54-f5c470c4874a">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 27 Mar 2009	cnwkpd1		PAR #19242 - prevent transient leaks from Kiosk form
// 31/05/2010	cnwdad1		PAR #24275 - was leaking transient hazard objects.
// 10/08/2015	cnwdap1		PAR #36421 Hazardous Materials Handling
// 21/05/2024	navdap1		TFS 63619 CUX | FR - POST and PUT /Cargo not saving Customs References for Onboard Cargo
// ---------------------------------------------------------------------------
vars
	hazardObj	: CM_Hazard;
	
begin
	if self.myMasterObject = null then //cnwgb1 PAR 23419 10.June.2010
		if (not updating) and self.myProxyTrackedItem &lt;&gt; null then
			self.myProxyTrackedItem.erase(NORMAL_ERASE);
		endif;
	endif;
	
	if self.myProxyTIRequest &lt;&gt; null then				// PAR #19242
		self.myProxyTIRequest.erase(NORMAL_ERASE);
	endif;
	
// cnwdad1 31/05/2010 - PAR #24275.
	//foreach hazardObj in self.allTIHazards do										// PAR #36421
	foreach hazardObj in self.allTIHazards where app.isValidObject(hazardObj) do	// PAR #36421
		if hazardObj.isTransient() then
			delete hazardObj;
		endif;
	endforeach;
	
	//10 Dec 2010	NDL	Par 26567
	if not self.allSeals.isEmpty then
		self.allSeals.purge;
	endif;
	
	self.allCustomsReferences.purge;		// TFS 63619
	
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteMyOriginalProxyTI" id="d04b0b2e-b2cd-4d7f-b71f-ad4cf92f243f">
        <updating/>
        <source>deleteMyOriginalProxyTI() updating;
// --------------------------------------------------------------------------------
// Created:		25 February 2010 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 25/02/2010	cnwdad1		Original implementation for PAR #21330.
// --------------------------------------------------------------------------------
begin
	delete self.myOriginalProxyTI;
end;</source>
    </JadeMethod>
    <JadeMethod name="eraseProxyTrackedItem" id="629a4182-e118-4097-9512-70615670f4f9">
        <updating/>
        <source>eraseProxyTrackedItem() updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	subItem		: CMIF_TIObject;
	cou			: CMIF_InOutCOU;
	attach		: CMIF_InOutAttachment;
	preNote		: CMIF_PreNote;
	
begin
	// need to check all subItems to see if the proxies will be deleted on
	// the items.  If reference on subitems not set to null then this would
	// result in an invalid object reference
	
	foreach subItem in self.allSubItems do
		if subItem.isKindOf(CMIF_InOutCOU) then
			cou := subItem.CMIF_InOutCOU;
			if cou.myProxyTrackedItem &lt;&gt; null and
			   cou.myProxyTrackedItem = self.myProxyTrackedItem.CM_Container.getCou then
			   	// set to null as this will be deleted by erase below
				cou.setMyProxyTrackedItem(null);
			endif;
			
		elseif subItem.isKindOf(CMIF_InOutAttachment) then
			attach := subItem.CMIF_InOutAttachment;
			if attach.myProxyTrackedItem &lt;&gt; null and
			  // self.myProxyTrackedItem.allChildren.includes(attach.myProxyTrackedItem) then//PAR 22954
			   self.myProxyTrackedItem.hasChild(attach.myProxyTrackedItem) then
			   	// set to null as this will be deleted by erase below
				attach.setMyProxyTrackedItem(null);
			endif;
			
		elseif subItem.isKindOf(CMIF_PreNote) then
			preNote := subItem.CMIF_PreNote;
			if preNote.myProxyTrackedItem &lt;&gt; null and
			  // self.myProxyTrackedItem.allChildren.includes(preNote.myProxyTrackedItem) then//PAR 22954
			   self.myProxyTrackedItem.hasChild(preNote.myProxyTrackedItem) then
			   	// set to null as this will be deleted by erase below
				preNote.setMyProxyTrackedItem(null);
			endif;
		endif;
	endforeach;

	self.myProxyTrackedItem.erase(NORMAL_ERASE);
	self.myProxyTrackedItem := null;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getCarbonDioxide" id="3b7d32ec-3aa0-430c-9b0c-78b58f715ffb">
        <source>getCarbonDioxide():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 April 2020	jlgndl1	Initial creation	TFS 47958

*/

vars

begin

	//All Carbon Dioxide display fields are limited to Decimal 6,2  so don't returm bigger than that
	if self.carbonDioxide &gt; 999.99 then
		return 999.99;
	endif;

	return self.carbonDioxide;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getCargoGroupFromId" id="9e57ce09-4a7f-4e7a-8c37-22ff50c00c95">
        <source>getCargoGroupFromId():CM_CargoGroup;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Feb 2016	cnwndl1	Initial creation	Par 37544
15 Aug 2023	navsp1	TFS Bug 59677: EUP - Manifest Instructions for Rail not applied to cargo group and work order
17 Aug 2023	navdap1	TFS 59862 EUP FR | 53824 Manifest - DB Load creating multiple Cargo Receive tasks on Work Order
06 Nov 2023	navnk30	ChangeRequest 60933: EUP - Operational Instructions - CM_TrackedItem Inverse
*/

vars

	cg : CM_CargoGroup;
	cgCargoType : CM_CargoType;
	operator : CM_Operator;
	subT : CM_SubTerminal;
	pxyTI : CM_TrackedItem;
	instruction : CM_InstructionType;
    instructionIssued : CM_InstructionsIssued;
begin

	if not app.isCargoGroupEnabled then
		return null;
	endif;
	
	if self.cargoGroupId.trimBlanks = null then
		return null;
	endif;
	
	//find an existing one	
	cg := self.myTerminal.getCargoGroupItem( self.cargoGroupId.trimBlanks );										//14.Nov.2023 navsp1 TFS 61127
	//cg := self.myTerminal.getCargoGroupItemForOperator(self.cargoGroupId.trimBlanks, self.operatorCode, null); 	//14.Nov.2023 navsp1 TFS 61127
	if cg &lt;&gt; null then
		return cg;
	endif;
	
	//create a proxy one.
	cgCargoType := self.myTerminal.getDefaultCargoGroupCargoType();
	if cgCargoType = null then
		app.raiseCMException( Unspecified_Cargo_Type, null, null );
		return null;
	elseif not cgCargoType.isCargoGroup then
		app.raiseCMException1( Cargo_type_selec_not_defin_car, cgCargoType.description, null, null );
		return null;
	endif;
	
	if self.operatorCode = null then
		app.raiseCMException( Please_select_operator, null, null );
		return null;
	endif;
	operator := app.myRoot.allOperators.getAtKey( self.operatorCode );
	if operator = null then
		app.raiseCMException( Please_select_operator, null, null );
		return null;
	endif;
	
	pxyTI := self.myTerminal.createTI(cgCargoType, true);
	pxyTI.zSetPxyTerminal( self.myTerminal );
	pxyTI.setCargoType(cgCargoType.id);

	pxyTI.setMyOperator(operator);
			
	pxyTI.setImExStatus(TI_IMEX_STATUS_STORAGE);

	pxyTI.zSetPxyCompany(self.myTerminal.getDefaultCompanyBank);
		
	if app.isSubTerminalsOn(self.myTerminal) then
		subT := self.myTerminal.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem, 0, TI_IMEX_STATUS_STORAGE, null, false); 
		pxyTI.setSubTerminal(subT,null);
	endif;
	pxyTI.zSetPxyId( self.cargoGroupId );
	
    if self.instructionsType &lt;&gt; null then                   //15.Aug.2023 navsp1 TFS 59677 &gt;&gt;&gt;&gt;
		instruction := self.myTerminal.allInstructionTypes[self.instructionsType];
		if instruction &lt;&gt; null then
			create instructionIssued transient;
			instructionIssued.setProxy(	self.instructionsInternal,
										self.instructionsExternal,
										instruction,
										pxyTI	);
			//pxyTI.setmyInstructions(instructionIssued);	//06.11.2023 navnk30 #60933
		endif;
	endif;                                                  //15.Aug.2023 navsp1 TFS 59677 &lt;&lt;&lt;&lt;
	
	// TFS 59862 start
	if self.isPreNote then
		if self.CMIF_PreNote.manifestNumber &lt;&gt; null and self.CMIF_PreNote.manifestNumber &lt;&gt; pxyTI.manifestNumber then
			pxyTI.setManifestNumber(self.CMIF_PreNote.manifestNumber);
		endif;
	endif;
	// TFS 59862 end
	
	return pxyTI.CM_CargoGroup;

epilog

end;</source>
        <ReturnType type="CM_CargoGroup"/>
    </JadeMethod>
