    <JadeMethod name="getObjects" id="52ee5356-cdbe-403f-8188-f1c1588b7fda">
        <source>getObjects(objects: ObjectLongNameDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/08/2023	navkc1	CR 59594  Task 59584: Jade - CustDocs New YA Criteria

*/

vars
	countryRegion : CM_CountryRegion;
begin

	foreach countryRegion in app.myRoot.allCountryRegions do
		objects[countryRegion.getYAIdentifier] := countryRegion;
	endforeach;
	
epilog

end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
