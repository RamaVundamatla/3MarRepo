    <JadeMethod name="doChangeGate" id="a1cb3cb3-9340-44d3-81d7-a42529433aed">
        <updating/>
        <source>doChangeGate(_gate: CM_Gate) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason

Everytime the gate combo is changed, we need to update the gate lanes and enable/disable gate lane combo
depending on whether or not the gate has lanes.  Might as well push all programmatic changes through this method.

*/

vars

begin
	self.cmbGate.listObject := _gate;
	self.myBulkGateAgent.setGate(_gate);
	self.onGateChange();
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_gate" type="CM_Gate"/>
    </JadeMethod>
    <JadeMethod name="doPreSaveValidation" id="f6bcabc2-a6d9-48da-b611-6605929c9eed">
        <updating/>
        <source>doPreSaveValidation( _scaleWeight : Decimal output; _cargoWeight : Decimal output ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2016	cnwndl1	Initial creation	TFS 2867

*/

vars

	realVVR : CM_VehicleVisitRecord;
	edition : Integer;
	invalid : Boolean;
	vehicle : CM_Vehicle;
	wle 	: CM_WorkListEntry;
	gte 	: CMGTE_Entity;
	vvrd 	: CM_VehicleVisitRecordDetail;
	cargoWeight : Decimal[16,4];  // in kilos
	arrivalWeight : Decimal[16,4];  // in kilos
	reserveDetail : CM_ReserveDetail;

begin

			
    self.myBulkGateAgent.myRealVVR := getVvrFromTable();
	
	if self.myBulkGateAgent.myRealVVR = null then
		app.raiseCMException(Invalid_vehicle_visit_record, "Null_vehicle_visit_record", null);
		return false;
	endif;
		
	if self.txtWeightOUT.getRawValue() = null then
		app.raiseCMException(Input_required_field_weight, "Weight Null", null);
		self.txtWeightOUT.setFocus;
		return false;
	endif;
	
	
	if 	self.txtWeightOUT.getConvertedValue() = 0 then	
		app.raiseCMException(Total_weight_should_not_zero, "Weight Zero", null);
		self.txtWeightOUT.setFocus;
		return false;
	endif;
	
	_scaleWeight := self.txtWeightOUT.getConvertedValue();
		
	
	on Exception do app.handleDeletedObject(exception,realVVR,invalid);
	realVVR := self.myBulkGateAgent.myRealVVR;
	if realVVR &lt;&gt; null then
		edition := realVVR.edition;
		if invalid then	
			self.clearForm();
			self.myBulkGateAgent.myPxyGTEEntity := null;
			app.raiseCMException(Invalid_Gate_Entity, "Invalid_Gate_Entity", null);
			return false;
		endif;
	else
		app.raiseCMException(Invalid_vehicle_visit_record, "Invalid_vehicle_visit_record", null);
		return false;
	endif;

	if realVVR.vehicle &lt;&gt; null then
		vehicle := realVVR.vehicle;
	else
		app.raiseCMException2(ERR_IsNotValid,app.getErrorString(Vehicle),null, "Vehicle", null);
		return false;
	endif;
	
	if vehicle.allRoadJobs.size &gt; 0 and vehicle.allRoadJobs.first.workListEntries.size &gt; 0 then
		wle :=	vehicle.allRoadJobs.first.workListEntries.first;
	else
		app.raiseCMException(Work_list_entry_ref, "Work_list_entry_ref", null);
		return false;
	endif;
	
	if realVVR.allGateEntities.size &gt; 0 then
		gte := realVVR.allGateEntities.first;
	else
		app.raiseCMException1(Truck_Has_No,app.getErrorString(Gate_entity), "Truck_Has_No,Gate_entity", null);
		return false;
	endif;
	
	vvrd := realVVR.getBulkGateIn(null);
	if vvrd &lt;&gt; null then
		arrivalWeight := vvrd.getExtraInfo_BulkGateInOrOut;
		cargoWeight :=   arrivalWeight - _scaleWeight; 	
		if cargoWeight &lt; 0 then
			_cargoWeight := cargoWeight.abs();
		else
			_cargoWeight := cargoWeight;
		endif;
	else
		app.raiseCMException1(Err_Is_Null,app.getErrorString(Vehicle_visit_record_detail),"VVRD_is_Null",null);
		return false;
	endif;
		
	if gte.isCMGTE_Receival and  arrivalWeight &lt;= _scaleWeight then
		app.raiseCMException(Exit_weigh_must_less_than_arri, "WeightTooHigh", null);
		return false;
	endif;
	
	if gte.isCMGTE_Release and arrivalWeight &gt;= _scaleWeight then
		app.raiseCMException(Exit_weigh_must_more_than_arri, "WeightTooLow", null);
		return false;
	endif;
	
	//15 Nov 2017	NDL	TFS 7820
	if gte.isCMGTE_Release then
		reserveDetail := gte.CMGTE_Release.myReserveDetail;
		if reserveDetail &lt;&gt; null then
			if reserveDetail.isBulkMulti then
				if reserveDetail.validateWeightQuantityAdd(	0, _cargoWeight, true ) &lt;&gt; null then
					return false;
				endif;
			endif;
		endif;
	elseif gte.isCMGTE_Receival then
		gte.CMGTE_Receival.validateBooking( false );
		if app.myPassport.hasErrors then
			return false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_scaleWeight" type="Decimal" usage="output"/>
        <Parameter name="_cargoWeight" type="Decimal" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQueryUnload" id="90da08a6-3b64-4f0f-8f2e-1aedc41ece1a">
        <updating/>
        <source>doQueryUnload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2018	jlgns1	Initial creation
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
*/
constants
	MaxWaitTime = 5000;
vars
	endWaitTime : Decimal[20];
	maxWaitTime : Integer;
begin
    if self.mySerialWeightIntController &lt;&gt; null then
		// Need to delay the actual form close and weight interface controller delete until all pending
		// serial port communications are complete
		
		self.mySerialWeightIntController.stopListening;
		self.visible := false;
		endWaitTime := app.relativeMachineTime() + maxWaitTime;
		
		while not self.mySerialWeightIntController.isOkToDelete() do
			app.writeLog(method.qualifiedName &amp; " waiting for serial port operations to complete", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			app.doWindowEvents(1000);
			if app.relativeMachineTime() &gt; endWaitTime then
				app.writeLog(method.qualifiedName &amp; " maximum wait time exceeded, exiting", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
				break;
			endif;
		endwhile;
	endif;
	
	//19 July 2021	NDL	TFS 51575
	if self.myOtherWeightIntController &lt;&gt; null and self.myOtherWeightIntController.myConnection &lt;&gt; null  then
		self.myOtherWeightIntController.closeConnection();
	endif;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="3f5bc914-ccd6-469e-8aec-37249bf852a1">
        <updating/>
        <source>doRefresh() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
