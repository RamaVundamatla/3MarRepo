    <JadeMethod name="txtDateBox_lostFocus" id="9af946e2-3051-4304-935b-dc2d22671f6a">
        <controlMethod name="CMUI_DateMask::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtDateBox_lostFocus(editMask: JadeEditMask input) updating;
// ---------------------------------------------------------------------------
// Created:     09 April 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	now,
	dateTime : TimeStamp;
begin
	now := self.systemToLocalTime(app.actualTimeServer());	// 10/5/16 cnwmp6 TFS 488 - Multi timezone support
	dateTime.setDate(txtDateBox.getDate());
	dateTime.setTime(self.txtEffectiveTime.getTime());
	if self.cbRetrospective.value and dateTime &gt; now then
		app.msgBox(app.getErrorString(RetrospectiveOperations), 'Retrospective DateTime', MsgBox_Stop_Icon + MsgBox_OK_Only);
		self.txtDateBox.setFocus();
		return;
	endif;		
	self.doRetrospective(dateTime);
epilog

end;</source>
        <Parameter name="editMask" type="JadeEditMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtEffectiveTime_lostFocus" id="3d502369-8eb6-40af-a14b-81d6ef775c5e">
        <controlMethod name="CMUI_TimeMask::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtEffectiveTime_lostFocus(editMask: JadeEditMask input) updating;
// ---------------------------------------------------------------------------
// Created:     09 April 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	now,
	dateTime : TimeStamp;
begin
	now := self.systemToLocalTime(app.actualTimeServer());	// 10/5/16 cnwmp6 TFS 488 - Multi timezone support
	dateTime.setDate(txtDateBox.getDate());
	dateTime.setTime(self.txtEffectiveTime.getTime());
	if self.cbRetrospective.value and dateTime &gt; now then
		app.msgBox(app.getErrorString(RetrospectiveOperations), 'Retrospective DateTime', MsgBox_Stop_Icon + MsgBox_OK_Only);
		//self.txtEffectiveTime.setFocus();	//Par15563. Commented to avoid indefinite raising of msgbox. This message is also generated by txtDateBox_lostFocus()
		self.txtDateBox.setFocus();			//Par15563. Jump to fix date firstly and avoid indefinite raising of msgbox
		return;
	endif;		
	self.doRetrospective(dateTime);

end;</source>
        <Parameter name="editMask" type="JadeEditMask" usage="input"/>
    </JadeMethod>
