    <JadeMethod name="clearCriteria" id="873e03cf-60f8-437b-801b-0d4fad5a6fbd">
        <source>clearCriteria() protected;
// --------------------------------------------------------------------------------
// Created:		30 January 1999 by cnwdad1
//
// Purpose:		Clears the selected/entered criteria details in the edit area.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	optInclude.value		:=	true;
	cmbProperty.listIndex	:=	CNEC_NULL_INDEX;
	cmbOperand.listIndex	:=	CNEC_NULL_INDEX;
	txtValue.text			:=	null;
	btnRemove.enabled		:=	false;
	btnAdd.caption			:=	"&amp;Add";
	lstCriteria.listIndex	:=	CNEC_NULL_INDEX;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="formAdd" id="8f4ba76b-a309-4fcf-8a31-18cde59dce5b">
        <source>formAdd(pIsNew:Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		30 January 1999 by cnwdad1
//
// Purpose:		This method will update a criteria into the list.
//
// Parameters:	pIsNew - True if the criteria are new.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	criteriaParts	: StringArray;
	option			: String;
	propertyName	: String;
	operand			: String;
	value			: String;
	rowString		: String;
	index			: Integer;

begin
	if optInclude.value then
		option	:=	self.INCLUDE_LITERAL;
	else
		option	:=	self.EXCLUDE_LITERAL;
	endif;

	propertyName	:=	cmbProperty.text.trimBlanks;
	operand			:=	cmbOperand.text.trimBlanks;
	value			:=	txtValue.text.trimBlanks;

	if pIsNew then
		create criteriaParts transient;
		criteriaParts.add(option);
		criteriaParts.add(propertyName);
		criteriaParts.add(operand);
		criteriaParts.add(value);
	else
		if lstCriteria.listIndex = CNEC_NULL_INDEX then
			app.msgBox("Please select the criteria to update.", "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
			return;
		endif;

		criteriaParts		:=	lstCriteria.itemObject[lstCriteria.listIndex].StringArray;
		criteriaParts[1]	:=	option;
		criteriaParts[2]	:=	propertyName;
		criteriaParts[3]	:=	operand;
		criteriaParts[4]	:=	value;
	endif;

	rowString	:=	option &amp; " where " &amp; propertyName;
	rowString	:=	rowString &amp; " " &amp; operand &amp; " '" &amp; value &amp; "'";

	if pIsNew then
		index							:=	lstCriteria.addItem(rowString);
		lstCriteria.itemObject[index]	:=	criteriaParts;
	else
		lstCriteria.itemText[lstCriteria.listIndex]	:=	rowString;
	endif;

	lstCriteria.listIndex	:=	CNEC_NULL_INDEX;
	self.clearCriteria();
end;</source>
        <access>protected</access>
        <Parameter name="pIsNew" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="formClear" id="80010b13-2fca-4e29-8272-f2064121a142">
        <source>formClear() protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		Standard form clear method.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	stringArray	: StringArray;
	index		: Integer;
	count		: Integer;

begin
	index	:=	1;
	count	:=	lstCriteria.listCount;

	while index &lt;= count do
		stringArray	:=	lstCriteria.itemObject[index].StringArray;

		if stringArray &lt;&gt; null and stringArray.isTransient() then
			delete stringArray;
		endif;

		index	:=	index + 1;
	endwhile;

	self.selectionCriteriaArray.clear();
	lstCriteria.clear();
	self.clearCriteria();

	if count &gt; 0 then
		btnOk.enabled	:=	true;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="formLoad" id="f172dd09-a6cb-4a43-a699-11b4b2e40dd3">
        <updating/>
        <source>formLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	list			: ListBox;
	index			: Integer;
	object			: Object;
	criteriaParts	: StringArray;
	option			: String;
	propertyName	: String;
	operand			: String;
	value			: String;
	rowString		: String;
	thePropertyColl	: PropertyColl;
	property		: Property;

begin
	self.caption		:=	'Object Filter: ' &amp; self.myClass.name;

	// Setup the Table.

	list				:=	lstCriteria;
	list.clear;
	optInclude.value	:=	true;

	// Now populate any existing selection criteria.

	foreach object in self.selectionCriteriaArray do
		criteriaParts	:=	object.StringArray;
		option			:=	criteriaParts[1];
		propertyName	:=	criteriaParts[2];
		operand			:=	criteriaParts[3];
		value			:=	criteriaParts[4];

		rowString	:=	option &amp; " where " &amp; propertyName;
		rowString	:=	rowString &amp; " " &amp; operand &amp; " '" &amp; value &amp; "'";

		index					:=	list.addItem(rowString);
		list.itemObject[index]	:=	criteriaParts;
	endforeach;

	// Setup the Properties.
	thePropertyColl	:=	self.myClass.allProperties();
	
	foreach property in thePropertyColl where (not property.isSystemObject()) do
		if (property.getType.isPrimitive) then
			cmbProperty.addItem(property.name);
		endif;
	endforeach;

	// Setup the Operands.

	cmbOperand.addItem("=");
	cmbOperand.addItem("&lt;");
	cmbOperand.addItem("&gt;");
	cmbOperand.addItem("&lt;&gt;");
	cmbOperand.addItem("&lt;=");
	cmbOperand.addItem("&gt;=");

	self.modalResult	:=	0;
epilog
	delete thePropertyColl;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="formNew" id="a44388fc-d93d-4d92-97b7-bb92a14d09ca">
        <source>formNew() protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		Standard form new method.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.clearCriteria();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="formUpdate" id="bac818f7-b389-4426-8c9c-7c6555bd1f05">
        <updating/>
        <source>formUpdate() updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		Standard form update method.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	objectArray		: ObjectArray;
	index			: Integer;
	count			: Integer;
	criteriaParts	: StringArray;

begin
	// get all of the current string arrays in the list.

	index			:=	1;
	count			:=	lstCriteria.listCount;
	create objectArray transient;

	while index &lt;= count do
		create criteriaParts transient;
		lstCriteria.itemObject[index].StringArray.copy(criteriaParts);
		delete lstCriteria.itemObject[index];
		objectArray.add(criteriaParts);
		index			:=	index + 1;
	endwhile;

	self.selectionCriteriaArray.clear();

	// Copy the new instances of the string arrays.

	if objectArray.size() &gt; 0 then
		objectArray.copy(self.selectionCriteriaArray);
	endif;
epilog
	delete objectArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getSelectionCriteriaArray" id="b07e6d6b-1ca9-47b3-9e7e-f40bab061410">
        <source>getSelectionCriteriaArray() : ObjectArray;
// --------------------------------------------------------------------------------
// Created:		30 January 1999 by cnwdad1
//
// Purpose:		Returns an object array, the elements of which are filter selection
//				criteria.
//
// Parameters:	None
// Returns:		The object array of filter criteria.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.selectionCriteriaArray;
end;</source>
        <ReturnType type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="load" id="9bf10d63-472c-4f8b-8c3d-8657b8e9c05e">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		28 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	centreWindow();
	self.formLoad();
epilog
	self.statusMsg('');
end;</source>
    </JadeMethod>
    <JadeMethod name="lstCriteria_click" id="a438e8c7-7458-4362-a01e-c5bd8e8070c4">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstCriteria_click(listbox: ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		31 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if listbox.listIndex &lt;&gt; CNEC_NULL_INDEX then
		btnRemove.enabled	:=	true;
		self.showSelectedCriteria();
	else
		btnRemove.enabled	:=	false;
		listbox.listIndex	:=	CNEC_NULL_INDEX;
		self.clearCriteria();
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeCriteria" id="60e42cf0-350f-445b-9d3d-a38a7d67e254">
        <source>removeCriteria() protected;
// --------------------------------------------------------------------------------
// Created:		30 January 1999 by cnwdad1
//
// Purpose:		Removes a selected selection criteria from the list.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	stringArray	: StringArray;

begin
	if lstCriteria.listIndex &lt;&gt; CNEC_NULL_INDEX then
		stringArray	:=	lstCriteria.itemObject[lstCriteria.listIndex].StringArray;

		if self.selectionCriteriaArray.includes(stringArray) then
			self.selectionCriteriaArray.remove(stringArray);
		endif;

		if stringArray &lt;&gt; null and stringArray.isTransient() then
			delete stringArray;
		endif;

		lstCriteria.removeItem(lstCriteria.listIndex);
		lstCriteria.listIndex	:=	CNEC_NULL_INDEX;
		self.clearCriteria();
		btnRemove.enabled		:=	false;
		btnNew.enabled			:=	true;
		btnOk.enabled			:=	true;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyClass" id="828277f5-1fa6-4ae8-a158-605f45643687">
        <updating/>
        <source>setMyClass(pValue: Class) updating;
// --------------------------------------------------------------------------------
// Created:		30 January 1999 by cnwdad1
//
// Purpose:		Sets a reference to the class to which the filters apply.
//
// Parameters:	pValue - The class to which the filters apply.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myClass &lt;&gt; pValue then 
		self.myClass := pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Class"/>
    </JadeMethod>
    <JadeMethod name="setSelectionCriteriaArray" id="544ffd94-1907-4b6f-8557-3e8f26e42ae9">
        <source>setSelectionCriteriaArray(pCriteriaArray:ObjectArray);
// --------------------------------------------------------------------------------
// Created:		30 January 1999 by cnwdad1
//
// Purpose:		Copies the passed object array into the form's local object array.
//
// Parameters:	pCriteriaArray (ObjectArray) - The array of criteria objects.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pCriteriaArray &lt;&gt; null and pCriteriaArray.size() &gt; 0 then
		pCriteriaArray.copy(self.selectionCriteriaArray);
	endif;
end;</source>
        <Parameter name="pCriteriaArray" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="showSelectedCriteria" id="d58362b8-4fb2-44ce-a947-3693ca774dbc">
        <source>showSelectedCriteria() protected;
// --------------------------------------------------------------------------------
// Created:		30 January 1999 by cnwdad1
//
// Purpose:		This method will show the criteria details when a table row is selected.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	criteriaParts	: StringArray;
	include			: String;
	propertyName	: String;
	operand			: String;
	value			: String;

begin
	if lstCriteria.listIndex &lt;&gt; CNEC_NULL_INDEX then
		criteriaParts		:=	lstCriteria.itemObject[lstCriteria.listIndex].StringArray;
		include				:=	criteriaParts[1];
		propertyName		:=	criteriaParts[2];
		operand				:=	criteriaParts[3];
		value				:=	criteriaParts[4];

		if include = self.INCLUDE_LITERAL then
			optInclude.value	:=	true;
		else
			optExclude.value	:=	true;
		endif;

		cmbProperty.listIndex	:=	cmbProperty.findStringExact(1, propertyName);
		cmbOperand.listIndex	:=	cmbOperand.findStringExact(1, operand);
		txtValue.text			:=	value;
		btnAdd.caption			:=	"Upd&amp;ate";
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateCriteria" id="5e3c5c30-4b7e-4976-ad47-b426e571d843">
        <source>validateCriteria():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		18 July 1999 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified filters
//				are valid.
//
// Parameters:	None
// Returns:		True if the filters are valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	criteriaParts	: StringArray;
	option			: String;
	propertyName	: String;
	operand			: String;
	value			: String;
	source			: String;

begin
	if optInclude.value then
		option	:=	self.INCLUDE_LITERAL;
	elseif optExclude.value then
		option	:=	self.EXCLUDE_LITERAL;
	else
		option	:=	'';
	endif;

	propertyName	:=	cmbProperty.text.trimBlanks;
	operand			:=	cmbOperand.text.trimBlanks;
	value			:=	txtValue.text.trimBlanks;

	if option.length = 0 then
		app.msgBox('Please choose whether to Include or Exclude the object.', 'Error', MsgBox_Stop_Icon + MsgBox_OK_Only);
		return false;
	endif;

	if cmbProperty.listIndex = CNEC_NULL_INDEX then
		app.msgBox('Please select a Property name.', 'Error', MsgBox_Stop_Icon + MsgBox_OK_Only);
		return false;
	endif;

	if cmbOperand.listIndex = CNEC_NULL_INDEX then
		app.msgBox('Please select an operand.', 'Error', MsgBox_Stop_Icon + MsgBox_OK_Only);
		return false;
	endif;

	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
