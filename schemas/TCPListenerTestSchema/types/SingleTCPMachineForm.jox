/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 March 2011	cnwndl1	Initial creation	Par 27290

*/

vars
	message			: TCPMessagePayload;
	tcpMessage		: String;
	
begin
	self.myValidateTextBox := _textBox;
	
	create message transient;
	message.operationName := Operation_ValidateDischarge;
	message.message := self.txtMachine.text &amp; ',' &amp; self.myValidateTextBox.text;
	
	self.sendTCPMessage(message);
	
	
epilog
	delete message;
	self.myValidateTextBox := null;
	
end;</source>
