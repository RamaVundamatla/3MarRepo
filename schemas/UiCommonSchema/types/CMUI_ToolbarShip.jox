    <JadeMethod name="addButton" id="8b1d7caa-2cca-4006-9b6b-1c6aecb5d8c6">
        <updating/>
        <source>addButton(pPictureUp, pPictureDown : Picture;pIndex : Integer; pBubble : String) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

constants
	LWidth =  25;
vars
	lControl : CMUI_ToolbarShipButton;
	lLeft : Integer;
	aWidth : Integer;
begin
	if pIndex &gt;= self.SpaceIndex then // Space Index
		aWidth := 8;
	else
		aWidth := LWidth;
	endif;
	self.offSet := self.offSet - 2;
	lControl := self.myButton.loadControl(pIndex).CMUI_ToolbarShipButton;
	lControl.picture := pPictureUp.picture;
	lControl.pictureDown := pPictureDown.picture;
	lControl.pictureRollOver := pPictureDown.picture;
	lControl.pictureRollUnder := pPictureUp.picture;
	lControl.style := CMUI_ToolbarShipButton.Style_Auto2State; //Style_2State;
	lControl.bubbleHelp := pBubble;
	lControl.top := 2;
	lControl.width := aWidth;
	lControl.height := LWidth;
	lControl.left := self.offSet;
	lControl.visible := true;
	lControl.myParent := self.myButton.myParent;
//	lControl.transparent := true;
//	lControl.transparentColor := 13423831;
	self.offSet := self.offSet + lControl.width.Integer + 2 ;
	self.width := self.offSet;

end;</source>
        <Parameter name="pPictureUp" type="Picture"/>
        <Parameter name="pPictureDown" type="Picture"/>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pBubble" type="String"/>
    </JadeMethod>
    <JadeMethod name="addButtonCharacter" id="5f7b8c6b-cdd5-47b5-85b3-5cb3111038b2">
        <updating/>
        <source>addButtonCharacter(pPictureUp, pPictureDown, pPictureDisable : Picture;_theAttribute : String;pIndex : Integer; pBubble : String) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

constants
	LWidth =  50;
vars
	lControl : CMUI_ToolbarShipButton;
	theAttribute : CM_DrawingAttribute;
	lLeft : Integer;
	aWidth : Integer;
begin
	theAttribute := app.myRoot.allDrawingAttributes[_theAttribute];

	if theAttribute = null then
		app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. NULL _theAttribute " &amp; _theAttribute);
		return;
	endif;
	self.offSet := self.offSet - 2;
	lControl := self.myButton.loadControl(pIndex).CMUI_ToolbarShipButton;
	lControl.style := CMUI_ToolbarShipButton.Style_Auto2State; //Style_2State;
	lControl.picture := pPictureUp.picture;
	lControl.pictureDown := pPictureDown.picture;
	lControl.pictureRollOver := pPictureDown.picture;
	lControl.pictureRollUnder := pPictureUp.picture;
	lControl.pictureDisabled := pPictureDisable.picture;
	lControl.fontName := theAttribute.fontName;
	lControl.foreColor := theAttribute.colour;
	lControl.userObject := theAttribute;
	lControl.backColor := Gray;
	lControl.fontSize := 14;
	lControl.caption := theAttribute.fontCharacter.Character;
	lControl.captionHeight := 0;
	lControl.captionWidth := 0;
	lControl.captionLeft := 0;
	lControl.captionTop := 0;
	lControl.width := 25;
	lControl.height := 25;
	
	lControl.bubbleHelp := pBubble;
	lControl.top := 2;
	lControl.left := self.offSet;
	lControl.visible := true;
	lControl.myParent := self.myButton.myParent;
//	lControl.transparent := true;
//	lControl.transparentColor := 13423831;
	self.offSet := self.offSet + lControl.width.Integer + 2 ;
	self.width := self.offSet;

end;</source>
        <Parameter name="pPictureUp" type="Picture"/>
        <Parameter name="pPictureDown" type="Picture"/>
        <Parameter name="pPictureDisable" type="Picture"/>
        <Parameter name="_theAttribute" type="String"/>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pBubble" type="String"/>
    </JadeMethod>
    <JadeMethod name="addButtonWithDisable" id="6755b66a-9126-4aa0-b24c-e2261c28890a">
        <updating/>
        <source>addButtonWithDisable(pPictureUp, pPictureDown, pPictureDisable : Picture;pIndex : Integer; pBubble : String) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lControl : Control;

begin
	self.addButton(pPictureUp, pPictureDown,pIndex, pBubble);

	if pPictureDisable = null then
		return;
	endif;
	
	lControl := self.myButton.getControl(pIndex);
	if lControl &lt;&gt; null then
		lControl.JadeMask.pictureDisabled := pPictureDisable.picture;
	endif;
end;</source>
        <Parameter name="pPictureUp" type="Picture"/>
        <Parameter name="pPictureDown" type="Picture"/>
        <Parameter name="pPictureDisable" type="Picture"/>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pBubble" type="String"/>
    </JadeMethod>
    <JadeMethod name="addUserToolbarTHTest" id="4e2e9eef-530b-4672-944d-85d77c24fe17">
        <updating/>
        <source>addUserToolbarTHTest(pPictureUp, 
				pPictureDown : Picture;
				pIndex : Integer; 
				pBubble : String;
				_userTool : CM_MenuUserToolbar;
				_btn : CMUI_Button input) updating;
// ---------------------------------------------------------------------------
// Created:     24 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	btn		 	: CMUI_Button;
	aLeft 		: Integer;
	aHeight,
	aWidth 		: Integer;
begin

	aWidth := 100;
	aHeight := 25;
	
	if not global.isValidObject(_userTool.mySystemToolbar) then
		return;
	endif;
	
	if _userTool.mySystemToolbar.menuId = CM_MenuToolbar.MENU_ID_SEP then
		aWidth := 8;
	endif;
	
	self.offSet := self.offSet - 2;
	btn := _btn.loadControl(pIndex).CMUI_Button;
	//self.allButtons.add(btn);
	//btn.myUserToolbar := _userTool;
	btn.picture := pPictureUp.picture;
	btn.pictureDown := pPictureDown.picture;
	btn.style := CMUI_ToolbarShipButton.Style_Auto2State; //Style_2State;
	btn.bubbleHelp := pBubble;
	btn.top := 2;
	btn.width := aWidth;
	btn.height := aHeight;
	btn.left := self.offSet;
	btn.caption := pBubble[1:10];
	btn.visible := true;
	btn.parent := self;
//	lControl.transparent := true;
//	lControl.transparentColor := 13423831;
	self.offSet := self.offSet + btn.width.Integer + 2 ;
	self.width := self.offSet;

end;</source>
        <Parameter name="pPictureUp" type="Picture"/>
        <Parameter name="pPictureDown" type="Picture"/>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pBubble" type="String"/>
        <Parameter name="_userTool" type="CM_MenuUserToolbar"/>
        <Parameter name="_btn" type="CMUI_Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="d3fdbdf2-c006-49c2-acc2-4b56d6ea0f0e">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.borderStyle := Frame.BorderStyle_None; //BorderStyle_Single;
	self.boundaryWidth := 0;
	self.bevelInnerWidth := 0;
	self.bevelOuterWidth := 0;
	self.caption := null;
	self.enabled := true;
	self.backColor := Mauve;
	self.autoRedraw := true;


end;</source>
    </JadeMethod>
    <JadeMethod name="createButton" id="6ee581f4-23aa-49e9-9d61-f05489d556dc">
        <updating/>
        <source>createButton() updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	create self.myButton transient;
	self.myButton.parent := self;
	self.form.addControl(self.myButton);
	self.myButton.myParent := self;

end;</source>
    </JadeMethod>
    <JadeMethod name="deleteButton" id="abfb69f2-8544-4daa-bc25-598e78a93fac">
        <updating/>
        <source>deleteButton() updating;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	lControl : Control;
begin

	self.clearGraphics();

	if self.myButton = null then
		return;
	endif;

	foreach idx in 1 to 100 do

		lControl := self.myButton.getControl(idx);
		if lControl &lt;&gt; null then
			delete lControl;
		endif;
	endforeach;

	delete self.myButton;

end;</source>
    </JadeMethod>
    <JadeMethod name="disableButton" id="d0cab3ca-5504-495a-a8d0-4a3a447f713f">
        <updating/>
        <source>disableButton(_theIndex : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lControl : Control;

begin
	lControl := self.myButton.getControl(_theIndex);
	if lControl &lt;&gt; null then
		lControl.enabled := false;
		if lControl.JadeMask.caption &lt;&gt; null then
			lControl.foreColor := Gray;
		endif;
//		lControl.bubbleHelp := lControl.bubbleHelp &amp; " (Disabled)";
	endif;

end;</source>
        <Parameter name="_theIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBtnToolBarMouseUp" id="adf126fc-40fd-44de-8060-5d0091cb5c69">
        <updating/>
        <source>doBtnToolBarMouseUp(jadeMask: JadeMask input) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if jadeMask.index &lt; self.SpaceIndex then
		self.setToolBarToViewMode(jadeMask.index);
		self.myParent.sendMsgWithParams("doBtnToolBarMouseUp",jadeMask);
	endif;

end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="enableButton" id="75958ffd-e1d2-43c9-8e9c-b3789b7b5cee">
        <updating/>
        <source>enableButton(_theIndex : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lControl : Control;
	theString : String;
begin
	lControl := self.myButton.getControl(_theIndex);
	if lControl &lt;&gt; null then
		lControl.enabled := true;
		if lControl.JadeMask.caption &lt;&gt; null then
			lControl.foreColor := lControl.userObject.CM_DrawingAttribute.colour;
		endif;
//		theString := lControl.bubbleHelp[ lControl.bubbleHelp.length - 9: end];
//		if theString = "(Disabled)" then
//			lControl.bubbleHelp := lControl.bubbleHelp[1: lControl.bubbleHelp.length - 10].trimBlanks;
//		endif;
	endif;

end;</source>
        <Parameter name="_theIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hideButton" id="f929823e-f59a-49b8-9009-6745943cbb8c">
        <updating/>
        <source>hideButton(_theIndex : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lControl : Control;

begin
	lControl := self.myButton.getControl(_theIndex);
	if lControl &lt;&gt; null then
		lControl.visible := false;
	endif;

end;</source>
        <Parameter name="_theIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setBubbleHelp" id="ad322e36-f83a-471e-9af7-25ce84a98a13">
        <updating/>
        <source>setBubbleHelp(_theIndex : Integer;_toolTip : String) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	lControl : Control;

begin
	lControl := self.myButton.getControl(_theIndex);
	if lControl &lt;&gt; null then
		lControl.bubbleHelp := _toolTip;
	endif;
end;</source>
        <Parameter name="_theIndex" type="Integer"/>
        <Parameter name="_toolTip" type="String"/>
    </JadeMethod>
    <JadeMethod name="setToolBarToViewMode" id="d7cc66af-ce6c-4224-9a0a-57b7c18bd640">
        <source>setToolBarToViewMode(pMode : Integer);
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lControl : Control;
	idx : Integer;
begin
	if pMode &lt;&gt; 0 then
		foreach idx in 1 to VIEW_TEMPERATURE do
			lControl := self.myButton.getControl(idx);
			if lControl &lt;&gt; null then
				lControl.CMUI_ToolbarShipButton.value := false;
			endif;
		endforeach;
		lControl := self.myButton.getControl(pMode);
		
		if lControl &lt;&gt; null then
			lControl.CMUI_ToolbarShipButton.value := true;
		endif;
	endif;


end;</source>
        <Parameter name="pMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showButton" id="e23b251a-9203-43f2-b5ec-8af9934c9519">
        <updating/>
        <source>showButton(_theIndex : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lControl : Control;

begin
	lControl := self.myButton.getControl(_theIndex);
	if lControl &lt;&gt; null then
		lControl.visible := true;
	endif;

end;</source>
        <Parameter name="_theIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="de349382-658d-4548-9fd8-058b08609c13">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	self.height := 30;
	self.width := 200;
	self.offSet := 4;
	self.borderStyle := Frame.BorderStyle_None;
	self.bevelInner := Frame.Bevel_None;
	self.bevelOuter := Frame.Bevel_None;
	self.boundaryWidth := 0;
	self.bevelInnerWidth := 0;
	self.bevelOuterWidth := 0;

	self.createButton();

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
