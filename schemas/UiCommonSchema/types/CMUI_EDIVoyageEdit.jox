    <JadeMethod name="cmbVoyage_lostFocus" id="c8b095c8-6370-4da6-8f50-c9b875ca2b8d">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyage_lostFocus(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		24 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	self.tblVoyage.setValueByControlName(combobox.name, combobox.text);
	if self.origValueStr &lt;&gt; combobox.text then	
		self.myVoyage := self.myAssistant.getVoyageFromCombo(combobox.text);
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initTblVoyage" id="47bfe130-271e-4d33-b52c-d64b1f0ce760">
        <source>initTblVoyage();
// ---------------------------------------------------------------------------
// Created:		24 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars
	entTableControl	: EntTableDef;
	theTable		: CM_EntryTable;
begin
	theTable := self.tblVoyage;
	theTable.rows := 0;
	theTable.optimiseRowHeight := true;
	
	entTableControl := app.myController.getEntTableDef(ETDef_EDIVoyageEdit); 
	
	theTable.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
	theTable.accessColumn(1).width := 120;
	
end;</source>
    </JadeMethod>
