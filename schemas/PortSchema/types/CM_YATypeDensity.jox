    <JadeMethod name="getCriteriaValueForTi" id="04c9eda3-722a-46d9-9f1d-a3752e602752">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2023	navmv20 TFS 56216 Task 56217: Jade - New YA Criteria

*/
begin
	_criteriaValue := _ti.getDensity().asStringJMT();
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaValue" type="Any" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="10262627-fc43-448d-9e9b-c860080f6cba">
        <source>getDataDisplay(pDataObj: CM_YAData): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2024	navrv30	Bug 64703: FR | 53383 - Release Request by Type - Cargo Group - Measurement Type

*/

vars
	measureType	: CM_MeasurementType;
	valueStr : String;
begin
	measureType := app.getDefaultMeasurementForType(Type_Density);
	valueStr := pDataObj.getDataValue().String;
	if measureType &lt;&gt; null and valueStr &lt;&gt; null then
			valueStr := app.convertMeasurementForDisplay(measureType.shortName, valueStr.Decimal);	
			return valueStr &amp; " " &amp; measureType.shortName;
	endif;
	return valueStr;
epilog

end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
