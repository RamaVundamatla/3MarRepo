    <ExplicitInverseRef name="myOptBtnTrue" id="02c4c214-c59c-488e-bc28-8d27b94500ab">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="OptBtn_QueryCriteria"/>
