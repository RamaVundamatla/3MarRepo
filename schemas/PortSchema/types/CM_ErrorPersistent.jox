    <JadeMethod name="setFromError" id="c02b9521-6fbf-496d-b102-f0560e1c6383">
        <updating/>
        <source>setFromError(_error : CM_Error input) updating;
// ---------------------------------------------------------------------------
// Created:     08 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.errorCode := _error.errorCode;
	self.fieldName := _error.fieldName;
	self.text := _error.text;
	_error.myErrorPersistent := self;
	
	if _error.warningOnly then
		self.type := CM_ErrorPersistent.Type_Warning;
	else
		self.type := CM_ErrorPersistent.Type_Error;
	endif;

	
epilog

end;</source>
        <Parameter name="_error" type="CM_Error" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromWLE" id="bd26972d-f529-4399-a280-d78b534c9cf7">
        <updating/>
        <source>setFromWLE(_wle : CM_WorkListEntry) updating;
// ---------------------------------------------------------------------------
// Created:     08 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.errorCode := 574;	
	self.fieldName := "MOVE";
	self.text := _wle.getMoveDescription();
	
	self.type := CM_ErrorPersistent.Type_Statement;

epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="setGateEntity" id="79bd713d-2c79-4044-981f-0ae644214fb9">
        <updating/>
        <source>setGateEntity(_gate : CMGTE_Entity) updating;
// ---------------------------------------------------------------------------
// Created:     23 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _gate &lt;&gt; self.myGateEntity then
		self.myGateEntity := _gate;
	endif;
epilog

end;</source>
        <Parameter name="_gate" type="CMGTE_Entity"/>
    </JadeMethod>
