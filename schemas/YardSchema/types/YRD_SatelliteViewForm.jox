    <JadeMethod name="doContextMenuBuild" id="ba874b2a-abc1-4cd5-8688-338a0e1049a9">
        <updating/>
        <source>doContextMenuBuild(
	_cntrl	: Control input;
	_conwin	: Window input;
	_mouse	: Boolean;
	_x		: Integer;
	_y		: Integer ) : Boolean updating;

//21 August 2008	cnwdw1	
// Context menu for Satellite View

/*

Date		Who		Reason
16 Dec 2008	cnwkpd1	PAR #18664 - Clean up leaked transients
17/04/2009	cnwrl1	PAR 19463 - major changes to the way this method is being used including comment below.
// This method was the original YRD_GridAreasOverviewForm and YRD_SatelliteViewForm methods
// combined this make the coding on the YRD_SatelliteViewForm easier to understand and change!


22 Sep 2011	NDL 	Par 28236Rip apart and re jig for Otago / Richard S. CCMS 2110  

*/

vars

	anLC				: CM_LocationsController;
	theObj				: Object;
	theDrawController	: YRD_ContainerDrawingController;
	retValue : Boolean;
begin


	self.myCM_LocationsController	:= null;
	
	self.saveContextMenuX := _x;
	self.saveContextMenuY := _y;
	
	self.doTurnOffContextMenus();
	self.allMenuTransients.purge();
	
	if self.myCurrentDrawingController = null then
		return retValue;
	endif;
	theDrawController := self.myCurrentDrawingController;
	
	if not theDrawController.allGridObjects.isEmpty then
		theObj := self.myDrawingFrame.getObjectForPosition( _x, _y );
		
		if theObj.isKindOf(CM_LocationsController) then
			anLC := theObj.CM_YardController;
		elseif theObj.isKindOf(CM_RoRoLaneArea) then	//20 Jan 2012	NDL	Par 28901
			anLC := theObj.CM_RoRoLaneArea.allLanesById.first;
		elseif theObj.isKindOf(CM_SubBlockStack) then //21/1/2013 epr PAR 30978 
			anLC := theObj.CM_SubBlockStack.myLocationsController;
		endif;
	endif;
	
	self.doBuildSep1MenuItems( anLC );	// Build the 'Row' or 'Bay' section.
	self.doBuildSep2MenuItems( anLC );	// Build the 'Area' section.
	self.doBuildSep3MenuItems( anLC );	// Build the 'Region' section.
	self.doBuildSep4MenuItems( anLC );	// Build the 'Summarise' and 'Report' section.
	self.doBuildSep5MenuItems( anLC );	// Build the 'Area Maint' section.
	self.doBuildSep6MenuItems( anLC );	// Build the 'Prefernces' section.

	self.showContextMenu(self.mnuNewMenu, _cntrl, _conwin, _mouse, _x, _y);
	return false;

	
epilog

end;	
</source>
        <Parameter name="_cntrl" type="Control" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDFContextMenu" id="bfc7d6d9-1e52-41cc-ae5d-f8f42561a987">
        <updating/>
        <source>doDFContextMenu(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
16 Dec 2008	cnwkpd1	PAR #18664 - Clean up leaked transients
23 Mar 2009	cnwdad1	PAR #19199 - When building Container menu, don't cast TI as CM_Container.
04 Nov 2011	cnwdap1	PAR #28629 - hide YA delete menu if user has no Yard Alocation Maintenance permission
03 July 2025	naviv1	MTN-35171 : MTN - Optimize Satellite View Screen to Handle Large Volumes of Failed Auto Plan Alerts Efficiently
*/

vars
	alert				: CM_SystemAlert;
	ya					: CM_YardAllocation;
	tiArray				: CM_TIArray;
	alertArray			: CM_AlertsArray;
	caption				: String;
	obj					: Object;
	failedToAutoplan	: CM_FailedToAutoplan;
	invalidYA			: Boolean;
	str					: String;
	
	theObj				: Object;
	anLC				: CM_LocationsController;
	gridController		: CM_GridController;
	lTI					: CM_TrackedItem;
	
	reserve				: CM_ReserveSelection;
	deliveryRequest : CM_DeliveryRequest;
	linkedToAlertObj	: CM_Object;
	reserveDetail		: CM_ReserveDetail;
begin
//+cnwml2 PAR 19627 start
	self.allMenuTransients.purge;
	
	if conwin.isKindOf( CM_FailedToAutoPlanTable) then
		
		foreach obj in conwin.CM_FailedToAutoPlanTable.allSelectedObjects do
			theObj := obj;
			if theObj = null then
		// eg if click on the background area or list of voyages etc
				return true;
			endif;
	
			if theObj.isKindOf( CM_LocationsController ) then
				anLC := theObj.CM_LocationsController;
				if theObj.isKindOf( CM_GridController ) then
					gridController := theObj.CM_GridController;
				endif;
			elseif theObj.isKindOf( CM_TrackedItem ) then
				lTI := theObj.CM_TrackedItem;
				anLC := lTI.myPrimaryActualLocation.CM_LocationsController;
				if anLC.allTrackedItems.size &gt; 1 then
					lTI := null;
				endif;
			elseif theObj.isKindOf( CM_SystemAlert) then
				alert := theObj.CM_SystemAlert;
				//epr par 20422 18/3/10
				if alert.myTrackedItem &lt;&gt; null then
					anLC := alert.myTrackedItem.myPrimaryActualLocation.CM_LocationsController;
				endif;
			endif;
			if anLC &lt;&gt; null then
				self.myCM_LocationsController	:= anLC;
			endif;
		endforeach;
		
		
	endif;
	//+cnwml2 PAR19627 end		
	self.doTurnOffContextMenus();


	
	if self.tblYAM = conwin then
		// Show Context menu for YAM table
		self.mnuYANew.visible		:=	app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198 CNWAB1

		if app.getMyUser.canDo(self.myTerminal, PmAdmYardStatistics) then
			self.mnuGridSeperator03.visible		:=	true;
			self.mnuRebuildStats.visible		:=	true;
			self.mnuProcessMovementLog.visible	:=	true;
		endif;
		self.mnuGridSeperator02.visible		:=	true;
		self.mnuColumnOrg.visible			:=	true;
		self.mnuColumnOrg.userObject		:=	self.tblYAM;
		
		//04 Jan 2012	NDL	Par 28889
		if self.allColumnFilters &lt;&gt; null then
			if not self.allColumnFilters.isEmpty then
				if self.allColumnFilters.includesFiltersFor( self.tblYAM ) then
					self.mnuClearYamTblFilters.visible := true;
				endif;
			endif;
		endif;
		
		// PAR 19177
		//if self.tblYAM.hasGroups then
		if self.tblYAM.hasGroups and self.tblYAM.getSelectedObjectsYA() &lt;&gt; null then
			self.mnuYAGroupNew.visible			:=	app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198 CNWAB1

		endif;
		if self.tblYAM.isSelected then
			self.mnuWhatIf.visible:=true;
			if self.tblYAM.isSingleSelection then
				if self.tblYAM.isYABlockSelected then
					 // PAR 19157
					 // caption := "Range ";
					 caption := app.getErrorString(YAM_Stats_Range) &amp; " ";
				elseif self.tblYAM.isYAGroupSelected then
					 // PAR 19157
					 //caption := "Group ";
					 caption := app.getErrorString(YAM_Msg_Group) &amp; " ";
				endif;
				caption := caption &amp; '"' &amp; self.tblYAM.getSelectedName() &amp; '"';
			else
				// PAR 19157
				//caption := 'Selected';
				caption := app.getErrorString(Selected);
			endif;
			if self.tblYAM.isSingleSelection or self.tblYAM.isYASelected then
				// PAR 19157
				//self.mnuYAEdit.caption := 'Edit ' &amp; caption &amp; '...';
				self.mnuYAEdit.caption := app.getErrorString(Edit) &amp; ' ' &amp; caption &amp; '...';
				self.mnuYAEdit.visible := app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198 CNWAB1;
				
				
				self.mnuAuditYardAllocation.userObject:=self.tblYAM.getSelectedObject();
				self.mnuAuditYardAllocation.visible:=app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198 CNWAB1;
			endif;
			// PAR 19157
			//self.mnuYADelete.caption := 'Delete ' &amp; caption;
			self.mnuYADelete.caption := app.getErrorString(Delete2) &amp; ' '  &amp; caption;
			if app.myCurrentUserCan(self.myTerminal, PmAdmYAMaint) then			// PAR #28629
				self.mnuYADelete.visible := app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198 CNWAB1;
			else																// PAR #28629
				self.mnuYADelete.visible := false;								// PAR #28629
			endif;																// PAR #28629
		endif;
		if self.tblYAM.isSingleSelection and self.tblYAM.isYABlockSelectedAndDeckable then
			self.mnuYADeckingOptions.visible := app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198 CNWAB1;
			// PAR 19157
			//self.mnuYADeckingOptions.caption := "Decking Options...";
			self.mnuYADeckingOptions.caption := app.getErrorString(DeckingOptions) &amp; "...";
		endif;
		
		//04 Jan 2012	NDL	Par 28889
		if self.tblYAM.isSingleSelection and self.tblYAM.isYASelected then
			self.mnuYABuildSelector.visible := app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198 CNWAB1;
			self.mnuYABuildSelector.caption := app.getErrorString(Selector_query_txt) &amp; " " &amp; caption &amp; "...";
			self.mnuYABuildSelector.userObject := self.tblYAM.getSelectedObject();
		endif;
		
		self.mnuInspect.visible				:=	false;
		self.mnuPurgeMovementLog.visible	:=	false;
		if app.isAllowedToInspect then
			self.mnuInspect.visible		:=	true;
			self.mnuInspect.enabled		:=	true;
			self.mnuInspect.userObject	:=	self.tblYAM.getSelectedObject();
			self.mnuPurgeMovementLog.visible	:=	app.isSpecial;
		endif;
		
		self.showContextMenu(self.mnuGridAreaContext, cntrl, conwin, mouse, x, y);

		return false;
	endif;

	if self.tblLocnStats = conwin then
		// Show Context menu for Location table
		self.mnuGridSeperator03.visible		:=	false;
		self.mnuRebuildStats.visible		:=	app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198 CNWAB1;
		self.mnuProcessMovementLog.visible	:=	app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198 CNWAB1;
		self.mnuGridSeperator02.visible		:=	true;
		self.mnuColumnOrg.visible			:=	true;
		self.mnuColumnOrg.userObject		:=	self.tblLocnStats;
		self.mnuInspect.visible				:=	false;
		
		if app.isAllowedToInspect then
			self.mnuInspect.visible		:=	true;
			self.mnuInspect.enabled		:=	true;
			self.mnuInspect.userObject	:=	self.tblLocnStats.getSelectedObject();
		endif;
		
		self.showContextMenu(self.mnuGridAreaContext, cntrl, conwin, mouse, x, y);
		
		return false;
	endif;
	
	// PAR 19463
	if self.frmColLegendTIs.myLegendTable = conwin then
		self.mnuInspect.visible		:= false;
		self.showContextMenu(self.mnuGridAreaContext, cntrl, conwin, mouse, x, y);
		return false;
	endif;
	
	if self.tblFailAutoPlan = conwin then
		// Show Context menu for FailAutoPlan table
		create tiArray transient;
		create alertArray transient;
		self.allMenuTransients.add(tiArray); // PAR 18723
		self.allMenuTransients.add(alertArray);
		foreach obj in tblFailAutoPlan.allSelectedObjects do
			alert := obj.CM_SystemAlert;
			alertArray.add(alert);		// 27/04/2009 cnwar2 #19401, #19524, #19522
			if alert.myTrackedItem &lt;&gt; null then	
				tiArray.add(alert.myTrackedItem);
			endif;
		endforeach;
		
		if tiArray.size &gt; 0 then
			self.doBuildMnuContainer(tiArray.first());
			
			self.mnuCreateYA.visible		:=	app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198 CNWAB1


			self.mnuFailToPlanAutoPlan.visible := app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198 CNWAB1
			if tiArray.size &gt; 1 then
				self.mnuFailToPlanAutoPlan.caption := app.getErrorString(AutoPlanSelectedCargo);
			else
				self.mnuFailToPlanAutoPlan.caption := app.getErrorString(AutoPlan) &amp; " " &amp; alert.myTrackedItem.id;
			endif;
			//self.mnuFailToPlanAutoPlan.userObject := tiArray;
			self.mnuFailToPlanAutoPlan.userObject := alertArray;	// 27/04/2009 cnwar2 #19401, #19524, #19522
			
			self.mnuFailToPlanQueue.visible := app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198 CNWAB1
			if tiArray.size &gt; 1 then
				self.mnuFailToPlanQueue.caption := app.getErrorString(QueueSelectedCargo);
			else
				self.mnuFailToPlanQueue.caption := app.getErrorString(Queue) &amp; ' ' &amp; alert.myTrackedItem.id;
			endif;
			//self.mnuFailToPlanQueue.userObject := tiArray;
			self.mnuFailToPlanQueue.userObject := alertArray;	// 27/04/2009 cnwar2 #19401, #19524, #19522

			self.mnuCargoLCL.visible		:=	false;
			self.mnuCargoAP.visible := false;
			self.mnuCargoMoveIt.userObject	:=	tiArray;
		endif;
		
		self.mnuFailToPlanDetails.visible := app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198 CNWAB1;
		self.mnuFailToPlanRemarks.visible := app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198 CNWAB1;
		self.mnuFailToPlanReveiw.visible := app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198 CNWAB1;
		
		self.mnuGridSeperator02.visible	:=	true;
		self.mnuColumnOrg.visible		:=	true;
		self.mnuColumnOrg.userObject	:=	self.tblFailAutoPlan;
		self.mnuInspect.visible			:=	false;
		
		alert := self.tblFailAutoPlan.getSelectedObject();
		if alert &lt;&gt; null then
			obj := alert.getLinkedTo();
			if obj &lt;&gt; null then
				if obj.isKindOf(CM_FailedToAutoplan) then			// 27/04/2009 cnwar2 #19401, #19524, #19522
					ya := obj.CM_FailedToAutoplan.myFirstYAFailure;
				else
					ya := obj.CM_YardAllocation;
				endif;
				if ya &lt;&gt; null then
					on Exception do app.handleDeletedObject(exception, ya, invalidYA);
					str := 	app.getErrorString(PositionAt) &amp; ' ' &amp; ya.code;
					if not invalidYA then
						self.mnuPositionAt.visible := true;
						self.mnuPositionAt.caption := str;
					endif;
				endif;
			endif;
		endif;
		
		if app.isAllowedToInspect then
			self.mnuInspect.visible		:=	true;
			self.mnuInspect.enabled		:=	true;
			self.mnuInspect.userObject	:=	self.tblFailAutoPlan.getSelectedObject();
		endif;

		self.showContextMenu(self.mnuGridAreaContext, cntrl, conwin, mouse, x, y);
		return false;
	endif;
	
	//10 Jan 2012	NDL	Par 28953
	if self.tblFailRequest = conwin then
		// Show Context menu for FailRequest table
		alert := self.getAlert();
		if alert &lt;&gt; null then
			linkedToAlertObj := alert.getLinkedTo();			//MTN-35171
			if linkedToAlertObj &lt;&gt; null and linkedToAlertObj.isKindOf(CM_DeliveryRequest) then					//MTN-35171
				deliveryRequest := linkedToAlertObj.CM_DeliveryRequest;
				reserveDetail := deliveryRequest.myReserveDetail;
				if reserveDetail &lt;&gt; null then 
					reserve := alert.getMyReserveSelection(reserveDetail);
				endif;
			endif;
			if alert &lt;&gt; null then
				
				if reserve &lt;&gt; null then
					caption := reserve.getDescription;				
					self.mnuRequestSelector.visible := true;
					self.mnuRequestSelector.userObject := reserve;
					self.mnuRequestSelector.caption := app.getErrorString(Selector_query_txt) &amp; " '" &amp; caption &amp; "'...";
				elseif deliveryRequest &lt;&gt; null then
					caption := "DeliveryRequest";				
					self.mnuRequestSelector.visible := true;
					self.mnuRequestSelector.userObject := deliveryRequest;
					self.mnuRequestSelector.caption := app.getErrorString(Selector_query_txt) &amp; " '" &amp; caption &amp; "'...";
				endif;
				self.mnuFailToPlanDetails.visible := app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198 CNWAB1;
				self.mnuFailToPlanRemarks.visible := app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198 CNWAB1;
				self.mnuFailToPlanReveiw.visible := app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198 CNWAB1;
				
				self.mnuGridSeperator02.visible	:=	true;
		
			endif;
		endif;
		
		self.mnuColumnOrg.visible		:=	true;
		self.mnuColumnOrg.userObject	:=	self.tblFailRequest;
		
		if app.isAllowedToInspect then
			self.mnuInspect.visible		:=	true;
			self.mnuInspect.enabled		:=	true;
			self.mnuInspect.userObject	:=	self.tblFailRequest.getSelectedObject();
		else
			self.mnuInspect.visible			:=	false;
		endif;

		self.showContextMenu(self.mnuGridAreaContext, cntrl, conwin, mouse, x, y);
		return false;
		
	endif;
	
	return inheritMethod( cntrl, conwin, mouse, x, y );
	
epilog
	
end;
</source>
        <Parameter name="cntrl" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDFDblClick" id="f300d447-dfdd-49ea-8fe2-454d122cb001">
        <updating/>
        <source>doDFDblClick( frame : Frame input ) updating;

/*

Purpose:			Display Yard Grid Areas form when area is double clicked

Parameters:			

Return Value:		


Date				Who		Reason
18 November 2008	consw1	Initial creation

*/

vars

begin
	
	//26 Sep 2011	NDL	Par 28236
	self.doDblClickUsingPrefAction();
	
/*
	self.setLocationControllerArray();			//+cnwml2 PAR24701	
	if locationControllerArray = null or locationControllerArray.isEmpty  then
		return;
	endif;	
	
	if locationControllerArray.size = 1 and locationControllerArray[1].CM_LocationsController.allTrackedItems.size = 1 then
		self.doMnuEnquiryClick;
	else
		self.doMnuGridBulkEnqClick( self.mnuGridBulkEnq );
	endif; */
	
epilog
	delete self.locationControllerArray;	// 26/05/2010 cnwmh5 #23880
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDFMouseDown" id="e6dff88a-522f-4f12-a8e1-561d6f80562d">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDFMouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
/*
Purpose:	

  // ### JIRA 35403 10JUL2025 NAVAB1
*/

vars
	theFramesObj : Object;
	locnid : String;
	tCapacityPC, pCapacityPC, aCapacityPC, capacityMax : Integer;
	caption : String;
	tAmount, aAmount, pAmount, capAmount  : Decimal[23,1];
	tQuantity, aQuantity, pQuantity : Integer;
	suffix : String;
	gclc : CM_IrregularBlockController;
	firstPoint : Point;
	lastPoint : Point;
	amountType : String;
	measurementTypeW : CM_MeasurementType;
	measurementTypeV : CM_MeasurementType;
	actualStr, plannedStr, totalStr, capacityStr : String;
	lc : CM_LocationsController;
	actualArray : CM_TIArray;
	ti : CM_TrackedItem;
	tiCargoType : CM_CargoType;
	tiSubType : CM_Product;
	tiCommodity : CM_Commodity;
begin

	self.myDrawingFrame.myOverlayViewingFrame.bubbleHelp := null;

	inheritMethod(frame, button, shift, x, y);

	theFramesObj := self.myDrawingFrame.getObjectForPosition( self.origXPos.Integer, self.origYPos.Integer );
	if theFramesObj = null 
	or not theFramesObj.isKindOf(CM_LocationsController) then
		return;
	endif;
	lc := theFramesObj.CM_LocationsController;
	
	if  lc.isShelf()  then
		return;
	endif;
		
	
	locnid := lc.getFullId() &amp; CrLf;
	

	if lc.isRowController() then
		if lc.CM_GeneralCargoAllocController.myGroup.allLocations.first() &lt;&gt; lc then
			lc :=  lc.CM_GeneralCargoAllocController.myGroup.allLocations.first();
		endif;
	endif;
	
	create actualArray transient;
	lc.getTIs(actualArray, REAL_MODE, true);
	

	amountType := lc.getCapacityUsedDetails(pCapacityPC,aCapacityPC, pAmount, aAmount, capacityMax);
	
	if amountType = "BULKW" or amountType = "BULKV" then
		if amountType = "BULKW" then
			measurementTypeW := app.getDefaultMeasurementForType(Type_Weight); 
			aAmount := measurementTypeW.convertValueAsValue(aAmount);
			pAmount := measurementTypeW.convertValueAsValue(pAmount);
			capAmount := measurementTypeW.convertValueAsValue(capacityMax);
			
			suffix := measurementTypeW.shortName; 
		else
			measurementTypeV := app.getDefaultMeasurementForType(Type_Volume); 
			aAmount := measurementTypeV.convertValueAsValue(aAmount);
			pAmount := measurementTypeV.convertValueAsValue(pAmount);
			capAmount := measurementTypeV.convertValueAsValue(capacityMax);
			
			suffix := measurementTypeV.shortName; 
		endif;
		tAmount := aAmount + pAmount; // Bulk
		
		// Convert to string so has 1 decimal place
		actualStr := aAmount.asStringJMTWithPrecision(1,false);
		plannedStr := pAmount.asStringJMTWithPrecision(1,false);
		totalStr := tAmount.asStringJMTWithPrecision(1,false);
		capacityStr := capAmount.asStringJMT();
	else
		aQuantity := aAmount.Integer;
		pQuantity := pAmount.Integer;
		tQuantity := pQuantity + aQuantity; // Break Bulk
		
		// Convert to string so has 0 decimal place
		actualStr := aQuantity.asStringJMT();
		plannedStr := pQuantity.asStringJMT();
		totalStr := tQuantity.asStringJMT();
		capacityStr := capacityMax.asStringJMT();
	endif;
	
	tCapacityPC := pCapacityPC + aCapacityPC;
	

	if lc.isKindOf(CM_IrregularBlockController) then
		gclc := lc.CM_IrregularBlockController;
	

		firstPoint := gclc.region.first;
		lastPoint := gclc.region.last;
	endif;

	ti := actualArray.first;
	if ti &lt;&gt; null then
		tiCargoType := ti.myCargoType;
		tiSubType := ti.myProduct;
		tiCommodity := ti.getCommodityObject;
			
		if tiCargoType &lt;&gt; null then
			locnid := locnid &amp; CrLf &amp; tiCargoType.description;
		endif;
		if tiSubType &lt;&gt; null then
			locnid := locnid &amp; CrLf &amp; tiSubType.description;
		endif;
		if tiCommodity &lt;&gt; null then
			locnid := locnid &amp; CrLf &amp; tiCommodity.description;
		endif;
	endif;
	
	if pAmount = 0 then
			caption := "Amount: " &amp; actualStr &amp; "/" &amp; capacityStr &amp; " " &amp; suffix &amp;  " - " &amp; aCapacityPC.String &amp; "%";
	
	else
			caption := "Actual: " &amp; actualStr &amp; "/" &amp; capacityStr &amp; " " &amp; suffix &amp;  " - " &amp; aCapacityPC.String &amp; "%" &amp;  CrLf  &amp; 
						"Planned: " &amp; plannedStr  &amp; "/" &amp; capacityStr &amp;  " " &amp; suffix &amp;  " - " &amp; pCapacityPC.String &amp; "%" &amp;  CrLf &amp; 
						"Total: " &amp; totalStr  &amp; "/" &amp; capacityStr &amp;  " " &amp; suffix &amp;  " - " &amp; tCapacityPC.String &amp; "%";
	endif;

	self.myDrawingFrame.myOverlayViewingFrame.bubbleHelp := locnid &amp; CrLf &amp; CrLf &amp; caption;
	self.myDrawingFrame.myOverlayViewingFrame.endTimer(YRD_ContainerOverDrawingFrame.TimerBubbleHelp);
	self.myDrawingFrame.myOverlayViewingFrame.beginTimer(6000, 0, YRD_ContainerOverDrawingFrame.TimerBubbleHelp);
epilog
	delete actualArray;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDOLFMouseUpNoDiff" id="86ccfd92-3047-494c-9b41-ac1a2f804e3d">
        <source>doDOLFMouseUpNoDiff(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

begin

	self.clearSelectedRegionObjs();

epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDOLFMouseUpOptions" id="7734645c-3436-4a60-9300-850819e45e95">
        <source>doDOLFMouseUpOptions(	_frame: Frame input;
						_button: Integer;
						_shift: Integer;
						_origXPos : Integer;
						_origYPos : Integer;
						_x: Real;
						_y: Real
						);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

	cdf : YRD_ContainerOverDrawingFrame;
	cdc : YRD_ContainerDrawingController;
	objs : ObjectArray;
	obj : Object;
	locCont : CM_LocationsController;
	x1 : Integer;
	y1 : Integer;																						// cnwjk3 PAR 21704	15/02/10
	x2 : Integer;
	y2 : Integer;
	regionObj : CMUI_Region;

begin

	// if the cntrl key is also pressed we should be adding to the collection of locations, if not we should clear them first.
	
	if _shift &lt;&gt; 2 then
		self.clearSelectedRegionObjs();
	endif;
	
	cdf := _frame.YRD_ContainerOverDrawingFrame;
	if cdf = null then
		return;
	endif;
	
	cdc := cdf.getDrawingController();
	if cdc = null then
		return;
	endif;
	
	create objs transient;
	
	x1 := _origXPos; 																	
	y1 := _origYPos;																		
	x2 := _x.Integer;							
	y2 := _y.Integer;
	cdf.getDrawingController().normaliseRectanglePoints(x1, y1, x2, y2);	
	cdc.allGridObjects.findObjectsInDict(x1, y1, x2, y2, objs, CM_LocationsController, true, false);
	
	foreach obj in objs do
		if not obj.isKindOf( CM_LocationsController ) then
			continue;
		endif;
		locCont := obj.CM_LocationsController;
		if locCont &lt;&gt; null then
			self.allSelectedRegionLocs.addNoDuplicates(locCont,false);
		endif;
	endforeach;
	
	create regionObj transient;
	regionObj.setData(x1, y1, x2, y2);
	self.allSelectedRegionObjs.add( regionObj );
	
	self.showUserSelectedRegions( cdf );

epilog

	delete objs;

end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_button" type="Integer"/>
        <Parameter name="_shift" type="Integer"/>
        <Parameter name="_origXPos" type="Integer"/>
        <Parameter name="_origYPos" type="Integer"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDOLFMouseUpVIEW" id="5f0e45b4-29a8-4821-be3c-d45221441bbf">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDOLFMouseUpVIEW(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	ydc : YRD_ContainerDrawingController;
	obj : Object;
	olf : YRD_ContainerOverDrawingFrame;
	idx : Integer;
	theTable : CM_YAMTable;

begin
	
	
	//epr par 25601 21/12/10  this method is not needed at all the yam table registers and handles notes independently
	//return;
	
	//26 Jan 2011	NDL	Par 26817 - put code back
	ydc := self.myCurrentDrawingController;

	olf := ydc.getOverlayFrame(false);

	if olf &lt;&gt; null then
		obj := olf.getObjectForPosition(x.Integer, y.Integer);
		
		theTable := self.tblYAM;
		if theTable.findObjectInRow(obj, idx) then
			theTable.row := idx;
			theTable.selectTheCurrentRow(idx);
			theTable.click(theTable);
		endif;
		
		//24 Nov 2011	NDL	Par 28721 - flip flop transparency of overlay frame to deal to a jade bug....
		olf.transparent := not olf.transparent;
		olf.transparent := not olf.transparent;
		
	endif;
	
epilog
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDblClickUsingPrefAction" id="0809d940-b6bd-4f6f-b855-d0d6543eb2f2">
        <updating/>
        <source>doDblClickUsingPrefAction() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 September 2011	cnwndl1	Initial creation	Par 28236
21 May 2024	naviv1	CR-64057 : EUP | Satellite View Table Performance
31 Mar 2025	navnk30	JIRA 34507: Double clicking on Satellite View opens Cargo Enquiry screen
01 Aug 2025	navhl20 Bug MTN-35594: PEN | Satellite View Options
*/

vars

	prefAction 		: String;
	theFramesObj 	: Object;
	terminalArea 	: CM_TerminalArea;
	cm_ObjectArray	: CM_ObjectArray;
	obj 			: Object;
	gridObject 		: CM_GridObject;
	ti 				: CM_TrackedItem;
	irregularBlock 	: CM_IrregularBlockController;

begin

	prefAction := self.dblClickAction;
	if prefAction = null then
		//default action.
		prefAction := self.DblClickYardEnqArea;
	endif;
	
	//find what terminal area we double clicked on.
	theFramesObj := self.myDrawingFrame.getObjectForPosition( self.origXPos.Integer, self.origYPos.Integer );
	if theFramesObj = null then
		return;
	endif;
	if theFramesObj.isKindOf(CM_IrregularBlockController) then		//21-05-2024 naviv1 #64057
		if self.myTerminal.getConfig(DblClkSatShowSubArea).Boolean then
			irregularBlock := theFramesObj.CM_IrregularBlockController;
			terminalArea := irregularBlock.myTerminalArea;
		else
			terminalArea := theFramesObj.CM_IrregularBlockController.myTerminalArea;
		endif;
	elseif theFramesObj.isKindOf( CM_StackController ) or theFramesObj.isKindOf( CM_RTGController ) then
		terminalArea := theFramesObj.CM_LocationsController.myTerminalArea;
		// if its a gridded area find the Bay / Row ( grid area )
		if theFramesObj.isKindOf( CM_StackController ) then
			gridObject := theFramesObj.CM_StackController.myGridRow;
		elseif theFramesObj.isKindOf( CM_RTGController ) then
			gridObject := theFramesObj.CM_RTGController.myGridColumn;
		endif;
	elseif theFramesObj.isKindOf( CM_LocationsController ) then
		terminalArea := theFramesObj.CM_LocationsController.myTerminalArea;
	elseif theFramesObj.isKindOf( CM_TrackedItem ) then
		terminalArea := theFramesObj.CM_TrackedItem.myPrimaryActualLocation.CM_LocationsController.myTerminalArea;
	endif;
	
	if terminalArea = null then
		return;
	endif;
	
	//Kludge to allow Yard Grid Enquiry for a NON gridded area to use the List Enquiry
	if ( prefAction = YRD_SatelliteViewForm.DblClickYardEnqArea or prefAction = YRD_SatelliteViewForm.DblClickYardEnqBayRow  )
	and gridObject = null then
		prefAction := YRD_SatelliteViewForm.DblClickCargoEnqArea;
	endif;

	create cm_ObjectArray transient;
	
	//if its a grid style action one we must have a gridObect
	if prefAction = YRD_SatelliteViewForm.DblClickCargoEnqBayRow
	or prefAction = YRD_SatelliteViewForm.DblClickReportBayRow
	or prefAction = YRD_SatelliteViewForm.DblClickSumBayRow
	or prefAction = YRD_SatelliteViewForm.DblClickYardEnqBayRow
	then
		if gridObject = null then
			return;
		endif;
		
		if prefAction = YRD_SatelliteViewForm.DblClickYardEnqBayRow then
			// get the collection of locations in this Row / Bay.
			self.findLocationsFromObject( gridObject, cm_ObjectArray );
		else
			// get the collection of cargo in this Row / Bay.
			self.findCargoFromObject( gridObject, cm_ObjectArray );
		endif;
	elseif irregularBlock &lt;&gt; null then					//21-05-2024 naviv1 #64057
		if prefAction = YRD_SatelliteViewForm.DblClickCargoEnqArea then
			// get the collection of cargo in this area
			self.findCargoFromObject(irregularBlock, cm_ObjectArray);
		endif;
	else
	// it must be a terminal area type action
		if prefAction = YRD_SatelliteViewForm.DblClickYardEnqArea then
			// get the collection of locations in this area.
			self.findLocationsFromObject( terminalArea, cm_ObjectArray );
		else
			// get the collection of cargo in this area.
			self.findCargoFromObject( terminalArea, cm_ObjectArray );
		endif;
		
	endif;
	
	if cm_ObjectArray.isEmpty then
		// nothing to process.
		return;
	endif;
			
	// ok ready to perform the action.	
	if ( prefAction = YRD_SatelliteViewForm.DblClickCargoEnqArea
	or prefAction = YRD_SatelliteViewForm.DblClickCargoEnqBayRow )
	then
		//Open the Cargo Enquiry form listing all cargo in the selected terminal Area.
		self.myAssistant.showCargoEnquiryForTIs(	cm_ObjectArray[1].CM_TrackedItem,		//31.03.2025 navnk30 JIRA 34507 START
												cm_ObjectArray,
												self.myMasterMenuAction,
												false
												);
	elseif ( prefAction = YRD_SatelliteViewForm.DblClickReportArea	
	or prefAction = YRD_SatelliteViewForm.DblClickReportBayRow )
	then
		// Run Report for selected cargo
		self.myAssistant.sendItemsToReport( cm_ObjectArray );

	
	elseif ( prefAction = YRD_SatelliteViewForm.DblClickSumArea
	or prefAction = YRD_SatelliteViewForm.DblClickSumBayRow )
	then
		// Summarise the selected cargo
		self.myAssistant.showXTABSummaryDefinitionForm( cm_ObjectArray, false, false, false, true );
		
	
	elseif ( prefAction = YRD_SatelliteViewForm.DblClickYardEnqArea			
	or prefAction = YRD_SatelliteViewForm.DblClickYardEnqBayRow )
	then
		// open Yard Grid enquiry for selected locations
		self.myAssistant.showYardGridAreasForm(	cm_ObjectArray,
												self.myCurrentDrawingController.getViewMode(),
												self.myMasterMenuAction,
												0);
			
	endif;
	

epilog

	delete cm_ObjectArray;

end;</source>
    </JadeMethod>
