    <JadeMethod name="btnClose_click" id="6560c5b5-1bc7-42ae-b1a4-667e9237ff7f">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.unloadForm();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnFieldAdd_click" id="3632d18a-dcda-4c5c-bdb9-47933f0537c3">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFieldAdd_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fieldForm	: CnEcWebTestFieldEditForm;

begin
	app.mousePointer	:=	Busy;

	create fieldForm;
	fieldForm.setCommonField(null, self.aMyWebTest);
	fieldForm.showModal();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnFieldEdit_click" id="4c459579-45f9-44d7-a34b-921a2fa170a6">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFieldEdit_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fieldForm	: CnEcWebTestFieldEditForm;
	commonField	: CnEcWebTestCommonField;

begin
	app.mousePointer	:=	Busy;
	commonField			:=	self.getSelectedField();

	if commonField &lt;&gt; null then
		create fieldForm;
		fieldForm.setCommonField(commonField, self.aMyWebTest);
		fieldForm.showModal();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnFieldRemove_click" id="f994df36-ba54-495f-bd55-8a07a762f406">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFieldRemove_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	commonField	: CnEcWebTestCommonField;

begin
	app.mousePointer	:=	Busy;
	commonField			:=	self.getSelectedField();

	if commonField &lt;&gt; null then
		if self.getConfirmDelete(commonField.fieldName) then
			self.aMyTA.trxCommonFieldDelete(commonField);
		endif;
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doEnabledButtonsField" id="b2b2b7aa-fbfd-439b-9707-5b52fceac174">
        <source>doEnabledButtonsField();
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	commonField	: CnEcWebTestCommonField;

begin
	commonField	:=	self.getSelectedField();

	btnFieldEdit.enabled	:=	(not commonField = null);
	btnFieldRemove.enabled	:=	(not commonField = null);
end;</source>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="1ab05c87-5061-47d8-b67c-5c2230062150">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	centreWindow();
	self.doLoadFieldProperties();
	beginClassNotification(CnEcWebTestCommonField, false, Any_System_Event, Response_Continuous, self.NOTIFY_FIELD_CHANGE);
	modalResult	:=	0;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadFieldProperties" id="317e4d70-392f-4554-a7f7-cee997f6a3e8">
        <updating/>
        <source>doLoadFieldProperties() updating, protected;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Purpose:		Populates the receiver's controls with a list of the web test fields.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setFormCaption(CAPTION_NAME, false, false);
	self.lblTestName.caption	:=	self.aMyWebTest.testName;
	self.doTableSetupFields();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTableLoadFields" id="35eb9bdf-9e75-4152-8689-be31a2faca2e">
        <updating/>
        <source>doTableLoadFields() updating, protected;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Purpose:		Populates a table control with a list of the web test's fields.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	webTest		: CnEcWebTest;
	commonField	: CnEcWebTestCommonField;
	table		: Table;
	rowString	: String;
	rowIndex	: Integer;

begin
	table		:=	tblFields;
	table.rows	:=	1;
	webTest		:=	self.aMyWebTest;

	foreach commonField in webTest.allCommonFields do
		rowString	:=	commonField.fieldName &amp;
						Tab &amp; commonField.isValidatedField.cnEcGetTableCheckBoxValue() &amp;
						Tab &amp; commonField.defaultFieldValue &amp;
						Tab &amp; commonField.getFieldType() &amp;
						Tab &amp; commonField.isValidateEqualTo.cnEcGetTableCheckBoxValue();

		rowIndex	:=	table.addItem(rowString);
		table.cnEcSetCellObject(rowIndex, 1, commonField);
	endforeach;

	self.doEnabledButtonsField();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTableSetupFields" id="d02973d9-c8ec-4fa2-94bd-9217ff58775b">
        <updating/>
        <source>doTableSetupFields() updating, protected;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Purpose:		Initializaes the table by clearing all of its rows (except the fixed
//				row), sets the column headings, and sets the column input types.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	COLUMN_HEADING_1	: String = "Name";
	COLUMN_HEADING_2	: String = "Validated";
	COLUMN_HEADING_3	: String = "Default Value";
	COLUMN_HEADING_4	: String = "Type";
	COLUMN_HEADING_5	: String = "Valid Equal";

vars
	table				: Table;
	columnWidthArray	: IntegerArray;
	oldAccessMode		: Integer;

begin
	table		:=	tblFields;
	table.rows	:=	1;
	table.setCellText(1, 1, COLUMN_HEADING_1 &amp; Tab &amp; COLUMN_HEADING_2 &amp; Tab &amp; COLUMN_HEADING_3 &amp; Tab &amp; COLUMN_HEADING_4 &amp; Tab &amp; COLUMN_HEADING_5);

	create columnWidthArray transient;
	columnWidthArray.add(20);
	columnWidthArray.add(15);
	columnWidthArray.add(25);
	columnWidthArray.add(20);
	columnWidthArray.add(20);
	table.cnEcSetColumnWidths(columnWidthArray);

	oldAccessMode		:=	table.accessMode;
	table.accessMode	:=	Table.AccessMode_Column;
	table.column		:=	2;
	table.inputType		:=	Table.InputType_CheckBox;
	table.column		:=	5;
	table.inputType		:=	Table.InputType_CheckBox;
	table.accessMode	:=	oldAccessMode;
	table.readOnly		:=	true;

	self.doTableLoadFields();
epilog
	delete columnWidthArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getSelectedField" id="3aaf5733-c5e7-4ef2-840d-173a5635f6ac">
        <source>getSelectedField():CnEcWebTestCommonField protected;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Purpose:		Returns the currently selected web test field in the table.
//
// Parameters:	None
//
// Returns:		The currently selected web test field object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	commonField	: CnEcWebTestCommonField;
	rowIndex	: Integer;

begin
	rowIndex	:=	tblFields.row;

	if rowIndex &gt; 1 and rowIndex &lt;= tblFields.rows then
		commonField	:=	tblFields.cnEcGetCellObject(rowIndex, 1).CnEcWebTestCommonField;
	endif;
epilog
	return commonField;
end;</source>
        <access>protected</access>
        <ReturnType type="CnEcWebTestCommonField"/>
    </JadeMethod>
    <JadeMethod name="setWebTest" id="887280eb-8963-4003-bbfb-ad9132e5dc21">
        <updating/>
        <source>setWebTest(pWebTest:CnEcWebTest) updating;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Purpose:		Sets a reference to the web test object who's fields are listed by
//				the receiver.
//
// Parameters:	pWebTest - The owner of the web test fields being listed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aMyWebTest	:=	pWebTest;
end;</source>
        <Parameter name="pWebTest" type="CnEcWebTest"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="ebb2564d-cc2e-4563-b49b-28f0bf5b24af">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		08 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;

	if eventTag = self.NOTIFY_FIELD_CHANGE then
		self.doTableLoadFields();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblFields_click" id="9b4b0dc5-f886-4883-898d-341aaed71c54">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFields_click(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.doEnabledButtonsField();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblFields_dblClick" id="9e74cec2-9ad3-400f-a542-2f6fcfedc418">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFields_dblClick(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.btnFieldEdit.click(btnFieldEdit);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblFields_mouseDown" id="f4b0f94a-3a52-4368-ba2b-4eaabb8364bd">
        <controlMethod name="Table::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFields_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		07 June 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	table.cnEcSelectRow();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
</GUIClass>
