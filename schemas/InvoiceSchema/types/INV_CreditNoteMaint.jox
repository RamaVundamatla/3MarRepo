    <JadeMethod name="translateForm" id="23aba85e-888c-415a-8ac4-f3948f993542">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 February 2023 08:34:34.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025459, locale);
	btnAdd.translateCaption(Xlat_0025460, locale);
	btnClose.translateCaption(Xlat_0025461, locale);
	btnRemove.translateCaption(Xlat_0025462, locale);
	btnSave.translateCaption(Xlat_0025463, locale);
	btnSearch.translateCaption(Xlat_0025464, locale);
	lblCreditDebtor.translateCaption(Xlat_0025465, locale);
	lblCreditInvoiceType.translateCaption(Xlat_0025466, locale);
	lblCreditStartDate.translateCaption(Xlat_0025467, locale);
	lblCreditStatus.translateCaption(Xlat_0025468, locale);
	lblDebtorAddress.translateCaption(Xlat_0025469, locale);
	lblInvoiceLink.translateCaption(Xlat_0025471, locale);
	lblInvoiceType.translateCaption(Xlat_0025472, locale);
	lblResult.translateCaption(Xlat_0025473, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0025474, locale);
	mnuMenuContext.translateCaption(Xlat_0025475, locale);
	shtDetails.translateCaption(Xlat_0025476, locale);
	shtInvoice.translateCaption(Xlat_0025477, locale);
	shtLinkInvoice.translateCaption(Xlat_0025478, locale);
end;</source>
    </JadeMethod>
