    <JadeMethod name="doCustomizeToolbar" id="78363307-b757-45ee-96dc-bd7d7fd79ca3">
        <updating/>
        <source>doCustomizeToolbar() protected, updating;
// ---------------------------------------------------------------------------
// Created:     21 January 2003		cnwth2	
/* Changes

Date		Name	TFS#		Description
============================================================================
19/2/2009	cnwcp2	PAR# 18073 	app method call can result in incorrect terminal being returned
20/09/2019 	jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/
vars
