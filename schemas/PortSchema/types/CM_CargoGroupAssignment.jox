    <JadeMethod name="pxyCreateUpdateProxy" id="d09cd25c-ec7a-446e-ae2d-a123789a4024">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	pxy : CM_CargoGroupAssignment;
	
	cg : CM_TrackedItem;
	pxyCg : CM_CargoGroup;
	
	cgn : CM_NotifiedCargoGroup;
	pxyCgn : CM_NotifiedCargoGroup;
	
	iter : Iterator;
	obj : Object;
	cargoId : String;
	
	completedOK : Boolean;

begin

	pxy := inheritMethod();
	
	//02 Oct 2018	NDL	TFS 39186
	foreach cg in self.allCargoGroupsByIdDict do
		pxyCg := cg.pxyCreateUpdateProxy().CM_CargoGroup;
		pxyCg.CM_CargoGroup.setMyCargoGroupAssignment( pxy );
	endforeach;
	
	foreach cgn in self.allNotifiedCargoGroupByIdDict do
		pxyCgn := cgn.pxyCreateUpdateProxy();
		pxyCgn.setMyCargoGroupAssignment( pxy );
	endforeach;
	
	iter := self.allCargoIdsDict.createIterator;
	while iter.next( obj ) do
		cargoId := iter.getCurrentKey( 1 ).String;
		if cargoId &lt;&gt; null then
			pxy.allCargoIds.add( cargoId );
		endif;
	endwhile;
	
	if not self.allProcessedTis.isEmpty then
		self.allProcessedTis.copy( pxy.allProcessedTis );
	endif;
	
	completedOK := true;
	return pxy;

epilog

	if not completedOK then
		delete pxy;
	endif;
	delete iter;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
