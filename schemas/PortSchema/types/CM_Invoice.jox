Date		Who		Reason
15 April 2016	cnwndl1	Initial creation	TFS 1849

*/

vars

	invNumber	: String;

begin

	invNumber := self.exportCurrencyCode;
	return invNumber;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExternalNumber" id="d513e95d-260f-4d68-a7cd-f9b4281505ea">
        <source>getExternalNumber():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Dec 2022 navtnr20	TFS CR 55308 TASK 55552: UI - Add new attribute to Invoice List columns

*/

