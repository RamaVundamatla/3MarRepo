    <JadeMethod name="getDutyDocInvoiceLineType" id="e8604773-09d7-4094-969d-f4fb52c9cfb6">
        <source>getDutyDocInvoiceLineType() : CM_InvoiceLineDesc;
// Find the the invoice line type for a Duty Documentation charge
// This is a bit of a hack at the moment - should be a configurable option
vars
	terminal	: CM_Terminal;
	bank		: CM_Bank;
begin
	// 35872 use default bank of 1st terminal
	terminal := app.myRoot.allTerminals.first;
	bank := terminal.getDefaultCompanyBank();

	return bank.invoiceLineDescriptors["Duty Documentation"];
epilog

end;</source>
        <ReturnType type="CM_InvoiceLineDesc"/>
    </JadeMethod>
