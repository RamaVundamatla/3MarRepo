    <JadeMethod name="autoCalcVolume" id="3f953713-f443-4d77-9d9a-ee4e5f5b23f5">
        <source>autoCalcVolume() protected;
/* ---------------------------------------------------------------------------
Created:	18 November 2010	by cnwvu1

Purpose:	
   
Change Date		Who			Reason
-----------		--------	--------------------------------------------------
27/03/2013		cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
11/03/2014		cnwdap1		PAR #33603 Correct measurement handling for different locales - can't just convert
							volume to String, and make this method aware of different measurement types at system 
							and cargo type / cargo subtype levels
21/08/2017		cnwma1		TFS #5695 STWO - Re-Calculate Volumes on Forms and EDI
------------------------------------------------------------------------------*/
vars
	volume			: Decimal[16,4];
	volumeType 		: CM_MeasurementType;			// PAR #31155
	cargoSubtype	: CM_Product;					// PAR #33603
	cargoType		: CM_CargoType;					// PAR #33603
	
begin

	//volume := self.myAssistant.autoCalcVolumeWhenNotNull(	txtLength.getInteger(),	// getInteger(),			// PAR #31155
	//														txtWidth.getInteger(),     // getInteger(),			// PAR #31155
	//														txtHeight.getInteger(),    //getInteger() );		// PAR #31155
	//														txtTotalVolume.getDecimal() );  // #26654 			// PAR #31155
	volume := self.myAssistant.autoCalcVolumeWhenNotNull(	self.tblLength.getConvertedValue,					// PAR #31155
															self.tblWidth.getConvertedValue,					// PAR #31155
															self.tblHeight.getConvertedValue,					// PAR #31155
															self.tblTotalVolume.getConvertedValue	);			// PAR #31155
	
	if self.cmbType.getObject &lt;&gt; null then																		// PAR #33603
		cargoType := self.cmbType.getObject.CM_CargoType;
	endif;
	if self.cmbSubCargo.getObject &lt;&gt; null then																		// PAR #33603
		//cargoSubtype := self.cmbProdType.getObject.CM_Product; // 21.08.2017 cnwma1 TFS #5695	
		cargoSubtype := self.cmbSubCargo.getObject.CM_Product;   // 21.08.2017 cnwma1 TFS #5695	
		if cargoSubtype.autoVolumeCalculate then	//10 Jun 2016	NDL	TFS 2141
			//this option uses 'setTotalVolumeFromProdAttrQty' method when 'cmbSubCargo', 'txtNumItems' or 'txtQuantity' gets lost focus 
			return;
		endif;
	endif;
	
	if cargoType &lt;&gt; null then	// 18 Sep 2017	NDL	- Found during generic use
		volumeType:= cargoType.myVolumeMeasurementType;
	endif;
	if volumeType = null then
		volumeType := app.getDefaultMeasurementForType(Type_Volume);	
	endif;
																										// PAR #33603
	self.tblTotalVolume.setValues(app.convertMeasurementForDisplay(volumeType.shortName, volume) &amp; Space &amp; volumeType.shortName);	// PAR #33603
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="autoCalcVolumeQtyPieces" id="737b4af4-1d6c-4b6b-a52f-d6d388395eff">
        <source>autoCalcVolumeQtyPieces()protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2017	cnwma1	TFS #5695:STWO - Re-Calculate Volumes on Forms and EDI

*/

vars
	cargoType : CM_CargoType;
	pieces : Integer;
	qty : Integer;
	w,
	length,
	hight : Decimal[14,4];
	volumeM3 : Decimal [16,4];
	measureType : CM_MeasurementType;
	displayValue : String;
begin
	
	if self.tblTotalVolume.isHidden then
		return;
	endif;

	if self.updateMode &lt;&gt; self.Mode_Add then
		return;
	endif;
	
	cargoType := self.cmbType.getObject().CM_CargoType;
/*	29/3/19 MAP TFS41707
	if cargoType = null or 
		not cargoType.allowAutoVolumeCalc  
	   or not (cargoType.isBreakBulk or cargoType.isBulk) then
		return;
	endif;
*/	
	
	measureType := app.getDefaultMeasurementForType(Type_Volume);	
	
	if measureType = null then
		return;
	endif;
	
	if not self.txtNumItems.isHidden then
		qty := self.txtNumItems.getInteger.max(1);
	endif;
	
	if not self.txtQuantity.isHidden then
		pieces := self.txtQuantity.getInteger.max(1);
	endif;
	
	if not self.tblWidth.isHidden then
		w:= self.tblWidth.getConvertedValue();
	endif;
	
	if not self.tblLength.isHidden then
		length := self.tblLength.getConvertedValue();
	endif;
	
	if not self.tblHeight.isHidden then
		hight := self.tblHeight.getConvertedValue();
	endif;
	
	//volumeM3 := self.tblVolume.getConvertedValue();
	volumeM3 := cargoType.calculateCargoVolume( null,qty,pieces,w,length,hight,null);
	self.tblTotalVolume.setValues(app.convertMeasurementForDisplay(measureType.shortName, volumeM3) &amp; Space &amp; measureType.shortName);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
