    <JadeMethod name="setBaySizeDetails" id="4ed778da-fd8f-4335-a86b-91680acc3697">
        <updating/>
        <source>setBaySizeDetails() updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpHold	: CM_Hold;
	tmpBay	: CM_Bay;
	tmpMaxCells,
	tmpMaxUnder,
	tmpMaxOn	: Integer;
	
begin

	// need to get max widths and heights for displayed bays first
	foreach tmpHold in self.allHolds do
		foreach tmpBay in tmpHold.allBays do

			tmpMaxCells := tmpBay.getNumCellsWide(self.displayMode).max(tmpMaxCells);	// tmpBay.getMaxCells.max(tmpMaxCells);
			
			// PAR 26760 
			if self.displayMode = ShpDisplayMode_Defn then
				tmpMaxOn := tmpBay.allTiersOnDeck.size.max(tmpMaxOn);
				tmpMaxUnder := tmpBay.allTiersUnderDeck.size.max(tmpMaxUnder);
			else
				tmpMaxOn := tmpBay.getNumTiersTotallyAvailable(true).max(tmpMaxOn);
				tmpMaxUnder := tmpBay.getNumTiersTotallyAvailable(false).max(tmpMaxUnder);
			endif;
		endforeach;
	endforeach;
	self.maxCells := tmpMaxCells;
	self.maxTiersOnDeck := tmpMaxOn;
	self.maxTiersUnderDeck := tmpMaxUnder;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setColourFromAllocation" id="167adacf-5ddb-49b7-8763-ecfe5cf26993">
        <source>setColourFromAllocation(_slotController : CM_SlotController) : Integer;
// ---------------------------------------------------------------------------
// Created:     25 March 2010 by cnwab1  // PAR 23426
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _slotController = null then
		return NullColour;
	endif;
	
	if _slotController.mySlotRequestLoad &lt;&gt; null then
		return _slotController.mySlotRequestLoad.getColourForAllocation();
	endif;
	
	return NullColour;
epilog

end;</source>
        <Parameter name="_slotController" type="CM_SlotController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
