    <JadeMethod name="validateAttGenerator" id="d4e843eb-4353-417a-8100-67dee37e175f">
        <source>validateAttGenerator();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2018	jlgma1	Initial creation
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
15 May 2018 cnwma1	Bug 38547: PENN - Gen Set Displayed as onsite when it has left the Terminal
*/

vars
	showErrAsWarn : Boolean;
	genMaster : CM_TIMaster;
	tiMasterAttached :CM_TIMaster;
	masterType : String;
begin
	
	showErrAsWarn := app.myRoot.getConfig(ShowRefGenOpErrAsWarn).Boolean;
	
	if self.isKindOf(CM_TIMasterTILC) then
		masterType := app.getErrorString(Trailer);
	elseif self.isKindOf(CM_TIMasterContainer) then
		masterType := app.getErrorString(ISO_Container);
	endif;
	
	foreach genMaster in self.allTIMasterAttachees do
	
		foreach tiMasterAttached in genMaster.allTIMasterAttachers do
			if tiMasterAttached &lt;&gt; null then			//15.5.2018 cnwma1 Bug 38547 
				if tiMasterAttached.id &lt;&gt; self.id then  //15.5.2018 cnwma1 Bug 38547 
					if tiMasterAttached.isKindOf(CM_TIMasterContainer) then
						app.raiseCMException2(Generator_Linked_Reefer, genMaster.id, tiMasterAttached.id,null,self);
					
					elseif tiMasterAttached.isKindOf(CM_TIMasterTILC) then
						app.raiseCMException2(Generator_Linked_Trailer, genMaster.id, tiMasterAttached.id,null,self);
					
					else
						app.raiseCMException2(Generator_Linked_Generator, genMaster.id, tiMasterAttached.id,null,self);
					endif;
				endif;
			endif;
			
		endforeach;
		
		if self.myOperatorNew.code &lt;&gt; genMaster.myOperatorNew.code then
			if showErrAsWarn then
				app.raiseCMWarning4(Generator_OpMisMatch, genMaster.id, 
									genMaster.myOperatorNew.code,masterType,self.id,self.myOperatorNew.code,null,null);
			else
				app.raiseCMException5(Generator_OpMisMatch, genMaster.id, 
									genMaster.myOperatorNew.code,masterType,self.id,self.myOperatorNew.code,null,null);
			endif;
		endif;
				
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
