    </JadeMethod>
    <JadeMethod name="doClonedMenuClickSpecial" id="0154b2ab-a92e-42f7-ae0d-32099da81946">
        <updating/>
        <source>doClonedMenuClickSpecial(menuItem: MenuItem input) updating, protected;
//----------------------------------------------------------------
//	Created:	14 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 15/06/2010 	cnwcs5	par 24342 - no cloned menu items for stops
vars

	obj	: Object;
	ti : CM_TrackedItem;
	realTiSet : CM_TISet;
	taskFormName : String;
	taskFormNameLength : Integer;
	passedAction : Integer;

begin
	//We need to be a TrackedItem to go through here as opposed to a CM_BOL object.
	obj := menuItem.userObject;
	// 37011 use the form to indicate 
	if obj = self then
		//self.myAssistant.showTasksForm (ti, tiSet, self.mode &lt;&gt; Mode_Update, 1 );
		return;
	endif;

	if not self.isMyCurrentObjectTrackedItem and 
	   not CM_StopsTable.hasInstance(obj) then //ccms 1017 cnwrs1 Aug 2007
		app.raiseCMException1(ERR_Item_Not_TrackedItem, self.myCurrentObject.getName, null, null);
	endif;
	
	if menuItem.helpKeyword = "LOAD" or menuItem.helpKeyword = "DISCHARGE" or menuItem.helpKeyword = "QUEUE" then
		self.doMnuUnplanClick(menuItem);
		

	elseif CM_ToDoTaskDesc.hasInstance(obj) then
		if self.todoTaskMode = TASK_MODE_ADD then
			self.doMenuTaskAddClick(obj.CM_ToDoTaskDesc);
		elseif self.todoTaskMode = TASK_MODE_COMPLETE then
			self.doMenuTaskCompleteClick(obj.CM_ToDoTaskDesc);
		elseif self.todoTaskMode = TASK_MODE_REMOVE then
			self.doMenuTaskRemoveClick(obj.CM_ToDoTaskDesc);
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'invalid todoTaskMode');
		endif;
		return;
	elseif CM_MTGrade.hasInstance(obj) then
		self.doMnuSetGradeClick(obj.CM_MTGrade, menuItem);	
		return;		
	elseif menuItem.helpKeyword = 'YAChild' then
		self.doYardAllocationMenuClick(menuItem);
		return;
	endif;
	
	//06 Oct 2015	NDL	Par 37011
	taskFormName := CMUI_TasksForm.name;
	taskFormNameLength := taskFormName.length;
	if menuItem.helpKeyword.length &gt; taskFormNameLength and menuItem.helpKeyword[1:taskFormNameLength] = taskFormName then
		passedAction := menuItem.helpKeyword[taskFormNameLength + 2:1].Integer;
		create realTiSet transient;
		if not tblData.allSelectedObjects.isEmpty then
			tblData.allSelectedObjects.copy(realTiSet);
		endif;
		ti  := self.myCurrentObject.CM_TrackedItem;
		if ti = null and realTiSet.isEmpty then
			return;
		endif;
		self.myAssistant.showTasksForm (ti, realTiSet, self.mode &lt;&gt; Mode_Update, passedAction );
		return;
	endif;

	inheritMethod(menuItem);
	
epilog

	delete realTiSet;

end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCmbCargoTypeCntntChange" id="8397fc85-0a97-42e7-af2f-fc5517be842c">
        <source>doCmbCargoTypeCntntChange();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/10/2025	navkc1 JIRA 36144
// 20/10/2025 navkc1	MTN JIRA 36367 - Clear Cargo Sub Type and Commodity as we change the Cargo Type for COntents
*/

vars
	cargoTypeForContents 	: CM_CargoType;
	colValue,
	theRow : Integer;
begin
	cargoTypeForContents := self.cmbCargoType4Cntnts.listObject.CM_CargoType;
	
	if cargoTypeForContents &lt;&gt; null then
		colValue := CM_EntryTable.ColumnValue;
		
		// Update Sub Type // 20/10/2025 navkc1	MTN JIRA 36367
		self.cmbProduct.setCargoType(cargoTypeForContents);
		self.cmbProduct.listIndex := -1;
		theRow := self.tblEdit1.getRowByControlName(self.cmbProduct.name);
		if theRow &lt;&gt; null then
			self.tblEdit1.accessCell(theRow, colValue).text := null;
		endif;
		
		// Udate COmmodity // 20/10/2025 navkc1	MTN JIRA 36367
		self.cmbCommodity.listCollection(cargoTypeForContents.allCommodities, true, 0);
		self.cmbCommodity.listIndex := -1; 
		theRow := self.tblEdit1.getRowByControlName(self.cmbCommodity.name);
		if theRow &lt;&gt; null then
			self.tblEdit1.accessCell(theRow, colValue).text := null;
		endif;
		
		
		// If is doing alpha // 20/10/2025 navkc1	MTN JIRA 36367
		if self.isShowingAlphabetised then
			// Update sub type
			theRow := self.tblAlpha.getRowByControlName(self.cmbProduct.name);
			if theRow &lt;&gt; null then
				self.tblAlpha.accessCell(theRow, colValue).text := null;
			endif;
			
			// update Commodity
			theRow := self.tblAlpha.getRowByControlName(self.cmbCommodity.name);
			if theRow &lt;&gt; null then
				self.tblAlpha.accessCell(theRow, colValue).text := null;
			endif;
		endif;
		
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbISOTypeChange" id="d58f8ea4-246f-446a-a5c6-b0ed806bf562">
        <source>doCmbISOTypeChange();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/10/2025	navkc1 JIRA 36144

*/

vars
	isoType	: CM_ISOType; 
	ti 		: CM_TrackedItem;
begin
	isoType := self.cmbISOType.listObject.CM_ISOType;
	ti := self.myProxyObject.CM_TrackedItem;
	
	// ISO Type is for Rotainer, show the Cargo Type for Contents and Cargo Sub Type rows
	if isoType &lt;&gt; null and isoType.isRotatable() then
		self.tblAlpha.showRowByName(ETRow_MyCargoTypeForContents, false);
		self.tblAlpha.showRowByName(ETRow_MyCarProduct, false);
		self.tblEdit1.showRowByName(ETRow_MyCargoTypeForContents, false);
		self.tblEdit1.showRowByName(ETRow_MyCarProduct, false);
	else
		// It is not Rotainer, rebuild the Commodity based on the Cargo Type
		self.cmbProduct.clear();
		
		if ti &lt;&gt; null then
			self.cmbCommodity.listCollection(ti.myCargoType.allCommodities, true, 0);
		endif;
		
		// Hide these rows since it's not Rotainer
		self.tblAlpha.hideRowByName(ETRow_MyCargoTypeForContents, false);
		self.tblAlpha.hideRowByName(ETRow_MyCarProduct, false);
		self.tblEdit1.hideRowByName(ETRow_MyCargoTypeForContents, false);
		self.tblEdit1.hideRowByName(ETRow_MyCarProduct, false);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbProductClick" id="6fabdc24-c8d7-4e8b-92ee-e1916eb8d84d">
        <source>doCmbProductClick(_product : CM_Product) protected;
// ---------------------------------------------------------------------------
// Created:     13 May 2004	cnwth2
//
// Purpose:     If a product has codes associated with any of the string attributes,
//				the corresponding combobox needs to be populated with those codes
// 29/08/2016   cnwma1  TFS #2607:PAR38173 STWO - Unable to edit cargo subtype	 
// ----------   ----------  --------------------------------------------------
vars
	strCode : String;
	editTable	: CM_EntryTable;
begin
	editTable := self.getTableForRow(ETRow_MyProduct);
	
	if editTable = null then //29/08/2016 cnwma1 TFS #2607 PAR #38173
			editTable := self.getTableForRow(ETRow_MyCarProduct);
	endif;
	if self.mode = self.Mode_View or
	   (not editTable.visible) or
	   _product = null then
		return;
	endif;
	
	if _product.myWidthString &lt;&gt; null and
	   _product.myWidthString.validationType = _product.myWidthString.ValidationType_Codes then
		if _product.myWidthString.myCode &lt;&gt; null then
		   strCode := _product.myWidthString.myCode.code;
		endif;
		self.myAssistant.comboBoxProdAttributeCodes(self.cmbWidthCodes, _product.myWidthString, strCode);
	endif;
	
	if _product.myHeightString &lt;&gt; null and
	   _product.myHeightString.validationType = _product.myHeightString.ValidationType_Codes then
	   	if _product.myHeightString.myCode &lt;&gt; null then
		   strCode := _product.myHeightString.myCode.code;
		endif;
		self.myAssistant.comboBoxProdAttributeCodes(self.cmbHeightCodes, _product.myHeightString, strCode);	
	endif;

	if _product.myLengthString &lt;&gt; null and
	   _product.myLengthString.validationType = _product.myLengthString.ValidationType_Codes then
	   	if _product.myLengthString.myCode &lt;&gt; null then
		   strCode := _product.myLengthString.myCode.code;
		endif;
		self.myAssistant.comboBoxProdAttributeCodes(self.cmbLengthCodes, _product.myLengthString, strCode);
	endif;

	if _product.myType &lt;&gt; null and
	   _product.myType.validationType = _product.myType.ValidationType_Codes then
	   	if _product.myType.myCode &lt;&gt; null then
		   strCode := _product.myType.myCode.code;
		endif;
	   
		self.myAssistant.comboBoxProdAttributeCodes(self.cmbTypeCodes, _product.myType, strCode);		
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_product" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="doCmbSearchTableEvent" id="9a06fd61-1d55-40f4-a1c2-799ad8784b70">
        <updating/>
        <source>doCmbSearchTableEvent(combobox: ComboBox input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2019	jlger1	Initial creation 47132

*/

vars
	theCell			: JadeTableCell;
	theRow , newCargoTypeID : Integer;
	obj				: Object;
	value : Any;	
	dependentCrits : CM_SelectorCriteriaLineArray;
	critHolder : CM_QueryCriteriaLineHolder;
	crit,
	dependentCrit : CM_SelectorCriteriaLine;
	depCombo : ComboBox;
	foundIdx  : Integer;
	newCargoType,
	oldCargoType : CM_CargoBOLType;
	checkTableHeight : Boolean;
	invalidCrit : Boolean;
begin
	theRow := combobox.tag.Integer;
	if theRow = 0 or theRow &gt; self.tblSearch.rows then
		return;
	endif;
	theCell := self.tblSearch.accessCell(theRow, CM_EntryTable.ColumnValue);
	obj := self.tblSearch.accessRow(theRow).itemObject;
	
	on Exception do app.handleDeletedObject(exception, crit,invalidCrit);
	if theCell.text &lt;&gt; combobox.text then
		 theCell.text:=combobox.text;
			if obj.isKindOf(CM_SelectorCriteriaLine) then
				crit:=obj.CM_SelectorCriteriaLine;
				value := combobox.listObject;
				if value = null then
					value := combobox.text;
				endif;	
				critHolder:=self.myCriteriaLineHolder;
				if crit.myQueryProperty.propertyName =  CM_TrackedItem::cargoType.name then
					oldCargoType:=app.myRoot.allCargoTypesById[self.filterCargoTypeId];
					if value.isKindOf(CM_CargoBOLType) then				
						newCargoTypeID:=value.CM_CargoBOLType.id;
					else
						newCargoTypeID:=null;
					endif;
					
					
					if self.filterCargoTypeId &lt;&gt; newCargoTypeID then
						if value.isKindOf(CM_BOLType)  then
							self.createDefaultCritLineHolder(value.CM_CargoBOLType,null);
							return;
						elseif (self.filterCargoTypeId &gt; BOLType_Min) and (self.filterCargoTypeId &lt; BOLType_Max)  and value.isKindOf(CM_CargoType) then
							self.createDefaultCritLineHolder(value.CM_CargoBOLType,null);
							return;
						elseif oldCargoType.isKindOf(CM_CargoType) and value.isKindOf(CM_CargoType) then
							if oldCargoType.isCargoGroup &lt;&gt; value.CM_CargoType.isCargoGroup then
								self.createDefaultCritLineHolder(value.CM_CargoBOLType,null);
								return;
							
							endif;	
						endif;
						
						
					endif;
					if value.isKindOf(CM_CargoBOLType) then
						self.setMyCurrentCargoBOLType(value.CM_CargoBOLType);
					else
						self.setMyCurrentCargoBOLType(null);
					endif;
					
					
				endif;
				
				if invalidCrit then
					return;
				endif;
				if crit.myQueryProperty.propertyName = CM_TrackedItem::myTerminalArea.name then
					if value.isKindOf(CM_TerminalArea) then
						self.setFilterTerminalArea(value.CM_TerminalArea);
					else
						self.setFilterTerminalArea(null);
					endif;
					
				endif;
				if crit.myQueryProperty.propertyName = CM_TrackedItem::voyageCode.name then
					if value.isKindOf(CM_Voyage) then
						self.filterVoyage:=value.CM_Voyage;
					else
						self.filterVoyage:=null;
					endif;
				endif;
				if crit.myQueryProperty.propertyName = CM_TrackedItem::operatorCode.name then
					if value.isKindOf(CM_Operator) then
						app.setMyCurrentOperator(value.CM_Operator);
					endif;
				endif;
				
				value := crit.myQueryProperty.translateToSearchValue(value);
			
				crit.myQueryOperator.setSearchValue( value );
			
			
				if critHolder &lt;&gt; null then
					create dependentCrits transient;
					critHolder.getAllDependentCriteria(obj.CM_SelectorCriteriaLine,dependentCrits);
					foreach dependentCrit in dependentCrits do
						if self.tblSearch.findObjectInRow(dependentCrit,foundIdx) then
							checkTableHeight:=true;
							if  not dependentCrit.showCriteria(critHolder) then
								self.tblSearch.hideRow(foundIdx);
								continue;
							else
								self.tblSearch.showRow(foundIdx);
							endif;
						endif;
						
						depCombo:=self.getControlByName("cmbQ" &amp; dependentCrit.propName).ComboBox;
						if depCombo &lt;&gt; null then
							dependentCrit.myQueryOperator.setSearchValue(null);
							dependentCrit.myQueryProperty.setComboValues(depCombo,critHolder,dependentCrit.myQueryOperator,app.myPassport);
							self.tblSearch.accessCell(foundIdx,CM_EntryTable.ColumnValue).text:=null;
						endif;
					endforeach;
				endif;
				
				
			endif;
		endif;
	 
	 if checkTableHeight then
		 self.adjustSearcherHeight;
	endif;
	 
epilog
	delete dependentCrits;
end;</source>
        <access>protected</access>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCompleteMAFILashingToDo" id="702b54d5-974b-460f-bbc9-90361243ed15">
        <updating/>
        <source>doCompleteMAFILashingToDo(_toDoTaskDesc : CM_ToDoTaskDesc input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2022	jlier1	Initial creation
05 Jul 2024 navbs1  CR 64901 Task 64903: UI - Show Cargo Ids in To Do Complete Thin Client

*/

vars
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	pxyTISet 				: CM_TISet;
	result : Integer;
begin
	self.addUpdateTransactionComplete:=true;
	create resourceUsageProxys transient;	// will be populated with template versions of the resources to apply..
	self.myAssistant.showResourceTypeUsageForTxn(null, null, _toDoTaskDesc, self.myCurrentObject.CM_TrackedItem, resourceUsageProxys, true, null);		//05.07.2024  navbs1  CR 64901 Task 64903
	
	create pxyTISet transient;
	pxyTISet.add(self.myProxyObject.CM_TrackedItem);
	
	while true do
		//cnwjo3 par 25879
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(_toDoTaskDesc, pxyTISet, resourceUsageProxys, app.myPassport);

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			if self.ackTodoStop then
				app.msgBox(app.getErrorString1(CT_Task_completed,_toDoTaskDesc.description), app.getString(Info), MsgBox_OK_Only + MsgBox_Information_Icon);
				
			endif;
			break;
		else
			result := app.showErrorWarningDialog(app.getString(Complete_TDTask), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog

	delete pxyTISet;
	
	if resourceUsageProxys &lt;&gt; null then
		resourceUsageProxys.purge;
		delete resourceUsageProxys;
	endif;
	

end;</source>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCreateCriteriaLine" id="19a64aa8-4319-438d-b9b5-86bb6d2efe73">
        <source>doCreateCriteriaLine(	_qDef : CM_QueryDefinition;
						_criteriaHolder : CM_QueryCriteriaLineHolder io;
						_propName : String;
						_qOperatorStr : String;
						_value : Any
						) : CM_SelectorCriteriaLine protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Jan 2014	cnwndl1	Initial creation
27 Nov 2019 cnwer1 TFS 47132 - just returning crit line created
*/

vars

	criteriaLine : CM_SelectorCriteriaLine;

begin
	if _qDef = null or _qDef.allQueryProperties[_propName] = null then
		return null;
	endif;
	criteriaLine := _qDef.createCriteriaLine(_propName, _qOperatorStr, _value);
	criteriaLine.setMyCriteriaLineHolder(_criteriaHolder);
	return criteriaLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
        <Parameter name="_criteriaHolder" type="CM_QueryCriteriaLineHolder" usage="io"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_qOperatorStr" type="String"/>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="CM_SelectorCriteriaLine"/>
    </JadeMethod>
    <JadeMethod name="doDeleteInterTerminalTransfer" id="71c8f8b5-a784-47d8-8ce9-c80ea8f56085">
        <updating/>
        <source>doDeleteInterTerminalTransfer(_ti : CM_TrackedItem input) protected, updating;
// -------------------------------------------
// Created 12 August 2004 by cnwdvb1
// -------------------------------------------
vars

	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	if app.msgBox(app.getErrorString(Delete_Inter_Terminal_Transfer),app.getErrorString(Inter_Terminal_Transfer),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxRemoveTransfer(_ti, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.doRefresh();
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Delete_Inter_Terminal_Transfer), app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFilterSiteClick" id="26f0f109-1a95-406b-9241-e538ef2b8aab">
        <updating/>
        <source>doFilterSiteClick(_filterStateStr : String) updating;
// ---------------------------------------------------------------------------
// Created:     25 September 2002 by cnwth2
//
// Purpose:     
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 04/04/2022	navdap1		TFS 53304 C3L Show Docket for Cargo returns 1086 Error
vars
	rowNameArray		: StringArray;
	showHideRows		: Integer;
begin
	create rowNameArray transient;
	
	// cnwrl1 29/10/2010 PAR 26162 - start of coding
	if self.cmbFiltTiType.listObject &lt;&gt; null and
	   self.cmbFiltTiType.listObject.CM_CargoBOLType.id &lt;&gt; TI_CargoType_Log then
		// C3 in particular want CargoType of "Log" to default "Site/State" to "**Anywhere**"
		self.non_Log_Index := self.cmbFiltSite.listIndex;	// save off the current value
	endif;
	// cnwrl1 29/10/2010 PAR 26162 - end of coding
	
	rowNameArray.add(ETRow_FilterTerminalArea);
	rowNameArray.add(ETRow_FilterYardLocation);
	
	if _filterStateStr = ANYSITE_STRING then
		self.filterState := null;
		showHideRows := CM_EntryTable.ShowRowsOnly;

	elseif _filterStateStr = ONSITE_STRING then
		self.filterState := TI_STATE_NORMAL;
		showHideRows := CM_EntryTable.ShowRowsOnly;

	elseif _filterStateStr = ONSHIP_STRING then
		self.filterState := TI_STATE_ONSHIP;
		showHideRows := CM_EntryTable.HideRowsOnly;

	elseif _filterStateStr = OFFLOADED_STRING then
		self.filterState := TI_STATE_OFFLOADED;
		showHideRows := CM_EntryTable.HideRowsOnly;

	elseif _filterStateStr = OFFSITE_STRING then
		self.filterState := TI_STATE_OFFSITE;
		showHideRows := CM_EntryTable.HideRowsOnly;

	elseif _filterStateStr = NOTIFIED_STRING then
		self.filterState := TI_STATE_NOTIFIED;
		showHideRows := CM_EntryTable.ShowRowsOnly;
	elseif _filterStateStr = TRANSFER_STRING_TO then
		self.filterState := TI_STATE_TRANSFER_TO;
		showHideRows := CM_EntryTable.ShowRowsOnly;
	elseif _filterStateStr = TRANSFER_STRING_FROM then
		self.filterState := TI_STATE_TRANSFER_FROM;
		showHideRows := CM_EntryTable.ShowRowsOnly;
	elseif _filterStateStr = DELETED_STRING then
		self.filterState := TI_STATE_DELETED;
		showHideRows := CM_EntryTable.ShowRowsOnly;		
	else
		self.filterState := TI_STATE_NORMAL;
		showHideRows := CM_EntryTable.ShowRowsOnly;
	endif;

	if self.useSelectorTable then													// TFS 53304
		self.tblSearch.showHideRowsByListSel(rowNameArray, showHideRows, false);	// TFS 53304
	else																			// TFS 53304
		self.tblSearch.showHideRowsByList(rowNameArray, showHideRows, false);	
	endif;																			// TFS 53304
	/*
		Date		Who		Reason
		3 Sep 2008	cnwdz2	Par17808 adjectresize the window size affter select site/state.
	*/
	self.adjustSearcherHeight();
		
epilog
	delete rowNameArray;
end;</source>
        <Parameter name="_filterStateStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="doInstructions" id="211dfa36-a6de-404e-bc53-e7e93089eed5">
        <source>doInstructions();
