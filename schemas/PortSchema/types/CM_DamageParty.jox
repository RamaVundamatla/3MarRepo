    <JadeMethod name="getDisplayStringForAttribute" id="d45fb907-35b2-43a4-848e-6710d56a3a94">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details

*/

vars

begin
	if _attrName = ETRow_IsNotAvailableForEntry then
		return self.isNotAvalableForEntry.String;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
