    <JadeMethod name="cmbBRType_click" id="8f427c7a-98d3-4714-9567-d212c7378117">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBRType_click(combobox: ComboBox input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	01 May 2007 By cnwth2

Purpose:	

Changed On  Changed By  Reason
	
----------  ----------  --------------------------------------------------
11/08/2011	cnwdap1		PAR #27972 Bulk release type no lonber translatable, replaced by string constants
13/03/2019	jlgka1		TFS 41708 Call Methods to populate bol.
*/
vars
	carrier,
	defRailCarrier		: CM_Carrier;
begin
	self.tblEntry.setValueByControlName(combobox.name, combobox.text);
	if combobox.listIndex &lt; 1 then
		return;
	endif;
	
	self.setViewForReleaseType(combobox.itemData[combobox.listIndex], self.tblEntry.getValueByName(ETRow_ReleaseByType).Boolean);
	//jlgka1 TFS 41708 --&gt;
	if self.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then
		self.populateHeaderBillOfLading(combobox.itemData[combobox.listIndex]);
		self.populateBOLDetails();
	endif;
	//jlgka1 TFS 41708 &lt;--
	
	
	//epr par 32568 18/10/13 only reload carrier combo on change of release type because some carriers may not be relevant
	// and try to keep the carrier if possible
	carrier:=self.cmbCarrier.listObject.CM_Carrier;
	self.myAssistant.setCarrierTransportMode(self.cmbCarrier, self.cmbBRType.text);
	self.cmbCarrier.initialise(true);
	self.cmbCarrier.setObject(carrier);	

	if self.cmbBRType.text = BR_TYPE_RAIL_STR and self.mode = self.Mode_Add and self.cmbCarrier.listIndex = -1 then 							// PAR #27972
		defRailCarrier := app.myRoot.allCarriers[self.myTerminal.getConfig(DefRailCarrier).String];
		self.cmbCarrier.setObject(defRailCarrier);
	endif;
	self.cmbCarrier.lostFocus(self.cmbCarrier);
	
end;

</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
