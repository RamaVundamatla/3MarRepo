    <JadeMethod name="timerEvent" id="3bb82882-b3ff-4359-aa75-11ed33f7a7d2">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

/*

Purpose:			Handle timer event to refresh the table if required

Parameters:			Timer event tag

Return Value:		None


Date		Who		Reason
01 Mar 2011	cnwkpd1	PAR #27032 - Load Colour Code performance

*/

vars

begin
	if eventTag = Timer_Tag_Refresh and self.refreshIsQueued then
		self.doRefresh();
	endif;
	
	
epilog

end;</source>
