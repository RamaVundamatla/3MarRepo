    <JadeMethod name="initializeTable" id="aa9a0359-9d00-42ce-85c2-84eb276e6e54">
        <source>initializeTable(pTheTable:Table input) protected;
// --------------------------------------------------------------------------------
// Created:		22 June 2002 by cnwdad1
//
// Purpose:		Initializes the specified table control with the standard headings
//				and column settings.
//
// Parameters:	pTheTable - The table control to initialize.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTable		: Table;
	
begin
	theTable	:=	pTheTable;
	theTable.rows			:=	1;
	theTable.clear();
	theTable.sortColumn[1]	:=	0;
	theTable.sortColumn[2]	:=	0;
	theTable.setCellText(1, 1, "" &amp; Tab &amp; "File Name" &amp; Tab &amp; "Size (KB) " &amp; Tab &amp; "TimeStamp" &amp; Tab &amp; "Attributes");
	
	// Because we want to be able to select multiple rows (and JADE dosn't handle this
	// natively), we'll have to go with multi-cell select, and write our own code to
	// select an entire row when one of its cells is selected.  So in short, this nifty
	// auto row-select is no good to us.
//	theTable.selectMode	:=	Table.SelectMode_CurrentRow;
	theTable.columnVisible[6]	:=	false;
	theTable.columnVisible[7]	:=	false;
	theTable.columnVisible[8]	:=	false;
	theTable.columnVisible[9]	:=	false;
	
	theTable.accessColumn(1).alignment	:=	Table.Alignment_Center;
	theTable.accessColumn(3).alignment	:=	Table.Alignment_Right;
	theTable.accessColumn(5).alignment	:=	Table.Alignment_Center;
end;</source>
        <access>protected</access>
        <Parameter name="pTheTable" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isPathEditable" id="13909a3c-e903-4d26-bc4b-653742f5570d">
        <source>isPathEditable(pPathName:String; pAllPathNames:HugeStringArray; pIsCreateFolder:Boolean io):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		23 July 2002 by cnwdad1
//
// Purpose:		This method will determine whether or not the user can edit the
//				specified directory.
//
//				If the developers have ued the addBasePathName() method on the
//				File Manager interface to restrict access to specific directories,
//				then we will also prevent the user from modifying the restricted
//				directory.  However, the user is free to modify the contents of
//				a restricted directory.
//
// Parameters:	pPathName - The name of the path to check for restrictions.
//				pAllPathNames - An array of restricted directory names.
//				pIsCreateFolder - If true, then a new folder is allowed to be
//					created.  If a base path name exists to restrict user access
//					to specific directories, then the user cannot manipulate files
//					or directories in any directories down to the level of the
//					restricted directory (base path), but they can create a new
//					folder (directory) in the bottom-most directory of the base path.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isEditable			: Boolean;
	isRestrictedPath	: Boolean;
	nodeName			: String;
	nodeNameLength		: Integer;
	checkPathName		: String;
	checkNameLength		: Integer;
	
begin
	if pAllPathNames.isEmpty() then
		isEditable	:=	true;
	else
		nodeName			:=	pPathName.toUpper();
		nodeNameLength		:=	nodeName.length();
		isEditable			:=	false;
		isRestrictedPath	:=	false;
		
		foreach checkPathName in pAllPathNames do
			checkNameLength	:=	checkPathName.length();
			
			if checkPathName[checkNameLength:1] = JSS_SEPARATOR_WIN then
				checkNameLength	:=	checkNameLength - 1;
				checkPathName	:=	checkPathName[1:checkNameLength];
			endif;
			
			if checkNameLength = 0 then
				continue;
			elseif nodeName[1] = checkPathName[1] then
				if nodeName = checkPathName then
					isRestrictedPath	:=	true;
					isEditable			:=	false;
					pIsCreateFolder		:=	true;
					break;		// Cannot edit this directory.
					
				elseif nodeNameLength &lt; checkNameLength then
					if nodeName = checkPathName[1:nodeNameLength] then
						isRestrictedPath	:=	true;
						isEditable			:=	false;
						pIsCreateFolder		:=	false;
						break;
					endif;
					
				elseif checkNameLength &lt; nodeNameLength then
					if checkPathName = nodeName[1:checkNameLength] then
						isRestrictedPath	:=	true;
						isEditable			:=	true;
						pIsCreateFolder		:=	true;
						break;
					endif;
					
				endif;
			endif;
		endforeach;
		
		if (not isRestrictedPath) and (not isEditable) then
			isEditable	:=	true;
		endif;
	endif;
epilog
	return isEditable;
end;</source>
        <access>protected</access>
        <Parameter name="pPathName" type="String"/>
        <Parameter name="pAllPathNames" type="HugeStringArray"/>
        <Parameter name="pIsCreateFolder" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSourceSameAsTarget" id="e5a3eabf-5ebd-41c4-a5e0-dc4c1062c07e">
        <source>isSourceSameAsTarget(pSourcePath:String; pTargetPath:String; pNodeOptions:Integer):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		16 July 2002 by cnwdad1
//
// Purpose:		Returns a flag to indicate whether the source file/directory is the
//				same as the target file/directory.  This is used to prevent copying
//				files or directories to themselves.
//
// Parameters:	pSourcePath - The source path of the file/directory.
//				pTargetPath - The target path of the file/directory.
//				pNodeOptions - The source/target node options flags.
//
// Returns:		True if the source is the same as the target, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isSamePathAndNode	: Boolean;
	
begin
	isSamePathAndNode	:=	false;
	
	if pSourcePath = pTargetPath then
		if (pNodeOptions - JSSFMFileManagerService.NODE_SOURCE_CLIENT) = JSSFMFileManagerService.NODE_TARGET_CLIENT
		or (pNodeOptions - JSSFMFileManagerService.NODE_SOURCE_APPSERVER) = JSSFMFileManagerService.NODE_TARGET_APPSERVER
		or (pNodeOptions - JSSFMFileManagerService.NODE_SOURCE_DBSERVER) = JSSFMFileManagerService.NODE_TARGET_DBSERVER
		then
			isSamePathAndNode	:=	true;
		endif;
	endif;
	
	return isSamePathAndNode;
end;</source>
        <access>protected</access>
        <Parameter name="pSourcePath" type="String"/>
        <Parameter name="pTargetPath" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
