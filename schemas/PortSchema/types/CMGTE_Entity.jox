    <JadeMethod name="setPXYFromController" id="c73d8c9e-d506-4d48-ad8c-f19c23986dbc">
        <updating/>
        <source>setPXYFromController(_flexi : CMIF_FlexiGateController) updating;
// ---------------------------------------------------------------------------
// Created:     19 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 21 FEB 2023      NAVSA20         Bug 56328: EUP Testing | Object Not Found error in Road Gate when saving a Booking
// ---------------------------------------------------------------------------
vars
	subTerminal	: CM_SubTerminal;	
	unique		: Boolean;	
	jobQNumber	: Integer;
	
begin
	// The initial sorting of entities will reflect the order that they have been added
	// Note that positions 1 &amp; 2 are reservered for chassis (in and out)
	if self.jobQueueNum = 0 and _flexi.myVehicleVisitRecord &lt;&gt; null then	
		jobQNumber := _flexi.myVehicleVisitRecord.allGateEntities.size()+2;
		unique := false;			
		while not unique do	
			jobQNumber := jobQNumber + 1;
			unique := _flexi.myVehicleVisitRecord.allGateEntities.getAtKey(jobQNumber) = null;			
		endwhile;		
		self.jobQueueNum := jobQNumber;	
	endif;
	
	self.myTerminal := _flexi.myTerminal;
	self.myTransferToTerminal := _flexi.myTransferToTerminal;
	self.myVehicleVisitRecord := _flexi.myVehicleVisitRecord;
	self.jobType := _flexi.jobType;
	
	self.subTerminalCode := _flexi.subTerminalCode;
	self.companyCode := _flexi.companyCode;
	
	if self.subTerminalCode = null then
		subTerminal := self.myTerminal.getDefaultSubTerminal(	CM_SubTerminal.Type_TrackedItem,
																0,		// cnwdad1 27/01/2010 - PAR #22205.
																_flexi.imexStatus,
																_flexi.commodity,
																true);
		if subTerminal &lt;&gt; null then
			self.subTerminalCode := subTerminal.code;
		endif;
	endif;

	self.description := _flexi.description;
	self.eirNumber := _flexi.eirNumber;
	self.freightForwarderCode := _flexi.freightForwarderCode;
	self.height := _flexi.height;
	self.heightString := _flexi.heightString;
	self.id := _flexi.id;
	self.length := _flexi.length;
	self.lengthString := _flexi.lengthString;
	self.mark := _flexi.mark;
	self.markNumber := _flexi.markNumber;
	self.myBookingRefItem := _flexi.myBookingRefItem;
	/*if self.myBookingRefItem = null then
		self.setmyBookingre
		
	*/	
	self.cargoGroupId := _flexi.cargoGroupId;       //21.02.2023 NAVSA20 TFS 56328
		
		
	self.myProduct := _flexi.myProduct;
	self.operatorCode := _flexi.operatorCode;
	self.quantity := _flexi.quantity;
	self.type := _flexi.type;
//	self.volume := _flexi.volume;
	self.setMyVolume(_flexi.volume);	//18 Jul 2011	NDL	Par 27868
	self.voyageCode := _flexi.voyageCode;
	self.weight := _flexi.weight;
	self.width := _flexi.width;
	self.widthString := _flexi.widthString;
	self.yardLocationTxt := _flexi.yardLocationTxt;
	self.allSourceTAs.clear();  //cnwrd1 par 24169 9.6.2010
	_flexi.allSourceTAs.copy( self.allSourceTAs); //cnwrd1 par 24169 9.6.2010
	self.allSourceTAGridObjs.clear();//cnwrd1 par 28628 5.12.2011
	_flexi.allSourceTAGridObjs.copy( self.allSourceTAGridObjs);  //cnwrd1 par 28628 5.12.2011
	
	self.clientRef 		:= _flexi.clientRef; //cnwrd1 par 23337  19.5.2010
	
	self.directDelivery := _flexi.directDelivery;	//31 Jan 2013	NDL	Par 31102
	
end;</source>
        <Parameter name="_flexi" type="CMIF_FlexiGateController"/>
    </JadeMethod>
