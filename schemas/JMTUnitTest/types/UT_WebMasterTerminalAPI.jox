}
}]';
VoyageWithTradeandPortRot= '[{
"id": "'&amp;Voyage4&amp;'",
"arrivalDT" : "2023-04-05T16:02:25.832611",
"departureDT" : "2023-04-10T16:02:25.832611",
"externalCode": "",
"estimatedArrivalDT" : "2023-04-06T16:02:25.832611",
"estimatedDepartureDT" : "2023-04-10T16:02:25.832611",
"inwardsCode" : "",
"operatorId" : "",
"portRotation" : [{
    "id" : "KRPUS",
    "tranship" : false
}],
"remarks" : "", 
"shippingLineId" : "ABC",
"tradeId" : "&lt;trade&gt;",
"vessel" :{
"id" : "'&amp;Vessel&amp;'",
"imo" : "",
"name" : "Laura Old Vessel",
"callSign" : "", 
"operatorId" : "LAUR",
"loa" : 1 
}
}]';
vars
expectFailure 		: Boolean;
loginJson,
incomingJsonString,
terminalCode,
params,
tradeString			: String;
root 				: CM_Root;
terminal 			: CM_Terminal;
voyage 				: CM_Voyage;
vessel 				: CM_Vessel;
portRotation 		: CM_PortRotation;
expectedTimeStamp	: TimeStamp;

begin
	// do the clean up 
	root := self.getRoot();
	
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	
	terminal := app.myPassport.myTerminal;
	self.assertNotNullMsg(terminal.code, "Terminal Code not set in Unit Test Profile");
	
	deleteVoyage(Voyage);
	deleteVoyage(Voyage2);
	deleteVoyage(Voyage3);
	deleteVoyage(Voyage4);
	deleteVessel(Vessel);
	
	self.opts.purge();
	
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	// trade did not exist on WMAST as different data
	if app.isRunningInDMAST then
		tradeString	:= TradeNameDMAST;
	elseif app.isRunningInWMAST then
		tradeString	:= TradeNameWMAST;
	endif;
// ########################
	self.logMessage("1. Test One create voyage OK request OK and two rotational port but no tranship ports");
// ########################
	incomingJsonString := VoyageJsonString.replace("&lt;trade&gt;", tradeString);
	//incomingJsonString := VoyageJsonString;
	expectFailure := false;
	// create the voyage first
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostVoyage.name, loginJson, incomingJsonString, expectFailure);
	// check yoyage status for creation of voyage without passing status
	voyage := terminal.lookupVoyage(Voyage,null,true);				// 10.07.24		navhn30		TFS #64828
	self.assertEqualMsg(voyage.status, 0, " Initial status for the terminal's voyage process didn't match");
	// TFS 65286 check voyage type
	self.assertTrueMsg(voyage.myGeneralCargoVoyage &lt;&gt; null, "General Cargo structure not set up");
	
	beginTransaction;
	voyage.myHMSVoyageData.setTidalClasses(app.myRoot.allTidalClasses.first,app.myRoot.allTidalClasses.last);
	commitTransaction;
	
	// update the voyage
	incomingJsonString := Voyage2JsonString.replace("&lt;trade&gt;", tradeString);
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutVoyage.name, loginJson, incomingJsonString, params, expectFailure);
	voyage := terminal.lookupVoyage(Voyage,null,true);
	self.assertEqualMsg(voyage.allPortRotations.size = 2, true, "there should be 2 port rotation");
	// check all ports should be 2
	self.assertEqualMsg(voyage.allPorts.size = 2, true, "there should be 2 port");
	portRotation := voyage.allPortRotations.first();
	self.assertNotNullMsg(portRotation, "No Port rotations created");
	// should be no tranship ports
	self.assertEqualMsg(portRotation.allTranshipPorts.size = 0, true, "there should be 0 tranship ports");
	// voyage status checking
	self.assertEqualMsg(voyage.status, 6, "status not matched");
	
	// Check timestamps
	expectedTimeStamp.setDateTime(2023, 04, 06, 02, 02, 25, 0);
	self.assertEqualMsg(voyage.arrivedDT, expectedTimeStamp, "Arrival DateTime not set correctly");
	expectedTimeStamp.setDateTime(2023, 04, 11, 01, 02, 25, 0);
	self.assertEqualMsg(voyage.departedDT, expectedTimeStamp, "Departure DateTime not set correctly");
	expectedTimeStamp.setDateTime(2023, 03, 07, 01, 02, 25, 0);
	self.assertEqualMsg(voyage.estimatedArrivalDT, expectedTimeStamp, "Estimated Arrival DateTime not set correctly");
	expectedTimeStamp.setDateTime(2023, 03, 11, 00, 02, 25, 0);
	self.assertEqualMsg(voyage.estimatedDepartureDT, expectedTimeStamp, "Estimated Departure DateTime not set correctly");
	
	// TFS 65286 check voyage type
	self.assertTrueMsg(voyage.structureIncludesLOLO,"LOLO structure not set up");		//08.08.2024	navhn30	  TFS #65480
	self.assertTrueMsg(voyage.structureIncludesRORO,"RORO structure not set up");
	self.assertTrueMsg(voyage.structureIncludesHolds, "Holds structure not set up");
	//self.assertTrueMsg(voyage.myGeneralCargoVoyage &lt;&gt; null, "General Cargo structure not set up");
	//self.assertTrueMsg(voyage.myROROStructure &lt;&gt; null, "RORO structure not set up");

	
// ########################
	self.logMessage("2. Test Two create/update voyage expect two rotational ports and 2 tranship port");
// ########################
	incomingJsonString := Voyage3JsonString.replace("&lt;trade&gt;", tradeString);
	expectFailure := false;
	// create the voyage first
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostVoyage.name, loginJson, incomingJsonString, expectFailure);
	voyage := terminal.lookupVoyage(Voyage3,null,true);
	// update the voyage
	incomingJsonString := Voyage3JsonString.replace("&lt;trade&gt;", tradeString);
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutVoyage.name, loginJson, incomingJsonString, params, expectFailure);
	voyage := terminal.lookupVoyage(Voyage3,null,true);
	self.assertEqualMsg(voyage.allPortRotations.size = 1, true, "there should be 1 port rotation");
	// check all ports should be 1
	self.assertEqualMsg(voyage.allPorts.size = 1, true, "there should be 1 port");
	portRotation := voyage.allPortRotations.first();
	self.assertNotNullMsg(portRotation, "No Port rotations created");
	// should be no tranship ports
	self.assertEqualMsg(portRotation.allTranshipPorts.size = 1, true, "there should be 1 tranship port");
	
// ########################
	self.logMessage("3. Test Three create check that you cannot change the vessel on voyage");
// ########################
	incomingJsonString := Voyage1JsonString.replace("&lt;trade&gt;", tradeString);
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :91361. Voyage '"&amp;Voyage&amp;"' current vessel is 'Laura Old Vessel and cannot be changed'");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutVoyage.name, loginJson, incomingJsonString, params, expectFailure);
	
// ########################
	self.logMessage("4. Test Four no voyage Id");
// ########################
	incomingJsonString := VoyageNoIdJsonString.replace("&lt;trade&gt;", tradeString);
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :75007. An input is required for the Voyage Id field.");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutVoyage.name, loginJson, incomingJsonString, params, expectFailure);
	
// ########################
	self.logMessage("5. Test Five no vessel Id");
// ########################
	incomingJsonString := NoVesselIdJsonString.replace("&lt;trade&gt;", tradeString);
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :75007. An input is required for the Vessel Id field.");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutVoyage.name, loginJson, incomingJsonString, params, expectFailure);
	
// ########################
	self.logMessage("6. Test Six voyage cannot be found");
// ########################
	incomingJsonString := VoyageIdParamJsonString.replace("&lt;trade&gt;", tradeString);
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :85914. Voyage "&amp;Voyage2&amp;" not found");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutVoyage.name, loginJson, incomingJsonString, params, expectFailure);
	
// ########################
	self.logMessage("7. Test Seven check we can update a single voyage");
// ########################
	params := "/"&amp;Voyage&amp;"";
	incomingJsonString := VoyageIdParamJsonString.replace("&lt;trade&gt;", tradeString);
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutVoyage.name, loginJson, incomingJsonString, params, expectFailure);
	// check that we can find the new voyage Id
	voyage := terminal.lookupVoyage(Voyage2,null,true);
	self.assertNotNullMsg(voyage, "voyage not created");
	
// ########################
	self.logMessage("8. Test Eight No Vessel LOA");
// ########################
	/*
	self.opts.purge();
	incomingJsonString := NoLoa;
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :75007. An input is required for the Vessel LOA field.");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutVoyage.name, loginJson, incomingJsonString, params, expectFailure);
	*/
	

// ########################
	self.logMessage("9. Test Nine the same port in port rotations Json, make sure we only create one port");
// ########################
	self.opts.purge();
	incomingJsonString := Voyage4Json.replace("&lt;trade&gt;", tradeString);
	params := "/"&amp;Voyage4&amp;"";
	expectFailure := false;
	// create the voyage first
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostVoyage.name, loginJson, incomingJsonString, expectFailure);

// navmd1 - this test doesn't make sense - why would we restrict this? We don't in the thin client
/*
	// update the voyage
	incomingJsonString := Voyage4SamePortJson;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutVoyage.name, loginJson, incomingJsonString, params, expectFailure);
	voyage := terminal.lookupVoyage(Voyage4,null,true);
	self.assertEqualMsg(voyage.allPortRotations.size, 1, "there should be 1 port rotation");
	// check all ports should be 2
	self.assertEqualMsg(voyage.allPorts.size, 1, "there should be 1 port");
	portRotation := voyage.allPortRotations.first();
	self.assertNotNullMsg(portRotation, "No Port rotations created");
	// should be no tranship ports
	self.assertEqualMsg(portRotation.allTranshipPorts.size = 0, true, "there should be 0 tranship ports");
*/
	
// ########################
	self.logMessage("10. Test Ten check that port rotations updates correctly");
// ########################
	self.opts.purge();
	incomingJsonString := Voyage4UpdatePort.replace("&lt;trade&gt;", tradeString);
	params := "/"&amp;Voyage4&amp;"";
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutVoyage.name, loginJson, incomingJsonString, params, expectFailure);
	voyage := terminal.lookupVoyage(Voyage4,null,true);
	self.assertEqualMsg(voyage.allPorts.size = 1, true, "there should be 1 port");
	portRotation := voyage.allPortRotations.first();
	self.assertNotNullMsg(portRotation, "No Port rotations created");
	self.assertEqualMsg(portRotation.myPort.code,"KRPUS", "Port rotation MyPort.code should of updated to KRPUS");
	
// ########################
	self.logMessage("11. Test Eleven check that port rotations updates correctly with trade");		//12.02.2024 naviv1 #62354
// ########################
	self.opts.purge();
	incomingJsonString := VoyageWithTrade.replace("&lt;trade&gt;", tradeString);
	params := "/"&amp;Voyage4&amp;"";
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutVoyage.name, loginJson, incomingJsonString, params, expectFailure);
	voyage := terminal.lookupVoyage(Voyage4,null,true);
	self.assertNotNull(voyage.myTrade);
	self.assertEqualMsg(voyage.allPortRotations.size = voyage.myTrade.allPortRotations.size, true,"No of voyage port rotation should be equal to no of trade port rotation");
	
// ########################
	self.logMessage("12. Test Twelve check that port rotations updates correctly with trade and portrotation");		//12.02.2024 naviv1 #62354
// ########################
	self.opts.purge();
	incomingJsonString := VoyageWithTradeandPortRot.replace("&lt;trade&gt;", tradeString);
	params := "/"&amp;Voyage4&amp;"";
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutVoyage.name, loginJson, incomingJsonString, params, expectFailure);
	voyage := terminal.lookupVoyage(Voyage4,null,true);
	self.assertEqualMsg(voyage.allPorts.size = 1, true, "there should be 1 port");
	portRotation := voyage.allPortRotations.first();
	self.assertNotNullMsg(portRotation, "No Port rotations created");
	self.assertEqualMsg(portRotation.myPort.code,"KRPUS", "Port rotation MyPort.code should of updated to KRPUS");
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tPutWorkPointJobSheet" id="8d29bddb-f1b4-4d31-898c-23d04f2d4210">
        <source>tPutWorkPointJobSheet();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Jul 2023	navlw1	ChangeRequest 58336: [58935] EUP | LMS Gang API - Endpoint Unit Tests

*/
constants
WPJS = "UTD-A01E";
WPJS1 = "UTD-B01E";
vars
	incomingJsonString,
	loginJson,
	params,
	terminalCode,
	startDT,
	endDT,
	newStartDT,
	newEndDT,
	jsonString,
	externalRef				: String;
	expectFailure 			: Boolean;
	terminal				: CM_Terminal;
	jobSheet				: CM_WorkPointJobSheet;
	newStartDTT				: TimeStamp;
begin
	
	// setup
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	
	terminal := app.myPassport.myTerminal;
	self.assertNotNullMsg(terminal.code, "Terminal Code not set in Unit Test Profile");
	
	// clean up the data
	jobSheet := terminal.getWorkPointJobSheet(WPJS);
	if jobSheet &lt;&gt; null then // only want to delete it if we find a job sheet
		app.myTrxDA.trxDeleteWorkPointJobSheet(jobSheet, app.myPassport);
	endif;
	self.deleteWorkPoint("UTCFS7");
	
	// date stuff
	startDT := app.actualTimeServer().utcToLocalTime().asJSONFormat;
	endDT := app.actualTimeServer().addDays(1).utcToLocalTime().asJSONFormat;
	
	// add the work point
	self.addWorkPoint("UTCFS7",false);
	
	self.opts.purge();
	
// Json string
jsonString := '{
  "id": "'&amp;WPJS&amp;'",
  "shift": {
    "startDT": "'&amp;startDT&amp;'",
    "endDT": "'&amp;endDT&amp;'",
    "code": "Shift-A",
    "description": "Shift-A"
  },
  "workPointId": "UTCFS7",
  "reference1": "UATTEST",
  "reference2": "EXT2",
  "reference3": "EXT3"
}';
	
/************* Test One create work point job sheet expect OK and check JobSheet has updated********************/
	incomingJsonString := jsonString;
	expectFailure := false;
	params := "/"&amp;WPJS&amp;"";
	// create the work point job sheet first
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostWorkPointJobSheet.name, loginJson, incomingJsonString, params, expectFailure);
	// check that the job sheet has been created
	jobSheet := terminal.getWorkPointJobSheet(WPJS);
	self.assertNotNullMsg(jobSheet, "Jobsheet not created!");
	// update the work point job sheet external reference
	externalRef := "UATTEST1";
	jsonString := '{
  "id": "'&amp;WPJS&amp;'",
  "shift": {
    "startDT": "'&amp;startDT&amp;'",
    "endDT": "'&amp;endDT&amp;'",
    "code": "Shift-A",
    "description": "Shift-A"
  },
  "workPointId": "",
  "reference1": "'&amp;externalRef&amp;'",
  "reference2": "EXT2",
  "reference3": "EXT3"
}';
	incomingJsonString := jsonString;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutWorkPointJobSheet.name, incomingJsonString, params, expectFailure);
	// check that we can find job sheet
	jobSheet := terminal.getWorkPointJobSheet(WPJS);
	self.assertNotNullMsg(jobSheet, "Jobsheet not found");
	// check that the external reference has updated
	self.assertEqualMsg(jobSheet.externalReference1.toUpper(),externalRef.toUpper(),"External Ref 1 should match " &amp; externalRef);
	
/************* Test Two no external name provided, expect fail, check error returned ********************/
	incomingJsonString := jsonString;
	expectFailure := true;
	params := "";
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :" &amp; Input_requir_extern_name_field.String &amp; ". " &amp; app.getErrorString1(Input_requir_extern_name_field, "external Name"));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutWorkPointJobSheet.name, incomingJsonString, params, expectFailure);
	
/************* Test Three cannot find job sheet to update, check error returned ********************/
	jsonString := '{
  "id": "",
  "shift": {
    "startDT": "'&amp;startDT&amp;'",
    "endDT": "'&amp;endDT&amp;'",
    "code": "Shift-A",
    "description": "Shift-A"
  },
  "workPointId": "",
  "reference1": "UATTEST",
  "reference2": "EXT2",
  "reference3": "EXT3"
}';
	incomingJsonString := jsonString;
	expectFailure := true;
	params := "/"&amp;WPJS1&amp;"";
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :" &amp; ERR_JobSheet_Not_Exist.String &amp; ". " &amp; app.getErrorString1(ERR_JobSheet_Not_Exist, WPJS1));
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutWorkPointJobSheet.name, incomingJsonString, params, expectFailure);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uDPManifestSea" id="5782b163-6f4f-4dc2-b7e8-2b248ac2e81e">
        <source>uDPManifestSea();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29 Jun 2023	navdap1		Initial creation TFS 58813 EUP Manifest Instructions
//
constants
	VesselCodeString = "EUP_VES01DP";
	VoyageCodeString = "EUP_VES01DP01";
IncomingJsonString = '{
	"clientRef": "UT_NAVDAP1MANIFESTSEA",
	"messageType": "Transport Manifest",
	"synchronous": false,
	"message":"';
IncomingJsonTrailer = '"	}';
vars
	incomingJsonString,
	terminalCode : String;
	testScenarioName : String;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediFile : CM_EDIFile;
	ediData : CM_EDIData;
	hmsVoyageData : HMS_VoyageData;
	terminal : CM_Terminal;
	workOrder : CM_WorkOrder;
	workOrderDtl : CM_WorkOrderDtl;
	cargoGroup : CM_CargoGroup;
	cargoGroupDtl : CM_CargoGroupDetail;
	errorMsg : String;
begin
	
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
		terminal := CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	terminal := CM_Root.firstInstance.allTerminals[terminalCode];
	
	// before deleting the voyage cleanup the cargoGroups and WorkOrderReceives
	voyage := self.getVoyage(VoyageCodeString);
	if voyage &lt;&gt; null then
		foreach cargoGroupDtl in voyage.allCargoGroupDetails do
			cargoGroup := cargoGroupDtl.myCargoGroup;
			if cargoGroup &lt;&gt; null then
				write "Delete CargoGroup="&amp;cargoGroup.id;
				self.deleteCargoGroup(cargoGroup.id);
			endif;
		endforeach;
		foreach workOrderDtl in voyage.allWOReceives do
			workOrder := workOrderDtl.myParent;
			if workOrder &lt;&gt; null then
				write "Delete WorkOrder="&amp;workOrder.id;
				self.deleteWorkOrderNoValidation(workOrder.id);
			endif;
		endforeach;
	endif;
	self.deleteVoyage(VoyageCodeString);
	self.deleteVessel(VesselCodeString);
	
	//Create a general cargo vessel
	vessel := self.addVesselGeneralCargo(VesselCodeString, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), 10);
	self.assertNotNullMsg(vessel, "Add vessel failed");
	
	//Create a general cargo voyage 
	voyage := self.addVoyageWithGeneralCargoStruc(VoyageCodeString, 
												  VesselCodeString,
												  self.getProfileSetting(UT_Profile.P_OPERATOR).asString, 
												  self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString,
												  10);
	self.assertNotNullMsg(voyage, "Add voyage failed");
	beginTransaction;
	create hmsVoyageData persistent;
	hmsVoyageData.setMyHarbour(terminal.myHarbour);
	hmsVoyageData.setDefaultBerthPreferences(app.myPassport); 
	voyage.setHMSVoyageData(hmsVoyageData);
	commitTransaction;
	
	testScenarioName := "ManifestSea|AutumnDay";
	incomingJsonString := IncomingJsonString &amp; self.zDPSeaExampleWithInstructions.Binary.base64EncodeNoCrLf() &amp; IncomingJsonTrailer;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostSendEDI.name, incomingJsonString, testScenarioName);
	return;
	foreach ediFile in CM_EDIFile.instances reversed where ediFile.ediClientRef = "UT_JLIRS1MANIFESTSEA" do
		beginTransaction;
write ediFile.ediClientRef&amp;"::"&amp;ediFile.String;
		ediData := ediFile.ediData;
		ediFile.erase(0);
		ediData.erase(0);
		commitTransaction;
		break;
	endforeach;
	ediFile	:=	self.ediLoadFileName(self.zDPSeaExampleWithInstructions, EDIFileType_TransportManifest, "Transport Manifest", "1" &amp; method.name);
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertTrueMsg(ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);

	cargoGroup := terminal.allCargoGroupsByIdCargoType.getAtKeyGeq("F100012502/1REEL", null).CM_CargoGroup;
	if cargoGroup &lt;&gt; null and cargoGroup.id = "F100012502/1REEL" then
		write "CargoGroup F100012502/1REEL found";
	endif;
	cargoGroup := terminal.allCargoGroupsByIdCargoType.getAtKeyGeq("F100012502/2REEL", null).CM_CargoGroup;
	if cargoGroup &lt;&gt; null and cargoGroup.id = "F100012502/2REEL" then
		write "CargoGroup F100012502/2REEL found";
	endif;
	workOrder := terminal.allWorkOrders["F100012502/1"];
	if workOrder &lt;&gt; null and workOrder.isKindOf(CM_WorkOrderTI) then
		workOrderDtl := workOrder.allWoDtls.first;
		write "Found first workOrder and tis are "&amp;workOrderDtl.CM_WodReceive.allSelectedTIs.size.String;
	endif;
	workOrder := terminal.allWorkOrders["F100012502/2"];
	if workOrder &lt;&gt; null and workOrder.isKindOf(CM_WorkOrderTI) then
		workOrderDtl := workOrder.allWoDtls.first;
		write "Found second workOrder and tis are "&amp;workOrderDtl.CM_WodReceive.allSelectedTIs.size.String;
	endif;

	self.assertEqual(ediFile.ediData.CM_EDIDataTransManifest.myShipManifest.allEDITrackedItems.size, 39);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uGetExample" id="e8eb749c-a38a-4dfe-8a08-2e1765aa4f61">
        <source>uGetExample();
/*

Purpose:			

