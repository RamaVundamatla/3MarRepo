    <JadeMethod name="getDateTimeLocalTZ" id="a225ac44-be39-4489-b1a8-44d0908c7978">
        <source>getDateTimeLocalTZ():TimeStamp;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
19 May 2016	cnwns1	TFS 488 - Multi Timezone Support

*/

vars

begin
	return self.systemToLocalTime(self.dateTime);
	
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="5158f796-26e3-45b8-91b6-2bc8f74b74f9">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theString : String;

begin
	if _attrName = ETRow_SequenceNum  then
		return self.sequenceNum.String;	
	elseif _attrName = ETRow_Code  then
		if self.myCharge &lt;&gt; null and self.myCharge.service &lt;&gt; null then		// 36965 handle null service
			return self.myCharge.service.name;
		else
			return null;
		endif;
	elseif _attrName = ETRow_Status  then
		return self.statusDescription;
	elseif _attrName = ETRow_Description  then
		if (not self.isDeleted) then
			if self.previousCost &lt;&gt; self.newCost then
				//theString :=  "Rate " &amp; self.previousCost.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true) &amp; " =&gt; " &amp; 
					//self.newCost.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true);
				// TFS 36954 MPD 20 Feb 2018
				theString :=  "Rate " &amp; self.previousCost.asStringJMTWithPrecision(self.getRateEntryDecimalPlaces, true) &amp; " =&gt; " &amp;
					self.newCost.asStringJMTWithPrecision(self.getRateEntryDecimalPlaces, true);
			else
					theString := "No Change.";
			endif;
		else
			//theString := "DELETED. Unit cost was " &amp; self.previousCost.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, true);
			theString := "DELETED. Unit cost was " &amp; self.previousCost.asStringJMTWithPrecision(self.getRateEntryDecimalPlaces, true);		// TFS 36954 MPD 20 Feb 2018
		endif;
		return theString;
	elseif _attrName = ETRow_User  then
		return self.userId;	
	elseif _attrName = ETRow_EndDate  then
		return self.dateTime.String;	
	elseif _attrName = ETRow_Ti  then
		if self.myCharge &lt;&gt; null and self.myCharge.invoiceLine &lt;&gt; null then
			return self.myCharge.invoiceLine.invoiceLineDesc.narration;
		else
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="statusDescription" id="69fc8f93-a4ee-42b4-9246-85be3ac9f051">
        <methodInvocation>mapping</methodInvocation>
        <source>statusDescription(set: Boolean; _value: String io) mapping;

vars

begin
	if set then
		// set code here
	else
		// get code here
		
		if self.status = self.Status_Create then
			_value :=  "Created";
		elseif self.status = self.Status_Update then
			_value :=  "Updated";
		elseif self.status = self.Status_Delete then
			_value :=  "Deleted";
		elseif self.status = self.Status_Reset then
			_value :=  "Reset";
		else
			_value :=  "";
		endif;
	endif;

end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
