    <JadeMethod name="transformMessage" id="d342626c-17b3-4e37-8bff-01850bb775d9">
        <updating/>
        <source>transformMessage(from:StringUtf8; to_:StringUtf8; topic:StringUtf8; headersXML:StringUtf8; body:StringUtf8; result:StringUtf8 output; logMessages:StringUtf8 output):Boolean updating;
	// 

vars
	_p1 : StringUtf8;
	_p2 : StringUtf8;
	_p3 : StringUtf8;
	_p4 : StringUtf8;
	_p5 : StringUtf8;

begin

	_p1 := from;
	_p2 := to_;
	_p3 := topic;
	_p4 := headersXML;
	_p5 := body;


	return jadeDotNetMethodio('TransformMessage', _p1, _p2, _p3, _p4, _p5, result, logMessages).Boolean;

end;
</source>
        <wsdlName>TransformMessage</wsdlName>
        <Parameter name="from" type="StringUtf8"/>
        <Parameter name="to_" type="StringUtf8"/>
        <Parameter name="topic" type="StringUtf8"/>
        <Parameter name="headersXML" type="StringUtf8"/>
        <Parameter name="body" type="StringUtf8"/>
        <Parameter name="result" type="StringUtf8" usage="output"/>
        <Parameter name="logMessages" type="StringUtf8" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
