    <JadeMethod name="shouldAuditProperty" id="34b14031-4fc6-49d9-b455-e5abd4fa33af">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
//----------------------------------------------------------------
//	Created:	29 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 04 May 2012	cnwrs1		Par 29531 - EDI Data auditing
// 04 Sep 2012	cnwcs5		par 30064 - do not audit status of processDateTime as they are not changed by user
//6/3/2025 navsaa30 TFS 20518 MTN - Notify user when a background DB Load has completed
vars
	propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if propName = CM_EDIData::allEDITrackedItems.name or
		propName = CM_EDIData::allErrorWarnings.name or
		propName = CM_EDIData::allExtraData.name or
		propName = CM_EDIData::ediConfig.name or
		propName = CM_EDIData::ediFileArray.name or
		propName = CM_EDIData::myBayPlanController.name or
		propName = CM_EDIData::myEDIFile.name or
		propName = CM_EDIData::myOperator.name or
		propName = CM_EDIData::mySubTerminal.name or
		propName = CM_EDIData::nodeName.name or
		propName = CM_EDIData::parseDatesForLocale.name or
		propName = CM_EDIData::processDate.name or				// par 30064 Sep 2012
		propName = CM_EDIData::processDateTime.name then			// par 30064 Sep 2012
		//propName = CM_EDIData::status.name then					// par 30064 Sep 2012 //comment line 6/3/25 navsaa30 #20518
		return false;
	endif;
	
	return inheritMethod(_rootClass, _property);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
