    <JadeMethod name="set" id="9f1848df-4374-4e4e-ad7d-c6ba1fb5c72c">
        <updating/>
        <source>set(_fileName : String; _csvBlob : Binary; _reportTemplate : CM_ReportTemplate; _fileStorageHdr : CM_FileDataHeader) updating;

vars

begin

	self.csvBlob 					:= _csvBlob;
	self.fileName					:= _fileName;
	self.myReportTemplate			:= _reportTemplate;
	self.myFileDataStorageHeader	:= _fileStorageHdr;

end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_csvBlob" type="Binary"/>
        <Parameter name="_reportTemplate" type="CM_ReportTemplate"/>
        <Parameter name="_fileStorageHdr" type="CM_FileDataHeader"/>
    </JadeMethod>
</Class>
