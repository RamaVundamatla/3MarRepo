    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <PrimAttribute name="includeDisplayNeverVoyages" id="85fc3b9d-f1a4-438a-a5ae-c1a27967c707">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="isDisplayByVesselName" id="c90f776d-791f-4ac9-8c66-14b0c1770a84">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="displayEntry" id="15e31294-9bea-4acf-83cf-6e8426f57951">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _voyageGlobalObj: CM_VoyageGlobal; lstIndex: Integer): String updating, clientExecution;
//--------------------------------------------------
// Created:	25 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	now : TimeStamp;
	failedDAC  :CM_DataAccessController;
begin
	if _voyageGlobalObj = null then
		return null;
	endif;
	if (not _voyageGlobalObj.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;
	if self.myObject = _voyageGlobalObj then	
		self.hasDirtyObject := true;
	
	elseif (not self.includeDisplayNeverVoyages) then
	endif;
	
	if self.isDisplayByVesselName then
		
		if _voyageGlobalObj.vesselName &lt;&gt; null then
			return _voyageGlobalObj.vesselName.trimBlanks &amp;  " - (" &amp; _voyageGlobalObj.code.trimBlanks &amp; ")" ;
		else
			return _voyageGlobalObj.code.trimBlanks;		
		endif;
	else
		return _voyageGlobalObj.getId();
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_voyageGlobalObj" type="CM_VoyageGlobal"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="b697cbe3-3b18-47c4-8124-a57392057b37">
        <source>getCollectionJMT(): Collection protected;
//--------------------------------------------------
// Created:	25 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	term : CM_Terminal;
begin
	return app.myRoot.allVoyagesGlobal;
end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
