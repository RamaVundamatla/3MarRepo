    <JadeMethod name="unloadForm" id="a02db0ed-b69c-4572-93d8-0c6bf0d61184">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>unloadForm(): Boolean updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date			  Who		Reason
01 September 2022 navcs2  	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot

*/

vars

begin
	if (self.mode = self.MODE_ADD or self.mode = self.MODE_BULK_ADD) and not self.isProxyUsed then
		delete myPxyVehicleBookTimeSlotItem;
	endif;
	
	return inheritMethod();

epilog

end;</source>
