    <JadeMethod name="valTBAMatch" id="025430ea-66e5-4d2e-af78-2b5683b07e49">
        <source>valTBAMatch(pProxyWLE : CM_WorkListEntry);
//--------------------------------------------------------------
//Created: 04 March 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNull(pProxyWLE, 'WLE Proxy');
	self.raiseExceptionIfNull(pProxyWLE.myTrackedItem, 'WLE trackedItem');
	pProxyWLE.myTrackedItem.validateForTBAMatch();

end;</source>
        <Parameter name="pProxyWLE" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="valTIChangeID" id="68cd77fa-73e4-4d76-a662-d1716ef7a714">
        <source>valTIChangeID(_ti : CM_TrackedItem; _newId : String);

vars

	newTi		: CM_TrackedItem;
	terminal	: CM_Terminal;
	location	: CM_LocationsController;

begin

	if _ti = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Tracked Item', null, null);
		app.raiseCMException(Input_required_field_trkdItem, null, null); // cnwdb2	PAR 35364
	endif;
	location := _ti.getPrimaryLocation(REAL_MODE);
	if location = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Location', null, null);
		app.raiseCMException(Input_required_field_location, null, null); // cnwdb2	PAR 35364


	endif;
	terminal := location.myTerminal;
	if terminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', null, null);
		app.raiseCMException(Input_required_field_terminal, null, null); // cnwdb2	PAR 35364
	endif;
	
	if terminal.lookupTrackedItem(_newId, _ti.cargoType, TI_STATE_NORMAL, null, false) &lt;&gt; null then
		app.raiseCMException1(UniqueIdRequired, null, null, null);
	endif;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_newId" type="String"/>
    </JadeMethod>
    <JadeMethod name="valTIConsigneeConsignor" id="f530e941-cc60-4fb8-83bf-e529861cdc41">
        <source>valTIConsigneeConsignor(pIncorrectConsign, pCorrectConsign : CM_ConsigneeConsignor);
//--------------------------------------------------------------
//Created: November 2001 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.raiseExceptionIfNull(pIncorrectConsign, 'Incorrect Consignee/Consignor');
	self.raiseExceptionIfNull(pCorrectConsign, "Correct Consignee/Consignor");

epilog
	
end;</source>
        <Parameter name="pIncorrectConsign" type="CM_ConsigneeConsignor"/>
        <Parameter name="pCorrectConsign" type="CM_ConsigneeConsignor"/>
    </JadeMethod>
    <JadeMethod name="valTIForCustomClearance" id="579a309c-1a82-4fe5-a224-7965a629d26a">
        <source>valTIForCustomClearance(_pxyTI: CM_TrackedItem; _ediCustomTI: CM_EDICustomStopTI; _passport: CM_Passport input);
//----------------------------------------------------------------
//	Created:	18 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//11 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window

vars

begin

	if _pxyTI.isExport then
		if (_ediCustomTI.responseStatus &lt;&gt; Customs_Export_Cleared 
		and _ediCustomTI.responseStatus &lt;&gt; Customs_Export_Cancel
		and _ediCustomTI.responseStatus &lt;&gt; SEP_ContainerRelease
		and _ediCustomTI.responseStatus &lt;&gt; SEP_ContainerCancellation
		and _ediCustomTI.responseStatus &lt;&gt; EDIFileType_XMLOneStopCust.String //09 Sep 2016	NDL	TFS 2278 / 2670
		and _ediCustomTI.responseStatus &lt;&gt; EDIFileType_XMLOneStopEIDO.String //03 Oct 2016	NDL	TFS 2718 / 2536
		and not _ediCustomTI.hasValidTSWResponse(false) // TFS 39133
		and _ediCustomTI.responseStatus &lt;&gt; SEP_InspectionRequired) then
			app.raiseCMWarning3(CUSTOM_DELIVERY_ORDER_CHECK, _pxyTI.getImExStatusStringDesc(true), _pxyTI.id, _ediCustomTI.responseStatus.String, 'responseStatus', _ediCustomTI, _pxyTI);
		endif;
	elseif _pxyTI.isImport then
		if (_ediCustomTI.responseStatus &lt;&gt; Customs_Import_Cleared 
		and _ediCustomTI.responseStatus &lt;&gt; CustomsX12_Hold1C
		and _ediCustomTI.responseStatus &lt;&gt; Customs_Import_Cancel 
		and _ediCustomTI.responseStatus &lt;&gt; CustomsX12_Hold1H
		and _ediCustomTI.responseStatus &lt;&gt; MAF_ContainerCancellation
		and _ediCustomTI.responseStatus &lt;&gt; MAF_ActionRequired 
		and _ediCustomTI.responseStatus &lt;&gt; EDIFileType_XMLOneStopCust.String //09 Sep 2016	NDL	TFS 2278 / 2670
		and _ediCustomTI.responseStatus &lt;&gt; EDIFileType_XMLOneStopEIDO.String //03 Oct 2016	NDL	TFS 2718 / 2536
		and not _ediCustomTI.hasValidTSWResponse(true) // TFS 39133
		and _ediCustomTI.responseStatus &lt;&gt; Customs_Deliver_BreakBulk) then
			app.raiseCMWarning3(CUSTOM_DELIVERY_ORDER_CHECK,  _pxyTI.getImExStatusStringDesc(true), _pxyTI.id, _ediCustomTI.responseStatus.String, 'responseStatus', _ediCustomTI, _pxyTI);
		endif;
	elseif _pxyTI.isTranshipItem then
		if (_ediCustomTI.responseStatus &lt;&gt; Customs_Export_Cleared //cnwrs1 par 25961 5 oct 2020 partail fix
		and _ediCustomTI.responseStatus &lt;&gt; Customs_Export_Cancel //cnwrs1 par 25961 5 oct 2020 partail fix
		and _ediCustomTI.responseStatus &lt;&gt; Customs_Tranship_Cleared
		and _ediCustomTI.responseStatus &lt;&gt; EDIFileType_XMLOneStopCust.String //09 Sep 2016	NDL	TFS 2278 / 2670
		and _ediCustomTI.responseStatus &lt;&gt; EDIFileType_XMLOneStopEIDO.String //03 Oct 2016	NDL	TFS 2718 / 2536
		and _ediCustomTI.responseStatus &lt;&gt; Customs_Tranship_Cancel)then
			app.raiseCMWarning3(CUSTOM_DELIVERY_ORDER_CHECK,  _pxyTI.getImExStatusStringDesc(true), _pxyTI.id, _ediCustomTI.responseStatus.String, 'responseStatus', _ediCustomTI, _pxyTI);
		endif;
	endif;
	
	
end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem"/>
        <Parameter name="_ediCustomTI" type="CM_EDICustomStopTI"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valTIPriorToWhousePacking" id="52be71d5-407c-43a8-8b4f-676b44cd03fe">
        <updating/>
        <source>valTIPriorToWhousePacking(_pxyTI : CM_TrackedItem; _pxyRelease : CM_BulkRelease; _bookingItem : CM_BookingRefItem; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
// 02/06/2015	cnwdap1		PAR #36231 Make sure we can't release more than the booking has asked for
//							Change availability grade message to a warning
// 10/07/2015	cnwdap1		PAR #36484 Container can be in Storage MT or Packing Target subterminal
// 01/10/2015	cnwdap1		PAR #36988 Release and Booking no longer have to be linked
//
vars
	realTI			: CM_TrackedItem;
	extraMessage 	: String;
	subTerminalMT	: CM_SubTerminal;
	subTerminalPack	: CM_SubTerminal;				// PAR #36484
	isoType			: String;
	isoGroup		: String;
	requested,										// PAR #36231
	received		: Integer;						// PAR #36231
	subTermMTCode : String;
	subTermPackCode  : String;
begin
	// container must be available for release, and in the Depot sub-terminal
	realTI := _pxyTI.pxyGetRealObject();
	if not _pxyTI.isAvailableForSubTerminal(realTI.mySubTerminal, extraMessage, true) then
		app.raiseCMException3(TI_TestReqAvailable, _pxyTI.id, 'Unavailable for Release', "Available for release" &amp; extraMessage, null, null);
		return;
	endif;
	if _pxyTI.myTerminal.isSubTerminalsOn then
		subTerminalMT := _pxyTI.myTerminal.getConfig(MySubTerminalForStorageMTY).CM_SubTerminal;
		subTerminalPack := _pxyTI.myTerminal.getConfig(MySubTerminalForTargetBulk).CM_SubTerminal;		// PAR #36484
		extraMessage := null;
		if not _pxyTI.isAvailableForSubTerminal(subTerminalMT, extraMessage, false) 
		and not _pxyTI.isAvailableForSubTerminal(subTerminalPack, extraMessage, false) then				// PAR #36484
			app.raiseCMException3(TI_TestReqAvailable, _pxyTI.id, 'Unavailable for Release', "Available for release" &amp; extraMessage, null, null);
			return;
		endif;
		if realTI.mySubTerminal &lt;&gt; subTerminalMT 
		and realTI.mySubTerminal &lt;&gt; subTerminalPack then												// PAR #36484
			//app.raiseCMException2(Container_not_in_subterminal, _pxyTI.id, subTerminalMT.code, null, null);						// PAR #36484
			if subTerminalMT &lt;&gt; null then
				subTermMTCode:=subTerminalMT.code;
			endif;
			if subTerminalPack &lt;&gt; null then
				subTermPackCode:=subTerminalPack.code;
			endif;
			app.raiseCMException3(Container_not_in_subterminal, _pxyTI.id, subTermMTCode, subTermPackCode, null, null);	// PAR #36484
			return;
		endif;
	endif;
	// check availability grade against TI
	if not _pxyRelease.getAllAvailabilityGrades.isEmpty and not _pxyRelease.getAllAvailabilityGrades.includes(_pxyTI.getAvailabilityGrade) then
		//app.raiseCMException2(Avail_grade_that_does_match_re, _pxyTI.id, _pxyTI.getAvailabilityGrade.String, null, null);			// PAR #36231
		app.raiseCMWarning2(Avail_grade_that_does_match_re, _pxyTI.id, _pxyTI.getAvailabilityGrade.String, null, null, null);		// PAR #36231
		//return;																													// PAR #36231
	endif;
	
	// container must be for the release's operator and iso type
	if not _pxyTI.operatorCode = _pxyRelease.myOperator.code then
		app.raiseCMException2(Conta_opera_does_not_match_rel, _pxyTI.operatorCode, _pxyRelease.myOperator.code, null, null);
		return;
	endif;
	isoType := _pxyRelease.getISOCode;
	if isoType &lt;&gt; null and isoType &lt;&gt; _pxyTI.getISOType then
		app.raiseCMException3(TI_TestReqISO, _pxyTI.id, _pxyTI.getISOType, isoType, null, null);
		return;
	endif;
	isoGroup := _pxyRelease.getISOGroupCode;
	if isoType = null and isoGroup &lt;&gt; null and isoGroup &lt;&gt; _pxyTI.getISOTypeGroup.code then
		app.raiseCMException3(TI_TestReqISOGroup, _pxyTI.id, _pxyTI.getISOTypeGroup.code, isoGroup, null, null);
		return;
	endif;
	
	// PAR #36231 Is this container exceeding the number of containers requested by the booking?
	//requested := _pxyRelease.myBookingRefStock.getTotalQuantity;									// PAR #36988
	//received := _pxyRelease.myBookingRefStock.numTIs;												// PAR #36988
	requested := _bookingItem.getQuantity;															// PAR #36988
	received := _bookingItem.getRecievedCount;														// PAR #36988
	//if received &gt;= requested and not _pxyRelease.myBookingRefStock.allTIs.includes(realTI) then	// PAR #36988
	if received &gt;= requested and realTI.myBookingRefItem &lt;&gt; _bookingItem then						// PAR #36988
		app.raiseCMException1(MTRequestExceedsNumBulkRequest, _pxyRelease.code &amp; ' (' &amp; requested.String &amp; ' items requested)', ETRow_Quantity, null);
		return;
	endif;
	// PAR #36231 end
	
epilog

end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem"/>
        <Parameter name="_pxyRelease" type="CM_BulkRelease"/>
        <Parameter name="_bookingItem" type="CM_BookingRefItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valTITransaction" id="8e746cfa-b494-41af-a6d9-3cb14e72881b">
        <source>valTITransaction(_tiTransactionController : CMIF_TITransactionController input; _origTrans : CM_TITransaction; _theTI : CM_TrackedItem; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     20 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	theClass : Class;
begin

	// PAR 8848
	if (not _tiTransactionController.validate) then
		return;
	endif;
	
	self.raiseExceptionIfNull(_origTrans, '_origTrans');
	
	_origTrans.validateCMIF_TITransCntrl(_tiTransactionController);
	
	theClass := global.getTiTxnClassForType(_tiTransactionController.type, true);

	if theClass = null then
		return;
	endif;
		
	if theClass = CM_Connect or  theClass = CM_ConnectPower or  theClass = CM_ConnectTower
	or theClass = CM_DisconnectPower or  theClass = CM_DisconnectTower then
		_theTI.checkDateConnectDisconnect(_tiTransactionController.dateTime, true);
	endif;

end;</source>
        <Parameter name="_tiTransactionController" type="CMIF_TITransactionController" usage="input"/>
        <Parameter name="_origTrans" type="CM_TITransaction"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valTIsBulkReleased" id="a8c04b58-1d10-44f3-ac39-561a3fb9235a">
        <source>valTIsBulkReleased(_tiSet : CM_TISet;
					_realBulkRelease : CM_BulkRelease;
					_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     23 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	ti		: CM_TrackedItem;
begin
	
	foreach ti in _tiSet do
		if ti.site &lt;&gt; TI_SITE_ONSITE then
			app.raiseCMException2(ERR_MUST_BE, ti.id, TI_SITE_ONSITE_str, null, null);
		endif;
		
		//if ti.isHeldForRelease and ti.myBulkReleaseReleased &lt;&gt; _realBulkRelease then
		//	app.raiseCMException2(ERR_TI_ALREADY_ALLOCATED, ti.id, ti.allBulkReleasesAssigned.first.code, null, null);
		//endif;
	endforeach;
	

end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_realBulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valTSWWebService" id="6628ec80-8952-4145-a29b-8bbb228f8053">
        <source>valTSWWebService(_existingTSWWebSevice, _pxyTSWWebService : CM_TSWWebService);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/08/2016	cnwdap1		Initial creation TFS #1832 TSW Changes
// 10/07/2020	jlgdap1		TFS 49714 POL TSW Web Service Definition Deleted while in use
//
vars
	tswTask : CM_AutoTaskTSWWebService;		// TFS 49714

begin
	self.raiseExceptionIfNull(_pxyTSWWebService, 'TSW Web Service Proxy');
	self.raiseExceptionIfNull(_existingTSWWebSevice, "TSW Web Service Existing");
	_pxyTSWWebService.raiseExceptionIfNotProxy(method);
	if _existingTSWWebSevice.name = _pxyTSWWebService.name then
		_pxyTSWWebService.validateForUpdate;
	else
		// TFS 49714 start
		foreach tswTask in CM_AutoTaskTSWWebService.instances discreteLock do
			if tswTask.name = _existingTSWWebSevice.name then
				app.raiseCMException2(Service_used_by_task, _existingTSWWebSevice.name, tswTask.description, null, null);
			endif;
		endforeach;
		// TFS 49714 end
		_pxyTSWWebService.validateForCreate;
	endif;
epilog

end;</source>
        <Parameter name="_existingTSWWebSevice" type="CM_TSWWebService"/>
        <Parameter name="_pxyTSWWebService" type="CM_TSWWebService"/>
    </JadeMethod>
    <JadeMethod name="valTaskAllocateMachine" id="59472468-9b36-4c1f-b7f6-82a51f25c1fd">
