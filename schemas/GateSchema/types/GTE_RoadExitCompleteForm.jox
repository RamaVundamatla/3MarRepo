	inheritMethod();
	self.initComboTrailers();
	self.initComboTrackedItem();
	self.initTblWorkEntries();
	self.initCmbCopies();
	self.doChkPrintReceiptCheck();
	self.armNotesForObject(self.myJob);
	self.doShowJobInfo();
epilog

end;</source>
