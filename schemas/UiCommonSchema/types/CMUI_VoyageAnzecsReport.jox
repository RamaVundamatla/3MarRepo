<GUIClass name="CMUI_VoyageAnzecsReport" id="e26e6338-467a-4983-aaed-a4a8da57daaa">
    <superclass name="CMUI_ReportBaseForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="myJRWVoyageSummary" id="ae5e87b3-8aba-41e1-99fa-c23dbbcf7ea7">
        <embedded/>
        <type name="CM_JRWVoyageSummary"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="picJadeLogo" id="5ee1c3c3-b1e3-4367-9702-2bdb5b1354c9">
        <embedded/>
        <type name="CMUI_Picture"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="picPortLogo" id="8a3ca1b2-fbdc-4c4a-a8a1-bfcf868f9e2a">
        <embedded/>
        <type name="CMUI_Picture"/>
    </ImplicitInverseRef>
    <JadeMethod name="doLoad" id="105636c5-0620-4c37-9820-66548fbf35ff">
        <source>doLoad();
// ---------------------------------------------------------------------------
// Created:     10 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tp			: CM_GenericTablePrint;
	progress	: CMS_Progress;
begin
	self.setupControls();
	self.setupHeader();
	self.populateTable();
	
	app.printer.setHeader(self.frmHeader);
	create tp transient;
	create progress transient;
	tp.printTable(self.tblReport, true, progress);
//	app.printer.print(self.frmTable);

epilog
	delete tp;
	delete progress;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateTable" id="11d7a1a0-bc4b-4576-aeb8-bdf22329320b">
        <source>populateTable() protected;
// ---------------------------------------------------------------------------
// Created:     10 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	voySummary				: CMIF_VoyageSummary;
	tbl						: Table;
	generalJEDUK,
	generalContinental,
	generalOther,
	northBoundEmpties,
	generalWeight,
	reeferJEDUK,
	reeferContinental,
	reeferOther,
	reeferWeight,
	totalWeight,
	total40s				: String;
	row						: Integer;
	iter					: Iterator;
	summaryDict				: CMIF_VoyageSummaryByValueDict;
	totalStr				: String;
	
begin
	summaryDict := self.myJRWVoyageSummary.allVoyageSummaryObjects;
	tbl := self.tblReport;
	//setup column and rows headings////////////////
	
	tbl.columns := 12;
	tbl.fixedColumns := 1;
	tbl.sortColumn[1] := 1;
	tbl.sortAsc[1] := true;
	
	//setup heading//////////////////////////////
	tbl.addItem('Oper' &amp; Tab &amp;
				'JED' &amp; CrLf &amp; 'or U.K.' &amp; Tab &amp;
				'CONT.' &amp; Tab &amp;
				'OTHER' &amp; Tab &amp;
				'N/BND' &amp; CrLf &amp; 'MTS' &amp; Tab &amp;
				'GEN+MTS' &amp; CrLf &amp; 'DWT' &amp; Tab &amp;
				'JED' &amp; CrLf &amp; 'or U.K.' &amp; Tab &amp;
				'CONT.' &amp; Tab &amp;
				'OTHER' &amp; Tab &amp;
				'REEFER' &amp; CrLf &amp; 'DWT' &amp; Tab &amp;
				'Total' &amp; CrLf &amp; 'DWT' &amp; Tab &amp; 
				'40');
	tbl.fixedRows := 1;
	tbl.accessRow(1).alignment := tbl.Alignment_Center_Middle;
	tbl.accessedRow.fontBold := true;
	////////////////////////////////////////////////
	iter := summaryDict.createIterator;
	
	while iter.next(voySummary) do
		
		if voySummary.generalJEDUK &lt;&gt; null then
			generalJEDUK := voySummary.generalJEDUK.String;
		endif;
		
		if voySummary.generalContinental &lt;&gt; null then
			generalContinental := voySummary.generalContinental.String;
		endif;
		
		if voySummary.generalOther &lt;&gt; null then
			generalOther := voySummary.generalOther.String;
		endif;
		
		if voySummary.northBoundEmpties &lt;&gt; null then
			northBoundEmpties := voySummary.northBoundEmpties.String;
		endif;
		
		if voySummary.generalWeight &lt;&gt; null then
			generalWeight := (voySummary.generalWeight / 1000).Integer.String;
		endif;
		////////////////////////////////////////////////////
		//reefer values
		if voySummary.reeferJEDUK &lt;&gt; null then
			reeferJEDUK := voySummary.reeferJEDUK.String;
		endif;
		
		if voySummary.reeferContinental &lt;&gt; null then
			reeferContinental := voySummary.reeferContinental.String;
		endif;
		
		if voySummary.generalOther &lt;&gt; null then
			reeferOther := voySummary.reeferOther.String;
		endif;
		
		if voySummary.reeferWeight &lt;&gt; null then
			reeferWeight := (voySummary.reeferWeight / 1000).Integer.String;
		endif;
		
		if voySummary.totalWeight &lt;&gt; null then
			totalWeight := (voySummary.totalWeight / 1000).Integer.String;
		endif;
		
		if voySummary.total40s &lt;&gt; null then
			total40s := voySummary.total40s.String;
		endif;
		row := tbl.addItem(voySummary.keyValue1 &amp; Tab &amp;
						generalJEDUK &amp; Tab &amp;
						generalContinental &amp; Tab &amp;
						generalOther &amp; Tab &amp;
						northBoundEmpties &amp; Tab &amp;
						generalWeight &amp; Tab &amp;
						reeferJEDUK &amp; Tab &amp;
						reeferContinental &amp; Tab &amp;
						reeferOther &amp; Tab &amp;
						reeferWeight &amp; Tab &amp;
						totalWeight &amp; Tab &amp; 
						total40s);
		
		tbl.accessRow(row).alignment := tbl.Alignment_Right_Middle;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="run" id="d64c5172-36fd-4419-ace7-c1044b8321ae">
        <updating/>
        <source>run(_isPrintPreview: Boolean; _isCSV: Boolean; _extraDetail: CM_ExtraDetail): Binary updating;
// ---------------------------------------------------------------------------
// Created:     10 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	inheritMethod(_isPrintPreview,_isCSV, _extraDetail);
	app.printer.printPreview := _isPrintPreview;
	app.printer.setMargins(Print_Landscape,0,0,10,10);
	self.myJRWVoyageSummary := app.myQAFilter.allJRWTransients.first.CM_JRWVoyageSummary;
	if self.myJRWVoyageSummary.allVoyageSummaryObjects.isEmpty then
		return null;
	endif;
	self.doLoad();
	return null;

epilog
	app.printer.close;
end;</source>
        <Parameter name="_isPrintPreview" type="Boolean"/>
        <Parameter name="_isCSV" type="Boolean"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setNoDataDisplay" id="c74f04de-c225-4cbe-b178-4c922950e296">
        <source>setNoDataDisplay();
// -------------------------------------------
// Created 23 September 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	
	
	self.lblNoData.caption := 'No Data To Display For Voyage Ansecs Report';


end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="f99bfe34-fd35-41c9-81d2-b54f1b234d1d">
        <source>setupControls() protected;
// ---------------------------------------------------------------------------
// Created:     10 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
constants
	Gap = 10;
vars

begin
	self.tblReport.gridLines := true;
	self.tblReport.fontName := 'Arial';
	self.tblReport.fontSize := 8;
	self.tblReport.visible := true;
	self.frmTable.visible := true;
	
	self.frmTable.left := Gap;
	self.frmTable.width := self.width - Gap * 2;
	self.frmTable.height := (self.height - self.frmHeader.height) - Gap;
	
	self.tblReport.left := self.tblReport.parent.left;
	self.tblReport.width := self.tblReport.parent.width;
	self.tblReport.height := self.tblReport.parent.height;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupHeader" id="016f6ad2-7066-46b7-b6de-04e612c9562e">
        <source>setupHeader() protected;
// ---------------------------------------------------------------------------
// Created:     07 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
constants
	Gap = 5;
vars

begin
	self.frmHeader.height := 145;
	self.lblPage.top := self.lblPrinted.top;
	self.lblHeading3_1.top := self.lblPrinted.top;
	self.lblHeading3_1.left := self.lblHeading3_1.left - Gap;
	
	self.lblTerminalName.visible := false;
	self.lblReportId.visible := false;
	self.lblPrinted.top := self.picPortLogo.top + self.picPortLogo.height + Gap;
	self.lblPrinted.left := self.lblPrinted.left - 10;
	self.lblPrintedDtl.top := self.lblPrinted.top;
	self.lblPrintedDtl.left := self.lblPrintedDtl.left - 10;
	self.lblPrintTime.top := self.lblPrinted.top;
	self.lblPrintTime.left := self.lblPrintTime.left - 15;
	
	self.picJadeLogo.picture := app.getPicLogoProduct;
	self.picPortLogo.picture := app.getPicLogoPort;
	self.picJadeLogo.zOrder(1);
	self.picPortLogo.zOrder(1);
	
	self.lblHeading1.caption := self.myJRWVoyageSummary.myVoyage.code &amp; ' - ' &amp; 
							self.myJRWVoyageSummary.myVoyage.vesselName.trimBlanks &amp; ' - Anzecs Report';
	self.lblHeading1.alignment := self.lblHeading2.Alignment_Center_Middle;
	self.lblHeading1.top := 10;
	self.lblHeading1.height := 20;
	self.lblHeading1.fontSize := 12;
	self.lblHeading1.fontBold := true;
	
	self.lblHeading2.caption := self.myJRWVoyageSummary.orderedByHeading1 &amp; ' by ' &amp; self.myJRWVoyageSummary.orderedByHeading2;
	self.lblHeading2.alignment := self.lblHeading2.Alignment_Center_Middle;
	self.lblHeading2.top := 40;
	self.lblHeading2.height := 20;
	self.lblHeading2.fontSize := 12;
	self.lblHeading2.fontBold := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
