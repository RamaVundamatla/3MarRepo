epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="73e52870-3b7a-4664-8a1d-fd4342ce2e96">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes

*/

vars
	theForm	: SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_WOJobGroupTbl);
	
	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_WOJobGroup);
	theForm.shtTblInput1.visible := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="e283087e-1081-44eb-9be1-e568a4ff0f47">
        <updating/>
        <source>showThumbnail(_woJobGroup : CM_WorkOrderJobGroupMethod) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes
*/

vars
	theForm 	: SOP_TableMaintForm;
	objArrAvail,
	objArrSel,
	objArr		: CM_ObjectArray;
	crit		: CM_Association;
	critInt		: Integer;
begin
	theForm := self.myForm;
	theForm.tblInput1.clearValues();
	
	theForm.loadLstWODtlType(_woJobGroup.allWorkOrderDetailTypes);
	theForm.tblInput1.setValueByName(ETRow_Code, 				_woJobGroup.code);
	theForm.tblInput1.setValueByName(ETRow_Description, 		_woJobGroup.description);
	theForm.tblInput1.setValueByName(ETRow_IsNotAvailForEntry,	_woJobGroup.isNotAvailableForEntry);
	theForm.tblInput1.setValueByName(ETRow_WorkOrderType,		_woJobGroup.getWOdtlType());
	
	create objArrAvail transient;
	create objArrSel transient;
	create objArr transient;
	theForm.mulSelect1.getAvailable(objArrAvail);
	theForm.mulSelect1.getSelected(objArrSel);
	foreach critInt in _woJobGroup.allGroupingCriteria do
		foreach crit in objArrAvail as CM_Association do
			if critInt = crit.getValue().Integer then
				objArr.add(crit);
			endif;
		endforeach;
		foreach crit in objArrSel as CM_Association do
			if critInt = crit.getValue().Integer then
				objArr.add(crit);
			endif;
		endforeach;
	endforeach;
	theForm.mulSelect1.setSelected(objArr);
	theForm.mulSelect1.cnEcResizeContents();
	
	theForm.mulSelect2.setSelected(_woJobGroup.allVessels);
	theForm.mulSelect2.cnEcResizeContents();
epilog
	delete objArrAvail;
	delete objArrSel;
end;</source>
        <Parameter name="_woJobGroup" type="CM_WorkOrderJobGroupMethod"/>
    </JadeMethod>
</Class>
