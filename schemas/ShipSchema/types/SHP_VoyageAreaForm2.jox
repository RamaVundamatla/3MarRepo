    <JadeMethod name="enableDisableWorkModes" id="1b8cfd72-f55e-4a0c-bfc9-c6ea4866f83a">
        <source>enableDisableWorkModes(_visible, _enabled : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     08 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.btnJobsMode.visible		:= _visible;
	self.btnSequenceMode.visible	:= _visible;
	self.btnPlanningMode.visible	:= _visible;

	if _visible then
		self.btnJobsMode.enabled		:= _enabled;
		self.btnSequenceMode.enabled	:= _enabled;
		self.btnPlanningMode.enabled	:= _enabled;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_visible" type="Boolean"/>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findContextSlot" id="e70bd9c3-8cda-495c-bc35-7f691c2243fd">
        <source>findContextSlot(slotRequest : CM_SlotRequest input) : CM_SlotRequest;
// answer the slot to use as context for creating the Assign Release Context Menu
// If no slot selected, then answer the slot the mouse is over
// If slot(s) selected, then answer the first slot in selection
// slots must be same job
vars
	contextSlot : CM_SlotRequest;
	slotRequestLoad : CM_SlotRequest;
	selectedObject : Object;
begin
	if self.workingMode = WorkMode_Plan then
		if self.myBayDrawingController.allSelectedObjects.size = 0 then
			// No slots selected
			if slotRequest.myJob &lt;&gt; null then
				contextSlot := slotRequest;
			endif;
		else
			// One or more slots selected
			foreach selectedObject in self.myBayDrawingController.allSelectedObjects do
				if selectedObject.isKindOf(CM_SlotController) and
				   selectedObject.CM_SlotController.mySlotRequestLoad &lt;&gt; null then
					slotRequestLoad := selectedObject.CM_SlotController.mySlotRequestLoad;
					// All selected slots must be in same job and not completed
					if slotRequestLoad.myJob = null then
						contextSlot := null;
						break;
					endif;
					// Slot request should not have been completed
					if slotRequestLoad.isComplete then
						contextSlot := null;
						break;
					endif;
					// Make sure nothing is already planned to this slot
					if selectedObject.CM_SlotController.hasPlannedTIs(self.displayMode = ShpDisplayMode_ColCodeLoad) then
						contextSlot := null;
						break;
					endif;
					
					// The first selected slot is used as the context
					if contextSlot = null then
						contextSlot := slotRequestLoad;
					endif;

					if contextSlot.myJob &lt;&gt; slotRequestLoad.myJob then
						contextSlot := null;
						break;
					endif;
				endif;
			endforeach;
		endif;
	endif;
	
	return contextSlot;

end;
</source>
        <Parameter name="slotRequest" type="CM_SlotRequest" usage="input"/>
        <ReturnType type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="frmBay_dblClick" id="66048c63-05db-4bfc-b7ab-6b2d83d7a61d">
        <controlMethod name="CMUI_GridAreaDrawingFrame::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmBay_dblClick(frame: SHP_BayDrawingFrame input) updating;
// ---------------------------------------------------------------------------
// Created:     26 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theObj 	: Object;
	theSlot	: CM_SlotController;
	ti		: CM_TrackedItem;
	numTIs	: Integer;
begin
	app.mousePointer := MousePointer_HourGlass;
	theObj := frame.getObjectForPosition(self.origXPos.Integer, self.origYPos.Integer); 
	
	if theObj = null or (not theObj.isKindOf(CM_SlotController)) then
		return;
	endif;
	
	theSlot := theObj.CM_SlotController;
	if theSlot = null then
		return;
	endif;
	
	ti := theSlot.getTIForDisplayMode(self.displayMode, 0, numTIs);
	
	if ti &lt;&gt; null then
		self.myAssistant.showCargoEnquiryForm(ti, self.myMasterMenuAction, true, false);	
	endif;
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="frame" type="SHP_BayDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="frmBay_dragDrop" id="b369fbae-5e51-485c-9aa6-e7f52d5b64a0">
        <controlMethod name="Frame::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmBay_dragDrop(frame: SHP_BayDrawingFrame input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     26 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
begin
	if self.workingMode = WorkMode_Plan
	or self.displayMode = ShpDisplayMode_Actual
	then
		self.doGridAreaDragDropEvent(frame, win, x, y);
	else
		if frame.isDrawDeskTopRectangle then
		
		else
			app.msgBox("Can only drag drop in Planning Mode or when viewing Actuals","Drag Drop Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		endif;
	endif;
end;</source>
        <Parameter name="frame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
