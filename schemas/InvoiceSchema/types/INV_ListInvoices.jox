// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	an : CM_InvoiceDesc;

begin
	self.tblInvProperties.setValueByControlName(combobox.name, combobox.text);
	an := combobox.listObject.CM_InvoiceDesc;
	
	if an.invoiceKey = CM_InvoiceDesc.Key_Voyage then
		self.tblInvProperties.enableRowByName(ETRow_Voyage);
	else
		self.tblInvProperties.disableRowByName(ETRow_Voyage);
		self.cmbVoyageInvProp.listIndex := -1;
		self.tblInvProperties.setValueByName(ETRow_Voyage,null);
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbInvTypeInv_click" id="5ffcbd5f-9db0-4912-a588-33080c17cf37">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbInvTypeInv_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 25 Jan 2021 	cnwma1 	Bug 50665: ASPA - Separation of a list of cargo items by terminal
// 23 Sep 2022	navpw1	TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
// ---------------------------------------------------------------------------

vars
	an 	           : CM_InvoiceDesc;
	theTable	   : CM_EntryTable;
	invoiceProcess : CM_InvoiceProcess; // TFS 39618
	cargoTypeCol   : CM_CargoTypeSet;
begin
	theTable := self.tblInvProperties;
	
	theTable.setValueByControlName(combobox.name, combobox.text);
	
	an := combobox.listObject.CM_InvoiceDesc;
	if an = null then
		app.msgBox("Please select a valid invoice type,","Invoice Type Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		combobox.listIndex := -1;
		theTable.setValueByControlName(combobox.name, combobox.text);
		return;
	endif;
	invoiceProcess := app.getInvoiceProcess(self.myTerminal, self.myCurrentInvoice);
	self.cmbStatusInvProp.listIndex := 1;
	theTable.setValueByControlName(self.cmbStatusInvProp.name, app.getInvoiceStatusString(invoiceProcess, CM_Invoice.INVOICE_PENDING)); //app.getErrorString(Pending)); // TFS 39618
	theTable.showRowByName(ETRow_StatusInvoiceManual, false);
	
	theTable.disableRowByName(ETRow_ArrivalTS);
	theTable.disableRowByName(ETRow_DepartureTS);
	theTable.disableRowByName(ETRow_VoyageDesc);
	theTable.disableRowByName(ETRow_Voyage);
	self.cmbVoyageInvProp.listIndex := -1;
	theTable.setValueByName(ETRow_Voyage,null);
	theTable.hideRowByName(ETRow_Voyage,false);
	theTable.hideRowByName(ETRow_ArrivalTS,false);
	theTable.hideRowByName(ETRow_DepartureTS,false);
	theTable.hideRowByName(ETRow_VoyageDesc,false);
	theTable.hideRowByName(ETRow_CargoType, false);
	theTable.hideRowByName(ETRow_CargoId, false);
	theTable.hideRowByName(ETRow_CargoOperator,false);	//12 Dec 2019	NDL	TFS 47954
	theTable.hideRowByName(ETRow_CargoTA,false);	//12 Dec 2019	NDL	TFS 47954
	theTable.hideRowByName(ETRow_CargoLocation,false);	//12 Dec 2019	NDL	TFS 47954
	theTable.hideRowByName(ETRow_ReceivedDT, false);
	theTable.hideRowByName(ETRow_ReleaseDT, false);
	theTable.disableRowByName(ETRow_ReceivedDT);
	theTable.disableRowByName(ETRow_ReleaseDT);
	
	//if an.isVoyageSpecific() then
	if an.isVoyageSpecificDebtor(null) then // ### TFS 54565 (54384) 22Sep2022 NAVPW1 - No invoice here not sure what to do
		if self.cmbVoyageInvProp.listCount &lt;= 1 then
			self.doCmbVoyageBuild(self.cmbVoyageInvProp,true,null); // PAR 10715
		endif;
		theTable.enableRowByName(ETRow_Voyage);
		
		theTable.setValueByName(ETRow_ArrivalTS,null);
		theTable.setValueByName(ETRow_DepartureTS,null);
		theTable.setValueByName(ETRow_VoyageDesc,null);
		
		theTable.showRowByName(ETRow_Voyage,false);
		theTable.showRowByName(ETRow_ArrivalTS,false);
		theTable.showRowByName(ETRow_DepartureTS,false);
		theTable.showRowByName(ETRow_VoyageDesc,false);
		
	//elseif an.isCargoItemSpecific() then
	elseif an.isCargoItemSpecificDebtor(null) then // ### TFS 54565 (54384) 22Sep2022 NAVPW1 - No invoice here not sure what to do
		if self.cmbCargoTypeInvP.listCount &lt;= 1 then
			//self.cmbCargoTypeInvP.listCollection( app.myRoot.allCargoTypesById, false, 0);  //25.01.2021 cnwma1 #50665
			
			create cargoTypeCol transient;                                                    //25.01.2021 cnwma1 #50665
			self.myTerminal.getAllCargoTypes(cargoTypeCol,true);
			self.cmbCargoTypeInvP.listCollection( cargoTypeCol, false, 0); 
		endif;
		self.populateCargoOperLocns();	//13 Dec 2019	NDL	TFS 47954
		theTable.setValueByName(ETRow_CargoType,null);
		theTable.setValueByName(ETRow_CargoId,null);
		theTable.setValueByName(ETRow_CargoOperator,null);	//12 Dec 2019	NDL	TFS 47954
		theTable.setValueByName(ETRow_CargoTA,null);	//12 Dec 2019	NDL	TFS 47954
		theTable.setValueByName(ETRow_CargoLocation,null);	//12 Dec 2019	NDL	TFS 47954
		theTable.setValueByName(ETRow_ReceivedDT,null);
		theTable.setValueByName(ETRow_ReleaseDT,null);
		theTable.showRowByName(ETRow_CargoType, false);
		theTable.showRowByName(ETRow_CargoId, false);
		theTable.showRowByName(ETRow_CargoOperator,false);	//12 Dec 2019	NDL	TFS 47954
		theTable.showRowByName(ETRow_CargoTA,false);	//12 Dec 2019	NDL	TFS 47954
		theTable.showRowByName(ETRow_CargoLocation,false);	//12 Dec 2019	NDL	TFS 47954
		theTable.showRowByName(ETRow_ReceivedDT, false);
		theTable.showRowByName(ETRow_ReleaseDT, false);
		
	else
		// nothing to do whem invoiceKey = None
	endif;
	
	self.resizeInvPropFrame(); //epr par 36958 29/9/15
	
epilog
	delete cargoTypeCol;
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
