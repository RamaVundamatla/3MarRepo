    <JadeMethod name="getFirstRailArea" id="bc306877-4957-47fe-85d4-43e3bee1665b">
        <source>getFirstRailArea() : CM_Rail;
// ---------------------------------------------------------------------------
// Created:     03 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 11 Jan 2011		cnwkpd1			PAR #26678 - Tidy up transient leaks
// ---------------------------------------------------------------------------

vars	
	iter : Iterator;
	terminalArea : CM_TerminalArea;
begin
	iter := self.myTerminal.allTerminalAreasByTypeId.createIterator();
	self.myTerminal.allTerminalAreasByTypeId.startKeyGeq(TA_TYPE_RAILWAY_TRACK, null, iter);

	while iter.next(terminalArea) do
		if iter.getCurrentKey(1).Integer = TA_TYPE_RAILWAY_TRACK then
			return terminalArea.CM_Rail;
		endif;
	endwhile;
	
	return null;

epilog
	delete iter;		// PAR #26678
end;</source>
        <ReturnType type="CM_Rail"/>
    </JadeMethod>
    <JadeMethod name="getIndexForXmlStrTblDataArray" id="d1843e7b-d37c-4930-832e-fe6a96449468">
        <source>getIndexForXmlStrTblDataArray() : Integer;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/03/2011	cnwdap1	Initial creation PAR #27166 CCMS POL 2001 Separate column organisers for Inwards / Outgoing
*/
vars

begin
	if self.optDirInTB.value then
		return 1;
	elseif self.optDirOutTB.value then
		return 2;
	else
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="Integer"/>
