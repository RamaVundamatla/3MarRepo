    <JadeMethod name="setDefaultProxyRules" id="53931455-4247-414a-ad99-ec3eddaccb64">
        <updating/>
        <source>setDefaultProxyRules(_fromHeight: Integer; _isIn: Boolean) updating;
//----------------------------------------------------------------
//	Created:	07 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	pxyRule					: CM_YADeckingRule;
	rule 					: Integer;
	defaultDeckingOptions	: CM_YADeckingOptions;
begin
	defaultDeckingOptions := self.getDeckingOptionsForDefault();
	
	if defaultDeckingOptions = null then
		create pxyRule transient;
		if _isIn then
			rule := self.getDefaultRuleIn(_fromHeight);
			self.allDeckingRulesIn.add(pxyRule);
		else
			rule := self.getDefaultRuleOut(_fromHeight);
			self.allDeckingRulesOut.add(pxyRule);
		endif;
		
		pxyRule.setProxyBasic(rule, null, null, _isIn);
		return;		//do not continue
	endif;
	
	//-----------------------------------------
	//	Copy from the found decking options
	//-----------------------------------------
	
	if _isIn then
		self.copyInRules(defaultDeckingOptions);
	else
		self.copyOutRules(defaultDeckingOptions);
	endif;
	
end;</source>
        <Parameter name="_fromHeight" type="Integer"/>
        <Parameter name="_isIn" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="8c94fc98-648e-4009-b169-52972413b509">
        <updating/>
        <source>setForCreate(_pxyDeckingOpts: CM_YADeckingOptions) updating;
//----------------------------------------------------------------
//	Created:	07 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	deckingRule		: CM_YADeckingRule;
begin
	
	self.setForUpdate(_pxyDeckingOpts, DeckingLevel_TA);

end;</source>
        <Parameter name="_pxyDeckingOpts" type="CM_YADeckingOptions"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e7506096-a677-4877-9fd1-7b645444840f">
        <updating/>
        <source>setForUpdate(_pxyDeckingOpts: CM_YADeckingOptions; _updateToLevel: Integer) updating;
//----------------------------------------------------------------
//	Created:	11 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
20 Mar 2009	cnwkpd1	PAR #19194 - Replace isValidObject with exception handler for performance

*/

vars
	pxyOptions		: CM_YADeckingOptions;
	newDR,
	deckingRule		: CM_YADeckingRule;
	locnCell		: CM_YALocationCell;
	invalidCell		: Boolean;
	
begin

	pxyOptions := _pxyDeckingOpts;
	
	self.showHeightsForCustom := pxyOptions.showHeightsForCustom;
	self.useReverseOfIn := pxyOptions.useReverseOfIn;

	if not pxyOptions.allDeckingRulesIn.isEmpty then
		self.allDeckingRulesIn.purge();
		foreach deckingRule in pxyOptions.allDeckingRulesIn do
			create newDR persistent;
			newDR.setForCreate(deckingRule);
			self.allDeckingRulesIn.add(newDR);
		endforeach;
	else
		if self.allDeckingRulesIn.isEmpty then
			//should have at least default
			create deckingRule transient;
			pxyOptions.allDeckingRulesIn.add(deckingRule);
			deckingRule.setProxyBasic(DeckingRule_Default, null, null, true);
			create newDR persistent;
			newDR.setForCreate(deckingRule);
			self.allDeckingRulesOut.add(newDR);
			delete deckingRule;
		endif;
	endif;
	
	if not pxyOptions.allDeckingRulesOut.isEmpty then
		self.allDeckingRulesOut.purge();
		foreach deckingRule in pxyOptions.allDeckingRulesOut do
			create newDR persistent;
			newDR.setForCreate(deckingRule);
			self.allDeckingRulesOut.add(newDR);
			if deckingRule.deckingRuleType = DeckingRule_ReverseOfOther then
				self.useReverseOfIn := true;
			endif;
		endforeach;
	else
		if self.allDeckingRulesOut.isEmpty then
			//should have at least default
			create deckingRule transient;
			pxyOptions.allDeckingRulesOut.add(deckingRule);
			deckingRule.setProxyBasic(DeckingRule_ReverseOfOther, null, null, false);
			create newDR persistent;
			newDR.setForCreate(deckingRule);
			self.allDeckingRulesOut.add(newDR);
			self.useReverseOfIn := true;
			delete deckingRule;
		endif;
	endif;

	// The proxies collection is not automatically updated via the inverse if
	// yard locations are deleted so need to check for invalids	
	on Exception do app.handleDeletedObject(exception, locnCell, invalidCell);			// PAR #19194

	self.allYALocationCellsIn.clear;

	//foreach locnCell in _pxyDeckingOpts.allYALocationCellsIn do
	foreach locnCell in _pxyDeckingOpts.allYALocationCellsIn where locnCell &lt;&gt; null do	//11 feb 2011	NDL Par 24181
		invalidCell := false;
		exclusiveLock(locnCell);
		if not invalidCell then
			self.allYALocationCellsIn.add(locnCell);
		endif;
	endforeach;
	
//	_pxyDeckingOpts.allYALocationCellsIn.copy(self.allYALocationCellsIn);
	
	self.allYALocationCellsOut.clear;
//	
//	foreach locnCell in _pxyDeckingOpts.allYALocationCellsOut do
	foreach locnCell in _pxyDeckingOpts.allYALocationCellsOut where locnCell &lt;&gt; null do		//11 feb 2011	NDL Par 24181
		invalidCell := false;
		exclusiveLock(locnCell);
		if not invalidCell then
			self.allYALocationCellsOut.add(locnCell);
		endif;
	endforeach;
//	_pxyDeckingOpts.allYALocationCellsOut.copy(self.allYALocationCellsOut);


epilog
	delete deckingRule;
	
end;</source>
        <Parameter name="_pxyDeckingOpts" type="CM_YADeckingOptions"/>
        <Parameter name="_updateToLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setOutDeckingReverseOfIn" id="86eadb2c-becd-4f8e-aaea-0dbd1b076ff2">
        <source>setOutDeckingReverseOfIn();
//----------------------------------------------------------------
//	Created:	14 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	locnCell		: CM_YALocationCell;
begin
	//do default out - reverse of in?
	
	self.allYALocationCellsOut.clear;
	foreach locnCell in self.allYALocationCellsIn reversed do
		self.allYALocationCellsOut.add(locnCell);
	endforeach;

end;</source>
