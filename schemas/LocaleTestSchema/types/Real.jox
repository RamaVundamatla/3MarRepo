<PrimType name="Real">
    <JadeMethod name="asStringJMT" id="e37319a2-f4b5-49ec-bc1d-37e8dc3de796">
        <source>asStringJMT() :String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
31 May 2007	cnwer1	Initial creation - PAR#xxxx

*/
constants
	JMTDecimalSeperator = ".";
vars
	decimalSeperator,
	thousandSeperator,
	currentStringValue,localeFormat: String;
	decimalPrecision : Integer;
begin
	decimalSeperator:=app.currentLocaleInfo.numericInfo.decimalSeparator;
	thousandSeperator:=app.currentLocaleInfo.numericInfo.thousandSeparator;
	//decimalPrecision:=self.getDeclaredPrecision;
	localeFormat:=self.display;
	localeFormat.replaceChar(JMTDecimalSeperator,decimalSeperator.Character);
	
	return localeFormat;


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asStringJMTWithPrecision" id="449dcbeb-a1de-452d-9e39-bb0289d08e36">
        <source>asStringJMTWithPrecision(_decimalPrecision : Integer; _useThousandSeparator : Boolean) :String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
31 May 2007	cnwer1	Initial creation - PAR#xxxx

*/
constants
	JMTDecimalSeperator = ".";
vars
	decimalSeperator,
	thousandSeperator,
	currentStringValue,localeFormat	: String;
	len, pos, sbe, diff 			: Integer;
	isNeg : Boolean;
	me : Decimal[12,2];
begin
	decimalSeperator	:=app.currentLocaleInfo.numericInfo.decimalSeparator;
	thousandSeperator	:=app.currentLocaleInfo.numericInfo.thousandSeparator;

	localeFormat 		:= self.roundedTo(_decimalPrecision).display;
	
	localeFormat.replaceChar(JMTDecimalSeperator, decimalSeperator.Character);

	if _decimalPrecision = 0 then
		return localeFormat;
	endif;
	
	// PAR 14668 PAD with ZEROS
	pos := localeFormat.pos(decimalSeperator,1);
	if pos = 0 then
		if _decimalPrecision &gt; 0 then // PAR 15494
			len := localeFormat.length;
			sbe :=len + 1  + _decimalPrecision;
			localeFormat := localeFormat &amp; decimalSeperator;
			foreach pos in 1 to _decimalPrecision do
				localeFormat := localeFormat &amp; "0";
			endforeach;
		endif;
	else
		len := localeFormat.length;
		sbe := pos + _decimalPrecision;
		diff := sbe - len;
		if diff &gt; 0 then
			foreach pos in 1 to diff do
				localeFormat := localeFormat &amp; "0";
			endforeach;
		
		endif;
	endif;
		
	// 09/01/2008 cnwar2 #14738
	if _useThousandSeparator then
		isNeg :=  (self &lt; 0); // PAR 16890 and 17110
		if isNeg then // PAR 16890 and 17110
			localeFormat := localeFormat[2:end]; // PAR 16890 and 17110
		endif; // PAR 16890 and 17110
		if _decimalPrecision &gt; 0 then
			pos	:= localeFormat.pos(decimalSeperator,1) - 1;
		else
			pos	:= localeFormat.length;
		endif;
		pos := pos - 3;
		while pos &gt; 0 do
			localeFormat := localeFormat[1:pos] &amp; thousandSeperator &amp; localeFormat[pos+1:end];
			pos := pos - 3;
		endwhile;
		if isNeg then // PAR 16890 and 17110
			localeFormat := "-" &amp; localeFormat;  // PAR 16890 and 17110
		endif; // PAR 16890 and 17110
	endif;

	return localeFormat;
epilog

end;</source>
        <Parameter name="_decimalPrecision" type="Integer"/>
        <Parameter name="_useThousandSeparator" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
