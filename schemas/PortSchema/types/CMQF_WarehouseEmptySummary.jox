    <JadeMethod name="createSummaryObjBR" id="582a7285-451c-42a4-9f4d-f26e33119e61">
        <source>createSummaryObjBR(_bulkRel: CM_BulkRelease; _summaryObjects: CMIF_MTSummaryByOpISOGrpAvaGrd input);
//----------------------------------------------------------------
//	Created:	08 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	sumObj		: CMIF_MTWarehouseSummary;
	isNew		: Boolean;
	avaGrades			: IntegerArray;
	firstAvaGrade		: Integer;
begin
	
	avaGrades := _bulkRel.getAllAvailabilityGrades();
	
	if avaGrades &lt;&gt; null and (not avaGrades.isEmpty) then
		firstAvaGrade := avaGrades.first;
	endif;
	
	sumObj := _summaryObjects[_bulkRel.getOperatorCode, _bulkRel.getISOGroupCode, firstAvaGrade].CMIF_MTWarehouseSummary; 

	if sumObj = null then
		create sumObj transient;
		sumObj.setForCreateFromFilter(self);
		isNew := true;
	endif;
	
	sumObj.setFromBR(_bulkRel, isNew);
	
	if isNew then
		_summaryObjects.add(sumObj);	
	endif;

end;</source>
        <Parameter name="_bulkRel" type="CM_BulkRelease"/>
        <Parameter name="_summaryObjects" type="CMIF_MTSummaryByOpISOGrpAvaGrd" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createSummaryObjBRByImEx" id="a59147f8-d0ae-49ae-bdf4-76aa91be7456">
        <source>createSummaryObjBRByImEx(_bulkRel: CM_BulkRelease; _summaryObjects: CMIF_MTSummaryByOpISOGrpAvaGrd input);
//----------------------------------------------------------------
//	Created:	08 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//
//	releases by type may be split off from those by ImEx - could be a work in progress so please keep - not currently used
//
vars
	sumObj			: CMIF_MTWarehouseSummary;
	isNew			: Boolean;
	outstanding		: Integer;
	tmpBR			: CM_BulkRelease;
	avaGrades			: IntegerArray;
	firstAvaGrade		: Integer;
begin
	tmpBR := _bulkRel;

	avaGrades := _bulkRel.getAllAvailabilityGrades();
	
	if avaGrades &lt;&gt; null and (not avaGrades.isEmpty) then
		firstAvaGrade := avaGrades.first;
	endif;
	
	sumObj := _summaryObjects[tmpBR.getOperatorCode, tmpBR.getISOGroupCode, firstAvaGrade].CMIF_MTWarehouseSummary; 

	if sumObj = null then
		create sumObj transient;
		isNew := true;
	endif;
	
/*	
	self.allBulkReleases.add(tmpBR);
	
	if _setKeys then
		self.operatorCode			:= tmpBR.getOperatorCode;
		self.operatorDesc			:= tmpBR.getOperatorDesc;
		self.isoGroupCode			:= tmpBR.getISOGroupCode;
		self.isoGroupDesc			:= tmpBR.getISOGroupDesc;
		self.avaGradeId				:= tmpBR.allAvailabilityGrades.first;
	endif;

	if self.isoGroupReportOrder = null 
	and tmpBR.myISOGroup &lt;&gt; null then
		self.isoGroupReportOrder := tmpBR.myISOGroup.reportGroupOrder;	//kind of a key
	endif;
	
	outstanding := (tmpBR.totalRequested - tmpBR.releasedItemStrings.size);
	
	if tmpBR.status = BR_ACTIVE then
	
		if tmpBR.type = BR_TYPE_RAIL
		or tmpBR.type = BR_TYPE_ROAD then
			self.totalTransportRequests := self.totalTransportRequests + outstanding;
		elseif tmpBR.type = BR_TYPE_GENERAL then
			self.totalGeneralCargoRequests := self.totalGeneralCargoRequests + outstanding;
		else
			//for debugging - not for display
			self.totalOtherBR := self.totalOtherBR + 1;
			app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " BR not categorised (" &amp; tmpBR.type.String &amp; ").  Total = " &amp; self.totalOtherBR.String);
		endif;
		
	elseif tmpBR.status = BR_PENDING then
		
		self.totalPendingRequests := self.totalPendingRequests + outstanding;
	
	else
		//for debugging - not for display
		self.totalOtherBR := self.totalOtherBR + 1;
		app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " BR not categorised (status).  Total = " &amp; self.totalOtherBR.String);
	endif;
end;
*/	
	if isNew then
		_summaryObjects.add(sumObj);	
	endif;

end;</source>
        <Parameter name="_bulkRel" type="CM_BulkRelease"/>
        <Parameter name="_summaryObjects" type="CMIF_MTSummaryByOpISOGrpAvaGrd" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createSummaryObjBRByType" id="85854774-296f-4126-8c76-fc0993d88464">
        <source>createSummaryObjBRByType(_bulkRel: CM_BulkRelease; _summaryObjects: CMIF_MTSummaryByOpISOGrpAvaGrd input);
//----------------------------------------------------------------
//	Created:	08 November 2004	by Jason Chapman  (cnwjc2)
