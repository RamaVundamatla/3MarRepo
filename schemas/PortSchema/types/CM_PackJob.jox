    <JadeMethod name="addTI" id="dd37311e-889c-4b51-b9ed-6fbe3734fa0b">
        <updating/>
        <source>addTI(_ti: CM_TrackedItem input; _request: CM_Request) updating;
/*
Purpose:			
Parameters:			
Return Value:		

Date			Who		Reason
29 July 2009	cnwrd1	Initial creation
// 01/04/2010	cnwcs5	par 23383 - pass context info (_request) to updateTICollections 
//									via new parameter (_extra)
// 29 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
*/
vars

begin
	exclusiveLock(self);

	if (_ti = null or _request = null) then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_TI_LINK_PARAM, null, null);
		return;	
	endif;

	sharedLock(_request);
	exclusiveLock(_ti);

	self.updateTICollections(_ti, _request);	// 01/04/2010 cnwcs5 par 23383

	self.updateObjectEdition(self);	// par 30292
	
	// PAR 11770 Lorcan Send note so screens can update
	app.myEventManager.createSingleObjInfoNoteEvt(self, app.myPassport.myTerminal.getTerminalEvent(YardJob_Update_Event), self);

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_request" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="addToJobSheet" id="dd569437-306f-4250-a635-be1c0d7b3a3e">
        <updating/>
        <source>addToJobSheet() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2009	cnwrd1	Initial creation

*/

vars
	jobSheet : CM_YardJobSheet;
begin
	//------------
	//Add the ourselves to terminal's jobSheet
	//------------
	jobSheet := self.myTerminal.myYardJobSheet;

	if jobSheet = null then	//Padding for disasters, this object is only created in terminal constructor.
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null yardJobSheet. Contact Developer.');
	endif;
	jobSheet.addJob(self, 0);
end;</source>
    </JadeMethod>
