<CollClass name="BooleanArray">
    <JadeMethod name="jssDoSort" id="488fa8ab-1098-4779-8188-3c337ed38b41">
        <lockReceiver/>
        <updating/>
        <source>jssDoSort(pTheSorter:JSSSorter) updating, protected;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Refer to method implementation on the Array class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	arrayPointer	: Integer;
	booleanValue	: Boolean;
	theSortKey		: Object;
	anyValue		: Any;

begin
	foreach booleanValue in self do
		pTheSorter.addValue(booleanValue);
	endforeach;
	
	self.purge();
	
	foreach theSortKey in pTheSorter.mySortColl do
		self.add(theSortKey.JSSSortKey.getValue().Boolean);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pTheSorter" type="JSSSorter"/>
    </JadeMethod>
</CollClass>
