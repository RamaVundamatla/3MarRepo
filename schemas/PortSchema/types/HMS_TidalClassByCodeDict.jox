<CollClass name="HMS_TidalClassByCodeDict" id="c2a77dd1-9b9d-41f8-ac71-1a81bf09540c">
    <memberType name="HMS_TidalClass"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="harbour"/>
    <MemberKey>
        <property name="HMS_TidalClass::code"/>
    </MemberKey>
    <JadeMethod name="getMatchingDesc" id="050483d1-f854-4cac-93c3-b4c38bc6e22d">
        <source>getMatchingDesc(_desc : String ):HMS_TidalClass;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2018	jlgndl1	Initial creation	TFS 39338

*/

vars

	tidalClass : HMS_TidalClass;

begin

	foreach tidalClass in self do
		if tidalClass.description = _desc then
			return tidalClass;
		endif;
	endforeach;

	return null;

epilog

end;</source>
        <Parameter name="_desc" type="String"/>
        <ReturnType type="HMS_TidalClass"/>
    </JadeMethod>
</CollClass>
