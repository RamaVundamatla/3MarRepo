    <JadeMethod name="drawHold" id="ec36629f-39c4-4397-91ad-cd8feb003d49">
        <updating/>
        <source>drawHold(	_hold : CM_LocationsController;
			_startX, _startY : Integer; 
			_bulkDrawingController : SHP_BulkDrawingController input; 
			_onDeck : Boolean;
			_objDict : CMUI_GridObjectByX1Y1X2Y2Dict input;
			_weight : Integer io	) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	displayMode, rowHeight : Integer;
	x1, y1, x2, y2 : Integer;
	frame : SHP_BulkDrawingFrame;

begin
	x1 := _startX;
	y1 := _startY;
	
	displayMode	:= _bulkDrawingController.displayMode;
	rowHeight	:= _bulkDrawingController.rowHeight;

	x2 := x1 + _bulkDrawingController.getHatchWidth - (_bulkDrawingController.SideMargin * 3);
	if _hold.isGeneralCargoController then
		y2 := y1 + _bulkDrawingController.getHoldHeightOnUnderDeck(_onDeck, _hold.CM_GeneralCargoController.hatch);
	elseif _hold.isShipBlockStack then
		y2 := y1 + _bulkDrawingController.holdDrawHeight - _bulkDrawingController.yOnDeckPos -18;
	endif;
	
	//write "drawing " &amp; _hold.getID &amp; " at " &amp; x1.String &amp; "," &amp; y1.String &amp; " -&gt; " &amp; x2.String &amp; "," &amp; y2.String;
	
	_bulkDrawingController.setFromHold(_hold, x1, y1, x2, y2);

	_bulkDrawingController.setDefaultFont(self);
	_bulkDrawingController.drawCurrentObject(self);
	
	// now set the font back for labels
	_bulkDrawingController.setLabelFont(self);
	
	_objDict.putAtKey(x1, y1, x2, y2, _hold);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_hold" type="CM_LocationsController"/>
        <Parameter name="_startX" type="Integer"/>
        <Parameter name="_startY" type="Integer"/>
        <Parameter name="_bulkDrawingController" type="SHP_BulkDrawingController" usage="input"/>
        <Parameter name="_onDeck" type="Boolean"/>
        <Parameter name="_objDict" type="CMUI_GridObjectByX1Y1X2Y2Dict" usage="input"/>
        <Parameter name="_weight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawHoldHeading" id="21ba0e41-9a81-412e-ad74-e051f685937a">
        <updating/>
        <source>drawHoldHeading(_hold : CM_LocationsController; _theX, _theY : Integer; _onDeck : Boolean; _drawingController : SHP_BulkDrawingController) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	string : String;
	scaleFactor : Real;
	halfGraphicWidth, yOffset2, theX : Integer;
	amPrinting : Boolean;
	frame : SHP_BulkDrawingFrame;
	textLength : Integer;
	
begin
	amPrinting := _drawingController.amPrinting;
	
	if amPrinting and _onDeck then
		return;
	endif;
	
	scaleFactor := _drawingController.scaleFactor;
	frame := self;
		
	yOffset2 := self.HeadingGraphicHeight;

	halfGraphicWidth := (self.HeadingGraphicWidth / 2).Integer;
	
	if _hold.isGeneralCargoController then
		string := _hold.CM_GeneralCargoController.hatch.String.padLeadingZeros(2);
	elseif _hold.isShipBlockStack then
//		string := "SHIP";
		string := myBulkDrawingController.myVoyage.code;	// 11/7/16 cnwmp6 TFS 1601
	endif;
	
	// ### BAY ID
	if amPrinting then
		theX := _theX;
		frame.drawFillStyle := Frame.DrawFillStyle_Transparent;
		frame.drawEllipse1(theX - 10 , _theY, theX + 10, _theY + yOffset2, Black);
		frame.drawTextAlign := Frame.DrawTextAlign_Center;
		frame.drawTextAt(string, theX, _theY + 3,Black);
		
		frame.drawFillStyle := Frame.DrawFillStyle_Solid;
		frame.drawTextAlign := Frame.DrawTextAlign_Left;
		
		return;
	endif;
	
	theX := _theX - halfGraphicWidth;

	// ### HOLD ID
	textLength := self.getTextExtent(string);
	theX := theX - (textLength / 2).Integer;
	frame.drawTextAlign := Frame.DrawTextAlign_Left;
	frame.drawFillColor := Blue; 
	frame.drawFillStyle := Frame.DrawFillStyle_Solid;
	frame.drawFilledRectangle(theX, _theY, theX + textLength + 5, _theY + self.HeadingGraphicHeight, Blue);
	frame.drawTextAt(string, theX + self.HeadingGraphicTextXOffset, _theY + self.HeadingGraphicTextYOffset, White);
	if self.allObjectsOnDeck.getAtKey(theX, _theY,theX + textLength + 5, _theY + self.HeadingGraphicHeight) = null then
		self.allObjectsOnDeck.putAtKey(theX, _theY,theX + textLength + 5, _theY + self.HeadingGraphicHeight, self);
	endif;

	frame.drawFillStyle := Frame.DrawFillStyle_Solid;
	frame.drawTextAlign := Frame.DrawTextAlign_Left;

	if _drawingController.showHoldID then
		string := _hold.getID;
		if string.trimBlanks &lt;&gt; null then
			theX := theX - 3 - HeadingGraphicWidth;
			frame.drawFillColor := Green;
			frame.drawFilledRectangle(theX, _theY, theX + self.HeadingGraphicWidth, _theY + self.HeadingGraphicHeight,Green);
			frame.drawTextAt(string, theX + self.HeadingGraphicTextXOffset, _theY + self.HeadingGraphicTextYOffset, White);
		endif;
	endif;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_hold" type="CM_LocationsController"/>
        <Parameter name="_theX" type="Integer"/>
        <Parameter name="_theY" type="Integer"/>
        <Parameter name="_onDeck" type="Boolean"/>
        <Parameter name="_drawingController" type="SHP_BulkDrawingController"/>
    </JadeMethod>
    <JadeMethod name="drawObjectAt" id="a39376ae-a076-47c2-b074-6570ae7763f6">
        <updating/>
        <source>drawObjectAt(_obj: Object; _x1: Integer; _y1: Integer; _x2: Integer; _y2: Integer; _drawingController: CMUI_GridDrawingController input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

begin
	if _obj = null then
		return;
	endif;

	if CM_GeneralCargoController.hasInstance(_obj) then
		_drawingController.SHP_BulkDrawingController.setFromHold(_obj.CM_GeneralCargoController, _x1, _y1, _x2, _y2);
		self.myHold := _obj.CM_GeneralCargoController;
		_drawingController.drawCurrentObject(self);
	
	elseif CM_ShipBlockController.hasInstance(_obj) then
		_drawingController.SHP_BulkDrawingController.setFromHold(_obj.CM_ShipBlockController, _x1, _y1, _x2, _y2);
		self.myHold := _obj.CM_ShipBlockController;
		_drawingController.drawCurrentObject(self);
		
	elseif SHP_BulkDrawingFrame.hasInstance(_obj) then	// 27/7/16 cnwmp6 TFS 1601 - in case hold heading clicked
	
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled object ' &amp; _obj.String);
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_drawingController" type="CMUI_GridDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawOnDeck" id="ce057209-5c72-48e6-b6a0-3b475861dd92">
        <updating/>
        <source>drawOnDeck(_holds : CM_ObjectArray; _drawingController : SHP_BulkDrawingController input) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	frame : SHP_BulkDrawingFrame;
	theX, spaceX, onDeckOffset,	weightYPos, volumeYPos, sideMargin : Integer;
	drawWeights : Boolean;
	mode, weight, maxWeight, offSet : Integer;
	volume, maxVolume: Decimal[16, 4];
	objDict : CMUI_GridObjectByX1Y1X2Y2Dict;
	hold : CM_LocationsController;
	obj : Object;
	count : Integer;
	overWeight,
	overVolume: Boolean;
	move : CM_FutureMove;
	tmpHoldHeight : Integer;

begin
	frame := self;
	if _holds.isEmpty then
		return;
	endif;
	hold := _holds.first.CM_GeneralCargoController;
	
	theX := (_drawingController.holdDrawWidth / 2).Integer;
	self.drawHoldHeading(hold, theX, 0, true, _drawingController);

	spaceX 			:= _drawingController.xAxisLabelOffset;
	onDeckOffset	:= self.getOnDeckOffset();
	objDict			:= self.allObjectsOnDeck;
	drawWeights 	:= _drawingController.hasWeights;
	weightYPos		:= _drawingController.yDeckPos - 15;
	volumeYPos		:= _drawingController.yDeckPos - 15;
	sideMargin		:= self.leftSideMargin;
	
	//mode := self.getParentFormMode();
	mode := self.myBulkDrawingController.actPlanQueMode;
	
	// draw each GC controller in the On deck collection
	foreach obj in _holds do
		hold := obj.CM_GeneralCargoController;
		if mode = ShpDisplayMode_Actual then
			weight := weight + hold.totalWeightTonnes.Integer;
			volume := volume + hold.totalVolume;
		elseif mode = ShpDisplayMode_Proposed then
			// weight is all planned moves for Export, plus all cargo currently in the location
			foreach move in hold.allPlannedFutureMoves do
				if self.myBulkDrawingController.imexMode = TI_IMEX_STATUS_EXPORT then
					if self.myBulkDrawingController.imexMode = move.getTrackedItem.getImExStatus then
						weight := weight + (move.getTrackedItem.totalWeight / 1000).Integer;
						volume := volume + move.getTrackedItem.totalVolume;
					endif;
				endif;
			endforeach;
			weight := weight + hold.totalWeightTonnes.Integer;
			volume := volume + hold.totalVolume;
		elseif mode = ShpDisplayMode_Queued then
			// weight is all queued moves for Export, plus all cargo currently in the location
			foreach move in hold.allQueuedFutureMoves do
				if self.myBulkDrawingController.imexMode = TI_IMEX_STATUS_EXPORT then
					if self.myBulkDrawingController.imexMode = move.getTrackedItem.getImExStatus then
						weight := weight + (move.getTrackedItem.totalWeight / 1000).Integer;
						volume := volume + move.getTrackedItem.totalVolume;
					endif;
				endif;
			endforeach;
			weight := weight + hold.totalWeightTonnes.Integer;
			volume := volume + hold.totalVolume;
		endif;
		maxWeight := maxWeight + hold.CM_GeneralCargoController.maxWeight.Integer;
		maxVolume := maxVolume + hold.CM_GeneralCargoController.maxVolume;
		self.myHold := hold;
		theX := _drawingController.SideMargin;// + (_drawingController.getHatchWidth * _drawingController.getColumnForGCController(hold) - _drawingController.getHatchWidth);
		//27 May 2016	NDL	TFS 1922
		if hold.CM_GeneralCargoController.isOnDeck then
			tmpHoldHeight := (_drawingController.getHoldHeightOnUnderDeck(true, hold.CM_GeneralCargoController.hatch) * count);
		else
			tmpHoldHeight := (_drawingController.getHoldHeight * count);
		endif;
		self.drawHold(hold, theX, (onDeckOffset + tmpHoldHeight), _drawingController, true, objDict, weight);
	//	self.drawHold(hold, theX, (onDeckOffset + (_drawingController.getHoldHeight * count)), _drawingController, true, objDict, weight);
		count := count + 1;
	endforeach;

	if self.myBulkDrawingController.workingMode = self.myBulkDrawingController.myVoyagePlanningForm.WorkMode_Volume then
		volumeYPos := _drawingController.yOnDeckPos - 15;
		if volume &gt; maxVolume and maxVolume &lt;&gt; null then
			overVolume := true;
		endif;
		_drawingController.drawHoldVolume(self, volume, maxVolume, overVolume, 38, volumeYPos);
	else
		// ### WEIGHT LABELS
		if drawWeights then
			weightYPos := _drawingController.yOnDeckPos - 15;
			if weight &gt; maxWeight and maxWeight &lt;&gt; null then
				overWeight := true;
			endif;
			_drawingController.drawHoldWeight(self, weight, maxWeight, overWeight, 38, weightYPos);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_holds" type="CM_ObjectArray"/>
        <Parameter name="_drawingController" type="SHP_BulkDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="7d5d1fd7-63d8-4a4e-b20a-9332a36dfe02">
        <updating/>
        <source>drawSelf(_drawingController : SHP_BulkDrawingController input; _ondeck : Boolean; _underDeck : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

begin
	self.beginBatchDrawing();
	
	self.allObjectsOnDeck.clear;
	self.allObjectsUnderDeck.clear;
	
	_drawingController.setLabelFont(self);
	
	if _ondeck then
		self.drawOnDeck(self.allHoldsOnDeck, _drawingController);
	endif;
	
	if _underDeck then
		self.drawUnderDeck(self.allHoldsUnderDeck, _drawingController);
	endif;
	_drawingController.setDefaultFont(self);

epilog
	self.endBatchDrawing(); 
end;</source>
        <Parameter name="_drawingController" type="SHP_BulkDrawingController" usage="input"/>
        <Parameter name="_ondeck" type="Boolean"/>
        <Parameter name="_underDeck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawShipBlockStack" id="d761db4d-e262-4b75-9b5e-631856d9d13c">
        <updating/>
        <source>drawShipBlockStack(_drawingController : SHP_BulkDrawingController input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	shipStack : CM_ShipBlockController;
	frame : SHP_BulkDrawingFrame;
	theX, spaceX, onDeckOffset,	sideMargin : Integer;
	//weightYPos, volumeYPos : Integer;
	drawWeights : Boolean;
	mode, weight, maxWeight : Integer;
	volume, maxVolume: Decimal[16, 4];
	objDict : CMUI_GridObjectByX1Y1X2Y2Dict;
	move : CM_FutureMove;

begin
	shipStack := _drawingController.myVoyage.myShipBlockStack.CM_ShipBlockController;
	frame := self;
	
	theX := (_drawingController.holdDrawWidth / 2).Integer;
	self.drawHoldHeading(shipStack, theX, 0, true, _drawingController);
	
	spaceX 			:= _drawingController.xAxisLabelOffset;
	onDeckOffset	:= self.getOnDeckOffset();
	objDict			:= self.allObjectsOnDeck;
	drawWeights 	:= _drawingController.hasWeights;
//	weightYPos		:= _drawingController.yOnDeckPos - 15;
//	volumeYPos		:= _drawingController.yOnDeckPos - 15;
	sideMargin		:= self.leftSideMargin;

	//mode := self.getParentFormMode();
	mode := self.myBulkDrawingController.actPlanQueMode;
	
	self.myHold := shipStack;
	theX := _drawingController.SideMargin + (_drawingController.getHatchWidth * _drawingController.getColumnForGCController(shipStack) - _drawingController.getHatchWidth);
	self.drawHold(shipStack, theX, onDeckOffset, _drawingController, true, objDict, weight);
	
//	weightYPos := _drawingController.yDeckPos - 15;
	if mode = ShpDisplayMode_Actual then
		weight := shipStack.totalWeightTonnes.Integer;
		volume := shipStack.totalVolume;
	elseif mode = ShpDisplayMode_Proposed then
		// weight is all planned moves for Exports, plus all cargo currently in the location
		foreach move in shipStack.allPlannedFutureMoves do
			if self.myBulkDrawingController.imexMode = TI_IMEX_STATUS_EXPORT then
				if self.myBulkDrawingController.imexMode = move.getTrackedItem.getImExStatus then
					weight := weight + (move.getTrackedItem.totalWeight / 1000).Integer;
					volume := volume + move.getTrackedItem.totalVolume;
				endif;
			endif;
		endforeach;
		weight := weight + shipStack.totalWeightTonnes.Integer;
		volume := volume + shipStack.totalVolume;
	elseif mode = ShpDisplayMode_Queued then
		// weight is all queued moves for Exports, plus all cargo currently in the location
		foreach move in shipStack.allQueuedFutureMoves do
			if self.myBulkDrawingController.imexMode = TI_IMEX_STATUS_EXPORT then
				if self.myBulkDrawingController.imexMode = move.getTrackedItem.getImExStatus then
					weight := weight + (move.getTrackedItem.totalWeight / 1000).Integer;
					volume := volume + move.getTrackedItem.totalVolume;
				endif;
			endif;
		endforeach;
		weight := weight + shipStack.totalWeightTonnes.Integer;
		volume := volume + shipStack.totalVolume;
	endif;
	if self.myBulkDrawingController.workingMode = self.myBulkDrawingController.myVoyagePlanningForm.WorkMode_Volume then
		_drawingController.drawHoldVolume(self, volume, null, false, 38, 37);
	else
		// ### WEIGHT LABELS
		if drawWeights then
			_drawingController.drawHoldWeight(self, weight, null, false, 38, 37);	//10 Apr 2017	NDL	TFS 4058
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_drawingController" type="SHP_BulkDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawUnderDeck" id="9ab289f7-47b6-48e2-9fea-e20c6c057e2f">
        <updating/>
        <source>drawUnderDeck(_holdsUnderDeck : CM_ObjectArray; _drawingController : SHP_BulkDrawingController input) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	offSet, 
	theX, theSpaceX	: Integer;
	theColWidth	: Integer;
	theRowHeight : Integer;
	theFrame : SHP_BulkDrawingFrame;
	iAmPrinting : Boolean;
	printOutputStyle	: Integer;
	theUnderDeckPos,
	theSideMargin,
	weightYPos,
	volumeYPos,
	maxWeight,
	tmpWeight : Integer;
	maxVolume,
	tmpVolume: Decimal[16, 4];
	hasLabels,
	drawWeights	: Boolean;
	tmpObjDict		: CMUI_GridObjectByX1Y1X2Y2Dict;
	mode : Integer;
	obj : Object;
	hold : CM_GeneralCargoController;
	count : Integer;
	overWeight,
	overVolume: Boolean;
	move : CM_FutureMove;

begin
	theFrame 		:= self;
	if _holdsUnderDeck.isEmpty then
		return;
	endif;
	hold := _holdsUnderDeck.first.CM_GeneralCargoController;
	
	theX := (_drawingController.holdDrawWidth / 2).Integer;
	self.drawHoldHeading(hold, theX, 0, true, _drawingController);
	
	iAmPrinting 	:= _drawingController.amPrinting;
	printOutputStyle := _drawingController.printOutputStyle;
	theColWidth	 	:= _drawingController.columnWidth;
	theSpaceX 		:= _drawingController.xAxisLabelOffset;
	drawWeights 	:= _drawingController.hasWeights;
	tmpObjDict		:= self.allObjectsUnderDeck;
	hasLabels		:= _drawingController.hasLabels;
	theUnderDeckPos	:= self.getUnderDeckOffSet() + 15;
	//maxWeight 		:= (_bay.maxPileWeightUD / 1000).rounded;
	weightYPos		:= _drawingController.yUnderDeckEndPos + 2;
	theSideMargin	:= self.leftSideMargin;

	//mode := self.getParentFormMode();
	mode := self.myBulkDrawingController.actPlanQueMode;
	
	// draw each GC controller in the Under deck collection
	foreach obj in _holdsUnderDeck do
		hold := obj.CM_GeneralCargoController;
		self.myHold := hold;
		if mode = ShpDisplayMode_Actual then
			tmpWeight := tmpWeight + hold.totalWeightTonnes.Integer;
			tmpVolume := tmpVolume + hold.totalVolume;
		elseif mode = ShpDisplayMode_Proposed then
			// weight is all planned moves for export, plus cargo currently in the location
			foreach move in hold.allPlannedFutureMoves do
				if self.myBulkDrawingController.imexMode = TI_IMEX_STATUS_EXPORT then
					if self.myBulkDrawingController.imexMode = move.getTrackedItem.getImExStatus then
						tmpWeight := tmpWeight + (move.getTrackedItem.totalWeight / 1000).Integer;
						tmpVolume := tmpVolume + (move.getTrackedItem.totalVolume);
					endif;
				endif;
			endforeach;
			tmpWeight := tmpWeight + hold.totalWeightTonnes.Integer;
			tmpVolume := tmpVolume + hold.totalVolume;
		elseif mode = ShpDisplayMode_Queued then
			// weight is all queued moves for export, plus cargo currently in the location
			foreach move in hold.allQueuedFutureMoves do
				if self.myBulkDrawingController.imexMode = TI_IMEX_STATUS_EXPORT then
					if self.myBulkDrawingController.imexMode = move.getTrackedItem.getImExStatus then
						tmpWeight := tmpWeight + (move.getTrackedItem.totalWeight / 1000).Integer;
						tmpVolume := tmpVolume + move.getTrackedItem.totalVolume;
					endif;
				endif;
			endforeach;
			tmpWeight := tmpWeight + hold.totalWeightTonnes.Integer;
			tmpVolume := tmpVolume + hold.totalVolume;
		endif;
		maxWeight := maxWeight + hold.maxWeight.Integer;
		maxVolume := maxVolume + hold.maxVolume;
		theX := _drawingController.SideMargin;// + (_drawingController.getHatchWidth * _drawingController.getColumnForGCController(hold) - _drawingController.getHatchWidth);
		self.drawHold(hold, theX, (theUnderDeckPos + (_drawingController.getHoldHeightOnUnderDeck(false, hold.CM_GeneralCargoController.hatch) * count)), _drawingController, false, tmpObjDict, tmpWeight);
		count := count + 1;
	endforeach;

	if self.myBulkDrawingController.workingMode = self.myBulkDrawingController.myVoyagePlanningForm.WorkMode_Volume then
			volumeYPos := _drawingController.yUnderDeckPos;
			if tmpVolume &gt; maxVolume and maxVolume &lt;&gt; null then
				overVolume := true;
			endif;
			_drawingController.drawHoldVolume(self, tmpVolume, maxVolume, overVolume, 38, volumeYPos);
	else
		// ### WEIGHT LABELS
		if drawWeights then
			weightYPos := _drawingController.yUnderDeckPos;
			if tmpWeight &gt; maxWeight and maxWeight &lt;&gt; null then
				overWeight := true;
			endif;
			_drawingController.drawHoldWeight(self, tmpWeight, maxWeight, overWeight, 38, weightYPos);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_holdsUnderDeck" type="CM_ObjectArray"/>
        <Parameter name="_drawingController" type="SHP_BulkDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="e840ec86-3635-4212-97f9-37e97e4ea1e8">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27 July 2016	cnwdap1		Initial creation PAR #
//
vars
	block : CM_DataContainerBlock;
	passport : CM_Passport;
	allBlocksArray : CM_DataContainerBlockArray;
	quantityTotal : Integer;
	qdQuantityTotal : Integer;
	pdQuantityTotal : Integer;
	lineQuantity: Integer;
	idx, idxSt, idxEnd,
	idxQ, idxP: Integer;
	cargoSort, lastCargoSort : String;
	sohCargoS,
	sohCargoP,
	sohCargoQ: StringArray;
	sohVolumeS,
	sohVolumeP,
	sohVolumeQ: DecimalArray;
	sohWeightS,
	sohWeightP,
	sohWeightQ: DecimalArray;
	sohItemS,
	sohItemP,
	sohItemQ: IntegerArray;
	sohQuantityS,
	sohQuantityP,
	sohQuantityQ: IntegerArray;
	totVolume,
	totVolQueue,
	totVolPlan,
	lineVolume: Decimal[16,4];
	totWeight,
	totWgtQueue,
	totWgtPlan,
	lineWeight: Decimal[14,4];
	failedDAC :CM_DataAccessController;
	sortTIs,
	sortTIsQueue,
	sortTIsPlan: CM_TIByCargoTypeDict;
	allTIs,
	allTIsQueue,
	allTIsPlan: CM_TIArray;
	ti : CM_TrackedItem;
	obj : Object;
	hold : CM_LocationsController;

begin
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Location), DC_Label, 1, null);
	if self.myHold.isKindOf(CM_ShipBlockController) then
		block.addNewItem(self.myBulkDrawingController.myVoyage.code, DC_Data, 3, null);
	else
		block.addNewItem(self.myHold.CM_GeneralCargoController.hatch.padLeadingWith("0", 2).String, DC_Data, 3, null);
	endif;

	//block := _dataContainer.addNewBlock;
	//block.addNewItem(app.getErrorString(Maximum_Weight), DC_Label, 3, null);
	//block.addNewItem(self.maxWeight.String, DC_Data, 3, null);

	create allBlocksArray transient;
	
	//passport := app.myPassport;
	//if (not self.canUserAccessSelf(null, failedDAC, passport)) then
	//	block := _dataContainer.addNewBlock;
	//	block.addNewItem(app.getErrorString(CM_You_Do_Not_Have_Access), DC_Header, 1, null);
	//	return;
	//endif;
		
	create sortTIs transient;
	create sortTIsPlan transient;
	create sortTIsQueue transient;
	create allTIs transient;
	create allTIsPlan transient;
	create allTIsQueue transient;
	create sohVolumeS transient; 
	sohVolumeS[10] := 0;
	create sohWeightS transient; 
	sohWeightS[10] := 0;
	create sohCargoS transient; 
	sohCargoS[10] := "";
	create sohItemS transient; 
	sohItemS[10] := 0;
	create sohQuantityS transient; 
	sohQuantityS[10] := 0;
	create sohVolumeP transient; 
	sohVolumeP[10] := 0;
	create sohWeightP transient; 
	sohWeightP[10] := 0;
	create sohCargoP transient; 
	sohCargoP[10] := "";
	create sohItemP transient; 
	sohItemP[10] := 0;
	create sohQuantityP transient; 
	sohQuantityP[10] := 0;
	create sohVolumeQ transient; 
	sohVolumeQ[10] := 0;
	create sohWeightQ transient; 
	sohWeightQ[10] := 0;
	create sohCargoQ transient; 
	sohCargoQ[10] := "";
	create sohItemQ transient; 
	sohItemQ[10] := 0;
	create sohQuantityQ transient; 
	sohQuantityQ[10] := 0;
	
	foreach obj in self.allHoldsOnDeck do
		obj.CM_LocationsController.getTIs(allTIs, REAL_MODE, false);
		obj.CM_LocationsController.getTIs(allTIsPlan, PLANNING_MODE, false);
		obj.CM_LocationsController.getTIs(allTIsQueue, QUEUE_MODE, false);
	endforeach;
	foreach obj in self.allHoldsUnderDeck do
		obj.CM_LocationsController.getTIs(allTIs, REAL_MODE, false);
		obj.CM_LocationsController.getTIs(allTIsPlan, PLANNING_MODE, false);
		obj.CM_LocationsController.getTIs(allTIsQueue, QUEUE_MODE, false);
	endforeach;
	allTIs.copy(sortTIs);
	allTIsPlan.copy(sortTIsPlan);
	allTIsQueue.copy(sortTIsQueue);

	//self.getTotalsByMode(REAL_MODE, totVolume, totWeight, quantityTotal);
	//self.getTotalsByMode(QUEUE_MODE, totVolQueue, totWgtQueue, qdQuantityTotal);
	//self.getTotalsByMode(PLANNING_MODE, totVolPlan, totWgtPlan, pdQuantityTotal);
	//qdQuantityTotal := sortTIsQueue.size;
	//pdQuantityTotal := sortTIsPlan.size;
	idx := 1;
	cargoSort := "";
	
	foreach ti in sortTIs discreteLock do
		//epr par 35905 26/3/15
		cargoSort := ti.getProductOrISODescr();
		if lastCargoSort &lt;&gt; "" and cargoSort &lt;&gt; lastCargoSort then
			idx := idx + 1;
		endif;
		//epr par 35905 26/3/15
		if sohCargoS.size &lt; idx then
			sohCargoS.add(null);
			sohVolumeS.add(null);
			sohWeightS.add(null);
			sohQuantityS.add(null);
			sohItemS.add(null);
		endif;
		
		if sohCargoS[idx] = "" then
			sohCargoS[idx] := cargoSort;
		endif;
		lastCargoSort := cargoSort;
		sohVolumeS[idx] := sohVolumeS[idx] + ti.totalVolume;
		sohWeightS[idx] := sohWeightS[idx] + ti.totalWeight;
		sohQuantityS[idx] := sohQuantityS[idx] + ti.totalQuantity;
		sohItemS[idx] := sohItemS[idx] + 1;
	endforeach;	
	
	idx := 1;
	cargoSort := "";
	lastCargoSort := "";
	foreach ti in sortTIsPlan discreteLock do
		//epr par 35905 26/3/15
		cargoSort := ti.getProductOrISODescr();
		if lastCargoSort &lt;&gt; "" and cargoSort &lt;&gt; lastCargoSort then
			idx := idx + 1;
		endif;
		//epr par 35905 26/3/15
		if sohCargoP.size &lt; idx then
			sohCargoP.add(null);
			sohVolumeP.add(null);
			sohWeightP.add(null);
			sohQuantityP.add(null);
			sohItemP.add(null);
		endif;
		
		if sohCargoP[idx] = "" then
			sohCargoP[idx] := cargoSort;
		endif;
		lastCargoSort := cargoSort;
		sohVolumeP[idx] := sohVolumeP[idx] + ti.totalVolume;
		sohWeightP[idx] := sohWeightP[idx] + ti.totalWeight;
		sohQuantityP[idx] := sohQuantityP[idx] + ti.totalQuantity;
		sohItemP[idx] := sohItemP[idx] + 1;
	endforeach;	
	
	idx := 1;
	cargoSort := "";
	lastCargoSort := "";
	foreach ti in sortTIsQueue discreteLock do
		//epr par 35905 26/3/15
		cargoSort := ti.getProductOrISODescr();
		if lastCargoSort &lt;&gt; "" and cargoSort &lt;&gt; lastCargoSort then
			idx := idx + 1;
		endif;
		//epr par 35905 26/3/15
		if sohCargoQ.size &lt; idx then
			sohCargoQ.add(null);
			sohVolumeQ.add(null);
			sohWeightQ.add(null);
			sohQuantityQ.add(null);
			sohItemQ.add(null);
		endif;
		
		if sohCargoQ[idx] = "" then
			sohCargoQ[idx] := cargoSort;
		endif;
		lastCargoSort := cargoSort;
		sohVolumeQ[idx] := sohVolumeQ[idx] + ti.totalVolume;
		sohWeightQ[idx] := sohWeightQ[idx] + ti.totalWeight;
		sohQuantityQ[idx] := sohQuantityQ[idx] + ti.totalQuantity;
		sohItemQ[idx] := sohItemQ[idx] + 1;
	endforeach;	

	// render the actual items
	if sohCargoS.size &gt; 0 then
		idxEnd := sohCargoS.size;
		idxSt := 1;
		idxQ := 1;
		idxP := 1;
		foreach idx  in idxSt to idxEnd discreteLock do
			if sohCargoS[idx] = "" then
				break;
			endif;
			create block transient;
			allBlocksArray.add(block);
			lineQuantity := 0;
			lineVolume := 0;
			lineWeight := 0;
			block.addNewItem(sohCargoS[idx], DC_Data, 1, null);
			if sohQuantityS[idx] = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(sohQuantityS[idx].String, DC_Data, 1, null); // actual quantity
				lineQuantity := sohQuantityS[idx];
				quantityTotal := quantityTotal + sohQuantityS[idx];
			endif;
			if sohVolumeS[idx] = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getVolumeForDefaultDisplay(sohVolumeS[idx]), DC_Data, 1, null);	// actual volume
				lineVolume := sohVolumeS[idx];
				totVolume := totVolume + sohVolumeS[idx];
			endif;
			if sohWeightS[idx] = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getWeightForDefaultDisplay(sohWeightS[idx]), DC_Data, 1, null);	// actual weight
				lineWeight := sohWeightS[idx];
				totWeight := totWeight + sohWeightS[idx];
			endif;
			// render any queued for this actual item
			if sohCargoS[idx] = sohCargoQ[idxQ] then
				if sohQuantityQ[idxQ] = 0 then
					block.addNewItem("", DC_Data, 1, null);
				else
					block.addNewItem(sohQuantityQ[idxQ].String, DC_Data, 1, null);	// queued quantity
					lineQuantity := lineQuantity + sohQuantityQ[idxQ];
					qdQuantityTotal := qdQuantityTotal + sohQuantityQ[idxQ];
				endif;
				if sohVolumeQ[idxQ] = 0 then
					block.addNewItem("", DC_Data, 1, null);
				else
					block.addNewItem(app.getVolumeForDefaultDisplay(sohVolumeQ[idxQ]), DC_Data, 1, null);	// queued volume
					lineVolume := lineVolume + sohVolumeQ[idxQ];
					totVolQueue := totVolQueue + sohVolumeQ[idxQ];
				endif;
				if sohWeightQ[idxQ] = 0 then
					block.addNewItem("", DC_Data, 1, null);
				else
					block.addNewItem(app.getWeightForDefaultDisplay(sohWeightQ[idxQ]), DC_Data, 1, null);	// queued weight
					lineWeight := lineWeight + sohWeightQ[idxQ];
					totWgtQueue := totWgtQueue + sohWeightQ[idxQ];
				endif;
				idxQ := idxQ + 1;
			else
				block.addNewItem("", DC_Data, 1, null);
				block.addNewItem("", DC_Data, 1, null);
				block.addNewItem("", DC_Data, 1, null);
			endif;
			// render any planned for this actual item
			if sohCargoS[idx] = sohCargoP[idxP] then
				if sohQuantityP[idxP] = 0 then
					block.addNewItem("", DC_Data, 1, null);
				else
					block.addNewItem(sohQuantityP[idxP].String, DC_Data, 1, null);	// planned quantity
					lineQuantity := lineQuantity + sohQuantityP[idxP];
					pdQuantityTotal := pdQuantityTotal + sohQuantityP[idxP];
				endif;
				if sohVolumeP[idxP] = 0 then
					block.addNewItem("", DC_Data, 1, null);
				else
					block.addNewItem(app.getVolumeForDefaultDisplay(sohVolumeP[idxP]), DC_Data, 1, null);	// planned volume
					lineVolume := lineVolume + sohVolumeP[idxP];
					totVolPlan := totVolPlan + sohVolumeP[idxP];
				endif;
				if sohWeightP[idxP] = 0 then
					block.addNewItem("", DC_Data, 1, null);
				else
					block.addNewItem(app.getWeightForDefaultDisplay(sohWeightP[idxP]), DC_Data, 1, null);	// planned weight
					lineWeight := lineWeight + sohWeightP[idxP];
					totWgtPlan := totWgtPlan + sohWeightP[idxP];
				endif;
				idxP := idxP + 1;
			else
				block.addNewItem("", DC_Data, 1, null);
				block.addNewItem("", DC_Data, 1, null);
				block.addNewItem("", DC_Data, 1, null);
			endif;
			// totals
			if lineQuantity  = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(lineQuantity.cnEcNumberFormat(), DC_Data, 1, null);
			endif;
			if lineVolume = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getVolumeForDefaultDisplay(lineVolume), DC_Data, 1, null);
			endif;
			if lineWeight = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getWeightForDefaultDisplay(lineWeight), DC_Data, 1, null);
			endif;
		endforeach;
		
		// render the remaining queued
		foreach idx in idxQ to sohCargoQ.size discreteLock do
			if sohCargoQ[idx] = "" then
				break;
			endif;
			create block transient;
			allBlocksArray.add(block);
			lineQuantity := 0;
			lineVolume := 0;
			lineWeight := 0;
			block.addNewItem(sohCargoQ[idx], DC_Data, 1, null);
			block.addNewItem("", DC_Data, 1, null);
			block.addNewItem("", DC_Data, 1, null);
			block.addNewItem("", DC_Data, 1, null);
			if sohQuantityQ[idx] = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(sohQuantityQ[idx].String, DC_Data, 1, null);	// queued quantity
				lineQuantity := sohQuantityQ[idx];
				qdQuantityTotal := qdQuantityTotal + sohQuantityQ[idx];
			endif;
			if sohVolumeQ[idx] = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getVolumeForDefaultDisplay(sohVolumeQ[idx]), DC_Data, 1, null);	// queued volume
				lineVolume := sohVolumeQ[idx];
				totVolQueue := totVolQueue + sohVolumeQ[idx];
			endif;
			if sohWeightQ[idx] = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getWeightForDefaultDisplay(sohWeightQ[idx]), DC_Data, 1, null);	// queued weight
				lineWeight := sohWeightQ[idx];
				totWgtQueue := totWgtQueue + sohWeightQ[idx];
			endif;
			// render any planned for this queued item
			if sohCargoQ[idx] = sohCargoP[idxP] then
				if sohQuantityP[idxP] = 0 then
					block.addNewItem("", DC_Data, 1, null);
				else
					block.addNewItem(sohQuantityP[idxP].String, DC_Data, 1, null);	// planned quantity
					lineQuantity := lineQuantity + sohQuantityP[idxP];
					pdQuantityTotal := pdQuantityTotal + sohQuantityP[idxP];
				endif;
				if sohVolumeP[idxP] = 0 then
					block.addNewItem("", DC_Data, 1, null);
				else
					block.addNewItem(app.getVolumeForDefaultDisplay(sohVolumeP[idxP]), DC_Data, 1, null);	// planned volume
					lineVolume := lineVolume + sohVolumeP[idxP];
					totVolPlan := totVolPlan + sohVolumeP[idxP];
				endif;
				if sohWeightP[idxP] = 0 then
					block.addNewItem("", DC_Data, 1, null);
				else
					block.addNewItem(app.getWeightForDefaultDisplay(sohWeightP[idxP]), DC_Data, 1, null);	// planned weight
					lineWeight := lineWeight + sohWeightP[idxP];
					totWgtPlan := totWgtPlan + sohWeightP[idxP];
				endif;
				idxP := idxP + 1;
			else
				block.addNewItem("", DC_Data, 1, null);
				block.addNewItem("", DC_Data, 1, null);
				block.addNewItem("", DC_Data, 1, null);
			endif;
			// totals
			if lineQuantity  = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(lineQuantity.cnEcNumberFormat(), DC_Data, 1, null);
			endif;
			if lineVolume = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getVolumeForDefaultDisplay(lineVolume), DC_Data, 1, null);
			endif;
			if lineWeight = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getWeightForDefaultDisplay(lineWeight), DC_Data, 1, null);
			endif;
		endforeach;

		// render the remaining planned
		foreach idx in idxP to sohCargoP.size discreteLock do
			if sohCargoP[idx] = "" then
				break;
			endif;
			create block transient;
			allBlocksArray.add(block);
			lineQuantity := 0;
			lineVolume := 0;
			lineWeight := 0;
			block.addNewItem(sohCargoP[idx], DC_Data, 1, null);
			block.addNewItem("", DC_Data, 1, null);
			block.addNewItem("", DC_Data, 1, null);
			block.addNewItem("", DC_Data, 1, null);
			block.addNewItem("", DC_Data, 1, null);
			block.addNewItem("", DC_Data, 1, null);
			block.addNewItem("", DC_Data, 1, null);
			if sohQuantityP[idx] = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(sohQuantityP[idx].String, DC_Data, 1, null);	// planned quantity
				lineQuantity := sohQuantityP[idx];
				pdQuantityTotal := pdQuantityTotal + sohQuantityP[idx];
			endif;
			if sohVolumeP[idx] = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getVolumeForDefaultDisplay(sohVolumeP[idx]), DC_Data, 1, null);	// planned volume
				lineVolume := sohVolumeP[idx];
				totVolPlan := totVolPlan + sohVolumeP[idx];
			endif;
			if sohWeightP[idx] = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getWeightForDefaultDisplay(sohWeightP[idx]), DC_Data, 1, null);	// planned weight
				lineWeight := sohWeightP[idx];
				totWgtPlan := totWgtPlan + sohWeightP[idx];
			endif;
			// totals
			if lineQuantity  = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(lineQuantity.cnEcNumberFormat(), DC_Data, 1, null);
			endif;
			if lineVolume = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getVolumeForDefaultDisplay(lineVolume), DC_Data, 1, null);
			endif;
			if lineWeight = 0 then
				block.addNewItem("", DC_Data, 1, null);
			else
				block.addNewItem(app.getWeightForDefaultDisplay(lineWeight), DC_Data, 1, null);
			endif;
		endforeach;
	endif;
		
	block := _dataContainer.addNewBlock;
	block.addNewItem("", DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(Actual), DC_LabelHeader, 3, null);
	block.addNewItem(app.getErrorString(Queued), DC_LabelHeader, 3, null);
	block.addNewItem(app.getErrorString(Planned), DC_LabelHeader, 3, null);
	block.addNewItem(app.getErrorString(Total), DC_LabelHeader, 3, null);
	block := _dataContainer.addNewBlock;
	block.addNewItem(null, DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Quantity), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Volume), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Weight), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Quantity), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Volume), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Weight), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Quantity), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Volume), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Weight), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Quantity), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Volume), DC_LabelHeader, 1, null);
	block.addNewItem(app.getErrorString(CM_Weight), DC_LabelHeader, 1, null);
	
	block := _dataContainer.addNewBlock();
	block.addNewItem(app.getErrorString(Total).toUpper &amp; "   ", DC_Data, 1, null);
	if quantityTotal = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(quantityTotal.cnEcNumberFormat(), DC_Data, 1, null);	// total quantity actual
	endif;
	if totVolume = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(app.getVolumeForDefaultDisplay(totVolume), DC_Data, 1, null);	// total volume actual
	endif;
	if totWeight = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(app.getWeightForDefaultDisplay(totWeight), DC_Data, 1, null);	// total weight actual
	endif;
	if qdQuantityTotal = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(qdQuantityTotal.cnEcNumberFormat(), DC_Data, 1, null);	// total quantity queued
	endif;
	if totVolQueue = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(app.getVolumeForDefaultDisplay(totVolQueue), DC_Data, 1, null);	// total volume queued
	endif;
	if totWgtQueue = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(app.getWeightForDefaultDisplay(totWgtQueue), DC_Data, 1, null);	// total weight queued
	endif;
	if pdQuantityTotal = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(pdQuantityTotal.cnEcNumberFormat(), DC_Data, 1, null);	// total quantity planned
	endif;
	if totVolPlan = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(app.getVolumeForDefaultDisplay(totVolPlan), DC_Data, 1, null);	// total volume planned
	endif;
	if totWgtPlan = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(app.getWeightForDefaultDisplay(totWgtPlan), DC_Data, 1, null);	// total weight planned
	endif;
	if quantityTotal + qdQuantityTotal + pdQuantityTotal = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem((quantityTotal + qdQuantityTotal + pdQuantityTotal).cnEcNumberFormat(), DC_Data, 1, null);	// total quantity
	endif;
	if totVolume + totVolQueue + totVolPlan = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(app.getVolumeForDefaultDisplay(totVolume + totVolQueue + totVolPlan), DC_Data, 1, null);	// total volume
	endif;
	if totWeight + totWgtQueue + totWgtPlan = 0 then
		block.addNewItem("", DC_Data, 1, null);
	else
		block.addNewItem(app.getWeightForDefaultDisplay(totWeight + totWgtQueue + totWgtPlan), DC_Data, 1, null);	// total weight
	endif;
	
	if app.isSpecial() then
		block := _dataContainer.addNewBlock();
		block.addNewItem("GC Controller", DC_MoreInfo, 2, self);
		block.addNewItem(self.String, DC_Data, 2, self);
		block.addNewItem("Voyage", DC_MoreInfo, 2, self.myBulkDrawingController.myVoyage);
		block.addNewItem(self.myBulkDrawingController.myVoyage.String, DC_Data, 2, self.myBulkDrawingController.myVoyage);
	endif;
	
	// Add the spec details after the summary details.
	_dataContainer.addMultipleBlocks(allBlocksArray);

epilog
	delete allBlocksArray;
	delete sortTIs;
	delete sortTIsPlan;
	delete sortTIsQueue;
	delete sohVolumeS;
	delete sohWeightS;
	delete sohCargoS;
	delete sohItemS;
	delete sohQuantityS;
	delete sohVolumeP;
	delete sohWeightP;
	delete sohCargoP;
	delete sohItemP;
	delete sohQuantityP;
	delete sohVolumeQ;
	delete sohWeightQ;
	delete sohCargoQ;
	delete sohItemQ;
	delete sohQuantityQ;
	delete allTIs;
	delete allTIsPlan;
	delete allTIsQueue;
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getObjectAndPointsForPosition" id="cdc6a788-f9ca-4611-a0b7-5dce84c1e8ea">
        <source>getObjectAndPointsForPosition(x: Integer; y: Integer; xy1: Point output; xy2: Point output): Object;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	drawingController : SHP_BulkDrawingController;

begin
	drawingController := self.myBulkDrawingController;
	if drawingController = null then
		return null;
	endif;
	
	if y &lt;= drawingController.yDeckPos or self.myHold.isKindOf(CM_ShipBlockController) then
		return self.allObjectsOnDeck.findObjectInDict(x, y, xy1, xy2);
	endif;
	
	return self.allObjectsUnderDeck.findObjectInDict(x, y, xy1, xy2);
epilog

end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="xy1" type="Point" usage="output"/>
        <Parameter name="xy2" type="Point" usage="output"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getObjectForPosition" id="9bc2fd5d-016d-453e-bc10-cca241a3a3a4">
        <updating/>
        <source>getObjectForPosition(x: Integer; y: Integer): Object updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	xy1, xy2 : Point;
	
begin
	return self.getObjectAndPointsForPosition(x, y, xy1, xy2);

epilog

end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
