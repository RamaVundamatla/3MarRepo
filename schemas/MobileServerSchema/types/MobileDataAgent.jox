*/

vars

begin
	myRoadJob := roadJob;
	app.myTrxUA.trxUpdateRoadJobDevices(self.myRoadJob, _strDevice, self.myRoadJob.Add_Device, app.myPassport);
end;</source>
        <Parameter name="roadJob" type="CM_RoadJob"/>
        <Parameter name="_strDevice" type="String"/>
    </JadeMethod>
    <JadeMethod name="showMessage" id="b31b7d89-bf5b-453c-bc18-67326313039b">
        <updating/>
        <source>showMessage(_str	: String; _isError : Boolean; _warnings : Boolean io) : Boolean updating;
/*
	Created on 01 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

//	frm	: HeyYouMessageForm;
	
begin

	if _str = null then
		return false;
	endif;
	
	if _isError then
		if _warnings then
			if not app.msgBox(	_str &amp; CrLf &amp; 'Do you wish to continue?',
								'Warning',
								MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
				_warnings := false;
			else
				return true;
			endif;
		else
			app.msgBox(_str, 'Error', MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		endif;
	else
		app.msgBox(_str, 'Information', MsgBox_Information_Icon + MsgBox_OK_Only);
	endif;
	return false;
end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_isError" type="Boolean"/>
        <Parameter name="_warnings" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="writeSystemColorsToIni" id="5cd028e6-33ca-4958-ad6e-86e45f717b4d">
        <source>writeSystemColorsToIni(_sysBackColorGeneral, _sysForeColorGeneral, _sysBackColorTable, _sysForeColorTable : Integer);
/*
	Created on 02 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/
vars
	iniFileName	: String;
begin
	iniFileName := app.getIniFileName();
	app.setProfileString(iniFileName, RTIniFileSection, RTBackColourForm, _sysBackColorGeneral.String);
	app.setProfileString(iniFileName, RTIniFileSection, RTForeColourGeneral, _sysForeColorGeneral.String);
	app.setProfileString(iniFileName, RTIniFileSection, RTBackColourTable, _sysBackColorTable.String);
	app.setProfileString(iniFileName, RTIniFileSection, RTForeColourTable, _sysForeColorTable.String);
end;</source>
        <Parameter name="_sysBackColorGeneral" type="Integer"/>
        <Parameter name="_sysForeColorGeneral" type="Integer"/>
        <Parameter name="_sysBackColorTable" type="Integer"/>
        <Parameter name="_sysForeColorTable" type="Integer"/>
    </JadeMethod>
