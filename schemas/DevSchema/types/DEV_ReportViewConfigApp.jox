    <JadeMethod name="txtFilter_keyUp" id="cda69862-bb0c-4dbf-929d-f9910067d7da">
        <controlMethod name="TextBox::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtFilter_keyUp(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2023	navkc1	Initial creation

*/

vars
	type,
	remaining	: Integer;
	
begin
	
	if self.getTimerStatus(self.FilterFieldTable, type, remaining) then
		self.endTimer(self.FilterFieldTable);
	endif;
	
	self.beginTimer(1000, Timer_OneShot, self.FilterFieldTable);
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
</GUIClass>
