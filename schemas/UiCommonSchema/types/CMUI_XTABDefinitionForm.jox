Date				Who		Reason
12 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	
begin
	// the double click is to run the summary definition
	self.btnRunDefn.click( self.btnRunDefn );
	
epilog
	
end;
</source>
