    <JadeMethod name="getSelectedCashDebtors" id="68f64e9d-2c6e-4d76-a9f0-36c08d7d856f">
        <source>getSelectedCashDebtors( _cashDebtors : CM_DebtorSet input );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars
	obj : Object;
begin
	if _cashDebtors = null then
		app.raiseCMException2( MethodWithNullParam, method.name, '_cashDebtors', null, null );
		return;
	endif;
	_cashDebtors.clear();
	
	if not self.isRowIncluded( ETRow_CashDebtors ) then
		return;
	endif;
	
	foreach obj in self.myLstCashDrs.allSelectedObjects do 
		if not obj.isKindOf( CM_Debtor ) then
			continue;
		endif;
		_cashDebtors.add( obj.CM_Debtor );
	endforeach;

epilog

end;</source>
