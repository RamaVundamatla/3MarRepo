    <JadeMethod name="tblCompare_click" id="034265f7-5826-48f0-8319-4cdba0ee5980">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCompare_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2014	cnwndl1	Initial creation

*/

vars

	colUpdateValue : Integer;
	colCompareValue : Integer;
	colCurrentValue : Integer;
	rowIndex : Integer;
	cmif : CMIF_ConfigOptionsDisplay;
	newValue : String;
	msg : String;

begin

	colUpdateValue := self.tblCompare.getColumnByRowName(ETRow_UpdateValue);
	
	rowIndex := self.tblCompare.row;
	if self.tblCompare.column = colUpdateValue and rowIndex &gt; 1 then
		colCompareValue := self.tblCompare.getColumnByRowName(ETRow_CompareValue);
		colCurrentValue := self.tblCompare.getColumnByRowName(ETRow_CurrentValue);
		if colCompareValue &gt; 0 then
			rowIndex := self.tblCompare.row;
			if doTblCompareColumnValuesMatch(	rowIndex, colCurrentValue, colCompareValue ) then
				self.tblCompare.setCellText( rowIndex, colUpdateValue, "0" );
				self.doColourConfigTable( colCurrentValue, colCompareValue, 0 );
				return;
			endif;
			newValue := self.tblCompare.accessCell( rowIndex, colCompareValue ).text;
			cmif := self.tblCompare.accessRow( rowIndex ).itemObject.CMIF_ConfigOptionsDisplay;
			msg := "Are you sure you want to update '" &amp; cmif.optionName &amp; "' to '" &amp; newValue &amp; "'.";
			if app.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No ) = MsgBox_Return_Yes then
				if not cmif.setNewCurrentValue(self.myTerminal,newValue) then
					self.tblCompare.setCellText( rowIndex, colUpdateValue, "0" );
					self.btnJumpTo.click(self.btnJumpTo);
					return;
				else
					self.redisplayCMIFsMatching( cmif );
				endif;
			endif;
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblCompare_contextMenu" id="490e9f33-f7e4-4d3f-8426-2abd7da9aa37">
