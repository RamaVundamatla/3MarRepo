    <JadeMethod name="setMoveControllerSource" id="f7751748-309c-4dfc-9d7b-7b5cbb838af7">
        <updating/>
        <source>setMoveControllerSource(_ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	moveController	: CMIF_MoveController;
	moveMode : Integer;
begin

	create moveController transient;
	
	moveController.setMyTrackedItem(_ti);
	delete app.myMoveController;
	app.myMoveController := moveController;
	if self.frmStatusLine.displayMode = DISPLAY_MODE_ACTUAL then
		moveMode := REAL_MODE;
	elseif self.frmStatusLine.displayMode = DISPLAY_MODE_PLAN then
		moveMode := PLANNING_MODE;
	elseif self.frmStatusLine.displayMode = DISPLAY_MODE_QUEUE then
		moveMode := QUEUE_MODE;
	endif;

	moveController.setMyOriginatingLocation(_ti.getPrimaryLocation(moveMode));
//	moveController.setMyOriginatingLocation(_ti.getPrimaryLocation(self.moveModeForm));	//REAL_MODE));
	moveController.setMoveMode(self.moveModeForm);	
	moveController.isRehandleMove := _ti.isRehandle;
	moveController.myOriginatingForm := self;
//	moveController.isOverstowMove := _ti.isOverStowed(REAL_MODE);

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setMoveControllerTarget" id="7c2b0f88-747a-4797-a53a-bac3083b52ed">
