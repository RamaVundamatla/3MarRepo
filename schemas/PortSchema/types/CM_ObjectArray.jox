    <JadeMethod name="copyFoo" id="78dbac15-34f8-44c4-9f55-c04e9ffbcb15">
        <source>copyFoo(_coll : Collection input);
/*
 ------------------------------------------------------------------------
Created:			17 October 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	ob : Object;
begin
	foreach ob in self where not _coll.includes(ob) do
		_coll.add(ob.Object);
	endforeach;
end;</source>
        <Parameter name="_coll" type="Collection" usage="input"/>
    </JadeMethod>
