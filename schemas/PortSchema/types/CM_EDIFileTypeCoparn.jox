    <JadeMethod name="setRawCommodityValue" id="dd2c2ffb-87ee-4c51-87e2-aaaed5b08b55">
        <source>setRawCommodityValue(_group :Integer; _ediTI: CM_EDIBookingItemTI; _value :String) protected;
/*
Date		Who		Reason
09 April 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
10 Sep   2015	cnwma1	PAR #36737 COPARN Booking Commodity
*/
vars
	key, value	:String;
	coll		:CM_StateDataDict;
begin
	key 	:= ETRow_CommodityDesc;
	coll	:= _ediTI.getAllExtraData;
	
	if _group = 3 then
		key := key &amp; '3';
		//global.setExtraData (coll, _ediTI, key, _value);  //10/09/2015 cnwma1 PAR #36737
		global.getExtraData (coll, key, value);			    //10/09/2015 cnwma1 PAR #36737
		
		if value &lt;&gt; null then
			value := value &amp; ':' &amp; _value;
		else
			value := _value;
		endif;
		
		global.setExtraData (coll, _ediTI, key, value);
	elseif _group = 7 then
		key := key &amp; '7';
		
		global.getExtraData (coll, key, value);
		
		if value &lt;&gt; null then
			value := value &amp; ':' &amp; _value;
		else
			value := _value;
		endif;
		
		global.setExtraData (coll, _ediTI, key, value);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_group" type="Integer"/>
        <Parameter name="_ediTI" type="CM_EDIBookingItemTI"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
</Class>
