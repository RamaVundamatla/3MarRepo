    <JadeMethod name="doTblDataContextMenu" id="88683ffc-c089-45fe-98d1-37a96a7895cc">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 February 2010	cnwrd1	Initial creation

*/

vars

	interTerminalMove 	: CM_InterTerminalMove;

begin

	self.mnuContextColourLegend.visible := false;
	self.mnuContextHide.visible   := false;
	self.mnuLoadTruckEG.visible   := false;
	self.mnuReturnTruckEG.visible := false;
	self.mnuReturnYardEG.visible  := false;
	self.mnuUnloadTruckEG.visible := false;
	self.mnuDeleteLoadEG.visible  := false;
	self.mnuCompleteEG.visible    := false;
	self.mnuEasyGateSep.visible   := true;

	interTerminalMove := self.myCurrentInterTerminalMove;
	if interTerminalMove = null then
		self.setButtonsForView(); // TFS 2734
		return inheritMethod(cntrl, conwin, mouse,x,y);
	endif;
	
	if interTerminalMove.status = ITT_LOADING then
		if interTerminalMove.mySourceTerminal = self.myTerminal then
			self.mnuDeleteLoadEG.visible  := true;
			self.mnuCompleteEG.visible    := true;
			self.mnuLoadTruckEG.visible   := true;
			self.mnuReturnYardEG.visible  := true;
		endif;
	elseif interTerminalMove.status = ITT_LOADED then
		if interTerminalMove.myTargetTerminal = self.myTerminal then
			self.mnuUnloadTruckEG.visible := true;		
		else
			self.mnuReturnYardEG.visible  := true; // can return to yard if we are at our source terminal
		endif;
		//self.mnuDeleteLoadEG.visible  := true;
	elseif interTerminalMove.status = ITT_UNLOADING then
		if interTerminalMove.myTargetTerminal = self.myTerminal then
			self.mnuUnloadTruckEG.visible := true;
			//self.mnuCompleteEG.visible    := true;
			//self.mnuDeleteLoadEG.visible  := true;
			self.mnuReturnTruckEG.visible := true;
		endif;
	elseif interTerminalMove.status = ITT_UNLOADED then
		//self.mnuDeleteLoadEG.visible := true;
	endif;
	
	
	self.setButtonsForView(); // TFS 2734

	return inheritMethod(cntrl, conwin, mouse,x,y);

epilog

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
