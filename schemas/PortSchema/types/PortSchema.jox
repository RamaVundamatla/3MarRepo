    <JadeMethod name="getApplicationTempDirectory" id="39648e4b-9a83-4e89-8c81-64494c0fd14c">
        <source>getApplicationTempDirectory(): String;
// -------------------------------------------
// Created 23 October 2003 by cnwdvb1
// -------------------------------------------
vars

begin
	//PAR22336 - cnwsh3 - 30/07/2010 - checked for usage and it appears it is used for email processing.  External email apps may rely on 
	//the temp dir so have not made any changes to try for the JMT system temp directory (app.getTempDirFromSystemConfig)
	if node.isApplicationServer then 
		return app.getTempDirAppServer;
	else
		return app.getTempDir;
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAppnameMutexLock" id="412d1a2f-f45a-49fc-bd58-b522cd27bb18">
        <source>getAppnameMutexLock( _context : Integer; _lockedMutex : CM_Mutex output ): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2021	navndl1	Initial creation	TFS 50488

*/

vars

	mutex : CM_Mutex;
	collLocked : Boolean;
	pxyMutex : CM_Mutex;

begin

	if process.isInTransactionState then
		app.writeLog(method.qualifiedName &amp; " failed to get mutex for " &amp; app.name &amp; " [" &amp; _context.String &amp; "], in trans state.", LogWARN);
		return false;
	endif;

	mutex := app.myRoot.allMutexes.getAtKey( app.name, _context );
	if mutex = null then
		if self.tryLock( app.myRoot.allMutexes, Exclusive_Lock, Transaction_Duration,  LockTimeout_Immediate ) then
			collLocked := true;
			
			//15 Sep 2021	NDL	TFS 511142
			create pxyMutex transient;
			pxyMutex.setDetails( app.myRoot, null, app.name, _context ); 
									
			beginTransaction;
			//create mutex persistent;
			//mutex.setDetails( app.myRoot, null, app.name, _context );
			app.myUtilityCA.utlCreateMutex( pxyMutex, mutex, app.myPassport );//15 Sep 2021	NDL	TFS 511142
			commitTransaction;
			
			delete pxyMutex;//15 Sep 2021	NDL	TFS 511142
			app.writeLog(method.qualifiedName &amp; " created new mutex for " &amp; app.name &amp; " [" &amp; _context.String &amp; "].", LogINFO);
		else
			app.writeLog(method.qualifiedName &amp; " failed to create mutex for " &amp; app.name &amp; " [" &amp; _context.String &amp; "], mutex collection locked.", LogWARN);
			return false;
		endif;
	endif;

	if self.tryLock( mutex, Exclusive_Lock, Transaction_Duration,  LockTimeout_Immediate ) then
		_lockedMutex := mutex;
		return true;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " failed to get lock on mutex for " &amp; app.name &amp; " [" &amp; _context.String &amp; "].", LogINFO);
	return false;

epilog

	if collLocked then
		self.unlock( app.myRoot.allMutexes );
	endif;
	delete pxyMutex;

end;</source>
        <Parameter name="_context" type="Integer"/>
        <Parameter name="_lockedMutex" type="CM_Mutex" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getBGPControllerForRequest" id="519ac48b-5c24-460b-81a5-a61769d9da22">
        <source>getBGPControllerForRequest(_requestName : String; _isRunning : Boolean) : BGP_Controller;
/*
Purpose:			if not running then it is configured, just because it exists.

Date		Who		Reason
03AUG2021	NAVAB1	TFS 50669
*/


vars
	controller		: BGP_Controller;
	manager			: BGP_Manager;
	
begin
	foreach manager in app.myRoot.allBGPManagers discreteLock do
		foreach controller in manager.allBGPControllers discreteLock do
			if controller.allRequestClassesToProcess.includes(_requestName) then
				if _isRunning then 
					if _isRunning = controller.isRunning() then
						return controller;
					endif;
				else // do not care if running or not, just want what is confugred
					return controller;
				endif;
			endif;
		endforeach;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_requestName" type="String"/>
        <Parameter name="_isRunning" type="Boolean"/>
        <ReturnType type="BGP_Controller"/>
    </JadeMethod>
    <JadeMethod name="getBGPManagerForRequest" id="8b90bf9f-69a6-4f11-ba67-d822b1b392ef">
        <source>getBGPManagerForRequest(_requestName : String; _isRunning : Boolean) : BGP_Manager;
/*
Purpose:			if not running then it is configured, just because it exists.

Date		Who		Reason
03AUG2021	NAVAB1	TFS 50669
*/


vars
	controller		: BGP_Controller;
	manager			: BGP_Manager;
	
begin
	foreach manager in app.myRoot.allBGPManagers discreteLock do
		foreach controller in manager.allBGPControllers discreteLock do
			if controller.allRequestClassesToProcess.includes(_requestName) then
				if _isRunning then 
					if _isRunning = controller.isRunning() then
						return manager;
					endif;
				else // do not care if running or not, just want what is confugred
					return manager;
				endif;
			endif;
		endforeach;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_requestName" type="String"/>
        <Parameter name="_isRunning" type="Boolean"/>
        <ReturnType type="BGP_Manager"/>
    </JadeMethod>
    <JadeMethod name="getBookingRefStatusString" id="ad5b721f-d193-4ec4-bdb7-7df67f9ed063">
        <source>getBookingRefStatusString(_status : Integer) : String;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		29 September 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change

//----------------------------------------------------------------------
vars

begin
	if _status = BOOKING_REF_PENDING then
		return app.getErrorString(Pending);
	elseif _status = BOOKING_REF_ACTIVE then
		return app.getErrorString(Active);
	elseif _status = BOOKING_REF_CLOSED then
		return app.getErrorString(Closed);
	elseif _status = BOOKING_REF_ARCHIVED then
		return app.getErrorString(Archived);
	elseif _status = -1 then
		return Any_String;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
