<Class name="HMS_DraftTidalData" id="e817e52a-9cfa-498a-af17-c12cd7ab4310">
    <superclass name="HMS_TidalData"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="hms"/>
    <PrimAttribute name="height" id="c6af5929-659e-418f-8e1e-7f49c216ca96">
        <embedded/>
        <type name="Real"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDataType" id="ed931a2c-faa4-4fc0-878f-23020b8389c0">
        <source>getDataType(): Integer;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return HMS_TidalDataType_Height;

end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getValue" id="48752c00-3762-4223-908a-bdf053a0df31">
        <source>getValue() : Decimal;
/*
----------   ----------  --------------------------------------------------
Created:	18 October 2006 By cnwth2

Purpose:	

Date		Who		Reason
02 May 2008	cnwkpd1	PAR #16642 - signature change to return a Decimal, to correct issues with
					Real imprecision

*/

vars

begin
	return height.Decimal.roundedTo(2);

	
end;


</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="45ded318-6d5c-4509-a720-5902158877d7">
        <updating/>
        <source>setForUpdate(_pxyTidalData: HMS_DraftTidalData; _passport: CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod(_pxyTidalData, _passport);

	self.height := _pxyTidalData.height;
end;


</source>
        <Parameter name="_pxyTidalData" type="HMS_DraftTidalData"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="6173c18a-fdb0-4b0c-bf37-781985665a91">
        <updating/>
        <source>setProxy(_ts 			: TimeStamp;
		_tidalModelDef 	: HMS_TidalModelDefinition;
		_height 		: Real) updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.ts 		:= _ts;
	self.myTidalModelDefinition := _tidalModelDef;
	self.height 	:= _height;
	
end;


</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_tidalModelDef" type="HMS_TidalModelDefinition"/>
        <Parameter name="_height" type="Real"/>
    </JadeMethod>
