    <JadeMethod name="removeBinary" id="c4afbd49-056e-4aa0-9647-450976ac95e2">
        <lockReceiver/>
        <updating/>
        <source>removeBinary(pBinaryValue:Binary):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 by cnwdad1
//
// Purpose:		Removes an array element which has a specified binary value.
//
// Parameters:	pBinaryValue (Binary) - The value to scan for in the array.
// Returns:		Boolean - True is an element was removed, false if not.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	elementsToDelete	: ObjectArray;
	object				: Object;
	arrayElement		: JSSArrayElement;
	isRemoved			: Boolean;

begin
	create elementsToDelete transient;

	// Find the array elements to be removed.

	foreach arrayElement in self do
		if arrayElement.getBinaryValue() = pBinaryValue then
			elementsToDelete.add(arrayElement);
		endif;
	endforeach;

	// Now removed the matching array elements.

	foreach object in elementsToDelete do
		self.remove(object.JSSArrayElement);

		if (not isRemoved) then
			isRemoved	:=	true;
		endif;
	endforeach;
epilog
	delete elementsToDelete;

	return isRemoved;
end;</source>
        <Parameter name="pBinaryValue" type="Binary"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeString" id="d632fefe-3566-4b18-ae0f-3082732e42ad">
        <lockReceiver/>
        <updating/>
        <source>removeString(pStringValue:String):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 by cnwdad1
//
// Purpose:		Removes an array element which has a specified string value.
//
// Parameters:	pStringValue (String) - The value to scan for in the array.
// Returns:		Boolean - True is an element was removed, false if not.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	elementsToDelete	: ObjectArray;
	object				: Object;
	arrayElement		: JSSArrayElement;
	isRemoved			: Boolean;

begin
	create elementsToDelete transient;

	// Find the array elements to be removed.

	foreach arrayElement in self do
		if arrayElement.getStringValue() = pStringValue then
			elementsToDelete.add(arrayElement);
		endif;
	endforeach;

	// Now removed the matching array elements.

	foreach object in elementsToDelete do
		self.remove(object.JSSArrayElement);

		if (not isRemoved) then
			isRemoved	:=	true;
		endif;
	endforeach;
epilog
	delete elementsToDelete;

	return isRemoved;
end;</source>
        <Parameter name="pStringValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
