    <JadeMethod name="clickArgShowAllSelected" id="7e77ad53-0a55-494f-8223-901e1118c040">
        <source>clickArgShowAllSelected( optionbutton: OptionButton input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/
vars

	tbl : CMUI_ListTable;
	checkBoxColumn : Integer;
	rowIndex : Integer;

begin

	tbl:= self.tblArgument;
	checkBoxColumn := tbl.getChkBoxColumn;

	if optionbutton = self.optAll and self.optAll.value
	or optionbutton = self.optSelected and not self.optSelected.value
	then
		//show all
		foreach rowIndex in 1 to tbl.rows do
			tbl.accessRow( rowIndex ).visible := true;
		endforeach;
	else
		//show only selected
		foreach rowIndex in 1 to tbl.rows do
			tbl.accessRow( rowIndex ).visible := tbl.accessCell( rowIndex, checkBoxColumn ).text = '1';
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
