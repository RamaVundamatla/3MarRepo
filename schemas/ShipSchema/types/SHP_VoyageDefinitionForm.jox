    <JadeMethod name="unload" id="3e524646-e0d5-4dca-8007-4496fe9aa6d3">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
//--------------------------------------------------
// Created:	29 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
    self.endClassNotification(CM_FileData,false,Object_Create_Event);
	self.endClassNotification(CM_FileData,false,Object_Delete_Event);
	self.allProxies.purge();
	self.allProxyCutoffs.purge(); // ### JIRA 34233 11MAR 2025 NAVAB1
	
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="9964ae12-fefe-41e0-a7a9-3834f640d53d">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	event : Integer;

begin

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	if event = Voyage_Update_Event or eventType = Voyage_Update_Event then
		self.loadTblWPOpHrs();
		self.displayHMSMovements();	//19 Nov 2018	NDL	TFS 42043
	elseif event.isOneOf(EVENT_DELAY_CREATE, EVENT_DELAY_UPDATE, EVENT_DELAY_DELETE) then	// PAR #35397
		self.displayHMSDelay();																// PAR #35397
		return;																				// PAR #35397
	elseif event = ROROExportAutoQueue then // ### TFS CR 57138 TASK 57310 27MAR2023 NAVAB1
		if self.myCurrentVoyage &lt;&gt; null and not self.myCurrentVoyage.isAutomaticProcess() then																				//navra1 - MTN-33086 - 21st Oct 2024
			app.msgBox(app.getErrorString1(Statu_chang_expor_items_have_b, self.myCurrentVoyage.statusDescription),app.getErrorString(Information),MsgBox_OK_Only);
		endif;																																								//navra1 - MTN-33086 - 21st Oct 2024
	endif;

	self.doUserNotifyStructuralTables(eventType,theObject,eventTag, userInfo);
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateDateTimes" id="736dca80-dee8-4866-a1e5-32f584197849">
        <updating/>
        <source>validateDateTimes() : Boolean updating;
//--------------------------------------------------
// Created:	14 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpTime,
	tmpArrivedDT,
	tmpDepartedDT : TimeStamp;
	voyage 	: CM_Voyage;
	invalidObject: Boolean;
	edition : Integer;
begin
	//They must enter arrival/departue DT when creating HMS data
	// do before setting voyage as needed on the voyage
	tmpArrivedDT.setDate(self.dateArrival.getDate());
	tmpArrivedDT.setTime(self.timeArrival.getTime()); 
	tmpDepartedDT.setDate(self.dateDeparture.getDate()); 
	tmpDepartedDT.setTime(self.timeDeparture.getTime()); 

	on Exception do app.handleDeletedObject(exception,voyage, invalidObject);
	
	voyage:=self.myCurrentVoyage;
	if voyage &lt;&gt; null then
		edition:=voyage.edition;
	endif;
	if invalidObject then
		self.myCurrentVoyage:=null;
		self.myCopyGCStruct := null;	//10 Jul 2013	NDL	Par 31965
	endif;
	
	if self.ckbCreateHMSData.value then
//	or (self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.myHMSVoyageData &lt;&gt; null) then			// 19/8/19 MAP TFS45926
		if (not tmpArrivedDT.isValid) then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Arrival Date/Time', null, null);
			app.raiseCMException(Input_required_field_arrDatTim, null, null); // cnwdb2	PAR 35364
			return false;
		elseif (not tmpDepartedDT.isValid) then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Departure Date/Time', null, null);
			app.raiseCMException(Input_required_field_dptDatTim, null, null); // cnwdb2	PAR 35364
			return false;
		elseif tmpArrivedDT &gt;= tmpDepartedDT then
			app.raiseCMException1(AutoScheduleDateError, "The arrival date/time must be before the departure date/time", null, null);
			return false;
		endif;
		
	elseif tmpArrivedDT.isValid
	and tmpDepartedDT.isValid then
		if tmpArrivedDT &gt;= tmpDepartedDT then
			app.raiseCMException1(AutoScheduleDateError, "The arrival date/time must be before the departure date/time", null, null);
			return false;
		endif;
	endif;

	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateHoldName" id="2b487d05-a235-41f6-9fff-cf17ce0d1765">
        <updating/>
        <source>validateHoldName(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2015	cnwma1	Initial creation PAR # 35519 1035 Error String Too Long

*/

vars
	cc	: CM_GeneralCargoController;
	maxLength: Integer;
	voyage  : CM_Voyage;
	invalidObject :Boolean;
	maxHoldName :String;
begin
	
	on Exception do app.handleDeletedObject(exception,voyage, invalidObject);
	
	voyage:=self.myCurrentVoyage;

	if invalidObject then
		self.myCurrentVoyage:=null;
	endif;
	
	if voyage &lt;&gt; null then
		if voyage.myGeneralCargoVoyage &lt;&gt; null then
	
			if not voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.isEmpty() then
			
				foreach  cc in voyage.myGeneralCargoVoyage.allLocationsByHatchPlace do
				
					if not (cc.validateHoldName(self.txtVoyageCode.text )) then
						return false;
					endif;
				endforeach;
			endif;		
		endif;
	endif;

	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validatecurrentStatusInProcess" id="b63175ec-3930-4a01-aa7c-238188d2c144">
        <source>validatecurrentStatusInProcess(voyageProcess : CM_VoyageProcess; currentStatus : Integer) : Boolean;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 09 August 2019
TFS#		: 45467
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	status : CM_VoyageStatus;
begin
	if voyageProcess = null then
		return false;
	endif;
	
	foreach status in voyageProcess.allStatuses do
		if status.id = currentStatus then
			return true;			
		endif;
	endforeach;
	
return false;
end;</source>
        <Parameter name="voyageProcess" type="CM_VoyageProcess"/>
        <Parameter name="currentStatus" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
