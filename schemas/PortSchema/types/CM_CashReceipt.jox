    <JadeMethod name="isNextProformaStatusValid" id="addcef32-0ad1-4a4b-b850-8777345e3b65">
        <source>isNextProformaStatusValid(_nextStatus : Integer; _nextValidStatusMsg : String output; _isFromJMT : Boolean) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/07/2024	navkc1 CR 64838 Task 64853: Jade - New Cash API putProformaStatus

*/

vars
	valid : Boolean;
begin
	
	//06/06/2025	navkc1 JIRA MTN 34779 - Updating status from JMT &gt; Cash Receipt Enquiry screen
	if _isFromJMT then
		/* Valid scenario
			If changing from Cash Receipt Enquiry screen, allows
				Hold &gt; Draft
				Hold &gt; Cancelled
				Hold &gt; Final
		*/
		if self.paymentStatus = self.API_RECEIPT_HOLD then
			if 	_nextStatus = self.API_RECEIPT_CANCELLED or 
				_nextStatus = self.API_RECEIPT_DRAFT or	
				_nextStatus = self.API_RECEIPT_FINAL
				then
					valid := true;
			endif;
			
			if not valid then
				_nextValidStatusMsg := 	app.paymentStatusCashEnumToString(self.API_RECEIPT_DRAFT) &amp; "/" &amp;
						app.paymentStatusCashEnumToString(self.API_RECEIPT_CANCELLED) &amp; "/" &amp;
						app.paymentStatusCashEnumToString(self.API_RECEIPT_FINAL);
			endif;
		endif;
	else
		/* Valid scenario
			Draft &gt; Hold
			Draft &gt; Expire
			Draft &gt; Cancelled
		*/
		if self.paymentStatus = self.API_RECEIPT_DRAFT then
			if 	_nextStatus = self.API_RECEIPT_HOLD or	
				_nextStatus = self.API_RECEIPT_EXPIRED or
				_nextStatus = API_RECEIPT_CANCELLED then
					valid := true;
			endif;
			
			if not valid then
				_nextValidStatusMsg :=	app.paymentStatusCashEnumToString(self.API_RECEIPT_HOLD) &amp; "/" &amp; 
									app.paymentStatusCashEnumToString(self.API_RECEIPT_EXPIRED) &amp; "/" &amp;
									app.paymentStatusCashEnumToString(self.API_RECEIPT_CANCELLED);
			endif;
		/* Valid scenario
		Hold &gt; Paid
		Hold &gt; Cancelled
		*/
		elseif self.paymentStatus = self.API_RECEIPT_HOLD then
			if 	_nextStatus = self.API_RECEIPT_PAID or
				_nextStatus = self.API_RECEIPT_CANCELLED
				then
					valid := true;
			endif;
			
			if not valid then
				_nextValidStatusMsg &amp;= 	app.paymentStatusCashEnumToString(self.API_RECEIPT_PAID) &amp; "/" &amp; 
							app.paymentStatusCashEnumToString(self.API_RECEIPT_CANCELLED);
			endif;
		
		/* Valid scenario
		Paid &gt; Final
		*/
		elseif self.paymentStatus = self.API_RECEIPT_PAID then
			if _nextStatus = self.API_RECEIPT_FINAL then
				valid := true;
			endif;
			
			if not valid then
				_nextValidStatusMsg := app.paymentStatusCashEnumToString(self.API_RECEIPT_FINAL);
			endif;
		endif;
	endif;
	
	return valid;
epilog

end;</source>
        <Parameter name="_nextStatus" type="Integer"/>
        <Parameter name="_nextValidStatusMsg" type="String" usage="output"/>
        <Parameter name="_isFromJMT" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isNotPaidByAPI" id="6e234310-c4d1-4f21-bed6-d184952c51f8">
        <source>isNotPaidByAPI() : Boolean;
/*
Purpose:	

Date		Who		Reason
07 January 2025	navab1	JIRA 33765
*/

vars

begin
	if self.paymentStatus = self.API_RECEIPT_DRAFT 
	or self.paymentStatus = self.API_RECEIPT_HOLD 
	or	self.paymentStatus = self.API_RECEIPT_EXPIRED 
	or self.paymentStatus = API_RECEIPT_CANCELLED then
			return true;
	endif;

	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOneOfValidAPIStatus" id="a99aa441-86d7-4a3a-b4d1-8f389ed79b97">
        <options>4</options>
        <source>isOneOfValidAPIStatus(_status : Integer; _validStatusMessage : String output) : Boolean typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//11/07/2024	navkc1 CR 64838 Task 64853: Jade - New Cash API putProformaStatus

*/

vars
	isValid : Boolean;
begin
	if 	_status = CM_CashReceipt.API_RECEIPT_HOLD or 
		_status = CM_CashReceipt.API_RECEIPT_CANCELLED or
		_status = CM_CashReceipt.API_RECEIPT_PAID or
		_status = CM_CashReceipt.API_RECEIPT_FINAL
			then
		isValid := true;
	endif;
	
	if not isValid then
		_validStatusMessage := 	" " &amp; app.paymentStatusCashEnumToString(CM_CashReceipt.API_RECEIPT_HOLD) &amp; "("&amp; CM_CashReceipt.API_RECEIPT_HOLD.asStringJMT() &amp; ")" &amp;
							" " &amp; app.paymentStatusCashEnumToString(CM_CashReceipt.API_RECEIPT_CANCELLED) &amp; "("&amp; CM_CashReceipt.API_RECEIPT_CANCELLED.asStringJMT() &amp; ")" &amp;
							" " &amp; app.paymentStatusCashEnumToString(CM_CashReceipt.API_RECEIPT_PAID) &amp; "("&amp; CM_CashReceipt.API_RECEIPT_PAID.asStringJMT() &amp; ")" &amp;
							" " &amp; app.paymentStatusCashEnumToString(CM_CashReceipt.API_RECEIPT_FINAL) &amp; "("&amp; CM_CashReceipt.API_RECEIPT_FINAL.asStringJMT() &amp; ")";
	endif;
	
	return isValid;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_validStatusMessage" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
