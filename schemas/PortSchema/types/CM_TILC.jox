    <JadeMethod name="hasStopsForOnboardTIs" id="a882d2a6-2807-41f8-9a29-35070dd53d57">
        <source>hasStopsForOnboardTIs() : Boolean;
/*

Purpose:			Checks if any cargo loaded on the MAFI has any stops applied

Parameters:			

Return Value:		

Date				Who		Reason
22 September 2022	jlizm1	Initial creation TFS 54702 CUX MAFI Auto Queueing

*/

vars

	tiSet : CM_TISet;
	ti : CM_TrackedItem;
	
begin

	create tiSet transient;
	self.getAllOnboardTIs(tiSet);
	foreach ti in tiSet discreteLock do
		if ti.hasStops then
			return true;
		endif;
	endforeach;
	
	return false;
	
epilog

	delete tiSet;
	
end;</source>
