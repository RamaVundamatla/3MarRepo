    <JadeMethod name="createEmptyChild" id="41aa0ec3-ec8d-4f94-a60e-d41e863233f6">
        <updating/>
        <source>createEmptyChild(_parent: SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		13 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	create myObject as CM_LogLength transient;
	myObject.CM_LogLength.setProxy(null, null, false, _parent.myObject.CM_CodeGroupLogSpecs);
	myParent := _parent;
	
end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
