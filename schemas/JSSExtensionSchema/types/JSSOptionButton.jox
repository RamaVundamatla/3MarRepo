    <DbClassMap file="_usergui"/>
    <PrimAttribute name="colorNoFocus" id="00e02a07-ad8d-4811-9e93-d51ce37c20bb">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="focusColor" id="a8e4eb4a-4956-4bb0-813d-267d1ad70d7e">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="controlNamePrefix" id="040901cf-a906-4020-84c3-b41711784f02">
        <source>controlNamePrefix(): String;
// --------------------------------------------------------------------------------
// Created:		06 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "opt";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="3db45379-4aa9-422c-902e-5f328d368bfe">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.focusColor		:=	self.backColor;
	self.colorNoFocus	:=	self.backColor;
end;</source>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="11ea9f84-5a7b-4e6e-bd07-5c4cc83ff317">
        <updating/>
        <source>gotFocus(optionbutton: OptionButton input) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(optionbutton);
	
	if self.backColor &lt;&gt; self.focusColor then
		self.colorNoFocus	:=	self.backColor;
		self.backColor		:=	self.focusColor;
	endif;
end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="8b65bfe8-de7d-4e6c-a043-6cfb70485070">
        <updating/>
        <source>lostFocus(optionbutton: OptionButton input) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(optionbutton);
	
	if self.backColor &lt;&gt; self.colorNoFocus then
		self.backColor		:=	self.colorNoFocus;
	endif;
end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
