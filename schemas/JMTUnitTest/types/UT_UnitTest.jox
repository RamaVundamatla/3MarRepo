    <JadeMethod name="createUnitTestResult" id="b4177be2-6980-4e72-b5e5-bfa407c05037">
        <updating/>
        <source>createUnitTestResult(_test: Method; _testRun : UM_TestRun; _ignore : Boolean; _blame : UM_Blame; _minimalLeakInfo : Boolean ): UT_TestResult protected, updating;
//16 July 2008	cnwdw1	
//
vars
	message, leaks : String;
	elapsedTime: TimeStampInterval;
	testResult: UT_TestResult;
	logMessage: String;
	doPersistResult : Boolean;
	profileDetails		: String;
	terminalsUsed		: String;
	rand : Integer;
begin

	self.getTerminalsUsedAndProfileDtls(self.getActiveProfile().String, self.allTerminalsUsed, 
		profileDetails, terminalsUsed);
	if self.allTerminalsUsed &lt;&gt; null then
		self.allTerminalsUsed.clear();
		delete self.allTerminalsUsed;
	endif;
	
	// 24/11/2014 cnwmh5
	if self.myMergeIter &lt;&gt; null then
		delete self.myMergeIter;
		self.myMergeIter := null;
	endif;
	
	if _testRun = null and not _ignore then
		elapsedTime := self.testFinishTime - self.testStartTime;
		if self.assertException then
			message := message &amp; "(" &amp; self.exceptionMethodName &amp; ":" &amp; self.exceptionMethodPosition.String &amp; ")";
		endif;
		if exceptionMessage &lt;&gt; null then
			message := message &amp; CrLf &amp; exceptionMessage;
		endif;
		if app.getLogger &lt;&gt; null then
			if self.logMessages then
				logMessage := CrLf &amp; app.getLogger.getLogs;
			endif;
			app.setLogger(null);
		endif;
		if self.leakChecker &lt;&gt; null then
			leaks := leakChecker.getLeaks(_minimalLeakInfo);
			app.writeLog("++++++++Transient Objects: starting: " &amp; leakChecker.returnStartingTransientsSize().String &amp; 
				' ending: ' &amp; leakChecker.returnEndingTransientsSize().String, LogINFO);
			if leaks &lt;&gt; null then
				message := message &amp; CrLf &amp; leaks;
			endif;
		endif;
		if _blame &lt;&gt; null and message &lt;&gt; null then
			message := message &amp; CrLf &amp; _blame.message;
		endif;
		
	elseif _testRun &lt;&gt; null and not _ignore then 	// 23/8/2012 cnwmc5
		if _blame &lt;&gt; null and self.logResult then
			doPersistResult := true;
		endif;
		if self.logResult then								// 19/12/2011 cnwmh5
			elapsedTime := self.testFinishTime - self.testStartTime;
			if self.assertException then
				message := message &amp; "(" &amp; self.exceptionMethodName &amp; ":" &amp; self.exceptionMethodPosition.String &amp; ")";
			endif;
			if exceptionMessage &lt;&gt; null then
				message := message &amp; CrLf &amp; exceptionMessage;
			endif;
			if app.getLogger &lt;&gt; null then
				if self.logMessages then
					logMessage := CrLf &amp; app.getLogger.getLogs;
				endif;
				app.setLogger(null);
			endif;
			if self.leakChecker &lt;&gt; null then
				leaks := leakChecker.getLeaks(_minimalLeakInfo);
				app.writeLog("++++++++Transient Objects: starting: " &amp; leakChecker.returnStartingTransientsSize().String &amp; 
					' ending: ' &amp; leakChecker.returnEndingTransientsSize().String, LogINFO);
				if leaks &lt;&gt; null then
					message := message &amp; CrLf &amp; leaks;
				endif;
			endif;
		endif;
	endif;
		
	create testResult transient;

	///testResult.construct(_test, message = null, _ignore, elapsedTime, message &amp; logMessage);
	testResult.construct(_test, message = null, _ignore, elapsedTime, message &amp; logMessage, _blame, doPersistResult, self, true);    // 10/09/2013 cnwmh5 // ### JIRA: MTN-34203 28Apr2025 NAVPW1 - Added by team true
	testResult.profile := profileDetails;
	testResult.terminals := terminalsUsed;
	self.testResults.add(testResult);

	return testResult;
end;</source>
        <access>protected</access>
        <Parameter name="_test" type="Method"/>
        <Parameter name="_testRun" type="UM_TestRun"/>
        <Parameter name="_ignore" type="Boolean"/>
        <Parameter name="_blame" type="UM_Blame"/>
        <Parameter name="_minimalLeakInfo" type="Boolean"/>
        <ReturnType type="UT_TestResult"/>
    </JadeMethod>
    <JadeMethod name="delete" id="ad8c0168-3ee2-4c6d-b3bc-011f3e5ac8fe">
