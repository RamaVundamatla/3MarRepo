    <JadeMethod name="initializeForActivity" id="fdc6c23c-ee92-49c8-9532-6dd3b9f78940">
        <updating/>
        <source>initializeForActivity(_any: Any; _ewsOpsView: CM_EWSActivityOpsview) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Jun 2022	navsp1	Initial creation TFS#53104

*/

vars
	product : CM_Product;
begin
	inheritMethod(_any, _ewsOpsView);
	self.tableName		:= self.Aux_crg_product_type;
	
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		self.gkey		:= self.generateFullGKey(_any, "");
		return;
	endif;
	
	if _any.isKindOf(CM_Product) then
		product	:= _any.CM_Product;
		product.initializeForActivity(_ewsOpsView,self);
	endif;
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
</Class>
