    <JadeMethod name="getVMRTMoveExtraDetails" id="f64b5aa4-9103-49b5-820b-3c7757cf93e5">
        <source>getVMRTMoveExtraDetails(_ti : CM_TrackedItem) : String;
// ---------------------------------------------------------------------------
// Created:     23 September 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpString : String;
begin
	tmpString := inheritMethod(_ti);
	
	if self.myTerminalArea &lt;&gt; null and self.myTerminalArea.isKindOf(CM_BlockStack) then
		if self.myTerminalArea.CM_BlockStack.isOverlapped then
			tmpString := tmpString &amp; "IS OVERLAPPING" &amp; CrLf;
		endif;
	endif;
	
	return tmpString;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="6b07cc6c-5c7a-4b9e-ba5b-2661a9af3f9d">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable: CMIF_OpsViewTables) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2022	navra1	Initial creation - TFS 54034 - MTN - Opsview Container Yard - Block Stacks - 4th Nov 2022

*/

vars
	opsviewtable 	:	CMIF_XpsStackStatus;
begin
	inheritMethod(_ewsOpsView, _opsViewTable);
	
	if _opsViewTable.isKindOf(CMIF_XpsStackStatus) then
		opsviewtable := _opsViewTable.CMIF_XpsStackStatus;
		opsviewtable.fillCapacityandOtherDetails(self);		//navra1 - TFS 54034 - MTN - Opsview Container Yard - Block Stacks - 4th Nov 2022
	endif;

epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
