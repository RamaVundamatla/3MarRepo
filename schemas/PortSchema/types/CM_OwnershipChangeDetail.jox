    <JadeMethod name="auditId" id="c9e44fa4-a5d2-4d89-8de9-f9cf359fc3e4">
        <source>auditId(): String;
/*
Purpose:			

Date		Who		Reason
21 July 2023	navab1	 // ### TFS CR 58246 TASK 58249 21JUL2023 NAVAB1
*/

vars
	audittext : String;
	coo : CM_OwnershipChange;
begin
	// ### TFS BUG 60189 31AUG2023 NAVAB1
	coo := self.getOwnershipChangeHeader();
	//if coo &lt;&gt; null then
	if coo &lt;&gt; null and app.isValidObject(coo) then //27/05/2024	navkc1 Bug 64182
		audittext := coo.auditId();
	endif;
	/*
	if self.myOwnershipChange &lt;&gt; null then
		audittext := self.myOwnershipChange.auditId();
	endif;
	*/
	if self.myTrackedItem &lt;&gt; null then
		audittext := audittext &amp; "/" &amp; self.myTrackedItem.id;
	endif;
	
	return audittext;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
