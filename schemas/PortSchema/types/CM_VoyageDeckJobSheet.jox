    <JadeMethod name="createOOWAuto" id="94b20791-981e-4f6f-97ce-7989f10fc788">
        <source>createOOWAuto(_controller: CMIF_VoyageJobParams input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	ooc : CM_OOWCreation;
	oocRORO : CM_OOWCreationRORODetail;
	theJobParams : CMIF_VoyageJobParams;
	theNewVoyageJob : CM_VoyageJob;
	aReq : CM_RORORequest;
begin

	foreach ooc in self.allOOWCreations do
		oocRORO	:=ooc.CM_OOWCreationRORODetail;
		if theJobParams &lt;&gt; null then
			delete theJobParams.myProxyJob;
		endif;
		delete theJobParams;
		
		create theJobParams transient;
		theJobParams.useNewMethod := false; //false becuase we are setting the requests manually here
		theJobParams.isDischarge		:=	oocRORO.isDischarge;
		theJobParams.jobNumLinkedLoad	:=null;
		theJobParams.craneID			:=	self.crane;
		theJobParams.myVoyage			:=	self.myVoyage;
		theJobParams.myProxyJob			:=	null;
		theJobParams.resquence			:=	true;		//set true whenever there's the posibility of slots added/removed from a job
		theJobParams.isSeqForJob		:=	false;
		theJobParams.myDeck				:= oocRORO.myDeck;
		theJobParams.myWorkPoint		:=self.myWorkPoint;
		theJobParams.myJobSheet := self;
		
		theJobParams.id := self.myVoyage.getNextJobNumber(self, self.myWorkPoint.IF_VoyageWorkPoint); 

		theJobParams.allowOutOfOrderLoading := self.myVoyage.allowOutOfOrderJobs; //cnwrd1 
		
		foreach aReq in oocRORO.allRORORequests do
			if aReq.isBackEndRequest then
				continue;
			endif;
			theJobParams.allRORORequests.add(aReq);
			theJobParams.allROROControllers.add(aReq.myROROController);
			theJobParams.allObjectEditions.add(aReq.myROROController);
			
		endforeach;
		theJobParams.setRequests(); // PAR 14420
		
		app.myUtilityCA.utlCreateVoyageJob(theJobParams, theNewVoyageJob, app.myPassport);
		
	endforeach;
epilog
	if theJobParams &lt;&gt; null then
		delete theJobParams.myProxyJob;
	endif;
	delete theJobParams;
end;</source>
        <Parameter name="_controller" type="CMIF_VoyageJobParams" usage="input"/>
    </JadeMethod>
