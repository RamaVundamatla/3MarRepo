    <JadeMethod name="allowAddToYardAllocation" id="a6a93ebd-c8e0-4ce4-903f-db0e07e46ece">
        <source>allowAddToYardAllocation() : Boolean;
/*
Purpose:			
Date		Who		Reason
16 September 2013	cnwab1	Initial creation
*/

vars

begin
	if self.allYardAllocations.size = 0 then
		return true;
	endif;
	
	if self.allYardAllocations.size = 1 then
		return self.allowMultipleAllocations();
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
