	self.name := 'External Web Services';
	self.schemaName := 'UiCommonSchema';
	self.allRequestClassesToProcess.clear();
//	self.setStatus(EWS_STATUS_STOPPED);  // ### TFS 50669 06AUG2021 NAVAB1 OPSVIEW/ANALYTICS STATUS
	self.isEditable := true;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCMIF" id="961df741-c1f0-42fa-bfab-4b177a9bfa40">
        <source>setCMIF(_cmif: CMIF_BGPManagerChildren input);
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
//
vars

begin
	inheritMethod(_cmif);
	_cmif.myExtWebService := self.myExternalWSDef;
	
epilog

end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a2270173-10c2-4eae-8a57-4be76007f74c">
        <updating/>
        <source>setForUpdate(_cmif: CMIF_BGPManagerChildren) updating;
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
// 27 Oct 2018  jlger1  tfs 41625 -  have tasks for each terminal
// 13 Mar 2019	jlgsl4	TFS40360 - NXL - KiwiRail EDI message
// 13 Aug 2020  cnwma1  ChangeRequest 49906: MTN - Ops View External Webservice Definition
// 01/03/2023	jlika1	56881 POB - QShips - BGP Not Processing QShip Tasks.
// 05 Apr 2023	navsp1	ChangeRequest 57207: EUP - Refactor Inspection App API Message
// 07 Dec 2023	navra1	Move processing to BGP - TFS 54090 CR 61633 - Task 61726
vars

begin
	app.writeLog(method.qualifiedName &amp; " BGP_NavisSmartProducerStatus TOP " &amp; self.String, LogDEBUG);
	inheritMethod(_cmif);
	self.myExternalWSDef := _cmif.myExtWebService;
	self.myTerminal:=_cmif.myTerminal;
	self.allRequestClassesToProcess.clear();
	if self.myExternalWSDef.isKindOf(CM_InaportnetWebService) then
		self.allRequestClassesToProcess.add(BGP_InaportnetWSRequest.name);
	elseif self.myExternalWSDef.isKindOf(CM_SAPWebService) then
		self.allRequestClassesToProcess.add(BGP_SAPWSRequest.name);
	elseif self.myExternalWSDef.isKindOf(CM_CargoChainServiceDef) then
		self.allRequestClassesToProcess.add(BGP_CargoChainWSRequest.name);		// 19/11/18 MAP TFS41999
	elseif self.myExternalWSDef.isKindOf(CM_KiwiRailCheckInWSDef) then // TFS 40360
		self.allRequestClassesToProcess.add(BGP_KiwiRailWSRequest.name); // TFS 40360
	elseif self.myExternalWSDef.isKindOf(CM_AllotracServiceDef) then	//04 Aug 2020	NDL	TFS 49869
		self.allRequestClassesToProcess.add(BGP_AllocWSRequest.name);
	elseif self.myExternalWSDef.isKindOf(CM_OpsViewServiceDef) then			  //13/08/2020 cnwma1 TFS #49906
		self.allRequestClassesToProcess.add(BGP_OpsViewWSRequest.name);       //13/08/2020 cnwma1 TFS #49906
	elseif self.myExternalWSDef.isKindOf(CM_QshipsWebServiceDef) then
		self.allRequestClassesToProcess.add(BGP_QshipsRequest.name); 
	// ### TFS 55215 30Nov2022 NAVPW1
	elseif self.myExternalWSDef.isEDBIC then
		self.allRequestClassesToProcess.add(BGP_EDBICWSRequest.name); 
	// ### TFS 55215 30Nov2022 NAVPW1
	elseif self.myExternalWSDef.isAPIDef then							// TFS 57207
		self.allRequestClassesToProcess.add(BGP_APIWSRequest.name);		// TFS 57207
	//navra1 - TFS 54090 CR 61633 - Task 61726 - 7th Dec 2023
	elseif self.myExternalWSDef.isInvoiceAPIDef() then
		self.allRequestClassesToProcess.add(BGP_InvoiceAPIWSRequest.name);
	//navra1 - TFS 54090 CR 61633 - Task 61726 - 7th Dec 2023
	//navra1 - MTN-34782 - 15th July 2025
	elseif self.myExternalWSDef.isAgGatewayServiceDef() then
		self.allRequestClassesToProcess.add(BGP_AgGatewayWSRequest.name);
	//navra1 - MTN-34782 - 15th July 2025
	endif;	
epilog

end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren"/>
    </JadeMethod>
