    <JadeMethod name="cloneReferences" id="cf5172a8-eaf7-41fb-b6a6-296a00a16168">
        <updating/>
        <source>cloneReferences(_obj: CMQF_WOTransactions; _transient: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2023 navhl20 Defect 57144: Send to Report showing Error

*/

vars

begin
	inheritMethod(_obj, _transient);
	
	self.allUsers.clear();
	_obj.allUsers.copy(self.allUsers);

epilog

end;</source>
        <Parameter name="_obj" type="CMQF_WOTransactions"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cloneSelf" id="a7e95e1d-0264-4f65-9300-5605b9736668">
        <source>cloneSelf(bTransient: Boolean): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2023 navhl20 ChangeRequest 59284:[59664] EUP | FR - VAS Work Order Transactions

*/

vars
	cloned 	: CMQF_WOTransactions;	
	todo	: CM_ToDoTaskDesc;
begin
	
	cloned := inheritMethod(bTransient);
	cloned.allToDoTaskDescs.clear();
	self.allToDoTaskDescs.copy(cloned.allToDoTaskDescs);

	return cloned;
epilog

end;</source>
        <Parameter name="bTransient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="bc613ee3-ab9f-4593-ab25-ae8a326aa3f6">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2023 navhl20 Defect 57144: Send to Report showing Error
19 Jun 2024 navhl20 Bug 64718: EUP | 53812 - VAS Work Order - WO Transactions Report issues
*/

vars
	trans			: Integer;
	transByTypeDict	: CM_WOTransByTypeDateTime;
	transByDTDict	: CM_WOTransByDateTime;
	toDT,fromDT		: TimeStamp;
	eventTypeKey	: Integer;
	dtKey			: TimeStamp;
	testToDT,
	testFromDT,
	breakOut,isType	: Boolean;
	iter 			: Iterator;
	terminal		: CM_Terminal;
begin
	if (not self.allQueryCriteriaHolders.isEmpty) then
		self.filterSelectorQuery(_collection, _passport);
		return;
	endif;
	
	isType := not self.allTransTypes.isEmpty;
	
	fromDT.setDate(self.startDate);
	fromDT.setTime(self.startTime);
	self.needFilterUsers := (not self.allUsers.isEmpty) or (self.allUsers.size &gt;= app.myRoot.allUsers.size);	//19.06.2024 navhl20 #64718
	
	foreach terminal in self.allTerminals do
		delete iter;
		
		if isType then
			transByTypeDict := terminal.allWOTransByTypeDateTime;
			iter := transByTypeDict.createIterator();
			foreach trans in self.allTransTypes do
				transByTypeDict.startKeyGeq(trans, fromDT, iter);
				self.filterObjectsForTypeDT(_collection, trans, transByTypeDict, iter, breakOut, _passport);
				if breakOut then
					return;
				endif;
			endforeach;
		else
			transByDTDict := terminal.allWOTransByDateTime;
			iter := transByDTDict.createIterator();
			transByDTDict.startKeyGeq(fromDT, iter);
			self.filterObjectsForDT(_collection, transByDTDict, iter, breakOut, _passport);
			if breakOut then
				return;
			endif;
		endif;
	endforeach;
epilog
	delete iter;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterObjectsForDT" id="96b64199-7d4b-4742-9c27-eb72f2f31f30">
        <updating/>
        <source>filterObjectsForDT(_collection		: Collection input;
				_transByDTDict 	: CM_WOTransByDateTime; 
				_iter 			: Iterator input;
				_breakOut 		: Boolean output;
				_passport		: CM_Passport) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2023 navhl20 Defect 57144: Send to Report showing Error
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
*/
vars
	woTrans			: CM_WOTransaction;
	toDT			: TimeStamp;
	dtKey			: TimeStamp;
	testToDT		: Boolean;
begin
	toDT.setDate(self.endDate);
	toDT.setTime(self.endTime);
	
	testToDT := toDT &lt;&gt; null and toDT.isValid();
	
	while _iter.next(woTrans) do : woTransLoop
		_iter.getCurrentKeys(dtKey); //MTN-35226
		if (testToDT and dtKey &gt; toDT) then
			return;
		endif;
		
		if self.includesObject(woTrans, _passport, _breakOut) then
			if not _collection.includes(woTrans) then
				_collection.add(woTrans);
			endif;
		endif;
		
		if _breakOut then
			return;
		endif;
	endwhile;
epilog

end;


</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_transByDTDict" type="CM_WOTransByDateTime"/>
        <Parameter name="_iter" type="Iterator" usage="input"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterObjectsForTypeDT" id="17415b9b-419e-46eb-8341-ac8e035ee330">
        <updating/>
        <source>filterObjectsForTypeDT(_collection	: Collection input;
					_transType 		: Integer;
					_transByTypeDict : CM_WOTransByTypeDateTime; 
					_iter 			: Iterator input;
					_breakOut 		: Boolean output;
					_passport 		: CM_Passport) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2023 navhl20 Defect 57144: Send to Report showing Error
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
*/
vars
	woTrans			: CM_WOTransaction;
	toDT			: TimeStamp;
	eventTypeKey	: Integer;
	dtKey			: TimeStamp;
	testToDT		: Boolean;
begin
	toDT.setDate(self.endDate);
	toDT.setTime(self.endTime);
	
	testToDT := toDT &lt;&gt; null and toDT.isValid();

	while _iter.next(woTrans) do : woTransLoop

		_iter.getCurrentKeys(eventTypeKey, dtKey); //MTN-35226
		if (eventTypeKey &lt;&gt; _transType) or
		   (testToDT and dtKey &gt; toDT) then
			return;
		endif;
		
		if self.includesObject(woTrans, _passport, _breakOut) then
			if not _collection.includes(woTrans) then
				_collection.add(woTrans);
			endif;
		endif;
		
		if _breakOut then
			return;
		endif;
	endwhile;

end;


</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_transType" type="Integer"/>
        <Parameter name="_transByTypeDict" type="CM_WOTransByTypeDateTime"/>
        <Parameter name="_iter" type="Iterator" usage="input"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterSelectorQuery" id="71315d14-6cb0-4d02-88bb-36af658bd3ac">
        <source>filterSelectorQuery(_collection  : Collection input;
					_passport : CM_Passport) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2023 navhl20 Defect 57144: Send to Report showing Error

*/

vars
	criteriaHolder 		: CM_QueryCriteriaLineHolder;
	qDef				: CM_QueryDefinition;
	enqController		: CM_EnquiryController;
	queryAgent			: CM_QueryAgentFilter;
begin

	// Special one because we need the copy
	on CM_BreakOutException do app.myQAFilter.xHandlerBreakOut(exception);
	
	queryAgent := app.myQAFilter;
	if queryAgent = null then
		return;
	endif;
	
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.Transaction_Query_Type, self.selectorMode];
	queryAgent.createEnqControllerForMode(self.selectorMode, CM_QueryDefinition.Transaction_Query_Type, enqController);
	delete enqController.allObjects;
	create enqController.allObjects as _collection.class transient;
	
	foreach criteriaHolder in self.allQueryCriteriaHolders discreteLock do
		enqController.myCriteriaLineHolder := criteriaHolder;
		enqController.doQuery(qDef);
	endforeach;

	enqController.allObjects.copy(_collection);
	
epilog
	if enqController &lt;&gt; null then
		delete enqController.allObjects;
	endif;
	delete enqController;
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="b273a9e8-c128-4ecb-a23e-03f6d9dfdba8">
        <source>getDisplayStringForAttribute(_attrName: String; _getCalculatedDate: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2023 navhl20 Defect 57144: Send to Report showing Error

*/

vars
	oid     : String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="b75cff52-51f9-4dfe-962f-0ca13f7b24c8">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid: String output): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2023 navhl20 Defect 57144: Send to Report showing Error
14 Aug 2023 navhl20 ChangeRequest 59284:[59664] EUP | FR - VAS Work Order Transactions
20 Jun 2024 navhl20 Bug 64718: EUP | 53812 - VAS Work Order - WO Transactions Report issues
*/

vars
	runDate		: Date;
begin
	runDate := app.actualTimeServer().Date;	
	
	if _attrName = ETRow_AllWOTransTypes then
		return self.getTransTypesString(_oid); 
	elseif _attrName = ETRow_AllUsers then
		return self.getUsersString(_oid); 
	
	elseif _attrName = ETRow_DateFromWO then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.startDateTplType, self.startDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.startDateTplType, self.startDateTplFactor);
		endif;
	
	elseif _attrName = ETRow_TimeFromWO then
		if self.startTime.isValid then
			return self.startTime.asStringJMT();  
		else
			return '00:00';
		endif;
	
	elseif _attrName = ETRow_TimeToWO then
		if self.endTime.isValid then
			return self.endTime.asStringJMT();  
		else
			return '00:00';
		endif;
		
	elseif _attrName = ETRow_DateToWO then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.endDateTplType, self.endDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.endDateTplType, self.endDateTplFactor);
		endif;
		
	elseif _attrName = ETRow_WorkOrderId then
		return self.workOrderId;  
	
	elseif _attrName = ETRow_TrainCode then
		return self.train;
	
	elseif _attrName = ETRow_VoyageCodeWO then
		return self.voyage;
	
	elseif _attrName = ETRow_WagonCodeWO then
		return self.wagon;
	
	elseif _attrName = ETRow_VVRCodeWO then
		return self.vehicleVisitRecord;
		
	elseif _attrName = ETRow_TruckPlateNoWO then				//20.06.2024 navhl20 #64718
		return self.truckPlateNumber;
	
	elseif _attrName = ETRow_VBSCodeWO then
		return self.vehicleBookingSlot;
	
	elseif _attrName = ETRow_RRNumberWO then
		return self.releaseRequestNumber;
	
	elseif _attrName = ETRow_TskType then
		return self.getTodoTaskDescStr();				//14.8.2023 navhl20 #59284[59664]
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTodoTaskDescStr" id="72f00b25-bafa-48cb-935b-9080c6328631">
        <source>getTodoTaskDescStr():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2023 navhl20 ChangeRequest 59284:[59664] EUP | FR - VAS Work Order Transactions

*/

vars
	str 	: String;
	todo	: CM_ToDoTaskDesc;
begin
	foreach todo in self.allToDoTaskDescs do	
		if str = null then
			str := str &amp; todo.description;
		else
			str := str &amp; Comma &amp; todo.description;
		endif;
	endforeach;
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTransTypeStringArray" id="e14cf7c8-1c5c-4409-b2b0-63017ef7e69d">
        <source>getTransTypeStringArray( _stringArray : StringArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2023 navhl20 Defect 57144: Send to Report showing Error

*/
vars
	index				: Integer;
	transactionType		: CM_TransactionType;
	
begin
	foreach index in self.allTransTypes do : trans_loop
		transactionType := app.myRoot.allTransactionTypes[ index ];
		if transactionType = null then
			continue trans_loop;
		endif;
		_stringArray.add( transactionType.description );
	endforeach trans_loop;
epilog
	
end;
</source>
        <Parameter name="_stringArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTransTypesString" id="9b54b247-8ee7-4ee4-b04c-80a6273e95f8">
        <source>getTransTypesString(_oid : String output) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2023 navhl20 Defect 57144: Send to Report showing Error

*/

vars
	str					: String;
	index				: Integer;
	transactionType		: CM_TransactionType;
	
begin
	foreach index in self.allTransTypes do : trans_loop
		transactionType := app.myRoot.allTransactionTypes[ index ];
		if transactionType = null then
			continue;
		endif;
		// needs to be exactly comma and then a space for the Web to default correctly.
		str	:= str &amp; transactionType.description &amp; CNEC_COMMA &amp; Space;
	endforeach trans_loop;
	
	// chop off last delimiter and space
	if str &lt;&gt; null then
		str := str[ 1 : str.length - 2 ];
	endif;
	
	return str;
epilog

end;</source>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUsersString" id="e64ab6d4-8ac5-4f0f-8f42-85dadc44d707">
        <source>getUsersString(_oid:String output) : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2023 navhl20 Defect 57144: Send to Report showing Error

*/
vars
	user				: CM_User;
	userDict			: CM_UserByCodeDict;
	str					: String;
begin
	
	foreach user in self.allUsers do
		if user = self.allUsers.last then
			_oid := _oid &amp; user.getOidAsString();
			str := str &amp; user.code;
		else
			_oid := _oid &amp; user.getOidAsString() &amp; ',';
			str := str &amp; user.code &amp; ',';
		endif;
	endforeach;
	
	if str = null then
		str := Any_String;
	endif;
	
	return str;
			
end;





</source>
        <access>protected</access>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="6bebd865-b512-4359-8c40-8e539d34147d">
        <updating/>
        <source>includesObject(_woTrans 	: CM_WOTransaction; 
				_passport	: CM_Passport; 
				_breakOut	: Boolean output): Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Mar 2023 navhl20 Defect 57144: Send to Report showing Error
14 Aug 2023 navhl20 ChangeRequest 59284:[59664] EUP | FR - VAS Work Order Transactions
19 Jun 2024 navhl20 Bug 64718: EUP | 53812 - VAS Work Order - WO Transactions Report issues
*/
vars
	todoTaskDesc	: CM_ToDoTaskDesc;
	count			: Integer;
	todoTaskSet		: CM_ToDoTaskDescSet;
begin
	if self.needFilterUsers then
		if self.allUsers[_woTrans.userCode] = null then
			return false;
		endif;
	endif;
	
	if self.workOrderId &lt;&gt; null then
		if  not _woTrans.myWorkOrder.id = self.workOrderId then
			return false;
		endif;
	endif;
	
	if self.train &lt;&gt; null then
		if  not _woTrans.getTrainCode = self.train.toUpper then
			return false;
		endif;
	endif;
	
	if self.voyage &lt;&gt; null then
		if  not _woTrans.getVoyageCode = self.voyage.toUpper then
			return false;
		endif;
	endif;
	
	if self.vehicleVisitRecord &lt;&gt; null then
		if  not _woTrans.getVVRCode = self.vehicleVisitRecord.toUpper then									//20.06.2024 navhl20 #64718
			return false;
		endif;
	endif;
	
	if self.truckPlateNumber &lt;&gt; null then																	//20.06.2024 navhl20 #64718
		if  not _woTrans.getRegNumber() = self.truckPlateNumber.toUpper then
			return false;
		endif;
	endif;
	
	if self.vehicleBookingSlot &lt;&gt; null then
		if  not _woTrans.getVBSCode = self.vehicleBookingSlot.toUpper then
			return false;
		endif;
	endif;
	
	if self.allToDoTaskDescs.isNotEmpty() then																//14.8.2023 navhl20 #59284[59664]
		todoTaskSet := _woTrans.getTodoTaskDescObj();														//19.06.2024 navhl20 #64718
		if todoTaskSet = null then
			return false;
		endif;
		foreach todoTaskDesc in self.allToDoTaskDescs do
			/*
			//19.06.2024 navhl20 #64718
			if _woTrans.getTodoTaskDesc().pos(",",1) &gt; 0 then
				if not _woTrans.getTodoTaskDesc().pos(todoTaskDesc.description,1) &gt; 0 then
					count := count + 1;
				endif;
			else
				if _woTrans.getTodoTaskDesc() &lt;&gt; todoTaskDesc.description then
					count := count + 1;
				endif;
			endif;*/
			if not todoTaskSet.includes(todoTaskDesc) then													//19.06.2024 navhl20 #64718
				return false;
			endif;
		endforeach;
		/*
		//19.06.2024 navhl20 #64718
		if count = self.allToDoTaskDescs.size then
			return false;
		endif;*/
	endif;
	
	if self.releaseRequestNumber &lt;&gt; null then
		if  not _woTrans.getReleaseRequestRef = self.releaseRequestNumber.toUpper then
			return false;
		endif;
	endif;
	
	if self.wagon &lt;&gt; null then
		if  not _woTrans.getWagonCode = self.wagon.toUpper then
			return false;
		endif;
	endif;
	
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_woTrans" type="CM_WOTransaction"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
