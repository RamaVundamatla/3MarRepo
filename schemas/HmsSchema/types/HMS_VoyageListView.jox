    <JadeMethod name="optByArrival_click" id="353fa943-730e-487b-ad25-4779cfb528bd">
        <controlMethod name="OptionButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optByArrival_click(optionbutton: OptionButton input) updating;

vars
    obj:				Object;
    currentPosn:		Integer;
   	expandedMovements:	ObjectArray;
   	objExpanded:		Object;
   	count:				Integer;	
begin
	// Set reference to currently selected object
	if lbxVoyageTree.listIndex&gt;0 then
		obj:=lbxVoyageTree.itemObject[lbxVoyageTree.listIndex];
	endif;
	// Build object array of items expanded to level 3
	create expandedMovements transient;
	count:=0;
	while count&lt;lbxVoyageTree.listCount do
		count:=count+1;
		if lbxVoyageTree.itemExpanded[count]=true then
			expandedMovements.add(lbxVoyageTree.itemObject[count]);
		endif;
	endwhile;

	optByArrival.value:=true;
	optByDeparture.value:=false;
	optByVoyageCode.value:=false;
	buildEntireForeground;

	// Expanded movements that were previously expanded in last view
	foreach objExpanded in expandedMovements do
		lbxVoyageTree.itemExpanded[lbxVoyageTree.findObject(objExpanded)]:=true;
	endforeach;


	// Reselect highlight currently selected object in new view
	if obj&lt;&gt;null then
		currentPosn:=lbxVoyageTree.findObject(obj);
		if currentPosn&gt;0 then
			lbxVoyageTree.listIndex:=currentPosn;
		endif;
	endif;
epilog
	delete expandedMovements;
end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
