    <JadeMethod name="deserializeJSON" id="f52fdf4c-320e-445f-999c-e71317cdabc6">
        <source>deserializeJSON(_json : String io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07  August 2019		jlger1	Initial creation TFS 45963

*/

vars

	allProperties : PropertyColl;
	property : Property;
	length,
	i,p : Integer;
	propCount : Integer;
	propName : String;
	propValue : Any;
	arrayValue : Any;
	iter : Iterator;
begin
	
		//16/12/21 jlier1 TFS 52595 handle JadeDynamicObjects 
	if self.isKindOf(JadeDynamicObject) then
		propCount:=self.JadeDynamicObject.propertyCount;
		_json:=_json &amp; "{"; 
		p:=1;
		while p &lt;= propCount do
			propName:=self.JadeDynamicObject.getPropertyName(p);
			propValue:=self.JadeDynamicObject.getPropertyValueByIndex(p);
			_json := _json &amp; '"' &amp; propName &amp; '": ';
			if propValue &lt;&gt; null then
				if  propValue.isKindOf(JadeDynamicObject)  then
					propValue.JadeDynamicObject.deserializeJSON(_json);
					
				else
					if propValue.isKindOf(Array) then
						_json := _json &amp; ' [';
						delete iter;
						iter:=propValue.Array.createIterator;
						i:=0;
						while iter.next(arrayValue) do
							if i &gt; 0 then
								_json:=_json &amp; ","; 
							endif;
							if arrayValue.isKindOf(JadeDynamicObject) then
								arrayValue.JadeDynamicObject.deserializeJSON(_json);
							else
							
							_json := _json &amp; self.formatAsJSONValue(arrayValue);
							endif;
							i:=i+1;
						endwhile;	
						_json := _json &amp; ']';
					else	
						 _json := _json &amp;  self.formatAsJSONValue(propValue) ; 
					endif;
					
				endif;
			else	
				_json := _json &amp;  self.formatAsJSONValue(propValue) ; 
			endif;
			_json:=_json &amp; ",";
			p:=p+1;
		endwhile;

		if _json[_json.length:end] = ',' then
			_json:=_json[1:_json.length-1];
		endif;
		
		_json:=_json &amp; "}";
		return;
	endif;
	
	
	allProperties:=self.class.allProperties();
	
	_json:=_json &amp; "{"; 
	foreach property in allProperties do
	
		if property.isKindOf(Reference) then		
			if self.deserializeJSONReference(property.Reference,_json) then
				_json:=_json &amp; ","; 
			endif;							
		elseif  property.isKindOf(Attribute) then
			if self.deserializeJSONAttribute(property.Attribute,_json) then
				_json:=_json &amp; ","; 
			endif;
		endif;
		i:=i+1;
	endforeach;
	if _json[_json.length:end] = "," then // TFS 50669 removed '-1'
		_json:=_json[1:_json.length-1];
	endif;
	
	_json:=_json &amp; "}";

epilog
	delete allProperties;
	delete iter;

end;</source>
        <text>This method can used instead of CM_Object:: exportAsJSON method.</text>
        <Parameter name="_json" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="deserializeJSONAttribute" id="93508f2d-a0ca-4b90-b80c-04c12019a268">
        <source>deserializeJSONAttribute(_property : Attribute input;  _json : String io) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07  August 2019		jlger1	Initial creation TFS 45963

*/

vars
	value, arrayValue : Any;
	iter : Iterator;
	i : Integer;
begin
	if self.exportAsXMLDocIgnoreAttr(_property) then
		return false;
	endif;

	value:=self.getPropertyValue(_property.name);
	
	if value.isKindOf(Binary) then
		return false;
	endif;
	
	_json := _json &amp; '"' &amp; _property.name &amp; '": ';
	if value.isKindOf(Array) then
		_json := _json &amp; ' [';
	
		iter:=value.Array.createIterator;
		i:=0;
		while iter.next(arrayValue) do
			if i &gt; 0 then
				_json:=_json &amp; ","; 
			endif;
			_json := _json &amp; self.formatAsJSONValue(arrayValue);
			i:=i+1;
		endwhile;	
		_json := _json &amp; ']';
	else	
		 _json := _json &amp;  self.formatAsJSONValue(value); 
	endif;
	
	return true;
epilog
	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Attribute" usage="input"/>
        <Parameter name="_json" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deserializeJSONReference" id="5b48e0c5-b709-47bd-a02d-de132841cfc4">
        <source>deserializeJSONReference(_property : Reference input; _json : String io) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2019	jlger1	Initial creation TFS 45963

*/

vars
	theCollection : Collection;
	obj 		: Object;
	iter : Iterator;
	classType : Class;
	exportReferenceAs : Integer;
	arrayValue : Any;
	childKeyProperty : Property;
	i 	: Integer;
begin
	
	if self.exportAsXMLDocIgnoreAttr(_property) then
		return false;
	endif;
	
	classType:=_property.type.class;
	obj:=self.getPropertyValue(_property.name).Object;
	if obj = null then
		return false;
	endif;
	
	exportReferenceAs:= self.exportAsXMLInverseRef(_property);
	//if  inverse reference do not export as a default

	if  obj.isKindOf(Btree) or  obj.isKindOf(ObjectArray) then
		// check if we should be exporting this collection reference	
		if exportReferenceAs  = NoExport then
			return false;
		endif;	
	
		theCollection:=obj.Collection;
		
		if theCollection.isEmpty then
			return false;
		endif;
		_json := _json &amp; '"' &amp; _property.name &amp; '": [';
		i:=0;
		iter:= theCollection.createIterator;		
		while iter.next(obj) do	
			if i &gt; 0 then
				_json:=_json &amp; ","; 
			endif;
			if exportReferenceAs =ExportAsParent then
				obj.deserializeJSON(_json);
			elseif exportReferenceAs = ExportAsChild then
				childKeyProperty:=obj.exportAsXMLDocGetChildRefKey(_property);
				_json := _json &amp; '{"' &amp; childKeyProperty.name &amp; '": ' &amp; self.formatAsJSONValue(obj.getPropertyValue(childKeyProperty.name));
				//_file.writeString(self.formatAsXML(childKeyProperty.name,obj.getPropertyValue(childKeyProperty.name).String));
			endif;
			i:=i+1;
		endwhile;
		
		_json := _json &amp; ']';
	
	

	elseif 	obj.isKindOf(Array) then
	
		if obj.Array.size = 0 then
			return false;
		endif;
		_json := _json &amp; '"' &amp; _property.name &amp; '": [';
	
		iter:=obj.Array.createIterator;
		i:=0;
		while iter.next(arrayValue) do
			if i &gt; 0 then
				_json:=_json &amp; ","; 
			endif;
			_json := _json &amp; self.formatAsJSONValue(arrayValue);
			if i &gt; 0 then
				_json:=_json &amp; ","; 
			endif;
			i:=i+1;
		endwhile;	
		_json := _json &amp; ']';
	else
		//elseif obj.isKindOf(CM_Object) orthen
		//have to specify and make sure only one end is exported
		// if parent will always export
		// if child will never
		// if peer have to specify which ends correctly	
			
		if exportReferenceAs = NoExport then
			return false;
		endif;	
	
		if exportReferenceAs =ExportAsParent then
			//if  obj.isKindOf(CM_Object) then	
				obj.deserializeJSON(_json);
			//endif;
		elseif exportReferenceAs = ExportAsChild then
			childKeyProperty:=self.exportAsXMLDocGetChildRefKey(_property);
			if childKeyProperty &lt;&gt; null then	
				_json := _json &amp; '"' &amp; childKeyProperty.name &amp; '": ' &amp; self.formatAsJSONValue(obj.getPropertyValue(childKeyProperty.name));
			endif;
		endif;
	endif;
	
	return true;
	
epilog
	delete iter;


end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference" usage="input"/>
        <Parameter name="_json" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRaiseAlert" id="2a686e18-8606-4eb8-bbe7-eae17dbbf192">
        <source>doRaiseAlert(_details:String);
// --------------------------------------------------------------------------------
// Created:		15 August 2006 by cnwdad1
//
// Purpose:		Raises a system alert with the details of of what needs to be actioned.
//
// Parameters:	_details - The details of the alert circumstances.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	alertObj 	: CM_SystemAlert;
begin

	
	app.writeLog(_details, LogERROR);
	
	create alertObj transient;
	alertObj.details	:=	_details;
	alertObj.setSeverity(SEVERE_WARNING);
	//-----------
	// Tell alert to add itself to the system.
	//-----------
	alertObj.add;

end;</source>
        <Parameter name="_details" type="String"/>
    </JadeMethod>
