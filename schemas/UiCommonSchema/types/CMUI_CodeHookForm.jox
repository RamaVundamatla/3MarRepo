    <JadeMethod name="setupForm" id="f153d03e-f072-4bf2-b3b5-aae06d3fc0c8">
        <updating/>
        <source>setupForm() updating;
// -------------------------------------------
// Created 03 February 2005 by cnwdvb1
// -------------------------------------------

// 25/09/2008	concms1	par 16762 - use jade editor control
begin
	inheritMethod();
//	self.cmbHookType.width := 150;
	self.setNavigatorHeading(self.caption);
	self.useTblThumb := false;
	self.zHideSearcher();
	self.showFilterOnStartup := false;
	
	//07/04/2006 cnwsh3 Form is not currently set up to allow for searches so have disabled using mapping method.
	self.allowSearch	:= false;
	
	// TFS 2010 separate lists of hook types for display and add/edit
	self.populateHookTypes();
	self.cmbHookType.listCollection(self.fullHookTypes, false, 0);
	
	self.cmbHookType.tabStop	:= false;
	self.lstTblLinks.tabStop	:= false;
	self.txtCode.tabStop		:= false;
	self.txtJadeCode.tabStop	:= true;
	
	self.tblData.tabStop		:= false;
	self.setupJadeEditor;	// par 16762
	
//	self.removeRegisteredKey(J_key_Tab);


end;</source>
    </JadeMethod>
    <JadeMethod name="setupJadeEditor" id="d891b5ad-e4ad-4195-88d8-fc61c4275388">
        <source>setupJadeEditor()protected;
// ---------------------------------------------------------------------------
// Created:     25 September 2008 by concms1
// Purpose:     PAR 16762 - use Jade Editor on this form
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.txtJadeCode.initializeJadeEditor(false);
	self.txtJadeCode.configureFor_Jade;
	
	self.txtJadeCode.tabWidth	:= 4;
	
	// enable class name highlighting
	self.txtJadeCode.setCurrentSchema(rootSchema.getSchema("PortSchema"));
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="bd6f351e-94b0-462c-9c68-ba70aa08ca48">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
// -------------------------------------------
// Created 04 February 2005 by cnwdvb1
// -------------------------------------------

// 25/09/2008	concms1	par 16762 - use jade editor control
vars

	code	: CM_HookCode;
	hookType	: Integer;

begin
//	inheritMethod(obj);
	code := self.myCurrentObject.CM_HookCode;
	
	self.lstTblLinks.enabled := true;	//10 Nov 2010	NDL Par 25530
	
	if code = null then
		return;
	endif;
	
	self.txtCode.text 			:= code.code;
	self.cmbHookType.listObject := code.myHookType;
	
	self.loadLstTblLinks(code.myHookType);
	self.getSelectedLinks(code);
	self.setCurrentCode(code);
	
	self.txtJadeCode.text 		:= code.getCurrentJadeCode();
	
	//10 Nov 2010	NDL Par 25530
	if code.myHookType &lt;&gt; null and code.myHookType.hookType = HookType_CalendarDay then
		self.lstTblLinks.enabled := false;
	endif;
	// TFS 2010 some hook types shown here can't be added or maintained here
	if code.myHookType &lt;&gt; null then
		hookType := code.myHookType.hookType;
	endif;

	self.btnEditTV.enabled := true;
	self.btnNewTV.enabled := true;
	if hookType = HookType_RTConfigDoorDir or
	   hookType = HookType_InvoiceQuantity or
	   hookType = HookType_InvoiceRate or
	   hookType = HookType_HMSInvoiceQuantity or
	   hookType = HookType_HMSInvoiceRate or
	   hookType = HookType_RTConfigIsoType or
	   hookType = HookType_RTConfigLocation or
	   hookType = HookType_YardAllocationOS then
		self.btnEditTV.enabled := false;
		
// TFS 2101 CNWAB1		self.btnNewTV.enabled := false;
	endif;
	
	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		self.btnEditTV.enabled := false;
		self.btnNewTV.enabled := false;
		self.btnDeleteTV.enabled := false;
	
	endif;

end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="09bfb394-39f0-411f-b6df-45e0578e1b49">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007312, locale);
	lblCode.translateCaption(Xlat_0000251, locale);
	lblHookCode.translateCaption(Xlat_0000252, locale);
	lblLink.translateCaption(Xlat_0000253, locale);
	lblType.translateCaption(Xlat_0000254, locale);
end;</source>
    </JadeMethod>
</GUIClass>
