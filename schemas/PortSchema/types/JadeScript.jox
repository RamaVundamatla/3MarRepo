    <JadeMethod name="rel812_par30680" id="d56c3ab9-c4eb-4822-9756-d446d43ab58a">
        <source>rel812_par30680();
/*

Purpose:			Load new and changed ent table defs for CCMS 2178
					Convert HMS calculation types
Parameters:			

Return Value:		

Date		Who		Reason
8/11/2012	cnwjre1	Initial creation	Par 30680

*/

vars
	etAgent		: EntTableAgent;
	array 		: StringArray;
	calcType	: CM_CalculationType;
begin
	app.initialize;
	
	create etAgent transient;
	create array transient;
	
	etAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	
	array.add ("ETGrp_HMSData");
	array.add ("ETGrp_VesselDimensions");
	array.add ("ETRow_NetRegTonnes");
	array.add ("ETRow_Dim_GrossRegTonnes");
	array.add ("ETRow_GrossRegTonnes");
	array.add ("ETDef_InvThumbNail");
	array.add ("ETDef_InvEntryTable");
	array.add ("ETDef_VesselCharacteristics");
	array.add ("ETDef_VesselDimensions");
	array.add ("ETDef_KeyDimensions");
	
	etAgent.trxUpdateFromConstant(array);	
	
	// calculation type conversion to add unit to selective types
	beginTransaction;
	foreach calcType in CM_CalculationType.instances do
		if calcType.calculationType = INV_CALC_TYPE_VESSEL_TON or
		   calcType.calculationType = INV_CALC_TYPE_VESSEL_TON_QTY1 or
		   calcType.calculationType = INV_CALC_TYPE_VESSEL_TON_RANGE then
			calcType.setPropertyValue("theCalcTypeUnit", INV_CALC_TYPE_UNIT_GRT);
		endif;
	endforeach;
	commitTransaction;
	
	return;
	
	write ETGrp_HMSData;
	write ETGrp_VesselDimensions;
	write ETRow_NetRegTonnes;
	write ETRow_Dim_GrossRegTonnes;
	write ETRow_GrossRegTonnes;
	write ETDef_InvThumbNail;
	write ETDef_InvEntryTable;
	write ETDef_VesselCharacteristics;
	write ETDef_VesselDimensions;
	write ETDef_KeyDimensions;
	
epilog

	delete etAgent;
	delete array;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="rel812_par30681" id="89c5a76d-03f7-4e2b-8696-60fcc51edee2">
        <source>rel812_par30681();
/*
Purpose:			
Date				Who			Reason
DEC 2012		CNWAB1		Initial creation
*/
vars
	etAgent : EntTableAgent;
	array : StringArray;
	transAgent 	: CM_TranslationAgent;
	tmpArray 	: StringArray;

begin
	app.initialize;
	
	// ## ENTABLEDEFN
	create etAgent transient;
	create array transient;
	
	etAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;	
	
	
	
	array.add ("ETRow_CalendarExclusionDates");
	array.add ("ETRow_CalendarNormalDates");
	array.add ("ETGrp_ConfigGroup");
	array.add ("ETDef_RootDefaults");	
	
	
	array.add ("ETRow_MyInvBusHrsDayTypeNorm");
	array.add ("ETRow_MyInvBusHrsDayTypeExcl");
	array.add ("ETGrp_InvCalcType");
	array.add ("ETDef_InvEntryTable");	
	array.add ("ETDef_InvThumbNail");	
	etAgent.trxUpdateFromConstant(array);
	
	// ## TRANSLATIONS
	create transAgent transient;
	create tmpArray transient;
	
	tmpArray.add('Overtime_hrs_rate');
	tmpArray.add('Normal_hrs_rate');
	tmpArray.add('Excluded_hrs_rate');
	transAgent.trxLoadSpecificErrors(tmpArray);
	
	return;
	write ETRow_CalendarExclusionDates;
	write ETRow_CalendarNormalDates;
	write ETGrp_ConfigGroup;
	write ETDef_RootDefaults;
	
	write ETRow_MyInvBusHrsDayTypeNorm;
	write ETRow_MyInvBusHrsDayTypeExcl;
	
	write ETGrp_InvCalcType;
	write ETDef_InvEntryTable;
	write ETView_InvCalcViewBusHrsVesVal;
	write ETDef_InvThumbNail;
	write ETGrp_InvCalcType;
	write MyInvBusHrsDayTypeExcl;
	write MyInvBusHrsDayTypeNorm;
	write Overtime_hrs_rate;
	write Normal_hrs_rate;
	write Excluded_hrs_rate;
	
	write INV_CALC_TYPE_BUSHRSVESELVALUE;
	write INV_CALC_TYPE_BUSHRSCARGOVALUE;
	
epilog
	delete tmpArray;
	delete transAgent;
	delete etAgent;
	delete array;
end;</source>
    </JadeMethod>
    <JadeMethod name="rel812_par30682" id="07048ae4-c5fb-41ef-b51f-920ff9886da0">
