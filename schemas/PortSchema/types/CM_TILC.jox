    <JadeMethod name="getTIsByBehaviourType" id="0b3a77a1-95f7-4460-9ede-4926deaa07a6">
        <source>getTIsByBehaviourType(_behaviour : Integer; _tis : CM_TIArray input; _clear : Boolean) ;
// ---------------------------------------------------------------------------
// Created:		05 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	behaviour : CM_TIBehaviourType;
	anLC : CM_TILCController;
	aTI : CM_TrackedItem;
begin
	if _clear then
		_tis.clear;
	endif;
	foreach anLC in self.allLCs discreteLock do
		foreach aTI in anLC.allTrackedItems discreteLock do
			behaviour := aTI.myCargoType.myTIBehaviourType;
			if behaviour &lt;&gt; null then	
				if behaviour.behaviourType = _behaviour then
					_tis.add(aTI);
				endif;
			endif;
		endforeach;
	endforeach;

end;</source>
        <Parameter name="_behaviour" type="Integer"/>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTIsInOrder" id="f96e6974-a155-4a19-a52b-62b979ac3976">
        <source>getTIsInOrder(_tis : CM_TIByOrder input; _clear : Boolean; _tier : Integer io) ;
// ---------------------------------------------------------------------------
// Created:		05 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	behaviour : CM_TIBehaviourType;
	anLC : CM_TILCController;
	aTI : CM_TrackedItem;
	idx, tmpTier, tmpTier1 : Integer;
begin
	if _clear then
		_tis.clear;
	endif;
	
	foreach anLC in self.allLCs discreteLock do
		tmpTier := _tier;
		idx := idx + 1;
		foreach aTI in anLC.allTrackedItems discreteLock do
			tmpTier := tmpTier + 1;
			_tis.putAtKey(tmpTier,idx,aTI);
			tmpTier1 := _tier + 1;
			aTI.getTIsInOrder(_tis,false,tmpTier1);
		endforeach;
	endforeach;

end;</source>
        <Parameter name="_tis" type="CM_TIByOrder" usage="input"/>
        <Parameter name="_clear" type="Boolean"/>
        <Parameter name="_tier" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTareWeight" id="2b5aec19-2fca-42a1-a4b8-5d6aa6f16df3">
        <source>getTareWeight(): Decimal;
//01 December 2009	cnwml2
// 18/05/2010 	cnwcs5	par 24178 - use superclass method
//						In theory we can remove this method once we know we wont break reporting views

vars

	tareWeight	:Decimal[14,4];

begin

	tareWeight := inheritMethod;
	
	if tareWeight = 0 then
		if self.myTILCType &lt;&gt; null then
			tareWeight := self.myTILCType.tareWeight;
		endif;
	endif;
	
	return tareWeight;
/*	
	
// par 24178 - start
	return inheritMethod;
// par 24178 - end

	if self.myTiMaster &lt;&gt; null then
		return self.myTiMaster.tWeight;
	endif;
	
	return 0;
	
	*/
	
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
