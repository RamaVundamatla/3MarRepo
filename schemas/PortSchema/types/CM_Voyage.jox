        <source>getKPIVoyBayCraneByCode(_code : String): CM_KPIVoyageBayCrane;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2025	navcs2	MTN-36746 MTN | KPI REST APIs - Voyage [1]

*/

vars
	kpi			: CM_KPI;
	retKPI		: CM_KPIVoyageBayCrane;	
begin
	foreach kpi in self.allVoyageKPIEntities discreteLock where kpi.isKPIVoyageEntity and kpi.CM_KPIVoyageEntity.isKPIVoyageBayCrane do
		retKPI := kpi.CM_KPIVoyageBayCrane;
		if retKPI.myCrane.code = _code or retKPI.getBayNumber = _code  then
			return retKPI;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
