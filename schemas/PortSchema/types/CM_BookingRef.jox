    <JadeMethod name="createBookingRefDiscrepEvents" id="82aa292b-16a9-4788-842d-e910ff34ddcc">
        <source>createBookingRefDiscrepEvents( _cmif : CMIF_BookingRef );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2009	cnwndl1	Initial creation
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	newEvent : CMEVT_BookingRefDiscrep;
	ti : CM_TrackedItem;
	realBRefItem : CM_BookingRefItem;
	pxyBRefItem : CM_BookingRefItem;
	cmifEventCtrl : CMIF_BookingRefDiscrepCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
	
begin

	if self.isTransient then
		return;
	endif;
	
	foreach ti in self.allTIs do
	
		realBRefItem := self.getBookingRefItemForTI(ti);
		if realBRefItem = null then
			pxyBRefItem := null;
		else
			pxyBRefItem := realBRefItem.pxyGetProxyObject();
		endif;
		
		if ti.requiresNewBookingRefDiscrep( _cmif, pxyBRefItem ) then
			/* //17/02/2025	navkc1 JIRA Bug MTN-33582
			newEvent := app.createEvent(EVT_BookingRefDiscrep, app.actualTimeServer, self.myTerminal, app.myPassport.userCode, false, false,0).CMEVT_BookingRefDiscrep;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			if newEvent &lt;&gt; null then
				if _cmif &lt;&gt; null then
					newEvent.setFromTiAndCmif(ti,_cmif);
				else
					newEvent.setFromTiAndBookingRef(ti, self, pxyBRefItem);
				endif;
				
				app.myPassport.addEventTransactionForDeferUpd(newEvent,self.myTerminal); // ### JIRA 33567 03DEC2024 NAVAB1
				//newEvent.createCharge(app.myPassport);
			endif; 
			*/
			
			//17/02/2025	navkc1 JIRA Bug MTN-33582 - Starts
			delete cmifEventCtrl;
			create cmifEventCtrl transient;
			cmifEventCtrl.type := EVT_BookingRefDiscrep;
			cmifEventCtrl.dateTime := app.actualTimeServer();
			cmifEventCtrl.myTerminal := self.myTerminal;
			cmifEventCtrl.userCode := app.myPassport.userCode;
			cmifEventCtrl.myTrackedItem := ti;
			
			if _cmif &lt;&gt; null then 
				cmifEventCtrl.myCMIFBookingRef := _cmif;
			else
				cmifEventCtrl.myBookingRef := self;
				cmifEventCtrl.myBookingRefItem := pxyBRefItem;
			endif;
			
			newEvent := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_BookingRefDiscrep;
			//17/02/2025	navkc1 JIRA Bug MTN-33582 - Ends
		endif;
	
	endforeach;

epilog
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
        <Parameter name="_cmif" type="CMIF_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="delete" id="e2f10db8-5f81-4525-ac51-65a53cf4eb1d">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		30 May 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 07 Dec 2011	cnwkpd1		PAR #28814 - Migrate code from erase to delete
// --------------------------------------------------------------------------------

vars
	ya			: CM_YardAllocation;
	crit		: CM_YACriteria;
	yaType 		: CM_YATypeBookingRef;
	
begin
	if not self.isTransient then
		self.allBookingRefItems.purge();

		// PAR #28814
		yaType := CM_YATypeBookingRef.firstInstance();
		if yaType &lt;&gt; null then
			yaType.removeMyDataObject(self);
		endif;
	
		// PAR #28524 delete booking discrepancies
		self.allBookingRefDiscreps.purge;
	endif;

	if self.isTransient() or not self.isStockBookingRef then
		self.allReleaseRequests.purge();
	endif;
	//if this is transient then allTIHazards will be transient so must delete 
	//if self is persistant then allTIHazards will be persistant so still have to delete
	self.allTIHazards.purge();
end;</source>
    </JadeMethod>
