        <source>wsPelindoReleaseExtensionWO(	_containers 	: CM_TISet io;
								_releaseWO 		: CM_WodRelease io;
								_requiredBy 	: TimeStamp io;
								_xtraTestString : String
								):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2019	jlgndl1	Initial creation	TFS 44774
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars
	ref 		 : String;
	webService 	 : JMTUserInterfaceService;
	request 	 : WS_WorkOrderDetailUpdateReq;
	response 	 : WS_Response;
	wsReleaseExt : WS_WorkOrderReleaseExt;
	container 	 : CM_TrackedItem;
	woTI         : WS_WorkOrderTrackedItem;
begin

	if _containers = null or _containers.isEmpty then
		return method.qualifiedName &amp; " " &amp; _xtraTestString &amp; ", &lt;null&gt; containers parameter supplied.";
	endif;
	if _releaseWO = null then
		return method.qualifiedName &amp; " " &amp; _xtraTestString &amp; ", &lt;null&gt; release workorder release parameter supplied.";
	endif;
	if not _requiredBy.date.isValid then
		return method.qualifiedName &amp; " " &amp; _xtraTestString &amp; ", &lt;null&gt; required by parameter supplied.";
	endif;
	
	if _releaseWO.getMyReleaseRequest = null then
		return method.qualifiedName &amp; " " &amp; _xtraTestString &amp; ", workorder parameter supplied, WodRelease has no 'Bulk Release'.";
	endif;

	//set up dummy web objects
	create request transient;
	create wsReleaseExt transient;
	
	request.myWorkOrderDetail := wsReleaseExt;
	
	wsReleaseExt.cargoTypeId := TI_CargoType_Container;
	wsReleaseExt.releaseRequestOid := _releaseWO.getMyReleaseRequest.getOidAsString;
	wsReleaseExt.releaseRequestNum := _releaseWO.getMyReleaseRequest.code;
	wsReleaseExt.releaseWorkOrderOid := _releaseWO.getMyParent.getOidAsString;
	foreach container in _containers do
		/* 29.09.2021 navma1 #51925
		wsReleaseExt.allCargoIds.add( container.id );
		wsReleaseExt.allCargoOids.add( container.getOidAsString );
		*/
		//29.09.2021 navma1 #51925
		create woTI transient;
		woTI.setProxyFromObject(container);
		wsReleaseExt.allTIs.add(woTI);
	endforeach;
	wsReleaseExt.requiredByDT := _requiredBy.asStringForWebInterface;

	//Start test
	create webService transient;
	response := webService.createWorkOrderDetail( request );

	if response = null then
		return method.qualifiedName &amp; " " &amp; _xtraTestString &amp; ", updateResponse not returned.";
	endif;
	
	return response.getErrorsAsStringForTesting;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsPelindoReleaseExtensionWO.name; 

epilog

	delete response;
	delete webService;
	delete request;

end;</source>
