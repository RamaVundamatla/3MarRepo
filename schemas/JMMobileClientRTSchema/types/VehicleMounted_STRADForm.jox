    <JadeMethod name="btnMove_click" id="4554bb36-cfea-4b7d-9588-46a38a81e78e">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnMove_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
16 June 2008	concms1	PAR 17123 (CCMS 1671) DCT Gdansk - RDT Screen to relocate containers

*/

vars

begin
	app.mousePointer	:=	Busy;	
	
	if self.btnMove.caption = "Move" then
		self.doMoveTI; 
	else
		self.doAutoplanPickup();
	endif;
epilog
	app.mousePointer	:=	Idle;	
end;</source>
