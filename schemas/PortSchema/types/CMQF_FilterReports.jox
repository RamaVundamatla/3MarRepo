    <JadeMethod name="getMyTerminal" id="71a056ca-c510-4a73-927a-3bb5a13dd44d">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2016	cnwmp6	Initial creation

*/

vars
	term			: CM_Terminal;
	timeZoneID		: String;
	invalidObject	: Boolean;
	edition			: Integer;

begin
	if self.allTerminals.isEmpty() then
		return null;
	elseif self.allTerminals.size() = 1 then
		return self.allTerminals.first();
	else
		on Exception do app.handleDeletedObject(exception, term, invalidObject);
		foreach term in self.allTerminals do
			invalidObject := false;
			edition := term.edition;
			if invalidObject then
				continue;
			endif;
			if timeZoneID = null then
				timeZoneID := term.timeZoneID;
			endif;
			if timeZoneID &lt;&gt; term.timeZoneID then
				return null;
			endif;
		endforeach;
		return self.allTerminals.first();
	endif;
epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
