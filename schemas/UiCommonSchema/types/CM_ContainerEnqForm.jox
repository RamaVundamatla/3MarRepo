// ---------------------------------------------------------------------------
// Created:     11 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	return ETDef_ContEnqFind;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="searcherTblInitControls" id="2add5199-5b72-46d5-aed4-f68f4446f8e1">
        <updating/>
        <source>searcherTblInitControls() updating;
// ---------------------------------------------------------------------------
// Created:     11 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theRow			: Integer;
	tmpCombo		: CMUI_ComboBox;
	idx,
	tmpTypeId		: Integer;
	
begin
	//epr TFS 47132 30/12/19
	if self.useSelectorTable then	
		return;
	endif;
	
	if CM_LocationsController.hasInstance(self.myCurrentObject) then
		self.filterTblInitWithLC();
		return;
	endif;
	
	if self.myCurrentObject &lt;&gt; null
	and self.myCurrentObject.isKindOf(CM_TrackedItem)
	then
		self.myCurrentCargoBOLType := self.myCurrentObject.CM_TrackedItem.myCargoType;
		tmpTypeId := self.myCurrentCargoBOLType.id;
	else
		tmpTypeId := self.getDefaultTiType(self.myCurrentCargoBOLType);
	endif;
	
	self.tblSearch.setTerminologyRelevant(self.myCurrentCargoBOLType, self.myTerminal);

	tmpCombo := cmbFiltTiType;
	tmpCombo.sorted := true;
	self.myAssistant.comboBoxCargoBolType(tmpCombo, tmpTypeId, true, true, true, true);
//	self.myAssistant.comboBoxCargoBolTypeWithNull(tmpCombo, tmpTypeId, true);
	tmpCombo.selLength := 100;
	tmpCombo.lostFocus(tmpCombo);
	self.loadProductCombo();
	self.loadSubTerminalFilter();
	self.loadTrailerCombo();
//  CCMS1235 new combobox object. 	
//	tmpCombo := cmbFiltISOType;
//	self.myAssistant.comboBoxISOType(tmpCombo, null);

	tmpCombo := cmbFiltVoyage;
	//self.myAssistant.setAllVoyageCodes(true, self.includeArchivedVoyages);		
	self.myAssistant.comboBoxVoyageCurrent(	tmpCombo,
											null,
											true,
											self.includeArchivedVoyages,
											self.includeSailedVoyages,
											true,
											true,
											true,
											true,
											false,
											false); //cnwrs1 par15258 nov 2007

//  CCMS1235 new combobox object. 		
//	tmpCombo := self.cmbFiltOperator;
//	self.myAssistant.comboBoxOperator(tmpCombo, null, null);

	//Manually enter and set a default for the state combo
	tmpCombo := cmbFiltSite;
	tmpCombo.clear;
	tmpCombo.addItem(ANYSITE_STRING);
	tmpCombo.addItem(ONSITE_STRING);
	tmpCombo.addItem(OFFSITE_STRING);
	tmpCombo.addItem(ONSHIP_STRING);
	tmpCombo.addItem(OFFLOADED_STRING);
	tmpCombo.addItem(NOTIFIED_STRING);
	tmpCombo.addItem(DELETED_STRING);
	
	// DVB changed to use new flags 05/04/05
	if app.isInterTerminalTransferEnabled() then
		tmpCombo.addItem(TRANSFER_STRING_TO);
		tmpCombo.addItem(TRANSFER_STRING_FROM);
	endif;
	
	tmpCombo.listIndex := 2;	//ONSITE IS DEFAULT
	tmpCombo.lostFocus(tmpCombo);
	tmpCombo := cmbFiltTAType;
	self.myAssistant.comboBoxTAType(tmpCombo, null, true);
	//05/11/2009 cnwdz2 par21455
	foreach idx in 1 to tmpCombo.listCount do
		if tmpCombo.itemObject[idx] = app.myRoot.allTerminalAreaTypes[TA_TYPE_ROAD_TRANS] then
			// this should never happen as all VTAs were deleted in 7.7.3 conversion !!!
			tmpCombo.removeItem(idx);
			break;
		endif;
	endforeach;
	
	self.setStateByCargoType(self.myCurrentCargoBOLType);
	self.setCargoTypeFields(self.myCurrentCargoBOLType);

	//CNWTH2 - this has already been called in this method - above(?)
	//self.myAssistant.comboBoxVoyageCode(self.cmbFiltVoyage, null, true);
	//self.myAssistant.comboBoxOperator(self.cmbFiltOperator, null, null);
	self.myAssistant.comboBoxTerminalArea(self.cmbFiltTermArea, TA_TYPE_NULL, null);
	
	self.resizeFilterIdRow(); //cnwas3 par 24542
end;</source>
    </JadeMethod>
    <JadeMethod name="setAnyTableValByEntRow" id="7aa78674-f44f-45d1-891a-15be8c662e89">
        <updating/>
        <source>setAnyTableValByEntRow(_entRow : String; _value : Any) updating;
/*
Purpose:			This will set every instance of the row provided to the value on each edit table
					and initialise those tables which have not yet been initialised

Parameters:			

Return Value:		

Date		Who		Reason
12/02/2012	cnwdap1	Initial creation PAR #28962 CCMS CPL 2100
*/
vars
	sheet	: CMUI_Sheet;
	idx		: Integer;
	
begin
	foreach idx in 1 to self.NUMBER_OF_SHEETS do
		sheet := self.getEditSheetForIndex(idx);
		if sheet.visible then
			// has the table for this ent row been initialised yet?
			if not self.allInitializedSheets.includes(idx) then
				// this table hasn't been initialised - do it now
				self.showThumbnailDataForSheet(sheet, false);
			endif;
		endif;
	endforeach;
	
	// and now that we've initialised it, do the normal setting of value
	self.setInitialisedTableValByEntRow(_entRow, _value);

epilog

end;</source>
        <Parameter name="_entRow" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setCargoTareWeight" id="aea68d58-c336-4168-bf77-ca7cd618a974">
        <source>setCargoTareWeight(_proxyTI : CM_TrackedItem input; _cargoBOLType : CM_CargoBOLType);
//
// 02 Oct 2012	cnwrs1	Par 30468 if not using the cargoType useTareCargoWeight dont clear out the weights
// 18 Oct 2012	cnwcs5	par 30614 - use cargoType passed into method, not self.myCurrentcargoBOLType
//
vars
	realTI 		: CM_TrackedItem;
begin
	if _cargoBOLType.isKindOf (CM_CargoType) and not _cargoBOLType.CM_CargoType.useTareCargoWeight then
		realTI := _proxyTI.pxyGetRealObject();
		
		if realTI.weightCargo &gt; 0 and _proxyTI.weightCargo = 0 then
			_proxyTI.setWeightCargo(realTI.weightCargo);
		endif;
		
		if realTI.weightTare &gt; 0 and _proxyTI.weightTare = 0 then
			_proxyTI.setWeightTare(realTI.weightTare);
		endif;
	endif;
end;</source>
        <Parameter name="_proxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_cargoBOLType" type="CM_CargoBOLType"/>
    </JadeMethod>
    <JadeMethod name="setCargoTypeCombo" id="564cb367-8ece-4e57-a045-738191ead487">
        <source>setCargoTypeCombo();
//18 November 2009	cnwml2
//+cnwml2 PAR21056
// 29 Oct 2018	jlgrh7 TFS #41190 STWO - LIMESTONE and AGGREGATES disapered from Cargo type selection list
// 30 Jun 2020	NDL	TFS 49597
vars

	cargoType : CM_CargoBOLType;
	trackedItem : CM_TrackedItem;
	tiType : CM_CargoBOLType;
	productType : Integer;
	
begin

	trackedItem := self.myCurrentObject.CM_TrackedItem;
	if trackedItem &lt;&gt; null then
		tiType := trackedItem.myCargoType;
	endif;
	if tiType &lt;&gt; null and tiType.isKindOf(CM_CargoType) then
		productType := tiType.CM_CargoType.productType;
	endif;
	
	self.cmbCargoType.clear();
	self.tblInputTop.enableRowByName(ETRow_CargoTypeEntry);
	
	if tiType.id = TI_CargoType_Container or tiType.id = TI_CargoType_Generator or tiType.id = TI_CargoType_Log or tiType.id = TI_CargoType_COU then
		self.tblInputTop.disableRowByName(ETRow_CargoTypeEntry);
		
	elseif productType = ProductType_Trailer then
		foreach cargoType in self.myTerminal.allCargoBOLTypes do
			if cargoType.isKindOf(CM_CargoType) and cargoType.CM_CargoType.productType = ProductType_Trailer then
				self.cmbCargoType.addItemObject(cargoType.description, cargoType);
			endif;
		endforeach;
		
	elseif productType = ProductType_Vehicle then
		foreach cargoType in self.myTerminal.allCargoBOLTypes do
			if cargoType.isKindOf(CM_CargoType) and cargoType.CM_CargoType.productType = ProductType_Vehicle then
				self.cmbCargoType.addItemObject(cargoType.description, cargoType);
			endif;
		endforeach;
	
	elseif trackedItem.isKindOf(CM_Bulk)  then																																									//+TFS41190 Not Handl Buk Cargo
		foreach cargoType in self.myTerminal.allCargoBOLTypes do
			if cargoType.isKindOf(CM_CargoType) and cargoType.CM_CargoType.classNameToCreate = CM_Bulk.name then
				self.cmbCargoType.addItemObject(cargoType.description, cargoType);
			endif;
		endforeach;
	
	else			//must be break bulk
		foreach cargoType in self.myTerminal.allCargoBOLTypes do
			if cargoType.isKindOf(CM_CargoType) and cargoType.CM_CargoType.isBreakBulk() then
				if cargoType.id = TI_CargoType_Container or cargoType.id = TI_CargoType_Generator or cargoType.id = TI_CargoType_Log or cargoType.id = TI_CargoType_COU then
					continue;
				else
					self.cmbCargoType.addItemObject(cargoType.description, cargoType);
				endif;
			endif;
		endforeach;
		
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCargoTypeFields" id="5cc8ea98-6989-43dc-acf7-2b60d4bc92c4">
        <updating/>
        <source>setCargoTypeFields(_obj : CM_CargoBOLType)updating;
//--------------------------------------------------------------
//Created: 30 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.setFilterTblView(_obj);
	self.tblSearch.resetSize();			
	
	self.zResetDataFilterRatio();
	self.resetNavigatorHeading(_obj);

	if (not self.amInitialisingWithObject) then
		self.zClearTblData();
		if self.myCurrentCargoBOLType &lt;&gt; null then
			self.setupTblDataForCargoType(self.myCurrentCargoBOLType.id);
			self.setupTblSearcherForCargoType(self.myCurrentCargoBOLType.id);			
		else
			tblData.setTblDataEntRowsFromDef(self.getTblDataDef);
		endif;
		self.zClearThumbnailData();
	endif;	

end;</source>
        <Parameter name="_obj" type="CM_CargoBOLType"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="bc5bedd2-9cdf-4714-908e-5d57f87e9402">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     12 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBackColor,
	tmpControlBack,
	tmpHeadingColor	: Integer;
	
begin
	inheritMethod(_colorControl);
	
	tmpBackColor 	:= self.backColor;
	tmpControlBack	:= self.colorControlBack;
	tmpHeadingColor	:= self.colorHeadingColumn;
	
	self.fldEdit.backColor	:= tmpBackColor;
	self.shtEdit1.backColor	:= tmpBackColor;	
	self.shtEdit2.backColor	:= tmpBackColor;	
	self.shtEdit3.backColor	:= tmpBackColor;	
	self.shtEdit4.backColor	:= tmpBackColor;	
	self.shtEdit5.backColor	:= tmpBackColor;	
	self.shtEdit6.backColor	:= tmpBackColor;
	self.shtEdit7.backColor := tmpBackColor;
	self.shtEdit8.backColor := tmpBackColor;
	self.shtEdit9.backColor := tmpBackColor;
	self.shtEdit10.backColor := tmpBackColor;
	self.shtTasks.backColor	:= tmpBackColor;

	// do not call self.setColorsForEntryTable for tblEditX as
	// we watn to set the backColors for the value cells specifically

	self.tblInputTop.backColor	:= tmpBackColor;
	self.tblAlpha.backColor := tmpBackColor;
	self.tblEdit1.backColor := tmpBackColor;
	self.tblEdit2.backColor := tmpBackColor;
	self.tblEdit3.backColor := tmpBackColor;
	self.tblEdit4.backColor := tmpBackColor;
	self.tblEdit5.backColor := tmpBackColor;
	self.tblEdit6.backColor := tmpBackColor;
	self.tblEdit7.backColor := tmpBackColor;
	self.tblEdit8.backColor := tmpBackColor;
	self.tblEdit9.backColor := tmpBackColor;
	self.tblEdit10.backColor := tmpBackColor;
	
	self.tblInputTop.accessColumn(self.tblEdit1.ColumnHeading).backColor := tmpHeadingColor;
	self.tblAlpha.accessColumn(self.tblAlpha.ColumnHeading).backColor := tmpHeadingColor;
	self.tblEdit1.accessColumn(self.tblEdit1.ColumnHeading).backColor := tmpHeadingColor;
	self.tblEdit2.accessColumn(self.tblEdit1.ColumnHeading).backColor := tmpHeadingColor;
	self.tblEdit3.accessColumn(self.tblEdit1.ColumnHeading).backColor := tmpHeadingColor;
	self.tblEdit4.accessColumn(self.tblEdit1.ColumnHeading).backColor := tmpHeadingColor;
	self.tblEdit5.accessColumn(self.tblEdit1.ColumnHeading).backColor := tmpHeadingColor;
	self.tblEdit6.accessColumn(self.tblEdit1.ColumnHeading).backColor := tmpHeadingColor;
	self.tblEdit7.accessColumn(self.tblEdit1.ColumnHeading).backColor := tmpHeadingColor;
	self.tblEdit8.accessColumn(self.tblEdit1.ColumnHeading).backColor := tmpHeadingColor;
	self.tblEdit9.accessColumn(self.tblEdit1.ColumnHeading).backColor := tmpHeadingColor;
	self.tblEdit10.accessColumn(self.tblEdit1.ColumnHeading).backColor := tmpHeadingColor;
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="01a6c8e0-1988-4ade-9c8f-639962f37db0">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     07 December 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 07/12/2009	cnwdap1		CCMS MES 1007 - add Reefer Ent Def to allow non-container reefer maintenance
// 29/03/2010	cnwdap1		PAR #23224 Expand reefer check to include commodity
// 14/06/2010	cnwcs5		par 24342 - remove ability to maintain stops
// 15/06/2010	cnwcs5		par 24342 - no longer using CMUI_StopsListTable
// 29/06/2010	cnwdap1		PAR #24516 Add Tranship tab to edit defs if TI is a Tranship item
// 13/08/2013	cnwdap1		PAR #32123 Added Colour Picker
// 30/06/2015	cnwdap1		PAR #36421 Hazardous Materials Handling
// 15/11/2016	cnwdap1		TFS 2842 STWR Hazardous Details Enhancements
// 27 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
//10 September 2023 CR 58250 Task 58253: UI - Cargo Enquiry New Sheet
vars
	obj			: CM_Object;
	tbl			: CM_EntryTable;
	ucTab		: CM_UserConfigTab;
	cbType		: CM_CargoBOLType;
	idx,
	numDefs		: Integer;
	sheet		: CMUI_Sheet;
	entDef		: EntTableDef;
	bulkEditing,
	ls			: Boolean;
	hasTranshipTab	: Boolean;
	hideTranshipTab	: Boolean;
	entRowName	: String;
	tmpDefArray	: StringArray;
	
begin
	app.cmsBeginLoad(ls);
	
	self.btnTransactions.enabled := false;
	self.btnTranship.enabled := false;
	
	self.hasEditedToDoTasks := false;
	self.allTasksToAdd.clear();
	self.allTasksToComplete.clear();
	self.allTasksToRemove.clear();
	// par 24342 self.clearStopsCollections();			// cnwrl1 29/01/2010 PAR 21889
	
	//cnwrd1 ccms 1804 22.5.09
	self.currentEditedBookingRef := null;
	
	bulkEditing := self.doingMultiEdit;
	obj := self.myCurrentObject.CM_Object;
	if obj = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Current object is null');
		return;
	endif;
	
	cbType := self.myProxyObject.CM_TrackedItem.myCargoType;
	
	if cbType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'CargoType is null for ' &amp; obj.String);
		return;
	endif;
	// 28374 Nov 2011 Logs have a different edit table from enquiry; 28882 add test for null myCurrentCargoBOLType
	if self.myCurrentCargoBOLType &lt;&gt; null and
	   self.myCurrentCargoBOLType.id = TI_CargoType_Log and
	   self.mode = Mode_Update then
		delete self.myUserCargoType;
		delete self.myReeferCargoType;
		self.myUserCargoType := app.myPassport.myUser.getUserCargoType(cbType, true);
	endif;
	
	// PAR 24516, revised
	foreach ucTab in self.myUserCargoType.allUserConfigTabs do
		if ucTab.name = ETDef_TranshipData then
			hasTranshipTab := true;
			break;
		endif;
	endforeach;
	if self.myProxyObject.CM_TrackedItem.isTranshipItem and
	   not hasTranshipTab then
		app.myPassport.myUser.getUserCargoTypeTranship(self.myUserCargoType, null);
	endif;

	numDefs := self.numberOfSheets;
	if hasTranshipTab and
	   not self.myProxyObject.CM_TrackedItem.isTranshipItem then
		hideTranshipTab := true;
	endif;
	if numDefs = 0 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No Edit EntTableDefs have been setup for ' &amp; cbType.description);
		return;
	endif;
	entDef := self.tblInputTop.myEntTableDef;
	
	//epr TFS 47132 12/11/19
	self.tblInputTop.visible		:= true;
	self.tblInputTop.clearValues();
	self.tblInputTop.setTableFromCM_Object(obj,null);
	
	self.allEntryTableDefs.clear();
	self.allInitializedSheets.clear();
	
	self.caption := self.caption &amp; ' - Currently Editing...';
	
	if self.isShowingAlphabetised then
		if (not self.canUpdate and self.canChangeFreightForwarder()) then
			self.showOnlyFreightForwarder(obj,numDefs);
		else
			self.showThumbnailAlphbetised(numDefs, obj, true);
		endif;
	else
		if (not self.canUpdate and self.canChangeFreightForwarder()) then
			self.showOnlyFreightForwarder(obj,numDefs);
			self.tblEdit1.visible := false;// PAR 16223
		else
			//show sheets for number of defs
			idx := 0;
			foreach ucTab in self.myUserCargoType.allUserConfigTabs do
				idx := idx + 1;
				sheet := self.getEditSheetForIndex(idx);
				if ucTab.name = ETDef_TranshipData and
				   hideTranshipTab then
					sheet.visible := false;
				elseif ucTab.name = ETDef_TILCLoadDetails then //jlier1 TFS 54700 20/9/22
					sheet.visible:=false;
				//10 September 2023 CR 58250 Task 58253: - start
				elseif ucTab.name = ETDef_StorageExpDetails then
					sheet.visible := false;
				//10 September 2023 CR 58250 Task 58253: - end
				else
					sheet.visible := true;
				endif;
				sheet.caption := ucTab.description;
				if ucTab.name = ETDef_TrailorData and cbType &lt;&gt; null  then //jlier1 TFS 54700 20/9/22
					sheet.caption:=cbType.description &amp; Space &amp; app.getErrorString(CM_Details);
				endif;
			endforeach;
			if self.isReeferTabVisible and self.myReeferCargoType &lt;&gt; null and
			   idx &lt; self.NUMBER_OF_SHEETS then
				foreach ucTab in self.myReeferCargoType.allUserConfigTabs do	// only one tab
					idx := idx + 1;
					sheet := self.getEditSheetForIndex(idx);
					sheet.caption := ucTab.description;
					sheet.visible := true;
				endforeach;
			endif;
			
			self.showThumbnailDataForSheet(self.fldEdit.topSheet.CMUI_Sheet, false);
		endif;
		if numDefs &lt; self.NUMBER_OF_SHEETS then
			// hide any other sheets
			foreach idx in (numDefs + 1) to self.NUMBER_OF_SHEETS do
				sheet := self.getEditSheetForIndex(idx);
				sheet.visible := false;
			endforeach;	
		endif;
	endif;
	
	if bulkEditing then
		delete self.myBulkEditController;
		create self.myBulkEditController transient;
		self.myBulkEditController.myMasterTI := self.myCurrentObject.CM_TrackedItem;
		self.lblBulkEditOpt.visible := true;
	else
		if self.allTITxnControllers.isEmpty then
			self.myCurrentObject.CM_TrackedItem.createTITxnControllers(self.allTITxnControllers);
		endif;	
	endif;

	
	// Check if we have to do any special processing for the current row
	tbl 		:= self.getEditTableForSheet(self.fldEdit.topSheet.CMUI_Sheet);
	entRowName 	:= tbl.getAttrName(tbl.row);
	
	if //entRowName = ETRow_AllStops or 14/06/2010 cnwcs5 par 24343 - commented out
		//entRowName = ETRow_AllHazards or 												// TFS 2842
		entRowName = ETRow_AllSpecialLifts or
		entRowName = ETRow_Colour then					// PAR #32123
		self.doTblEditRowColChange(tbl);
	endif;
	// End of special processing for current row

	self.fldEdit.cnEcResizeContents();
	self.btnMoveIt.enabled := false;
	self.btnPrintList.enabled := false;
	self.btnExportCSVTV.enabled := false;
	self.btnInstruction.enabled := false;//27.10.2022 navtnr20 TFS 54967
	self.setCargoTypeCombo();					//+cnwml2 PAR21056

	// from 29944, if showing damage form, which will be from view, close it so can open again in edit mode is required
	if self.myDamageCodesForm &lt;&gt; null and
	   app.isValidObject(self.myDamageCodesForm) then
		delete self.myDamageCodesForm;
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuCargo.enabled := false;
		self.btnTranship.enabled := false;
		self.btnMoveIt.enabled := false;
		self.btnEditTV.enabled:= false;
	endif;	
	
epilog
	app.cmsEndLoad(ls);	
	delete tmpDefArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="8cacce69-5de6-4945-93e2-5f7bbca994c8">
        <updating/>
        <source>setControlsForView() updating;
// ---------------------------------------------------------------------------
// Created:     07 December 2000 by cnwrs2
//
// Purpose:     
// 18 Nov 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
// ---------------------------------------------------------------------------
vars
	idx,
	topSheet			: Integer;
	tbl					: CM_EntryTable;
begin
	if self.canAccessTransactions then
		self.btnTransactions.enabled := true;
	endif;
	
	if self.canUpdate then
		//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366	
		self.btnTranship.enabled := true;
	endif;

	self.hasEditedToDoTasks := false;
	
	//cnwrd1 ccms 1804 22.5.09
	self.currentEditedBookingRef := null;
	
	self.allTasksToAdd.clear();
	self.allTasksToComplete.clear();
	self.allTasksToRemove.clear();
	
	self.btnSelectAllTV.enabled := true;
	if self.tblData.visible then
		self.btnPrintList.enabled 	:= true;
		self.btnExportCSVTV.enabled := true;
		self.btnInstruction.enabled := true;	//18.11.2022 navtnr20 TFS 54967
	endif;
	
	self.allTITxnControllers.purge();
	self.allTITxnControllers.clear();
	self.lblBulkEditOpt.visible := false;
	
	delete self.myBulkEditController;

	//epr TFS 47132 13/12/19
	self.tblInputTop.clearValues();
	//+cnwml2 PAR24389 start
	/*self.tblInputTop.clear();
	self.tblInputTop.allEntRowTransients.purge();
	self.tblInputTop.rows := self.tblInputTop.fixedRows;*/
	
	self.tblAlpha.clear();
	self.tblAlpha.allEntRowTransients.purge();
	self.tblAlpha.rows := self.tblAlpha.fixedRows;	
	
	self.tblEdit1.clear();
	self.tblEdit1.allEntRowTransients.purge();
	self.tblEdit1.rows := self.tblEdit1.fixedRows;	
	
	self.tblEdit2.clear();
	self.tblEdit2.allEntRowTransients.purge();
	self.tblEdit2.rows := self.tblEdit2.fixedRows;
	
	
	self.tblEdit3.clear();
	self.tblEdit3.allEntRowTransients.purge();
	self.tblEdit3.rows := self.tblEdit3.fixedRows;	
	
	self.tblEdit4.clear();
	self.tblEdit4.allEntRowTransients.purge();
	self.tblEdit4.rows := self.tblEdit4.fixedRows;
	
	self.tblEdit5.clear();
	self.tblEdit5.allEntRowTransients.purge();
	self.tblEdit5.rows := self.tblEdit5.fixedRows;	
	
	self.tblEdit6.clear();
	self.tblEdit6.allEntRowTransients.purge();
	self.tblEdit6.rows := self.tblEdit6.fixedRows;

	self.tblEdit7.clear();
	self.tblEdit7.allEntRowTransients.purge();
	self.tblEdit7.rows := self.tblEdit7.fixedRows;

	self.tblEdit8.clear();
	self.tblEdit8.allEntRowTransients.purge();
	self.tblEdit8.rows := self.tblEdit8.fixedRows;

	self.tblEdit9.clear();
	self.tblEdit9.allEntRowTransients.purge();
	self.tblEdit9.rows := self.tblEdit9.fixedRows;

	self.tblEdit10.clear();
	self.tblEdit10.allEntRowTransients.purge();
	self.tblEdit10.rows := self.tblEdit10.fixedRows;
	//+cnwml2 PAR24389 end
	
	//epr TFS 47132 13/12/19
	//self.editTblSetForView(self.tblInputTop);
	self.editTblSetForView(self.tblAlpha);
	self.editTblSetForView(self.tblEdit1);
	self.editTblSetForView(self.tblEdit2);
	self.editTblSetForView(self.tblEdit3);
	self.editTblSetForView(self.tblEdit4);
	self.editTblSetForView(self.tblEdit5);
	self.editTblSetForView(self.tblEdit6);
	self.editTblSetForView(self.tblEdit7);	
	self.editTblSetForView(self.tblEdit8);	
	self.editTblSetForView(self.tblEdit9);	
	self.editTblSetForView(self.tblEdit10);	
	
	self.cmbVoyage.clear();
	
	self.cmbSortingMethod.clear();	// ### TFS 57812 (58439) 12Jun2023 NAVPW1
	
end;</source>
    </JadeMethod>
