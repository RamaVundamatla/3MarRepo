	comCode.add("GLAS");

	opCode.add("MSK");
	voyCode.add("JBL300N");
	disCode.add("USPHL");
	destCode.add("USPHL");
	comCode.add("GENL");
	opCode.add("MSK");
	voyCode.add("JBL300N");
	disCode.add("USPHL");
	destCode.add("USPHL");
	comCode.add("WINE");
	opCode.add("MSK");
	voyCode.add("JBL300N");
	disCode.add("USPHL");
	destCode.add("USPHL");
	comCode.add("MACH");
	opCode.add("MSK");
	voyCode.add("JBL300N");
	disCode.add("USPHL");
	destCode.add("USPHL");
	comCode.add("AUTO");
