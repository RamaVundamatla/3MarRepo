        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setFromTransaction" id="01ad0308-bf61-4f54-8361-f361e1da7ffa">
        <updating/>
        <source>setFromTransaction(_txn: CM_Hire) updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_txn);
	self.fleetDisposition 	:= _txn.fleetDisposition;
	self.hireType			:= _txn.hireType;
	self.messageStatus		:= _txn.messageStatus;
	self.otherParty			:= _txn.otherParty;
	self.ownership			:= _txn.ownership;

end;</source>
        <Parameter name="_txn" type="CM_Hire"/>
    </JadeMethod>
    <JadeMethod name="setTransactionDetails" id="13af6918-c941-4bf1-b562-731e941a63af">
        <updating/>
        <source>setTransactionDetails(pTrx: CM_TITransaction input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     12 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(pTrx);


end;</source>
        <access>protected</access>
        <Parameter name="pTrx" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
</Class>
