    <JadeMethod name="btnJobsMode_click" id="b1ec8b96-bb33-466d-b6c9-0654dc705e5b">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnJobsMode_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     08 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if (not self.toolbarClickPreProcessing(VIEW_JOB)) then
		return;
	endif;

	if self.workingMode = self.WorkMode_Job then
		// already in job mode so set to none
		self.switchWorkingMode(self.WorkMode_None);
		btn.value := false;
	else
		self.switchWorkingMode(self.WorkMode_Job);
	endif;

	if self.displayMode &lt;&gt; ShpDisplayMode_ColCodeLoad and 
	   self.displayMode &lt;&gt; ShpDisplayMode_ColCodeDisch then
		self.switchDisplayMode(ShpDisplayMode_ColCodeDisch, true);
	endif;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
