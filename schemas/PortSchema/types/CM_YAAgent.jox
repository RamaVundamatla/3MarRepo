    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="addRange" id="b88f1bf3-b164-48de-956d-581c9acf7e18">
        <source>addRange(_proxyYA: CM_YardAllocation io; _range: String): CM_YABlock;
//13 February 2009	cnwdw1	
// Add a new range to the YA
vars
	result: Boolean;
	topLeft, bottomRight: CM_LocationsController;
	locations: CM_LCArray;
begin
	// PAR 19308
	//if _proxyYA.myTerminal.findYABlock(_range, topLeft, bottomRight) then
	if _proxyYA.myTerminal.findYABlock(_range, topLeft, bottomRight, null) then
		create locations transient;
		self.findAllLocations(topLeft, bottomRight, locations);
		return self.addYABlock(_proxyYA, locations);
	endif;
	
	return null;
epilog
	delete locations;
end;</source>
        <Parameter name="_proxyYA" type="CM_YardAllocation" usage="io"/>
        <Parameter name="_range" type="String"/>
        <ReturnType type="CM_YABlock"/>
    </JadeMethod>
    <JadeMethod name="addYABlock" id="c14162f5-e440-4468-a998-265fb79f2631">
        <source>addYABlock(_proxyYA: CM_YardAllocation io; _locations: CM_LCArray): CM_YABlock;
//13 February 2009	cnwdw1	
//
vars
	yaBlock: CM_YABlock;
begin
	yaBlock := _locations.first.yaBuildBlock(true, _proxyYA);
	_locations.copy(yaBlock.allYardControllers);
	yaBlock.setProxyDeckingOptions();
	_proxyYA.allYABlocksIn.add(yaBlock);
	_proxyYA.allYABlocksOut.add(yaBlock);
	_proxyYA.allYABlockGroupsIn.first.allYABlocksIn.add(yaBlock);
	_proxyYA.allYABlockGroupsIn.first.allYABlocksOut.add(yaBlock);
	return yaBlock;
end;</source>
        <Parameter name="_proxyYA" type="CM_YardAllocation" usage="io"/>
        <Parameter name="_locations" type="CM_LCArray"/>
        <ReturnType type="CM_YABlock"/>
    </JadeMethod>
    <JadeMethod name="deleteYABlock" id="50e5a4e2-7580-4601-ad47-c69134289c2c">
        <source>deleteYABlock(_proxyYA: CM_YardAllocation io; _yaBlock: CM_YABlock io);
//13 February 2009	cnwdw1	
//
vars

begin
	delete _yaBlock;
end;</source>
        <Parameter name="_proxyYA" type="CM_YardAllocation" usage="io"/>
        <Parameter name="_yaBlock" type="CM_YABlock" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findAllLocations" id="b18f966a-c829-44e6-9512-7d374e1e88fb">
        <source>findAllLocations(_topLeft, _bottomRight: CM_LocationsController input; _locations: CM_LCArray io);
//13 February 2009	cnwdw1	
//epr par 25601 21/12/10 checking for null
//dap TFS 49453 12/06/2020 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	topLeftLocation, bottomRightLocation,
	foundLocation	: CM_GridController;
	terminalArea : CM_TerminalArea;
	row, col: Integer;

	la : CM_RoRoLaneArea;
	topLane : CM_RoRoController;
	bottomLane : CM_RoRoController;
	lane : CM_RoRoController;
	laneNo : Integer;
	
	group : CM_GeneralCargoAllocGroup;						// TFS 49453
	topRow, bottomRow : CM_GeneralCargoAllocController;		// TFS 49453
	lc, column : CM_LocationsController;					// TFS 49453
	allColumns : CM_LCByIdExtKeyDict;						// TFS 49453
begin
	if _topLeft.isKindOf(CM_GridController) then
		topLeftLocation := _topLeft.CM_GridController;
		bottomRightLocation := _bottomRight.CM_GridController;
		terminalArea :=  topLeftLocation.myTerminalArea;
		foreach row in topLeftLocation.row to bottomRightLocation.row do
			foreach col in topLeftLocation.column to bottomRightLocation.column do
				foundLocation:=terminalArea.CM_GridArea.allGridControllersByRowColumn[row, col];
				//epr par 25601 21/12/10 checking for null
				if foundLocation &lt;&gt; null then
					_locations.add(foundLocation);
				endif;
			endforeach;
		endforeach;	
	//cnwjo3 par 23077
	elseif _topLeft.isKindOf(CM_RoRoController) then //its a roro lane
		topLane := _topLeft.CM_RoRoController;
		bottomLane := _bottomRight.CM_RoRoController;
		la := topLane.myTerminalArea.CM_RoRoLaneArea;
		foreach laneNo in topLane.laneNumber to bottomLane.laneNumber do
			lane := la.allLanesByLaneNumber[laneNo];
			//epr par 25601 21/12/10 checking for null
			if lane &lt;&gt; null then
				_locations.add(lane);
			endif;
		endforeach;
	elseif _topLeft.isKindOf(CM_IrregularBlockController) then // it's a GC Rack
		_topLeft.myTerminalArea.CM_IrregularBlockArea.findAllYABlockLocations(_topLeft.CM_IrregularBlockController, _bottomRight.CM_IrregularBlockController, _locations);
	// TFS 49453 start
	elseif _topLeft.isKindOf(CM_GeneralCargoAllocController) then
		topRow := _topLeft.CM_GeneralCargoAllocController;
		bottomRow := _bottomRight.CM_GeneralCargoAllocController;
		terminalArea := topRow.myTerminalArea;
		create allColumns transient;
		terminalArea.CM_GeneralCargoAllocRowArea.getAllLocationsControllersById(allColumns);
		foreach lc in allColumns do
			if lc.CM_GeneralCargoAllocController.id &gt;= topRow.id
			and lc.CM_GeneralCargoAllocController.id &lt;= bottomRow.id then
				_locations.add(lc);
			endif;
		endforeach;
	// TFS 49453 end
	else
		_locations.add(_topLeft.CM_YardController);
	endif;
	
epilog
	delete allColumns;			// TFS 49453
end;</source>
        <Parameter name="_topLeft" type="CM_LocationsController" usage="input"/>
        <Parameter name="_bottomRight" type="CM_LocationsController" usage="input"/>
        <Parameter name="_locations" type="CM_LCArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateRange" id="4e4d02e0-86c0-4c9c-9a89-06005d026e39">
        <source>updateRange(_proxyYABlock: CM_YABlock io; _range: String);
//13 February 2009	cnwdw1	
// Update with new range to the YA

/********************************************

	cnwjo3 - 8 June 2010

	In PAR 24293, found that this method
	does not work as well as it should.
	If you are intending to update
	a range of a YA you should either
	use the updateYALocations method
	or correct this one.  It is only used
	on the CMUI_YAMaintForm screen.

*********************************************/
vars
	result: Boolean;
	topLeft, bottomRight: CM_LocationsController;
	locations: CM_LCArray;
begin

	// PAR 19308
	//if _proxyYABlock.myYardAllocationIn.myTerminal.findYABlock(_range, topLeft, bottomRight) then
	if _proxyYABlock.myYardAllocationIn.myTerminal.findYABlock(_range, topLeft, bottomRight, null) then
		create locations transient;
		self.findAllLocations(topLeft, bottomRight, locations);
		self.updateYABlock(_proxyYABlock, locations);
	endif;
epilog
	delete locations;
end;</source>
        <Parameter name="_proxyYABlock" type="CM_YABlock" usage="io"/>
        <Parameter name="_range" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateYABlock" id="e920ab05-e00c-40ef-a156-749ddbe8bc49">
        <source>updateYABlock(_yaBlock: CM_YABlock io; _locations: CM_LCArray);
//13 February 2009	cnwdw1	
//
vars
begin
	_yaBlock.allYardControllers.clear();
	_locations.copy(_yaBlock.allYardControllers);
	_yaBlock.updateDescriptionFromYAM();//epr 26189 23/11/10 sat view improvements
end;</source>
        <Parameter name="_yaBlock" type="CM_YABlock" usage="io"/>
        <Parameter name="_locations" type="CM_LCArray"/>
    </JadeMethod>
    <JadeMethod name="updateYABlocksAttributes" id="8e19588b-4bcc-4507-be30-01fcd905da7d">
        <source>updateYABlocksAttributes(_ya : CM_YardAllocation;	_allPxyYABlock : CM_YABlockArray);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 March 2009	cnwer1	Initial creation

*/

vars
	yaBlock,
	pxyYABlock : CM_YABlock;
	idx : Integer;
	pxyDeckingOptions,
	deckingOptions: CM_YADeckingOptionsBlock;
begin
	if _allPxyYABlock = null then
		return;
	endif;
	idx:=1;
	foreach yaBlock in _ya.allYABlocksIn do
		if _allPxyYABlock.size &lt; idx then
			break;
		endif;
		
		pxyYABlock:=_allPxyYABlock[idx];
		yaBlock.setMinMaxHeight(pxyYABlock.getMinHeight,pxyYABlock.getMaxHeight);
		yaBlock.setStatus(pxyYABlock.status);
		//epr 3/7/12 29889
		deckingOptions := pxyYABlock.myDeckingOptions;
		if deckingOptions &lt;&gt; null then
			yaBlock.myDeckingOptions.setMyBlock(null);
			deckingOptions.setMyBlock(yaBlock);
		endif;
		idx:=idx+1;
	endforeach;
epilog

end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
        <Parameter name="_allPxyYABlock" type="CM_YABlockArray"/>
    </JadeMethod>
    <JadeMethod name="updateYALocations" id="b375521d-19e9-47f1-86a4-ba8afe392e9d">
        <updating/>
        <source>updateYALocations(	_ya: CM_YardAllocation;
					_locations: ObjectArray;
					_allPxyYABlock : CM_YABlockArray): Boolean updating;
/* --------------------------------------------------------------------------------
	Created:		05 November 2008 by cnwdad1:2

	Purpose:		Refer to superclass implementation.

	Changed On	Changed By	Reason
	----------	----------	-------------------------------------------------------

	CNWER1		20/3/09 	PAR 19121  add _allPxyYABlocks because we need to save of some existing info like min,max height &amp; status
										not ideal as could of done without _locations parameter and just passed in the proxies but alot 
										of other methods rely on this and didn't want to break it before the release
	cnwdap1		17/08/11	PAR #28002	Call copyDecking to replace default decking rules on all block proxies with the 
										actual decking rules each existing block has
	cnwer1		03/7/12  	PAR 29889  - Deck options are updated in updateYABlocksAttributes copyDecking removed
	cnwdap1		14/10/2014	PAR #34988	Purge proxy YA blocks before we call yaParser.createBlocks, as this adds the 
										(new) blocks from the drawing controller to the (existing) blocks on the 
										proxy, leading to duplicate entries
	cnwma1		29/12/2015  PAR 37100   Failed to autoplan, no space											
	navdap1		06/11/2024	MTN-18897 	EUP | FR 53485 EUP - Warehouse Yard Allocation
 --------------------------------------------------------------------------------
 */
vars
	proxyYA: CM_YardAllocation;
	criterias: CMIF_Array;
	yaBlock: CM_YABlock;
	yaParser: CM_YAParser;
	firstBlock : CM_YAIrregularBlock;	// MTN-18897
begin
	proxyYA := app.createUpdateProxy(_ya).CM_YardAllocation;
	// Purge all the block proxies as we create them all from scratch					// PAR #34988
	proxyYA.allYABlocksIn.purge();														// PAR #34988
	create yaParser transient;
	yaParser.createBlocks(proxyYA, _locations);
	// Purge all the block proxies as we create them all from scratch					// PAR #34988
	//proxyYA.allYABlocksIn.purge();													// PAR #34988
	// Now update the YA
	proxyYA.setProxyGroupBlocks(yaParser.allYABlocksIn, yaParser.allYABlocksOut);
	
	if _allPxyYABlock &lt;&gt; null then
		self.updateYABlocksAttributes(proxyYA,_allPxyYABlock);
	endif;
	// Make sure the block order is retained
	yaParser.orderBlocks(proxyYA);
	
	foreach yaBlock in proxyYA.allYABlocksIn do                                          //29/12/2015  cnwma1 PAR #37100
		yaBlock.updateProxyDeckingOptions();
		
		// MTN-18897 start
		if yaBlock.isKindOf(CM_YAIrregularBlock) then
			if yaBlock.CM_YAIrregularBlock.myYABlockGroupIn &lt;&gt; null 
			and yaBlock.CM_YAIrregularBlock.myYABlockGroupIn.allYABlocksIn.isNotEmpty then
				firstBlock := yaBlock.CM_YAIrregularBlock.myYABlockGroupIn.allYABlocksIn.first.CM_YAIrregularBlock;
				if firstBlock.getDisplayDetails(false) = firstBlock.myTerminalArea.id then
					proxyYA.setIsFullGCArea(true);
				endif;
			endif;
		endif;
		// MTN-18897 end
	endforeach;
	
	create criterias transient;
	app.myTrxUA.trxUpdateYardAllocation(proxyYA, criterias, app.myPassport);
	return app.myPassport.trxCompletedOK;

epilog
	delete criterias;
	delete proxyYA;
	delete yaParser;
end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
        <Parameter name="_locations" type="ObjectArray"/>
        <Parameter name="_allPxyYABlock" type="CM_YABlockArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
