    <JadeMethod name="jssSet" id="36626280-118e-47ce-8c83-e65a45c23e50">
        <updating/>
        <source>jssSet(pValue: String) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Overrides the TextBox class's implementation of this method to reset
//				the receiver's date.  If the string is a valid date, then the receiver's
//				date will be set to that date, otherwise the date will be set to null.
//
// Parameters:	pValue - The string value to set the date to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pValue.Date.isValid() then
		self.setDate(pValue.Date);
	else
		self.setDate(null);
	endif;
end;</source>
        <Parameter name="pValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="jssString" id="c6857407-b233-4446-b76f-ad0076e6849e">
