    <JadeMethod name="readBoolean" id="0ea19e67-9fec-45c1-ba9c-5b113c346cb6">
        <source>readBoolean(_file : File io):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 February 2020	jlgma1	Initial creation

*/

vars
	ch : Integer;
begin
	ch := _file.readBinary(1).Integer;
	
	return ch &lt;&gt; 0;
epilog

end;</source>
        <Parameter name="_file" type="File" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
