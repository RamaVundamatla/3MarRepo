	return null;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="totColourCodedSpecialStowSlots" id="5f92537b-8d08-401e-a388-fb7038390d2f">
        <source>totColourCodedSpecialStowSlots():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 Nov 2009	cnwndl1	Initial creation	CCMS 1864 Par 21652
29 Mar 2010	cnwkpd1	PAR #23479 - Improve performance of Load List

*/

vars

//	sr			: CM_SlotRequest;
	req			: CM_Request;	//20 Nov 2012	NDL	Par 30754
	strSS		: String;
	intCounts	: IntegerArray;
	strCodes	: StringArray;
	idx			: Integer;
	strReturn	: String;
	invalidSR	: Boolean;			// PAR #23479
	
begin

	create intCounts transient;
	create strCodes transient;
	
	on Exception do app.handleDeletedObject(exception, req, invalidSR);		// PAR #23479
	
	foreach req in self.allLoadRequests do

		invalidSR := false;

		strSS := req.getSpecialStowStr();
		if invalidSR or strSS = null then			// PAR #23479
			continue;
		endif;
		
		idx := strCodes.indexOf(strSS);
		if idx = 0 then
			strCodes.add(strSS);
			intCounts.add(1);
		else
			intCounts[idx] := intCounts[idx] + 1;
		endif;
	endforeach;
	
	foreach idx in 1 to intCounts.size do
		if strReturn = null then
			strReturn := strCodes[idx] &amp; " " &amp; intCounts[idx].String;
		else
			strReturn := strReturn &amp; ", " &amp; strCodes[idx] &amp; " " &amp; intCounts[idx].String;
		endif;
	endforeach;
	
	return strReturn;
	
epilog

	delete intCounts;
	delete strCodes;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
