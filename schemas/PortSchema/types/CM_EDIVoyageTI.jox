    <JadeMethod name="delete" id="931c03e0-4399-40b4-a88a-78cab4cd0e04">
        <updating/>
        <source>delete() updating;

/*
Date			Who		Reason
14 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
*/
	
vars
	voyageCodeStr	: String;
	
begin
	// remove this EDITrackedItem from the manual collection on myEDIConfig if it is there
	if self.myEDIConfig = null then
		return;
	endif;
	
	voyageCodeStr	:= self.getInwardCode();
	if voyageCodeStr &lt;&gt; null then
		if self.myEDIConfig.allEDITrackedItemsByVoyageCode.includesKey( voyageCodeStr.toUpper, self ) then
			self.myEDIConfig.allEDITrackedItemsByVoyageCode.removeKeyEntry( voyageCodeStr.toUpper, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="296c5a50-2771-467c-9951-d49b2c2c350b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:	16 March 2010 By Graeme Black cnwgb1
// Purpose:	PAR 23207 Add Valid Operators
// ---------------------------------------------------------------------------
vars
	str : String;
	strReturn : String;
begin
	if _attrName = ETRow_ValidOperators then
		foreach str in self.allValidOperatorCodes do
			if strReturn = null then
				strReturn := str;	
			else
				strReturn := strReturn &amp; ";" &amp; str;
			endif;
		endforeach;
		return strReturn;
	endif;
	
	return inheritMethod(_attrName, _short);
end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
