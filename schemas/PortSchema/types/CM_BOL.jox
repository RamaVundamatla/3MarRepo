    <JadeMethod name="getTotalCargoItems" id="a89c7797-b41a-48bf-a913-dfaaac244359">
        <source>getTotalCargoItems() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2014	cnwmc5	Initial creation	PAR 34185

*/

vars
	ti 		: CM_TrackedItem;
	
	total 	: Integer;
	
begin
	total := 0;

	foreach ti in self.allTrackedItems do
