    <JadeMethod name="isSameCriteria" id="a3ef715a-137f-4b55-92a6-63cf63dd0cb6">
        <source>isSameCriteria(_compareData: SelfType): Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	15 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	idx,
	val			: Integer;
begin
	if self.allValues.size &lt;&gt; _compareData.allValues.size then
		return false;
	endif;
	foreach val in self.allValues do
		idx := idx + 1;
		if _compareData.allValues[idx] &lt;&gt; val then
			return false;
		endif;
	endforeach;
	
	return true;

end;


</source>
        <Parameter name="_compareData" type="SelfType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValueUsed" id="424e92fd-a05e-4be4-aa3d-92a0b637027d">
        <source>isValueUsed(pAllValues: Any): Boolean;
// --------------------------------------------------------------------------------
// Created:		13 June 2005 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	paramValue	: Integer;
	
begin
	foreach paramValue in pAllValues.IntegerArray do
		if self.allValues.includes(paramValue) then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="pAllValues" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="3f8d1b89-279e-4e6a-a438-9ddc86bec9bc">
