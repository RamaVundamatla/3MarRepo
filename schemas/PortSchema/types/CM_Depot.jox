    <JadeMethod name="getDisplayStringForAttribute" id="c002b4e5-d254-4934-a2e7-078e9306147a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     15 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	cnt : Integer;
begin
	if _attrName = ETRow_NumItemsStr then
		return self.getNumTIs(REAL_MODE).String; //rs oct 2005 par 10886
	elseif _attrName = ETRow_NumTIs then
		return self.getNumTIs(REAL_MODE).String; //rs oct 2005 par 10886
	elseif _attrName =  ETRow_Height then
		return self.height.asStringJMT;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
