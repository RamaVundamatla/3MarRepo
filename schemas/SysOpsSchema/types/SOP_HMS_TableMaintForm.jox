    <JadeMethod name="getSelected" id="1953830e-365b-4eb6-aa80-a4ed4cbd8381">
        <source>getSelected(_collectionObj : Collection input);
/*
----------   ----------  --------------------------------------------------
Created:	30 October 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tableObj		: Table;
	cellText		: String;
	rowPointer		: Integer;
	maxRow			: Integer;
	selectedObj		: Object;
	
begin
	tableObj	:=	self.tblRoute;
	maxRow		:=	tableObj.rows;
	
	foreach rowPointer in 1 to maxRow do
		cellText	:=	tableObj.accessCell(rowPointer, 1).text;
		if cellText = null then
			continue;
		endif;
		selectedObj	:=	tableObj.accessRow(rowPointer).itemObject;
		
		if cellText = null or selectedObj &lt;&gt; null then
			_collectionObj.add(selectedObj);
		endif;
	endforeach;
end;</source>
        <Parameter name="_collectionObj" type="Collection" usage="input"/>
    </JadeMethod>
