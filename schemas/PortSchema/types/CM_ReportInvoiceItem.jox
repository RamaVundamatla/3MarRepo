    <JadeMethod name="getXMLSubline" id="21d7c777-7a65-4d0b-bce5-f3c2acd7e338">
        <source>getXMLSubline() : String;
// 28218 CCMS 2120 Oct 2011 electronic invoicing, method used in report writer
vars
	result	: String;
begin

	if self.equipmentIdentifier &lt;&gt; null then
		result := '&lt;equipment&gt;' &amp; CrLf &amp;
				'&lt;equipmenttype&gt;' &amp; self.equipmentType &amp; '&lt;/equipmenttype&gt;' &amp; CrLf &amp;
				'&lt;equipmentidentifier&gt;' &amp; self.equipmentIdentifier.xmlReplaceReservedChars(true) &amp; '&lt;/equipmentidentifier&gt;' &amp; CrLf &amp;
				'&lt;quantity&gt;' &amp; self.quantity.String &amp; '&lt;/quantity&gt;' &amp; CrLf &amp;
				'&lt;/equipment&gt;' &amp; CrLf;
	endif;
	result := result &amp; '&lt;eventdate&gt;' &amp; CrLf &amp;
			  '&lt;dateidentifier&gt;' &amp; self.endIdentifier &amp; '&lt;/dateidentifier&gt;' &amp; CrLf &amp;
			  '&lt;datevalue&gt;' &amp; self.endDate &amp; '&lt;/datevalue&gt;' &amp; CrLf &amp;
			  '&lt;/eventdate&gt;';
	result.encodeUTF8();
	return result;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
