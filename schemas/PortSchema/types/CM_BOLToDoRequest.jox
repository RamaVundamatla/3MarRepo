<Class name="CM_BOLToDoRequest" id="bf9890ae-87b9-4032-a0c7-8aeff109e8d1">
    <superclass name="CM_ToDoRequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="operatn"/>
    <ImplicitInverseRef name="myBOL" id="fff347e3-5a06-49c1-b0e9-b48ef2c1755a">
        <embedded/>
        <type name="CM_BOL"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="erase" id="560c3acc-a73b-4d5c-acb7-baecd00a5355">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

vars

begin
	exclusiveLock(self);
	self.myBOL := null;
	
	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="d916cec6-1af9-4f68-ba91-8bbfa73c7da0">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	block : CM_DataContainerBlock;

	str : String;
	ticket : CM_TicketSequence;
begin

	inheritMethod(_dataContainer);
	
	if self.myBOL &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_BOL_GC), DC_Label, 1, null);
		block.addNewItem(self.myBOL.number, DC_Data, 1, null);
	else
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_BOL_GC), DC_Label, 1, null);
		block.addNewItem(app.getErrorString(Unknown), DC_Data, 1, null);
	endif;

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Number_Of_Pieces), DC_Label, 1, null);
	block.addNewItem(self.myBOL.numItems.String, DC_Data, 1, null);

	if self.myBOL.myPlannedLocation &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Target_Location), DC_Label, 1, null);
		block.addNewItem(self.myBOL.myPlannedLocation.getID, DC_Data, 1, null);
	endif;


end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="390781f5-39db-441d-a053-b5fddf9e1298">
        <updating/>
        <source>setForCreate(pProxyRequest: CM_BOLToDoRequest) updating;
// ---------------------------------------------------------------------------
// Created:     08 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(pProxyRequest);
	
	self.myBOL	:= pProxyRequest.myBOL;

end;</source>
        <Parameter name="pProxyRequest" type="CM_BOLToDoRequest"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="943bf885-0ef0-4556-9eaa-d3d5408ea306">
        <updating/>
        <source>setProxy(_bol : CM_BOL; _requestType : CM_ToDoRequestType; _userCode : String; _job : CM_Job) updating;
// ---------------------------------------------------------------------------
// Created:     08 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.setProxyForToDoRequest(_requestType, _userCode, _job);
	
	self.myBOL := _bol;

end;</source>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_requestType" type="CM_ToDoRequestType"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
</Class>
