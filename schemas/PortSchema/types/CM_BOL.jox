    <JadeMethod name="setMatchTime" id="0866fec4-4cf9-416b-a946-7a36eeebf7a8">
        <updating/>
        <source>setMatchTime(_matchTime : TimeStamp) updating;
//--------------------------------------------------------------
//Created: 24 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars

	ti : CM_TrackedItem;

begin

	exclusiveLock(self);
	
	//15 Jan 2014	NDL	Par 33264
	if self.matchTime &lt;&gt; _matchTime and not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		foreach ti in self.allTrackedItems do
			self.updateObjectEdition( ti );
		endforeach;
	endif;

	self.matchTime := _matchTime;
	//CNWTH2 - 04/07/2003 now we have snappy BOLs by TypeDT dict, this
	//potentially makes it a BOLs by TypeMatchTime dict - which is what Northport want.
	if _matchTime.isValid and self.dateTime &lt;&gt; _matchTime then
		self.dateTime := _matchTime;
	endif;

end;</source>
        <Parameter name="_matchTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setMyExtension" id="7c0c1a8d-c0a0-4911-b40a-b10a336c08bc">
        <updating/>
        <source>setMyExtension() updating, protected;
//--------------------------------------------------------------
//Created: 14 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	extClass	: Class;
	ti : CM_TrackedItem;
begin

	exclusiveLock(self);

	extClass := self.getExtensionClass();
	if self.myExtension &lt;&gt; null then
		if extClass = null or extClass &lt;&gt; self.myExtension.class then
			self.myExtension.erase(NORMAL_ERASE);
		endif;
	endif;
	
	if extClass &lt;&gt; null and self.myExtension = null then
		if self.isTransient then
			create self.myExtension as extClass transient;
		else
			create self.myExtension as extClass persistent;
		endif;
	endif;
	
	if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		//15 Jan 2014	NDL	Par 33264
		foreach ti in self.allTrackedItems do
			self.updateObjectEdition( ti );
		endforeach;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyJobReceive" id="5bf3a203-3bb7-4209-b569-c7cb736e476c">
        <updating/>
