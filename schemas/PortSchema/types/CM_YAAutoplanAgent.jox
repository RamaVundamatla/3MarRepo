/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 December 2008	cnwer1	Initial creation  Par 18614

*/

vars

begin
	self.hadError := false;
	self.numberOfLocationsFound := 0;
	self.numControllers := 0;
	self.myCurrentAllocation := null;
	
	self.setYAAutoPlan(null);
	self.setCurrentYAAutoPlan(null);
	
	if global.isValidObject(self.myLinkedYAAutoPlan) then
		delete self.myLinkedYAAutoPlan;
	endif;
	self.myLinkedYAAutoPlan:=null;

epilog

end;</source>
