    <JadeMethod name="addGCRackOrGround" id="d891656b-e89e-42eb-a9f3-1e5b47ff3622">
        <source>addGCRackOrGround(realGeneralCargoArea : CM_IrregularBlockArea input; _x1, _y1, _x2, _y2 : Integer; _id : String) : CM_IrregularBlockController;

/*

Purpose:		Add a General Cargo Area

Date			Who		Reason
06/12/2011		cnwmh5	Initial creation

*/

vars
	locationProxy,blockLocation 				: CM_IrregularBlockController;
	region 						: PointArray;
	topLeft,
	bottomRight					: Point;
	
	locationType				: Integer;
	capacity					: Integer;
	maxWeight					: Real;
	colour						: Integer;
	
begin
	
	create region transient;
	create locationProxy transient;
	topLeft.set(_x1,_y1);
	region.add(topLeft);
	bottomRight.set(_x2,_y2);
	region.add(bottomRight);
	
	locationType := GC_RackLocation;						// 17/11/2015 cnwmh5
	if self.opts.includesKey("LocationType") then
		locationType := self.opts.int("LocationType");
	endif;
	capacity := self.opts.int("Capacity");
	maxWeight := self.opts.real("MaxWeight");
	colour := self.opts.int("Colour");
	
	locationProxy.setProxy(realGeneralCargoArea, _id, region,
									colour, 			//0,	//_colour : Integer;
									capacity, 		//0,	//_defaultCapacity : Integer;
									locationType, 		// GC_RackLocation,	//_locationType : Integer;			
									maxWeight, 		//0,	//_maximumWeight : Real;
									null	//_myICArea : CM_InterchangeArea
									);
	

	beginTransaction;
		// location added
		create blockLocation;
		blockLocation.setForCreate(locationProxy.CM_IrregularBlockController, realGeneralCargoArea);
	commitTransaction;
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	return blockLocation;

epilog
delete locationProxy;
	delete region;
end;</source>
        <Parameter name="realGeneralCargoArea" type="CM_IrregularBlockArea" usage="input"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_IrregularBlockController"/>
    </JadeMethod>
    <JadeMethod name="addGCShelf" id="b36d2463-ed45-4715-a06d-aeb3e5e12057">
        <source>addGCShelf(_rack : CM_IrregularBlockController; _index : Integer; _shelfId : String; _defaultCapacity : Integer; _maxWeight : Real; _ica : CM_InterchangeArea) : CM_RackShelfController;
/*
Purpose:			
Date		Who		Reason
20 September 2013	cnwab1	Initial creation
*/

vars

	lastCurrentSub : CM_RackShelfController;
	shelfProxy : CM_RackShelfController;
	newIndex : Integer;
	msg : String;
	realShelf : CM_RackShelfController;
begin

	
	create shelfProxy transient;
	shelfProxy.setDefaultProxy( _index, _rack, null );

	shelfProxy.setProxy(	null,	//blockAreaProxy : CM_IrregularBlockArea;
					_shelfId,	//id: String;
					shelfProxy.region,	//region: PointArray;
					Blue,	//_colour : Integer;
					_defaultCapacity,	//_defaultCapacity : Integer;
					GC_ShelfLocation,	//_locationType : Integer;
					_maxWeight,	//_maximumWeight : Real;
					_ica	//_myICArea : CM_InterchangeArea
					);
	beginTransaction;
		create realShelf as CM_RackShelfController persistent;
		realShelf.setForCreate( shelfProxy, null );
		realShelf.setMyLocation(_rack);
		realShelf.setForUpdateICA(_ica);
	commitTransaction;
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	return realShelf;
epilog
	delete shelfProxy;
end;</source>
        <Parameter name="_rack" type="CM_IrregularBlockController"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_shelfId" type="String"/>
        <Parameter name="_defaultCapacity" type="Integer"/>
        <Parameter name="_maxWeight" type="Real"/>
        <Parameter name="_ica" type="CM_InterchangeArea"/>
        <ReturnType type="CM_RackShelfController"/>
    </JadeMethod>
    <JadeMethod name="addGCStructureDefn" id="82e4ff57-e9cc-4e33-8495-982c85caa752">
        <source>addGCStructureDefn(_gcVessel: CM_Vessel input):CM_GeneralCargoVesselStructure;
/*
Purpose:			
Date				Who			Reason
JANUARY 2014		CNWAB1		Initial creation
*/


vars
	

	gcStructureDefn : CM_GeneralCargoVesselStructure;

begin

	self.assertTrueMsg(_gcVessel &lt;&gt; null, "Vessel is null!");
	
	app.myTrxCA.trxCreateVesselGCStructure(_gcVessel, gcStructureDefn, app.myPassport);
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "GC Structure not created : " &amp; app.myPassport.getAllErrorsAndWarningsAsStr );
	
	return gcStructureDefn;
	
epilog

	

end;</source>
