    <JadeMethod name="doCriteriaValueAdd" id="5b71968b-8254-461b-bd33-cf74ec6d0bea">
        <source>doCriteriaValueAdd(pProxyYAObj:CM_YardAllocation; pControlObj:CMUI_YACriteriaValue; pItemCode:String) protected;
// --------------------------------------------------------------------------------
// Created:		08 May 2008 by cnwdad1
//
// Purpose:		Adds the selected Criteria to the Criteria table.
//
// Parameters:	pProxyYAObj - A reference to the proxy Yard Allocation object.
//				pControlObj - A reference to the YA Criteria Value control.
//				pItemCode - A code for the currentl selection.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allValuesObj		: ObjectSet;
	itemCode			: String;
	criteriaObj			: CM_YACriteriaPriority;	// This will be deleted by the CMIF object's destructor.
	transientObj		: CMIF_YACriteriaPriority;
	criteriaTypeObj		: CM_YACriteriaType;
	allDataValues		: IntegerArray;
	booleanValue		: Integer;
	transportMode		: Integer;
	critValueObj		: Object;
	codeLength			: Integer;
	
begin
	criteriaTypeObj	:=	pControlObj.myCriteriaType;
	
	if criteriaTypeObj = null then
		return;
	endif;
	
	// Truncate any of the YA Code that exceeds the maximum length of the Criteria Code.
	
	itemCode	:=	pItemCode;
	codeLength	:=	CM_YACriteriaPriority.cnEcGetStringPropertyLength(CM_YACriteriaPriority::code.name);
	
	if codeLength &gt; 1 and itemCode.length() &gt; codeLength then
		itemCode	:=	itemCode[1:codeLength];
	endif;
	
	// Create the proxy Criteria object, and the associated CMIF object,
	// then fetch the appropriate data for the YA Criteria.
	
	if criteriaTypeObj.isBooleanType() then
		if pControlObj.listIndex = CNEC_NULL_INDEX then
			return;
		else
			booleanValue	:=	pControlObj.getBooleanValue();
			
			if booleanValue = 0 then
				return;
			endif;
		endif;
		
		create criteriaObj as CM_YACriteria transient;
		
		criteriaObj.setProxy(criteriaTypeObj, booleanValue, itemCode);
		
	elseif criteriaTypeObj.isTransportModeType() then
		if pControlObj.listIndex = CNEC_NULL_INDEX then
			return;
		else
			transportMode	:=	pControlObj.getTransportModeValue();
			
			if transportMode = 0 then
				return;
			endif;
		endif;
		
		create criteriaObj as CM_YACriteria transient;
		create allDataValues transient;
		allDataValues.add(transportMode);
		
		criteriaObj.setProxy(criteriaTypeObj, allDataValues, itemCode);
		
	else
		create allValuesObj transient;
		critValueObj	:=	pControlObj.getCriteriaValue();
		
		if critValueObj = null then
			return;
		else
			allValuesObj.add(critValueObj);
		endif;
		
		create criteriaObj as CM_YACriteria transient;
		criteriaObj.setProxy(criteriaTypeObj, allValuesObj, itemCode);
	endif;
	
	criteriaObj.CM_YACriteria.setYardAllocation(pProxyYAObj);
	transientObj	:=	criteriaObj.getTransient();
	transientObj.setFlag(true, false, false);
	self.aAllSelectedCriteria.add(transientObj);
epilog
	delete allValuesObj;
	delete allDataValues;
end;</source>
        <access>protected</access>
        <Parameter name="pProxyYAObj" type="CM_YardAllocation"/>
        <Parameter name="pControlObj" type="CMUI_YACriteriaValue"/>
        <Parameter name="pItemCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="32623300-eca1-4f3c-ba30-41c84b9c74a7">
        <updating/>
        <source>doSave():Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 May 2008 by cnwdad1
//
// Purpose:		This is the standard form update method.
//
// Parameters:	None
//
// Returns:		True if the update was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// adm 270509 Par 19483 myTerminal
// 02/07/2014	cnwdap1		PAR #34488 Set up proxy allocation before calling doParseLocationString
//							as parsing code now depends on having a terminal on the allocation
vars
	terminalObj		: CM_Terminal;
	allocationObj	: CM_YardAllocation;		// Returned as a transaction parameter.
	proxyYAObj		: CM_YardAllocation;
	allCriteriaObj	: CMIF_Array;
	criteriaCode	: String;
	criteriaDesc	: String;
	location		: String;
	colour			: Integer;
	allBlocksInObj	: CM_YABlockArray;			// PAR #34488
	allBlocksOutObj	: CM_YABlockArray;			// PAR #34488
	
begin
	// Validate the user's inputs/selections.
	
	if not self.validateForm() then
		return false;
	endif;
	
	// Set up the proxy Yard Allocation object.
	
	terminalObj	:=	self.myTerminal();
	
	create proxyYAObj transient;
	create allBlocksInObj transient;			// PAR #34488
	create allBlocksOutObj transient;			// PAR #34488
	
	criteriaCode	:=	txtCode.cnEcString();
	location		:=	txtLocation.cnEcString();
	colour			:=	self.getProductColour();
	self.aAllBlockGroupsIn.purge();
	self.aAllBlockGroupsOut.purge();
	self.aAllSelectedCriteria.purge();
	
	// Gather the YA Criteria data selected by the User.
	
	if cmbCriteria1.visible and cmbCriteria1.listIndex &lt;&gt; CNEC_NULL_INDEX then
		self.doCriteriaValueAdd(proxyYAObj, cmbCriteria1, criteriaCode);
	endif;
	
	if cmbCriteria2.visible and cmbCriteria2.listIndex &lt;&gt; CNEC_NULL_INDEX then
		self.doCriteriaValueAdd(proxyYAObj, cmbCriteria2, criteriaCode);
	endif;
	
	if cmbCriteria3.visible and cmbCriteria3.listIndex &lt;&gt; CNEC_NULL_INDEX then
		self.doCriteriaValueAdd(proxyYAObj, cmbCriteria3, criteriaCode);
	endif;
	
	if cmbCriteria4.visible and cmbCriteria4.listIndex &lt;&gt; CNEC_NULL_INDEX then
		self.doCriteriaValueAdd(proxyYAObj, cmbCriteria4, criteriaCode);
	endif;
	
	create allCriteriaObj transient;
	self.aAllSelectedCriteria.copy(allCriteriaObj);
	
	// Parse the location string entered by the user to get a list of Yard Blocks.											// PAR #34488
	//if not self.doParseLocationString(location, true, proxyYAObj, self.aAllBlockGroupsIn, self.aAllBlockGroupsOut) then	// PAR #34488
	//	return false;																										// PAR #34488
	//endif;																												// PAR #34488
	
	// Update the proxy Yard Allocation object with the relevant data.
	
	criteriaDesc	:=	self.getDescription();
	
	proxyYAObj.setProxy(criteriaCode,
						criteriaDesc,
						null,
						YAFillOption_InOrder,
						YAFillOption_FIFO,
						YAExpiryType_WhenEmpty, //22/05/2009 cnwdz2 ccms1801 changed from YAExpiryType_Never to YAExpiryType_WhenEmpty
						null,
						colour,
						null,  //cnwjo3 par 24145
						YAOverlap_Always,
						YANoLocation_Continue,
						null,
						0,
						false,
						false,
						self.aAllBlockGroupsIn,
						self.aAllBlockGroupsOut,
						true,
						terminalObj);
	if self.aAllBlockGroupsIn.isEmpty then										// PAR #34488
		proxyYAObj.setProxyGroupBlocks(allBlocksInObj, allBlocksOutObj);		// PAR #34488
	endif;																		// PAR #34488
	
	// Parse the location string entered by the user to get a list of Yard Blocks.
	if not self.doParseLocationString(location, true, proxyYAObj, self.aAllBlockGroupsIn, self.aAllBlockGroupsOut) then		// PAR #34488
		return false;																										// PAR #34488
	endif;																													// PAR #34488
	proxyYAObj.setGroupBlocks(self.aAllBlockGroupsIn, self.aAllBlockGroupsOut);												// PAR #34488
	
	// Finally, create the Yard Allocation for real.
	
	app.myTrxCA.trxCreateYardAllocation(proxyYAObj, allCriteriaObj, allocationObj, app.myPassport);
	
	if app.myPassport.trxCompletedOK() then
		return true;
	else
		self.checkAndShowErrors();
		return false;
	endif;
epilog
	self.aAllBlockGroupsIn.purge();
	self.aAllBlockGroupsOut.purge();
	self.aAllSelectedCriteria.purge();
	delete proxyYAObj;
	delete allCriteriaObj;
	delete allBlocksInObj;						// PAR #34488
	delete allBlocksOutObj;						// PAR #34488
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSpaceControls" id="c1d81475-d8f5-497b-af23-9667f2a4848a">
        <source>doSpaceControls() protected;
// --------------------------------------------------------------------------------
// Created:		05 May 2008 by cnwdad1
//
// Purpose:		Vertically spaces out the receiver's input controls evenly down the
//				form.
//
// NOTE: The dynamic Criteria controls MUST have already been set up prior to calling
// this method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	SEPARATION	: Real = 10;
	
vars
	typeCount	: Integer;
	topPos		: Real;
	nextPos		: Real;
	labelHeight	: Real;
	
begin
	typeCount	:=	self.aAllCriteriaTypes.size();
	
	// Get pre-determined vertical co-ordinates based upon the number of dynamic Criteria
	// controls that are being used.
	
	if typeCount = 4 then
		topPos	:=	70;
	elseif typeCount = 3 then
		topPos	:=	94;
	elseif typeCount = 2 then
		topPos	:=	112;
	elseif typeCount = 1 then
		topPos	:=	133;
	else
		topPos	:=	155;
//	else
//		topPos	:=	181;
	endif;
	
	// Now space out the label controls vertically.
	
	nextPos			:=	topPos;
	labelHeight		:=	lblCode.height;
	lblLocation.top	:=	nextPos;
	
	nextPos			:=	nextPos + labelHeight + SEPARATION;
	lblCode.top		:=	nextPos;
	
	if lblLabel1.visible then
		nextPos			:=	nextPos + labelHeight + SEPARATION;
		lblLabel1.top	:=	nextPos;
	endif;
	
	if lblLabel2.visible then
		nextPos			:=	nextPos + labelHeight + SEPARATION;
		lblLabel2.top	:=	nextPos;
	endif;
	
	if lblLabel3.visible then
		nextPos			:=	nextPos + labelHeight + SEPARATION;
		lblLabel3.top	:=	nextPos;
	endif;
	
	if lblLabel4.visible then
		nextPos			:=	nextPos + labelHeight + SEPARATION;
		lblLabel4.top	:=	nextPos;
	endif;
	
	// Finally, line up the input controls with the label controls.
	
	txtLocation.top		:=	lblLocation.top;
	txtCode.top			:=	lblCode.top;
	cmbCriteria1.top	:=	lblLabel1.top;
	cmbCriteria2.top	:=	lblLabel2.top;
	cmbCriteria3.top	:=	lblLabel3.top;
	cmbCriteria4.top	:=	lblLabel4.top;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getDescription" id="819a5db2-6d67-470b-9194-cb251becc52d">
        <source>getDescription():String protected;
// --------------------------------------------------------------------------------
// Created:		13 May 2008 by cnwdad1
//
// Purpose:		Returns a description for a Yard Allocation, based upon the Criteria
//				that have been selected.
//
// Parameters:	None
//
// Returns:		A description for the Yard Allocation, or null if no Criteria are
//				selected.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cmifObj			: CMIF_Object;
	yaDescription	: String;
	criteriaObj		: CMIF_YACriteriaPriority;
	
begin
	foreach cmifObj in self.aAllSelectedCriteria do
		criteriaObj	:=	cmifObj.CMIF_YACriteriaPriority;
		
		if yaDescription = null then
			yaDescription	:=	criteriaObj.getListDisplay();
		else
			yaDescription	:=	yaDescription &amp; ", " &amp; criteriaObj.getListDisplay();
		endif;
	endforeach;

	//cnwjo3 par 22890.  If no critieria then add a 'no description' description
	if yaDescription = null then
		yaDescription := "(no description)";
	endif;
	
	return yaDescription;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProductColour" id="25f14f83-67ea-4b8f-b25e-716e4d887b71">
        <source>getProductColour():Integer protected;
// --------------------------------------------------------------------------------
// Created:		12 May 2008 by cnwdad1
//
// Purpose:		If any of the Criteria Types are handing a Product Type, and a Product
//				has been selected, then return the colour of that Product.
//
// Parameters:	None
//
// Returns:		The colour of the selected Product, otherwise zero.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if cmbCriteria1.visible and cmbCriteria1.listIndex &lt;&gt; CNEC_NULL_INDEX then
		if cmbCriteria1.isProductType then
			return cmbCriteria1.getProductColour();
		endif;
	endif;
	
	if cmbCriteria2.visible and cmbCriteria2.listIndex &lt;&gt; CNEC_NULL_INDEX then
		if cmbCriteria2.isProductType then
			return cmbCriteria2.getProductColour();
		endif;
	endif;
	
	if cmbCriteria3.visible and cmbCriteria3.listIndex &lt;&gt; CNEC_NULL_INDEX then
		if cmbCriteria3.isProductType then
			return cmbCriteria3.getProductColour();
		endif;
	endif;
	
	if cmbCriteria4.visible and cmbCriteria4.listIndex &lt;&gt; CNEC_NULL_INDEX then
		if cmbCriteria4.isProductType then
			return cmbCriteria4.getProductColour();
		endif;
	endif;
	
	return 0;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
