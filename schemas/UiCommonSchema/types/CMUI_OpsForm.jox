        <controlMethod name="Frame::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmGridArea_mouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//--------------------------------------------------------------
//Created: 19 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if button &lt;&gt; 1 then
		return;
	endif;
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
	
	
	
	self.frmGridArea := frame.CMUI_GridAreaFrame;
	if app.dragDetected(x, y, origXPos, origYPos) then
		self.gridAreaMouseMoveEvent(button, x, y);
	endif;
	
// PAR 19710	origXPos := null;
// PAR 19710	origYPos := null;		
end;</source>
