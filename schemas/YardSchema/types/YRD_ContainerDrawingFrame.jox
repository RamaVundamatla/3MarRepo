    <JadeMethod name="drawObject" id="89dd6f99-1157-4bfe-86b9-9a8f3e28248a">
        <updating/>
        <source>drawObject(_obj: Object; _drawingController: CMUI_GridDrawingController input) updating;
// ---------------------------------------------------------------------------
// Created:		09 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	x1, y1, x2, y2	: Integer;

begin
	
	if _drawingController.isKindOf(YRD_RoRoLaneDrawingController) then								// cnwjk3 PAR 22733 09/03/2010
		if self.getPointsForObject(_obj, x1, y1, x2, y2) then											// cnwjk3 PAR 22733 08/03/2010
			_drawingController.YRD_RoRoLaneDrawingController.allDrawnObjects.removeObjectFromDict(_obj);// cnwjk3 PAR 22733 08/03/2010
			self.drawRoRoObjectAt(_obj, x1, y1, x2, y2, _drawingController);							// cnwjk3 PAR 22733 08/03/2010
		endif;
	elseif _drawingController.isKindOf(YRD_GCRackDrawingController) then
		if self.getPointsForObject(_obj, x1, y1, x2, y2) then
		
			self.drawObjectAt(_obj, x1, y1, x2, y2, _drawingController);
		endif;

	else
		inheritMethod(_obj, _drawingController);
	endif;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_drawingController" type="CMUI_GridDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawObjectAt" id="e83e073a-cb1b-4028-9240-7c5f4894af91">
        <updating/>
        <source>drawObjectAt(_obj: Object; _x1: Integer; _y1: Integer; _x2: Integer; _y2: Integer; _drawingController: CMUI_GridDrawingController input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars
	tmpLC : CM_LocationsController;
	tmpCDC : YRD_ContainerDrawingController;
	x1, y1, x2, y2 : Integer;
	theTI : CM_TrackedItem;
	anFM : CM_FutureMove;
	flipped : Boolean;
begin
	if _obj = null then
		return;
	endif;
	x1 := _x1;
	x2 := _x2;
	y1 := _y1;
	y2 := _y2;
	
	tmpCDC := _drawingController.YRD_ContainerDrawingController;

	if _obj.isKindOf(CM_LocationsController) then
		tmpLC := _obj.CM_LocationsController;
	elseif _obj.isKindOf(CM_TrackedItem) then
		theTI := _obj.CM_TrackedItem;
		if tmpCDC.displayMode = DISPLAY_MODE_ACTUAL then
			tmpLC := _obj.CM_TrackedItem.myPrimaryActualLocation;
		elseif tmpCDC.displayMode = DISPLAY_MODE_PLAN then
//			tmpLC := theTI.myPrimaryPlannedLocation;
			// tranship stuff. It will be the tranship import that is planned into the yard so get its LC. 
			// We only draw tranship exports in the yard.
			// PAR #23645 CCMS 1116 Tranships are now one TI, not two
			//if not tmpLC.isKindOf(CM_GridController) 						// PAR #23645 CCMS 1116
			//and theTI.isTranshipExport() then								// PAR #23645 CCMS 1116
			//	tmpLC := theTI.myTranshipImport.myPrimaryPlannedLocation;	// PAR #23645 CCMS 1116
			//else															// PAR #23645 CCMS 1116
						// PAR 15340
				if theTI.isRehandle 
				and (not theTI.myPrimaryPlannedLocation.isGridLocation()) 
				and theTI.allPlannedFutureMoves.size = 2 then
					tmpLC := theTI.allPlannedFutureMoves.last.CM_FutureMovePlanned.allLocationsControllers.first; // LAST FM
					if tmpLC &lt;&gt; null then
						if not tmpLC.isGridLocation then
							tmpLC := theTI.allPlannedFutureMoves.first.CM_FutureMovePlanned.allLocationsControllers.first; // FIRST FM
						endif;
					endif;
				endif;
	
				if tmpLC = null then
//	PAR 19362 we now have future move objects in the grid drawing dict so this now needs to be the actual location				
//	PAR 19362				tmpLC := theTI.myPrimaryPlannedLocation;  
					tmpLC := _obj.CM_TrackedItem.myPrimaryActualLocation;
				endif;

			//endif;														// PAR #23645 CCMS 1116
		elseif tmpCDC.displayMode = DISPLAY_MODE_QUEUE then
//	PAR 19362 we now have future move objects in the grid drawing dict so this now needs to be the actual location				
//	PAR 19362		tmpLC := _obj.CM_TrackedItem.myPrimaryQueuedLocation;
			tmpLC := _obj.CM_TrackedItem.myPrimaryActualLocation;
		endif;
		self.getPointsForObject(tmpLC, x1, y1, x2, y2) ;  //could change tmpLC to _obj since YRD_ContainerDrawingController::drawCurrentObject draws TIs.. BUT
															//YRD_CargoRowDrawingController::drawCurrentObject only works on LCs!
	elseif _obj.isKindOf(CM_FutureMove) then // PAR 19600
		anFM := _obj.CM_FutureMove;
		tmpLC := anFM.getPrimaryLocation();
		self.getPointsForObject(tmpLC, x1, y1, x2, y2) ;
		
	elseif _obj.isKindOf(CM_YALocationCell) then	//24 Aug 2011	NDL	Par 28035
		self.getPointsForObject(_obj, x1, y1, x2, y2);
		if tmpCDC.allSelectedObjects.includes(_obj) then
			self.drawRectangle(x1, y1, x2, y2, Red);
		else
			self.drawRectangle(x1, y1, x2, y2, Black);
		endif;

	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled object ' &amp; _obj.String);
	endif;

	// PAR 19215 from here
	if not _drawingController.drawFromNote and theTI &lt;&gt; null then
		//cnwjo3 par 25479
		/* PAR 26858 WAS
		if tmpCDC.isKindOf(YRD_CargoRowDrawingController) and theTI.myTerminalArea &lt;&gt; null and (theTI.myTerminalArea.isKindOf(CM_RTGArea) 
																																or theTI.myTerminalArea.isKindOf(CM_ForkLiftStack)) then // PAR 27005
		NOW */
		if tmpCDC.isKindOf(YRD_CargoRowDrawingController) then
			if  tmpCDC.YRD_CargoRowDrawingController.myYardGridEnqForm &lt;&gt; null and tmpCDC.YRD_CargoRowDrawingController.myYardGridEnqForm.isAllDrawSideOn then
				tmpCDC.setForRedraw(theTI, _x1, _y1, _x2, _y2);  //set the drawing area.  If its a TI then use original x,y values
			else
				if theTI.myTerminalArea &lt;&gt; null and (theTI.myTerminalArea.isRTGArea() or theTI.myTerminalArea.isForkliftStack()) then
					tmpCDC.setForRedraw(theTI, x1, y1, x2, y2);   //set the drawing area.  When drawing EndView we only can work with LCs
				else
					tmpCDC.setForRedraw(theTI, _x1, _y1, _x2, _y2);  //set the drawing area.  If its a TI then use original x,y values
				endif;
			endif;
		else
			tmpCDC.setForRedraw(theTI, _x1, _y1, _x2, _y2);  //set the drawing area.  If its a TI then use original x,y values
		endif;
		tmpCDC.setMyCurrentObject(theTI);
		flipped := tmpCDC.flipHorizontal;
		tmpCDC.setFlip(false, tmpCDC.flipVertically);
		tmpCDC.drawCurrentObject(self);
		tmpCDC.setFlip(flipped, tmpCDC.flipVertically);
	else
		// PAR 19215 to here
		if tmpLC &lt;&gt; null 
		//and tmpLC.isKindOf(CM_GridController) then									// cnwjk3 ccms 1018 26/01/10
		and tmpLC.isKindOf(CM_GridController) or tmpLC.isKindOf(CM_RoRoController) or tmpLC.isKindOf(CM_RackShelfController) then	// cnwjk3 ccms 1018 26/01/10
			tmpCDC.setForRedraw(tmpLC,x1, y1, x2, y2);
			tmpCDC.setMyCurrentObject(tmpLC);
			tmpCDC.drawCurrentObject(self);
		endif;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_drawingController" type="CMUI_GridDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawPictureAt" id="ef4bf9a1-8dda-4933-a8c2-9ff3d074160b">
        <executionLocation>client</executionLocation>
        <source>drawPictureAt(_pict: Binary; _x: Real; _y: Real) clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
26 November 2008	consw1	Initial creation

*/

vars

begin
	if self.swapXY then
		inheritMethod(_pict, _y + self.swapYadjustment, _x + self.swapXadjustment);
	else
		inheritMethod(_pict, _x, _y);
	endif;

epilog

end;</source>
        <Parameter name="_pict" type="Binary"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
