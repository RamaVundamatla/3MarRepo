begin
	voy := _voyage;

	aPort := app.myRoot.allPorts["NZAKL"];

	create strs transient;
	
	bs:= self.getTerminalArea(BlockStack).CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	deleteTerminalArea(BlockStack);
	bs:= addBlockStack(BlockStack, 100, null);

	// ### 20 GENERALS
	self.deleteContainer("GENU2077441");
	//cargo := self.addContainerAtLocnDisch("GENU2077441", "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	cargo := self.addContainerAtLocation( "GENU2077441", self.myOperator, "2200", "MT", TI_IMEX_STATUS_STORAGE, bs.myLocationsController);
	
	_containers.add(cargo);
	self.deleteContainer("GENU2077442");
	cargo := self.addContainerAtLocation("GENU2077442", self.myOperator, "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
