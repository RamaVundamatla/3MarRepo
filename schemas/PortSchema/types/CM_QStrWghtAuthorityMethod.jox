    <JadeMethod name="create" id="60905156-6a9f-4e8f-a649-1420ccda0c1f">
        <updating/>
        <source>create() updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 10 October 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	queryOperator	: CM_QueryOperator;
begin

	if self.isTransient then	
		return;
	endif;

	create queryOperator as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(queryOperator);	
end;
</source>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="2940457b-4753-49d9-abd9-530b2e7c80c3">
        <source>getKeyLengthForXTABDictionary(): Integer;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 29 August 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if type = CertifyingPerson then
		return CM_WeighAuthority::certifiedName.length;
	elseif type = CertifyingAuthority then
		return CM_WeighAuthority::authorisedName.length;
	endif;
	return null;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWebDataRowName" id="ead49bd6-e51d-44c7-b7c1-4704f5a08678">
        <source>getWebDataRowName(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/08/2019	jlgdap1		Initial creation TFS 45769 JMTY Web Portal selector query parameters
//
vars

begin
	if self.type = CertifyingPerson then
		return ETRow_WeightCertAuth;
	elseif self.type = CertifyingAuthority then
		return ETRow_WeightCertPerson;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="5fed0ce2-c737-4999-9c0c-300468962a28">
        <source>setComboValues(comboBox 				: ComboBox input; 
			   queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder; 
			   queryOperator			: CM_QueryOperator; 
			   passport					: CM_Passport);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 10 October 2018
TFS#		: 40200
Function	: Populate comboBox List.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	weightAuthority		: CM_WeighAuthority;	
	selectStr			: String;
	storeIdx			: Integer;
	idx					: Integer;
	selecteWeightAuth	: CM_WeighAuthority;
begin
	comboBox.clear();	
	comboBox.sorted := true;
	
	if CM_QStringLookup.hasInstance(queryOperator) then
		selectStr := queryOperator.CM_QStringLookup.selectionValue;
	elseif CM_QStringLookupNotEqual.hasInstance(queryOperator) then
		selectStr := queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;

	foreach weightAuthority in CM_WeighAuthority.instances do
		if type = CertifyingPerson then
			idx := comboBox.addItem(weightAuthority.certifiedName);
		elseif type = CertifyingAuthority then
			idx := comboBox.addItem(weightAuthority.authorisedName);
		endif;
		
		comboBox.itemObject[idx] := weightAuthority;
		if type = CertifyingPerson then			
			if weightAuthority.certifiedName = selectStr then
				selecteWeightAuth := weightAuthority;
			endif;		
		elseif type = CertifyingAuthority then
			if weightAuthority.authorisedName = selectStr then
				selecteWeightAuth := weightAuthority;
			endif;		
		endif;
	endforeach;
	
	storeIdx := comboBox.findObject(selecteWeightAuth);
	
	if storeIdx &gt; 0 and storeIdx &lt; comboBox.listCount then
		comboBox.listIndex := storeIdx;
	endif;

end;</source>
        <Parameter name="comboBox" type="ComboBox" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="439f3a0b-2595-4c08-9bf3-481e9a03e123">
        <source>setListValues(table						: Table input; 
			  queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder;
			  queryOperator				: CM_QueryOperator; 
			  passport					: CM_Passport);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 10 October 2018
TFS#		: 40200
Function	: Populate Selection List.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	weightAuthority	: CM_WeighAuthority;
	selectionValue	: Integer;
	idx				: Integer;
	array			: ObjectArray;
begin
	
	table.rows := table.fixedRows;
	table.sortColumn[1] := 2;
	table.sortAsc[1] := true;
	
	array := table.getPropertyValue('allSelectedObjects').ObjectArray;
	array.clear;
	
	foreach weightAuthority in CM_WeighAuthority.instances do	
		selectionValue := 0;
		if type = CertifyingPerson then		
			if queryOperator &lt;&gt; null and  queryOperator.CM_QStringIsOneOf.allSelectionValues.includes(weightAuthority.certifiedName) then
				selectionValue := 1;
				array.add(weightAuthority);
			endif;
		
			idx := table.addItem(selectionValue.String &amp; Tab  &amp; weightAuthority.certifiedName);
		elseif type = CertifyingAuthority then
			if queryOperator &lt;&gt; null and  queryOperator.CM_QStringIsOneOf.allSelectionValues.includes(weightAuthority.authorisedName) then
				selectionValue := 1;
				array.add(weightAuthority);
			endif;
		
			idx := table.addItem(selectionValue.String &amp; Tab  &amp; weightAuthority.authorisedName);
		endif;
		table.accessRow(idx).itemObject := weightAuthority;
	endforeach;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="767864b2-5b8d-4155-962b-4932978938f8">
        <source>setValuesFromList(table: Table input; queryOperator: CM_QueryOperator input);

/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 10 October 2018
TFS#		: 40200

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	weightAuthority	: CM_WeighAuthority;
	str				: String;
	numRows			: Integer;
	idx				: Integer;
	strArray		: StringArray;

begin

	create strArray transient;
	
	numRows := table.rows;
	foreach idx in (table.fixedRows + 1) to numRows do
		str := table.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			weightAuthority := table.accessRow(idx).itemObject.CM_WeighAuthority;
			if type = CertifyingPerson then
				strArray.add(weightAuthority.certifiedName);
			elseif type = CertifyingAuthority then
				strArray.add(weightAuthority.authorisedName);
			endif;
		endif;
	endforeach;
	
	queryOperator.setSearchValue(strArray);

epilog
	delete strArray;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryOperator" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="78ea2b8a-b6b2-4c61-af06-3adc2ac00bda">
        <source>translateToDisplayValue(_value: Any): String;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 10 October 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if _value.isKindOf(CM_WeighAuthority) then
		if _value &lt;&gt; null then
			if type = CertifyingPerson then
				return _value.CM_WeighAuthority.certifiedName;
			elseif type = CertifyingAuthority then
				return _value.CM_WeighAuthority.authorisedName;
			endif;
		else 
			return null;
		endif;
	else
		return _value.String;
	endif;
	
	return null;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="2e2545ec-cde3-4924-9d91-46584e301f39">
        <source>translateToSearchValue(value : Any) : Any;

/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 10 October 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	invalidObj 		: Boolean;
	weightAuthority	: CM_WeighAuthority;
	returnVal		: String;
	
begin
	if value &lt;&gt; null then
		if value.isKindOf(Collection) then			
			return value;
		endif;

		if value.isKindOf(CM_WeighAuthority) then
			weightAuthority := value.CM_WeighAuthority;
		endif;
	endif;
	
	if weightAuthority &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, weightAuthority, invalidObj);
		if type = CertifyingPerson then
			returnVal := weightAuthority.certifiedName;
		elseif type = CertifyingAuthority then
			returnVal := weightAuthority.authorisedName;
		endif;
	endif;
	
	return returnVal;	
end;
</source>
        <Parameter name="value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="1706ed18-be28-4187-a67c-7b6209b7ce58">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Poral selector query parameters
//
vars
	str, result : String;
	wa, weightAuthority : CM_WeighAuthority;
	strArray : StringArray;
	invalidObj : Boolean;

begin
	if _value.isKindOf(CM_WeighAuthority) then
		if self.type = self.CertifyingPerson then
			return _value.CM_WeighAuthority.authorisedName;
		elseif self.type = self.CertifyingAuthority then
			return _value.CM_WeighAuthority.certifiedName;
		endif;
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			str := _value.String;
			create strArray transient;
			str.getTokensForDelimiter("|", strArray);
			return strArray;
		endif;
		
		foreach wa in app.myRoot.allWeighAuthorities discreteLock do
			if (self.type = self.CertifyingAuthority and wa.authorisedName = _value.String)
			or (self.type = self.CertifyingPerson and wa.certifiedName = _value.String) then
				weightAuthority := wa;
				break;
			endif;
		endforeach;
		if weightAuthority &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, weightAuthority, invalidObj);
			if type = CertifyingPerson then
				return weightAuthority.certifiedName;
			elseif type = CertifyingAuthority then
				return weightAuthority.authorisedName;
			endif;
		endif;
		
	elseif _value.isKindOf(StringArray) then
		foreach str in _value.StringArray do
			result := result &amp; str &amp; CNEC_COMMA &amp; Space;
		endforeach;
		result := result[1:result.length-2];
		return result;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
