    <JadeMethod name="moveTrackedItem" id="ca439555-76c8-4b9c-8c6e-a4ac63783870">
        <source>moveTrackedItem(_ti : CM_TrackedItem; tbl : CM_DataTable) protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 24 July 2007
//
//----------------------------------------------------------------------

vars
	obj				: Object;
	moveController	: CMIF_MoveController;
	toLocation : CM_LocationsController;
begin

	create moveController transient;
	delete app.myMoveController;
	moveController.setMyTrackedItem(_ti);
	//foreach obj in tbl.allSelectedObjects do
	//	if obj &lt;&gt; _ti then
	//		moveController.allOtherTrackedItems.add(obj.CM_TrackedItem);
	//	endif;
	//endforeach;
	app.myMoveController := moveController;

	moveController.isRehandleMove := _ti.isRehandle;
	moveController.setMoveMode(self.moveModeForm);	
	
/*	if moveController.isRehandleMove
	and moveController.moveMode = PLANNING_MODE
	and self.filterTerminalArea &lt;&gt; null then
		// If it's a blockstack or depot then a single controller will be returned.
		toLocation := self.filterTerminalArea.getLocationsController();
		if toLocation = null then
			// may be a grid area then
			toLocation := self.filterYardLocation;
			moveController.setMyOriginatingLocation(toLocation);
		endif;
	endif;
	*/

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="tbl" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="requestsAreComplete" id="a03a0a0a-6db8-4262-a587-73f4a757b7bd">
        <updating/>
        <source>requestsAreComplete() : Boolean updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 25 June 2007
//
//
//----------------------------------------------------------------------

vars
	wle : CM_WorkListEntry;
begin
	foreach wle in self.myJob.workListEntries discreteLock where wle.myTrackedItem = null do
		return false;
	endforeach;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMoveController" id="3bffd87b-9a85-42bf-a240-2f0d60f6cedd">
        <updating/>
        <source>setMoveController(_ti : CM_TrackedItem) updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 19 June 2007
//
//----------------------------------------------------------------------

vars
	moveController : CMIF_MoveController;
	origLocn : CM_LocationsController;
begin
	create moveController transient;	
	app.myMoveController := moveController;
	moveController.setMoveMode(self.moveModeForm);			
	moveController.setMyTrackedItem(_ti);
	origLocn := _ti.getPrimaryLocation(REAL_MODE);	
	if origLocn &lt;&gt; null then
		moveController.setEffectiveTimeStampOverride(origLocn.getEffectiveTimeStamp());
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setTblDataDetailCellText" id="32db0930-3f83-47cd-afe0-a03e0c339787">
        <updating/>
        <source>setTblDataDetailCellText(_tbl : CM_DataTable input) updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 25 June 2007
//
//----------------------------------------------------------------------

vars
	cntrl : Control;
	table : CM_DataTable;
begin
	table := _tbl;
	
	if (not table.userInputEnabled)
	or table.row &lt;= table.fixedRows then
		return;
	endif;
	
	if table.accessCell(table.row, table.column).enabled then
		cntrl := table.accessedCell.cellControl;
		if ComboBox.hasInstance(cntrl) then
			table.accessedCell.text := cntrl.ComboBox.text;
		endif;
	endif;
		
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTblWorkEntryCols" id="b4774582-6b3a-482b-8db3-a4a581f368f5">
        <updating/>
        <source>setTblWorkEntryCols() protected, updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 05 June 2007
//
//----------------------------------------------------------------------

vars

begin
	//Receivals Table
	self.locationColumn := self.tblReceivals.getColumnByRowName(ETRow_TargetLocation);
	self.cargoTypeColumn := self.tblReceivals.getColumnByRowName(ETRow_CargoTypeDescr);	
	//Release Table
	self.cargoIdColumnRelease := self.tblReleases.getColumnByRowName(ETRow_Id);
	self.cargoTypeColumnReleaseTable := self.tblReleases.getColumnByRowName(ETRow_CargoTypeDescr);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c487e76b-9b76-4e22-9796-f95e21132f18">
