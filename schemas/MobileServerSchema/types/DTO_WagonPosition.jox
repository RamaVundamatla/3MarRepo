<Class name="DTO_WagonPosition" id="127170ab-c9cd-496b-b5d9-9062ae38b3cc">
    <superclass name="DTO_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="mobileServer"/>
    <PrimAttribute name="idx" id="64762e29-a390-4f1d-b893-d13693c26594">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="isBackEnd" id="886546ef-7b5f-44bb-8c5e-ea3ba33a5ae6">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myButton" id="23d018af-fab1-4509-b4f1-a50ae12f0214">
        <embedded/>
        <virtual/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myDTOContainer" id="c3fc0d25-5872-48f6-8d4e-38fc216a0d77">
        <embedded/>
        <type name="DTO_ContainerInfo"/>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myDTOWagon" id="c145f8b0-a81f-40e4-abd0-9b40c89dc769">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="DTO_Wagon"/>
        <Inverse name="DTO_Wagon::allDTOWagonPositions"/>
    </ExplicitInverseRef>
    <PrimAttribute name="position" id="00c7dbf5-8fee-4ec4-84de-9b04901ae59d">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="stackHeight" id="a969d4b9-d720-4a07-a0f8-8976e9692529">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="canBeEdited" id="206130dc-a5ca-43ba-8c9c-26631c9f1cf3">
        <source>canBeEdited() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2009	cnwer1	Initial creation

*/

vars
	wagonPositionUnder : DTO_WagonPosition;
begin
	if self.stackHeight = 1 then
		return true;
	endif;
	
	wagonPositionUnder:=self.myDTOWagon.allDTOWagonPositions[self.idx,self.stackHeight-1];
	return  wagonPositionUnder.hasProxyContainer;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="ecdbefdb-2f9e-4415-b9c3-81d3850b4d86">
        <updating/>
        <source>delete() updating;
/*
----------   ----------  --------------------------------------------------
Created:	27 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	delete self.myDTOContainer;

end;


</source>
    </JadeMethod>
    <JadeMethod name="hasProxyContainer" id="c56642aa-2591-46f4-b08d-96ed31d23ad9">
        <source>hasProxyContainer() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2009	cnwer1	Initial creation

*/

vars

begin
	if self.myDTOContainer &lt;&gt; null and
		self.myDTOContainer.myPxyTrackedItem &lt;&gt; null then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myButton" id="d6d8d874-3923-4a5b-bbe9-86d3847b67d1">
        <methodInvocation>mapping</methodInvocation>
        <source>myButton(set: Boolean; _value: Button io) mapping;
/*
----------   ----------  --------------------------------------------------
Created:	30 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if set then
		if self.myDTOContainer &lt;&gt; null then
			self.myDTOContainer.myButton := _value;
		endif;
	else
		if self.myDTOContainer &lt;&gt; null then
			_value := self.myDTOContainer.myButton;
		endif;
	endif;



end;


</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Button" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setButtonCaption" id="7af7c763-c533-41c6-b689-badc9722476d">
        <source>setButtonCaption();
/*
----------   ----------  --------------------------------------------------
Created:	30 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.myDTOContainer &lt;&gt; null then
		self.myDTOContainer.setButtonCaption();
		if self.myDTOContainer.myButton &lt;&gt; null and self.isBackEnd then
			self.myDTOContainer.myButton.caption := '&lt;40ft backend&gt;';
			self.myDTOContainer.myButton.enabled := false;
		endif;
		
	endif;
	

end;


</source>
    </JadeMethod>
</Class>
