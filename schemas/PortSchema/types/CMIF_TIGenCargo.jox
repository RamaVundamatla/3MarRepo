    <JadeMethod name="doMove" id="4855ac8a-e17e-41a9-83a7-c0912ef2a0c1">
        <source>doMove(_roadJob : CM_RoadJob; _passport : CM_Passport input):Boolean protected;
/*
	Created on 22 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	wle 				: CM_WorkListEntry;
	moveController		: CMIF_MoveController;
	targetLocn			: CM_LocationsController;
	lcnStr				: String;
	moveMode 			: Integer;
begin

	moveMode	:= REAL_MODE;
	targetLocn 	:= self.myNewLocation;
	if targetLocn = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'New location', null, null);
		app.raiseCMException(Input_required_field_newLocn, null, null); // cnwdb2	PAR 35364
		return false;
	endif;

	if self.myTrackedItem = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Cargo Item', null, null);
		app.raiseCMException(Input_required_field_cargoItem, null, null); // cnwdb2	PAR 35364
		return false;
	endif;

	lcnStr := targetLocn.getFullId();
	
	create moveController transient;
	moveController.setMyTrackedItem(self.myTrackedItem);	
	moveController.setMyToPrimaryLocation(targetLocn);
	moveController.setMoveMode(moveMode);
	moveController.setJobForMove(_roadJob);
	
//	wle := self.myTrackedItem.getWLEForRoadRailMove();
	wle := self.myTrackedItem.getIncompleteRoadReceiveWle();	//20 Sep 2013	NDL	Par 32497
	if wle &lt;&gt; null then
		moveController.setMyWorkListEntry(wle);
	endif;
	
	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	
	
	return _passport.noErrors;
	
epilog
	delete moveController;
end;</source>
        <access>protected</access>
        <Parameter name="_roadJob" type="CM_RoadJob"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPreNote" id="746f62e7-cb0f-45e9-8269-376c0829923c">
        <updating/>
        <source>doPreNote(_passport : CM_Passport input):Boolean updating, protected;
/*
	Created on 22 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	nullObject	: CM_Object;

begin

	delete self.myCMIFReceival;
	create self.myCMIFReceival transient;
	
	self.myCMIFReceival.setFromTI(self.myTrackedItem, self.myTrackedItem.myTerminal);
	
	self.myCMIFReceival.validateForCreate(_passport);
	if (not _passport.checkValidation()) then
		return false;
	endif;

	if (not self.myCMIFReceival.actionForCreate(nullObject, _passport)) then
		return false;
	endif;

	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doReceiveItem" id="3f10f6ee-baa9-41c6-bdc1-9d984952a1b7">
        <updating/>
        <source>doReceiveItem(_passport : CM_Passport input):Boolean protected, updating;
/*
	Created on 22 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	wle 				: CM_WorkListEntry;
	moveController		: CMIF_MoveController;
	targetLocn			: CM_LocationsController;
	lcnStr				: String;
	moveMode 			: Integer;
	
	nullObject	: CM_Object;

begin
	if self.myNewLocation = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'location', 'location', null);
		app.raiseCMException(Input_required_field_location, 'location', null); // cnwdb2	PAR 35364
		return false;
	endif;
	self.myCMIFReceival.yardLocationTxt := self.myNewLocation.getFullId;
	self.myCMIFReceival.validateForCreate(_passport);
	if (not _passport.checkValidation()) then
		return false;
	endif;
	if (not self.myCMIFReceival.actionForCreate(nullObject, _passport)) then
		return false;
	endif;
	self.myTrackedItem := self.myCMIFReceival.myPersistentTrackedItem;
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCargoId" id="8aaaf90f-fa9b-4013-96f9-023fbe908f7c">
        <source>getCargoId():String;
/*
	Created on 01 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if myTrackedItem &lt;&gt; null then
		return myTrackedItem.id;
	elseif myCMIFReceival &lt;&gt; null then
		return myCMIFReceival.id;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationString" id="22bcb987-a6df-46a8-ab6f-0abece1903ac">
        <source>getLocationString():String;
/*
	Created on 15 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if myNewLocation &lt;&gt; null then
		return myNewLocation.getFullId;
	else
		return '';
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTrackedItem" id="1a372fc7-79da-47a1-880c-7f17213134d1">
        <source>getTrackedItem():CM_TrackedItem;

vars

begin
	if myTrackedItem &lt;&gt; null then
		return myTrackedItem;
	else 
		return myRefPrenote;
	endif;
end;
</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="save" id="8fe53002-e1ee-4983-b15f-a870583cf1c6">
        <updating/>
        <source>save(_roadJob : CM_RoadJob io; _passport : CM_Passport input; _errorId : String io):Boolean updating;
/*
	Created on 22 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if _roadJob &lt;&gt; null then
		_roadJob.setAutoComplete(true);
	endif;
	if self.action = self.Action_Move then
		return self.doMove(_roadJob, _passport);
	elseif self.action = self.Action_ReceivePrenote then
		if self.doReceiveItem(_passport) then
			return self.doMove(_roadJob, _passport);
		endif;
	elseif self.action = self.Action_CreateItem then
		if self.doReceiveItem(_passport) then
			return self.doMove(_roadJob, _passport);
		endif;
	elseif self.action = self.Action_ReleaseByID then
		return self.doMove(_roadJob, _passport);
	endif;
	_errorId := getCargoId;
	return true;
end;</source>
        <Parameter name="_roadJob" type="CM_RoadJob" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_errorId" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
