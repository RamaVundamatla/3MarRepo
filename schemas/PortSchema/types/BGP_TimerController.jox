<Class name="BGP_TimerController" id="f111da22-8087-455f-a0e2-82fc54359767">
    <superclass name="BGP_Controller"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>Abstract timer class that allows requests to be run at user defined intervals.</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="timerInterval" id="5e3d3c22-3322-48b9-81b3-59876b76507b">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="createTimerRequest" id="8059e1b6-4026-4fa4-8832-2c888456a80f">
        <updating/>
        <source>createTimerRequest() : Boolean updating, protected;

// cnwdvb1 11 December 2002 
//03 Jan 2013	cnwrs1	32983 crash after user deleted.

vars

	tmpClass	: Class;
	className	: String;
	request		: BGP_Request;
	returnValue	: Boolean;
	msg : String;
begin

	foreach className in self.allRequestClassesToProcess do
		tmpClass := self.getClass(className);
		if tmpClass = null then
			app.remoteErrorWarningToAlert('INFO &gt;&gt; Error creating timer rquest ' &amp; className &amp; 
						'. Request class not found' , null, null, null, true, true);
			continue;
		endif;
		app.myTrxCA.trxCreateBGPRequestTimer(tmpClass, request, self, app.myPassport);
		msg := 'Starting to Process ' &amp; request.String;
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		app.myTrxUA.trxUpdateBGPControllerPre(self, app.actualTimeServer, request, app.myPassport);
		if request.action() then
			returnValue := self.doPostRequest();
		endif;
		app.myTrxUA.trxUpdateBGPControllerPost(self, app.myPassport);
	endforeach;
	
	app.myTrxDA.trxDeleteBGPRequest(null, request, true, app.myPassport);
epilog
	return returnValue;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPostRequest" id="19cb58b9-0d8b-4a7f-8816-4f3613d59264">
        <updating/>
        <source>doPostRequest() : Boolean protected, updating;

// cnwdvb1 13 January 2003 

vars

begin

	// Do nothing.
	return false;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doProcessing" id="36e80fc6-760e-4df4-8948-61ce54912d64">
        <updating/>
        <source>doProcessing() : Boolean updating, protected;

// cnwdvb1 11 December 2002 

vars

begin

	// Do any work related to this timer event.
	// i.e Check for email, monitor directory.
	return false;	
	
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTimerEvent" id="4580cc98-7fad-4fa1-9b79-e2d6d3fde70d">
        <updating/>
        <source>doTimerEvent() updating, protected;

// cnwdvb1 11 December 2002 
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	error 		: Integer;
	errorText	: String;

begin


	on Exception do app.alertExceptionHandler(exception, null,'Timer BGP Controller Event', error, errorText, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	self.processTimer();

epilog

	// The reason we do this is so we have more control over when the timer fires.
	// The timer fires once and when everything has completed we reset it.
	self.endTimer(AutoTimer_Event_Tag);
	self.beginTimer(self.timerInterval * 1000, Timer_OneShot, AutoTimer_Event_Tag);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getFields" id="1d6c5f8e-b728-4dc7-9e39-6cc82bfc1582">
        <source>getFields(_allFields: StringArray input);
// --------------------------------------------------------------------------------
// Created:		23 February 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(_allFields);
