    <JadeMethod name="drawGridLeftRowHeader" id="7bfa47c9-d990-42d2-8b04-bed700af4f33">
        <source>drawGridLeftRowHeader(_x1, _y1, _x2, _y2 : Real; _frame : Frame input; _scaleFactor : Real;  _isLandscape, _flipH, _flipV : Boolean; _mode : Integer; _isGapRow : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21/06/2011	cnwdz2	Initial creation 27732

*/

vars
begin

	if _mode = self.MODE_TOPDOWN then
		self.drawGridLeftRowHeaderTopDown(_x1, _y1, _x2, _y2, _frame, _scaleFactor, _isLandscape, _flipH, _flipV, _mode, _isGapRow);
	elseif _mode = self.MODE_FACE then
		self.drawGridLeftRowHeaderFace(_x1, _y1, _x2, _y2, _frame, _scaleFactor, _isLandscape, _flipH, _flipV, _mode, _isGapRow);	
	elseif _mode = self.MODE_END then
		self.drawGridLeftRowHeaderEnd(_x1, _y1, _x2, _y2, _frame, _scaleFactor, _isLandscape, _flipH, _flipV, _mode, _isGapRow);		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, "unsupported drawing mode specified");
	endif;
epilog

end;</source>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_scaleFactor" type="Real"/>
        <Parameter name="_isLandscape" type="Boolean"/>
        <Parameter name="_flipH" type="Boolean"/>
        <Parameter name="_flipV" type="Boolean"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_isGapRow" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawGridLeftRowHeaderEnd" id="b28643e5-178f-4394-9ab2-8518bd417e95">
        <source>drawGridLeftRowHeaderEnd(_x1, _y1, _x2, _y2 : Real; _frame : Frame input; _scaleFactor : Real;  _isLandScape, _flipH, _flipV : Boolean; _mode : Integer; _isGapRow : Boolean) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Sep 2010	cnwdz2	Initial creation 25642
29 May 2012 cnwer1	PAR 29588
*/
vars
	lc 				: CM_LocationsController;
	gridLc			: CM_GridController;
	headerX, headerY,
	noAccessDrawX, noAccessDrawY,
	lengthPixels	: Real;
	label, accessLabel  : String;
	labelTextHeight : Real;
	forkLiftStack : CM_ForkLiftStack;
	tmpTA	: CM_GridArea;
begin	
	if _frame = null then
		return;
	endif;
	
	lc := self.getLocationController();
	if lc = null or not lc.isKindOf(CM_GridController) then
		return;
	endif;
	
	gridLc := lc.CM_GridController;
	tmpTA := gridLc.getMyTerminalArea.CM_GridArea;
	//17/06/2011 cnwdz2 27732
	if tmpTA.isKindOf(CM_ForkLiftStack) then
		forkLiftStack := tmpTA.CM_ForkLiftStack;
	endif;

	lengthPixels := self.getSizeInPixels(self.widthFt, _scaleFactor);	
	//08/10/2010 cnwdz2 par25671
	if lc.isGap() then
		if _isGapRow then
			lengthPixels := lc.getGapWidthPixels(lengthPixels);
		endif;
	endif;
	label := gridLc.getColumnLabel(true);
	
	if _flipH then 
		headerX := _x2 + (_x2-_x1)/2;
	else
		headerX := _x1 + (_x2-_x1)/2;
	endif;
	
	labelTextHeight := _frame.drawTextHeight(label);

	headerY := _y1 + lengthPixels/2 - labelTextHeight/2;

	accessLabel:=null;
	if _flipH then
		if ( tmpTA.bottomLabel &lt;&gt; null and gridLc.myGridRow.row = tmpTA.allGridRows.size) then											
			accessLabel :=tmpTA.bottomLabel;	
		endif;	
		headerX := headerX + 5;
	else
		if tmpTA.topLabel &lt;&gt; null and gridLc.myGridRow.row = 1 then
			accessLabel :=tmpTA.topLabel;					
		endif;	
		headerX := headerX + 5;
	endif;
	
	//epr par 29823 drawTextRotation is not supported on WindowsCe
	if accessLabel &lt;&gt; null and not app.cnThinClientOSIsWindowsMobile()  then 
		_frame.drawTextRotation := 270;
		_frame.drawTextCharRotation := 270;
		_frame.drawTextAlign := Frame.DrawTextAlign_Left;
		_frame.drawTextAt(accessLabel, headerX ,headerY, Red);	
		headerX := headerX + 5;
		_frame.drawTextRotation := 0;
		_frame.drawTextCharRotation := 0;
	endif;
	
	
	_frame.drawTextAlign := Frame.DrawTextAlign_Center;	
	_frame.drawTextAt(label, headerX, headerY, Black);
	//16/06/2011 cnwdz2 27732
	if forkLiftStack &lt;&gt; null and 
	   	((not forkLiftStack.accessFront and gridLc.myGridRow.row = tmpTA.allGridRows.size) or
			(not forkLiftStack.accessBack and gridLc.myGridRow.row = 1)) then		 		  		
		_frame.drawWidth := 3;		
		if _flipH then 
			noAccessDrawX := (_x2-_x1)-2;
		else
			noAccessDrawX := _x2-2;
		endif;
		noAccessDrawY := _y1 + (_y2-_y1)*forkLiftStack.heightOfStack;
		_frame.drawLine(noAccessDrawX,_y1,noAccessDrawX, noAccessDrawY,Red);					
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_scaleFactor" type="Real"/>
        <Parameter name="_isLandScape" type="Boolean"/>
        <Parameter name="_flipH" type="Boolean"/>
        <Parameter name="_flipV" type="Boolean"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_isGapRow" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawGridLeftRowHeaderFace" id="c3aeb2b2-0c4e-49ef-aaf9-85bdf2b8fdfd">
        <source>drawGridLeftRowHeaderFace(_x1, _y1, _x2, _y2 : Real; _frame : Frame input; _scaleFactor : Real;  _isLandScape, _flipH, _flipV : Boolean; _mode : Integer; _isGapRow : Boolean) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Sep 2010	cnwdz2	Initial creation 25642
29 May 2012 cnwer1	PAR 29588
*/
vars
	lc 				: CM_LocationsController;
	gridLc			: CM_GridController;
	headerX, headerY,
	lengthPixels	: Real;
	label        : String;
	labelTextHeight : Real;
	tmpTA	: CM_GridArea;
begin	
	if _frame = null then
		return;
	endif;
	
	lc := self.getLocationController();
	if lc = null or not lc.isKindOf(CM_GridController) then
		return;
	endif;
	gridLc := lc.CM_GridController;
	tmpTA := gridLc.getMyTerminalArea.CM_GridArea;

	lengthPixels := self.getSizeInPixels(self.widthFt, _scaleFactor);	
	//08/10/2010 cnwdz2 par25671
	if lc.isGap() then
		if _isGapRow then
			lengthPixels := lc.getGapWidthPixels(lengthPixels);
		endif;
	endif;
	
	label := gridLc.getRowLabel();
	
	if _flipH then 
		headerX := _x2 + (_x2-_x1)/2;
	else
		headerX := _x1 + (_x2-_x1)/2;		
	endif;
	
	labelTextHeight := _frame.drawTextHeight(label);
	
	headerY := _y1 + lengthPixels/2 - labelTextHeight/2;
	

	if _flipV and tmpTA.rightLabel &lt;&gt; null then
		if (_flipH and gridLc.myGridRow.row = tmpTA.allGridRows.size) or 
		   (not _flipH and gridLc.myGridRow.row = 1) then						
			_frame.drawTextAt(tmpTA.rightLabel, headerX+1, 1, Red);						
		endif;	
		headerY := headerY + 5;
	endif;
			
	if not _flipV and tmpTA.leftLabel &lt;&gt; null then	
		if (_flipH and gridLc.myGridRow.row = tmpTA.allGridRows.size) or 
		   (not _flipH and gridLc.myGridRow.row = 1) then						
			_frame.drawTextAt(tmpTA.leftLabel, headerX+1, 1, Red);						
		endif;	
		headerY := headerY + 5;
	endif;					

	_frame.drawTextAlign := Frame.DrawTextAlign_Center;	
	_frame.drawTextAt(label, headerX, headerY, Black);
	
end;</source>
        <access>protected</access>
