<CollClass name="CMIF_ScanPlanLegendDict" id="b8e776f4-7b66-4404-9f99-39d5d39bad91">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CMIF_ScanPlanLegend"/>
    <superclass name="MemberKeyDictionary"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <MemberKey>
        <property name="CMIF_ScanPlanLegend::title"/>
    </MemberKey>
    <JadeMethod name="getSubHeader" id="d4cbbeea-545b-410c-b027-1a95e87130ac">
        <source>getSubHeader( _headerType : Integer ):CMIF_ScanPlanLegend;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

	iter : Iterator;
	legend : CMIF_ScanPlanLegend;

begin

	iter := self.createIterator;
	while iter.next( legend ) do
		if legend.header = _headerType then
			return legend;
		endif;
	endwhile;
	
	return null;
	

epilog

	delete iter;

end;</source>
        <Parameter name="_headerType" type="Integer"/>
        <ReturnType type="CMIF_ScanPlanLegend"/>
    </JadeMethod>
    <JadeMethod name="includesAttributes" id="e91fd465-90f3-4529-8f30-19e4cb8b36f9">
        <source>includesAttributes():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

	iter : Iterator;
	legend : CMIF_ScanPlanLegend;

begin

	iter := self.createIterator;
	while iter.next( legend ) do
		if legend.attributeIndex &gt; 0 then
			return true;
		endif;
	endwhile;
	
	return false;
	

epilog

	delete iter;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesColours" id="994b2c37-cc00-42b1-9768-648aa6b15c53">
        <source>includesColours():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

	iter : Iterator;
	legend : CMIF_ScanPlanLegend;

begin

	iter := self.createIterator;
	while iter.next( legend ) do
		if legend.attributeIndex = 0 and legend.header = 0 then
			return true;
		endif;
	endwhile;
	
	return false;
	

epilog

	delete iter;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
