    <JadeMethod name="cnwdad1_Test_ProcessField" id="52f4a955-ef70-4257-b4db-df8c226806d4">
        <source>cnwdad1_Test_ProcessField();
// --------------------------------------------------------------------------------
// Created:		03 December 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allFieldNames	: StringArray;
	allFieldValues	: StringArray;
	fieldName		: String;
	fieldIndex		: Integer;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	
	create allFieldNames transient;
	create allFieldValues transient;
	
	foreach fieldIndex in 1 to 5 do
		allFieldNames.add("FIELD" &amp; fieldIndex.String);
		allFieldValues.add("Value" &amp; fieldIndex.String);
	endforeach;
	
	write "UserInfo=" &amp; process.userInfo;
	fieldIndex	:=	0;

	foreach fieldName in allFieldNames do
		fieldIndex	:=	fieldIndex + 1;
		
		beginTransaction;
		process.cnEcSetUserInfoFieldValue(allFieldNames[fieldIndex], allFieldValues[fieldIndex]);
		commitTransaction;
		write "UserInfo=" &amp; process.userInfo;
	endforeach;

	write "Field 3=" &amp; process.cnEcGetUserInfoFieldValue(allFieldNames[3]);

	beginTransaction;
	process.cnEcSetUserInfoFieldValue(allFieldNames[3], "New Value 3");
	commitTransaction;
	write "UserInfo=" &amp; process.userInfo;

	beginTransaction;
	process.cnEcSetUserInfoFieldValue(allFieldNames[5], "New Value 5");
	commitTransaction;
	write "UserInfo=" &amp; process.userInfo;

	beginTransaction;
	process.cnEcSetUserInfoFieldValue(allFieldNames[1], "New Value 1");
	commitTransaction;
	write "UserInfo=" &amp; process.userInfo;

	write "Field 1=" &amp; process.cnEcGetUserInfoFieldValue(allFieldNames[1]);
	write "Field 3=" &amp; process.cnEcGetUserInfoFieldValue(allFieldNames[3]);
	write "Field 5=" &amp; process.cnEcGetUserInfoFieldValue(allFieldNames[5]);
epilog
	delete allFieldNames;
	delete allFieldValues;
	
	write "Process Field completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
