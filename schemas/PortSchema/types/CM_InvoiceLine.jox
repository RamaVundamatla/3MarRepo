    <JadeMethod name="setForCreate" id="3749951c-182b-4fd1-803a-84009b5c45bf">
        <updating/>
        <source>setForCreate(_sequenceNum 	  : Integer;
			 _manual 		  : Boolean; 
			 _remarks 		  : String; 
			 _invoiceLineDesc : CM_InvoiceLineDesc; 
			 _invoice 	      : CM_Invoice; 
			 _debtor 		  : CM_Debtor;
			 _bank 			  : CM_Bank; 
			 _quantity 		  : Real; 
			 _chargeTime 	  : TimeStamp) updating;
/*
------------------------------------------------------------------------
Created:			04 June 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
30 Jan 2023 	navvt20			TFS CR 56132 Task 56135: Jade - Invoice Line - UOM									
------------------------------------------------------------------------
*/
vars

begin
	self.sequenceNum     := _sequenceNum;
	self.manual	         := _manual;
	self.remarks         := _remarks;
	self.invoiceLineDesc := _invoiceLineDesc;
	self.invoice 	     := _invoice;
	self.debtor 	     := _debtor;	
	self.bank            := _bank;
	self.quantity        := _quantity;
	if _invoiceLineDesc.myUOM &lt;&gt; null then	// 30 Jan 2023 navvt20 TFS 56135
		self.uomCode := _invoiceLineDesc.myUOM.code; // 30 Jan 2023 navvt20 TFS 56135
	endif;
	self.setChargeTime(_chargeTime);
	
epilog
end;</source>
        <Parameter name="_sequenceNum" type="Integer"/>
        <Parameter name="_manual" type="Boolean"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_invoiceLineDesc" type="CM_InvoiceLineDesc"/>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_quantity" type="Real"/>
        <Parameter name="_chargeTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setForCreateWeb" id="b547658e-e9d0-45fb-8c70-e81505028833">
        <updating/>
        <source>setForCreateWeb(_pxyInvoiceLine: CM_InvoiceLine) updating;
/*

Purpose:		
	
	Method to set the extra details of an invoice line required for a TAS invoice line

Parameters:

	_pxyInvoiceLine: The proxy invoice line to set the new invocie line tas details from

Return Value:

	None

Date		Who		Reason
06/06/2023	navcs2	ChangeRequest 56901: [58447]: TAS Invoicing Invoice Endpoint - JADE changes

*/

vars

begin
	self.sequenceNum     := _pxyInvoiceLine.sequenceNum;
	self.manual	         := _pxyInvoiceLine.manual;
	self.remarks         := _pxyInvoiceLine.remarks;
	self.invoiceLineDesc := _pxyInvoiceLine.invoiceLineDesc;
	self.invoice 	     := _pxyInvoiceLine.invoice;
	self.debtor 	     := _pxyInvoiceLine.debtor;	
	self.bank            := _pxyInvoiceLine.bank;
	self.quantity        := _pxyInvoiceLine.quantity;
	self.chargeTime		 := _pxyInvoiceLine.chargeTime;
	self.externalRef1 	:= _pxyInvoiceLine.externalRef1;
	self.externalRef2 	:= _pxyInvoiceLine.externalRef2;
	self.externalRef3 	:= _pxyInvoiceLine.externalRef3;
	self.externalRef4	:= _pxyInvoiceLine.externalRef4;
	self.uomCode		:= _pxyInvoiceLine.uomCode;
epilog

end;</source>
        <Parameter name="_pxyInvoiceLine" type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateConvert" id="1924c032-2738-409a-9a33-5f9b1f4a16cc">
        <updating/>
        <source>setForUpdateConvert(newLineDescription: CM_InvoiceLineDesc) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
//  28 Oct 2021 navma1 		ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements
//  23 Oct 2024	navlw1		JIRA-33107: Invoice Logging Use Levels
//	25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
//	13 Aug 2025	navnk30		JIRA-35585: NSW | Wharfage invoice line integrated to D365, is not the full rate
vars
	auditOfLineChange:    CM_AuditLineDescChanged;
	now:                  TimeStamp;
	charge:               CM_Charge;
	canLogExtra	:		  Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	// from 31331 Apr 2013 use the server time
	now := app.serverTimestampAtTrxStart;
	// reuse old line description change audits
	auditOfLineChange := getAuditOfClass(CM_AuditLineDescChanged).CM_AuditLineDescChanged;

	if auditOfLineChange = null then
		// create line description change audit
		create auditOfLineChange;
		auditOfLineChange.sequenceNum := app.getNextInvoiceSeqNumOnRootBank(SN_AUDIT); // PAR 15036 
	endif;

	auditOfLineChange.newDescNarration  := newLineDescription.narration;			//28.10.2021 navma1 #52163
	auditOfLineChange.prevDescNarration := self.invoiceLineDesc.narration;          //28.10.2021 navma1 #52163
	auditOfLineChange.userId 			:= app.getMyUserCode();
	auditOfLineChange.datetime 			:= now;
	auditOfLineChange.setRemarksForInvoiceLineChange(self); // PAR 35033
	

	foreach charge in self.charges do
		charge.void;
	endforeach;

	// add audit to self and invoice

	auditOfLineChange.auditedFOs.clear;
	auditOfLineChange.unauditedFOs.clear;

	auditOfLineChange.auditedFOs.add(self);
	auditOfLineChange.unauditedFOs.add(self.invoice);

	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(self, true);			// 10/5/18 MAP TFS37718
	self.invoiceLineDesc := newLineDescription;
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(self, false);			// 10/5/18 MAP TFS37718

	self.createCharges();
	// 31331 Apr 2013 get and use the rates for these new services
	foreach charge in self.charges do
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(charge, true);		// 11/5/18 MAP TFS37718
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Calling CM_Charge.evaluateRate", LogINFO.String);   // TFS 42084
		endif;
		charge.evaluateRate();
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(charge, false);		// 11/5/18 MAP TFS37718
	endforeach;
	self.setTotalAndTaxForResync();		//17AUG2025 navnk30 JIRA-35585

end;</source>
        <Parameter name="newLineDescription" type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateQuantity" id="4c961fc0-5c54-4dae-8d7b-21d507e9cdf2">
        <updating/>
        <source>setForUpdateQuantity(_qty : Real) updating;
// ---------------------------------------------------------------------------
// Created:		18 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.quantity := _qty;
	
	self.resetTotalOnCharge(); // ### TFS BUG 58785 22JUN2023 NAVAB1
	
	self.setTotalAmount();  // ### JIRA 35502 21JUL2025 NAVAB1 in cash have switched to using totalAmount on invoice line for performance, if changing lineTotal need to change static toalAmount //JIRA-35867 navsp1 05.SEP.2025
end;</source>
        <Parameter name="_qty" type="Real"/>
    </JadeMethod>
