    <JadeMethod name="getPackagesDesc" id="b27a0a74-38f5-48eb-b718-d754e1e9a9fa">
        <source>getPackagesDesc(_objSet : CM_PackageInvoiceSet):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle

*/

vars
	obj : Object;
	tmpStr,
	strObj : String;
	count : Integer;
begin


	foreach obj in _objSet do
		strObj := getDictObjectDisplay(obj);
		count := count + 1;
		if count &gt; 6 then
			tmpStr := tmpStr &amp; "," &amp; CrLf;
			count := 1;
		endif;
		if tmpStr = "" then
			tmpStr := strObj;
		elseif count = 1 then
			tmpStr := tmpStr &amp; strObj;
		else
			tmpStr := tmpStr &amp; ", " &amp; strObj;
		endif;
	endforeach;
	
	return tmpStr;
epilog

end;</source>
        <Parameter name="_objSet" type="CM_PackageInvoiceSet"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPaymentType" id="1aa5b6f9-0a13-40fd-a575-6c2d5731a6ae">
        <source>getPaymentType( _service : CM_Service ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

	payTypeMapping : CM_ServicePayTypeMapping;

begin

	if _service &lt;&gt; null  then
		payTypeMapping := self.bank.getServicePayTypeMapping( _service, self, true );	 // this debtor or otherwise the default debtor.
		if payTypeMapping &lt;&gt; null then
			return payTypeMapping.paymentType;
		else
			return self.getDefaultPaymentType( _service.getMyTerminal );
		endif;
	endif;
	
	return 0;

epilog

end;</source>
        <Parameter name="_service" type="CM_Service"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
