    <JadeMethod name="isFromMobileApp" id="2b085626-9629-4b70-b63e-505c45eddf22">
        <source>isFromMobileApp() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 July 2018	jlger1	Initial creation 39623
25 July 2022	jlier1 	TFS 53363
*/

vars
	context : String;
begin
	context:=self.getExtraData(TrnsExtraDataContext).String;
	
	if context = null then
		return false;
	endif;
	
	if context = JMTWebService or context = JMTAppHandheld or context = InternalAPIService then
		return true;
	else
		if context.length &gt; 2 then
			if context[1:3] = "MOB" then
				return true;
			endif;
		endif;
	endif;
	
	
	
	return false;
		
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
