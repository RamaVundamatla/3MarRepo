    <Constant name="MSG_BOX_CLOSE" id="8d26fd83-3cac-458a-b5fa-7f62f1e51d86">
        <source>1</source>
        <type name="Integer"/>
    </Constant>
    <PrimAttribute name="aCloseSeconds" id="38f8cfc1-20a0-49e7-8ac5-7aa9bd8b1490">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="aDialogMessage" id="ac6110a6-f7e5-42a3-8edd-1548afd74e59">
        <type name="String"/>
    </PrimAttribute>
    <ImplicitInverseRef name="btnOK" id="29b08fa2-13e1-4552-9725-68ebe9a74554">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblMsg" id="10395898-92fd-4ba6-9e51-2613a610b61b">
        <embedded/>
        <type name="Label"/>
    </ImplicitInverseRef>
    <JadeMethod name="cancelTimer" id="a2479c4b-69c2-4daf-8868-802944239e58">
        <source>cancelTimer();

vars
	timerOption		: Integer;
	timeRemaining	: Integer;

begin
	if getTimerStatus(self.MSG_BOX_CLOSE, timerOption, timeRemaining) then
		endTimer(MSG_BOX_CLOSE);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doAdjustLabelSize" id="1f32f585-0097-42e4-8046-e36932fe4b9d">
        <source>doAdjustLabelSize() protected;

vars
	characters : Integer;
begin
	characters := lblMsg.caption.length();
	 
	if characters &gt; 100 then 
		lblMsg.width := 500;
	elseif characters &gt; 60 then 
		lblMsg.width := 400;
	elseif  characters &gt; 30 then 
		lblMsg.width := 200;
	else
		lblMsg.width := 100;
	endif;			
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnOK" id="323df10f-80d6-4dd8-bdff-ba42e910be9a">
        <updating/>
        <source>doBtnOK() updating, protected;

vars

begin
	self.unload();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="c60b1f25-b97d-43e5-8f08-aba781e4fa26">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

vars

begin
	loadForm();
end;</source>
    </JadeMethod>
    <JadeMethod name="loadForm" id="af728ba9-fd78-4f26-8e86-c81a620f3f4a">
        <updating/>
        <source>loadForm() updating, protected;

vars

begin
	if self.aDialogMessage[1:255].pos(" ", 1) = 0 then
		lblMsg.caption := self.aDialogMessage[1:255];
	else		
		lblMsg.caption := self.aDialogMessage[1:1024];
	endif;
	
	self.doAdjustLabelSize();

	self.height := lblMsg.top + lblMsg.height + 75;
	self.width	:= lblMsg.width + 15;

	if self.height &lt; 80 then
		self.height := 80;
	endif;

	btnOK.top	:= self.height - 60;
	btnOK.left 	:= (self.width / 2) - 50;

	self.centreWindow();

	beginTimer(self.aCloseSeconds * 1000, Timer_OneShot, self.MSG_BOX_CLOSE);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="d5b9a6c7-8074-47a2-8d37-b74d6d08f1a1">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

vars

begin
	if eventTag = MSG_BOX_CLOSE then
		doBtnOK();
	endif;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="unload" id="9f863d6e-1687-4caf-a13d-a03d884c7687">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

vars

begin
	cancelTimer();
	self.unloadForm;
end;</source>
    </JadeMethod>
</GUIClass>
