<Class name="CMIF_GarbageCollect" id="03d5f7ef-3947-476b-a0ef-3c8d79036a48">
    <superclass name="CMIF_Object"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>Used for garbage collection in SYSOPS app.</text>
    <PrimAttribute name="lTEDT" id="a9873d53-efc0-47bf-8792-2babe05a00f3">
        <embedded/>
        <type name="TimeStamp"/>
        <text>Less than or Equal to this Date/time</text>
    </PrimAttribute>
    <PrimAttribute name="maxToCheck" id="21e9077c-3ea8-401b-950c-f549430e4e7b">
        <embedded/>
        <type name="Integer"/>
        <text>Set by users, after we have searched this many oids, 
we come back</text>
    </PrimAttribute>
    <PrimAttribute name="numDone" id="e1057506-b8ee-4e1b-8676-a295988f48ea">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="numToDo" id="00021dc1-7c53-4b92-ba82-43df7ac48555">
        <embedded/>
        <type name="Integer"/>
        <text>Returned by method, total to work thru.</text>
    </PrimAttribute>
    <PrimAttribute name="returnWarnings" id="5088452b-9076-4248-9537-432f462f1945">
        <embedded/>
        <type name="Boolean"/>
        <text>If set, returns warning msgs, else we return oid as one to 
delete</text>
    </PrimAttribute>
    <PrimAttribute name="state" id="9efc9c19-650e-4a8d-bbf9-d13c829c0c76">
        <embedded/>
        <type name="Integer"/>
        <text>State values
Const GC_INIT = 0
Const GC_NEXT_CLASS = 1 Finished current class, jumping to next
Const GC_COMPLETE = 2   Done all classes
Const GC_ERR = 3        fell over
Const GC_SEARCHING = 4  Should NEVER be seen, is INTERNAL to method
Const GC_PROCESSING = 5 Have a live one
Const GC_WARNING = 6    Issuing a Warning back, will CONTINUE on next call.
Const GC_BREATHER = 7   Having a breather, have searched to return limit.</text>
    </PrimAttribute>
    <PrimAttribute name="warning" id="dfdaeca2-1ba9-46ce-9f5e-7754c70dc6ab">
        <embedded/>
        <type name="Integer"/>
        <text>Used to return a warning value. Different from Ark2 in that warnings can not 
be returned in result due to exception handling intervention</text>
    </PrimAttribute>
</Class>
