    <JadeMethod name="delete" id="683064aa-e8cb-4aa9-b256-a514783a5be5">
        <updating/>
        <source>delete() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/12/2014	cnwmc5	Initial creation
24/03/2016	cnwdap1	PAR #37675 Transient leaks in getLowRows web service
*/

vars

begin

	delete self.myLocationRestriction;
	delete self.myTerminal;					//cnwmc5 - 7 Jan 2015 - PAR 35446
	
	self.allSOHLocations.purge;				// PAR #37675
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCMIFLogRow" id="14e877a8-f7ff-4ce6-8967-df93558f52f9">
        <source>setCMIFLogRow(_cmifLogRow : CMIF_LogRowRestriction input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2014	cnwmc5	Initial creation

*/

vars
	wsLocationRestriction 	: WS_LocationRestriction;
	terminalArea			: CM_TerminalArea;
	rowArea					: CM_LogArea;
	rowAreaTo				: CM_RowAreaRow;
	
	allOperators,
	allSpecies,
	allGrades,
	allLogTypes,
	allTreatments,
	allLengths				: ObjectArray;
	
	wsOperator				: WS_Operator;
	wsSpecies				: WS_LogSpecies;
	wsGrade					: WS_LogGrade;
	wsLogType				: WS_LogType;
	wsTreatment				: WS_LogTreatment;
	wsLength				: WS_LogLength;
	
	operator				: CM_Operator;
	species					: CM_LogSpecies;
	grade					: CM_LogGrade;
	logType					: CM_LogType;
	treatment				: CM_LogTreatment;
	length					: CM_LogLength;
	
	terminal				: CM_Terminal;
	user					: CM_User;
	failedDAC				: CM_DataAccessController;
	
	comment,
	previousRow				: String;
	isSplit,
	isExternallyVisible		: Boolean;
	transportMode			: Integer;
	
begin
	
	wsLocationRestriction := self.myLocationRestriction;
	terminal := app.myPassport.myTerminal;
	user := app.myPassport.myUser;
	
	if wsLocationRestriction &lt;&gt; null then
		
		transportMode := wsLocationRestriction.transportMode;
		
		terminalArea := terminal.allTerminalAreas[self.terminalAreaId];
		if terminalArea.isKindOf(CM_LogArea) then
			rowArea := terminalArea.CM_LogArea;
		endif;
		
		create allOperators		transient;
		create allSpecies		transient;
		create allGrades		transient;
		create allLogTypes		transient;
		create allTreatments	transient;
		create allLengths		transient;
		
		foreach wsOperator in wsLocationRestriction.allOperators do
			operator := app.myRoot.allOperators[wsOperator.code];
			if operator.canUserAccessSelf(user, failedDAC, app.myPassport) and not operator.isNotAvailableForEntry then
				allOperators.add(operator);
				
				foreach wsSpecies in wsLocationRestriction.allLogSpecies do
					species := operator.getLogSpecies(wsSpecies.code);
					if species &lt;&gt; null and not species.notAvailableForEntry then
						allSpecies.addExclusive(species);
						
						foreach wsGrade in wsLocationRestriction.allLogGrades do
							grade := operator.getLogGrade(species.code, wsGrade.code);
							if grade &lt;&gt; null and not grade.notAvailableForEntry then
								allGrades.addExclusive(grade);
								
								foreach wsLogType in wsLocationRestriction.allLogTypes do
									logType := operator.getLogTypeForGrade(species.code, grade.code, wsLogType.code);
									if logType &lt;&gt; null and not logType.notAvailableForEntry then
										allLogTypes.addExclusive(logType);
									endif;
								endforeach;
								
								foreach wsLength in wsLocationRestriction.allLogLengths do
									length := operator.getLogLengthForGrade(species.code, grade.code, wsLength.code);
									if length &lt;&gt; null and not length.notAvailableForEntry then
										allLengths.addExclusive(length);
									endif;
								endforeach;
								
								foreach wsTreatment in wsLocationRestriction.allLogTreatments do
									treatment := operator.getLogTreatmentForGrade(species.code, grade.code, wsTreatment.code);
									if treatment &lt;&gt; null and not treatment.notAvailableForEntry then
										allTreatments.addExclusive(treatment);
									endif;
								endforeach;
							endif;
						endforeach;
					endif;
				endforeach;
			endif;
		endforeach;
	endif;
	
	comment := self.remarks;		//cnwmc5 - 7 Jan 2015 - PAR 35446
	isSplit := false;				//review
	rowAreaTo := null;				//review
	previousRow := null;			//review
	isExternallyVisible := false;	//review
	
	_cmifLogRow.set(rowArea,
					self.id,
					allOperators,
					allSpecies,
					allGrades,
					allLogTypes,
					allTreatments,
					allLengths,
					self.status,
					comment,
					self.docketChecked,
					self.checkScaled,
					self.isInspected,
					self.isFumigated,
					self.rowIsMixed,
					self.estimatedMaxVolume,
					transportMode,
					self.ignoreArchiving,
					self.rowWidth,
					isSplit,
					user.code,
					rowAreaTo,
					previousRow,
					self.distanceFromPrevious,
					isExternallyVisible);
	
epilog
	delete allOperators;
	delete allSpecies;
	delete allGrades;
	delete allLogTypes;
	delete allTreatments;
	delete allLengths;
end;</source>
        <Parameter name="_cmifLogRow" type="CMIF_LogRowRestriction" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCMIFLogRowForUpdate" id="4aa8ed6e-15d9-49c9-ab3d-c2f7ecc7458d">
        <source>setCMIFLogRowForUpdate(_cmifLogRow : CMIF_LogRowRestriction input; _realLogRow : CM_LogController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2014	cnwmc5	Initial creation

*/

vars
	wsLocationRestriction 	: WS_LocationRestriction;
	terminalArea			: CM_TerminalArea;
	rowArea					: CM_LogArea;
	rowAreaTo				: CM_RowAreaRow;
	
	allOperators,
	allSpecies,
	allGrades,
	allLogTypes,
	allTreatments,
	allLengths				: ObjectArray;
	
	wsOperator				: WS_Operator;
	wsSpecies				: WS_LogSpecies;
	wsGrade					: WS_LogGrade;
	wsLogType				: WS_LogType;
	wsTreatment				: WS_LogTreatment;
	wsLength				: WS_LogLength;
	
	operator				: CM_Operator;
	species					: CM_LogSpecies;
	grade					: CM_LogGrade;
	logType					: CM_LogType;
	treatment				: CM_LogTreatment;
	length					: CM_LogLength;
	
	terminal				: CM_Terminal;
	user					: CM_User;
	failedDAC				: CM_DataAccessController;
	
	comment,
	previousRow				: String;
	isSplit,
	isExternallyVisible		: Boolean;
	transportMode			: Integer;
	
begin
	
	wsLocationRestriction := self.myLocationRestriction;
	terminal := app.myPassport.myTerminal;
	user := app.myPassport.myUser;
	
	if wsLocationRestriction &lt;&gt; null then
		
		transportMode := wsLocationRestriction.transportMode;
		
		terminalArea := terminal.allTerminalAreas[self.terminalAreaId];
		if terminalArea.isKindOf(CM_LogArea) then
			rowArea := terminalArea.CM_LogArea;
		endif;
		
		create allOperators		transient;
		create allSpecies		transient;
		create allGrades		transient;
		create allLogTypes		transient;
		create allTreatments	transient;
		create allLengths		transient;
		
		foreach wsOperator in wsLocationRestriction.allOperators do
			operator := app.myRoot.allOperators[wsOperator.code];
			if operator.canUserAccessSelf(user, failedDAC, app.myPassport) and not operator.isNotAvailableForEntry then
				allOperators.add(operator);
				
				foreach wsSpecies in wsLocationRestriction.allLogSpecies do
					species := operator.getLogSpecies(wsSpecies.code);
					if species &lt;&gt; null and not species.notAvailableForEntry then
						allSpecies.addExclusive(species);
						
						foreach wsGrade in wsLocationRestriction.allLogGrades do
							grade := operator.getLogGrade(species.code, wsGrade.code);
							if grade &lt;&gt; null and not grade.notAvailableForEntry then
								allGrades.addExclusive(grade);
								
								foreach wsLogType in wsLocationRestriction.allLogTypes do
									logType := operator.getLogTypeForGrade(species.code, grade.code, wsLogType.code);
									if logType &lt;&gt; null and not logType.notAvailableForEntry then
										allLogTypes.addExclusive(logType);
									endif;
								endforeach;
								
								foreach wsLength in wsLocationRestriction.allLogLengths do
									length := operator.getLogLengthForGrade(species.code, grade.code, wsLength.code);
									if length &lt;&gt; null and not length.notAvailableForEntry then
										allLengths.addExclusive(length);
									endif;
								endforeach;
								
								foreach wsTreatment in wsLocationRestriction.allLogTreatments do
									treatment := operator.getLogTreatmentForGrade(species.code, grade.code, wsTreatment.code);
									if treatment &lt;&gt; null and not treatment.notAvailableForEntry then
										allTreatments.addExclusive(treatment);
									endif;
								endforeach;
							endif;
						endforeach;
					endif;
				endforeach;
			endif;
		endforeach;
	endif;
	
	if _realLogRow.myRow &lt;&gt; null then
		rowAreaTo := null;
		_cmifLogRow.myRowAreaRow := _realLogRow.myRow;
		if _realLogRow.myRow.allRowControllers.size &gt; 1 then 
			isSplit := true;
		endif;
	endif;
	
	if isSplit then
		rowAreaTo := null;
	endif;
	previousRow := null;
	
	_cmifLogRow.set(rowArea,
					self.id,
					allOperators,
					allSpecies,
					allGrades,
					allLogTypes,
					allTreatments,
					allLengths,
					self.status,
					self.remarks,			//cnwmc5 - 7 Jan 2015 - PAR 35446
					self.docketChecked,
					self.checkScaled,
					self.isInspected,
					self.isFumigated,
					self.rowIsMixed,
					self.estimatedMaxVolume,
					transportMode,
					self.ignoreArchiving,
					self.rowWidth,
					isSplit,
					user.code,
					rowAreaTo,
					previousRow,
					self.distanceFromPrevious,
					_realLogRow.isExternallyVisible);
	
epilog
	delete allOperators;
	delete allSpecies;
	delete allGrades;
	delete allLogTypes;
	delete allTreatments;
	delete allLengths;
end;</source>
        <Parameter name="_cmifLogRow" type="CMIF_LogRowRestriction" usage="input"/>
        <Parameter name="_realLogRow" type="CM_LogController"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="74dab9f8-0c2d-449b-a7e5-99835f11e0ff">
        <updating/>
        <source>setProxyFromObject(_logRow : CM_LogController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2014	cnwmc5	Initial creation

*/

vars
	wsLocationRestriction 	: WS_LocationRestriction;
	wsTerminal				: WS_Terminal;
	
begin
	inheritMethod(_logRow);
	
	//self.allStockOrderAllocations := _logRow.allStockOrderAllocations
	
	self.averageSED 			:= _logRow.averageSED;
	self.checkScaled 			:= _logRow.checkScaled;
	self.distanceFromPrevious 	:= _logRow.getDistanceFromPrevious();
	self.docketChecked 			:= _logRow.docketChecked;
	self.estimatedMaxVolume 	:= _logRow.estimatedMaxVolume;
	self.id 					:= _logRow.id;
	self.ident 					:= _logRow.ident;
	self.ignoreArchiving 		:= _logRow.ignoreArchiving;
	self.isFumigated			:= _logRow.isFumigated;
	self.isInspected			:= _logRow.isInspected;
	self.lastMoveOutDateTime	:= _logRow.lastMoveOutDateTime.asStringForWebInterface;				//cnwmc5 - 26 Jan 2016 - PAR 37326
	self.remarks				:= _logRow.remarks;
	if _logRow.myLocationRestriction &lt;&gt; null then
		self.rowIsMixed				:= _logRow.myLocationRestriction.CM_LocationRestrictLog.mixedRow;
	endif;
	self.rowWidth				:= _logRow.getRowWidth();
	self.status					:= _logRow.status;
	self.statusDateTime			:= _logRow.statusDateTime.asStringForWebInterface;					//cnwmc5 - 26 Jan 2016 - PAR 37326
	self.statusDescription		:= _logRow.getStatusDescription();
	self.terminalAreaId			:= _logRow.terminalAreaId;
	
	if _logRow.myLocationRestriction &lt;&gt; null then
		create wsLocationRestriction transient;
		wsLocationRestriction.setProxyFromObject(_logRow.myLocationRestriction);
		self.myLocationRestriction := wsLocationRestriction;
	endif;
	
	if _logRow.myTerminal &lt;&gt; null then
		create wsTerminal transient;
		wsTerminal.setProxyFromObject(_logRow.myTerminal);
		self.myTerminal := wsTerminal;
	endif;

epilog

end;</source>
        <Parameter name="_logRow" type="CM_LogController"/>
    </JadeMethod>
    <JadeMethod name="setProxySOHLocations" id="a9472243-8cd9-4218-a7ac-44cee42d0a43">
        <updating/>
        <source>setProxySOHLocations(_logRow : CM_LogController) updating;
/*

Date		Who		Reason
06 October 2015	cnwer1	Initial creation PAR

*/

vars
	soh			: CM_SOHLocation;
	failedDAC  :CM_DataAccessController;
	wsSOHLocation : WS_SOHLocation;

begin

	
	foreach soh in _logRow.allProductLocations do
		if soh.allTrackedItems.isEmpty and
			  soh.allStockOrderAllocations.isEmpty then
			continue;
		endif;
		if not soh.canUserAccessSelf(null, failedDAC, app.myPassport) then
			continue;
		endif;
		create wsSOHLocation transient;
		wsSOHLocation.setProxyFromObject(soh);
		self.allSOHLocations.add(wsSOHLocation);
		self.peiceCount:=self.peiceCount + wsSOHLocation.peiceCount;
		self.docketCount:=self.docketCount + wsSOHLocation.docketCount;
		self.volume:=self.volume + wsSOHLocation.volume;
		self.weight:=self.weight + wsSOHLocation.weight;
		
		
	endforeach;
epilog

end;</source>
        <Parameter name="_logRow" type="CM_LogController"/>
    </JadeMethod>
</Class>
