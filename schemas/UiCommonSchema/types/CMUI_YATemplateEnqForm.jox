    <JadeMethod name="showSearchParameters" id="6dfcd001-761c-4c30-8470-fffb9bce467f">
        <updating/>
        <source>showSearchParameters() updating, protected;

/*

Purpose:		Display current search parameters

Parameters:			

Return Value:		


Date			Who		Reason
13 August 2008	consw1	Initial creation

*/

vars
	proxyCriteria	: CM_YACriteria;
	tmpObj			: CMIF_Object;

begin
	if self.mySearchParameters.hasDefaultValues() then
		self.zHideSearcher();
		return;
	endif;

	self.tblSearch.rows := 0;
	self.tblSearch.accessColumn(1).visible := false;
	self.tblSearch.accessColumn(2).widthPercent := 100;

	foreach tmpObj in self.mySearchParameters.allSearchCriteria do
		proxyCriteria := tmpObj.CMIF_YACriteriaPriority.myProxy.CM_YACriteria;
		tblSearch.addItem( Tab &amp; proxyCriteria.getDescription() );
	endforeach;
	
	tblSearch.addItem( Tab &amp; self.mySearchParameters.getStatusDisplay() );

	self.zShowSearcher();
	
	self.btnShowSearchTV.caption := app.getErrorString(ShowSearcher);
	self.btnShowSearchTV.bubbleHelp := self.btnShowSearchTV.caption;

	self.doExpandSearchParameters();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
