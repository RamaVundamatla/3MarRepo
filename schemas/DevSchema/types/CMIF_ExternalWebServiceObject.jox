<Class name="CMIF_ExternalWebServiceObject">
    <JadeMethod name="populateWithTestingData" id="2ea340d1-3f43-473b-9309-f36c8e610c09">
        <updating/>
        <source>populateWithTestingData() updating;
/*

Purpose:			Populate the receiver object and all its collections with test data 

Parameters:			

Return Value:		

Date		Who		Reason
08 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/


vars
	props			: PropertyColl;
	property		: Property;
	propName		: String;
	propValue		: Any;
	obj				: CMIF_ExternalWebServiceObject;
	memberType		: Type;
	coll			: Collection;
	stringValue		: String;
	today			: Date;
	
begin
	props := self.class.allProperties;
	foreach property in props where property.access = null do		// only public properties
		
		propName := property.name;
		if propName[1:1] = "_" then
			continue;
		endif;
		
		if property.type.isKindOf(CollClass) then					// Assume collections are exclusive
			
			memberType := property.type.CollClass.memberType;
			propValue := self.getPropertyValue(propName);
			coll := propValue.Collection;
			
			if memberType.inheritsFrom(CMIF_ExternalWebServiceObject) then
				create obj as memberType.Class transient;
				
				obj.populateWithTestingData();
				coll.add(obj);
			else
				coll.add(null);										// Not applicable type, just add a null entry
			endif;

		elseif property.type.inheritsFrom(CMIF_ExternalWebServiceObject) then

			create obj as property.type.Class transient;
			
			obj.populateWithTestingData();
			self.setPropertyValue(propName, obj);
		
		elseif property.type.name = String.name then
			
			// Set a default value for each string property
			stringValue := self.String &amp; "::" &amp; propName;
			self.setPropertyValue(propName, stringValue);

		elseif property.type.name = Date.name then
			
			// Set a default value for each binary property
			self.setPropertyValue(propName, today);

		endif;
	endforeach;
	
epilog
	delete props;
		
end;
</source>
    </JadeMethod>
</Class>
