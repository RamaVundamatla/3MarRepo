    <JadeMethod name="isOnboadCargoType_Match" id="c827d437-b0ad-4884-afd5-0a270f1dd3f7">
        <source>isOnboadCargoType_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2024	jlier1	Initial creation 63834

*/

vars
	tiSet : CM_TISet;
	cargoTypeSet : CM_CargoTypeSet;
	ti : CM_TrackedItem;
	cargoType : CM_CargoType;
begin
	if _yaData.isEmpty() then
		return true;
	endif;
	
	if self.myTrackedItem = null or not self.myTrackedItem.isKindOf(CM_TILC) then
		return false;
	endif;
	
	create tiSet transient;
	self.myTrackedItem.CM_TILC.getAllOnboardTIs(tiSet);
	
	create cargoTypeSet transient;
	
	foreach ti in tiSet discreteLock do
		cargoTypeSet.tryAddIfNotNull(ti.myCargoType);	
	endforeach;
	
	
	foreach cargoType in cargoTypeSet do
		if _yaData.matches(cargoType) then
			return true;
		endif;
	endforeach;
	
	return false;
	

epilog
	delete tiSet;
	delete cargoTypeSet;

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOnboardCommodity_Match" id="0d52cc0d-e684-49f3-9538-3dd59f424933">
        <source>isOnboardCommodity_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2025	navhn30	Initial creation

*/
vars
	tiSet	: CM_TISet;
	ti 		: CM_TrackedItem;
	str			: String;
begin
	if _yaData.isEmpty() then
		return true;
	endif;
	
	if self.myTrackedItem = null or not self.myTrackedItem.isTILC() then
		return false;
	endif;
	
	create tiSet transient;
	self.myTrackedItem.CM_TILC.getAllOnboardTIs(tiSet);
	
	foreach ti in tiSet discreteLock do
		str := ti.commodity.trimBlanks();
		return _yaData.visitObjectsUntilTrue(self, CMIF_YAAutoPlanNormal::isCommodity_Compare, str);
	endforeach;
	
	
	return false;
	

epilog
	delete tiSet;

end;</source>
