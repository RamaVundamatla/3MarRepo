    <JadeMethod name="doSave" id="dc9ff71c-c932-4208-a8fb-05746a576e74">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/07/2022	jlizm1		TFS 54165 EDI Voyage Events
// ---------------------------------------------------------------------------

vars
	rtnValue			: Boolean;
	proxyEventType		: CM_EventType;
	lDescription,
	lName,
	unitDescription		: String;
	lColour, lCategory,
	numDecPlaces,
	lType				: Integer;
	theForm				: SOP_TableMaintForm;
	
	pxyError			: XLAT_Translation;
	pxyInterestedWarning: CM_InterestedWarning;
	error 				: Object;
	selectedErrors		: ObjectArray;
	isFromToDateTimeRequired	: Boolean;
	delay 				: CM_DelayType;	//24 Aug 2018	NDL	TFS 40309
	showWeight			: Boolean;				// TFS 54165
	weightType			: CM_MeasurementType;	// TFS 54165
begin
	
    theForm := self.myForm; 
	lDescription	:=	theForm.tblInput1.getValueByName(ETRow_Description).String;
	lName			:=	theForm.tblInput1.getValueByName(ETRow_Name).String;
	lColour			:=	theForm.tblInput1.getValueByName(ETRow_Colour).Integer;
	numDecPlaces	:=	theForm.tblInput1.getValueByName(ETRow_NumDecimalPlaces).Integer; //epr par 36902 14/9/15
 	isFromToDateTimeRequired:=  theForm.tblInput1.getValueByName(ETRow_IsFromToDateTimeRequired).Boolean;//nds TFS 3047 13/01/17
	unitDescription :=  theForm.tblInput1.getValueByName(ETRow_UnitDescription).String;			//nds TFS 3047 13/01/17
	delay 			:= theForm.cmbVoyageDelay.listObject.CM_DelayType;	//24 Aug 2018	NDL	TFS 40309
	showWeight		:= theForm.tblInput1.getValueByName(ETRow_ShowWeight).Boolean;	// TFS 54165
	weightType 		:= theForm.cmbMeasureUnit.listObject.CM_MeasurementType;		// TFS 54165

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_EventType transient;
			// 29 Oct 2009	NDL	Par 21519
			if theForm.cmbCategory.listIndex &gt; 0 then
				lCategory	:=	theForm.cmbCategory.itemData[theForm.cmbCategory.listIndex];
			endif;  	
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	else
		lCategory:=theForm.myProxyObject.CM_EventType.category;
	endif;

	proxyEventType := theForm.myProxyObject.CM_EventType;
	if theForm.mode = theForm.Mode_Add then
		if theForm.comboBox1.listIndex &gt; 0 then
			lType:=theForm.comboBox1.listData;
		else
			lType := proxyEventType.getNextTypeInteger();
		endif;
	elseif theForm.mode = theForm.Mode_Update then
		lType := theForm.myProxyObject.CM_EventType.type;
	endif;

	proxyEventType.setProxy(lType, lName, lDescription, theForm.myProxyObject.CM_EventType.classNameToCreate, lColour, lCategory, app.myRoot,numDecPlaces,isFromToDateTimeRequired,unitDescription);
	proxyEventType.setMyDelayTypeToCreate( delay );	//24 Aug 2018	NDL	TFS 40309
	proxyEventType.setShowWeight(showWeight);		// TFS 54165
	if showWeight then								// TFS 54165
		proxyEventType.setMyWeightType(weightType);	// TFS 54165
	else
		proxyEventType.setMyWeightType(null);		// TFS 54165
	endif;
	
	create selectedErrors transient;
	theForm.mulSelect1.getSelected(selectedErrors);
	proxyEventType.allInterestedWarnings.purge();
	
	foreach error in selectedErrors do
		create pxyInterestedWarning transient;
		pxyInterestedWarning.setProxy(error.XLAT_Translation.myTranslatableText.number);
		pxyInterestedWarning.addEventType(proxyEventType);
	endforeach;

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateEventType(proxyEventType, theForm.myCurrentObject, app.myPassport);
		rtnValue	:=	app.myPassport.trxCompletedOK;
		
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateEventType(proxyEventType, app.myPassport);
		rtnValue	:=	app.myPassport.trxCompletedOK;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return rtnValue;
epilog
	delete selectedErrors;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
