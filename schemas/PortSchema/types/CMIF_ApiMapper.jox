<Class name="CMIF_ApiMapper" id="1ede54b9-a35e-49d5-8c84-2c921eea7cde">
    <superclass name="CMIF_DotNetWrap"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <Constant name="CUSTOMER_CPL" id="e62b7de1-7bcf-4038-8ebc-ebcc1762e0e5">
        <source>"CentrePort"</source>
        <type name="String"/>
    </Constant>
    <Constant name="CUSTOMER_CUX" id="53374cc9-676c-443e-9386-853bfd3089f3">
        <source>"CuxPort"</source>
        <type name="String"/>
    </Constant>
    <Constant name="CUSTOMER_EUP" id="c031eaa7-927f-455f-94b4-6c98222e23f6">
        <source>"EuroPorts"</source>
        <type name="String"/>
        <text>Not case sensitive, but must match MTNAPIMapper.cs Customer Enum</text>
    </Constant>
    <Constant name="CUSTOMER_NSW" id="a852bd5b-4e6d-4efc-ac6e-40331127018d">
        <source>"NSWPorts"</source>
        <type name="String"/>
    </Constant>
    <ImplicitInverseRef name="myApiMapper" id="3188c407-7e20-4b88-993a-54f917aa2601">
        <embedded/>
        <type name="ApiMapper"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="e2d31d17-84e6-42ea-94af-c021969ecd86">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 July 2022	navlw1	Initial creation tfs 53854 ApiMapper Change Request

*/

vars
	hadException	: Boolean;
	fileName		: String;
	iniValue		: String;
	usePresentation	: Boolean;
begin
	on Exception do self.handleExceptions(exception, hadException);
	create self.myApiMapper transient;
	
	if self.myApiMapper &lt;&gt; null then
		self.myApiMapper.usePresentationClient := self.usePresentationClient;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="750700ad-665c-44c9-ae25-76bc167869b3">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 July 2022	navlw1	Initial creation tfs 53854 ApiMapper Change Request

*/

vars

begin
	delete self.myApiMapper;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getClientNameFromSystem" id="02789199-95ab-4fd0-ba81-ef18c8a3a53f">
        <options>4</options>
        <source>getClientNameFromSystem(): String typeMethod;
/*

Purpose:			Used to pass in the 'customer' to the transform methods

Parameters:			

Return Value:		

Date			Who		Reason
15 August 2023	navmd1	Initial creation TFS 59811
23 October 2024	navdap1	MTN-14005 NSW | OnePort Integration - Requested Changes
25 Nov 2025		navdap1	MTN-36569 CPL | Reefer Runner Integration
*/

vars
	root : CM_Root;
begin
	root := app.myRoot;

	if root.isClientEuroPorts then
		return CMIF_ApiMapper.CUSTOMER_EUP;
	elseif root.isClientCuxport then
		return CMIF_ApiMapper.CUSTOMER_CUX;
	elseif root.isClientNSWPorts then			// MTN-14005
		return CMIF_ApiMapper.CUSTOMER_NSW;		// MTN-14005
	elseif root.isClientCentrePort then			// MTN-36569
		return CMIF_ApiMapper.CUSTOMER_CPL;		// MTN-36569
	endif;
	
	return null;	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="transformIncomingMessage" id="e6375b6e-95e7-49be-96b9-ce15ec760f57">
        <source>transformIncomingMessage(_scopeOperatorId : String; _messageName : String; _messageData : String; _httpVerb : String; _errors : String output) : String;
/*

Purpose: To make the call to the API Mapper which is a .net dll. The API Mapper will Map the Message Data into a readable format,
so that our Api can process the request. At the moment we can handle PUT and Post Requests			

Parameters:			

Return Value:		

Date			Who		Reason
20 July 2022	navlw1	Initial creation tfs 53854 ApiMapper Change Request
10 July 2024	navmd1	TFS 65034 Suppress errors for customised methods that don't get transformed via the mapper dll

*/

vars
	hadException 	: Boolean;
	body 			: StringUtf8;
	errorsUtf8		: StringUtf8;
begin
	on Exception do self.handleExceptions(exception, hadException);
	// Check creation has been successful
	if self.myApiMapper = null then
		app.writeLog(method.qualifiedName &amp; " myApiMapperPostRequest is null", LogERROR);
		return _messageData;
	endif;
	
	// do the work
	body := self.myApiMapper.processIncomingMessage(_scopeOperatorId.StringUtf8, _messageName.StringUtf8, _messageData.StringUtf8, _httpVerb.StringUtf8, errorsUtf8);
	_errors := errorsUtf8.String;
	
	if _errors &lt;&gt; "" or hadException then
		if _errors.pos("Returning unmodified message", 1) &gt; 0 then
			// Consider these ones 'warnings' that we don't really care about logging normally
			app.writeLog(method.qualifiedName &amp; " Message Data: " &amp; _messageData.StringUtf8.String, LogDEBUG);
			app.writeLog(method.qualifiedName &amp; " result=" &amp; "|" &amp; _errors &amp; "|" &amp; _scopeOperatorId &amp; "|", LogDEBUG);
			_errors := null;	// Nothing to see here, as you were
		else
			app.writeLog(method.qualifiedName &amp; " Message Data: " &amp; _messageData.StringUtf8.String, LogERROR);
			app.writeLog(method.qualifiedName &amp; " result=" &amp; "|" &amp; _errors &amp; "|" &amp; _scopeOperatorId &amp; "|", LogERROR);
		endif;
		return _messageData;
	endif;
	
	return body.String;
	
epilog

end;</source>
        <Parameter name="_scopeOperatorId" type="String"/>
        <Parameter name="_messageName" type="String"/>
        <Parameter name="_messageData" type="String"/>
        <Parameter name="_httpVerb" type="String"/>
        <Parameter name="_errors" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="transformOutgoingMessage" id="edf4d783-6796-4879-9648-f863eae31b09">
        <source>transformOutgoingMessage(_customerId : String; _messageName : String; _messageData : String; _httpVerb : String; _errors : String output) : String;
/*

Purpose: To make the call to the API Mapper which is a .net dll. The API Mapper will Map the Message Data into a readable format,
so that sn external Api can process the request. At the moment we can handle PUT and POST Requests			

Parameters:			

Return Value:		

Date			Who		Reason
16 March 2023	navmd1	TFS 57092 EUP Transform Outgoing CAMS messages before sending to an external API endpoint
10 July 2024	navmd1	TFS 65034 Suppress errors for customised methods that don't get transformed via the mapper dll

*/

vars
	hadException 	: Boolean;
	body 			: StringUtf8;
	errorsUtf8		: StringUtf8;
begin
	on Exception do self.handleExceptions(exception, hadException);
	// Check creation has been successful
	if self.myApiMapper = null then
		app.writeLog(method.qualifiedName &amp; " myApiMapper is null", LogERROR);
		return _messageData;
	endif;
	
	// do the work
	body := self.myApiMapper.processOutgoingMessage(_customerId.StringUtf8, _messageName.StringUtf8, _messageData.StringUtf8, _httpVerb.StringUtf8, errorsUtf8);
	_errors := errorsUtf8.String;
	
	if _errors &lt;&gt; null or hadException then
		if _errors.pos("Returning unmodified message", 1) &gt; 0 then
			// Consider these ones 'warnings' that we don't really care about logging normally
			app.writeLog(method.qualifiedName &amp; " Message Data: " &amp; _messageData.StringUtf8.String, LogDEBUG);
			app.writeLog(method.qualifiedName &amp; " result=" &amp; "|" &amp; _errors &amp; "|" &amp; _customerId &amp; "|", LogDEBUG);
			_errors := null;	// Nothing to see here, as you were
		else
			app.writeLog(method.qualifiedName &amp; " Message Data: " &amp; _messageData.StringUtf8.String, LogERROR);
			app.writeLog(method.qualifiedName &amp; " result=" &amp; "|" &amp; _errors &amp; "|" &amp; _customerId &amp; "|", LogERROR);
		endif;
		
		return _messageData;
	endif;
	
	return body.String;
	
epilog

end;</source>
        <Parameter name="_customerId" type="String"/>
        <Parameter name="_messageName" type="String"/>
        <Parameter name="_messageData" type="String"/>
        <Parameter name="_httpVerb" type="String"/>
        <Parameter name="_errors" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
