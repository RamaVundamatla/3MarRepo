vars

begin
	self.callbackMethod := _methodName;
epilog

end;</source>
        <Parameter name="_methodName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setShowCaptions" id="638e6b0e-3a0d-4986-8872-76c69970030a">
        <updating/>
        <source>setShowCaptions(_showCaptions: Boolean) updating;
/*

Purpose:			This method is called when we do the "Show Caption" in CMUI_Toolbar

Parameters:			

Return Value:		

Date		Who		Reason
05/06/2024	navkc1 CR 63736 Task 63737: Jade - New Filter Control

*/

vars
	tmpHeight	: Real;
	control		: Control;
	btn			: CMUI_ToolbarButtonTblFilter;
begin
	if _showCaptions then
		tmpHeight := CMUI_Toolbar.ControlHeightWithCaptions;
	else
		tmpHeight := CMUI_Toolbar.ControlHeightWithoutCaptions;
	endif;
	
	self.height := tmpHeight;
	
	/* This should ideally only have 2 children
		1) Textbox
		2) Clear button
	   We only want to show the caption of (2)
	*/
	foreach control in self.allControlChildren do
		
		if not control.isKindOf(CMUI_ButtonForToolbarTblFilter) then
			continue;
		endif;
		
		btn := control.CMUI_ButtonForToolbarTblFilter.myToolbarButtonTblFilter;
		
		if btn &lt;&gt; null then
			btn.setShowCaptions(_showCaptions);
		endif;
		
	endforeach;
epilog

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSkipControlFilter" id="ad23f1e3-9534-4fdd-8476-66f48e4ca6d1">
        <updating/>
        <source>setSkipControlFilter(_skip : Boolean) updating;
/*

Purpose:			If set to true, this control will skip the "doTableFilter" method, and only do "doCallBackMethod"
					It will still do the "doClearFilter" method to make all the rows visible again.	If the form you are working on has a label to display number of rows visible, you can use the numOfRowVisisble

Parameters:			

Return Value:		

Date		Who		Reason
//02/08/2024	navkc1 Defect 65489: MTN - Invoice notes audit form filter not filtering as expected

*/

vars

begin
	self.skipControlFilter := _skip;
epilog

end;</source>
        <Parameter name="_skip" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupControl" id="721bcd95-2d6a-48c5-9f60-5ac9528b03e9">
        <updating/>
        <source>setupControl(_table : CM_DataTable; _width : Real) updating;
/*

Purpose:			This basically tell the control which table it should do the filter and
					Set the width if defined
					

Parameters:			

Return Value:		

Date		Who		Reason
18/04/2024	navkc1 CR63736 Task 63737: Jade - New Filter Control

*/

vars

begin
	self.myDataTable := _table;
	
	if _width &lt;&gt; null and not width &lt; 200 then
		self.width := _width;
	endif;
	
	
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
        <Parameter name="_width" type="Real"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="4a6051be-5ed1-4f75-9302-c2c73e2c4977">
        <controlMethod name="Frame::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>sysNotify(frame: Frame input; eventType: Integer; theObject: Object; eventTag: Integer) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2024	navkc1	Initial creation

*/

vars

begin
	if eventType = self.ShowCaptionEvent then
		self.btnClearFilter.height += 5;
	else
		inheritMethod(frame, eventType, theObject, eventTag);
	endif;
	

epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="bb6688de-1bb9-4247-957d-c4b43ae5d1f6">
        <controlMethod name="Frame::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>userNotify(frame: Frame input; eventType: Integer; theObject: Object; eventTag: Integer; showCaption: Boolean) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2024	navkc1	Initial creation

*/

vars
	clearBtn	: CMUI_ButtonForToolbarTblFilter;
begin
	clearBtn := self.btnClearFilter;
	self.backColor := Black;
	if eventType = self.ShowCaptionEvent then
		if clearBtn &lt;&gt; null then
			if showCaption = true then
				self.btnClearFilter.height := 37;
				self.btnClearFilter.width := 37;
				
			else
				self.btnClearFilter.height := 32;
				self.btnClearFilter.width := 32;
			endif;
		endif;
	else
		return;
	endif;
	

epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="showCaption" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="28e073c1-b833-4804-bac5-a93624cc61c1">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/04/2024	navkc1 CR63736 Task 63737: Jade - New Filter Control

*/

vars

begin
	inheritMethod(cntrl, persistCntrl);
	self.buildSelf();
epilog

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
