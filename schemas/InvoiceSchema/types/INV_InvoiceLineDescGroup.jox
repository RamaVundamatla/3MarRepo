    <JadeMethod name="initFilterTable" id="8a8716fe-97ff-4cb5-a5aa-11b70817e747">
        <updating/>
        <source>initFilterTable() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		Query by business unit, when there are more than one present
//
// ---------------------------------------------------------------------------

vars
	entTableDef	: EntTableDef;
	
begin

	entTableDef := app.myController.getEntTableDef(ETDef_InvQuery);
	
	if entTableDef &lt;&gt; null then
		tblSearch.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
		tblSearch.adjustHeight(200);
		// adjust column width for the "Business Unit"
		tblSearch.accessColumn(1).width := 100;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="5cc7edcb-6a59-4df2-873d-d732f576a929">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.allowPrint		:= true;
	self.allowExportCSV	:= true;
	self.allowSearch	:= false;
	// 35872 if more than one business unit, enable business unit search
	if self.cmbBank.listCount &gt; 1 then
		self.allowSearch := true;
	endif;
	self.allowTblDataSearch := true;
	
	self.setNavigatorHeading(self.caption);

	self.useTblThumb := true;
	self.frmDetailsBottom.visible := false;
	self.mnuTblVPrint.enabled	:= true;	
	self.mnuTblVExportCSV.enabled:= true;	
	
	self.initTblThumb();
	self.initTblEntDetail();
	self.clearErrorWarnings();	
	
	self.fldEntDetail.visible := false;
	self.fldEntDetail.useSheetBackColors := true;
	self.fldEntDetail.setDefaultSheetBackColors();
	self.fldEntDetail.initSheetBackColors();
end;</source>
    </JadeMethod>
    <JadeMethod name="initMSG" id="b1033214-af15-484c-b273-94ae1e033cf7">
        <source>initMSG();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theGroupBox : CMUI_MultiSelectGroupBox;
begin
	theGroupBox := self.msgLines;
	theGroupBox.caption := null;
	theGroupBox.distanceFromBottom 	:= 5;
	theGroupBox.distanceFromRight 		:= 5;
	theGroupBox.lockBottom 				:= false;
	theGroupBox.lockRight				:= false;
	theGroupBox.stretchHeight 			:= false;
	theGroupBox.stretchWidth 			:= true;
	theGroupBox.multiSelect 	:= ListBox.MultiSelect_Extended;
	theGroupBox.formDisplayEntryMethodName := "displayLine";
	theGroupBox.availableHeading := app.getErrorString(Available_lines);
	theGroupBox.selectedHeading := app.getErrorString(Selected_lines);
	theGroupBox.myBaseForm	:= self;
	theGroupBox.mySelectedListBox.sorted := false;
	theGroupBox.cnEcResizeContents();
	theGroupBox.readOnly := false;


end;</source>
    </JadeMethod>
    <JadeMethod name="initTblEntDetail" id="4e176b1f-c939-429e-81f3-29da64abd2a2">
        <source>initTblEntDetail();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
begin

	theTable := self.tblEntDetail;
	theTable.warningMethod := 'entTableWarning';

	theTable.stretchToParent := true;
	theTable.optimiseRowHeight := true;
	entTableDef := app.myController.getEntTableDef(ETDef_InvMaintLineGroupEnt);
	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	theTable.hideRowByName (ETRow_InvLineDesc, true);//added by cnwyl
	
	theTable.adjustHeight(200);	
	theTable.optimiseHeadingColumn();
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblThumb" id="b52aaca6-bc43-4645-b861-7d672eb455ba">
        <source>initTblThumb();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTable		: CM_ThumbnailTable;
begin
	theTable := self.tblThumb;
	theTable.clear;
//	theTable.setColumnHeadingsFromDef(ETDef_InvMaintLineGroupEnt, false);

end;</source>
