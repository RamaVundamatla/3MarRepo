    <JadeMethod name="setFilterDefaults" id="fd48245f-87a3-4ba7-b7b4-5b4b9e83c9f6">
        <updating/>
        <source>setFilterDefaults()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	self.filterDateFrom := null;
	self.filterDateTo := null;
	self.filterCargoType := null;
	self.filterOperator := null;
	self.filterTerminalArea := null;
	self.filterLocation := null;
	self.filterTrain := null;
	self.filterVoyage := null;
	self.filterVehicleVisitRecord := null;

epilog

end;</source>
