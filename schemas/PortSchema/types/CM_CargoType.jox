        <updating/>
        <source>setDefaultMeasurementTypes(_weight, _volume : CM_MeasurementType) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/03/2014	cnwdap1		Initial creation PAR #33606 set measurement type references
//
