    <JadeMethod name="cloneReferences" id="d194a294-0adf-4742-bc09-9a8059eb52a1">
        <updating/>
        <source>cloneReferences(_obj: CMQF_WorkOrder; _transient: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting

*/

vars

begin
	inheritMethod(_obj, _transient);
	
	self.allUsers.clear();
	_obj.allUsers.copy(self.allUsers);
	
	self.allWODetailTypes.clear();
	_obj.allWODetailTypes.copy(self.allWODetailTypes);
	
	self.allWOStatus.clear();
	_obj.allWOStatus.copy(self.allWOStatus);
epilog

end;</source>
        <Parameter name="_obj" type="CMQF_WorkOrder"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="7cf30337-b065-4e9a-9c37-cd622d4f991b">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting

*/

vars
	iter 			: Iterator;
	terminal		: CM_Terminal;
	breakOut		: Boolean;
begin
	if (not self.allQueryCriteriaHolders.isEmpty) then
		self.filterSelectorQuery(_collection, _passport);
		return;
	endif;
	
	foreach terminal in self.allTerminals do
		delete iter;
		iter := terminal.allWorkOrders.createIterator();
		self.getWorkOrders(_collection,iter,breakOut,_passport);
	endforeach;
epilog
	
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterSelectorQuery" id="ed3bb1fe-19f7-4f9f-a5bb-60a6ec97ea1d">
        <source>filterSelectorQuery(_collection  : Collection input;
					_passport : CM_Passport) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting

*/

vars
	criteriaHolder 		: CM_QueryCriteriaLineHolder;
	qDef				: CM_QueryDefinition;
	enqController		: CM_EnquiryController;
	queryAgent			: CM_QueryAgentFilter;
begin

	// Special one because we need the copy
	on CM_BreakOutException do app.myQAFilter.xHandlerBreakOut(exception);
	
	queryAgent := app.myQAFilter;
	if queryAgent = null then
		return;
	endif;
	
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.WorkOrder_Query_Type, self.selectorMode];
	queryAgent.createEnqControllerForMode(self.selectorMode, CM_QueryDefinition.WorkOrder_Query_Type, enqController);
	delete enqController.allObjects;
	create enqController.allObjects as _collection.class transient;
	
	foreach criteriaHolder in self.allQueryCriteriaHolders discreteLock do
		enqController.myCriteriaLineHolder := criteriaHolder;
		enqController.doQuery(qDef);
	endforeach;

	enqController.allObjects.copy(_collection);
	
epilog
	if enqController &lt;&gt; null then
		delete enqController.allObjects;
	endif;
	delete enqController;
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="abd6a7b6-8dac-4b8a-bce5-45306deeee69">
        <source>getDisplayStringForAttribute(_attrName: String; _getCalculatedDate: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting

*/

vars
	oid     : String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="ae5cd8ff-856b-4ffe-b331-f4bf1ff47366">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid: String output): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting
*/

vars
	runDate		: Date;
begin
	runDate := app.actualTimeServer().Date;	
	
	if _attrName = ETRow_WorkOrderStatus then
		return self.getWOStatusString(); 
	elseif _attrName = ETRow_WorkOrderType then
		return self.getWOTypeString(); 
	elseif _attrName = ETRow_RequiredByDateFrom then
		return self.fromReqDT.asStringJMT;
	elseif _attrName = ETRow_RequiredByDateTo then
		return self.toReqDT.asStringJMT;
	elseif _attrName = ETRow_WorkOrderId then
		return self.workOrderId; 
	elseif _attrName = ETRow_AllUsers then
		return self.getUsersString(_oid);
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUsersString" id="40a04dbd-05af-4ee7-9f7f-ba6e7397332e">
        <source>getUsersString(_oid:String output) : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting

*/
vars
	user				: CM_User;
	userDict			: CM_UserByCodeDict;
	str					: String;
begin
	
	foreach user in self.allUsers do
		if user = self.allUsers.last then
			_oid := _oid &amp; user.getOidAsString();
			str := str &amp; user.code;
		else
			_oid := _oid &amp; user.getOidAsString() &amp; ',';
			str := str &amp; user.code &amp; ',';
		endif;
	endforeach;
	
	if str = null then
		str := Any_String;
	endif;
	
	return str;
			
end;</source>
        <access>protected</access>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWOStatusString" id="db5faac8-25c0-4cbd-9046-071d567b4482">
        <source>getWOStatusString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting

*/

vars
	str,
 	statusStr	: String;
	idx			: Integer;
	todo		: CM_ToDoTaskDesc;
begin
	foreach idx in self.allWOStatus do
		statusStr := app.workOrderStatusEnumToString(idx);
		if str = null then
			str := str &amp; statusStr;
		else
			str := str &amp; Comma &amp; statusStr;
		endif;
	endforeach;
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWOStatusStringArray" id="1e3f5fbe-dbeb-431b-baed-78e63cf1a17d">
        <source>getWOStatusStringArray( _strArray : StringArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting

*/
vars
	index	: Integer;
	str		: String;
	
begin
	foreach index in self.allWOStatus do : wo_loop
		str := app.workOrderStatusEnumToString(index);
		if str = null then
			continue wo_loop;
		endif;
		_strArray.add( str );
	endforeach wo_loop;
epilog
	
end;
</source>
        <Parameter name="_strArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getWOTypeString" id="3143f6de-4221-4234-9eda-1b6c870906a1">
        <source>getWOTypeString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2023	navhl20	Initial creation

*/

vars
	str,
 	typeStr		: String;
	idx			: Integer;
	todo		: CM_ToDoTaskDesc;
begin
	foreach typeStr in self.allWODetailTypes do
		if str = null then
			str := str &amp; typeStr;
		else
			str := str &amp; Comma &amp; typeStr;
		endif;
	endforeach;
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWOTypeStringArray" id="56ff2235-2a34-4cf5-9adb-d7d91ee72bda">
        <source>getWOTypeStringArray( _stringArray : StringArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2023 navhl20 Defect 57144: Send to Report showing Error

*/
vars
	str					: String;
	transactionType		: CM_TransactionType;
	
begin
	foreach str in self.allWODetailTypes do : wo_loop
		if str = null then
			continue wo_loop;
		endif;
		_stringArray.add( str );
	endforeach wo_loop;
epilog
	
end;
</source>
        <Parameter name="_stringArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getWorkOrders" id="1a02c863-482b-41d0-8cb6-3a3ac8b97e9d">
        <updating/>
        <source>getWorkOrders(_collection: Collection input; _iter : Iterator input; _breakOut : Boolean output; _passport : CM_Passport)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting

*/

vars
	wo			: CM_WorkOrder;
	terminal	: CM_Terminal;
begin
	while _iter.next(wo) do
		if self.fromReqDT &lt;&gt; null then
			if wo.requiredByDT.Date &lt; fromReqDT then
				continue;
			endif;
		endif;
		
		if self.toReqDT &lt;&gt; null then
			if wo.requiredByDT.Date &gt; toReqDT then
				continue;
			endif;
		endif;
		
		if self.includesObject(wo, _passport, _breakOut) then
			if not _collection.includes(wo) then
				_collection.add(wo);
			endif;
		endif;
		
		if _breakOut then
			return;
		endif;
	endwhile;
epilog

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_iter" type="Iterator" usage="input"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="e7ab87a0-a6b8-4134-894e-fe346966c50f">
        <updating/>
        <source>includesObject(_wo			: CM_WorkOrder; 
				_passport	: CM_Passport; 
				_breakOut	: Boolean output): Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting
*/
vars
	wod 	: CM_WorkOrderDtl;
	count 	: Integer;
begin
	if self.needFilterUsers then
		if self.allUsers[_wo.userCode] = null then
			return false;
		endif;
	endif;
	
	if self.workOrderId &lt;&gt; null then
		if  not _wo.id = self.workOrderId then
			return false;
		endif;
	endif;
	
	if self.allWOStatus.isNotEmpty() then
		if self.allWOStatus.includes(_wo.taskStatus) = null then
			return false;
		endif;
	endif;
	
	if self.allWODetailTypes.isNotEmpty() then
		foreach wod in _wo.allWoDtls do
			if self.allWODetailTypes.includes(wod.getTypeDescription())= null then
				count := count + 1;
			endif;
		endforeach;
		if count = _wo.allWoDtls.size then
			return false;
		endif;
	endif;
	
	return true;

end;


</source>
        <access>protected</access>
        <Parameter name="_wo" type="CM_WorkOrder"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
