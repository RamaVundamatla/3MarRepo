    <JadeMethod name="getFutureMoveForTI" id="fcff3bb8-1c32-48de-85e6-034f6d8c7cda">
        <source>getFutureMoveForTI(_ti : CM_TrackedItem) : CM_FutureMoveQueued;
// ---------------------------------------------------------------------------
// Created:     17 September 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// PAR 18970
// ---------------------------------------------------------------------------

vars
	fm : CM_FutureMoveQueued;
begin
	foreach fm in self.myEntry.allQueuedFutureMoves  discreteLock do
		if fm.myTrackedItem = _ti then
			return fm;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_FutureMoveQueued"/>
    </JadeMethod>
