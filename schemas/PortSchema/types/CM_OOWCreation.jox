        <source>setForCreate(_pxyMe : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:		05 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.init(_pxyMe.myBay, _pxyMe.ordinalDeck,_pxyMe.orderType,_pxyMe.order,_pxyMe.getIs40());
	self.setJobSheet(_pxyMe.myCraneJobSheet);
end;</source>
        <Parameter name="_pxyMe" type="SelfType"/>
    </JadeMethod>
