    <JadeMethod name="getQueueCriteriaSingleCMIF" id="882c2603-57a0-4370-8b77-ec83f1255235">
        <source>getQueueCriteriaSingleCMIF(_cmifArray : CMIF_Array input; _criteriaType : CM_YACriteriaType; _value : Any);
/*

Purpose:			Update/add transient maintenance object for given criteria type

Parameters:			

Return Value:		

Date				Who		Reason
01 October 2025		jlizm1	Initial creation MTN 35861 RTQueue configuration - cargo attribute criteria

*/

vars
	cmifCriteria : CMIF_YACriteriaPriority;
	itemCode : String;
	proxyCriteria: CM_YARTQueueCriteria;

begin
	// Create an Add Criteria request
	
	create proxyCriteria transient;
	itemCode := _criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	proxyCriteria.setProxy(_criteriaType, _value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	cmifCriteria.setFlag(true, false, false);
	_cmifArray.add(cmifCriteria);
	
epilog

end;</source>
        <Parameter name="_cmifArray" type="CMIF_Array" usage="input"/>
        <Parameter name="_criteriaType" type="CM_YACriteriaType"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="getQueueTask" id="16684820-ca9c-4eec-b5e3-31362e03e808">
        <source>getQueueTask(_ti: CM_TrackedItem): CM_RTQueueTask;
//21 December 2010	cnwdw1	
// 
vars
	queueTask: CM_RTQueueTask;
	queueEntry: CM_RTQueueEntry;
	tasks	: CM_RTQueueTaskArray;
	invalid : Boolean;
	edition : Integer;
begin
	
	on Exception do app.handleDeletedObject( exception, _ti, invalid );
	edition := _ti.edition;
	if invalid then
		return null;
	endif;
	
	queueTask := _ti.queueTask;
	if queueTask &lt;&gt; null then
		return queueTask;
	endif;
	
	if queueTask = null and _ti.isQueued then
		create tasks transient;
		self.getTerminal.radioTelemetry.masterQueue.getAllTasks(tasks);
		foreach queueTask in tasks do
			if queueTask.ti = _ti then
				return queueTask;
			endif;
		endforeach;
	endif;
					
	return null;

epilog
	delete tasks;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
