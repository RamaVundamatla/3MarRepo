<Class name="CMIF_JsonAddressEUP" id="3f30f38a-1dca-4bcc-9cd1-cacdd6a172a8">
    <superclass name="CMIF_JsonTransform"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
