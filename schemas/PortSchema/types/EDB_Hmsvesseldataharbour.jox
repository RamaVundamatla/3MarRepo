    <JadeMethod name="edb_RemarksPilotOnly" id="abb8a58f-3cf0-4a06-b90a-858320ab629f">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>edb_RemarksPilotOnly(set:Boolean; value:String io) mapping, updating, subschemaHidden;
begin
	if set then
		_setVirtualString( 'remarksPilotOnly',20, value );
	else
		value := _getVirtualString( 'remarksPilotOnly',20);
	endif;
end;</source>
