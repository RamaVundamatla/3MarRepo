    <JadeMethod name="canAutoResequenceOnPickup" id="7c7be463-8069-424e-a0f3-e36bb2bbe7dc">
        <source>canAutoResequenceOnPickup(): Boolean;

/*

Purpose:	par 29846		

Parameters:			

Return Value:		


Date		Who		Reason
12 July 2012	cnwrd1	Initial creation

*/

vars

	config 			:CM_RTVehicleConfig;
	gotException	:Boolean;
	result			:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, config, gotException);
	
	config := self.myTerminal.getRTVehicleConfigForObject (self);
	
	if config &lt;&gt; null then
		result := config.autoResequenceJobs;
	endif;
	
	// will return false if no config object
	return result;
epilog

end;</source>
