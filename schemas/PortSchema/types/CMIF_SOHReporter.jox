    <JadeMethod name="calculateAgeVolumes" id="ea45a4fa-2e44-4ae3-a552-833ebdab72a9">
        <updating/>
        <source>calculateAgeVolumes(_blockLength : Integer; _ageType : String) updating;
// ---------------------------------------------------------------------------
// Created:     19 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	tempVolume		: Decimal[16,4];
	tiSet			: CM_TISet;
	iter			: Iterator;
	ti				: CM_TrackedItem;
	oldestTIAge,
	age,
	tiAge,
	tempQuantity,
	tempAge,
	i				: Integer;
	quantityPropName,
	volumePropName,
	datePropName 	: String;
	periodDate		: Date;
begin
	oldestTIAge := null;
	tiSet := self.mySOHLocation.allTrackedItems;
	iter := tiSet.createIterator;
	periodDate := self.baseDate;
	//populate datePeriod attributes
	foreach i in 1 to NumberOfBlocks do
		age := age + _blockLength;
		self.allAges[i] := age;
	endforeach;
	
	while iter.next(ti) do
		tiAge := ti.getAgeForType(self.baseDate, _ageType);
		if oldestTIAge = null or tiAge &gt; oldestTIAge then
			oldestTIAge := tiAge;
		endif;
		foreach i in 1 to NumberOfBlocks do	
			tempAge := self.allAges[i];
			if tiAge &lt;= tempAge or i = NumberOfBlocks then
				self.allQuantities[i] := self.allQuantities[i] +1;
				self.allVolumes[i] := self.allVolumes[i] + ti.getMyTotalVolume;
				break;
			endif;
		endforeach;
	endwhile;

	// PAR - 11185 - added + 1 day
	self.oldestTIDate := self.baseDate - oldestTIAge + 1;

epilog
	delete iter;
end;</source>
        <Parameter name="_blockLength" type="Integer"/>
        <Parameter name="_ageType" type="String"/>
    </JadeMethod>
    <JadeMethod name="cloneReferences" id="e87f1551-50b0-4eaf-ac32-bc18879e8382">
        <updating/>
        <source>cloneReferences(_obj : CMIF_SOHReporter) updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myLot			:= _obj.myLot;
	self.myProduct		:= _obj.myProduct;
	self.mySOHLocation	:= _obj.mySOHLocation;
	self.mySupplier		:= _obj.mySupplier;

end;</source>
        <Parameter name="_obj" type="CMIF_SOHReporter"/>
    </JadeMethod>
    <JadeMethod name="create" id="fae6b8a5-b54f-4bb1-a5d2-1fb3031bc924">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     16 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	i		: Integer;
begin
	create self.allAges transient;
	create self.allVolumes transient;
	create self.allQuantities transient;
	
	//need to init the subscripts for some reason ?!
	foreach i in 1 to NumberOfBlocks do
		self.allAges[i] := 0;
		self.allVolumes[i] := 0;
		self.allQuantities[i] := 0;
	endforeach;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="date1" id="dce8c10b-e521-4b7e-a4de-75729601352b">
        <methodInvocation>mapping</methodInvocation>
        <source>date1(set: Boolean; _value: Date io) mapping;
// ---------------------------------------------------------------------------
// Created:     16 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		
	else
		_value := self.baseDate - self.allAges[1];
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Date" usage="io"/>
    </JadeMethod>
