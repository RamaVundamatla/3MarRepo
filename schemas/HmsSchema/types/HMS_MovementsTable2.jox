    <JadeMethod name="showMovementsForAllVoyages" id="442188cd-3531-4261-a880-7e6ff0b7befc">
        <updating/>
        <source>showMovementsForAllVoyages() updating;

vars
	count: 	Integer;
begin
	showAllVoyages:=true;
	// This method sets the visible property on all rows so that all the 
	// movements for all voyages are visible
	count:=self.fixedRows+1;
	while count&lt;=self.rows do
		self.rowVisible[count]:=true;
		count:=count+1;
	endwhile;

	// Scroll table to this position
	if self.row &gt; self.fixedRows then
		self.topRow:=self.fixedRows + 1;
	else
		self.topRow:= self.fixedRows;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showMovementsForCurrentVoyage" id="97f89e90-e4e3-4c82-aef3-da446e67138f">
        <updating/>
        <source>showMovementsForCurrentVoyage() updating;

vars
	count	: Integer;
	obj		: Object;
begin
	showAllVoyages:=false;
	// This method sets the visible property on all rows so that only the 
	// movements for the current voyage are visible
	count:=self.fixedRows+1;
	while count &lt;= self.rows do
		obj := self.accessRow(count).itemObject;
		if obj &lt;&gt; null then
			if obj.CMIF_HMS_WorkingMovement.myClonedVoyage=currentVoyage then
				self.rowVisible[count]:=true;
			elseif obj.CMIF_HMS_WorkingMovement.myWorkingVoyage=currentVoyage then
				self.rowVisible[count]:=true;
			else
				self.rowVisible[count]:=false;
			endif;
		endif;
		count:=count+1;
	endwhile;
	self.paintStripes();
end;</source>
    </JadeMethod>
