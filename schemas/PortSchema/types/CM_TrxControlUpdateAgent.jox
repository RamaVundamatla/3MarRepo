        <updating/>
        <source>trxUpdateWORelReqToPending(_manifestNumber : String; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/10/2023	navdap1		Initial creation TFS 58926 EUP | Calloff Update - Replace/ Create Logic and DB Load
//	15/07/2025	navcs2	MTN-35210 Add Deferred Updates for WO Transaction During Transport Manifest and Call-Off Loading to Reduce Deadlocks
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Set to use deffered updates
	_passport.useTITransactionDeferUpdate := true;							// 15/07/2025	navcs2	MTN-35210
	_passport.useWOTransactionDeferUpdate := true;							// 15/07/2025	navcs2	MTN-35210	
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateWORelReqToPending(_manifestNumber, _passport);

epilog
	if _passport.noErrors() then				// 15/07/2025	navcs2	MTN-35210
		_passport.doDeferredUpdates();			// 15/07/2025	navcs2	MTN-35210	
	endif;										// 15/07/2025	navcs2	MTN-35210
	
	self.finaliseActivityWithPassport(_passport);
end;</source>
