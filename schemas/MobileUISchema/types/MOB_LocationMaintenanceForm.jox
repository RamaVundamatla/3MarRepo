vars

begin
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="hasUnsavedChanges" id="38610a2b-9288-45f2-8470-73902a1ce5d0">
        <source>hasUnsavedChanges(): Boolean;
// --------------------------------------------------------------------------------
// Created:		04 June 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlllerObj	: CM_LocationsController;
	
begin
	if self.aAllRemovedAllocations.cnEcIsNotEmpty() then
		return true;
	endif;
	
	controlllerObj	:=	self.aMyLocationsController;
	
	if controlllerObj &lt;&gt; null then
		if controlllerObj.status = LC_Status_Open
		and not optAvailable.value then
			return true;
		endif;
		
		if controlllerObj.status = LC_Status_Closed
		and not optClosed.value then
			return true;
		endif;
	endif;
	
	return inheritMethod();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setLocationStr" id="5216f88d-8ab7-4a58-a54e-32320e4ea4c2">
        <updating/>
        <source>setLocationStr(_strLoc : String)updating;

vars

begin
	aLocation := _strLoc;
end;
</source>
        <Parameter name="_strLoc" type="String"/>
