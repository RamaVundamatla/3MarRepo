    <JadeMethod name="doBtnCCModeDischClick" id="97ab8d5b-287c-4831-8f0e-276e4430e750">
        <updating/>
        <source>doBtnCCModeDischClick() updating;
/*
Purpose:			
Date		Who		Reason
24 June 2011	cnwab1	Initial creation
*/

vars
	realROROController : CM_VoyageROROController;
	itemLayout : CM_DeckItemLayout;
	theReturn : Integer;
	theLCs : CM_LCSet;
	obj : Object;
begin
	create theLCs transient;

	foreach obj in self.myROROLocnDrawingController.allSelectedObjects  discreteLock  where obj.isKindOf(CM_LocationsController) do
	
		theLCs.add(obj.CM_LocationsController);
	endforeach;



	while true do
		app.myTrxCA.trxCreateRORODischargeCCs(theLCs, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("RORO Colour Codings", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;



epilog
	delete theLCs;


end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnCCModeErase" id="f67f69c5-1a13-4df6-aaaf-f8076873f538">
        <updating/>
        <source>doBtnCCModeErase() updating;
/*
Purpose:			
Date			Who		Reason
28 June 2011	cnwab1	Initial creation
13/08/2012		cnwcs5	par 29124
*/

vars
	lc			: CM_LocationsController;	// par 29124 Aug 2012
	theLCs 		: CM_LCSet;
	obj 		: Object;
	isLoad 		: Boolean;
	theReturn 	: Integer;
begin
	create theLCs transient;
	
	isLoad := (self.myROROLocnDrawingController.modeView=ShpDisplayMode_ColCodeLoad);
	
	foreach obj in self.myROROLocnDrawingController.allSelectedObjects  discreteLock do
		if obj.isKindOf(CM_LocationsController) then
			theLCs.add(obj.CM_LocationsController);
		endif;
	endforeach;

	while true do
		app.myTrxDA.trxDeleteRORORequests(theLCs, isLoad, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			// remove the controls ...
			if isLoad then													// par 29124 Aug 2012
				foreach lc in theLCs do										// par 29124 Aug 2012
					self.doRemoveSlotRemarks (lc.CM_ROROSlotController);	// par 29124 Aug 2012
				endforeach;													// par 29124 Aug 2012
			endif;															// par 29124 Aug 2012
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Erase Requests", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

epilog
	delete theLCs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnCargoEnquiryAll" id="0efcea2b-b8cb-4a78-8c76-40f604367843">
        <source>doBtnCargoEnquiryAll(_edit : Boolean);
/*
Date		    Who			Reason
12 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars	
	tiSet : ObjectArray;
	masterTI : CM_TrackedItem;
begin
	
	create tiSet transient;
	
	self.getAllTIs(tiSet);	
	//self.getSelectedTIs(tiSet);				//only the ones selected within the side view form
	
	tiSet.removeInvalidObjects();
	tiSet.removeDuplicateObjects();
	
	if tiSet.isEmpty() then		
		app.msgBox(app.getErrorString(Select_some_cargo_enquire), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);		
		return;
	endif;
	
	masterTI := tiSet.first().CM_TrackedItem;	
	self.myAssistant.showCargoEnquiryForTIs(masterTI,tiSet,self.myMasterMenuAction,_edit);
epilog
	
	delete tiSet;
end;</source>
        <Parameter name="_edit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBtnCargoEnquirySelected" id="b393152d-f094-4939-8ab3-bf5fb224aa3a">
        <source>doBtnCargoEnquirySelected(_edit : Boolean);
/*
Date		    Who			Reason
12 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars	
	tiSet : ObjectArray;
	masterTI : CM_TrackedItem;
begin
	
	create tiSet transient;
	
	//self.getSelectedCellsTIs(tiSet);	
	self.getSelectedCellsTIs(tiSet);				//only the ones selected within the side view form
	
	tiSet.removeInvalidObjects();
	tiSet.removeDuplicateObjects();
	
	if tiSet.isEmpty() then		
		app.msgBox(app.getErrorString(Select_some_cargo_enquire), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);		
		return;
	endif;
	
	masterTI := tiSet.first().CM_TrackedItem;	
	self.myAssistant.showCargoEnquiryForTIs(masterTI,tiSet,self.myMasterMenuAction,_edit);
epilog
	
	delete tiSet;
end;
</source>
        <Parameter name="_edit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBtnCargoErase" id="0d9c3dbd-1ab2-4e74-b3a7-6f77d9e5b0fc">
        <updating/>
        <source>doBtnCargoErase() updating;
/*
Date		Who		Reason
26 July 2012	cnwmc5	Initial creation - par 30018

*/

vars	
	tiSet : ObjectArray;
	masterTI : CM_TrackedItem;
begin
	create tiSet transient;
	
	self.getSelectedCellsTIs(tiSet);
	
	tiSet.removeInvalidObjects();
	tiSet.removeDuplicateObjects();
	
	if tiSet.isEmpty() then		
		app.msgBox(app.getErrorString(Select_some_cargo_enquire), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);		
		return;
