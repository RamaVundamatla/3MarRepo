    <JadeMethod name="doFormLoad" id="48871d4d-a57e-475b-8b97-2a52c71971db">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		01 August 2000 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	parameterNameArray	: StringArray;

begin
	centreWindow();
	inheritMethod();

	if self.aIsNewEntry then
		self.caption	:=	$CNEC_CREATE($CNEC_REPORT_PARAMETER);
	else
		self.caption	:=	$CNEC_EDIT($CNEC_REPORT_PARAMETER);
	endif;

	create parameterNameArray transient;
	global.cnEcGetReportParameterNames(self.aReportFormName, parameterNameArray);
	txtDescription.text	:=	self.aDescription.trimBlanks();
	cmbName.listCollection(parameterNameArray, false, 0);
	cmbName.listIndex	:=	cmbName.findStringExact(1, self.aParameterName.trimBlanks());
	txtSequence.text	:=	self.aSequence.String;
	txtDisplay.text		:=	self.aDisplayValue;

	if self.aIsValueList then
		optClass.value		:=	true;
	else
		optPrimitive.value	:=	true;
	endif;

	self.doLoadTypes();
	cmbType.listIndex	:=	cmbType.findString(1, self.aParameterType);
epilog
	delete parameterNameArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="046a53c0-fb43-4031-b026-a047e1082c68">
        <updating/>
        <source>doFormUpdate(pIsDelete: Boolean): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		01 August 2000 by cnwdad1
//
// Purpose:		Standard form update method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.doValidateDetails() then
		self.aParameterName	:=	cmbName.text.trimBlanks();
		self.aDisplayValue	:=	txtDisplay.cnEcString();
		self.aParameterType	:=	cmbType.text.trimBlanks();
		self.aSequence		:=	txtSequence.cnEcInteger();
		self.aIsValueList	:=	optClass.value;
	endif;
epilog
	return self.doShowError();
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadTypes" id="7f4fee3c-9251-4b23-b5bb-33d0ac831568">
        <updating/>
        <source>doLoadTypes() updating, protected;

vars
	typesColl	: ClassColl;

begin
	cmbType.clear();

	if optPrimitive.value then
		cmbType.addItem("Boolean");
		cmbType.addItem("Date");
		cmbType.addItem("Decimal");
		cmbType.addItem("Integer");
		cmbType.addItem("Real");
		cmbType.addItem("String");
		cmbType.addItem("Time");
	else
		create typesColl transient;
		global.cnEcGetReportParameterTypes(typesColl);
		cmbType.listCollection(typesColl, false, 0);
	endif;
epilog
	delete typesColl;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doValidateDetails" id="d546b3b7-171f-4c67-be9f-0aaba02cd4f8">
        <updating/>
        <source>doValidateDetails():Boolean updating, protected;


begin
	if cmbName.text.trimBlanks() = null then
		self.setErrorMessage("Please enter the parameter name.");
		return false;
	elseif not self.isValidParameterNameLength(cmbName.text.trimBlanks()) then
		// The error message will already have been set by the above (inherited) validation method.
		return false;
	endif;

	if txtSequence.text.trimBlanks() = null then
		self.setErrorMessage("Please enter the sequence number.");
		return false;
	endif;

	if cmbType.listIndex = CNEC_NULL_INDEX then
		self.setErrorMessage("Please select the Type of the parameter.");
		return false;
	endif;

	if txtDisplay.cnEcString() = null then
		txtDisplay.text	:=	cmbName.text.trimBlanks();
	endif;

	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="optClass_click" id="ab14f32d-a7f7-4fe3-8a49-268b998dba30">
        <controlMethod name="OptionButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optClass_click(optionbutton: OptionButton input) updating;
/*
	Changed On	Changed By	Reason
	----------	----------	--------------------------------------------------------------------------------
	2/11/1998	Darrell		Changed to set focus on type combobox after a type is selected.
*/
vars

begin
	app.mousePointer	:=	Busy;
	self.doLoadTypes();
	cmbType.setFocus();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="optPrimitive_click" id="6d6756d3-e5bf-4b99-8e11-28f10387d1c9">
        <controlMethod name="OptionButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optPrimitive_click(optionbutton: OptionButton input) updating;
/*
	Changed On	Changed By	Reason
	----------	----------	--------------------------------------------------------------------------------
	2/11/1998	Darrell		Changed to set focus on type combobox after a type is selected.
*/
vars

begin
	app.mousePointer	:=	Busy;
	self.doLoadTypes();
	cmbType.setFocus();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
</GUIClass>
