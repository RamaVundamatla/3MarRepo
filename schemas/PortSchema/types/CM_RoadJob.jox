    <JadeMethod name="getUnusedReleaseByAnyIdWle" id="c7b33e17-f16c-437c-b207-8cd17eaaef46">
        <source>getUnusedReleaseByAnyIdWle():CM_WorkListEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 November 2015	cnwndl1	Initial creation	Par 37084

	This is for the Steinweg Auto Gate Out.
	We may have created a release by any id at Auto Gate In that we no longer want to use.
	This allows us to find and delete it, so it doesn't stop us from gating out..

*/

vars

	iter : Iterator;
	wle : CM_WorkListEntry;
	request : CM_Request;
	bulkRel : CM_BulkRelease;

begin

	iter := self.workListEntries.createIterator;
	while iter.next( wle ) do
		if wle.isReceipt then
			continue;
		endif;
		if wle.status = WLE_COMPLETED then
			continue;
		endif;
		if wle.myTrackedItem &lt;&gt; null then
			continue;
		endif;
		request := wle.myRequest;
		if request = null or not request.isKindOf( CM_DeliveryRequest ) then
			continue;
		endif;
		if not request.CM_DeliveryRequest.isAnyId then
			continue;
		endif;
		// Ok we have a Release by Id that has no associated cargo, and is not actioned
		// it is for an 'any id' release, so can be deleted.
		return wle;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getVehicleReleasedLocalTZ" id="9adafcc7-869b-4601-b0fd-799aa87b3c36">
