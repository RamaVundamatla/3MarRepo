        <source>isOperator_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars

	operator : CM_Operator;

begin

	// Return regardless.
	if self.operatorCode = null then
		return true;
	endif;
	
	operator := app.myRoot.allOperators[self.operatorCode];
	
	if operator = null then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.matches(operator);


end;</source>
