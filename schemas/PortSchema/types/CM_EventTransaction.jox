    <JadeMethod name="validateUpdate" id="144d7609-1270-46b2-92f5-0e16ec0a7fe7">
        <source>validateUpdate(_passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	12 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.dateTime = null or (not self.dateTime.isValid) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'dateTime (' &amp; self.dateTime.String &amp; ') is invalid');
	endif;
	
	if self.myEventType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myEventType is null');
	endif;
	
	if self.myRoot = null and (self.myTerminal = null and not app.myPassport.useEventDeferUpdate) then //30/05/2025	navkc1 JIRA MTN 34639 If it's using defered update, then it's fine the terminal is null. It'll be set in the defered update anyway
		app.raiseUnexpectedProgramError(class.name, method.name, 'Root and terminal reference are both null');
	endif;
	
	if self.myRoot &lt;&gt; null and self.myTerminal &lt;&gt; null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Both root and terminal references are populated. Only one or the other should be populated based on whether the terminal is currently known.');
	endif;
	
	if self.type = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Type is null');
	endif;
	
	if self.type &lt;&gt; self.myEventType.type then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Type is different from myEventType.type!');
	endif;
	

end;

</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
