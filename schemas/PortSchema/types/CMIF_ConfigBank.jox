    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="cashInvoiceType" id="87e8ff48-1857-497f-b094-fc6d8fe05482">
        <embedded/>
        <type name="CM_InvoiceDesc"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="cashRoundInvLineType" id="96b3582d-a06d-4aa0-955a-7ba24ee85279">
        <embedded/>
        <type name="CM_InvoiceLineDesc"/>
    </ImplicitInverseRef>
