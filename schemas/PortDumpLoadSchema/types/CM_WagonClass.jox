<Class name="CM_WagonClass">
    <JadeMethod name="importPLXMLReference" id="7cae9a76-c916-40a5-af2c-ed5803a65b46">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_WagonClass::myRoot.name then
		return app.myRoot;
	else
		return null;
	endif;
end;</source>
