    <JadeMethod name="doCancel" id="712c1cd6-ed56-4476-bb38-ff9ec4177d97">
        <updating/>
        <source>doCancel() : Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwdap1	Initial creation

*/

vars

begin
//	if not self.isUpdatable() or
//	   app.msgBox("Are you sure that you want to end your data input and close this form?" , " Confirmation", MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
	if self.isVVRUpdatable() and self.changed then
		if app.msgBox(app.getErrorString(EditChangedAndClosing), app.getErrorString(MSGBOX_UnsavedChangesTitle), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			return false;
		endif;
	endif;
	
	self.unloadForm();
	self.bringMainFormToFront();
	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
