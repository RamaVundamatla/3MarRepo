	self.hasChanged := false;
	self.resetFirstChange();

	self.myCM_OutputFormat_SS := null;
	createMyProxyFormat( self.myCM_OutputFormat_SS );
	self.loadModeCombo();
	self.loadData();
	self.txtName.setFocus();
		
epilog

end;</source>
