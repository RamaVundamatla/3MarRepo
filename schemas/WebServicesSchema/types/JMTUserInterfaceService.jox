    <JadeWebServicesMethod name="getOrganisations" id="cd7940e1-addf-4683-89b4-5d6796fe1f3b">
        <usesRPC>default</usesRPC>
        <source>getOrganisations() : WS_OrganisationsResponse webService;

/*

Purpose:			Get a list of Organisations available to the current user.

Parameters:			None

Return Value:		


Date		Who		Reason
15 July 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	response		: WS_OrganisationsResponse;
	completedOK		: Boolean;
	
	passport		: CM_Passport;
	org				: CM_Organisation;
	failedDAC  		: CM_DataAccessController;
	proxyOrg		: WS_Organisation;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	passport := app.myPassport;
	
	// Populate response - cloned from CMUI_ComboOrganisation
	foreach org in app.myRoot.allOrganisations discreteLock do
		if not org.canUserAccessSelf(null, failedDAC, passport) then
			continue;
		endif;
		
		if org.isNotAvailableForEntry then
			continue;
		endif;
	
		create proxyOrg transient;
		proxyOrg.setProxyFromObject(org);
		response.allOrganisations.add(proxyOrg);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Get a list of Organisations available to the current user.</text>
        <wsdlName>getOrganisations</wsdlName>
        <ReturnType type="WS_OrganisationsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getOutputFormatsForReport" id="ff9989c3-7c88-4a04-aaa6-393bd06e1e8e">
        <usesRPC>default</usesRPC>
        <source>getOutputFormatsForReport(reportName : String) : WS_ReportOutputFormatsResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 September 2008	cnwkao1	Initial creation - ideally this would be used instead of getReportOutputFormats (and consequently validateReportOutputFormat)

*/

vars
	report			: CM_QryReport;
	reportFormats	: IntegerArray;
	reportFormat	: WS_ReportOutputFormat;
	response		: WS_ReportOutputFormatsResponse;
	completedOK		: Boolean;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	report := app.myRoot.getQryReport(reportName);
	
	if report = null then
		app.raiseCMException1(Report_Not_Found,
							reportName,
							null, 
							null);
		completedOK := true;
		return response;
	endif;
	
	reportFormats := report.reportFormats;
	
	if reportFormats.includes(JadeReportWriterReport.HTML) then
		create reportFormat transient;
		reportFormat.id				:= JadeReportWriterReport.HTML.String;
		reportFormat.description	:= "On Screen";	
		response.allOutputFormats.add(reportFormat);
	endif;

//	if reportFormats.includes(CM_QryReport.PDF_Format) and app.myRoot.canDo(PmPDFBackground) then
	if reportFormats.includes(CM_QryReport.PDF_Format) then	//07 Oct 2019	NDL	TFS 46169
		create reportFormat transient;
		reportFormat.id				:=  CM_QryReport.PDF_Format.String;
		reportFormat.description	:= "PDF";		
		response.allOutputFormats.add(reportFormat);
	endif;

	if (report.isFormBasedReport) and (report.canCSV) and reportFormats.includes(JadeReportWriterReport.CSV) then
		create reportFormat transient;
		reportFormat.id				:= JadeReportWriterReport.CSV.String;
		reportFormat.description	:= "CSV";	
		response.allOutputFormats.add(reportFormat);
		
	elseif (not report.isFormBasedReport) then
		if reportFormats.includes(JadeReportWriterReport.CSV) then
			create reportFormat transient;
			reportFormat.id				:= JadeReportWriterReport.CSV.String;
			reportFormat.description	:= "CSV";	
			response.allOutputFormats.add(reportFormat);
		endif;
		
		if reportFormats.includes(JadeReportWriterReport.RTF) then
			create reportFormat transient;
			reportFormat.id				:= JadeReportWriterReport.RTF.String;
			reportFormat.description	:= "RTF";	
			response.allOutputFormats.add(reportFormat);
		endif;
		
		if reportFormats.includes(JadeReportWriterReport.XML) then
			create reportFormat transient;
			reportFormat.id				:= JadeReportWriterReport.XML.String;
			reportFormat.description	:= "XML";		
			response.allOutputFormats.add(reportFormat);
		endif;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;
</source>
        <wsdlName>getOutputFormatsForReport</wsdlName>
        <Parameter name="reportName" type="String"/>
        <ReturnType type="WS_ReportOutputFormatsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getPaymentMethods" id="ace4b348-f2f8-454b-b6f9-a62d97d3e1d2">
        <source>getPaymentMethods() : WS_CodeResponse webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/08/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	response : WS_CodeResponse;
	iter : Iterator;
	completedOK : Boolean;
	paymentMethod : CM_PaymentMethod;
	wsCode : WS_Code;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	iter := app.myRoot.allPaymentMethods.createIterator;
	while iter.next(paymentMethod) do
		create wsCode transient;
		wsCode.setProxyDetails(paymentMethod, paymentMethod.code, paymentMethod.description);
		response.allCodes.add(wsCode);
	endwhile;
	
	completedOK := true;
	return response;
	
epilog
	delete iter;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <ReturnType type="WS_CodeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getPlaceForActualVoyage" id="3dcf9da0-f71e-42f4-868e-0d2ec25da93f">
        <source>getPlaceForActualVoyage(voyageId : String) : WS_PlaceResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2008	cnwkao1	Initial creation

*/

vars

	voyageGlobal    : CM_VoyageGlobal;
	
	
	pxyPlace		: WS_Place;
	response	: WS_PlaceResponse;
	obj			: Object;
	completedOK	: Boolean;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	if voyageId = null then
		completedOK := true;
		return response;
	endif;
	//epr TFS 5535 4/8/17
	voyageGlobal := app.myPassport.getObjectOfTypeFromOid(voyageId,CM_VoyageGlobal).CM_VoyageGlobal;
	if voyageGlobal = null then 
		completedOK := true;
		return response;
	endif;
	
	create pxyPlace transient;
	pxyPlace.code := app.vesselPlaceEnumToStr(PlaceHold);
	response.allPlaces.add(pxyPlace);	
	
	create pxyPlace transient;
	pxyPlace.code := app.vesselPlaceEnumToStr(PlaceDeck);
	response.allPlaces.add(pxyPlace);
	
	completedOK := true;
	return response;
	
	
epilog

	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <wsdlName>getPlaceForActualVoyage</wsdlName>
        <Parameter name="voyageId" type="String"/>
        <ReturnType type="WS_PlaceResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getPopupFormDef" id="aa325ff8-f9e2-4386-b420-df450b5bb831">
        <source>getPopupFormDef(formRequest : String) : WS_FormDefinitionResponse webService;

/*
Purpose:			This method is designed for the JMT RIA.

Parameters:			Form name

Return Value:		Form response


Date		Who		Reason
17 Dec 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	entTableGroup	: EntTableGroup;
	entTableDef		: EntTableDef;
	entTableRow		: EntTableRow;
	dataStore		: String;
	
	formDef			: WS_FormDefinition;
	response		: WS_FormDefinitionResponse;

	completedOK		: Boolean;
	requestParaArray  : StringArray;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create requestParaArray transient;
	formRequest.getTokensForDelimiter("|", requestParaArray);
	if requestParaArray.size &lt;&gt; 2 then
		//rasise an error;
		app.raiseCMException(Error,null,null);
	endif;
	
	// Create the response
	create response transient;
	
	create formDef transient;
	formDef.formName := requestParaArray[1];	
	response.myFormDefinition := formDef;	
	
	formDef.buildMyPopupFormDef(requestParaArray[2]);

	// Got to here, everything is ok
	completedOK := true;
	return response;
epilog
    delete requestParaArray;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;
</source>
        <text>This method is designed for the JMT RIA.</text>
        <wsdlName>getPopupFormDef</wsdlName>
        <Parameter name="formRequest" type="String"/>
        <ReturnType type="WS_FormDefinitionResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getPorts" id="1a5a7d0d-1043-4e5e-9bc6-4df57acad85d">
        <usesRPC>default</usesRPC>
        <source>getPorts(portsRequest : WS_PortsRequest) : WS_PortsResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
08 Sep 2008	cnwkao1	modified
28/07/2023	navcs2	Bug 52469: MTN - Changes are needed to improve the performance of the following webservices. getPorts() and getPortsForVoyage()
*/


vars
	response		: WS_PortsResponse;
	completedOK		: Boolean;
	
	voyage			: CM_Voyage;
	port			: CM_Port;
	proxyPort		: WS_Port;
	
	portColl		: Collection;
	iter			: Iterator;
	
	failedDAC		: CM_DataAccessController;
	passport		: CM_Passport;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	passport := app.myPassport;
	
	// Validate response - cloned from CMUI_ComboPorts
	if portsRequest.voyageCode &lt;&gt; null then
		voyage := passport.myTerminal.allVoyagesByCode.getAtKeyGeq(portsRequest.voyageCode, null);
		if voyage.code &lt;&gt; portsRequest.voyageCode then
			app.raiseCMException1(Voyage_code_found, portsRequest.voyageCode ,
								  null, 
								  null);
			completedOK := true;
			return response;
		endif;
	endif;			

	// Get the appropriate Ports collection
	if voyage = null or voyage.isNullVoyage() then
		portColl := app.myRoot.allActivePorts;			// 28/07/2023 navcs2 Bug 52469
	else
		portColl := voyage.allPorts;
	endif;

	// Populate the response
	// 28/07/2023 navcs2 Bug 52469
	iter := portColl.createIterator;
	while iter.next(port) do
		if not port.bIsPort then
			continue;
		endif;
		
		create proxyPort transient;
		proxyPort.setProxyFromObject(port);
		response.allPorts.add(proxyPort);
	endwhile;

	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up transients
	delete iter;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <wsdlName>getPorts</wsdlName>
        <Parameter name="portsRequest" type="WS_PortsRequest"/>
        <ReturnType type="WS_PortsResponse"/>
    </JadeWebServicesMethod>
