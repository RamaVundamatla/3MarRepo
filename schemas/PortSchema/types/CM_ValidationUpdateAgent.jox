    <JadeMethod name="valSubBlockStack" id="7b052ee2-fdeb-407d-aff4-17bb68345a0b">
        <source>valSubBlockStack(_theGridTARegion : CMIF_GridTARegion input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aTA					: CM_TerminalArea;
	theSubBlockStack 	: CM_SubBlockStack;
	anLCArray : CM_LCArray;
	controller	: CM_LocationsController;
begin

	if _theGridTARegion.allLocationControllers.size = 0 then			// PAR 29183
		app.raiseCMException(ERR_No_Locations_Selected, null,  null);
		return;		
    endif;
	
	theSubBlockStack := _theGridTARegion.myGridArea.allSubBlockStacks[_theGridTARegion.idOriginal];
	
	if theSubBlockStack = null then
		//validateForCreate

		aTA := _passport.myTerminal.allTerminalAreas[_theGridTARegion.id]; 
		if aTA &lt;&gt; null then
			app.raiseCMException2(ERR_INVALID_VALUE, 
								"Terminal Area ID ",
								 " The ID is already in use by " &amp; aTA.typeString &amp; " '" &amp; aTA.id &amp; "'.", 
								 null, 
								 null);
			return;		
		endif;

		foreach controller in _theGridTARegion.allLocationControllers do
			if controller.hasTIs then
				app.raiseCMException(ERR_CONV_LC_HAS_TIS, null, null);
				break;
			endif;
		endforeach;


		create anLCArray transient;
		_theGridTARegion.allLocationControllers.copy(anLCArray);
		if not _theGridTARegion.myGridArea.testAreWeTogether(anLCArray) then // AKB2001DEC
			app.raiseCMException1(ERR_CONTROLLERS_NOT_CONTIGUOUS, " Converting " 
				&amp; _theGridTARegion.myGridArea.myTerminal.code &amp; " "  
				&amp; _theGridTARegion.myGridArea.id &amp; " To A Sub Block Stack.", null, null);
		endif;
	else
		theSubBlockStack.validateSubBlock(_theGridTARegion);
	endif;
epilog
	delete anLCArray;
end;</source>
        <Parameter name="_theGridTARegion" type="CMIF_GridTARegion" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
