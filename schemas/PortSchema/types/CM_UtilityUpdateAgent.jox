    <JadeMethod name="utlVoyageJobUpdateAllocCargo" id="000074e7-b0f1-4b67-be2a-600815412bec">
        <updating/>
        <source>utlVoyageJobUpdateAllocCargo(_theJob : CM_VoyageJob; _allTIs : CM_TISet; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 Nov 2012	cnwrd1	Initial creation
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	realJob : CM_VoyageJob;
begin
	self.initialiseActivity();
		
	app.setContinueCMExceptions(false);
	
	realJob := _theJob;
	
	if realJob  = null then
		return;
	endif;
	
	exclusiveLock(realJob);
	realJob.allAssignedCargoForAlloc.clear();
	
	_allTIs.copy(realJob.allAssignedCargoForAlloc);	
	
	if _passport.noErrors then
		if realJob &lt;&gt; null then
			realJob.causeTerminalEvent(CM_VoyageJob.Event_Mode_Update);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_theJob" type="CM_VoyageJob"/>
        <Parameter name="_allTIs" type="CM_TISet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlVoyageVesselChange" id="08795ec5-da50-48f5-a142-938527ade5b0">
        <updating/>
        <source>utlVoyageVesselChange( _realVoyage : CM_Voyage io; _vessel : CM_Vessel; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2020	jlgndl1	Initial creation	TFS 49417
04 Mar 2021 cnwma1  ChangeRequest 50852: ASPA - Change Vessel on Barge
10 May 2022 navlw1  ChangedRequest 53330 EUP - Change Barge Vessel
29 Jul 2022 navsj20	ChangeRequest 54220: EUP - INB - Change Vessel Name
07 Mar 2023 navmp20 Bug 56603: FR 53330/54104 | EUP - Unexpected warnings when changing Barges or Vessels
*/

vars

	pxyVoyage       : CM_Voyage;
	hasStructure    : Boolean;
	conflictManager : CMIF_HMS_ConflictsManager;
	ti              : CM_TrackedItem;
	lc              : CM_LocationsController;
	tiset           : CM_TISet;
	primLoc			: CM_LocationsController;	// END 29 Jul 2022	navsj20	TFS 54220
	fmsToDelete		: ObjectArray;				// END 29 Jul 2022	navsj20	TFS 54220
	fm				: CM_FutureMove;			// END 29 Jul 2022	navsj20	TFS 54220

begin

	app.myPassport.setIgnoreVesselChanges(true);      //07.03.2023 navmp20 TFS 56603
	pxyVoyage := _realVoyage.pxyCreateUpdateProxy();
	app.myValUA.valVoyageVesselChange(pxyVoyage,_realVoyage);	//28 Jul 2022	navsj20	TFS 54220
	pxyVoyage.pxyChangeVesselAttribs( _vessel );
	
	hasStructure := pxyVoyage.myCellularVoyageStructure &lt;&gt; null;
	
	//Temporary Move 
	create tiset transient;
	if _realVoyage.allOnshipTIsByCargoTypeId.isNotEmpty then
		foreach ti in _realVoyage.allOnshipTIsByCargoTypeId do
			if _realVoyage.myNotNotifiedStack &lt;&gt; null then
				ti.doForcedMove(_realVoyage.myNotNotifiedStack,null, REAL_MODE, true, false, _passport);
				tiset.add(ti);
			endif;
		endforeach;
	endif;
	
	app.myUtilityUA.utlUpdateVoyage( hasStructure, true, pxyVoyage, conflictManager, false, _passport );
	
	if  _passport.noErrors then 
		// Find the Correct Location
		if _realVoyage .myGeneralCargoVoyage &lt;&gt; null then
			lc := _realVoyage.myGeneralCargoVoyage.allLocationsByHatchPlace.first;		
		endif;
		
		if lc = null then
			if _realVoyage.myShipBlockStack &lt;&gt; null then
				lc := _realVoyage.myShipBlockStack;
			endif;
		endif;
		//Move to next Location 
		if lc &lt;&gt; null then
			foreach ti in tiset do
				ti.doForcedMove(lc,null, REAL_MODE, true, false, _passport);
			endforeach;
		endif;
		
		//START 28 Jul 2022	navsj20	TFS 54220
		create fmsToDelete transient;
		foreach  ti in _realVoyage.allOnsiteTIsByIdCargoType discreteLock do 
			foreach fm in ti.allQueuedFutureMoves do
				primLoc := fm.getPrimaryLocation;
				if primLoc &lt;&gt; null and primLoc.isVoyageController then
					fmsToDelete.add(fm);
				endif;
			endforeach;
			foreach fm in ti.allPlannedFutureMoves do
				primLoc := fm.getPrimaryLocation;
				if primLoc &lt;&gt; null and primLoc.isVoyageController then
					fmsToDelete.add(fm);
				endif;
			endforeach;	
		endforeach;

		foreach ti in _realVoyage.allNotifiedTIsByIdCargoType discreteLock do
			foreach fm in ti.allQueuedFutureMoves do
				primLoc := fm.getPrimaryLocation;
				if primLoc &lt;&gt; null and primLoc.isVoyageController then
					fmsToDelete.add(fm);
				endif;
			endforeach;
			foreach fm in ti.allPlannedFutureMoves do
				primLoc := fm.getPrimaryLocation;
				if primLoc &lt;&gt; null and primLoc.isVoyageController then
					fmsToDelete.add(fm);
				endif;
			endforeach;	
		endforeach;
		fmsToDelete.purge();
		//END 28 Jul 2022	navsj20	TFS 54220
	endif;
	
	// navlw1 10 May 2022 TFS 53330
	// fire off an event so we can update the caption on the voyage ops screen
	if _passport.noErrors() then
		_realVoyage.causeEvent(_realVoyage.myTerminal.getTerminalEvent(EVENT_BARGEVESSELCHANGE), false, _realVoyage);
	endif;
	
epilog

	delete pxyVoyage;
	delete tiset;
	delete fmsToDelete; //29 Jul 2022	navsj20	TFS 54104
end;</source>
        <Parameter name="_realVoyage" type="CM_Voyage" usage="io"/>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlWOUnApprove" id="70642362-362e-40d3-a018-8a9db9178673">
        <updating/>
        <source> utlWOUnApprove(_workorder : CM_WorkOrder io;
				_passport  : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Apr 2024 navhl20 ChangeRequest 63583: EUP | 54014 - Cargo Work Orders Enhancements - Remedial
*/
vars
	
begin
	
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	if _passport.noErrors then												
		self.myUpdateAuditAgent.audUpdateGeneric(_workorder, true);
	endif;
	
	_workorder.doUnapprove(_passport);

	if _passport.noErrors then												
		self.myUpdateAuditAgent.audUpdateGeneric(_workorder, false);
	endif;
epilog
	
end;</source>
        <Parameter name="_workorder" type="CM_WorkOrder" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlWorkOrderAction" id="3f3c1ed0-19c4-49ef-91c3-be49eb6a96dd">
        <updating/>
        <source>utlWorkOrderAction(_woActionIF : CMIF_WorkOrderAction input;
				  _realJob	   : CM_Job io;
				  _grpMethod   : CM_WorkOrderJobGroupMethod input;
				  _passport    : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Apr 2023 navma1 ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
19 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes
28 Sep 2023 navhl20 ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
22 Nov 2023 navhl20 Defect 61396: EUP - Release Cargo - Ship WO shows exception on Action Task
*/

vars
	workOrderDtl,
 	wod				: CM_WorkOrderDtl;
	trxAA 	   		: CM_UpdateTransactionAuditAgent;
	wo				: CM_WorkOrder;
	isActioned		: Boolean;
begin
	
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valWorkOrderAction(_woActionIF,	_passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	workOrderDtl := _woActionIF.myWorkOrderDtl.CM_WorkOrderDtl;	
	
	create trxAA transient;					

	if _grpMethod &lt;&gt; null and workOrderDtl.isKindOf(CM_WorkOrderTIDtl) then	//19.9.2023 navhl20 #60063
		workOrderDtl.myParent.setMyWOJobGrpMethod(_grpMethod);
		trxAA.audUpdateGeneric(workOrderDtl.myParent, true);
		workOrderDtl.CM_WorkOrderTIDtl.updateWObyJobGrp(_grpMethod,wo);	//28.9.2023 navhl20 #59638
		
		foreach wod in wo.allWoDtls do									//28.9.2023 navhl20 #59638
			_woActionIF.myWorkOrderDtl 		 := wod;
			_woActionIF.numberFromKnownCargo := wod.CM_WorkOrderTIDtl.allSelectedTIs.size;
			wo.setTaskStatus(WO_STATUS_APPROVED);
			wod.doActionTask(_woActionIF,_realJob,_passport);
		endforeach;
		if _passport.noErrors then												
			trxAA.audUpdateGeneric(wo, false);
		endif;
		isActioned := true;
	endif;
	
	if not isActioned then													//28.9.2023 navhl20 #59638
		trxAA.audUpdateGeneric(workOrderDtl.myParent, true);
		
		workOrderDtl.doActionTask(_woActionIF,_realJob,_passport);

		if _passport.noErrors then												
			trxAA.audUpdateGeneric(workOrderDtl.myParent, false);
		endif;
	endif;
epilog
	delete trxAA;
end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction" usage="input"/>
        <Parameter name="_realJob" type="CM_Job" usage="io"/>
        <Parameter name="_grpMethod" type="CM_WorkOrderJobGroupMethod" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
