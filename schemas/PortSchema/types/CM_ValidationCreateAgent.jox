    <JadeMethod name="valEDIBayPlan" id="fae02be3-3b98-4a94-b5e0-02ce534d1ff8">
        <source>valEDIBayPlan(_control : CMIF_TIUpdateController);

// cnwdvb1 25 February 2003 

vars

begin

	if _control = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'CMIF_TIUpdateController', null, null);
		app.raiseCMException(Input_required_field_CMIFUpdat, null, null);

	endif;

	if _control.mode &lt;&gt; TI_UPDMODE_BAYPLAN then
		app.raiseCMException2(CodeInvalid, 'CMIF_TIUpdateController mode', _control.mode.String, null, null);
	endif;

	if _control.myVoyage = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Voyage', null, null);
		app.raiseCMException(Input_required_field_voyage, null, null); // cnwdb2	PAR 35364


	endif;
	
	if _control.comment = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Description', null, null);
		app.raiseCMException(Input_required_field_Desc, null, null); // cnwdb2	PAR 35364
	endif;

end;</source>
        <Parameter name="_control" type="CMIF_TIUpdateController"/>
    </JadeMethod>
