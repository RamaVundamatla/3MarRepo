    <JadeMethod name="doCreate_GateArea_Proxies" id="3b1ce4c4-539a-4a3a-b4d6-12c1e241c759">
        <source>doCreate_GateArea_Proxies(_pxyGate :CM_Gate input; _gateIn, _gateOut :CM_GateArea; _id1, _id2 :String; _areaType :Integer;
							_in, _newIn, _out, _newOut, _sameOut :Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	_pxyGateArea 	:CM_GateArea;

begin
	if _in then
		if _newIn then
			// creating new gate area
			if _sameOut then
				// same gate area for both in/out
				_pxyGateArea := _pxyGate.pxyAddNewGateArea (_id1, null, _areaType, true, true);
			else
				_pxyGateArea := _pxyGate.pxyAddNewGateArea (_id1, null, _areaType, true, false);
			endif;
		else
			// selecting existing gate area
			
			if _sameOut then
				// same gate area for both in/out
				_pxyGate.pxyAddGateArea (_gateIn, true, true);
			else
				if optPSelect_Out.value and _gateIn = _gateOut then
					_pxyGate.pxyAddGateArea (_gateIn, true, true);
				else
					_pxyGate.pxyAddGateArea (_gateIn, true, false);
				endif;
			endif;
		endif;
	endif;
	if _out and not _sameOut then
		if _newOut then
			_pxyGateArea := _pxyGate.pxyAddNewGateArea (_id2, null, _areaType, false, true);
		else			
			_pxyGate.pxyAddGateArea (_gateOut, false, true);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_pxyGate" type="CM_Gate" usage="input"/>
        <Parameter name="_gateIn" type="CM_GateArea"/>
        <Parameter name="_gateOut" type="CM_GateArea"/>
        <Parameter name="_id1" type="String"/>
        <Parameter name="_id2" type="String"/>
        <Parameter name="_areaType" type="Integer"/>
        <Parameter name="_in" type="Boolean"/>
        <Parameter name="_newIn" type="Boolean"/>
        <Parameter name="_out" type="Boolean"/>
        <Parameter name="_newOut" type="Boolean"/>
        <Parameter name="_sameOut" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEnableOptions" id="1c9296e8-35ea-4a62-8a96-1276c2c6360a">
        <source>doEnableOptions()protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if chkDualGate.value then
		if chkIn.value then
			grpIn.enabled	:= true;
		else
			grpIn.enabled		:= false;
			chkPGate_In.value	:= false;
			chkTrouble_In.value	:= false;
		endif;
		if chkOut.value then
			grpOut.enabled	:= true;
		else
			grpOut.enabled		:= false;
			chkPGate_Out.value	:= false;
			chkTrouble_Out.value	:= false;
		endif;
	else
		chkPGate_In.value		:= false;
		chkPGate_Out.value		:= false;
		chkTrouble_In.value		:= false;
		chkTrouble_Out.value	:= false;
		grpIn.enabled			:= false;
		grpOut.enabled			:= false;
	endif;
	
	self.doEnable_pGate_In;
	self.doEnable_pGate_Out;
	self.doEnable_Trouble_In;
	self.doEnable_Trouble_Out;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEnable_Trouble_In" id="b9a0b27d-03b8-487f-9c2b-c8e74b3d7134">
        <source>doEnable_Trouble_In() protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1
// Purpose:     Par 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	if not chkTrouble_In.value then
		optTNew_In.value 		:= true;
		optTNew_In.enabled		:= false;
		optTSelect_In.enabled	:= false;
		cmbTrouble_In.enabled	:= false;
		cmbTrouble_In.listIndex 	:= -1;
		return;
	endif;
	// we have an inward p-gate
	optTNew_In.enabled		:= true;
	optTSelect_In.enabled	:= true;
	
	if optTNew_In.value then
		cmbTrouble_In.listIndex 	:= -1;
		cmbTrouble_In.enabled		:= false;
		txtID_InT.enabled			:= true;
		lblID_InT.enabled			:= true;
	else
		cmbTrouble_In.enabled		:= true;
		txtID_InT.enabled			:= false;
		txtID_InT.text				:= null;
		lblID_InT.enabled			:= false;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEnable_Trouble_Out" id="3c2f16b1-7aa4-40c6-8499-3884b63b4a98">
        <source>doEnable_Trouble_Out() protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	if not chkTrouble_Out.value then
		optTNew_Out.value 		:= true;
		optTNew_Out.enabled		:= false;
		optTSelect_Out.enabled	:= false;
		optTSame_Out.enabled	:= false;
		cmbTrouble_Out.enabled	:= false;
		cmbTrouble_Out.listIndex 	:= -1;
		return;
	endif;
	// we have an Outward p-gate
	optTNew_Out.enabled		:= true;
	optTSelect_Out.enabled	:= true;
	optTSame_Out.enabled	:= true;
	
	if not optTSelect_Out.value then
		cmbTrouble_Out.listIndex 	:= -1;
		cmbTrouble_Out.enabled		:= false;
	else
		cmbTrouble_Out.enabled		:= true;
	endif;
	
	if optTNew_Out.value then
		txtID_OutT.enabled	:= true;
		lblID_OutT.enabled	:= true;
	else
		txtID_OutT.enabled	:= false;
		txtID_OutT.text		:= null;
		lblID_OutT.enabled	:= false;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEnable_pGate_In" id="0a8bad60-d82d-4c90-8bd0-082d488cf855">
        <source>doEnable_pGate_In() protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1
// Purpose:     Par 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	if not chkPGate_In.value then
		optPNew_In.value 		:= true;
		optPNew_In.enabled		:= false;
		optPSelect_In.enabled	:= false;
		cmbPGate_In.enabled		:= false;
		cmbPGate_In.listIndex 	:= -1;
		return;
	endif;
	// we have an inward p-gate
	optPNew_In.enabled		:= true;
	optPSelect_In.enabled	:= true;
	
	if optPNew_In.value then
		cmbPGate_In.listIndex 	:= -1;
		cmbPGate_In.enabled		:= false;
		txtID_InP.enabled		:= true;
		lblID_InP.enabled		:= true;
	else
		cmbPGate_In.enabled		:= true;
		txtID_InP.enabled		:= false;
		txtID_InP.text			:= null;
		lblID_InP.enabled		:= false;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEnable_pGate_Out" id="c0145049-5953-4e79-85a1-7da82d804aaa">
        <source>doEnable_pGate_Out() protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1
// Purpose:     Par 
// Parameters:  None
// Returns:     NothOutg
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	if not chkPGate_Out.value then
		optPNew_Out.value 		:= true;
		optPNew_Out.enabled		:= false;
		optPSelect_Out.enabled	:= false;
		optPSame_Out.enabled	:= false;
		cmbPGate_Out.enabled	:= false;
		cmbPGate_Out.listIndex 	:= -1;
		return;
	endif;
	// we have an Outward p-gate
	optPNew_Out.enabled		:= true;
	optPSelect_Out.enabled	:= true;
	optPSame_Out.enabled	:= true;
	
	if not optPSelect_Out.value then
		cmbPGate_Out.listIndex 	:= -1;
		cmbPGate_Out.enabled	:= false;
	else
		cmbPGate_Out.enabled	:= true;
	endif;
	
	if optPNew_Out.value then
		txtID_OutP.enabled	:= true;
		lblID_OutP.enabled	:= true;
	else
		txtID_OutP.enabled	:= false;
		txtID_OutP.text		:= null;
		lblID_OutP.enabled	:= false;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOK" id="d7d3d6f9-b135-48b9-84ca-738a69ffe6dc">
        <updating/>
        <source>doOK() updating;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/02/2010	cnwcs5	par 18061 - prompt for RFID tag read
// ---------------------------------------------------------------------------
vars
	proxy					:CM_Gate;
	pGate_In, pGate_Out, 
	trouble_In, trouble_Out	:CM_GateArea;
	doPrompt				:Boolean;	// 23/02/2010 cnwcs5 par 18061
begin
	// first do a bit of checking
	if not self.doValidate (pGate_In, pGate_Out, trouble_In, trouble_Out) then
		return;
	endif;
			
	// if we get to here we have enough to create our new gate
	create proxy transient;
	// interhcange area can be set in main form
	// default promptForRFIDTag to true if the terminal has RFID Tags otherwise false
	doPrompt := not self.myTerminal.allRFIDTagsByCode.isEmpty;	// 23/02/2010 cnwcs5 par 18061
	
	proxy.setProxy (txtName.text.trimBlanks, chkDualGate.value, chkIn.value, chkOut.value, doPrompt, null, self.myTerminal);
	// now add gate areas
	// a-gate	 - only if entry gate
	self.doCreate_GateArea_Proxies (proxy, null, null, txtID.text.trimBlanks, null, CM_GateArea.AreaType_A, 
									chkIn.value, true, 
									false, false, false);				
	// p-gate
	self.doCreate_GateArea_Proxies (proxy, pGate_In, pGate_Out, txtID_InP.text.trimBlanks, txtID_OutP.text.trimBlanks, 
									CM_GateArea.AreaType_P, 
									chkPGate_In.value, optPNew_In.value, 
									chkPGate_Out.value, optPNew_Out.value, optPSame_Out.value);
	// trouble
	self.doCreate_GateArea_Proxies (proxy, trouble_In, trouble_Out, txtID_InT.text.trimBlanks, txtID_OutT.text.trimBlanks, 
									CM_GateArea.AreaType_T, 
									chkTrouble_In.value, optTNew_In.value, 
									chkTrouble_Out.value, optTNew_Out.value, optTSame_Out.value);
									
	self.myGateProxy := proxy;
	
	inheritMethod();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doValidate" id="319bfdc8-8388-4daf-b2ac-53ee4ca6011c">
        <source>doValidate(_pGate_In, _pGate_Out, _trouble_In, _trouble_Out :CM_GateArea output ):Boolean protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str_id, str_in_p, str_in_t, str_out_p, str_out_t	:String;
begin
	str_id 		:= txtID.text.trimBlanks;
	str_in_p	:= txtID_InP.text.trimBlanks;
	str_in_t	:= txtID_InT.text.trimBlanks;
	str_out_p	:= txtID_OutP.text.trimBlanks;
	str_out_t	:= txtID_OutT.text.trimBlanks;
	
	// id fields must be entered
	if str_id = null then
		app.msgBox (app.getErrorString (Gate_Error15), app.getErrorString (Error), MsgBox_OK_Only);
		txtID.setFocus;
		return false;
	endif;
	if not self.doValidateID (str_id) then
		txtID.setFocus;
		return false;
	endif;
	if chkPGate_In.value and optPNew_In.value then
		if str_in_p = null  then
			app.msgBox (app.getErrorString1 (Gate_Error14, app.getErrorString (XLAT_PGATE_IN)), app.getErrorString (Error), MsgBox_OK_Only);
			txtID_InP.setFocus;
			return false;
		endif;
		if str_in_p =str_id  then
			app.msgBox (app.getErrorString1 (Gate_Error16, app.getErrorString (XLAT_PGATE_IN)), app.getErrorString (Error), MsgBox_OK_Only);
			txtID_InP.setFocus;
			return false;
		endif;
		if not self.doValidateID (str_in_p) then
			txtID_InP.setFocus;
			return false;
		endif;
	endif;
	if chkTrouble_In.value and optTNew_In.value then
		if str_in_t.trimBlanks = null then
			app.msgBox (app.getErrorString1 (Gate_Error14,  app.getErrorString (XLAT_TROUBLE_IN)), app.getErrorString (Error), MsgBox_OK_Only);
			txtID_InT.setFocus;
			return false;
		endif;
		if str_in_t = str_id  or
			str_in_t = str_in_p then
			app.msgBox (app.getErrorString1 (Gate_Error16, app.getErrorString (XLAT_TROUBLE_IN)), app.getErrorString (Error), MsgBox_OK_Only);
			txtID_InT.setFocus;
			return false;
		endif;
		if not self.doValidateID (str_in_t) then
			txtID_InT.setFocus;
			return false;
		endif;
	endif;
	if chkPGate_Out.value and optPNew_Out.value then
		if str_out_p = null then
			app.msgBox (app.getErrorString1 (Gate_Error14,  app.getErrorString (XLAT_PGATE_OUT)), app.getErrorString (Error), MsgBox_OK_Only);
			txtID_OutP.setFocus;
			return false;
		endif;
		if str_out_p = str_id  or
			str_out_p = str_in_p or
			str_out_p = str_in_t then
			app.msgBox (app.getErrorString1 (Gate_Error16, app.getErrorString (XLAT_PGATE_OUT)), app.getErrorString (Error), MsgBox_OK_Only);
			txtID_OutP.setFocus;
			return false;
		endif;
		if not self.doValidateID (str_out_p) then
			txtID_OutP.setFocus;
			return false;
		endif;
	endif;
	if chkTrouble_Out.value and optTNew_Out.value then
		if str_out_t = null then
			app.msgBox (app.getErrorString1 (Gate_Error14,  app.getErrorString (XLAT_TROUBLE_OUT)), app.getErrorString (Error), MsgBox_OK_Only);
			txtID_OutT.setFocus;
			return false;
		endif;
		if str_out_t = str_id  or
			str_out_t = str_in_p or
			str_out_t = str_in_t or
			str_out_t = str_out_p then
			app.msgBox (app.getErrorString1 (Gate_Error16, app.getErrorString (XLAT_TROUBLE_OUT)), app.getErrorString (Error), MsgBox_OK_Only);
			txtID_OutT.setFocus;
			return false;
		endif;
		if not self.doValidateID (str_out_t) then
			txtID_OutT.setFocus;
			return false;
		endif;
	endif;
	
	if optPSelect_In.value then
		_pGate_In := cmbPGate_In.listObject.CM_GateArea;
			
		if _pGate_In = null then
			app.msgBox (app.getErrorString (Gate_Error7), app.getErrorString (Error), MsgBox_OK_Only);
			cmbPGate_In.setFocus;
			return false;
		endif;
	endif;
	
	if optPSelect_Out.value then
		_pGate_Out := cmbPGate_Out.listObject.CM_GateArea;
		
		if _pGate_Out = null then
			app.msgBox (app.getErrorString (Gate_Error8), app.getErrorString (Error), MsgBox_OK_Only);
			cmbPGate_Out.setFocus;
			return false;
		endif;
	endif;
	
	if optTSelect_In.value then
		_trouble_In := cmbTrouble_In.listObject.CM_GateArea;
			
		if _trouble_In = null then
			app.msgBox (app.getErrorString (Gate_Error9), app.getErrorString (Error), MsgBox_OK_Only);
			cmbTrouble_In.setFocus;
			return false;
		endif;
	endif;
	
	if optTSelect_Out.value then
		_trouble_Out := cmbTrouble_Out.listObject.CM_GateArea;
			
		if _trouble_Out = null then
			app.msgBox (app.getErrorString (Gate_Error10), app.getErrorString (Error), MsgBox_OK_Only);
			cmbTrouble_In.setFocus;
			return false;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_pGate_In" type="CM_GateArea" usage="output"/>
        <Parameter name="_pGate_Out" type="CM_GateArea" usage="output"/>
        <Parameter name="_trouble_In" type="CM_GateArea" usage="output"/>
        <Parameter name="_trouble_Out" type="CM_GateArea" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doValidateID" id="e9ab0cae-0f77-4aa8-be88-02dd6cc019ae">
        <source>doValidateID(_id :String):Boolean protected;
// ---------------------------------------------------------------------------
// Created:     19 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ta	:CM_TerminalAreaMaster;
begin
	ta := self.myTerminal.allTerminalAreas[_id]; 
	
	if ta &lt;&gt; null then
		app.raiseCMException2(XLAT_id_is_terminal_area, _id, ta.getName(), null, null); 
		return false;
	endif;
	
	if self.myTerminal.machines[_id] &lt;&gt; null then
		app.raiseCMException1(XLAT_is_is_machine, _id, null, null);
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
