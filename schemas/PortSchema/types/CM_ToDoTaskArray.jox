<CollClass name="CM_ToDoTaskArray" id="0acbb6ac-aae4-40f3-950e-4b9be31f0204">
    <memberType name="CM_ToDoTask"/>
    <superclass name="CM_ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="misc"/>
    <JadeMethod name="getLastToDoTask" id="d5cc0647-f450-453c-a7a7-f371561c14b6">
        <source>getLastToDoTask(_code : Integer) : CM_ToDoTask;
/*

Purpose:			Gets the last To Do Task from the collection that matches the code

Parameters:			_code	Integer	Code to match the task based on

Return Value:		CM_ToDoTask Returns the To DO Task that matches the code passed in

Date		Who		Reason
19 May 2022	navpw1	Initial creation TFS: 53255

*/

vars
	toDo : CM_ToDoTask;

begin
	
	foreach toDo in self reversed do
		if toDo.toDoTaskDescCode = _code then
			return toDo;
		endif;
	endforeach;
	
	return null;
	
end;</source>
        <Parameter name="_code" type="Integer"/>
        <ReturnType type="CM_ToDoTask"/>
    </JadeMethod>
