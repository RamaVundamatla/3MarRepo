    <JadeMethod name="showInvoiceStatusEmailOptions" id="5dec0657-ff50-42a2-bed2-69e7cfd9a0c8">
        <source>showInvoiceStatusEmailOptions(_emailDefault: CM_InvStatusDefaultEmail; _sending: Boolean) : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/01/2019	jlgsl4		TFS 39618
//
vars
	form			: CMUI_InvStatusEmailForm;
	canView			: Boolean;
	canMaintain		: Boolean;
	limitedUpdate	: Boolean;

begin
	canView := app.myPassport.myUser.canDo(self.myTerminal, PmAdmVSEmailDefaultView); // need invoice-specific permissions...
	canMaintain := app.myPassport.myUser.canDo(self.myTerminal, PmAdmVSEmailDefaultMaint); // need invoice-specific permissions...
	
	if not (canView or canMaintain) then
		//just return OK - send default email
		app.msgBox("You do not have the permissions required for viewing or modifying the email defaults.","E-mail Options",null);
		return IDOK;
	endif;

	if _emailDefault = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'email defaults is null from form');
		return IDCANCEL;
	endif;
	
	if not _emailDefault.enabled then
		app.msgBox("Invoice Status emails have not been enabled.", "E-mail Options", MsgBox_OK_Only);
		return IDCANCEL;
	endif;
	
	if canMaintain then
		limitedUpdate := false;
	else
		limitedUpdate := true;
	endif;
	
	create form;
	form.setAssistantAndTerminalRefs(self, self.myTerminal);
	form.setCaption(form.caption &amp; ' Options - ' &amp; _emailDefault.name);
	form.setupForInvoiceStatus(_emailDefault, limitedUpdate, _sending);
	form.centreWindow;
	form.showModal();
	
	return form.modalResult;

epilog

end;</source>
        <Parameter name="_emailDefault" type="CM_InvStatusDefaultEmail"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showJobPriorityForSysConifg" id="eaed9ded-b9db-4ebc-9a7d-322571e17f62">
        <updating/>
        <source>showJobPriorityForSysConifg(_masterMenuAction : CMUI_MenuAction) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 August 2016	cnwma1	Initial creation FS # 2230:System Config - Issues

*/

vars
	theForm		: Form;
	theClass 	: Class;
	assistClass : Class;
	jrw 		: Schema;
	prenote		: CM_TrackedItem;
	numItems	: Integer;
	menuAction	: CMUI_MenuAction;
begin
	jrw 		:= rootSchema.getSchema("ShipSchema");
	theClass 	:= jrw.getClass("SHP_JobPriority");
	assistClass := jrw.getClass("SHP_Assistant");
	
	theForm := app.loadForm(theClass, assistClass, false, false, true, self.myTerminal, _masterMenuAction);
	if theForm = null then
		return;
	endif;
	
	if _masterMenuAction &lt;&gt; null then
		menuAction := _masterMenuAction;
		menuAction.setPropertyValue("myFormWhenMaster", theForm);
	endif;
	
	theForm.show;
epilog

end;
</source>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
