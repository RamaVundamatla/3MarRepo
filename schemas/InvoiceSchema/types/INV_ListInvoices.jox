	self.cmbCargoSite_.addItem(app.getErrorString(INV_On_Ship));
	self.cmbCargoSite_.itemData[self.cmbCargoSite_.newIndex()] := TI_SITE_ONSHIP;
	self.cmbCargoSite_.addItem(app.getErrorString(INV_To_Be_Advised));
