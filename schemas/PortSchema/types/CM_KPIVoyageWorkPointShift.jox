    <JadeMethod name="setKPI" id="95940f06-0f92-4539-a183-ef36e5327a2f">
        <updating/>
        <source>setKPI(_movesTEU: Decimal; _movesTI: Integer; _start: TimeStamp; _end: TimeStamp; 
//		_js: CM_VoyageDeckJobSheet; _shift: CM_Shift; _tis: CM_TISet input; _trans: CM_TITransactionSet input) updating;  //11/04/2017 cnwma1 TFS #4027
		_js: CM_VoyageJobSheet; _shift: CM_Shift; _tis: CM_TISet input; _trans: CM_TITransactionSet input) updating;
/*
Date		Who		Reason
08 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
11 April 2017		cnwma1	TFS #4027:MSL - Voyage Side Profile - delay not showed
*/
vars

begin
	self.myWorkPoint := _js.getMyWorkPoint;
	
	inheritMethod(_movesTEU, _movesTI, _start, _end, _js, _shift, _tis, _trans);

epilog

end;</source>
        <Parameter name="_movesTEU" type="Decimal"/>
        <Parameter name="_movesTI" type="Integer"/>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_end" type="TimeStamp"/>
        <Parameter name="_js" type="CM_VoyageJobSheet"/>
        <Parameter name="_shift" type="CM_Shift"/>
        <Parameter name="_tis" type="CM_TISet" usage="input"/>
        <Parameter name="_trans" type="CM_TITransactionSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setKPIForCreate" id="e3392ffd-e2fc-4119-942c-52fbca677ca1">
        <updating/>
        <source>setKPIForCreate(_start: TimeStamp; _end: TimeStamp; _js: CM_VoyageDeckJobSheet; _shift: CM_Shift; _voy: CM_Voyage; _terminal: CM_Terminal) updating;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
08 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars

begin
	self.myWorkPoint 	:= _js.getMyWorkPoint;

	inheritMethod(_start, _end, _js, _shift, _voy, _terminal);

epilog

end;</source>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_end" type="TimeStamp"/>
        <Parameter name="_js" type="CM_VoyageDeckJobSheet"/>
        <Parameter name="_shift" type="CM_Shift"/>
        <Parameter name="_voy" type="CM_Voyage"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
