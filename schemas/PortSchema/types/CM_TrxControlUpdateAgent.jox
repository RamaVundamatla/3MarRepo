// --------------------------------------------------------------------------------
// Created:		25 August 2008 by cnwdad1
//
// Purpose:		Adds/Removes Freight Fordarder objects to/from the specified Operator's
//				collection of Forwarders for Booking Ref updates.
//
// Parameters:	_operatorObj - A reference to the Operator object to update.
//				_allForwardersObj - A set of Freight Forwarder objects.
//				_passportObj - A reference to the user's Passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14 Aug 2018	jlgrs1		TFS 39619 PEN - Approved Carriers For Operator 
// 21 Aug 2019	jlgdap1		TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//								Removed carrierSet and carrierCargoType parameters
// --------------------------------------------------------------------------------
begin
	self.initialiseActivityWithPassport(_passportObj, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passportObj);
	on LockException do agtPassportLockExHandler(exception, _passportObj);
	
	app.setContinueCMExceptions(false);
	
	beginTransaction;
	
	app.myUtilityUA.utlUpdateOperatorAdvSettings(_operatorObj, _allForwardersObj, _allBookingRefDiscreps, _passportObj);	// TFS 45836
epilog
	self.finaliseActivityWithPassport(_passportObj);
end;</source>
