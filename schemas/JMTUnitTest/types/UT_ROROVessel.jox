    <JadeMethod name="xAlignController" id="ed6b72a3-de96-4952-bc7b-2fa55197dd32">
        <source>xAlignController() : CMIF_RectangleAlignor;
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	XLEFT = 20;
	XRIGHT = 120;
	YTOP = 20;
	YBOT = 120;
vars
	pxyItemLayout, realItemLayout: CM_DeckItemLayout;
	pointsPolygon : PointArray;
	pxyLayout : CM_DeckLayerLayout;
	pxyDeckLayout : CM_DeckLayout;
	controller : CMIF_RectangleAlignor;
	pxyGraphic : CM_Graphic;
	tmpPoint : Point;
	idx : Integer;
begin
	create controller transient;
	// ## PROXY
	create pointsPolygon transient;
	create pxyDeckLayout transient;
	// ## PROXY
	create pxyLayout transient;
	pxyLayout.setProxy("Layer 1", "Layer One", null, pxyDeckLayout, true,ROROLayerType_Structure);


	// ## CREATE 1
	create pxyItemLayout transient;
	pxyItemLayout.setDefaultOutline4(XLEFT,YTOP, XRIGHT, YBOT,pointsPolygon);
	pxyItemLayout.setProxyRORO(DEFAULT_YARD_X, DEFAULT_YARD_Y, null, Black, 0, 0, null, pointsPolygon,"UT_NEW", pxyLayout, Black, Frame.DrawFillStyle_Transparent, 1, true, DeckItemLayoutType_Graphic);
	
	controller.addGraphic(pxyItemLayout);

	// ## CREATE 2
	create pxyItemLayout transient;
	pxyItemLayout.setDefaultOutline4(XLEFT+ 80,YTOP+ 80, XRIGHT + 80, YBOT+ 80,pointsPolygon);
	pxyItemLayout.setProxyRORO(DEFAULT_YARD_X, DEFAULT_YARD_Y, null, Black, 0, 0, null, pointsPolygon,"UT_NEW", pxyLayout, Black, Frame.DrawFillStyle_Transparent, 1, true, DeckItemLayoutType_Graphic);
	controller.addGraphic(pxyItemLayout);

	// ## CREATE 3
	create pxyItemLayout transient;
	pxyItemLayout.setDefaultOutline4(XLEFT + 120,YTOP + 120, XRIGHT + 120, YBOT + 120,pointsPolygon);
	pxyItemLayout.setProxyRORO(DEFAULT_YARD_X, DEFAULT_YARD_Y, null, Black, 0, 0, null, pointsPolygon,"UT_NEW", pxyLayout, Black, Frame.DrawFillStyle_Transparent, 1, true, DeckItemLayoutType_Graphic);
	controller.addGraphic(pxyItemLayout);

	return controller;
	
epilog
	delete pointsPolygon;
end;</source>
        <ReturnType type="CMIF_RectangleAlignor"/>
    </JadeMethod>
