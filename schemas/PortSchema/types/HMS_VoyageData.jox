    <JadeMethod name="createPropertyChangesFromProxy" id="f69fb513-a4e0-4825-bb41-8958c7aecc0d">
        <source>createPropertyChangesFromProxy(_transaction : HMS_Transaction; _pxyVoyageData : HMS_VoyageData);
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	vesselCode,
	oldStr,
	newStr:				String;
	tmpSteveDict:		CM_StevedoreByCodeDict;
	tmpDict:			CM_CommodityByCodeDict;
	theVoyage:			CM_Voyage;
 	propertyChange:		HMS_PropertyChange;
 	commodity:			CM_Commodity;
 	stevedore:			CM_Stevedore;
 	cargoToLoad,
 	cargoHasChanged:	Boolean;	
 	stevedoresChanged:	Boolean;
begin
	// Voyage
	theVoyage := self.myVoyage;
	if theVoyage &lt;&gt; null then
		// _pxyVoyageData.myVoyage can be null when voyageType swapped around
		if _pxyVoyageData.myVoyage &lt;&gt; null then	
			if theVoyage.code &lt;&gt; _pxyVoyageData.myVoyage.code then
		    	// Property has changed
				create propertyChange;
				propertyChange.set(_transaction, "Voyage code", theVoyage.code, _pxyVoyageData.myVoyage.code);
			endif;
		endif;
		// Ship
		vesselCode := theVoyage.vesselCode;		
	endif;

	if vesselCode &lt;&gt; _pxyVoyageData.vesselCode then
    	// Property has changed
		create propertyChange;
		oldStr := vesselCode;
		newStr := _pxyVoyageData.vesselCode;
  		propertyChange.set(_transaction, "Vessel", oldStr, newStr);   			
	endif;


    // Comments
    if self.shortComment &lt;&gt; _pxyVoyageData.shortComment then
    	// Property has changed
		create propertyChange;
   		propertyChange.set(_transaction, "Voyage comments", self.shortComment, _pxyVoyageData.shortComment);
	endif;

	// Vessel Class IN
	if self.myVesselCategoryIn &lt;&gt; _pxyVoyageData.myVesselCategoryIn then
    	// Property has changed
		create propertyChange;
   		if self.myVesselCategoryIn &lt;&gt; null then
   			oldStr := self.myVesselCategoryIn.description;
   		else
   			oldStr := "None Selected";
   		endif;
   		if _pxyVoyageData.myVesselCategoryIn &lt;&gt; null then
   			newStr := _pxyVoyageData.myVesselCategoryIn.description;
   		else
   			newStr := "None Selected";
   		endif;	
   		propertyChange.set(_transaction, "Ship Class IN", oldStr, newStr);
	endif;

	// Vessel Class OUT
	if self.myVesselCategoryOut &lt;&gt; _pxyVoyageData.myVesselCategoryOut then
    	// Property has changed
		create propertyChange;
   		if self.myVesselCategoryOut &lt;&gt; null then
   			oldStr := self.myVesselCategoryOut.description;
   		else
   			oldStr := "None Selected";
   		endif;
   		if _pxyVoyageData.myVesselCategoryOut &lt;&gt; null then
   			newStr := _pxyVoyageData.myVesselCategoryOut.description;
   		else
   			newStr := "None Selected";
   		endif;	
   		propertyChange.set(_transaction, "Ship Class OUT", oldStr, newStr);
	endif;

	// Discharge cargo
	/*if (not self.cargoToDischarge) and (not _pxyVoyageData.cargoToDischarge) then
		// No property change
	elseif self.cargoToDischarge and _pxyVoyageData.cargoToDischarge then
		// Compare cargo's new:old
		cargoHasChanged := false;
		if self.allCommodityDischarge.size &lt;&gt; _pxyVoyageData.allCommodityDischarge.size then
			// Cargo added or removed - ie Cargo assignment has changed
			cargoHasChanged:=true;
		else
			// Number of cargo type selected is same - directly compare members of each collection
			foreach commodity in self.allCommodityDischarge do
				if (not _pxyVoyageData.allCommodityDischarge.includes(commodity)) then
					cargoHasChanged:=true;
				endif;
			endforeach;
			foreach commodity in _pxyVoyageData.allCommodityDischarge do
				if (not self.allCommodityDischarge.includes(commodity)) then
					cargoHasChanged:=true;
				endif;
			endforeach;
		endif;
		if cargoHasChanged=true then
			// Cargo assignments have changed
			// Property has changed
			create propertyChange;
	   		if self.allCommodityDischarge.isEmpty then
				oldStr := "None Selected";
			else
		   		foreach commodity in self.allCommodityDischarge do
		   			oldStr := oldStr &amp; commodity.description &amp; "; ";
				endforeach;
				// Trim last "; "
				oldStr := oldStr[1:(oldStr.length-2)];
			endif;
			if _pxyVoyageData.allCommodityDischarge.isEmpty then
				newStr := "None Selected";			
			else
		   		foreach commodity in _pxyVoyageData.allCommodityDischarge do
		   			newStr := newStr &amp; commodity.description &amp; "; ";
				endforeach;
				// Trim last "; "
				newStr := newStr[1:(newStr.length-2)];
			endif;
	   		propertyChange.set(_transaction, "Cargo for discharge", oldStr, newStr);			
		endif;
	elseif (not self.cargoToDischarge) and
	   _pxyVoyageData.cargoToDischarge and
	   (not _pxyVoyageData.allCommodityDischarge.isEmpty) then
		// Property changed;  old=None Selected; new=All discharge charge
		// Cargo has been selected for discharge
		create propertyChange;
   		oldStr := "None selected";	
   		foreach commodity in _pxyVoyageData.allCommodityDischarge do
	   		newStr := newStr &amp; commodity.description &amp; "; ";
		endforeach;
		// Trim last "; "
		newStr := newStr[1:(newStr.length-2)];
   		propertyChange.set(_transaction, "Cargo for discharge", oldStr, newStr);			
	elseif self.cargoToDischarge and
	   (not _pxyVoyageData.cargoToDischarge) and
	   (not self.allCommodityDischarge.isEmpty) then
		// Property changed;  old=All discharge charge; new=None Selected
		// Cargo has been selected for discharge
		create propertyChange;
   		newStr := "None selected";	
   		foreach commodity in self.allCommodityDischarge do
	   		oldStr := oldStr &amp; commodity.description &amp; "; ";
		endforeach;
		// Trim last "; "
		oldStr := oldStr[1:(oldStr.length-2)];
   		propertyChange.set(_transaction, "Cargo for discharge", oldStr, newStr);			
	endif;*/ // ### TFS 53132 20Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage


   	// Load cargo
   	/*cargoToLoad := self.cargoToLoad;
   	tmpDict := self.allCommodityLoad;
	if cargoToLoad=false and _pxyVoyageData.cargoToLoad=false then
		// No property change
	elseif cargoToLoad=true and _pxyVoyageData.cargoToLoad=true then
		// Compare cargo's new:old
		cargoHasChanged:=false;
		if tmpDict.size&lt;&gt;_pxyVoyageData.allCommodityLoad.size then
			// Cargo added or removed - ie Cargo assignment has changed
			cargoHasChanged:=true;
		else
			// Number of cargo type selected is same - directly compare members of each collection
			foreach commodity in tmpDict do
				if _pxyVoyageData.allCommodityLoad.includes(commodity)=false then
					cargoHasChanged:=true;
				endif;
			endforeach;
			foreach commodity in _pxyVoyageData.allCommodityLoad do
				if tmpDict.includes(commodity)=false then
					cargoHasChanged:=true;
				endif;
			endforeach;
		endif;
		if cargoHasChanged=true then
			// Cargo assignments have changed
			// Property has changed
			create propertyChange;
	   		if (not tmpDict.isEmpty) then
		   		foreach commodity in tmpDict do
		   			oldStr := oldStr &amp; commodity.description &amp; "; ";
				endforeach;
				// Trim last "; "
				oldStr := oldStr[1:(oldStr.length-2)];
			else
				oldStr := "None Selected";
			endif;
			if (not _pxyVoyageData.allCommodityLoad.isEmpty) then
		   		foreach commodity in _pxyVoyageData.allCommodityLoad do
		   			newStr := newStr &amp; commodity.description &amp; "; ";
				endforeach;
				// Trim last "; "
				newStr :=newStr[1:(newStr.length-2)];
			else
				newStr := "None Selected";
			endif;
	   		propertyChange.set(_transaction, "Cargo to load", oldStr, newStr);			
		endif;
	elseif cargoToLoad=false and _pxyVoyageData.cargoToLoad=true and _pxyVoyageData.allCommodityLoad.size&gt;0 then
		// Property changed;  old=None Selected; new=All discharge charge
		// Cargo has been selected for discharge
		create propertyChange;
   		oldStr := "None selected";	
   		foreach commodity in _pxyVoyageData.allCommodityLoad do
   			newStr := newStr &amp; commodity.description &amp; "; ";
		endforeach;
		// Trim last "; "
		newStr := newStr[1:(newStr.length-2)];
   		propertyChange.set(_transaction, "Cargo to load", oldStr, newStr);			
	elseif cargoToLoad and (not _pxyVoyageData.cargoToLoad) and (not tmpDict.isEmpty) then
		// Property changed;  old=All discharge charge; new=None Selected
		// Cargo has been selected for discharge
		create propertyChange;
   		newStr := "None selected";	
   		foreach commodity in tmpDict do
	   		oldStr :=oldStr &amp; commodity.description &amp; "; ";
		endforeach;
		// Trim last "; "
		oldStr := oldStr[1:(oldStr.length-2)];
   		propertyChange.set(_transaction, "Cargo to load", oldStr, newStr);			
	endif;*/ // ### TFS 53132 20Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage

	// Stevedores for cargo discharge
	// Compare stevedore's new:old
	stevedoresChanged:=false;
	tmpSteveDict := self.allStevedoresDischarge;
	if tmpSteveDict.size&lt;&gt;_pxyVoyageData.allStevedoresDischarge.size then
		// Stevedores added or removed - ie Stevedore assignment has changed
		stevedoresChanged:=true;
	else
		// Number of stevedores selected is same - directly compare members of each collection
		foreach stevedore in tmpSteveDict do
			if _pxyVoyageData.allStevedoresDischarge.includes(stevedore)=false then
				stevedoresChanged:=true;
			endif;
		endforeach;
		foreach stevedore in _pxyVoyageData.allStevedoresDischarge do
			if tmpSteveDict.includes(stevedore)=false then
				stevedoresChanged:=true;
			endif;
		endforeach;
	endif;
	if stevedoresChanged=true then
		// Stevedore assignments have changed
		// Property has changed
		create propertyChange;

   		if (not tmpSteveDict.isEmpty) then
	   		foreach stevedore in tmpSteveDict do
	   			oldStr := oldStr &amp; stevedore.description &amp; "; ";
			endforeach;
			// Trim last "; "
			oldStr :=oldStr[1:(oldStr.length-2)];
		else
			oldStr := "None Selected";
		endif;
		if (not _pxyVoyageData.allStevedoresDischarge.isEmpty) then
	   		foreach stevedore in _pxyVoyageData.allStevedoresDischarge do
	   			newStr := newStr &amp; stevedore.description &amp; "; ";
			endforeach;
			// Trim last "; "
			newStr := newStr[1:(newStr.length-2)];
		else
			newStr := "None Selected";
		endif;
   		propertyChange.set(_transaction, "Stevedore/s for discharge", oldStr, newStr);		
	endif;

   	// Stevedores for discharge 
   	// Compare stevedore's new:old
	stevedoresChanged:=false;
	tmpSteveDict := self.allStevedoresLoad;
	if tmpSteveDict.size&lt;&gt;_pxyVoyageData.allStevedoresLoad.size then
		// Stevedores added or removed - ie Stevedore assignment has changed
		stevedoresChanged:=true;
	else
		// Number of stevedores selected is same - directly compare members of each collection
		foreach stevedore in tmpSteveDict do
			if _pxyVoyageData.allStevedoresLoad.includes(stevedore)=false then
				stevedoresChanged:=true;
			endif;
		endforeach;
		foreach stevedore in _pxyVoyageData.allStevedoresLoad do
			if tmpSteveDict.includes(stevedore)=false then
				stevedoresChanged:=true;
			endif;
		endforeach;
	endif;
	if stevedoresChanged=true then
		// Stevedore assignments have changed
		// Property has changed
		create propertyChange;
   		if (not tmpSteveDict.isEmpty) then
	   		foreach stevedore in tmpSteveDict do
	   			oldStr := oldStr &amp; stevedore.description &amp; "; ";
			endforeach;
			// Trim last "; "
			oldStr := oldStr[1:(oldStr.length-2)];
		else
			oldStr := "None Selected";
		endif;
		if _pxyVoyageData.allStevedoresLoad.size&gt;0 then
	   		foreach stevedore in _pxyVoyageData.allStevedoresLoad do
	   			newStr := newStr &amp; stevedore.description &amp; "; ";
			endforeach;
			// Trim last "; "
			newStr := newStr[1:(newStr.length-2)];
		else
			newStr := "None Selected";
		endif;
   		propertyChange.set(_transaction, "Stevedore/s for loading", oldStr, newStr);		
	endif;

end;</source>
