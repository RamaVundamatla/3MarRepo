/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 November 2009	cnwas3	Initial creation

*/

vars

begin
	self.comparisonMode := VOYAGE_DETAILS_COMPARISON;
	//self.initTable(ETDef_LoadListComp);
	self.hideComparisonControls(false);
	if self.myCurrentVoyage &lt;&gt; null then
		self.initiateCompareVoyDet(false);
	else
		app.msgBox(app.getErrorString(Voyage_needs_selected), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);		
