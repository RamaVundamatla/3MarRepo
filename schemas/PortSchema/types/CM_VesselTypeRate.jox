Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types

*/

vars

begin
	self.myVesselType := _pxyRate.myVesselType;
	inheritMethod(_pxyRate);
	

epilog

end;</source>
        <Parameter name="_pxyRate" type="CM_VesselTypeRate"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="5c336a80-3f95-4525-88b0-b8be74a79d7b">
        <updating/>
        <source>setProxy(_service: CM_Service; _ref: CM_Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types

*/

vars

begin
	inheritMethod(_service, _ref);
