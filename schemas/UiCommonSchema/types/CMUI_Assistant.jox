//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	app.writeStatement( str);

end;</source>
        <Parameter name="str" type="String"/>
    </JadeMethod>
</Class>
