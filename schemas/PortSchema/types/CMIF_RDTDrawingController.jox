    <JadeMethod name="gridRowToStackHeight" id="7774a533-ef92-492d-ad15-8f09cfb504d8">
        <source>gridRowToStackHeight(_row : Integer; _gridArea : CM_GridArea) : Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwjk3	Initial creation

*/

