    <JadeMethod name="getMyTerminal" id="4bc02f13-23b7-4e66-a25b-806b8471b6fd">
        <source>getMyTerminal(): CM_Terminal;
/*
Purpose:		TFS 2682	
Date		Who		Reason
15 September 2016	cnwab1	Initial creation
*/

vars
	bu : CM_Bank;
begin
	bu := self.getBank();
	
	if bu = null then
		return null;
	endif;
	
	return bu.getMyTerminal();

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getYACriteriaTypes" id="3b8551e0-c26d-4354-9528-315487fc115a">
        <source>getYACriteriaTypes() : ObjectArray;
/*
Purpose:			

Date		Who		Reason
26MAY2021	NAVAB1	TFS 51219
*/


vars

	criteriaTypes: ObjectArray;
	criteria : CM_YACriteriaType;
begin
	
	create criteriaTypes transient;
	foreach criteria in app.myRoot.allYACriteriaTypes discreteLock do
		if not criteria.isUsed then	
			continue;
		endif;
		if criteria.isForCargo() then
			criteriaTypes.add(criteria);
		endif;
 
	endforeach;

	return criteriaTypes;
epilog

end;</source>
        <ReturnType type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="healthCheckIsValid" id="cded28f5-d3e2-4692-a674-9da115072221">
        <source>healthCheckIsValid(_agent : CMIF_InvoiceHealthAgent) : Boolean;
/*
Purpose:			
Date				Who			Reason
September 2017		CNWAB1		Initial creation
*/

vars
	message : String;
	resultType : Integer;
	detail : CMIF_InvoiceHealthAgentDetail;
	term : CM_Terminal;
// TFS 40620	invLineDescs : CM_InvoiceLineDescMapDict;
	invLineDescs : CM_InvoiceLineDescSet; // TFS 40620
	
	invLineDesc : CM_InvoiceLineDesc;
	paths : HugeStringArray;
	items : ObjectArray;
	bu : CM_Bank;	invalid : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, invLineDesc, invalid);

	
	bu := self.getBank();
	if bu = null then
		return true;
	endif;
	if not _agent.allBusinessUnits.includes(bu) then
		return true;
	endif;
	
//	term := self.getMyTerminal();
//	if term = null then
//		return true;
//	endif;
//	if not _agent.allTerminals.includes(term) then
//		return true;
//	endif;
	
	// ### CARGO  Calculation Type
	if _agent.checkTypesToQuery.includes(CMIF_InvoiceHealthAgent.CheckType_CalcType) then
		resultType := CMIF_InvoiceHealthAgent.ResultType_CalcTypeCargo;
		invLineDescs := self.getAllMappedInvoiceLineTypes();
		
		foreach invLineDesc in invLineDescs do
			if  invLineDesc.myCalculationType &lt;&gt; null then
				if not invLineDesc.myCalculationType.isCargoCalcType then
					create detail transient;
					detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_CalcType,"Line Type: '" &amp; invLineDesc.narration &amp;  "'", CMIF_InvoiceHealthAgent.ItemType_TranMapAlloc, self.getMyTerminal(), resultType, self);
				endif;
			endif;
		endforeach;
		if invalid then
					create detail transient;
					detail.setForCreate(_agent, CMIF_InvoiceHealthAgent.CheckType_InvoiceLineType,"Line Type is Invalid Object", CMIF_InvoiceHealthAgent.ItemType_TranMapAlloc, self.getMyTerminal(), CMIF_InvoiceHealthAgent.ResultType_Invalid, self);
		endif;
		return false;
	endif;
	return true;
epilog
	delete invLineDescs;
end;</source>
        <Parameter name="_agent" type="CMIF_InvoiceHealthAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="e3b6a9bc-73dd-4859-b1d5-a21f8eca06da">
        <updating/>
        <source>initialise(_bank : CM_Bank) updating;
/*
Purpose:			
Date				Who			Reason
MARCH 2015		CNWAB1		Initial creation
*/
vars
	config : CM_InvoiceAllocationConfig;
	criteriaType: CM_YACriteriaType;
begin
	self.myBank := _bank;
	
	create config;
	config.myTransactionMap := self;
	
		
	// ### HARD CODE TRANSACTION TYPE
	criteriaType := app.myRoot.allYACriteriaTypes[YACriteriaType_TransactionType];

	config.allOpCriteria.add(criteriaType);

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="recalcAllocationPriorities" id="2817af00-091f-4fca-812a-14447121e124">
        <source>recalcAllocationPriorities();
/*

Purpose:			Recalculate the priorities of all the invoice allocations belonging to this 
					map.  Will be called after any changes to the configuration which may result
					in a change of priorities.

Parameters:			None

Return Value:		None

Date		Who		Reason
30 May 2017	cnwkpd1	TFS #4542 - Invoicing performance changes

*/

vars
	alloc			: CM_InvoiceCargoAllocation;
	iter			: Iterator;
	term			: CM_Terminal;
	trxTypes		: IntegerArray;
	trxType			: Integer;
	
begin
	self.allInvoiceAllocByTranType.clear();
	
	create trxTypes transient;
	
	iter := self.allInvoiceCargoAllocations.createIterator();
	while iter.next(alloc) do
		alloc.setPriority();
		trxTypes.clear();
		alloc.getTransactionTypes(trxTypes);
		foreach trxType in trxTypes do
			self.allInvoiceAllocByTranType.putAtKey(trxType, alloc.priorityValue, alloc);
		endforeach;
	endwhile;
	
	term := self.getMyTerminal();
	if term &lt;&gt; null then
		app.myEventManager.createSingleObjInfoNoteEvt(self, term.getTerminalEvent(EVENT_INVCARGOALLOC_UPDATE), null);
	endif;
		
epilog
	delete iter;
	delete trxTypes;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="removeDeletedCriteriaTypes" id="f05136d1-070c-4afa-a0da-9b1588e4c223">
        <updating/>
        <source>removeDeletedCriteriaTypes(_typeArray : IntegerArray) updating;
/*
Purpose:			

Date		Who		Reason
26MAY2021	NAVAB1	TFS 51219
*/

vars
	criteriaToDelete : ObjectArray;
	yardAlloc : CM_YardAllocation;
	allocation : CM_InvoiceCargoAllocation;
	criteria : CM_YACriteria;

begin

	create criteriaToDelete transient;
	
	foreach yardAlloc in self.allInvoiceCargoAllocations discreteLock do
		allocation := yardAlloc.CM_InvoiceCargoAllocation;
		foreach criteria in allocation.allCriteriaByType discreteLock do
			if _typeArray.includes(criteria.myYACriteriaType.type)
			and criteria.myYACriteriaType.isBooleanType then
				criteriaToDelete.add(criteria);
			endif;
		endforeach;
	endforeach;
	
	criteriaToDelete.purge;
	
epilog
	delete criteriaToDelete;
end;</source>
        <Parameter name="_typeArray" type="IntegerArray"/>
    </JadeMethod>
