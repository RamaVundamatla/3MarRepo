    <PrimAttribute name="nonBargeVesselChanges" id="8087d4ef-c5b5-4c4b-acc5-c0fb2ef285a1">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="cmbVessel_displayEntry" id="476300b1-70c9-4db4-a659-4f6e43bf75de">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVessel_displayEntry(combobox: ComboBox input; pVessel: CM_Vessel; lstIndex: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2020	jlgndl1	Initial creation	TFS 49417
29 Jul 2022 navsj20	ChangeRequest 54220: EUP - INB - Change Vessel Name

*/

vars

	failedDAC  : CM_DataAccessController; 

begin

	if pVessel = null then
		return null;
	endif;
	
	if (not pVessel.canCreateVoyages) then
		return null;
	endif;
	//if (not pVessel.isBarge) then										//29 Jul 2022	navsj20	TFS 54104
	if (not pVessel.isBarge and not self.nonBargeVesselChanges) then	//29 Jul 2022	navsj20	TFS 54104
		return null;
	endif;
	
	if not pVessel.canUserAccessSelf(null, failedDAC, app.myPassport) then
		return null;
	endif;
	
	return pVessel.code &amp; Tab &amp; pVessel.name;		
	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="pVessel" type="CM_Vessel"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="54a0bf2f-2125-4f24-8b12-6c326185d6a7">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2020	jlgndl1	Initial creation	TFS 49417

*/

vars

begin

	self.permissionView  := PmShipBargeChange;
	self.permissionMaint := PmShipBargeChange;
	self.helpFileName := HelpFile_Voyage;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="42ad9cb6-4813-4e1e-8b1c-ccf5c014aae6">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2020	jlgndl1	Initial creation	TFS 49417

*/

vars

begin

	if self.doSave then
		inheritMethod();	//closes the form
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="69b293ae-6c85-4cee-b58a-286a176b4acd">
        <updating/>
        <source>doSave():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2020	jlgndl1	Initial creation	TFS 49417

*/

vars

	bargeVessel : CM_Vessel;
	msg : String;
	result : Integer;
	
begin

	bargeVessel := self.cmbVessel.listObject.CM_Vessel;
	if bargeVessel = null then
		msg := app.getErrorString( Input_required_field_vessel );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.cmbVessel.setFocus();
		return false;
	endif;

	
	while true do
		app.mousePointer :=	Busy;
		app.myTrxCA.trxVoyageVesselChange( self.myCurrentVoyage, bargeVessel, app.myPassport );
		
		if app.myPassport.trxCompletedOK then
			return true;
			break;
			
		else
			app.mousePointer :=	Idle;
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_Definition), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);	
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
	
		endif;
		return false;
		
	endwhile;
	
	return false;

epilog

	app.mousePointer :=	Idle;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentVoyage" id="fb0a794b-1ddd-41d6-a021-5973c63bb32e">
        <updating/>
        <source>setMyCurrentVoyage( _myCurrentVoyage : CM_Voyage )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2020	jlgndl1	Initial creation	TFS 49417

*/

vars

	currentVessel : CM_Vessel;

begin

	self.myCurrentVoyage := _myCurrentVoyage;
	
	if self.myTerminal = null and self.myCurrentVoyage &lt;&gt; null then
		self.myTerminal := self.myCurrentVoyage.myTerminal;
	endif;
	
	if self.myCurrentVoyage &lt;&gt; null then
		currentVessel := self.myCurrentVoyage.myVessel;
	endif;
	
	if currentVessel &lt;&gt; null then
		self.lblVoyageCode.caption := app.getErrorString2( Voyage_current_vessel, self.myCurrentVoyage.code, currentVessel.name);
	endif;

epilog

end;</source>
        <Parameter name="_myCurrentVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="9b170586-c1a2-4f73-acd5-afa0b937dd76">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2020	jlgndl1	Initial creation	TFS 49417
04 Mar 2021 cnwma1  ChangeRequest 50852: ASPA - Change Vessel on Barge
02 Aug 2022 navsj20	ChangeRequest 54220: EUP - INB - Change Vessel Name

*/

vars

	vessel : CM_Vessel;
	index  : Integer;
	msg, vesselName : String;
	
begin
    
	/* 04.03.2021 cnwma1 #50852
	if not self.myCurrentBarge.allOnshipTIsByCargoTypeId.isEmpty then
		msg := app.getErrorString(Voyag_alrea_cargo_board_unabl);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		self.unloadForm;
		return;
	endif;
	*/
	// START 29 Jul 2022	navsj20	TFS 54220
	if not myCurrentVoyage.isBarge then 
		self.nonBargeVesselChanges:= true;
	endif;
	if 	self.nonBargeVesselChanges then 
		self.caption := app.getErrorString(Change_voyage_vessel);
		lblVessel.caption := app.getErrorString(New_vessel);
	endif;
	// END 29 Jul 2022	navsj20	TFS 54220
	self.cmbVessel.listCollection( app.myRoot.allVessels, true, 0 );
	
	inheritMethod();
	
	vessel := self.myCurrentVoyage.myVessel;
	// START 02 Aug 2022	navsj20	TFS 54220
	if vessel &lt;&gt; null then 
		vesselName := vessel.name;		
	endif;
	// END 02 Aug 2022	navsj20	TFS 54220
	index := self.cmbVessel.findObject( vessel );
	if index &gt; 0 then
		self.cmbVessel.itemEnabled[index] := false;
	endif;
	
	//self.lblVoyageCode.caption := app.getErrorString2( Voyage_current_vessel_chg, self.myCurrentVoyage.code, vessel.name );	//02 Aug 2022	navsj20	TFS 54220
	self.lblVoyageCode.caption := app.getErrorString2( Voyage_current_vessel_chg, self.myCurrentVoyage.code, vesselName );		//02 Aug 2022	navsj20	TFS 54220

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="6412433e-9d6d-4d3e-ad5e-94c662a7811f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 03 June 2020 13:20:26.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023915, locale);
	lblVessel.translateCaption(Xlat_0023916, locale);
	lblVoyageCode.translateCaption(Xlat_0023917, locale);
end;</source>
    </JadeMethod>
</GUIClass>
