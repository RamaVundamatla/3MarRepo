    <JadeMethod name="setupThumbnailDetails" id="c673489a-24ba-44e5-8681-9709a795cbb1">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jan 2019	jlgsl4	TFS 39618 - LNX - Invoice Approved Status

*/

vars
	form : SOP_TableMaintForm;

begin
	form := self.myForm;
	form.useProxyObject := true;
	form.setTblDataEntRows(ETDef_InvoiceStatusDetail);
	form.shtTblInput1.caption := app.getErrorString(Details);
	form.initTblInput(form.tblInput1, ETDef_InvoiceStatusThumb);
	form.shtTblInput1.visible := true;
epilog

end;</source>
