    <JadeMethod name="plotEntranceWindow" id="2d844646-cc06-45bb-a3c8-748d84f90351">
        <updating/>
        <source>plotEntranceWindow(_moveTime : TimeStamp; _chkptTime : TimeStamp)updating;
//
// Changed On	By			Reason
// ----------	-------		----------------------------------------------------------------
// 28/05/2012	cnwdap1		PAR #29639 Correct the drawing of the tidal windows when system 
//							cannot derive an opening time
vars
	redLineX,
	offsetLineX,
	roundTo,
	int,
	size	: Integer;
	ts1Offset,
	ts2Offset,
	now,
	ts1,
	ts2 	: TimeStamp;
	tblHeight, tblHeightBlackBox,
	start,
	stop,
	tHeight,
	offset	: Real;
	str		: String;
	
begin
	roundTo := 15;	// Round reported times to the nearest 15 mins
	now := app.actualTimeServer();
	
	self.tblEntranceWindow.clearGraphics;
	self.tblEntranceWindow.drawTextAlign := DrawTextAlign_Center;
	tblHeight := self.tblEntranceWindow.height;
	tblHeightBlackBox	:= tblHeight;
	if not self.showRelativeTimesOnTidalModel then	//Par 17906. Feb 2009
		tblHeightBlackBox := tblHeightBlackBox * 2;	//black box will take whole area
	endif;
	
	int := 1;
	size := self.windowArray.size;

	while int &lt;= size do
		if int mod 2 &lt;&gt; 0 then
			ts1 := self.windowArray[int];
		else
			ts2 := self.windowArray[int];
			// draw the window of opportunity
			// Modified by Russell 19/10/99 - Round reported times to nearest 15 mins
			// ------------------------------------------------------------------
			if ts1 &lt;&gt; null then												// PAR #29639
				ts1Offset := ts1.changeByXXMinutes(self.chkptToTTTATime);
			endif;															// PAR #29639
			if ts2 &lt;&gt; null then												// PAR #29639
				ts2Offset := ts2.changeByXXMinutes(self.chkptToTTTATime);
			endif;															// PAR #29639

            // Round offset times
            ts1Offset := ts1Offset.roundToXXMinutes(roundTo);
            ts2Offset := ts2Offset.roundToXXMinutes(roundTo);

			if ts1 &lt;&gt; null then												// PAR #29639
				ts1 := ts1Offset.changeByXXMinutes(-1 * self.chkptToTTTATime);
			endif;															// PAR #29639
			if ts2 &lt;&gt; null then												// PAR #29639
				ts2 := ts2Offset.changeByXXMinutes(-1 * self.chkptToTTTATime);
			endif;															// PAR #29639

			// ------------------------------------------------------------------

            //AA Old code: does not plot windows in right place !
			//start := (timestampStart.minutesDiff(ts1) / minutesPerPixel).Integer;
			//stop  := (timestampStart.minutesDiff(ts2) / minutesPerPixel).Integer;

			//New code. Use the time array to find the pixel position of the tidal window
			//The +2 at the end is a fudge factor to get the exact pixel posn

			
			if (not self.timeArray.isEmpty) then
				if ts1 &lt;&gt; null then															// PAR #29639
					start := ((self.timeArray[1].minutesDiff(ts1) / self.minutesPerPixel).Integer) + 2;
				endif;																		// PAR #29639
				if ts2 &lt;&gt; null then															// PAR #29639
					stop  := ((self.timeArray[1].minutesDiff(ts2) / self.minutesPerPixel).Integer) + 2;
				else																		// PAR #29639
					stop := (self.tblEntranceWindow.left + self.tblEntranceWindow.width);	// PAR #29639
				endif;																		// PAR #29639
			endif;
						// draw the actual time blocks
			self.tblEntranceWindow.drawFillColor := Black;
			self.tblEntranceWindow.drawFilledRectangle(start, 0, stop, tblHeightBlackBox / 2, Black);
			str := (int / 2).String;
			tHeight := self.tblEntranceWindow.drawTextHeight(str) / 2;
			offset  := tblHeightBlackBox / 4;
			self.tblEntranceWindow.drawTextAt(str, ((stop - start) / 2) + start, offset - tHeight, White);

			if self.showRelativeTimesOnTidalModel then	//Par17906 Feb 2009
				// draw the offset time as seen from the wharf
				start := start + (self.chkptToTTTATime / self.minutesPerPixel).Integer;
				stop  := stop  + (self.chkptToTTTATime / self.minutesPerPixel).Integer;
	
				self.tblEntranceWindow.drawFillColor := TidalWindowBlue;
				self.tblEntranceWindow.drawFilledRectangle(start, tblHeight / 2, stop, tblHeight, TidalWindowBlue);
				self.tblEntranceWindow.drawTextAt(str, ((stop - start) / 2) + start, (offset * 3) - tHeight, White);
			endif;
			
			// draw the time labels
			self.makeTimeLabel(ts1, start);
			self.makeTimeLabel(ts2, stop);
			
		endif;		
		int := int + 1;
	endwhile;

	if size &lt; 1 then
		legendRegion.visible := false;
		legendBerth.visible	:= false;
		lblLegendRegion.caption := '';
		lblLegendBerth.caption	:= '';
		self.caption := self.Caption &amp; ': Tidal Data Not Available';
	else
		self.caption := self.Caption;	
	endif;

	// draw the center lines on the graphs
	self.tblEntranceWindow.drawWidth := 2;
	self.tblFlowRate.drawWidth 		:= 2;
	self.tblDepth.drawWidth 			:= 2;

	//AA 23/8/01:Find pixel posn of red line and offset small red line
	//Now we adjust for daylight saving, it may not be in the centre of the graph
	//Main Red line is time at checkpoint. Offset Red line is pilot / berth time
	if self.timeArray.isEmpty then
		redLineX := ((now.minutesDiff(_chkptTime) / self.minutesPerPixel).Integer) + 2;
		offsetLineX := ((now.minutesDiff(_moveTime) / self.minutesPerPixel).Integer) + 2;
	else
		redLineX := ((self.timeArray[1].minutesDiff(_chkptTime) / self.minutesPerPixel).Integer) + 2;
 		offsetLineX := ((self.timeArray[1].minutesDiff(_moveTime) / self.minutesPerPixel).Integer) + 2;
 	endif;

	if not self.showRelativeTimesOnTidalModel then	//Par 17906 Feb 2009
		tblEntranceWindow.drawLine(redLineX, 0, redLineX, tblHeight, Red);	//showing red line only for black box
	else
		tblEntranceWindow.drawLine(redLineX, 0, redLineX, tblHeight / 2, Red);
		tblEntranceWindow.drawLine(offsetLineX, tblHeight / 2, offsetLineX, tblHeight, Red);
	endif;
	tblFlowRate.drawLine(redLineX, 0, redLineX, tblFlowRate.height, Red);
	tblDepth.drawLine(redLineX, 0, redLineX, tblDepth.height, Red);
end;</source>
        <Parameter name="_moveTime" type="TimeStamp"/>
        <Parameter name="_chkptTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="plotGraphCurrent" id="255606ff-b4c3-4324-b51e-295e318030ec">
        <source>plotGraphCurrent(_tidalModel 		: HMS_TidalModelDefinition; 
					_currentArray 	: RealArray input; 
					_colour, 
					_multiplier		:Integer);

vars
	int,
	size		: Integer;
	value,
	y,
	c,
	lowestPlot,
	highestPlot,
	meanPlot		: Real;
	tbl			: Table;
begin
	tbl := self.tblFlowRate;
	tbl.visible := false;
	tbl.drawWidth := 3;
	tbl.clearGraphics;
	c := tbl.height / 2;
	self.lblFRPositive.caption := "+ "; //par19678 cnwrs1 june 2009
	self.lblFRPositive.top := tbl.top-5;
	self.lblFRNegitive.caption := "- ";
	self.lblFRNegitive.top := tbl.top+tbl.height-10;
	
	lowestPlot := ((_tidalModel.lowestValue * _multiplier) * -1) + c;
	highestPlot := ((_tidalModel.highestValue * _multiplier) * -1) + c;
	meanPlot := (lowestPlot - highestPlot) /2;
	
	size := _currentArray.size;
	int := 1;
	while int &lt;= size do
		y := (((_currentArray[int] * _multiplier) * -1) + c) + meanPlot;
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;y.String;
		tbl.drawPoint(int, y, _colour);
		int := int + 1;
	endwhile;
	
epilog
	tbl.visible := true;
end;</source>
        <Parameter name="_tidalModel" type="HMS_TidalModelDefinition"/>
        <Parameter name="_currentArray" type="RealArray" usage="input"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_multiplier" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="plotGraphCurrentGraduated" id="f42794f7-d961-47f6-a8a7-b0714c434962">
        <source>plotGraphCurrentGraduated(_tidalModel : HMS_TidalModelDefinition; 
					_currentArray : RealArray input; 
					_colour, 
					_multiplier	:Integer);
//
// cnwrs1 Par19678 June 2009 to enable current graph to be graduated with a scale
//
vars
	int : Integer;
	size : Integer;
	value : Real;
	y : Real;
	c : Real;
	lowestPlot : Real;
	highestPlot : Real;
	meanPlot : Real;
	tbl	: Table;
	lowestValue : Real;
	highestValue : Real;
	highest, lowest : Real;
	yl , yh : Real;
begin
	tbl := self.tblFlowRate;
	tbl.visible := false;
	tbl.drawWidth := 3;
	tbl.clearGraphics;
	c := tbl.height / 2;
	if _tidalModel.highestValue.abs &gt; _tidalModel.lowestValue.abs then
		highestValue := _tidalModel.highestValue.abs;
		lowestValue := -(_tidalModel.highestValue.abs);
	else
		highestValue := _tidalModel.lowestValue.abs;
		lowestValue := -(_tidalModel.lowestValue.abs);
	endif;
	self.lblFRPositive.caption := "+"&amp;highestValue.String&amp;' ';
	self.lblFRPositive.top := tbl.top-5;
	self.lblFRNegitive.caption := "-"&amp;highestValue.String&amp;' ';
	self.lblFRNegitive.top := tbl.top+tbl.height-10;
	highestPlot := (highestValue * _multiplier) + c;
	lowestPlot := (lowestValue * _multiplier) + c;
	meanPlot := (lowestPlot - highestPlot) /2;
//write class.name&amp;'::'&amp;method.name&amp;' graph c='&amp;c.String&amp;' lowestValue='&amp;lowestValue.String&amp;' highestValue='&amp;highestValue.String&amp;' meanPlot='&amp;meanPlot.String&amp;' _multiplier='&amp;_multiplier.String;
//write class.name&amp;'::'&amp;method.name&amp;' graph lowestPlot='&amp;lowestPlot.String&amp;' highestPlot='&amp;highestPlot.String;
	size := _currentArray.size;
	int := 1;
	while int &lt;= size do
		y := (_currentArray[int] * (-c/highestValue)) + c;
//		y := (((_currentArray[int] * _multiplier) * -1) + c) + meanPlot;
//write class.name&amp;'::'&amp;method.name&amp;' points value='&amp;_currentArray[int].String&amp;' y='&amp;y.String;
		if _currentArray[int] &lt; lowest then
			lowest := _currentArray[int];
			yl := y;
		endif;
		if _currentArray[int] &gt; highest then
			highest := _currentArray[int];
			yh := y;
		endif;
		tbl.drawPoint(int, y, _colour);
		int := int + 1;
	endwhile;
//write class.name&amp;'::'&amp;method.name&amp;' highest='&amp;yh.String&amp;' '&amp;highest.String&amp;' lowest='&amp;yl.String&amp;' '&amp;lowest.String;	
epilog
	tbl.visible := true;
end;</source>
        <Parameter name="_tidalModel" type="HMS_TidalModelDefinition"/>
        <Parameter name="_currentArray" type="RealArray" usage="input"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_multiplier" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="plotGraphDaylight" id="2f3a9529-e4e2-4ac9-9666-c11d59eab013">
        <source>plotGraphDaylight(_tidalModel 		: HMS_TidalModelDefinition; 
					_daylightArray 	: RealArray input; 
					_colour, 
					_multiplier		:Integer);

vars
	int : Integer;
	size: Integer;
	value,
	y,
	c,
	lowest,
	highest,
	highestPlot,
	tmpVal		: Real;
	tbl			: Table;
begin
	//tbl := self.tblFlowRate;
	tbl.visible := false;
	tbl.drawWidth := 3;
	tbl.clearGraphics;
	c := tbl.height / 2;
	
	size := _daylightArray.size;
	int := 1;
	while int &lt;= size do
		y := (((_daylightArray[int] * _multiplier) * -1) + c);// - highestPlot;
		tbl.drawPoint(int, y, _colour);
		int := int + 1;
	endwhile;
	
epilog
	tbl.visible := true;
end;</source>
        <Parameter name="_tidalModel" type="HMS_TidalModelDefinition"/>
        <Parameter name="_daylightArray" type="RealArray" usage="input"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_multiplier" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="plotGraphHeight" id="bdc45bb4-cd96-45f6-81da-2f2f08e111bf">
        <source>plotGraphHeight(_tidalModel : HMS_TidalModelDefinition; _heightArray : RealArray input; _colour, _multiplier:Integer);

vars
	int : Integer;
	size: Integer;
	value,
	h,
	y,
	c,
	lowestPlot,
	highestPlot,
	meanPlot		: Real;
	tbl			: Table;
	
begin
	tbl := self.tblDepth;
	//tbl.visible := false;
	tbl.drawWidth := 3;
	tbl.clearGraphics;
	c := tbl.height / 2;
	
	lowestPlot := ((_tidalModel.lowestValue * _multiplier) * -1) + c;
	highestPlot := ((_tidalModel.highestValue * _multiplier) * -1) + c;
	meanPlot := (lowestPlot - highestPlot) /2;

/*	size := _heightArray.size;
	int := 1;
	while int &lt;= size do
		y := (((_heightArray[int] * _multiplier) * -1) + c) + meanPlot;
		tbl.drawPoint(int, y, _colour);
		int := int + 1;
	endwhile;
	
// could be
	foreach h in _heightArray do
		y := (((h * _multiplier) * -1) + c) + meanPlot;
		int := int + 1;
	endforeach;
	
*/
	int := 1;
	foreach h in _heightArray do
		y := ((( h * _multiplier) * -1) + c) + meanPlot;
		tbl.drawPoint(int, y, _colour);
		int := int + 1;
	endforeach;
	
epilog
//	tbl.visible := true;
end;</source>
        <Parameter name="_tidalModel" type="HMS_TidalModelDefinition"/>
        <Parameter name="_heightArray" type="RealArray" usage="input"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_multiplier" type="Integer"/>
    </JadeMethod>
