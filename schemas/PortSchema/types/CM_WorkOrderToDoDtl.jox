    <JadeMethod name="prepareAuditDetail" id="3ec211ff-e83d-4117-98d7-b4fb867fd745">
        <source>prepareAuditDetail(_str : String io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2023	navhl20	ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders

*/

vars
	tmpStr,
	priority 	: String;
	aCT		 	: CM_CalculationType;
	toDoTask	: CM_ToDoTaskDesc;
begin
	tmpStr := app.workOrderStatusEnumToString(self.status) &amp;" "&amp; tmpStr;
	_str := _str &amp; app.getErrorString(Status) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;

	tmpStr := null;
	if self.priority = CM_WorkOrder.WO_Priority_High then
		tmpStr := app.getErrorString(WO_PRIORITY_HIGH) &amp;" "&amp; tmpStr ;
		_str := _str &amp; app.getErrorString(Priority) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	else
		tmpStr := "" &amp;" "&amp; tmpStr ;
		_str := _str &amp; app.getErrorString(Priority) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.allToDoTasksDescs.isNotEmpty then
		foreach toDoTask in self.allToDoTasksDescs do
			if tmpStr = null then
				tmpStr := tmpStr &amp; toDoTask.description;
			else
				tmpStr :=tmpStr &amp; Comma &amp; toDoTask.description;
			endif;
		endforeach;
		_str := _str &amp; "ToDo Tasks" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	/* // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1
	tmpStr := null;
	foreach aCT in app.myRoot.allCalculationTypesByCode do
		if self.overrideCalcType = aCT.calculationType then
			tmpStr := aCT.description &amp;" "&amp; tmpStr ;
			_str := _str &amp; "Calculation Type" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
			break;
		endif;
	endforeach;
	*/
epilog

end;</source>
        <Parameter name="_str" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="da58f2d6-82b4-4654-9e9a-cef5d8ed2a30">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 December 2022	navcs2	ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen

*/

vars
	pxy 			: SelfType;
	completedOK		: Boolean;
begin
	pxy := inheritMethod();

	self.allToDoTasks.copy(pxy.allToDoTasks);
	self.allToDoTasksDescs.copy(pxy.allToDoTasksDescs);
	pxy.myDebtor := self.myDebtor; // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1

	completedOK := true;	
	return pxy;
	
epilog
	if not completedOK then
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="61a16cc1-85a3-461c-9505-81a0abb3b484">
        <updating/>
        <source>setForCreate(_pxyWoDDtl: CM_WorkOrderToDoDtl io; _realWorkOrder: CM_WorkOrder) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 November 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
02 March 	2023	navtnr20  Task 56815: EUP - Work Order Contract Id
28 Mar 2023 		navhl20 ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
*/

vars
	pxy : CM_WorkOrderDtl;
begin
	pxy := _pxyWoDDtl;
	inheritMethod(pxy, _realWorkOrder);
	
	self.remarks 			:= _pxyWoDDtl.remarks;
	self.noCharge 			:= _pxyWoDDtl.noCharge;
 // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1	self.overrideCalcType 	:= _pxyWoDDtl.CM_WorkOrderToDoDtl.overrideCalcType;
	self.priority 			:= _pxyWoDDtl.priority;
 // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1	self.overrideRate 		:= _pxyWoDDtl.CM_WorkOrderToDoDtl.overrideRate;
	self.contractId			:= _pxyWoDDtl.contractId;		 //navtnr20 02-03-2023 56815
	self.myDebtor := _pxyWoDDtl.myDebtor; // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1
	self.status				:= WO_STATUS_PENDING;								//28.3.2023 navhl20	#57301[57303]
	self.allToDoTasksDescs.clear();
	self.allToDoTasks.clear();
	
	_pxyWoDDtl.allToDoTasksDescs.copy(self.allToDoTasksDescs);
	_pxyWoDDtl.allToDoTasks.copy(self.allToDoTasks);
epilog

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WorkOrderToDoDtl" usage="io"/>
        <Parameter name="_realWorkOrder" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="c9d7836b-a25c-4e84-8485-e255d6da9acd">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WorkOrderToDoDtl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
30 December 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
02 March 	2023	navtnr20  Task 56815: EUP - Work Order Contract Id
*/

vars
	taskDesc : CM_ToDoTaskDesc;
	wod 	 : CM_WorkOrderToDoDtl;
	pxy : CM_WorkOrderDtl;
begin
	pxy := _pxyWoDDtl;
	inheritMethod(pxy);
	
	self.remarks 			:= _pxyWoDDtl.remarks;
	self.noCharge 			:= _pxyWoDDtl.noCharge;
 // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1	self.overrideCalcType 	:= _pxyWoDDtl.overrideCalcType;
	self.priority 			:= _pxyWoDDtl.priority;
 // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1	self.overrideRate 		:= _pxyWoDDtl.overrideRate;
	self.contractId			:= _pxyWoDDtl.contractId; //navtnr20 02-03-2023 56815
	self.myDebtor := _pxyWoDDtl.myDebtor; // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1
	self.allToDoTasksDescs.clear();
	self.allToDoTasks.clear();
	
	_pxyWoDDtl.allToDoTasksDescs.copy(self.allToDoTasksDescs);
	_pxyWoDDtl.allToDoTasks.copy(self.allToDoTasks);
epilog

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WorkOrderToDoDtl"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateCompleted" id="26f065e5-9911-43c3-a277-99ab18479b41">
        <updating/>
        <source>setForUpdateCompleted(_pxyWODtl: CM_WorkOrderToDoDtl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/11/2024	navkc1 JIRA Story MTN-33012: EUP | WO Transaction Billing Change of Debtor

*/

vars

begin
	
	self.noCharge := _pxyWODtl.noCharge;
	
	// If we are changing it to No charge, don't bother updating other fields.
	// Simply void the exisiting invoice lines and that's it.
	if self.noCharge then
		return;
	endif;
	
	inheritMethod(_pxyWODtl);
	
	self.myDebtor := _pxyWODtl.myDebtor;
	
	self.remarks 	:= _pxyWODtl.remarks;
epilog

end;</source>
        <Parameter name="_pxyWODtl" type="CM_WorkOrderToDoDtl"/>
    </JadeMethod>
