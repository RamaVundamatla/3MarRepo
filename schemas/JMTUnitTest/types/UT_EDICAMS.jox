    <JadeMethod name="tSuzanoCamsReleaseSTPF" id="442d1785-1eaf-4b64-9593-413a4c041f5b">
        <source>tSuzanoCamsReleaseSTPF();
//
// cnwrs1
//26 May 2016	cnwrs1	SuzanoCamsRelease with 2 trans to check Single Transaction Per File
constants
	Cargo_Type = "PLAS";//= "PULPPAPER";
	Cargo_Subtype = "PULP";
	CamGroup 		= "UTSUREL";
	CamProtocol 	= "UT_SUZRELEASE_34561";
	SenderCode 		= "UT_SENDER";
	SenderCodeDepot = "UT_SENDERDEPOT";
	ShipperCode 	= "UT_SHIPPER";
	FacilityCode 	= "UT_FACILITY";
	RecipientCode 	= "UT_RECIPIENT";
	OperatorCode = "SUZ";
	CargoName1 = "0058675-010-078";
	CargoName2 = "0058675-010-079";
	VehicleID1 : String = 'SGTUTV1';
	DriverID1 : String = 'SGTDRIVER1';
	VehicleID2 : String = 'SGTUTV2';
	DriverID2 : String = 'SGTDRIVER2';
vars
	runDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camProtocolDesc :CM_CamProtocolDesc;
	operatorDict : CM_OperatorByCodeDict;
	freightForwarders : CM_ConsigneeConsignorSet;
	operator : CM_Operator;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camTaskHistory : CM_CamTaskHistory;
//	str : String;
	registeredTransactions : StringArray;
	strArray : HugeStringArray;
	vvr	: CM_VehicleVisitRecord;
	tempStr : String;
	transObj : CM_Transaction;
	registeredCargoTypes : IntegerArray;
	cargo1 : CM_TrackedItem;
	cargo2 : CM_TrackedItem;
	bs1 : CM_BlockStack;
	cargoTypeObj : CM_CargoType;
	gateOut	: CM_GateArea;
	product : CM_Product;
	expectedOutput : String;
	actualOutput : String;
	actualXML : JadeXMLDocument;
	expectedXML : JadeXMLDocument;
	ignoreList : StringArray;
	theLines : HugeStringArray;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	bs					: CM_BlockStack;
begin

	// 25/01/2017 cnwmh5
	bs := self.addBlockStack("SCMR1", 99, null);
	self.assertNotNull(bs);
	
	create camEditTriggerFields transient;
	create theLines transient;
	startDateTime := app.actualTimeServer;
	operator := app.myRoot.allOperators[OperatorCode];
	cargoTypeObj := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	product := cargoTypeObj.allProducts[operator.code, Cargo_Subtype];
	gateOut := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_POUT).asString);
	assertNotNull(gateOut);
	
	// Delete the cargo 
	cargo1 := self.getTrackedItem(CargoName1).CM_Cargo;
	self.deleteTrackedItem(cargo1, false);
	cargo1 := self.getTrackedItem(CargoName1).CM_Cargo;
	self.assertIsDeleted(cargo1);
	cargo2 := self.getTrackedItem(CargoName2).CM_Cargo;
	self.deleteTrackedItem(cargo2, false);
	cargo2 := self.getTrackedItem(CargoName2).CM_Cargo;
	self.assertIsDeleted(cargo2);

	deleteTerminalArea("UTBS345");
	bs1:=self.addBlockStack("UTBS345", 200, null);
	self.assertNotNull(bs1);
	self.deleteVehicle(VehicleID1);
	self.deleteVehicle(VehicleID2);

	// Add the cargo
	cargo1 := self.createTrackedItem(CargoName1,
										cargoTypeObj.type,
										"MT",					// commodity is not needed
										operator,
										false, 
										bs.myLocationsController).CM_Cargo;			// transhipToPort
	tempStr	:= 'Adding Cargo ' &amp; CargoName1.display &amp; ' failed.' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(cargo1, tempStr);
	beginTransaction;
	cargo1.setPropertyValue("myProduct", product);
    cargo1.setRemarks("000002", false ); //TFS 2188 Change Previously it was always 1
	commitTransaction;
	self.move(cargo1, bs1);
	self.opts.addAssoc("TotalRequested", 1);
	///self.opts.addAssoc("addRelease", true);
	self.opts.addAssoc("ReleaseRequest", null);
	vvr := gateOutGC(VehicleID1, "", DriverID1, cargo1, gateOut.getFirstExitGate, null);
	self.workVehicle(vvr);
	self.roadExit(vvr);

	cargo2 := self.createTrackedItem(CargoName2,
										cargoTypeObj.type,
										"MT",					// commodity is not needed
										operator,
										false, 
										bs.myLocationsController).CM_Cargo;			// transhipToPort
	tempStr	:= 'Adding Cargo ' &amp; CargoName2.display &amp; ' failed.' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(cargo2, tempStr);
	beginTransaction;
    cargo2.setRemarks("000002", false ); //TFS 2188 Change Previously it was always 1
	cargo2.setPropertyValue("myProduct", product);
	commitTransaction;
	self.move(cargo2, bs1);
	self.opts.addAssoc("TotalRequested", 1);
	///self.opts.addAssoc("addRelease", true);
	self.opts.addAssoc("ReleaseRequest", null);
	vvr := gateOutGC(VehicleID2, "", DriverID2, cargo2, gateOut.getFirstExitGate, null);
	self.workVehicle(vvr);
	self.roadExit(vvr);

	// create cam group and protocols
	camGroup := self.getCamGroup(CamGroup);
	if camGroup &lt;&gt; null then
		foreach camProtocol in camGroup.protocols do
			self.deleteCamProtocol(camProtocol.code);
		endforeach;
	endif;
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, RecipientCode, SenderCode, SenderCodeDepot, FacilityCode, false, false, false, operatorDict, freightForwarders, 16, ShipperCode);
	self.assertNotNull(camGroup);
	self.deleteCamProtocol(CamProtocol);
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	
	create registeredCargoTypes transient;
	registeredCargoTypes.add(cargoTypeObj.id);

	create registeredTransactions transient;
	camProtocolDesc := app.myRoot.allCamProtocolDescs["Suzano Release"];
//	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRail).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRoad).asStringJMT);
	camProtocol	:= self.createCamProtocol(CamProtocol, camGroup, "NZCHC", operator.code, camProtocolDesc, false, true, false, registeredTransactions, registeredCargoTypes, null, camEditTriggerFields,null);	

	// RUNS CAMS
//	runDateTime := app.actualTimeServer;
//	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	self.runCamsNow(startDateTime, camProtocol);
	
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq[camProtocol, 1];
	self.assertNotNull(camTaskHistory);
	
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		
		actualOutput := actualOutput &amp; tempStr;
	endforeach;
	create ignoreList transient;
	ignoreList.add("ns0:ID");
	ignoreList.add("ns0:Delivery_Date");
	ignoreList.add("ns0:Transport_ID");
	
	expectedOutput := self.zOutput_SuzanoReleaseXMLSTPF1();
	create actualXML transient;
	create expectedXML transient;
	actualXML.parseString(actualOutput);
	expectedXML.parseString(expectedOutput);
	self.zCompareXML(actualXML, expectedXML, ignoreList);
	actualOutput := null;
	delete actualXML;
	delete expectedXML;
	delete ignoreList;

	camTaskHistory := camProtocol.taskHistoryByProtocolSeq[camProtocol, 2];
	self.assertNotNull(camTaskHistory);
	
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		
		actualOutput := actualOutput &amp; tempStr;
	endforeach;
	create ignoreList transient;
	ignoreList.add("ns0:ID");
	ignoreList.add("ns0:Delivery_Date");
	ignoreList.add("ns0:Transport_ID");
	
	expectedOutput := self.zOutput_SuzanoReleaseXMLSTPF2();
	create actualXML transient;
	create expectedXML transient;
	actualXML.parseString(actualOutput);
	expectedXML.parseString(expectedOutput);
	self.zCompareXML(actualXML, expectedXML, ignoreList);
epilog
	delete actualXML;
	delete expectedXML;
	delete ignoreList;
	delete operatorDict;
	delete freightForwarders;
	delete registeredTransactions;
	delete registeredCargoTypes;
	delete theLines;
	delete camEditTriggerFields;
end;
</source>
