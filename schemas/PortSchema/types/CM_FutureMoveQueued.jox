    <JadeMethod name="isLCNextToFM" id="c14d316e-cd19-42bc-9a38-001783047f02">
        <source>isLCNextToFM(_lc : CM_LocationsController) : Boolean;
// ---------------------------------------------------------------------------
// Created:     20 January 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lc : CM_LocationsController;
begin

	lc := self.allLocationsControllers.last;
	
	if lc = null then
		return false;
	endif;
	
	if not lc.isGridLocation() then
		return false;
	endif;
	
	if lc.CM_GridController.myNextController = _lc then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMultiQueuedMove" id="24cb5950-9567-47af-9a18-ea0ef3a75966">
        <source>isMultiQueuedMove(): Boolean;

// Created by cnwdvb1 on 17 September 2007

vars

begin
	if not self.isMultiQueueMove then
		return false;
	endif;
	
	// PAR 18639 If this is the first future move queued, then it is ok to work it
	if self.myTrackedItem.allQueuedFutureMoves.first = self then
		return false;
	endif;

	return self.isMultiQueueMove;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isQueueEntryAbove" id="31ac959f-8446-4b0b-a220-06a140967f7e">
        <source>isQueueEntryAbove(_currentQueue : CM_RadioTelemetryQueue;
					_currentIndex : Integer) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 January 2010	cnwer1	Initial creation

*/

vars
	rtQueueEntry : CM_RTQueueEntry;
	invalidObj : Boolean;	//17 Jun 2013	NDL	Par 31793
begin
	
	//if there is more than one it will be for multi machine moves we are on interested in te first one from this location
	rtQueueEntry:=self.allRTQueueEntries.first;
	if rtQueueEntry = null then
		return false;
	endif;
	on Exception do app.handleDeletedObject(exception, rtQueueEntry, invalidObj);	//17 Jun 2013	NDL	Par 31793
	if rtQueueEntry.hasHeldTasks() then
		return false;
	endif;
	//now check 
	if invalidObj then	//17 Jun 2013	NDL	Par 31793
		return false;
	endif;
	if rtQueueEntry.myQueue &lt;&gt; _currentQueue then
		return false;
	endif;
	if invalidObj then	//17 Jun 2013	NDL	Par 31793
		return false;
	endif;
	if _currentQueue.allEntries.indexOf(rtQueueEntry) &lt; _currentIndex then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_currentQueue" type="CM_RadioTelemetryQueue"/>
        <Parameter name="_currentIndex" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveQueueEntryAbove" id="7db62604-4e49-4ca5-a70f-5d3452194553">
        <source>moveQueueEntryAbove(_rtQueueEntry :CM_RTQueueEntry;
					 _allRestrictingLCs : CM_LCSet ) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 January 2010	cnwer1	Initial creation

*/

vars
	rtQueueEntry 	: CM_RTQueueEntry;
	queueIndex		: Integer;
	targetLC 		: CM_LocationsController;
	currentQueue	: CM_RadioTelemetryQueue;
begin
	if self.allRTQueueEntries.isEmpty then
		return false;
	endif;
	//if there is more than one it will be for multi machine moves we are on interested in te first one from this location
	rtQueueEntry:=self.allRTQueueEntries.first;
	//now check 
	if rtQueueEntry.myQueue &lt;&gt; _rtQueueEntry.myQueue then
		return true;
	endif;
	
	currentQueue:=rtQueueEntry.myQueue;
	//might already be moved above rt queue entry
	queueIndex:=currentQueue.allEntries.indexOf(_rtQueueEntry);
	if 	currentQueue.allEntries.indexOf(rtQueueEntry) &lt; queueIndex then
		return true;
	endif;
	
	
	//see if its queue entry is queued in a location not found in allRestrictingLCs
	targetLC:=rtQueueEntry.allTasks.first.ultimateTargetLocation;
	if not _allRestrictingLCs.includes(targetLC) then
		//need to move this entry up in the rt queue
		currentQueue.allEntries.remove(rtQueueEntry);
		currentQueue.allEntries.insert(queueIndex,rtQueueEntry);
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
        <Parameter name="_allRestrictingLCs" type="CM_LCSet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeLocationController" id="7601d1e8-c140-45da-bf93-9a1febac8352">
        <source>removeLocationController(_location : CM_LocationsController);
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.allLocationsControllers.includes(_location) then
		self.allLocationsControllers.remove(_location);
	endif;
end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="resetLocations" id="bfe220b1-4878-4f86-b56f-8ed256e13e16">
        <updating/>
        <source>resetLocations(_control : CMIF_MoveController) updating;
// -------------------------------------------
// Created 13 October 2003 by cnwdvb1
// -------------------------------------------
/*

Date		Who		Reason
27 Feb 2009	cnwkpd1	Fix Grid form refresh for target location changes
29 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
14 Aug 2013 cnwer1 	par 32256
*/

vars

begin

	self.allLocationsControllers.clear();
	_control.allToLocations.copy(self.allLocationsControllers);
	self.updateObjectEdition(self);	// par 30292
	
	//14 Aug 2013 cnwer1 	par 32256
	if self.myFutureMovePlanned &lt;&gt; null then
		self.myFutureMovePlanned.resetLocations(_control);
	endif;
	
end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d43c3984-a621-4860-beef-0b45c84ec023">
        <updating/>
        <source>setForCreate(_control : CMIF_MoveController; _moveType : Integer; arrayIndex : Integer ) updating;
/*
 ------------------------------------------------------------------------
Created:			05 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------	--------------	-----------------------------------------
12/05/2010		cnwdap1			CCMS 1116 Tranship changes
21/05/2019		jlgzm1			TFS 42840 MSL Direct Release between Voyages and Rail
06/11/2024		navdap1			MTN-18897 EUP | FR 53485 EUP - Warehouse Yard Allocation
---------------------------------------------------------------------------
*/
vars
	theTI : CM_TrackedItem;
	wle : CM_WorkListEntry;
	lc : CM_LocationsController;
	control : CMIF_MoveController;
	anFM : CM_FutureMove;
	source, target : String;
	
	//cnwmc5 - 20 Jan 2014 - PAR 31507
	futureMovePlan : CM_FutureMovePlanned;
	pwle, pwleDR : CM_WorkListEntry; //planned FM wles //tfs42840
begin

	theTI := _control.myTrackedItem;
	wle := _control.myWorkListEntry;
	
	self.moveType := _moveType;
		
	theTI.setQueuedFutureMove(arrayIndex, self);
	self.myTerminal := self.myTrackedItem.myTerminal;		

	if _control.allToLocations.isEmpty and not _control.isDriverInitiatedMove then	 //epr CCMS 1391 21/8/14 driver initiated moves don't have to have a target the driver will specify one
	//TI has not been queued moved yet!	
		
		//! Hmm, maybe this is a delete case?
		return;
	endif;
	
	self.setLocations(_control.allToLocations);
	//_control.allToLocations.copy(self.allLocationsControllers);
	self.isMoveToFullGCArea := _control.isPlannedToFullGCArea;			// MTN-18897
	
	lc := _control.myToPrimaryLocation;
	if wle &lt;&gt; null then
		anFM := wle.myFutureMove; // PAR 8061
	//	if anFM &lt;&gt; null and anFM.isKindOf(CM_FutureMovePlanned) then // PAR 8061
		if anFM &lt;&gt; null and anFM.isKindOf(CM_FutureMovePlanned) and ( self.myFutureMovePlanned &lt;&gt; anFM.CM_FutureMovePlanned ) then	// 28 Feb 2011	NDL	Par 27079
			self.myFutureMovePlanned :=  anFM.CM_FutureMovePlanned; // PAR 8061
		endif; // PAR 8061
	endif;
	if self.myFutureMovePlanned = null then // PAR 8061
		//cnwmc5 - 20 Jan 2014 - PAR 31507
		if lc &lt;&gt; null then
			futureMovePlan := lc.getFutureMoveOfTypeForTI(PLANNING_MODE, TI_FutureMovePlannedOrDLR, self.myTrackedItem).CM_FutureMovePlanned;
			if futureMovePlan &lt;&gt; null and futureMovePlan.myFutureMoveQueued = null then
				self.myFutureMovePlanned := futureMovePlan;
			endif;
		endif;
	endif;
		
	theTI.refreshMyFutureLocations(QUEUE_MODE,null);

	control := _control;
	if wle = null then
		// see if the job has a wle for this TI.
		if control.jobForMove &lt;&gt; null then
			wle := control.jobForMove.getWLEForTI(theTI);
			control.setMyWorkListEntry(wle);
		endif;
	endif;

	if wle = null or control.isDirectorMove then
		if control.isHHInTransitMove and wle = null then	//17 Jan 2018	NDL	TFS 36704
			// This will only happen if we are moved to ground as part of an in transit move and we were unplanned before teh process started.
			// create a voyage job so we go in the voayge queue.
			control.createVoyageWLEForNonCraneMove();
		else
			// create a yard internal job/tasks for the RT queue.
			control.createYardInternalQueueJob(self);
		endif;
	endif;	
	
	if not control.isOverstowMove then
		// tfs42840 start
		// if is a direct release move then need to link DR Wle
		if _control.myDDWorkListEntry &lt;&gt; null then
			// if we have a planned FM then want the queued wles in the same order.
			if self.myFutureMovePlanned &lt;&gt; null then
				pwle := self.myFutureMovePlanned.myWorkListEntry;
				pwleDR := self.myFutureMovePlanned.myWorkListEntryDR;
				if pwle &lt;&gt; null and pwleDR &lt;&gt; null then
					self.setMyWorkListEntry(pwle, false);
					self.setMyWorkListEntryDR(pwleDR, false);
				endif;
			else
				self.setMyWorkListEntry(control.myWorkListEntry, false);
				self.setMyWorkListEntryDR(control.myDDWorkListEntry, false);
			endif;
		else
			self.setMyWorkListEntry(control.myWorkListEntry, false);	
		endif;
		// tfs42840 end			
	endif;
	
	// ### PAR 8712
	if wle &lt;&gt; null then
		if wle.locationTarget = null then

			source := wle.locationSource;
			//target := _control.getPrimaryLocationId();
			target := control.myToPrimaryLocationString;

			wle.setLocations(source,target);		
		endif;
	endif;
		
end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="arrayIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForDRRTMove" id="19659677-33db-496f-9341-d6692cf61796">
        <updating/>
        <source>setForDRRTMove(_control : CMIF_MoveController; _destLoc : CM_LocationsController; _plannedFM : CM_FutureMovePlanned input) updating;
/*

Purpose:			When the TI/WLE is split by a machine during a move, a new FM needs to be
					created to link the new WLEs, this method initialises the FutureMove 
					with the information required for the Direct Release move

Parameters:			_Control : The controller for the move
					_destLoc : destination location for the move
					_plannedFM : the FutureMovePlanned to link to self

Return Value:		

Date				Who		Reason
20 June 2019		jlgzm1	TFS 42863 MSL - Direct Delivery Between RORO Voyages and Rail - Break Bulk

*/

vars
	theTI 		: CM_TrackedItem;
	sourceWLE,
	destWLE		: CM_WorkListEntry;
	arrayIndex	: Integer;
	la			: CM_LCArray;
begin

	if _control = null then
		return;
	endif;
	
	if not _control.isDirectReleaseMove then
		return;
	endif;
	
	if _control.myWorkListEntry.isReceipt then
		sourceWLE := _control.myWorkListEntry;
		destWLE := _control.myDDWorkListEntry;
	else
		sourceWLE := _control.myDDWorkListEntry;
		destWLE := _control.myWorkListEntry;
	endif;
	
	self.setMyWorkListEntry(destWLE, false);
	self.setMyWorkListEntryDR(sourceWLE, false);
	
	theTI := sourceWLE.myTrackedItem;
	
	if theTI = null then
		// I can't beleive you've done this
		return;
	endif;
	
	arrayIndex := self.determineFutureMoveIndex(TI_FutureMoveQueued);
	//way to force future move to be inserted
	if arrayIndex = 0 and _control.moveIndex &gt; 0 then
		arrayIndex:=_control.moveIndex;
	endif;
	
	theTI.setQueuedFutureMove(arrayIndex, self);
	self.myTerminal := self.myTrackedItem.myTerminal;
	
	if _destLoc &lt;&gt; null then
		create la transient;
		la.add(_destLoc);
		self.setLocations(la);
	else
		self.setLocations(_control.allToLocations);
	endif;
	
	self.moveType := TI_FutureMoveQueued;
	theTI.refreshMyFutureLocations(QUEUE_MODE,null);
	
	if _plannedFM &lt;&gt; null then
		// set the required values on the planned FM
		_plannedFM.setMyTrackedItem(theTI);
		_plannedFM.setMyOriginalSplitCargo(theTI.CM_Cargo);
		_plannedFM.setLocations(self.allLocationsControllers);
		
		self.setMyFutureMovePlanned(_plannedFM);
	endif;

epilog
	delete la;
end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
        <Parameter name="_destLoc" type="CM_LocationsController"/>
        <Parameter name="_plannedFM" type="CM_FutureMovePlanned" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setLocations" id="d0775f28-8d65-4a27-afc4-d1680345ed19">
        <updating/>
        <source>setLocations(_allLocationsControllers: CM_LCArray) updating;

// Created by cnwdvb1 on 02 November 2006

vars

begin
	
	
	self.allLocationsControllers.clear;
	
	if _allLocationsControllers = null then
		return;
	endif;
	
	if not _allLocationsControllers.isEmpty then
		_allLocationsControllers.copy(self.allLocationsControllers);
	endif;

end;</source>
        <Parameter name="_allLocationsControllers" type="CM_LCArray"/>
    </JadeMethod>
