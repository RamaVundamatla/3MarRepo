    <JadeMethod name="setComboValues" id="7250bb3b-5ba0-48c1-8626-b08a73b5aee1">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
// TFS 8390
vars

begin
	_combo.clear();
//	_combo.addItem(AuditAny_str);
	_combo.addItem(AuditCreated_str);
	_combo.addItem(AuditDeleted_str);
	_combo.addItem(AuditUpdated_str);
	_combo.addItem(AuditInformation_str);
	
	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.text := self.translateToDisplayValue(_queryOperator.CM_QIntegerLookupEqual.searchValue);
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := self.translateToDisplayValue(_queryOperator.CM_QIntegerLookupNotEqual.searchValue);
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="13f207b5-e062-494c-8c00-ad4a7dcd06d2">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QIntegerIsOneOf; _passport: CM_Passport);
// TFS 8390
vars
	intArray	: IntegerArray;
	idx,intSite	: Integer;
	strObj		: CM_String;
begin

	_tbl.purgeTableObjects();
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	
	create intArray transient;
	
//	intArray.add(AuditAny);
	intArray.add(AuditCreated);
	intArray.add(AuditUpdated);
	intArray.add(AuditDeleted);
	intArray.add(AuditInformation);

	self.setListTableFromIntConstants(_tbl, _operator, intArray, Audit_Type_Constant);	

epilog
	delete intArray;
end;
</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QIntegerIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="de141787-ed7f-4eb7-ae7b-8793a19f3975">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
// TFS 8390
vars
	str			: String;
	auditType,
	numRows,
	idx			: Integer;
	ia			: IntegerArray;

begin

	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			auditType := app.auditTypeStringToEnum(_tbl.getCellText(idx, 2));
/*			
			if _tbl.getCellText(idx, 2) = AuditCreated_str then
				couType := AuditCreated;
			elseif _tbl.getCellText(idx, 2) = AuditUpdated_str then
				couType := AuditUpdated;
			elseif _tbl.getCellText(idx, 2) = AuditDeleted_str then
				couType := AuditDeleted;
			elseif _tbl.getCellText(idx, 2) = AuditInformation_str then
				couType := AuditInformation;
			elseif _tbl.getCellText(idx, 2) = AuditAny_str then
				couType := AuditAny;
			endif;
*/
			ia.add(auditType);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);

epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="13c7ba7e-1761-4c0c-bf0b-7e2be67fe35d">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine : CM_SelectorCriteriaLine ): Any;
// TFS 8390
vars
	couType	: Integer;

begin

	if _value.String.isInteger then
		return _value;
	endif;
	
	
	if _value.String = AuditCreated_str then
		couType := AuditCreated;
	elseif _value.String = AuditUpdated_str then
		couType := AuditUpdated;
	elseif _value.String = AuditDeleted_str then
		couType := AuditDeleted;
	elseif _value.String = AuditInformation_str then
		couType := AuditInformation;
	elseif _value.String = AuditAny_str then
		couType := AuditAny;
	endif;

	
	return couType;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="f50141b5-3b2f-42c4-b409-ce00cbf5c622">
        <source>translateToDisplayValue(_couType : Integer): String;
// TFS 8390
vars

begin
	if _couType = AuditUpdated then
		return 'Updated';
	elseif _couType = AuditCreated then
		return 'Created';
	elseif _couType = AuditDeleted then
		return 'Deleted';
	elseif _couType = AuditInformation then
		return 'Info';
	else
		return 'Any';
	endif;

end;</source>
        <Parameter name="_couType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="40871f43-2870-4392-b374-917703c1decf">
        <source>translateToSearchValue(_couTypeDescription : String): Any;
// TFS 8390
vars

begin
	if _couTypeDescription = AuditCreated_str then
		return  AuditCreated;
	elseif _couTypeDescription = AuditUpdated_str then
		return  AuditUpdated;
	elseif _couTypeDescription = AuditDeleted_str then
		return  AuditDeleted;
	elseif _couTypeDescription = AuditInformation_str then
		return  AuditInformation;
	elseif _couTypeDescription = AuditAny_str then
		return  AuditAny;
	endif;

	
end;</source>
        <Parameter name="_couTypeDescription" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="0daf32b0-fae2-444b-8531-083e60841b0f">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	auditType : Integer;

begin
	if _value.isKindOf(String) then
		return _value.String;
	elseif _value.isKindOf(Integer) then
		auditType := _value.Integer;
		if auditType = AuditCreated then
			return  AuditCreated_str;
		elseif auditType = AuditUpdated then
			return  AuditUpdated_str;
		elseif auditType = AuditDeleted then
			return  AuditDeleted_str;
		elseif auditType = AuditInformation then
			return  AuditInformation_str;
		elseif auditType = AuditAny then
			return  AuditAny_str;
		endif;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
