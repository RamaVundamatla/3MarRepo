    <JadeMethod name="getEntTableGroup" id="711dd8c2-6005-4945-922b-9761108757a2">
        <source>getEntTableGroup(pName : String) : EntTableGroup;
// ---------------------------------------------------------------------------
// Created:     19 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableGroup	: EntTableGroup;

begin

	entTableGroup := app.myRoot.myEntTableDataRoot.allEntTableGroups[pName];

/*	
	if entTableGroup = null then
		// group hasn't been loaded into transient copy for easy access
		// load group into transient 
		self.loadEntTableGroup(pName);

		// set entTableDef to transient copy
		entTableGroup := self.allEntTableGroups[pName];
		
		if entTableGroup = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableGroup (' &amp; pName &amp; ') not found');
		endif;
	endif;
*/	
	return entTableGroup;

end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="EntTableGroup"/>
    </JadeMethod>
    <JadeMethod name="getNavObjectByCode" id="0ade2ae0-14dc-4bb0-b271-9e9ecb28c08f">
        <source>getNavObjectByCode(pCode : String) : CMUI_NavigatorObject;
// ---------------------------------------------------------------------------
// Created:     20 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx			: Integer;
	navObject	: CMUI_NavigatorObject;

begin

	foreach idx in 1 to self.allNavigatorObjects.size do
		if self.allNavigatorObjects[idx].code = pCode then
			navObject := self.allNavigatorObjects[idx];
			break;
		endif;
	endforeach;
	
	return navObject;
	
end;</source>
        <Parameter name="pCode" type="String"/>
        <ReturnType type="CMUI_NavigatorObject"/>
    </JadeMethod>
    <JadeMethod name="goToNavObjectByCode" id="444e2cee-d3e0-44f5-966e-ab06ca180776">
        <source>goToNavObjectByCode(pCode : String);
// ---------------------------------------------------------------------------
// Created:     19 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	navObject	: CMUI_NavigatorObject;
	
begin

	app.mousePointer := Window.MousePointer_HourGlass;

	navObject := app.myController.getNavObjectByCode(pCode);

	if navObject &lt;&gt; null then
		navObject.goToObject(null, null, true);
	endif;

epilog
	app.mousePointer := Window.MousePointer_Default;
	
end;</source>
        <Parameter name="pCode" type="String"/>
    </JadeMethod>
