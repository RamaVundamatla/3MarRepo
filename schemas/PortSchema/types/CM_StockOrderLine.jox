    <JadeMethod name="setForCreate" id="e301ba80-9600-4341-aa73-5e20435feedf">
        <updating/>
        <source>setForCreate(_pxyLine: CM_StockOrderLine) updating;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	disPort : CM_Port;
	voyage : CM_Voyage;
begin
	_pxyLine.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	self.comments			:= _pxyLine.comments;
	self.commentsOperator 	:= _pxyLine.commentsOperator;
	self.dischargePort		:= _pxyLine.dischargePort;
	self.operatorRef1		:= _pxyLine.operatorRef1;
	self.operatorRef2		:= _pxyLine.operatorRef2;

	//disPort	:= app.myRoot.allPorts[self.dischargePort];
	disPort	:= app.myRoot.allPorts[self.dischargePort];
	if self.myStockOrderHeader &lt;&gt; null then
		voyage := self.myStockOrderHeader.myVoyage;
		if voyage &lt;&gt; null and disPort &lt;&gt; null then
			voyage.addPortToAllPorts(disPort);
		endif;				
	endif;
end;</source>
        <Parameter name="_pxyLine" type="CM_StockOrderLine"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="578b9710-4c64-4787-9d86-b22c2d499c06">
        <updating/>
        <source>setForUpdate(_pxyLine: CM_StockOrderLine) updating;
// ---------------------------------------------------------------------------
// Created:     27 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	disPort : CM_Port;
	voyage : CM_Voyage;
begin

	_pxyLine.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	self.comments			:= _pxyLine.comments;
	self.commentsOperator 	:= _pxyLine.commentsOperator;	
	self.dischargePort	:= _pxyLine.dischargePort;
	self.operatorRef1	:= _pxyLine.operatorRef1;
	self.operatorRef2	:= _pxyLine.operatorRef2;
	
	//disPort	:= app.myRoot.allPorts[self.dischargePort];
	disPort	:= app.myRoot.allPorts[self.dischargePort];
	voyage := self.myStockOrderHeader.myVoyage;
	if voyage &lt;&gt; null and disPort &lt;&gt; null then
	//cnwer1 ccms 1058
		voyage.addPortToAllPorts(disPort);
	endif;				

end;</source>
        <Parameter name="_pxyLine" type="CM_StockOrderLine"/>
    </JadeMethod>
