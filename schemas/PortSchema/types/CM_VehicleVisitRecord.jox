    <JadeMethod name="getPreGateCompleteTimeLocalTZ" id="7c18ded6-45a5-4a80-9e17-985b63c18d65">
        <source>getPreGateCompleteTimeLocalTZ(): TimeStamp;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
03 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars

begin
	return self.systemToLocalTime(self.getPreGateCompleteTime());
epilog

end;</source>
