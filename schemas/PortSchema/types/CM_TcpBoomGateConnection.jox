<Class name="CM_TcpBoomGateConnection" id="5da6f5f0-64fe-4c3c-9140-320b424d7696">
    <superclass name="CnTcpConnection"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="init" id="0bc46b22-f991-4ca8-9a62-32a147b6a93d">
        <updating/>
        <source>init(_gateLane : CM_GateLaneController) updating;
/*
----------   ----------  --------------------------------------------------
Created:	27 February 2007 By cnwth2

Purpose:	At time of writing: no specs been given - all on assumption.
			Assuming the boom gate will be hooked up to a PC listening for a TCP packet of some sort
			and that the message is alway just to trigger the raising of the boom gate, and it
			automatically goes back down on a timer or sensor.
			
			Also assuming there's no problem with opening connection, sending msg and then closing.
			Also assuming we don't have to listen for a verification response from the boom gate.
			
Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	msg		: Binary;
begin
	if _gateLane = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null gate lane passed into send boom gate message');
		return;
	endif;
	
//th2 temp	
return;
	
	self.name				:= _gateLane.boomMachineName;//_tagReader.ipAddress;	
	self.port				:= _gateLane.boomPortNo;
	self.open();
	
	
	self.writeBinary(msg);
	self.close;
	

end;





</source>
        <Parameter name="_gateLane" type="CM_GateLaneController"/>
    </JadeMethod>
</Class>
