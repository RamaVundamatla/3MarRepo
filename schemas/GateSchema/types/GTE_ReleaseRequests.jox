/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/03/2010	cnwmh5	Initial creation
14/03/2016	cnwdap1	PAR #37606 Only call myAssistant.comboBoxISOTypeByGroup if ico group is not nul
					- otherwise qwe end up putting not available for entry iso types back in the combo box
*/

vars

begin
	self.tblEntry.setValueByControlName(combobox.name, combobox.text);
	//epr TFS 5831 25/8/17 if you null the iso group you want all the iso types to display
	self.myAssistant.comboBoxISOTypeByGroup(self.cmbISOType,self.cmbISOGroup.listObject.CM_ISOTypeGroup,self.cmbISOType.listObject.CM_ISOType);

epilog

