vars

begin


end;</source>
    </JadeMethod>
    <JadeMethod name="doEnableVoyage" id="4021db1a-3ac6-4898-8695-eda4c4a628df">
        <updating/>
        <source>doEnableVoyage(_enable : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	idx : Integer;
	
begin
	self.hideShowViewModes(false);
	self.hideShowPens(true, true);
	self.frmToolbar2.visible := _enable;
	
	if _enable then
		self.enableDisableAttributePens(true);
		self.enableDisableDrawingPens(true);
	else
		//self.splMain.hideLeftControl(true);
		self.enableDisableWorkModes(false, false);
		self.enableDisableAttributePens(false);
		self.enableDisableDrawingPens(false);
	endif;

	self.cmbCargoType.visible	:=	_enable;
	self.cmbCommodity.visible	:=	_enable;
	self.cmbPortDis.visible		:=	_enable;
	self.txtWeight.visible		:=	_enable;		// cnwdad1 30/07/2010 - PAR #24045.
	self.chkIgnoreWeightV.visible :=	_enable;	// cnwdad1 30/07/2010 - PAR #24045.
	self.doMnuWorkRemarksBayBuild();

	self.cmbCrane.visible := false;
	self.cmbJob.visible := false;

	self.doResize();
end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEstimatePages" id="2cceb343-3458-4683-b3f7-85f24fd556dc">
        <source>doEstimatePages() : Integer;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	numAreas : Integer;
	thePages : Real;
	tmpDrawingController	: SHP_BayDrawingController;
	tmpScale				: Real;
begin

	tmpDrawingController := self.myBayDrawingController;
	numAreas := tmpDrawingController.allBayDrawingFramesById.size;
	tmpScale := tmpDrawingController.scaleFactor;
	
	if tmpScale = 1 then
		thePages := (numAreas / 24);
	elseif tmpScale = 1.5 then
		thePages := (numAreas / 24);
	elseif tmpScale = 2 then
		thePages := (numAreas / 8);
	elseif tmpScale = 3 then
		thePages := (numAreas / 4);
	elseif tmpScale = 4 then
		thePages := (numAreas / 2);
	elseif tmpScale = 6 then
		thePages := (numAreas / 2);
	elseif tmpScale = 9 then
		thePages := numAreas;
	endif; 
	if thePages &lt; 1 then
		thePages := 1;
	else
		thePages := thePages + .5;
	endif;

	return thePages.Integer;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doFlipHVPos" id="ee29ea19-2661-41f1-9275-b4bedf810b0f">
        <updating/>
        <source>doFlipHVPos() updating;
// ---------------------------------------------------------------------------
// Created:     07 July 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if (not self.toolbarClickPreProcessing(self.BTN_HOLDDRAWMODE)) then
		return;
	endif;

	app.mousePointer := Window.MousePointer_HourGlass;
	
	self.myBayDrawingController.drawHoldVertical := (not self.myBayDrawingController.drawHoldVertical);
	self.drawHolds(true);

epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doGetSelectorTIs" id="c610bef3-7092-4948-9b0b-0597ba10f71b">
        <updating/>
        <source>doGetSelectorTIs(_objs : ObjectSet) : CM_EnquiryController updating;



// NOT USED, MOVED TO ASSISTANT DELETE in 761





// ---------------------------------------------------------------------------
// Created:		November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	enqController			: CM_EnquiryController;
	queryDef				: CM_QueryDefinition;
	queryParams				: CM_QueryCriteriaLineHolder;
	anObject : Any;
	aTI : CM_TrackedItem;
	idx		: Integer;
	aTA : CM_TerminalArea;
	taStr : String;
	taS :	ObjectSet;
begin


// NOT USED, MOVED TO ASSISTANT DELETE in 761
return null;




	app.mousePointer := Window.MousePointer_HourGlass;

	queryDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 0];//mode = 0 for TrackedItem mode
	app.myQAFilter.createEnqControllerForMode(queryDef.mode, queryDef.type, enqController);
	
	create taS transient;
	create enqController.allObjects as CM_ObjectSet transient;
	create queryParams transient;
	queryParams.collectionBelongsTo := CM_Terminal.firstInstance;//don't need this?


	foreach anObject in _objs do
		aTI := anObject.CM_TrackedItem;
		if aTI.myTerminalArea &lt;&gt; null 
		and not taS.includes(aTI.myTerminalArea) then
			taS.add(aTI.myTerminalArea);
		endif;		
	endforeach;

	//create criteria
	self.doSetSelectorCriteria(queryParams,queryDef,'myTerminal', CM_QueryOperator.Operator_Equal,self.myTerminal);
	self.doSetSelectorCriteria(queryParams,queryDef,'site', CM_QueryOperator.Operator_Equal,TI_SITE_ONSITE_str);
	self.doSetSelectorCriteria(queryParams,queryDef,'voyageCode', CM_QueryOperator.Operator_Equal,self.myCurrentVoyage);
//	self.doSetSelectorCriteria(queryParams,queryDef,'planningState', CM_QueryOperator.Operator_NotEqual,"Planned to Load");
	self.doSetSelectorCriteria(queryParams,queryDef,'myTerminalArea', CM_QueryOperator.Operator_IsOneOf,taS);


	//execute query
	enqController.myCriteriaLineHolder := queryParams;
	enqController.doQuery(queryDef);


	return enqController;
epilog
	delete taS;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_objs" type="ObjectSet"/>
        <ReturnType type="CM_EnquiryController"/>
    </JadeMethod>
    <JadeMethod name="doGridAreaDragDropEvent" id="b8079a02-984f-4d03-b37d-fc01763b66e1">
        <updating/>
        <source>doGridAreaDragDropEvent(frame: SHP_BayDrawingFrame input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/05/2019	jlgzm1		TFS 42840 MSL - Direct Delivery Between LOLO RORO Voyages and Rail
// ---------------------------------------------------------------------------
vars
begin
	
	/* With Direct Release, its now ok to drag drop from Rail or Road Ops form
	if CM_DataTable.hasInstance(win) and win. CM_DataTable.form.isKindOf( CMUI_OpsForm) then 
			app.msgBox("Cannot drag drop from Rail or Road Ops form to the Ship Planning form.","Dragging Error",
							MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
	endif;
	*/
	
	if CMUI_GridAreaForm.hasInstance(win) or 
	   CMUI_GridAreaFrame.hasInstance(win) or
	   CMUI_GridAreaDrawingFrame.hasInstance(win) or
	   CM_DataTable.hasInstance(win) then 
		self.doDropFromGridAreaForm(frame, win, x,y);
	endif;
	
	/*
	if app.myPassport.trxCompletedOK then
		app.isDragging := true;
	else
		app.isDragging := false;
	endif;
	frame.dragMode := DragMode_None;
	*/
		
epilog
	app.isDragging := false;
	frame.dragMode := DragMode_None;
	frame.enableEvent("mouseMove",false);
end;</source>
        <Parameter name="frame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doGridAreaMouseMoveEvent" id="bdf8757e-0a01-4993-9b72-0201a5efb052">
        <updating/>
        <source>doGridAreaMouseMoveEvent(frame: SHP_BayDrawingFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     26 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	frameObj		: SHP_BayDrawingFrame;
	tmpObj			: Object;
	theTI			: CM_TrackedItem;
	dragCursorObj	: Picture;
	aTIArray		: CM_TIArray;
	controllerObj	: SHP_BayDrawingController;
	tmpSlot			: CM_SlotController;
	tmpRequest		: CM_SlotRequest;
	
begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	if frame = self.aMyOriginalWindow then
		frameObj	:=	frame;
	else
		frameObj	:=	self.aMyOriginalWindow.SHP_BayDrawingFrame;
	endif;
	
	if button = Window.MouseButton_Left 
	and shift.hasNoKeyboardPressed() // ### PAR 14287
	and app.dragDetected(x, y, self.origXPos, self.origYPos)
	then
		// initiate a drag/drop
		tmpObj	:=	frameObj.getObjectForPosition(self.origXPos.Integer, self.origYPos.Integer);
		
		if tmpObj = null or (tmpObj &lt;&gt; null and (not tmpObj.isKindOf(CM_SlotController))) then
			return;
		endif;

		controllerObj	:=	self.myBayDrawingController;
		tmpSlot			:=	tmpObj.CM_SlotController;
		
		if self.displayMode = ShpDisplayMode_ColCodeDisch then
			// for planning discharge
			theTI := tmpSlot.getTIAtIndex(REAL_MODE, 1);

		elseif self.displayMode = ShpDisplayMode_ColCodeLoad
		and self.workingMode = WorkMode_Plan
		then
			tmpRequest	:=	tmpSlot.mySlotRequestLoad;
			
			if tmpRequest &lt;&gt; null then
				theTI	:=	tmpSlot.getTIAtIndex(PLANNING_MODE, 1);
			endif;

			// Now check if there is a discharge SOB associated
			// with this slot.  It is valid to drag this to the
			// load slot for planning.
			tmpRequest := tmpSlot.mySlotRequestDischarge;
			if tmpRequest &lt;&gt; null
			and tmpRequest.isSOB
			then
				if theTI &lt;&gt; null then
					// we found a load request above so need to ask user which one to drag
					if app.msgBox('There is a planned load cargo and a planned SOB for this slot.  ' &amp;
								  'Do you want to drag the SOB cargo?', 'Which Cargo?', 
								  MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
						theTI := null;
					endif;
				endif;
				
				if theTI = null then
					theTI := tmpSlot.getTIAtIndex(REAL_MODE, 1);
				endif;
			endif;
		else
			theTI	:=	tmpSlot.getTIAtIndex(controllerObj.moveMode, 1);
		endif;

		if theTI = null then
			return;
		endif;
			
		if controllerObj.displayMode = ShpDisplayMode_Proposed
		or controllerObj.workingMode = self.WorkMode_Plan
		then
			controllerObj.moveMode := PLANNING_MODE;
		else
			controllerObj.moveMode := REAL_MODE;
		endif;
		
		self.moveModeForm := controllerObj.moveMode;
		app.myDraggedTrackedItem := theTI;
		self.setMoveControllerSource(theTI);
		
		if controllerObj.moveMode = REAL_MODE then
			app.myMoveController.mySlotRequest := null;
		// AKB2004FEB added from here
		// having planned cargo to the load slots, the users can drag the cargo around, within a job, to even out the weight.
		// this is actually unplanning and replanning the cargo to a different slot.
		// this if statement if for when the users are doing that for DLR Loads.
		// The problem was that the originating location was being set to the DLR TI actual location, which in this case is wrong.
		elseif controllerObj.moveMode = PLANNING_MODE then
			if theTI.isRehandle and controllerObj.displayMode = ShpDisplayMode_ColCodeLoad then
				app.myMoveController.setMyOriginatingLocation(tmpSlot);
				app.myMoveController.mySlotRequest := tmpSlot.mySlotRequestLoad;
			endif;
		endif;
		
		frameObj.dragMode	:=	self.DragMode_Drag;
		create dragCursorObj transient;

		self.setPictureDragCursor(dragCursorObj);
		
		if dragCursorObj &lt;&gt; null then
			frameObj.dragCursor	:=	dragCursorObj.picture;
		endif;
	endif;
epilog
	delete dragCursorObj;
	delete aTIArray;
end;</source>
        <Parameter name="frame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doGridAreaMouseUpEvent" id="021ea4e8-08fc-4111-b7f9-dc2ae55ebcd2">
        <updating/>
        <source>doGridAreaMouseUpEvent(frame: SHP_BayDrawingFrame input;button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	frameObj	: SHP_BayDrawingFrame;
	theObj		: Object;
	thePIC		: CMIF_PopupInfoController;
	
begin
	frameObj	:=	frame;
	theObj		:=	frameObj.getObjectForPosition(x.Integer, y.Integer);
	self.txtWeight.text	:=	0.Decimal.asStringWeightJMT();		// cnwdad1 30/07/2010 - PAR #24045.
	
	if app.myMoveController &lt;&gt; null then
		app.myMoveController.ignoreWeightValidation	:=	self.chkIgnoreWeightV.value;	// cnwdad1 02/08/2010 - PAR #24045.
	endif;
	
	if theObj = null then
		self.myBayDrawingController.clearAllSelectedObjects();
		self.cmbJob.listIndex := -1;
		self.chkOutOfSequence.value := self.myCurrentVoyage.createOutOfSequenceLoadJobs(); //cnwrd1 par 30626 ccms 2209 23.10.12
		return;
	endif;
	
	if frameObj.longLeftClick
	and (not app.isDragging)
	and (not frameObj.isDrawDeskTopRectangle)
	and self.mnuGridHideMacro.caption = self.MNU_MACRO_SHOW		// macro info is hidden
	and (CM_SlotController.hasInstance(theObj)
	or CM_HatchLid.hasInstance(theObj))
	then
		create thePIC transient;
		thePIC.setForCreate(theObj, self.displayMode, self.frmPopupInfo,
							self.tblPopupInfo,self.frmToolBarPopup,
							self.frmPopupInfoPic1, self.picExtraInfoTI1, 
							self.btnPopupEnq);
		self.showPopupInfoFrame(thePIC);
	else
		self.showExtraInfo(theObj);
	endif;

	self.doSetCombosFromMouseUp(theObj, x, y, shift);
	
	frameObj.handleMouseUp(theObj, button, shift, x, y);
	self.doGridAreaMouseUpStatusLine(theObj);
epilog
	frameObj.enableEvent(Frame::mouseMove.name, false);
	app.isDragging := false;
end;</source>
        <Parameter name="frame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doGridAreaMouseUpStatusLine" id="314d6d04-d6a9-4872-950d-d4a659f26922">
        <source>doGridAreaMouseUpStatusLine(_obj : Object);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	numTIs,
	theMode		: Integer;
	theCaption	: String;
	tmpTI		: CM_TrackedItem;
	tmpSlot		: CM_SlotController;
	tmpSlotDefn	: CM_SlotDefn;
	tmpJob		: CM_VoyageJob;
	tmpRequest	: CM_SlotRequest;
begin

	if _obj = null then
		return;
	endif;
	if (not CM_SlotController.hasInstance(_obj)) then
		return;
	endif;
	tmpSlot := _obj.CM_SlotController;

	theMode := self.displayMode;

	if theMode = ShpDisplayMode_Actual then
		tmpTI := _obj.CM_SlotController.getTIForDisplayMode(ShpDisplayMode_Actual, 0, numTIs);
		if tmpTI &lt;&gt; null then
			theCaption := tmpTI.id;
		endif;

	elseif theMode = ShpDisplayMode_Proposed then
		_obj.CM_SlotController.getProposedCargo(tmpTI, numTIs);
		if tmpTI &lt;&gt; null then
			theCaption := tmpTI.id;
		endif;

	elseif theMode = ShpDisplayMode_ColCodeLoad then
		tmpRequest := tmpSlot.mySlotRequestLoad; 
		if tmpRequest &lt;&gt; null then
			tmpJob := tmpSlot.mySlotRequestLoad.myJob.CM_VoyageJob;
			if tmpJob &lt;&gt; null then
				theCaption := "Job " &amp; tmpJob.jobNum;
				if tmpJob.isTwinLift then
					theCaption := theCaption &amp; " (T/L)";
				else
					theCaption := theCaption &amp; " (S/L)";
				endif;
				if tmpJob.isJobComplete then
					theCaption := theCaption &amp; " (C)";
				endif;
			elseif tmpRequest.dischargePort &lt;&gt; null then
				theCaption := tmpRequest.dischargePort &amp; ' ' &amp; tmpRequest.commodity;
			else
				tmpTI := tmpRequest.getTrackedItem();
				if tmpTI &lt;&gt; null then
					theCaption := tmpTI.id;
				endif;
			endif;
		endif;

	elseif theMode = ShpDisplayMode_ColCodeDisch then
		tmpRequest := tmpSlot.mySlotRequestDischarge; 
		if tmpRequest &lt;&gt; null then
			tmpJob := tmpRequest.myJob.CM_VoyageJob;
			if tmpJob &lt;&gt; null then
				theCaption := "Job " &amp; tmpJob.jobNum;
				if tmpJob.isJobComplete then
					theCaption := theCaption &amp; " (C)";
				endif;
				theCaption := theCaption &amp; " " &amp; tmpRequest.getSeqNum().asStringJMT;
			elseif tmpRequest.dischargePort &lt;&gt; null then
				theCaption := tmpRequest.dischargePort &amp; ' ' &amp; tmpRequest.commodity;
			else
				tmpTI := tmpRequest.getTrackedItem();
				if tmpTI &lt;&gt; null then
					theCaption := tmpTI.id;
				else
					tmpRequest := tmpSlot.mySlotRequestLoad;
					if tmpRequest &lt;&gt; null then
						theCaption := "Load CC: " &amp; tmpRequest.dischargePort &amp; " " &amp; tmpRequest.commodity;
					endif;
				endif;
			endif;
		endif;
	endif;
	theCaption := theCaption &amp; " Selected: " &amp; self.myCurrentDrawingController.allSelectedObjects.size.asStringJMT;

epilog
	self.frmStatusLine.myFrameCaption.caption := theCaption;

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doInitialiseSDF" id="5cb26c48-373a-430a-9fc2-56a374132886">
        <updating/>
        <source>doInitialiseSDF() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	tmpScrollableFrame	: CMUI_ScrollableFrame;
	tmpController	: SHP_BayDrawingController;
	tmpDkbGridArea	: CMUI_GridAreaDockBar;
begin

	tmpController := self.myBayDrawingController;

	tmpDkbGridArea	:= self.dkbGridArea;

	tmpDkbGridArea.setScrollingFrame(self.frmScrollBackgrd);
	tmpDkbGridArea.setHLabelDetails(0, false);
	tmpDkbGridArea.setVLabelDetails(0, false);


	// when able add labels as virtual to CMUI_GridAreaDockBar and
	// make dkbGridArea.myScrollableFrame protected
	tmpScrollableFrame := self.dkbGridArea.myScrollableFrame;
	tmpScrollableFrame.labels := ScrollBars_Both;

	self.btnViewDischPort.value := true;
	tmpController.setViewMode(VIEW_DISPORT);
	tmpController.moveMode := self.moveModeForm;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doInitialiseSDFPurge" id="88875fae-2b64-41b4-a020-0910c7123093">
        <source>doInitialiseSDFPurge();
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	self.myDrawingFrame.refreshNow();
	self.myDrawingFrame.visible := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="doLinkSlotRequests" id="c7bfdb2e-b9fe-4f35-86e1-ea43ca73034c">
        <updating/>
        <source>doLinkSlotRequests() updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		If the user has clicked the ALT key whilst colour coding we auto create the opposite colour coding.
//				i.e. if we are doing discharge CC then we auto CC the load.
// ---------------------------------------------------------------------------
vars
	theSelSlots,
	theAltSlots		: CM_SlotControllerArray;
	tmpObj	: Object;
	isDischarge		: Boolean;
	tmpDrawController	: SHP_BayDrawingController;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	tmpDrawController := self.myBayDrawingController;

	create theSelSlots transient;
	create theAltSlots transient;
	
	foreach tmpObj in tmpDrawController.allSelectedObjects do
		if tmpObj.isKindOf(CM_SlotController) then
			theSelSlots.add(tmpObj.CM_SlotController);
		endif;
	endforeach;

	foreach tmpObj in tmpDrawController.allSelectedObjectsAlt do
		if tmpObj.isKindOf(CM_SlotController) then
			theAltSlots.add(tmpObj.CM_SlotController);
		endif;
	endforeach;
	
	// nothing to do here...
	if theSelSlots.isEmpty or theAltSlots.isEmpty then
		return;
	endif;
	
	isDischarge := (self.displayMode = ShpDisplayMode_ColCodeDisch);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateSlotReqLinkSOBDLR2(theSelSlots, theAltSlots, tmpDrawController.allObjectEditions, isDischarge, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Attribute Setting', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	self.doClearAllSelectedPoints();

epilog
	delete theAltSlots;
	delete theSelSlots;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuAllocateCargo" id="cb45652d-ef6e-4cef-a941-fea226803dd4">
        <updating/>
        <source>doMnuAllocateCargo(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2012	cnwrd1	Initial creation

*/

vars
	theJob : CM_VoyageJob;
begin
	
	if menuItem.userObject = null then
		return;
	endif;
	
	theJob := menuItem.userObject.CM_VoyageJob;
	
	if theJob &lt;&gt; null then
		self.doDisplayJobAllocCargoForm(theJob);
	endif;
	

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
