    <JadeMethod name="doTableDblClick" id="04bc4a29-7a7c-419b-9ca5-5c4ed9db8661">
        <updating/>
        <source>doTableDblClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	itemObject : CM_Object;
begin

	if table = null then
		return;
	endif;
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	
	if table.accessRow(table.row).itemObject &lt;&gt; null then
		//cnwjo3 par 25628
		itemObject := table.accessRow(table.row).itemObject.CM_Object;
		
		if itemObject.isKindOf(CM_VoyageAllocation) then
			//at the moment do nothing.  possibly open voyage configuration later if customer requires
		else
			self.myAssistant.showTableMaintForm(itemObject, self.myMasterMenuAction, false, false);
		endif;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTurnOffContextMenus" id="79149d09-121e-4ced-a4bd-ebe93df05fd7">
        <source>doTurnOffContextMenus();
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	mnuChild : MenuItem;	
	idx : Integer;
begin
	inheritMethod();
	self.mnuGridSelectAreas.visible := true;
	self.mnuCargo.visible := false;
	self.mnuReturnToYard.visible := false;	
	self.mnuCargoEnquiry.visible := false;
	self.mnuCargoEdit.visible := false;
	self.mnuCargoCreateItem.visible := false; //ccms 1093 cnwrs1 Mar 2008
	self.mnuCargoAttach.visible := false;
	self.mnuCargoConnectDis.visible := false;
	self.mnuCargoUnplan.visible := false;
	self.mnuCargoManagement.visible := false;
	self.mnuTaskAdd.visible := false;
	self.mnuTaskComplete.visible := false;
	self.mnuStops.visible := false;
	self.mnuCargoLCL.visible := false;
	self.mnuGridUnplan.visible := false;
	self.mnuGridUnplanBay.visible := false;
	self.mnuGridUnplanJob.visible := false;
	self.mnuGridUnplanSlot.visible := false;
	self.mnuGridAutoplanBay.visible := false;
	self.mnuGridAutoplanJob.visible := false;
	self.mnuGridAutoplanSlot.visible := false;
	self.mnuGridSeperator01.visible := false;
	self.mnuGridLinkMain.visible := false;
	self.mnuGridReLink.visible := false;
	self.mnuGridDeLink.visible := false;
	self.mnuGridLink.visible := false;
	self.mnuGridReverse.visible := false;
	self.mnuTranship.visible:=false;
	
	// Clear Out The Clones // mnuErase done in inherit method
	foreach idx in 1 to 20 do
		mnuChild := 	self.mnuCargoEnquiry.getMenuItem(idx);
		if mnuChild = null then
			break;
		endif;
		delete mnuChild;
	endforeach;
	
	foreach idx in 1 to 20 do
		mnuChild := 	self.mnuCargoEdit.getMenuItem(idx);
		if mnuChild = null then
			break;
		endif;
		delete mnuChild;
	endforeach;
	
	self.allVoyAreaMenuItems.purge;
	
end;</source>
