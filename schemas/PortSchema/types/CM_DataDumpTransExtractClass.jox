<Class name="CM_DataDumpTransExtractClass" id="81a008db-ff3a-4a85-b557-ea4681413023">
    <superclass name="CM_DataDumpTransient"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>1:1 with CM_DataDumpExtractClass.</text>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="allTransSpecClasses" id="53244e06-06ea-4c2a-9c28-2173d95c7ead">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <type name="CM_DataDumpTransClassArray"/>
        <access>readonly</access>
        <Inverse name="CM_DataDumpTransSpecClass::myTransExtractClass"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myDataDumpClass" id="6486b59d-2105-40d7-a5ab-e95b5be6e219">
        <embedded/>
        <type name="CM_DataDumpClass"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myDataDumpExtractClass" id="9eff142b-c6ea-4345-826f-c127fedab571">
        <embedded/>
        <type name="CM_DataDumpExtractClass"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myTransExtractDef" id="1feecbe5-5338-409a-8358-234c799221a2">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_DataDumpTransExtractDef"/>
        <access>readonly</access>
        <Inverse name="CM_DataDumpTransExtractDef::allTransExtractClasses"/>
    </ExplicitInverseRef>
    <JadeMethod name="createClass" id="554cc898-736b-4140-b57f-de2c44e90994">
        <source>createClass(_extractClass: CM_DataDumpExtractClass; _realClass: Class;
		_initialiseOnCreate: Boolean) : CM_DataDumpTransSpecClass protected;
// ---------------------------------------------------------------------------
// Created:     03 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	newClass : CM_DataDumpTransSpecClass;

begin
	create newClass transient;
	newClass.setForCreate(_extractClass, _realClass, _initialiseOnCreate);
	self.allTransSpecClasses.add(newClass);
	
	return newClass;
end;</source>
        <access>protected</access>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass"/>
        <Parameter name="_realClass" type="Class"/>
        <Parameter name="_initialiseOnCreate" type="Boolean"/>
        <ReturnType type="CM_DataDumpTransSpecClass"/>
    </JadeMethod>
    <JadeMethod name="getExtractSequence" id="52e8a4cc-16ab-4c33-ae4e-8c8669a5697d">
        <source>getExtractSequence() : Integer;
// ---------------------------------------------------------------------------
// Created:     22 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	return self.myTransExtractDef.allTransExtractClasses.indexOf(self);
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b51e236a-1e40-4e73-8019-8e6a9c02c758">
        <updating/>
        <source>setForCreate(_extractClass: CM_DataDumpExtractClass; _initialiseAllClassesOnCreate: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     03 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	dataDumpClass : CM_DataDumpClass;
	subClasses: ClassColl;
	realClass : Class;

begin
	self.myDataDumpClass := _extractClass.myDataDumpClass;
	self.myDataDumpExtractClass := _extractClass;

	create subClasses transient;
	
	dataDumpClass := _extractClass.myDataDumpClass;
	dataDumpClass.getRealSubClasses(subClasses, true);
	
	foreach realClass in subClasses do
		self.createClass(_extractClass, realClass, _initialiseAllClassesOnCreate);
	endforeach;
	
epilog
	delete subClasses;
end;</source>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass"/>
        <Parameter name="_initialiseAllClassesOnCreate" type="Boolean"/>
    </JadeMethod>
</Class>
