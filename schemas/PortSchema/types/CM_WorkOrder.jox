    <JadeMethod name="canShowCargo" id="f554458e-df82-4636-844b-b9fd40551fbf">
        <source>canShowCargo():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2022 navma1	ChangeRequest 54645: MTN - Work Order Refactor (Additional Changes and remove IsSpecial)
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
04 Apr 2023	navma1	Bug 57456: EUP - Not Approved Status is not enabled for ToDo work orders
*/

vars

begin
	
	if self.isVoyageWorkOrder then
		if self.isWorkOrderForPermit or self.isWorkOrderForVoyageCargo then
			return true;
		endif;
	elseif self.isToDoWorkOrder then	//04.04.2023 navma1 #57456
		return false;
	else
		return true;
	endif;
	
	return false;
epilog

end;</source>
