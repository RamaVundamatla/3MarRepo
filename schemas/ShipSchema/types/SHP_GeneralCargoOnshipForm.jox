    <JadeMethod name="doTableClick" id="eabefdda-96b1-48f2-9649-276852bfb1c5">
        <source>doTableClick(table : Table input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2010	cnwmd1	Initial creation

*/

vars

begin
	if table.row &gt; table.fixedRows then
		self.mnuInspect.userObject := table.accessRow(table.row).itemObject;
	else
		self.mnuInspect.userObject := null;
	endif;
	
	//27 Apr 2016	NDL	TFS 1903
	self.btnTransfer.enabled := not self.tblBOLItems.allSelectedObjects.isEmpty;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnCOBAdd.enabled:= false;
		self.btnCOBDelete.enabled:= false;
		self.btnBOLAdd.enabled:= false;
		self.btnBOLDelete.enabled:= false;
		self.btnBOLItemAdd.enabled:= false;
		self.btnBOLItemDelete.enabled:= false;
		self.btnStowItmEdit.enabled:= false;
		self.btnStowItmDelete.enabled:= false;
		self.btnTransfer.enabled:= false;
		self.mnuTableEdit.enabled:= false;
		self.mnuTableEditStops.enabled:= false;
		self.mnuTransfer.enabled:= false;
		self.mnuTableAdd.enabled:= false;
		self.mnuTableDelete.enabled:= false;
		self.mnuTableUnlink.enabled:= false;
		self.mnuCargo.enabled:= false;
	endif;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTableContext" id="84c6fc9e-93a9-4f8d-bb90-a15549e742bb">
        <updating/>
        <source>doTableContext(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer) : Boolean protected, updating;

vars
	xLeft 	: Real;
	yTop	: Real;
	obj	 	: CM_Object;
begin

	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	self.mnuTableContext.userObject := cntrl;
	
	self.mnuCustomsStatus.visible := false;		//cnwmc5 - 3 July 2014 - CCMS 2353
	self.mnuCargo.visible := false;
	self.mnuTableEdit.visible := false;
	self.mnuTableDelete.visible := false;
	self.mnuTableLink.visible := false;
	self.mnuTableRelink.visible := false;
	self.mnuTableUnlink.visible := false;
	self.mnuTransfer.visible := false;	//27 Apr 2016	NDL	TFS 1903
	self.mnuInspect.visible := (self.mnuInspect.userObject &lt;&gt; null and app.isAllowedToInspect()); //+ cnwmd1 Par 24177
	self.mnuDEVCargo.visible := app.isSpecial();
	self.mnuOutTurnBOL.visible := false;	//07 Aug 2017	NDL	TFS 5701
	self.mnuOutTurnVoy.visible := false;	//24 Oct 2017	NDL	TFS 6940
	self.setupContextMenu(cntrl);

	self.popupMenu(self.mnuTableContext, xLeft.Integer, yTop.Integer);

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTableDblClick" id="f7d5d1d1-0f4f-4a4d-a522-fb3f16c1a86c">
        <updating/>
        <source>doTableDblClick(table: Table input) updating, protected;
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes
//
vars
	ti : CM_TrackedItem;
	obj : CM_Object;
begin
	if table.row = table.fixedRows then
		table.CM_DataTable.resortTableByColumn(table.column);
		table.CM_DataTable.colourRows(self.colorRow1, self.colorRow2);
		return;
	endif;

	obj := table.accessRow(table.row).itemObject.CM_Object;

	if not global.isValidObject(obj) then
		return;
	endif;
	if obj.isKindOf(CM_TrackedItem) then
		ti := obj.CM_TrackedItem;
	elseif obj.isKindOf(CM_BOLDtl) then
		self.myCurrentBOLDetail := obj.CM_BOLDtl;
		self.doAddEditBOL(false);
		return;
	// 23917 it can also be a BOL, from the 23144 changes
	elseif obj.isKindOf(CM_BOL) then
		self.myCurrentBOL := obj.CM_BOL;
		self.myCurrentBOLDetail := null;
		self.doAddEditBOL(false);
		return;
	endif;

	if table.row &gt; table.fixedRows then
		//if ti.isTranshipItem then																	// PAR #23645 CCMS 1116
		//	if ti.isOnSite then																		// PAR #23645 CCMS 1116
		//		if ti.myTranshipExport &lt;&gt; null then													// PAR #23645 CCMS 1116
		//			ti := ti.myTranshipExport;														// PAR #23645 CCMS 1116
		//		endif;																				// PAR #23645 CCMS 1116
		//	else																					// PAR #23645 CCMS 1116
		//		if ti.isTranshipExport then // from par13698 if the export is on ship show export	// PAR #23645 CCMS 1116
		//		elseif ti.myTranshipImport &lt;&gt; null then												// PAR #23645 CCMS 1116
		//			ti := ti.myTranshipImport;														// PAR #23645 CCMS 1116
		//		endif;																				// PAR #23645 CCMS 1116
		//	endif;																					// PAR #23645 CCMS 1116
		//endif;																					// PAR #23645 CCMS 1116
		self.myAssistant.showCargoEnquiryForm(ti, self.myMasterMenuAction, true, false);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTableExtract" id="2a9457f7-6f24-4e46-bfd2-10e43750338a">
        <updating/>
        <source>doTableExtract() updating, protected;

vars

begin
	if self.myCurrentTable &lt;&gt; null then
		self.doExtractTableToCSV(self.myCurrentTable);
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTablePrint" id="b7cb8b5f-64c6-4e9e-8ba6-45ec5930a38f">
        <updating/>
        <source>doTablePrint() updating, protected;

// 29 Nov 12	PJS		PAR # 30787 







vars
	header	: String;
begin
	if self.myCurrentTable &lt;&gt; null then
		header := self.caption &amp; " ";
		if self.myCurrentTable = self.tblBOL then
			header := header &amp; app.getErrorString(Bills_lading); 
		elseif self.myCurrentTable = self.tblBOLItems then
			header := header &amp; app.getErrorString(Cargo_items_BOL) &amp; " " &amp;  self.myCurrentBOL.number;
		elseif self.myCurrentTable = self.tblStowageItems then
			header := header &amp; app.getErrorString(Cargo_items_stowage) &amp; " " &amp; self.myCurrentHatch.getFullId();
		elseif self.myCurrentTable = self.tblCargo then
			header := header &amp; app.getErrorString(Cargo_board);  
		endif;
		self.doPrintOutTable(self.myCurrentTable, header, true, false, true, false);
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTransfer" id="be2dfc30-6f40-471d-852a-4806d78e4bfb">
        <updating/>
        <source>doTransfer()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2016	cnwndl1	Initial creation	TFS 1903

*/

vars

	modalResult : Integer;
	obj : Object;

begin

	modalResult := self.myAssistant.showTransferToBolForm( self.myCurrentBOL, self.tblBOLItems.allSelectedObjects );
	
	if modalResult = ModalResultOK then
		self.showBOLCargo();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUnlinkItems" id="8f73ac83-c8e3-4dd7-9a1e-e2f263caa527">
        <updating/>
        <source>doUnlinkItems(_tiSet : CM_TISet input) updating, protected;

vars
	count,
	idx,
	result 	: Integer;
	obj		: CM_Object;
	ti		: CM_TrackedItem;
begin
	if _tiSet = null then
		return;
	endif;

	// if dropping COB items (already have no BOL or BOLDtl), or empty set, just exit
	foreach ti in _tiSet do
		if ti.myReceivalBOL &lt;&gt; null then		//cnwmc5 - 1 May 2014 - PAR 34074
		//or ti.myBOLDtl &lt;&gt; null then			//cnwmc5 - 1 May 2014 - PAR 34074
			count := count + 1;
		endif;
	endforeach;
	if count = 0 then
		return;
	endif;

	while true do
		app.myTrxUA.trxDetachTIsFromBOLDtl(_tiSet, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			// refresh tables, buttons
			foreach ti in _tiSet do
				if self.tblBOLItems.findObjectInRow(ti, idx) then
					self.tblBOLItems.removeItem(idx);
					self.btnBOLItemEdit.enabled := false;
					self.btnBOLItemDelete.enabled := false;
				endif;
				if not self.tblCargo.findObjectInRow(ti, idx) then
					obj := ti;
					self.addItemObjectToTable(obj, tblCargo);
					self.hasCOB := true;
					self.btnCOBSearch.enabled := true;
				endif;
			endforeach;
			if self.isBOLDetailMode() then
				self.refreshBOLDetailEntry(null);
			else
				self.refreshBOLEntry(null);
			endif;
			break;
		else
			result := app.showErrorWarningDialog('Unlink BOL', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

end;
</source>
        <access>protected</access>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dragTrackedItem" id="56a19c5f-202b-4b78-966e-e69a54dcdf0e">
        <source>dragTrackedItem(_ti : CM_TrackedItem; _table : CM_DataTable input) protected;

vars
	picture : Picture;
begin

	if _ti = null then
		return;
	endif;
	_table.dragMode := DragMode_Drag;
	
	create picture transient;
	self.setPictureDragCursor(picture);
	if picture &lt;&gt; null then
		_table.dragCursor := picture.picture;
	endif;

epilog
	if picture &lt;&gt; null then
		delete picture;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="filterCargoTypes" id="0385a244-8ad5-4a8e-8313-002bc5bd3886">
        <source>filterCargoTypes() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 March 2010	cnwmd1	Initial creation

*/

vars
	combo : CMUI_ComboBox;
	cType : CM_CargoBOLType; //CM_CargoType;
	cTypes : CM_CargoBOLTypeArray;//CM_CargoTypeSet;
	i : Integer;
begin
	create cTypes transient;
	if self.allCargoTypes.size = 0 then
		self.myTerminal.allCargoBOLTypes.copy(cTypes);
	else
		self.allCargoTypes.copy(cTypes);
	endif;
	
	combo := self.cmbSearchCType;
	combo.clear();
	
	foreach cType in cTypes do
		if (not CM_CargoType.hasInstance(cType)) then
			continue;
		endif;
		combo.itemObject[combo.addItem(cType.description)] := cType;
	endforeach;
epilog
	delete cTypes;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getAllSelectedTIs" id="2a05b565-375f-4d37-986b-c2bcdccd6581">
        <updating/>
        <source>getAllSelectedTIs(_tiSet : CM_TISet input; _all : Boolean; _table : CM_DataTable input) updating;
//--------------------------------------------------------------
//Created: Par 26708 cnwrs1 12 Jan 2011
//--------------------------------------------------------------
vars
	rowIdx,
	rows : Integer;
	obj : Object;
begin
	
	if _tiSet = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _tiSet passed to method');
		return;
	endif;

	if _table = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _table passed to method');
		return;
	endif;	

	if _all then
		rows := _table.rows;
		foreach rowIdx in 2 to rows do
			obj := _table.accessRow(rowIdx).itemObject;
			if obj = null then
				continue;
			endif;
			_tiSet.add(obj.CM_TrackedItem);			
		endforeach;		
	else
		foreach obj in _table.allSelectedObjects do
			_tiSet.add(obj.CM_TrackedItem);			
		endforeach;	
	endif;
	
end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_all" type="Boolean"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSearchType" id="0f07f313-454d-45ae-973e-b91ca89561c4">
        <source>getSearchType() : String protected;

vars
	searchString : String;
begin
	if self.searchType = Search_BOL then
		searchString := app.getErrorString(BOL_Search); //"BOL Search";
	elseif self.searchType = Search_BOL_Detail then
		searchString := app.getErrorString(BOL_Details_search); //"BOL Details Search";
	elseif self.searchType = Search_BOL_Item then
		searchString := "BOL Cargo Search";
	elseif self.searchType = Search_Stowage then
		searchString := "Stowage Search";
	elseif self.searchType = Search_Stowage_Item then
		searchString := "Stowage Cargo Search";
	elseif self.searchType = Search_COB then
		searchString := app.getErrorString(Unassigned_cargo_search); 	//"Cargo on Board Search";
	endif;
	return searchString;
end;
</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableColumFilters" id="c930ddb4-f394-4a98-85f4-bc70f022a43e">
        <updating/>
        <source>getTableColumFilters(_table: Table; _allFilterColumns: CM_ColumnFilterDict io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2014	cnwmc5	Initial creation	PAR 34074

*/

vars

begin

	if self.allColumnFilters = null then
		create self.allColumnFilters transient;  // this is a non exclusive collection.
	endif;
	
	if self.allColumnFilters.isEmpty then
		return;
	endif;
	
	self.allColumnFilters.cloneFiltersForTable( _table, _allFilterColumns );
	

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_allFilterColumns" type="CM_ColumnFilterDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="51c5a4c1-9934-4c97-8b14-214583cd0673">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

vars
	xmlStr	: String;
begin
	xmlStr := inheritMethod();
	
	xmlStr := xmlStr &amp; self.xmlStrBOL; //epr par 31274 12/3/13 col organiser didn't remember when switching type of table
	xmlStr := xmlStr &amp; self.tblBOLItems.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; self.tblCargo.getXmlStrForColumns(true);
	
	xmlStr := xmlStr &amp; global.formatAsXML(XMLTag_splMain_Ratio, self.splMain.leftToRightRatio.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XMLTag_splBOL_Ratio, self.splBOL.leftToRightRatio.String);
	
	xmlStr := xmlStr &amp; global.formatAsXML( self.chkCurrentVoys.name, self.chkCurrentVoys.value.String );	//25 Feb 2021	NDL	TFS 50834
	
	return xmlStr;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleExceptionObject" id="ee68bde0-fd9c-4daa-991a-5528f217dec3">
        <source>handleExceptionObject(exObj : Exception; _obj : CM_Object io) : Integer protected;
// null the object if not found or deleted
constants
	ObjectNotFound	: Integer = 4;
	ObjectDeleted	: Integer = 1072;
begin

	if exObj.errorCode = ObjectNotFound 
	or exObj.errorCode = ObjectDeleted then
		_obj := null;
		return Ex_Resume_Next;
	endif;

	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_obj" type="CM_Object" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleNotificationEvent" id="2d91822b-ba4c-4208-aa10-9b7aaf546183">
        <updating/>
        <source>handleNotificationEvent(_eventType: Integer; _theObject: Object; _eventTag: Integer) updating;
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------
// 29/08/2023	navdap1		TFS 59721 EUP | Manifest Verify of Work Orders
vars

begin


	if _theObject.isKindOf(CM_Voyage) then // cnwrd1 par 23145 12.3.2010
		if self.myCurrentVoyage = _theObject  and _eventType = Object_Delete_Event then  // have we had our voyage deleted
			self.myCurrentVoyage := null;
			app.msgBox( app.getErrorString(ERR_DELETED_VOYAGE) ,'Voyage Deleted',MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon); //inform user
		endif;		
		self.doLoadVoyages(); //refresh search combo
	endif;
	
///app.writeStatement(method.name&amp;" eventType="&amp;_eventType.String&amp;" theObj="&amp;_theObject.String);
	if _eventType = Object_Update_Event then
		if CM_Object.hasInstance(_theObject) then
			if not app.isValidObject(_theObject) then		// TFS 59721
				self.removeObject(_theObject.CM_Object);	// TFS 59721
				return;										// TFS 59721
			endif;											// TFS 59721
			//self.updateObject(_theObject.CM_Object);
			if (self.isBOLDetailMode and _theObject.isKindOf(CM_BOLDtl)) or _theObject.isKindOf(CM_BOLIn) or _theObject.isKindOf(CM_TrackedItem) then		// 11/01/2011 cnwmh5 #26710		//cnwmc5 - 13 May 2014 - PAR 34134
				self.updateObject(_theObject.CM_Object);
			endif;
		endif;
	endif;
	
	if _eventType = Object_Delete_Event then
		if CM_Object.hasInstance(_theObject) then
			self.removeObject(_theObject.CM_Object);
		endif;
	endif;

end;
</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleUserNotificationEvent" id="f9bb25b9-a426-43fd-be46-caff1c77d926">
        <updating/>
        <source>handleUserNotificationEvent(_event : Integer; _theObject, _userObject : CM_Object) updating;
// CM_BOL and CM_BOLDtl add, change, delete; cargo add, delete; refresh tables
// 11/01/2011	cnwmh5		#26710 - Refactor Event_BOLAdd and Event_BOLUpdate
vars
	termEvent : Integer;
	bolCount : Integer;
	idx	: Integer;
	obj : CM_Object;
	ti	: CM_TrackedItem;
	bolDetail : CM_BOLDtl;
begin

	if self.myTerminal &lt;&gt; null then
		termEvent := self.myTerminal.getEventFromTerminalEvent(_event);
	endif;
	
	if termEvent = Event_BOLAdd and _theObject.isKindOf(CM_BOLIn) and self.myCurrentVoyage &lt;&gt; null then				// 11/01/2011 cnwmh5 #26710
		self.updateBillsOfLadingTblFrmNotif(_theObject);
	endif;	
	
	if termEvent = Event_BOLUpdate and _userObject.isKindOf(CM_BOLIn) and self.myCurrentVoyage &lt;&gt; null then			// 11/01/2011 cnwmh5 #26710
		self.updateBillsOfLadingTblFrmNotif(_userObject);
	endif;
	
	/*
	// 11/01/2011 cnwmh5 #26710 - Refactored
	if termEvent = Event_BOLAdd and
	   _theObject.isKindOf(CM_BOLIn) and
	   self.myCurrentVoyage &lt;&gt; null then
		if _theObject.CM_BOLIn.myVoyage = self.myCurrentVoyage then
			foreach bolDetail in _theObject.CM_BOLIn.allBOLDtls do
				bolCount := bolCount + 1;
				if self.includeBOLDetails(bolDetail) then
					obj := bolDetail;
					self.addItemObjectToTable(obj, self.tblBOL);
				endif;
			endforeach;
		endif;
		// handle first BOL being added this way
		if not self.hasBOLs then
			self.hasBOLs := (bolCount &gt; 0);
		endif;
		self.btnBOLSearch.enabled := self.hasBOLs;
	endif;
			
	if termEvent = Event_BOLUpdate and
	   _userObject.isKindOf(CM_BOLIn) and
	   self.myCurrentVoyage &lt;&gt; null then
		if _userObject.CM_BOLIn.myVoyage = self.myCurrentVoyage then
			// add any BOL Details not already in the table
			foreach bolDetail in _userObject.CM_BOLIn.allBOLDtls do
				bolCount := bolCount + 1;
				if self.includeBOLDetails(bolDetail) then
					if not self.tblBOL.findObjectInRow(bolDetail, idx) then
						obj := bolDetail;
						self.addItemObjectToTable(obj, self.tblBOL);
					endif;
				endif;
			endforeach;
		endif;
		// handle first BOL being added this way
		if not self.hasBOLs then
			self.hasBOLs := (bolCount &gt; 0);
		endif;
		self.btnBOLSearch.enabled := self.hasBOLs;

	endif;
	*/
	
	// either on-ship cargo add or BOL detail add
	if termEvent = TIEvent_PreNote_Add and
	   _theObject.isKindOf(CM_TrackedItem) and
	   self.myCurrentVoyage &lt;&gt; null then
		ti := _theObject.CM_TrackedItem;
		if ti.myVoyage = self.myCurrentVoyage then
			if ti.myBOLDtl = null then
				// add to cargo on board table
				if not self.tblCargo.findObjectInRow(ti, idx) then
					obj := ti;
					self.addItemObjectToTable(obj, self.tblCargo);
				endif;
				
			else
				// refresh the BOL (Detail) table entry as well, to get the TI total and qty differences current
				if self.isBOLDetailMode() then
					self.refreshBOLDetailEntry(null);
				else
					self.refreshBOLEntry(null);
				endif;
				self.showBOLCargo();
			endif;
		endif;
	endif;		
	
	
end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_theObject" type="CM_Object"/>
        <Parameter name="_userObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="hideSearch" id="e6ca50d6-1565-4c4c-ab23-bfda943b23c2">
        <source>hideSearch();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Dec 2012	cnwpjs1	Initial creation PAr #30787

*/

vars

begin

	if self.frmSearch.visible then
		self.frmSearch.visible := false;
	endif;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="includeBOL" id="5678c1df-d495-4437-8a6b-3f43ca2d2db1">
        <source>includeBOL(_bol : CM_BOL) : Boolean protected;
// 23144 apply BOL filtering to the current BOL
// 04/12/12	PJS		PAR #30787
vars

	includeReconciled	: Boolean;
	
begin
	
	if _bol = null then
		return false;
	endif;
	
	//30787
	if self.filterBOL &lt;&gt; null then
		if not _bol = self.filterBOL then
			return false;
		endif;
	endif;
		
	if self.filterBOLOperator &lt;&gt; null then
		if _bol.myOperator &lt;&gt; self.filterBOLOperator then
			return false;
		endif;
	endif;	
	
	if self.filterBOLReconciled &lt;&gt; null then
		includeReconciled := filterBOLReconciled = app.getErrorString(Yes);
		if not includeReconciled = _bol.isMarkedAsReconciled then
			return false;
		endif;
	endif;
	
	
	if self.filterBOLCommodity &lt;&gt; null then
			if not _bol.detailsIncludeCommodity(filterBOLCommodity) then
			return false;
		endif;
	
	endif;
	
	if self.filterBOLMarks &lt;&gt; null then
		if not _bol.detailsIncludeMarksLike(filterBOLMarks) then
			return false;
		endif;
	endif;
	
	if self.filterBOLCargoType &lt;&gt; null then
		if not _bol.detailsIncludeCargoType(filterBOLCargoType) then
			return false;
		endif;
	
	
	endif;
	
	/*
	if self.filterBOLNumber &lt;&gt; null then
		if not _bol.number.startsWith(self.filterBOLNumber) then
			return false;
		endif;
	endif;	
	*/

	return true;
end;
</source>
        <access>protected</access>
        <Parameter name="_bol" type="CM_BOL"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeBOLDetails" id="3e79d568-d8b3-4cbb-affd-857f15ded48a">
        <source>includeBOLDetails(_bd : CM_BOLDtl) : Boolean protected;
// apply BOL filtering to the current BOL detail

vars
	
begin
	
	if _bd = null then
		return false;
	endif;
	
	//+ cnwmd1 Par 22846
	if not self.allCargoTypes.includes(_bd.myCargoType) then
		return false;
	endif;
	/* //- cnwmd1, Par 22846
	if self.filterAllCargoType &lt;&gt; null then
		if _bd.cargoType &lt;&gt; self.filterAllCargoType.id then
			return false;
		endif;
	endif;*/
	

	if self.filterBOLCargoType &lt;&gt; null then
		if _bd.cargoType &lt;&gt; self.filterBOLCargoType.id then
			return false;
		endif;
	endif;
	
	//30787
	if self.filterBOL &lt;&gt; null then
		if not _bd.myBOL = self.filterBOL then
			return false;
		endif;
	endif;
	
	/*
	if self.filterBOLNumber &lt;&gt; null then
		if not _bd.myBOL.number.startsWith(self.filterBOLNumber) then
			return false;
		endif;
	endif;
	*/

	if self.filterBOLMarks &lt;&gt; null then
		if not _bd.markNumber.startsWith(self.filterBOLMarks) then
			return false;
		endif;
	endif;	

	if self.filterBOLCommodity &lt;&gt; null then
		if _bd.commodity &lt;&gt; self.filterBOLCommodity.code then
			return false;
		endif;
	endif;	

	return true;
end;
</source>
        <access>protected</access>
        <Parameter name="_bd" type="CM_BOLDtl"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeBOLItems" id="460997fb-9bf4-496a-be02-0c1e739f6cc4">
        <source>includeBOLItems(_ti : CM_TrackedItem) : Boolean protected;
// apply BOL Item filtering to the current tracked item
vars
	
begin
	
	if _ti = null then
		return false;
	endif;
	
	// 03/07/2014 cnwar2 #34488
	if _ti.isDeleted then
		return false;
	endif;
	
	//+ cnwmd1 Par 22846
	if not self.allCargoTypes.includes(_ti.myCargoType) then
		return false;
	endif;

	/* //- cnwmd1, Par 22846
	if self.filterAllCargoType &lt;&gt; null then
		if _ti.cargoType &lt;&gt; self.filterAllCargoType.id then
			return false;
		endif;
	endif;*/

	if self.filterBOLItemId &lt;&gt; null then
		if not _ti.id.startsWith(self.filterBOLItemId) then
			return false;
		endif;
	endif;	

	if self.filterBOLItemCargoType &lt;&gt; null then
		if _ti.cargoType &lt;&gt; self.filterBOLItemCargoType.id then
			return false;
		endif;
	endif;
	
	if self.filterBOLItemLocation &lt;&gt; null then
		if not _ti.locationId.startsWith(self.filterBOLItemLocation) then
			return false;
		endif;
	endif;	

	/*
	if self.filterBOLItemBOLNumber &lt;&gt; null and
	   _ti.myReceivalBOL &lt;&gt; null then
		if not _ti.myReceivalBOL.number.startsWith(self.filterBOLItemBOLNumber) then
			return false;
		endif;
	endif;
	*/

	if self.filterBOLItemMarks &lt;&gt; null then
		if not _ti.mark.startsWith(self.filterBOLItemMarks) then
			return false;
		endif;
	endif;	

	if self.filterBOLItemCommodity &lt;&gt; null then
		if _ti.commodity &lt;&gt; self.filterBOLItemCommodity.code then
			return false;
		endif;
	endif;	

	if self.filterBOLItemOperator &lt;&gt; null then
		if _ti.operatorCode &lt;&gt; self.filterBOLItemOperator.code then
			return false;
		endif;
	endif;	

	return true;
end;
</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeCOBItems" id="4f1dc0a0-74f2-4a56-9070-b9c7ec6b8c23">
        <source>includeCOBItems(_ti : CM_TrackedItem) : Boolean protected;
// apply COB filtering to the current tracked item
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
vars
	
begin
	
	if _ti = null then
		return false;
	endif;
	
	//+ cnwmd1 Par 22846
	if not self.allCargoTypes.includes(_ti.myCargoType) then
		return false;
	endif;
	/* //- cnwmd1, Par 22846
	if self.filterAllCargoType &lt;&gt; null then
		if _ti.cargoType &lt;&gt; self.filterAllCargoType.id then
			return false;
		endif;
	endif;*/
	
	//+ cnwmd1 Par 22846
	//if _ti.isExport or _ti.isStorage then 							// PAR #25021
	if _ti.isExport or _ti.isTranshipOutbound or _ti.isStorage then 	// PAR #25021
		return false;
	endif;

	if self.filterCOBItemId &lt;&gt; null then
		if not _ti.id.startsWith(self.filterCOBItemId) then
			return false;
		endif;
	endif;	

	if self.filterCOBCargoType &lt;&gt; null then
		if _ti.cargoType &lt;&gt; self.filterCOBCargoType.id then
			return false;
		endif;
	endif;
	
	if self.filterCOBLocation &lt;&gt; null then
		if not _ti.locationId.startsWith(self.filterCOBLocation) then
			return false;
		endif;
	endif;	

	if self.filterCOBBOLNumber &lt;&gt; null and
	   _ti.myReceivalBOL &lt;&gt; null then
		if not _ti.myReceivalBOL.number.startsWith(self.filterCOBBOLNumber) then
			return false;
		endif;
	endif;	

	if self.filterCOBMarks &lt;&gt; null then
		if not _ti.mark.startsWith(self.filterCOBMarks) then
			return false;
		endif;
	endif;	

	if self.filterCOBCommodity &lt;&gt; null then
		if _ti.commodity &lt;&gt; self.filterCOBCommodity.code then
			return false;
		endif;
	endif;	

	if self.filterCOBOperator &lt;&gt; null then
		if _ti.operatorCode &lt;&gt; self.filterCOBOperator.code then
			return false;
		endif;
	endif;	

	return true;
end;
</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeStowageItems" id="4ba6f042-8a84-49bf-aea0-826b1982cc5f">
        <source>includeStowageItems(_ti : CM_TrackedItem) : Boolean protected;
// apply all filtering to the current tracked item
vars
	
begin
	
	if _ti = null then
		return false;
	endif;
	
	//+ cnwmd1 Par 22846
	if not self.allCargoTypes.includes(_ti.myCargoType) then
		return false;
	endif;
	/* //- cnwmd1, Par 22846
	if self.filterAllCargoType &lt;&gt; null then
		if _ti.cargoType &lt;&gt; self.filterAllCargoType.id then
			return false;
		endif;
	endif;*/

	if self.filterStowItemId &lt;&gt; null then
		if not _ti.id.startsWith(self.filterStowItemId) then
			return false;
		endif;
	endif;	

	if self.filterStowItemCargoType &lt;&gt; null then
		if _ti.cargoType &lt;&gt; self.filterStowItemCargoType.id then
			return false;
		endif;
	endif;
	
	if self.filterStowItemLocation &lt;&gt; null then
		if not _ti.locationId.startsWith(self.filterStowItemLocation) then
			return false;
		endif;
	endif;	

	/*
	if self.filterStowItemBOLNumber &lt;&gt; null and
	   _ti.myReceivalBOL &lt;&gt; null then
		if not _ti.myReceivalBOL.number.startsWith(self.filterStowItemBOLNumber) then
			return false;
		endif;
	endif;	
	*/

	if self.filterStowItemMarks &lt;&gt; null then
		if not _ti.mark.startsWith(self.filterStowItemMarks) then
			return false;
		endif;
	endif;	

	if self.filterStowItemCommodity &lt;&gt; null then
		if _ti.commodity &lt;&gt; self.filterStowItemCommodity.code then
			return false;
		endif;
	endif;	

	if self.filterStowItemOperator &lt;&gt; null then
		if _ti.operatorCode &lt;&gt; self.filterStowItemOperator.code then
			return false;
		endif;
	endif;	

	return true;
end;
</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initBOLTable" id="e0cea15d-9e5f-47f9-bb29-26ebcb2c8686">
        <source>initBOLTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2013	cnwer1	Initial creation PAR 31274

*/

vars
	entTableDef	: EntTableDef;
begin
	
	self.tblBOL.stretchHeight	:= true;
	self.tblBOL.stretchWidth		:= true;
	self.tblBOL.setDistanceFromBottom(2);
	self.tblBOL.userInputEnabled := false;
	self.tblBOL.multiSelect := CM_DataTable.MultiSelect_None;
	self.tblBOL.selectMode := Table.SelectMode_CurrentRow;
	self.tblBOL.selectionType := CM_DataTable.SelectionType_Row;
	self.tblBOL.stretchWidth := true;
	
	if self.isBOLDetailMode() then
		entTableDef := app.myController.getEntTableDef(ETDef_BOLShipItems);
	else
		entTableDef := app.myController.getEntTableDef(ETDef_BOLShip);
	endif;

	if entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Def (' &amp; ETDef_VisitRecordForEnquir &amp; ') not found');
		return;
	endif;

	self.tblBOL.setTblDataEntRowsArray(entTableDef, null, self.xmlStrBOL);
	self.setColorsForTable(self.tblBOL);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="092b6fb3-ca07-46d6-9982-f73c006fac23">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;

vars
	str			: String;
begin
	inheritMethod(_userWindow);
	
	str := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XMLTag_splMain_Ratio);
	if str &lt;&gt; null then
		self.splMain.setLeftToRightRatio(str.Integer);
	endif;
	
	str := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XMLTag_splBOL_Ratio);
	if str &lt;&gt; null then
		self.splBOL.setLeftToRightRatio(str.Integer);
	endif;
	//epr par 31274 12/3/13 col organiser didn't remember when switching type of table
	str  := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.tblBOL.XMLTag_Table &amp; self.tblBOL.name);
	if str  &lt;&gt; null then
		self.xmlStrBOL := global.formatAsXMLPrefix(self.tblBOL.XMLTag_Table &amp; self.tblBOL.name) &amp; str &amp; global.formatAsXMLSuffix(self.tblBOL.XMLTag_Table &amp; self.tblBOL.name);
	endif;
	
	//25 Feb 2021	NDL	TFS 50836
	str  := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkCurrentVoys.name);
	if str  &lt;&gt; null then
		self.chkCurrentVoys.value := str.Boolean;
	endif;
	
end;
</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initQueryFrame" id="2a189f0f-dca6-4e3c-a828-c9aa117660c6">
        <source>initQueryFrame();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 March 2010	cnwmd1	Initial creation

*/
constants
	HorzGap = 5;
	VertGap = 20;
vars
	sht	: CMUI_Sheet;
	lstTable : CMUI_ListTable;
	combo : CMUI_ComboBox;
begin

	self.chkCurrentVoys.left := HorzGap;	//25 Feb 2021	NDL	TFS 50836
	self.chkCurrentVoys.top := VertGap;	//25 Feb 2021	NDL	TFS 50836
	
	
	combo := self.cmbVoyages;
	combo.left := HorzGap;
	combo.top := self.chkCurrentVoys.top + self.chkCurrentVoys.height + VertGap;	//25 Feb 2021	NDL	TFS 50836
	combo.width := combo.parent.width - (HorzGap * 2);
	sht := self.shtVoyage;
	sht.visible := true;
	sht.caption := app.getErrorString(Voyage);	
	
	
	sht := self.shtCargoTypes;
	lstTable := self.lstCargoTypes;
	lstTable.width := sht.clientWidth;
	lstTable.height := sht.clientHeight;
	sht.visible := true;
	sht.caption := app.getErrorString(CargoTypes);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initTable" id="5fc0ab5c-0dd9-4a5b-adf3-503fca9e320c">
        <updating/>
        <source>initTable(_table : CM_DataTable input; _type : String) updating;

vars

begin
	if _table = null then
		return;
	endif;
	
	_table.stretchHeight	:= true;
	_table.stretchWidth		:= true;
	_table.setDistanceFromBottom(2);
	
	self.setTableHeadings(_table, _type);
	
	_table.userInputEnabled := false;
	if _table = self.tblBOL then
		_table.multiSelect := CM_DataTable.MultiSelect_None;
	else
		_table.multiSelect := CM_DataTable.MultiSelect_Simple;
	endif;
	_table.selectMode := Table.SelectMode_CurrentRow;
	_table.selectionType := CM_DataTable.SelectionType_Row;
	_table.stretchWidth := true;

	self.setColorsForTable(_table);

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
    <JadeMethod name="isBOLDetailMode" id="0bcb5390-9e6e-4a0b-affd-39ea807f51ca">
        <source>isBOLDetailMode() : Boolean protected;
// 23144 handle cargo linked to BOL but not BOL detail
vars

begin
	return self.btnShowBOL.value; //+ cnwmd1 Par 24177
	//return not self.btnShowBOL.value; //- cnwmd1 Par 24177
end;
</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="bd802e2a-bcec-4177-89f2-875f81f8f19f">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

vars
begin
	if keyCode = CMUI_Key_F3 then
		app.mousePointer := MousePointer_HourGlass;
		self.showHideSelector();
		return;
	elseif keyCode = J_key_Return then
		if self.frmQuery.visible then
			self.doSelection();
			return;
		elseif self.frmSearch.visible then
			self.doSearch();
			return;
		endif;
	endif;

	inheritMethod(keyCode, shift);

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="0705d217-d765-4305-8982-c4ae50d50c09">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;

vars

begin
	inheritMethod();
		
	create self.myBOLAgent transient;
	self.doLoadVoyages();
	//self.myCurrentVoyage := app.myCurrentVoyage;
	//cnwjo3 par 23105
	self.myCurrentVoyage := app.getMyCurrentVoyage();

	// self.loadCargoTypes(); //- cnwmd1, Par 22846
	if self.myCurrentVoyage &lt;&gt; null then
	// show details of current voyage and hide the selector
		self.doSelectVoyage();
		//self.showHideSelector(); //- cnwmd1, Par 23143
	endif;
	self.showHideSelector(); //+ cnwmd1 Par 23143

end;
</source>
        <access>protected</access>
    </JadeMethod>
