    <JadeMethod name="getXlatedOperatorCode" id="6649b544-d46b-4f65-b13d-a062807b55b5">
        <source>getXlatedOperatorCode( pXlateOperator : String	// this is the EDI translation operator code from Cam Protocol or wherever else 
						) : String;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich               

 Purpose:     MES1011  For use by JRW and Cams.
 			  Note, these methods will show as not being referenced, but they are selected on the CM_TransactionView for the JRW.


 Parameters:  EDI Translation Operator Code

 Returns:     the translation of the operator code, or orignal if no translation

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
 ---------------------------------------------------------------------------
*/

vars
	xlateOperator : CM_Operator;
	foreignCode : String;
	foundMatch	: Boolean;
begin
	if  pXlateOperator 				&lt;&gt; null 	and 
		operatorCode.trimBlanks 	&lt;&gt; "" 		then
		xlateOperator := app.myRoot.allOperators[pXlateOperator];
		if xlateOperator &lt;&gt; null then
			foreignCode := xlateOperator.getXlationForeignCode(operatorCode, XLATION_TYPE_OPERATOR_BYOP, foundMatch);
			if foreignCode &lt;&gt; null then
				return foreignCode;
			endif;
		endif;
	endif;
	
	return operatorCode.trimBlanks;	// default to same code if not translated

end;
</source>
        <Parameter name="pXlateOperator" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXlatedOwnerOperatorCode" id="86f730c9-938e-4b17-80dc-49d2ae72a55f">
        <source>getXlatedOwnerOperatorCode( pXlateOperator : String	// this is the EDI translation operator code from Cam Protocol or wherever else 
						) : String;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich               

 Purpose:     MES1011  For use by JRW and Cams.
 			  Note, these methods will show as not being referenced, but they are selected on the CM_TransactionView for the JRW.


 Parameters:  EDI Translation Operator Code

 Returns:     the translation of the owner operator code, or orignal if no translation

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
 ---------------------------------------------------------------------------
*/

vars
	xlateOperator : CM_Operator;
	owner : String;
	foreignCode : String;
	foundMatch	: Boolean;
begin
	if myTrackedItem &lt;&gt; null then 
		owner := myTrackedItem.getOwnerOperatorCode;
		
		if  pXlateOperator 		&lt;&gt; null 	and 
			owner.trimBlanks 	&lt;&gt; "" 		then
			xlateOperator := app.myRoot.allOperators[pXlateOperator];
			if xlateOperator &lt;&gt; null then
				foreignCode := xlateOperator.getXlationForeignCode(owner, XLATION_TYPE_OPERATOR_BYOP, foundMatch);
				if foreignCode &lt;&gt; null then
					return foreignCode;
				endif;
			endif;
		endif;
	endif;
	
	return owner.trimBlanks;	// default to same code if not translated

end;
</source>
        <Parameter name="pXlateOperator" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXlatedTerminal" id="cbb1a18f-cf3d-4a86-8bf0-13caf92d56d9">
        <source>getXlatedTerminal( pXlateOperator : String	// this is the EDI translation operator code from Cam Protocol or wherever else 
						) : String;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich               

 Purpose:     MES1011  For use by JRW and Cams
 			  Note, these methods will show as not being referenced, but they are selected on the CM_TransactionView for the JRW.


 Parameters:  EDI Translation Operator Code

 Returns:     the translation of the terminal code, or orignal if no translation

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
 ---------------------------------------------------------------------------
*/

vars
	xlateOperator 	: CM_Operator;
	foreignCode 	: String;
	terminalCode 	: String;
	foundMatch		: Boolean;
begin
	if myTerminal = null then
		return null;
	endif;
	
	terminalCode := myTerminal.code;
	
	if  pXlateOperator 				&lt;&gt; null 	and
		terminalCode.trimBlanks 	&lt;&gt; "" 		then
		xlateOperator := app.myRoot.allOperators[pXlateOperator];
		if xlateOperator &lt;&gt; null then
			foreignCode := xlateOperator.getXlationForeignCode(terminalCode, XLATION_TYPE_TERMINAL_BYOP, foundMatch);
			if foreignCode &lt;&gt; null then
				return foreignCode;
			endif;
		endif;
	endif;
	
	return terminalCode;	// default to same code if not translated

end;
</source>
        <Parameter name="pXlateOperator" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasEDIDateTimeCondition" id="7a77f5ea-69fe-4dac-bac8-02454816a96f">
        <condition/>
        <source>hasEDIDateTimeCondition():Boolean condition;

/*

Purpose:			Condition to control whether or not the receiver is included
					in the CM_Terminal::allTITransactionsByEDIDateTime collection

Parameters:			None

Return Value:		True if it should be included, false otherwise


Date		Who		Reason
29 Jun 2010	cnwkpd1	PAR #24793 - Speed up of 7.8.2 upgrade process

*/

begin
	return (self.camsTimeStamp &lt;&gt; null) and self.isNotSupersededCondition;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
