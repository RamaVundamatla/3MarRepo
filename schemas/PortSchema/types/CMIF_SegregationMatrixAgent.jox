<Class name="CMIF_SegregationMatrixAgent" id="0e021068-f7b6-471f-9f78-8a7d1213103c">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="allSegMatrixTransByColRow" id="9a46a6e9-fc05-4339-aeba-adaf521b31b9">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_SegMatrixTransByColRow"/>
        <Inverse name="CM_SegregationMatrixTrans::mySegregationMatrixAgent"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="allSegMatrixTransByRowCol" id="06b767e0-b844-4134-9623-2f58926430ba">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_SegMatrixTransByRowCol"/>
        <Inverse name="CM_SegregationMatrixTrans::mySegregationMatrixAgent"/>
    </ExplicitInverseRef>
    <PrimAttribute name="ruleType" id="b633a34b-12cc-43b7-8450-688fc758bac6">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="exportMyCollectionsXML" id="73b57be3-a424-405a-af11-31d6a490f8ca">
        <source>exportMyCollectionsXML(_file: File; _objArray: ObjectArray io);
/*
----------   ----------  --------------------------------------------------
Created:	29 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	segMatrixTrans			: CM_SegregationMatrixTrans;
begin
	/*
	_file.writeLine('&lt;allSegMatrixTransColRow&gt;');
	foreach segMatrixTrans in self.allSegMatrixTransByColRow do
		_file.writeLine('&lt;segMatrixTrans&gt;');
		segMatrixTrans.exportMeXML(_file,_objArray, true, false);
		_file.writeLine('&lt;/segMatrixTrans&gt;');
	endforeach;
	_file.writeLine('&lt;/allSegMatrixTransColRow&gt;');
	*/
	_file.writeLine('&lt;allSegMatrixTransRowCol&gt;');
	foreach segMatrixTrans in self.allSegMatrixTransByColRow do
		_file.writeLine('&lt;segMatrixTrans&gt;');
		segMatrixTrans.exportMeXML(_file,_objArray, true, false);
		_file.writeLine('&lt;/segMatrixTrans&gt;');
	endforeach;
	_file.writeLine('&lt;/allSegMatrixTransRowCol&gt;');
	
end;


</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="importMeXMLValidateProperty" id="bb563eea-9798-4d5d-8517-c8aea995a12b">
        <updating/>
        <source>importMeXMLValidateProperty(_propertyName: String; _propertyValue: Any): Boolean updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	29 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _propertyName = CMIF_SegregationMatrixAgent::ruleType.name then
		return false;
	endif;
	
	return inheritMethod(_propertyName, _propertyValue);


end;


</source>
        <access>protected</access>
        <Parameter name="_propertyName" type="String"/>
        <Parameter name="_propertyValue" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="importMyCollectionsXML" id="4cfd3ee3-bb01-49fa-8cef-056400909be7">
        <updating/>
        <source>importMyCollectionsXML(_collectionsBlock: String) updating;
/*
----------   ----------  --------------------------------------------------
Created:	29 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	newMatrixTrans		: CM_SegregationMatrixTrans;
	codeStr,
	allTransBlock,
	matrixTransBlock	: String;
	blockLength,
	pos			: Integer;
begin
	/*
	allTransBlock := _collectionsBlock.cnEcGetTagValueOfName('allSegMatrixTransColRow');

	if allTransBlock = null then
		return;
	endif;
	
	pos := 1;
	blockLength := allTransBlock.length;
	
	while pos &lt; blockLength do
		matrixTransBlock := allTransBlock.cnEcGetNextTagValueOfName('segMatrixTrans', pos);
		if pos &lt; 1 then
			break;
		endif;
		
		if matrixTransBlock = null then
			continue;
		endif;
		
		
		create newMatrixTrans transient;
		newMatrixTrans.mySegregationMatrixAgent := self;
		newMatrixTrans.importMeXML(matrixTransBlock);
		
	endwhile;
	*/
	
	allTransBlock := _collectionsBlock.cnEcGetTagValueOfName('allSegMatrixTransRowCol');

	if allTransBlock = null then
		return;
	endif;
	
	pos := 1;
	blockLength := allTransBlock.length;
	
	while pos &lt; blockLength do
		matrixTransBlock := allTransBlock.cnEcGetNextTagValueOfName('segMatrixTrans', pos);
		if pos &lt; 1 then
			break;
		endif;
		
		if matrixTransBlock = null then
			continue;
		endif;
		
		
		create newMatrixTrans transient;
		newMatrixTrans.mySegregationMatrixAgent := self;
		newMatrixTrans.importMeXML(matrixTransBlock);
		
		if (not app.myPassport.noErrors) then
			return;
		endif;
	endwhile;

end;


</source>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
</Class>
