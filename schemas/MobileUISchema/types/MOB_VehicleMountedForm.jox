    <JadeMethod name="canGFXDisplay" id="e44cc50c-28b9-4c09-a408-6349b6382bb0">
        <source>canGFXDisplay( _lc : CM_LocationsController io; _strLocation : String io; _ti : CM_TrackedItem io; _ignoreMoveState : Boolean) : Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2010	cnwjk3	Initial creation
23 May 2012 cnwer1	Par 29611 
*/

vars
	tiSet		: ObjectSet;
	strLocation : String;
	height		: Integer;
	lc 			: CM_LocationsController;
begin
	//epr 14/6/10 if no graphic views then don't display then
	if app.myVMAgent.getMyRTVehicleConfig.allAvailableGraphicViews.isEmpty then
		return false;
	endif;
	
	_ti := null;
	if self.isDirectorTask() then
		lc := self.getFirstDirectorLocation();	
		if not _ignoreMoveState and app.myVMAgent.getNextMoveState() = app.myVMAgent.PICKUP_TASK then
			// We will now be displaying the list of TIs wihich match the request, so
			// we don't show the gfx. the users can swicth between the gfx view and list 
			// view manually...
			return false;
		endif;	
		
		if lc = null then
			return false;
		endif;
		
		_ti := self.getFirstDirectorTI();
		_strLocation := null;
		_lc := lc;
	
		self.setDirectorTaskTISet();
		
	elseif self.isShowOverstowCargo then
		if self.isSettingDown then
			_lc:=self.myMachine.myLastKnownLocation;
			_ti:=self.myMachine.myMachineController.allTrackedItems.first;
			_strLocation := null;
			return true;
		endif;
		lc:= self.getFirstDirectorLocation();	
		if lc = null then
			return false;
		endif;
		_ti := self.getFirstDirectorTI();
		_strLocation := null;
		_lc := lc;
		
	elseif self.isEnquiryMode then
		_ti:=self.getNonRTMoveCargo();
		if _ti = null then
			return false;
		endif;
		
		if _ti.myPrimaryActualLocation = self.myMachine.myMachineController then
			_lc:=self.myMachine.myLastKnownLocation;
		else
			_lc:=_ti.myPrimaryActualLocation;
		endif;
		
	else
		if self.myMachine.currentQueueTask  &lt;&gt; null then
			_ti:=self.myMachine.currentQueueTask.ti;
		endif;
		if app.myVMAgent.getNextMoveState() = app.myVMAgent.PICKUP_TASK then
			// Get the source location
			strLocation := self.getSourceLocID();
		elseif app.myVMAgent.getNextMoveState() = app.myVMAgent.SETDOWN_TASK then
			// Get destination location
			strLocation := self.getSetdownLocID();
		elseif app.myVMAgent.getNextMoveState() = app.myVMAgent.ACCEPT_TASK then
		//epr par 29611 23/5/12
			if app.myVMAgent.isIMV then
				if self.myMachine.myMachineController.includesTI(_ti,REAL_MODE) then
					strLocation :=self.myMachine.currentQueueTask.targetLocationId;
				else
					strLocation :=self.myMachine.currentQueueTask.sourceLocationId;
				endif;
			else
				strLocation :=self.myMachine.currentQueueTask.sourceLocationId;
			endif;
		endif;
		
		if strLocation = null then
			return false;
		endif;
		
		app.myVMAgent.myTerminal.findLocationFromString(strLocation.trimBlanks(), true, lc, height);
		
		self.myDrawingController.clearHighlightLCs();
		
		_lc := lc;
		_strLocation := strLocation;
		
	endif;
	
	//epr par 24659 &amp; 24737 25/6/10
	
	return self.canLCGFXDisplay(_lc);

epilog
	delete tiSet;
end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController" usage="io"/>
        <Parameter name="_strLocation" type="String" usage="io"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_ignoreMoveState" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canLCGFXDisplay" id="8f759c26-aee0-4d2f-85b2-8a304e9aabb0">
        <source>canLCGFXDisplay(_lc : CM_LocationsController) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 June 2010	cnwer1	Initial creation

*/

vars

begin
		//epr par 24659 &amp; 24737 25/6/10
	if _lc = null then
		return false;
	endif;
	
	if _lc.myTerminalArea = null then
		return false;
	endif;
	
	if not _lc.myTerminalArea.isKindOf(CM_GridArea) and not _lc.myTerminalArea.isKindOf(CM_Rail) then 
		return false;
	endif;
	
	if _lc.myTerminalArea.isKindOf(CM_YardInterchangeArea) and _lc.myTerminalArea.CM_YardInterchangeArea.isBufferZone then
		return false;
	endif;
	
	if not _lc.isKindOf(CM_GridController) and  not _lc.isKindOf(CM_WagonController) then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canRejectNonRTCargo" id="de2e935e-742f-4db8-8673-40d4cd8c381e">
        <source>canRejectNonRTCargo() : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2010	cnwer1	Initial creation

*/

vars
	ti : CM_TrackedItem;
begin
	ti:=self.getNonRTMoveCargo();
	if ti = null then
		return true;
	endif;
	
	if ti.myPrimaryActualLocation = self.myMachine.myMachineController then
	
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeCargoID" id="a22ae265-e06c-4fcf-8b41-3b9779ae8eab">
        <source>changeCargoID(_ti : CM_TrackedItem) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 May 2010	cnwjk3	Initial creation

*/

vars
	id	: String;
begin
	if _ti = null then
		return;
	endif;	
	id := _ti.id;
	
	self.myMoveTableDetails.addDataForEntRowName(ETRow_CargoID, id);	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="changeSetDownLocation" id="c15aadac-079b-4aa8-8e09-f8f7903e9070">
        <source>changeSetDownLocation( _lc : CM_LocationsController) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 May 2010	cnwjk3	Initial creation
02 Jul 2010 cnwer1	PAR 24668 change setdown location set the tandem location if visible
*/

vars
	id,
	twinId : String;
	
begin
	if _lc = null then
		return;
	endif;
	
	id := _lc.getFullId();
	if id = null then
		return;
	endif;
	
	self.myMoveTableDetails.addDataForEntRowName(ETRow_TargetID, id);
	
	
	if self.myMoveTableDetails.isEntRowNameVisible(ETRow_TwinTargetID) then
		if _lc.CM_GridController.myNextController &lt;&gt; null then
			twinId:=_lc.CM_GridController.myNextController.getFullId();
		endif;
		
		if twinId &lt;&gt; null then
			self.myMoveTableDetails.addDataForEntRowName(ETRow_TwinTargetID, twinId);
		endif;
	endif;
	
	//epr par 24668 2/7/10
	if self.myMoveTableDetails.isEntRowNameVisible(ETRow_TandemTargetID) then
		self.myMoveTableDetails.addDataForEntRowName(ETRow_TandemTargetID, id);
	
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="checkIDForDirectorTask" id="9530cc3b-149c-4d59-be75-d0ac35a44223">
        <source>checkIDForDirectorTask( _id : String );

/*

Purpose:		for par 27812, check a typed ID for sutability for director task.	

Parameters:			

Return Value:		


Date		Who		Reason
02 August 2011	cnwrd1	Initial creation

*/

vars
	result 		: Boolean;
	request 	: CM_Request;
	rtQTask 	: CM_RTQueueTask;
	ti 			: CM_TrackedItem;
	dtoEntry 	: DTO_RTQueueEntry;
	sourceLC 	: CM_LocationsController;	
	sourceTA 	: CM_TerminalArea;
	allTIs		: ObjectSet;
	alert 		: CM_SystemAlert;
begin

	//06 Dec 2012	NDL	Par 30585
	if app.myVMAgent.myMachine = null or app.myVMAgent.myMachine.currentQueueTask = null then
		return;
	endif;
	
	dtoEntry :=app.myVMAgent.findDTOEntryByRTQueueEntry(app.myVMAgent.myMachine.currentQueueTask.myEntry);
	
	request:=dtoEntry.myRealQueueEntry.CM_RTQueueEntry.getMyRequest;
	rtQTask:=dtoEntry.myRealQueueEntry.CM_RTQueueEntry.findTaskOfType(TASK_DIRECTOR,NULL_INTEGER);
	
	sourceLC:=rtQTask.sourceLocation;
	if sourceLC &lt;&gt; null and
	   sourceLC.isGridLocation() then
		sourceTA:= sourceLC.myTerminalArea;
	elseif sourceLC.isKindOf(CM_BlockController) then
		sourceTA:=sourceLC.myTerminalArea;
	elseif sourceLC.isKindOf(CM_RoRoController) then	//29 May 2012	NDL	Par 29641
		sourceTA:=sourceLC.myTerminalArea;
	else
		sourceTA:=request.getSourceTA();
	endif;
	
	ti := self.myMobileDataAgent.myTerminal.lookupTrackedItem( _id ,  TI_CargoType_Container, TI_STATE_NORMAL, null, false);

	if ti = null then 
		return ;
	endif;
	
	app.myPassport.clearErrorsWarnings();
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);

	if sourceTA &lt;&gt; null then
	
		if sourceTA.isKindOf(CM_BlockStack) then
			if not sourceTA.CM_BlockStack.myLocationsController.allTrackedItems.includes(ti) then		
				app.raiseCMException2(Cargo_item_not_requi_sourc_ter, ti.id, sourceTA.id, null, self);		
			endif;
		else
			create allTIs transient;
			sourceTA.getAllLocationsTrackedItems(allTIs);		
			if not allTIs.includes(ti) then
				app.raiseCMException2(Cargo_item_not_requi_sourc_ter, ti.id, sourceTA.id, null, self);		
			endif;
		endif;
	endif;		
	
	ti.testAgainstRequest(request);
	
	if app.myPassport.hasErrorsOrWarnings then
	
		app.showErrorWarningDialog('Errors', app.myPassport, ErrWarnMode_CanAckWarnings);
		alert := app.myPassport.convertErrorsWarningsToAlert(app.getErrorString3(Cargo_item_does_not_match_requ , ti.id, rtQTask.getTaskId, self.myMachine.id ), rtQTask.myEntry);
		
	endif;
	
	return;
	
epilog
	app.setContinueCMExceptions(false);
	delete allTIs;
end;</source>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
    <JadeMethod name="clearTableData" id="c43c3aee-bca8-4c84-b757-9b930ad3740f">
        <source>clearTableData(_table : Table input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 April 2010	cnwer1	Initial creation

*/

vars
	row,col : Integer;
	headerIsTopRow : Boolean;
begin
	
	
	self.getTableOrientation(_table,headerIsTopRow);
	
	if headerIsTopRow then
		row:=_table.fixedRows + 1;
		while row &lt;= _table.rows do
			_table.deleteRow(row);
		endwhile;
		_table.rows:=_table.fixedRows;
	else
		col:=2;
		while col &lt;= _table.columns do
			_table.deleteColumn(col);
		endwhile;
		_table.columns:=1;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="configLabelFrames" id="683db616-91b3-4d7c-ad09-79dbdc51cfbb">
        <updating/>
        <source>configLabelFrames() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 November 2010	#cnwdz2	 26196

*/

vars
	columnLabelsPlacement,
	rowLabelsPlacement		: Integer;
begin
	columnLabelsPlacement := app.myVMAgent.getMyRTVehicleConfig.columnLabelsPlacement;
	if columnLabelsPlacement = COLUMN_LABEL_TOP then
		self.frmBottomHLabels := null;
		self.frmBotmLeftLabel := null;
		self.frmBotmRightLabl := null;
	elseif columnLabelsPlacement = COLUMN_LABEL_BOTTOM then
		self.frmTopHLabels := null;
		self.frmTopLeftLabel := null;
		self.frmTopRightLabel := null;
	elseif columnLabelsPlacement = COLUMN_LABEL_NONE then
		self.frmTopHLabels := null;
		self.frmTopLeftLabel := null;
		self.frmTopRightLabel := null;
		self.frmBottomHLabels := null;
		self.frmBotmLeftLabel := null;
		self.frmBotmRightLabl := null;
	endif;
	
	rowLabelsPlacement    := app.myVMAgent.getMyRTVehicleConfig.rowLabelsPlacement;
	if rowLabelsPlacement = ROW_LABEL_LEFT then
		self.frmRightVLabels := null;
		self.frmTopRightLabel := null;
		self.frmBotmRightLabl := null;
	elseif rowLabelsPlacement = ROW_LABEL_RIGHT then
		self.frmLeftVLabels := null;
		self.frmTopLeftLabel := null;
		self.frmBotmLeftLabel := null;
	elseif rowLabelsPlacement = ROW_LABEL_NONE then
		self.frmLeftVLabels := null;
		self.frmRightVLabels := null;		
		self.frmTopLeftLabel := null;
		self.frmTopRightLabel := null;
		self.frmBotmLeftLabel := null;
		self.frmBotmRightLabl := null;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
