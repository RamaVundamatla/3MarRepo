    <JadeMethod name="camNotAdhocRun" id="9681f918-ad92-47d8-b322-a3290514589c">
        <source>camNotAdhocRun();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12 September 2023	navdap1		Initial creation TFS 
//
constants
	Terminal1 : String = 'UT';
vars
	terminal : CM_Terminal;
	bgpRequest : BGP_CamsRequest;
begin
	app.initialize;
	terminal := app.myRoot.allTerminals[Terminal1];
	if terminal = null then
		app.writeStatement('Can not find required terminal ' &amp; Terminal1);
		return;
	endif;
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	app.changeLogLevel(LogDEBUG);
	create bgpRequest transient;
	bgpRequest.setPropertyValue(BGP_CamsRequest::myTerminal.name, terminal);
	bgpRequest.setPropertyValue(BGP_CamsRequest::myUser.name, app.myPassport.myUser);
	
	
	
	bgpRequest.action();
epilog
	delete bgpRequest;
end;</source>
    </JadeMethod>
    <JadeMethod name="changeTransitStatus" id="8de2eff0-1135-458d-b2e4-370fede9b319">
        <source>changeTransitStatus();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 April 2025	navra1	Initial creation

*/

vars
	term : CM_Terminal;
	ti : CM_TrackedItem;
begin
	app.initialize();
	term := app.myRoot.allTerminals['RAM'];
	foreach ti in term.allOnsiteTIsByCargoTypeId where ti.id ='DFSU2765482' do
		break;
	endforeach;
	
	beginTransaction;
	ti.setPropertyValue(CM_TrackedItem::transitStatus.name, TI_TransitStatusNull);
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="checkInvoice" id="96724fa0-3e88-416a-b052-082d45d496a1">
        <source>checkInvoice();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2024	navra1	Initial creation

*/

vars
	inv : CM_Invoice;
	theInvoice : CM_Invoice;
	term : CM_Terminal;
	
begin
	app.initialize();
	term:=app.myRoot.allTerminals["RAM"];
	
	write term.getDefaultCompanyBank().code;
	
	foreach inv in app.myRoot.allInvoiceProcesses["InvoiceAPI"].allInvoices do
		if inv.invoiceLines.size() &gt; 100 then
			write inv.invoiceLines.size();
			theInvoice := inv;
		endif;
		if inv.invoiceLines.getOidAsString().endsWith("1107119") then
			write inv.getOidAsString();
		endif;
	endforeach;
	
	write "hi";
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="cleanInvProStatus" id="d5a21b5e-233c-4fb1-9e35-8b95b7b677ea">
