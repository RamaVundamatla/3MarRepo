    <JadeMethod name="cnwdad1_Test_ColorArray" id="373815e7-2e67-400f-b671-dab9b8968a93">
        <source>cnwdad1_Test_ColorArray();
// -----------------------------------------------------------------------------
// Created:		06 November 2001 by cnwdad1
//
