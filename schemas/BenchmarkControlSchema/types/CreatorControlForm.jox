    <JadeMethod name="startAppWithParam" id="893e99de-2047-4cd0-82b7-c3c7b3685919">
        <updating/>
        <source>startAppWithParam(envid,host,controlPort,schemaName,appName,param:String):String updating;

vars
	path,cmd,appserverhost:String;
	i,j,retCode:Integer;
begin
	if computerName='cnwchcs73' then
		path:='c:\thinbin_host\'&amp;envid;
	else
		path:='c:\thinbin\'&amp;envid;
	endif;

	if computerName[1:7]='cnwchcs' and host='cnwchcc46' then
		appserverhost:='cnwchcs46';
	else
		appserverhost:=host;
	endif;
	cmd:=path&amp;'\jade.exe'
			&amp;' schema='&amp;schemaName
			&amp;' app='&amp;appName
			&amp;' appserver='&amp;appserverhost
			&amp;' appserverport='&amp;controlPort;

	cmd:=cmd&amp;" endjade "&amp;param;
	return cmd&amp;" result="&amp;node.createExternalProcess(null,cmd,null,null,true,false,retCode).String;
end;</source>
        <Parameter name="envid" type="String"/>
        <Parameter name="host" type="String"/>
        <Parameter name="controlPort" type="String"/>
        <Parameter name="schemaName" type="String"/>
        <Parameter name="appName" type="String"/>
        <Parameter name="param" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
