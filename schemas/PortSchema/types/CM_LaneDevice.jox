    <JadeMethod name="getAuditText" id="7b1a207f-807b-4eb2-8f52-2adfda059618">
        <source>getAuditText(): String;

/*
Date			Who		Reason
01 September 2009	cnwar2	Initial creation
11/09/2009			cnwcs5	Changed to implemented class specific stuff on subclasses
*/
vars
	tmpStr : String;
begin
	tmpStr := "GateArea " &amp; self.myLaneController.getGridAreaId() &amp; " Lane " &amp; self.myLaneController.getLaneNumber.String &amp; " ";

	return tmpStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLaneDescription" id="e5bb459d-009a-4813-b213-fca9d3cf2e44">
        <source>getLaneDescription():String;
// ---------------------------------------------------------------------------
// Created:     20 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.myLaneController &lt;&gt; null then
		return self.myLaneController.getFullId;
	endif;
	
	return app.getErrorString (Unknown);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
