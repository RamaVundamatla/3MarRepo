    <JadeMethod name="addToolbarControls" id="5d003ce6-2c0c-4dfb-8bbc-a3e9a8ed1dca">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------------------
//Created: 02 May 2006 By: cnwyl1
//--------------------------------------------------------------

vars
	toolbar		: CMUI_Toolbar;
begin
	inheritMethod();
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnAutoplan, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnUnplanJob, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
