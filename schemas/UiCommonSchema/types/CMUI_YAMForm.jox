	newYA 		: CM_YardAllocation;
begin

	newYA:=self.tblData.openYAMaintForm(null, null, 0);
	
	if newYA &lt;&gt; null then
		if self.tblData.mySearchParameters.isMatchingYA( newYA ) then
			self.tblData.addItemYardAllocation(newYA);
