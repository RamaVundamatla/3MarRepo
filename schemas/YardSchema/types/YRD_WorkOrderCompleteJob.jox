    <JadeMethod name="findObjectInTableRows" id="35407f4e-ce76-4d7b-b2ed-170614d8860b">
        <source>findObjectInTableRows(_table :CM_DataTable input;_obj : Object; _rowIdx : Integer io) : Boolean ;
/*

Purpose: method is similar to CM_DataTable: findObjectInRow except this method also checks for null object

Parameters:			

Return Value:		

Date		Who		Reason
22 Jul 2024 navbs1 ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group

*/
vars
	idx,
	startPos,
	numRows		: Integer;
	found		: Boolean;
	rowObj		: Object;
begin
	
	numRows := _table.rows;
	if _rowIdx &gt; numRows then
		return found;
	endif;
	startPos := (_table.fixedRows + 1).max(_rowIdx);
	if startPos &gt; numRows then
		return found;
	endif;	 
	
	foreach idx in startPos to numRows do	
		rowObj := _table.accessRow(idx).itemObject;
		
		if rowObj = _obj then
			found 	:= true;
			_rowIdx := idx;
			break;
		endif;
	endforeach;

epilog
	return found;
	
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAmountToLoadShip" id="2d7f9b27-3e9a-4adf-bbde-b7171844110c">
        <updating/>
        <source>getAmountToLoadShip(_tiSet : CM_TISet; _moveController : CMIF_MoveController io; _weight : Decimal io; _quantity : Integer io; _trackByWeight : Boolean; _ti : CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars
	ti : CM_TrackedItem;
begin
	if _tiSet.size = 1 and not self.isBulkMode then
		if _ti.totalQuantity &gt; 1 or (_trackByWeight and _ti.totalWeight &gt; 1) then
			if app.myMoveController = null or not app.isValidObject(app.myMoveController) then
				app.myMoveController := _moveController;
			endif;
			_moveController.setMyTrackedItem(_ti);
			if not self.myAssistant.showMoveAmountForm(_moveController) then
				return;
			endif;
			if _trackByWeight then
				_weight := _moveController.weight;
			else
				_quantity := _moveController.quantity; 
			endif;
		endif;
	else
		if _trackByWeight then
			foreach ti in _tiSet do
				_weight := _weight + ti.totalWeight;
			endforeach;
		else
			foreach ti in _tiSet do
				_quantity := _quantity + ti.totalQuantity;
			endforeach;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="io"/>
        <Parameter name="_weight" type="Decimal" usage="io"/>
        <Parameter name="_quantity" type="Integer" usage="io"/>
        <Parameter name="_trackByWeight" type="Boolean"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getAmountToLoadTruck" id="0e5257ba-ee17-4c71-ab72-06eb280ede9c">
        <source>getAmountToLoadTruck(_trackByWeight : Boolean; _weight : Decimal io; _quantity : Integer io; _ti : CM_TrackedItem input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars
	tblAvail 	: CM_DataTable;
	ti			: CM_TrackedItem;
begin
	tblAvail := self.tblAvailCargo;
	if tblAvail.allSelectedObjects.size &gt; 1 then 
		if _trackByWeight then
			foreach ti in tblAvail.allSelectedObjects as CM_TrackedItem do
				_weight := _weight + ti.totalWeight;
			endforeach;
		else
			foreach ti in tblAvail.allSelectedObjects as CM_TrackedItem do
				_quantity := _quantity + ti.totalQuantity;
			endforeach;
		endif;
	else
		if _trackByWeight then
			self.showMoveAmountForm(_ti, _quantity,_weight);
		else
			if _ti.totalQuantity &gt; 1 then 
				self.showMoveAmountForm(_ti, _quantity,_weight);
			else
				_quantity := _ti.totalQuantity;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_trackByWeight" type="Boolean"/>
        <Parameter name="_weight" type="Decimal" usage="io"/>
        <Parameter name="_quantity" type="Integer" usage="io"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAmountToUnloadTruck" id="9d50f579-c792-4188-b610-446e61d83171">
        <source>getAmountToUnloadTruck(_ti : CM_TrackedItem input; _weight : Decimal io; _quantity : Integer io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars

begin
	if _ti.isBulkByWeight then
		_weight := _ti.weight;
		if _weight &gt; 1 then
			self.showMoveAmountForm(_ti,_quantity,_weight);
		endif;
	else
		_quantity := _ti.totalQuantity;
		if _quantity &gt; 1 then
			self.showMoveAmountForm(_ti,_quantity,_weight);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_weight" type="Decimal" usage="io"/>
        <Parameter name="_quantity" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAvailPackTis" id="cab03550-bc0c-47ab-b011-3bb99ea6c81f">
        <source>getAvailPackTis(_parent : Boolean): CM_TIArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
13 May 2024 navhl20 Bug 64101: EUP - For the Pack Job the parent and child details are empty on the Complete Job form
09 Jul 2024 navlc30 Bug 63707: EUP - 1090 Exception when clicking on the Pack button for the retrospective Pack jobs
08 Aug 2024 navhl20	Bug 65572: FR | 54177 - Retrospective Operations - Pack Process issue
12 Aug 2024 navhl20	Bug 65586: Pack Work order - Issues
01 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	tiArr 		: CM_TIArray;
	cmifMobile	: CMIF_MobileGenericAgent;
	relReq		: CM_BulkRelease;
	relsel		: CM_ReserveSelection;
	stwRule 	: Integer;
	sourceLC 	: CM_LocationsController;
	job			: CM_Job;
	wod			: CM_WodPack;
	parent		: CM_TrackedItem;
	wle			: CM_WorkListEntry;
	row			: Integer;
	minLength 	: Integer;
begin
	job := self.myJob;
	if _parent then
		wod := self.myJob.myWODtl.CM_WodPack;
		if wod &lt;&gt; null then
			job := wod.allJobs.first;
		endif;
	endif;
	relsel := job.allRequests.first.myReserveDetail.CM_ReserveSelection;
	
	create tiArr transient;
	
	if relsel &lt;&gt; null then
		relReq := relsel.myReserveHeader;
		if _parent then
			relReq.getProspectiveParentCargo(tiArr,false);
			foreach parent in wod.allCompleteTIs discreteLock do									//12.08.2024 navhl20 #65586
				if tiArr.includes(parent) then
					tiArr.tryRemove(parent);
				endif;
			endforeach;
		else
			if self.tblParent.rows &gt; 1 then															//09.07.2024 navlc30 #63707
				foreach row in 2 to self.tblParent.rows do											//08.08.2024 navhl20 #65572
					parent := self.tblParent.accessRow(row).itemObject.CM_TrackedItem;
					if parent.isPackingComplete then
						continue;
					else
						break;
					endif;
				endforeach;
			endif;
			create cmifMobile transient;
			cmifMobile.setMyTerminal( app.myPassport.myTerminal);
			cmifMobile.setPackContainerDetails(null,null,null,null,parent);
			cmifMobile.getCargoBasedOnSTW12Rules(relReq,relsel, sourceLC, null,stwRule,tiArr);
		endif;
	endif;
	
	if tiArr.isEmpty then				//13.05.2024 navhl20 #64101
		foreach wle in job.workListEntries do
			if  wle.myTrackedItem &lt;&gt; null and wle.status &lt;&gt; WLE_COMPLETED then
				tiArr.tryAdd(wle.myTrackedItem);
			endif;
		endforeach;
	endif;
	
	return tiArr;
epilog
	delete cmifMobile;
end;</source>
        <Parameter name="_parent" type="Boolean"/>
        <ReturnType type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="getAvailableTis" id="3856ccf8-3c62-41f4-bd14-2698513692a7">
        <source>getAvailableTis():CM_TIArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
11 Mar 2024 navhl20 ChangeRequest 60097: EUP | Ship Operations in DD - [54176.060] - [Receive] Retrospective Operations
02 Jul 2024 navnk30 Bug 64601: FR | 54883 - Start and End Times for Operations in Mobile App
12 Aug 2024 navma1	Bug 65379: MTN - 1090 in work order operations screen
01 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	wle,
	woWle		: CM_WorkListEntry;
	job			: CM_Job;
	tiArr 		: CM_TIArray;
	cmifMobile	: CMIF_MobileGenericAgent;
	relReq		: CM_BulkRelease;
	resDtl		: CM_ReserveDetail;
	relsel		: CM_ReserveSelection;
	woJob		: CM_WorkOrderJob;
	stwRule 	: Integer;
	sourceLC, 
	targetLC 	: CM_LocationsController;
	firstRequest: CM_Request;
begin
	if self.myJob.isVoyageWorkpointJob then
		woJob 	:= self.myJob.CM_VoyageWorkPointJob.getMyWOJob().CM_WorkOrderJob;			//04.04.2025 navhl20 #34493
		if woJob &lt;&gt; null then
			job := woJob;
		endif;
	elseif self.myJob.isKindOf(CM_WOToDoTaskJob) then	// ### TFS CR 62818 TASK 62821 14MAR2024 NAVAB1
		job := self.myJob;
	else
		job := self.myJob;
		wle := self.myJob.workListEntries.first;
		if wle &lt;&gt; null then
			woWle := wle.myWorkOrderWLE;
		endif;
		if woWle &lt;&gt; null then
			woJob := wle.myWorkOrderWLE.job.CM_WorkOrderJob;
		endif;
	endif;
	
	create tiArr transient;
	
	if self.myJob.isKindOf(CM_WOToDoTaskJob) then	// ### TFS CR 62818 TASK 62821 14MAR2024 NAVAB1
		self.myJob.CM_WOToDoTaskJob.allTrackedItems.copy(tiArr);
	else
		
		if woJob &lt;&gt; null then																		//12.8.2024 navma1 #65379
			firstRequest := woJob.allRequests.first;
		endif;
		
		if firstRequest &lt;&gt; null then																//02.04.2025 navhl20 #34493
			resDtl := firstRequest.myReserveDetail;
		endif;
		
		if resDtl &lt;&gt; null and resDtl.isReserveSelection then  			//12.8.2024 navma1 #65379	//01.04.2025 navhl20 #34493
			relsel := resDtl.CM_ReserveSelection;								 //02.07.2024 navnk30 #64601 END
		endif;
		
		if relsel = null then
			foreach wle in job.workListEntries discreteLock do										//01.04.2025 navhl20 #34493
				if  wle.myTrackedItem &lt;&gt; null and wle.status &lt;&gt; WLE_COMPLETED then
					tiArr.tryAdd(wle.myTrackedItem);
				endif;
			endforeach;
		else
			create cmifMobile transient;
			cmifMobile.setMyTerminal( app.myPassport.myTerminal);
			relReq := relsel.myReserveHeader;
			firstRequest := self.myJob.allRequests.first;									//02.07.2024 navnk30 #64601
			
			if self.myJob.isRoadJob then
				targetLC := self.myJob.CM_RoadJob.myVehicle.locationsController;
			elseif firstRequest.isHoldRequest then
				targetLC := firstRequest.CM_HoldRequest.myHoldControllerLoad;				//02.07.2024 navnk30 #64601 END
			endif;
			
			cmifMobile.getCargoBasedOnSTW12Rules(relReq,relsel, sourceLC, targetLC,stwRule,tiArr);
		endif;
	endif;
	
	return tiArr;
epilog

end;</source>
        <ReturnType type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="getBulkReleaseFromJob" id="d44a0e31-8797-4bb3-ac8a-f77fdc779bab">
        <source>getBulkReleaseFromJob(): CM_BulkRelease;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars
	bulkRelease				: CM_BulkRelease;
	job 					: CM_Job;
	wodtl					: CM_WorkOrderDtl;
begin
	job := self.myJob;
	if job &lt;&gt; null then
		wodtl := job.myWODtl;
	endif;
	if wodtl &lt;&gt; null then
		bulkRelease := wodtl.CM_WodPack.myReleaseRequest;
	endif;
	
	return bulkRelease;
epilog

end;</source>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="getCompletedTis" id="7d3021d2-866e-4d3b-81ff-96bfb3a9a217">
        <source>getCompletedTis():CM_TISet;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
02 Apr 2024 navma1	ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
01 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	wle 	: CM_WorkListEntry;
	tiSet	: CM_TISet;
begin
	create tiSet transient;
	foreach wle in self.myJob.allCompletedWLEsByDate discreteLock do			//02.04.2024 navma1 #63302 //01.04.2025 navhl20 #34493
		tiSet.tryAddIfNotNull(wle.myTrackedItem);		
	endforeach;
	
	return tiSet;
epilog

end;</source>
        <ReturnType type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="getEffectiveDate" id="3a8638b9-f9c7-437a-8017-92036c6c5d5e">
        <source>getEffectiveDate():TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars
	effectiveDate : TimeStamp;
begin
	effectiveDate.setDate(self.txtDate.text.asDateJMT);
	effectiveDate.setTime(self.txtTime.text.asTimeJMT);
	
	return effectiveDate;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getPackedTis" id="cf759883-ed32-41c0-8f76-cae19b52aee2">
        <source>getPackedTis():CM_TIArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
21 Aug 2024 navhl20	Bug 65424: EUP | 53729 - WO Jobs - Split Pack or Unpack job issues
01 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	tiArr 		: CM_TIArray;
	job			: CM_Job;
	wod			: CM_WodPack;
	wle			: CM_WorkListEntry;
begin
	wod := self.myJob.myWODtl.CM_WodPack;
	if wod &lt;&gt; null then
		foreach job in wod.allJobs discreteLock where job.id = self.myJob.id do	//21.08.2024 navhl20 #65424	//01.04.2025 navhl20 #34493
			break;
		endforeach;
	endif;
	
	create tiArr transient;
	
	foreach wle in job.allCompletedWLEsByDate discreteLock do		//01.04.2025 navhl20 #34493
		if  wle.myTrackedItem &lt;&gt; null then
			tiArr.tryAdd(wle.myTrackedItem);
		endif;
	endforeach;
	
	return tiArr;
epilog

end;</source>
        <ReturnType type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="getQuantityCompleted" id="2ad9a8d7-4aeb-493c-a1d9-41a2997c468f">
        <source>getQuantityCompleted():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Feb 2024 navhl20 ChangeRequest 62418: EUP | Retrospective Operations - [54177.040] - Road Release6

*/

vars
	tiSet	: CM_TISet;
	ti		: CM_TrackedItem;
	count	: Integer;
begin
	tiSet := self.getCompletedTis();
	
	foreach ti in tiSet do
		count := count + ti.totalQuantity;
	endforeach;
	
	return count;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQuantitytoPack" id="cd02006f-d28b-4519-8c6e-73effa46b6f3">
        <source>getQuantitytoPack(_quantity : Integer io; _weight : Decimal io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars
	packCargo : CM_TrackedItem;
begin
	if self.tblChild.allSelectedObjects.size =1 then
		packCargo := self.tblChild.allSelectedObjects.first.CM_TrackedItem;
		_quantity := packCargo.totalQuantity;
		if packCargo.totalQuantity &gt; 1 then
			self.showMoveAmountForm(packCargo,_quantity,_weight);
		endif;
	else
		foreach packCargo in self.tblChild.allSelectedObjects as CM_TrackedItem do
			_quantity := _quantity + packCargo.totalQuantity;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_quantity" type="Integer" usage="io"/>
        <Parameter name="_weight" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getReleaseDetailsForRail" id="9019a69b-7257-4a03-bfa3-9dfcdb6c3586">
        <source>getReleaseDetailsForRail(_ti : CM_TrackedItem; _wle : CM_WorkListEntry io; _wagon : CM_Wagon);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
24 Jun 2025	navbs1  Bug MTN-35184: MTN - 1090 exception on the complete job form when loading the cargo item for the release road job

*/

vars
	reserveDetail 	: CM_ReserveDetail;
	reserveSel		: CM_ReserveSelection;
begin
	if _ti.allReserveDetails.isEmpty then	//Check to make sure the allReserveDetails is not empty as we need one
		self.getReleaseDetailsFromWLE(_wle,reserveSel);					//24.06.2025 navbs1 #35184
		
		if reserveSel = null then 
			if app.msgBox(app.getErrorString(Reserve_detail_not_found), app.getErrorString(Error) , MsgBox_Question_Mark_Icon + MsgBox_OK_Only) = MsgBox_Return_OK then
				return;
			endif;
		endif;
	elseif _ti.allReserveDetails.size = 1 then
		//We have 1 reserve detail so just grab it and use it.
		reserveDetail := _ti.allReserveDetails.first;
		//Get release. The release should not be null as every reserveDetail should have a release if it doesn't that's a huge issue
		_wle := _wagon.getWLEforCargo(_ti, reserveDetail);
	else
		//We have more than 1 reserve detail so loop through all reserve details.
		//Trying to find the wle that matches the wagon, cargo and eserve detail.
		foreach reserveDetail in _ti.allReserveDetails do
			_wle := _wagon.getWLEforCargo(_ti, reserveDetail);
			if _wle &lt;&gt; null then
				//Get release. The release should not be null as every reserveDetail should have a release if it doesn't that's a huge issue
				break;
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="io"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="getReleaseDetailsFromWLE" id="33e67ab0-57f0-4236-98e8-b347c1ec3189">
        <source>getReleaseDetailsFromWLE(_wle : CM_WorkListEntry io; _reserveSel : CM_ReserveSelection io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
23 Jun 2025	navbs1  Bug MTN-35184: MTN - 1090 exception on the complete job form when loading the cargo item for the release road job

*/

vars
	wle				: CM_WorkListEntry;
	woWle			: CM_WOWLE;
	wod 			: CM_WodRelease;
	job 			: CM_Job;
	reserveDtl 		: CM_ReserveDetail;
begin
	_wle := self.myJob.getFirstWle();   
	
	if _wle &lt;&gt; null  then 
		woWle		:= _wle.myWorkOrderWLE;
	endif;
	
	if woWle &lt;&gt; null then
		job := woWle.job;
	endif;
	
	if job &lt;&gt; null and job.myWODtl.isWodRelease then
		wod 	:= job.myWODtl.CM_WodRelease;
	endif;
	
	//23.6.2025 navbs1 #35184 START
	/*if wod &lt;&gt; null and wod.myReserveDetail.isReserveSelection then
		_reserveSel := wod.myReserveDetail.CM_ReserveSelection;
		_release := _reserveSel.myReserveHeader;
	endif;*/
	
	if wod &lt;&gt; null then 
		reserveDtl := wod.myReserveDetail;
	endif;
	if reserveDtl &lt;&gt; null and  reserveDtl.isReserveSelection then 
		_reserveSel := wod.myReserveDetail.CM_ReserveSelection;
	endif;
	//23.6.2025 navbs1 #35184 END
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="io"/>
        <Parameter name="_reserveSel" type="CM_ReserveSelection" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getReleaseFromJobShipRel" id="a5e28c63-2595-4566-8a1a-6e81a86ab199">
        <source>getReleaseFromJobShipRel(_reserveSel : CM_ReserveDetail io; _release : CM_BulkRelease io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars
	job,
	context			: CM_Job;
begin
	context := self.myJob;
	job	:= context.CM_VoyageWorkPointJob.myWorkOrderReleaseJob;
	
	_reserveSel := job.allRequests.first.myReserveDetail;
	if _reserveSel &lt;&gt; null then
		_release := _reserveSel.myReserveHeader;
	endif;
epilog

end;</source>
        <Parameter name="_reserveSel" type="CM_ReserveDetail" usage="io"/>
        <Parameter name="_release" type="CM_BulkRelease" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getResDtlFromJob" id="18472dc3-1f0e-4ff4-ac63-e63d8b707cd4">
        <source>getResDtlFromJob(_resDtl : CM_ReserveDetail io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars
	req		: CM_Request;
	woJob	: CM_Job;
begin
	req := self.myJob.allRequests.first;
	if req &lt;&gt; null then
		_resDtl := req.myReserveDetail;
	endif;
	
	if _resDtl = null and self.myJob.isVoyageWorkpointJob then
		woJob := self.myJob.CM_VoyageWorkPointJob.myWorkOrderReceiveJob;
		if woJob = null then
			woJob := self.myJob.CM_VoyageWorkPointJob.myWorkOrderReleaseJob;
		endif;
		
		if woJob &lt;&gt; null then
			req := woJob.allRequests.first;
			if req &lt;&gt; null then
				_resDtl := req.myReserveDetail;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_resDtl" type="CM_ReserveDetail" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getSelectedObjects" id="3bb5a0e9-6ac1-4467-893f-b651e706aca6">
        <source>getSelectedObjects(_table :CM_DataTable input; _tiSet : CM_TISet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jul 2024 navbs1 ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group
03 Dec 2024 navbs1 Bug MTN-33570: MTN - Ship WorkOrder Enhancements

*/

vars
	row,endRow  : Integer;
	selectedTI :CM_TrackedItem;
	selectedRow :JadeTableRow;
	detail :CM_CargoGroupDetail;
begin

	if _table = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _table passed to method');
		return;
	endif;
	
	if not self.isCargoGrouping then					//03.12.2024  navbs1  #33570
		_table.allSelectedObjects.copy(_tiSet);
		return;
	endif;
	
	row := _table.fixedRows+1;
	endRow := _table.rows;

	while row &lt;= endRow do 
		selectedRow :=_table.accessRow(row);
		if not selectedRow.selected then 
		row:= row+1;
		continue;
		endif;
		selectedTI:= selectedRow.itemObject.CM_TrackedItem;

		if selectedTI = null or selectedTI.isCargoGroupItem then
			if  self.isBulkMode then 
			detail:=self.allCargoGroupDetails[_table.name,selectedTI].CM_CargoGroupDetail;
			detail.allAssignedTrackedItems.copy(_tiSet);	//03.12.2024  navbs1  #33570
			endif;
		else
			_tiSet.tryAdd(selectedTI);						//03.12.2024  navbs1  #33570
		endif;
		row:= row+1;
	endwhile;

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTotalCount" id="6da6f36a-43cf-46c7-b322-6229d7ba91b1">
        <source>getTotalCount(_tbl : CM_DataTable input):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
24 May 2024 navhl20 ChangeRequest 64271: EUP - Improve Bulk Discharge - Retrospective Screen
08 Aug 2025	jlizm1	MTN 35316 Pagination - Work Order Complete
*/

vars
	count,
	row			: Integer;
	ti			: CM_TrackedItem;
	col			: CM_ObjectArray;
	tmpObj		: Object;
	
begin
	
	if _tbl.isPaginated then
		create col transient;
		_tbl.getAllRowObjects(col);
		
		foreach tmpObj in col where tmpObj.isKindOf(CM_TrackedItem) do
			count 	:= count + tmpObj.CM_TrackedItem.totalQuantity;
		endforeach;
		
	else
		foreach row in 2 to _tbl.rows do
			ti 		:= _tbl.accessRow(row).itemObject.CM_TrackedItem;
			if ti &lt;&gt; null then						//24.05.2024 navhl20 #64271
				count 	:= count + ti.totalQuantity;
			endif;
		endforeach;
	endif;
	
	return count;
	
epilog
	delete col;

end;</source>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalQuantity" id="24277cc4-1247-4d22-9366-e010d973cf31">
        <source>getTotalQuantity(_tiArr	: Collection) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Aug 2024	navnk30	Bug 65566: Table name is displayed wrongly on the Complete Job form for Ship Jobs

*/

vars
	ti				: CM_TrackedItem;
	totalQuantity	: Integer;
begin
	foreach ti in _tiArr as CM_TrackedItem do
		totalQuantity += ti.totalQuantity;
	endforeach;
	return totalQuantity;
epilog

end;</source>
        <Parameter name="_tiArr" type="Collection"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTragetLocation" id="6f90b1ff-232a-4e9c-a8b0-50d420c42aac">
        <source>getTragetLocation():CM_LocationsController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Apr 2024 navma1	ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
04 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	targetLocation	: CM_LocationsController;
	ta				: CM_TerminalArea;
	gridObject		: CM_GridObject;
	subArea			: Object;
begin
	subArea := self.cmbSubArea.listObject;
	
	if subArea &lt;&gt; null then
		if subArea.isKindOf(CM_LocationsController) then
			targetLocation 	:= subArea.CM_LocationsController;
		elseif subArea.isKindOf(CM_GridObject) then
			gridObject     	:= subArea.CM_GridObject;
			targetLocation 	:= gridObject.getNextAvailableLocation(REAL_MODE);
		endif;
	endif;
	
	if targetLocation = null then
		ta 					:= self.cmbTerminalArea.listObject.CM_TerminalArea;
		if ta &lt;&gt; null then
			targetLocation 	:= ta.allLocationsControllers.first;
		endif;
	endif;
	
	return targetLocation;
epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getWagonForJob" id="c4d91a17-3c57-43e7-887d-3d855038aeca">
        <source>getWagonForJob(_railJob : CM_RailJob): CM_Wagon;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars
	wagon : CM_Wagon;
begin
	wagon := _railJob.getWagonFromWle();
	if wagon = null then
		wagon := _railJob.getMyWagon();
	endif;
	
	if wagon = null then
		wagon := _railJob.getWagonFromTrain();
	endif;
	
	return wagon;
epilog

end;</source>
        <Parameter name="_railJob" type="CM_RailJob"/>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="d6f5f2ed-8c5d-424b-ad46-5876dc0f729e">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
13 Feb 2024 navhl20 ChangeRequest 62418: EUP | Retrospective Operations - [54177.040] - Road Release
14 Mar 2024 navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
03 Dec 2024 navbs1  Bug MTN-33570: MTN - Ship WorkOrder Enhancements
01 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	rtnString	:	String;
begin
	rtnString := inheritMethod();
	if self.defAvailCargo &lt;&gt; null then
		rtnString := rtnString &amp; global.formatAsXML(self.tblAvailCargo.name, self.defAvailCargo);
	endif;
	if self.defCompletedCargo &lt;&gt; null then
		rtnString := rtnString &amp; global.formatAsXML(self.tblCompletedCargo.name, self.defCompletedCargo);
	endif;
	if self.defParent &lt;&gt; null then													//14.03.2024 navhl20 #62861
		rtnString := rtnString &amp; global.formatAsXML(self.tblParent.name, self.defParent);
	endif;
	if self.defChild &lt;&gt; null then													//14.03.2024 navhl20 #62861
		rtnString := rtnString &amp; global.formatAsXML(self.tblChild.name, self.defChild);
	endif;
	if self.defUnpacked &lt;&gt; null then												//14.03.2024 navhl20 #62861
		rtnString := rtnString &amp; global.formatAsXML(self.tblUnpacked.name, self.defUnpacked);
	endif;
	rtnString := rtnString &amp; global.formatAsXML(self.chkHideCompleted.name, self.chkHideCompleted.value.String);
	
	rtnString := rtnString &amp; global.formatAsXML(self.chkCargoGrouping.name, self.chkCargoGrouping.value.String);			//03.12.2024  navbs1  #33570
	
	return rtnString;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="f19c66e8-7eca-46ec-a6c8-4d0bc8badb52">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Feb 2024 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
13 Feb 2024 navhl20 ChangeRequest 62418: EUP | Retrospective Operations - [54177.040] - Road Release
14 Mar 2024 navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
03 Dec 2024 navbs1 Bug MTN-33570: MTN - Ship WorkOrder Enhancements
01 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	hideCompleted		: String;
	cargoGrpEnabled		: String;
begin
	
	inheritMethod(_userWindow);
	
	if _userWindow = null then
		return;
	endif;
	
	self.defAvailCargo   	:= _userWindow.xmlInfo.cnEcGetTagValueOfName(self.tblAvailCargo.name);
	self.defCompletedCargo 	:= _userWindow.xmlInfo.cnEcGetTagValueOfName(self.tblCompletedCargo.name);
	self.defParent   		:= _userWindow.xmlInfo.cnEcGetTagValueOfName(self.tblParent.name);					//14.03.2024 navhl20 #62861
	self.defChild 			:= _userWindow.xmlInfo.cnEcGetTagValueOfName(self.tblChild.name);					//14.03.2024 navhl20 #62861
	self.defUnpacked 		:= _userWindow.xmlInfo.cnEcGetTagValueOfName(self.tblUnpacked.name);				//14.03.2024 navhl20 #62861
	
	hideCompleted := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkHideCompleted.name);
	if hideCompleted &lt;&gt; null then
		self.chkHideCompleted.value := hideCompleted.Boolean;
	endif;
	
	cargoGrpEnabled := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkCargoGrouping.name);			//03.12.2024  navbs1  #33570
	if cargoGrpEnabled &lt;&gt; null then																		//03.12.2024  navbs1  #33570
		self.chkCargoGrouping.value := cargoGrpEnabled.Boolean;
	endif;
epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initTblResource" id="97d3568f-6239-4d0f-abf5-b0b9ea29dfd9">
        <source>initTblResource();
/*
Purpose - 	
Who - NAVAB1
Date - 14MAR2024
ADO -  CR 62818 TASK 62821 
*/

vars
	theTable		: CM_DataTable;
	entTableDef		: EntTableDef;
begin
	theTable := self.tblResources;
	theTable.allSelectedObjects.clear;
	
	theTable.userInputEnabled := false;
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.columns := 4;
	
	theTable.rows := 0;
	theTable.addItem("Resource" &amp; Tab &amp; "Group" &amp; Tab &amp; "Mandatory" &amp; Tab &amp; "Completed");
	theTable.fixedRows := 1;
end;</source>
    </JadeMethod>
    <JadeMethod name="isCargoGrouping" id="6e5274ab-64ba-4b50-8c50-d60646e61b8b">
        <source>isCargoGrouping(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jul 2024 navbs1 ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group
03 Dec 2024 navbs1 Bug MTN-33570: MTN - Ship WorkOrder Enhancements
01 Apr 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars

begin
	return self.chkCargoGrouping.visible and self.chkCargoGrouping.value ;				//03.12.2024  navbs1  #33570
epilog

end;</source>
        <ReturnType type="Boolean"/>
