    <JadeMethod name="doMnuListAll" id="055cc461-4c8f-4404-a76f-73884e1386d2">
        <updating/>
        <source>doMnuListAll() updating;
/*
	PAR 24343 - RJS - 31 May 2010 - List selected TIs

*/
vars
	coll	: ObjectSet;
	oa		: ObjectArray;
	
begin
	self.mousePointer	:= Busy;
	
	if self.myCurrentDrawingController &lt;&gt; null and self.myCurrentDrawingController.myTerminalArea &lt;&gt; null then
		self.myAssistant.showLocationEnquiryForm(self.myCurrentDrawingController.myTerminalArea, self.myMasterMenuAction, false, false);
	endif;
	
	/*
	create coll transient;
	
	// Get a collection of ALL the objects (containers) to pass to the Summary Definition form.
	if self.myCurrentDrawingController &lt;&gt; null and self.myCurrentDrawingController.myTerminalArea &lt;&gt; null then
		// For the current drawing controller process each of the location controllers and get the tracked items.
		self.myCurrentDrawingController.myTerminalArea.CM_TerminalArea.getAllLocationsTrackedItems( coll );
	endif;
	if (not coll.isEmpty) then
		// need to refactor some of these methods so do not need to copy here (RJS)
		create oa transient;
		coll.copy(oa);
		self.myAssistant.showCargoEnquiryForTIs(coll.first.CM_TrackedItem, oa, self.myMasterMenuAction, false);
	endif;
	*/
	
	
epilog
//	delete coll;
//	delete oa;
	self.mousePointer	:= Idle;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doMnuListSelected" id="a0eb6930-54e4-4811-a5d2-d5bc2007436d">
        <updating/>
        <source>doMnuListSelected() updating;
/*
	PAR 24343 - RJS - 31 May 2010 - List selected TIs

*/
	
vars
	coll	: ObjectArray;
	
begin
	self.mousePointer	:= Busy;
	create coll transient;
	
	// Get a collection of all the objects (containers) SELECTED to pass to the Summary Definition form.
	if self.myCurrentDrawingController &lt;&gt; null then
		self.myCurrentDrawingController.allSelectedObjects.copy( coll );
	endif;
	
	if (not coll.isEmpty) then
		self.myAssistant.showCargoEnquiryForTIs(coll.first.CM_TrackedItem, coll, self.myMasterMenuAction, false);
	endif;
	
epilog
	delete coll;
	self.mousePointer	:= Idle;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doMnuQuickCargoClick" id="17a4d49e-8372-4f36-a767-85836ab1a488">
        <updating/>
        <source>doMnuQuickCargoClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     30 November 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	gridLC : CM_GridController;
	numItems : Integer;
	is40 : Boolean;
begin
	if menuItem.userObject = null then
		return;
	endif;
	if not menuItem.userObject.isKindOf(CM_GridController) then
		return;
	endif;
	
	gridLC := menuItem.userObject.CM_GridController;
	
	numItems := 10;
	read numItems;
	
	if app.msgBox("Create " &amp; numItems.String &amp; " Quick Cargo Items in " &amp; gridLC.myTerminalArea.id &amp; "?", "Quick Cargo", MsgBox_Yes_No) = MsgBox_Return_Yes then
		is40 := app.msgBox("Create 40 foot?", "Quick Cargo", MsgBox_Yes_No) = MsgBox_Return_Yes;

		gridLC.myTerminalArea.CM_GridArea.createQuickCargo(numItems, is40,gridLC);
		return;
	endif;
	
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
