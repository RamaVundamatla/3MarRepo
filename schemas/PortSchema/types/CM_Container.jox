					CM_Terminal::chilledTIsOffPower collection

Parameters:			None

Return Value:		True if it can have

Date		Who		Reason
20 Nov 2017	jlgkpd1	Initial creation - TFS 7466

*/

vars

begin
	// By default, containers can be in the collection
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
