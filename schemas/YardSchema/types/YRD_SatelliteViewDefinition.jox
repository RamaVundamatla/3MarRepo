    <JadeMethod name="populateForm" id="ebcbaad6-0811-4376-a230-e175406e8cc3">
        <updating/>
        <source>populateForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
01 September 2008	consw1	Initial creation
19 September 2011	cnwdap1	PAR #27814 prevent 1090 when adding a new default view
*/

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	area 				: CM_TerminalArea;
	areaMaster : CM_TerminalAreaMaster;
	areaType			: CM_TerminalAreaType;
	areaViewPosition	: CM_TerminalAreaViewPosition;
	areaView			: CM_TerminalAreaView;
	clonedFrame			: Frame;
	index 				: Integer;
	areaViewName 		: String;
	isempty : Boolean;
	dynaDict : DynaDictionary;
	iter : Iterator;
	state, totqty : Integer;
begin

	self.frmArea.visible := false;
	self.allAreaFrames.purge();
	self.lstAreas.clear();

	/* TFS 51097 - Sort Terminal Area Types by Name
	foreach area in self.myTerminal.allTerminalAreasByTypeId where area.myType.isSatelliteViewable do
		if area.myType &lt;&gt; areaType then
			areaType := area.myType;
			index := self.lstAreas.addItem(areaType.description);
			self.lstAreas.itemLevel[index]	:= 1;
			self.lstAreas.itemObject[index]	:= null;
			self.lstAreas.itemExpanded[index]	:= true;
		endif;
		index := self.lstAreas.addItem(area.id);
		self.lstAreas.itemLevel[index]	:= 2;
		self.lstAreas.itemObject[index]	:= area;
	endforeach;
*/
	// TFS 51097 - Sort Terminal Area Types by Name
	create dynaDict transient;	
	dynaDict.setMembership(CM_TerminalAreaType);
	dynaDict.addMemberKey(CM_TerminalAreaType::description.name, false, true);
	dynaDict.endKeys(true);


	app.myRoot.allTerminalAreaTypes.copy(dynaDict);
	iter := dynaDict.createIterator();

	while(iter.next(areaType))  do
		if not areaType.isSatelliteViewable() then 
			continue;
		endif;
		isempty:= true;
		foreach areaMaster in areaType.allTerminalAreasByTerminal where areaMaster.myTerminal = self.myTerminal do
			isempty := false;
			break;
		endforeach;		
		
		if isempty then
			continue;
		endif;
		
		
		index := self.lstAreas.addItem(areaType.description);
		self.lstAreas.itemLevel[index]	:= 1;
		self.lstAreas.itemObject[index]	:= null;
		self.lstAreas.itemExpanded[index]	:= true;

		foreach areaMaster in areaType.allTerminalAreasByTerminal where areaMaster.myTerminal = self.myTerminal do
			if not areaMaster.isKindOf(CM_TerminalArea) then
				continue;
			endif;
				area := areaMaster.CM_TerminalArea;
				
				
				
			index := self.lstAreas.addItem(area.id);
			self.lstAreas.itemLevel[index]	:= 2;
			self.lstAreas.itemObject[index]	:= area;
		endforeach;
	endwhile;


	
	
	areaView := self.getAreaView();
	if areaView &lt;&gt; null then
		foreach areaViewPosition in areaView.allTerminalAreaViewPositions do
			clonedFrame := self.cloneAreaFrame( areaViewPosition );
			self.drawArea( clonedFrame );
			index := self.lstAreas.findObject(areaViewPosition.myTerminalArea);
			if index &gt; 0 then
				self.lstAreas.itemObject[index] := clonedFrame;
			endif;
		endforeach;
		
		//areaViewName:=self.myAreaView.name;	// PAR #27814
		areaViewName := areaView.name;			// PAR #27814
	endif;

	self.enableAreaButtons();

	self.setCaption(app.zGetTranslatedText(XLAT_FormCaptions,Xlat_0010428).text &amp; " - "  &amp; areaViewName);
	self.setNavigatorHeading(self.caption); 

	

epilog		
	delete dynaDict;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="saveScrollingMainOffset" id="e6388863-0a9b-4b37-911c-bd1358a9e29f">
        <updating/>
        <source>saveScrollingMainOffset() updating;

/*

Purpose:		This method is called to save the initial position (0,0) of the scrolling view relative to it parent control.

Parameters:			

Return Value:


Date				Who		Reason
05 September 2008	consw1	Initial creation

*/

vars
	x1, x2, y1, y2	: Real;

begin
	self.frmScrollingMain.windowToScreen( x1, y1 );
	self.frmScrollingMain.parent.windowToScreen( x2, y2 );

	scrollingMainOffset.setX( (x1 - x2).Integer );
	scrollingMainOffset.setY( (y1 - y2).Integer );

epilog

end;</source>
    </JadeMethod>
