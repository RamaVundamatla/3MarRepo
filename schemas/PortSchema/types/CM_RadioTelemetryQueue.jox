    <JadeMethod name="doesTIMatch" id="a0f6dcdb-1ede-4a9f-8aef-c77109b91115">
        <source>doesTIMatch(_ti : CM_TrackedItem; _failReason : String output) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 October 2025		jlizm1	Initial creation MTN 35861 RTQueue configuration - cargo attribute criteria

*/

vars
	criteria : CM_YACriteria;
	cmifAutoPlan : CMIF_YAAutoPlanNormal;
	
begin
	create cmifAutoPlan transient;
	cmifAutoPlan.attachTI(_ti);

	foreach criteria in self.allCriteria discreteLock do
		if not criteria.isCMIFAutoPlanDataMatch(cmifAutoPlan) then
			_failReason := criteria.getDescription;
			return false;
		endif;
	endforeach;
	
	return true;
	
epilog
	delete cmifAutoPlan;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_failReason" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
