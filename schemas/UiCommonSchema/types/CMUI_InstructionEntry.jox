    <JadeMethod name="createInstructionEntry" id="6a3ca4c5-583c-4b53-baf4-82a1e1d0eeb9">
        <updating/>
        <source>createInstructionEntry()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
06 Nov 2023	navnk30	ChangeRequest 60933: EUP - Operational Instructions - CM_TrackedItem Inverse

*/

vars
	myInstruction : CM_InstructionType;
	internalInstru,
	externalinstru : String;
	pxyInstructionIssued,
	realInstructionIssued: CM_InstructionsIssued;
	theReturn : Integer;
begin
	if self.txtExternalReference &lt;&gt; null then
		externalinstru := self.txtExternalReference.text.String;
	endif;
	if self.txtInternalInstructions &lt;&gt; null then
		internalInstru := self.txtInternalInstructions.text.String;
	endif;
	if self.cmbInstructions.listIndex &lt;&gt; -1 then
		myInstruction := self.cmbInstructions.itemObject[self.cmbInstructions.listIndex].CM_InstructionType;
	endif;
	
	create pxyInstructionIssued transient;
	/*if self.myObject.isKindOf(CM_TrackedItem) then 		//06.11.2023 navnk30 #60933
		pxyInstructionIssued.setProxy(internalInstru,externalinstru,myInstruction,null);
	else
		pxyInstructionIssued.setProxy(internalInstru,externalinstru,myInstruction,self.myObject);
	endif;
	*/
	pxyInstructionIssued.setProxy(internalInstru,externalinstru,myInstruction,self.myObject);	//06.11.2023 navnk30 #60933
	
	while true do
		app.myTrxCA.trxCreateInstructionIssued(pxyInstructionIssued, realInstructionIssued, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			/*beginTransaction;					//06.11.2023 navnk30 #60933
			if self.myObject.isKindOf(CM_TrackedItem) then
				self.myObject.CM_TrackedItem.setmyInstructions(realInstructionIssued);
			endif;
			commitTransaction;
			*/
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Instructio_entry_created), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
	self.unloadForm();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createPxyInstructions" id="49e9da48-4b7f-4cec-9a7f-eeeed4024156">
        <source>createPxyInstructions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2024	navnk30	ChangeRequest 63607: FR | 53127 - Additional Operational Instructions on the Order - Remedial

*/

vars
	insType : CM_InstructionType;
	internalIns,
	externalIns : String;
	pxyIns		: CM_InstructionsIssued;
begin
	if self.txtExternalReference &lt;&gt; null then
		externalIns := self.txtExternalReference.text.String;
	endif;
	if self.txtInternalInstructions &lt;&gt; null then
		internalIns := self.txtInternalInstructions.text.String;
	endif;
	if self.cmbInstructions.listIndex &lt;&gt; -1 then
		insType := self.cmbInstructions.itemObject[self.cmbInstructions.listIndex].CM_InstructionType;
	endif;
	create pxyIns transient;
	pxyIns.setProxy(internalIns, externalIns, insType, self.myObject);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="disableControls" id="c0b37c83-0ee4-4eef-9914-5b4ba7ee88a4">
        <source>disableControls();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Aug 2023 navhl20 Bug 60029: MTN - Able to delete the instructions even after the booking is fully received.

*/

vars

begin
	self.cmbInstructions.enabled 	  	 := false;
	self.txtExternalReference.enabled 	 := false;
	self.txtInternalInstructions.enabled := false;
	self.btnSave.enabled 				 := false;
	self.btnClear.enabled 				 := false;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displaySelectedItem" id="a00a1323-b00b-406b-86f3-df8b67f775ad">
        <source>displaySelectedItem();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars
	instructionType : CM_InstructionType;
begin
	self.cmbInstructions.listIndex := self.cmbInstructions.findObject(instructionType.allInstructionsIssued);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClear" id="04484620-040d-40e0-85c3-0719ead09b6f">
        <updating/>
        <source>doClear() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Nov 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars

begin
	if self.populateInstruction then 
		self.clearInstructions(self.myObject);	
	else
		self.txtInternalInstructions.text := "";
		self.txtExternalReference.text := "";
		self.cmbInstructions.listIndex	:= -1;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPermissionCheck" id="4f0798a7-2a78-4917-93e3-9fb54dad40db">
        <source>doPermissionCheck();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars

begin
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnClear.enabled := false;
		self.btnSave.enabled:= false;
		self.txtExternalReference.enabled	:= false;
		self.txtInternalInstructions.enabled := false;
		self.cmbInstructions.enabled := false;		
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="fc0ebd03-1cdd-4c33-9f50-5ccfad425949">
        <updating/>
        <source>doSave()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
15 Dec 2022 navmv20 TFS ChangeRequest 55858 Task 55867 : EUP - Instruction code refactor
14 May 2024	navnk30	ChangeRequest 63607: FR | 53127 - Additional Operational Instructions on the Order - Remedial

*/

vars
	
begin
	//if self.txtExternalReference.text = null and self.txtInternalInstructions.text = null and self.cmbInstructions.listIndex = -1 then	//14.05.2024 navnk30 #63607
	if self.myObject = null or							//14.05.2024 navnk30 #63607
			(self.txtExternalReference.text = null and 
			 self.txtInternalInstructions.text = null and
			 self.cmbInstructions.listIndex = -1) then
		return;
	endif;
	
	//if self.myObject &lt;&gt; null then						//14.05.2024 navnk30 #63607
	if self.myObject.cnEcIsPersistent() then			//14.05.2024 navnk30 #63607

		 //15/12/2022 navmv20 TFS CR 55867 Task 55858 START
		if self.myObject.hasInstructionsForUpdate() then
			self.updateInstructionEntry();
		else
			self.createInstructionEntry();
		endif;
		//15/12/2022 navmv20 TFS CR 55867 Task 55858 - END
	else												//14.05.2024 navnk30 #63607
		if self.myObject.hasInstructionsForUpdate() then
			self.updatePxyInstructions();
		else
			self.createPxyInstructions();
		endif;
		self.unloadForm();
	endif;
epilog

end;</source>
    </JadeMethod>
