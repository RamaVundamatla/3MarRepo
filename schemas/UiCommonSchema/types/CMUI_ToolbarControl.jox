    <JadeMethod name="positionSelf" id="60c2b68c-a197-4f7f-a410-ffb444bb5173">
        <updating/>
        <source>positionSelf(_showCaptions : Boolean; _offSet : Integer) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2003		cnwth2	
//
// Purpose:      
// ----------   ----------  --------------------------------------------------
vars

begin
	self.left := _offSet;
	
	return self.getWidth(_showCaptions) + self.ControlGap;

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
        <Parameter name="_offSet" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
