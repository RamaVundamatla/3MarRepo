        <source>getWorkOrderForInvoice() : CM_WorkOrder;
/*

Purpose:		TFS 39349	cargo that is on a voyage work order  for cargo or additional cargo need their invoices linked to that work order

Parameters:			

Return Value:		

Date		Who		Reason
03 August 2018	jlgab1:AM	Initial creation

*/

vars
	ti : CM_TrackedItem;
	
begin
	ti := self.myTrackedItem;
	
	if ti = null then
		return null;
	endif;
	
	
	return ti.getWorkOrderForInvoice();
epilog

end;</source>
