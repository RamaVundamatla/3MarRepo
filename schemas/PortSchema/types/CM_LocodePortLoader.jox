    <JadeMethod name="create" id="8850434f-a617-4052-ab10-bf0a89ea21a4">
        <updating/>
        <source>create() updating;
// -------------------------------------------
// Created 05 April 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	self.rootObj := app.myRoot;
	self.myExistingPorts.setMembership(CMIF_PortSorter);
	self.myExistingPorts.addMemberKey(CMIF_PortSorter::portCode.name, false, true);
	self.myExistingPorts.addMemberKey(CMIF_PortSorter::countryCode.name, false, true);
	self.myExistingPorts.endKeys(false);
	
	self.myUpdatingPorts.setMembership(CMIF_PortSorter);
	self.myUpdatingPorts.addMemberKey(CMIF_PortSorter::filePortCode.name, false, true);
	self.myUpdatingPorts.addMemberKey(CMIF_PortSorter::fileCountryCode.name, false, true);
	self.myUpdatingPorts.endKeys(false);
	
	self.mySortedPorts.setMembership(CM_Port);
	self.mySortedPorts.addMemberKey(CM_Port::portCode.name, false, true);
	self.mySortedPorts.endKeys(true);
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="4891a0d2-d6f4-4009-96b6-52e8322df630">
        <updating/>
        <source>delete() updating;
// -------------------------------------------
// Created 05 April 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	self.myExistingPorts.purge();
	self.myUpdatingPorts.purge();


end;</source>
    </JadeMethod>
    <JadeMethod name="findPortCodeInCurrentList" id="14c0217d-d9e6-48b2-b62b-451e7b8b21f0">
        <source>findPortCodeInCurrentList(_obj : CM_Object input; _attribute : String) protected;

// Created by cnwdvb1 on 07 April 2006

vars

	str,
	strValue	: String;
	port		: CM_Port;
	
begin

	strValue := _obj.getPropertyValue(_attribute).String.trimBlanks();

	if strValue = null or strValue.length &gt; 3 then
		return;
	endif;
	
	port := self.mySortedPorts[strValue].CM_Port;
	
	if port = null then
		str := 'Could not find a port for '&amp;_obj.auditId()&amp;'('&amp;_obj.String&amp;') '&amp;_attribute&amp;' port code - '&amp;strValue;
		app.writeLog(str, LogINFO);
		return;	
	endif;
	
	self.exclusiveLock(_obj);
	_obj.setPropertyValue(_attribute, port.code);	

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object" usage="input"/>
        <Parameter name="_attribute" type="String"/>
    </JadeMethod>
    <JadeMethod name="getCountry" id="62db9e72-597a-4c19-a75d-7460e362c6e7">
        <source>getCountry( array : HugeStringArray; cmif : CMIF_Country io);
//-----------------------------------------------------------------------
//	Created:	18 April 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	countryName,
	countryCode	: String;
	pxyCountry,
	country		: CM_Country;	
	aPort 		: CM_Port;


begin

	countryCode := array[2];
	countryName := array[4][2:end];
		
	// Find the country in the database.
	country := app.myRoot.allCountries.getAtKey(countryCode);	
	
	// We have it so update it.
	if country &lt;&gt; null then
	
		if self.allUpdatedCountries.includes(country) then
			return;
		endif;
		
		pxyCountry := app.createUpdateProxy(country).CM_Country;
		pxyCountry.setProxy(countryCode, countryName, null, null, false, null);
		cmif.myProxyCountry := pxyCountry;
		cmif.allRealPorts.clear();
		country.ports.copy(cmif.allRealPorts);
		
		// Perform the operation
		app.myUtilityUA.utlUpdateCountry(cmif, pxyCountry, app.myPassport);
	
		foreach aPort in country.ports do
			aPort.setMyCountry(null);
		endforeach;
		
		foreach aPort in cmif.allRealPorts do
			aPort.setMyCountry(country);
		endforeach;
	
//		app.myTrxUA.trxUpdateCountry(cmif, app.myPassport);
//		if not app.myPassport.trxCompletedOK then

//		endif;
	else
		// Create a new one.
		create pxyCountry transient;
		pxyCountry.setProxy(countryCode, countryName, null, null, false, null);
		cmif.myProxyCountry := pxyCountry;
		cmif.allRealPorts.clear();
		
		// Perform the operation
		app.myUtilityCA.utlCreateCountry(cmif, country, app.myPassport);
		
//		app.myTrxCA.trxCreateCountry(cmif, country, app.myPassport);
//		if not app.myPassport.trxCompletedOK then

//		endif;
	endif;
	
	self.allUpdatedCountries.add(country);
	
	

epilog
	delete pxyCountry;
end;</source>
        <Parameter name="array" type="HugeStringArray"/>
        <Parameter name="cmif" type="CMIF_Country" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getPort" id="56763e8d-089c-4465-9371-7e15b7b697d9">
        <source>getPort( array : HugeStringArray);
//-----------------------------------------------------------------------
//	Created:	18 April 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	portSorter	: CMIF_PortSorter;
	locode,
	country,
	locodeDesc, 
	locodeType	: String;
	port		: CM_Port;
	count		: Integer;

begin

	// get data from array
	if array[2].length &lt;&gt; 2 then
		return;
	endif;
	country 	:= array[2];
	locode		:= array[3];
	locodeDesc 	:= array[4][1:40];
	locodeType	:= array[7];

	portSorter := self.myExistingPorts.getAtKey(locode, country).CMIF_PortSorter;
			
	// We have found one. Make sure we haven't updated it already as file as dupes.
	if portSorter &lt;&gt; null and not portSorter.isFound then
		// Update port with new information and change code. Add appropriate  current sets
		port := portSorter.myPort;
		portSorter.filePortCode				:= locode;
		portSorter.fileCodeDescription		:= locodeDesc;
		portSorter.fileCountryCode			:= country;
		portSorter.fileCodeType				:= locodeType;
		portSorter.isActive					:= true; // Just incase
		portSorter.isFound					:= true;
	else
		// Just try without country.
		// This was used for data fix
	/*	self.myExistingPorts.startKeyGeq(locode, null, iter);
		while iter.next(portSorter) do
			if portSorter.portCode = locode and portSorter.countryCode = null then
				if not portSorter.isFound then
					break;
				else
					continue;
				endif;
			else
				portSorter := null;
				break;
			endif;
		endwhile;
		
		// Try and find this code without a country code.
		portSorter := self.myExistingPorts.getAtKey(locode, null).CMIF_PortSorter;
		if portSorter &lt;&gt; null and not portSorter.isFound then
			// Update port with new information and change code. Add appropriate  current sets
			port := portSorter.myPort;
			portSorter.filePortCode				:= locode;
			portSorter.fileCodeDescription		:= locodeDesc;
			portSorter.fileCountryCode			:= country;
			portSorter.fileCodeType				:= locodeType;
			portSorter.isActive					:= true; // Just incase
			portSorter.isFound					:= true;
		else*/
	 	// This locode doesn't exist in the current set.
		create portSorter transient; 
		port := app.myRoot.allPorts.getAtKey(country[1:2] &amp; locode[1:3]);
		// Double check. Will be duplicate
		if port &lt;&gt; null then //and not port.isActive then
			portSorter.myPort := port;
			portSorter.isActive := port.isActive;
		else
			portSorter.isActive					:= false; // Just incase	
		endif;
		
		portSorter.filePortCode				:= locode;
		portSorter.fileCodeDescription		:= locodeDesc;
		portSorter.fileCountryCode			:= country;
		portSorter.fileCodeType				:= locodeType;
		portSorter.isFound					:= true;
		
	endif;

	// Check for duplicates.  We don't want to keep updating the same object.	
	if self.myUpdatingPorts.getAtKey(portSorter.filePortCode, portSorter.fileCountryCode) = null then
		self.myUpdatingPorts.add(portSorter);
	else
		// We have a dupe so delete it.
		count := count + 1;
		
		delete portSorter;		
	endif;
	

epilog

end;</source>
        <Parameter name="array" type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="setupExistingPorts" id="26d0ab9f-2a31-4de7-885b-967d4a650b75">
        <source>setupExistingPorts();
// -------------------------------------------
// Created 05 April 2006 by cnwdvb1
// -------------------------------------------
vars

	port 	: CM_Port;
	sorter	: CMIF_PortSorter;
	dict	: CM_PortByCodeDict;
	sorterW	: CMIF_PortSorter;
	countryCode : String;
	
begin

	if self.isUpgradeProcess then
		dict := app.myRoot.allPorts;
	else
		dict := app.myRoot.allActiveDestinations;
	endif;
	
	self.myExistingPorts.purge();
	
	foreach port in dict discreteLock do
		create sorter transient;
		sorter.initialise(port);
		
		if port.myCountry &lt;&gt; null then
			countryCode := port.myCountry.code;
		else
			countryCode := null;
		endif;
		if self.myExistingPorts[port.portCode, countryCode] = null then
			self.myExistingPorts.add(sorter);
		else	//Par17504 Oct 2008
			app.raiseCMException2(ERR_PortDuplicateLoadCSV, port.myCountry.code, port.portCode, null, null);
		endif;
		
	endforeach;
	
	self.allUpdatedCountries.clear();


end;</source>
    </JadeMethod>
    <JadeMethod name="unLocodePortAndCountryChecker" id="37d919e5-47d3-49b6-a22d-e030e969face">
        <source>unLocodePortAndCountryChecker(_useFile : Boolean) : Boolean;

// Created by cnwdvb1 on 13 April 2006

vars

	port	: CM_Port;
	country	: CM_Country;
	file	: File;
	filePath: String;
	
begin


	if _useFile then
		app.msgBox('This process will log to a file all ports that do not have a country code. You will need to correct this data before the 7.4.2 upgrade', 
		'Port Codes', MsgBox_OK_Only + MsgBox_Information_Icon);
		
		filePath := app.getFilePath('c:\', '*.*', null, true);
		
		if filePath = null then
			return false;
		endif;
		
		create file transient;
		file.mode := File.Mode_Output;	// 25/2/16 cnwmp6 PAR 36286 unicode version
		file.fileName := filePath;
		file.open();
	endif;
		
	
	foreach port in app.myRoot.allPorts discreteLock do
		country := port.myCountry;
		if country = null then
			if _useFile then
				file.writeLine('Port code ' &amp; port.code &amp; ' does not have a country specified ' &amp; port.getOidString());
			else
				return false;
			endif;
		endif;
	endforeach;
	
	return true;


epilog

	if file &lt;&gt; null then
		file.close();
	endif;
	delete file;

end;</source>
        <Parameter name="_useFile" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateBOLs" id="6b6bcf5a-a439-4ac9-8bd8-d89d912fcf0d">
        <source>updateBOLs(_objArrayBOL : ObjectArray input) protected;

// Created by cnwdvb1 on 13 April 2006

vars

	obj			: Object;
	bol			: CM_BOL;
	count		: Integer;

begin


	beginTransaction;
	foreach obj in _objArrayBOL do
		bol := obj.CM_BOL;
		count := count + 1;
		// Get the destination
		self.findPortCodeInCurrentList(bol, CM_BOL::destinationPort.name);
		// Get the discharge port
		self.findPortCodeInCurrentList(bol, CM_BOL::dischargePort.name);
		// Get the load port
		self.findPortCodeInCurrentList(bol, CM_BOL::loadPortCode.name);
		if count mod 100 = 0 then
			commitTransaction;
			beginTransaction;
		endif;
		
	endforeach;
	commitTransaction;
end;</source>
        <access>protected</access>
        <Parameter name="_objArrayBOL" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateBookingRefs" id="674886fb-0fca-4741-97b0-474303ddb960">
        <source>updateBookingRefs(_objArrayBookingRefs : ObjectArray input) protected;

// Created by cnwdvb1 on 13 April 2006

vars

	objArrayTI	: ObjectArray;
	obj			: Object;
	port		: CM_Port;
	str,
	str2		: String;
	ref			: CM_BookingRef;
	count		: Integer;
	strArray	: StringArray;

begin

	create strArray transient;
	beginTransaction;
	foreach obj in _objArrayBookingRefs do
		ref := obj.CM_BookingRef;
		count := count + 1;
		// Get the destination
		self.findPortCodeInCurrentList(ref, CM_BookingRef::destinationPort.name);
		// Get the discharge port
		self.findPortCodeInCurrentList(ref, CM_BookingRef::dischargePort.name);
		// Get all discharge ports
		strArray.clear();
		foreach str in ref.allDischargePorts do
		
			if str = null or str.length &gt; 3 then
				continue;
			endif;
			
			port :=  self.mySortedPorts[str].CM_Port;
			if port = null then
				str2 := 'Could not find a port for ' &amp; ref.getOidString() &amp; ' discharge port ' &amp;  str;
				app.writeLog(str, LogINFO);
				app.writeStatement( str);
				continue;
			endif;
			strArray.add(port.code);
		endforeach;
		
		ref.allDischargePorts.clear();
		strArray.copy(ref.allDischargePorts);
	
		if count mod 100 = 0 then
			commitTransaction;
			beginTransaction;
		endif;
		
	endforeach;
	commitTransaction;
epilog
	delete strArray;
end;</source>
        <access>protected</access>
        <Parameter name="_objArrayBookingRefs" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateCountries" id="09dc728a-16a7-405b-b4b5-ce68fd155382">
        <source>updateCountries() : Boolean;
// -------------------------------------------
// Created 05 April 2006 by cnwdvb1
// -------------------------------------------
vars

	file		: File;
	str,
	str2,
	countryName,
	countryCode	: String;
	array		: HugeStringArray;
	filePath	: String;
	count		: Integer;
	pxyCountry,
	country		: CM_Country;	
	cmif		: CMIF_Country;
begin

	filePath := app.getFilePath('c:\', '*.csv', null, true);
	
	if filePath = null then
		return false;
	endif;
	
	create file transient;
	file.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	file.fileName := filePath;
	
	
	if not file.isAvailable then
		app.msgBox('Unable to locate file ' &amp; filePath, 'Open File', MsgBox_OK_Only +MsgBox_Information_Icon);
		return false;
	endif;
	
	file.open();

	create array transient;
	create cmif transient;

	while not file.endOfFile do
		count := count + 1;
		str := file.readLine();
		
		if str = null then
			continue;
		endif;
		
		str.parseCSV(array);
		
		if not array.size &gt; 2 then
			app.writeStatement( 'Array size was less than 3');
			continue;
		endif;
		
		str2 := array[1];
		if str2 = null then
			continue;
		endif;
		if str2.pos('Country Name', 1) &lt;&gt; 0 then
			// Header
			continue;
		endif;
		countryName := str2[1:25];
			
		str2 := array[2];
		if str2 = null then
			continue;
		endif;
		countryCode := str2[1:4];
		
		// Find the country in the database.
		country := app.myRoot.allCountries.getAtKey(countryCode);	
		
		// We have it so update it.
		if country &lt;&gt; null then
			pxyCountry := app.createUpdateProxy(country).CM_Country;
			pxyCountry.setProxy(countryCode, countryName, null, null, false, null);
			cmif.myProxyCountry := pxyCountry;
			cmif.allRealPorts.clear();
			country.ports.copy(cmif.allRealPorts);
			app.myTrxUA.trxUpdateCountry(cmif, app.myPassport);
			if not app.myPassport.trxCompletedOK then
				app.writeStatement( countryCode &amp; ' failed update');
			endif;
		else
			// Create a new one.
			create pxyCountry transient;
			pxyCountry.setProxy(countryCode, countryName, null, null, false, null);
			cmif.myProxyCountry := pxyCountry;
			cmif.allRealPorts.clear();
			app.myTrxCA.trxCreateCountry(cmif, country, app.myPassport);
			if not app.myPassport.trxCompletedOK then
				app.writeStatement( countryCode &amp; ' failed create');
			endif;
		endif;
		
	endwhile;
	return true;

epilog

	if file &lt;&gt; null and file.isOpen() then
		file.close();
	endif;
	delete file;
	delete cmif;
	delete array;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateForUnitTests" id="64a2bd1e-d53d-44d1-8a10-d8536cc6c67d">
        <source>updateForUnitTests(_filePath : String): Boolean;

/*

Purpose:		Load the ports up (copy of UpdateFromUNFile with file name passed in

Date			Who		Reason
02/03/2012		cnwmh5	Initial creation

*/

vars
	filePath,
	filter 		: String;
	file		: File;
	array		: HugeStringArray;
	str,str2,
	strInfo		: String;
	count,i		: Integer;
	cmif		: CMIF_Country;
	obj			: Object;
	notFound,
	stop : Boolean;
	
begin
	// Build transient structures.
	self.setupExistingPorts();
	
	filter := "Comma Separated Variable (*.csv)|*.csv|All Files (*.*)|*.*"; // AER 18/07/2008 Par13774
	filePath := _filePath;
	
	if filePath = null then
		return false;
	endif;
	
	create file transient;
	create cmif transient;
	file.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	file.fileName := filePath;
	
	if not file.isAvailable then
		app.msgBox('Unable to locate file ' &amp; filePath, 'Open File', MsgBox_OK_Only +MsgBox_Information_Icon);
		return false;
	endif;
	
	file.open();

	create array transient;
	stop := false;
	beginTransaction;
	while not file.endOfFile do
		count := count + 1;
	
		str := file.readLine();
		
		if str = null then
			continue;
		endif;
		
		str.parseCSV(array);

		// cnwjk3 par 13774 - 19/11/08 
		if array.size &lt; 7 then 
			strInfo := 'Too few fields';
			stop := true;
			break;
		endif;
		
		// cnwjk3 par 13774 - 19/11/08 
		if array[2].length &lt;&gt; 2 then  // country code must be 2 characters
			strInfo := 'Country code (' &amp; array[2] &amp; ') must be 2 characters long';
			stop := true;
			break;
		endif;
		
		// if the second field has a string of length 2 chars (country) then we 
		// assume we have a valid field
		
		// it is a country if the there is a forth field and it begins with a "."
		// it is a port if third field is 3 chars long
	
		if array[4] &lt;&gt; null and array[4][1] = "." then
			getCountry (array, cmif);
		endif;
		if array[3] &lt;&gt; null and array[3].length = 3 and array[4] &lt;&gt; null and array[7] &lt;&gt; null then
			getPort (array);
		endif;
		
//		There is potentially 45000 entries in the file (if you have the right one)
//		use this code if you need to debug
//		if count &gt; 100 then
//			break;
//		endif;

		if count mod 100 = 0 then
			commitTransaction;
			beginTransaction;
		endif;
	endwhile;
	
	commitTransaction;
	
	// cnwjk3 par 13774 - 19/11/08 
	if stop then
		write app.getErrorString(ERR_LineFormatInvalidFile) &amp; ": " &amp; filePath &amp; CrLf &amp; 
		   'Error on line ' &amp; count.String &amp; ':' &amp; CrLf &amp; '&gt;&gt;&gt;' &amp;  str &amp; '&lt;&lt;&lt;' &amp; CrLf &amp;
		   'Reason: ' &amp; strInfo;
		return false;
	endif;

	// Check to see how many of our current set aren't in the file.
	// This should only happen during the upgrade.
	foreach obj in self.myExistingPorts do
		if not obj.CMIF_PortSorter.isFound then
			notFound := true;
		endif;
	endforeach;

	// Update the database.
	app.myTrxUA.trxImportUNLocodeFile(self.myUpdatingPorts, app.myPassport);
	
	if not app.myPassport.trxCompletedOK then
		return false;
	endif;	
	
	return true;
	
epilog
	if file &lt;&gt; null and file.isOpen() then
		file.close();
	endif;
	delete file;
	delete cmif;
	delete array;
end;</source>
        <Parameter name="_filePath" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateFromUNFile" id="4ee68200-91e5-4641-9e7b-99417d0aff68">
        <source>updateFromUNFile(): Boolean;
//-----------------------------------------------------------------------
//	Created:	18 April 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------
// 29/03/2016	cnwdap1		PAR #35843 Make monitor time-based rather than object-based
vars
	filePath,
	filter 		: String;
	file		: File;
	array		: HugeStringArray;
	str,str2,
	strInfo		: String;
	cmifMonitor	: CMIF_Monitor;
	avRecLength,
	count,i		: Integer;
	cmif		: CMIF_Country;
	obj			: Object;
	notFound,
	stop : Boolean;
	lastUpdated	: Decimal [20];							// PAR #35843
	
begin
	// Build transient structures.
	self.setupExistingPorts();
	
	cmifMonitor	:= app.myPassport.myCMIFMonitor;
	filter := "Comma Separated Variable (*.csv)|*.csv|All Files (*.*)|*.*"; // AER 18/07/2008 Par13774
	filePath := app.getFilePath('c:\', filter, null, true);  //the filter was = '*.csv' 
	
	if filePath = null then
		return false;
	endif;
	
	create file transient;
	create cmif transient;
	file.fileName := filePath;
	file.kind := File.Kind_Unknown_Text;						// 01/07/2015 cnwmh5 - Handle Unicode
	
	
	if not file.isAvailable then
		app.msgBox('Unable to locate file ' &amp; filePath, 'Open File', MsgBox_OK_Only +MsgBox_Information_Icon);
		return false;
	endif;
	
	file.open();

	create array transient;
	cmifMonitor.partsInJob := file.fileLength;
	avRecLength := (cmifMonitor.partsInJob/74).Integer;
	stop := false;
	beginTransaction;
	while not file.endOfFile do
		count := count + 1;
	//	cmifMonitor.updateProgress ("Reading UN port/country codes", (file.fileLength/74).Integer, count);
	
		str := file.readLine();
		
		if str = null then
			continue;
		endif;
		
		str.parseCSV(array);

		// cnwjk3 par 13774 - 19/11/08 
		if array.size &lt; 7 then 
			strInfo := 'Too few fields';
			stop := true;
			break;
		endif;
		
		// cnwjk3 par 13774 - 19/11/08 
		if array[2].length &lt;&gt; 2 then  // country code must be 2 characters
			strInfo := 'Country code (' &amp; array[2] &amp; ') must be 2 characters long';
			stop := true;
			break;
		endif;
		
		// if the second field has a string of length 2 chars (country) then we 
		// assume we have a valid field
		
		// it is a country if the there is a forth field and it begins with a "."
		// it is a port if third field is 3 chars long
	
		if array[4] &lt;&gt; null and array[4][1] = "." then
			getCountry (array, cmif);
		endif;
		if array[3] &lt;&gt; null and array[3].length = 3 and array[4] &lt;&gt; null and array[7] &lt;&gt; null then
			getPort (array);
		endif;
		
//		There is potentially 45000 entries in the file (if you have the right one)
//		use this code if you need to debug
//		if count &gt; 100 then
//			break;
//		endif;

		//if count mod 100 = 0 then																	// PAR #35843
		if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
			commitTransaction;
			cmifMonitor.updateProgress ("Reading UN port/country codes", avRecLength, count);
			beginTransaction;
			lastUpdated := app.relativeMachineTime;													// PAR #35843
		endif;
	endwhile;
	
	commitTransaction;
	
	// cnwjk3 par 13774 - 19/11/08 
	if stop then
		app.msgBox(app.getErrorString(ERR_LineFormatInvalidFile) &amp; ": " &amp; filePath &amp; CrLf &amp; 
			       'Error on line ' &amp; count.String &amp; ':' &amp; CrLf &amp; '&gt;&gt;&gt;' &amp;  str &amp; '&lt;&lt;&lt;' &amp; CrLf &amp;
				   'Reason: ' &amp; strInfo,  
				   'Error loading file', MsgBox_OK_Only);
		return false;
	endif;

	// Check to see how many of our current set aren't in the file.
	// This should only happen during the upgrade.
	foreach obj in self.myExistingPorts do
		if not obj.CMIF_PortSorter.isFound then
//			str := obj.CMIF_PortSorter.portCode &amp; ' ' &amp; obj.CMIF_PortSorter.countryCode &amp; ' has not been found';
//			str2 := str2 &amp; str &amp; CrLf;

			notFound := true;
		endif;
	endforeach;
	
	// A few messages.
/*	if not self.isUpgradeProcess then
		if notFound then
			app.msgBox('A number of existing port codes have not been located in the UN Locode file. Please refer to log files', null, MsgBox_OK_Only +MsgBox_Information_Icon);
		endif;
		
		if app.msgBox('Do you wish to continue with the database update', 'Update Database', MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			return false;
		endif;
	endif;*/

	// Update the database.
	app.myTrxUA.trxImportUNLocodeFile(self.myUpdatingPorts, app.myPassport);
	
	if not app.myPassport.trxCompletedOK then
		return false;
	endif;	
	
	return true;
	
epilog
	if file &lt;&gt; null and file.isOpen() then
		file.close();
	endif;
	delete file;
	delete cmif;
	delete array;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateHMSVoyageData" id="17d9e6c0-bf06-4b52-8b51-15475185a9b7">
        <source>updateHMSVoyageData() protected;

vars
	objArray : ObjectArray;
	obj : Object;
	slotReq : HMS_VoyageData;
	count : Integer;
begin
	create objArray transient;
	HMS_VoyageData.allInstances(objArray, 0, false);
	beginTransaction;
	foreach obj in objArray do
		slotReq := obj.HMS_VoyageData;
		count := count + 1;
		self.findPortCodeInCurrentList(slotReq, HMS_VoyageData::portArrivingFromCode.name);
		self.findPortCodeInCurrentList(slotReq, HMS_VoyageData::portDepartingToCode.name);
		if count mod 1000 = 0 then
			commitTransaction;
			beginTransaction;
		endif;
	endforeach;
	commitTransaction;
epilog
	delete objArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateItemHistoryOld" id="82b33ea2-6e10-4391-b740-aa775b929eae">
        <source>updateItemHistoryOld() : Boolean;

// Created by cnwdvb1 on 07 April 2006

vars

	objArrayTI	: ObjectArray;
	obj			: Object;
	port		: CM_Port;
	str,
	str2,
	nextOid		: String;
//	lastOid		: String;
	isFound		: Boolean;
	ti			: CM_TrackedItem;
	count2,
	count		: Integer;
	strArray	: StringArray;
//	cmifMonitor	: CMIF_Monitor;

begin

	// THIS WILL BE RUN FROM THE 7.4.2 UPGRADE NOW.
	
	self.rootObj.allPorts.copy(self.mySortedPorts);
	
//	lastOid := app.myRoot.getConfig(PortCodeLastOid).String;
		
	create objArrayTI transient;
	create strArray transient;
	
	CM_TrackedItem.allInstances(objArrayTI, 0, true);
	
/*	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor &lt;&gt; null then
		cmifMonitor.partsInJob := objArray.size;
	endif;*/

	// Should only be one instance in the current set that has the three letter code for 
	// the first time. After that we can only get the first one so not a good idea to run
	// more than once. Will be keeping track of last oid but this might not be good enough.
	beginTransaction;
	foreach obj in objArrayTI do
	//	count2 := count2 + 1;
		nextOid := obj.getOidString();
		
	/*	if count2 mod 100 = 0 then
			if cmifMonitor &lt;&gt; null then
				cmifMonitor.partsDone := count2;
				cmifMonitor.updateProgress(null, cmifMonitor.partsInJob, cmifMonitor.partsDone);
				if cmifMonitor.monitorReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel then
					abortTransaction;
					return false;
				endif;
			endif;
		endif;*/
		
/*		if not isFound then
			if lastOid &lt;&gt; null and lastOid &lt;&gt; nextOid then
				continue;
			else
				isFound := true;
			endif;
		endif;*/
	
		ti := obj.CM_TrackedItem;
		count := count + 1;
		// Get the destination
		self.findPortCodeInCurrentList(ti, CM_TrackedItem::destinationPort.name);
		// Get the discharge port
		self.findPortCodeInCurrentList(ti, CM_TrackedItem::dischargePort.name);
		// Get the load port
		self.findPortCodeInCurrentList(ti, CM_TrackedItem::loadPort.name);
		// Get all discharge ports
		strArray.clear();
		foreach str in ti.allDischargePorts do
			port :=  self.mySortedPorts[str].CM_Port;
			if port = null then
				str2 := 'Could not find a port for ' &amp; ti.getOidString() &amp; ' discharge port ' &amp;  str;
				app.writeLog(str, LogINFO);
				app.writeStatement( str);
				continue;
			endif;
			strArray.add(port.code);
		endforeach;
		
		ti.allDischargePorts.clear();
		strArray.copy(ti.allDischargePorts);
	
		if count mod 100 = 0 then
		//	self.rootObj.setConfig(PortCodeLastOid, nextOid);
			commitTransaction;
			beginTransaction;
		endif;
		
	endforeach;
//	self.rootObj.setConfig(PortCodeLastOid, nextOid);
	commitTransaction;
	
	return true;

epilog
	delete strArray;
	delete objArrayTI;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updatePortDestinat" id="02dff041-ffc1-401e-889c-84045e6e1026">
        <source>updatePortDestinat() protected;

vars
	code : String;
	terminal : CM_Terminal;
	port : CM_Port;
begin
	foreach terminal in app.myRoot.allTerminals do
		code := terminal.getConfig(PortDestCode).String;
		if code.length &lt; 5 then
			port := self.mySortedPorts[code].CM_Port;
			if port &lt;&gt; null then
				beginTransaction;
				terminal.setConfig(PortDestCode, port.code);
				commitTransaction;
				app.writeLog("Terminal "&amp;terminal.code&amp;" Port Dest code changed from "&amp;code&amp;" to "&amp;port.code, 0);
			else
				app.writeLog("Terminal "&amp;terminal.code&amp;" Port Dest code not changed from "&amp;code, 0);
			endif;
		else
			app.writeLog("Terminal "&amp;terminal.code&amp;" Port Dest code not changed from "&amp;code, 0);
		endif;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updatePorts" id="8d07a9b1-e6d9-41a4-91d0-8907960435dd">
        <source>updatePorts() : Boolean;
// -------------------------------------------
// Created 05 April 2006 by cnwdvb1
// -------------------------------------------
vars

	file		: File;
	country,
	locode,
	str,
	str2,
	locodeDesc,
	locodeType	: String;
	array		: HugeStringArray;
	notFound,
	isPort		: Boolean;
	filePath	: String;
	count		: Integer;
	agent		: CM_LocodePortLoader;
	portSorter	: CMIF_PortSorter;
	obj			: Object;
	port		: CM_Port;
	iter		: Iterator;
	
begin

	// Build transient structures.
	self.setupExistingPorts();
	filePath := app.getFilePath('c:\', '*.csv', null, true);
	
	if filePath = null then
		return false;
	endif;
	
	create file transient;
	file.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	file.fileName := filePath;
	
	
	if not file.isAvailable then
		app.msgBox('Unable to locate file ' &amp; filePath, 'Open File', MsgBox_OK_Only +MsgBox_Information_Icon);
		return false;
	endif;
	
	file.open();

	create array transient;

// This was used for data fix
//	iter := self.myExistingPorts.createIterator();
	while not file.endOfFile do
		str := file.readLine();
		
		if str = null then
			continue;
		endif;
		
		str.parseCSV(array);
		
		if not array.size &gt; 5 then
			write 'Array size was less than 6';
			continue;
		endif;
		
		str2 := array[1];
		if str2 = null then
			app.writeLog('Locode null continuing', LogINFO);
			continue;
		endif;
		if str2 = "Locode" then
			// Header
			continue;
		endif;
		locode := str2[1:3];
	
		
		str2 := array[3];
		if str2 = null then
			app.writeLog('Country null continuing', LogINFO);
			continue;
		endif;
		country := str2[1:2];

		str2 := array[4];
		if str2 &lt;&gt; null then
			locodeDesc := str2[1:40];
		endif;
		
		str2 := array[6];
		if str2 &lt;&gt; null then
			locodeType := str2[1:30];
		endif;
			
		// Try and find this 3 letter code and 2 letter country in the database.
		// We are looking in the current set only.
		portSorter := self.myExistingPorts.getAtKey(locode, country).CMIF_PortSorter;
			
		// We have found one. Make sure we haven't updated it already as file as dupes.
		if portSorter &lt;&gt; null and not portSorter.isFound then
			// Update port with new information and change code. Add appropriate  current sets
			port := portSorter.myPort;
			portSorter.filePortCode				:= locode;
			portSorter.fileCodeDescription		:= locodeDesc;
			portSorter.fileCountryCode			:= country;
			portSorter.fileCodeType				:= locodeType;
			portSorter.isActive					:= true; // Just incase
			portSorter.isFound					:= true;
		else
			// Just try without country.
			// This was used for data fix
		/*	self.myExistingPorts.startKeyGeq(locode, null, iter);
			while iter.next(portSorter) do
				if portSorter.portCode = locode and portSorter.countryCode = null then
					if not portSorter.isFound then
						break;
					else
						continue;
					endif;
				else
					portSorter := null;
					break;
				endif;
			endwhile;
			
			// Try and find this code without a country code.
			portSorter := self.myExistingPorts.getAtKey(locode, null).CMIF_PortSorter;
			if portSorter &lt;&gt; null and not portSorter.isFound then
				// Update port with new information and change code. Add appropriate  current sets
				port := portSorter.myPort;
				portSorter.filePortCode				:= locode;
				portSorter.fileCodeDescription		:= locodeDesc;
				portSorter.fileCountryCode			:= country;
				portSorter.fileCodeType				:= locodeType;
				portSorter.isActive					:= true; // Just incase
				portSorter.isFound					:= true;
			else*/
		 	// This locode doesn't exist in the current set.
			create portSorter transient; 
			port := app.myRoot.allPorts.getAtKey(country[1:2] &amp; locode[1:3]);
			// Double check. Will be duplicate
			if port &lt;&gt; null and not port.isActive then
				portSorter.myPort := port;
			endif;
			portSorter.filePortCode				:= locode;
			portSorter.fileCodeDescription		:= locodeDesc;
			portSorter.fileCountryCode			:= country;
			portSorter.fileCodeType				:= locodeType;
			portSorter.isActive					:= false; // Just incase
		endif;
	
		// Check for duplicates.  We don't want to keep updating the same object.	
		if self.myUpdatingPorts.getAtKey(portSorter.filePortCode, portSorter.fileCountryCode) = null then
			self.myUpdatingPorts.add(portSorter);
		else
			// We have a dupe so delete it.
			count := count + 1;
			
			delete portSorter;		
		endif;
	endwhile;

	// Check to see how many of our current set aren't in the file.
	// This should only happen during the upgrade.
	foreach obj in self.myExistingPorts do
		if not obj.CMIF_PortSorter.isFound then
			str := obj.CMIF_PortSorter.portCode &amp; ' ' &amp; obj.CMIF_PortSorter.countryCode &amp; ' has not been found';
			str2 := str2 &amp; str &amp; CrLf;
			app.writeLog(str, LogINFO);
			app.writeStatement( str);
			notFound := true;
		endif;
	endforeach;
	
	app.writeStatement( count.String &amp; ' duplicates');
	
	// A few messages.
	if not self.isUpgradeProcess then
		if notFound then
			app.msgBox('A number of existing port codes have not been located in the UN Locode file. Please refer to log files', null, MsgBox_OK_Only +MsgBox_Information_Icon);
		endif;
		
		if app.msgBox('Do you wish to continue with the database update', 'Update Database', MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			return false;
		endif;
	endif;

	// Update the database.
	app.myTrxUA.trxImportUNLocodeFile(self.myUpdatingPorts, app.myPassport);
	
	if not app.myPassport.trxCompletedOK then
		return false;
	endif;	
	
	return true;
	
epilog

	if file &lt;&gt; null and file.isOpen() then
		file.close();
	endif;
	delete file;
	delete array;
	delete agent;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updatePortsForUpgrade" id="32e0d3c0-7beb-4e4e-85e9-46024a5b16c4">
        <updating/>
        <source>updatePortsForUpgrade() : Boolean updating;

// Created by cnwdvb1 on 13 April 2006

vars

	portCode,
	portCodeAltered,
	country		: String;
	countryRef	: CM_Country;
	port		: CM_Port;
	portSorter	: CMIF_PortSorter;
	obj			: Object;
	str,
	str2		: String;
	
begin

	// Build transient structures.
	self.isUpgradeProcess := true;
	self.setupExistingPorts();

	//foreach port in self.rootObj.allPorts do
	foreach obj in self.myExistingPorts do
		portSorter := obj.CMIF_PortSorter;
		
		port := portSorter.myPort;
		countryRef := port.myCountry;
		if countryRef = null then
			continue;
		endif;
		
		country := countryRef.code[1:2];
		// Try and find the code and 2 letter country in the database.
		// We are looking in the current set only.
		portCode := port.code;
//		portSorter := self.myExistingPorts.getAtKey(portCode, country).CMIF_PortSorter;
			
		// We have found one. 
		//if portSorter &lt;&gt; null and not portSorter.isFound then
		if not portSorter.isFound then
			// Update port with new information and change code. Add appropriate  current sets
			if portCode.length &gt; 3 then
				if portCode[1:2] = country then
					portCodeAltered := portCode[3:end];
				elseif portCode[4:2] = country then
					portCodeAltered := portCode[1:3];
				endif;
			else
				portCodeAltered := portCode;
			endif;
			port := portSorter.myPort;
			portSorter.filePortCode				:= portCodeAltered[1:3];
			portSorter.fileCodeDescription		:= port.description;
			portSorter.fileCountryCode			:= portSorter.countryCode;
			portSorter.fileCodeType				:= 1.String;
			portSorter.isActive					:= true; // Just incase
			portSorter.isFound					:= true;
			if self.myUpdatingPorts.getAtKey(portSorter.filePortCode, portSorter.fileCountryCode) = null then
				self.myUpdatingPorts.add(portSorter);
			endif;
		endif;
	endforeach;

	// Only ones that won't be updated are 5 code ports that we can't work out what they are.
/*	foreach obj in self.myExistingPorts do
		if not obj.CMIF_PortSorter.isFound then
			return false;
		endif;
	endforeach;*/
	
	// Update the database.
	app.myTrxUA.trxImportUNLocodeFile(self.myUpdatingPorts, app.myPassport);

	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateSlotRequests" id="0359e313-6d9b-4588-8091-4d1b528c140d">
        <source>updateSlotRequests() protected;

vars
	objArray : ObjectArray;
	obj : Object;
	slotReq : CM_SlotRequest;
	count : Integer;
begin
	create objArray transient;
	CM_SlotRequest.allInstances(objArray, 0, false);
	beginTransaction;
	foreach obj in objArray do
		slotReq := obj.CM_SlotRequest;
		if slotReq.dischargePort &lt;&gt; null then
			count := count + 1;
			self.findPortCodeInCurrentList(slotReq, CM_SlotRequest::dischargePort.name);
			if count mod 1000 = 0 then
				commitTransaction;
				beginTransaction;
			endif;
		endif;
	endforeach;
	commitTransaction;
epilog
	delete objArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
