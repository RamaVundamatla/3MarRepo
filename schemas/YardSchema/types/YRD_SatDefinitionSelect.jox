    <JadeMethod name="doRename" id="5146ccb9-869a-46b2-be34-470f13446448">
        <updating/>
        <source>doRename() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 November 2010	cnwer1	Initial creation

*/

vars
	form : YRD_SatDefinitionRename;
	newName : String;
	isSystem : Boolean;
	taView : CM_TerminalAreaView;
begin


	taView:=self.lstTAViews.listObject.CM_TerminalAreaView;
	if taView = null then
		return;
	endif;
	
	create form transient;
	form.initializeSelf(self.myTAViewInterface,taView);
	form.showModal;
	
	if form.modalResult = IDOK then
		self.loadTerminalViews();
	endif;
epilog
	delete form;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSecurity" id="e4b59ad4-59de-4dce-94c6-1de670dbf82f">
        <source>doSecurity();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 October 2011	cnwrd1	Initial creation
//cnwrd1 par 28498 20.10.2011
*/

vars
	user	: CM_User;
begin

	user := app.getMyUser();
	

	if user.canDo(self.myTerminal,PmAdmSatelliteViewDefnMaint) then // TFS 2198
		btnAdd.enabled := true;
		btnCopyTo.enabled := true;
		btnDelete.enabled := true;
		btnEdit.enabled := true;
		btnRename.enabled := true;		
	else
		btnAdd.enabled := false;
		btnCopyTo.enabled := false;
		btnDelete.enabled := false;
		btnEdit.enabled := false;
		btnRename.enabled := false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTerminalViews" id="3604bdfe-1794-41c0-8b6d-748440995e1b">
        <updating/>
        <source>loadTerminalViews() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16/11/2010	cnwer1	Initial creation
19/09/2011	cnwdap1	PAR #27814 set terminal view selection to current terminal view
10/07/2015	cnwma1  PAR #36594 14011 Error
*/

vars
	iter : Iterator;
	tav 	: CM_TerminalAreaView;
	idx 	: Integer;
	tavName : String;
	user 	: CM_User;
begin
	self.lstTAViews.clear;
	user:=app.myPassport.myUser;
	iter:=self.myTerminal.allTerminalAreaViews.createIterator;
	self.myTerminal.allTerminalAreaViews.startKeyGeq(null,null,iter);
	while iter.next(tav) do
		if tav.myUser &lt;&gt; null then
			break;
		endif;
		idx:=self.lstTAViews.addItem(tav.name);
		self.lstTAViews.itemObject[idx]:=tav;
	endwhile;
	
	self.myTerminal.allTerminalAreaViews.startKeyGeq(user,null,iter);
	while iter.next(tav) do
		if tav.myUser &lt;&gt; user then
			break;
		endif;
		tavName:=tav.name&amp; "(P)";
		idx:=self.lstTAViews.addItem(tavName);
		self.lstTAViews.itemObject[idx]:=tav;
	endwhile;
	
	// PAR #27814 start
	if self.myTAView &lt;&gt; null then
		self.lstTAViews.selectObject(self.myTAView);
	else
		// just select the first one
		if self.lstTAViews.listCount &gt; 0 then					// 10/07/2015 cnwma1 PAR #36594
			self.myTAView := self.lstTAViews.itemObject[1].CM_TerminalAreaView;
			self.lstTAViews.selectObject(self.myTAView);
		endif;
	endif;
	// PAR #27814 end
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstTAViews_click" id="52862aef-1733-4ea0-b9ce-5c9dd110884d">
