    <JadeMethod name="setControlsForAddEdit" id="be6e96bc-1b02-4911-b32f-ef782eb4447c">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

	theForm : SOP_TableMaintForm;
	iter : Iterator;
	mt : CM_MeasurementType;
	index : Integer;

begin
  
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := false;
	
	theForm.cmbGrams.clear;
	theForm.cmbKilos.clear;
	theForm.cmbOunces.clear;
	theForm.cmbPounds.clear;
	theForm.cmbTons.clear;
	
	iter := app.myRoot.allMeasurementTypesByShortName.createIterator;
	while iter.next( mt ) do
		if mt.measurementType &lt;&gt; Type_Weight then
			continue;
		endif;
		theForm.cmbGrams.itemObject[ theForm.cmbGrams.addItem( mt.name ) ] := mt;
		theForm.cmbKilos.itemObject[ theForm.cmbKilos.addItem( mt.name ) ] := mt;
		theForm.cmbOunces.itemObject[ theForm.cmbOunces.addItem( mt.name ) ] := mt;
		theForm.cmbPounds.itemObject[ theForm.cmbPounds.addItem( mt.name ) ] := mt;
		theForm.cmbTons.itemObject[ theForm.cmbTons.addItem( mt.name ) ] := mt;
		if not mt.isAvailableForEntry then
			index := theForm.cmbGrams.findObject(mt);
			theForm.cmbGrams.itemEnabled[index] := false;
			theForm.cmbKilos.itemEnabled[index] := false;
			theForm.cmbOunces.itemEnabled[index] := false;
			theForm.cmbPounds.itemEnabled[index] := false;
			theForm.cmbTons.itemEnabled[index] := false;
		endif;
	endwhile;
			
	if theForm.mode = theForm.Mode_Add then
	
		self.setTypeWeightConvRows( null );	//05 Jul 2019	NDl	TFS 44965
		self.setupValidCodes( theForm.cmbScaleTypes );	//05 Jul 2019	NDL	TFS 44965
		
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.moveFirst();
		// call this last as sets cell input type (case etc)
		// if not called can get problems with case on entry. 
		theForm.tblInput1.gotFocus(theForm.tblInput1);
		
		
	else

		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_WeighBridgeObjType);
		// cannot update code		
		theForm.tblInput1.disableRowByName(ETRow_Code);
		
	endif;
	
epilog

	delete iter;
	
end;</source>
    </JadeMethod>
