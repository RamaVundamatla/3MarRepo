        <source>showAssignCargo(_wle : CM_WorkListEntry) : CM_TrackedItem;
/*

Date		Who		Reason
15 May 2014	cnwer1	Initial creation PAR

*/

vars
	tmpForm : CMUI_AssignCargo;
begin
	tmpForm := app.loadForm(CMUI_AssignCargo, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_AssignCargo;
	
	if tmpForm = null then
