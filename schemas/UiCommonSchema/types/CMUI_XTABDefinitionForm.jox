vars
	
begin
	self.txtName.readOnly			:= not _enabled;
	self.txtDescription.readOnly	:= not _enabled;
	self.chkTotalColumn.enabled		:= _enabled;
	self.txtTotColHeading.readOnly	:= not _enabled;
	self.chkTotalRow.enabled		:= _enabled;
	self.txtTotRowHeading.readOnly	:= not _enabled;
	self.txtCaption.readOnly		:= not _enabled;
	self.cmbOrder.enabled			:= _enabled;
	self.chkSubTotals.enabled		:= _enabled;
	self.txtSubTotHeading.readOnly	:= not _enabled;
	self.chkSummary.enabled			:= _enabled;
	self.txtCaption_Cell.readOnly	:= not _enabled;
	self.cmbFunction.enabled		:= _enabled;
	self.txtDecimals.enabled		:= _enabled;
	self.chkSeperator.enabled		:= _enabled;
	self.chkHideDetails.enabled		:= _enabled;
	self.chkHideSubTotal.enabled	:= _enabled;
	self.chkHideGrandTot.enabled	:= _enabled;
	self.txtSummHeading.enabled		:= _enabled;
	
epilog
	
end;</source>
