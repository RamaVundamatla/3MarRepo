    <JadeMethod name="generateSequenceNums" id="d39bcf59-b953-43ee-941c-07305fcbb4bf">
        <updating/>
        <source>generateSequenceNums(_onDeck: Boolean; _origin: Integer; _propToUpdate: String; _is40 : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	cellStart, cellEnd, cellDirn : Integer;
	tierStart, tierEnd, tierDirn : Integer;
	cellIndex,  tierIndex : Integer;
	numCells, numTiers : Integer;
	sequenceOrdinal : Integer;
	ordinalDeck : Integer;
	useCellTier : Boolean;
	slotDefnVesse:CM_SlotDefnVessel;
	slotDefn : CM_SlotDefn;
begin
	
	exclusiveLock(self);
	//-------------------------------------------
	// Get the right set of instvar names to use
	//-------------------------------------------
	if _onDeck then //ON Deck
		numCells := self.allCellsOnDeck.size;
		numTiers := self.allTiersOnDeck.size;
		ordinalDeck :=  DeckOnDeck;
		if _is40 then
			useCellTier := self.useCellTierODSequencing40;
		else
			useCellTier := self.useCellTierODSequencing;
		endif;
	else
		numCells := self.allCellsUnderDeck.size;
		numTiers := self.allTiersUnderDeck.size;
		ordinalDeck :=  DeckUnderDeck;
		if _is40 then
			useCellTier := self.useCellTierUDSequencing40;
		else
			useCellTier := self.useCellTierUDSequencing;
		endif;
	endif;
	//--------------------------------------------------------------
	// Iterate through all the slot defn objects in an appropriate
	// dirns for the type of sequence number series
	//--------------------------------------------------------------
	if _origin = Start_Bottom_Left then
		cellStart := 1; // was 0;
		cellEnd := numCells;
		cellDirn := 1;
		tierStart := 1; // was 0;
		tierEnd := numTiers;
		tierDirn := 1;
      
	elseif _origin = Start_Bottom_Right then
		cellStart := numCells; //was numCells - 1;
		cellEnd := 1; //was -1;
		cellDirn := -1;
		tierStart := 1; //was 0;
		tierEnd := numTiers;
		tierDirn := 1;

	elseif _origin = Start_Top_Left then
		cellStart := 1; // was 0;
		cellEnd := numCells;
		cellDirn := 1;
		
		tierStart := numTiers; // was numTiers - 1;
		tierEnd := 1; // was -1;
		tierDirn := -1;
		
	elseif _origin = Start_Top_Right then
		cellStart := numCells; // was numCells - 1;
		cellEnd := 1; // was -1;
		cellDirn := -1;
		tierStart := numTiers; // was numTiers - 1;
		tierEnd := 1; // was -1;
		tierDirn := -1;
	else
		app.raiseCMException(ERR_INVALID_INDEX, null, null);
		return;
	endif;
	sequenceOrdinal := 1;
	if useCellTier then
		//Cell tier slot
		foreach cellIndex in cellStart to cellEnd  step cellDirn do
			foreach tierIndex in tierStart to  tierEnd step tierDirn do
				//---------------
				// Retrieve Slot
				//--------------
				slotDefn := self.allSlotsByOrdinal[ ordinalDeck, cellIndex, tierIndex];
				if slotDefn = null then
					continue;
				endif;
				
				exclusiveLock(slotDefn);
				// CCMS 1367 Need seqential numbers which cover unavailable slots too
			//	if slotDefn.unavailable then
			//		slotDefn.setPropertyValue(_propToUpdate, -1);
			//		continue; //Go onto the next
			//	endif;
				slotDefn.setPropertyValue(_propToUpdate, sequenceOrdinal);
				sequenceOrdinal := sequenceOrdinal + 1;
			endforeach;
		endforeach;
	else
		//Tier Cell slot
		foreach tierIndex in tierStart to tierEnd step tierDirn do
		      foreach cellIndex in cellStart to cellEnd step cellDirn do
				//---------------
				// Retreive Slot
				//--------------
				slotDefn := self.allSlotsByOrdinal[ordinalDeck, cellIndex, tierIndex];
				if slotDefn = null then
					continue;	//Go onto the next
				endif;
				exclusiveLock(slotDefn);
				// CCMS 1367 Need seqential numbers which cover unavailable slots too
			//	if slotDefn.unavailable then
			//		slotDefn.setPropertyValue(_propToUpdate, -1);
			//		continue; //Go onto the next
			//	endif;
				slotDefn.setPropertyValue(_propToUpdate, sequenceOrdinal);
				sequenceOrdinal := sequenceOrdinal + 1;
			endforeach;
		endforeach;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_onDeck" type="Boolean"/>
        <Parameter name="_origin" type="Integer"/>
        <Parameter name="_propToUpdate" type="String"/>
        <Parameter name="_is40" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllCellsHiCubeHeightsString" id="f7299270-7ec9-4f0f-81ab-15ba5da3054b">
        <source>getAllCellsHiCubeHeightsString() : String;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theHiCubeHeights : String;
	theCellDefn :	CM_CellDefn;
begin

	foreach theCellDefn in self.allCellsUnderDeckByOrdinal do
		theHiCubeHeights := theHiCubeHeights &amp; " " &amp; theCellDefn.maxNumHighCubesIfFull.String;
	endforeach;

	return theHiCubeHeights.trimBlanks;
end;</source>
