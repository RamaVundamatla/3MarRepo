    <JadeMethod name="isMinimumChargeByGroup" id="663a253e-48af-4eee-8fa0-e2f375b0bbc6">
        <source>isMinimumChargeByGroup(): Boolean;

/*

Purpose:			
	
Parameters:			

Return Value:		


Date		Who		Reason
06 Nov 2019	Bug 46674: JMT - Form - Minimum charges does not calculate minimum charges when grouping invoice lines

*/

vars
	invLineDesc : CM_InvoiceLineDesc;
	grp			: CM_InvoiceLineDescGroup;
	bank        : CM_Bank;
begin
	bank := self.getBank();
	
	if self.myProformaDetail &lt;&gt; null then
		invLineDesc := self.myProformaDetail.myInvoiceLineType;
	elseif self.myInvoiceLine &lt;&gt; null then
		invLineDesc := self.myInvoiceLine.invoiceLineDesc;
	endif;
	
	if invLineDesc &lt;&gt; null  then
		foreach grp in bank.invLineDescGroups discreteLock do 
			if grp.myMinimumChargeInvoiceLineType &lt;&gt; null then
				if invLineDesc = grp.myMinimumChargeInvoiceLineType then
					return true;
				endif;
			endif;
		endforeach;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isNotPaidByAPI" id="bb0146e1-5e91-4b28-9bfc-bfd5522da927">
        <source>isNotPaidByAPI() : Boolean;
/*
Purpose:	

Date		Who		Reason
07 January 2025	navab1	JIRA 33765
*/

vars

begin
	if self.myCashReceipt = null then
		return false;
	endif;
	
	if self.isTaxPayment() then // tax payments ignore
		return false;
	endif;
	
	return self.myCashReceipt.isNotPaidByAPI();
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPaid" id="217ca5db-097f-4b6e-8a0f-06cffded7522">
        <source>isPaid():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Sep 2020	jlgma1	Bug 50011: SSL - Cash Module -&gt; Proforma Invoice Issue

*/

vars
	cashRec : CM_CashReceipt;
	realPay : CM_CashPayment;
begin
	
	if self.pxyIsProxy  then
		realPay := self.pxyGetRealObject().CM_CashPayment;
		if realPay &lt;&gt; null then
			return true;
		endif;
	elseif not self.isTransient then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
