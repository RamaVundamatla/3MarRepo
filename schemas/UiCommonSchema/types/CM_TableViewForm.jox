    <JadeMethod name="showThumbnailData" id="1cdfd576-df6f-40bc-bb56-417a91c5c0f5">
        <updating/>
        <source>showThumbnailData(obj : Object) updating;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     Display the data in the thumbnail table.  This should be reimplemented.
//				Refer to the sample code below.
//
// Parameters:  The object to be displayed in the thumbnail.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	tblThumb.rows := 0;
	if app.isDevelopmentSystem then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  WARNING - you need to reimplement this method in your own form.');

		tblThumb.addItem('Developer needs to reimplement ' &amp; method.name &amp; ' at the form level');
	endif;


/* 
Sample code for reimplementation:

	br := obj.CM_BulkRelease;
	
	tblThumb.rows := 0;
	
	tblThumb.addItem('Release No' &amp; Tab &amp; br.code);
	tblThumb.addItem('Operator' &amp; Tab &amp; br.supplier);
	tblThumb.addItem('');			// adds a blank row
	tblThumb.addItem('Date' &amp; Tab &amp; br.releaseDate.String);

*/
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailForDef" id="d0227821-2f52-4800-85cb-ad2c5d580b6a">
        <source>showThumbnailForDef(pDefName : String; _obj : CM_Object);
// ---------------------------------------------------------------------------
// Created:     05 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableDef	: EntTableDef;
	tmpHeadings	: StringArray;
	tmpData		: HugeStringArray;
	str,
	dataStr		: String;
	count,
	i, rowIdx,
	dataSize,
	rowHeight	: Integer;
	entRow 		: EntTableRow;
begin
	entTableDef := app.myController.getEntTableDef(pDefName);
	if entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef (' &amp; pDefName &amp; ') not found');
		return;
	endif;

	create tmpHeadings transient;
	create tmpData transient;

	_obj.getDataForDef(entTableDef, tmpHeadings, tmpData, self.myTerminal);

	dataSize := tmpData.size;
	foreach str in tmpHeadings do
		i := i + 1;
		if i &gt; dataSize then
			break;
		endif;
		dataStr := tmpData[i];
		//epr 9/4/14 menu option to hide empty rows
		if not self.includeThumbnailEmptyRow(dataStr,entTableDef,str) then
			continue;
		endif;
			
		
		rowIdx := tblThumb.addItem(str &amp; Tab &amp; dataStr);
		tblThumb.formatRow(rowIdx);  // PAR 19910
	endforeach;
	
//	tblThumb.optimiseHeadingColumn();

epilog
	delete tmpHeadings;
	delete tmpData;	
end;</source>
        <Parameter name="pDefName" type="String"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailForDefWithView" id="2f5784ea-21ae-4c06-b7c2-c3013e4090ce">
        <source>showThumbnailForDefWithView(pDefName, pViewName : String; _obj : CM_Object);
/*
	Created on 31 January 2008 by Debby Hutchison
*/

vars
	entTableDef	: EntTableDef;
	entTableView: EntTableView;
	entTableRow	: EntTableRow;
	tmpHeadings	: StringArray;
	tmpData		: HugeStringArray;
	str,
	dataStr, oidStr		: String;
	count,
	i, rowIdx,
	dataSize,
	rowHeight	: Integer;
	showRow 		: Boolean;
	ti : CM_TrackedItem;
	cmobject : CM_Object;
	isTI : Boolean;
begin
	entTableDef := app.myController.getEntTableDef(pDefName);

	if entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef (' &amp; pDefName &amp; ') not found');
		return;
	endif;
	
	if pViewName &lt;&gt; null then
		entTableView := entTableDef.allEntTableViews[pViewName];
	endif;

	create tmpHeadings transient;
	create tmpData transient;
	
	_obj.getDataForETView(entTableDef, entTableView, tmpHeadings, tmpData, self.myTerminal);

	dataSize := tmpData.size;

	foreach str in tmpHeadings do
		i := i + 1;
		if i &gt; dataSize then
			break;
		endif;
		dataStr := tmpData[i];
		oidStr := tmpData[i]; // TFS 4052
		// TFS 4052 - when you have many TIs with the same ID the double click in the thumbnail was always showing the same TI.
		
		dataStr := _obj.getTableViewThumbnailData(dataStr,pDefName); // TFS 4052
		
			//epr 9/4/14 menu option to hide empty rows
		if not self.includeThumbnailEmptyRow(dataStr,entTableDef,str) then
			continue;
		endif;
		
		rowIdx := tblThumb.addItem(str &amp; Tab &amp; dataStr);
		//expand row if text has carriage returns
		count := dataStr.countOccurrences(Cr);
		tblThumb.accessRow(rowIdx);
		if count &gt; 0 then
			rowHeight := tblThumb.accessRow(rowIdx).height;
			tblThumb.accessedRow.height := rowHeight * (count+1);
		endif;

		tblThumb.accessRow(rowIdx);
		
		tblThumb.accessedRow.itemObject := _obj.getTableViewThumbnailOid(oidStr, pDefName); // TFS 4052

	endforeach;
	
//	tblThumb.optimiseHeadingColumn();

epilog
	delete tmpHeadings;
	delete tmpData;	
end;</source>
        <Parameter name="pDefName" type="String"/>
        <Parameter name="pViewName" type="String"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="showWithObject" id="6309a94f-1e79-43a5-9a6f-6d687b1b2b59">
        <updating/>
        <source>showWithObject(_object : CM_Object; _thumbnailOnly, _doEdit : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     19 October 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.amInitialisingWithObject 	:= true;
	self.myCurrentObject 			:= _object;
	//epr TFS 2236 12/7/16
	self.setInitialisingInEditMode( _doEdit);
	
	self.useTblData					:= (not _thumbnailOnly);
	self.useThumbArea				:= true;
	self.isThumbnailVisible			:= true;

	if _object &lt;&gt; null and app.isValidObject(_object) and (not _object.isTransient) then	
		self.armNotesForObject(_object);
	endif;
	
	self.show();
end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_thumbnailOnly" type="Boolean"/>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
