    <JadeMethod name="getAllCheckScaleReports" id="3eb4ab50-b791-4f6d-b46b-281f09fde571">
        <updating/>
        <source>getAllCheckScaleReports() protected, updating;
/*

Date		Who		Reason
01 June 2016	cnwer1	Initial creation TFS 2011 performance inprovements

*/

vars
	menuItem			: CM_MenuItem;
	menuDict			: CM_MenuItemByTypeMenuIdDict;
	report 				: JadeReportWriterReport;
	reportManager		: JadeReportWriterManager;
	viewName			: String;	
begin
	if self.checkScaleRepInitialised then
		return;
	endif;
	
	reportManager := app.createReportWriterManager();
	
	menuDict := app.myRoot.myReportMenuRoot.allMenuItems;
	
	foreach menuItem in menuDict do
		if not menuItem.isKindOf(CM_QryReport) then
			continue;
		endif;

		report := reportManager.getReport(menuItem.CM_QryReport.jrwReportName[1]);
		if report = null then
			continue;
		endif;
		
		viewName := report.getReportingViewName();
		
		if viewName = CM_LogCheckScaleView then
			self.myForm.cmbChkRep1.addItemObject(menuItem.CM_QryReport.reportName,menuItem);
			self.myForm.cmbChkRep2.addItemObject(menuItem.CM_QryReport.reportName,menuItem);
		endif;
		
		delete report;
	endforeach;
	
	self.checkScaleRepInitialised:=true;
	
epilog
	delete reportManager;
	delete report;

end;</source>
        <access>protected</access>
    </JadeMethod>
