    <JadeMethod name="setupForm" id="b2ed8cb2-0455-454a-b67d-433e41bd6dcd">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     14 September 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	self.doCmbBankBuild;
	self.myCurrentBank := self.myTerminal.getDefaultCompanyBank();			// 35872
//	TFS 2682	self.caption := self.caption &amp; " " &amp;  self.myCurrentBank.code;
	self.setCaption("Tax Code Maintenance " &amp; self.myCurrentBank.code);
	
	
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled:= false;
		self.btnNew.enabled:= false;
		self.btnEdit.enabled:= false;
		self.mnuAddTaxCode.visible := false;
		self.mnuAddTaxRate.visible := false;
		self.mnuDelete.visible := false;
		self.mnuUpdate.visible := false;
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showPropertyFrameForObject" id="9c4e357b-46ca-40da-b919-a2641e531881">
        <updating/>
        <source>showPropertyFrameForObject(_taxObj : CM_Object; _grpBox : CMUI_GroupBox) updating, protected;
//------------------------------------------------
// Created: 17 May 2006 By: cnwgd1
//------------------------------------------------
//
//------------------------------------------------
// 13/10/2009	cnwmh5		PAR 21243	Turn off fromToolBar
// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 29/3/22  jlier1	TFS 53286
//------------------------------------------------
vars
	theFrame : Frame;
	tmpGrpBox : CMUI_GroupBox;
	localTS : TimeStamp;
begin

	self.fldProperties.visible := false;
	self.txtTaxCode.text := null;
	self.txtTaxDescr.text := null;
	self.txtTaxRate.text := null;
	self.effectiveDate.setDate(null);
	self.effectiveTime.setTime(null);
	self.grpTaxCode.visible := false;
	self.grpTaxRate.visible := false;
	self.ckbNotAvailable.value := false;
	self.lblTaxRateCode.caption := null;
	self.txtExtRef1.text:=null;
	
	if self.updateMode = self.UpdateMode_Update then
		if CM_TaxCode.hasInstance(_taxObj) then
			tmpGrpBox := self.grpTaxCode;
			self.myCurrentTaxCode := _taxObj.CM_TaxCode;
			self.txtTaxCode.text := self.myCurrentTaxCode.code;
			self.txtTaxDescr.text := self.myCurrentTaxCode.description;
			self.ckbNotAvailable.value := self.myCurrentTaxCode.notAvailableForEntry;
			self.cmbGLCode.listObject := _taxObj.CM_TaxCode.myGLCode;
			self.txtExtRef1.text:=_taxObj.CM_TaxCode.externalReference1;
			
		elseif CM_TaxRate.hasInstance(_taxObj) then
			tmpGrpBox := self.grpTaxRate;
			self.myCurrentTaxRate := _taxObj.CM_TaxRate;
			self.myCurrentTaxCode := self.myCurrentTaxRate.myTaxCode;
			self.txtTaxRate.text := self.myCurrentTaxRate.rate.String;
			localTS := self.systemToLocalTime(self.myCurrentTaxRate.effectiveDT);	// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			self.effectiveDate.setDate(localTS.date);								// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			self.effectiveTime.setTime(localTS.time);								// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			self.lblTaxRateCode.caption := 'Tax Code: ' &amp; self.myCurrentTaxCode.getDisplayDetails(false);
			
		else	
			self.updateMode := null;
			app.msgBox('Please select an item from the list to update.', app.getErrorString(SelectItem), MsgBox_OK_Only+MsgBox_Information_Icon);
			fromToolbar := false;							// 13/10/2009 mhill #21243
			return;					
		endif;				
	elseif _grpBox &lt;&gt; null then
		tmpGrpBox := _grpBox;
	elseif self.lstData.listIndex &lt; 1 then
		tmpGrpBox := self.grpTaxCode;
	elseif self.lstData.itemLevel[self.lstData.listIndex] &lt; 3 then
		tmpGrpBox := self.grpTaxCode;
	elseif self.lstData.itemLevel[self.lstData.listIndex] = 3 then
		tmpGrpBox := self.grpTaxRate;		
	else
		self.updateMode := null;	
		app.msgBox('Please select an item from the list.', app.getErrorString(SelectItem), MsgBox_OK_Only+MsgBox_Information_Icon);	
		fromToolbar := false;							// 13/10/2009 mhill #21243
		return;	// nothing selected		
	endif;
	
	if self.updateMode = self.UpdateMode_New
	and tmpGrpBox = self.grpTaxRate then
		if self.myCurrentTaxCode = null then
			app.msgBox('Please select a Tax Code from the list to add the new rate to.', app.getErrorString(SelectItem), MsgBox_OK_Only+MsgBox_Information_Icon);				
			return;
		endif;
		localTS := self.systemToLocalTime(app.actualTimeServer);	// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.effectiveDate.setDate(localTS.date);					// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.effectiveTime.setTime(localTS.time);					// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.lblTaxRateCode.caption := 'Tax Code: ' &amp; self.myCurrentTaxCode.getDisplayDetails(false);				
	endif;	
	
	tmpGrpBox.visible := true;
	tmpGrpBox.centreHorizontallyInParent();
	tmpGrpBox.top := self.frmPropToolbar.height;

	theFrame := self.frmProperties;
	theFrame.height := (tmpGrpBox.height + self.frmPropToolbar.height + 20).Integer;	
	theFrame.zOrder(1);
	theFrame.centreWindow();
	theFrame.visible := true;
	tmpGrpBox.setFocus();
	
	self.setEnableObjects(false);

end;</source>
        <access>protected</access>
        <Parameter name="_taxObj" type="CM_Object"/>
        <Parameter name="_grpBox" type="CMUI_GroupBox"/>
    </JadeMethod>
    <JadeMethod name="showSearchFrame" id="d825a4c5-92ac-46c0-a4e9-04bea96b52cf">
        <updating/>
        <source>showSearchFrame() updating;
// 35872 search frame shows business unit
vars

begin
	self.lblBank.visible := true;
	self.cmbBank.visible := true;
	self.lblSearch.visible := false;
	self.txtSearch.visible := false;
	
	inheritMethod();
	
	self.lblBank.top := self.frmSeachToolbar.height; // ### TFS 50421 17SEP2021 NAVAB1
	self.cmbBank.top := self.lblBank.top + self.lblBank.height; // ### TFS 50421 17SEP2021 NAVAB1
	self.lblSearch.top := self.cmbBank.top  + self.lblBank.height; // ### TFS 50421 17SEP2021 NAVAB1
	self.txtBank.visible := false; // ### TFS 50421 17SEP2021 NAVAB1

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="caf78955-6066-4d82-a982-420ca0dc9a28">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 14 April 2022 08:39:46.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006228, locale);
	btnDelete.translateCaption(Xlat_0002255, locale);
	btnEdit.translateCaption(Xlat_0002256, locale);
	btnNew.translateCaption(Xlat_0002257, locale);
	ckbNotAvailable.translateCaption(Xlat_0002252, locale);
	lblExtRef1.translateCaption(Xlat_0024640, locale);
	lblRate.translateCaption(Xlat_0002258, locale);
	lblRateDT.translateCaption(Xlat_0002259, locale);
	lblTaxCode.translateCaption(Xlat_0002260, locale);
	lblTaxCode_1.translateCaption(Xlat_0002253, locale);
	lblTaxDescr.translateCaption(Xlat_0002254, locale);
	mnuAddTaxCode.translateCaption(Xlat_0006229, locale);
	mnuAddTaxRate.translateCaption(Xlat_0006230, locale);
	mnuAudits.translateCaption(Xlat_0006231, locale);
	mnuDelete.translateCaption(Xlat_0006232, locale);
	mnuListContext.translateCaption(Xlat_0006233, locale);
	mnuUpdate.translateCaption(Xlat_0006234, locale);
end;</source>
    </JadeMethod>
</GUIClass>
