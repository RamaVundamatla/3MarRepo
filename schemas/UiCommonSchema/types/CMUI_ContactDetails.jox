    <JadeMethod name="translateForm" id="b42dbc6e-359a-4e86-b745-9be04a9a78c6">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 February 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019397, locale);
	lblAdd1.translateCaption(Xlat_0019398, locale);
	lblAdd2.translateCaption(Xlat_0019399, locale);
	lblAdd3.translateCaption(Xlat_0019400, locale);
	lblCountry.translateCaption(Xlat_0019401, locale);
	lblPost.translateCaption(Xlat_0019402, locale);
	lblRegion.translateCaption(Xlat_0019403, locale);
end;</source>
    </JadeMethod>
