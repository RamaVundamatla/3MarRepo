    <JadeMethod name="setRFIDListener" id="6d48fa2c-a7cb-4d36-872a-9c3b5c535397">
        <source>setRFIDListener(_cmif : CMIF_BGPManagerChildren input) : Boolean protected;
/*
----------   ----------  --------------------------------------------------
Created:	31 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	object	: Object;

begin
	_cmif.allRFIDTagReaders.clear();
	_cmif.myTerminal := self.fieldTerminal.getObject().CM_Terminal;
	// Par 14587
	foreach object in self.lstTagReaders.allSelectedObjects where global.isValidObject(object) do
		_cmif.allRFIDTagReaders.add(object.CM_RFIDTagReader);
	endforeach;
	
	return true;
end;
</source>
