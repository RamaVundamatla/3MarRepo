    <JadeMethod name="doBaseFormSave" id="f5d02948-48f8-4135-a17e-f4d9c8672930">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// ---------------------------------------------------------------------------
// Created:		05 April 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	controller : CMIF_JobPriorityController;
	theReturn : Integer;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	inheritMethod();

	create controller transient;
	self.populateControllerForSave(controller);

	while true do
		app.myTrxCA.trxCreateVoyageJobPriority(controller, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(JOBPriorities), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings); // PAR 34655
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
	self.doRefresh();//cnwyl1  for PAR12216
	

epilog
	self.caption :=app.getErrorString(JOBPriorities) &amp; " " &amp; self.priorityObject.getNiceName() &amp; " " &amp; self.myController.tempLabel;
	controller.allJobPriorities.purge;
	delete controller;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <access>protected</access>
    </JadeMethod>
