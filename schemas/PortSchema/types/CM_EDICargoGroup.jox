    <JadeMethod name="assignValueSpecial" id="aa16b073-3528-43f4-81b4-de35174c12b9">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2016	cnwndl1	Initial creation	Par 37544

*/

vars

begin

	if _propName = ETRow_Action then
		self.messageMode := _processedValue;
		return true;
	endif;
	
	return inheritMethod(_propName, _processedValue, _xlationOperator);

epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
