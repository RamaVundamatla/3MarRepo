/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
17 March 2014	cnwndl1	Initial creation	Par 33268
20 June 2022	navpw1	TFS 52773 - Added isValidObject check to ensure that the object exists to protect against error code 4, whereby the object reference no longer exists
14 July 2022	navmd1	TFS 52777 And then changed it to just use the existing handler
*/

vars
	ld			: CM_LDWeighBridge;
	invalidObj	: Boolean;
	
begin
	ld := self.getLaneDevice_WeighBridge();
	on Exception do app.handleDeletedObject(exception, ld, invalidObj);
	
	if ld &lt;&gt; null then
		ld.edition;
		if not invalidObj then
			return ld.myWeighBridge;
		endif;
	endif;
	
	return null;
	
end;</source>
        <ReturnType type="CM_WeighBridgeObj"/>
    </JadeMethod>
    <JadeMethod name="getWeighBridgeName" id="47cb3566-11f7-4d11-b25d-d7a41dfe95ab">
