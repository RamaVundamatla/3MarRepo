<GUIClass name="CM_ColourLegendTable" id="e9aa1498-6531-44f2-9a66-2c7d438700d8">
    <superclass name="CM_ViewTable"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="myCaller" id="9ded1c3a-fa64-4fc2-9221-23f0fba6378d">
        <embedded/>
        <type name="Control"/>
    </ImplicitInverseRef>
    <JadeMethod name="click" id="e37d4ba2-0f3e-4146-9c3b-86a8c9f0a52c">
        <updating/>
        <source>click(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	if table = null or table.rows = 0 then //PAR17125 cnwgb1
		return;
	endif;
	inheritMethod(table);
	if table.row &lt;= table.fixedRows then
		table.clearAllSelected();
	endif;
	self.myCaller.sendMsgWithParams("doTableClick",table);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="contextMenu" id="55dad5ae-b962-4735-9450-ecaae39452ae">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating, clientExecution;
//----------------------------------------------------------------
//	Created:	19 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	retVal		: Boolean;
begin

	retVal := inheritMethod(table, conwin, mouse, x, y);
	
	self.myCaller.sendMsgWithParams("contextMenu", table, conwin, mouse, x, y);

	return retVal;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="dblClick" id="561d8442-58aa-4a79-84ce-eeca3af1ef9b">
        <updating/>
        <source>dblClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
begin
	
	inheritMethod(table);
	
	
	self.myCaller.sendMsgWithParams("doTableDblClick",table);

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
