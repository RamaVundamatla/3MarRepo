    <JadeMethod name="doDateSearch" id="c7ea098a-7b58-41c4-988e-0df85c965afd">
        <updating/>
        <source>doDateSearch()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars
	iter : Iterator;
	bolTrx : CM_BOLTransaction;
	keyTimeStamp : TimeStamp;
	keyType : Integer;
	breakOut : Boolean;
	passport : CM_Passport;
	trxTypeObj : CM_TransactionType;
	type : Integer;
	
begin
	passport := app.myPassport;
	
	if transactionTypes.isEmpty then
	
		iter :=	myTerminal.allBOLTransactions.createIterator();
		myTerminal.allBOLTransactions.startKeyGeq(self.startDateTime, iter);
		
		while iter.next( bolTrx ) do
			iter.getCurrentKeys(keyTimeStamp);
			
			if (self.endDateTime &lt;&gt; null and keyTimeStamp &gt; self.endDateTime) then
				break;
			endif;
			
			if self.includesObject(bolTrx, breakOut, passport) then
				self.addObjectToSet(bolTrx);
			endif;
				
			if breakOut or self.breakOutOfSearch then
				break;
			endif;
		endwhile;
		
		delete iter;
	
	else
	
		foreach trxTypeObj in transactionTypes do
		
			type := trxTypeObj.trxType;
	
			iter :=	myTerminal.allBOLTransactionsByTypeDate.createIterator();
			myTerminal.allBOLTransactionsByTypeDate.startKeyGeq( type, self.startDateTime, iter);
			
			while iter.next( bolTrx ) do
				iter.getCurrentKeys( keyType, keyTimeStamp );
				if keyType &lt;&gt; type then
					break;
				endif;
				
				if (self.endDateTime &lt;&gt; null and keyTimeStamp &gt; self.endDateTime) then
					break;
				endif;
				
				if self.includesObject(bolTrx, breakOut, passport) then
					self.addObjectToSet(bolTrx);
				endif;
					
				if breakOut or self.breakOutOfSearch then
					break;
				endif;
			endwhile;
			
			delete iter;
		
		endforeach;
	
	
	endif;
	
epilog

	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="0d25626b-a1f2-4d79-a41e-8b03baddfbd6">
        <updating/>
        <source>doQuery(_qDef: CM_QueryDefinition) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

	now				: TimeStamp;
	crit			: CM_SelectorCriteriaLine;
	termSet			: CM_TerminalSet;
	ut				: CM_UserTerminal;
	tranType		: CM_TransactionType;
	term			: CM_Terminal;

begin
	self.reset();
	now := app.actualTimeServer();
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_BOLTransaction::dateTime.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.isKindOf(CM_QDateEquals) then
			self.startDateTime.setDate( crit.myQueryOperator.getSearchValue().Date );
			self.endDateTime.setDate( crit.myQueryOperator.getSearchValue().Date );
			self.endDateTime.setTime('23:59:59:999'.Time);
		elseif crit.myQueryOperator.isKindOf(CM_QDateGreaterThan) then
			self.startDateTime.setDate( crit.myQueryOperator.getSearchValue().Date );
			self.endDateTime := now;
		elseif crit.myQueryOperator.isKindOf(CM_QDateLessThan) then
			self.endDateTime.setDate( crit.myQueryOperator.getSearchValue().Date );
			if self.myContext = null then
				self.endDateTime.setTime('23:59:59:999'.Time);
			endif;
			self.startDateTime := null;
		elseif crit.myQueryOperator.isKindOf(CM_QDateRange) then
			self.startDateTime.setDate( crit.myQueryOperator.CM_QDateRange.getSearchValueFromDate() );
			self.endDateTime.setDate( crit.myQueryOperator.CM_QDateRange.getSearchValueToDate() );
			if self.myContext = null then
				self.endDateTime.setTime('23:59:59:999'.Time);
			endif;
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_TITransaction::getTransactionType.name, _qDef.className];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(self.transactionTypes);
	endif;
	
	create termSet transient;	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName['myTerminal', _qDef.className];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(termSet);
	else
		foreach ut in app.myPassport.myUser.allUserTerminals do
			termSet.add(ut.getMyTerminal);
		endforeach;
	endif;

	if not termSet.isEmpty then
		foreach term in termSet do
			self.myTerminal := term;
			self.doSearch;
		endforeach;
	endif;
	
epilog
	endLoad;
	self.myContext := null;
	delete termSet;
end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="2f44d11f-e489-4ee6-96ad-0bb6142d6fa8">
        <updating/>
        <source>doSearch() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin
	self.doDateSearch();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="reset" id="b3a94585-b707-4ea7-b301-0cc4a6939eef">
        <updating/>
        <source>reset() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin
	inheritMethod();

	self.myTerminal := null;
	if self.myContext = null then
		self.startDateTime := null;
		self.endDateTime := null;
	else
		//we actually want top keep the times that have been set from the form.
		self.startDateTime.setDate( null );
		self.endDateTime.setDate( null );
	endif;
	self.transactionTypes.clear();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyFilterClass" id="fb674e0f-e06a-4e3f-9996-b1be3b25acb4">
