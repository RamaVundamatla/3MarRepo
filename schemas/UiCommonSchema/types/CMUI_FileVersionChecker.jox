    <JadeMethod name="calculateDownloadSize" id="6044579a-099c-4ca1-8280-a413f60045f1">
        <updating/>
        <source>calculateDownloadSize() updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	totalBytes,
	row,
	numRows		: Integer;
	tbl			: CMUI_ListTable;
	fileObj		: CMUI_FileObj;
	megs		: Decimal[12,2];
	selected	: Boolean;
begin
	tbl := self.tblFiles;
	numRows := tbl.rows;
	
	foreach row in tbl.fixedRows + 1 to numRows do
		if tbl.getCellText(row,1) &lt;&gt; '1' then
			continue;
		endif;
			
		fileObj := tbl.accessRow(row).itemObject.CMUI_FileObj;
		if fileObj = null then
			continue;
		endif;
		
		totalBytes := totalBytes + fileObj.fileSizeServer;
	endforeach;
	
	megs := ((totalBytes / 1024) /1024);
	self.lblDownloadSize.caption := 'Total Download Size ' &amp; megs.String &amp; ' MB';
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDownloadFiles" id="62144159-b07d-4f5d-8b05-09fcc16287bb">
        <updating/>
        <source>doDownloadFiles() updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	row,
	numRows			: Integer;
	tbl				: CMUI_ListTable;
	selected		: Boolean;
	fileObj			: CMUI_FileObj;
	fileToGetFromServer,
	fileToMakeOnClient		: String;
	cmifMonitor		: CMIF_Monitor;
begin
	app.mousePointer := Busy;
	tbl := self.tblFiles;
	numRows := tbl.rows;
	create cmifMonitor transient;
	cmifMonitor.myParent := self;
	self.modalDialogReturnValue := null;
	
	self.modalDialogShow('Help file download progress',
						'Cancel',
						null,
						null,
						'File Progress',
						null);
	self.pbProgressBar.visible := true;
	
	global.checkFileFolderExists(self.pathClient, true, true);
	
	foreach row in tbl.fixedRows + 1 to numRows do
		selected := (tbl.getCellText(row, 1) = '1');
		if not selected then
			continue;
		endif;
		
		fileObj := tbl.accessRow(row).itemObject.CMUI_FileObj;
		if fileObj = null then
			continue;
		endif;
		if fileObj.isFolder then
			global.copyServerFolderToClient(self.pathServer &amp; fileObj.fileName, self.pathClient &amp; fileObj.fileName, cmifMonitor);
		else
			global.copyServerFileToClient(self.pathServer &amp; fileObj.fileName, self.pathClient &amp; fileObj.fileName, cmifMonitor);
		endif;
	endforeach;

epilog
	app.mousePointer := Idle;
	self.frmModalDialog.visible := false;
	delete cmifMonitor;
	if self.type = "Help" then
		self.loadHelpFileObjects;
	endif;
	self.loadTblFile();	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="18faffa1-a9fc-4b9c-9da2-85e83137a275">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     23 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();
	self.tblFiles.width := (self.tblFiles.parent.width - 10); 
	self.tblFiles.height := (self.tblFiles.parent.height - 60); 
end;</source>
    </JadeMethod>
    <JadeMethod name="loadHelpFileObjects" id="c76d092a-9bba-4a7c-969e-9cefcefa8217">
        <updating/>
        <source>loadHelpFileObjects() protected, updating;
// ---------------------------------------------------------------------------
// Created:     Oct 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars	
	fileObj: CMUI_FileObj;
	helpFileNames: StringArray;
	fileName, fileToCheck: String;
	user: CM_User;
	idx: Integer;
begin

	self.allFileObjects.purge;

	self.pathClient := global.getJMTDocumentationDir();
	self.pathServer := global.getJMTDocumentationDirServer();

	create helpFileNames transient;
	
	user := app.getMyUser();
	user.getHelpFileNames(helpFileNames);

	foreach fileName in helpFileNames do
		create fileObj transient;
		self.allFileObjects.add(fileObj);
		
		if fileName = HelpFile_Index then
			if idx = 0 then
				idx := 1;
				fileToCheck := fileName;
				fileObj.description := HelpFile_IndexFolder_Desc;
				fileObj.isFolder := true;
			else
				fileToCheck := fileName &amp; HelpFile_IndexExtension;
			endif;
		else
			//fileToCheck := fileName &amp; HelpFile_VersionAppendage;
			//fileToCheck := fileToCheck &amp; HelpFile_Extension;		
			fileToCheck := fileName &amp; HelpFile_Extension;		
		endif;
		
		fileObj.fileName := fileToCheck;
		if fileObj.description = null then
			fileObj.description := app.getHelpFileDescr(fileName);
			fileObj.status := app.getFileStatus(fileToCheck, self.pathClient, self.pathServer, fileObj.fileSizeServer);
		else
			fileObj.status := app.getFolderStatus(fileToCheck, self.pathClient, self.pathServer, fileObj.fileSizeServer);
		endif;
		fileObj.userMessage := app.getFileStatusUserMessage(fileObj.status);
	endforeach;
epilog
	delete helpFileNames;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTblFile" id="44fdff92-f2f0-4641-a036-118afb6bc68b">
        <updating/>
        <source>loadTblFile() protected, updating;
// ---------------------------------------------------------------------------
// Created:     23 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tbl			: CMUI_ListTable;
	fileDescr	: String;
	idx			: Integer;
	obj			: Object;
	fileObj		: CMUI_FileObj;
	totalDownloadSize,
	checkValue	: Integer;
begin
	tbl := self.tblFiles;
	tbl.rows := 1;
	tbl.fixedRows := 1;
	tbl.columns := 4;
	tbl.gridLines := true;
	tbl.allSelectedObjects.clear;
	tbl.backColor := self.ColourYellowLight;
	tbl.setCellText(1,1, Tab &amp; 'File Title' &amp; Tab &amp; 'File Name' &amp; Tab &amp; 'Status');
	
	foreach obj in self.allFileObjects do
		fileObj := obj.CMUI_FileObj;
		if fileObj.status = app.FileStatus_AbsentClient or
		   fileObj.status = app.FileStatus_OutOfDate or
		   fileObj.status = app.FileStatus_EmptyFolderClient or  //par 11711
		   fileObj.status = app.FileStatus_EmptyFolderServer then //par 11711
			checkValue := 1;
		else
			checkValue := 0;
		endif;
		
		idx := tbl.addItem(checkValue.String &amp; Tab &amp; 
					fileObj.description &amp; Tab &amp; 
					'(' &amp; fileObj.fileName &amp; ')' &amp; Tab &amp; 
					fileObj.userMessage);
					
		tbl.accessRow(idx).itemObject := fileObj;
	endforeach;
	
	self.calculateDownloadSize();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="41e9ced7-0659-480a-b4de-7325b7ef98e4">
