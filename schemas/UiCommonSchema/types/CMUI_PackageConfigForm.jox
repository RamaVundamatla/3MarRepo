	_cmb.itemData[idx] := PackageReports;
	
	//idx := _cmb.addItem(app.getErrorString(Invoice_posted));  // Invoice_posted);  //09/03/2020 cnwma1 TFS #48524
	idx := _cmb.addItem(app.getErrorString(Invoice_package)); // Invoice_posted);  //09/03/2020 cnwma1 TFS #48524
