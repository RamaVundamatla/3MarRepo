        <updating/>
        <source>btnPrintList_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     23 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 23/6/25 	jlier1 JIRA-34771 MTN | Pagination - Cargo Enquiry Form
vars
	selectedOnly,printPreview : Boolean;
	jrwReportName,filePath : String;
	outputType : Integer; 
	coll : Collection;
begin
	selectedOnly:=true;
	if app.getReportToSendItems(CM_TrackedItemView, null, selectedOnly, jrwReportName, printPreview, outputType, filePath) then
		if selectedOnly then
			coll:= self.tblData.allSelectedObjects;
		else
			coll:=self.tblData.getCollection;
		endif;
		app.sendItemsToReport(CM_JRWTrackedItems, coll, jrwReportName, printPreview, outputType, filePath);
	endif;
epilog
	
end;</source>
