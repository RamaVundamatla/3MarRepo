    <JadeMethod name="handleSystemNotification" id="677b2ee5-decb-4f45-9122-19edfbc0dcfd">
        <updating/>
        <source>handleSystemNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	eventReq : CM_EventRequestTI;
	term : CM_Terminal;
begin
	if eventType = Object_Update_Event
	or eventType = Object_Create_Event then
		//05 Nov 2012	NDL	Par 30542
		if CM_EventRequestTI.hasInstance( theObject ) then
			eventReq := theObject.CM_EventRequestTI;
			term := eventReq.myTerminal;
			if term = null or term &lt;&gt; self.myTerminal then
				return;
			endif;
		else
			return;
		endif;
		self.tblData.updateItemObject(theObject.CM_Object, self.colorRow1, self.colorRow2, app.myPassport);
	elseif eventType = Object_Delete_Event then
		self.tblData.removeDeletedObject(theObject);
		if theObject = self.myCurrentEventRequest then
			self.myCurrentEventRequest := null;
		endif;
	endif;
	
//	self.doRefresh();//2/11/2009 cnwdz2 par21480
	self.statusLine.caption := (self.tblData.rows-self.tblData.fixedRows).String &amp; ' rows found.';			
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeRequest" id="c450d633-0629-45d5-aa94-3344575b7d62">
        <source>includeRequest(_eventRequest : CM_EventRequest) : Boolean;
//--------------------------------------------------
// Created:	18 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	failedDAC  :CM_DataAccessController;
begin
	if _eventRequest = null then
		return false;
	endif;
	
	
	if self.myCMIFSearchEventRequest = null then
		return true;
	endif;
	
	if self.myCMIFSearchEventRequest.status &gt; EventRequestStatusAny then
		if _eventRequest.status &lt;&gt; self.myCMIFSearchEventRequest.status then
			return false;
		endif;
	endif;
	
	if self.myCMIFSearchEventRequest.cargoId &lt;&gt; null then
		if _eventRequest.CM_EventRequestTI.cargoId &lt;&gt; self.myCMIFSearchEventRequest.cargoId then
			return false;
		endif;
	endif;
	
	return true;
end;</source>
        <Parameter name="_eventRequest" type="CM_EventRequest"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
