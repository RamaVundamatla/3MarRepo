    <JadeMethod name="setForUpdate" id="bd5b42b8-113a-494c-97e5-b5839d489b0a">
        <updating/>
        <source>setForUpdate(_theController : CMIF_BankDetails) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
24 Aug 2012	cnwkpd1	PAR #30262 - Fix leaked persistent HugeStringArray
	
*/

vars
	errCode : Integer;
	aBank : CM_Bank;
begin
	if allBankDetails &lt;&gt; null then
		self.allBankDetails.clear();			// PAR #30262
	endif;
	self.mailingAddress.purge;
	self.physicalAddress.purge;
	
// TFS 43314	self.initialise(_theController.mailingName, _theController.code, _theController.myParentCompany, app.myPassport.myTerminal);
	
	
	 // TFS 39618 next number is now on BU maint
	if _theController.nextInvoiceNumber &gt; 0 then
		if self.keySeries[SN_INVOICE].nextKey.root &gt; _theController.nextInvoiceNumber then	
			app.raiseCMException(User_updated_invoice_number, null, null);
		endif;
		errCode := self.keySeries[SN_INVOICE].setNext(_theController.nextInvoiceNumber, true);
		if errCode &lt;&gt; 0 then
			app.raiseCMException(errCode,null,null);
		endif;
	
	endif;
	
	// TFS 43314 self.setForCreate(_theController);
	
	
	// TFS 43314 copied the following from setForCreate
	self.code := _theController.code;
	self.mailingName := _theController.mailingName;
	self.isSuspended := _theController.isSuspended;
	
	if _theController.isBU then
		_theController.allBankDetails.copy(self.allBankDetails);
		_theController.mailingAddress.copy(self.mailingAddress);
		_theController.remittanceAddress.copy(self.physicalAddress); // CCMS 1587
		self.emailAddress := _theController.emailAddress;
		self.faxNumber := _theController.faxNumber;
		self.phoneNumber :=	_theController.phoneNumber;
		self.onsiteStorageChargeTime := _theController.onsiteStorageChargeTime;
		self.businessUnitDebtor := _theController.myBusinessUnitDebtor;
		if _theController.myInvoiceProcess &lt;&gt; self.myInvoiceProcess then // TFS 39618
			self.setInvoiceProcess( _theController.myInvoiceProcess ); //13 Jan 2021	NDL	TFS 50600
		endif; // TFS 39618
		if _theController.myDefaultPackage &lt;&gt; self.myDefaultPackage then		//navra1 - CR 61910//Task 62303 - 12th Feb 2024
			self.myDefaultPackage := _theController.myDefaultPackage;			//navra1 - CR 61910//Task 62303 - 12th Feb 2024
		endif;																	//navra1 - CR 61910//Task 62303 - 12th Feb 2024
	else
		self.retrospectiveRates := _theController.retrospectiveRates;
		self.taxNarration := _theController.taxNarration;
		self.taxNumber := _theController.taxNumber;
		self.taxPercentageRate := _theController.taxPercentageRate;
		
		foreach aBank in self.subCompanies do
			aBank.retrospectiveRates := _theController.retrospectiveRates;
			aBank.taxNarration := _theController.taxNarration;
			aBank.taxNumber := _theController.taxNumber;
			aBank.taxPercentageRate := _theController.taxPercentageRate;
		
		endforeach;
	
	endif;
	

end;</source>
        <Parameter name="_theController" type="CMIF_BankDetails"/>
    </JadeMethod>
    <JadeMethod name="setInvoiceProcess" id="774fb7e4-4860-4dd7-924c-91581156babf">
        <updating/>
        <source>setInvoiceProcess(_invoiceProcess : CM_InvoiceProcess) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jan 2019	jlgsl4	TFS 39618
05 Jun 2025 navma1  MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
*/

vars
	invProc : CM_InvoiceProcess;
begin

	if _invoiceProcess &lt;&gt; null then
		if self.myInvoiceProcess &lt;&gt; _invoiceProcess then	//13 Jan 2021	NDL	TFS 50600
			self.myInvoiceProcess := _invoiceProcess;
		endif;
	else
		//13 Jan 2021	NDL	TFS 50600
		invProc := app.myRoot.allInvoiceProcesses[InvoiceProcessDefault];		//05.06.2025 navma1 #MTN-34114;
		if invProc &lt;&gt; null then
			if self.myInvoiceProcess &lt;&gt; invProc then
				self.myInvoiceProcess := invProc;
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_invoiceProcess" type="CM_InvoiceProcess"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="e027b5e8-4534-4010-a817-8707a1077c26">
        <updating/>
        <source>setProxy(_theController : CMIF_BankDetails) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.allBankDetails = null then
		create self.allBankDetails transient;
	endif;
	_theController.allBankDetails.copy(self.allBankDetails);
	if _theController.code.length &gt; 4 then
		self.code := _theController.code[1:4];
	else
		self.code := _theController.code;
	endif;
	self.emailAddress := _theController.emailAddress;
	self.faxNumber := _theController.faxNumber;
	_theController.mailingAddress.copy(self.mailingAddress);
	_theController.remittanceAddress.copy(self.physicalAddress); // CCMS 1587
	
	self.isSuspended := _theController.isSuspended;
	self.mailingName :=_theController.mailingName;
	self.businessUnitDebtor := _theController.myBusinessUnitDebtor;
	self.onsiteStorageChargeTime := _theController.onsiteStorageChargeTime;
	self.phoneNumber := _theController.phoneNumber;
	self.retrospectiveRates := _theController.retrospectiveRates;
	self.taxNarration := _theController.taxNarration;
	self.taxNumber := _theController.taxNumber;
	self.taxPercentageRate := _theController.taxPercentageRate;
	self.myInvoiceProcess := _theController.myInvoiceProcess;	//14 Jan 2021	NDL	TFS 50600
	self.myDefaultPackage := _theController.myDefaultPackage;	//navra1 - CR 61910//Task 62303 - 12th Feb 2024
	
end;</source>
        <Parameter name="_theController" type="CMIF_BankDetails"/>
    </JadeMethod>
    <JadeMethod name="setProxySuspend" id="a42cb47d-66ac-4685-8a01-a192259e3371">
        <updating/>
        <source>setProxySuspend(_sus : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.isSuspended := _sus;
end;</source>
        <Parameter name="_sus" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSelectedProformaCriteria" id="1f41e406-e247-440d-beac-2eae123454ee">
