        <source>setMyHookCode( _hookCode : CM_HookCode ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2010	cnwndl1	Initial creation

*/

vars

begin

	self.myHookCode := _hookCode;
	
epilog

end;</source>
        <Parameter name="_hookCode" type="CM_HookCode"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="3e3956f5-f9c6-4412-ab9b-501ee5a91718">
        <updating/>
        <source>setProxy(	_code : String;
			_description : String;
			//_currentCalendar : CM_Calendar;
			_hasEndTime : Boolean;
			_hasTime : Boolean;
			_myDayType : CM_DayType;
			_myHookCode : CM_HookCode;
			_myHookLink : CM_HookLink;
			_allTerminals : CM_TerminalByCodeDict
			) updating;
// ---------------------------------------------------------------------------
// Created:     21 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	calendar : CM_Calendar;
begin

	self.raiseExceptionIfNotTransient(method);
	self.code			:= _code[1:4];
	self.description	:= _description[1:30];
	
	self.hasEndTime := _hasEndTime;
	self.hasTime := _hasTime;
	self.myDayType := _myDayType;
	self.myHookCode := _myHookCode;
	
	self.allTerminals.clear();
	if not _allTerminals.isEmpty then
		_allTerminals.copy(self.allTerminals);
	endif;

	self.myRoot			:= app.myRoot;
	
//		calendar := _currentCalendar;
//		calendar.allCalendarDates.copy(self.allCalendarDates);

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_hasEndTime" type="Boolean"/>
        <Parameter name="_hasTime" type="Boolean"/>
        <Parameter name="_myDayType" type="CM_DayType"/>
        <Parameter name="_myHookCode" type="CM_HookCode"/>
        <Parameter name="_myHookLink" type="CM_HookLink"/>
        <Parameter name="_allTerminals" type="CM_TerminalByCodeDict"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="38be667e-f80a-41e7-b103-587e1e9d6076">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     21 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin

	if app.myRoot.allCalendars[self.code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;
	
	self.validateMe();

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="a7b3a900-70bf-4f34-8903-8f740a457736">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     25 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	terminal : CM_Terminal;
	strTerminal : String;
	iter : Iterator;
	vsDayTemp : CM_VehicleBookingDayTemplate;
	storageConfig : CM_StorageConfig;
begin
	
	// 29 Oct 2010	NDL	par 25530
	strTerminal := null;
	foreach terminal in app.myRoot.allTerminals do
		if terminal.getMyHolidayCalendar = self then
			if strTerminal = null then
				strTerminal := terminal.getDisplayDetails(true);
			else
				strTerminal := strTerminal &amp; ", " &amp; terminal.getDisplayDetails(true);
			endif;
		endif;
	endforeach;
	if strTerminal &lt;&gt; null then
		app.raiseCMException2(Current_holiday_calendar, self.description, strTerminal, null, null);
	endif;
	
	if not self.allTerminals.isEmpty then 
		app.raiseCMException(Calendar_in_use, null, null);  
	endif;
	
	//11 Apr 2013	NDL	Par 31393
	if app.isVehicleBookingEnabled then
		iter := CM_VehicleBookingDayTemplate.instances.createIterator;
		while iter.next( vsDayTemp ) do
			if vsDayTemp.myCalendar = self then
				app.raiseCMException1(Calendar_used_By, vsDayTemp.getDisplayForError(),null, null);
			endif;
		endwhile;
	endif;
	
	//20 Sep 2017	NDL	TFS 7032
	foreach storageConfig in CM_StorageConfig.instances do
		if storageConfig.myWorkingDaysCalendar = self or storageConfig.myCompulsoryCalendar = self then
			app.raiseCMException1(Calendar_used_By, storageConfig.getDescForError, null, null);
		endif;
	endforeach;

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="1b3c4e36-941f-474a-a6ca-39b83ded5d80">
