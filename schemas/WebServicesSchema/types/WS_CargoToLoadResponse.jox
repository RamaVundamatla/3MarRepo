    <JadeMethod name="setCanLoadAll" id="78f5d0b2-f5eb-44db-966b-7504b217ed35">
        <updating/>
        <source>setCanLoadAll(_context : Integer; _tiSet : CM_TISet input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 September 2021	jlier1	Initial creation 51879

*/

vars
	cargoCheck	  : CM_CargoCheck;
	terminal 	  : CM_Terminal;
	ti : CM_TrackedItem;
	hasChecks : Boolean;
	cmifAutoPlan	: CMIF_YAAutoPlanNormal;
	check 			: CM_CargoCheckItem;
begin
	self.canLoadAll:=true;
	terminal 	:= app.myPassport.myTerminal;
	if not  app.getMyUser.canDo(app.myPassport.myTerminal, PmHHAllowLoadAll) then
		self.canLoadAll:=false;
		return;
	endif;
	cargoCheck := terminal.allCargoChecks[_context];
	hasChecks:=cargoCheck &lt;&gt; null and cargoCheck.allCargoCheckItems.first &lt;&gt; null;
	//see if any cargo that needs an amount
	foreach ti in _tiSet discreteLock do
		if ti.canSplitTotalQuantity then
			self.canLoadAll:=false;
			return;
		endif;
		if hasChecks then
			delete cmifAutoPlan;
			create cmifAutoPlan transient;
			cmifAutoPlan.attachTI(ti);		
			foreach check in cargoCheck.allCargoCheckItems discreteLock do
				if  check.doesTIMatchMe(cmifAutoPlan) then	
					self.canLoadAll:=false;
					return;
				endif;
			endforeach;
		endif;
	endforeach;
		
epilog
	delete cmifAutoPlan;
end;</source>
        <Parameter name="_context" type="Integer"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setWeightAndCounts" id="3c7cdd7d-6cef-4623-93f2-b0bc19f620e5">
        <updating/>
        <source>setWeightAndCounts(_release : CM_BulkRelease; _targetLocation : CM_LocationsController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 September 2021	jlier1	Initial creation 51879
11 January 2024	navcs2	ChangeRequest 61549: EUP | Release Request by Weight - Pack/Load, Rail Lander

*/

vars
	countLoaded, countToLoad : Integer;
	weightLoaded, weightToLoad : Decimal[16,4];
	measureType : CM_MeasurementType;	
begin
	if _release = null  then
		return;
	endif;
	
	_release.getLoadedAmountsForTarget(_targetLocation,countLoaded,countToLoad,weightLoaded, weightToLoad);
	self.countLoaded:=countLoaded;
	self.countToLoad:=countToLoad;
	if self.countToLoad = 0 then
		self.countToLoad:=countLoaded;
	endif;
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType &lt;&gt; null then
		self.weightLoaded:=app.convertMeasurementForDisplay(measureType.shortName, weightLoaded)&amp; " " &amp; measureType.shortName;
		self.weightToLoad:=app.convertMeasurementForDisplay(measureType.shortName, weightToLoad)&amp; " " &amp; measureType.shortName;	// 11 January 2024	navcs2	ChangeRequest 61549
	else
		self.weightLoaded:= weightLoaded.asStringWeightJMT;
		self.weightToLoad:= weightToLoad.asStringWeightJMT;	// 11 January 2024	navcs2	ChangeRequest 61549
	endif;
epilog

end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
    </JadeMethod>
</Class>
