    <JadeMethod name="getOIDAndDescForAttribute" id="a29f0a54-a9db-4842-8a6d-0fb57ded73dc">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid: String output): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
17 July 2018		jlgmd1	Initial creation - TFS 39407 SNO - Fixed Bulk Release criteria not saving on the template

*/

vars

begin

	if _attrName = ETRow_OperatorGroup then
		if self.myOperatorGroup &lt;&gt; null then
			_oid := self.getMyOperatorGroup.getOidAsString();
			return self.getMyOperatorGroup.code;
		endif;
	elseif _attrName = ETRow_IsoTypeGroup then
		if self.myISOTypeGroup &lt;&gt; null then
			_oid := self.getMyOperatorGroup.getOidAsString();
			return self.getMyISOTypeGroup.code;
		endif;
	elseif _attrName = ETRow_ReleaseType then
		return self.releaseType.String;
	//elseif _attrName = ETRow_AvaGrade then		// Loaded directly in its load method
	elseif _attrName = ETRow_PoolParty then
		if self.myMTPoolParty &lt;&gt; null then
			_oid := self.getMyMTPoolParty.getOidAsString();
			return self.getMyMTPoolParty.code;
		endif;
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="17bd9073-5745-4b4d-ab7c-9dbf18a8407e">
        <updating/>
        <source>includesObject(_bulkRelease: CM_BulkRelease; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//----------------------------------------------------------------
//	Created:	30 May 2005	by Jason Chapman  (cnwjc2)
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------
// 21/09/2009	consw1		SFW1035 - get info from ReserveDetail rather than Yard Request
// 02/08/2017	jlgdap1		TFS 5558 SNO Empty Release Report
//----------------------------------------------------------------
vars
	i 					: Integer;
	failedDAC  			:CM_DataAccessController;
	avaGrades			: IntegerArray;
	firstAvaGrade		: Integer;
	matched 			: Boolean;
	reserveDetail 		: CM_ReserveDetail;
begin
	self.numSearched := self.numSearched + 1;
	
	avaGrades := _bulkRelease.getAllAvailabilityGrades();
	
	if avaGrades &lt;&gt; null and (not avaGrades.isEmpty) then
		firstAvaGrade := avaGrades.first;
	endif;
	
	
	if inheritMethod(_bulkRelease, _passport, _breakOut)
	and (not _bulkRelease.isSystemGenerated)
//	and _bulkRelease.getDeliveryRequest(false) &lt;&gt; null then
	and _bulkRelease.allReserveDetails.size &gt; 0 then

		if (self.allQryAvaGrades.isEmpty or self.allQryAvaGrades.includes(firstAvaGrade)) 
//		and (self.myISOTypeGroup = null or _bulkRelease.getISOGroup = self.myISOTypeGroup) 
		and	(self.myOperator = null or _bulkRelease.myOperator = self.myOperator)
		and	(self.getMyOperatorGroup = null or _bulkRelease.myOperatorGroup = self.getMyOperatorGroup)
		and (self.releaseType = null or _bulkRelease.type = self.releaseType) 
		//29/04/2009 cnwdz2 ccms1735
		and (self.getMySubTerminal = null or _bulkRelease.mySubTerminal = self.getMySubTerminal)
		and (self.getMyMTPoolParty = null or _bulkRelease.myPoolingParty = self.getMyMTPoolParty)				// TFS 5558
		then
			if _bulkRelease.myOperator &lt;&gt; null
			and (not _bulkRelease.myOperator.canUserAccessSelf(null, failedDAC, _passport))
			then
				return false;
			endif;

			if self.getMyISOTypeGroup &lt;&gt; null then
				foreach reserveDetail in _bulkRelease.allReserveDetails do
					if reserveDetail.getISOGroup() = self.getMyISOTypeGroup then
						matched := true;
						break;
					endif;
				endforeach;
				if not matched then
					return false;
				endif;
			endif;
			
			self.numFound := self.numFound + 1;
			return true;
		endif;
	endif;


	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
