    </JadeMethod>
    <JadeMethod name="loadTreeViewArray" id="4be8b931-8a4c-4317-a030-1741aa62dfc3">
        <source>loadTreeViewArray(_collection : Collection input; _level : Integer; _form : CMUI_CodesMaintTree);
// -----------------------------------------------------------------------------
// Created:		08 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	code : CM_Code;	
	iter : Iterator;
	obj  : SOPVM_CodeGroup;
	dummySourceLocation : SOPVM_SourceLocation;
	includeNotAvail : Boolean;	//	//21 Jun 2013	NDL	Par 31770
begin
	create obj transient;
	
	obj.initializeMe(self, _level, null);
	_collection.add(obj);
	obj.myForm := _form;
	
	//19 June 2013	NDL	Par 31770
	if self.groupType = CodeGroup_SourceLocation then
		//so we don't preload all of the data straight away for source locations
		//add a dummy line instead.
		if not self.allCodes.isEmpty then
			create dummySourceLocation transient;
			dummySourceLocation.initializeMe(null,  _level + 1, obj);
			dummySourceLocation.myForm := _form;
			_collection.add(dummySourceLocation);
		endif;
		return;
	endif;
	
	includeNotAvail := not _form.chkInclNotAvail.visible or ( _form.chkInclNotAvail.visible and _form.chkInclNotAvail.value );	//21 Jun 2013	NDL	Par 31770
	
	iter := self.allCodes.createIterator();
	while iter.next(code) do
		if includeNotAvail or not code.notAvailableForEntry then	//21 Jun 2013	NDL	Par 31770
			code.loadTreeViewArray(_collection, _level + 1, _form, obj);
		endif;
	endwhile;
	
epilog
	delete iter;

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_form" type="CMUI_CodesMaintTree"/>
    </JadeMethod>
    <JadeMethod name="loadTreeViewArrayWithoutCodes" id="acad65d1-339c-4d0b-a911-278fbb7ba7b2">
