        <source>trxUpdateMoveMatchedDocket(_bolExt : CM_BOLExtLogIn input; _passport : CM_Passport input ) updating;
// -------------------------------------------
// Created 22 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	// Always initialize the activity first
