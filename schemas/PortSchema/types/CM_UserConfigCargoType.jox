    <JadeMethod name="clearContent" id="387f0e80-4541-439d-8ca8-ebe393177861">
        <updating/>
        <source>clearContent() updating;
// called in load-from-file code after proxy create to clear out all but the CM_UserConfigCargoType instance itself
vars
	ucTab	: CM_UserConfigTab;
	oa		: ObjectArray;
	obj		: Object;
begin
	create oa transient;
	foreach ucTab in self.allUserConfigTabs do
		oa.add(ucTab);
	endforeach;
	foreach obj in oa do
		ucTab := obj.CM_UserConfigTab;
		ucTab.erase(NORMAL_ERASE);
	endforeach;
epilog
	delete oa;
end;
</source>
    </JadeMethod>
    <JadeMethod name="copyFrom" id="cab986ff-72cc-4e87-bbd8-ed69c90235df">
        <updating/>
        <source>copyFrom(_userCargoType : CM_UserConfigCargoType; _newUser : CM_User; _persistent : Boolean) updating;
// 09 August 2011	cnwjre1	CCMS 1776 Cargo Enquiry User Definable Layout
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/09/2013	cnwdap1		PAR #32426 Don't create notification if I am a transient
vars
	newTab,
	uctab	: CM_UserConfigTab;
	newAttr,
	ucattr	: CM_UserConfigAttribute;
begin
	// replace config tabs and attributes - simplest way to keep the sequence of each from user maintenance
	self.allUserConfigTabs.purge();
	foreach uctab in _userCargoType.allUserConfigTabs do
		if _persistent then
			create newTab persistent;
		else
			create newTab transient;
		endif;
		newTab.setup(uctab.description, uctab.name, uctab.tabType, self);
		foreach ucattr in uctab.allAttributes do
			if _persistent then
				create newAttr persistent;
			else
				create newAttr transient;
			endif;
			newAttr.setup(newTab, ucattr.myEntTableRow);
		endforeach;
	endforeach;
	self.myUser := _newUser; //cnwrd1 par 31318 shifted here due to key issues 
	self.myCargoBOLType := _userCargoType.myCargoBOLType;
	
	// PAR #32426 Don't trigger notification for transients
	if not self.isTransient then
		app.myPassport.myTerminal.causeEvent(app.myPassport.myTerminal.getTerminalEvent(UserConfigCargo_Update_Event), false, self);		// 21/06/2013 cnwmh5 #31679
	endif;
	
end;
</source>
        <Parameter name="_userCargoType" type="CM_UserConfigCargoType"/>
        <Parameter name="_newUser" type="CM_User"/>
        <Parameter name="_persistent" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasReeferTab" id="338a98d4-ad31-4b18-bb29-5550def9911f">
        <source>hasReeferTab() : Boolean;

vars
	uctab : CM_UserConfigTab;
begin
	foreach uctab in self.allUserConfigTabs do
		if uctab.tabType = 1 then
			return true;
		endif;
	endforeach;
	
	return false;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesTable" id="c5a705e0-da9c-4ff0-9bf2-5af6031d54b2">
        <source>includesTable(_tableName : String) : Boolean;
// return true if the given ent table name is found in a tab of this config
vars
	ucTab	: CM_UserConfigTab;
begin
	foreach ucTab in self.allUserConfigTabs do
		if ucTab.name = _tableName then
			return true;
		endif;
	endforeach;

	return false;
end;
</source>
        <Parameter name="_tableName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveTab" id="b47846a3-725d-4cb9-94b7-c0c1e05a0e0d">
        <source>moveTab(_tab : CM_UserConfigTab; _moveUp : Boolean);

vars

begin
	self.allUserConfigTabs.moveElement(_tab, _moveUp);
end;
</source>
        <Parameter name="_tab" type="CM_UserConfigTab"/>
        <Parameter name="_moveUp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="1a950ac4-0629-4b3f-ae3b-1d0a333205c8">
        <source>pxyCreateUpdateProxy() : SelfType;
// 09 August 2011	cnwjre1	CCMS 1776 Cargo Enquiry User Definable Layout
// create a full set of transient children
vars
	proxyUser_CargoType	: CM_UserConfigCargoType;
	ucTab,
	proxyTab	: CM_UserConfigTab;
	ucAttr,
	proxyAttr	: CM_UserConfigAttribute;
begin
	proxyUser_CargoType := inheritMethod();
	proxyUser_CargoType.myCargoBOLType := self.myCargoBOLType;
	proxyUser_CargoType.myUser := self.myUser;
	
	foreach ucTab in self.allUserConfigTabs do
		create proxyTab transient;
		proxyTab.setup(ucTab.description, ucTab.name, ucTab.tabType, proxyUser_CargoType);
		foreach ucAttr in ucTab.allAttributes do
			create proxyAttr transient;
			proxyAttr.setup(proxyTab, ucAttr.myEntTableRow);
		endforeach;
	endforeach;

	return proxyUser_CargoType;
end;
</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="3a93319a-4d1d-4ca4-9208-88022c34c49b">
        <updating/>
        <source>setForUpdate(_proxyUser_CargoType : CM_UserConfigCargoType) updating;
// 09 August 2011	cnwjre1	CCMS 1776 Cargo Enquiry User Definable Layout
vars
	newTab,
	uctab	: CM_UserConfigTab;
	newAttr,
	ucattr	: CM_UserConfigAttribute;
begin
	// replace config tabs and attributes - simplest way to keep the sequence of each from user maintenance
	self.allUserConfigTabs.purge();
	foreach uctab in _proxyUser_CargoType.allUserConfigTabs do
		create newTab persistent;
		newTab.setup(uctab.description, uctab.name, uctab.tabType, self);
		foreach ucattr in uctab.allAttributes do
			create newAttr persistent;
			newAttr.setup(newTab, ucattr.myEntTableRow);
		endforeach;
	endforeach;
	self.myCargoBOLType := _proxyUser_CargoType.myCargoBOLType;
	self.myUser := _proxyUser_CargoType.myUser;
end;
</source>
        <Parameter name="_proxyUser_CargoType" type="CM_UserConfigCargoType"/>
    </JadeMethod>
    <JadeMethod name="setup" id="687c162c-778c-42b6-a2a9-89b426e1091c">
        <updating/>
        <source>setup(_user : CM_User; _cargoType : CM_CargoBOLType) updating;

vars

begin
	self.myUser := _user;
	self.myCargoBOLType := _cargoType;
end;
</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_cargoType" type="CM_CargoBOLType"/>
    </JadeMethod>
