    <JadeMethod name="addDriverRowForNewDescriptor" id="1fcbdb6d-64a7-4af1-9712-072667066522">
        <updating/>
        <source>addDriverRowForNewDescriptor(desc : ProcessDescriptor) updating, protected;

// assumes that a row for the node of the process exists in the table

vars
	viewNodes, viewProcs, lookingForProcessRow, objIsKindOfProcDesc : Boolean;
	n, m, rows, firstNonFixedRow, descProcInstId : Integer;
	nodeDesc : NodeDescriptor;
	obj : Object;
	tbl : Table;
	
begin
	self.setCaption(true);
	
	if desc = null then
		return;
	endif;

	tbl := self.tblDrivers;
	
	rows := tbl.rows;
	firstNonFixedRow := tbl.fixedRows + 1;

	if firstNonFixedRow &gt; rows then
		return;
	endif;

	viewNodes := self.mnuViewSysNodesProcs.checked or self.mnuViewSysNodesOnly.checked;
	viewProcs := self.mnuViewSysNodesProcs.checked;
	
	tbl.accessCell(firstNonFixedRow, 1).text := app.mySession.getTableString;

	m := self.availMemoryWarningThreshold;

	if app.mySession.getDbServerFreeMemoryMegabytes &gt; m then
		tbl.accessCell(firstNonFixedRow, self.MemoryStartCol).backColor := self.SystemRowColor;
		tbl.accessCell(firstNonFixedRow, self.MemoryStartCol + 1).backColor := self.SystemRowColor;
	else
		tbl.accessCell(firstNonFixedRow, self.MemoryStartCol).backColor := self.ErrorColor;
		tbl.accessCell(firstNonFixedRow, self.MemoryStartCol + 1).backColor := self.ErrorColor;
	endif;

	if not viewNodes then
		// if nodes aren't being displayed then this method can't display
		// processes either, so the value of viewProcs doesn't matter
		return;
	endif;

	lookingForProcessRow := false;
	descProcInstId := desc.processInstanceId;
	nodeDesc := desc.myNodeDescriptor;

	foreach n in firstNonFixedRow + 1 to rows do
		obj := tbl.accessCell(n, 1).itemObject;
		
		if obj = desc then
			// a row for this process descriptor has already been added
			return;
		endif;

		if lookingForProcessRow then
			objIsKindOfProcDesc := obj.isKindOf(ProcessDescriptor);
			
			if (objIsKindOfProcDesc and descProcInstId &gt; obj.ProcessDescriptor.processInstanceId) or
			   (not objIsKindOfProcDesc)
			then
				tbl.addItemAt(desc.getTableString, n);
				tbl.accessCell(n, 1).itemObject := desc;
				if desc.getAvailableMemoryMegabytes &lt;= m then
					tbl.accessCell(n, self.MemoryStartCol).backColor := self.ErrorColor;
					tbl.accessCell(n, self.MemoryStartCol + 1).backColor := self.ErrorColor;
				endif;

				return;
			endif;

			continue;
		endif;
				
		if obj = nodeDesc then
			tbl.accessedCell.text := nodeDesc.getTableString;

			if nodeDesc.getAvailableMemoryMegabytes &gt; m then
				tbl.accessCell(n, self.MemoryStartCol).backColor := self.NodeRowColor;
				tbl.accessCell(n, self.MemoryStartCol + 1).backColor := self.NodeRowColor;
			else
				tbl.accessCell(n, self.MemoryStartCol).backColor := self.ErrorColor;
				tbl.accessCell(n, self.MemoryStartCol + 1).backColor := self.ErrorColor;
			endif;
			
			if not viewProcs then
				// we're not displaying processes - nothing more to do
				return;
			endif;
			
			lookingForProcessRow := true;
		endif;
	endforeach;
	
	if lookingForProcessRow then
		// we're looking for the row at which to insert details for the
		// supplied process descriptor but have scanned all rows in the
		// table - this means we must add a row at the end of the table
		tbl.addItem(desc.getTableString);
		n := tbl.rows;
		tbl.accessCell(n, 1).itemObject := desc;
		if desc.getAvailableMemoryMegabytes &lt;= m then
			tbl.accessCell(n, self.MemoryStartCol).backColor := self.ErrorColor;
			tbl.accessCell(n, self.MemoryStartCol + 1).backColor := self.ErrorColor;
		endif;
	endif;		
end;</source>
        <access>protected</access>
        <Parameter name="desc" type="ProcessDescriptor"/>
    </JadeMethod>
    <JadeMethod name="colorTableColumnsForRow" id="e7f7d071-f7a0-4de5-8ff5-32f856448ad1">
        <source>colorTableColumnsForRow(tbl : Table input; row, fromCol, toCol, color : Integer) protected;

vars
	i : Integer;
	
begin
	foreach i in fromCol to toCol do
		tbl.accessCell(row, i).backColor := color;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="tbl" type="Table" usage="input"/>
        <Parameter name="row" type="Integer"/>
        <Parameter name="fromCol" type="Integer"/>
        <Parameter name="toCol" type="Integer"/>
        <Parameter name="color" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="displayDbServerFreeDisk" id="e5f1b96c-48d5-4eac-a68a-91a83b8f843b">
        <source>displayDbServerFreeDisk() protected;

begin
	self.lblStatusMiddle.caption := "DB Server free disk on " &amp; app.mySession.dbServerDriveName &amp;
		": " &amp; app.mySession.dbServerFreeDisk.asMegabytes.roundedTo(2).String &amp; " MB";
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmdStart" id="25de8022-d532-49bc-8082-65047d35c876">
        <source>doCmdStart(target : Object) protected;

begin
	// If we get any exceptions executing a start command, we just
	// abort the operation which will cut the stack back to an idle
	// point (this method should be called only via an event).
	// The command is effectively ignored.
	on Exception do app.abortActionExHandler(exception);

	app.mySession.doCmdStart(target);
end;</source>
        <access>protected</access>
        <Parameter name="target" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doCmdStop" id="b0668532-bc4e-414d-8b75-32fa1091ba8e">
        <source>doCmdStop(target : Object) protected;

begin
	// If we get any exceptions executing a stop command, we just
	// abort the operation which will cut the stack back to an idle
	// point (this method should be called only via an event).
	// The command is effectively ignored.
	on Exception do app.abortActionExHandler(exception);

	app.mySession.doCmdStop(target);
end;</source>
        <access>protected</access>
        <Parameter name="target" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doCmdTerminate" id="aab44bff-b80b-4992-840b-3939313256bc">
        <updating/>
        <source>doCmdTerminate(target : Object) protected, updating;

vars
	md : MachineDescriptor;
	
begin
	if target = null or target = system then
		doSaveToLogs;

		if app.msgBox("Are you sure you want to terminate all driver processes?",
			"Confirm Terminate", MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) &lt;&gt; MsgBox_Return_Yes
		then
			return;
		endif;

	elseif Node.hasInstance(target) then
		if app.msgBox("Are you sure you want to terminate all driver processes in the selected node?",
			"Confirm Terminate", MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) &lt;&gt; MsgBox_Return_Yes
		then
			return;
		endif;

	elseif MachineDescriptor.hasInstance(target) then
		md := target.MachineDescriptor;
		if app.msgBox("Are you sure you want to terminate all driver processes on " &amp; md.name &amp; '?',
			"Confirm Terminate", MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_Yes
		then
			app.mySession.doCmdTerminateMachine(md);
		endif;
		return;
	endif;

	app.mySession.doCmdTerminate(target);
end;</source>
        <access>protected</access>
        <Parameter name="target" type="Object"/>
    </JadeMethod>
