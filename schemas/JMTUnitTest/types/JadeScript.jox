    <JadeMethod name="mdhTestCM_ObjectInstanceSize" id="3552b8b6-26a7-432e-beb3-eb3f77ad27dd">
        <source>mdhTestCM_ObjectInstanceSize();

/*

Purpose:		Get the sizes of class instances under CM_Object

Date			Who		Reason
09/06/2015		cnwmh5	Initial creation

*/

vars

	root						: UM_Root;
	schema						: Schema;
	klass						: Class;
	file						: File;

	classes						: ClassColl;
	
	count						: Integer;
	totalCount					: Integer;
	totalInstances				: Decimal[12,0];

begin

	root := UM_Root.firstInstance;
	//self.assertNotNull(root);
	if root = null then
		write "unable to find UM_Root.  Exiting Jadescript...";
		return;
	endif;
	
	schema := rootSchema.getSchema("PortSchema");
	//self.assertNotNull(schema);
	if schema = null then
		write "Unable to find schema (PortSchema).  Exiting Jadescript...";
		return;
	endif;
	
	///klass := schema.getClass("CM_Object");
	klass := schema.getClass("CM_Voyage");
	///self.assertNotNull(klass);
	if klass = null then
		write "Unable to find class (CM_Object).  Exiting Jadescript...";
		return;
	endif;
	
	create file transient;
	file.fileName := "c:\temp\CMObjectInstanceSizeA.csv";
	if file.isAvailable() then
		file.purge();
	endif;
	file.writeLine("class, size");
	
	create classes transient;
	classes.add(klass);
	klass.allSubclasses(classes);
	
	foreach klass in classes do
		
		totalCount := totalCount + 1;
		
		if klass.abstract then
			continue;
		endif;
		
		count := count + 1;
		
		write klass.name &amp; Tab &amp; klass.instances.size.String;
		file.writeLine(klass.name &amp; "," &amp; klass.instances.size.String);
		totalInstances := totalInstances + klass.instances.size;
	
	endforeach;
	file.close();
	
	write 'count: ' &amp; count.String &amp; Tab &amp; 'totalCount: ' &amp; totalCount.String &amp; Tab &amp; 
		'totalInstances: ' &amp; totalInstances.String;
	

epilog

	delete classes;
	delete file;
	
end;</source>
    </JadeMethod>
