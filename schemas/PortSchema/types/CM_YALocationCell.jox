    <JadeMethod name="testCellHeight" id="2c6a1695-f4af-4f8a-a9a8-d7412c899719">
        <source>testCellHeight(_yaBlock : CM_YABlock;
				_yaAgent : CM_YAAutoplanAgent input) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwer1	Initial creation CCMS 1025 refactored code block taken from testCellSuitabilityForTi

*/

vars
	currentHeight : Integer;
begin
	// CCMS 1030 Apply the height range check
	if _yaBlock &lt;&gt; null and _yaBlock.isKindOf(CM_YABlockGridArea) then
		if (self.height &lt; _yaBlock.getMinHeight or self.height &gt; _yaBlock.getMaxHeight) then
			_yaAgent.addLogEntry(AP_Log_YA_Default,'Failed height range(' &amp; _yaBlock.getMinHeight.String &amp; "-" &amp; _yaBlock.getMaxHeight.String &amp; ')  check at height ' &amp; self.height.String, true);
			return false;
		endif;
		// Make sure container wont end up in the air
		currentHeight := self.myYardController.numTIs;
		if not _yaAgent.isOnlyCheckRealCargo  then
			//currentHeight:=currentHeight + self.myYardController.numPlannedTIs + self.myYardController.numQueuedTIs;
			currentHeight:=currentHeight + self.myYardController.numPlannedTIs + self.myYardController.numQueuedTIs + _yaAgent.getTestPlannedCargoCountFor( self.myYardController );	//18 jul 2013	NDL	Par 31899
		endif;
		if (self.height-1) &gt; currentHeight then
			_yaAgent.addLogEntry(AP_Log_YA_Default,'Failed height check - height ' &amp; (self.height-1).String &amp; " is greater then " &amp;currentHeight.String, true);
			return false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_yaBlock" type="CM_YABlock"/>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testCellSuitabilityForTi" id="7bbe5edb-f6b7-4279-9301-af5cee97963e">
        <source>testCellSuitabilityForTi(_yaAgent : CM_YAAutoplanAgent input; _yaBlock: CM_YABlock) : Boolean;
// -------------------------------------------
// Created 30 March 2005 by cnwdvb1
// -------------------------------------------
vars

	locationCell	: CM_YALocationCell;
	yardLocation	: CM_YardController;
	ti				: CM_TrackedItem;
	numControllers	: Real;
	currentHeight   : Integer;
	reason : String;
	currentMaxHeightForPad : Integer;
begin

	yardLocation := self.myYardController;
	
	_yaAgent.addLogEntry(AP_Log_YA_Default,'Testing suitability for ' &amp; yardLocation.getFullId &amp; ' at height ' &amp; self.height.String, true);
	
	_yaAgent.iteration := self.height;
	
	// Do various tests on cell
	
	// Test whether locations are available. 
	// Based on existing method testIsControllerFull
	if yardLocation.testIsControllerFullYA(_yaAgent) then
		return false;
	endif;
	if not _yaAgent.useOverstowRules and not _yaAgent.isOnlyCheckRealCargo then
		if yardLocation.testOverstowPlannedQueuedYA(_yaAgent) then
			return false;
		endif;
	endif;

	//+cnwml2 PAR25712
	if yardLocation.isKindOf(CM_GridController) and yardLocation.CM_GridController.isOverDimensions(_yaAgent) then
		return false;
	endif;
	
	// CCMS 1030 Apply the height range check
	if not self.testCellHeight(_yaBlock,_yaAgent) then
		return false;
	endif;
	
	//08 Sep 2020	NDL	TFS 49984
	if yardLocation.isKindOf(CM_GridController) then
		currentMaxHeightForPad := yardLocation.CM_GridController.getCurrentMaxHeightForPad( reason );
		if currentMaxHeightForPad &lt;&gt; 0 and currentMaxHeightForPad &lt; self.height then
			_yaAgent.addLogEntry(AP_Log_YA_Default,'Failed Max Stack Height check at height ' &amp; self.height.String &amp; '. ' &amp; reason, true);
			return false;
		endif;
	endif;
	
	//17 Jan 2019	NDL	TFS 42292
	if _yaAgent.isFindOverstowLocation and _yaAgent.ignorePlanQueuedTIForOS then
		if yardLocation.isGridLocation then
			_yaAgent.addLogEntry(AP_Log_YA_Default,'Checking ' &amp; yardLocation.getFullId &amp; ' to ensure nothing here that is already planned/queued out.', true);
			if yardLocation.numPlannedTIsOut() &gt; 0 then
				return false;
			elseif yardLocation.numQueuedTIsOut() &gt; 0 then
				return false;
			endif;
		endif;
	endif;

	return true;
	
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_yaBlock" type="CM_YABlock"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
