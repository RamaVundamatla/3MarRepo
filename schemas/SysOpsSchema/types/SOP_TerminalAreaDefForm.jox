    <JadeMethod name="onRectChangedIC" id="843936b2-7158-4c93-95ce-728243cf3dc6">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_RectangleHandler::onRectChanged"/>
        </interfaceImplements>
        <source>onRectChangedIC(_rect : CMUI_ResizableRectFrame input);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 February 2010	cnwer1	Initial creation

*/

vars
	theGridArea : CMUI_GridArea;
	topRow,
	bottomRow : CMUI_GridRow;
	firstColumn,
	lastColumn	: CMUI_GridColumn;
	y1,y2,x1,x2 	: Real;
	outsideBottomEdge,
	outsideTopEdge	: Boolean;
	iter			: Iterator;
	gridController	: CM_GridController;
	cmifGridLCsAssocWithICArea  : CMIF_GridLCsAssocICArea;
begin
	theGridArea:=self.frmGrdArea.myGridArea;
	

	y1:=_rect.top;
	y2:=_rect.top + _rect.clientHeight;
	x1:=_rect.left;
	x2:=_rect.left + _rect.clientWidth;
	
	topRow:=theGridArea.convertPosToClosestGridRow(y1,outsideBottomEdge); 
	bottomRow:=theGridArea.convertPosToClosestGridRow(y2,outsideBottomEdge);
	firstColumn:=theGridArea.convertPosToClosestGridColumn(x1,outsideTopEdge);
	lastColumn:=theGridArea.convertPosToClosestGridColumn(x2,outsideTopEdge);
	
	
	_rect.top:=topRow.y1;
	_rect.left:=firstColumn.x1;
	
	if outsideTopEdge then
		_rect.width:= (lastColumn.x2 ) -_rect.left ;
	else
		_rect.width:= (lastColumn.x1  ) -_rect.left ;
	endif;
	
	
	if outsideBottomEdge then
		_rect.height:= (bottomRow.y2  ) -_rect.top ;
	else
		_rect.height:= (bottomRow.y1  ) -_rect.top ;
	endif;
	
	cmifGridLCsAssocWithICArea:=_rect.userObject.CMIF_GridLCsAssocICArea;
	cmifGridLCsAssocWithICArea.clearAllGridControllers;
	iter:=self.myProxyObject.CM_GridArea.allGridControllersByRowColumn.createIterator;
	self.myProxyObject.CM_GridArea.allGridControllersByRowColumn.startKeyGeq(topRow.row,firstColumn.column,iter);
	while iter.next(gridController) do
		if gridController.column &lt; firstColumn.column then
			continue;
		endif;
		if outsideTopEdge then
			if gridController.column &gt; lastColumn.column then	
				continue;
			endif;
		else
			if gridController.column &gt;= lastColumn.column then	
				continue;
			endif;
		endif;
		
		if outsideBottomEdge then
			if gridController.row &gt; bottomRow.row then
				break;
			endif;
		else
			if gridController.row &gt;= bottomRow.row then
				break;
			endif;
		endif;
		
		cmifGridLCsAssocWithICArea.addGridController(gridController);
	//	write gridController.ident; //row.String &amp; Space &amp; gridController.column.String;
	endwhile;
	
epilog
	delete iter;

end;</source>
        <Parameter name="_rect" type="CMUI_ResizableRectFrame" usage="input"/>
    </JadeMethod>
