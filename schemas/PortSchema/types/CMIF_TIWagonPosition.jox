<Class name="CMIF_TIWagonPosition" id="a74b740e-8ee0-495b-b97f-1bc15bf47feb">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This is used to store information about the make up of a wagons controllers. There is one of these for every wagon controller on a wagon. 
An index of zero can be used to refer to the actual wagon itself, if necessary.
The Index and Position are used to identify the controller and then where on that controller the TI goes.</text>
    <DbClassMap file="discrep"/>
    <ImplicitInverseRef name="allTrackedItems" id="dd393322-e437-45e1-a4a7-b99726a5cef9">
        <memberTypeInverse/>
        <type name="CM_TIArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="available" id="e4095771-d373-47e7-bcbd-d133674fb236">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="hasTwistLocks" id="d3d63898-cda1-4fa9-83ac-062f10f54db6">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myRailLine" id="7f52cad0-ea5b-48a1-82cc-0a566a3fe125">
        <embedded/>
        <type name="CM_RailLine"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTrackedItem" id="ec784563-4264-49a1-93a7-096877083f7c">
        <embedded/>
        <type name="CM_TrackedItem"/>
    </ImplicitInverseRef>
    <PrimAttribute name="position" id="0d1eb92c-339e-4a47-8f6f-c6d1b1813cce">
        <embedded/>
        <type name="Integer"/>
        <text>This relates to the index of the Wagon Controller being used.</text>
    </PrimAttribute>
    <PrimAttribute name="twistLocksAreUp" id="179a8a7b-9d3f-4ec6-aac4-c8a1e5d1f1de">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="setDetails" id="0c86c590-c879-41b8-9f96-febf3295ced4">
        <updating/>
        <source>setDetails( _available,
			_hasTwistLocks : Boolean;
			_pos : Integer;
			_railLine : CM_RailLine;
			_allTis : CM_TIArray
			) updating;
/*
----------   ----------  --------------------------------------------------
Created:	31 October 2006 By cnwth2

Purpose:	Th2 for gdanks hand held trx. Large number of unsed attributes on this class at this time
			This method implemented to set only the attrs that appear to be used currently.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.available 		:= _available;
	self.hasTwistLocks	:= _hasTwistLocks;
	self.position		:= _pos;
	self.myRailLine		:= _railLine;
	
	//14 Oct 2014	NDL	Par 35040
	self.allTrackedItems.clear();
	if _allTis &lt;&gt; null and not _allTis.isEmpty then
		_allTis.copy( self.allTrackedItems );
	endif;
	
	

end;


</source>
        <Parameter name="_available" type="Boolean"/>
        <Parameter name="_hasTwistLocks" type="Boolean"/>
        <Parameter name="_pos" type="Integer"/>
        <Parameter name="_railLine" type="CM_RailLine"/>
        <Parameter name="_allTis" type="CM_TIArray"/>
    </JadeMethod>
</Class>
