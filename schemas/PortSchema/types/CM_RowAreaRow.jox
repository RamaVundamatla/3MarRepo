<Class name="CM_RowAreaRow" id="8cb3e7c6-5352-4c2c-8e7a-d85000bf8949">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <ExplicitInverseRef name="allRowControllers" id="b3c3ab0e-5671-4c2a-becc-87d06a96cbca">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <type name="CM_RowControllerArray"/>
        <access>readonly</access>
        <Inverse name="CM_RowController::myRow"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myRowArea" id="6ad34fb9-f3e5-49d7-8974-4bfe4d7addc3">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_RowArea"/>
        <access>readonly</access>
        <Inverse name="CM_RowArea::allRows"/>
    </ExplicitInverseRef>
    <PrimAttribute name="width" id="f8faa893-a862-43d3-a365-455e07110af8">
        <embedded/>
        <type name="Real"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="addController" id="319bb678-a6c4-4201-8bfb-5caa24d0d904">
        <source>addController(_rowController : CM_RowController);

vars

begin

	// Place controller at the front.
	self.allRowControllers.add(_rowController);

end;</source>
        <Parameter name="_rowController" type="CM_RowController"/>
    </JadeMethod>
    <JadeMethod name="getPrevGap" id="adb34385-80ab-451d-a96b-ec6b2face338">
        <source>getPrevGap() : Real;
/* ---------------------------------------------------------------------------
Created:	05 May 2011	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if self.myRowArea &lt;&gt; null and self &lt;&gt; null then
		return self.myRowArea.getPrevGap(self);
	endif;
	return null;

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getRowPosition" id="9e676242-8f1a-4036-a232-ce0e00f2ba79">
        <source>getRowPosition() : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	23 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.myRowArea = null then
		return null;
	endif;
		
	return self.myRowArea.allRows.indexOf(self);

end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setAttributes" id="dcd506e9-b823-4aa6-bc10-39047303d835">
        <updating/>
        <source>setAttributes(_width : Real) updating;

vars

	rowCont : CM_RowController;

begin

	self.width := _width;
	
	if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		//15 Jan 2014	NDL	Par 33264
		if self.myRowArea &lt;&gt; null then
			self.updateObjectEdition(self.myRowArea);
			foreach rowCont in  self.myRowArea.allRowControllersById do
				self.updateObjectEdition(rowCont);
			endforeach;
		endif;
	endif;
		

end;</source>
        <Parameter name="_width" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setForCreateFromCMIFLogRow" id="9a288389-c27b-4d80-9df4-6ba2b00ced28">
        <updating/>
        <source>setForCreateFromCMIFLogRow(_cmifLogRow : CMIF_LogRowRestriction) updating;

vars

begin

	if _cmifLogRow.isSplit then
		_cmifLogRow.myRowArea.adjustWidth(self, _cmifLogRow.width, _cmifLogRow.distanceFromPrevious);
	else
		_cmifLogRow.myRowArea.insertNewRow(self, _cmifLogRow.previousRow, _cmifLogRow.width, _cmifLogRow.distanceFromPrevious);
	endif;

end;</source>
        <Parameter name="_cmifLogRow" type="CMIF_LogRowRestriction"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateFromCMIFLogRow" id="3bdd87a3-bbd8-43bd-990b-f0424c31827e">
        <updating/>
        <source>setForUpdateFromCMIFLogRow(_cmifLogRow : CMIF_LogRowRestriction; _rowController : CM_RowController) updating;

vars

	previousName	: String;
	prevDistance	: Real;
	newRow			: CM_RowAreaRow;
	

begin

	if self.allRowControllers.size = 1 then
		// We are currently not split
		if _cmifLogRow.isSplit then
			// We are going to become a split
			if _cmifLogRow.myRowAreaRowTo &lt;&gt; null then
				if _cmifLogRow.myRowAreaRowTo &lt;&gt; self then
					if self.allRowControllers.includes(_rowController) then
						self.allRowControllers.remove(_rowController);
						newRow := _cmifLogRow.myRowAreaRowTo;
						_cmifLogRow.myRowArea.removeRowAreaRow(self);
						_cmifLogRow.myRowArea.adjustWidth(newRow, _cmifLogRow.width, _cmifLogRow.distanceFromPrevious);
						_cmifLogRow.myRowAreaRowTo.addController(_rowController);
					else
						app.raiseCMException(CannotLocateRowController, null, null);
					endif;
				endif;
			else
			//	app.raiseCMException1(REQUIRED_FIELD, 'Row to split', null, null);
				app.raiseCMException(Input_required_field_rowToSplt, null, null); // cnwdb2	PAR 35364
			endif;
		else
			// we can just move to new position
			_cmifLogRow.myRowArea.moveExistingRow(self, _cmifLogRow.previousRow, _cmifLogRow.width, _cmifLogRow.distanceFromPrevious);
		endif;

	elseif self.allRowControllers.size &gt; 1 then
		// This is already a split row
		if _cmifLogRow.isSplit then
			if _cmifLogRow.myRowAreaRowTo = null then
				_cmifLogRow.myRowArea.moveExistingRow(self, _cmifLogRow.previousRow, _cmifLogRow.width, _cmifLogRow.distanceFromPrevious);
				return;
			endif;
			// staying a split
			if self.allRowControllers.includes(_rowController) then
				self.allRowControllers.remove(_rowController);
				newRow := _cmifLogRow.myRowAreaRowTo;
				_cmifLogRow.myRowArea.adjustWidth(newRow, _cmifLogRow.width, _cmifLogRow.distanceFromPrevious);
				_cmifLogRow.myRowAreaRowTo.addController(_rowController);
			else
				// Row controller is not in this row so EXCEPTION
				app.raiseCMException(CannotLocateRowController, null, null);
			endif;
		else
			// new position is not split
			if self.allRowControllers.includes(_rowController) then
				self.allRowControllers.remove(_rowController);
				create newRow persistent;
				_cmifLogRow.myRowArea.insertNewRow(newRow, _cmifLogRow.previousRow, _cmifLogRow.width, _cmifLogRow.distanceFromPrevious);
				newRow.addController(_rowController);
			else
				// Row controller is not in this row so EXCEPTION
				app.raiseCMException(CannotLocateRowController, null, null);
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="_cmifLogRow" type="CMIF_LogRowRestriction"/>
        <Parameter name="_rowController" type="CM_RowController"/>
    </JadeMethod>
</Class>
