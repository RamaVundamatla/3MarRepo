        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="423f4922-818b-4bef-a481-1fd8fe28b514">
        <updating/>
        <source>setProxyFromObject(_object: CM_WodCargoRequest) updating;
/*

Purpose:			TFS 40127 - not actually used by TFS 40127, but is needed.

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlger1	Initial creation

*/

vars
	marineServiceDetail : CM_WodMarineServiceDetail;
	wsHMSResourceUsed : WS_HMSResourceUsed;

begin
	inheritMethod(_object);

	create self.myVoyageHoldCargo transient;
	self.myVoyageHoldCargo.setProxyFromObject(_object);
	
	// TFS 40127
	foreach marineServiceDetail in  _object.allMarineServiceDetails discreteLock do
		create wsHMSResourceUsed transient;
		wsHMSResourceUsed.setProxyFromMarineService(marineServiceDetail);
		self.allHMSResourcesUsed.add(wsHMSResourceUsed);
		
	endforeach;
	
epilog

end;</source>
        <Parameter name="_object" type="CM_WodCargoRequest"/>
    </JadeMethod>
    <JadeMethod name="updateProxyWorkOrder" id="ee1f3dba-d279-4c72-8c7f-522fcb3fbd9e">
        <source>updateProxyWorkOrder(_pxyWorkOrder: CM_WodCargoRequest input);
/*

Purpose:			TFS 40127 - not actually used by TFS 40127, but is needed.

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2018	jlger1	Initial creation

*/

vars
	allFiles : CM_FileDataSet;
	wsDocument : WS_Document;
	pxyFile : CM_FileData;
	pxyResourceUsed : HMS_ResourceUsed;
	wsHMSResourceUsed : WS_HMSResourceUsed;
	allPxyHMSResourcesUsed : HMS_ResourceUsedSet;
	hmsResource : HMS_Resource;
	
begin
	inheritMethod(_pxyWorkOrder);
	create allFiles transient;
	foreach wsDocument in self.allDocuments discreteLock do
		create pxyFile transient;
		wsDocument.setProxyFileData(pxyFile);
		allFiles.add(pxyFile);
	
	endforeach;
	
	
	_pxyWorkOrder.setProxyWodCargoRequest(self.myVoyageHoldCargo.getDischargePortCode,
											self.myVoyageHoldCargo.imexStatus,
											self.myVoyageHoldCargo.gangs,
											self.myVoyageHoldCargo.totalQuantity,
											self.myVoyageHoldCargo.totalVolume.asDecimalFromWebInterface,
											self.myVoyageHoldCargo.totalWeight.asDecimalFromWebInterface,
											self.myVoyageHoldCargo.getTransferType,
											self.myVoyageHoldCargo.cargoWeight.asDecimalFromWebInterface,
											self.myVoyageHoldCargo.tareWeight.asDecimalFromWebInterface,								
											self.myVoyageHoldCargo.getProduct,
											self.myVoyageHoldCargo.getCargoType,
											self.myVoyageHoldCargo.getCommodity,
											self.myVoyageHoldCargo.getConsignee,
											self.myVoyageHoldCargo.getConsignor,
											self.myVoyageHoldCargo.getFreightForwarder,
											self.myVoyageHoldCargo.getHoldLocation,
											self.myVoyageHoldCargo.getOperator,
											self.myVoyageHoldCargo.getWorkPoint,
											allFiles,
											0,	//_permitType : Integer //27 Jun 2018	NDL	TFS 39246
											self.myVoyageHoldCargo.getLoadPortCode,	//_loadPort : String;	//20 Jul 2018	NDL	TFS 39837
											self.myVoyageHoldCargo.bolNumber,	//_bolNumber : String;	//20 Jul 2018	NDL	TFS 39837
											self.myVoyageHoldCargo.estimatedStartDT.asTimeStampFromWebInterface,	//_estStartTS : TimeStamp;	//20 Jul 2018	NDL	TFS 39837
											self.myVoyageHoldCargo.estimatedEndDT.asTimeStampFromWebInterface
											);
											
	
	
	// TFS 40127
	create allPxyHMSResourcesUsed transient;
	
	foreach wsHMSResourceUsed in self.allHMSResourcesUsed discreteLock do
		create pxyResourceUsed transient;
		wsHMSResourceUsed.setProxyHMSResorceUsed(pxyResourceUsed);
		allPxyHMSResourcesUsed.add(pxyResourceUsed);		
	endforeach;
	

	
	_pxyWorkOrder.setMarineDetsFromResourceUsed(allPxyHMSResourcesUsed);


epilog
	if allPxyHMSResourcesUsed &lt;&gt; null then
		allPxyHMSResourcesUsed.purge;
	endif;
	delete allPxyHMSResourcesUsed;
	
	delete allFiles;
end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WodCargoRequest" usage="input"/>
    </JadeMethod>
</Class>
