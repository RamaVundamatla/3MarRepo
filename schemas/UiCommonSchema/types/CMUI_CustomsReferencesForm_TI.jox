    <JadeMethod name="addItem" id="7c433983-573c-43a5-abc9-4715a53236ab">
        <updating/>
        <source>addItem() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
19 March 2024	navlw1	ChangeRequest 62959: CUX FR | Tk 62917 - EDBIC Make Customs references editable
09 April 2024	navlw1	Bug 63566: CUX - Code 75755 when adding a Customs Reference with Cargo Item in Edit Mode
*/

vars
	pxyCustomsReference : CM_CustomsReference;
begin

	// check that we at least have something in these fields
	if self.txtRefType.text = null and self.txtRefNum.text = null and self.txtPosNum.text = null and self.txtCustomsControl.text = null 
		and self.txtObjectName.text = null and self.txtPosNum.text = null then
		return;
	endif;
	
	// create the proxy that will be used to create the customs reference
	create pxyCustomsReference transient;
	self.setSelectedItem(pxyCustomsReference);
	
	self.updateItem();
	self.allProxyCustomsRefs.add(pxyCustomsReference);
	
	self.clearFormControls();
	
	// select the item we just added
	self.tblData.clearAllSelected();
	self.tblData.selectObject(pxyCustomsReference, false);
	self.displaySelectedItem(); 
	
	self.btnAdd.enabled := false;
	self.btnUpdate.enabled := true;
	self.btnRemove.enabled := true;
	
	self.txtRefType.enabled := true;
	self.txtRefNum.enabled := true;
	self.txtPosNum.enabled := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="btnAdd_click" id="19921a2d-8c9b-466d-b944-cad9161732b7">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAdd_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2024	navlw1	ChangeRequest 62959: CUX FR | Tk 62917 - EDBIC Make Customs references editable

*/

vars

begin
	self.addItem();
	self.hasChanged := true;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnNew_click" id="614c33c8-1392-466e-abfb-275273babb8b">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNew_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
19 March 2024	navlw1	ChangeRequest 62959: CUX FR | Tk 62917 - EDBIC Make Customs references editable

*/

vars

begin
	if /*self.allProxyCustomsRefs.isNotEmpty and*/ self.isFormChanged then
		if app.msgBox(app.getErrorString(ConfirmNew), 'Are you sure?', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then
			return;
		endif;
	endif;
	self.clearFormControls();
	self.btnUpdate.enabled := false;
	self.btnRemove.enabled := false;
	self.btnAdd.enabled := true;
	self.frmControls.enabled := true;
	self.txtPosNum.enabled := true;
	self.txtRefType.enabled := true;
	self.txtRefNum.enabled := true;
	self.hasChanged := true;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnRemove_click" id="1a07768e-0567-4ae2-a38a-50d71c4c32d5">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRemove_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2024	navlw1	ChangeRequest 62959: CUX FR | Tk 62917 - EDBIC Make Customs references editable

*/

vars

begin
	self.hasChanged := true;
	self.removeItem();
	if self.tblData.rows = 1 then		
		self.btnAdd.enabled := true;		
	else
		self.btnAdd.enabled := false;		
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
