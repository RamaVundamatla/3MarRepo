    <JadeMethod name="pxyCreateUpdateProxy" id="3c0316e9-476a-4568-bf8d-219bec0ac7f1">
        <source>pxyCreateUpdateProxy(): SelfType;
/* ---------------------------------------------------------------------------
Created:     22 February 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason
20/04/2011	cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
					trying to create the proxy
------------------------------------------------------------------------------*/
vars
	pxyToDo	: CM_ToDoTask;
	completedOK		: Boolean;
	
begin
	pxyToDo := inheritMethod();
	
	pxyToDo.toDoTaskDesc := self.toDoTaskDesc;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyToDo;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyToDo;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreateToDoTask" id="84253f9b-596d-4eff-9883-8ddb51864228">
        <updating/>
        <source>setForCreateToDoTask(_status : Integer; _toDoTaskDesc : CM_ToDoTaskDesc; _toDoRemarks : String; _userCode : String) updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09 August 2002	DWQ	The _status parameter was NEVER being set.
// ---------------------------------------------------------------------------
begin

	self.dtLastUpdate 		:= app.serverTimestampAtTrxStart;
	self.status 			:= _status;
	self.toDoTaskDesc 		:= _toDoTaskDesc;
	self.toDoTaskDescCode 	:= _toDoTaskDesc.code;
	self.toDoTaskDescDesc 	:= _toDoTaskDesc.description;
	self.toDoTaskDescReport := _toDoTaskDesc.reportDescription;
	self.toDoTaskDescShort 	:= _toDoTaskDesc.shortDescription;
	self.userLastUpdate 	:= _userCode;
	self.remarks 			:= _toDoRemarks; 
end;</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_toDoRemarks" type="String"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
