    <JadeMethod name="tblData_dblClick" id="48ec658e-e837-41df-8c30-3976fb8e5827">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:     04 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if table.row &lt;= table.fixedRows then
		table.resortTableByColumn(table.column);
	endif;

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblData_rowColumnChg" id="34f0d37f-2b4b-4e88-9e26-fd9c0c68383c">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_rowColumnChg(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     04 September 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	ti	: CM_TrackedItem;
	
begin
	if table.row &gt; table.fixedRows then
		ti := table.accessRow(table.row).itemObject.CM_TrackedItem;
		self.showDetailsForTI(ti);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
