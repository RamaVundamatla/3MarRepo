    <JadeMethod name="doRemove" id="d11a8bce-77c5-411a-902a-dcca4b227b6f">
        <updating/>
        <source>doRemove()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2023 navtnr20	TFS CR 58224	Task 58227: UI - COO Delete
*/

vars
	theReturn : Integer;
	ownership	: CM_OwnershipChange;

begin
	// ### TFS BUG 59640 03AUG2023 NAVAB1 - check is selected
	if  self.tblData.row &lt;=  self.tblData.fixedRows then
		return;
	endif;
	
	if self.tblData.accessRow( self.tblData.row).selected then
		ownership := self.tblData.accessedRow.itemObject.CM_OwnershipChange;
	endif;

// ### TFS BUG 59640 03AUG2023 NAVAB1	ownership := _obj.CM_OwnershipChange;
	if ownership = null then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	
	if app.msgBox(app.getErrorString1(Please_confirm_deletion_COO,ownership.refNumber), 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	while true do
 	app.myTrxDA.trxDeleteOwnershipChange(ownership, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Ownership_change_delete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblCOOContMenu" id="827e44f2-4e97-4165-8031-cc29ad5739cc">
        <updating/>
        <source>doTblCOOContMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2023 navtnr20	TFS CR 58224	Task 58225: UI - Change of Ownership Enquiry
*/

vars
	canEdit		: Boolean;
	x1,
	y1			: Real;
begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	self.mnuColumnOrganiser.visible := true;
	self.mnuColumnOrganiser.userObject := self.tblData;
	self.mnuInspectObject.visible := app.isAllowedToInspect();  // ### TFS 60004 24AUG2023 NAVAB1
	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="dobtnUpdate" id="f880d3b9-6b25-42b2-99b8-d99d79db86f0">
        <updating/>
        <source>dobtnUpdate() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023 navtnr20	TFS CR 58233	Task 58238: UI - Notifications
*/

vars
	form : CMUI_OwnershipChangeMaint;
	bank :CM_Bank;
	ownership : CM_OwnershipChange;
begin
	ownership := self.tblData.accessRow(self.tblData.row).itemObject.CM_OwnershipChange;
	if ownership = null then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	if ownership &lt;&gt; null then
		form := app.loadForm(CMUI_OwnershipChangeMaint, CMUI_Assistant, false, false,false, self.myTerminal,null).CMUI_OwnershipChangeMaint;
		if form &lt;&gt; null then
			form.updateMode := true;
			form.setMyOwnershipChange(self.myOwnershipChange);
			form.centreWindow();
			self.myMaintForm := form; // ### TFS BUG 64115 13MAY2024 NAVAB1
			form.myEnquiryForm := self; // ### TFS BUG 64115 13MAY2024 NAVAB1
			form.show(); // ### TFS BUG 64115 13MAY2024 NAVAB1  .showModal;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getCOOforOperator" id="d4e49f73-b36d-4e44-a422-d7023fd6a406">
        <source>getCOOforOperator();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2023 navtnr20	TFS CR 58224	Task 58225: UI - Change of Ownership Enquiry
*/

vars
	ownership : CM_OwnershipChange;
begin
	self.tblData.rows := self.tblData.fixedRows;

	foreach ownership in self.myTerminal.allOwnershipChangeOpOld discreteLock do
		
		if not self.includeCOO(ownership, true) then
			continue;
		endif;
		
		self.addRowToTable(ownership);
	endforeach;
epilog

end;</source>
