    <JadeMethod name="isDefaultValue" id="ab881f7e-e6d9-4964-a416-b503d13a7dbc">
        <source>isDefaultValue() : Boolean;
//14 August 2008	cnwdw1	
// Return true if the value is the default value
vars

begin
	if self.isBooleanVisible() then
		return self.getBooleanValue() = CM_YADataBoolean.VALUE_FALSE;
	endif;
	
	return not self.hasValue();

end;</source>
