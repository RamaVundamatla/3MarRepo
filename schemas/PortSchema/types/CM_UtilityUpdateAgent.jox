    <JadeMethod name="utlUpdateStorageDetail" id="0b3ff530-a7d1-4b15-bcbf-2126cc0633e2">
        <source>utlUpdateStorageDetail(_proxyStorageDetail : CM_StorageDetail; _passport : CM_Passport input);
// 13 September 2012	cnwjre1	CCMS SFW 1295 Free Storage Days
vars
	realStorageDetail	: CM_StorageDetail;
	expectedEdition	: Integer;
	terminal 		: CM_Terminal;
begin
	self.initialiseActivity();

	_proxyStorageDetail.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyStorageDetail.pxyGetRealObjectAndEdition(realStorageDetail, expectedEdition);

	if realStorageDetail= null then
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_StorageDetail.name, null, null);
		return;
	endif;

	app.myValUA.valStorageDetail(_proxyStorageDetail);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realStorageDetail);

	if _passport.noErrors and realStorageDetail.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, "storageDetail", null, null);
		return;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realStorageDetail, true);
	endif;

	if _passport.noErrors then
		realStorageDetail.setForUpdate(_proxyStorageDetail);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realStorageDetail, false);
	endif;
	terminal:=realStorageDetail.myStorageConfig.myTerminal;
	terminal.causeEvent(terminal.getTerminalEvent(EVENT_STORAGE_CRITERIA_CREATE),false,realStorageDetail);

end;
</source>
        <Parameter name="_proxyStorageDetail" type="CM_StorageDetail"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSubBlockStack" id="a2b52d02-07ef-4b83-9e7a-bf318de1f9eb">
        <source>utlUpdateSubBlockStack(_theGridTARegion : CMIF_GridTARegion input; _theRealSubBlock : CM_SubBlockStack output;
				_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		May 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	aTA : CM_GridArea;
	theBlockStack	: CM_BlockStack;
begin


	self.initialiseActivity();

	if _theGridTARegion = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CMIF_GridTARegion.name, null, null);
		return;
	endif;
	aTA := _theGridTARegion.myGridArea;

	app.setContinueCMExceptions(true);

	app.myValUA.valSubBlockStack(_theGridTARegion, _passport); 
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(aTA, true);
	endif;
	
	if _passport.noErrors then
		_theGridTARegion.myGridArea.convStackToSubBlock(_theGridTARegion,_theRealSubBlock, _passport); // CREATE IT
	endif;

	if _passport.noErrors then
		aTA.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),false,aTA); //epr 11/6/08  par 16956 
		aTA.causeEvent(aTA.myTerminal.getTerminalEvent(Event_TALocation_Update),false,_theRealSubBlock); //epr 11/6/08  par 16956 
		self.myUpdateAuditAgent.audUpdateGeneric(aTA, false);
	endif;
epilog
end;</source>
        <Parameter name="_theGridTARegion" type="CMIF_GridTARegion" usage="input"/>
        <Parameter name="_theRealSubBlock" type="CM_SubBlockStack" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSubTerminal" id="c742b90c-343b-45cd-8ee2-e652ab185c14">
        <source>utlUpdateSubTerminal(_proxySubTerminal:CM_SubTerminal; _passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	08 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	cancelSave:Boolean;
	realSubTerminal:CM_SubTerminal;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	_proxySubTerminal.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxySubTerminal.pxyGetRealObjectAndEdition(realSubTerminal, expectedEdition);
	
	if realSubTerminal = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_SubTerminal.name, null, null);
		return;
	endif;

	app.myValUA.valSubTerminal(realSubTerminal, _proxySubTerminal);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realSubTerminal);

	if _passport.noErrors and realSubTerminal.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Sub-Terminal', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realSubTerminal, true);
	endif;
	
	if _passport.noErrors then
		realSubTerminal.setForUpdate(_proxySubTerminal);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realSubTerminal, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="_proxySubTerminal" type="CM_SubTerminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
