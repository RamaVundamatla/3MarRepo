    <JadeMethod name="sundryExceptionHandler" id="caddb37b-0499-4bc2-b885-7d64b9b725fa">
        <updating/>
        <source>sundryExceptionHandler(exObj : Exception;
						_remoteHeader : CM_RemoteDataHdr;
						_description : String;
						_error : Integer output;
						_errStr	: String output;
						_alertMe,
						_emailMe : Boolean) : Integer updating;
//
// 11 Jul 2019	jlgrs1	TFS45051 JMT terminate on a SDS secondary exception ie a takeover has happened.
//
vars
	longErrStr,
	errStr,
	msgStr,
	aStr,
	theDisplay		: String;
	error			: CM_Error;
	lockEx			: LockException;
	aTime 			: TimeStamp;
	errorArray		: StringArray512;
	callStack		: ProcessStackArray;
	methCallDesc	: MethodCallDesc;
	alertMe			: Boolean;
	msg : String;
begin
	if exObj.errorCode = 1228 or 
	   exObj.errorCode = 1295 or 
	   exObj.errorCode = 3015 or 
	   exObj.errorCode = 3037 then
		abortTransaction;
		abortTransientTransaction;
		msg := class.name&amp;'::'&amp;method.name&amp;' SDS Exception, cant continue,'&amp;exObj.errorCode.String&amp;' '&amp;exObj.extendedErrorText&amp;' processApp= '&amp;process.persistentApp.name&amp;' '&amp;process.userInfo&amp;' ('&amp;process.node.String&amp;", "&amp;process.String&amp;')';
		app.writeLog(msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		
		terminate;
	endif;

	// Get specific information.
	msg := 'INFO &gt;&gt; Exception handled by alertExceptionHandler. Alert generated = '&amp;_alertMe.String&amp;' Email generated = '&amp;_emailMe.String&amp;'('&amp;exObj.errorCode.String&amp;')';
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	longErrStr := _description;
	errStr := '(' &amp; exObj.errorCode.String &amp; '). ' &amp; exObj.extendedErrorText;
   	_error := exObj.errorCode;
   	create errorArray transient;
   	alertMe := _alertMe;
   	if _emailMe then
   		alertMe := true;
   	endif;
   	if not exObj.isKindOf(CM_Exception) and _alertMe then
   		errStr := errStr &amp; '(' &amp;  exObj.text &amp; ')';
   		app.doDumpStack(exObj);
   		// cut back the stack to the current method
   		
   		if exObj.errorCode = 1027 then
   			if exObj.isKindOf(LockException)  then
   				lockEx := exObj.LockException;
				if lockEx.lockType = Share_Lock then
					msgStr := " Share_Lock ";
				elseif lockEx.lockType =  Reserve_Lock then
					msgStr := " Reserve_Lock ";
				elseif lockEx.lockType =  Exclusive_Lock then
					msgStr :=  " Exclusive_Lock ";
				endif;
				msgStr := msgStr &amp; " Of Object :" &amp; getOidStringForObject(lockEx.lockTarget); //getName;
				errorArray.add(msgStr[1:256]);
				if lockEx.targetLockedBy &lt;&gt; null then
					msgStr := " By " &amp; lockEx.targetLockedBy.userCode &amp; " " &amp; lockEx.targetLockedBy.userInfo;
				else
					msgStr := " By unknown user";
				endif;
				process.getLockDuration(lockEx.lockTarget, aTime, aStr);
				msgStr := msgStr &amp; " Locked on" &amp; aTime.display &amp; " for " &amp; aStr;
				errorArray.add(msgStr[1:256]);
				errStr := errStr &amp; ' Background Lock exception';
			endif;
		endif;
	endif;
	if alertMe then
		// get the stack for the current process
		//-------------
		create callStack;
		process.currentStack(callStack);
		//-------------
		// cut back the stack to the current method
		//-------------
		while callStack.size &gt; 0 and callStack[1].method &lt;&gt; exObj.currentMethodDesc.method do
			delete callStack.removeAt(1);		// PAR #18009
		endwhile;
		//-------------
		//Add the call stack to the alert
		//-------------
		foreach methCallDesc in callStack do
			theDisplay := methCallDesc.display();
			if theDisplay.length &gt; 0 then
				errorArray.add(theDisplay[1:256]);
			endif;
		endforeach;
		app.remoteErrorWarningToAlert(longErrStr &amp; ' ' &amp; errStr, _remoteHeader,  null, errorArray, _emailMe, true);
	endif;
	if global.isValidObject(app.myBGPObject) then
		app.myBGPObject.causeEvent(BGP_Object.BGP_DisplayUpdate, true, null);
	endif;
	_errStr := errStr;
	return Ex_Resume_Next;
epilog
	if callStack &lt;&gt; null then
		callStack.purge;
		delete callStack;
	endif;
	delete errorArray;
end;</source>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_remoteHeader" type="CM_RemoteDataHdr"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_error" type="Integer" usage="output"/>
        <Parameter name="_errStr" type="String" usage="output"/>
        <Parameter name="_alertMe" type="Boolean"/>
        <Parameter name="_emailMe" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xHandlerBlockCommit" id="4a451be1-3690-4d46-9c2d-aa7741ac14db">
        <updating/>
        <source>xHandlerBlockCommit(_exObj	: Exception; _setAll, _setErrors : CM_ObjectSetActual input; _currentObj : CM_Object; _hadException : Boolean io) : Integer updating;
// -------------------------------------------
// Created 25 August 2004 by cnwdvb1
// -------------------------------------------
vars

	jmtException	: CM_Exception;
	le				: LockException;
	err				: String;
	retryCount		: Integer;
	msg : String;
begin

//	if _exObj.isKindOf(CM_Exception) then
// Par 10003
	if _exObj.resumable then
		abortTransaction;
		_hadException := true;
		if _currentObj &lt;&gt; null and _setAll.includes(_currentObj) then
			_setAll.remove(_currentObj);
			_setErrors.add(_currentObj);
			err := _currentObj.getName () &amp; ' ' &amp; _exObj.extendedErrorText;
			self.allErrors.add(err);
			app.remoteErrorWarningToAlert(app.getErrorString(Garbage_Collection) &amp; ' ' &amp; err, null, null, null, false, false);
			msg := app.getErrorString(Garbage_Collection) &amp; ' ' &amp; err;
			app.writeLog(msg,LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
		endif;
		return Ex_Resume_Next;
	else
		return Ex_Pass_Back;
	endif;
end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_setAll" type="CM_ObjectSetActual" usage="input"/>
        <Parameter name="_setErrors" type="CM_ObjectSetActual" usage="input"/>
        <Parameter name="_currentObj" type="CM_Object"/>
        <Parameter name="_hadException" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xHandlerLogError" id="658f5c92-a4b3-4a0e-89e0-e98f3e75ff1e">
        <source>xHandlerLogError(_exObj	: Exception) : Integer;

vars

	err 	: String;
	msg : String;
begin

	abortTransaction;
	msg := 'XHanderLogError';
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	if _exObj.isKindOf(CM_Exception) then
		err := _exObj.extendedErrorText;
	else
		err := _exObj.text;
	endif;
	self.allErrors.add(err &amp; ' (' &amp; self.currentArchiveType &amp; ' )');
	self.createActivityHistory(self.currentArchiveType &amp; ' Errors (Dbl Click)', true, false);
	return Ex_Pass_Back;

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xLockHandler" id="6f64ebe2-98a3-4718-9f09-4502dc317af6">
        <source>xLockHandler(_le	: LockException; _hadLockException : Boolean io; _num : Integer io; _errTxt : String io; _doPassback : Boolean) : Integer;
// -------------------------------------------
// Created 30 August 2004 by cnwdvb1
// -------------------------------------------
vars

	retryCount	: Integer;
	msg : String;
begin

 	while not tryLock(_le.lockTarget, _le.lockType, _le.lockDuration, 1000) do
 		retryCount := retryCount + 1;
 		if retryCount &gt; 4 then
 			abortTransaction;
 			_hadLockException := true;
 			_num := _num + 1;
			if _doPassback then
				msg := 'Passback';
				app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				
				return Ex_Pass_Back;
			endif;
			_errTxt := 	_le.text &amp; " :" &amp; app.getOidStringForObject(_le.lockTarget);
			msg := 'Resume Next';
			app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
 			return Ex_Resume_Next;
 		endif;
 	endwhile;
	msg := 'Continue';
 	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
  	return Ex_Continue;
end;</source>
        <Parameter name="_le" type="LockException"/>
        <Parameter name="_hadLockException" type="Boolean" usage="io"/>
        <Parameter name="_num" type="Integer" usage="io"/>
        <Parameter name="_errTxt" type="String" usage="io"/>
        <Parameter name="_doPassback" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
