<Class name="CM_AutoIdCustomDocs" id="cdae0a92-61a2-4999-8f03-412801db1d09">
    <superclass name="CM_AutoIdGenerator"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="idGen"/>
    <CompAttribute name="nextSequenceNumArray" id="3ae14fd8-75ff-4011-98a0-d4fc8873c4c3">
        <type name="RealArray"/>
        <access>readonly</access>
    </CompAttribute>
    <JadeMethod name="auditIdDisplay" id="15c1d7b8-e9bc-4710-93c5-3a99d151d577">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/08/2023	navkc1	CR 59556  Task 59557: Jade - CustDocs Auto Id

*/

vars
	idDisplay		: String;
	terminal		: CM_Terminal;
	
begin

	idDisplay := app.getErrorString(Auto) &amp; " " &amp; self.getDisplayStringForId(self.idType);
	
	terminal := self.myTerminal;
	
	if terminal &lt;&gt; null then
		idDisplay := idDisplay &amp; " - " &amp; terminal.code;
	endif;
	
	return idDisplay;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="21e096c7-c833-4d19-b539-d8c2f5fd5d75">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/08/2023	navkc1	CR 59556  Task 59557: Jade - CustDocs Auto Id

*/

vars

begin
	self.idType := self.CustDocNumberType;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="e4f1723e-f6f3-4b38-a820-5ba37710098b">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/08/2023	navkc1	CR 59556  Task 59557: Jade - CustDocs Auto Id

*/

vars
	audTxt, 
	tmpStr			: String;
	size,
	year,
	seq				: Integer;
begin
	audTxt[10000] 	:= '*';
	
	audTxt := inheritMethod();
	
	size := self.nextSequenceNumArray.size();
	
	if size = 0 then
		return audTxt;
	endif;
	
	while year &lt; size do
		year += 1;
		
		seq := self.nextSequenceNumArray[year].Integer;
		
		if seq = 0 then
			continue;
		endif;
		
		tmpStr := (2000 + year).String &amp; "-" &amp; seq.String &amp; Cr &amp; tmpStr;
	endwhile;
	
	audTxt := audTxt &amp; AuditStringSeparator &amp; CM_AutoIdCustomDocs::nextSequenceNum.name &amp; AuditStringSeparator &amp; tmpStr.length().String &amp; AuditStringSeparator &amp; tmpStr;
	
	return audTxt;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextIdForYear" id="f5d92c02-096b-471d-9498-128c7f8746c6">
        <updating/>
        <source>getNextIdForYear(_date: Date): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/08/2023	navkc1	CR 59556  Task 59557: Jade - CustDocs Auto Id

*/

vars
	bank				: CM_Bank;
	serverDate 			: Date;
	prefix 				: String;
	year 				: String;
	seqNum 				: Real;
	newId 				: String;
	nextSeqNum 			: Real;
	
	failSafeCount 		: Integer;
	inTransactionState 	: Boolean;
	
begin
	year := _date.format("yy");
	seqNum := self.getNextSequenceNumArray(year.Integer);
	
	if seqNum = 0 then
		seqNum := 1;
	endif;
	
	// Prefix
	if self.idStyle = AutoIdStyle_P_YY_SSS then
		prefix &amp;= self.idPrefix &amp; _date.format("yy");
	endif;
	
	while true do
		if seqNum.String.length &gt; self.idSeqNumLength then
			// just in case the user has made the seq num length shorter since last time thru,
			// or we have naturally reached the end of the series and need to reset.
			seqNum := 1;
		endif;
		newId := prefix &amp; seqNum.String.padLeadingZeros(self.idSeqNumLength);
		
		if self.newIdNotAlreadyUsed( newId ) then
			// no object of this type already uses this id.
			break;
		endif;
		
		seqNum := seqNum + 1;
		
		failSafeCount := failSafeCount + 1;
		
		if failSafeCount &gt; 9 then
			return null;
		endif;
		
	endwhile;
	
	nextSeqNum := seqNum + 1;
	
	if nextSeqNum.String.length &gt; self.idSeqNumLength then
		nextSeqNum := 1;
	endif;
	
	
	inTransactionState := process.isInTransactionState;
	
	if not inTransactionState then
		beginTransaction;
	endif;
	
	self.setLastAndNextValues(	newId, nextSeqNum, year.Integer, serverDate);
	
	if not inTransactionState then
		commitTransaction;
	endif;
	
	return newId;

epilog

end;</source>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextSequenceNumArray" id="24aaa013-7a70-4e80-b2db-1df86c55a442">
        <source>getNextSequenceNumArray(theYear: Integer): Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/08/2023	navkc1	CR 59556  Task 59557: Jade - CustDocs Auto Id

*/

vars

begin
	
	if self.nextSequenceNumArray.size() &lt; theYear then
		return 0;
	endif;
	
	return self.nextSequenceNumArray[theYear];

epilog

end;</source>
        <Parameter name="theYear" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
