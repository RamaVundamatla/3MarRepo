    <JadeMethod name="flipVertical" id="1bcc6f18-a7f9-4e82-b23b-069b33973c13">
        <updating/>
        <source>flipVertical(_recenterLocation : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2010	cnwjk3	Initial creation

*/

vars

begin
	if self.myDisplayBuilder &lt;&gt; null and not self.myDisplayBuilder.canFlipV(self.drawMode) then
		return;
	endif;
	
	self.flipV := not self.flipV;
	
	if self.flipV then
		self.topOffset := 0;
	else
		self.bottomOffset := 0;
	endif;

	if _recenterLocation then
		self.resetScrollOffsets();
		self.resizeDrawingFrames();
		self.reDrawAreaFromLocation(self.myTargetLocation, self.drawMode);	
	else			
		// Code for flipping without re-centering on location
		self.resetScrollOffsets();
		self.resizeDrawingFrames();
		self.calcViewSizes();	
		self.reCalcRowsForFlip();
		self.calcDrawRows();
		self.calcDrawCols();
		self.drawEverything();
	endif;

epilog

end;</source>
        <Parameter name="_recenterLocation" type="Boolean"/>
