    <JadeMethod name="getDisplayStringForAttribute" id="fba5eb47-9385-49ea-ba53-4eb334438e21">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 November 2012	cnwndl1	Initial creation	Par 30486

*/

vars

begin

	if _attrName = ETRow_JobNumber then
		if self.id &lt;&gt; null then
			return self.id;
		else
			return self.jobId;
		endif;
		
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
