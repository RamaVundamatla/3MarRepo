    <JadeMethod name="toggleMultiSelect" id="5fc9d3b3-5678-49cb-81cd-9aa429e31635">
        <updating/>
        <source>toggleMultiSelect(_table : CM_DataTable input) updating;
//--------------------------------------------------------------
//Created: 15 October 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if _table = null then
		return;
	endif;
	if _table.multiSelect = CM_DataTable.MultiSelect_Simple then
		_table.multiSelect := CM_DataTable.MultiSelect_None;
		self.mnuToggleMultiSelect.checked := false;	
	else
		_table.multiSelect := CM_DataTable.MultiSelect_Simple;		
		self.mnuToggleMultiSelect.checked := true;			
	endif;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
