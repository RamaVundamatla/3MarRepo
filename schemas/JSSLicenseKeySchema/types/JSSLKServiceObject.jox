    <JadeMethod name="getManager" id="9ab0a580-c3cf-4cb2-9b0c-cedbd6b972c9">
        <source>getManager(): JSSLKServiceManager protected;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad1
//
// Purpose:		Reimplementation of the superschema's abstraction.
//
// Parameters:	None
//
// Returns:		A reference to the Service Manager object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myServiceManager.JSSLKServiceManager;
end;</source>
        <access>protected</access>
        <ReturnType type="JSSLKServiceManager"/>
    </JadeMethod>
    <JadeMethod name="getTA" id="8dc84025-c78e-400b-887f-e456491bc0e0">
        <source>getTA(): JSSLKTransactionAgent;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad1
//
// Purpose:		Reimplementation of the superschema's abstraction.
//
// Parameters:	None
//
// Returns:		A reference to the Transaction Agent object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myServiceManager.getTA().JSSLKTransactionAgent;
end;</source>
        <ReturnType type="JSSLKTransactionAgent"/>
    </JadeMethod>
