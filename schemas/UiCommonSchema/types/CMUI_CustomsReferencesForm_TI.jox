    <JadeMethod name="initEntTable" id="05105972-b9cf-494f-91e3-24f03c3ff8f1">
        <source>initEntTable(_table : CM_DataTable; _entTableDef : String) protected;
/*

Purpose:			Initializes an Ent Table from a definition and a view

Parameters:			_table			CM_DataTable	The Ent Table to set the view for
					_entTableDef	String			The Ent Table Def to use

Return Value:		NONE

Date		Who		Reason
18 November 2022	navpw1	Initial creation TFS: 55215

*/

vars
	theTable		: CM_DataTable;
	entTableDef		: EntTableDef;
	
begin
	theTable := _table;
	
	entTableDef := app.myController.getEntTableDef(_entTableDef);
	
	theTable.setTblDataEntRowsFromDef(entTableDef);
	
	theTable.stretchToParent := true;
	theTable.optimiseRowHeight := true;
	theTable.selectionType := theTable.SelectionType_Row;
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable"/>
        <Parameter name="_entTableDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="9b6ef41a-b81e-4b3d-b6af-741ba7cddb75">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 November 2022	navpw1	Initial creation TFS: 55215
20 March 2024		navlw1	ChangeRequest 62959: CUX FR | Tk 62917 - EDBIC Make Customs references editable

*/

vars
	row					: Integer;
	col					: Integer;
	gotException		: Boolean;
	table				: CM_DataTable;
	customsReference,
	pxyCustomsRef		: CM_CustomsReference;
	ti					: CM_TrackedItem;
	theDataLine			: String;
	
begin
	ti := self.myTrackedItem;
	on Exception do app.handleDeletedObject (exception, ti, gotException);
	
	// this next line will cause an exception if ti is invalid
	self.expectedEdition := ti.edition;
	
	if gotException then
		// display message and close form
		self.unloadFormWithMessage;
	endif;
	
	table 		:= self.tblData;
	table.rows	:= table.fixedRows;
	
	if ti.allCustomsReferences &lt;&gt; null then
		foreach customsReference in ti.allCustomsReferences do
			theDataLine := customsReference.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
			pxyCustomsRef := customsReference.pxyGetProxyObject();
			if pxyCustomsRef = null then
				pxyCustomsRef := app.createUpdateProxy(customsReference).CM_CustomsReference;
			endif;
			self.allProxyCustomsRefs.add(pxyCustomsRef);
			// we need to create a proxy for each item we add to the data table so that we can delete it etc
			row := self.tblData.addItemObject(pxyCustomsRef, theDataLine);
		endforeach;
	endif;
	
	if col &lt;&gt; null then
		table.sortColumn [1] := col;
		table.resort;
	endif;
	if self.allProxyCustomsRefs.isNotEmpty then
		table.selectRow(2, false);
		displaySelectedItem();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="removeItem" id="1fc3ad20-952a-45af-9180-8ac5928aa178">
        <updating/>
        <source>removeItem() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2024	navlw1	ChangeRequest 62959: CUX FR | Tk 62917 - EDBIC Make Customs references editable

*/

vars
	idx : Integer;
begin
	if self.mySelectedItem = null then
		app.msgBox('Please select an Item to remove', 'Select Item', 0);
		return;
	endif;
	self.tblData.findObjectInRow(self.mySelectedItem, idx);
	if idx &gt; 0 then
		self.tblData.removeItem(idx);
		if self.allProxyCustomsRefs.includes(self.mySelectedItem) then
			self.allProxyCustomsRefs.remove(self.mySelectedItem);
		endif;
		delete self.mySelectedItem;
		self.clearFormControls();
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resizeTable" id="2872cfb6-2bb9-4378-a948-caf4c3799484">
        <source>resizeTable(_table : CM_DataTable) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 November 2022	navpw1	Initial creation TFS: 55215
20 March 2024		navlw1	ChangeRequest 62959: CUX FR | Tk 62917 - EDBIC Make Customs references editable

*/

vars
	theTable	: CM_DataTable;
	
begin
	theTable				:= _table;
	theTable.left			:= 0;
	theTable.top			:= 0;
	theTable.height			:= self.clientHeight - 10;
	theTable.width			:= self.clientWidth  - 10;
	theTable.parentAspect	:= 3;
	
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="saveCustomsReferences" id="96913b3f-172a-42ea-a6fd-d4e6b893ee7a">
        <updating/>
        <source>saveCustomsReferences() : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2024	navlw1	ChangeRequest 62959: CUX FR | Tk 62917 - EDBIC Make Customs references editable
09 April 2024	navlw1 	Bug 63566: CUX - Code 75755 when adding a Customs Reference with Cargo Item in Edit Mode

*/

vars
	theReturn 						: Integer;
	invalid							: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myTrackedItem, invalid);
	if self.hasChanged then
		while true do
			app.myTrxCA.trxCreateCustomsReferences(self.allProxyCustomsRefs, self.myTrackedItem, app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(Customs_references), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
					theReturn = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return false;
			endif;
			break;
		endwhile;
		self.expectedEdition := self.myTrackedItem.edition;
		if invalid then
			return false;
		endif;
	endif;
	
	return true;
epilog
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSelectedItem" id="f323be0f-ef16-467b-8948-c56a8cf29783">
        <updating/>
        <source>setSelectedItem(_customsReference : CM_CustomsReference) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2024	navlw1	ChangeRequest 62959: CUX FR | Tk 62917 - EDBIC Make Customs references editable

