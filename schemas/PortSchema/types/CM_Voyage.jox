    <JadeMethod name="getMovementForDateTime" id="5fbc7229-2b1f-49aa-8802-e30c6484a6b7">
        <source>getMovementForDateTime(_dateTime : TimeStamp) : HMS_VoyageMovement;
/*
Purpose:		// TFS 40747 	
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/

vars
	tmpMovement	: HMS_Movement;

begin
	if self.myHMSVoyageData = null then
		return null;
	endif;

	if self.myHMSVoyageData.allVoyageMovements = null then
		return null;
	endif;
	
	if self.myHMSVoyageData.allVoyageMovements.size &lt; 1 then
		return null;
	endif;
	
	//match movement to date
	return self.myHMSVoyageData.allVoyageMovements.getAtKeyLeq(_dateTime);
	

end;
</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <ReturnType type="HMS_VoyageMovement"/>
    </JadeMethod>
    <JadeMethod name="getMovementForWorkOrder" id="590e128e-0a24-4d2a-b97f-f56323078551">
        <source>getMovementForWorkOrder(_workOrderId : String) : HMS_VoyageMovement;
/*

Purpose:	// TFS 40747  REPORT WRITER METHOD		

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2018	jlgab1	Initial creation

*/

vars
	workorder : CM_WorkOrder;
	occursdt : TimeStamp;
begin
	foreach workorder in self.allWorkOrders	discreteLock do
		if workorder.id = _workOrderId then
		//	occursdt:= workorder.getOccursDT();
		//	return self.getMovementForDateTime(occursdt);
			//27 Nov 2018	NDL	TFS 42166
			return workorder.getMyHMSVoyageMovement();
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_workOrderId" type="String"/>
        <ReturnType type="HMS_VoyageMovement"/>
    </JadeMethod>
    <JadeMethod name="getMovementShift" id="52411436-659e-48a6-b178-f43e790a0a74">
        <source>getMovementShift(_index : Integer) : HMS_VoyageMovement;
/*
Purpose:		Get the 1st, 2nd movement for the voyage	
Date				Who			Reason
JANUARY 2015		CNWAB1		Initial creation
*/

vars
	idx : Integer;
	move : HMS_VoyageMovement;
begin

	if self.myHMSVoyageData = null then
		return null;
	endif;
	
	foreach move in self.myHMSVoyageData.allVoyageMovements do
		if move.moveType = HMSMovementTypeShift then
			idx := idx + 1;
			if _index = idx then
				return move;
			endif;
		endif;
	endforeach;

	return null;
	
epilog

end;</source>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="HMS_VoyageMovement"/>
    </JadeMethod>
    <JadeMethod name="getMovesReadyForInvoicingStr" id="9cd7dbde-3a0c-4f26-ab88-d656a4e0ece0">
        <source>getMovesReadyForInvoicingStr() : String;
// ---------------------------------------------------------------------------
// Created:		04 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	aVM : HMS_VoyageMovement;
	str : String;
begin
	foreach aVM in self.myHMSVoyageData.allVoyageMovements do
		if aVM.moveStatusNEW &lt;&gt; MovementStatus_Actual then // PAR 10975
			if aVM.occursOnDTNEW &gt; app.actualTimeServer then// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				continue;
			endif;
		endif;
		
		str := str &amp; aVM.moveType &amp; " " ;
	endforeach;
	
	if str.trimBlanks &lt;&gt; null then
		str := str &amp; " movement(s)";
	endif;

	return str;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyBerth" id="7d3eae8d-46ff-4534-bd16-388d9a24edf7">
        <source>getMyBerth() : HMS_Berth;
//--------------------------------------------------
// Created:	05 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	obj		: Object;
	berth	: HMS_Berth;
begin
	if self.myHMSVoyageData = null then
		// CCMS 1124 log voyage berth saved in stopChargingAt
		if self.stopChargingAt &lt;&gt; null then
			obj := self.stopChargingAt.asObject();
			if obj &lt;&gt; null and global.isValidObject(obj) then
				if obj.isKindOf(HMS_Berth) then
					berth := obj.HMS_Berth;
				endif;
			endif;
		endif;
	else
		berth := self.myHMSVoyageData.getMyBerth();
	endif;
	
	return berth;
end;</source>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getMyCurrentBerth" id="5bc75409-9d42-4c34-be68-aed03b959d65">
        <source>getMyCurrentBerth() : HMS_Berth;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 06 June 2019
TFS#		: 44772
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	obj				: Object;
	berth			: HMS_Berth;
	voyageMovement 	: HMS_VoyageMovement;
	voyageData	   	: HMS_VoyageData;
begin
	if self.myHMSVoyageData = null then		
		if self.stopChargingAt &lt;&gt; null then
			obj := self.stopChargingAt.asObject();
			if obj &lt;&gt; null and global.isValidObject(obj) then
				if obj.isKindOf(HMS_Berth) then
					berth := obj.HMS_Berth;
				endif;
			endif;
		endif;
	else
		voyageData := self.myHMSVoyageData;
		
		if voyageData.allVoyageMovements &lt;&gt; null then
			foreach voyageMovement in voyageData.allVoyageMovements reversed do
				if voyageMovement.moveType = HMSMovementTypeArrival then
					berth := voyageMovement.getMyBerth();
					break;
				endif;
			endforeach;
		endif;
	endif;
	
	/*
	14.01.2022 navma1 Pending
	if voyageMovement &lt;&gt; null then
		prevMovement := voyageMovement.myPreviousMovement;
		if prevMovement &lt;&gt; null then
			if prevMovement.HMS_VoyageMovement.moveStatus = MovementStatus_Actual then
				berth := prevMovement.getMyBerth;
			else
				if prevMovement.moveType   = HMSMovementTypeArrival then
					if prevMovement.getMyBerth &lt;&gt; null and prevMovement.getMyBerth.isLogicalBerth then
						berth := prevMovement.getMyBerth;
					else
						seaHarbourRegion := app.myRoot.getSeaHarbourRegion();
						berth 			 := seaHarbourRegion.getArrivalBerth();
					endif;
				elseif   prevMovement.moveType   = HMSMovementTypeShift then
					secondPrevMovment := prevMovement.myPreviousMovement;
					if secondPrevMovment &lt;&gt; null then
						if secondPrevMovment.HMS_VoyageMovement.moveStatus = MovementStatus_Actual then
							berth := secondPrevMovment.getMyBerth;
							write berth.code;
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	14.01.2022 navma1 Pending
	*/
	return berth;
end;</source>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getMyDBLoadedEDIShipManifests" id="5fe52a81-82e0-42ca-889b-5de246d42862">
        <source>getMyDBLoadedEDIShipManifests(_ediDatas : CM_EDIDataArray io );
/*
Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
29 Oct 2024			navra1	Initial Creation for //navra1 - MTN-33087 - 23rd Oct 2024
14/07/2025			naviv1		MTN-35226	MTN - Usage of Iterator.getCurrentKeys  
*/
	
vars
	ediData		: CM_EDIData;
	ediConfig	: CM_EDIConfig;
	iter		: Iterator;
	keyType		: Integer;
	keyID		: Integer;
	
begin
	ediConfig := self.myTerminal.myEdiConfig;
	
	if ediConfig = null then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(ERR_NO_EDI_CONFIG));
		return;
	endif;
	
	iter := ediConfig.allEDIDatasByTypeNumber.createIterator();
	ediConfig.allEDIDatasByTypeNumber.startKeyGeq(EDIDataType_ShipManifest,0,iter);
	
	while iter.next(ediData) do	
		iter.getCurrentKeys(keyType,keyID); //MTN-35226
		
		if keyType &lt;&gt; EDIDataType_ShipManifest then
			break;
		endif;
		
		if ediData.CM_EDIDataShipManifest.getMyVoyageObject() &lt;&gt; null and ediData.CM_EDIDataShipManifest.getMyVoyageObject().code = self.code then
			if ediData.status = CM_EDIFile.EDI_STATUS_DBLOADED then
				_ediDatas.add(ediData);
			endif;
		endif;
	endwhile;
	
epilog
	delete iter;	
end;
</source>
        <Parameter name="_ediDatas" type="CM_EDIDataArray" usage="io"/>
    </JadeMethod>
