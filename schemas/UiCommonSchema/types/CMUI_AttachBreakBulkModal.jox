<GUIClass name="CMUI_AttachBreakBulkModal" id="c3524179-c695-4f83-b2a1-408174499a51">
    <superclass name="CMUI_AttachBreakBulk"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>The only reason for this subclass is so the MDIChild setting (not able to be set at run time)
can be set for the modal display neccessary from the gateIn screen where this form is used
to create CMIF_Attachments rather than real break bulks</text>
    <JadeMethod name="translateForm" id="fb988f8b-3409-4c40-afd8-f58fc7ac3ef7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017252, locale);
end;</source>
    </JadeMethod>
</GUIClass>
