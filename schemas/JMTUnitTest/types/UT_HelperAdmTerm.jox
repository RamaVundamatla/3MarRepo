    <JadeMethod name="xSetupTerminalConfigs" id="8452573b-52e4-4a33-841e-176cdac015bb">
        <source>xSetupTerminalConfigs(_configArr : StringArray; _value : Any; _terminal : CM_Terminal);
/*

Purpose:			Sets the terminal configs passed in to the value specified

Parameters:			_configArr	StringArray	
					_value		Boolean		
					_terminal	CM_Terminal	

Return Value:		NONE

Date		Who		Reason
14 November 2024	navpw1	Initial creation JIRA: MTN-14770

*/

vars
	currentConfigValue	: Any;
	configName			: String;
	
begin
	foreach configName in _configArr do
		currentConfigValue := _terminal.getConfig(configName).Any;
		if currentConfigValue = _value then
			continue;
		endif;
		
		self.setTerminalConfig(configName, _value);
	endforeach;
	
end;</source>
        <Parameter name="_configArr" type="StringArray"/>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="xSetupVbsProcess" id="3b162905-1b0a-4675-b3f4-a39b37f087c5">
        <source>xSetupVbsProcess(_vbsProcess : CM_VBSProcess; _terminal : CM_Terminal input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 November 2024	navpw1	Initial creation JIRA: MTN-14770

*/

vars
	completedOk : Boolean;
	
begin
	beginTransaction;
	_terminal.setPropertyValue(CM_Terminal::myVBSProcess.name, _vbsProcess);
	commitTransaction;
	
	completedOk := true;
	
epilog
	if not completedOk then
		abortTransaction;
	endif;
	
end;</source>
        <Parameter name="_vbsProcess" type="CM_VBSProcess"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
    </JadeMethod>
    <JadeMethod name="xUpdateGateEntityOutRelease" id="02156dba-90e8-430c-96b8-120f7b1b903c">
        <source>xUpdateGateEntityOutRelease(_vvr : CM_VehicleVisitRecord input;
						_pxyGteEntityRelease : CMGTE_Release input
						): CMGTE_Release;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2024	navpw1	Initial creation TFS: 65623 (65624)

*/

vars
	realGteRelease	: CMGTE_Release;
	
begin
	self.assertTrueMsg(_pxyGteEntityRelease.isTransient, "Expected _pxyGteEntityRelease to be a transient");
	self.assertTrueMsg(_pxyGteEntityRelease.pxyIsProxy, "Expected _pxyGteEntityRelease to be a proxy");
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateInOutFlexiGateEntity(_vvr, _pxyGteEntityRelease, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(_pxyGteEntityRelease, "_pxyGteEntityRelease");
	
	realGteRelease := _pxyGteEntityRelease.pxyGetRealObject();
	self.assertNotNullMsg(realGteRelease, "realGteRelease");
	
	return realGteRelease;
	
epilog
	
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_pxyGteEntityRelease" type="CMGTE_Release" usage="input"/>
        <ReturnType type="CMGTE_Release"/>
    </JadeMethod>
    <JadeMethod name="xUpdateVbsTimeSlot" id="ab6fb1ae-9cbb-4453-9242-0a87226c1773">
        <source>xUpdateVbsTimeSlot(_realVbsTimeSlot : CM_VehicleBookingTimeSlot; _tsStart, _tsEnd : TimeStamp; _vehicleBookingTerminal : CM_VehicleBookingTerminal;
					_carrier, _subCarrier : CM_Carrier; _driver : CM_DriverDetails; _vehicle : CM_Vehicle;
					_remarks : String; _includesDelivering, _includesPickUp : Boolean; _ids : StringArray;
					_vvr : CM_VehicleVisitRecord; _vbsTimeSlotType : CM_VehicleBookingTimeSlotType;
					_id : String; _allBookingRefs : CM_BookingRefSet; _allBulkReleases : CM_BulkReleaseSet;
					_allVbsTimeSlotItems : CM_VehicleBookingTSItemSet; 
					_preGateInCheck, _preGateOutChck, _kioskCheck : Boolean;
					_externalReference : String; _myTILCType : CM_TILCType) : CM_VehicleBookingTimeSlot;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navpw1	Initial creation TFS: 54049 (55844)

*/

vars
	proxyVbsTimeSlot : CM_VehicleBookingTimeSlot;
	
begin
	proxyVbsTimeSlot := app.createUpdateProxy(_realVbsTimeSlot).CM_VehicleBookingTimeSlot;
	
	proxyVbsTimeSlot.setProxy(_tsStart, _tsEnd, _vehicleBookingTerminal, _carrier, _subCarrier, _driver, _vehicle, _remarks, _includesDelivering,
								_includesPickUp, _ids, _vvr, _vbsTimeSlotType, _id, _allBookingRefs, _allBulkReleases, _allVbsTimeSlotItems, 
								_preGateInCheck, _preGateOutChck, _kioskCheck, _externalReference, _myTILCType);
	
	app.myTrxUA.trxUpdateVehicleBooking(proxyVbsTimeSlot, _ids, null, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertNotNullMsg(proxyVbsTimeSlot, "proxyVbsTimeSlot");
	
	return _realVbsTimeSlot;
	
epilog
	delete proxyVbsTimeSlot;
	
end;</source>
        <Parameter name="_realVbsTimeSlot" type="CM_VehicleBookingTimeSlot"/>
        <Parameter name="_tsStart" type="TimeStamp"/>
        <Parameter name="_tsEnd" type="TimeStamp"/>
        <Parameter name="_vehicleBookingTerminal" type="CM_VehicleBookingTerminal"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_subCarrier" type="CM_Carrier"/>
        <Parameter name="_driver" type="CM_DriverDetails"/>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_includesDelivering" type="Boolean"/>
        <Parameter name="_includesPickUp" type="Boolean"/>
        <Parameter name="_ids" type="StringArray"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_vbsTimeSlotType" type="CM_VehicleBookingTimeSlotType"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_allBookingRefs" type="CM_BookingRefSet"/>
        <Parameter name="_allBulkReleases" type="CM_BulkReleaseSet"/>
        <Parameter name="_allVbsTimeSlotItems" type="CM_VehicleBookingTSItemSet"/>
        <Parameter name="_preGateInCheck" type="Boolean"/>
        <Parameter name="_preGateOutChck" type="Boolean"/>
        <Parameter name="_kioskCheck" type="Boolean"/>
        <Parameter name="_externalReference" type="String"/>
        <Parameter name="_myTILCType" type="CM_TILCType"/>
        <ReturnType type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
    <JadeMethod name="xUpdateWorkOrder" id="d35b59f8-bccd-431c-bf9c-731ce0b65caf">
        <source>xUpdateWorkOrder(_pxyWorkOrder : CM_WorkOrder io;
				_realWorkOrder : CM_WorkOrder io;
				_id 		   : String;
				_woStatus 	   : Integer;
				_tiSet 		   : CM_TISet;
				_allWod		   : CM_WorkOrderDtlArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
26 Mar 2024	navpw1	TFS: 62849 (62927) - Reverted Code by changing call to trxUpdateWorkOrder

*/

vars
	remarks	 	  : String;
	totalReq      : Integer;
	dtRequired,
	dtStart	      :	TimeStamp;
	emails   	  : CM_EmailEntityByTypeNameDict;
begin
	

	if self.opts.includesKey("Remarks") then
		remarks := self.opts.str("Remarks");
	endif;
	create emails transient;
	
	_pxyWorkOrder.setProxy(		
			emails, 							//_allEmailAddresses
			null, 								//_customerReference
			false, 								//_emailNotification
			app.actualTimeServer, 				//_enteredByDT
			app.getMyUser(), 					//_enteredByUser 
			'',									//_approvedBy
			app.getMyUser().myOrganisation, 	// _myOrganisation
			app.myPassport.myTerminal, 			//_myTerminal
			remarks,  							//_remarks
			dtRequired,							//_requiredByDT
			dtStart, 							//_startAtDT
			_woStatus 							//_taskStatus    WO_STATUS_USERENTRY
			);
			
			
	_pxyWorkOrder.setID( _id );						
	//_pxyWorkOrder.CM_WorkOrderTI.setTotalRequired(totalReq);					///08.02.2023 navma1 #56457:[56458]
	app.myTrxUA.trxUpdateWorkOrder(_pxyWorkOrder,true,app.myPassport);			//12.01.2023 navma1 #56141 Task#56147
	
	if app.myPassport.noErrors then
		_realWorkOrder := _pxyWorkOrder.pxyGetRealObject();
	endif;
epilog
	delete emails;
	_pxyWorkOrder.allWoDtls.purge;
	delete _pxyWorkOrder;
end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrder" usage="io"/>
        <Parameter name="_realWorkOrder" type="CM_WorkOrder" usage="io"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_woStatus" type="Integer"/>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_allWod" type="CM_WorkOrderDtlArray"/>
    </JadeMethod>
