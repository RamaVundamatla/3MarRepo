    <JadeMethod name="updateFulfilledStatus" id="ecd132aa-1939-44ed-97cb-2b9124cfa485">
        <updating/>
        <source>updateFulfilledStatus(_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     30 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	bolOutLine				: CM_BOLOutStockOrderLineTI;
	orderLine				: CM_StockOrderLine;
	totalPercent			: Decimal[16,2];
	percent			: Decimal[5,2];
	noLines,
	noFulfilled,
	fulfilledCount			: Integer;
	
begin
	if self.allStockOrderLines.isEmpty then
		return;
	endif;
	
	foreach orderLine in self.allStockOrderLines do
		foreach bolOutLine in orderLine.allBOLOutStockOrderTIs do
			noLines := noLines + 1;
			if bolOutLine.myTrackedItem &lt;&gt; null then
				noFulfilled := noFulfilled + 1;
			endif;
		endforeach;	
	endforeach;
	
	percent := ((noFulfilled / noLines) * 100).roundedTo(2);
	
	if percent &gt;= 100 then
		percent := 100;
		self.fulfilledDT := app.actualTimeServer();
		self.fulfilledStatus := OrderStatus_Fulfilled;
	elseif percent &gt; 0 then
		self.fulfilledDT := null;
		self.fulfilledStatus := OrderStatus_Partial;
	else
		percent := 0;
		self.fulfilledDT := null;
		self.fulfilledStatus := OrderStatus_Unfulfilled;
	endif;
	
	self.percentFulfilled := percent;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateDetailsUnique" id="538f6673-ac19-469d-b603-af770340d411">
        <source>validateDetailsUnique();
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pxyLine		: CM_StockOrderLine;
	product		: CM_Product;
	products	: CM_ProductSet;

begin
	self.raiseExceptionIfNotTransient(method);
	
	create products transient;

	foreach pxyLine in self.allStockOrderLines do
		if pxyLine.isKindOf(CM_StockOrderProductLine) then
			product := pxyLine.CM_StockOrderProductLine.myProduct;
			if product = null then
				continue;
			endif;
			
			if products.includes(product) then
				app.raiseCMWarning2(OrderLineNotUnique, app.getErrorString(Product),
						product.code, null, null, self);
			else
				products.add(product);
			endif;
		endif;
	endforeach;
	
epilog
	delete products;
end;</source>
    </JadeMethod>
