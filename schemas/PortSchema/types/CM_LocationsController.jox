    <JadeMethod name="getSOHLevelsForDate" id="1c2ed340-a2ae-4887-9b84-1b1c460a35b6">
        <source>getSOHLevelsForDate(_date 				: Date; 
					_closingLevel 		: Boolean; 
					_totalQuantity		: Integer io;
					_totalVolume		: Decimal io;
					_totalWeight		: Decimal io);
// ---------------------------------------------------------------------------
// Created:     31 July 2002 by cnwth2
// ---------------------------------------------------------------------------
vars
	sohLocation		: CM_SOHLocation;
	
begin
	if _closingLevel and _date &gt;= app.actualTimeServer.date then
		// make do with current actual quantities for future dates 
		_totalQuantity	:= _totalQuantity 	+ self.getQuantityActual();
		_totalVolume	:= _totalVolume 	+ self.getTotalVolumeActual();
		_totalWeight 	:= _totalWeight 	+ self.getTotalWeightActual();
		return;
	endif;
	
	foreach sohLocation in self.allProductLocations do
		sohLocation.getSOHLevelsForDate(_date, _closingLevel, _totalQuantity, _totalVolume, _totalWeight);
	endforeach;
end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_closingLevel" type="Boolean"/>
        <Parameter name="_totalQuantity" type="Integer" usage="io"/>
        <Parameter name="_totalVolume" type="Decimal" usage="io"/>
        <Parameter name="_totalWeight" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getSOHLevelsNoProduct" id="e827b7b6-3541-4fc8-85ec-861765b5cb28">
        <source>getSOHLevelsNoProduct(_closingLevel 	: Boolean; 
					_totQty				: Integer io;
					_totVol				: Decimal io;
					_totWeight 			: Decimal io);
// ---------------------------------------------------------------------------
// Created:     31 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------
vars
	ti			: CM_TrackedItem;
	tot			: Integer;
	loadState	: Boolean;
begin


	app.cmsBeginLoad(loadState);
	foreach ti in self.allTrackedItems where ti.myProduct = null do
		_totQty := _totQty + ti.quantity;
		_totVol	:= _totVol + ti.getMyTotalVolume;
		//_totWeight := _totWeight + ti.weight;					//-cnwml2 MSL CCMS 1017
		_totWeight := _totWeight + ti.totalWeight;				//+cnwml2 MSL CCMS 1017
	endforeach;
	
epilog
	app.cmsEndLoad(loadState);
end;</source>
        <Parameter name="_closingLevel" type="Boolean"/>
        <Parameter name="_totQty" type="Integer" usage="io"/>
        <Parameter name="_totVol" type="Decimal" usage="io"/>
        <Parameter name="_totWeight" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getSOHLocationForProduct" id="34fe04e7-5c87-4054-847f-f085efc29dd2">
        <source>getSOHLocationForProduct(_product : CM_Product) : CM_SOHLocation;
// ---------------------------------------------------------------------------
// Created:     27 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpSOHLocation	: CM_SOHLocation;

begin

	if _product = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to create SOHLocation for null product');
		return null;
	endif;

	tmpSOHLocation := self.allProductLocations[_product];
	if tmpSOHLocation = null then
		create tmpSOHLocation persistent;
		tmpSOHLocation.setForCreate(self, _product);
	endif;
	
	return tmpSOHLocation;

end;</source>
        <Parameter name="_product" type="CM_Product"/>
        <ReturnType type="CM_SOHLocation"/>
    </JadeMethod>
    <JadeMethod name="getSOHValuesForProduct" id="0ed926ab-9aac-4999-a39b-e164fcad5706">
        <source>getSOHValuesForProduct(_product : CM_Product; _quantity: Integer output; _weight: Decimal output; _volume: Decimal output);
// ---------------------------------------------------------------------------
// Created:     23 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	sohLocn	: CM_SOHLocation;

begin

	sohLocn := self.allProductLocations[_product];
	if sohLocn &lt;&gt; null then
		_quantity	:= sohLocn.currentQuantity;
		_weight		:= sohLocn.currentWeightKgs;
		_volume		:= sohLocn.currentVolume;
	endif;

end;</source>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_quantity" type="Integer" usage="output"/>
        <Parameter name="_weight" type="Decimal" usage="output"/>
        <Parameter name="_volume" type="Decimal" usage="output"/>
    </JadeMethod>
