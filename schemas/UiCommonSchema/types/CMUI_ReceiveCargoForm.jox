    <JadeMethod name="btnWeigh_click" id="84de33ed-e9b4-4a87-b05c-d0626aa7db49">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnWeigh_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2014	cnwndl1	Initial creation

*/

vars

	tiId : String;
	cargoType : CM_CargoType;
	product : CM_Product;
	preNote : CM_TrackedItem;

begin

	tiId := self.txtCargoID.getString.trimBlanks;

	if tiId &lt;&gt; null then
		product := self.cmbProdType.getObject.CM_Product;
		cargoType := self.cmbType.getObject.CM_CargoType;
		
		//13 May 2020	NDL	TFS 49296 - The data on the form is based on a pre-note
		if self.hasPreNote() then
			preNote := self.myTI;
			if preNote &lt;&gt; null then
				self.myAssistant.showWeighForm( self, preNote, preNote.id, null );
				return;
			endif;
		endif;
	
		if product &lt;&gt; null then
			self.myAssistant.showWeighForm( self, product, tiId, null );
		elseif cargoType &lt;&gt; null then
			self.myAssistant.showWeighForm( self, cargoType, tiId, null );
		endif;
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildLocationCombo" id="3793f67c-5d39-47c9-83b3-87ea6ebf7319">
        <source>buildLocationCombo() protected;
// ** to be reviewed
vars
	tmpDict : CM_GeneralCCtrByHatchPlaceDict;
	locn : CM_LocationsController;
	bay	  : CM_BayVoyage;
	sc	  : CM_SlotController;
begin

	self.cmbCargoLocation.clear();
	
	if self.myVoyage = null then
		return;
	endif;
	if self.myVoyage.myShipBlockStack &lt;&gt; null then
		// ship block stack id is null - prefixed by voyage code when finding location, which finds it OK
		self.cmbCargoLocation.addItemObject("", self.myVoyage.myShipBlockStack);
	endif;
	
	if self.myVoyage.myGeneralCargoVoyage &lt;&gt; null then
		tmpDict := self.myVoyage.myGeneralCargoVoyage.allLocationsByHatchPlace;
		foreach locn in tmpDict discreteLock, reversed do
			self.cmbCargoLocation.addItemObject(locn.getID().replaceString("/", " "), locn);		
		endforeach;

	elseif self.myVoyage.myCellularVoyageStructure &lt;&gt; null then
		foreach locn in self.myVoyage.allVoyageLocations do
			self.cmbCargoLocation.addItemObject(locn.getStowageId(locn.allTrackedItems.first), locn);		
		endforeach;
	endif;
	
	if self.cmbCargoLocation.getEmbeddedControl.CMUI_FieldComboBoxControl.listCount &gt; 0 then
		self.cmbCargoLocation.getEmbeddedControl.CMUI_FieldComboBoxControl.listIndex := 1;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="calculateTotalWeight" id="d88aa347-4def-4bcc-a597-5a0d08e7dc7b">
        <updating/>
        <source>calculateTotalWeight( _fromControl : Control ) updating, protected;
/*
Date		Who		Reason
18/09/2009	cnwdap1	Initial creation
12/10/2009	cnwdap1	PAR #20832 Correct Total Weight handling when both Nett and Tare are entered
18/03/2010	cwnmh5	PAR #22546 - Bypass exception when cargo/tare weight length &gt; txtTotalWeight
						which is being caught when validation is done
27/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
24/06/2013	cnwcs5	par 31758 - if total weight entered and cargo weight not entered then calculate cargo weight
16 Jul 2013	NDL	Par 32006 - Didn't work for empty receivals.  I.e. Tare weight and No cargo weight, also should recalc unconditionally based
							on the field you are leaving if in Nett or Total weight
25/03/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk - if cargo type is bulk and tracked by weight, calculate and set total volume if we have a density
*/
vars
	totalWeight, nettWeight	: Decimal[23,10];		// PAR #31155
	totWeightExceedsLength	: Boolean;		
	hasTotal, hasNett		: Boolean;
	cargoType				: CM_CargoType;			// PAR #33606
	product					: CM_Product;			// PAR #33606
	volume					: Decimal [16,8];		// PAR #33606
	weight					: Decimal [16,8];		// PAR #33606
	density					: Decimal [16,8];
begin
	on Exception do handleException(exception, totWeightExceedsLength);				
	
	hasTotal	:= self.tblTotalWeight.getRawValue &lt;&gt; null; 
	hasNett		:=not self.tblNettWeight.isHidden and self.tblNettWeight.getRawValue &lt;&gt; null; 
	
	//if hasNett and not hasTotal then
	if hasNett and not hasTotal or _fromControl = self.tblNettWeight then	//16 Jul 2013	NDL	Par 32006
		// 10/12/2010 cnwar2 #26541 - recalculate total weight regardless
		totalWeight := (self.tblNettWeight.getConvertedValue + self.tblTareWeight.getConvertedValue);	// PAR #31155
		
		if totalWeight &gt; 0 then
			self.tblTotalWeight.setValueDefault(totalWeight.String);													// PAR #31155
		endif;
	//elseif hasTotal and not hasNett then
	elseif hasTotal and not hasNett or _fromControl = self.tblTotalWeight then	//16 Jul 2013	NDL	Par 32006
		if not self.tblNettWeight.isHidden then
			nettWeight := (self.tblTotalWeight.getConvertedValue - self.tblTareWeight.getConvertedValue);	
			
			if nettWeight &gt; 0 then
				self.tblNettWeight.setValueDefault(nettWeight.String);													
			endif;
		endif;
	
	//16 Jul 2013	NDL	Par 32006 - MT container has Tare weight and No cargo weight and No Total weight, Total weight s/be Tare weight.
	elseif not hasTotal and not hasNett then
		if not self.tblTareWeight.isHidden then
			totalWeight := self.tblTareWeight.getConvertedValue;
			if totalWeight &gt; 0 then
				self.tblTotalWeight.setValueDefault(totalWeight.String);
			endif;
		endif;
	endif;
	
	// PAR #33606 are we a bulk cargo type, and do we have a density?
	cargoType := self.cmbType.getObject().CM_CargoType;
	if cargoType &lt;&gt; null and cargoType.isBulkProduct then
		if not self.cmbSubCargo.isHidden then
			product := self.cmbSubCargo.getObject.CM_Product;
		else
			product := cargoType.mySystemProductType;
		endif;
		if product &lt;&gt; null and product.myDensityDec.value &lt;&gt; null then			// ### TFS 52193 22Nov2021 NAVPW1
			//epr TFS 7756 if we are showing density then have to change the weight when this changes
			density:=product.myDensityDec.value;								// ### TFS 52193 22Nov2021 NAVPW1
			if not self.tblDensity.isHidden then		
				if self.tblDensity.getConvertedValue &lt;&gt; null then
					density:=self.tblDensity.getConvertedValue;
				endif;
			endif;	
			
			if _fromControl = self.tblTotalVolume then
				// calculate total weight
				weight := self.tblTotalVolume.getConvertedValue * density;
				self.tblTotalWeight.setValue(weight);
			else
				// calculate total volume
				volume := self.tblTotalWeight.getConvertedValue / density;
				self.tblTotalVolume.setValue(volume);
			endif;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_fromControl" type="Control"/>
    </JadeMethod>
    <JadeMethod name="checkHasChanged" id="b8fac953-fe17-49ea-95c9-e81d8bcd5e04">
        <source>checkHasChanged(_changedProperties : PropertySet io) : Boolean protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2009	cnwdap1	Initial creation
*/
vars
	versionChecker 		: CM_DisplayVersionChecker;
	tempTrackedItem		: CM_TrackedItem;

begin
	
	if self.myProxyTrackedItem = null or self.isFlexiGateForm then
		return false;
	endif;
	
	create versionChecker transient;
	create tempTrackedItem as self.myProxyTrackedItem.class transient;
	self.saveDataToProxyTrackedItem(tempTrackedItem);
	
	versionChecker.init(self.myProxyTrackedItem, tempTrackedItem);
	if versionChecker.allChangedProperties.size &gt; 0 then
		if _changedProperties &lt;&gt; null then
			versionChecker.getAllChangedProperties(_changedProperties);
		endif;
		if app.isSpecial then
			versionChecker.writeChangedProperties();
		endif;
		if _changedProperties &lt;&gt; null then
			return true;
		endif;
	endif;
	
	return false;
	
epilog
	if versionChecker &lt;&gt; null then
		delete versionChecker;
		delete tempTrackedItem;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_changedProperties" type="PropertySet" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkIMEXvalue" id="46e74b2d-87de-4237-8df7-c4be691e750b">
        <source>checkIMEXvalue();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2013	cnwndl1	Initial creation	Par 32154

*/

vars

	localPortString : String;
	theLocalPort : CM_Port;
	dischargePort : CM_Port;
	imex : CM_IMEXStatus;

begin

	if self.isOnshipForm then
		if self.updateMode &lt;&gt; self.Mode_Update then
		
			localPortString 	:= self.myTerminal.getConfig(PortDestCode).String;
			if localPortString &lt;&gt; null then
				theLocalPort := app.myRoot.allPorts[localPortString];
			endif;
			//we are in creating cargo directly on a ship
			dischargePort := self.cmbDischargePort.listObject.CM_Port;
			
			if dischargePort = theLocalPort then
				self.cmbImexStatus.setForObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT]);
			else
				self.cmbImexStatus.setForObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_REMAINONBOARD]);
				if self.cmbImexStatus.getObject = null then
					imex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_REMAINONBOARD];
					self.cmbImexStatus.addItemObject(imex.description, imex);
					self.cmbImexStatus.setForObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_REMAINONBOARD]);
				endif;
			endif;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="checkSectionState" id="27ec26fe-3841-4024-a231-9d736db3ca0a">
        <updating/>
        <source>checkSectionState() updating, protected;
/*
Purpose:			Checks state of an opened/closed section - primarily for cargo type/sub cargo type
					changes, where changing the cargo type displays the dimension details by
					leaves the dimension button and boolean in the incorrect state

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2009	cnwdap1	Initial creation
*/
vars

begin
	inheritMethod();

	if self.closedCargo and not self.lblCargoDetails.visible then
		self.closedCargo := false;
	elseif self.closedDimensions and not self.lblDimensions.visible then
		self.closedDimensions := false;
	elseif self.closedReefer and not self.lblReeferDetails.visible then
		self.closedReefer := false;
	elseif self.closedVoyage and not self.lblVoyageDetails.visible then
		self.closedVoyage := false;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
