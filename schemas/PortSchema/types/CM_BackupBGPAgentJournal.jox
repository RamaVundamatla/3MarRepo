<Class name="CM_BackupBGPAgentJournal" id="0e59c160-c162-4b3b-97e4-0237376ddc70">
    <superclass name="CM_BackupBGPAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backup"/>
    <JadeMethod name="finalizeAgent" id="198ffb1c-375e-4c0f-bab9-3a305fba679e">
        <updating/>
        <source>finalizeAgent() updating;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	app.myRoot.myBackup.finalizeJournalBackup;
	delete self.myDBA;
end;</source>
    </JadeMethod>
    <JadeMethod name="initializeAgent" id="4df1e785-cdc5-4908-8c68-291a808037a9">
        <updating/>
        <source>initializeAgent() updating;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if not self.isValidToBackup then
		return;
	endif;
	if app.myRoot.myBackup = null then
		self.raiseAlert("Journal Backup Failed","Database journal backup initailize has failed. Backup not setup.",SEVERE_ERROR);
	else
		if self.myDBA = null then
			create self.myDBA transient;
		endif;
		app.myRoot.myBackup.initializeJournalBackup;
	endif;
end;</source>
    </JadeMethod>
</Class>
