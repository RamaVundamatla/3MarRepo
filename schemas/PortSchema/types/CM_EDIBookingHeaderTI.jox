    <JadeMethod name="canUserSet" id="0ccf0351-772b-428d-a1b6-37374c2a7d08">
        <source>canUserSet(_propName: String): Boolean;
//
// 30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
vars

begin
	if _propName = CM_EDIBookingHeaderTI::myBookingRef.name or
	   _propName = CM_EDITrackedItem::cargoTypeDescr.name or
	   _propName = CM_EDIBookingHeaderTI::rawVoyageCode.name then
		return false;
	elseif _propName = CM_EDITrackedItem::subTerminalCode.name then	// Booking Item/Release Request is allowed to use this field
		return true;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cargoTypeDescr" id="8e07dd5b-ecbf-4c5e-81fe-f8870e4e59d6">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>cargoTypeDescr(set : Boolean; _value : String io) mapping, updating;
///
// cnwrs1 sept 2009 CCMS Messina 1008 par21718
//
vars
	cType : CM_CargoType;
	int : Integer;
begin
	if set then
		int := app.myRoot.getCargoTypeIDFromDescription(_value);
		if int &lt;&gt; 0 then
			self.cargoType := int;
		endif;
	else
		cType := app.myRoot.allCargoTypesById[self.cargoType];
		if cType &lt;&gt; null then
			_value := cType.description;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="create" id="eb9ac798-8f08-4f17-84c3-1058c499d4df">
        <updating/>
        <source>create() updating;
//
// cnwrs1 sept 2009 CCMS Messina 1008 par21718
//
vars

begin
	self.messageMode 	:= 'A'; //par 21396 cnwrs1 oct 2009
	self.cargoType 		:= TI_CargoType_Container;
end;
</source>
    </JadeMethod>
    <JadeMethod name="delete" id="38982ea6-9173-4b56-8bab-39da87f4189b">
        <updating/>
        <source>delete() updating;

/*
Date			Who		Reason
14 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
*/
	
vars
	voyageCodeStr	: String;
	
begin
	// remove this EDITrackedItem from the manual collection on myEDIConfig if it is there
	if self.myEDIConfig = null then
		return;
	endif;
	
	voyageCodeStr	:= self.getRawVoyageCode();
	if voyageCodeStr &lt;&gt; null then
		if self.myEDIConfig.allEDITrackedItemsByVoyageCode.includesKey( voyageCodeStr.toUpper, self ) then
			self.myEDIConfig.allEDITrackedItemsByVoyageCode.removeKeyEntry( voyageCodeStr.toUpper, self, self );
		endif;
	endif;
	
	voyageCodeStr	:= self.getTranshipOriginalVoyage();
	if voyageCodeStr &lt;&gt; null then
		if self.myEDIConfig.allEDITrackedItemsByVoyageCode.includesKey( voyageCodeStr.toUpper, self ) then
			self.myEDIConfig.allEDITrackedItemsByVoyageCode.removeKeyEntry( voyageCodeStr.toUpper, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="destinationPort" id="725b892f-e43a-42ac-a327-8d0b26279a1f">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>destinationPort(set: Boolean; _value: String io) updating, mapping;
//
// cnwrs1 sept 2009 CCMS Messina 1008 par21718
//
vars
	port : CM_Port;
begin
	if set then
		// make sure is upper case only
		_value			:= _value.toUpper;
		self.destinationPort	:= _value;
	else
		if self.destinationPort.length = 3 then
			port := app.myRoot.allLocodesByShortCode.getAtKeyGeq(self.destinationPort, null);
			if port &lt;&gt; null and port.portCode = self.destinationPort then
				_value := port.code;
			else
				_value := self.destinationPort;
			endif;
		else
			_value := self.destinationPort;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="dischargePort" id="5b7a1bc9-554c-41a0-a92a-d9900617c251">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>dischargePort(set: Boolean; _value: String io) updating, mapping;
//
// cnwrs1 sept 2009 CCMS Messina 1008 par21718
//
vars
	port : CM_Port;
begin
	if set then
		// make sure is upper case only
		_value			:= _value.toUpper;
		self.dischargePort	:= _value;
	else
		if self.dischargePort.length = 3 then
			port := app.myRoot.allLocodesByShortCode.getAtKeyGeq(self.dischargePort, null);
			if port &lt;&gt; null and port.portCode = self.dischargePort then
				_value := port.code;
			else
				_value := self.dischargePort;
			endif;
		else
			_value := self.dischargePort;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findRealBookingRef" id="31c9f6f0-c381-4557-8659-80809c8fc4cd">
        <source>findRealBookingRef( _terminal : CM_Terminal ) : CM_BookingRef;
///
// cnwrs1 sept 2009 CCMS Messina 1008 par21718
//
vars
	br						: CM_BookingRef;
	voyage					: CM_Voyage;
	misVersionBookingRef	: Boolean;
	
begin
	misVersionBookingRef := _terminal.getConfig(ProcessMISVersionBkRef).Boolean;
	
	if self.getVoyageCode().trimBlanks = null then
		// get the terminals null voayage
		voyage	:= _terminal.getNullVoyage;
	else
		// attempt to find the voyage and not archived.
		voyage	:= _terminal.lookupVoyage( self.getVoyageCode().trimBlanks, null, false );
	endif;
	
	br := _terminal.getBookingReference(self.operatorCode, self.getId(misVersionBookingRef), voyage);

	return br;
end;
</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
