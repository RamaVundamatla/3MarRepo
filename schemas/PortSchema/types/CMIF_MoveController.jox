    <JadeMethod name="addToRTQueue" id="87493ad8-3681-44f7-9855-811a4008bb31">
        <updating/>
        <source>addToRTQueue(_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31/07/2019	jlgzm1		TFS 42863 Direct Release Between RORO Voyages and Rail - Break Bulk
// 30/06/2025 	navma1		 MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev
// 28/10/2025	jlizm1		MTN 36255 Rotabox Assign Release To Vessel
// ---------------------------------------------------------------------------

vars
	anArbiter				: CM_RTQueueArbiter;
	drWLE 					: CM_WorkListEntry; // TFS 42863
	dRLinkedVoyageJob		: CM_VoyageJob;
	rtQueueEntry 			: CM_RTQueueEntry;
	rtQueueTask 			: CM_RTQueueTask;
	imvMachine				: CM_Machine;
	machineLC 				: CM_MachineController;
	moveController 			: CMIF_MoveController;
	priorLC 				: CM_LocationsController;
begin
	
	if self.doNotAddQueuedMovesToRTQueue then
		return;
	endif;
	
	if self.isUndoMove then
		return;
	endif;
	
	if self.moveMode &lt;&gt; QUEUE_MODE then
		return;
	endif;
		
	// Have create arbiter so it can carry the queue for sending event.
	anArbiter := self.getRTQueueArbiter();
	app.writeLog(method.name &amp; Tab &amp; self.myWorkListEntry.String, LogINFO);	
	if self.myWorkListEntry &lt;&gt; null then
		
		// Direct Release Moves have a WLE on both sides of the move
		// If one of these is a voyage wle, will want to use that one
		// for queueing, so that it uses a voyage queue where needed
		dRLinkedVoyageJob := self.myWorkListEntry.getDRLinkedVoyageJob();	//30.06.2025 navma1 #MTN-34090
		if dRLinkedVoyageJob &lt;&gt; null then									// TFS 42863
			anArbiter.job := dRLinkedVoyageJob;								// TFS 42863
		else																// TFS 42863
			anArbiter.job := self.myWorkListEntry.job;
		endif;																// TFS 42863
		self.myWorkListEntry.enqueueWLE(anArbiter);
			
		//jlier1 JIRA-36155 14/10/25
		if not _passport.hasErrors then
			if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isOnSite and  self.myTrackedItem.isRotatableContainer  then
				priorLC:=	self.myTrackedItem.getPriorLocationLC;
				if priorLC &lt;&gt; null and priorLC.isMachineController then
					machineLC:=priorLC.CM_MachineController;
					if machineLC.myMachine.isIMV then
						imvMachine:=machineLC.myMachine;
					endif;
				endif;
				app.writeLog(method.name &amp; "Proir LC"   &amp; Tab &amp; self.myTrackedItem.priorLocation, LogINFO);
			endif;
			
			app.writeLog(method.name &amp; "Proir LC2"   &amp; Tab &amp; priorLC.String, LogINFO);
			
			if imvMachine &lt;&gt; null then
				
				rtQueueEntry:=self.myWorkListEntry.getFirstUncompleteRTEntry;
				if rtQueueEntry &lt;&gt; null then
					rtQueueTask:=rtQueueEntry.allTasks.first;
					//10 Nov 2025 jlier1	MTN-36536 	if the first task is an unactioned move task move back onto the imv and accept
					if rtQueueTask &lt;&gt; null and rtQueueTask.isMove and rtQueueTask.status = TASK_UNACTIONED and rtQueueTask.machine = null then
						//came from an IMV - which is now in transfer area 
						//if the next move is IMV -&gt; and move it back on 
						// now will be in the transfer area so this won't work
						create moveController transient;
						moveController.setMyTrackedItem(self.myTrackedItem);
						moveController.setMyToPrimaryLocation(imvMachine.myMachineController);
						moveController.setMoveMode(REAL_MODE);
						app.myUtilityUA.utlUpdateMoveTrackedItem(moveController,_passport);
						if _passport.hasErrors then
							app.writeLog(method.name &amp; Tab &amp; _passport.getAllErrorsAndWarningsAsStr, LogINFO);
							return;
						endif;
						
						app.myUtilityUA.utlChangeTaskStatus(rtQueueTask,imvMachine,TASK_WORKING,_passport);	
					endif;
				endif;	
		endif;
	endif;
		
		
	elseif self.jobForMove &lt;&gt; null and not self.isOverstowMove and not self.isDirectorMove then
		//anArbiter can be null as it gets created and set in enqueueWLE
		self.jobForMove.enqueueJob();
	
	endif;

	
	
	
epilog
	//delete anArbiter;
	delete moveController;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addToRTQueuePOP" id="51240bb8-cce5-47be-8ddc-02704dd1c616">
        <updating/>
        <source>addToRTQueuePOP(_passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2011	cnwrd1	Initial creation

*/

vars
	anArbiter	: CM_RTQueueArbiter;
begin
	
	if self.doNotAddQueuedMovesToRTQueue then
		return;
	endif;
	
	if self.isUndoMove then
		return;
	endif;
	
	if self.moveMode &lt;&gt; QUEUE_PLAN_ON_PICKUP then
		return;
	endif;
		
	if self.myWorkListEntry &lt;&gt; null then
		// Have create arbiter so it can carry the queue for sending event.
		anArbiter := self.getRTQueueArbiter();
		//create anArbiter transient;
		anArbiter.job := self.myWorkListEntry.job;
		self.setJobForMove(anArbiter.job);
		self.myWorkListEntry.enqueueWLE(anArbiter);
	elseif self.jobForMove &lt;&gt; null and not self.isOverstowMove and not self.isDirectorMove then
		//anArbiter can be null as it gets created and set in enqueueWLE
		self.jobForMove.enqueueJob();
	
	endif;

	
epilog
	//delete anArbiter;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="continueVoyageAutoProgression" id="b9dbebfa-6127-416c-9c8f-047549611d86">
        <source>continueVoyageAutoProgression(_ti : CM_TrackedItem io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jul 2024	navra1	Initial creation for //navra1 - TFS 65376 - 31st July 2024 - 1
11 Sep 2024 navma1	Bug 66070: CUX - Error 75793 when updating a Fully Lashed MAFI
*/

vars
	voyage 			: CM_Voyage;
	voyageProgress 	: CM_VoyageProgress;
	sourceLocation, 
	targetLocation 	: CM_LocationsController;
	ti				: CM_TrackedItem;
begin
	
	if _ti = null then									//11.09.2024 navma1 #66070
		if self.allOtherTrackedItems.isEmpty then
			return;
		endif;
		_ti := self.allOtherTrackedItems.first;
	endif;
	
	voyage := _ti.myVoyage;
	
	if voyage = null then
		return;
	endif;
	

	if self.isFromAutoProgression then					//11.09.2024 navma1 #66070
		return;
	endif;
	

	voyageProgress := voyage.myVoyageProgress;
	
	if  voyageProgress &lt;&gt; null and voyage.myVoyageProcess.isAutomaticProcess() then 
		sourceLocation := self.mySourceLocation;
		targetLocation := self.myTargetLocation;
		
		//navra1 - CR 65823 - 6th Sep 2024  - start
		if voyageProgress.pauseProgress = true then
			return;
		endif;
		//navra1 - CR 65823 - 6th Sep 2024 - end
		
		
		if self.moveMode = REAL_MODE then				
			if sourceLocation &lt;&gt; null then
				if sourceLocation.isYardLocation() and targetLocation &lt;&gt; null and targetLocation.isVoyageController then					//it is a load
					//if a manual load was performed, then trigger the VoyStage_LoadManMoved stage with the ti's operator, assuming that 
					//there was an issue with loading for that operator and it is fixed now indicating we move the rest automatically							
					voyageProgress.progressStage(CM_VoyageStage.VoyStage_LoadManMoved, null, _ti.myOperator, CM_VoyageStage.Type_Load);					//navra1 - MTN-34829 - 8th May 2025
				//discharge can be to a release transfer area with auto release turned on - in which case the target location will be null and the myDirectReleaseArea will be filled up
				elseif sourceLocation.isVoyageController then
					if targetLocation &lt;&gt; null and targetLocation.isYardLocation then				//it is a discharge to a normal location BS or somewhere else						
						//if a manual discharge was performed, then trigger the VoyStage_DischManMoved stage with the ti's operator, assuming that 
						//there was an issue with discharging for that operator and it is fixed now indicating we move the rest automatically								
						voyageProgress.progressStage(CM_VoyageStage.VoyStage_DischManMoved, null, _ti.myOperator, CM_VoyageStage.Type_Discharge);					//navra1 - MTN-34829 - 8th May 2025
					elseif self.myDirectReleaseArea &lt;&gt; null then					//it is a discharge to a release transfer area with auto release turned on								
						voyageProgress.progressStage(CM_VoyageStage.VoyStage_DischManMoved, null, _ti.myOperator, CM_VoyageStage.Type_Discharge);					//navra1 - MTN-34829 - 8th May 2025
					endif;			//otherwise, we cant decide anything
				endif;
			endif;
		endif;				
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
    </JadeMethod>
    <JadeMethod name="create" id="e6fb9995-8a4b-40f3-bea2-9110eecc4699">
        <updating/>
        <source>create() updating;
/*
 ------------------------------------------------------------------------
Created:			26 July 2001 by cnwdwq1
Purpose:			Constructor - defaults the timeStamp to serverTime.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	self.effectiveTimeStamp := app.actualTimeServer();
	create self.myHazardSegMoveAgent transient;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="createAsAutoMovePlan" id="65c34591-7347-4143-bd4f-16a72745dbe5">
        <source>createAsAutoMovePlan() : CMIF_AutoMovePlan;
/*
 ------------------------------------------------------------------------
Created:			26 October 2001 by cnwdwq1
Purpose:			Returns a NEWLY CREATED tAutoPlanMove, remember to DELETE
							this AFTER you have used it. Created this way, it does NOT have
							the isAutoPlanMove property set, so tests get done for instant
							moves as well as autoplans
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	tmpAutoMovePlan	: CMIF_AutoMovePlan;

begin

	tmpAutoMovePlan := self.cloneSelfAs(CMIF_AutoMovePlan, true).CMIF_AutoMovePlan;
	tmpAutoMovePlan.generateLog := true;

	tmpAutoMovePlan.setMyTrackedItem(self.myTrackedItem);
	tmpAutoMovePlan.setMyToPrimaryLocation(self.myToPrimaryLocation);
	tmpAutoMovePlan.setMyToSecondaryLocations(self.myToSecondaryLocations); // PAR 17759
	tmpAutoMovePlan.setAlertManager;
	tmpAutoMovePlan.myRTQueueEntry := self.myRTQueueEntry;
	tmpAutoMovePlan.isRadioTelemetryMove := self.isRadioTelemetryMove;
	tmpAutoMovePlan.myMachine :=self.myMachine;
	self.allOtherTrackedItems.copy(tmpAutoMovePlan.allOtherTrackedItems); // PAR 17793
	return tmpAutoMovePlan;
end;</source>
        <ReturnType type="CMIF_AutoMovePlan"/>
    </JadeMethod>
    <JadeMethod name="createRotatableCargo" id="99317e2d-6b58-478d-ae75-56f4d153c245">
        <updating/>
        <source>createRotatableCargo(_passport : CM_Passport input) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Oct 2025	jlier1	Initial creation 36155
10 Nov 2025 jlier1	MTN-36536 	
*/

vars
	cargoType : CM_CargoType;
	subType : CM_Product;
	iter  : Iterator;
	ti,foundTI, interchangeTI : CM_TrackedItem;
	dynaDict : DynaDictionary;
	id, subTypeID : String;
	interchangeLC, origLocn : CM_LocationsController;
	moveControl : CMIF_MoveController;
	newTI, pxyTI : CM_TrackedItem;
	matches : Integer;
	terminal : CM_Terminal;
	craneWP : Object;
	ta : CM_TerminalArea;
	moveVolume : Decimal[23,6];
begin

	self.setMyRotatableContainer(self.myTrackedItem);

	if self.myRotatableContainer = null then	
		return;
	endif;
	origLocn:=self.myOriginatingLocation;
	terminal:=self.myRotatableContainer.getMyTerminal;
	cargoType:=self.myRotatableContainer.getCargoTypeForContents();
	subType:= self.myRotatableContainer.getCargoSubTypeForContents();
	if subType &lt;&gt; null then
		subTypeID:=subType.code;
	endif;
	
	create dynaDict transient;
	dynaDict.setMembership(CM_TrackedItem);
	dynaDict.addMemberKey(CM_TrackedItem::cargoType.name,false,true);
	dynaDict.addMemberKey(CM_TrackedItem::myProduct.name,false,true);
	dynaDict.addMemberKey(CM_TrackedItem::operatorCode.name,false,true);
	dynaDict.addMemberKey(CM_TrackedItem::commodity.name,false,true);
	dynaDict.endKeys(true);
	
	self.myToPrimaryLocation.allTrackedItemsById.copy(dynaDict);
	
	if cargoType.allowDuplicates then
		iter:=dynaDict.createIterator;	
		dynaDict.startKeyGeq(cargoType.id,subType,self.myRotatableContainer.operatorCode,self.myRotatableContainer.commodity,iter);
		while iter.next( ti ) do
			if ti.cargoType &lt;&gt; cargoType.id then
				break;
			endif;
			if ti.myProduct &lt;&gt; subType then
				break;
			endif;
			if ti.operatorCode &lt;&gt; self.myRotatableContainer.operatorCode then
				break;
			endif;
			if ti.commodity &lt;&gt; self.myRotatableContainer.commodity then
				break;
			endif;
			
			//should not happen but add extra check for location with bad data 
			if ti.hasBeenMerged then
				continue;
			endif;
			//match on operator 
			//cargo type
			// subytpe
				
			foundTI :=ti;
			break;
		endwhile;
	endif;
	
	
	interchangeLC:=self.myToPrimaryLocation.CM_VoyageController.getDefaultDischargeLane;
	//jlier1 11/11/25 MTN-36405 - lets just get a load lane from the first cta or workpoint interchange
	if interchangeLC =null then
		ta:=terminal.allTerminalAreasByTypeId.getAtKeyGeq(TA_TYPE_CRANE_TRANS,null);
		if ta &lt;&gt; null and ta.isKindOf(CM_CraneTransferArea) then
			interchangeLC:=ta.CM_CraneTransferArea.getFirstAvailableLoadLane;
		endif;
		if interchangeLC = null then
			ta:=terminal.allTerminalAreasByTypeId.getAtKeyGeq(TA_TYPE_WORKPOINT_INTERCHANGE,null);
			if ta &lt;&gt; null and ta.isKindOf(CM_WorkPointInterchangeArea) then
				interchangeLC:=ta.CM_WorkPointInterchangeArea.getFirstAvailalableLane;
			endif;
		endif;
	endif;
	
	if interchangeLC = null then
		app.raiseCMException1(NO_Default_interchange,self.myToPrimaryLocation.getFullId, null,null);
		return;
	endif;
	
	create moveControl transient;	//move it to the interchange area
	moveControl.setMyTrackedItem(self.myRotatableContainer);
	moveControl.setMyToPrimaryLocation(interchangeLC);
	app.myUtilityUA.utlUpdateMoveTrackedItem(moveControl,_passport);
	if _passport.hasErrors then
		return;
	endif;
	delete moveControl;
		
	
	if foundTI &lt;&gt; null then
		id:= foundTI.id;
	else
		id:=terminal.generateNextCargoId(true,false,cargoType.abbreviation).trimBlanks;
	endif;
	
	if foundTI &lt;&gt; null then
		interchangeTI:=interchangeLC.searchForOnsiteTI(id,matches,cargoType.id,null,subTypeID,null);
	endif;
	
	//jlier1 MTN-36570 12/11/25 - need to get the volume to move
	//if the cargo volume is set use that otherwise calculate from the cargo weight
	moveVolume:=self.myRotatableContainer.volume;
	if moveVolume = null and cargoType.isBulkByVolume then
		if foundTI &lt;&gt; null then
			moveVolume:=self.weight/foundTI.getDensity;
		else
			//calcuate a move volume
		//	moveVolume:=
			if subType &lt;&gt; null and subType.getDensityValue &lt;&gt; 0 then
				moveVolume:=self.weight/subType.getDensityValue;
			endif;
			if moveVolume = null and cargoType.density &lt;&gt; 0 then
				moveVolume:=self.weight/ cargoType.density;
			endif;
		endif;	
	endif;
	
	if interchangeTI &lt;&gt; null then
		
		newTI:=	interchangeTI.cloneMe(id, TI_STATE_NORMAL, moveControl, false, true, true, false, interchangeLC, self.myRotatableContainer.myVoyage, _passport).CM_TrackedItem;
		newTI.setQVW(self.quantity.max(1),moveVolume,self.weight);
	elseif foundTI  &lt;&gt; null then
		//create moveControl transient;	//move it to the 
		newTI:=	foundTI.cloneMe(id, TI_STATE_NORMAL, moveControl, false, true, true, false, interchangeLC, self.myRotatableContainer.myVoyage, _passport).CM_TrackedItem;
		newTI.setQVW(self.quantity.max(1),moveVolume,self.weight);
	else
		
		pxyTI:=self.myRotatableContainer.cloneSelfAs(cargoType.myClassToCreate,true).CM_TrackedItem;
		pxyTI.zSetPxyId(id);
		pxyTI.setCloneIdReferences(id,self.myRotatableContainer,false,null,null,_passport);
		pxyTI.setCargoType(cargoType.id);
		pxyTI.setMyProduct(subType);
		pxyTI.setWeightCargo(0);
		pxyTI.setWeightTare(0);
		pxyTI.setWeightDeclared(0);
		pxyTI.setQVW(self.quantity.max(1),moveVolume,self.weight);
		newTI:=terminal.createTrackedItem(pxyTI,_passport);
		if _passport.hasErrors then
			return;
		endif;
	endif;
	create moveControl transient;	//move it to the 
	moveControl.setMyTrackedItem(newTI);
	moveControl.setMyToPrimaryLocation(interchangeLC);
	moveControl.quantity:=self.quantity.max(1);
	moveControl.weight:=self.weight;
	moveControl.volume:=moveVolume;
	
	app.myUtilityUA.utlUpdateMoveTrackedItem(moveControl,_passport);
	if _passport.hasErrors then
		return;
	endif;
	newTI:=moveControl.myTrackedItem; //might of merged into cargo in the interchange area;

	self.myTrackedItem:=newTI;
	self.myOriginatingLocation:=origLocn;
	self.myWorkListEntry:=null; //triggers validation that is not valid because this is not what we are moving
epilog
	delete pxyTI;
	delete moveControl;
	delete iter;
	delete dynaDict;

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createVoyageWLEForNonCraneMove" id="918c7ff8-8799-4f2a-bc6a-89572dda8c81">
        <updating/>
        <source>createVoyageWLEForNonCraneMove() updating;
// ---------------------------------------------------------------------------
// Created:     06 May 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 27/06/2016		cnwma1			PAR37969 TFS #2196 SPL - Missing Planned Location on Sequence Sheets
// 23/08/2016 		cnwma1 			TFS #2557:SPT - Missing Planned Location on Sequence Sheets- Issue not fixed from previous TFS
// 13 Oct 2023 		navhl20 		Bug 60788: STWO | Cargo Lander in Mobile App does not show all holds in "Planned Ship Location" as drop-down
// 05 Apr 2024 		navhl20 		Bug 63513: EUP - Planning the cargo creates extra work list entry
// 28 Oct 2025		jlizm1			MTN 36255 Rotabox Assign Release To Vessel
// ---------------------------------------------------------------------------

vars
	job : CM_VoyageJob;
	voy : CM_Voyage;
	moveType : Integer;
	shipLC : CM_LocationsController;
	otherWle : CM_WorkListEntry;
	existingJob : Boolean;	//05 Feb 2015	NDL	Par 35643
	wle			: CM_WorkListEntry;
	ti			: CM_TrackedItem;
	voyage		: CM_Voyage;
	
begin
	if self.doNotAddQueuedMovesToRTQueue then
		return;
	endif;
	
	if self.isUndoMove then
		return;
	endif;
	
	//14 Feb 2013	NDL	Par 31102
	if self.moveMode = REAL_MODE
	and self.myTrackedItem &lt;&gt; null
	and self.myTrackedItem.directDelivery
	and self.myWorkListEntry = null
	then
		//This direct delivery is being actioned from the NWNP form
		foreach otherWle in self.myTrackedItem.allWorklistEntries do
			if otherWle.status = WLE_UNACTIONED then
				if otherWle.getTargetLocation = self.myToPrimaryLocation then
					self.myWorkListEntry := otherWle;
					return;
				elseif otherWle.getSourceLocation = self.myOriginatingLocation then
					self.myWorkListEntry := otherWle;
					return;
				endif;
			endif;
		endforeach;
	endif;
	
	//epr par 33984 27/5/14
	if self.moveMode &lt;&gt; QUEUE_MODE and self.moveMode &lt;&gt; PLANNING_MODE then 
		return;
	endif;
	
	
	
	if self.myToPrimaryLocation.isKindOf(CM_VoyageController) then
		voy := self.myToPrimaryLocation.CM_VoyageController.myVoyage;
		moveType := LOAD_MOVETYPE;
		//03 Mar 2015	NDL	Par 35734
		if self.myOriginatingLocation.isKindOf(CM_VoyageController) then
			if voy = self.myOriginatingLocation.CM_VoyageController.myVoyage then
				if not self.myToPrimaryLocation.mustBePlannedForHHLanderLoad and not self.myOriginatingLocation.mustBePlannedForHHLanderLoad then
					moveType := SOB_MOVETYPE;
				endif;
			endif;
		endif;
	elseif self.myOriginatingLocation.isKindOf(CM_VoyageController) then
		voy := self.myOriginatingLocation.CM_VoyageController.myVoyage;
		moveType := DISCHARGE_MOVETYPE;
		
		//cnwma1  //27/06/2016  PAR# 37969 TFS #2196  
		if self.moveMode = PLANNING_MODE
		and self.myTrackedItem &lt;&gt; null
		//epr break bulk always have to have a new wle because that is where the amount is stored - this finding the wle seems a bit crazy to me
		and not self.myTrackedItem.myCargoType.isBreakBulkMulti 
		and not self.myTrackedItem.myCargoType.isBulkMulti 
		//and self.myTrackedItem.isKindOf(CM_Container)    //23/08/2016 cnwma1 TFS# 2557
		and self.myWorkListEntry = null
		then
			foreach otherWle in self.myTrackedItem.allWorklistEntries reversed do
				if otherWle.status = WLE_UNACTIONED and otherWle.isKindOf(CM_VoyageWLE) and otherWle.CM_VoyageWLE.isReceipt then
					if  otherWle.getSourceLocation = self.myOriginatingLocation then
						self.myWorkListEntry := otherWle;
						return;
					endif;
				endif;
			endforeach;
		endif;
		
	elseif	(self.myOriginatingLocation.isCraneLaneController() // 35091
		or self.myOriginatingLocation.isWorkPointLaneController())  // 35091
		and self.myTrackedItem &lt;&gt; null // 35091
		and self.myTrackedItem.myVoyage &lt;&gt; null then // 35091
		
		voy := self.myTrackedItem.myVoyage; // 35091
		moveType := DISCHARGE_MOVETYPE; // 35091

	else
		return;
	endif;
	//job.createForQueuedJob(voy, self.myTrackedItem, moveType );
	
	if self.myToPrimaryLocation.isVoyageController() then
		shipLC := self.myToPrimaryLocation; // load to ship
	elseif self.myOriginatingLocation.isVoyageController() then
		shipLC := self.myOriginatingLocation; // discharge from ship
	endif;
	
	//05 Feb 2015	NDL	Par 35643
	if self.moveMode = QUEUE_MODE then
		job := self.myTrackedItem.allWorklistEntries.getExistingPlannedROROJob( self.myToPrimaryLocation ).CM_VoyageROROJob;
		
		if job = null 
		and self.myWorkListEntry &lt;&gt; null
		and (shipLC.isKindOf(CM_GeneralCargoController)
		or shipLC.isKindOf(CM_ShipBlockController)) then
			// assigning release to hold voyage in voyage ops will create job differently
			// get job from assigned wle
			job := self.myWorkListEntry.job.CM_VoyageJob;
		endif;
		existingJob := job &lt;&gt; null;
	endif;
	
	if job = null then																			//05.04.2024 navhl20 #63513
		ti := self.myTrackedItem;
		voyage := ti.myVoyage;
		if voyage &lt;&gt; null and voyage.myVoyageProcess &lt;&gt; null and 
		voyage.myVoyageProcess.isEUPDefaultProcess then
			wle := ti.getIncompleteReceiveWle();
			if wle &lt;&gt; null then
				existingJob := wle.job &lt;&gt; null;
			endif;
		endif;
	endif;
	
	if not existingJob then	//05 Feb 2015	NDL	Par 35643
		create job as CM_VoyageROROJob;
		job.CM_VoyageROROJob.createForQueuedJob(voy, self.myTrackedItem, self.allOtherTrackedItems, moveType, shipLC );	//28 Jun 2010	NDL	Par 24583 // PAR 35397 added target ocation
	endif;
	
	/*
	//05.04.2024 navhl20 #63513
	self.myWorkListEntry := job.workListEntries.first;
	
	if self.weight &lt;&gt; 0 then
		self.myWorkListEntry.setWeight(self.weight);
	endif;
	
	if self.quantity &gt; 0 then
		self.myWorkListEntry.setQuantity(self.quantity);
	endif;
	
	//28 Jun 2010	NDL	Par 24583
	if job.workListEntries.size &gt; 1 then
		foreach otherWle in job.workListEntries do
			if self.myWorkListEntry = otherWle then
				// skip the first one.
				continue;
			endif;
			self.allOtherWLEs.add(otherWle);
		endforeach;
	endif;*/
	
	//Start 05.04.2024 navhl20 #63513
	if job &lt;&gt; null then
		self.myWorkListEntry := job.workListEntries.first;
		
		//28 Jun 2010	NDL	Par 24583
		if job.workListEntries.size &gt; 1 then
			foreach otherWle in job.workListEntries do
				if self.myWorkListEntry = otherWle then
					// skip the first one.
					continue;
				endif;
				self.allOtherWLEs.add(otherWle);
			endforeach;
		endif;
	else
		if wle &lt;&gt; null then
			self.myWorkListEntry := wle;
		endif;
	endif;
	
	if self.weight &lt;&gt; 0 then
		self.myWorkListEntry.setWeight(self.weight);
	endif;
	
	if self.quantity &gt; 0 then
		self.myWorkListEntry.setQuantity(self.quantity);
	endif;
	//End 05.04.2024 navhl20 #63513

	//self.isNonCraneVoyageMove := false;			//13.10.2023 navhl20 #60788
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createVoyageWLEForNotNotified" id="3c0680bf-0819-403f-a0b4-ba4187fb6f00">
        <updating/>
        <source>createVoyageWLEForNotNotified() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 September 2011	cnwndl1	Initial creation	Par 28173

*/

vars
	wle : CM_VoyageWLE;
	job : CM_VoyageNotNotifiedJob;
	req : CM_SlotRequest;
	voy : CM_Voyage;
	moveType : Integer;
	otherWle : CM_WorkListEntry;
begin
	if self.doNotAddQueuedMovesToRTQueue then
		return;
	endif;
	
	if self.isUndoMove then
		return;
	endif;
	
	if self.moveMode &lt;&gt; QUEUE_MODE then
		return;
	endif;
	
	create job;
	if self.myOriginatingLocation.isKindOf(CM_VoyageController) then
		voy := self.myOriginatingLocation.CM_VoyageController.myVoyage;
		moveType := DISCHARGE_MOVETYPE;
	else
		return;
	endif;
	
	job.createForQueuedJob(voy, self.myTrackedItem, self.allOtherTrackedItems, moveType );
	self.myWorkListEntry := job.workListEntries.first;
	
	if job.workListEntries.size &gt; 1 then
		foreach otherWle in job.workListEntries do
			if self.myWorkListEntry = otherWle then
				// skip the first one.
				continue;
			endif;
			self.allOtherWLEs.add(otherWle);
		endforeach;
	endif;

	self.isNonCraneVoyageMove := false;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createYardInternalQueueJob" id="16aa2b14-b406-40c7-8634-005ebbf8e5f2">
        <updating/>
        <source>createYardInternalQueueJob(_futureMove : CM_FutureMoveQueued input) updating;
//-----------------------------------------
// Created: August 2003 By: cnwgd1
//-----------------------------------------
vars
	theJob 	: CM_Job;
	entry	: CM_RTQueueEntry;
begin

	if self.isUndoMove then
		return;
	endif;
	
	if self.moveMode &lt;&gt; QUEUE_MODE then
		return;
	endif;	

	if (not self.myTrackedItem.canBeQueued()) then
		return;
	endif;
	
	// Attach new task to existing RT Queue entry.
	if self.isOverstowMove or self.isDirectorMove then
		// Job populated from original ti's queued job.
		entry := self.myRTQueueEntry;
		if entry = null then
			app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Overstow move queue entry not found', null, null);						
			return;
		endif;
		entry.createExtraTasks(self, _futureMove);
		entry.resetOfferedTask();
	
	else
	
		if self.myWorkListEntry &lt;&gt; null then
			return;
		endif;
		// Maybe Drag Drop then, create an Internal job
		// rs 13/10/2003 this was failing during conversion of Beta5
		if self.myPassport = null then
			self.myPassport := app.myPassport;
		endif;
		
		//epr par 25285 13/9/10 added parameter with target location can't just rely on the _future move being the first for the ti
		theJob := self.myTrackedItem.createYardInternalQueueJob(QUEUE_MODE, _futureMove.getPrimaryLocation,self.quantity,self.weight,self.isDriverInitiatedMove, self.myPassport);
		
		if theJob &lt;&gt; null then
			self.setMyWorkListEntry(theJob.workListEntries.first);
		endif;

	endif;	

end;</source>
        <Parameter name="_futureMove" type="CM_FutureMoveQueued" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createYardInternalQueueJobPOP" id="dff45f6a-27e8-4418-a675-44d34ef70d66">
        <updating/>
        <source>createYardInternalQueueJobPOP(_futureMove : CM_FutureMoveQueued input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2011	cnwrd1	Initial creation

*/
vars
	theJob 	: CM_Job;
	entry	: CM_RTQueueEntry;
	is20 	: Boolean;
	request	: CM_Request;
	wle		: CM_WorkListEntry;
begin

	if self.isUndoMove then
		return;
	endif;
	
	if self.moveMode &lt;&gt; QUEUE_PLAN_ON_PICKUP then
		return;
	endif;	

	if (not self.myTrackedItem.canBeQueued()) then
		return;
	endif;
	
	// Attach new task to existing RT Queue entry.
	if self.isOverstowMove or self.isDirectorMove then
		// Job populated from original ti's queued job.
		entry := self.myRTQueueEntry;
		if entry = null then
			app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Overstow move queue entry not found', null, null);						
			return;
		endif;
		entry.createExtraTasks(self, _futureMove);
		entry.resetOfferedTask();
	
	else
	
		if self.myWorkListEntry &lt;&gt; null then
			return;
		endif;
		// Maybe Drag Drop then, create an Internal job
		// rs 13/10/2003 this was failing during conversion of Beta5
		if self.myPassport = null then
			self.myPassport := app.myPassport;
		endif;
		
		
		//cnwrd1 par 22240 2.2.2010 
		// now having multiple yard internal jobs so we will create a new one instead of appending a request to the existing one.
		// Are we multi queing the same box.
		/*
		theJob := self.myTrackedItem.jobYardInternal;
		if theJob &lt;&gt; null then
			request := self.myTrackedItem.createTiRequest(theJob, self.myPassport);
			if request = null then
				app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Request cannot be null', null, null);
				return;
			endif;
			wle := request.allWorkListEntries.first;
			
			self.setMyWorkListEntry(wle);
		else
		*/
			theJob := self.myTrackedItem.createYardInternalQueueJobPOP(QUEUE_PLAN_ON_PICKUP, self.jobForMove, self , self.myPassport);
			//PAR15937 and 15932 cannot return an exception as this method is called during discharge and ship side moves cnwsh3
			//if theJob = null then
			//	app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Job cannot be null', null, null);
			//	return;
			//endif;
			
			if theJob &lt;&gt; null then
				self.setMyWorkListEntry(theJob.getWLEForTI( self.myTrackedItem) );
			endif;
		//endif;
	endif;	

end;</source>
        <Parameter name="_futureMove" type="CM_FutureMoveQueued" usage="input"/>
    </JadeMethod>
    <JadeMethod name="delete" id="79f3f3b7-72be-45d9-bb92-0d6f31e861a0">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     18 December 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// from 27334 testing, transient leak
	self.allTISets.purge();

	delete myHazardSegMoveAgent;
	if self.isUsingSessionLocks then
		self.doSessionUnlockForAll();
	endif;
	
	delete self.myRTQueueArbiter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="determineFutureMoveType" id="0da53a14-708d-4ebb-97ab-72608a908042">
        <source>determineFutureMoveType( ): Integer;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 23/02/2017	cnwdap1		TFS 3489 LNX DLR/SOB - ensure SOB jobs create SOB future moves
vars
	moveType : Integer;
	isToSlot,
	isOrigSlot	: Boolean;
	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
begin


	if self.moveMode = QUEUE_PLAN_ON_PICKUP then //cnwrd1 par 26734 CCMS 2014 plan on pickup
		return TI_FutureMovePoP;
	endif;
	
	if self.moveMode = QUEUE_MODE then
		if self.isOverstowMove then
			return TI_FutureMoveOverstow;
		else
			return TI_FutureMoveQueued;
		endif;
	endif;
	//------------------------
	//self.moveMode = PLANNING_MODE
	//------------------------
// PAR 27749	isOrigSlot := CM_SlotController.hasInstance(self.myOriginatingLocation);
//	isToSlot := CM_SlotController.hasInstance(self.myToPrimaryLocation);

	if self.myOriginatingLocation &lt;&gt; null then
		isOrigSlot := self.myOriginatingLocation.isVoyagePlanningLC();
	endif;
	if self.myToPrimaryLocation &lt;&gt; null then
		isToSlot := self.myToPrimaryLocation.isVoyagePlanningLC();
	endif;
	// TFS 3489 Special handling for Voyage Hold SOB jobs								// TFS 3489
	if self.jobForMove &lt;&gt; null and self.jobForMove.isVoyageHoldJob then					// TFS 3489
		wle := self.jobForMove.workListEntries.first;									// TFS 3489
		if wle &lt;&gt; null and wle.myTrackedItem &lt;&gt; null and wle.myTrackedItem.isSOB then	// TFS 3489
			return TI_FutureMoveSOB;													// TFS 3489
		endif;																			// TFS 3489
	endif;																				// TFS 3489

	if isOrigSlot and isToSlot then
//		if self.myOriginatingLocation.CM_SlotController.myVoyage = self.myToPrimaryLocation.CM_SlotController.myVoyage then // CCMS 1011
		if self.myOriginatingLocation.getMyVoyage() = self.myToPrimaryLocation.getMyVoyage() then // PAR 27749 RORO
			// WAS PAR 8884. if self.isMoveAnExportRePlan() then // PAR 7094 AKB2003DEC
			if self.isReplanAnExport then
				if self.isRehandleMove then
					return TI_FutureMoveDLRLoad; // AKB2004FEB
				else
					return TI_FutureMovePlanned; // PAR 7094 AKB2003DEC
				endif;
			else
				if self.isDLRLoadWithOutDischarge then // CCMS 1368 this is a DLR load plan 
					return TI_FutureMoveDLRLoad;
				else
					return TI_FutureMoveSOB;
				endif;
			endif;
		endif;
	endif;
	
	if self.isRehandleMove = false then
		if self.isOverstowMove then
			return TI_FutureMoveOverstow;
		else
			if self.myOriginatingLocation = null then
				if self.indexForEDIBayPlan &lt;&gt; 0 then
					return TI_FutureMoveEDI;
				endif;
			endif;
			return TI_FutureMovePlanned;
		endif;
	endif;

	if isOrigSlot then
		if (not isToSlot) then
			//NOT to a slot selfler, i.e. is to land-based location
			return TI_FutureMoveDLRDischarge;
		endif;
		
		// ## SHIP TO SHIP
		
		
		if self.isDLRLoadWithOutDischarge then // CCMS 1368 allow DLR load plan without DLR discharge, whilst TI still on ship
			return TI_FutureMoveDLRLoad;
		else
			return TI_FutureMoveSOB;
		endif;
	endif;
	
	// TFS 2228 check the destination to determine if DLR discharge or load
	if self.myToPrimaryLocation &lt;&gt; null and
	   self.myToPrimaryLocation.isYardLocation() then
		return TI_FutureMoveDLRDischarge;
	else
		return TI_FutureMoveDLRLoad;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="directDeliveryPostMove" id="a0112893-83b3-4a51-a2b1-a407848cfd24">
        <updating/>
        <source>directDeliveryPostMove( _passport : CM_Passport input ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Feb 2013	cnwndl1	Initial creation	Par 31102
06 Dec 2021	navdap1	TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
31 Jan 2022	navdap1	TFS 52712 SNO Missing containers to load into the Cargo Lander application
*/

vars

	unQueueMoveCont	: CMIF_MoveController;
	fmIndex : Integer;
	ti : CM_TrackedItem;
	wle : CM_WorkListEntry;				// TFS 52293
	voyageWle : CM_VoyageWLE;			// TFS 52293
	fm : CM_FutureMove;					// TFS 52293

begin

	if self.moveMode &lt;&gt; REAL_MODE then
		return;
	endif;

	ti := self.myTrackedItem;
	if ti = null then
		return;
	endif;

	if self.myDirectDeliverySecondFM &lt;&gt; null then
	
		create unQueueMoveCont transient;
		unQueueMoveCont.setMoveMode(QUEUE_MODE);
		
		fmIndex := ti.allQueuedFutureMoves.indexOf(self.myDirectDeliverySecondFM);
		if 	fmIndex &gt; 0 then
			unQueueMoveCont.setMoveIndex(fmIndex);
			unQueueMoveCont.isFullyUnplan:=true;
			unQueueMoveCont.setMyTrackedItem(ti);
			app.myUtilityUA.utlUpdateMoveTIUndo(unQueueMoveCont, _passport);
		endif;
		
		delete unQueueMoveCont;
		
	endif;
	
	// TFS 52293 Moved the entire onsite TI to ship as part of a direct delivery move
	// Need to tidy up direct delivery WLEs and fix weight/quantity 
	if ti.state = TI_STATE_ONSHIP then
		//if self.myWorkListEntry &lt;&gt; null and self.myWorkListEntry.isRoad and self.myWorkListEntry.isCompleteForJob												// TFS 52712
		if self.myWorkListEntry &lt;&gt; null and app.isValidObject(self.myWorkListEntry) and self.myWorkListEntry.isRoad and self.myWorkListEntry.isCompleteForJob	// TFS 52712
		and self.myDDWorkListEntry &lt;&gt; null and self.myDDWorkListEntry.job &lt;&gt; null and self.myDDWorkListEntry.job.isDirectDeliveryJob then
			foreach wle in ti.allWorklistEntries do
				if wle.myDirectDeliveryParentWLE &lt;&gt; null then
					voyageWle := wle.CM_VoyageWLE;
					voyageWle.clearMyDirectDeliveryParentWLE();
					if voyageWle.locationTarget = ti.locationId and voyageWle = self.myDDWorkListEntry then
						if ti.isBulkByQuantity and voyageWle.quantity &gt; ti.totalQuantity then
							voyageWle.setQuantity(ti.totalQuantity);
							voyageWle.setWeight(ti.weight);			// keep weight in line with quantity
						elseif (ti.isBulkByVolume or ti.isBulkByWeight) and voyageWle.weight &gt; ti.weight then
							voyageWle.setWeight(ti.weight);
						endif;
						if not voyageWle.job.CM_VoyageJob.allReleaseTrackeditems.includes(ti) then
							voyageWle.job.CM_VoyageJob.allReleaseTrackeditems.add(ti);
						endif;
					else
						if voyageWle.job.CM_VoyageJob.allReleaseTrackeditems.includes(ti) then
							voyageWle.job.CM_VoyageJob.allReleaseTrackeditems.remove(ti);
						endif;
						if voyageWle.myFutureMove &lt;&gt; null then
							fm := voyageWle.myFutureMove;
							delete fm;
						endif;
						voyageWle.erase(NORMAL_ERASE);
					endif;
				endif;
			endforeach;
		endif;
	endif;
	// TFS 52293 end
	
epilog

	self.myDirectDeliverySecondFM := null;
	delete unQueueMoveCont;

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="directDeliveryPreMove" id="468d7cda-1c71-4e86-9aca-4b54e38b719a">
        <updating/>
        <source>directDeliveryPreMove() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Feb 2013	cnwndl1	Initial creation	Par 31102
15 Oct 2021	navdap1	TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
07 Dec 2021	navdap1	TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
*/

vars

	ti : CM_TrackedItem;
	otherDDWle : CM_WorkListEntry;

begin

	self.myDirectDeliverySecondFM := null;
	
	if self.moveMode &lt;&gt; REAL_MODE then
		return;
	endif;
	
	ti := self.myTrackedItem;
	
	if ti &lt;&gt; null and ti.directDelivery then
		//if ti.myTerminal.getConfig(DirectTruck2VesselMult).Boolean then							// TFS 51935	// TFS 52293
		if self.myWorkListEntry &lt;&gt; null and self.myWorkListEntry.job &lt;&gt; null 										// TFS 52293
		and self.myWorkListEntry.job.isDirectDeliveryJob then														// TFS 52293
			return;																					// TFS 51935
		endif;																						// TFS 51935
		otherDDWle := ti.getDirectDeliverySourceWle( self.myWorkListEntry );
		if otherDDWle = null or otherDDWle = self.myWorkListEntry then
			otherDDWle := ti.getDirectDeliveryTargetWle( self.myWorkListEntry );
			if otherDDWle = self.myWorkListEntry then
				otherDDWle := null;
			endif;
		endif;
		if otherDDWle &lt;&gt; null then
			otherDDWle.setStatus(WLE_COMPLETED);
			self.myDirectDeliverySecondFM := otherDDWle.myFutureMove;
		endif;
		
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="directLoadCheckJobStatus" id="1ee05055-b6bb-45ea-aec8-a36035d55419">
        <source>directLoadCheckJobStatus(_wle : CM_WorkListEntry);
//
// Purpose:			Direct prenote load stuff is insanely complicated - need to do some tidyup work after the fact
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 25/11/2021	navdap1		Initial creation TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
// 09/12/2021	navdap1		TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
//
vars
	otherWle : CM_WorkListEntry;
	voyageWle : CM_VoyageWLE;
	job : CM_VoyageHoldJob;
	jobTotal : Integer;
	ti : CM_TrackedItem;
	yardJob : CM_Job;
	yardWLE, unactionedYardWLE : CM_WorkListEntry;
	yardJobTotal : Integer;
	useQuantity : Boolean;
	prenote : CM_TrackedItem;
	fmsToDelete : ObjectArray;

begin
	// If all complete wles for this job add up to the original job amount, set subseqnum to 0
	// for all incomplete / unactioned WLEs - no longer need them
	if not _wle.job.isKindOf(CM_VoyageHoldJob) then
		return;
	endif;
	job := _wle.job.CM_VoyageHoldJob;
	foreach otherWle in job.workListEntries do
		if otherWle.status = WLE_COMPLETED and otherWle.myTrackedItem &lt;&gt; null and not otherWle.myTrackedItem.hasBeenMerged then
			if otherWle.myTrackedItem.isBulkByQuantity then
				jobTotal := jobTotal + otherWle.quantity;
			else
				jobTotal := jobTotal + otherWle.weight.Integer;
			endif;
		endif;
	endforeach;
	//if jobTotal = job.originalJobAmount then		// TFS 52293
	if jobTotal &gt;= job.originalJobAmount then		// TFS 52293
		// job is finished - subSeqNum (which we use to keep track of how much is left to move)
		// can be set to zero for all WLEs on this job
		foreach otherWle in job.workListEntries where otherWle.status = WLE_UNACTIONED do
			otherWle.CM_VoyageWLE.setSubSeqNum(null);
			//if otherWle.myFutureMove &lt;&gt; null then
			//	otherWle.myFutureMove.erase(NORMAL_ERASE);
			//endif;
		endforeach;
		if job.status &lt;&gt; JOB_COMPLETE then
			job.changeStatus(JOB_COMPLETE);
		endif;
		// tidy up any future planned moves
		create fmsToDelete transient;
		foreach ti in job.allReleaseTrackeditems where ti.isOnShip do
			ti.allPlannedFutureMoves.copy(fmsToDelete);
		endforeach;
		fmsToDelete.purge;
	else
		// job is not finished - do we ned to reset the job status
		if job.status = JOB_COMPLETE then
			job.changeStatus(JOB_PART_COMPLETE);
		endif;
	endif;
	
	// If there are unactioned WLEs on this wle's TI that have a subSeqNum larger than the TI's quantity/weight, fix them up
	ti := _wle.myTrackedItem;
	foreach otherWle in ti.allWorklistEntries where otherWle &lt;&gt; _wle do
		if otherWle.isKindOf(CM_VoyageWLE) then
			voyageWle := otherWle.CM_VoyageWLE;
			if ti.isBulkByQuantity and ti.totalQuantity &lt; voyageWle.subSeqNum then
				voyageWle.setSubSeqNum(ti.totalQuantity);
			elseif (ti.isBulkByWeight or ti.isBulkByVolume) and ti.weight.Integer &lt; voyageWle.subSeqNum then
				voyageWle.setSubSeqNum(ti.weight.Integer);
			endif;
		endif;
	endforeach;
	// Also check the original TI on me, if there's been a split
	if self.myOriginalTI &lt;&gt; null then
		ti := self.myOriginalTI;
		foreach otherWle in ti.allWorklistEntries where otherWle &lt;&gt; _wle do
			if otherWle.isKindOf(CM_VoyageWLE) then
				voyageWle := otherWle.CM_VoyageWLE;
				if ti.isBulkByQuantity and ti.totalQuantity &lt; voyageWle.subSeqNum then
					voyageWle.setSubSeqNum(ti.totalQuantity);
				elseif (ti.isBulkByWeight or ti.isBulkByVolume) and ti.weight.Integer &lt; voyageWle.subSeqNum then
					voyageWle.setSubSeqNum(ti.weight.Integer);
				endif;
			endif;
		endforeach;
	endif;
	
	// When a WLE gets split, the quantity on the originating WLE is reduced. But we don't want that to happen
	// if we're using subSeqNum on the WLE to keep track of how much is left for a particular job.
	// So we have to restore the quantity on the originating WLE, if we don't have a prenote any more. Sigh.
	// Start with the Yard WLE on the controller (which will be complete). Get its job. Go through the WLEs on the
	// yard job looking for an incomplete WLE, and total up the quantity/weight on all the yard WLEs. 
	// For the incomplete yard WLE, look at all its Direct Delivery WLEs.
	// If one has a quantity/weight that doesn't match the calculated total from the yard WLEs,
	// set its quantity back to the total
	prenote := self.myTrackedItem.myVoyage.allNotifiedTIsByIdCargoType[self.myTrackedItem.id, self.myTrackedItem.cargoType];
	useQuantity := self.myTrackedItem.isBulkByQuantity;
	if prenote = null then
		yardJob := self.myWorkListEntry.job;
		if yardJob.isKindOf(CM_YardJob) then
			foreach yardWLE in yardJob.workListEntries do
				if yardWLE.status = WLE_UNACTIONED then
					unactionedYardWLE := yardWLE;
				endif;
				if useQuantity then
					yardJobTotal := yardJobTotal + yardWLE.quantity;
				else
					yardJobTotal := yardJobTotal + yardWLE.weight.Integer;
				endif;
			endforeach;
			
			if unactionedYardWLE &lt;&gt; null then
				foreach otherWle in unactionedYardWLE.allDirectDeliveryChildWLEs where otherWle.myTrackedItem.isOnTruck do
					if useQuantity and otherWle.quantity &lt;&gt; yardJobTotal then
						otherWle.setQuantity(yardJobTotal);
					elseif not useQuantity and otherWle.weight.Integer &lt;&gt; yardJobTotal then
						otherWle.setWeight(yardJobTotal);
					endif;
				endforeach;
			endif;
		endif;
	endif;
	
epilog
	delete fmsToDelete;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="directReleasePostMove" id="b72a4ff2-b69f-48c5-9a5f-61d92a65f37a">
        <updating/>
        <source>directReleasePostMove(_passport : CM_Passport input ) updating, protected;
/*

Purpose:			Carry out any post move actions for direct release moves

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2019	jlgzm1	TFS42840 MSL - Direct Delivery Between LOLO RORO Voyages and Rail

*/

vars
	wle, drwle : CM_WorkListEntry; 
	invalidWLE : Boolean;
begin
	if self.moveMode &lt;&gt; REAL_MODE then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, self.myWorkListEntry, invalidWLE); 	// TFS 42879 jlgzm1 03/09/2019
	on Exception do app.handleDeletedObject(exception, self.myDDWorkListEntry, invalidWLE); // TFS 42879
	
	// Are we a direct release move?
	if self.myWorkListEntry = null or
	   self.myDDWorkListEntry = null then
		// We are not, so exit
		return;
	endif;
	
	wle := self.myWorkListEntry;
	drwle := self.myDDWorkListEntry;
	
	// If both WLEs and all RT Tasks are complete, remove from queue
	if wle.status = WLE_COMPLETED and wle.areAllEntryTasksEqStatus(TASK_COMPLETE) and	
	   drwle.status = WLE_COMPLETED and drwle.areAllEntryTasksEqStatus(TASK_COMPLETE) then
		wle.unQueueWLE(_passport);
		drwle.unQueueWLE(_passport);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doChildDocActions" id="5844843a-be60-4909-abff-14d53b6d9636">
        <source>doChildDocActions(_ti : CM_TrackedItem);
//
// Purpose:			Process document actions for any child cargo of the TI that we've just moved
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/10/2016	cnwdap1		Initial creation TFS 2654
//
vars
	child : CM_TrackedItem;
	tiArray : CM_TIArray;
	amountArray : RealArray;
	moveAmount : Real;

begin
	// only interested in tis that have child items
	if not _ti.hasChildren then
		return;
	endif;
	
	create tiArray transient;
	create amountArray transient;
	foreach child in _ti.allChildren do
		// does the child have a bnooking item?
		if child.myBookingRefItem = null then
			continue;
		endif;
		// does the child's booking item have a document action?
		if child.myBookingRefItem.myBookingRefItemActions = null then
			continue;
		endif;
		
		tiArray.clear;
		amountArray.clear;
		tiArray.add(child);
		moveAmount := child.totalQuantity.max(1);
		if child.myCargoType.allowDuplicates then
			if child.myCargoType.isBulkByVolume then
				moveAmount := child.totalVolume;
			elseif child.myCargoType.isBulkByWeight then
				moveAmount := child.totalWeight;
			endif;	
		endif; 
		amountArray.add(moveAmount);
		child.myBookingRefItem.myBookingRefItemActions.assignTasksAndStops(tiArray, amountArray);		
	endforeach;
	
epilog
	delete tiArray;
	delete amountArray;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doDRSplitCreateNewWLE" id="651e5ff0-9aa4-4a21-9474-1e595ef498d6">
        <updating/>
        <source>doDRSplitCreateNewWLE(_postMove : Boolean): Boolean updating;
/*

Purpose:			For direct release moves for splittable cargo. If is postMove, then source wle would 
					have been split during the move, and we want to check/split the destination wle too, or
					if is preMove/planning, no cargo is being split, we just want to split the wles if we
					need to.

Parameters:			_postMove is this method called in the post move phase

Return Value:		True if a WLE was split

Date				Who		Reason
05 July 2019		jlgzm1	TFS 42863 MSL - Direct Delivery Between RORO Voyages and Rail 
19 August 2019		jlgzm1	TFS 42872 Direct Release Between HOLD Voyages and Rail
03 September 2019	jlgzm1	TFS 42879 Direct Release Between Voyage Operations and Road &amp; Rail

*/

vars
	destWLE,
	sourceWLE,
	newSourceWLE,
	newDestWLE			: CM_WorkListEntry;
//	destLoc				: CM_LocationsController;
	moveQty,
	newQty				: Integer;
	adjustQuantity,
	adjustWeight 		: Boolean;
	wleSource,wleTarget : String;
	amountsMatch 		: Boolean; 
	splitSourceWLE 		: Boolean; // are we splitting the source wle
	splitDestWLE		: Boolean; // are we splitting the destination wle
	tmpFM				: CM_FutureMove;
	job					: CM_Job; // extend for Road/ Rail	TFS 42876
	totalQty 			: Integer; 			// TFS 42872
	totalWeight			: Decimal[14,4];	// TFS 42872
	invalidWLE			: Boolean;			// TFS 42879
	
begin
	// if not a DR move then leave
	if self.myWorkListEntry = null or
	   self.myDDWorkListEntry = null then
		return false;
	endif;
	
	on Exception do app.handleDeletedObject(exception, self.myWorkListEntry, invalidWLE); 	// TFS 42879
	on Exception do app.handleDeletedObject(exception, self.myDDWorkListEntry, invalidWLE);	// TFS 42879
	
	// if cargo not splittable then leave
	if self.myTrackedItem = null or
	   not self.myTrackedItem.myCargoType.isAllowDuplicates then
		return false;
	endif;
	
	if self.myWorkListEntry.status = WLE_COMPLETED then
		return false;
	endif;
	
	self.myDDWorkListEntry.edition; // TFS 42879
	// if either of the wles is invalid then cant do much, so should leave
	if invalidWLE then	// TFS 42879
		return false;	// TFS 42879
	endif;
	
	if self.myTrackedItem.isKindOf(CM_BreakBulkGeneric) then
		adjustQuantity:=true;
	endif;
	if self.myTrackedItem.isKindOf(CM_Bulk) then
		adjustWeight:=true;
	endif;
	
	if not adjustWeight and not adjustQuantity then
		return false;
	endif;
	
	// do wle quantities/weights match
	if _postMove then
		if self.myWorkListEntry.quantity = self.myDDWorkListEntry.quantity and
		   self.myWorkListEntry.weight = self.myDDWorkListEntry.weight then
			amountsMatch := true;
		endif;
	else
		if adjustQuantity then
			if (self.quantity = self.myWorkListEntry.quantity or
			   self.quantity = self.myDDWorkListEntry.quantity) and
			   self.myWorkListEntry.quantity = self.myDDWorkListEntry.quantity then
				amountsMatch := true;
			endif;
		elseif adjustWeight then
			if (self.weight = self.myWorkListEntry.weight or
			   self.weight = self.myDDWorkListEntry.weight) and
			   self.myWorkListEntry.weight = self.myDDWorkListEntry.weight then
				amountsMatch := true;
			endif;
		endif;
	endif;
	
	// if amounts don't match then we need to split
	if not amountsMatch then
		// if post move, only want to split if wles are complete
		if (self.myWorkListEntry.isCompleteForJob and
			self.myDDWorkListEntry.isCompleteForJob) or
			not _postMove then
			
	//		if process.isNDL then
			
				job := self.myWorkListEntry.job;
				if job &lt;&gt; null then
					if job.isRelease then
						destWLE := self.myWorkListEntry;
						sourceWLE := self.myDDWorkListEntry;
					else
						destWLE := self.myDDWorkListEntry;
						sourceWLE := self.myWorkListEntry;
					endif;
				endif;
			
	/*		else
			
				destLoc := self.myToPrimaryLocation;
				if destLoc &lt;&gt; null then
					if destLoc.isKindOf(CM_WagonController) then
						if self.myWorkListEntry.isKindOf(CM_YardWLE) then
							destWLE := self.myWorkListEntry;
							sourceWLE := self.myDDWorkListEntry;
						else
							destWLE := self.myDDWorkListEntry;
							sourceWLE := self.myWorkListEntry;
						endif;
						
					elseif destLoc.isKindOf(CM_VoyageController) then
						if self.myWorkListEntry.isKindOf(CM_VoyageWLE) then
							destWLE := self.myWorkListEntry;
							sourceWLE := self.myDDWorkListEntry;
						else
							destWLE := self.myDDWorkListEntry;
							sourceWLE := self.myWorkListEntry;
						endif;
					endif;
				endif;
			
			endif; */
			
		endif;
	else
		// no need to split
		return false;
	endif;
	
	// have we got everything we need
	if destWLE = null or sourceWLE = null then
		return false;
	endif;
	
	if adjustQuantity then
		if self.quantity &gt; destWLE.quantity then
			//planning to move more than we can fit
			app.raiseCMException2(	ERR_LOWER_GT_UPPER,
								app.getErrorString( Move ) &amp; " " &amp; app.getErrorString( Quantity ),
								app.getErrorString( Required ) &amp; " " &amp; app.getErrorString( Quantity ),
								null,
								null );
		endif;
		if self.quantity &lt; sourceWLE.quantity then
			splitSourceWLE := true;
		endif;
		if self.quantity &lt; destWLE.quantity then
			splitDestWLE := true;
		endif;
		
	elseif adjustWeight then
		if self.weight &gt; destWLE.weight then
			//planning to move more than we can fit
			app.raiseCMException2(	ERR_LOWER_GT_UPPER,
								app.getErrorString( Move ) &amp; " " &amp; app.getErrorString( Weight ),
								app.getErrorString( Required ) &amp; " " &amp; app.getErrorString( Weight ),
								null,
								null );
		endif;
		if self.weight &lt; sourceWLE.weight then
			splitSourceWLE := true;
		endif;
		if self.weight &lt; destWLE.weight then
			splitDestWLE := true;
		endif;
	endif;
	
	// Handle splitting of source WLE
	if splitSourceWLE then
		wleSource:= sourceWLE.locationSource;
		wleTarget:= sourceWLE.locationTarget;
		
		// create new wle
		newSourceWLE := sourceWLE.cloneSelf(false);
		newSourceWLE.setJob(sourceWLE.job);
		newSourceWLE.setLocations(wleSource, wleTarget);
		newSourceWLE.updateRequest(sourceWLE.myRequest);
		
		if adjustQuantity then
			totalQty := sourceWLE.quantity;	// TFS 42872
			newSourceWLE.setQuantity(sourceWLE.quantity - self.quantity);
			sourceWLE.setQuantity(self.quantity);
			
			// If WLE is by quantity but has weight, then will want to adjust weight too
			if sourceWLE.weight &gt; 0 and not adjustWeight then								// TFS 42872
				totalWeight := sourceWLE.weight;											// TFS 42872
				newSourceWLE.setWeight(totalWeight * (newSourceWLE.quantity / totalQty));	// TFS 42872
				sourceWLE.setWeight(totalWeight - newSourceWLE.weight);						// TFS 42872
			endif;
		endif;
		
		if adjustWeight then
			newSourceWLE.setWeight(sourceWLE.weight-self.weight);
			sourceWLE.setWeight(self.weight);
		endif;
		newSourceWLE.setMyTrackedItem(sourceWLE.myTrackedItem);

		if newSourceWLE.job &lt;&gt; null then
			newSourceWLE.causeEvent(newSourceWLE.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), false, newSourceWLE);
			if newSourceWLE.job.isVoyageTypeJob then	// TFS 42872
				app.myEventManager.createSingleObjInfoNoteEvt(newSourceWLE.job.getMyVoyageObject, newSourceWLE.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), newSourceWLE);	// TFS 42872
			endif;
		endif;
	endif;
	
	//Handle splitting of destination WLE
	if splitDestWLE then
		wleSource:= destWLE.locationSource;
		wleTarget:= destWLE.locationTarget;
		
		// create new wle
		newDestWLE := destWLE.cloneSelf(false);
		newDestWLE.setJob(destWLE.job);
		newDestWLE.setLocations(wleSource, wleTarget);
		newDestWLE.updateRequest(destWLE.myRequest);
		
		//04 Oct 2019	NDL	TFS 42876
		if newDestWLE.myTrackedItem = null then
			if newDestWLE.myRequest &lt;&gt; null and newDestWLE.myRequest.isKindOf(CM_TIRequest) then
				newDestWLE.setMyTrackedItem( newDestWLE.myRequest.CM_TIRequest.trackedItem );
			endif;
		endif;
		
		if adjustQuantity then
			totalQty := destWLE.quantity;	// TFS 42872
			newDestWLE.setQuantity(destWLE.quantity - self.quantity);
			destWLE.setQuantity(self.quantity);
			
			// If WLE is by quantity but has weight, then will want to adjust weight too
			if destWLE.weight &gt; 0 and not adjustWeight then								// TFS 42872
				totalWeight := destWLE.weight;											// TFS 42872
				newDestWLE.setWeight(totalWeight * (newDestWLE.quantity / totalQty));	// TFS 42872
				destWLE.setWeight(totalWeight - newDestWLE.weight);						// TFS 42872
			endif;
		endif;
		
		if adjustWeight then
			newDestWLE.setWeight(destWLE.weight-self.weight);
			destWLE.setWeight(self.weight);
		endif;

		if newDestWLE.job &lt;&gt; null then
			newDestWLE.causeEvent(newDestWLE.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), false, newDestWLE);
			if newDestWLE.job.isVoyageTypeJob then	// TFS 42872
				app.myEventManager.createSingleObjInfoNoteEvt(newDestWLE.job.getMyVoyageObject, newDestWLE.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), newDestWLE);	// TFS 42872
			endif;
		endif;
	endif;
	
	// TFS 42872 Start
	// WorkListEntries for voyage hold jobs are already planned at the time of creation
	// so to set it for direct release we need to remove its current planned discharge move
	// and either delete it, or pass it on to the split wle that is not currently for direct
	// release
	if not _postMove and
	   sourceWLE.job.isKindOf(CM_VoyageHoldJob) and
	   sourceWLE.myFutureMove &lt;&gt; null then
	    if newSourceWLE &lt;&gt; null then
			sourceWLE.myFutureMove.setMyWorkListEntry(newSourceWLE, false);
		else
			tmpFM := sourceWLE.myFutureMove;
			delete tmpFM;
			self.setMoveIndex(0);
		endif;
	endif;
	
	return true;
	// TFS 42872 End
	
epilog

end;</source>
        <Parameter name="_postMove" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFromLocationsLock" id="82b15fd0-df88-4d46-b791-1e9f21e46f7e">
        <source>doFromLocationsLock();
/*
 ------------------------------------------------------------------------
Created:			27 July 2001 by cnwdwq1
Purpose:			Locks the locations controllers where the TI currently is
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	lc : CM_LocationsController;
	array : CM_LCArray;
begin
	if self.isUndoMove then
		//-----------------
		//No need to lock anything if we are undoing a move
		//-----------------
		return;
	endif;
	array := self.myTrackedItem.getLocationsArray(self.moveMode, 0);
	if array = null then
		//This is OK, it means the planned or queued moves dont exist
		return;
	endif;

	foreach lc in array do
		if self.warningsHaveBeenAcknowledged = false then
			//Doing validation
			//sharedLock(lc);
			// get a reservelock to ensure we
			// can upgrade later
			reserveLock(lc);
		else
			//Doing update
			exclusiveLock(lc);
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doJobUpdate" id="9cf1981c-f144-4f4e-968f-277bbc0660cd">
        <source>doJobUpdate(_passport : CM_Passport input) protected;
/*
 ------------------------------------------------------------------------
Created:			30 April 2002 by cnwdwq1
Purpose:			Calls the job update code.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if self.jobForMove = null then
		return;
	endif;
	
	// This does not have any code in it.
	self.jobForMove.moveEvent();

	// do the update status stuff in the service layer for notification purposes.
	app.myUtilityUA.utlUpdateJobStatus(self.jobForMove, _passport);
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSessionLockForAll" id="78ad6da3-839f-420c-a4d6-e95ef9b6c678">
        <updating/>
        <source>doSessionLockForAll() updating;
// ---------------------------------------------------------------------------
// Created:     29 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti	: CM_TrackedItem;

begin

	self.isUsingSessionLocks := true;

	foreach ti in self.allTrackedItemsForSplit do
		lock(ti, Exclusive_Lock, Session_Duration, 10);
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSessionUnlockForAll" id="4b4852e7-6698-401a-b196-50549d559466">
        <updating/>
        <source>doSessionUnlockForAll() updating;
// ---------------------------------------------------------------------------
// Created:     29 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti	: CM_TrackedItem;

begin

	foreach ti in self.allTrackedItemsForSplit do
		unlock(ti);
	endforeach;

	self.isUsingSessionLocks := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="doTILock" id="6093a732-5c2c-4102-a391-457daaabc717">
        <source>doTILock() protected;
/*
 ------------------------------------------------------------------------
Created:			27 July 2001 by cnwdwq1
Purpose:			Does the required locking.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	if self.warningsHaveBeenAcknowledged = false then
		//Validating
		sharedLock(self.myTrackedItem);
	else
		//Updating
		exclusiveLock(self.myTrackedItem);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doToLocationColLock" id="9959a0b6-7ac2-4844-8456-9912d93d5061">
        <source>doToLocationColLock();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 March 2025		jlizm1	Initial creation MTN 23109 Deadlock between Truck Loader and Work Order Operations

*/

vars
	target : CM_LocationsController;
	lc	   : CM_LocationsController;
begin
	
	lc := self.myToPrimaryLocation;
	
	if lc = null then
		// no location to lock
		return;
	endif;
	
	if self.moveMode &lt;&gt; REAL_MODE then
		// not actually moving to location, so don't need exclusive lock
		return;
	endif;
	
	target := lc;

	if not self.tryLock(target.allTrackedItems, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
		self.exclusiveLock(target.allTrackedItems);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doToLocationLock" id="a18844ac-9605-48c4-9b30-22e9429978d8">
        <source>doToLocationLock();
/*
 ------------------------------------------------------------------------
Created:			27 July 2001 by cnwdwq1
Purpose:			Locks the locations primary controller where the TI is intending to go to
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if self.myToPrimaryLocation = null then
		//----------------
		//The location can be NULL
		//----------------
		return;
	endif;
	if self.warningsHaveBeenAcknowledged = false then
		//Doing validation
		//sharedLock(self.myToPrimaryLocation);
		// get a reservelock to ensure we
		// can upgrade later
		reserveLock(self.myToPrimaryLocation);
	else
		//Doing update
		exclusiveLock(self.myToPrimaryLocation);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doToSecondaryLocationsLock" id="4416584a-eb55-4c6f-864d-3dfe917f62e9">
        <source>doToSecondaryLocationsLock();
/*
 ------------------------------------------------------------------------
Created:			08 August 2001 by cnwdwq1
Purpose:			Locks the locations controllers passed in where the TI is intending to go to
							The collection woill have been found by the lc::.getSpannedToLCs method
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	lc : CM_LocationsController;
begin
	foreach lc in self.myToSecondaryLocations do
		if self.warningsHaveBeenAcknowledged = false then
			//Doing validation
			//sharedLock(lc);
			// get a reservelock to ensure we
			// can upgrade later
			reserveLock(lc);
		else
			//Doing update
			exclusiveLock(lc);
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateDisplay" id="7524dc70-03f1-4602-b840-ad57f4402b71">
        <source>doUpdateDisplay() protected;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02 May 2024 navma1 ChangeRequest 63936: MTN - Use Deferred Updates When Confirm Wagons
// ---------------------------------------------------------------------------

vars
	tmpBOL			: CM_BOL;
	theVoyage		: CM_Voyage;
	theTerminal		: CM_Terminal;
	lControllerS, 
	lControllerT	: CM_LocationsController;
	ti				: CM_TrackedItem;
begin
	
	ti := self.myTrackedItem;								//02.05.2024 navma1 #63936
	
	if ti = null then
		return;
	endif;

	theTerminal  := ti.myTerminal;	
	lControllerS := self.myOriginatingLocation;
	lControllerT := self.myToPrimaryLocation; 

	self.doUpdateDisplayEvent(lControllerS);

	if lControllerT = null or lControllerS = null then
		//Move from or to offsite
		theVoyage := ti.myVoyage;
		if theVoyage &lt;&gt; null and theTerminal &lt;&gt; null then
			if theVoyage.isHOLDSorSHIP() then
				app.myEventManager.createSingleObjInfoNoteEvt(theVoyage,
														      theTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),
														      theVoyage);			
			endif;
		endif;		
	endif;
	
	foreach lControllerT in self.allToLocations do
		self.doUpdateDisplayEvent(lControllerT);
	endforeach;
	
	//01 Feb 2018	NDL	TFS 36848 - Needed to draw back ends, in end view on Yard Grid View.
	if self.moveMode = QUEUE_MODE and ti.myOSBackEndLocationQd &lt;&gt; null then
		self.doUpdateDisplayEvent(ti.myOSBackEndLocationQd);
	elseif self.moveMode = PLANNING_MODE and ti.myOSBackEndLocationPd &lt;&gt; null then
		self.doUpdateDisplayEvent(ti.myOSBackEndLocationPd);
	endif;
	
	tmpBOL := ti.myReceivalBOL;
	if tmpBOL &lt;&gt; null then
		app.myEventManager.createSingleObjInfoNoteEvt(tmpBOL, theTerminal.getTerminalEvent(BOL_Update_Event), tmpBOL);				
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUpdateDisplayEvent" id="b8cdde57-b0a2-43bf-ab98-8ba7ece47581">
        <source>doUpdateDisplayEvent(_theLocationController : CM_LocationsController);
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:	
// 02 May 2024 navma1 ChangeRequest 63936: MTN - Use Deferred Updates When Confirm Wagons	
// ---------------------------------------------------------------------------
vars
	theTerminal : CM_Terminal;
	theTI 		: CM_TrackedItem;
begin
	if _theLocationController = null or app.isUnitTestGarbageCollect then
		return;
	endif; 
	
	theTerminal := _theLocationController.myTerminal;
	theTI := self.myTrackedItem;
	
	if theTerminal = null then
		return;
	endif;
	
	_theLocationController.executeDisplayNotesForMove(self);	
	
end;</source>
        <Parameter name="_theLocationController" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="doUpdateDisplayKPIYard" id="8ddda6c3-ce36-42e0-9a2a-e88455c0eed7">
        <updating/>
        <source>doUpdateDisplayKPIYard(_before : Boolean) protected, updating;
// ---------------------------------------------------------------------------
// Created:		January 2008 By Andrew Bishop cnwab1
//
// Purpose:		create notes to update the YARD KPI screen, we calculate adjusters which will have a value of 1, 0 or -1
//
// ---------------------------------------------------------------------------
constants
	Delimiter = "^";
	Header = "~";
vars
	theTerminal		: CM_Terminal;
	lControllerS, 
	lControllerT	: CM_LocationsController;
	taS, taT : CM_TerminalArea;
	is40 : Boolean;
	localInfo : String;
	beforeKPISource, beforeKPITarget : Integer;
	teu, afterKPISource, afterKPITarget : Integer;
	
	stackIndex, stackValue, maxStack, totTI, totTEU, padsMT, padsOccupied, padsFull : Integer;
	infoString : String;
begin
	if self.moveMode &lt;&gt; REAL_MODE then
		return;
	endif;
	
	// no cargo
	if self.myTrackedItem = null then
		return;
	endif;

	theTerminal := self.myTrackedItem.myTerminal;	

	// no kpi license
//	if not app.myPassport.myUser.canDo(theTerminal, PmKPIModule) then
	if not app.myPassport.myUser.canDo(theTerminal, Mod_BaseSystem) then//07 Oct 2019	NDL	TFS 46169
		return;
	endif;

	
	
	lControllerS := self.myOriginatingLocation;
	lControllerT := self.myToPrimaryLocation; 

	// BEFORE MOVE
	if _before then
		if lControllerS &lt;&gt; null then
			taS := lControllerS.myTerminalArea;
			// only yard
			if taS &lt;&gt; null and lControllerS.isYardLocation() then
					self.numKPISource := lControllerS.allTrackedItems.size;
			endif;
		endif;
		if lControllerT &lt;&gt; null then
			taT := lControllerT.myTerminalArea;
			// only yard
			if taT &lt;&gt; null and lControllerT.isYardLocation() then
					self.numKPITarget := lControllerT.allTrackedItems.size;
			endif;
		endif;
		
		
		return; // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
		
		
	endif;

	
	// ### AFTER MOVE
	infoString := CMIF_KPIYardMove.name &amp; Header &amp; self.getOidStringForObject(lControllerS) &amp; Delimiter &amp; self.getOidStringForObject(lControllerT)
						 &amp; Delimiter &amp;  self.getOidStringForObject(self.myTrackedItem) &amp; Delimiter &amp; self.numKPISource.String &amp; Delimiter &amp; self.numKPITarget.String;
	system.causeEvent(KPIAgent_UpdateEvent, false, infoString);

	return;
/*	
	// ### AFTER MOVE
	beforeKPISource := self.numKPISource;
	beforeKPITarget := self.numKPITarget;

	is40 := self.myTrackedItem.isForty();
	if is40 then
		teu := 2;
	else
		teu := 1;
	endif;
	

	// ### SOURCE
	// ### At the source it is about an item leaving 
	if lControllerS &lt;&gt; null 
	and lControllerS.isYardLocation() then
		taS := lControllerS.myTerminalArea;
		if taS &lt;&gt; null then
			// AFTER MOVE
			afterKPISource := lControllerS.allTrackedItems.size;
			maxStack := lControllerS.getMaxStackingHeight();
			totTI := -1;
			totTEU := (-1 * teu);
			
			if afterKPISource = 0 then // NOW EMPTY
				padsMT := (1 * teu);
				padsOccupied := (-1 * teu);
				if beforeKPISource = maxStack then
					padsFull := (-1 * teu);
				else
					padsFull := 0;
				endif;
				stackIndex := 1;
				stackValue := (1 * teu);
			else // IS OCCUPIED
				padsMT := 0;
				padsOccupied := 0;
				if afterKPISource = maxStack then // NOW FULL
					padsFull := (1 * teu);
				else
					if beforeKPISource = maxStack then // WAS FULL
						padsFull := (-1 * teu);
					else
						padsFull := 0; // do not adjust
					endif;
				endif;
				stackIndex := beforeKPISource;
				stackValue := (1 * teu);
			endif;
			localInfo := totTI.String &amp; Delimiter &amp;  totTEU.String &amp; Delimiter &amp;  padsMT.String &amp; Delimiter &amp;  padsOccupied.String &amp; 
							Delimiter &amp;  padsFull.String &amp; Delimiter &amp; stackIndex.String &amp; Delimiter  &amp; stackValue.String;
			taS.causeEvent(theTerminal.getTerminalEvent(EVENT_KPIYARDMOVE),false,localInfo );				
		endif;
	endif;
	
	// ### TARGET
	// ### At the target it is about an item being received.
	if lControllerT &lt;&gt; null 
	and lControllerT.isYardLocation() then
		taT := lControllerT.myTerminalArea;
		if taT &lt;&gt; null then
			afterKPITarget := lControllerT.allTrackedItems.size;
			maxStack := lControllerT.getMaxStackingHeight();
			totTI := 1;
			totTEU := (1 * teu);
			
			if beforeKPITarget = 0 then // WAS EMPTY
				padsMT := (-1 * teu);
				padsOccupied := 1;
				if afterKPITarget = maxStack then // NOW FULL
					padsFull := (1 * teu);
				else
					padsFull := 0;
				endif;
				stackIndex := 1;
				stackValue := (-1 * teu);
			else // WAS OCCUPIED
				padsMT := 0;
				padsOccupied := 0;
				if afterKPITarget = maxStack then // NOW FULL
					padsFull := (1 * teu);
				else
					padsFull := 0;
				endif;
				stackIndex := afterKPITarget;
				stackValue := (-1 * teu);
					
			endif;
			localInfo := totTI.String &amp; Delimiter &amp;  totTEU.String &amp; Delimiter &amp;  padsMT.String &amp; Delimiter &amp;  padsOccupied.String &amp; 
							Delimiter &amp;  padsFull.String &amp; Delimiter &amp;  stackIndex.String &amp; Delimiter  &amp; stackValue.String;
			taT.causeEvent(theTerminal.getTerminalEvent(EVENT_KPIYARDMOVE),false,localInfo );				
		endif;
	endif;
	*/
end;</source>
        <access>protected</access>
        <Parameter name="_before" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateParentAfterPack" id="7beb1f83-b504-4766-9f8a-49ff873c1b04">
        <source>doUpdateParentAfterPack(	_packWeight : Decimal;
							_packVolume : Decimal;
							_passport : CM_Passport input) protected;
/* Changes

Date		Name	TFS#		Description
============================================================================
14/07/2014	cnwer1				Initial creation PAR
08/09/2016  cnwma1  TFS #2589
					PAR38142 	STWR - TFS2239 " Double assign to release" -fix not OK
23/05/2019	jlgka1	TFS 43346	LNX - Multiple Hazardous Details with same Hazardous Class.
20/11/2019	jlgzm1	TFS 47222 	Remove All Import stops is redundant
19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
21/05/2024	jlika1	TFS 64218 CUX | Error raised when packing LCL with LCL (which should be possible)
06 Jun 2024	navnk30	Bug 64066: PRP- Duplicated Hazardous details.
============================================================================*/

vars
	pxyPackCargo,
	pxyParentCargo 		: CM_TrackedItem;
	newBR				: CM_BulkRelease;
	packToUpdateCntrl,
	tiUpdateCntrl		: CMIF_TIUpdateController;	
	transhipInterface	: CMIF_TranshipTIController;	// PAR #31196
	haz 				: CM_Hazard;
	tiHaz 				: CM_TIHazard;
	setParentFromChild 	: Boolean;
	pxyParentCreated	: Boolean;		//cnwmc5 - 3 Feb 2016 - PAR 37499
	defCommodity, mtCommodity	: String;
begin
	if self.myPackToTI = null then
		return;
	endif;

	newBR := self.myPackRelease; //epr TFS 2897 5/12/16
	if newBR = null then
		newBR := self.myPackToTI.allBulkReleasesAssigned.getAtKeyGeq(BR_TYPE_PACKING, null, null, null);
	endif;
	if newBR &lt;&gt; null then
		if newBR.myTerminal.getConfig(OnlyPackAssignedItems).Boolean then // rjs - change to use correct terminal
			if not  self.myTrackedItem.allBulkReleasesAssigned.includes(newBR) then
				app.raiseCMWarning2(Not_Assigned_To_PR,  self.myTrackedItem.id, newBR.code, null, null, null);
			endif;
		endif;
	endif;	
	//epr par 36556 6/4/15
	if self.myPackToTI.myBookingRef &lt;&gt; null and self.myPackToTI.myBookingRef.packAs = BOOKING_PACKAS_FCL  and not self.myTrackedItem.isEquipment then //epr par 37213 20/11/15
		if self.myTrackedItem.myBookingRef &lt;&gt; null and self.myTrackedItem.myBookingRef &lt;&gt; self.myPackToTI.myBookingRef 
			or self.myTrackedItem.bookingReference &lt;&gt; self.myPackToTI.myBookingRef.bookingReference then //epr par 37213 20/11/15
			//raise Exception
			app.raiseCMException4(Booking_can_not_differ,self.myPackToTI.id ,self.myPackToTI.getBookingReference,self.myTrackedItem.id,self.myTrackedItem.getBookingReference,null,null);
			return;
		endif;
	elseif self.myPackToTI.myBookingRef &lt;&gt; null and self.myPackToTI.myBookingRef.packAs = BOOKING_PACKAS_LCL then
		if self.myTrackedItem.myTerminal.getConfig(ShowErrorWhenFCLonLCL).Boolean and (self.myTrackedItem.myBookingRef &lt;&gt; null and self.myTrackedItem.myBookingRef.packAs &lt;&gt; BOOKING_PACKAS_LCL) then 
			//raise Exception
			app.raiseCMException4(Booking_can_not_differ,self.myPackToTI.id ,self.myPackToTI.getBookingReference,self.myTrackedItem.id,self.myTrackedItem.getBookingReference,null,null);
			return;
		endif;
	endif;
	setParentFromChild := self.myPackToTI.allChildren.isEmptyOrContainsOnlyEquipment and self.myPackToTI.isStorage;	//29 Apr 2015	NDL	Par 36111 - TFS243
	
	tiUpdateCntrl:=app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.myPassport.userCode, null);	
	tiUpdateCntrl.saveTIDataPriorUpdate(self.myTrackedItem, app.myPassport);	
	
	// 37501 Feb 2016 clear child cargo booking from pack unpack screen but not from hand-held to retain prior functionality
	if app.activeForm &lt;&gt; null and
	   app.activeForm.class.name = "YRD_PackUnpack" and
	   self.myTrackedItem.bookingReference = self.myPackToTI.bookingReference then
		 self.myTrackedItem.setBookingReference(null);
	endif;	
	
	//updating packedCargo
	if self.myTrackedItem.isTranshipItem then																		// PAR #31196
			if self.myPackToTI.isStorage then																	// PAR #31196
				// 1. Tranship child packed in to Storage parent											// PAR #31196
				// copy tranship details from child to parent													// PAR #31196
				create transhipInterface transient;																// PAR #31196
				transhipInterface.myExportDestPort 	:= app.myRoot.allPorts[self.myTrackedItem.destinationPort];		// PAR #31196
				// TFS 2122 add null test
				if self.myTrackedItem.myTranshipDetail &lt;&gt; null then
					transhipInterface.myExportDisPort	:=  self.myTrackedItem.myTranshipDetail.myDischargePort;			// PAR #31196
				endif;
				transhipInterface.myExportVoyage	:=  self.myTrackedItem.myExportVoyage;							// PAR #31196
				transhipInterface.myTranshipToPort	:=  self.myTrackedItem.myTranshipToPort;							// PAR #31196
				transhipInterface.remarks			:=  self.myTrackedItem.remarksTranship;							// PAR #31196
				// TFS 2122 add null test
				if self.myTrackedItem.myTranshipDetail &lt;&gt; null then
					transhipInterface.bookingRef		:=  self.myTrackedItem.myTranshipDetail.exportBookingReference;	// PAR #31196
					transhipInterface.billOfLading		:=  self.myTrackedItem.myTranshipDetail.exportBOL;				// PAR #31196
				endif;
				
				pxyParentCargo:= self.myPackToTI.pxyGetProxyObject();
				if pxyParentCargo = null then
					pxyParentCargo := self.myPackToTI.pxyCreateUpdateProxy();
					pxyParentCreated := true;		//cnwmc5 - 3 Feb 2016 - PAR 37499
				endif;
				
				pxyParentCargo.setPxyFromCMIF_TranShip(transhipInterface, self.myPackToTI);							// PAR #31196
				self.myPackToTI.setMyVoyage( self.myTrackedItem.myImportVoyage, _passport);								// PAR #31196
				self.myPackToTI.setTranship(pxyParentCargo, _passport, true);								// PAR #31196
				delete transhipInterface;																		// PAR #31196
				
			elseif self.myPackToTI.isExport then	
				pxyPackCargo:=  self.myTrackedItem.pxyGetProxyObject();
				if pxyPackCargo = null then
					pxyPackCargo :=  self.myTrackedItem.pxyCreateUpdateProxy();
				endif;// PAR #31196
				// 2. Tranship child packed in Export parent												// PAR #31196
				pxyPackCargo.zSetPxyImexStatus(TI_IMEX_STATUS_EXPORT);										// PAR #31196
				pxyPackCargo.zSetPxyRemarks(null);															// PAR #31196
				pxyPackCargo.zSetImportVoyage(null);															// PAR #31196
				self.myTrackedItem.setTranshipToNonTranship(pxyPackCargo, null, _passport);					// PAR #31196

			endif;																							// PAR #31196
	elseif  self.myTrackedItem.isImport or  self.myTrackedItem.isStorage then													// PAR #31196
		// 3. Import or Storage child packed in to Tranship parent										// PAR #31196
		if self.myPackToTI.isTranshipItem then															// PAR #31196
			// change child to Export - use statusEvent instead of setImExStatus to get edit transaction// PAR #31196
			if  self.myTrackedItem.myVoyage =  self.myTrackedItem.myTerminal.getNullVoyage then									// PAR #31196
				 self.myTrackedItem.changeVoyage(self.myPackToTI.myVoyage, _passport);								// PAR #31196
			endif;																						// PAR #31196
			 self.myTrackedItem.statusEvent(VOYAGE_STATUS_EV, true, _passport);										// PAR #31196
		endif;																							// PAR #31196
	endif;		
	self.myTrackedItem.endUpdate(tiUpdateCntrl,_passport);
	
	packToUpdateCntrl:=app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.myPassport.userCode, null);	
	packToUpdateCntrl.saveTIDataPriorUpdate(self.myPackToTI, app.myPassport);	
	
	if not self.myPackToTI.allChildren.includes( self.myTrackedItem) then
		self.myPackToTI.attachChild( self.myTrackedItem, _passport);
	endif;
	if (app.getMyUser.canDo(self.myPackToTI.myTerminal, PmAdmWeightOverride))
	and not self.isPackUnpackWeightSet then			//cnwmc5 - 3 Dec 2015 - PAR 37213
		self.myPackToTI.updateTotalWeightFromChildren();
	endif;
	
	//jlgka1 TFS 43346 --&gt;
	foreach haz in  self.myTrackedItem.allTIHazards do
		if self.myPackToTI.hasHazByCodePackUNDG(haz.CM_TIHazard) then		//06.06.2024 navnk30 #64066
			continue;
		endif;
		create tiHaz persistent;
		tiHaz.setForCreate(haz, self.myPackToTI, app.myPassport);
	endforeach;
	//jlgka1 TFS 43346 &lt;--
	
	self.myPackToTI.setSpecialStowFromPackChild(self.myTrackedItem);		//cnwmc5 - 14 Sep 2015 - PAR 36891
	
	self.myPackToTI.setWeightCargo(self.myPackToTI.weightCargo + _packWeight);	//13 Sep 2011	NDL	Par 26476
	self.myPackToTI.setMyCargoVolume(self.myPackToTI.getMyCargoVolume + _packVolume);
	//self.myPackToTI.createPackTransactions( self.myTrackedItem,self.quantity,_packWeight ,_passport); //08/09/2016 cnwma1 TFS #2589
// TFS 7031	self.myPackToTI.createPackTransactions( self.myTrackedItem,self.quantity,_packWeight ,newBR,_passport);  //08/09/2016 cnwma1 TFS #2589
	self.myPackToTI.createPackTransactions( self, self.myTrackedItem,self.quantity,_packWeight, _packVolume ,newBR,self.retrospectiveDT,_passport);  // TFS 7031 added volume	//19.03.2024 navhl20 #62863

	if self.myPackToTI.canBoxBeReweighed(self.myPackToTI.myTerminal) then
		self.myPackToTI.setWeighStatus(WEIGH_STATUS_FORCED);
	endif;
	
	self.myPackToTI.setTotalWeightSetFlag(false);
	
	// jlier1 TFS 51879 13/9/21 -  don't want the page to update commodity - set to the def commodity if is still MT after pack
	if self.updatePackToCommodity then
		mtCommodity:=self.myPackToTI.myTerminal.getDefaultEmptyCommodity;
		if self.myPackToTI.commodity.trimBlanks = mtCommodity then
			defCommodity:= self.myPackToTI.myTerminal.getConfig(DefCommodity).String;
			if defCommodity &lt;&gt; null and defCommodity &lt;&gt; mtCommodity then
				self.myPackToTI.setCommodity(defCommodity);
			endif;
		endif;
	endif;
	
	
	self.myPackToTI.endUpdate(packToUpdateCntrl,_passport);
	 
	self.myTrackedItem.updateForPackOfChildEquipment( self.myPackToTI, setParentFromChild );	//29 Apr 2015	NDL	Par 36111 - TFS243
	
	
epilog
	delete tiUpdateCntrl;
	delete packToUpdateCntrl;
	delete pxyPackCargo;
	
	//cnwmc5 - 3 Feb 2016 - PAR 37499
	if pxyParentCreated then
		delete pxyParentCargo;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_packWeight" type="Decimal"/>
        <Parameter name="_packVolume" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateParentAfterUnpack" id="24da257b-e4c8-47b6-9b71-8550d368965e">
        <source>doUpdateParentAfterUnpack(	_unpackWeight : Decimal;
							_unpackVolume : Decimal;
							_passport : CM_Passport input) protected;
/*

Date		Who		Reason
11 July 2014	cnwer1	Initial creation PAR
14 Mar 2024 	navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
*/

vars
	pxyParent 		: CM_TrackedItem;
	unpackFromUpdateCntrl,
	tiUpdateCntrl	: CMIF_TIUpdateController;
	futureMove 		: CM_FutureMove;
	rtQueueEntry 	: CM_RTQueueEntry;
	task 			: CM_RTQueueTask;
	remainHeld 		: Boolean;
	reason 			: String;
	pxyParentCreated	: Boolean;		//cnwmc5 - 3 Feb 2016 - PAR 37499
	
begin
	if self.myUnpackFromTI = null then
		return;
	endif;
	
	if self.moveMode &lt;&gt; REAL_MODE then
		return;
	endif;
	
	unpackFromUpdateCntrl:=app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.myPassport.userCode, null);	
	unpackFromUpdateCntrl.saveTIDataPriorUpdate(self.myUnpackFromTI, app.myPassport);	
	
	 self.myUnpackFromTI.detachChild(self.myTrackedItem);

	 self.myUnpackFromTI.setTotalWeightSetFlag(false);
	if (app.getMyUser.canDo( self.myUnpackFromTI.myTerminal, PmAdmWeightOverride))
	and not self.isPackUnpackWeightSet then			//cnwmc5 - 3 Dec 2015 - PAR 37213
		 self.myUnpackFromTI.updateTotalWeightFromChildren();
	endif;	
	
	//13 Sep 2011	NDL	Par 26476
	 self.myUnpackFromTI.setWeightCargo(( self.myUnpackFromTI.weightCargo - _unpackWeight).max(0));	
	 self.myUnpackFromTI.setMyCargoVolume(( self.myUnpackFromTI.getMyCargoVolume - _unpackVolume).max(0));	
	
	//create unpack transactions
	 self.myUnpackFromTI.createUnpackTransactions(self.myTrackedItem,self.quantity ,	self.weight, _unpackVolume, self.retrospectiveDT, _passport); // TFS 7031	//14.03.2024 navhl20 #62861
	
	if  self.myUnpackFromTI.allChildren.isEmpty then
		if  self.myUnpackFromTI.isTranshipItem then	
			
			//cnwmc5 - 3 Feb 2016 - PAR 37499
			pxyParent := self.myUnpackFromTI.pxyGetProxyObject;
			if pxyParent = null then
				pxyParent := self.myUnpackFromTI.pxyCreateUpdateProxy;
				pxyParentCreated := true;
			endif;
			
			//pxyParent	:= self.myUnpackFromTI.pxyCreateUpdateProxy;
			pxyParent.zSetPxyImexStatus(TI_IMEX_STATUS_STORAGE);										// PAR #31196
			pxyParent.zSetPxyRemarks(null);															// PAR #31196
			pxyParent.zSetImportVoyage(null);														// PAR #31196
				
			self.myUnpackFromTI.setTranshipToNonTranship(pxyParent, null, _passport);			// PAR #31196
			self.myUnpackFromTI.changeVoyage( self.myUnpackFromTI.myTerminal.getNullVoyage, _passport);				// PAR #31196
			
		endif;	
		//mt this updates dimensions weight etc when mt
		 self.myUnpackFromTI.updateHazardODWhenUnpack();
		 self.myUnpackFromTI.assignToDoTasks(true,_passport);
	
	endif;
	
	if  self.myUnpackFromTI.canBoxBeReweighed(_passport.myTerminal) then
		 self.myUnpackFromTI.setWeighStatus(WEIGH_STATUS_FORCED);
	endif;
	
	//30 July 2014	NDl	Par 34665
	if not self.myTrackedItem.allQueuedFutureMoves.isEmpty then
		foreach futureMove in self.myTrackedItem.allQueuedFutureMoves do
			foreach rtQueueEntry in futureMove.CM_FutureMoveQueued.allRTQueueEntries do
				task := rtQueueEntry.allTasks.first;
				remainHeld := false;
				if task.ti &lt;&gt; null then												
					remainHeld := task.ti.isHeldRTQueueStatus(true, null, reason);	
				endif;															
				if task.status = TASK_SYS_HELD and not remainHeld then											
					task.setStatus(TASK_UNACTIONED);
				endif;
			endforeach;
		endforeach;
	endif;
	self.myUnpackFromTI.endUpdate(unpackFromUpdateCntrl,_passport);
	
	tiUpdateCntrl:=app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.myPassport.userCode, null);	
	tiUpdateCntrl.saveTIDataPriorUpdate(self.myTrackedItem, app.myPassport);	
		//after detach refesh future locations and the ti location id
	self.myTrackedItem.refreshMyFutureLocations(REAL_MODE,null);
	self.myTrackedItem.setLocationId(self.myToPrimaryLocation.getFullIdForTIForMode(REAL_MODE)[1:30]);
	self.myTrackedItem.setUnpackedDT(app.actualTimeServer);
	
	self.myTrackedItem.endUpdate(tiUpdateCntrl,_passport);
	//epr CCMS 2512 if you call this method here we get the edit transaction if something has changed
	self.myTrackedItem.updateForUnpackOfChildEquip( self.myTrackedItem.myTerminal );	//29 Apr 2015	NDL	Par 36111 - TFS243
	
	
	 
epilog
	//cnwmc5 - 3 Feb 2016 - PAR 37499
	if pxyParentCreated then
		delete pxyParent;
	endif;
	
	delete unpackFromUpdateCntrl;
	delete tiUpdateCntrl;
end;</source>
        <access>protected</access>
        <Parameter name="_unpackWeight" type="Decimal"/>
        <Parameter name="_unpackVolume" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateRotatableAfterUnload" id="834a641d-c1c5-4a05-96fc-8c6e33311c73">
        <updating/>
        <source>doUpdateRotatableAfterUnload(_passport : CM_Passport input) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 October 2025	jlier1	Initial creation 36155

*/

vars

	rotatableMTController : CMIF_RotatableContEmptyCntlr;
	contentsCargoType : CM_CargoType;
	contentsCargoSubType : CM_Product;
	commodity 			: String;
	rotatableTransaction : CM_TITransaction;
begin
	if self.myRotatableContainer = null then
		return;
	endif;
	
	if self.moveMode &lt;&gt; REAL_MODE then
		return;
	endif;
		
	
	//get the contents cargo type and subtype before they get cleared
	contentsCargoType:=self.myRotatableContainer.getCargoTypeForContents;
	contentsCargoSubType:=self.myRotatableContainer.getCargoSubTypeForContents;
	commodity:=self.myRotatableContainer.commodity;
	
	self.myRotatableContainer.clearDetailsForUnpack(); // IMEX is being set to storage here, Voyage is set to null voyage, discharge, destination port is being set to null.
	self.myRotatableContainer.setCommodity(self.myRotatableContainer.myTerminal.getDefaultEmptyCommodity());
	self.myRotatableContainer.setContentsStatus(TI_CONTENTS_STATUS_EMPTY);  
	self.myRotatableContainer.setImExStatus(TI_IMEX_STATUS_STORAGE);
	self.myRotatableContainer.updateForUnpackOfChildEquip(self.myRotatableContainer.myTerminal); //does storage and clears the voyage
	self.myRotatableContainer.updateTotalWeightFromChildren(); //should set to the tare weight - cargo weight becomes zero
	self.myRotatableContainer.setWeightCargo(0);
	self.myRotatableContainer.setCargoTypeForContents(null);
	self.myRotatableContainer.setCargoSubTypeForContents(null);
	
	create rotatableMTController transient;
	rotatableMTController.type := TRANS_TYPE_ROTATABLE_EMPTY;
	rotatableMTController.myTrackedItem := self.myRotatableContainer;  
	if contentsCargoType &lt;&gt; null then
		rotatableMTController.cargoTypeForContents:=contentsCargoType.id;
	endif;
	if contentsCargoSubType &lt;&gt; null then
		rotatableMTController.cargoSubTypeForContents:=contentsCargoSubType.code;
	endif;
	rotatableMTController.commodity:=commodity;
	rotatableMTController.cargoWeight:=self.weight;
	
	self.myRotatableContainer.createTransaction(rotatableMTController,_passport);
	
epilog
	
	delete rotatableMTController;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateSnap" id="6c490088-4297-4d22-bb0c-7f4d9b45e1de">
        <updating/>
        <source>doUpdateSnap() updating;
// ---------------------------------------------------------------------------
// Created:     14 January 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	gridArea : CM_GridArea;
	primGC, prevGC, nextGC : CM_GridController;
	theTI, tmpTI : CM_TrackedItem;
	anFM : CM_FutureMove;
begin
	
	if self.isShiftMove then
		return;
	endif;
	
	if self.myToPrimaryLocation = null then
		return;
	endif;
	
	if self.myToPrimaryLocation.myTerminalArea = null then
		return;
	endif;
	
	if  not self.myToPrimaryLocation.myTerminalArea.isGridArea() then
		return;
	endif;
	theTI := self.myTrackedItem;

	if theTI = null then
		return;
	endif;
	
	gridArea := self.myToPrimaryLocation.myTerminalArea.CM_GridArea;
	
	if not (gridArea.isSnapStrictGrid or gridArea.isSnapToBackend) then
		return;
	endif;
	
	primGC := self.myToPrimaryLocation.CM_GridController;
	
	if gridArea.isRightAligned() then
		if gridArea.isSnapStrictGrid then
		
		endif;
		if gridArea.isSnapToBackend then
			if not primGC.doesTIMatchOffsetForPrime(theTI) then
				if not primGC.allTrackedItems.isEmpty() then
					tmpTI := primGC.allTrackedItems.first;
					if tmpTI = theTI then // ignore itself, if moving 1 location over
						return;
					endif;
					if tmpTI.getActualLength() = theTI.getActualLength() then
						primGC := tmpTI.myPrimaryActualLocation.CM_GridController;
					endif;
				elseif not primGC.allTrackedItemOSBackEnds.isEmpty() then
					tmpTI := primGC.allTrackedItemOSBackEnds.first;
					if tmpTI = theTI then // ignore itself, if moving 1 location over
						return;
					endif;
					if tmpTI.getActualLength() = theTI.getActualLength() then
						primGC := tmpTI.myPrimaryActualLocation.CM_GridController;
					endif;
				else
					if primGC.allTrackedItemOSBackEnds.isEmpty() then
						nextGC := primGC.getNextControllerOfType(CM_GridController);
						
						if nextGC &lt;&gt; null then
							if primGC &lt;&gt; nextGC then
								tmpTI := nextGC.allTrackedItems.first;
								if tmpTI = theTI then // ignore itself, if moving 1 location over
									return;
								endif;
								if nextGC.offsetFlexi &gt; 0 and nextGC.offsetFlexi &lt; 20 then
									primGC := nextGC;
								endif;
							endif;
						endif;
					endif;
				endif;
			endif;
			
		endif;
	else
		if gridArea.isSnapStrictGrid then
			if not primGC.doesTIMatchOffsetForPrime(theTI) then
				prevGC := primGC.getPreviousControllerOfType(CM_GridController);
				
				if prevGC &lt;&gt; null then
					if prevGC.isOKForOverSizedCargo() then
						if prevGC.doesTIMatchOffsetForPrime(theTI) then
							primGC := prevGC;
						else
							prevGC := prevGC.getPreviousControllerOfType(CM_GridController);
							if prevGC &lt;&gt; null then
								if prevGC.doesTIMatchOffsetForPrime(theTI) then
									primGC := prevGC;
								endif;
							endif;
						endif;
					endif;
				endif;
			endif;
		endif;
		if gridArea.isSnapToBackend then
			if not primGC.doesTIMatchOffsetForPrime(theTI) then
				 // ### SNAP to existing ACTUAL TI
				if not primGC.allTrackedItems.isEmpty() then
					tmpTI := primGC.allTrackedItems.first;
					if tmpTI = theTI then // ignore itself, if moving 1 location over
						return;
					endif;
					if tmpTI.getActualLength() = theTI.getActualLength() then
						primGC := tmpTI.myPrimaryActualLocation.CM_GridController;
					endif;
				 // ### SNAP to existing PLANNED TI
				elseif not primGC.allPlannedFutureMoves.isEmpty() then
					anFM := primGC.allPlannedFutureMoves.first;
					tmpTI := anFM.getTrackedItem();
					
					if tmpTI.getActualLength() = theTI.getActualLength() then
						primGC  := anFM.getPrimaryLocation().CM_GridController;
					endif;
				 // ### SNAP to existing QUEUED TI
				elseif not primGC.allQueuedFutureMoves.isEmpty() then
					anFM := primGC.allQueuedFutureMoves.first;
					tmpTI := anFM.getTrackedItem();
					
					if tmpTI.getActualLength() = theTI.getActualLength() then
						primGC  := anFM.getPrimaryLocation().CM_GridController;
					endif;
				 // ### SNAP to backend TI
				else
					if primGC.allTrackedItemOSBackEnds.isEmpty() then
						prevGC := primGC.getPreviousControllerOfType(CM_GridController);
						
						if prevGC &lt;&gt; null then
							if primGC &lt;&gt; prevGC then
								if prevGC.offsetFlexi &gt; 0 and prevGC.offsetFlexi &lt; 20 then
									primGC := prevGC;
								endif;
							endif;
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	self.setMyToPrimaryLocation(primGC);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateTruckReceiptReloadWLEs" id="24b1d01d-412b-4108-ae3f-c092d673a08f">
        <source>doUpdateTruckReceiptReloadWLEs(_reloadWLE : CM_WorkListEntry input) protected;
/*

Date		Who		Reason
27 Apr 2016	cnwer1	Initial creation TFS 1842
22 Apr 2020 cnwma1  Bug 49078: MTN - UE Floods
*/

vars
	ti              : CM_TrackedItem;
	reloadRequest   : CM_Request;
	reloadWLE,
	truckReceiptWLE : CM_WorkListEntry;
	newQuantity,
	moveQuantity    : Integer;
	newWeight,
	moveWeight      : Decimal[14,4];
	wleUpdateEvent  : Integer;
begin
	if self.myTrackedItem = null then
		return;
	endif;
	
	//only an issue for allow duplicates
	if not self.myTrackedItem.myCargoType.allowDuplicates then
		return;
	endif;
	
	reloadRequest := _reloadWLE.myRequest;
	//find the unactioned wle with the same ti id
	if self.jobForMove &lt;&gt; null then               //22.04.2020 cnwma1 #49078
		truckReceiptWLE := self.jobForMove.getWLEforTIwithStatus(null,self.myTrackedItem.id,false,true,reloadRequest);
	endif;
	
	if truckReceiptWLE = null or truckReceiptWLE = _reloadWLE then
		return;
	endif;
	
	wleUpdateEvent:=truckReceiptWLE.getMyTerminal.getTerminalEvent(WLE_Update_Event);
	
	//add back the truck receipt quanity/ weight
	reloadWLE := _reloadWLE;
	if self.myTrackedItem.myCargoType.isBreakBulkMulti then
		newQuantity := reloadWLE.quantity - self.quantity;
		truckReceiptWLE.setQuantity(truckReceiptWLE.quantity + self.quantity);
		while reloadWLE &lt;&gt; null do
			if newQuantity &gt;  0 then			
				reloadWLE.setQuantity(newQuantity);
				app.myEventManager.createSingleObjInfoNoteEvt(reloadWLE,wleUpdateEvent, reloadWLE);
				break;
			else
				delete reloadWLE;
				reloadWLE := self.jobForMove.getWLEforTIwithStatus(null,self.myTrackedItem.id,true,true,reloadRequest);
				newQuantity:=newQuantity.abs();
				if reloadWLE &lt;&gt; null then
					newQuantity := reloadWLE.quantity - newQuantity;
				endif;
			endif;
		endwhile;
	elseif self.myTrackedItem.myCargoType.isBulkMulti then
		newWeight := reloadWLE.weight - self.weight;
		truckReceiptWLE.setWeight(truckReceiptWLE.weight + self.weight );
		while reloadWLE &lt;&gt; null do
			if newWeight &gt;  0 then
				reloadWLE.setWeight(newWeight);
				app.myEventManager.createSingleObjInfoNoteEvt(reloadWLE, wleUpdateEvent, reloadWLE);		
				break;
			else
				delete reloadWLE;
				reloadWLE := self.jobForMove.getWLEforTIwithStatus(null,self.myTrackedItem.id,true,true,reloadRequest);
				newWeight := newWeight.abs();
				if reloadWLE &lt;&gt; null then
					newWeight := reloadWLE.weight - newWeight;
				endif;
			endif;
		endwhile;
	endif;
	app.myEventManager.createSingleObjInfoNoteEvt(truckReceiptWLE, wleUpdateEvent, truckReceiptWLE);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_reloadWLE" type="CM_WorkListEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateTruckReleaseUndoWLEs" id="d51b5f65-e04b-42b6-bce5-227a1eac13a0">
        <updating/>
        <source>doUpdateTruckReleaseUndoWLEs(	_undoWLEs : CM_WLEArray input;
								_orginalTI : CM_TrackedItem input ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/01/2018	jlger1	Initial creation tfs 36605
28/02/2018	jlgdap1	TFS 37277 PEN Items loaded not showing in Road Ops
18/05/2018 	Jlgns1	Bug 38595: PEN - Delivery Release stays attached after load then unload
*/

vars
	undoRequest : CM_Request;
	wle : CM_WorkListEntry;
	unactionedWLE : CM_WorkListEntry;	
	moveQuantity : Integer;
	moveWeight : Decimal[14,4];
	wlesToDelete : ObjectSet;
	updatedTIAmount,
	byQuantity : Boolean;
	byWeight  : Boolean;
	deliveryRequest : CM_DeliveryRequest;
	bulkRelease : CM_BulkRelease;
	tiTransAssign : CM_RelRequestAssign;
begin
	
	if self.myTrackedItem = null then
		return;
	endif;
	
	if self.myWorkListEntry = null then
		return;
	endif;
	if self.myWorkListEntry.myRequest = null then
		return;
	endif;
	
	undoRequest:=self.myWorkListEntry.myRequest;
	if undoRequest = null then
		return;
	endif;
	
	if  self.myWorkListEntry.isAnyAmount then
		self.doUpdateTruckUndoAnyAmount(_orginalTI);
		return;
	endif;
	
	create wlesToDelete transient;
	if self.myTrackedItem.myCargoType.allowDuplicates then
		byWeight:=self.myTrackedItem.myCargoType.isBulkMulti;
		byQuantity:=not byWeight and self.myTrackedItem.myCargoType.isBreakBulkMulti;
		//any amount break bulk does not create new wle on split so if it hasn;t completed and deleted itself remove the amount moved
		if byQuantity then
			moveQuantity:=self.quantity;
		elseif byWeight then
			moveWeight:=self.weight;
		endif;	
	endif;	
		
				
		foreach wle in self.jobForMove.workListEntries discreteLock where not wle.isReceipt do
			if wle.isAnyAmount then
				continue;
			endif;
				//theres been a split and a new wle has been created 
			//if  wle.myRequest = undoRequest  then																		// TFS 37277
			if wle.myRequest = undoRequest and wle.myTrackedItem &lt;&gt; null and wle.myTrackedItem.id = _orginalTI.id then	// TFS 37277
				wle.rebuildStatus;
				if not _undoWLEs.includes(wle)  then
					if wle.status = WLE_UNACTIONED then 
						if unactionedWLE = null then
							unactionedWLE:=wle;
						else
							wlesToDelete.add(wle);
						endif;
					else
						wlesToDelete.add(wle);
					endif;				
				endif;
			endif;					
		endforeach;
			
	//if unactioned ti wle for the request already exists with have to update that quantity with the move amount
	// and go around taking off the amount from the competed wles and potentially deleting them if they get to zero
	if unactionedWLE &lt;&gt; null and unactionedWLE &lt;&gt; self.myWorkListEntry then
		if byQuantity then
		
			unactionedWLE.setQuantity(unactionedWLE.quantity  + self.quantity);
		elseif byWeight then
			
			unactionedWLE.setWeight(unactionedWLE.weight + self.weight);
		endif;		
	
	endif;
	
	
	if self.myWorkListEntry.status = WLE_UNACTIONED and  self.myWorkListEntry.myRequest.isKindOf(CM_DeliveryRequest) then 	//Bug 38595
		//epr TFS 39624 23/7/18
		// check if ti was assigned by a handheld/mobile user
		//if so we can unassign it from the release request || otherwise just set ti null on wle and remove from job
		bulkRelease:=self.myWorkListEntry.myRequest.myOriginatingBulkRelease;
		if  bulkRelease &lt;&gt; null then //JLIER1 MTN-34143 11/4/25   - was // not self.myTrackedItem.myCargoType.allowDuplicates and
			tiTransAssign:=self.myTrackedItem.getLastTransOfClass(CM_RelRequestAssign).CM_RelRequestAssign;
			if tiTransAssign &lt;&gt; null and tiTransAssign.isFromMobileApp and tiTransAssign.myBulkReleaseCode = bulkRelease.code then
				self.myWorkListEntry.unassignTI();
			else
				self.myWorkListEntry.setMyTrackedItem(null);
				self.myWorkListEntry.job.updateTICollectionsUnassign(self.myTrackedItem);
			endif;
		else
			self.myWorkListEntry.unassignTI();
		endif;
		
																						//Bug 38595
		if _undoWLEs.includes(self.myWorkListEntry) then																	//Bug 38595
			_undoWLEs.remove(self.myWorkListEntry);																			//Bug 38595
		endif;																												//Bug 38595
	endif;																													//Bug 38595
	
	foreach wle in _undoWLEs discreteLock do
		if wle.myTrackedItem.myPrimaryActualLocation = self.myOriginatingLocation then
			if updatedTIAmount then
				//this other wle remove
				wlesToDelete.add(wle);
			else
				//some of the trackedItem is still on the truck then
				//set this wles amount to whats on the truck and delete any of the other ones
				if byQuantity then
					wle.setQuantity(wle.myTrackedItem.totalQuantity);
				elseif  byWeight then
					wle.setWeight(wle.myTrackedItem.totalWeight);
				endif;
				updatedTIAmount:=true;	
			endif;
		else
			if unactionedWLE = null then
				//one of the original completed wles on the truck is now unactioned and the ti is pointing to on site
				//the quantity should be the amount moved 
				if byQuantity then
					wle.setQuantity(self.quantity);
				elseif  byWeight then
					wle.setWeight(self.weight);
				endif;
				unactionedWLE:=wle;
			else			
				if wle &lt;&gt; unactionedWLE  then
					wlesToDelete.add(wle);
				endif;
			endif;
		endif;
				
	endforeach;
		
	if wlesToDelete.includes(self.myWorkListEntry) then
		self.myWorkListEntry:=null;
	endif;
	wlesToDelete.purge;

epilog
	delete wlesToDelete;
	
end;</source>
        <access>protected</access>
        <Parameter name="_undoWLEs" type="CM_WLEArray" usage="input"/>
        <Parameter name="_orginalTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateTruckUndoAnyAmount" id="a5ee72ec-2dbb-4421-b2f7-75d2a2fb59f7">
        <updating/>
        <source>doUpdateTruckUndoAnyAmount(_orginalTI : CM_TrackedItem input ) protected,  updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2018	jlger1	Initial creation 36605

*/

vars
	anyMasterWLE,
	wle : CM_WorkListEntry;
	undoRequest : CM_Request;
	byQuantity : Boolean;
	byWeight  : Boolean;
	moveQuantity : Integer;
	moveWeight : Decimal[14,4];
	wlesToDelete : ObjectSet;
begin
	if self.myTrackedItem = null then
		return;
	endif;
	
	if self.myWorkListEntry = null then
		return;
	endif;
	if self.myWorkListEntry.myRequest = null then
		return;
	endif;
	
	if not self.myWorkListEntry.isAnyAmount then
		return;
	endif;
		
	undoRequest:=self.myWorkListEntry.myRequest;
	
	byWeight:=self.myTrackedItem.myCargoType.isBulkMulti;
	byQuantity:=not byWeight and self.myTrackedItem.myCargoType.isBreakBulkMulti;
	//any amount break bulk does not create new wle on split so if it hasn;t completed and deleted itself remove the amount moved
	if byQuantity then
		moveQuantity:=self.quantity;
	elseif byWeight then
		moveWeight:=self.weight;
	endif;	
	
	create wlesToDelete transient;
	
	foreach wle in self.jobForMove.workListEntries discreteLock where not wle.isReceipt do
			wle.rebuildStatus;
			if not wle.isAnyAmount then
				continue;
			endif;
			if wle.myRequest = undoRequest and wle.myTrackedItem = null then
				anyMasterWLE:=wle;
			endif;
			if wle.myTrackedItem &lt;&gt; _orginalTI and wle.myTrackedItem &lt;&gt; self.myTrackedItem then
				continue;					
			endif;
			//still some on the truck
			if byQuantity then
								
				if moveQuantity &gt; wle.quantity then
					wlesToDelete.add(wle);
					moveQuantity:= moveQuantity - wle.quantity;
				else
					moveQuantity:=wle.quantity - moveQuantity;
					wle.setQuantity(moveQuantity);
				endif;
			elseif byWeight then
										
				if moveWeight &gt; wle.weight then
					wlesToDelete.add(wle);
					moveWeight:=moveWeight - wle.weight;
				else
					moveWeight:= wle.weight - moveWeight;
					wle.setWeight(moveWeight);
				endif;
			endif;
			
			if wle.status &lt;&gt; WLE_COMPLETED then
				wle.unassignTI();
			
			//moved off the truck
				if not wlesToDelete.includes(wle) then
					wlesToDelete.add(wle);
				endif;
			endif;
			
	endforeach;
		
	// if the we loaded the last cargo on a car then we would have created the new wle
	if anyMasterWLE = null then
		create anyMasterWLE as self.myWorkListEntry.class;
		anyMasterWLE.setForCreate( wle.job , wle.myRequest );
	endif;
	
	if wlesToDelete.includes(self.myWorkListEntry) then
		self.myWorkListEntry:=null;
	endif;
	wlesToDelete.purge;
epilog
	delete wlesToDelete;
end;</source>
        <access>protected</access>
        <Parameter name="_orginalTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doWLEUpdate" id="41a49510-807e-4a21-bc6c-9e86cf999dcf">
        <updating/>
        <source>doWLEUpdate(_passport : CM_Passport input) updating, protected;
//-----------------------------------------
//Created: May 2003 By: cnwgd1
//-----------------------------------------
// 08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
// 14/08/5018	jlgdap1	TFS 40003 PEL1 Voyage to Road Moves
// 05/07/2019	jlgzm1	TFS 42863 MSL - Direct Release Between RORO Voyages and Rail 
// 22/11/2021	navdap1	TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
// 07/12/2021	navdap1	TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
// 28/01/2025	navpw1	MTN-33663 - Passed move controller 'self' into wle.moveEvent

vars
	ti : CM_TrackedItem;
	invalidWLE : Boolean;
	wle		: CM_WorkListEntry;
	fm : CM_FutureMove;						// TFS 40003
begin
	on Exception do app.handleDeletedObject(exception, wle, invalidWLE);//PAR 16929
	//epr par 17561 16/7/08
	wle := self.myWorkListEntry;
	if wle = null then
		return;
	endif;
	
	// handle any splitting of WLEs for direct release moves
	self.doDRSplitCreateNewWLE(true); // tfs42863
	
	wle.moveEvent(self);
	if invalidWLE then
		return;
	endif;
	
	if self.myDDWorkListEntry &lt;&gt; null then															// TFS 40003
		wle := self.myDDWorkListEntry;																// TFS 40003
		wle.moveEvent(self);																			// TFS 40003
		// Direct Delivery WLE is a yard wle, starting from the same location we've just 			// TFS 40003
		// moved the TI to. So it's the queued yard wle from a truck that we've just 				// TFS 40003
		// moved the actual TI on to																// TFS 40003
		if wle.isCompleteForJob() and wle.isKindOf(CM_YardWLE) and wle.myFutureMove &lt;&gt; null then	// TFS 40003
			if wle.locationSource = self.myWorkListEntry.locationSource then						// TFS 40003
				fm := wle.myFutureMove;																// TFS 40003
				fm.erase(NORMAL_ERASE);																// TFS 40003
				while wle.allRTQueueEntries.isEmpty = false do										// TFS 40003
					wle.allRTQueueEntries.last.deleteEntry( false, null);							// TFS 40003
					if app.myPassport &lt;&gt; null then													// TFS 40003
						if app.myPassport.hasErrors then											// TFS 40003
							break; 																	// TFS 40003
						endif;																		// TFS 40003
					endif;																			// TFS 40003
				endwhile;																			// TFS 40003
			endif;																					// TFS 40003
		endif;																						// TFS 40003
		
		// TFS 52360 Double check job status and wle subseqnum settings
		//if wle.getMyTerminal &lt;&gt; null and wle.getMyTerminal.getConfig(DirectTruck2VesselMult).Boolean then		// TFS 52293
		if wle.job &lt;&gt; null and wle.job.isDirectDeliveryJob then													// TFS 52293
			self.directLoadCheckJobStatus(wle);
		endif;
		// TFS 52360 end
	endif;																							// TFS 40003
	// 07/10/2009 cnwar2 #21059 - moved to when rail release transaction created
	//self.myWorkListEntry.updateForRelease(); //PAR 16929
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doWleUpdateForChild" id="f950fa1f-d465-4799-8341-0e5dd7d28535">
        <source>doWleUpdateForChild(_ti : CM_TrackedItem; _passport : CM_Passport input) protected;
//-----------------------------------------
//Created: 23 October By: cnwgd1
//-----------------------------------------
// 28/01/2025	navpw1	MTN-33663 - Passed move controller 'self' into wle.moveEvent

vars
	wle : CM_WorkListEntry;
begin
	if self.moveMode &lt;&gt; REAL_MODE then
		// already done for planned and queued moves when future move cleaned up
		return;
	endif;
	
	if _ti = null then
		return;
	endif;
	
	foreach wle in _ti.allWorklistEntries do
		if wle = self.myWorkListEntry then
			continue;
		endif;
		wle.moveEvent(self);
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="executeMove" id="843aa4b7-e677-41a9-88b1-a17e55f15c1e">
        <updating/>
        <source>executeMove(_passport : CM_Passport input) updating;
/*
 ------------------------------------------------------------------------
Created:			13 September 2001 by cnwdwq1
Purpose:			DOES THE MOVE, calls to the tracked item to do the work
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------	--------------	-----------------------------------------
12/05/2010		cnwdap1			CCMS 1116 Tranship changes
20/10/2016		cnwdap1			TFS 2652 Do document actions for child cargo
13/03/2018		jlgsl4			TFS 37567 Avoid null exception for released cargo move to yard from Road Ops
28 Aug 2018		jlgrs1			TFS 39619 PEN - Approved Carriers For Operator 
29/08/2018		JLGNS1			Bug 40008: PEN - Restrict Operator Issue - removed TFS2749
29/07/2020		jlgdap1			TFS 49851 Satellite View Graphical Display - this method used to 
											adjust any future planned move WLE quantity / weight 
											if the cargo type was splittable. But normal split/merge
											processing already does this
19/08/2021		navdap1			TFS 51710 C3 - Reject logs being reinstated by move
02/12/2021		navdap1			TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
07/12/2021		navdap1			TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
08/12/2022 		navma1 			ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
---------------------------------------------------------------------------
*/
vars
	tmpEdition			  : Integer;
	tmpLC				  : CM_LocationsController;
	packVolume,
	packWeight 			  : Decimal[14,4];
	truckReceiptReloadWLE : CM_WorkListEntry;
	tiArray 			  : CM_TIArray;
	moveAmount 			  : Real;
	amountArray 		  : RealArray;
	dummyString 		  : String;
	plannedMove			  : CM_FutureMove;
	ti					  : CM_TrackedItem;
	allUndoWLEs 		  : CM_WLEArray;
	extraLcForNotes 	  : CM_LocationsController;	//01 Feb 2018	NDL	TFS 36848
	fm 					  : CM_FutureMove;			// TFS 52360
	isInEdiVerifyMode	  : Boolean;
begin
	
	//jlier1 8/10/2025 36155
	if self.myRotatableContainer = null and self.myTrackedItem.isRotatableContainer then
		self.createRotatableCargo(_passport);
		if _passport.hasErrors then
			return;
		endif;
	endif;
	
	if self.myTrackedItem = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'self.myTrackedItem = null');
		return;
	endif;
	
	ti 					:= self.myTrackedItem;					// 18/9/17 MAP TFS2749
	isInEdiVerifyMode	:= app.myPassport.isInEdiVerifyMode();	//07.12.2022 navma1 #52499
	

	if self.myPassport = null then
		self.myPassport := _passport;
		self.userCode := _passport.userCode;
	endif;
		
	if self.moveMode &lt;&gt; QUEUE_MODE and self.myPassport &lt;&gt; null and self.myPassport.myStateChangeController &lt;&gt; null then
		self.myPassport.myStateChangeController.initForObject(ti); //jlier1 TFS 61676 14/12/23 
		//loadding to trailer also re-evaluate the  trailer TFS 62260 31/1/24
		if self.myToPrimaryLocation &lt;&gt; null and self.myToPrimaryLocation.isKindOf(CM_TILCController) then
			self.myPassport.myStateChangeController.initForObject(self.myToPrimaryLocation.CM_TILCController.myTILC);
		endif;
		//jlier1 TFS 65902 30/8/24 - re-evaluate the parent after pack
		if self.myPackToTI &lt;&gt; null then
			self.myPassport.myStateChangeController.initForObject(self.myPackToTI);
		endif;
	endif;
	
	self.setIsTruckUndoLoad(); //epr tfs 36605 25/1/18
	if self.isTruckUndoLoad then //epr TFs 36534 29/1/18
		//get all the wles for the ti on the truck before the move i.e. splits and merges happen
		create allUndoWLEs transient;
		if self.jobForMove &lt;&gt; null then // TFS 37567
			self.jobForMove.getWLEsForTI(self.myTrackedItem,allUndoWLEs);
		endif; // TFS 37567
	endif;
	self.directDeliveryPreMove();	//01 Feb 2012	NDL	Par 31102
	
	self.processDDTurnaround();	//19 Feb 2013	NDL	Par 31102
	
	if self.isMoveToPlanned then
		if self.myTrackedItem.allPlannedFutureMoves.size &gt; 0 then		// 26/6/17 MAP TFS4719
			// TFS 52630 there may be more than 1 future move
			//if self.myTrackedItem.myTerminal.getConfig(DirectTruck2VesselMult).Boolean then											// TFS 52293
			if self.myWorkListEntry &lt;&gt; null and self.myWorkListEntry.job &lt;&gt; null and self.myWorkListEntry.job.isDirectDeliveryJob then	// TFS 52293
				foreach fm in self.myTrackedItem.allPlannedFutureMoves do
					if fm.isKindOf(CM_FutureMovePlanned) and fm.CM_FutureMovePlanned.myWorkListEntry &lt;&gt; null
					and fm.CM_FutureMovePlanned.myWorkListEntry.CM_VoyageWLE.subSeqNum &lt;&gt; null then
						plannedMove := fm;
						break;
					endif;
				endforeach;
			// TFS 52360 end
			else
				plannedMove := self.myTrackedItem.allPlannedFutureMoves[1];
			endif;
			self.setMyToPrimaryLocation(plannedMove.getLocationsArray.first());
			/* TFS 49851 removed the planned future move adjustments - normal split/merge/move processing already does this
			if plannedMove.myWorkListEntry &lt;&gt; null then
				if self.myTrackedItem.myCargoType.isBreakBulkMulti then
					if plannedMove.myWorkListEntry.quantity &gt; 0 then
						if self.quantity &gt;= plannedMove.myWorkListEntry.quantity then
							self.myTrackedItem.allPlannedFutureMoves.removeAt(1);
						else
							self.myTrackedItem.allPlannedFutureMoves[1].myWorkListEntry.setQuantity(plannedMove.myWorkListEntry.quantity - self.quantity);
						endif;
					endif;
				else//if self.myTrackedItem.myCargoType.isTrackByWeight then
					if plannedMove.myWorkListEntry.weight &gt; 0 then
						if self.weight &gt;= plannedMove.myWorkListEntry.weight then
							self.myTrackedItem.allPlannedFutureMoves.removeAt(1);
						else
							self.myTrackedItem.allPlannedFutureMoves[1].myWorkListEntry.setWeight(plannedMove.myWorkListEntry.weight - self.weight);
						endif;
					endif;
				endif;
			endif;		TFS 49851 end	*/
		else
			return;
		endif;
	endif;

	if not isInEdiVerifyMode then						//07.12.2022 navma1 #52499
		self.doUpdateSnap(); 							// PAR 18682 CCMS 1055
	endif;
	
	// PAR 23819
	if self.isNotNotifiedJob then	//12 Sep 2011	NDL	Par 28173
		self.createVoyageWLEForNotNotified();
	elseif self.isNonCraneVoyageMove then
		self.createVoyageWLEForNonCraneMove();
	else
		//epr par 35898 14/5/15
		if self.myWorkListEntry = null then
			if self.myOriginatingLocation &lt;&gt; null and self.myToPrimaryLocation &lt;&gt; null and
				//epr par 36470 18/6/15
				(self.myOriginatingLocation.isGeneralCargoController or (self.myOriginatingLocation.isShipBlockStack and not self.myOriginatingLocation.isKindOf(CM_ShipNotNotifiedController))) then
				self.createVoyageWLEForNonCraneMove();
			else
				//epr par 36470 18/6/15
				if self.myToPrimaryLocation &lt;&gt; null and (self.myToPrimaryLocation.isGeneralCargoController or (self.myToPrimaryLocation.isShipBlockStack and not self.myOriginatingLocation.isKindOf(CM_ShipNotNotifiedController))) then
					self.createVoyageWLEForNonCraneMove();
				endif;
			endif;
		endif;
	endif;
	
	
	self.validateMove(_passport);

	
	if self.validateOnly then
		return;
	endif;

	//if _passport.hasErrors then 
	if _passport.hasErrors and not self.isLogMovement then // ### TFS 52572 21Jan2022 NAVPW1
		return;
	endif;
	// TFS 51710 Don't move rejected logs - C3 move dockets between log row areas by drag-dropping in cargo enquiry.
	// This sets myTrackedItem on the move controller to the first log in the docket, and all logs on the docket
	// are copied to allOtherTrackedItems. This caters for the first log in the docket being rejected,
	// CMIF_MoveController executePostMove caters for rejected logs in the allOtherTrackedItems collection
	if self.tiTransType &lt;&gt; TRANS_TYPE_ReinstateReject then
		if self.myTrackedItem.isRejected then
			return;
		endif;
	endif;
	// TFS 51710 end
	
	//epr TFS 1842 28/4/16
	if self.isTruckReceiveReLoad() then
		truckReceiptReloadWLE:=self.myWorkListEntry;
		self.myWorkListEntry:=null;	
	endif;
	
	tmpEdition := self.myTrackedItem.edition;
	
	// set to true as this is used to determine what
	// locks to put on objects later.
	self.warningsHaveBeenAcknowledged := true;

	//-------------------------
	//Upgrade the locks. 
	//-------------------------
	self.doFromLocationsLock();
	self.doToLocationLock();
	self.doToSecondaryLocationsLock();
	exclusiveLock(self.myTrackedItem);
	if tmpEdition &lt;&gt; self.myTrackedItem.edition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, self.myTrackedItem.cargoTypeDescr, null, null);
		return;
	endif;
	
	// there is a hole where-by the TI can be moved by another process prior to 
	// coming in here.  We cannot check the edition of the TI because the current
	// process may have validly updated the TI before coming in here.  We check it
	// is still where it was originally and go with that - RJS
	tmpLC := self.myTrackedItem.getPrimaryLocation(REAL_MODE);

	if not self.isSystemMove	//exclude system moves
	and self.myOriginatingLocation &lt;&gt; null		// cnwjre1 from TFS 1990 dev, this can get cleared for some break-bulk during the move giving this error when it is actually OK
	and self.myOriginatingLocation &lt;&gt; tmpLC 
	and self.moveMode = REAL_MODE and self.myRotatableContainer = null then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, self.myTrackedItem.cargoTypeDescr, null, null);
		return;
	endif;
	
	//-------------------------
	//CLEAR Hazard locations
	//-------------------------
	self.setHazardLocationsPreMove();
	
	//### YARD KPI
	if not isInEdiVerifyMode then					//07.12.2022 navma1 #52499
		self.doUpdateDisplayKPIYard(true);
	endif;
	
	if self.myToPrimaryLocation &lt;&gt; null  then
		self.myToPrimaryLocation.setupForPremove( self );
		
		// cnwmc5 - 4 August 2016 - TFS 2274 
		// CM_ROROSlotController setupForPremove changes the myToPrimaryLocation and deletes the old one...
		// if a warning is rasied, the old myToPrimaryLocation is deleted and the application falls over duing executeControlMove...
		// this is a safety for the CM_ROROSlotController...
		if not app.myPassport.checkValidation() and self.myToPrimaryLocation.isKindOf(CM_ROROSlotController) then
			return;
		endif;
	endif;
	
	//if it is an unpack get how much is being unpacked before.
	//has to be before because the split/merge bulk complicates this 
	if self.isPackUnpackWeightSet then										//cnwmc5 - 3 Dec 2015 - PAR 37213		
		// Do not get packWeight or packVolume, already done on form.		//cnwmc5 - 3 Dec 2015 - PAR 37213
	elseif self.myUnpackFromTI &lt;&gt; null or self.myPackToTI &lt;&gt; null then		//cnwmc5 - 3 Dec 2015 - PAR 37213
	
		//31 Aug 2015	NDL	Par 36666
		if self.myUnpackFromTI &lt;&gt; null and not self.myUnpackFromTI.isOnSite then
			app.raiseCMException1(Not_unpack_offsite, self.myUnpackFromTI.id,null,null);
			return;
		endif;
		
		//28 Nov 2016	NDL	TFS 2967 - Raise a warning if TI being packed has outstanding 'Document Actions'
		if self.myPackToTI &lt;&gt; null then
			self.myTrackedItem.hasUnactionedDocumentActions(true,false,dummyString); // TFS 3972 added warning
		endif;
	
		packWeight:= self.myTrackedItem.totalWeight;
		packVolume:= self.myTrackedItem.getMyTotalVolume;
		if self.myTrackedItem.myCargoType.isBreakBulkMulti or self.myTrackedItem.myCargoType.isBulkMulti then
			//this cargo could of been merged when unpacked so get weight from passed in quantity/weight
			if self.myTrackedItem.myCargoType.isBulkMulti then
				if self.weight &lt;&gt; null then
					packWeight:= self.weight;
				endif;
				if self.myTrackedItem.myCargoType.isBulkByVolume then
					packVolume:=packWeight/self.myTrackedItem.getDensity;
				endif;
			else
				if self.quantity &lt;&gt; null then
					packWeight:=(self.quantity/ self.myTrackedItem.totalQuantity) * self.myTrackedItem.totalWeight;
					packVolume:=(self.quantity/ self.myTrackedItem.totalQuantity) * self.myTrackedItem.getMyTotalVolume;
				endif;	
			endif;	
		endif;
	endif;
	
	//01 Feb 2018	NDL	TFS 36848 - Needed to draw back ends, in end view on Yard Grid View.
	if self.moveMode = QUEUE_MODE and self.myTrackedItem.myOSBackEndLocationQd &lt;&gt; null and self.isReQueue then
		extraLcForNotes := self.myTrackedItem.myOSBackEndLocationQd;
	endif;
	
	//-------------------------
	//MOVE the sucker
	//-------------------------
	
	if self.isLogMovement then																		// ### TFS 52572 21Jan2022 NAVPW1
		if (self.myTrackedItem.getPrimaryLocation(REAL_MODE) &lt;&gt; self.myToPrimaryLocation) then		// ### TFS 52572 21Jan2022 NAVPW1
			self.myTrackedItem.executeControlMove(self, _passport);									// ### TFS 52572 21Jan2022 NAVPW1
		endif;																						// ### TFS 52572 21Jan2022 NAVPW1
	else																							// ### TFS 52572 21Jan2022 NAVPW1
		self.myTrackedItem.executeControlMove(self, _passport);
	endif;																							// ### TFS 52572 21Jan2022 NAVPW1
	//28 Sep 2016	NDL	TFS 2647 / 2001
	if self.myDocumentActions &lt;&gt; null then
		create tiArray transient;
		create amountArray transient;
		tiArray.add( self.myTrackedItem );
		moveAmount := self.quantity.max(1);
		if self.myTrackedItem.myCargoType.allowDuplicates then
			if self.myTrackedItem.myCargoType.isBulkByVolume then
				moveAmount := self.volume;
			elseif self.myTrackedItem.myCargoType.isBulkByWeight then
				moveAmount := self.weight;
			endif;	
		endif; 
		amountArray.add( moveAmount );
		self.myDocumentActions.assignTasksAndStops(tiArray,amountArray);	//05 Oct 2016	NDL	TFS 2001 / 2792
		
		self.doChildDocActions(self.myTrackedItem);	//08 Mar 2017	NDL	TFS 3668 - need sto be conditional
		
		
	endif;
//	self.doChildDocActions(self.myTrackedItem);							// TFS 2654
	
	if self.myToTerminal &lt;&gt; null and
	   self.myTrackedItem.myTerminal &lt;&gt; self.myToTerminal 
	   and not(self.myTrackedItem.myTerminal = null and self.myTrackedItem.quantity = 0) then
		app.raiseCMException3(ERR_TERMINAL_MISMATCH, self.myTrackedItem.id, 
							  self.myTrackedItem.myTerminal.code,
							  self.myToTerminal.code, null, null);
		return;	
	endif;
	
	if self.myUnpackFromTI &lt;&gt; null then
		self.doUpdateParentAfterUnpack(packWeight, packVolume,_passport);
	endif;
	
	if self.myPackToTI &lt;&gt; null then
		self.doUpdateParentAfterPack(packWeight, packVolume,_passport);
	endif;
	//epr tfs 1842 28/4/16
	if truckReceiptReloadWLE &lt;&gt; null then
		self.doUpdateTruckReceiptReloadWLEs(truckReceiptReloadWLE);
	endif;
	
	if self.isTruckUndoLoad then
		//epr TFS 36534 29/1/18
		if self.jobForMove &lt;&gt; null then // TFS 37567 - for non-ctr. cargo
			self.doUpdateTruckReleaseUndoWLEs(allUndoWLEs,ti);
		endif; // TFS 37567
	endif;
	
	//jlier1 8/10/2025 36155
	self.doUpdateRotatableAfterUnload(_passport);
	
	// this will cause an event to update any yard area GUI displays
	self.doUpdateDisplay();
	
	//01 Feb 2018	NDL	TFS 36848 - Needed to draw back ends, in end view on Yard Grid View.
	if extraLcForNotes &lt;&gt; null then
		self.doUpdateDisplayEvent(extraLcForNotes);
	endif;

	//### YARD KPI
	if not isInEdiVerifyMode then							//07.12.2022 navma1 #52499
		self.doUpdateDisplayKPIYard(false);
	endif;
	
	//15/04/2025	navkc1 JIRA Defect Sub-task MTN-34620
	if truckReceiptReloadWLE &lt;&gt; null and global.isValidObject(truckReceiptReloadWLE) then
		app.myEventManager.createSingleObjInfoNoteEvt(truckReceiptReloadWLE, truckReceiptReloadWLE.getMyTerminal().getTerminalEvent(WLE_Update_Event), truckReceiptReloadWLE);
	endif;
epilog
	delete tiArray;
	delete amountArray;
	delete allUndoWLEs;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="executePostMove" id="45aecb47-d77e-471b-a9aa-b2ea965ec1d2">
        <updating/>
        <source>executePostMove(_passport : CM_Passport input) updating;
/*
 ------------------------------------------------------------------------
Created:			14 September 2001 by cnwdwq1
Purpose:			This method is called AFTER the executeMove method, we set the
							properties etc required after the move.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
22 mar 2011 cnwer1  PAR #25573 - removed redundant code
21 Sep 2020 cnwma1  ChangeRequest 49906: MTN - Ops View External Webservice
19 Aug 2021	navdap1	TFS 51710 C3 Rejected Logs being reinstated by move
31 Oct 2022	navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
*/

vars
	origTI,
	child		: CM_TrackedItem;
	otherWle,
	childWLE,
	origWLE		: CM_WorkListEntry;
	partsDone,
	numTIs		: Integer;
	lController : CM_LocationsController;
	controller  : CMIF_MoveController;
	movementLog : CM_MovementLog;
	tmpJob      : CM_VoyageJob;
	plannedLC	: CM_LocationsController;
	//Start 14 Nov 2022 NAVSKS20 TFS 52721
	ti 			: CM_TrackedItem;
	wle 		: CM_WorkListEntry;
	term		: CM_Terminal;
	qtask		: CM_RTQueueTask;
	req			: CM_Request;
	releaseItem : CM_ReserveDetail;
	subTerm, tiSubTerm : CM_SubTerminal;
	delReqRequest : CM_YardDeliveryRequest;
	subTermStr : String;
	wo			: CM_WorkOrder;
	//End 14 Nov 2022 NAVSKS20 TFS 52721
begin
	//--------------------
	//Set the cleanup flag so validation is not called
	//--------------------
	//epr 11/3/14 removing voyage commodity planning as part of bulk CCMS 1366
	
	//10 May 2016	NDL	TFS 1969 - Packing cargo that might have been queued somewhere would otherwise
	//                             leave a completed and queued WLE sitting aroumd.
	if self.myPackToTI &lt;&gt; null and self.myWorkListEntry = null then
		foreach otherWle in self.myTrackedItem.allWorklistEntries where otherWle.isQueued do
			// unqueue any queued wles. (Can't queue children)
			if otherWle.myFutureMove &lt;&gt; null then
				otherWle.myFutureMove.erase(NORMAL_ERASE);
			endif;
			otherWle.unQueueWLE(_passport);
		endforeach;
	endif;
	
	wle := self.myWorkListEntry;  // ### TFS 52721 16NOV2022 NAVAB1
    if wle &lt;&gt; null then  // ### TFS 52721 16NOV2022 NAVAB1
		req := wle.myRequest;  // ### TFS 52721 16NOV2022 NAVAB1
    endif;
	if req &lt;&gt; null  // ### TFS 52721 16NOV2022 NAVAB1
	and req.isYardDeliveryReq() then  // ### TFS 52721 16NOV2022 NAVAB1
		delReqRequest := req.CM_YardDeliveryRequest;  // ### TFS 52721 16NOV2022 NAVAB1
		releaseItem := delReqRequest.myReleaseItem;  // ### TFS 52721 16NOV2022 NAVAB1
		subTerm := delReqRequest.myUpdateSubTerminal;   // ### TFS 52721 17NOV2022 NAVAB1
    endif;
	
	self.isPostMoveCleanup := true;
	controller := self;	//rs1 feb 2006 ccms1416
	self.myTrackedItem.executeControlPostMove(controller, _passport); // this create transactions
	
	//
	// Needed for MovementLog - multi select from Block Stack
	//
	self.myTargetLocation := self.myToPrimaryLocation;
	self.mySourceLocation := self.myOriginatingLocation;	
	numTIs := self.allOtherTrackedItems.size;

	if numTIs &gt; 0 then
		// This needs to be done BEFORE the collections are
		// cleared out below, otherwise code called here does not
		// know where to move the other ti's to.
		origTI := self.myTrackedItem;
		origWLE := self.myWorkListEntry;
		foreach child in self.allOtherTrackedItems do
			if _passport.hasMonitor then
				partsDone := partsDone + 1;
				if partsDone mod MONITOR_RETURN_MOVE = 0 then
					_passport.myCMIFMonitor.updateProgress(null, numTIs, partsDone);
				endif;
			endif;
			// TFS 51710 ignore rejected logs - C3 move dockets between log row areas by drag-dropping in cargo enquiry.
			// This sets myTrackedItem on the move controller to the first log in the docket, and all logs on the docket
			// are copied to allOtherTrackedItems. Ignore any rejected logs in the docket
			if self.tiTransType &lt;&gt; TRANS_TYPE_ReinstateReject then
				if child.isRejected then
					continue;
				endif;
			endif;
			// TFS 51710 end
			self.setMyTrackedItem(child);
			childWLE := self.getWLEForTI(child);
			// Par 8635 Want null wle for log children so we
			// get a receival transaction.
			//if childWLE &lt;&gt; null then
				// also set to null if no matching wle
				self.setMyWorkListEntry(childWLE);
			//endif;
			lController := child.getPrimaryLocation(REAL_MODE);
			if self.isMoveToPlanned then		// 27/6/17 MAP TFS4719
				plannedLC := child.myPrimaryPlannedLocation;
				if plannedLC = null then
					continue;
				else
					self.myTargetLocation := plannedLC;
					self.setMyToPrimaryLocation(plannedLC);
				endif;
			endif;
			
			//20 Sep 2017	NDL	TFS 7016
			if controller.isNonCraneVoyageMove then
				if controller.myWorkListEntry &lt;&gt; null then
					controller.setWeight(controller.myWorkListEntry.weight);
					controller.setQuantity(controller.myWorkListEntry.quantity);
				else
					controller.setWeight(0);
					controller.setQuantity(0);
				endif;
			endif;
			
			if self.isLogMovement then														// ### TFS 52572 21Jan2022 NAVPW1
				if (child.getPrimaryLocation(REAL_MODE) &lt;&gt; self.myToPrimaryLocation) then 	// ### TFS 52572 21Jan2022 NAVPW1
					child.executeControlMove(self, _passport); 								// ### TFS 52572 21Jan2022 NAVPW1
				endif;																		// ### TFS 52572 21Jan2022 NAVPW1
			else																			// ### TFS 52572 21Jan2022 NAVPW1
				child.executeControlMove(self, _passport);
			endif;																			// ### TFS 52572 21Jan2022 NAVPW1
			child.executeControlPostMove(controller, _passport);
			self.doWleUpdateForChild(child, _passport);
			self.doUpdateDisplayEvent(lController);
			self.doUpdateDisplayEvent(self.myToPrimaryLocation);

			// PAR 9002. We are queueing so enqueue job/wles and add to the RT Q
			if self.moveMode = QUEUE_MODE then
				self.addToRTQueue(_passport);
			endif;			
			
			if self.moveMode = QUEUE_PLAN_ON_PICKUP then //cnwrd1 par 26734 CCMS 2014 plan on pickup
				self.addToRTQueuePOP(_passport);
			endif;

		endforeach;
		self.setMyTrackedItem(origTI);
		self.setMyWorkListEntry(origWLE);
		
		origTI := null;
		origWLE := null;
	endif;
	//if self.myToPrimaryLocation &lt;&gt; null then
	//	self.myToPrimaryLocation.executeControlPostMove(self);
	//endif;

	if _passport.noErrors then
		// we are queueing so enqueue job/wles and add to the RT Q
		if self.moveMode = QUEUE_MODE then
			self.addToRTQueue(_passport);
		endif;
		
		if self.moveMode = QUEUE_PLAN_ON_PICKUP then //cnwrd1 par 26734 CCMS 2014 plan on pickup
			self.addToRTQueuePOP(_passport);
		endif;		
	endif;

	//------------------
	//Tell the job about the move if there is one
	//------------------

	if self.myWorkListEntry &lt;&gt; null then
		self.doWLEUpdate(_passport);
	elseif self.jobForMove &lt;&gt; null then
		self.doJobUpdate(_passport);
	endif;

	if _passport.noErrors 
	and self.moveMode = PLANNING_MODE 
	and self.autoSeqLoadPlan then
		if self.myWorkListEntry &lt;&gt; null then
			tmpJob := self.myWorkListEntry.job.CM_VoyageJob;
			if tmpJob &lt;&gt; null then
				tmpJob.reSeqWLEForAutoSeq(self.myWorkListEntry.CM_VoyageWLE);
			endif;
		endif;
	endif;
	
	self.myTrackedItem.reviewFailToPlanAlertAfterMove();  // CCMS 1030
	
	
	self.directDeliveryPostMove(_passport);	//01 Feb 2012	NDL	Par 31102
	
	self.directReleasePostMove(_passport); // 30/05/2019 jlgzm1 TFS 42840
	
	self.nonWorkedInstantPostMove(); //01 Aug 2013 Par 32140
	
	//jlier1 JIRA-36155 14/10/25
	self.rotatableContainerPostMove(_passport);
	
	//
	// Now create a MovementLog object for background task to update statistics
	// Code needs to be added here if we do not want to do this for selected CM_Terminals
	//
	if _passport.noErrors then
		create movementLog persistent;
		movementLog.setupForCreate(self.myTargetLocation, self.mySourceLocation,
					self.myTrackedItem, self.moveMode, Move_Action);
		
		//21.09.2020 cnwma1 TFS #49906
		self.opsViewCreateRequest();
		//21.09.2020 cnwma1 TFS #49906
	endif;
	//Start 31 OCT 2022 NAVSKS20 TFS 52721
	ti := self.myTrackedItem;
    if ti &lt;&gt; null then
		term := ti.myTerminal;
		qtask := ti.queueTask;
    endif;

    if ti &lt;&gt; null then
		if qtask &lt;&gt; null then
			if delReqRequest &lt;&gt; null // if a yard delivery request
            and ti.myPrimaryActualLocation &lt;&gt; null 
            and ti.myPrimaryActualLocation.isMachineController() 
			and releaseItem &lt;&gt; null then // has a bulk release detail specified
				if term.getConfig(DelReqAddToAssigned).Boolean then
					releaseItem.addTI(ti);
				endif;
			endif;
        else // no qtask so this is after the final set down, so no job, request, wles left
		
			if releaseItem &lt;&gt; null then // has a bulk release detail specified on the yard delivery request
				if term.getConfig(DelReqAddToReleased).Boolean then
					releaseItem.addTIReleased(ti); // Add the Ti to the released collection
					releaseItem.myReserveHeader.updateStatus(); // set to complete if 'all released'
				endif;
			endif;
			// ### subTerm will only be populated by a yard delivery request on an internal yard job.
            if term.getConfig(DelReqChangeSubTerm).Boolean then  // ### TFS 52721 17NOV2022 NAVAB1
                if subTerm &lt;&gt; null then
					tiSubTerm := ti.mySubTerminal;
					if tiSubTerm &lt;&gt; null then
						subTermStr := tiSubTerm.code;
					endif;
                    ti.setMySubTerminal(subTerm.code); 
					ti.createEditTransaction("Sub Terminal Changed '" &amp; subTermStr &amp; "' ==&gt; '" &amp; subTerm.code &amp; "'");
                endif;
            endif;
        endif;
    endif;
	//End 31 OCT 2022 NAVSKS20 TFS 52721
	
	//jlier1 JIRA-35636   27/8/25
	if self.moveMode = REAL_MODE then
		CMIF_TrxActionOverstow@createAction(self.myOriginatingLocation, self.myToPrimaryLocation, self.myTrackedItem, app.myPassport);
	endif;
	
	
	//15/04/2025	navkc1 JIRA Defect Sub-task MTN-34620
	if self.myWorkListEntry &lt;&gt; null then
		app.myEventManager.createSingleObjInfoNoteEvt(self.myWorkListEntry, term.getTerminalEvent(WLE_Update_Event), self.myWorkListEntry);
		
		//23/06/2025	navkc1 JIRA Defect 35182
		if app.isValidObject(self.myWorkListEntry) then
			wo := self.myWorkListEntry.getWorkOrder();
		endif;
		
		//23/06/2025	navkc1 JIRA Defect 35182
		if wo &lt;&gt; null then
			app.myEventManager.createSingleObjInfoNoteEvt(wo, term.getTerminalEvent(Event_WorkOrder_Update), wo);
		endif;
		
	endif;
epilog	
	self.autoSeqLoadPlan := false;
	if origTI &lt;&gt; null and
	   self.myTrackedItem &lt;&gt; origTI then
		self.setMyTrackedItem(origTI);
	endif;
	if origWLE &lt;&gt; null and
	   self.myWorkListEntry &lt;&gt; origWLE then
		self.setMyWorkListEntry(origWLE);
	endif;
	
	//navra1 - TFS 65376 - 31st July 2024 - 1 - start
	self.continueVoyageAutoProgression(ti);
	//navra1 - TFS 65376 - 31st July 2024 - 1 - end
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="executePostUndoMove" id="d65240ca-5495-4c27-b030-97c1eb296043">
        <updating/>
        <source>executePostUndoMove(_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpSlotReq : CM_SlotRequest;	
	tmpHoldRequest : CM_HoldRequest;
	tmpROROReq : CM_RORORequest;
	tmpWLE      : CM_WorkListEntry;
	movementLog : CM_MovementLog;
	controller  : CMIF_MoveController;
	theJob : CM_Job;
begin
	//--------------------
	//Set the cleanup flag so validation is not called
	//--------------------
	//jlier1 TFS 61698 rtl auto unqueing - now doing for all cargo
	/*if self.myTrackedItem.isBulkCargo() then
		// For now return;
		return;  
	endif; */
	
	self.isPostMoveCleanup := true;

	tmpSlotReq := self.mySlotRequest;
	if tmpSlotReq &lt;&gt; null 
	and tmpSlotReq.isSOB()
	and tmpSlotReq.isLinked() then
		if tmpSlotReq.isLoad then
			// ### LOAD SOB
			tmpWLE := tmpSlotReq.allWorkListEntries.first;
			if tmpWLE &lt;&gt; null then
				tmpWLE.setLocations(null,null);
				tmpWLE.setMyTrackedItem(null);
			endif;
			// ### DISCH SOB
			tmpWLE := tmpSlotReq.getLinkedRequest(tmpSlotReq.isReleaseType).allWorkListEntries.first; // PAR 28968 getDLRSOBRequestLink.allWorkListEntries.first;
			if tmpWLE &lt;&gt; null then
				tmpWLE.setLocations(tmpWLE.locationSource,null);
			endif;
		else
			// ### DISCH SOB
			tmpWLE := tmpSlotReq.allWorkListEntries.first;
			if tmpWLE &lt;&gt; null then
				tmpWLE.setLocations(tmpWLE.locationSource,null);
			endif;
			// ### LOAD SOB
			tmpWLE := tmpSlotReq.getLinkedRequest(tmpSlotReq.isReleaseType).allWorkListEntries.first; // PAR 28968 getDLRSOBRequestLink.allWorkListEntries.first;
			if tmpWLE &lt;&gt; null then
				tmpWLE.setLocations(null,null);
				tmpWLE.setMyTrackedItem(null);
			endif;
		
		endif;
	endif;
	
	if self.myVoyageRequest &lt;&gt; null and self.myVoyageRequest.isHoldRequest() then
		if self.moveMode = PLANNING_MODE then
			tmpHoldRequest := self.myVoyageRequest.CM_HoldRequest;
			if tmpHoldRequest.myBulkReleaseReserveDetail &lt;&gt; null then
				// ### CM_HoldRequest that are assigned to a reserve detail have 1 job, 1 request and 1 wle
				theJob := tmpHoldRequest.myJob;
				theJob.erase(NORMAL_ERASE);
			endif;
		endif;
	else
		tmpROROReq := self.myVoyageRequest.CM_RORORequest;
		if tmpROROReq &lt;&gt; null 
		and tmpROROReq.isSOB()
		and tmpROROReq.isLinked() then
			if tmpROROReq.isLoad then
				// ### LOAD SOB
				tmpWLE := tmpROROReq.allWorkListEntries.first;
				if tmpWLE &lt;&gt; null then
					tmpWLE.setLocations(null,null);
					tmpWLE.setMyTrackedItem(null);
				endif;
				// ### DISCH SOB
				tmpWLE := tmpROROReq.getDLRSOBRequestLink.allWorkListEntries.first;
				if tmpWLE &lt;&gt; null then
					tmpWLE.setLocations(tmpWLE.locationSource,null);
				endif;
			else
				// ### DISCH SOB
				tmpWLE := tmpROROReq.allWorkListEntries.first;
				if tmpWLE &lt;&gt; null then
					tmpWLE.setLocations(tmpWLE.locationSource,null);
				endif;
				// ### LOAD SOB
				tmpWLE := tmpROROReq.getDLRSOBRequestLink.allWorkListEntries.first;
				if tmpWLE &lt;&gt; null then
					tmpWLE.setLocations(null,null);
					tmpWLE.setMyTrackedItem(null);
				endif;
			
			endif;
		endif;
	endif;

	controller := self;	//rs1 feb 2006 ccms1416
	self.myTrackedItem.executeControlPostMove(controller, _passport);
	//
	// Now create a MovementLog object for background task to update statistics
	// Code needs to be added here if we do not want to do this for selected CM_Terminals
	//
	create movementLog persistent;
	movementLog.setupForCreate(self.mySourceLocation, self.myTargetLocation,
			    self.myTrackedItem, self.moveMode, CancelMove_Action);

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="executeUndoMove" id="8d623c83-4c7a-4c9c-b66b-16972a2869ee">
        <updating/>
        <source>executeUndoMove(_passport : CM_Passport input) updating;
/*
 ------------------------------------------------------------------------
Created:			20 December 2001 by cnwdwq1
Purpose:			The method depends on 2 things ONLY.
							1) The mode being PLANNED or QUEUED mode
							2) The myTrackedItem reference being set. We use this object to get the
									appropriate locations to wind back.
							
							All other properties are ignored
							
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------	--------------	-----------------------------------------
12/05/2010		cnwdap1			CCMS 1116 Tranship changes
21 May 2010		cnwkpd1			PAR #20728 - remove isValidObject calls for performance
19 Oct 2021		navdap1			TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
---------------------------------------------------------------------------
*/

vars
	child : CM_TrackedItem;
	theSource, theTarget, theTargetOH : CM_LocationsController;
	numCleaned	: Integer;
	origIsUndoMove : Boolean;
	tmpWLE, theWLE	: CM_WorkListEntry;
	source, target : String;
	theFM : CM_FutureMove;
	invalid : Boolean;
	dlrLoad : Boolean;
begin
	//-------------------------
	//Check the move is OK to proceed
	//-------------------------
	// Save self.isUndoMove original value as the move controller
	// can be re-used multiple times for various types of moves
	origIsUndoMove := self.isUndoMove;
	self.isUndoMove := true;

	if self.myPassport = null then
		self.myPassport := _passport;
		self.userCode := _passport.userCode;
	endif;
	
	if self.myTrackedItem = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'self.myTrackedItem = null');
		return;
	endif;
	if self.moveMode = PLANNING_MODE and self.myPassport &lt;&gt; null and self.myPassport.myStateChangeController &lt;&gt; null then
		self.myPassport.myStateChangeController.initForObject(self.myTrackedItem); //jlier1 TFS 61676 14/12/23 
	endif;	
	if not self.isDLRLoadWithOutDischarge  then // CCMS 1368
		self.isDLRLoadWithOutDischarge := self.myTrackedItem.isDLRLoadWithOutDischarge();
	endif;
	
	if self.isPostMoveCleanup = false then
		//--------------------
		//This move is external, and NOT part of a move. We validate the undo
		//--------------------
		self.validateMove(_passport);
		if _passport.hasErrorsOrWarnings 
		and not _passport.warningsAcknowledged 
		and not _passport.warningsIgnored then // AKB2003MAY added or warnings and warningsAcknowledged
			return;
		endif;
	endif;
	
	// ### JIRA 33775 22JAN2025 NAVAB1 use the WLE on the move controller, if unplanning LOLO the WLE has dettached its TI by now so the 'else' did not work.
	//																A rehandle 20 footer that is planned for dishcarge and load will have 2 WLEs, when unplan the load by this line of code the load WLE has dettached the TI so the TI only has 1 WLE. 
	//																A rehandle 40 footer that is planned for dishcarge and load will have 4 WLEs, when unplan the load by this line of code the load WLE for the front end has dettached the TI so the TI only has 3 WLEs. 
	if self.moveMode = PLANNING_MODE
	and self.myTrackedItem.isRehandle
	and self.moveIndex &gt; 0 then
		if self.myWorkListEntry &lt;&gt; null and self.myWorkListEntry.status = WLE_UNACTIONED then
			theFM := self.myTrackedItem.allPlannedFutureMoves[self.moveIndex];
			
			theTarget := theFM.getPrimaryLocation();
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'WLE is null on move controller');
			return;
		endif;
	else
	
		//17 Feb 2011	NDL	Par 27006 - If passing in the wle to unqueue, and the ti has multiple queued moves, can pick the wrong
		//							location to unqueue....
		if self.moveMode = PLANNING_MODE or self.moveMode = QUEUE_MODE then
			if self.myTrackedItem.allWorklistEntries.size &gt; 1 then
				on Exception do app.handleDeletedObject(exception, self.myWorkListEntry, invalid);
				if self.myWorkListEntry &lt;&gt; null and self.myWorkListEntry.status = WLE_UNACTIONED then
					theTarget := self.myWorkListEntry.getTargetLocation;
					
					//10 Dec 2019	NDL	TFS 46875 - if this one is rail source and split off the original wle
					// and there is another unmoved with no location then merge this back in, i.e. increment the quantty
					//if self.moveMode = PLANNING_MODE and self.myOriginatingLocation.isWagon then											// TFS 51935
					if self.moveMode = PLANNING_MODE and self.myOriginatingLocation &lt;&gt; null and self.myOriginatingLocation.isWagon then		// TFS 51935
						if self.myTrackedItem.myCargoType.isBulkByQuantity
						and self.myWorkListEntry.myRequest &lt;&gt; null
						and self.myWorkListEntry.myRequest.isKindOf( CM_TIRequest )
						then
							foreach tmpWLE in self.myWorkListEntry.myRequest.allWorkListEntries do
								if self.myWorkListEntry.status &lt;&gt; WLE_UNACTIONED then	// only want unaction wles
									continue;
								endif;
								if tmpWLE = self.myWorkListEntry then// don't want ourself.
									continue;
								endif;
								if tmpWLE.myTrackedItem &lt;&gt; self.myWorkListEntry.myTrackedItem then//must be teh same ti
									continue;
								endif;
								if tmpWLE.myFutureMove &lt;&gt; null then //don't want one already planned or queued
									continue;
								endif;
								// got the brother with the same mother, update his quantity and delete me
								tmpWLE.setQuantity( tmpWLE.quantity + self.myWorkListEntry.quantity );
								if self.myWorkListEntry.myFutureMove &lt;&gt; null then
									self.myWorkListEntry.myFutureMove.erase(NORMAL_ERASE);
								endif;
								self.myWorkListEntry.erase(NORMAL_ERASE);
								return;
							endforeach;
						endif;
					endif;
					
				endif;
			endif;
		endif;
	
		// do this here before they are nulled out
		// we use these at bottom to cause an event to update any yard area GUI displays

		if theTarget = null and self.deleteQueuedLocation &lt;&gt; null then	
			theTarget := self.deleteQueuedLocation;
			self.setMoveIndex(self.myTrackedItem.allQueuedFutureMoves.getIndexOfLC(theTarget));
		endif;
		
		if theTarget = null then	//17 Feb 2011	NDL	Par 27006 - it may have been set just above..
			//27 Aug 2019	NDL	TFS 42876
	//		if self.myTrackedItem.allQueuedFutureMoves.size &gt; 1 and self.moveIndex &lt;&gt; 1 then
			if self.myTrackedItem.allQueuedFutureMoves.size &gt; 1 and self.moveIndex &gt; 1 then	//13 Mar 2020	NDL	TFS 48861
				if self.moveIndex &lt;= self.myTrackedItem.allQueuedFutureMoves.size then
					theTarget := self.myTrackedItem.allQueuedFutureMoves[self.moveIndex].CM_FutureMoveQueued.getPrimaryLocation();
				endif;
			endif;
			if theTarget = null then
				theTarget := self.myTrackedItem.getPrimaryLocation(QUEUE_MODE);
			endif;
			self.setMoveIndex(self.myTrackedItem.allQueuedFutureMoves.getIndexOfLC(theTarget));
		endif;
		if theTarget = null then
			theTarget := self.myTrackedItem.getPrimaryLocation(PLANNING_MODE);
			self.setMoveIndex(self.myTrackedItem.allPlannedFutureMoves.getIndexOfLC(theTarget));
		endif;
	endif;
	
	theSource := self.myTrackedItem.getPrimaryLocation(REAL_MODE);
	
	// ### JIRA 33775 22JAN2025 NAVAB1
	if self.myWorkListEntry &lt;&gt; null and self.myTrackedItem.isRehandle and not self.myWorkListEntry.isReceipt then // LOAD
		dlrLoad   := true;
		 // ### JIRA 34799 05MAY2025 NAVAB1
		if  self.myTrackedItem.allRehandleDischLocations = null or self.myTrackedItem.allRehandleDischLocations.isEmpty() then // if the discharge has been done this is empty
			theSource := self.myTrackedItem.myPrimaryActualLocation;
		else
			theSource := self.myTrackedItem.allRehandleDischLocations.first;
		endif;
	endif;

	//
	// Needed for MovementLog
	//
	self.myTargetLocation := theTarget;
	self.mySourceLocation := theSource;

	//-------------------------
	//Null out the locations (so the move goes to null)
	//-------------------------
	self.setMyToPrimaryLocation(null);
	self.setMyToSecondaryLocations(null);

	//-------------------------
	//MOVE the sucker, this performs the undo at the lowest level.
	//-------------------------
	self.myTrackedItem.executeControlMove(self, _passport);

	if self.isOverstowMoveSecondary then
		self.isOverstowMove := true;
	endif;
	if self.allOtherTrackedItems.size &gt; 0 then
		foreach child in self.allOtherTrackedItems do
			child.executeControlMove(self, _passport);
			self.doWleUpdateForChild(child, _passport);			
		endforeach;
	endif;	
	
	// this will cause an event to update any yard area GUI displays
	// do this here before they are nulled out
	// Not necessary to do this as the CM_FutureMove.ERASE send out the notes for Qd and Pd
	
	
	// ### JIRA 33775 22JAN2025 NAVAB1
	if dlrLoad then
		self.doUpdateDisplayEvent(theSource);
//	self.doUpdateDisplayEvent(theTarget);
	endif;
	
	self.doWLEUpdate(_passport);
	//if self.moveMode = PLANNING_MODE then									// cnwjk3 ccms 1018 29/01/10
	if self.moveMode = PLANNING_MODE or self.moveMode = QUEUE_MODE then		// cnwjk3 ccms 1018 29/01/10
		//self.doWLEUpdate(_passport);
		if theTarget &lt;&gt; null then
			theTarget.executePostUndoMove(self, _passport);
		endif;
		if theSource &lt;&gt; null then
			theSource.executePostUndoMove(self, _passport);				
		endif;
	endif;	

	// DVB  24/05/04 changed this code to check for invalid wle as it was crashing system
	// when unqueing a Yard Internal job.
	tmpWLE := self.myWorkListEntry;
	if self.moveMode = PLANNING_MODE then
		if tmpWLE &lt;&gt; null then			// and global.isValidObject(tmpWLE) then
			invalid := false;
			on Exception do app.handleDeletedObject(exception, tmpWLE, invalid);
			source := tmpWLE.locationSource;
			
			if not invalid then
				target := null;
				
				if tmpWLE.isKindOf(CM_VoyageWLE) then
					if tmpWLE.CM_VoyageWLE.isRehandle then
						if not tmpWLE.isReceipt then // DLR LOAD, may know its source from the Disch DLR
							theFM := self.myTrackedItem.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveDLRDischarge);
							if theFM &lt;&gt; null then
								source := theFM.getPrimaryLocationId();
							endif;
						// ### PAR 9089 AKB2004OCT new from here
						else
							if tmpWLE.status = WLE_COMPLETED then // ### PAR 9747 tmpWLE is the discharge DLR move. If it is complete it is being unplanned because it has been instant drag dropped in voyage ops.
								// do nothing for the moment
							else
								theFM := self.myTrackedItem.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveDLRLoad);
								if theFM &lt;&gt; null then
									theWLE := theFM.myWorkListEntry;
									if theWLE &lt;&gt; null then
										theWLE.setLocations(null,theWLE.locationTarget);
									endif;
								endif;
							endif;
						// ### AKB2004OCT new to here
						endif;
					endif;
				endif;
				tmpWLE.setLocations(source,target);
	
				if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isTranshipOnInboundVoyage() then
					//theFM := self.myTrackedItem.myTranshipExport.getFutureMoveOfType(PLANNING_MODE,TI_FutureMovePlanned);	// PAR #23645 CCMS 1116
					theFM := self.myTrackedItem.getFutureMoveOfType(PLANNING_MODE,TI_FutureMovePlanned);					// PAR #23645 CCMS 1116
					if theFM &lt;&gt; null and theFM.myWorkListEntry &lt;&gt; null then
						source := target;
						target := theFM.getPrimaryLocationId();
						theFM.myWorkListEntry.setLocations(source,target);
					endif;
				endif;
			endif;
		endif;
	endif;


	//cnwjo3 par 18862
	if theTarget &lt;&gt; null then
		self.doUpdateDisplayEvent(theTarget);
	endif;
	// PAR 28339
	if theSource &lt;&gt; null then
		self.doUpdateDisplayEvent(theSource);
	endif;
epilog
	self.isUndoMove := origIsUndoMove;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getEstimateFinString" id="4bd6ceb6-c72f-425c-97bd-fff950e26064">
        <source>getEstimateFinString(_started : TimeStamp; _parts : Integer; _done : Integer) : String;
// ---------------------------------------------------------------------------
// Created:		08 September 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	now : TimeStamp;
	pcDone, pcToDo, diffSeconds, todoSeconds : Integer;
	hours, minutes, seconds : Integer;
	etc : String;
begin
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
		diffSeconds := (now.cnEcDiff(_started) / 1000).Integer;
		
		pcDone := ((_done / _parts) * 100).Integer;
		pcToDo := 100 - pcDone;
		
		todoSeconds := (diffSeconds * (pcToDo / pcDone)).Integer;
		
		etc := todoSeconds.getHMS();
		
		return "(" &amp; etc &amp; " ETC)";
			
end;</source>
        <Parameter name="_started" type="TimeStamp"/>
        <Parameter name="_parts" type="Integer"/>
        <Parameter name="_done" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMachineId" id="bce8bfe2-ab33-4604-a7aa-d57ea2fe7dd8">
        <source>getMachineId() : String;
/*
 ------------------------------------------------------------------------
Created:			25 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	if self.myMachine = null then
		return null;
	endif;
	return self.myMachine.id;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMoveAmountDisplay" id="4452b7d3-3aa5-4ab7-b1c4-20293aae9984">
        <source>getMoveAmountDisplay(_showUnit : Boolean) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2014	cnwndl1	Initial creation	Par 

*/

vars
	
	ti 			: CM_TrackedItem;
	ct			: CM_CargoType;
	moveWeight 	: Decimal[14,4];
begin
	ti:=self.myTrackedItem;
	if ti &lt;&gt;  null then
		ct:=ti.myCargoType;
	endif;
	
	if ct &lt;&gt; null and  ct.isBulkMulti then
		moveWeight:=self.weight;
		if moveWeight = 0 and  ti &lt;&gt;  null then
			moveWeight:=  ti.totalWeight;
		endif;
		return self.getMoveAmountForWeight(moveWeight,_showUnit);
	endif;		
	
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isKindOf(CM_BreakBulkGeneric) then
		if self.quantity = 0 then
			return self.myTrackedItem.totalQuantity.String;
		else
			return self.quantity.String;
		endif;
	else
		return self.quantity.max(1).String;
	endif;
	

epilog

end;</source>
        <Parameter name="_showUnit" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMoveAmountForWeight" id="691049f9-3c93-483a-aa5e-ca03af88c604">
        <source>getMoveAmountForWeight(_weight : Decimal;_showUnit : Boolean) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2014	cnwndl1	Initial creation	Par 34665

*/

vars
	ti 			: CM_TrackedItem;
	ct			: CM_CargoType;
	product	 	: CM_Product;
	density 		: Decimal[14,4];
	
begin
	ti:=self.myTrackedItem;
	if ti &lt;&gt;  null then
		ct:=ti.myCargoType;
	endif;
	
	density:=ti.getDensity();
	
	if ct &lt;&gt; null then
		return ct.getBulkTrackByDisplayForWeight(_weight,density,_showUnit);
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_showUnit" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMoveModeString" id="43bee8c8-3d55-4e46-9a16-796581a0af91">
        <source>getMoveModeString() : String;
// ---------------------------------------------------------------------------
// Created:     04 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.moveMode = REAL_MODE then
		return app.getErrorString( Actual_move);
	elseif self.moveMode = QUEUE_MODE then
		return app.getErrorString(Queued_Move);
	elseif self.moveMode = PLANNING_MODE then
		return app.getErrorString(Planned_Move);
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyVehicleVisitRecord" id="25eaa8d1-32b8-4156-9f1e-8907603e1eee">
        <source>getMyVehicleVisitRecord():CM_VehicleVisitRecord;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2020	jlgndl1	Initial creation	TFS 50113

*/

vars

	terminal : CM_Terminal;
	vehicle : CM_Vehicle;

begin

	if self.myAssociatedVVR &lt;&gt; null then
		//This guy has a VVR, use it
		return self.myAssociatedVVR;
	endif;
	
	if self.jobForMove &lt;&gt; null then
		if self.jobForMove.isRoadJob and self.jobForMove.CM_RoadJob.myVehicleVisit &lt;&gt; null then 
			return self.jobForMove.CM_RoadJob.myVehicleVisit;
		endif;
	endif;
	
	if self.isMoveToVehicle then	
		vehicle := self.myToPrimaryLocation.getVehicle;
	endif;
	
	if vehicle = null and self.isMoveFromVehicle then
		vehicle := self.myOriginatingLocation.getVehicle;
	endif;
	
	if vehicle = null then
		return null;
	endif;
	
	return vehicle.getCurrentVisit();

epilog

end;</source>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="getOriginatingLocationId" id="4ecbdd2a-ef30-424a-b576-3be66996752a">
        <source>getOriginatingLocationId() : String;
/*
 ------------------------------------------------------------------------
Created:			25 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------	--------------	-----------------------------------------
07 Dec 2022 	navma1 			ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
// 21.05.2024 	navma1 			Bug 64201: MTN - Stop Creating Alerts When Loading Ship manifest
---------------------------------------------------------------------------
*/
vars
	theTI  				 : CM_TrackedItem;
	originatingLocation  : CM_LocationsController;
begin
	
	theTI 				:= self.myTrackedItem;
	originatingLocation := self.myOriginatingLocation;		//21.05.2024 navma1 #64201
	
	if originatingLocation = null then
		
		
		//21.05.2024 navma1 #64201
		/*
		if theTI &lt;&gt; null and app.myPassport &lt;&gt; null and not app.myPassport.isInEdiVerifyMode  then // PAR 17496			//07.12.2022 navma1 #52499
			// PAR 17496 only do this if has been released, problem with move from nowhere is that this will be true every time a TI is created
			if theTI.isContainer() then
				trans := theTI.getLastTransOfTypeClass(CM_Release); // PAR 17496
			endif;
			
			// AKB2004FEB added from here
			if (self.isUndoMove or self.isFullyUnplan)
			or (trans &lt;&gt; null) then  // PAR 17496 - has been released, so offsite, but is coming back onsite
				if theTI &lt;&gt; null  then
					if self.moveMode = PLANNING_MODE then
						msgStr := "unplanned";
					else
						msgStr := "unqueued";
					endif;
					create alert;
					alert.details := theTI.id &amp; " (" &amp; theTI.String &amp; ") is being " &amp; msgStr &amp; " from nowhere!";
					app.outputProcessStackToAlert(alert);
					alert.setMyTrackedItem(theTI);
					alert.setSeverity(SEVERE_ERROR);
					alert.add;
					app.commitAlert();
				endif;	
			endif;
		endif;
		// AKB2004FEB added to here
		*/
		return app.getErrorString(Nowhere);
	endif;

	if self.moveMode = PLANNING_MODE or self.moveMode = QUEUE_MODE then
		if originatingLocation.isKindOf(CM_VoyageController) then // PAR 7978
			return originatingLocation.getFullIdTI(theTI); // PAR 7978
		else
			return originatingLocation.getFullIdAndLevel(theTI, self.moveMode, false);// PAR 14387 MO took these out, put back as need 20 or 40 ID
		endif;
	else
		// REAL MODE
		//return self.myOriginatingLocation.getFullIdAndLevel(theTI,self.moveMode, true);// PAR 15133 
		//changed to TRUE // PAR 14387 MO took these out, put back as need 20 or 40 ID
		// PAR 17775 - this is crap and whole setting/getting of source location string needs to be reviewed
		// BUT was required as Generators were being detached and moved - level was being shown incorrectly.
		if theTI &lt;&gt; null and theTI.isContainer then
			return originatingLocation.getFullIdAndLevel(theTI,self.moveMode, true);// PAR 15133 changed to TRUE // PAR 14387 MO took these out, put back as need 20 or 40 ID
		else
			return originatingLocation.getFullId();
		endif;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPrimaryLocationId" id="baf7e93f-c2ed-407c-b663-93b70dc6e696">
        <source>getPrimaryLocationId() : String;
/*
 ------------------------------------------------------------------------
Created:			25 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------	--------------	-----------------------------------------
07 Dec 2022 	navma1 			ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
21 May 2024     navma1			// 21.05.2024 navma1 Bug 64201: MTN - Stop Creating Alerts When Loading Ship manifest
---------------------------------------------------------------------------
*/
vars
	theTI 				: CM_TrackedItem;
	toPrimaryLocation	: CM_LocationsController;
begin
	
	toPrimaryLocation := self.myToPrimaryLocation;									//21.05.2024 navma1 #64201
	theTI 			  := self.myTrackedItem;
	
	if toPrimaryLocation = null then 
		
		/*
		//21.05.2024 navma1 #64201
		if app.myPassport &lt;&gt; null and not app.myPassport.isInEdiVerifyMode then		//07.12.2022 navma1 #52499
			if (self.moveMode = PLANNING_MODE or self.moveMode = QUEUE_MODE) 
			and not (self.isUndoMove or self.isFullyUnplan) then
			
				// AKB2004JUNE added from here
				if theTI &lt;&gt; null  then
					if self.moveMode = PLANNING_MODE then
						msgStr := "planned";
					else
						msgStr := "queued";
					endif;
					create alert;
					alert.details := theTI.id &amp; " (" &amp; theTI.String &amp; ") is being " &amp; msgStr &amp; " to nowhere!";
					app.outputProcessStackToAlert(alert);
					alert.setMyTrackedItem(theTI);
					alert.setSeverity(SEVERE_ERROR);
					alert.add;
					app.commitAlert();
				endif;	
			endif;
		endif;
		// AKB2004JUNE added to here
		*/
		
		return app.getErrorString(Nowhere);
		
	endif;
	
	if self.moveMode = PLANNING_MODE or self.moveMode = QUEUE_MODE then
		// WAS PAR 7978 return self.myToPrimaryLocation.getFullId();
		// instant move on ship needs a TI so taht it can pass back the 20 or 40 bay id. 
		// The problem was that the move is complete now so the orginal location has no ti to test
		if CM_VoyageController.hasInstance(toPrimaryLocation) then
			return toPrimaryLocation.getFullIdTI(self.myTrackedItem);
		else
			// RBarr	24/7/2006	PAR 11955	Add indication of TI level in stack
			//return self.myToPrimaryLocation.getFullId();
			return toPrimaryLocation.getFullIdAndLevel(theTI, self.moveMode, true);
		endif;
	elseif self.myToPrimaryLocationString &lt;&gt; null then
		return self.myToPrimaryLocationString;
	else
		// RBarr	24/7/2006	PAR 11955	Add indication of TI level in stack
		//return self.myToPrimaryLocation.getFullId();
		return toPrimaryLocation.getFullIdAndLevel(theTI,self.moveMode, true);
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRTQueueArbiter" id="b81480ba-b24c-4b0a-8002-d60768af5ae6">
        <updating/>
        <source>getRTQueueArbiter() : CM_RTQueueArbiter updating;

// Created by cnwdvb1 on 22 March 2007
//10 Nov 2025 jlier1	MTN-36536 	
vars
	machine : CM_Machine;
begin

	if self.myRTQueueArbiter = null then
		create self.myRTQueueArbiter transient;
	else
		self.myRTQueueArbiter.reset();
	endif;

	self.myRTQueueArbiter.isDriverInitiatedMove:=self.isDriverInitiatedMove; //epr CCMS 1391 21/8/14 driver initiated moves don't need a target need this flag to subdue errors
	self.myRTQueueArbiter.myCurrentMachineTypeGroup:=app.myRoot.allMachineTypeGroups[self.machineTypeGrp];
	
	/*//jlier1 JIRA-36155 14/10/25 - not needed because is now in the interchange area
	if self.myTrackedItem &lt;&gt; null then
		//if the 
		if self.myTrackedItem.isRotatableContainer and self.myTrackedItem.myPrimaryActualLocation.isKindOf(CM_MachineController) then
			machine:=	self.myTrackedItem.myPrimaryActualLocation.CM_MachineController.myMachine;
			if machine &lt;&gt; null and machine.myLastKnownLocation &lt;&gt; null then
				self.myRTQueueArbiter.sourceLocation:=machine.myLastKnownLocation;
			endif;
		endif;
	
	endif;*/
	
	
	return self.myRTQueueArbiter;
end;</source>
        <ReturnType type="CM_RTQueueArbiter"/>
    </JadeMethod>
    <JadeMethod name="getStowageDisplay" id="9234ca06-b29b-447a-a778-b7d067d280d8">
        <source>getStowageDisplay() : String;
/*

Date		Who		Reason
09 September 2015	cnwer1	Initial creation PAR 36320

*/

vars
	voyRequest : CM_Request;
	voyController : CM_LocationsController;
begin
	voyRequest := getVoyageRequest();
	
	if voyRequest = null then
		return null;
	endif;
	voyController:=voyRequest.getVoyageController();
	if voyController &lt;&gt; null then
		return voyController.getMyVoyage.code &amp; " " &amp; voyController.getStowageId(self.myTrackedItem);
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypesForDebtorRelease" id="10fc37e4-bbcb-4690-88a6-24fe2a1ebc3a">
        <source>getTiTxnTypesForDebtorRelease(_intArray : IntegerArray input);
//----------------------------------------------------------------
//	Created:	22 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	theDebtor	: CM_Debtor;
	txnType		: Integer;
begin
/* WAS TFS 41295
	// PAR 23816 - change to pass _intArray through
	if not self.isValidDebtorRelease(_intArray) then
		return;
	endif;

	if self.myTrackedItem = null and 
	self.myTrackedItem.myOperator = null then
		return;
	endif;
	
	theDebtor := self.myTrackedItem.myOperator.debtor;
	NOW */
	
	if not self.isValidDebtorRelease(_intArray) then
		return;
	endif;

	if self.myTrackedItem = null then
		return;
	endif;
	
	// TFS 41295 get the debtor from the configured cash debtor
	if self.myTrackedItem.myTerminal.getConfig(CashProcessingEnabled).Boolean then
		theDebtor := self.myTrackedItem.getDebtorForCashDebtorType();
	elseif	self.myTrackedItem.myOperator &lt;&gt; null then
		theDebtor := self.myTrackedItem.myOperator.debtor;
	endif;
	
	if theDebtor = null then
		return;
	endif;
	
	foreach txnType in theDebtor.allSpecialReleaseTxnTypes do
		if not _intArray.includes(txnType) and
		self.myTrackedItem.isRelevantTxnType(txnType) then
			_intArray.add(txnType);
		endif;
	endforeach;
	

end;</source>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypesToCreate" id="37dece07-1996-4d47-9679-84f4f4fa9bd0">
        <source>getTiTxnTypesToCreate(_intArray : IntegerArray input);
//--------------------------------------------------------------
//Created: 10 October 2002 By: cnwgd1
/* Changes

Date		Name	TFS#		Description
============================================================================
01/08/2018	jlgdap1	TFS 39964 	PEL1 Hold Job Ops Loading Changes
01/10/2019 	jlgka1 	TFS 46600 	PEL1 - Loading break-bulk PreNote to ship using Job Lander
19/09/2025		navcs2	MTN-35846 Dev - Returning of Lot Based Cargo | PortSchema Changes
============================================================================*/
vars
	toLocn,
	fromLocn	: CM_LocationsController;
	wle			: CM_WorkListEntry;
	trans 		: CM_TITransaction;	
begin

	if self.moveMode &lt;&gt; REAL_MODE then
		return;
	endif;
	
	if _intArray = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _intArray passed to method. Contact Developer.');
		return;
	endif;

	wle := self.myWorkListEntry;	
	
	if wle &lt;&gt; null then	
		if wle.status = WLE_COMPLETED then
		
			// 30 Jan 2012	NDL	Par 29034
			// Moving from Crane Lane to Ship via teklogix wont have created release trans etc.
			if process.persistentApp.name = "JMTRTProcess" or app.isJMTUnitTest then
				fromLocn := self.myOriginatingLocation;
				if fromLocn &lt;&gt; null and fromLocn.isKindOf( CM_CraneLaneController ) then
					toLocn := self.myToPrimaryLocation;
					if toLocn &lt;&gt; null and toLocn.isKindOf( CM_SlotController ) then
						if self.myTrackedItem.getLastTransOfType(TRANS_TYPE_REL_SHIP) = null then
							toLocn.getTiTxnTypesForMoveToFromLC(fromLocn, _intArray, self);
							fromLocn.getTiTxnTypesForMoveFromToLC(toLocn, _intArray, self);
						endif;	
					endif;
				endif;
			endif;
			
			//TI is being turned around and sent back to where it came from
			//No extra trans to create in this case
			return;
		endif;
	endif;
	//epr TFS  41751 1/11/18
	toLocn 		:= self.myToPrimaryLocation;
	if self.myDirectReleaseArea &lt;&gt; null then	//08 Jun 2018	NDL	TFS 38897
		//fromLocn := self.myDirectReleaseArea.CM_BlockStack.myLocationsController;
		toLocn :=self.myDirectReleaseArea.CM_BlockStack.myLocationsController;
	endif;
		
	fromLocn := self.myOriginatingLocation;
	
	
	if toLocn &lt;&gt; null then
		if fromLocn &lt;&gt; null then
			toLocn.getTiTxnTypesForMoveToFromLC(fromLocn, _intArray, self);
			fromLocn.getTiTxnTypesForMoveFromToLC(toLocn, _intArray, self);
		else
			// TFS 45731 deleted old code
			// TFS 45731 now just this check on already having a recevial			
			trans := self.myTrackedItem.findLastReceivalTrans();
			// TFS 45731 if the only 'receive' is created then create a proper receive
			if trans = null or trans.type = TRANS_TYPE_CREATED or self.isFromWeb or self.moveContext = CMIF_MoveController.CONTEXT_UPDATED_VEHICLEVISIT then // jlgka1 TFS 46600  		19/09/2025	navcs2	MTN-35846
				toLocn.getTiTxnTypesForMoveToFromNULL(self, _intArray);
			endif;
		endif;
		// To Rail and Road Not created until departureProcess i.e rake cleared or road exit process
		
		//epr TFS 41751 1/11/18
		if self.myDirectReleaseArea &lt;&gt; null and self.myToPrimaryLocation = null then
			self.myDirectReleaseArea.CM_BlockStack.myLocationsController.getTiTxnTypesForMoveFromToNULL(self, _intArray);			
		endif;
		
	elseif fromLocn &lt;&gt; null then
		// TFS 45731 deleted old code
		// TFS 45731 now just this check on already having a release
		if self.myTrackedItem.getLastTransOfType(TRANS_TYPE_REL_ROAD) = null then	
			//epr TFS  41751 1/11/18
			fromLocn.getTiTxnTypesForMoveFromToNULL(self, _intArray);
		endif;
	endif;

	//CCMS 1090 - need to create special txns for some debtors
	self.getTiTxnTypesForDebtorRelease(_intArray);

end;</source>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getVoyageRequest" id="91232e4b-13c8-4521-9a81-57bd7215ab30">
        <source>getVoyageRequest() : CM_Request;
/*

Date		Who		Reason
09 September 2015	cnwer1	Initial creation PAR

*/

vars
	voyRequest : CM_Request;
	
begin
	
	if	self.mySlotRequest &lt;&gt; null then
		voyRequest := self.mySlotRequest;		
	elseif self.myVoyageRequest &lt;&gt; null then
		voyRequest := self.myVoyageRequest;
	endif;
	
	return voyRequest;
epilog

end;</source>
        <ReturnType type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="getWLEForTI" id="baaf0098-b81d-4c76-9523-e08fb471adab">
        <source>getWLEForTI(_ti : CM_TrackedItem) : CM_WorkListEntry;
//--------------------------------------------------
// Created:	29 January 2004 By: cnwgd1
//--------------------------------------------------
//This is the WLE associated with the TI when the move is Operational.
//i.e. Ship/Rail/Road Ops move. 
vars
	wle : CM_WorkListEntry;
	ti	: CM_TrackedItem;
	invalidWLE : Boolean;

begin
	on Exception do app.handleDeletedObject(exception, wle, invalidWLE);	// PAR 36650

	if _ti = null then
		return null;
	endif;
	foreach wle in self.allOtherWLEs do
		invalidWLE := false;
		ti := wle.myTrackedItem;		// cause exception if wle is invalid
		if invalidWLE then				// 36650
			continue;
		endif;
		if ti = _ti then
			return wle;
		endif;
	endforeach;			
	return null;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getWeightForValidation" id="869ad445-47ab-4cd2-a3c1-8be55df56b84">
        <source>getWeightForValidation():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 September 2013	cnwndl1	Initial creation	Par 32479

*/

vars

	ti : CM_TrackedItem;
	weightOfMovingCargo : Decimal [16,4];
//	quantity : Integer;

begin

	//02 Feb 2016	NDL	Par 37492
	if self.weight &lt;&gt; 0 then
		return self.weight;
	endif;

	ti := self.myTrackedItem;
	if ti &lt;&gt; null then
		weightOfMovingCargo := ti.totalWeight;
		if ti.canSplitTotalQuantity then
		//	quantity := 0;
			if quantity &gt; 0 and quantity &lt; ti.totalQuantity then
				weightOfMovingCargo := ti.totalWeight * ( quantity / ti.totalQuantity );
			endif;
		endif;
	endif;
	
	return weightOfMovingCargo;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="handleWorkListEntryDeleted" id="51d08cee-c83f-4d26-9dbc-0cb6283cc44b">
        <source>handleWorkListEntryDeleted(_exc :Exception; _wle :CM_WorkListEntry) :Integer;

constants
	ObjectNotFound	= 4;
	ObjectDeleted	= 1072;
vars

begin
	if _exc.errorCode = ObjectNotFound or _exc.errorCode = ObjectDeleted then
		if _exc.errorObject = _wle then
			app.raiseCMException(Work_List_Entry_Deleted, null, null);
			return Ex_Resume_Next;
		endif;
	endif;
	return Ex_Pass_Back;
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasTranshipItems" id="c7a5a20c-3fc1-42e9-861a-88722f5cdadb">
        <source>hasTranshipItems() : Boolean;
/*
Purpose:			

Date		Who		Reason
17 July 2023	navab1	 BUG  58853
*/

vars
	ti : CM_TrackedItem;
begin
	ti := self.myTrackedItem;
	
	if ti &lt;&gt; null and ti.isTranshipItem then	
		return true;
	endif;
	
	foreach ti in self.allOtherTrackedItems discreteLock do
		if  ti.isTranshipItem then	
			return true;
		endif;
	
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCreateCargoOnVoyage" id="34dba844-7705-42ea-9472-569c9b011bab">
        <source>isCreateCargoOnVoyage():Boolean;
/*

Purpose:			I.e. are we creating Cargo on a ship?

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2021	navndl1	Initial creation	TFS	50866 

*/

vars

begin

	if self.moveMode &lt;&gt; REAL_MODE then
		return false;
	endif;

	if self.myOriginatingLocation = null then
		//we weren't anywhere
		if self.myToPrimaryLocation &lt;&gt; null then
			// and we are moving to the voyage
			return self.myToPrimaryLocation.isVoyageController;
		endif;		
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isDirectReleaseMove" id="33ff08de-8c8f-4c1a-add3-da0db20d3a6c">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>isDirectReleaseMove(set : Boolean; _value : Boolean io) updating, mapping;
/*

Purpose:			Is the controller set up to be processing a direct release move

Parameters:			

Return Value:		

Date				Who		Reason
05 July 2019		jlgzm1	TFS 42863 MSL - Direct Delivery Between RORO Voyages and Rail - BreakBulk

*/

vars

begin
	if set = true then
		self.isDirectReleaseMove := _value;
	else
		// if self.myDDWorkListEntry &lt;&gt; null then this is a direct release move
		// but while the move is being set up, this may not have been initialized
		// yet so need to be able to set manually temporarily
		if self.isDirectReleaseMove = true then
			_value := true;
		else
			if self.myDDWorkListEntry &lt;&gt; null then
				_value := true;
			else 
				_value := false;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isForShipLoadPlanning" id="8e20da17-5b52-4f71-99a1-5c6ab7ab6d03">
        <source>isForShipLoadPlanning() : Boolean;
/*

Date		Who		Reason
09 September 2015	cnwer1	Initial creation PAR 36320

*/

vars
	voyRequest 			: CM_Request;
	invalidObj			: Boolean;
begin
	on Exception do app.handleDeletedObject( exception, voyRequest, invalidObj);
	
	voyRequest:=getVoyageRequest;
	
	
	if voyRequest = null then
		return false;
	endif;
	
	if voyRequest.myJob &lt;&gt; null and not voyRequest.getIsDischarge() then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isJobShipDisharge" id="75265c2d-2bc0-4d5b-bccc-b53ee308c18f">
        <source>isJobShipDisharge() : Boolean;
/*
 ------------------------------------------------------------------------
Created:			01 May 2002 by cnwdwq1
Purpose:			Returns true if the job here is a ship discharge job.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	aJob : CM_Job;
begin
	aJob := self.jobForMove;
	
	if aJob &lt;&gt; null 
	and aJob.isKindOf(CM_VoyageJob) then
		return  aJob.CM_VoyageJob.isDischarge;
	elseif self.myWorkListEntry &lt;&gt; null then
		aJob := self.myWorkListEntry.job;
		if aJob &lt;&gt; null 
		and aJob.isKindOf(CM_VoyageJob) then
			return  aJob.CM_VoyageJob.isDischarge;
		endif;
	elseif self.mySlotRequest &lt;&gt; null then
		aJob := self.mySlotRequest.myJob;
		if aJob &lt;&gt; null 
		and aJob.isKindOf(CM_VoyageJob) then
			return  aJob.CM_VoyageJob.isDischarge;
		endif;
	elseif self.myVoyageRequest &lt;&gt; null then
		aJob := self.myVoyageRequest.myJob;
		if aJob &lt;&gt; null 
		and aJob.isKindOf(CM_VoyageJob) then
			return  aJob.CM_VoyageJob.isDischarge;
		endif;
	endif;
	return false;
/*
	if self.jobForMove = null then
		return false;
	endif;
	if self.jobForMove.isKindOf(CM_VoyageJob) = false then
		return false;
	endif;
	return self.jobForMove.CM_VoyageJob.isDischarge;
*/
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isJobShipLoad" id="451fdfd3-699a-47bd-a606-d8771a11222e">
        <source>isJobShipLoad() : Boolean;
/*
 ------------------------------------------------------------------------
Created:			01 May 2002 by cnwdwq1
Purpose:			Returns true if the job here is a ship discharge job.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	aJob : CM_Job;
	invalid : Boolean;
begin
	aJob := self.jobForMove;
	if aJob &lt;&gt; null 
	and aJob.isKindOf(CM_VoyageJob) then
		return not aJob.CM_VoyageJob.isDischarge;
	elseif self.myWorkListEntry &lt;&gt; null then
//		on Exception do handleWorkListEntryDeleted(exception, self.myWorkListEntry); // adm 160708 Par 17535
		on Exception do app.handleDeletedObject( exception, self.myWorkListEntry, invalid);	//06 Dec 2019	NDL	TFS 46875
		aJob := self.myWorkListEntry.job;
		if aJob &lt;&gt; null 
		and aJob.isKindOf(CM_VoyageJob) then
			return not aJob.CM_VoyageJob.isDischarge;
		endif;
	elseif self.mySlotRequest &lt;&gt; null then
		aJob := self.mySlotRequest.myJob;
		if aJob &lt;&gt; null 
		and aJob.isKindOf(CM_VoyageJob) then
			return not aJob.CM_VoyageJob.isDischarge;
		endif;
	elseif self.myVoyageRequest &lt;&gt; null then
		aJob := self.myVoyageRequest.myJob;
		if aJob &lt;&gt; null 
		and aJob.isKindOf(CM_VoyageJob) then
			return not aJob.CM_VoyageJob.isDischarge;
		endif;
	endif;
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMoveAnExportRePlan" id="5c82833b-b8fd-4c58-9ec6-c51f17bdbdc5">
        <source>isMoveAnExportRePlan() : Boolean;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		Do we have a TI that is planned Loaded as an export (load request), that the user now wants planned to another slot controller?

//
// ---------------------------------------------------------------------------

vars
	theTI : CM_TrackedItem;
	aLC : CM_LocationsController;
	aFM : CM_FutureMove;
		moves : CM_FutureMoveArray;
begin
	if self.moveMode = PLANNING_MODE then
		theTI := self.myTrackedItem;
		if theTI = null then
			return false;
		endif;
		
		if theTI.isSOB then
			return false;
		endif;
		
		aLC := theTI.myPrimaryPlannedLocation;
		if aLC = null then
			aLC := self.myOriginatingLocation;
			if aLC = null then
				return false;
			endif;
		endif;
		if self.mySlotRequest &lt;&gt; null  then
	
			if self.mySlotRequest.isRehandle and  self.mySlotRequest.isDischarge then // AKB2004FEB added is discharge
				return false;
			endif;
//			if self.mySlotRequest.isRehandle and  self.mySlotRequest.isLoad then // AKB2004FEB added is discharge
			if self.mySlotRequest.isLoad and theTI.isRehandle then  // PAR 37282 
				create moves transient; // PAR 37282 
				theTI.getFutureMovesOfType(PLANNING_MODE, TI_FutureMoveDLRLoad,moves); // PAR 37282 
				if moves.isEmpty() then // PAR 37282 If it is not currently DLR load planned then it is not a replan.
					return false; // PAR 37282 
				endif; // PAR 37282 
				aLC := self.myOriginatingLocation; // AKB2004FEB added is discharge
				if aLC = null then // AKB2004FEB added is discharge
					return false; // AKB2004FEB added is discharge
				endif;
			endif;
			
			// from one part of the ship to another
			if self.myToPrimaryLocation.isKindOf(CM_SlotController)
			and aLC.isKindOf(CM_SlotController) then
				// it's a load
				if self.mySlotRequest.isLoad then
					return self.myToPrimaryLocation.CM_SlotController.myVoyage = aLC.CM_SlotController.myVoyage; //12 Mar 2013	NDL	Part of Direct Delivery change.
				/*	if theTI.isTranshipExport() then
						if self.myToPrimaryLocation.CM_SlotController.myVoyage = aLC.CM_SlotController.myVoyage then
							return true;
						endif;
					else
						return true;
					endif; */
				endif;
			endif;
		elseif self.myVoyageRequest &lt;&gt; null  then
	
			if self.myVoyageRequest.isRehandle and  self.myVoyageRequest.isDischarge then 
				return false;
			endif;
			if self.myVoyageRequest.isRehandle and  self.myVoyageRequest.isLoad then 
				aLC := self.myOriginatingLocation; 
				if aLC = null then 
					return false; 
				endif;
			endif;
			
			// from one part of the ship to another
			if self.myToPrimaryLocation.isKindOf(CM_VoyageROROController)
			and aLC.isKindOf(CM_VoyageROROController) then
				// it's a load
				if self.myVoyageRequest.isLoad then
					return self.myToPrimaryLocation.CM_VoyageROROController.myVoyage = aLC.CM_VoyageROROController.myVoyage;	//03 Oct 2013	NDL	Par 32613  Allow for Direct Delivery					
				/*	if theTI.isTranshipExport() then
						if self.myToPrimaryLocation.CM_VoyageROROController.myVoyage = aLC.CM_VoyageROROController.myVoyage then
							return true;
						endif;
					else
						return true;
					endif; */
				endif;
			endif;
		endif;		
	endif;

	return false;
epilog
	delete moves;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMoveFromVehicle" id="1d32e397-c8be-475e-8563-02a4ada2b79b">
        <source>isMoveFromVehicle():Boolean;
// ---------------------------------------------------------------------------
// Created:     20 May 2009 by concms1
// Purpose:     Par 19715 - Vehicle Visit Record Detail Changes
// Parameters:  None
// Returns:     True if moving from a vehicle
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.myOriginatingLocation &lt;&gt; null and
			(self.myOriginatingLocation.isVehicle or self.myOriginatingLocation.isKindOf(CM_TILCController)); //epr par 33302 16/1/14 make sure VVR created when moved from/to a chassis
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMoveRealNWShipAToNWShipB" id="dfffefc7-125e-4d82-83dc-8bd96e7b2ae3">
        <source>isMoveRealNWShipAToNWShipB():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2013	cnwndl1	Initial creation	Par 32163

*/

vars

	toLocn : CM_LocationsController;
	fromLocn : CM_LocationsController;
	toVoyage : CM_Voyage;
	fromVoyage : CM_Voyage;

begin

	if self.moveMode &lt;&gt; REAL_MODE then
		//real mode only
		return false;
	endif;

	fromLocn := self.myOriginatingLocation;
	toLocn := self.myToPrimaryLocation;
	if fromLocn = null or toLocn = null then
		// A null location means coming from or going to 'off site'
		return false;
	endif;
	
	if not fromLocn.isKindOf( CM_VoyageController ) then
		//not ship to ship
		return false;
	endif;
	
	if not toLocn.isKindOf( CM_VoyageController ) then
		//not ship to ship
		return false;
	endif;
	
	toVoyage := toLocn.CM_VoyageController.myVoyage;
	fromVoyage := fromLocn.CM_VoyageController.myVoyage;
	if fromVoyage = null or toVoyage = null then
		//Huh? Voyage controller without a voyage should not happen
		return false;
	endif;
	
	if fromVoyage = toVoyage then
		//this would be a Shift on board
		return false;
	endif;
	
	//cnwmc5 - 17 Dec 2015 - PAR 37308 - this was too high level, adjusted to work with LOLO/RORO vessels with HOLDs
	if fromLocn.isSlotController() or fromLocn.isVoyageROROController 
	or toLocn.isSlotController() or fromLocn.isVoyageROROController then
		// At least one of these locations is worked
		return false;
	endif;
	/*
// PAR 33644	if not fromVoyage.isNonWorkedVoyage 
// PAR 33644	or not toVoyage.isNonWorkedVoyage then
	if fromVoyage.isLOLOorRORO 
	or toVoyage.isLOLOorRORO then
		// At least one of these boats is Worked
		return false;
	endif;
	*/
	//cnwmc5 - 17 Dec 2015 - PAR 37308 - end
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMoveTerminalAreaGroupChange" id="6ad97bc1-d1e5-41f8-8e82-a71e95d9c65b">
        <source>isMoveTerminalAreaGroupChange() : Boolean;
/*

Purpose:			TFS 41427

Parameters:			

Return Value:		

Date		Who		Reason
12 October 2018	jlgab1	Initial creation

*/

vars
	taStorageGroup : CM_TerminalAreaStorageGroup;
	terminal : CM_Terminal;
	sourceTA, targetTA : CM_TerminalArea;
	sourceGrp, targetGrp : CM_TerminalAreaStorageGroup;
begin

	if self.myTrackedItem = null then
		return false;
	endif;

	if self.myOriginatingLocation = null then
		return false;
	endif;

	if self.myToPrimaryLocation = null then
		return false;
	endif;
	
	terminal := self.myTrackedItem.myTerminal;
	
	if terminal = null then
		return false;
	endif;
	
	sourceTA := self.myOriginatingLocation.myTerminalArea;
	targetTA := self.myToPrimaryLocation.myTerminalArea;
	
	foreach taStorageGroup in terminal.allTerminalAreaStorageGroups 	discreteLock do
		if taStorageGroup.includesArea(sourceTA) 
		and sourceGrp= null then
			sourceGrp := taStorageGroup;
		endif;
		
		if taStorageGroup.includesArea(targetTA) 
		and targetGrp= null then
			targetGrp := taStorageGroup;
		endif;
		
	endforeach;
	
	if targetGrp = null then
		return false;
	endif;

	if sourceGrp = null then
		return false;
	endif;
	
	return targetGrp &lt;&gt; sourceGrp;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMoveToPackLocation" id="b0402304-519f-475f-892e-481697573c15">
        <source>isMoveToPackLocation():Boolean;
// ---------------------------------------------------------------------------
// Created:     09 February 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lc	:CM_LocationsController;
begin	
	lc := self.myToPrimaryLocation;
	
	return lc &lt;&gt; null and lc.isInPackArea;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMoveToVehicle" id="4b97c684-a1b7-4d7f-86b0-67a62aed662c">
        <source>isMoveToVehicle():Boolean;
// ---------------------------------------------------------------------------
// Created:     20 May 2009 by concms1
// Purpose:     Par 19715 - Vehicle Visit Record Detail Changes
// Parameters:  None
// Returns:     True if moving to a vehicle
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.myToPrimaryLocation &lt;&gt; null and
			(self.myToPrimaryLocation.isVehicle or self.myToPrimaryLocation.isKindOf(CM_TILCController)); //epr par 33302 16/1/14 make sure VVR created when moved from/to a chassis
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOverrideLocnRestrictions" id="5926a6c8-c201-49b8-ba97-add7293a2370">
        <source>isOverrideLocnRestrictions() : Boolean;
// -------------------------------------------
// Created 25 September 2003 by cnwdvb1
// -------------------------------------------
vars


begin

	if self.myRTQueueEntry &lt;&gt; null then
		if self.myRTQueueEntry.myWorkListEntry &lt;&gt; null then
			return self.myRTQueueEntry.myWorkListEntry.myRequest.isOverrideLocnRestrictions();
		endif;		
	endif;
	return false;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRealMoveToVoyagePosition" id="5643b957-5d20-4fff-a851-fc3a5c6a75fd">
        <source>isRealMoveToVoyagePosition():Boolean;
/*

Purpose:			I.e. are we moving Cargo from somewhere else (not creating from new ) to a position on a ship?

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2021	navndl1	Initial creation	TFS	50866 

*/

vars

begin

	if self.moveMode &lt;&gt; REAL_MODE then
		return false;
	endif;

	if self.myOriginatingLocation &lt;&gt; null then
		//we were somewhere already
		if self.myToPrimaryLocation &lt;&gt; null then
			// and we are moving to a position the voyage
			return self.myToPrimaryLocation.isVoyageController;
		endif;		
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isShiftLeft" id="138c70c5-76bc-4823-8a03-ff8cd2196757">
