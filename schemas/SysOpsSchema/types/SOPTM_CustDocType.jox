    <JadeMethod name="setControlsForAddEdit" id="5cdd4647-0efa-4d05-9143-5276aa17af1c">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*
Purpose:			

Date		Who		Reason
04 August 2023	navab1	CR 56093 TASK 59625
01/09/2023	navkc1	CR 59937 Task 59939: UI - Cust Doc Mandatory Fields
//05/09/2023	navkc1	CR 60156  Task 60157: UI - Cust Doc Type Colour
*/

vars
	theForm : SOP_TableMaintForm;
	dirStr : String;
begin
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := true;
	theForm.mulSelect2.userInputEnabled := true;
	theForm.mulSelect3.userInputEnabled := true;
	theForm.mulSelect6.userInputEnabled := true;
	theForm.mulSelect7.userInputEnabled := true; //01/09/2023	navkc1	CR 59937 Task 59939
		
	if theForm.mode = theForm.Mode_Add then 
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.clearValues;
		theForm.tblInput1.setValueByName(ETRow_Colour, White.String); //05/09/2023	navkc1	CR 60156  Task 60157
		theForm.mulSelect1.setSelected(null);
		theForm.mulSelect2.setSelected(null);
		theForm.mulSelect3.setSelected(null);
		theForm.mulSelect6.setSelected(null);
		theForm.mulSelect7.setSelected(null); //01/09/2023	navkc1	CR 59937 Task 59939
		theForm.tblInput1.setFocus;
		theForm.tblInput1.gotFocus(theForm.tblInput1);
		dirStr := CM_CustomDocumentType@getDirectStrFromInt(CM_CustomDocumentType.CustDocTypeDir_Inward);
		
		theForm.tblInput1.setValueByName(ETRow_Direction,dirStr); 
		theForm.cmbDirection.setIndexForItemData(CM_CustomDocumentType.CustDocTypeDir_Inward);
	else
		self.showThumbnail(theForm.myCurrentObject.CM_CustomDocumentType);
		theForm.tblInput1.disableRowByName(ETRow_Code);
	endif;
    theForm.tblInput1.cnEcResizeContents;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="e1f9d4ab-62a0-473b-83a4-66f3c0207216">
        <updating/>
        <source>setCtrlsForView() updating;
/*
Purpose:			

Date		Who		Reason
