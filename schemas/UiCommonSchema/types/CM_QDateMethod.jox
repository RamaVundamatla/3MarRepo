<Class name="CM_QDateMethod">
    <JadeMethod name="setDateRangeValues" id="95003934-ea03-44b5-b716-c9a6609414b1">
        <source>setDateRangeValues(_textboxArray : ObjectArray input; 
					_params: CM_QueryCriteriaLineHolder; 
					_operator: CM_QueryOperator; 
					_passport: CM_Passport);
// ---------------------------------------------------------------------------
// Created:     29 January 2009	cnwar2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	dateRangeOp		: CM_QDateRange;
	fromDate,
	toDate,
	today			: Date;
begin
	
	if _textboxArray = null or 
	   (_textboxArray.size &lt; 2) or
	   (not CM_QDateRange.hasInstance(_operator)) then
		return;
	endif;
	
	today := app.actualTimeServer.date;
	dateRangeOp := _operator.CM_QDateRange;
	fromDate := dateRangeOp.fromDate;
	toDate := dateRangeOp.toDate;
	
	if (not fromDate.isValid) and (not toDate.isValid) then
		fromDate := today -1;
		toDate := today;
	endif;
	
	_textboxArray[1].CMUI_DateMask.setDate(fromDate);
	_textboxArray[2].CMUI_DateMask.setDate(toDate);

end;</source>
        <Parameter name="_textboxArray" type="ObjectArray" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setDateValues" id="988c379e-4b0b-479c-854d-e5fb00b2b1f3">
        <source>setDateValues(_txt: CMUI_DateMask input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
// ---------------------------------------------------------------------------
// Created:     29 January 2009	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars
	theDate		: Date;
begin
	if _txt = null or (not  CM_QueryDateOperators.hasInstance(_operator)) then
		return;
	endif;
	
	theDate := _operator.CM_QueryDateOperators.searchValue;
	if (not theDate.isValid) then
		theDate := app.actualTimeServer.date;
	endif;
	
	_txt.setDate(theDate);

end;</source>
        <Parameter name="_txt" type="CMUI_DateMask" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setTextRangeValues" id="5149562c-1b44-4f36-bb35-31d57097ab23">
        <source>setTextRangeValues(_textboxArray : ObjectArray input; 
					_params: CM_QueryCriteriaLineHolder; 
					_operator: CM_QueryOperator; 
					_passport: CM_Passport);
/*

Purpose:			


Return Value:		


Date		Who		Reason
29 January 2009	cnwar2	Initial creation

*/
vars
	dateRangeOp		: CM_QDateDayRange;
	fromDay,
	toDay			: Integer;
	today			: Date;
begin
	
	if _textboxArray = null or 
	   (_textboxArray.size &lt; 2) or
	   (not CM_QDateDayRange.hasInstance(_operator)) then
		return;
	endif;
	
	today := app.actualTimeServer.date;
	dateRangeOp := _operator.CM_QDateDayRange;
	fromDay := dateRangeOp.fromNumDays;
	toDay := dateRangeOp.toNumDays;
	
//	if (not fromDate.isValid) and (not toDate.isValid) then
//		fromDate := today -1;
//		toDate := today;
//	endif;
	
	_textboxArray[1].TextBox.text:=fromDay.String;//.setDate(fromDate);
	_textboxArray[2].TextBox.text:=toDay.String;

epilog

end;</source>
        <Parameter name="_textboxArray" type="ObjectArray" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
