    <JadeMethod name="getReference" id="0820ac57-65ea-41cf-9011-45b2c074c83f">
        <source>getReference():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2024	navhl20	ChangeRequest 62056:[62122] FR | 53891 - Mobile App changes for Delivery Dispatch - multiple Release Line Items
25 Mar 2024 navhl20 ChangeRequest 62300: EUP | 53729 - Delivery Dispatch Screen - outstanding issues - 2
10 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work - 1
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wle  	: CM_WorkListEntry;
	woWle	: CM_WOWLE;
	wod		: CM_WorkOrderTIDtl;
	str		: String;
	ref		: String;
begin
	if self.myWODtl &lt;&gt; null then
		return self.myWODtl.getReference();
	endif;
	
	foreach wle in self.workListEntries discreteLock do		//06.03.2025 navma1 #MTN-34179
		woWle := wle.myWorkOrderWLE;
		if woWle &lt;&gt; null and woWle.job &lt;&gt; null and woWle.job.myWODtl &lt;&gt; null then
			wod := woWle.job.myWODtl;
			ref := wod.getReference;
			if str = null then
				str := str &amp; ref;
			elseif not str.cnContains(ref) then
				str := str &amp; Comma &amp; ref;
			endif;
		endif;
	endforeach;
	
	return str;
epilog
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
