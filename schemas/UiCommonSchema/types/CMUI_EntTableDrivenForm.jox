    <JadeMethod name="clearDetails" id="b71b9d37-d3d8-4798-86bb-a8a72a54f7c9">
        <updating/>
        <source>clearDetails() updating, protected;
/*
Purpose:			Clears all CMUI_FieldFrame controls
					Reimplement this method at your form level to clear any control in generic field frames,
					and to clear any local attributes and references

Parameters:			None

Return Value:		None

Date		Who		Reason
22 July 2009	cnwdap1	Initial creation
*/
vars
	frame 	: CMUI_FieldFrame;

begin
	foreach frame in self.allFieldFrames where frame.enabled do
		if frame.isKindOf(CMUI_FieldCheckBox) then
			frame.CMUI_FieldCheckBox.setValue(false);
		elseif frame.isKindOf(CMUI_FieldComboBox) then
			frame.CMUI_FieldComboBox.setForObject(null);
		elseif frame.isKindOf(CMUI_FieldDateBox) then
			frame.CMUI_FieldDateBox.setValue(null);
		elseif frame.isKindOf(CMUI_FieldGeneric) then
			frame.CMUI_FieldGeneric.doUpdateValue(null);
		elseif frame.isKindOf(CMUI_FieldTextBox) then
			frame.CMUI_FieldTextBox.setValue(null);
		elseif frame.isKindOf(CMUI_FieldTimeBox) then
			frame.CMUI_FieldTimeBox.setValue(null);
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAddExtraControls" id="c5843724-99b4-4875-af26-b3a173046017">
        <updating/>
        <source>doAddExtraControls(_entTableDef : EntTableDef; _cloneFrom : String; _captions : StringArray; _controlNames : StringArray) updating, protected;
/*
Purpose:			Build the allEntTableRows array from the existing Ent Table Def, and any
					entries for cloned controls

Parameters:			_entTableDef	The Ent Table Def that is being used on this form
					_cloneFrom		The name of the Ent Table Row that is to be cloned/repeated
					_captions		A string array of the captions to be used for the cloned/repeated
									controls (also defines how many cloned controls will be created)

Return Value:		self.allEntTableRows updated with existing and cloned rows, in the correct order

Date		Who		Reason
31/08/2010	cnwdap1	Initial creation CCMS SFW 1131 PAR #25596
*/
vars
	cargoType				: CM_CargoType;
	rowsBefore, rowsAfter	: ObjectArray;
	entRow, rowToCopy		: EntTableRow;
	entRowProxy				: EntTableRowProxy;
	before					: Boolean;
	nbrRequired, idx,
	subControlIdx			: Integer;
	control, clonedControl,
	existingControl			: Control;
	obj						: Object;
	subcontrols				: CnEcControlArray;
	subcontrol,
	clonedSubControl		: Control;

begin
	if _entTableDef = null then
		return;
	endif;
	
	// figure out where in the ent table def the control we're cloning is, so we can add it in the right place
	create rowsBefore transient;
	create rowsAfter transient;
	before := true;
	foreach entRow in _entTableDef.allEntTableRows do
		if entRow.name = _cloneFrom then
			before := false;
			continue;
		endif;
		if before then
			rowsBefore.add(entRow);
		else
			rowsAfter.add(entRow);
		endif;
	endforeach;
	
	// rowsBefore now contains all rows before the row to be cloned, rowsAfter contains all rows after the one to be cloned
	// load all prior controls in to allEntTableRows
	self.allEntTableRows.clear;
	foreach obj in rowsBefore do
		entRow := obj.EntTableRow;
		self.allEntTableRows.add(entRow);
	endforeach;
	
	//get the row to copy so we know its control name and edit details
	rowToCopy := _entTableDef.getEntTableRow(_cloneFrom);
	if rowToCopy &lt;&gt; null then
	
		// delete all existing cloned controls (for instance from a change in ent table def)
		foreach idx in self.controlCount to 1 step -1 do
			existingControl := self.controls(idx);
			if existingControl.index &gt; 0 then		// is a cloned control
				delete existingControl;
			endif;
		endforeach;
		self.cloneCount := null;
		
		// clone a control and create an ent row for each copy required
		nbrRequired := _captions.size;
		foreach idx in 1 to nbrRequired do
			self.getControlForEntDefRow(rowToCopy.controlName, control);
			// clone the control anew
			self.cloneCount := self.cloneCount + 1;
			clonedControl := control.loadControl(self.cloneCount);
			clonedControl.name := /*control.name[1:3] &amp; */_controlNames[idx];
			clonedControl.parent := control.parent;
	
			// create the ent table row with the appropriate caption from the array
			create entRowProxy transient;
			entRowProxy.setBasicDetails(_cloneFrom, _captions[idx], rowToCopy.inputType, rowToCopy.visible);
			entRowProxy.setControlName(clonedControl.name);
			entRowProxy.setEntTableCellControl(rowToCopy.myEntTableCellControl);
			
			// add the cloned ent row to the array of ent rows
			self.allEntTableRows.add(entRowProxy);
			// and add the control to the array of cloned controls
			self.allClonedControls.add(clonedControl);
		endforeach;
	endif;
	
	// finally, load all controls from the rowsAfter array in to self.allEntTableRows
	foreach obj in rowsAfter do
		entRow := obj.EntTableRow;
		self.allEntTableRows.add(entRow);
	endforeach;
	
epilog
	delete rowsAfter;			// PAR #27874
	delete rowsBefore;
	
end;</source>
        <access>protected</access>
        <Parameter name="_entTableDef" type="EntTableDef"/>
        <Parameter name="_cloneFrom" type="String"/>
        <Parameter name="_captions" type="StringArray"/>
        <Parameter name="_controlNames" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="doAlignControlsInGenericFrames" id="0ed8bcd0-91f4-4b2b-9a32-660ec8f73d0f">
        <updating/>
        <source>doAlignControlsInGenericFrames() updating, protected;
/*
Purpose:			Calls the doAlignCtrls event on each CMUI_FieldGeneric control, to align subcontrols
					doAlignCtrls event should be reimplemented on each CMUI_FieldGeneric control that has subcontrols

Parameters:			None

Return Value:		None

Date		Who		Reason
22 July 2009	cnwdap1	Initial creation
*/
vars
	frame 			: CMUI_FieldFrame;
	genericFrame	: CMUI_FieldGeneric;
	idx				: Integer;
	control			: Control;

begin
	foreach frame in self.allFieldFrames where frame.isKindOf(CMUI_FieldGeneric) do
		genericFrame := frame.CMUI_FieldGeneric;
		genericFrame.doAlignCtrls(genericFrame);
	endforeach;
	
	foreach idx in 1 to self.controlCount do
		control := self.controls(idx);
		if control.index &lt;&gt; null and CMUI_FieldGeneric.hasInstance(control) then
			control.CMUI_FieldGeneric.doAlignCtrls(control.CMUI_FieldGeneric);
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCancel" id="03b8ba85-fc33-4387-b245-baea2d4bc8fe">
        <updating/>
        <source>doCancel() : Boolean updating, protected;
/*
Purpose:			'Cancel' button click - checks form update and unloads form

Parameters:			None

Return Value:		None

Date		Who		Reason
22 July 2009	cnwdap1	Initial creation
*/
vars
	changedProperties	: PropertySet;
begin
	if self.checkHasChanged(changedProperties) then
		if app.msgBox(app.getErrorString(EditChangedAndClosing), app.getErrorString(MSGBOX_UnsavedChangesTitle), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			return false;
		endif;	
	endif;
	
	self.unloadForm;
	return true;
epilog
	delete changedProperties;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
