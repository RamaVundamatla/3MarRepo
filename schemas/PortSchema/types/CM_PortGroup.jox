<Class name="CM_PortGroup" id="49804d37-c377-4642-bd38-17a68e7a0903">
    <superclass name="CM_Group"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="allPorts" id="2d7b4546-91db-47b6-927b-7ff3c87efe45">
        <transientToPersistentAllowed/>
        <type name="CM_PortByCodeDict"/>
        <access>readonly</access>
        <text>Only man/auto for creating proxies - should be auto</text>
        <Inverse name="CM_Port::myPortGroup"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myRoot" id="cfb13dfd-280f-4a7b-835f-b19fdb5c6d4e">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Root"/>
        <access>readonly</access>
        <Inverse name="CM_Root::allPortGroups"/>
    </ExplicitInverseRef>
    <JadeMethod name="checkEntriesDict" id="c141b988-b748-4c1a-8987-435b6b9d7855">
        <source>checkEntriesDict();

vars
	port:CM_Port;
	object:Object;
begin
	if entries.size &lt;&gt; allPorts.size then
		app.writeStatement( "Port size mismatch by " &amp; (entries.size - allPorts.size).String);
	endif;
	foreach object in entries do
		port := object.CM_Port;
		if not allPorts.includes(port) then
			app.writeStatement("Port " &amp;  port.code &amp; " is not in old entries for " &amp; code &amp; ".");
		endif; 
	endforeach;
	foreach port in allPorts do
		if not entries.includes(port) then
			app.writeStatement( "Port " &amp;  port.code &amp; " is not in new entries for " &amp; code &amp; ".");
		endif; 
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="9d4aa926-2d8e-48f3-91c0-0fb8897f3790">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     19 April 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	txt		: String;
	tmpStr	: String;
	port  : CM_Port;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	foreach port in self.allPorts do
		if tmpStr = null then
			tmpStr := port.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; port.code;
		endif;
	endforeach;
	txt := txt &amp; 'Selected Ports' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	return txt;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="65e7e9c7-1fbb-4e16-9b9c-2681520c2247">
        <source>pxyCreateUpdateProxy(): SelfType;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 01 September 2003
//
//-----------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	portGroup	:	CM_PortGroup;
	completedOK		: Boolean;
begin
	portGroup := inheritMethod();
	
	self.allPorts.copy(portGroup.allPorts);
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return portGroup;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete portGroup;
	endif;	

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="9320b8e1-a770-49d4-9edb-362fbe1a4fab">
        <updating/>
        <source>setForCreate(pProxyPortGroup:CM_PortGroup) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	setForUpdate(pProxyPortGroup);
	self.myRoot := app.myRoot;

end;</source>
        <Parameter name="pProxyPortGroup" type="CM_PortGroup"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e8cfc874-be11-419c-8062-1505079b4690">
        <updating/>
        <source>setForUpdate(pProxyPortGroup:CM_PortGroup) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	port	:	CM_Port;
begin
	self.code := pProxyPortGroup.code.trimBlanks;
	self.description := pProxyPortGroup.description.trimBlanks;
	
	self.allPorts.clear;
	foreach port in pProxyPortGroup.allPorts do
		port.setMyPortGroup(self);
	endforeach;
	
	


end;</source>
        <Parameter name="pProxyPortGroup" type="CM_PortGroup"/>
    </JadeMethod>
    <JadeMethod name="setMyRoot" id="681c2927-39ec-4c46-8f38-dcbeefa1275d">
        <updating/>
        <source>setMyRoot() updating;
// ---------------------------------------------------------------------------
// Created:     04 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myRoot := app.myRoot;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="698edbaf-7a54-4e64-9ac9-f55ee6863afc">
        <updating/>
        <source>setProxy( pCode, pDescription : String;
		  pAllPorts			  : CM_PortByCodeDict ) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.code 			:= pCode[1:4];
	self.description 	:= pDescription[1:30];
	self.myRoot 		:= app.myRoot;
	
	self.allPorts.clear;
	pAllPorts.copy(self.allPorts);
	
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pAllPorts" type="CM_PortByCodeDict"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="db536913-8425-4547-806a-c8fc4ac3293c">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
vars
	propName	: String;

begin

	propName := _property.name;
	if propName = CM_Group::colour.name or
	   propName = CM_Group::reportGroupOrder.name or
	   propName = CM_Group::isAvailableForEntry.name then
		return false;
	endif;
	
	return inheritMethod(_rootClass, _property);
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="cc32fee5-6bcf-418f-acb5-ecd9242f2c42">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if app.myRoot.allPortGroups[code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code.String, null, null);
	endif;
	self.validateForUpdate;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="6de46184-a4d2-401b-bf6c-9a5b55a5c881">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.allPorts.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.code, "ports", null, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="b9f560df-4868-42a6-b019-e033e36c967c">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'PortGroup Code', null, null);
		app.raiseCMException(Input_required_field_prtGrpCde, null, null); // cnwdb2	PAR 35364
	endif;
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'PortGroup Description', null, null);
		app.raiseCMException(Input_required_field_prtGrpDes, null, null); // cnwdb2	PAR 35364
	endif;
end;</source>
    </JadeMethod>
</Class>
