    <JadeMethod name="valEDIDeckPlan" id="da109c1b-3f9f-4abc-b2b0-4fb66df84663">
        <source>valEDIDeckPlan(_ediData :CM_EDIDataDeckPlan; _passport :CM_Passport input);
/*
Date		Who		Reason
24 May 2012	cnwcs5	Initial creation - par 29583
// 30 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
*/
vars
	voyage		:CM_Voyage;
	voyageCode	:String;
	roro		:CM_ROROVoyageStructure;
	ediTI		:CM_EDITrackedItem;
	locationID	:String;
	theLayout 	:CM_EDILayoutTI;
	thePoint 	:CM_EDILayoutPointTI;
	idx			:Integer;
	checkRange 	:Real;
	roroDeck	:CM_DeckVoyage;
begin
	// GET VOYAGE
	voyage 		:= _ediData.getVoyage;
	voyageCode	:= _ediData.getVoyageCode;
	
	if voyage = null then
		app.raiseCMException1(Voyage_code_invalid, voyageCode, null, _ediData);
		return;
	endif;
		
		/* PAR 33644 REMOVED not needed
	if voyage.isNonWorkedVoyage and //24 Apr 2012	cnwrs1	Par 29476 //27 Apr 2012 cnwrs1 par 29502
	   not voyage.isNonPlannedVoyage then
	else
		app.raiseCMException1(Voyage_must_have_worked_planed, voyageCode, null, _ediData);
	endif;
	*/

	roro := voyage.myROROStructure;
	
	if roro = null then
		app.raiseCMException1(Voyage_code_invalid, voyageCode, null, _ediData);
		return;
	endif;
	
	// ### VALIDATE
	
	// The deck ID is at the start of the location id, check that the deck exists
	foreach ediTI in _ediData.allEDITrackedItems  discreteLock  do
		locationID := null;
		if ediTI.isKindOf(CM_EDICargoOnShipTI) then
			locationID := ediTI.CM_EDICargoOnShipTI.locationId;
		elseif ediTI.isKindOf(CM_EDILayoutTI) then
			theLayout := ediTI.CM_EDILayoutTI;
			if theLayout.layoutId.trimBlanks() = "" then
				app.raiseCMException(Layout_must_have,  null, ediTI);
				continue;
			endif;
			locationID := ediTI.CM_EDILayoutTI.layoutId;
		elseif ediTI.isKindOf(CM_EDILayoutPointTI) then
			thePoint := ediTI.CM_EDILayoutPointTI;
			idx := idx + 1;
			if thePoint.layoutId.trimBlanks() = "" then
				app.raiseCMException1(Layout_must_have, idx.String, null, ediTI);
				continue;
			endif;

			// ## Check if the X Y are within our range	
			checkRange := ((ROROStructureRearLine /ROROStructurePixelsPerMetre) * -1); // -20M
			if thePoint.longPos &lt; checkRange then
				app.raiseCMException4(Position_side_range, "X", thePoint.longPos.String, thePoint.layoutId, checkRange.String, null, ediTI);
			endif;
			checkRange :=  ((ROROStructureCentreLine /ROROStructurePixelsPerMetre) * -1); // -30M
			if thePoint.transPos &lt; checkRange then
				app.raiseCMException4(Position_side_range, "Y", thePoint.transPos.String, thePoint.layoutId, checkRange.String, null, ediTI);
			endif;
			checkRange :=  ((3000 /ROROStructurePixelsPerMetre) - (ROROStructureRearLine /ROROStructurePixelsPerMetre) ); // 280M
			if thePoint.longPos &gt; checkRange then
				app.raiseCMException4(Position_side_range, "X", thePoint.longPos.String, thePoint.layoutId, checkRange.String, null, ediTI);
			endif;
			checkRange :=  ((1500 /ROROStructurePixelsPerMetre) - (ROROStructureCentreLine /ROROStructurePixelsPerMetre) ); // 120M
			if thePoint.transPos &gt; checkRange then
				app.raiseCMException4(Position_side_range, "Y", thePoint.transPos.String, thePoint.layoutId, checkRange.String, null, ediTI);
			endif;
			locationID := ediTI.CM_EDILayoutPointTI.layoutId;
		elseif ediTI.isKindOf(CM_EDIVoyageHeaderTI) or
			ediTI.isKindOf(CM_EDISealTI) then
			continue;
		endif;
			
		roroDeck := roro.getDeckFromLocationString(locationID).CM_DeckVoyage;
		
		if roroDeck = null then
			app.raiseCMException1(Valid_deck_code_could_not_deri, locationID, null, ediTI);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_ediData" type="CM_EDIDataDeckPlan"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valEDIDeckStowageAdvice" id="48a82a15-117b-4e4a-be25-9f5821501386">
        <updating/>
        <source>valEDIDeckStowageAdvice(_validateOnly : Boolean; _ediData : CM_EDIDataDeckStowageAdvice input;  _passport : CM_Passport input) updating;
/*
Date		Who		Reason
09 Aug 2012	cnwcs5	Initial creation - CCMS MES 2168 / par 29124
					Code moved from trx method so that exception handling will work
25/02/2013	cnwmh5	#31192 - Add checking of hazard codes
*/
vars
	ediTI			: CM_EDITrackedItem;
	voyageCode, locationID 		: String;
	voyage			: CM_Voyage;
	roro 			: CM_ROROVoyageStructure;
	roroLC 			: CM_LocationsController;
	foundHeight, idx 	: Integer;
	roroDeck 		: CM_DeckVoyage;
	thePoint 		: CM_EDILayoutPointTI;
	checkRange 		: Real;
	theLayout 		: CM_EDILayoutTI;
	terminal		: CM_Terminal;	// par 29124 Aug 2012
	hazardCode		: String;				// 26/02/2013 cnwmh5 #31192
begin
	// GET VOYAGE
	foreach ediTI in _ediData.allEDITrackedItems  discreteLock where ediTI.isKindOf(CM_EDIVoyageHeaderTI) do
		voyageCode 	:= ediTI.CM_EDIVoyageHeaderTI.getVoyageCode();
		voyage 		:= _ediData.getMyTerminal().allVoyagesByCode.getAtKeyGeq(voyageCode,null );
		break; // should only be 1 voyage line
	endforeach;
	
	if voyage = null then
		app.raiseCMException1(Voyage_code_invalid, voyageCode, null, _ediData);
		return;
	endif;
	
	if voyage.code &lt;&gt; voyageCode then
		app.raiseCMException1(Voyage_code_invalid, voyageCode, null, _ediData);
	endif;
	
	
	terminal := _ediData.getMyTerminal();
	//epr par 37090 CCMS 2538 29/10/15
	if  terminal.getConfig(EdiAddVoyageDepartError).Boolean and voyage.hasDeparted  then
		app.raiseCMException1(Voyage_departed,voyageCode,"Voyage Code", self);
	endif;
	
	roro := voyage.myROROStructure;
	
	if roro = null then
		return;
	endif;
	
	// The deck ID is at the start of the location id, check that the deck exists
	foreach ediTI in _ediData.allEDITrackedItems  discreteLock  do
		locationID := "";
		
		if ediTI.isKindOf(CM_EDIStowAdviceTI) then
			locationID := ediTI.CM_EDIStowAdviceTI.stowageId;
			
			foreach hazardCode in ediTI.CM_EDIStowAdviceTI.imCodes do					// 25/02/2013 cnwmh5 #31192
				if app.myRoot.allHazardClasses[hazardCode] = null then
					app.raiseCMException1(ERR_INVALID_HAZARD, "(" &amp; hazardCode &amp; ").", 'hazard', _ediData);
				endif;
			endforeach;
			
		elseif ediTI.isKindOf(CM_EDILayoutTI) then
			locationID := ediTI.CM_EDILayoutTI.layoutId.trimBlanks;
			
			if locationID = "" then
				app.raiseCMException(Voyage_code_must_specifi,  null, ediTI);
			endif;
		
		elseif ediTI.isKindOf(CM_EDILayoutPointTI) then
			locationID := ediTI.CM_EDILayoutPointTI.layoutId;
			
		elseif ediTI.isKindOf(CM_EDIVoyageHeaderTI) then
			continue;
		endif;
		// par 29124 -- if existing location no need to validate deck
		terminal.findLocationFromString(voyage.code &amp; ' ' &amp; locationID,true, roroLC, foundHeight);
		
		if roroLC &lt;&gt; null then
			// must be valid
			continue;
		endif;
		
		roroDeck := roro.getDeckFromLocationString(locationID).CM_DeckVoyage;
		
		if roroDeck = null then
			app.raiseCMException1(Valid_deck_code_could_not_deri, locationID,  null, ediTI);
		endif;
	endforeach;
			
	foreach ediTI in _ediData.allEDITrackedItems  discreteLock where ediTI.isKindOf(CM_EDILayoutPointTI) do
		thePoint	:= ediTI.CM_EDILayoutPointTI;
		idx 		:= idx + 1;
		
		if thePoint.layoutId.trimBlanks() = "" then
			app.raiseCMException1(Layout_must_have, idx.String, null, ediTI);
		endif;
		
		// ## Check if the X Y are within our range
		checkRange := ((ROROStructureRearLine /ROROStructurePixelsPerMetre) * -1); // -20M
		
		if thePoint.longPos &lt; checkRange then
			app.raiseCMException4(Position_side_range, "X", thePoint.longPos.String, theLayout.layoutId, checkRange.String, null, ediTI);
		endif;
		
		checkRange :=  ((ROROStructureCentreLine /ROROStructurePixelsPerMetre) * -1); // -30M
		
		if thePoint.transPos &lt; checkRange then
			app.raiseCMException4(Position_side_range, "Y", thePoint.transPos.String, theLayout.layoutId, checkRange.String, null, ediTI);
		endif;
		
		checkRange :=  ((3000 /ROROStructurePixelsPerMetre) - (ROROStructureRearLine /ROROStructurePixelsPerMetre) ); // 280M
		
		if thePoint.longPos &gt; checkRange then
			app.raiseCMException4(Position_side_range, "X", thePoint.longPos.String, theLayout.layoutId, checkRange.String, null, ediTI);
		endif;
		
		checkRange :=  ((1500 /ROROStructurePixelsPerMetre) - (ROROStructureCentreLine /ROROStructurePixelsPerMetre) ); // 120M
		
		if thePoint.transPos &gt; checkRange then
			app.raiseCMException4(Position_side_range, "Y", thePoint.transPos.String, theLayout.layoutId, checkRange.String, null, ediTI);
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_ediData" type="CM_EDIDataDeckStowageAdvice" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valEDIFileExtract" id="182803dd-fd30-4da3-aa7b-4820381a68eb">
        <source>valEDIFileExtract(_ediFileType	: CM_EDIFileType; _fileName: String; _status: Integer; _passport : CM_Passport input);
//
//16 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//
vars
	file	: File;
begin

	
//	if _ediFileType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'EDIFileType', null, null);
//rs		app.raiseCMException(Input_required_field_ediFleTyp, null, null); // cnwdb2	PAR 35364
//	endif;

	//if _fileName = null then
	if _fileName = null and _status = CM_EDIFile.EDI_STATUS_EXTRACTED then	//06 Jan 2016	NDL	Par 37212
	//	app.raiseCMException1(REQUIRED_FIELD, 'extract file name', null, null);
		app.raiseCMException(Input_required_field_extrctFle, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
//rs	if (not app.myRoot.canDoEDIFileType(_ediFileType.type)) then
//rs		app.raiseCMException1(NotLicensedToPerformAction, 'Create EDI File Type ' &amp; _ediFileType.name, null, null);
//rs		return;	
//rs	endif;
	
	if _status = CM_EDIFile.EDI_STATUS_EXTRACTED then
		create file transient;
		file.kind := File.Kind_Unknown_Text;	// 26/2/16 cnwmp6 PAR 36286 unicode version
		file.fileName := _fileName;
		file.mode := File.Mode_Input;
		if file.isAvailable then
			app.raiseCMWarning3(ItemAlreadyExists, 'extract file', 'file', 'in existence.  OK to overwrite?',null, null,_ediFileType);
		endif;
	endif;
	
epilog
	delete file;	
end;</source>
        <Parameter name="_ediFileType" type="CM_EDIFileType"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
