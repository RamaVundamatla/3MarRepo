    <JadeMethod name="loadChildFields" id="e7ce558a-6d5e-49ae-841f-7a1472b73f61">
        <source>loadChildFields(_child: CM_Object);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	deckItemRamp : CM_RORORamp; 
	machinery : CM_ROROEquipment;
	genItem : CM_ROROGeneralArea;
begin
	
	if _child.isKindOf(CM_RORORamp) then
		deckItemRamp:=_child.CM_RORORamp;
		
		self.txtCode.text:=deckItemRamp.code;
		self.txtDescription.text:=deckItemRamp.description;
		self.txtRemarks.text:=deckItemRamp.remarks;
	
		self.txtClearHeight.text:=deckItemRamp.maxClearHeight.asStringJMT();
		self.txtLength.text:=deckItemRamp.length.asStringJMT();
		self.txtMaxTotalWeigh.text:=deckItemRamp.maxLoadTotal.asStringJMT();
		self.txtMaxAxelWeight.text:=deckItemRamp.maxLoadAxel.asStringJMT();
		self.txtMaxLoadM2.text:=deckItemRamp.maxLoadM2.asStringJMT();
		self.txtWidth.text:=deckItemRamp.width.asStringJMT();
		self.chkIsMovable.value:=deckItemRamp.isMovable;
	
		self.cmbType.setIndexForItemData(deckItemRamp.typeInteger);
		//self.setupTextBoxes(true);
	elseif _child.isKindOf(CM_ROROEquipment) then
		machinery := _child.CM_ROROEquipment;
		self.txtCode.text:=machinery.code;
		self.txtDescription.text:=machinery.description;
		self.txtRemarks.text:=machinery.remarks;
		
		self.txtMaxTotalWeigh.text:=machinery.weight.asStringJMT();
		self.cmbType.setIndexForItemData(machinery.typeInteger);
		//self.setupTextBoxes(false);
	else
		genItem := _child.CM_ROROGeneralArea;
		self.txtCode.text:=genItem.code;
		self.txtDescription.text:=genItem.description;
		self.txtRemarks.text:=genItem.remarks;
		
		self.txtMaxTotalWeigh.text:=genItem.weight.asStringJMT();
		self.cmbType.setIndexForItemData(genItem.typeInteger);
		//self.setupTextBoxes(false);
	endif;
	
	


	
epilog

end;</source>
        <Parameter name="_child" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="loadParentCombo" id="b04e5ce8-199c-4fe6-9a94-bc83bba18006">
        <source>loadParentCombo(_parent : CM_Object) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	roroStructure : CM_Object;
begin

	roroStructure:=_parent.CM_Deck.getROROStructure();
	

	self.myAssistant.comboBoxRORODecks(self.cmbParent,roroStructure,null);

	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_parent" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="76450657-77b3-4e15-855f-6c3b15a319fd">
        <updating/>
        <source>setProxy() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	code,
	description,
	remarks  :String;
	isMovable : Boolean;
	length,
	maxClearHeight,
	maxLoadAxel ,
	maxLoadM2,
	maxLoadTotal ,	
	width : Decimal[12,2];
	proxyDeckItem : CM_DeckItem;
	type : Integer;
begin
	if self.mode = self.Mode_New then
		if self.cmbType.listIndex &lt; 0 then
			app.msgBox(app.getErrorString(Select_deck_item_type_create),app.getErrorString(Error),MsgBox_OK_Only);
			//raise msg box must select a type 
			return;
		endif;
			
		type:= self.cmbType.itemData[self.cmbType.listIndex];
			
		if type = DeckItem_Lift then
			create self.myProxyChild as CM_ROROLift transient;
		elseif type = DeckItem_Machinery then
			create self.myProxyChild as CM_ROROEquipment transient;
		elseif type = DeckItem_General_Items then
			create self.myProxyChild as CM_ROROGeneralArea transient;
		elseif type = DeckItem_Internal_Ramp then
			create self.myProxyChild as CM_RORORampInternal transient;
		endif;
	endif;
	
	proxyDeckItem:=self.myProxyChild.CM_DeckItem;
	
	code:=self.txtCode.text;
	description:=self.txtDescription.text;
	remarks:=self.txtRemarks.text;
	isMovable:=self.chkIsMovable.value;
	length:=self.txtLength.text.asDecimalJMT();
	width:=self.txtWidth.text.asDecimalJMT();
	maxClearHeight:=self.txtClearHeight.text.asDecimalJMT();
	maxLoadAxel:=self.txtMaxAxelWeight.text.asDecimalJMT();
	maxLoadM2:=self.txtMaxLoadM2.text.asDecimalJMT();
	maxLoadTotal:=self.txtMaxTotalWeigh.text.asDecimalJMT();
	 
	
	proxyDeckItem.setProxyDeckItem(code,description,remarks,self.myParent.CM_Deck,null);
	if proxyDeckItem.isRamp() then
		proxyDeckItem.CM_RORORamp.setProxyRamp(isMovable,length,maxClearHeight,maxLoadAxel,maxLoadM2,maxLoadTotal,width);
	elseif proxyDeckItem.isMachinery() then
		proxyDeckItem.CM_ROROEquipment.setProxyMachinery(maxLoadTotal);
	else
		proxyDeckItem.CM_ROROGeneralArea.setProxyGeneralItems(maxLoadTotal);
	endif;
		

	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b7821829-f6be-474e-ba51-8be09a36cb8c">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	inheritMethod();

	self.lblChild.caption:=app.getErrorString(Deck) &amp; " " &amp; app.getErrorString(Item);
	self.lblParent.caption:=app.getErrorString(Deck);
	
	self.btnDeleteChild.bubbleHelp := app.getErrorString(Delete).cnEcFirstToUpper &amp; " " &amp; app.getErrorString(Deck) &amp; " " &amp; app.getErrorString(Item);
	self.btnEditChild.bubbleHelp := app.getErrorString(Edit) &amp; " " &amp; app.getErrorString(Deck) &amp; " " &amp; app.getErrorString(Item);
	self.btnNewChild.bubbleHelp := app.getErrorString(New) &amp; " " &amp; app.getErrorString(Deck) &amp; " " &amp; app.getErrorString(Item);
	

	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupTextBoxes" id="41816bab-ba88-43fd-8c2c-5e4ea7a2ff77">
        <source>setupTextBoxes(_switch,_show : Boolean);
/*
Date		    Who			Reason
16 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	widthTop,
	lengthTop,
	remarksTop,
	totalWeightTop : Real;
	show : Boolean;
begin
	
	widthTop := self.txtWidth.top;
	totalWeightTop := self.txtMaxTotalWeigh.top;
	lengthTop := self.txtLength.top;
	remarksTop := self.txtRemarks.top;
	
	show := _show;
	if not _switch and self.myCurrentChild &lt;&gt; null then		//for when opening the form in edit mode,with a "loaded" current child
		if self.myCurrentChild.isKindOf(CM_ROROEquipment) or self.myCurrentChild.isKindOf(CM_ROROGeneralArea) then			
			show := false;
		else			
			show := true;
		endif;
	endif;
	if _switch or not show then						//if we select a different deck item type in the combobox, or for when we just need to hide the fields from the beginning
		self.txtMaxTotalWeigh.top := widthTop;
		self.lblMaxLoadWeight.top := widthTop;
		self.txtRemarks.top := lengthTop;
		self.lblRemarks.top := lengthTop;
		self.txtLength.top := remarksTop;
		self.lblLength.top := remarksTop;
		self.txtWidth.top := totalWeightTop;
		self.lblWidth.top := totalWeightTop;
	endif;
	if show then
		self.lblMaxLoadWeight.caption := app.getErrorString(Max_Total_Weight_Kg);
	else
		self.lblMaxLoadWeight.caption := app.getErrorString(Label_Weight_Kg);
	endif;		
	
	self.txtLength.visible := show;
	self.lblLength.visible := show;
	
	self.txtWidth.visible := show;
	self.lblWidth.visible := show;	
		
	self.lblClearHeight.visible := show;
	self.txtClearHeight.visible := show;
	self.lblMaxAxelWeight.visible := show;
	self.txtMaxAxelWeight.visible:= show;
	self.lblMaxLoadM2.visible := show;
	self.txtMaxLoadM2.visible := show;
	self.chkIsMovable.visible := show;
	self.lblIsMovable.visible := show;
	
epilog

end;</source>
        <Parameter name="_switch" type="Boolean"/>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="1ca5f3d6-bd45-4a30-80d6-afd1c1d25755">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 August 2018 15:39:10.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022915, locale);
	lblClearHeight.translateCaption(Xlat_0015460, locale);
	lblCode.translateCaption(Xlat_0015461, locale);
	lblDescription.translateCaption(Xlat_0015462, locale);
	lblIsMovable.translateCaption(Xlat_0015463, locale);
	lblLength.translateCaption(Xlat_0016558, locale);
	lblMaxAxelWeight.translateCaption(Xlat_0016559, locale);
	lblMaxLoadM2.translateCaption(Xlat_0016560, locale);
	lblMaxLoadWeight.translateCaption(Xlat_0015466, locale);
	lblRemarks.translateCaption(Xlat_0015468, locale);
	lblType.translateCaption(Xlat_0015469, locale);
	lblWidth.translateCaption(Xlat_0016562, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="d1d7c4a8-357b-48bb-99fb-6329f84e7ad2">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*
Date		    Who			Reason
06 May 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

begin
		
	if self.myCurrentChild &lt;&gt; null then
		if self.myCurrentChild.isTransient() then
			delete self.myCurrentChild;
		endif;
	endif;	
	
	if self.myParent &lt;&gt; null then
		if self.myParent.isTransient() then
			delete self.myParent;
		endif;
	endif;	
	
	if self.myProxyChild &lt;&gt; null then
		if self.myProxyChild.isTransient() then
			delete self.myProxyChild;
		endif;
	endif;	
	
	inheritMethod();
	
epilog

end;</source>
    </JadeMethod>
</GUIClass>
