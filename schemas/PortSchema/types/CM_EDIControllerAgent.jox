    <JadeMethod name="displayStatus" id="c6edf9d5-cac6-4184-b8c3-be56bd4344cc">
        <source>displayStatus(_status : Integer) : String;

/*
Purpose:	To have one common place for the return of a translated string for the EDI system.
			Also put the more common ones first.
			As at 30/03/2010 have from -5 throught to 20 inclusive.

Changes

Date		Name	TFS#		Description
============================================================================
30 Mar 2010	cnwrl1	Initial creation as part of PAR 23432 - Consolidate the EDI Status messages
31/05/2012	cnwcs5	CCMS SFW 1284 - remove unused statuses
18 Jul 2013	cnwrs1	Par 31150 EDI Pack not restarting after lock error
25/07/0213	cnwcs5	CCMS POL 2221 / par 32094 - FIX UP STATII
16 Jan 2014	cnwrs1	par 33309 - looks like the EDI Status DBLoading has run its course and needs to be removed
10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP
============================================================================*/

begin
	if _status = CM_EDIFile.EDI_STATUS_UNPROCESSED then					// ie 0
		return app.getString(Un_processed);
	elseif _status = CM_EDIFile.EDI_STATUS_LOADED then					// ie 1
		return app.getString(Loaded);
	elseif _status = CM_EDIFile.EDI_STATUS_LOADED_ERRORS then			// ie 2
		return app.getString(Load_failed);
	elseif _status = CM_EDIFile.EDI_STATUS_VERIFIED then				// ie 3
		return app.getString(Verified);
	elseif _status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS then			// ie 4
		return app.getString(Verify_errors);
	elseif _status = CM_EDIFile.EDI_STATUS_DBLOADED then					// ie 5
		return app.getString(DB_Loaded);
	elseif _status = CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS then			// ie 6
		return app.getString(DB_Load_failed);
	elseif _status = CM_EDIFile.EDI_STATUS_RELOAD_ERRORS then			// ie 7
		return app.getString(Re_Load_failed);
	elseif _status = CM_EDIFile.EDI_STATUS_LOADING then					// ie 8
		return app.getString(Loading);
	elseif _status = CM_EDIFile.EDI_STATUS_VERIFYING then				// ie 9
		return app.getString(Verifying);
	elseif _status = CM_EDIFile.EDI_STATUS_DBLOADING then				// ie 10	//jlgka1 TFS 45332
		return app.getString(DB_Loading);											//jlgka1 TFS 45332
	elseif _status = CM_EDIFile.EDI_STATUS_RELOAD then					// ie 12
		return app.getString(Re_Load);
	elseif _status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then		// ie 14
		return app.getString(Verify_warnings);
	elseif _status = CM_EDIFile.EDI_STATUS_EXTRACTED then				// ie 15
		return app.getString(Extracted);
	elseif _status = CM_EDIFile.EDI_STATUS_MADE_ACTUAL then				// ie 16
		return app.getString(Made_Actual);
	elseif _status = CM_EDIFile.EDI_STATUS_INVALID then					// ie 17
		return app.getString(Deleted);
	elseif _status = CM_EDIFile.EDI_WEB_STATUS_QUEUED then				// ie 18
		return app.getString(Queued_Not_Processed_Yet);
	elseif _status = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then		// ie 19
		return app.getString(DB_Partially_loaded);
	elseif _status = CM_EDIFile.EDI_WEB_STATUS_QUEUED_FAILED then		// ie 20
		return app.getString(Queued_But_Failed_In_EDI_BGP);
	elseif _status = CM_EDIFile.EDI_STATUS_SKIP_PROCESSING then			// ie 21
		return app.getString(Will_not_beprocessed);
	elseif _status = CM_EDIFile.EDI_STATUS_LOCKERROR then				// ie 22
		return app.getString(Objects_locked);
	elseif _status = CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X then			// ie 23
		return app.getString(Verify_errors) &amp; '(*)';
	elseif _status = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X then		// ie 24
		return app.getString(DB_Partially_loaded) &amp; '(*)';
	elseif _status = CM_EDIFile.EDI_STATUS_FATAL_ERRORS then			// ie 25
		return app.getString(Fatal_errors);
	elseif _status = CM_EDIFile.EDI_WEB_STATUS_CREATION_ERROR then		// ie -1
		return app.getString(Failed_To_Create_EDIFile);
	elseif _status = CM_EDIFile.EDI_WEB_STATUS_INVALIDFILETYPE then		// ie -2
		return app.getString(Valid_MsgType_Must_Be_Supplied);
	elseif _status = CM_EDIFile.EDI_WEB_STATUS_NO_CLIENTREF then		// ie -3
		return app.getString(ClientRef_Must_Be_Supplied);
	elseif _status = CM_EDIFile.EDI_WEB_STATUS_DUPL_CLIENTREF then		// ie -4
		return app.getString(ClientRef_Already_Exists);
	elseif _status = CM_EDIFile.EDI_WEB_STATUS_EDIFILENOTFOUND then		// ie -5
		return app.getString(File_Not_Found);
	elseif _status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then		// ie 26
		return app.getString(Failed_ToProcess_EDIFile);
	elseif _status = CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE then		// ie 27
		return app.getString(Sequence_error);
	//START 07.10.2022	navsj20	TFS 55084
	elseif _status = CM_EDIFile.EDI_STATUS_CANCELLED then			// ie 29
		return app.getString(Cancelled);
	elseif _status = CM_EDIFile.EDI_STATUS_REVOKED then				// ie 30			
		return app.getString(Revoked);
	//END 07.10.2022  navsj20  TFS 55084
	elseif _status = CM_EDIFile.EDI_STATUS_QUEUED_FOR_BGP then		// ie 31		//05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP
		return app.getString(QueuedForBGP);
	elseif _status = CM_EDIFile.EDI_STATUS_AUTO_PAUSED then		// ie 32					//navra1 - MTN-33087 - 23rd Oct 2024
		return app.getString(Auto_voyag_paused);											//navra1 - MTN-33087 - 23rd Oct 2024
	endif;																					//navra1 - MTN-33087 - 23rd Oct 2024
end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doGeneralSearch" id="2e6bd5fb-d535-4ad5-a697-d38aa28b9a98">
        <updating/>
        <source>doGeneralSearch(_voyage: CM_Voyage; _search: Integer; _fileName: String; _operator: CM_Operator; _fileType: CM_EDIFileType):CM_EDIData updating;
//----------------------------------------------------------------
//	Created:	16 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ediData		: CM_EDIData;
	tiDict		: CM_TIByIdDict;
begin

	//do the search
	create tiDict transient;
	self.getTIs(_search, _voyage, _operator, tiDict);

//	app.myTrxCA.trxCreateEdiDataFromTIs(tiDict, ediData, self.myTerminal.myEdiConfig, _fileName, _fileType, app.myPassport);	// cnwrl1 10/08/2009 PAR 20318 - MES 1011 Web EDI Link - what it was
	app.myTrxCA.trxCreateEDIDataFromTIs(	tiDict,
											ediData,
											self.myTerminal.myEdiConfig,
											_fileName,
											_fileType,
											app.myPassport,
											self.ediClientRef,
											null,
											null );
	
epilog
	delete tiDict;
	return ediData;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_search" type="Integer"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_fileType" type="CM_EDIFileType"/>
        <ReturnType type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="doOutwardRailSearch" id="361187fd-3525-428e-92aa-6812fb3f2b52">
        <updating/>
        <source>doOutwardRailSearch( _voyage: CM_Voyage; _operator: CM_Operator; _tiDict: CM_TIByIdDict io) updating, protected;
//----------------------------------------------------------------
//	Created:	25 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	iter		: Iterator;
	dict		: CM_TITransactionByTypeDateDict;
	keyDate		: TimeStamp;
	tiTrans		: CM_TITransaction;
	nullVoyage  : CM_Voyage;
begin
	if self.myTerminal = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'expecting terminal to be set');
		return;
	endif;
	
	if _voyage &lt;&gt; null
	and _voyage.myTerminal &lt;&gt; null then
		nullVoyage := _voyage.myTerminal.getNullVoyage();
	endif;
	
	keyDate.setTime("0:00:00.000".Time);
	  
	dict := self.myTerminal.allTITransactionsByTypeDate;
	
	//get all rail released today
	iter := dict.createIterator();
	
	dict.startKeyGeq(TRANS_TYPE_REL_RAIL, keyDate, iter);

	while iter.next(tiTrans) do
		
		if tiTrans.type &gt; TRANS_TYPE_REL_RAIL
		or tiTrans.dateTime.date &lt;&gt; keyDate.date then
			break;
		endif;

		if tiTrans.myTrackedItem &lt;&gt; null
		and (_voyage = nullVoyage or _voyage = tiTrans.getVoyage())
		and (_operator = null or _operator.code = tiTrans.operatorCode) then
			_tiDict.add(tiTrans.myTrackedItem);
		endif;	
	
	endwhile;
	
epilog
	delete iter;		// PAR #26678
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_tiDict" type="CM_TIByIdDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doOutwardWagonSearch" id="e0101959-8a07-405f-a3ac-8b96c2f8cf60">
        <updating/>
        <source>doOutwardWagonSearch(_fileName: String; _operator: CM_Operator; _fileType: CM_EDIFileType) : CM_EDIData updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 05 October 2007
//
//----------------------------------------------------------------------

vars
	ediData : CM_EDIData;
	train : CM_Train;
	wagonDict : CM_WagonByIdDict;
begin
	create wagonDict transient;
	train := self.getTestTrain();
	
	self.getWagonsForTrain(train, wagonDict);
	
epilog
	delete wagonDict;
	return ediData;
end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_fileType" type="CM_EDIFileType"/>
        <ReturnType type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="emptyRecord" id="477c4292-6113-408a-ad9c-1b1c1cd43a8a">
        <source>emptyRecord(_record: String):Boolean;
//
//11 Jul 2014	cnwrs1	Par 34566 CCMS 2346 Suzano - Viagram Prenote file 
//
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
constants
	TIID_Length : Integer = 2;
vars
	strRec		: String;
begin
	strRec := _record.replaceString( CNEC_COMMA, null ).trimBlanks;
	
	if strRec = null or 					//no information
	(strRec.length &lt; TIID_Length) then		//not enough information
		return true;
	else
		return false;
	endif;
end;</source>
        <Parameter name="_record" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="extractFile" id="3b54b296-a2d9-4cde-b2b5-a1fbadcb1116">
        <source>extractFile(_ediFile: CM_EDIFile io; _messageNumber: Integer; _ediDataDetails: CMIF_EDIDataDetails);
//----------------------------------------------------------------
//	Created:	25 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
vars

begin
	app.myTrxCA.trxCreateEDIDiskFile(_ediFile, _messageNumber, _ediDataDetails, app.myPassport);
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_messageNumber" type="Integer"/>
        <Parameter name="_ediDataDetails" type="CMIF_EDIDataDetails"/>
    </JadeMethod>
    <JadeMethod name="findEDIFileType" id="37225606-59e4-4ea6-ae65-0b196f70b89f">
        <updating/>
        <source>findEDIFileType(_fileType:String; _version:String; _association:String; _ediFileType: CM_EDIFileType io; _ediDataType : Integer io) : Boolean updating;
//
//16 Apr 2012	cnwrs1	Par 29447 not finding EDI file Type for fixed length
//
//11 Jul 2014	cnwrs1	Par 34566 CCMS 2346 Suzano - Viagram Prenote file 
//12 Jul 2014	cnwrs1	Par 34702 - Add support for JMT XML
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//25 Jun 2015	cnwrs1	Par 33901/36027 - Default booking commodity
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS EDI
//19 May 2016	cnwdap1	TFS #1881 BAPLIE/EDI VGM Updates
//10 Jun 2016	cnwrs1	TFS 2150 - create alias for "JMTInternal"
//23 Aug 2016	cnwdap1	TFS #2566 AAT EDI IFCSUM
// 27 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 4
//7  Mar 2023	navra1	TFS 56793 PRP - Suzano EDI - Shipment Download
//08 Mar 2023 	navsp1  TFS ChangeRequest 56795: PRP - Suzano EDI - Release Order
//27 Mar 2023	jlika1	TFS 57276 POB | QShips - Manual Load of XML EDI File.
//29 Jun 2023	navdap1	TFS 58923 EUP - CallOff EDI Data Type / EDI Load
//14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
// 25 Sep 2023 	jlirs1	TFS 59170 Port Authority Config
//23 Jul 2024   navsp1  TFS ChangeRequest 63842: NSW | OnePort Integration Dev
vars
	aFileFormat,
	aFileType	: Integer;
	fileFormat	: CM_FileFormatEDI;
	cls : Class;
	intArray : IntegerArray;
begin

	if _fileType = "BAPLIE" then
		if _version = EDIFileVersion_910 then
			aFileType := EDIFileType_Baplie14;
		elseif _version = EDIFileVersion_911 then
			aFileType := EDIFileType_Baplie15;
		elseif _version = EDIFileVersion_95B then
			if _association = "SMDG22" then						// TFS #1881
				aFileType := EDIFileType_Baplie22;				// TFS #1881
			else												// TFS #1881
				aFileType := EDIFileType_Baplie20;
			endif;												// TFS #1881
		elseif _version = EDIFileVersion_921 then
			aFileType := EDIFileType_Baplie10;
		else
			aFileType := null;
		endif;
	elseif _fileType = "CUSCAR" then
		aFileType := EDIFileType_CusCar;
	elseif _fileType = "CUSRES" then
		aFileType := EDIFileType_CusRes;
	elseif _fileType = "COREOR" then
		aFileType := EDIFileType_Coreor;
	elseif _fileType = "COPRAR" then
		aFileType := EDIFileType_Coprar;
	elseif _fileType = "BAYFILE" then
		aFileType := EDIFileType_BayFile;
	elseif _fileType = "IFTMCS" then
		if _version = EDIFileVersion_03A then
			aFileType := EDIFileType_IFTMCS03A;
		endif;
	elseif _fileType = "IFTMBC" then
		if _version = EDIFileVersion_96B then
			aFileType := EDIFileType_IFTMBC96B;
//		elseif _version = EDIFileVersion_03A then
//			aFileType := EDIFileType_IFTMCS03A;
		elseif _version = EDIFileVersion_98B then
			if _association = "PONL" then
				aFileType := EDIFileType_IFTMBCPonl98B;
			else
				aFileType := EDIFileType_IFTMBC98B;
			endif;
		elseif _version = EDIFileVersion_99B then
			if _association = "PONL" then
				aFileType := EDIFileType_IFTMBCPonl99B;
			else
				aFileType := EDIFileType_IFTMBC99B;
			endif;
		endif;
	elseif _fileType = "IFTMIN" then				// cnwrl1 23/04/2009 PAR 19510 - CCMS 1812
		aFileType := EDIFileType_IFTMIN;
	elseif _fileType = "COPARN" then
		aFileType := EDIFileType_Coparn;
	elseif _fileType = "COPINO" then
		aFileType := EDIFileType_Copino;
	elseif _fileType = "MOVINS" then
		aFileType := EDIFileType_Movins;
	elseif _fileType = "VSLSTOW" then
		aFileType := EDIFileType_VSLStow;
	elseif _fileType = "VERMAS" then
		aFileType := EDIFileType_Vermas;
	elseif _fileType = "WWL" then //gdansk car dec 2007 cnwrs1
		aFileType := EDIFileType_WWLCar;
	elseif _fileType = "ANF" then
		aFileType := EDIFileType_Anf;
	elseif _fileType[1:3] = "CSV" then
		if _version = EDIFileVersion_CSV then
			aFileType := EDIFileType_CSV;
		elseif _version = EDIFileVersion_CSVPONLoad then
			aFileType := EDIFileType_CSVPONLoad;
		elseif _version = EDIFileVersion_CSVMSKLoad then
			aFileType := EDIFileType_CSVMSKLoad;
		elseif _version = EDIFileVersion_CSVMSCLoad then
			aFileType := EDIFileType_CSVMSCLoad;
		endif;
	elseif _fileType[1:3] = "XML" then
		if _version = EDIFileVersion_XML then
			aFileType := EDIFileType_XML;
		elseif _version = EDIFileVersion_TollNZAdvNot then
			aFileType := EDIFileType_XML;
			aFileFormat := TollNZAdvNot;
		elseif _version = EDIFileVersion_FonterraPack then //ccms 1976 cnwrs1 10 dec 2010
			aFileType := EDIFileType_XML;
			aFileFormat := FonterraPack;
		elseif _version = EDIFileVersion_Celina then //gdansk car dec 2007 cnwrs1
			aFileType := EDIFileType_XML_Polish_Customs;
		elseif _version = EDIFileVersion_SuzanoPrenote then 
			aFileType := EDIFileType_XMLSuzanoPrenotes;
		elseif _version = EDIFileVersion_SuzanoRelease then 
			aFileType := EDIFileType_XMLSuzanoRelease;
		elseif _version = EDIFileVersion_SuzanoManifest then 
			aFileType := EDIFileType_XMLSuzanoManifest;
		elseif _version = EDIFileVersion_Milaha_Customs then //29 Jun 2015	NDL	Par 36543
			aFileType := EDIFileType_XML_Milaha_Customs;
		elseif _version = EDIFileVersion_CargoGrpAssign then //31 Jul 2015	NDL	Par 36608
			aFileType := EDIFileType_XML_CargoGrpAssign;
		elseif _version = EDIFileVersion_MultiMoveGroup then //16 Sep 2015	NDL	Par 36906
			aFileType := EDIFileType_XML_MultiMoveGrp;
		elseif _version = EDIFileVersion_OneStop then	//01 Sep 2016	NDL	TFS 2276 / 2565
			aFileType := EDIFileType_XMLOneStopPre;
		elseif _version = EDIFileVersion_OneStopCust then //03 Oct 2016	NDL	TFS 2718 / 2536
			aFileType := EDIFileType_XMLOneStopCust;
		elseif _version = EDIFileVersion_OneStopEIDO then //03 Oct 2016	NDL	TFS 2718 / 2536
			aFileType := EDIFileType_XMLOneStopEIDO;
		elseif _version = EDIFileVersion_XMLQShipsVoyage then 
			aFileType := EDIFileType_XMLQShipsVoyage;
		endif;
	//US ANSI EDI Formats
	elseif _fileType = "X12_301" then
		if _version = EDIFileVersion_X123014010 then
			aFileType := EDIFileTypeX12_301_4010;
		endif;
	elseif _fileType = "X12_309" then
		if _version = EDIFileVersion_X123094010 then
			aFileType := EDIFileTypeX12_309_4010;
		endif;
	elseif _fileType = "X12_315" then
		if _version = EDIFileVersion_X123154010 then
			aFileType := EDIFileTypeX12_315_4010;
		endif;
	elseif _fileType = "X12_322" then
		if _version = EDIFileVersion_X123224010 then
			aFileType := EDIFileTypeX12_322_4010;
		endif;
	elseif _fileType = "X12_350" then
		if _version = EDIFileVersion_X123504010 then
			aFileType := EDIFileTypeX12_350_4010;
		endif;
	//cnwmc5 - 9 July 2014 - CCMS 2353 PEN
	elseif _fileType = "CAMIR" then
		aFileType := EDIFileTypeCAMIR_CustomsStatus;
	elseif _version = EDIFileVersion_JMTInternal then
		cls := currentSchema.getClass("CM_EDIData"&amp;_fileType).Class;
		if cls &lt;&gt; null then
			create intArray transient;
			self.myTerminal.myEdiConfig.getDataTypeFromClass(cls, intArray);
			aFileType := EDIFileType_JMTInternal; //intArray[1];
			_ediDataType := intArray[1];
		endif;
		
	elseif _fileType = "IFCSUM" then						// TFS #2566
		if _version = EDIFileVersion_94B or _version = EDIFileVersion_98B then				// TFS #2566
			if self.myTerminal.getConfig(ProcIFCSUMPortAuthority).Boolean then		// 25 Sep 2023 	jlirs1	TFS 59170 Port Authority Config
				aFileType := EDIFileType_IFCSUMAUBNE94B;
			else
				aFileType := EDIFileType_IFCSUM94B;				// TFS #2566
			endif;
		endif;												// TFS #2566
	
	//08Mar2023 navsp1 TFS 56795
	elseif _fileType = "Suzano Release" then
		if _version = EDIFileVersion_SuzanoRelease then
			aFileType	:= EDIFileType_SuzanoReleaseOrder;
		endif;
		
	elseif _fileType = "Suzano Manifest" then					//navra1 - TFS 56793 - 7th Mar 2023 
		if _version = EDIFileVersion_SuzanoManifest then 		//navra1 - TFS 56793 - 7th Mar 2023 
			aFileType := EDIFileType_SuzanoManifest;			//navra1 - TFS 56793 - 7th Mar 2023 		
		endif;
	elseif _fileType = "Transport Manifest" then				//05.Jun.2023 navsp1 TFS 58054
		aFileType := EDIFileType_TransportManifest;
	elseif _fileType = "CallOff" then					// TFS 58923
		aFileType := EDIFileType_CallOff;				// TFS 58923
	elseif _fileType = "OnePort Voyage" then			//TFS 63842
		aFileType	:= EDIFileType_JSONOnePortVoyage;	//TFS 63842
	else
		aFileType := null;
		return false;	//16 Apr 2012	cnwrs1	Par 29447 not finding EDI file Type for fixed length
	endif;
	
	//02 July 2020	NDL	TFS 49485
	if _fileType &lt;&gt; null and aFileType = null then
		//we were passed one of the special types above, that has multiple versions
		//but the 'aFileType' failed to be set from the matching '_version' parameter so bail
		return false;
	endif;

	_ediFileType := app.myRoot.allEDIFileTypes.getAtKeyGeq(aFileType, null);
	
	if _ediFileType = null or _ediFileType.type &lt;&gt; aFileType then
		return false;
	endif;
	
	self.setCurrentFileFormat(null, null); //Par13295 cnwrs1 Jan 2007 
	// in case it dosnt need to be set for the next file 
	//any formats?
	foreach fileFormat in _ediFileType.allFormats do
		if fileFormat.sequenceNumber = aFileFormat then
			self.setCurrentFileFormat(fileFormat, fileFormat.myOperator);
		endif;
	endforeach;
	
	return _ediFileType &lt;&gt; null;
epilog
	delete intArray;
end;</source>
        <Parameter name="_fileType" type="String"/>
        <Parameter name="_version" type="String"/>
        <Parameter name="_association" type="String"/>
        <Parameter name="_ediFileType" type="CM_EDIFileType" usage="io"/>
        <Parameter name="_ediDataType" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findEDIFileTypeUserDefined" id="e3b9c97f-2cc3-456c-bbf1-9a2adc16eda5">
        <source>findEDIFileTypeUserDefined(_ediFileType : CM_EDIFileType io; _fileData : String) : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	09 January 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
22 Mar 2012	cnwrs1	Par 29295 Fix up finding EDI file type for CSV and XML files
16 Apr 2012	cnwrs1	Par 29447 not finding EDI file Type for fixed length
01 Aug 2012	cnwcs5	par 30136 - change usage of _file parameter

22 Jan 2014	cnwrs1	Par 35504 - Refactor EDI file load for .NET
04 Feb 2015	cnwrs1	Par EDI Refactor for fileload  
08 Dec 2016	cnwkpd1	TFS 3112 - Performance issue related to search words
// 27 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 4
11/07/2025		naviv1			MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
*/

vars
	dict		: CM_EDIFileTypeByTypeNameDict;
	fileTypeUser : CM_EDIFileTypeUser;
	fileTypeUserTemp : CM_EDIFileTypeUser;
	fileType	: CM_EDIFileType;
	iter		: Iterator;
	typeKey		: Integer;
	nameKey		: String;
	numHits,
	pos,
	idx			: Integer;
	searchWord,
	searchWordUpper,
	lineStr		: String;
	ediFile : CM_EDIFile;
	theLines : HugeStringArray;
begin
	create theLines transient;
	dict := app.myRoot.allEDIFileTypes;
	iter := dict.createIterator;
	dict.startKeyGeq(EDIFileType_UserDefined, null, iter);
	
	create ediFile transient;
	ediFile.setRawDataString(_fileData);
	if _ediFileType = null then
		create fileTypeUserTemp transient;
		fileTypeUserTemp.rawDataToHSA(ediFile, theLines);
	else
		_ediFileType.rawDataToHSA(ediFile, theLines);
	endif;
	while iter.next(fileType) do
		iter.getCurrentKeys(typeKey,nameKey); //MTN-35226
		if typeKey &lt;&gt; EDIFileType_UserDefined then
			break;
		endif;
		
		fileTypeUser := fileType.CM_EDIFileTypeUser;
		if fileTypeUser.emailActive = false then
			continue;
		endif;
		numHits := 0;
		foreach searchWord in fileTypeUser.emailSearchWords do : searchWordLoop	
			idx := 0;
			searchWordUpper := searchWord.toUpper();
			foreach lineStr in theLines do							// foreach through array for performance
				idx := idx + 1;
				if idx &gt; fileTypeUser.emailNumLinesToSearch then	// stop after checking the specified number of lines
					break;
				endif;
				pos := 1;
				if lineStr.toUpper.pos(searchWordUpper, pos) &gt; 0 then
					numHits := numHits + 1;
					
					continue searchWordLoop;
				endif;
			endforeach;
		endforeach;
		
		if numHits = fileTypeUser.emailSearchWords.size then //we've found it
			_ediFileType := fileType;
			return true;
		endif;
	endwhile;

	return false;

epilog
	delete iter;
	delete theLines;
	delete ediFile;
	delete fileTypeUserTemp;
end;
</source>
        <Parameter name="_ediFileType" type="CM_EDIFileType" usage="io"/>
        <Parameter name="_fileData" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllEDIDataTypeValues" id="ae7d4c16-83cd-4c91-aae7-ccdf54320e06">
        <source>getAllEDIDataTypeValues(_coll :IntegerArray input; _userDefined :Boolean);
// ---------------------------------------------------------------------------
// Created:     27 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//19 Sep 2012	cnwrs1		CCMS SFW 1290 Transaction file
// ---------------------------------------------------------------------------
//11 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS EDI
// 13 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 18 Jul 2018	jlgrs1	TFS PLI01
// 08 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
// 27 Jun 2023	jlizm1	TFS 53901 EUP VBS EDI
// 12 Jul 2023	navdap1	TFS 58923 EUP CallOff EDI Data Type / EDI Load
//13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
vars

begin
	_coll.add(EDIDataType_BayPlan);
	_coll.add(EDIDataType_BookingSingleLine);
	_coll.add(EDIDataType_Prenote);
	_coll.add(EDIDataType_StowAdvice);
	_coll.add(EDIDataType_CustomStop);
	_coll.add(EDIDataType_LoadList);
	_coll.add(EDIDataType_Tranship);
	_coll.add(EDIDataType_Cargo); 
	_coll.add(EDIDataType_CargoOnSite); 
	_coll.add(EDIDataType_CargoOnShip); 
	_coll.add(EDIDataType_Pack); 	//ccms 1976 01 Dec 2010 cnwrs1
	_coll.add(EDIDataType_Product); 
	_coll.add(EDIDataType_Fleet); 
	
	if not _userDefined then 
		_coll.add(EDIDataType_CustomsBOL);  
		_coll.add(EDIDataType_CustomsMessage); 
		_coll.add(EDIDataType_Generic); 
		_coll.add(EDIDataType_OutwardRail); 
		_coll.add(EDIDataType_OperatorStop); 
		_coll.add(EDIDataType_TrainMovement);	// TFS 2533
		_coll.add(EDIDataType_GateDocument);
//		_coll.add(EDIDataType_TransportManifest); 	// 05.Jun.2023 navsp1 TFS 58054		//13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
//		_coll.add(EDIDataType_CallOff);				// TFS 58923						//13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
	endif;
	
	//Messina Line changes 20317, 20318, 20320 ccms 1008, 1011, 1010
	_coll.add(EDIDataType_FleetWagon);
	_coll.add(EDIDataType_ReleaseRequest);
	_coll.add(EDIDataType_RequestMultiLine);
	_coll.add(EDIDataType_BOL);
	_coll.add(EDIDataType_Stop);
	_coll.add(EDIDataType_Train);
	_coll.add(EDIDataType_Voyage);
	_coll.add(EDIDataType_Wagon);
	_coll.add(EDIDataType_TrainConsist);
	_coll.add(EDIDataType_BookingMultiLine); 
	_coll.add(EDIDataType_DeckPlan); 
	_coll.add(EDIDataType_DeckStowageAdvice); //cnwgb1 14.10.2011 CCMS 1009
	_coll.add(EDIDataType_ShipManifest); 
	_coll.add(EDIDataType_CargoFieldUpdate);
	_coll.add(EDIDataType_Transaction);	//19 Sep 2012	cnwrs1		CCMS SFW 1290 Transaction file
	_coll.add(EDIDataType_ToDoTask);
	_coll.add(EDIDataType_Consignoree);	
	_coll.add(EDIDataType_VGM);	
	
	//epr par 35304 2/12/14
	_coll.add(EDIDataType_Carrier);
	_coll.add(EDIDataType_Commodity);
	_coll.add(EDIDataType_CustomsAgent);
	_coll.add(EDIDataType_Driver);
	_coll.add(EDIDataType_Vehicle);
	_coll.add(EDIDataType_Debtor); //epr par 36370 2/6/15 
	_coll.add(EDIDataType_MultiMoveGroup);	//16 Sep 2015	NDL	Par 36906
	_coll.add(EDIDataType_QueueMove);		// 16 Sep 2015	JRE	Par 36912
	_coll.add(EDIDataType_OneStopPre);	//14 Sep 2016	NDL	TFS 2278 / 2670
	_coll.add(EDIDataType_OneStopCust);	//14 Sep 2016	NDL	TFS 2278 / 2670
	_coll.add(EDIDataType_OneStopEIDO);	//04 Oct 2016	NDL	TFS 2718 / 2536
	_coll.add(EDIDataType_OpCarrierAcessByCT);
	_coll.add(EDIDataType_VoyageEvent);	// 29 jul 2022 jlizm1 TFS 54165
	
	if app.isCargoGroupEnabled then	 //10 Aug 2015	NDL	Par 36608
		_coll.add(EDIDataType_CargoGroupAssign);
		_coll.add(EDIDataType_CargoGroup);	//16 Feb 2016	NDL	Par 37544
	endif;
	
	if app.myRoot.canDo(Sub_VBSSlotValidation) then	// TFS 53901
		_coll.add(EDIDataType_VBSSlot);
	endif;
	
	_coll.add(EDIDataType_WagonReleaseAssign);	//navra1 - 2nd Dec 2022 - TFS 54124
	_coll.add(EDIDataType_TransportManifest); 	// 05.Jun.2023 navsp1 TFS 58054		//13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
	_coll.add(EDIDataType_CallOff);				// TFS 58923						//13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
	_coll.add(EDIDataType_DeliveryParty);    //27/1/25 jlier1 TFS 33694	
epilog

end;</source>
