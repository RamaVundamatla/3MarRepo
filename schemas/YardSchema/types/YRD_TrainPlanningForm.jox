    <JadeMethod name="doMnuContext" id="532cde96-852f-4d93-97a2-21f2b857a3c4">
        <updating/>
        <source>doMnuContext(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lX, lY : Real;
	gridPoint : CMUI_GridPoint;

begin
	if cntrl &lt;&gt; null and
			cntrl.isKindOf(CMUI_GridAreaFrame) and
			cntrl.CMUI_GridAreaFrame.myGridArea &lt;&gt; null then
		gridPoint := cntrl.CMUI_GridAreaFrame.myGridArea.convertPositionToGridPoint(x, y); 
	endif;
	
	if gridPoint &lt;&gt; null then
		self.myCurrentLocation := gridPoint.myLocationsController;
	endif;

	lX := x;
	lY := y;
	conwin.windowToScreen(lX, lY);
	self.screenToWindow(lX, lY);
	self.setGridAreaContextMenu(gridPoint, lX.Integer, lY.Integer);
	
	return false;
end;</source>
        <Parameter name="cntrl" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuDetachGenSet" id="a219a5dc-5f92-4289-8007-f9a20db63d86">
        <updating/>
        <source>doMnuDetachGenSet( menuItem: MenuItem ) updating, protected;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form	: CMUI_DetachGenSet;
	anObject: Object;
	theTI	: CM_TrackedItem;

begin

	anObject := menuItem.userObject;
	if anObject = null then 
		return;
	endif;
	
	if not anObject.isKindOf(CM_Container) and not anObject.isKindOf(CM_TILC) then
		return;
	endif;
	self.mousePointer := Window.MousePointer_HourGlass;
	
	theTI := anObject.CM_TrackedItem;
	create form;
	form.centreWindow;
	form.myTrackedItem := theTI;
	form.setMyTerminal(self.myTerminal);
	form.setFormParent( self );
	form.showModal;
	
epilog
	self.mousePointer := Window.MousePointer_Default;


end;</source>
