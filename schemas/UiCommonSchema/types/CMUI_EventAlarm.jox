        <access>protected</access>
        <Parameter name="_control" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMouseMove" id="82499dca-70fd-438c-b4b4-dc17b56c3695">
        <updating/>
        <source>doMouseMove(_control 	: Control input; 
			_button		: Integer; 
			_shift		: Integer; 
			_x, _y		: Real) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	18 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tmpX, tmpY,
	parentX,
	parentY			: Real;

begin
	
	if self.inDragMode then
		// convert x,y to be relative to parent window
		parentX := _x + self.left;
		parentY := _y + self.top;
		
		tmpX := self.left + parentX - self.mouseDownX;
		tmpY := self.top + parentY - self.mouseDownY;
		
		self.move(tmpX, tmpY, self.width, self.height);

		self.mouseDownX := parentX;
		self.mouseDownY := parentY;
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_control" type="Control" usage="input"/>
        <Parameter name="_button" type="Integer"/>
        <Parameter name="_shift" type="Integer"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
