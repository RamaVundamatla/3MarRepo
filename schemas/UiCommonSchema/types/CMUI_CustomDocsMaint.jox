    <JadeMethod name="updateCustDoc" id="0311c43f-6b15-411c-a808-4601b4b5acf0">
        <updating/>
        <source>updateCustDoc()updating;
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
01/09/2023	navkc1	CR 59937 Task 59939: UI - Cust Doc Mandatory Fields
*/

vars
	pxyCustDoc, realCustDoc 		: CM_CustomDocument;
	theReturn : Integer;
	terminal				: CM_Terminal;
	hsCode : CM_HarmonizedSystem;
	docLic : CM_CustomLicense;
	docType	: CM_CustomDocumentType;
	custAgent : CM_CustomsAgent;
	refNumber,remarks,code,desc,extRef : String;
	direction, itemNumber : Integer;
	scheduleTSstart 		: TimeStamp;
	partialUpdate : Boolean;
begin
	partialUpdate := self.mode = self.Partial_Update_Mode; // ### TFS CR 60424 TASK 60549 24OCT2023 NAVAB1
	
	pxyCustDoc := app.createUpdateProxy(self.myCustomDocument).CM_CustomDocument;	
	
	code := self.txtCode.text;
	desc := self.txtDesc.text;
	extRef := self.txtExtRef.text;
	//01/09/2023	navkc1	CR 59937 Task 59939
	if self.cmbDirection.listIndex &lt;= 0 then
		direction := -1;
	else
		direction := self.cmbDirection.itemData[self.cmbDirection.listIndex];
	endif;
	itemNumber := self.txtRefNumber.text.Integer;
	
	scheduleTSstart.setDate(self.mskCOOFromStart.getDate());
	scheduleTSstart.setTime(self.mskCOOFromStartTime.getTime());
	scheduleTSstart := self.localToSystemTime(scheduleTSstart);
	
	hsCode := self.cmbHSCodes.listObject.CM_HarmonizedSystem;
	docLic := self.cmbLicense.listObject.CM_CustomLicense;
	docType := self.cmbDocType.listObject.CM_CustomDocumentType;
	custAgent := self.cmbCustomsAgent.listObject.CM_CustomsAgent;
	
	if self.txtRemarks &lt;&gt; null then
		remarks := self.txtRemarks.text.String;
	endif;
	
	if self.txtRefNumber &lt;&gt; null then
		refNumber := self.txtRefNumber.text.String;
	endif;
	terminal := self.getMyTerminal;
	pxyCustDoc.setProxy(terminal,code,desc,extRef,null,remarks,scheduleTSstart,null,null,
		direction,itemNumber,docType,docLic,custAgent,hsCode, self.txtSequence.text.Integer);
	while true do
		app.myTrxUA.trxUpdateCustDocHeader(pxyCustDoc, partialUpdate, app.myPassport); // ### TFS CR 60424 TASK 60549 24OCT2023 NAVAB1 - partial
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			app.msgBox("Update Successful", app.getErrorString(Confirmation),MsgBox_OK_Only);
			break;
		else
			theReturn := app.showErrorWarningDialog("Custom Document Update", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
epilog
	self.mousePointer := Window.MousePointer_Default;
	delete pxyCustDoc;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="updateCustomDocumentDetails" id="00b5fd8b-d2c7-40a5-a33f-e1adc3420696">
        <source>updateCustomDocumentDetails();
/*
Purpose - 	
Who - NAVAB1
Date - 24JUNE2024
ADO -  CR 64285 TASK 64286
*/

vars
	cmifCustomDocumentDtl : CMIF_CustomDocumentDetail;
	theReturn, option, timeRemaining : Integer;
begin

	create cmifCustomDocumentDtl transient;
	// put all the sub items in, whether 'included' or not.
	self.allProxyDetailsForInclude.copy(cmifCustomDocumentDtl.allProxyCustDocDetails);
	
	while true do
		app.myTrxUA.trxUpdateCustDocsDetails(cmifCustomDocumentDtl,app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			self.showMessage(app.getErrorString(Details_auto_saved), 1500, self.Position_TopCentered);
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Custom_documents), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				  theReturn = IDOK then
				  // there must have just been warnings that the user has acknoledged so ..
				  app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
			
		break;
	endwhile;
	

epilog
	self.allProxyDetailsForInclude.purge();
	delete cmifCustomDocumentDtl;


end;</source>
    </JadeMethod>
