    <JadeMethod name="setMyLogLot" id="494e1bf8-5815-42f6-9504-6579ef7d92ce">
        <updating/>
        <source>setMyLogLot() updating;
//--------------------------------------------------------------
//Created: 26 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
//	if self.myLogVoyage &lt;&gt; null  and then 
//		self.myLogLot := self.myLogVoyage.allLogLots[self.lotNo];
//	endif;

	if self.myLogVoyageStructure &lt;&gt; null then 
		self.myLogLot := self.myLogVoyageStructure.allLogLots[self.lotNo];
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyLogVoyageStruct" id="ab73c8da-94fb-4959-852e-87c83eea2cdd">
        <updating/>
        <source>setMyLogVoyageStruct() updating;
//--------------------------------------------------------------
//Created: 27 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	voy : CM_Voyage;
begin

	if self.myVoyageGlobal &lt;&gt; null and self.myTerminal &lt;&gt; null then
		voy := self.myVoyageGlobal.getVoyageForArrivingDTTerminal(null, self.myTerminal);
		if voy &lt;&gt; null then 
			self.myLogVoyageStructure := voy.myLogVoyageStructure;
		endif;
	endif;

end;
</source>
    </JadeMethod>
