    <JadeMethod name="drawArea" id="07dce1f6-99d5-446c-83e2-8189b022c59d">
        <updating/>
        <source>drawArea( _frame : Frame input ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 Sep 2008	consw1	Initial creation
12 Jun 2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars
	area 				: CM_TerminalArea;
	areaViewPosition	: CM_TerminalAreaViewPosition;
	gridSize			: Point;
	numberOfCols		: Integer;
	numberOfRows		: Integer;
	tmpWidth			: Real;
	tmpHeight			: Real;
	topAlignment		: Integer;
	leftAlignment		: Integer;
	topOffset,
	leftOffset 			: Integer;
	rowCoordinates		: IntegerArray;
	columnCoordinates	: IntegerArray;
	coordinates			: String;				// TFS 49453
	first, last			: String;				// TFS 49453
begin
	areaViewPosition := _frame.userObject.CM_TerminalAreaViewPosition;
	area := areaViewPosition.myTerminalArea;

	topAlignment := areaViewPosition.getTopAlignment;
	leftAlignment := areaViewPosition.getLeftAlignment;
	
	_frame.clearGraphics;
	_frame.left := areaViewPosition.origin.x * zoom;
	_frame.top 	:= ( areaViewPosition.origin.y * zoom ) - YRD_ContainerDrawingController.TitleHeight;
	_frame.visible := true;
	
	numberOfCols := YRD_ContainerDrawingController.BlockStackSize;
	numberOfRows := YRD_ContainerDrawingController.BlockStackSize;

	if area.isKindOf(CM_BlockStack) then	// 29 Aug 2011	NDL	Par 28076
		numberOfCols := area.CM_BlockStack.getColumns(true);
		numberOfRows := area.CM_BlockStack.getRows(true);
		
	elseif area.isKindOf(CM_GridArea) and not  area.isKindOf(CM_YardInterchangeArea) then
		numberOfCols := area.CM_GridArea.numberOfColumns;
		numberOfRows := area.CM_GridArea.numberOfRows;
		
	elseif area.isKindOf(CM_IrregularBlockArea) then
		numberOfCols := area.CM_IrregularBlockArea.columns;
		numberOfRows := area.CM_IrregularBlockArea.rows;		
	endif;

	if area.isKindOf(CM_IrregularBlockArea) then
		gridSize := self.getTotalIrregularGridSize();
	else
		gridSize := self.getTotalGridSize;
	endif;

	if area.isKindOf(CM_IrregularBlockArea) then
		tmpWidth := numberOfCols * gridSize.x + (YRD_ContainerDrawingController.GridBorderWidth ).Integer * 2;
		tmpHeight:= numberOfRows * gridSize.y + (YRD_ContainerDrawingController.GridBorderWidth ).Integer * 2;
	elseif area.isKindOf(CM_RoRoLaneArea) then						// cnwjk3 ccms 1018 25/11/09
		if topAlignment = areaViewPosition.AlignTop or
			topAlignment = areaViewPosition.AlignBottom then
			tmpWidth := area.CM_RoRoLaneArea.getSatDrawWidthInPixels(zoom);
			tmpHeight := area.CM_RoRoLaneArea.getSatDrawHeightInPixels(zoom);
			leftOffset := 2;		// 9/10/17 MAP TFS7084
		else
			// Rotated 90 or 270, so width becomes height and vice versa			
			tmpWidth := area.CM_RoRoLaneArea.getSatDrawHeightInPixels(zoom);
			tmpHeight := area.CM_RoRoLaneArea.getSatDrawWidthInPixels(zoom);
		endif;
	// TFS 49453 start
	elseif area.isGeneralCargoAllocArea() then
		if topAlignment = areaViewPosition.AlignTop 
		or topAlignment = areaViewPosition.AlignBottom then
			tmpWidth := area.CM_GeneralCargoAllocRowArea.getSatDrawLengthInPixels(zoom);
			tmpHeight := area.CM_GeneralCargoAllocRowArea.getSatDrawWidthInPixels(zoom);
		else
			// Rotated 90 or 270, so width becomes height and vice versa			
			tmpWidth := area.CM_GeneralCargoAllocRowArea.getSatDrawWidthInPixels(zoom);
			tmpHeight := area.CM_GeneralCargoAllocRowArea.getSatDrawLengthInPixels(zoom);
		endif;
	// TFS 49453 end
	elseif not area.canBeDesigned then
	
		//cnwrd1 par 36667 rotate of block stacks
		if topAlignment = areaViewPosition.AlignTop
		or topAlignment = areaViewPosition.AlignBottom then
			if areaViewPosition.getHeight() &gt; 0 then
				tmpHeight:=(areaViewPosition.getHeight() * zoom).Integer;
			else
				tmpHeight:= numberOfRows * gridSize.y;
			endif;
			
			if areaViewPosition.getWidth() &gt; 0 then
				tmpWidth:=(areaViewPosition.getWidth() * zoom).Integer;
			else
				tmpWidth := numberOfCols * gridSize.x;
			endif;
		else
		
		
			if areaViewPosition.getHeight() &gt; 0 then
				tmpWidth:=(areaViewPosition.getHeight() * zoom).Integer;
			else
				tmpWidth:= numberOfRows * gridSize.y;
			endif;
			
			if areaViewPosition.getWidth() &gt; 0 then
				tmpHeight:=(areaViewPosition.getWidth() * zoom).Integer;
			else
				tmpHeight := numberOfCols * gridSize.x;
			endif;
		
		endif;
		
	else
		if topAlignment = areaViewPosition.AlignTop
		or topAlignment = areaViewPosition.AlignBottom then
			// PAR 19411
			if area.isKindOf(CM_GridArea)  and not  area.isKindOf(CM_YardInterchangeArea) then
				tmpWidth := self.getTAWidth(area.CM_GridArea);
			else
				tmpWidth := numberOfCols * gridSize.x;
			endif;
			// PAR 19411
			// Note that we don't need to compensate for gaps when calculating the heights,
			// as when a gap is draw horizontally, it is drawn the same size as a grid block.
			tmpHeight:= numberOfRows * gridSize.y;
		else
			// PAR 19411
			if area.isKindOf(CM_GridArea)  and not  area.isKindOf(CM_YardInterchangeArea) then
				tmpHeight := self.getTAWidth(area.CM_GridArea);
				//tmpWidth := self.getTAHeight(area.CM_GridArea);
			else
				tmpHeight:= numberOfCols * gridSize.x;
			endif;
			tmpWidth := numberOfRows * gridSize.y;
		endif;
	endif;
	
	topOffset := YRD_ContainerDrawingController.TitleHeight;
	_frame.drawFontSize:=8;
	_frame.drawTextAlign := Frame.DrawTextAlign_Left;
	
	_frame.width:=tmpWidth + (leftOffset*2) + 6;
	_frame.height:=tmpHeight + (topOffset*2);
	_frame.autoRedraw:=true;
	_frame.ignoreSkin:=true;
	_frame.borderStyle:=BorderStyle_None;

	_frame.drawStyle:=Frame.DrawStyle_Solid;
	_frame.drawFillColor:=self.myTerminal.getConfig(SatelliteViewCellColour).Integer;//LightBlue;
	_frame.drawFilledRectangle(leftOffset,topOffset,leftOffset+tmpWidth,topOffset+tmpHeight, self.myTerminal.getConfig(SatelliteViewGridColour).Integer);//DarkBlue

	if _frame.drawTextWidth(area.id) &gt; _frame.width then
		_frame.width := _frame.drawTextWidth(area.id);
	endif;
	_frame.drawTextAlign := Frame.DrawTextAlign_Center;
	_frame.drawTextAt(area.id,_frame.width/2,0,self.myTerminal.getConfig(SatelliteViewFontColour).Integer);//Blue

	create columnCoordinates transient;
	create rowCoordinates transient;
	rowCoordinates.add(0);				columnCoordinates.add(0);
	rowCoordinates.add(numberOfRows);	columnCoordinates.add(numberOfCols);
	rowCoordinates.add(numberOfRows);	columnCoordinates.add(numberOfCols);
	rowCoordinates.add(0);				columnCoordinates.add(0);
	
	_frame.drawFontSize:=6;
	_frame.drawTextAlign := Frame.DrawTextAlign_Left;

	//if area.isKindOf(CM_GridArea) or area.isKindOf(CM_IrregularBlockArea) then
	if (area.isKindOf(CM_GridArea)  and not  area.isKindOf(CM_YardInterchangeArea) ) or area.isKindOf(CM_IrregularBlockArea) or area.isKindOf(CM_RoRoLaneArea) then // cnwjk3 ccms 1018 29/11/09
		coordinates := "(" &amp; rowCoordinates[( ( 0 + topAlignment  ) mod 4) + 1 ].String 
						&amp; "," &amp; columnCoordinates[( ( 0 + leftAlignment ) mod 4) + 1 ].String &amp; ")";
		_frame.drawTextIn(coordinates,leftOffset+1,topOffset+1,leftOffset+tmpWidth-1,topOffset+tmpHeight-1,self.myTerminal.getConfig(SatelliteViewFontColour).Integer);//Blue
		
		_frame.drawTextAlign := Frame.DrawTextAlign_Right;

		coordinates := "(" &amp; rowCoordinates[( ( 3 + topAlignment  ) mod 4) + 1 ].String 
						&amp; "," &amp; columnCoordinates[( ( 3 + leftAlignment ) mod 4) + 1 ].String &amp; ")";
		if _frame.drawTextWidth(coordinates) * 2.5 &lt; tmpWidth then
			_frame.drawTextIn(coordinates,leftOffset+1,topOffset+1,leftOffset+tmpWidth-1,topOffset+tmpHeight-1,self.myTerminal.getConfig(SatelliteViewFontColour).Integer);
		endif;
			
		coordinates := "(" &amp; rowCoordinates[( ( 2 + topAlignment  ) mod 4) + 1 ].String 
						&amp; "," &amp; columnCoordinates[( ( 2 + leftAlignment ) mod 4) + 1 ].String &amp; ")";
		if _frame.drawTextWidth(coordinates) * 2.5 &lt; tmpWidth and _frame.drawTextHeight(coordinates) * 2.5 &lt; tmpHeight then
			_frame.drawTextIn(coordinates,leftOffset+1,tmpHeight,leftOffset+tmpWidth-1,topOffset+tmpHeight-1,self.myTerminal.getConfig(SatelliteViewFontColour).Integer);
		endif;
		
		_frame.drawTextAlign := Frame.DrawTextAlign_Left;

		coordinates := "(" &amp; rowCoordinates[( ( 1 + topAlignment  ) mod 4) + 1 ].String 
						&amp; "," &amp; columnCoordinates[( ( 1 + leftAlignment ) mod 4) + 1 ].String &amp; ")";
		if _frame.drawTextHeight(coordinates) * 2.5 &lt; tmpHeight then
			_frame.drawTextIn(coordinates,leftOffset+1,tmpHeight,leftOffset+tmpWidth-1,topOffset+tmpHeight-1,self.myTerminal.getConfig(SatelliteViewFontColour).Integer);
		endif;
		
	// TFS 49453
	elseif area.isGeneralCargoAllocArea() then
		if areaViewPosition.horizontalFlip then
			last := area.CM_GeneralCargoAllocRowArea.allRowControllersById.first.CM_GeneralCargoAllocGroup.firstColumn;
			first := area.CM_GeneralCargoAllocRowArea.allRowControllersById.last.CM_GeneralCargoAllocGroup.lastColumn;
		else
			first := area.CM_GeneralCargoAllocRowArea.allRowControllersById.first.CM_GeneralCargoAllocGroup.firstColumn;
			last := area.CM_GeneralCargoAllocRowArea.allRowControllersById.last.CM_GeneralCargoAllocGroup.lastColumn;
		endif;
		
		coordinates := "(" &amp; first &amp; ")";
		_frame.drawTextIn(coordinates,leftOffset+1,topOffset+1,leftOffset+tmpWidth-1,topOffset+tmpHeight-1,self.myTerminal.getConfig(SatelliteViewFontColour).Integer);//Blue
		
		coordinates := "(" &amp; last &amp; ")";
		if topAlignment = areaViewPosition.AlignTop	or topAlignment = areaViewPosition.AlignBottom then	
			_frame.drawTextAlign := Frame.DrawTextAlign_Right;
			_frame.drawTextIn(coordinates,leftOffset+1,topOffset+1,leftOffset+tmpWidth-1,topOffset+tmpHeight-1,self.myTerminal.getConfig(SatelliteViewFontColour).Integer);
		else
			_frame.drawTextAlign := Frame.DrawTextAlign_Left;
			_frame.drawTextIn(coordinates,leftOffset+1,tmpHeight,leftOffset+tmpWidth-1,topOffset+tmpHeight-1,self.myTerminal.getConfig(SatelliteViewFontColour).Integer);
		endif;
	// TFS 49453
	endif;

epilog
	delete rowCoordinates;
	delete columnCoordinates;
end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawBaseGrid" id="f7e90d87-26ee-4f34-9c3b-6eacc40c0894">
        <source>drawBaseGrid();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2008	cnwer1	Initial creation

*/

vars
	stepSize: Point;
	lineSize,
	i: Integer;
begin
	//draw dotted grid  800 x 800 
	stepSize:=self.getTotalGridSize;
	lineSize:=self.frmScrollingMain.width.Integer;
	foreach i in 0 to lineSize step stepSize.x do
		self.frmScrollingMain.drawStyle:=Frame.DrawStyle_Solid;

		self.frmScrollingMain.drawLine(1,i,lineSize,i,Grey);
		self.frmScrollingMain.drawLine(i,1,i,lineSize,Grey);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="enableAreaButtons" id="7a17d0b9-e08e-46a3-8273-92278cc9774b">
        <source>enableAreaButtons();

/*

Purpose:		Enable area action buttons

Parameters:			

Return Value:		


Date				Who		Reason
04/09/2008	consw1	Initial creation
23/07/2020	jlgdap1	TFS 49783 ASPA Graphical Display
*/

vars
	enableEdit	: Boolean;
	enableNew	: Boolean;
	obj			: Object;

begin
	obj := lstAreas.listObject;
	
	if 	obj &lt;&gt; null and (self.isEditMode or self.isAddMode) then
		enableNew	:= obj.isKindOf(CM_TerminalArea);
		enableEdit 	:= obj.isKindOf(Frame);
	endif;

	self.btnFlipV.enabled		:= enableEdit;
	self.btnFlipH.enabled		:= enableEdit;
	self.btnRotate.enabled		:= enableEdit;
	self.btnProperties.enabled		:=enableEdit;
	self.btnAreaNew.enabled		:= enableNew;
	self.btnAreaDelete.enabled	:= enableEdit;
	self.btnAlignLeft.enabled	:= enableEdit;
	self.btnAlignTop.enabled	:=enableEdit;
		// cnwjk3  We don't yet allow rotation/flipping of CM_IrregularBlockArea
	if obj.isKindOf(Frame) then
		if obj.Frame.userObject &lt;&gt; null then
			if obj.Frame.userObject.CM_TerminalAreaViewPosition.myTerminalArea.isKindOf(CM_IrregularBlockArea) then
				self.btnFlipV.enabled	:= false;
				self.btnFlipH.enabled	:= false;
				self.btnRotate.enabled	:= false;
			// TFS 498783 We don't allow flip vertical for General Cargo Allocation Row Areas
			elseif obj.Frame.userObject.CM_TerminalAreaViewPosition.myTerminalArea.isKindOf(CM_GeneralCargoAllocRowArea) then
				self.btnFlipV.enabled := false;
			endif;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="frmArea_mouseDown" id="433f1088-a4b3-428d-9c4e-7e16fd6b20f7">
        <controlMethod name="CMUI_ResizableRectFrame::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmArea_mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 Sep 2008	consw1	Initial creation
*/

vars
	curentFrame : Frame;
	idx 		: Integer;
	selectItem  : Boolean;
	obj 		: Object;
begin
	selectItem:=true;
	if shift.bitAnd(1) = null and shift.bitAnd(2) = null then
		foreach idx in 1 to self.lstAreas.listCount where self.lstAreas.itemSelected[idx] = true do
			
			
			if  self.lstAreas.itemObject[idx].isKindOf(Frame) then
				curentFrame:=self.lstAreas.itemObject[idx].Frame;
			endif;
			
			if curentFrame  &lt;&gt; null then
				curentFrame.boundaryWidth:=0;
				self.lstAreas.itemSelected[idx]:=false;
				if self.allSelectedFrames.indexOf(curentFrame) &gt;  0 then
					self.allSelectedFrames.remove(curentFrame);
				endif;
			endif;
		endforeach;
		foreach obj in self.allSelectedFrames do
			obj.Frame.boundaryWidth:=0;
		endforeach;
		self.allSelectedFrames.clear;
	else
		foreach idx in 1 to self.lstAreas.listCount where self.lstAreas.itemSelected[idx] = true do
			if self.lstAreas.itemObject[idx] = null then
				continue;
			endif;
			if self.lstAreas.itemObject[idx]=frame then
				frame.boundaryWidth:=0;
				lstAreas.itemSelected[idx]:=false;
				if self.allSelectedFrames.indexOf(frame) &gt;  0 then
					self.allSelectedFrames.remove(frame);
				endif;
				selectItem:=false;
				if self.allSelectedFrames.size &gt; 0 then
					self.allSelectedFrames.last.Frame.boundaryBrush:=Frame.BoundaryBrush_Dotted;
				endif;
			else
				self.lstAreas.itemObject[idx].Frame.boundaryBrush:=Frame.BoundaryBrush_Solid;
			endif;
		endforeach;
	endif;
	
	if not selectItem then
		return;
	endif;
	self.lstAreas.selectObject( frame );
	self.allSelectedFrames.add(frame);
	
	frame.boundaryWidth:=3;
	frame.boundaryBrush:=Frame.BoundaryBrush_Dotted;
	self.enableAreaButtons();
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="frmArea_mouseUp" id="c38d20f8-ee23-4c16-a9a1-624bab01bf1e">
        <controlMethod name="CMUI_ResizableRectFrame::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmArea_mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
03 September 2008	consw1	Initial creation

*/

vars
	origin : Point;

begin
//	self.snapToGrid(frame.top);
//	self.snapToGrid(frame.left);

	if ( frame.left * zoom ) &lt; 0 then
		frame.left := 0;
	endif;
	
	if (frame.top / zoom ) &lt; 0 then
		frame.top := 0;//- YRD_ContainerDrawingController.TitleHeight;
	endif;

	//  Keep proxy in step with display
	
	origin.setX(( frame.left / zoom ).rounded);
	origin.setY((( frame.top + YRD_ContainerDrawingController.TitleHeight ) / zoom ).rounded);
	frame.userObject.CM_TerminalAreaViewPosition.setOrigin(origin);
	
epilog

end;</source>
