    <JadeMethod name="includeObjectTI" id="9e79c607-8693-4f82-845d-15b6e879c4f3">
        <updating/>
        <source>includeObjectTI(_ti : CM_TrackedItem; _numItems : Integer; _breakOut : Boolean output): Boolean updating;
//--------------------------------------------------------------
//Created: 25 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	locnMode : Integer;
begin
	//epr TFS 47132 18/12/19
	if self.useSelectorTable then
		return inheritMethod(_ti, _numItems, _breakOut);
	endif;
	
	if (not inheritMethod(_ti, _numItems, _breakOut)) then
		return false;
	endif;

	locnMode := self.frmStatusLine.getMoveModeForDisplayMode();
	if _ti.getPrimaryLocation(locnMode) = null then
		return false;
	endif;
	
	if self.filterTerminalArea &lt;&gt; null then
		if _ti.getPrimaryLocation(locnMode).myTerminalArea &lt;&gt; self.filterTerminalArea then
			return false;
		endif;
	endif;

	return true;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_numItems" type="Integer"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
