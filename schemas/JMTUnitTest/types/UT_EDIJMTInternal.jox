	&lt;AllRequestHeader&gt;
		&lt;RequestHeader&gt;
			&lt;allowCargoMultiReleases/&gt;
			&lt;customsAssistance/&gt;
			&lt;mtRelease&gt;true&lt;/mtRelease&gt;
			&lt;releaseByType&gt;true&lt;/releaseByType&gt;
			&lt;removeStops/&gt;
			&lt;requestDateDoUpdate/&gt;
			&lt;deliveryReason/&gt;
			&lt;bookingRef/&gt;
			&lt;businessUnit/&gt;
			&lt;cargoSubType/&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;carrierCode/&gt;
			&lt;consignee&gt;UTCOE&lt;/consignee&gt;
			&lt;consignor/&gt;
			&lt;consignorVoyage/&gt;
			&lt;customsAgent/&gt;
			&lt;deliveryReleaseNumber/&gt;
			&lt;description/&gt;
			&lt;destTerminal/&gt;
			&lt;destinationPort/&gt;
			&lt;dischargePort/&gt;
			&lt;freightForwarder/&gt;
			&lt;fullOrMT&gt;E&lt;/fullOrMT&gt;
			&lt;generatorType/&gt;
			&lt;id/&gt;
			&lt;loadPort/&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;operatorGroup/&gt;
			&lt;releaseRequestNumber&gt;'&amp;RELEASE_001&amp;'&lt;/releaseRequestNumber&gt;
			&lt;releaseType/&gt;
			&lt;releaseTypeStr&gt;Rail&lt;/releaseTypeStr&gt;
			&lt;remarks&gt;release remark stuff&lt;/remarks&gt;
			&lt;senderCode/&gt;
			&lt;statusBulkRelease&gt;Active&lt;/statusBulkRelease&gt;
			&lt;subTerminalCode&gt;UT_Depot&lt;/subTerminalCode&gt;
			&lt;trailerType/&gt;
			&lt;vesselName&gt;'&amp;VESSELNAME&amp;'&lt;/vesselName&gt;
			&lt;voyageCode&gt;'&amp;VOYAGECODE&amp;'&lt;/voyageCode&gt;
			&lt;estimatedRequiredDate/&gt;
			&lt;expiryTimeStamp/&gt;
			&lt;requestDate/&gt;
			&lt;AllRequestDetail&gt;
				&lt;RequestDetail&gt;
					&lt;checkISOGroup/&gt;
					&lt;clean/&gt;
					&lt;heavyDuty/&gt;
					&lt;isChild/&gt;
					&lt;isGeneratorAttachment/&gt;
					&lt;volume/&gt;
					&lt;weight/&gt;
					&lt;quantity&gt;1&lt;/quantity&gt;
					&lt;availabilityGrades/&gt;
					&lt;billOfLading/&gt;
					&lt;cargoSubType/&gt;
					&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
					&lt;description/&gt;
					&lt;fullOrMT/&gt;
					&lt;id/&gt;
					&lt;ids/&gt;
					&lt;isoType&gt;22G1&lt;/isoType&gt;
					&lt;isoTypeGroup&gt;GEN2&lt;/isoTypeGroup&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;releaseRequestNumber&gt;&lt;/releaseRequestNumber&gt;
					&lt;remarks/&gt;
					&lt;requestDetailID/&gt;
					&lt;sequence/&gt;
					&lt;stopsToApply/&gt;
					&lt;AllRequestCriteria&gt;
						&lt;RequestCriteria&gt;
							&lt;cargoTypeDescr/&gt;
							&lt;criteriaName&gt;Cargo Group ID&lt;/criteriaName&gt;
							&lt;criteriaValue&gt;8123928&lt;/criteriaValue&gt;
							&lt;description/&gt;
							&lt;fullOrMT/&gt;
							&lt;id/&gt;
							&lt;messageMode&gt;A&lt;/messageMode&gt;
							&lt;releaseRequestNumber/&gt;
							&lt;requestDetailID/&gt;
						&lt;/RequestCriteria&gt;
					&lt;/AllRequestCriteria&gt;
					&lt;AllTaskActionsToApply&gt;
						&lt;TaskActionsToApply&gt;
							&lt;bookingId/&gt;
							&lt;bookingItemSeq/&gt;
							&lt;cargoTypeDescr/&gt;
							&lt;description/&gt;
							&lt;fullOrMT/&gt;
							&lt;id/&gt;
							&lt;messageMode&gt;A&lt;/messageMode&gt;
							&lt;releaseRequestNumber/&gt;
							&lt;requestDetailID/&gt;
							&lt;taskCode&gt;UT_ToDo2&lt;/taskCode&gt;
							&lt;toDoRemarks&gt;To Do Task 2 Remarks&lt;/toDoRemarks&gt;
						&lt;/TaskActionsToApply&gt;
					&lt;/AllTaskActionsToApply&gt;
				&lt;/RequestDetail&gt;
			&lt;/AllRequestDetail&gt;
 		&lt;/RequestHeader&gt;
	&lt;/AllRequestHeader&gt;
&lt;/JMTInternalGateDoc&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
//	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 11, "incorrect number of EDI trackedItems");
	bookingRef := self.getBooking(BOOKING001);
	self.assertNotNull(bookingRef);
	self.assertEqualMsg(bookingRef.allBookingRefItems.size, 1, "");
//return;
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertNotNull(container);
	self.assertEqualMsg(container.dischargePort, "HKHKG", "wrong remarks");

	relRequest := self.getReleaseRequest(RELEASE_001);
	self.assertNotNull(relRequest);
	self.assertEqualMsg(relRequest.consigneeCode, "UTCOE", "consigneeCode wrong");
	self.assertNotNull(relRequest.cargoRemarks);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tLoadDischargeListAction" id="96df2d48-cf40-4033-aa86-15b02683d998">
        <source>tLoadDischargeListAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalLoadList";
	CONTAINERID : String = "SARG1234543";
	VOYAGECODE = 'VOY27418';
	VESSELNAME = 'SHIP27418';
	OPERATORCODE = 'MSK';
	BookingId1 = 'BK27418';
	BlockStackName	= 'BS26728';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	bs : CM_BlockStack;
	container : CM_Container;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
begin
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID);
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertIsDeleted(container);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Delete and add the required bookings
	self.opts.addAssoc('Stock', true);
	self.opts.addAssocIfNotNull(ETRow_PackAs, app.getString(PackAs_LCL));
	self.deleteBooking(BookingId1);
	container := self.addContainerOnShip(CONTAINERID, operator, "4102", "GOLD", BookingId1, voyage, self.getTerminal.getConfig(PortDestCode).String, "010682").CM_Container;
	bs := addBlockStack(BlockStackName, 100, null);
	self.opts.addAssoc('IsForcedMove', true);
	self.move(container, bs);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalLoadList xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalLoadList.xsd"&gt;
	&lt;AllDataLoadList&gt;
		&lt;DataLoadList&gt;
			&lt;operatorCode&gt;'&amp;OPERATORCODE&amp;'&lt;/operatorCode&gt;
			&lt;listType&gt;L&lt;/listType&gt;
			&lt;vesselName&gt;'&amp;VESSELNAME&amp;'&lt;/vesselName&gt;
			&lt;voyageCode&gt;'&amp;VOYAGECODE&amp;'&lt;/voyageCode&gt;
			&lt;AllLoadDischargeList&gt;
				&lt;LoadDischargeList&gt;
					&lt;curtainsIn/&gt;
					&lt;hazardous/&gt;
					&lt;isWaterCooled/&gt;
					&lt;isWeightCertified/&gt;
					&lt;outOfGauge/&gt;
					&lt;height/&gt;
					&lt;length/&gt;
					&lt;overHeight/&gt;
					&lt;overLengthBack/&gt;
					&lt;overLengthFront/&gt;
					&lt;overWidthLeft/&gt;
					&lt;overWidthRight/&gt;
					&lt;vent/&gt;
					&lt;weight/&gt;
					&lt;width/&gt;
					&lt;carbonDioxide/&gt;
					&lt;cooledType/&gt;
					&lt;humidity/&gt;
					&lt;oxygen/&gt;
					&lt;state/&gt;
					&lt;temperature/&gt;
					&lt;bol/&gt;
					&lt;bookingRef/&gt;
					&lt;cargoTypeDescr/&gt;
					&lt;commodity/&gt;
					&lt;consignee/&gt;
					&lt;consignor/&gt;
					&lt;description/&gt;
					&lt;destinationPort/&gt;
					&lt;dischargePort/&gt;
					&lt;freightForwarder/&gt;
					&lt;fullOrMT/&gt;
					&lt;id&gt;'&amp;CONTAINERID&amp;'&lt;/id&gt;
					&lt;isoGroup/&gt;
					&lt;isoType/&gt;
					&lt;loadPort/&gt;
					&lt;locationId/&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;myTranshipToPort/&gt;
					&lt;opStatus/&gt;
					&lt;operatorCode&gt;'&amp;OPERATORCODE&amp;'&lt;/operatorCode&gt;
					&lt;sealCustoms/&gt;
					&lt;sealNum/&gt;
					&lt;sealNumberVent/&gt;
					&lt;sealShipper/&gt;
					&lt;sealTerminalOperator/&gt;
					&lt;sealUnknown/&gt;
					&lt;shipperDesc/&gt;
					&lt;subTerminalCode/&gt;
					&lt;transhipBOLId/&gt;
					&lt;transhipBookingRef/&gt;
					&lt;transhipDischargePort/&gt;
					&lt;transhipVesselName/&gt;
					&lt;transhipVoyageCode/&gt;
					&lt;vgmAuthSignature/&gt;
					&lt;vgmCommsType/&gt;
					&lt;vgmDocumentDetails/&gt;
					&lt;vgmEDITransmission/&gt;
					&lt;vgmElectronicMail/&gt;
					&lt;vgmMail/&gt;
					&lt;vgmPhone/&gt;
					&lt;vgmTelefax/&gt;
					&lt;vgmTelephone/&gt;
					&lt;voyageCode/&gt;
					&lt;weightCertifiedName/&gt;
					&lt;weightCertifiedReference/&gt;
					&lt;vgmDeterminationDT/&gt;
					&lt;vgmDocsIssuedDT/&gt;
					&lt;AllSealDetails&gt;
						&lt;SealDetails&gt;
							&lt;id&gt;'&amp;CONTAINERID&amp;'&lt;/id&gt;
							&lt;messageMode&gt;A&lt;/messageMode&gt;
							&lt;sealEDINum&gt;Seal01&lt;/sealEDINum&gt;
							&lt;sealEDIType&gt;OPER&lt;/sealEDIType&gt;
						&lt;/SealDetails&gt;
					&lt;/AllSealDetails&gt;
				&lt;/LoadDischargeList&gt;
			&lt;/AllLoadDischargeList&gt;
		&lt;/DataLoadList&gt;
	&lt;/AllDataLoadList&gt;
&lt;/JMTInternalLoadList&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;

	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 2, "incorrect number of EDI trackedItems");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tLoadList" id="71504004-60f8-4ecc-a282-6328b7fddce8">
        <source>tLoadList();
//
// 26 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
// 30 Apr 2019	jlgrs1	TFS40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
//
constants
	USER_DEF_NAME : String = "JMTInternalLoadList";
	VESSEL_CODE	: String = "UTXVES1";
	VOYAGE_CODE	: String = "UTXVOY1";
	VOYAGE_OUT : String = "VOYEXP32985Z";
	CONTAINER_ID01 : String = "TEST0000001";
	CONTAINER_ID02 : String = "TEST0000002";
	CONTAINER_ID03 : String = "TEST0000003";
	BlockStackName : String = "BS4462";
vars
	containerObj : CM_TrackedItem;
	vesselObj : CM_Vessel;
	voyageObj : CM_Voyage;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	operator : CM_Operator;
	ediTI : CM_EDITrackedItem;
	allTIs : ObjectArray;
	ti : CM_TrackedItem;
	str : String;
	str2 : String;
	bs : CM_BlockStack;
	lLCAgent : CM_LoadListComparisonAgent;
	voyageOut : CM_Voyage;
begin
	// turn off CertifiedWeightNeedsVGM
	self.setTerminalConfig(CertifiedWeightNeedsVGM, false);
	passportObj	:=	app.myPassport;
	create lLCAgent transient;
	///voyageOut := self.getVoyage(VOYAGE_OUT);
	self.deleteContainer(CONTAINER_ID01);
	containerObj := self.getTrackedItem(CONTAINER_ID01);
	self.assertIsDeleted(containerObj);
	self.deleteContainer(CONTAINER_ID02);
	containerObj := self.getTrackedItem(CONTAINER_ID02);
	self.assertIsDeleted(containerObj);
	self.deleteContainer(CONTAINER_ID03);
	containerObj := self.getTrackedItem(CONTAINER_ID03);
	self.assertIsDeleted(containerObj);
	// Create the Vessel and the Voyage.
	self.deleteVessel(VESSEL_CODE);
	vesselObj	:=	self.getVessel(VESSEL_CODE);
	self.assertIsDeleted(vesselObj);
	self.deleteVoyage(VOYAGE_CODE);
	voyageObj	:=	self.getVoyage(VOYAGE_CODE);
	self.assertIsDeleted(voyageObj);
	self.createVoyageVessel(VOYAGE_CODE, VESSEL_CODE, voyageObj, vesselObj);
	self.assertNotNullMsg(vesselObj, "Add vessel failed!");
	
	// 10/02/2020 jlgmh5 - For some reason this started failing.  Can't see the reason but it was becuase the voyage didn't exist.  Now create the voyage in this test.  
	// 					   Have tested this with the other tests that use this voyage and everything seems to be working correctly
	voyageOut := self.getVoyage(VOYAGE_OUT);
	if voyageOut = null then
		voyageOut := self.addVoyageWithContainerStructur(VOYAGE_OUT, VESSEL_CODE, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
		self.assertNotNull(voyageOut);
	endif;
	
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	operator := self.getOperator("MSK");
	containerObj := self.addContainer(CONTAINER_ID01, operator, "4102", "GOLD", TI_IMEX_STATUS_IMPORT).CM_Container;
	bs := addBlockStack(BlockStackName, 100, null);
	self.opts.addAssoc('IsForcedMove', true);
	self.move(containerObj, bs);
	self.opts.purge;
	self.opts.addAssoc("Voyage", voyageOut);
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_IMPORT);
	self.updateTI(containerObj);	
	beginTransaction;
	containerObj.setPropertyValue("imexStatus", TI_IMEX_STATUS_IMPORT);
	commitTransaction;
	self.setCargoAsTranshipTo(containerObj, voyageObj);
	self.deleteEDIInwardXlation("22ZZ", XLATION_TYPE_ISOTYPE_BYOP, operator, null);	
	self.createEDIXlation("22ZZ", "22G1", XLATION_TYPE_ISOTYPE_BYOP, false, operator, null);
	self.deleteEDIInwardXlation("MAERSK SEALAND", XLATION_TYPE_OPERATOR, null, null);	
	self.createEDIXlation("MAERSK SEALAND", "MSK", XLATION_TYPE_OPERATOR, false, null, null);
	self.deleteEDIInwardXlation("MAEU", XLATION_TYPE_OPERATOR, null, null);	
	self.createEDIXlation("MAEU", "MSK", XLATION_TYPE_OPERATOR, false, null, null);
//&lt;xlateOperatorCode&gt;MAEU&lt;/xlateOperatorCode&gt;
//&lt;operatorCode&gt;MAERSK SEALAND&lt;/operatorCode&gt;

	ediText :=
'
&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;SystemXMLLoadList&gt;
	&lt;AllDataLoadList&gt;
		&lt;DataLoadList&gt;
//&lt;operatorCode&gt;MAERSK SEALAND&lt;/operatorCode&gt;
			&lt;voyageCode&gt;'&amp;VOYAGE_CODE&amp;'&lt;/voyageCode&gt;
			&lt;listType&gt;L&lt;/listType&gt;
			&lt;AllLoadDischargeList&gt;
				&lt;LoadDischargeList&gt;
					&lt;weight&gt;2001&lt;/weight&gt;
					&lt;commodity&gt;GENL&lt;/commodity&gt;
					&lt;id&gt;'&amp;CONTAINER_ID01&amp;'&lt;/id&gt;
					&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
					&lt;isoType&gt;22ZZ&lt;/isoType&gt;
					&lt;dischargePort&gt;AUSYD&lt;/dischargePort&gt;
					&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
					&lt;operatorCode&gt;MAERSK SEALAND&lt;/operatorCode&gt;
					&lt;orderNumber&gt;111111OrderNum&lt;/orderNumber&gt;
					&lt;invoiceNumber&gt;111111InvoiceNum&lt;/invoiceNumber&gt;
					&lt;sealCustoms&gt;CUSTSEAL1&lt;/sealCustoms&gt;
					&lt;transhipPortCodes&gt;DEBRV DEHAM AUBRI&lt;/transhipPortCodes&gt;
				&lt;/LoadDischargeList&gt;
				&lt;LoadDischargeList&gt;
					&lt;weight&gt;2001&lt;/weight&gt;
					&lt;commodity&gt;GENL&lt;/commodity&gt;
					&lt;id&gt;'&amp;CONTAINER_ID02&amp;'&lt;/id&gt;
					&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
					&lt;isoType&gt;22ZZ&lt;/isoType&gt;
					&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
					&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
					&lt;operatorCode&gt;MAERSK SEALAND&lt;/operatorCode&gt;
					&lt;orderNumber&gt;222222OrderNum&lt;/orderNumber&gt;
					&lt;invoiceNumber&gt;222222InvoiceNum&lt;/invoiceNumber&gt;
					&lt;sealCustoms&gt;CUSTSEAL2&lt;/sealCustoms&gt;
					&lt;sealTerminalOperator&gt;TermOpSeal1&lt;/sealTerminalOperator&gt;
					&lt;sealTerminalOperator&gt;TermOpSeal2&lt;/sealTerminalOperator&gt;
					&lt;specialStowage&gt;UD&lt;/specialStowage&gt;
					&lt;AllSealDetails&gt;
						&lt;SealDetails&gt;
							&lt;sealEDIType&gt;SH&lt;/sealEDIType&gt;
							&lt;sealEDINum&gt;SH0031&lt;/sealEDINum&gt;
						&lt;/SealDetails&gt;
						&lt;SealDetails&gt;
							&lt;sealEDIType&gt;SHIP&lt;/sealEDIType&gt;
							&lt;sealEDINum&gt;SH0032&lt;/sealEDINum&gt;
						&lt;/SealDetails&gt;
					&lt;/AllSealDetails&gt;
				&lt;/LoadDischargeList&gt;
				&lt;LoadDischargeList&gt;
					&lt;weight&gt;2001&lt;/weight&gt;
					&lt;commodity&gt;GENL&lt;/commodity&gt;
					&lt;id&gt;'&amp;CONTAINER_ID03&amp;'&lt;/id&gt;
					&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
					&lt;isoType&gt;2200&lt;/isoType&gt;
					&lt;dischargePort&gt;NZAKL&lt;/dischargePort&gt;
					&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
					&lt;operatorCode&gt;MAERSK SEALAND&lt;/operatorCode&gt;
					&lt;orderNumber&gt;333333OrderNum&lt;/orderNumber&gt;
					&lt;invoiceNumber&gt;333333InvoiceNum&lt;/invoiceNumber&gt;
					&lt;sealCustoms&gt;CUSTSEAL3&lt;/sealCustoms&gt;
					&lt;sealTerminalOperator&gt;TermOpSeal3&lt;/sealTerminalOperator&gt;
				&lt;/LoadDischargeList&gt;
			&lt;/AllLoadDischargeList&gt;
		&lt;/DataLoadList&gt;
	&lt;/AllDataLoadList&gt;
&lt;/SystemXMLLoadList&gt;
';
//&lt;id&gt;'&amp;CONTAINER_ID01&amp;'&lt;/id&gt;
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertIsOneOf(ediFileObj.fileStatus, errorMsg, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	ediDataObj := ediFileObj.ediData;
	self.doLoadListComparison(lLCAgent, ediDataObj, TI_IMEX_STATUS_EXPORT, voyageObj);
	self.doUpdateFromLoadList(lLCAgent, ediDataObj, TI_IMEX_STATUS_EXPORT, voyageObj);

	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 10, "incorrect number of EDI trackedItems");
	create allTIs transient;
	foreach ediTI in ediFileObj.ediData.allEDITrackedItems do
		if ediTI.id &lt;&gt; CONTAINER_ID01 then
			allTIs.add(ediTI);
		endif;
	endforeach;
	app.myPassport.setWarningsIgnored(true);
	ediFileObj.ediData.CM_EDIDataLoadList.createPreNotes(allTIs, app.myPassport);

	// check the create Prenote has worked ok
	ti := self.getTrackedItem(CONTAINER_ID01);
	self.assertNotNull(ti);
	self.assertEqualMsg(ti.myTranshipDetail.getToPortsString(), "DEBRV DEHAM AUBRI", "Incorrect Tranship Discharge Ports");
	ti := self.getTrackedItem(CONTAINER_ID02);
	self.assertNotNull(ti);
	self.assertEqualMsg(ti.getSealNumTerminalOperator(), "TermOpSeal1", "Incorrect Terminal Operator Seal");
	self.assertEqualMsg(ti.getSealNumShipper(), "SH0031,SH0032", "Incorrect Shipper Seal");
	self.assertEqualMsg(ti.specialStow, "UD", "Special Stowage wrong");
//	self.assertEqualMsg(ti.getSealNumTerminalOperator(), "TermOpSeal2", "Incorrect Terminal Operator Seal");
	ti := self.getTrackedItem(CONTAINER_ID03);
	self.assertNotNull(ti);
	self.assertEqualMsg(ti.getSealNumTerminalOperator(), "TermOpSeal3", "Incorrect Terminal Operator Seal");
	foreach str in ediDataObj.allEDITrackedItems.first.CM_EDILoadListTI.transhipPortCodes   do
		str2 := str2&amp;str&amp;' ';
	endforeach;
	self.assertEqualMsg(str2, "DEBRV DEHAM AUBRI ", "incorrect tranship ports");
	
epilog
	delete allTIs;
	lLCAgent.allUnmatchedDBTIs.purge;
	lLCAgent.allDiscrepancyTIs.purge;
	lLCAgent.allMatchingTIs.purge;
	delete lLCAgent;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tMoveAction" id="79a7632c-39e4-4ea0-8c7e-119614ab4d56">
        <source>tMoveAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalMove";
	CONTAINERID : String = "SARG1234543";
	VOYAGECODE = 'VOY27418';
	VESSELNAME = 'SHIP27418';
	OPERATORCODE = 'MSK';
	BookingId1 = 'BK27418';
	BlockStackName1	= 'BS267_1';
	BlockStackName2	= 'BS267_2';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	bs : CM_BlockStack;
	container : CM_Container;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
begin
	passportObj := app.myPassport;
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID);
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertIsDeleted(container);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	self.deleteTerminalArea(BlockStackName1);
	bs := self.getTerminalArea(BlockStackName1).CM_BlockStack;
	self.assertIsDeleted(bs);
	self.deleteTerminalArea(BlockStackName2);
	bs := self.getTerminalArea(BlockStackName2).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Delete and add the required bookings
	self.opts.addAssoc('Stock', true);
	self.opts.addAssocIfNotNull(ETRow_PackAs, app.getString(PackAs_LCL));
	self.deleteBooking(BookingId1);
	container := self.addContainerOnShip(CONTAINERID, operator, "4102", "GOLD", BookingId1, voyage, self.getTerminal.getConfig(PortDestCode).String, "010682").CM_Container;
	bs := addBlockStack(BlockStackName2, 100, null);
	bs := addBlockStack(BlockStackName1, 100, null);
	self.opts.addAssoc('IsForcedMove', true);
	self.move(container, bs);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalMove xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalMove.xsd"&gt;
	&lt;AllMove&gt;
		&lt;Move&gt;
			&lt;moveType&gt;REAL&lt;/moveType&gt;
			&lt;quantity/&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;description/&gt;
			&lt;fullOrMT/&gt;
			&lt;id&gt;'&amp;CONTAINERID&amp;'&lt;/id&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;sourceLocn&gt;'&amp;BlockStackName1&amp;'&lt;/sourceLocn&gt;
			&lt;targetLocn&gt;'&amp;BlockStackName2&amp;'&lt;/targetLocn&gt;
		&lt;/Move&gt;
	&lt;/AllMove&gt;
&lt;/JMTInternalMove&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertNotNull(container);
	self.assertEqualMsg(container.locationId, BlockStackName2, "wrong remarks");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tMoveViaWeb" id="4523ed3a-4927-46c5-8f69-b7972b9a868b">
        <source>tMoveViaWeb();
// cnwmp6
/* Changes

Date		Name	TFS#		Description
============================================================================
Sep 2015	cnwjre1	Test EDI queued move for TFS 456 36912
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
============================================================================*/
constants
	USER_DEF_NAME : String = "JMTInternalMove";
	BSId1 : String = "UTRSBS1";
	BSId2 : String = "UTRSBS2";
	TiId1 : String = "UTTU0102201";
vars
	bs1,
	bs2	: CM_BlockStack;
	ti1 : CM_TrackedItem;
	oper		: CM_Operator;
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	ediControllerAgent : CM_EDIControllerAgent;
	binaryMsg : Binary;
	bSynchronous : Boolean;
	messageType : String;
	idx : Integer;
	clientRef : String;
	errorStr : String;
begin
	passportObj	:=	app.myPassport;
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	self.deleteTerminalArea(BSId1);
	self.deleteTerminalArea(BSId2);
	self.deleteContainer(TiId1);
	
	bs1 := self.addBlockStack(BSId1, 200, null);
	self.assertNotNull(bs1);
	bs2 := self.addBlockStack(BSId2, 200, null);
	self.assertNotNull(bs2);

	ti1 := self.addContainerAtLocation(TiId1, oper, "2200", "MT", TI_IMEX_STATUS_STORAGE, bs1);
	self.assertTrueMsg(ti1 &lt;&gt; null,TiId1 &amp; " not created - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal(self.getTerminal);
	// cargoType=1 is container, moveType=2 is QueuedMoved
	ediText :=
'
&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;JMTInternalMove&gt;
&lt;AllMove&gt;
&lt;Move&gt;
&lt;id&gt;' &amp; TiId1 &amp; '&lt;/id&gt;
&lt;cargoType&gt;1&lt;/cargoType&gt;
&lt;moveType&gt;2&lt;/moveType&gt;
&lt;targetLocn&gt;' &amp; BSId2 &amp; '&lt;/targetLocn&gt;
&lt;/Move&gt;
&lt;/AllMove&gt;
&lt;/JMTInternalMove&gt;
';

	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := USER_DEF_NAME;						// ie 63
	idx := idx + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;idx.String;		// ie 30
	ediControllerAgent.setEdiClientRef(clientRef);
	// make sure all of the objects are deleted and created correctly.
	ediFileObj := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFileObj &lt;&gt; null then
		beginTransaction;
		if ediFileObj.ediData = null then
			delete ediFileObj;
		else
			ediDataObj := ediFileObj.ediData;
			delete ediDataObj;
		endif;
		commitTransaction;
	endif;
	ediFileObj := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFileObj);
	
	// Load and DB load the message
	ediControllerAgent.loadMessageFromWeb(System_EDIFileType, binaryMsg, ediFileObj, bSynchronous, null); //jlgka1 TFS 45332
	errorStr := 'Failed to load edi data ';
	errorStr :=	errorStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, errorStr);
	// check that the container has been queued to the second block stack
	self.assertEqualMsg(ti1.getPrimaryLocation(QUEUE_MODE), bs2.myLocationsController, "Queued-to location");
epilog
	delete ediControllerAgent;
end;

</source>
    </JadeMethod>
    <JadeMethod name="tMultiMoveGroupAction" id="be5ae94d-36ec-4c26-9210-43ba99dd9f62">
        <source>tMultiMoveGroupAction();
//
//14 August 2017	jlgrs1	Initial creation
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	USER_DEF_NAME : String = "JMTInternalMultiMoveGroup";
	CONTAINERID1 : String = "SARG1234543";
	CONTAINERID2 : String = "SARG1234544";
	CONTAINERID3 : String = "SARG1234545";
	VOYAGECODE = 'VOY27418';
	VESSELNAME = 'SHIP27418';
	OPERATORCODE = 'MSK';
	BookingId1 = 'BK27418';
	BlockStackName	= 'BS26728';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	bs : CM_BlockStack;
	container : CM_Container;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	str : String;
	str2 : String;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID1);
	container := self.getTrackedItem(CONTAINERID1).CM_Container;
	self.assertIsDeleted(container);
	self.deleteContainer(CONTAINERID2);
	container := self.getTrackedItem(CONTAINERID2).CM_Container;
	self.assertIsDeleted(container);
	self.deleteContainer(CONTAINERID3);
	container := self.getTrackedItem(CONTAINERID3).CM_Container;
	self.assertIsDeleted(container);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Delete and add the required bookings
	self.opts.addAssoc('Stock', true);
	self.opts.addAssocIfNotNull(ETRow_PackAs, app.getString(PackAs_LCL));
	self.deleteBooking(BookingId1);
	bs := addBlockStack(BlockStackName, 100, null);
	container := self.addContainerOnShip(CONTAINERID1, operator, "4102", "GOLD", BookingId1, voyage, self.getTerminal.getConfig(PortDestCode).String, "010182").CM_Container;
	self.opts.addAssoc('IsForcedMove', true);
	self.move(container, bs);
	container := self.addContainerOnShip(CONTAINERID2, operator, "4102", "GOLD", BookingId1, voyage, self.getTerminal.getConfig(PortDestCode).String, "010282").CM_Container;
	self.opts.addAssoc('IsForcedMove', true);
	self.move(container, bs);
	container := self.addContainerOnShip(CONTAINERID3, operator, "4102", "GOLD", BookingId1, voyage, self.getTerminal.getConfig(PortDestCode).String, "010382").CM_Container;
	self.opts.addAssoc('IsForcedMove', true);
	self.move(container, bs);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalMultiMoveGroup xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalMultiMoveGroup.xsd"&gt;
	&lt;AllMultiMoveGroup&gt;
		&lt;MultiMoveGroup&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;description/&gt;
			&lt;fullOrMT/&gt;
			&lt;id/&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;targetLocation&gt;MMG2&lt;/targetLocation&gt;
			&lt;allCargoIds&gt;'&amp;CONTAINERID1&amp;' '&amp;CONTAINERID2&amp;' '&amp;CONTAINERID3&amp;'&lt;/allCargoIds&gt;
		&lt;/MultiMoveGroup&gt;
	&lt;/AllMultiMoveGroup&gt;
&lt;/JMTInternalMultiMoveGroup&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	foreach str in ediDataObj.allEDITrackedItems.first.CM_EDIMultiMoveGroup.allCargoIds do
		str2 := str2&amp;str&amp;' ';
	endforeach;
	self.assertEqualMsg(str2, "SARG1234543 SARG1234544 SARG1234545 ", "incorrect cargoids");

epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tOpCarrierAcessByCTAct" id="88f91f78-de8e-458e-ac7c-dd740e1eddcf">
        <source>tOpCarrierAcessByCTAct();
//
// 28 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
// 21 Aug 2019	jlgdap1	TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
// 12 Aug 2020	NDL	TFS 49908
constants
	USER_DEF_NAME : String = "JMTInternalOpCarrierAcessByCT";
	OPERATORCODE = 'MSK';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	bs : CM_BlockStack;
	carrierSet : CM_CarrierSet;
	carrierCargoType : Integer;
	carrier : CM_Carrier;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	str : String;
	str2 : String;
	opCrit : CM_OperatorCarrierCriteria;			// TFS 45836
begin
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);

	create carrierSet transient;
/*	carrierSet.clear;
	carrierCargoType := 1;
	foreach opCrit in operator.allOperatorCarrierCriteria do												// TFS 45836
		if opCrit.allCriteria.first.myYACriteriaType.type = YACriteriaType_CargoType then					// TFS 45836
			
			beginTransaction;																				// TFS 45836
			opCrit.allCarriers.clear;																		// TFS 45836
			commitTransaction;																				// TFS 45836
		endif;																								// TFS 45836
	endforeach;																								// TFS 45836

	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalOpCarrierAcessByCT xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalOpCarrierAcessByCT.xsd"&gt;
	&lt;AllDataOpCarrierAcessByCT&gt;
		&lt;DataOpCarrierAcessByCT&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;AllCarrierAccess&gt;
				&lt;CarrierAccess&gt;
					&lt;cargoTypeDescr&gt;1&lt;/cargoTypeDescr&gt;
					&lt;carrierCodes&gt;TRIPLE B&lt;/carrierCodes&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
				&lt;/CarrierAccess&gt;
				&lt;CarrierAccess&gt;
					&lt;cargoTypeDescr&gt;CONT&lt;/cargoTypeDescr&gt;
					&lt;carrierCodes&gt;TRIPLE C&lt;/carrierCodes&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
				&lt;/CarrierAccess&gt;
				&lt;CarrierAccess&gt;
					&lt;cargoTypeDescr&gt;2&lt;/cargoTypeDescr&gt;
					&lt;carrierCodes&gt;JJJ&lt;/carrierCodes&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
				&lt;/CarrierAccess&gt;
				&lt;CarrierAccess&gt;
					&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
					&lt;carrierCodes&gt;KKK&lt;/carrierCodes&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
				&lt;/CarrierAccess&gt;
				&lt;CarrierAccess&gt;
					&lt;cargoTypeDescr&gt;COU&lt;/cargoTypeDescr&gt;
					&lt;carrierCodes&gt;LLL&lt;/carrierCodes&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
				&lt;/CarrierAccess&gt;
				&lt;CarrierAccess&gt;
					&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
					&lt;carrierCodes&gt;MMM&lt;/carrierCodes&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
				&lt;/CarrierAccess&gt;
				&lt;CarrierAccess&gt;
					&lt;cargoTypeDescr&gt;ISO clip-on-unit&lt;/cargoTypeDescr&gt;
					&lt;carrierCodes&gt;NNN&lt;/carrierCodes&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
				&lt;/CarrierAccess&gt;
				&lt;CarrierAccess&gt;
					&lt;cargoTypeDescr&gt;Container&lt;/cargoTypeDescr&gt;
					&lt;carrierCodes&gt;OOO&lt;/carrierCodes&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
				&lt;/CarrierAccess&gt;
				&lt;CarrierAccess&gt;
					&lt;cargoTypeDescr&gt;BBLK&lt;/cargoTypeDescr&gt;
					&lt;carrierCodes&gt;OOO&lt;/carrierCodes&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
				&lt;/CarrierAccess&gt;
				&lt;CarrierAccess&gt;
					&lt;cargoTypeDescr&gt;Container&lt;/cargoTypeDescr&gt;
					&lt;carrierCodes&gt;DOUG&lt;/carrierCodes&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
				&lt;/CarrierAccess&gt;
				&lt;CarrierAccess&gt;
					&lt;cargoTypeDescr&gt;Container&lt;/cargoTypeDescr&gt;
					&lt;carrierCodes&gt;UT_OTHER&lt;/carrierCodes&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
				&lt;/CarrierAccess&gt;
				&lt;CarrierAccess&gt;
					&lt;cargoTypeDescr&gt;Container&lt;/cargoTypeDescr&gt;
					&lt;carrierCodes&gt;ABC&lt;/carrierCodes&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
				&lt;/CarrierAccess&gt;
			&lt;/AllCarrierAccess&gt;
		&lt;/DataOpCarrierAcessByCT&gt;
	&lt;/AllDataOpCarrierAcessByCT&gt;
&lt;/JMTInternalOpCarrierAcessByCT&gt;
'; */

	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalOpCarrierAcessByCT xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalOpCarrierAcessByCT.xsd"&gt;
	&lt;AllDataOpCarrierAcessByCT&gt;
		&lt;DataOpCarrierAcessByCT&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;AllCarrierAccess&gt;
				&lt;CarrierAccess&gt;
					&lt;cargoTypeDescr&gt;2&lt;/cargoTypeDescr&gt;
					&lt;carrierCodes&gt;JJJ LLL NNN&lt;/carrierCodes&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
				&lt;/CarrierAccess&gt;
				&lt;CarrierAccess&gt;
					&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
					&lt;carrierCodes&gt;KKK MMM OOO DOUG UT_OTHER ABC TRIPLE&lt;/carrierCodes&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
				&lt;/CarrierAccess&gt;
				&lt;CarrierAccess&gt;
					&lt;cargoTypeDescr&gt;BBLK&lt;/cargoTypeDescr&gt;
					&lt;carrierCodes&gt;OOO&lt;/carrierCodes&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
				&lt;/CarrierAccess&gt;
			&lt;/AllCarrierAccess&gt;
		&lt;/DataOpCarrierAcessByCT&gt;
	&lt;/AllDataOpCarrierAcessByCT&gt;
&lt;/JMTInternalOpCarrierAcessByCT&gt;
';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	//self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);					// TFS 45836
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						"Load Failed",
						CM_EDIFile.EDI_STATUS_DBLOADED,
						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
//	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 12, "incorrect number of EDI trackedItems");
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 3, "incorrect number of EDI trackedItems");	
	//carrierSet := operator.allCarriersByCargoTypeId.getAtKey(1).CM_CarrierSet;							// TFS 45836
	//self.assertEqualMsg(carrierSet.size, 8, "incorrect number of EDI carriers for CONT");					// TFS 45836
	foreach opCrit in operator.allOperatorCarrierCriteria do												// TFS 45836
		if opCrit.allCriteria.first.myYACriteriaType.type = YACriteriaType_CargoType 						// TFS 45836
		and opCrit.allCriteria.first.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType.id = 1 then	// TFS 45836
			self.assertEqualMsg(opCrit.allCarriers.size, 6, "incorrect number of EDI carriers for CONT");	// TFS 45836
		endif;																								// TFS 45836
	endforeach;																								// TFS 45836
	//carrierSet := operator.allCarriersByCargoTypeId.getAtKey(2).CM_CarrierSet;							// TFS 45836
	//self.assertEqualMsg(carrierSet.size, 3, "incorrect number of EDI carriers for COU");					// TFS 45836
	foreach opCrit in operator.allOperatorCarrierCriteria do												// TFS 45836
		if opCrit.allCriteria.first.myYACriteriaType.type = YACriteriaType_CargoType 						// TFS 45836
		and opCrit.allCriteria.first.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType.id = 2 then	// TFS 45836
			self.assertEqualMsg(opCrit.allCarriers.size, 3, "incorrect number of EDI carriers for COU");	// TFS 45836
		endif;																								// TFS 45836
	endforeach;																								// TFS 45836
	//carrierSet := operator.allCarriersByCargoTypeId.getAtKey(3).CM_CarrierSet;							// TFS 45836
	//self.assertEqualMsg(carrierSet.size, 1, "incorrect number of EDI carriers for BBLK");					// TFS 45836
	foreach opCrit in operator.allOperatorCarrierCriteria do												// TFS 45836
		if opCrit.allCriteria.first.myYACriteriaType.type = YACriteriaType_CargoType 						// TFS 45836
		and opCrit.allCriteria.first.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType.id = 3 then	// TFS 45836
			self.assertEqualMsg(opCrit.allCarriers.size, 1, "incorrect number of EDI carriers for BBLK");	// TFS 45836
		endif;																								// TFS 45836
	endforeach;																								// TFS 45836
	
	//TFS 49908 Now do check that a change to the carriers is treated as a replace, i.e. Delete existing xcarriers add back new set. 
	
	carrierSet.clear();
	carrierSet.add( app.myRoot.allCarriers.getAtKey("WILLYS") );
	carrierSet.add( app.myRoot.allCarriers.getAtKey("UT_OTHER") );
	carrierSet.add( app.myRoot.allCarriers.getAtKey("UTCARRIER") );
	
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalOpCarrierAcessByCT xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalOpCarrierAcessByCT.xsd"&gt;
	&lt;AllDataOpCarrierAcessByCT&gt;
		&lt;DataOpCarrierAcessByCT&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;AllCarrierAccess&gt;
				&lt;CarrierAccess&gt;
					&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
					&lt;carrierCodes&gt;WILLYS UT_OTHER UTCARRIER&lt;/carrierCodes&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
				&lt;/CarrierAccess&gt;
			&lt;/AllCarrierAccess&gt;
		&lt;/DataOpCarrierAcessByCT&gt;
	&lt;/AllDataOpCarrierAcessByCT&gt;
&lt;/JMTInternalOpCarrierAcessByCT&gt;
';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	
	self.assertNotNull(ediFileObj.ediData);		
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed - Second run" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						"Load Failed - Second run",
						CM_EDIFile.EDI_STATUS_DBLOADED,
						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed - Second run" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems - Second run");	
	foreach opCrit in operator.allOperatorCarrierCriteria do												
		if opCrit.allCriteria.first.myYACriteriaType.type = YACriteriaType_CargoType 						
		and opCrit.allCriteria.first.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType.id = 1 then	
			self.assertEqualMsg(opCrit.allCarriers.size, 3, "incorrect number of EDI carriers for CONT - Second run");
			foreach carrier in carrierSet do
				self.assertTrueMsg(opCrit.allCarriers.includes(carrier), "Carrier '" &amp; carrier.code &amp; "' missing from CONT - Second run");
			endforeach;
		endif;																								
	endforeach;	
	
	carrierSet.clear();
	//KKK MMM OOO DOUG UT_OTHER ABC
	carrierSet.add( app.myRoot.allCarriers.getAtKey("KKK") );
	carrierSet.add( app.myRoot.allCarriers.getAtKey("MMM") );
	carrierSet.add( app.myRoot.allCarriers.getAtKey("OOO") );
	carrierSet.add( app.myRoot.allCarriers.getAtKey("DOUG") );
	carrierSet.add( app.myRoot.allCarriers.getAtKey("UT_OTHER") );
	carrierSet.add( app.myRoot.allCarriers.getAtKey("ABC") );
	
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalOpCarrierAcessByCT xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalOpCarrierAcessByCT.xsd"&gt;
	&lt;AllDataOpCarrierAcessByCT&gt;
		&lt;DataOpCarrierAcessByCT&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;AllCarrierAccess&gt;
				&lt;CarrierAccess&gt;
					&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
					&lt;carrierCodes&gt;KKK MMM OOO DOUG UT_OTHER ABC&lt;/carrierCodes&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
				&lt;/CarrierAccess&gt;
			&lt;/AllCarrierAccess&gt;
		&lt;/DataOpCarrierAcessByCT&gt;
	&lt;/AllDataOpCarrierAcessByCT&gt;
&lt;/JMTInternalOpCarrierAcessByCT&gt;
';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	
	self.assertNotNull(ediFileObj.ediData);		
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed - Third run" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
	self.assertIsOneOf(	ediFileObj.fileStatus,
						"Load Failed - Third run",
						CM_EDIFile.EDI_STATUS_DBLOADED,
						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed - Third run" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems - Third run");	
	foreach opCrit in operator.allOperatorCarrierCriteria do												
		if opCrit.allCriteria.first.myYACriteriaType.type = YACriteriaType_CargoType 						
		and opCrit.allCriteria.first.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType.id = 1 then	
			self.assertEqualMsg(opCrit.allCarriers.size, 6, "incorrect number of EDI carriers for CONT - Third run");
			foreach carrier in carrierSet do
				self.assertTrueMsg(opCrit.allCarriers.includes(carrier), "Carrier '" &amp; carrier.code &amp; "' missing from CONT - Third run");
			endforeach;
		endif;																								
	endforeach;		
	
	
epilog
//	create carrierSet transient;
//	carrierSet.clear;
//	carrierCargoType := 1;
/*	foreach opCrit in operator.allOperatorCarrierCriteria do												// TFS 45836
		if opCrit.allCriteria.first.myYACriteriaType.type = YACriteriaType_CargoType 						// TFS 45836
		and opCrit.allCriteria.first.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType.id = 1 then	// TFS 45836
			beginTransaction;																				// TFS 45836
			opCrit.allCarriers.clear;																		// TFS 45836
			commitTransaction;																				// TFS 45836
		elseif (opCrit.allCriteria.first.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType.id = 2 	// TFS 45836
		or opCrit.allCriteria.first.myYAData.CM_YADataObjects.allObjects.first.CM_CargoType.id = 3) then	// TFS 45836
			beginTransaction;																				// TFS 45836
			delete opCrit;																					// TFS 45836
			commitTransaction;																				// TFS 45836
		endif;																								// TFS 45836
	endforeach;	*/																						// TFS 45836
	//app.myTrxUA.trxUpdateOperatorAdvSettings(operator, null, null, carrierSet, carrierCargoType, app.myPassport);
	delete carrierSet;
end;</source>
