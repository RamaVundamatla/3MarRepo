    <JadeMethod name="populateCombos" id="c997b737-62ea-4437-b56b-a079bb646e46">
        <source>populateCombos();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 March 2018	jlgndl1	Initial creation	TFS 37437
19 Sept 2022 	navrk21 Bug 54841: MTN - Work Point Rate Error
*/

vars

	index : Integer;
	voyTfrType : CM_VoyageJobTransferType;

begin

	self.cmbJobType.clear();
	self.cmbJobType.itemData[ self.cmbJobType.addItem( app.getErrorString(Default) ) ] := -1;
	self.cmbJobType.itemData[ self.cmbJobType.addItem( app.getErrorString(SHP_Discharge) ) ] := JOB_TYPE_DISCHARGE;
	self.cmbJobType.itemData[ self.cmbJobType.addItem( app.getErrorString(SHP_Load) ) ] := JOB_TYPE_LOAD;
	self.cmbJobType.itemData[ self.cmbJobType.addItem( app.getErrorString(SHP_Shift_On_Board) ) ] := JOB_TYPE_SOB;
	self.cmbJobType.listIndex := 1;
	
	
	self.cmbTransferType.clear();
	foreach voyTfrType in app.myRoot.allVoyageJobTransferTypes do
		if voyTfrType.id= 0 then
			continue;
		endif;
		self.cmbTransferType.itemData[ self.cmbTransferType.addItem( voyTfrType.description ) ] := voyTfrType.id;
	endforeach;
	//self.cmbTransferType.listIndex := -1;	// 19.09.2022 navrk21 TFS 54841
	self.cmbTransferType.listIndex := self.cmbTransferType.findItemData(1);	// 19.09.2022 navrk21 TFS 54841
	
	self.cmbCargoType.clear();
	self.cmbCargoType.myTerminal := self.myTerminal;
	
	
	self.rePopulateProducts();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateRatesTable" id="5a214d58-9290-4f67-a38d-7a99322a7969">
        <updating/>
        <source>populateRatesTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2018	jlgndl1	Initial creation	TFS 37437

*/

vars

	iter : Iterator;
	wpCargoRate : CM_WorkPointCargoRates;
	entTableDef	: EntTableDef;

begin

	self.tblRates.clear();
	entTableDef := app.myController.getEntTableDef(ETDef_WorkPointRate);
	self.tblRates.setTblDataEntRowsArray(entTableDef, null, self.xmlStrTblRate);
	
	self.tblRates.selectMode := Table.SelectMode_CurrentRow;
	
	iter := self.myWorkPoint.allWorkPointRates.createIterator;
	while iter.next( wpCargoRate ) do
		self.tblRates.addItemObject( wpCargoRate, wpCargoRate.getAttributeStringForDefArray(self.tblRates.allTblDataEntRows) );
	endwhile;
	
	self.clearDetails();
	
	self.frmDetail.enabled := false;
	self.mode := Mode_View;
	self.setupButtons();
	
	self.tblRates.column := 1;
	self.tblRates.row := 1;
	

epilog

	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="rePopulateProducts" id="9ee9b24e-17ba-4304-8b57-4eeec81f4897">
        <source>rePopulateProducts();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2018	jlgndl1	Initial creation

*/

vars

	cargoType : CM_CargoType;

begin

	self.cmbProduct.setCargoType( null );
	self.cmbProduct.clear();
	self.cmbProduct.enabled := false;
	self.lblProduct.enabled := false;
	
	cargoType := self.cmbCargoType.listObject.CM_CargoType;
	if cargoType = null or cargoType.allProducts.isEmpty then
		self.setWeightVolQtyForCargoType();
		return;
	endif;
	
	self.cmbProduct.enabled := true;
	self.lblProduct.enabled := true;
	self.cmbProduct.setCargoType( cargoType );
	
	self.setWeightVolQtyForCargoType();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyWorkPoint" id="74440cb9-fafa-406f-aeca-cbc34f9c49a7">
        <updating/>
        <source>setMyWorkPoint( _workPoint : CM_WorkPoint ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2018	jlgndl1	Initial creation

*/

vars

begin

	self.myWorkPoint := _workPoint;

epilog

end;</source>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="09985880-1d5f-4ab7-accd-e53b03ec082e">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2018	jlgndl1	Initial creation	TFS 37437

*/

vars

begin

	self.xmlStrTblRate := self.tblRates.getXmlStrForColumns(true);
	self.populateRatesTable();

epilog

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setWeightVolQtyForCargoType" id="a9e2bdb2-8cc1-4309-920a-8e59fde11b68">
        <source>setWeightVolQtyForCargoType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2018	jlgndl1	Initial creation	TFS 37437

*/

vars

	cargoType : CM_CargoType;
	product : CM_Product;
	measurementType : CM_MeasurementType;

begin

	self.lblTargetQuantity.visible := false;
	self.lblTargetVolume.visible := false;
	self.lblTargetWeight.visible := false;
	self.txtTargetQuantity.visible := false;
	self.tblTargetVolume.visible := false;
	self.tblTargetWeight.visible := false;
	
	cargoType := self.cmbCargoType.listObject.CM_CargoType;
	if cargoType = null then
		return;
	endif;
	
	if self.cmbProduct.enabled and self.cmbProduct.listIndex &gt; 0 then
		product := self.cmbProduct.listObject.CM_Product;
	endif;
	
	if cargoType.isTrackByWeight then
		if product &lt;&gt; null then
			measurementType := product.getDefaultMeasurementForType( Type_Weight );
		else
			measurementType := cargoType.getDefaultMeasurementForType( Type_Weight );
		endif;
		
		self.tblTargetWeight.setValues(app.convertMeasurementForDisplay(measurementType.shortName, null) &amp; Space &amp; measurementType.shortName);
		self.lblTargetWeight.visible := true;
		self.tblTargetWeight.visible := true;
		
	elseif cargoType.isTrackByVolume then
		if product &lt;&gt; null then
			measurementType := product.getDefaultMeasurementForType( Type_Volume );
		else
			measurementType := cargoType.getDefaultMeasurementForType( Type_Volume );
		endif;
		
		self.tblTargetVolume.setValues(app.convertMeasurementForDisplay(measurementType.shortName, null) &amp; Space &amp; measurementType.shortName);
		self.lblTargetVolume.visible := true;
		self.tblTargetVolume.visible := true;
		
	else
		self.lblTargetQuantity.visible := true;
		self.txtTargetQuantity.visible := true;
		
	endif;
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupButtons" id="a8fd1128-d231-4a16-89dc-4dcad7300d8d">
        <source>setupButtons();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2018	jlgndl1	Initial creation

*/

vars

begin

	if not self.allowUpdate then
		self.btnDoAdd.enabled := false;
		self.btnDoUpdate.enabled := false;
		self.btnDoSave.enabled := false;
		self.btnDoDelete.enabled := false;
		return;
	endif;

	self.btnDoAdd.enabled := not self.frmDetail.enabled;
	self.btnDoUpdate.enabled := self.tblRates.row &gt; self.tblRates.fixedRows and not self.frmDetail.enabled;
	self.btnDoSave.enabled := self.frmDetail.enabled and ( self.mode = self.Mode_Add or self.mode = self.Mode_Update );
	self.btnDoDelete.enabled := self.btnDoUpdate.enabled;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="32b8f07f-70ce-4af8-822f-7d603034b587">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2018	jlgndl1	Initial creation

*/

vars

	str : String;

begin

	create self.myAssistant transient;
	
	self.allowUpdate := app.myPassport.myUser.canDo(self.myTerminal,PmAdmWorkPointMaint);
	
	self.minimumHeight := 530;
	self.minimumWidth := 585;
	
	self.frmMain.left := 0;
	self.frmMain.top := 0;
	self.frmMain.width := self.clientWidth;
	self.frmMain.height := self.clientHeight;
	self.frmMain.parentAspect := 3; //Stretch Both
	
	self.centreOverParent(1);
	
	self.tblTargetWeight.setup(Type_Weight, self.backColor);
	self.tblTargetWeight.tabKey := J_key_Tab;
	
	self.tblTargetVolume.setup(Type_Volume, self.backColor);
	self.tblTargetVolume.tabKey := J_key_Tab;
	
	inheritMethod();
	
	if self.myWorkPoint = null then
		app.msgBox( "No Workpoint selected!", app.getErrorString(Error), MsgBox_OK_Only );
		self.unloadForm();
		return;
	endif;
	
	str := self.myWorkPoint.getName &amp; " " &amp; app.getErrorString(Rate);
	if self.myWorkPoint.description.trimBlanks &lt;&gt; null then
		str := str &amp; " (" &amp; self.myWorkPoint.description.trimBlanks &amp; ")";
	endif;
	setCaption( str );
	
	self.populateRatesTable();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblRates_contextMenu" id="5fa3953f-ac79-457d-ba6b-6eed0ddff96c">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblRates_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2018	jlgndl1	Initial creation

*/

vars

begin

	self.mnuInspect.visible := false;

	self.mnuColumnOrg.visible := true;
	self.mnuColumnOrg.userObject := self.tblRates;
	if app.isAllowedToInspect then
		self.mnuInspect.userObject := self.tblRates.accessRow(self.tblRates.row).itemObject;
		self.mnuInspect.visible := true;
	endif;
	
	return self.showContextMenu(mnuContext, table, conwin, mouse, x, y);


epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
