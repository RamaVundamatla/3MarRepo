    <JadeMethod name="getDisplayStringForAttribute" id="f615fc61-aa7d-4a69-9c55-213f54af989f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders

*/

vars

begin
	if _attrName = ETRow_Type then
		return self.getWorkOrderTypeDescription();
	elseif _attrName = ETRow_RequiresApproval then
		return self.requiresApproval.getYes();
	endif;
	
	return inheritMethod(_attrName, _short);
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWodClass" id="be5d3f4b-f879-4ca1-a6bb-6374ac64daed">
        <source>getWodClass(_woType : Integer):Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
20 Feb 2023 navma1  ChangeRequest 56637: EUP - Add VAS WorkOrder Detail Types
*/

vars
	cls : Class;
begin
	if _woType = WorkOrderMode_Voyage then
		if self.id  = WO_TASK_SHIFTMOVEMENT then
			cls := CM_WodShiftMovement;
		elseif self.id = WO_TASK_PERMIT then
			cls := CM_WodPermitRequest;
		elseif self.id = WO_TASK_TIMECHANGE then
			cls := CM_WodTimeChange ;
		elseif self.id = WO_TASK_EXTENSION then
			cls := CM_WodExtension ;
		elseif self.id = WO_TASK_WATER then
			cls := CM_WodWaterRequest ;
		elseif self.id = WO_TASK_HMSCANCEL then
			cls := CM_WodHMSRequestCancel ;
		elseif self.id = WO_TASK_BILLINGADJ then 
			cls := CM_WodBillingAdjustment ;
		elseif self.id = WO_TASK_CARGOINITIAL then 
			cls := CM_WodVoyageCargoRequest ;
		else
			app.raiseUnexpectedProgramError(self.class.name, method.name, "Unexpected Task Type");
		endif;
	elseif _woType = WorkOrderMode_Cargo then
		if self.id  = WO_TASK_MOVE then
			cls := CM_WodMove;
		elseif self.id = WO_TASK_PACK then
			cls := CM_WodPack;
		elseif self.id = WO_TASK_UNPACK then
			cls := CM_WodUnpack;
		elseif self.id = WO_TASK_EXPORTRETURN then
			cls := CM_WodExportReturn;
		elseif self.id = WO_TASK_CHANGEVOYAGE then
			cls := CM_WodNullVoyage;
		elseif self.id = WO_TASK_RECEIVE then
			cls := CM_WodReceive;
		elseif self.id = WO_TASK_RELEASE then
			cls := CM_WodRelease;
		elseif self.id = WO_TASK_TODO then
			cls := CM_WodToDo;
		elseif self.id = WO_TASK_RELEASEEXTENSION then
			cls := CM_WodReleaseExtension;
		else
			app.raiseUnexpectedProgramError(self.class.name, method.name, "Unexpected Task Type");
		endif;
		
	elseif _woType = WorkOrderMode_ToDo then					//20.02.2023 navma1 #56637
		if self.id  = WO_TASK_ToDo_TRAIN then
			cls := CM_WodToDoTrain;
		elseif self.id = WO_TASK_ToDo_NONOPS then
			cls := CM_WodToDoNonOperational;
		elseif self.id = WO_TASK_ToDo_TRUCK then
			cls := CM_WodToDoVehicleVisit;
		elseif self.id = WO_TASK_ToDo_VBS then
			cls := CM_WodToDoVBS;
		elseif self.id = WO_TASK_ToDo_VOYAGE then
			cls := CM_WodToDoVoyage;
		elseif self.id = WO_TASK_ToDo_WAGON then
			cls := CM_WodToDoWagon;								//20.02.2023 navma1 #56637
		else
			app.raiseUnexpectedProgramError(self.class.name, method.name, "Unexpected Task Type");
		endif;
	endif;	
	return cls;
	
epilog

end;</source>
        <Parameter name="_woType" type="Integer"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getWorkOrderTaskIdByClass" id="d3e5567c-9470-4076-a40d-d24b2ffc1344">
        <source>getWorkOrderTaskIdByClass(_woType : Integer ;_wodClass : Class):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
20 Feb 2023 navma1 ChangeRequest 56637: EUP - Add VAS WorkOrder Detail Types
*/

vars
	wodTaskId : Integer;
begin
	if _woType = WorkOrderMode_Cargo then
		if _wodClass = CM_WodMove then
			wodTaskId := WO_TASK_MOVE;
		elseif  _wodClass = CM_WodNullVoyage then
			wodTaskId := WO_TASK_CHANGEVOYAGE;
		elseif  _wodClass = CM_WodPack then
			wodTaskId := WO_TASK_PACK;
		elseif  _wodClass = CM_WodUnpack then
			wodTaskId := WO_TASK_UNPACK;
		elseif  _wodClass = CM_WodReceive then
			wodTaskId := WO_TASK_RECEIVE;	
		elseif  _wodClass = CM_WodRelease then
			wodTaskId := WO_TASK_RELEASE;	
		elseif  _wodClass = CM_WodReleaseExtension then
			wodTaskId := WO_TASK_RELEASEEXTENSION;	
		elseif  _wodClass = CM_WodToDo then
			wodTaskId := WO_TASK_TODO;	
		endif;
		
	elseif _woType = WorkOrderMode_Voyage then
		
		
	elseif _woType = WorkOrderMode_ToDo then						//20.02.2023 navma1 #56637
		if _wodClass = CM_WodToDoNonOperational then
			wodTaskId := WO_TASK_ToDo_NONOPS;
		elseif  _wodClass = CM_WodToDoTrain then
			wodTaskId := WO_TASK_ToDo_TRAIN;
		elseif  _wodClass = CM_WodToDoVehicleVisit then
			wodTaskId := WO_TASK_ToDo_TRUCK;
		elseif  _wodClass = CM_WodToDoVoyage then
			wodTaskId := WO_TASK_ToDo_VOYAGE;
		elseif  _wodClass = CM_WodToDoWagon then
			wodTaskId := WO_TASK_ToDo_WAGON;	
		endif;
	endif;														    //20.02.2023 navma1 #56637
	
	return wodTaskId;
epilog

end;</source>
        <Parameter name="_woType" type="Integer"/>
        <Parameter name="_wodClass" type="Class"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWorkOrderTypeDescription" id="5e54bec7-83fc-49ef-aa9d-028c6789a07c">
        <source>getWorkOrderTypeDescription():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
22 Dec 2022 navhl20 Defect 56025[56637]: EUP - VAS Work order details type are missing from WMAST
20 Feb 2023 navma1  ChangeRequest 56637: EUP - Add VAS WorkOrder Detail Types
*/

vars

begin
	
	if self.type = WorkOrderMode_Cargo then
		return app.getErrorString(WorkOrder_Type_cargo);
	elseif self.type = WorkOrderMode_Voyage then
		return app.getErrorString(WorkOrder_Type_Voyage);
	else 
		return app.getErrorString(WorkOrder_Type_ToDo);
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
