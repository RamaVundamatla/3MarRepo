    <JadeMethod name="showStowage" id="02d44877-c02b-4377-8869-31ae17841623">
        <updating/>
        <source>showStowage() updating, protected;
// this uses a temporary table, to be replaced with a proper CM_DataTable once the stowage classes have been added
vars
	indx : Integer;
	cargoType : String;
	weight : Integer;
	qty : Integer;
	hatch : CM_GeneralCargoController;
	ti	: CM_TrackedItem;
begin
	self.tblStowagePlan.rows := self.tblStowagePlan.fixedRows;
	self.tblStowageItems.rows := self.tblStowageItems.fixedRows;
	self.tblStowagePlan.addItem("Location" &amp; Tab &amp; "Cargo Type" &amp; Tab &amp; " Weight" &amp; Tab &amp; "Qty");
	self.tblStowagePlan.accessRow(1).backColor := self.colorHeadingColumn;
	self.btnStowageSearch.enabled := false;
	self.btnStowageEdit.enabled := false;
	self.btnStowageDelete.enabled := false;
	self.btnStowItmSearch.enabled := false;
	self.btnStowItmEdit.enabled := false;
	self.btnStowItmDelete.enabled := false;
	self.hasStowage := false;
	
	if self.myCurrentVoyage = null or self.myCurrentVoyage.myGeneralCargoVoyage = null then
		return;
	endif;
	
	foreach hatch in self.myCurrentVoyage.myGeneralCargoVoyage.allLocationsByHatchPlace do
		cargoType := "";
		qty := 0;
		weight := 0;
		if hatch.allTrackedItems.size &gt; 0 then
			self.hasStowage := true;
			foreach ti in hatch.allTrackedItems do
				cargoType := ti.cargoTypeDescr;
				qty := qty + ti.quantity;
				weight := weight + ti.totalWeight.Integer;
			endforeach;
			indx := self.tblStowagePlan.addItem(hatch.getID() &amp; Tab &amp; cargoType &amp; Tab &amp; weight.asStringJMT &amp; Tab &amp; qty.asStringJMT);
			self.tblStowagePlan.accessRow(indx).itemObject := hatch;
		endif;
	endforeach;
	
	self.btnStowageSearch.enabled := self.hasStowage;
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showStowageCargo" id="2bd5b48f-6346-4b43-b645-58e2d787b8be">
        <source>showStowageCargo() protected;

vars
	count,
	rowIdx	: Integer;
	obj : CM_Object;
	ti	: CM_TrackedItem;
begin
	if self.myCurrentHatch = null then
		return;
	endif;

	self.btnStowItmEdit.enabled := false;
	self.btnStowItmDelete.enabled := false;
	self.tblStowageItems.rows := self.tblStowageItems.fixedRows;

	foreach ti in self.myCurrentHatch.allTrackedItems do
		count := count + 1;
		if self.includeStowageItems(ti) then
			obj := ti;
			self.addItemObjectToTable(obj, self.tblStowageItems);
		endif;
	endforeach;
	self.btnStowItmSearch.enabled := (count &gt; 0);
end;
</source>
        <access>protected</access>
    </JadeMethod>
