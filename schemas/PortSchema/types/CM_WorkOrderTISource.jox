    <JadeMethod name="proxyRemoveWoRequest" id="9d37f966-d3e4-4d7a-aa36-8dcad0821d79">
        <updating/>
        <source>proxyRemoveWoRequest(_woRequest : CM_WorkOrderRequestByType input) updating;
// -----------------------------------------------------------------------------
// Created:		05 August 2009 by consw1
//
// Purpose:		Unlink Request from Source.  Note that the Request will need to be deleted if no longer wanted.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin

	if _woRequest = null then
		return;
	endif;

	self.raiseExceptionIfNotTransient(method);

	_woRequest.raiseExceptionIfNotTransient(method);

	if _woRequest.myWorkOrderTISource &lt;&gt; self then
		app.raiseUnexpectedProgramError(class.name, method.name, "Request does not belong to Source");
	endif;
	
	self.allWORequestByType.remove(_woRequest);
	
epilog

end;</source>
        <Parameter name="_woRequest" type="CM_WorkOrderRequestByType" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="3f4eabf0-d896-4b37-9787-0c5feb4ec0ca">
        <source>pxyCreateUpdateProxy(): SelfType;
// -----------------------------------------------------------------------------
// Created:		05 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// -----------------------------------------------------------------------------

vars
	pxy : SelfType;
	woRequest : CM_WorkOrderRequestByType;
	completedOK		: Boolean;
	
begin
	pxy := inheritMethod();

	self.allBookings.copy(pxy.allBookings);
	self.allBulkReleases.copy(pxy.allBulkReleases);
	self.allSourceWorkOrders.copy(pxy.allSourceWorkOrders);
	
	foreach woRequest in self.allWORequestByType do
		pxy.allWORequestByType.add( app.createUpdateProxy(woRequest).CM_WorkOrderRequestByType );
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="removeTrackedItemFromParent" id="037e845e-ab59-439b-b71d-956bb32aafd9">
        <source>removeTrackedItemFromParent( _ti : CM_TrackedItem);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwrd1	Initial creation

*/

vars
	
begin

	if _ti = null then
		return;
	endif;
	
	if self.myParent = null then
		return;
	endif;

	if  CM_WorkOrderTI.hasInstance(self.myParent) then
		self.myParent.CM_WorkOrderTI.removeTrackedItem(_ti);
	elseif CM_WodPack.hasInstance(self.myParent) then
		//nothing here yet
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="5a873021-62e7-44e1-9c5f-091af9d2fe35">
        <updating/>
        <source>setForCreate( _pxyTISource : CM_WorkOrderTISource) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwrd1	Initial creation

*/

vars

begin

	self.setForUpdate( _pxyTISource );
epilog

end;</source>
        <Parameter name="_pxyTISource" type="CM_WorkOrderTISource"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d8edeaa2-e07e-4816-91fd-5af7a37f35d0">
        <updating/>
        <source>setForUpdate ( _pxyTISource : CM_WorkOrderTISource) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwrd1	Initial creation
11 June 2018 	jlger1	tfs 38947 make sure the ti.allWorkOrders is set and removed at the right statuses
*/

vars
	proxyRequest	  : CM_WorkOrderRequestByType;
	realRequest 	  : CM_WorkOrderRequestByType;
	requestColl		  : CM_WorkOrderRequestByTypeSet;
	ti				  : CM_TrackedItem;
	parentTIWorkOrder : CM_WorkOrderTI;
	tiList  		  :  HugeStringArray;
begin

	if self.myParent.isKindOf(CM_WorkOrderTI) then
		parentTIWorkOrder:=self.myParent.CM_WorkOrderTI;
			//epr TFS 42924 8/2/19
		if parentTIWorkOrder.taskStatus &gt;= WO_STATUS_PENDING and 
			parentTIWorkOrder.taskStatus &lt;&gt; WO_STATUS_CANCELLED then
			// need to update the work order if the TI list has changed.
			create tiList transient;	
			self.tiTextList.parseCSV(tiList);
			
			if self.tiTextList &lt;&gt; _pxyTISource.tiTextList or
				tiList.size &lt;&gt; parentTIWorkOrder.allTIs.size then  // if was created at user entry and the change change status to approved then the old and new ti list size is the same
				parentTIWorkOrder.updateFromSourceTIlist(self.tiTextList, _pxyTISource.tiTextList );
			endif;	
		else
			//changed to user entry or cancelled make sure it removes the cargos reference to work order
			foreach ti in parentTIWorkOrder.allTIs discreteLock do
				parentTIWorkOrder.removeTrackedItem(ti);
			endforeach;
		endif;
	endif;
	self.cargoType := _pxyTISource.cargoType;
	self.tiTextList := _pxyTISource.tiTextList;

	self.allBookings.clear(); 
	_pxyTISource.allBookings.copy( self.allBookings );
	
	self.allBulkReleases.clear();
	_pxyTISource.allBulkReleases.copy( self.allBulkReleases );
	
	self.allSourceWorkOrders.clear();
	_pxyTISource.allSourceWorkOrders.copy( self.allSourceWorkOrders );
	self.allSourceWorkOrders.removeInvalidObjects();

	//  Add/Update requests
	
	create requestColl transient;
	
	foreach proxyRequest in _pxyTISource.allWORequestByType do
		realRequest := proxyRequest.pxyGetRealObject();
		if realRequest = null then
			create realRequest persistent;
			realRequest.setForCreate(proxyRequest);
			self.allWORequestByType.add(realRequest);
		else
			realRequest.setForUpdate(proxyRequest);
		endif;
		requestColl.add(realRequest);
	endforeach;
	
	//  Delete requests that have been removed

	foreach realRequest in self.allWORequestByType where not requestColl.includes(realRequest) do
		delete realRequest;
	endforeach;

epilog
	delete requestColl;
	delete tiList;
end;</source>
        <Parameter name="_pxyTISource" type="CM_WorkOrderTISource"/>
    </JadeMethod>
    <JadeMethod name="setMyParent" id="4552f6d7-8b54-44cd-b750-2bde740e4672">
