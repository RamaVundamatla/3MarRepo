	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realVesselRampPositionType);

	if _passport.noErrors and realVesselRampPositionType.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Vessel Ramp Position Type', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVesselRampPositionType, true);
	endif;
	
	if _passport.noErrors then
		realVesselRampPositionType.setForUpdate(_vesselRampPositionType);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVesselRampPositionType, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="_vesselRampPositionType" type="CM_VesselRampPositionType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVesselSection" id="04a6a99b-77c0-4be8-97b3-f8460404a9b2">
        <source>utlUpdateVesselSection(_proxyVesselSection: CM_VesselSection; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

	realVesselSection	: CM_VesselSection;
	expectedEdition	: Integer;

begin
	self.initialiseActivity();

