    <JadeMethod name="setLastYABlock" id="4ea5d7a0-5892-4db1-9788-2bef95a12c06">
        <updating/>
        <source>setLastYABlock(_yaBlock : CM_YABlock; _isIn : Boolean) updating;
// -------------------------------------------
// Created 04 May 2005 by cnwdvb1
// -------------------------------------------
vars

	tmpGroup : CM_YABlockGroup;

begin

	// Par 14730 Needed to set other end to null
	if _isIn then
		if _yaBlock &lt;&gt; null then
			tmpGroup := _yaBlock.myLastBlockGroupIn;
			if tmpGroup &lt;&gt; null then
				tmpGroup.setPropertyValue(CM_YABlockGroup::myLastYABlockIn.name, null);
			endif;
		endif;
		self.myLastYABlockIn := _yaBlock;
		
	else
		if _yaBlock &lt;&gt; null then
			tmpGroup := _yaBlock.myLastBlockGroupOut;
			if tmpGroup &lt;&gt; null then
				tmpGroup.setPropertyValue(CM_YABlockGroup::myLastYABlockOut.name, null);
			endif;
		endif;
		self.myLastYABlockOut := _yaBlock;
	endif;

end;</source>
        <Parameter name="_yaBlock" type="CM_YABlock"/>
        <Parameter name="_isIn" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="218e8dc3-2220-4c3c-9faf-7fa4183ec8d8">
        <updating/>
        <source>setProxy(	_description:String;
			_allBlocksIn:CM_YABlockArray;
			_allBlocksOut:CM_YABlockArray) updating;
// --------------------------------------------------------------------------------
// Created:		10 May 2006 by cnwdad1
//
// Purpose:		Standard method for setting the data of a proxy object.
//
// Parameters:	Each parameter corresponds to the receiver's properties/references.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.description	:=	_description;
	
	self.allYABlocksIn.clear();
	_allBlocksIn.copy(self.allYABlocksIn);
	
	self.allYABlocksOut.clear();
	_allBlocksOut.copy(self.allYABlocksOut);
end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_allBlocksIn" type="CM_YABlockArray"/>
        <Parameter name="_allBlocksOut" type="CM_YABlockArray"/>
    </JadeMethod>
    <JadeMethod name="updateLastYABlock" id="20225d0b-ec7d-4954-bf43-25f87d01d920">
        <updating/>
        <source>updateLastYABlock(_block : CM_YABlock; _isIn : Boolean) : Boolean protected, updating;
// -------------------------------------------
// Created 05 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	app.myTrxUA.trxUpdateYAGroupLastBlock(self, _block, _isIn, app.myPassport);
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_block" type="CM_YABlock"/>
        <Parameter name="_isIn" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="9b199f98-597d-4eca-b579-d00be0195851">
        <source>validate();
// --------------------------------------------------------------------------------
// Created:		10 May 2006 by cnwdad1
//
// Purpose:		Standard validation method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	group: CM_YABlockGroup;
begin
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "A description is required for a Yard Allocation Block Group", "YA Block Group", null);	
		app.raiseCMException(Input_required_field_descYrdBG, "YA Block Group", null);	// cnwdb2	PAR 35364
	endif;
	
	// The names of the groups must be unique
	foreach group in self.myYardAllocationIn.allYABlockGroupsIn where group &lt;&gt; self do
		if group.description = self.description then
			app.raiseCMException(ERR_INVALID_YA_GROUP, null, null);
		endif;
	endforeach;
	
end;</source>
    </JadeMethod>
</Class>
