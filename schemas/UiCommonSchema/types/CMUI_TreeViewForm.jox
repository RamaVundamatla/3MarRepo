    <JadeMethod name="buildLstTreeMenu" id="a664eea9-163a-42f8-b6b5-88516f28ba22">
        <updating/>
        <source>buildLstTreeMenu(_selectedObj : CM_Object;  _conwin: Window input; _mouse: Boolean; _x: Integer; _y: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	02 May 2007 By cnwth2

Purpose:	re-implement and inherit as necessary

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.mnuAddPeerItem.visible := false;
	self.mnuAddChildItem.visible := false;
	self.mnuEditItem.visible := false;
	self.mnuRemoveItem.visible := false;
	self.mnuLstTreeSep1.visible := false;
	self.mnuLstTreeSep2.visible := false;
	self.mnuEnquireCargo.visible := false;
	self.mnuStopsToApply.visible := false;	//16 Sep 2016	NDL	TFS 2646 / 2001
	self.mnuTasksToApply.visible := false;	//16 Sep 2016	NDL	TFS 2646 / 2001
	self.mnuActsApplied.visible := false;	//26 Sep 2016	NDL	TFS 2649 / 2001
	
	if app.isAllowedToInspect then
		self.mnuInspectObject.userObject := _selectedObj;
		self.mnuLstTreeSep4.visible := true;
		self.mnuInspectObject.visible := true;
		
	else
		self.mnuInspectObject.userObject := null;
		self.mnuLstTreeSep4.visible := false;
		self.mnuInspectObject.visible := false;
	endif;
			
	
end;


</source>
        <Parameter name="_selectedObj" type="CM_Object"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
    </JadeMethod>
