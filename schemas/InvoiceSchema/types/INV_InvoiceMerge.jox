    <JadeMethod name="translateForm" id="60043d30-ee2a-4c49-808f-1299c4fb0103">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 January 2024 12:53:18.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026613, locale);
	//btnClearFilter.translateBubbleHelp(Xlat_0026614, locale);
	btnClose.translateCaption(Xlat_0026615, locale);
	btnMerge.translateCaption(Xlat_0026616, locale);
	cmbTargetInvoice.translateBubbleHelp(Xlat_0026617, locale);
	lblTarget.translateBubbleHelp(Xlat_0026618, locale);
	lblTarget.translateCaption(Xlat_0026619, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0026620, locale);
	mnuMenuContext.translateCaption(Xlat_0026621, locale);
	//txtFilterBox.translateBubbleHelp(Xlat_0026622, locale);
end;</source>
    </JadeMethod>
