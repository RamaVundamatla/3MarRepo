<CollClass name="BooleanArray">
    <JadeMethod name="jssDoSort" id="c953597e-dc01-4df9-bfaa-06761594e856">
        <lockReceiver/>
        <updating/>
        <source>jssDoSort(pSorterObj: JSSSorter) updating, protected, lockReceiver;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Refer to method implementation on the Array class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	booleanValue	: Boolean;
	sortKeyObj		: Object;

begin
	foreach booleanValue in self do
		pSorterObj.addValue(booleanValue);
	endforeach;
	
	self.purge();
	
	foreach sortKeyObj in pSorterObj.mySortColl do
		self.add(sortKeyObj.JSSSortKey.getValue.Boolean);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pSorterObj" type="JSSSorter"/>
    </JadeMethod>
</CollClass>
