    <JadeMethod name="createRoadMovementLeg" id="69c1f6c8-2ca0-4c6e-a275-c9939699a3bf">
        <updating/>
        <source>createRoadMovementLeg(mode: String) : CM_KPIMovementLegDtl updating;
/*
Purpose: Add a leg for the Truck movement from/to Gate			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2012	cnwdw1	Initial creation
*/
vars
	iter: Iterator;
	visits: CM_VehicleVisitsByDTDups;
	visit: CM_VehicleVisitRecord;
	leg: CM_KPIMovementLegDtl;
	truck: String;
	arrival: CM_VehicleVisitRecordDetail;
	token: Integer;
	sentinelDate: TimeStamp;
begin
	
	visits := self.getTerminal.allVehicleVisits;
	iter := visits.createIterator;
	visits.startKeyGtr(self.startTime, iter);
	sentinelDate := self.startTime.subtractHoursAndMinutes(24);

	token := 1;
	if mode = "RECEIPT" then
		truck := self.source.getNextToken(token);
	else
		truck := self.target.getNextToken(token);
	endif;
	
	while iter.back(visit) do
		if visit.timeIn &lt; sentinelDate then
			break;
		endif;
		if visit.vehicle &lt;&gt; null and visit.vehicle.code = truck then
			create leg transient;
			leg.setFromVehicleVisit(mode, visit);

			// update the road movement
			if mode = "RECEIPT" then
				self.source := leg.source;
				self.sourceType := leg.sourceType;
			else
				self.target := leg.target;
				self.target := leg.targetType;
			endif;
			self.workPointId := visit.getGateInName.cnEcFindReplace(" ", "_", false);
			return leg;
		endif;
	endwhile;
	
	return null;
epilog
	delete iter;
end;</source>
        <Parameter name="mode" type="String"/>
        <ReturnType type="CM_KPIMovementLegDtl"/>
    </JadeMethod>
    <JadeMethod name="delete" id="d08875c0-3004-4ac2-84fe-18d1397588ee">
