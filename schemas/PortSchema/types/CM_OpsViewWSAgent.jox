    <JadeMethod name="getOpsViewDataOnActivity" id="9aacc69d-8d44-4bd3-b086-6ad91891c85e">
        <updating/>
        <source>getOpsViewDataOnActivity(_ewsActivity : CM_EWSActivityOpsview) : String updating;
/*
Purpose:			

Date		Who		Reason
27AUG2021	NAVAB1	TFS 51853
*/


vars
	opsViewCmif     : CMIF_OpsView;
	updateAction    : Character;
	json,
	updateType	: String;
	cmifArray       : CMIF_OpsViewTablesArray;
	object          : Object;
	objectOid       : String;
	jsonHelper : JadeJson;
begin

	on Exception do self.handleExceptionForAgent(exception); // ### TFS 51855 05FEB2022 NAVAB1
	
	create cmifArray transient;
	
	create  opsViewCmif  as CMIF_OpsView transient ;
	
	updateAction := _ewsActivity.dataAction;
	updateType   := _ewsActivity.dataType;
	object       := _ewsActivity.myOpsviewObject;
	objectOid    := _ewsActivity.objectOid;
	
	opsViewCmif.initializeForActivity(_ewsActivity);

	if updateType = BGP_OpsViewWSRequest.OPS_TYPE_VOYAGE then
		cmifArray := self.setupVoyageForActivity(cmifArray,_ewsActivity);
		
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_DELAY then
		cmifArray := self.setupDelayForActivity(cmifArray,_ewsActivity);
	
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_HMSMOVE then
		cmifArray := self.setupHMSMovementForActivity(cmifArray,_ewsActivity);
		
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_TERMINAL then
		cmifArray := self.setupTerminalForActivity(cmifArray,_ewsActivity);
	
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_OPERATOR then
		cmifArray := self.setupOperatorForActivity(cmifArray,_ewsActivity);
	
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_TRADE then
		cmifArray := self.setupTradeForActivity(cmifArray,_ewsActivity);
	
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_BERTH then
		cmifArray := self.setupBerthForActivity(cmifArray,_ewsActivity);
	
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_MACHINE then
		cmifArray := self.setupMachineForActivity(cmifArray,_ewsActivity);
	
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_DELAYTYPE then
		cmifArray := self.setupDelayTypeForActivity(cmifArray,_ewsActivity);
	
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_VESSEL then
		cmifArray := self.setupVesselForActivity(cmifArray,_ewsActivity);
		
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_WLE then
		cmifArray := self.setupWleForActivity(cmifArray,_ewsActivity);
		
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_VVR then // ### TFS 51853 26AUG2021 NAVAB1
		cmifArray := self.setupVVRForActivity(cmifArray,_ewsActivity); // ### TFS 51853 26AUG2021 NAVAB1
		
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_CARRIER then // ### TFS 51853 26AUG2021 NAVAB1
		cmifArray := self.setupCarrierForActivity(cmifArray,_ewsActivity); // ### TFS 51853 26AUG2021 NAVAB1
	
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_ISOTYPE then // ### TFS 53569 03MAY2022 NAVAB1
		cmifArray := self.setupIsoTypeForActivity(cmifArray,_ewsActivity); // ### TFS 53569 03MAY2022 NAVAB1
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_JOB then
		cmifArray := self.setupJobForActivity(cmifArray,_ewsActivity);
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_TRAIN then // ### TFS 51855 14DEC2021 NAVAB1
		cmifArray := self.setupTrainForActivity(cmifArray,_ewsActivity); // ### TFS 51855 14DEC2021 NAVAB1
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_WAGON then // ### TFS 51855 14DEC2021 NAVAB1
		cmifArray := self.setupWagonForActivity(cmifArray,_ewsActivity); // ### TFS 51855 14DEC2021 NAVAB1
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_MOVE then // ### TFS 51855 21DEC2021 NAVAB1
		cmifArray := self.setupMoveForActivity(cmifArray,_ewsActivity); // ### TFS 51855 21DEC2021 NAVAB1
 // ### TFS 52914 04MAR2022 NAVAB1	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_WAGONCLASS then // ### TFS 51855 10JAN2022 NAVAB1
 // ### TFS 52914 04MAR2022 NAVAB1		cmifArray := self.setupWagonClassForActivity(cmifArray,_ewsActivity); // ### TFS 51855 10JAN2022 NAVAB1
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_TERMINALAREA then // ### TFS 51854 08FEB2022 NAVAB1
		cmifArray := self.setupTerminalAreaForActivity(cmifArray,_ewsActivity); // ### TFS 51854 08FEB2022 NAVAB1
	
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM then // ### TFS 52925 21FEB2022 NAVAB1
		cmifArray := self.setupTrackedItemForActivity(cmifArray,_ewsActivity); // ### TFS 52925 21FEB2022 NAVAB1
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_DOCUMENT then // ### TFS 53105 30MAY2022 NAVAB1
		cmifArray := self.setupDocumentForActivity(cmifArray,_ewsActivity); // ### TFS 53105 30MAY2022 NAVAB1
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_DOCDETAIL then // ### TFS 53105 30MAY2022 NAVAB1
		cmifArray := self.setupDocDetailForActivity(cmifArray,_ewsActivity); // ### TFS 53105 30MAY2022 NAVAB1
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_CONSIGNEENOR then // ### TFS 53105 31MAY2022 NAVAB1
		cmifArray := self.setupConsigneenorForActivity(cmifArray,_ewsActivity); // ### TFS 53105 31MAY2022 NAVAB1
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_CARGOTYPE then 			// navsp1 02Jun2022 TFS#53104
		cmifArray := self.setupCargoTypeForActivity(cmifArray,_ewsActivity); 	// navsp1 02Jun2022 TFS#53104
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_MEASUREMENTTYPE then 		// navsp1 02Jun2022 TFS#53104
		cmifArray := self.setupMeasurementForActivity(cmifArray,_ewsActivity); // navsp1 02Jun2022 TFS#53104
	elseif updateType = BGP_OpsViewWSRequest.OPS_TYPE_CARGOSUBTYPE then 		// navsp1 02Jun2022 TFS#53104
		cmifArray := self.setupCargoSubTypeForActivity(cmifArray,_ewsActivity); // navsp1 02Jun2022 TFS#53104
	endif;
	
	cmifArray.copy(opsViewCmif.allTableData);
	
	create jsonHelper; // ### TFS 51853 10DEC2021 NAVAB1
	json := jsonHelper.generateJson(opsViewCmif, JadeJson.Format_Json_Microsoft); // ### TFS 51853 10DEC2021 NAVAB1
	 // ### TFS 51853 10DEC2021 NAVAB1 opsViewCmif.deserializeJSON(json);
	
	/*  // ### TFS 51855 24MAY2022 NAVAB1 - too much noise. Now have EWS monitor screen
	executeWhen JMTDevelopmentEnvironment;
	if not app.isJMTUnitTest then
	write "RESQUEST";
	write json;
	endif;
	endExecuteWhen;
	*/
	return json;

epilog
	cmifArray.purge();
	delete cmifArray;
	delete opsViewCmif;
	delete jsonHelper;
end;</source>
        <Parameter name="_ewsActivity" type="CM_EWSActivityOpsview"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleExceptionForAgent" id="1d09a68a-bbef-483c-83dd-fbf7fe25be13">
        <source>handleExceptionForAgent(_exc : Exception) : Integer protected;
/*
Purpose:	Must not stop operations with any exceptions, best to not send data to OpsView at all.		

Date		Who		Reason
05FEB2022	NAVAB1	TFS 51855
*/

vars
	methodName : MethodCallDesc;
	detailsStr : String;
begin
	methodName := _exc.currentMethodDesc;
	
	if methodName &lt;&gt; null then
		detailsStr := methodName.display;
	endif;
	
	// Nothing we can do, so just log the details of the exception, and resume next
	
	executeWhen JMTDevelopmentEnvironment; // ### TFS 53569 04MAY2022 NAVAB1
		if not app.isJMTUnitTest then // ### TFS 53569 04MAY2022 NAVAB1
			write "OPSVIEW AGENT EXCEPTION " &amp; _exc.errorCode.String &amp; " " &amp; detailsStr &amp; " " &amp; _exc.extendedErrorText; // ### TFS 53569 04MAY2022 NAVAB1
		endif;
	endExecuteWhen; // ### TFS 53569 04MAY2022 NAVAB1
	
	app.writeLog("OPSVIEW AGENT EXCEPTION " &amp; _exc.errorCode.String &amp; " " &amp; detailsStr &amp; " " &amp; _exc.extendedErrorText, LogINFO);

	return Ex_Resume_Next;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="sendOpsViewDataForActivity" id="4f1613aa-4bcf-42c9-a4c1-c17554c86d10">
        <updating/>
        <source>sendOpsViewDataForActivity(_ewsActivity : CM_EWSActivityOpsview):Boolean updating;
/*
Purpose:			

Date		Who		Reason
26AUG2021	NAVAB1	TFS 51853
*/

vars
	resultCode      : Integer;
	json,
	url,
	jsonResponse	: String;
begin
	json := _ewsActivity.request;

	url 	:= self.baseEndpoint;
	
	
	jsonResponse := self.doSendHTTPRequest(url,
									   "POST",
										self.getAdditionalHeadersForHTTP(),
									   json,
									   resultCode);
		
	/*  // ### TFS 51855 24MAY2022 NAVAB1 - too much noise. Now have EWS monitor screen
	executeWhen JMTDevelopmentEnvironment;
	write "RESPONSE";
	write json;
	write jsonResponse;
	endExecuteWhen;
	*/
	
	if resultCode = HttpResponseOK then
		return true;

	endif;

	return false;
epilog

end;</source>
        <Parameter name="_ewsActivity" type="CM_EWSActivityOpsview"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
