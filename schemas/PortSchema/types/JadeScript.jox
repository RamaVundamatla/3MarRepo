        <source>rel812_par31486();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 24/05/2013	cnwdap1		Initial creation PAR #
//
vars
	etAgent	: EntTableAgent;
	array : StringArray;
	transAgent 	: CM_TranslationAgent;
	tmpArray 	: StringArray;
begin
	app.initialize();
	create etAgent transient;
	create array transient;
	etAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	array.add ("ETRow_Colour");
	array.add ("ETDef_BreakBulkEnt");
	array.add ("ETRow_MarkNumber");
	array.add ("ETDef_GeneralData");
	array.add ("ETDef_WHGeneralData");
	etAgent.trxUpdateFromConstant(array);
	
	create transAgent transient;
	create tmpArray transient;
	
	tmpArray.add('User_Defined_Cargo');
	transAgent.trxLoadSpecificErrors(tmpArray);
	
	// and update query definitions
	app.myRoot.createQueryDefinitionObjects();
	beginTransaction;
	app.myRoot.myQueryMenuRoot.resetUserSelectorColumns(true);
	commitTransaction;
	
	return;
	
	write ETRow_Colour;
	write ETDef_BreakBulkEnt;
	write ETRow_MarkNumber;
	write ETDef_GeneralData;
	write ETDef_WHGeneralData;
	write User_Defined_Cargo;
epilog
	delete etAgent;
	delete array;
end;</source>
    </JadeMethod>
