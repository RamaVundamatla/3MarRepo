    <JadeMethod name="populateTrackedItem" id="b2aa1b64-2151-4cb2-accf-cd5cfd89a0da">
        <updating/>
        <source>populateTrackedItem() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation	Par 31506

*/

vars

begin

	if self.myTrackedItem &lt;&gt; null then
		self.txtCargoId.text := self.myTrackedItem.id;
		
	else
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
		
	endif;
	
	self.displayLocation();
	self.displayTemperature;
	self.setForView();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectCargoItem" id="f0b39177-0562-48ba-ab74-9fe2278ef03e">
        <updating/>
        <source>selectCargoItem( _manual : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation	Par 31506

*/

vars

	cargoId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	tiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	errMsg : String;
	
	revDict : CM_TIByIdCargoTypeDictRev;	
	cargoIdLength : Integer;	
	cargoIdReversed : String;
	cargoType : CM_CargoType;
	
begin

	cargoId := txtCargoId.text.trimBlanks.toUpper;
	if cargoId = lblCargoId.caption.toUpper then
		cargoId := null;
	endif;
	cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	
	term := self.myMobileDataAgent.myTerminal;
	
	create tiArray transient;
	
	if cargoId &lt;&gt; null then
	
		cargoIdLength := cargoId.length;	
		cargoIdReversed := cargoId.reverse;
		
		firstTi := term.allOnsiteTIsByIdCargoType.getAtKeyGeq(cargoId,TI_CargoType_Container);
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then	
			iter := term.allOnsiteTIsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		firstTi := term.allOnsiteTIsByIdCargoTypeRev.getAtKeyGeq(cargoIdReversed,TI_CargoType_Container);
		if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
			iter := term.allOnsiteTIsByIdCargoTypeRev.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		
	endif;
		
	if tiArray.size = 1 then
		self.setMyTrackedItem( tiArray.first );
		self.populateTrackedItem();
		return;
		
	else
		app.myMobileCargoFindAgent.setID( cargoId );
		app.myMobileCargoFindAgent.setMyTrackedItemToProcess(null);
		app.myMobileCargoFindAgent.setDoSearchImmediate( cargoId.trimBlanks &lt;&gt; null );
		app.myMobileCargoFindAgent.setSearchSite(TI_SITE_ONSITE);
		app.myMobileCargoFindAgent.setMyCargoType( cargoType );
		app.myMobileCargoFindAgent.setReefersOnly(self.isReeferOnlyForm);
		
		self.gotoForm( MOB_HHCargoFind, false );
		return;
		
	endif;
	

epilog

	delete tiArray;
	delete iter;
	delete revDict;	

end;</source>
        <Parameter name="_manual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForEdit" id="e86e229e-fa6c-42ab-a69d-494b8df60878">
        <source>setForEdit() protected;
/*
Purpose:			

Date		Who		Reason
23/01/2009	cnwcp2	Initial creation
19/03/2015	cnwdap1	PAR #35874 TFS 265 Added humidity and ventilation fields
09/06/2017 cnwrh7       TFS2207       #TFS4536  Reefer Reading updating with HHT for Commodities not requiring temperature
*/

vars
	canEditTemp : Boolean;			//+TFS4518
	canEditHumi : Boolean;
	canEditVenti : Boolean;
begin
	// reselect the correct container in the combo box
	
	self.btnOne.caption := app.getErrorString(Edit);
	self.btnOne.enabled := false;
	self.btnTwo.enabled := true;
	self.txtCargoId.enabled := false;
	self.btnPartCargoId.enabled := false;
	//self.txtTemperature.readOnly := false;												//-TFS4518
	//self.txtHumidity.readOnly := false;						// PAR #35874	//-TFS4518
	//self.txtVentilation.readOnly := false;					// PAR #35874	//-TFS4518
	//TFS 4518 Starts
	if self.myTrackedItem &lt;&gt; null then
		canEditTemp := self.myTrackedItem.requiresTemperature;
		canEditHumi := self.myTrackedItem.requiresHumidity;
		canEditVenti := self.myTrackedItem.requiresVentilation;
	endif;
	self.txtTemperature.readOnly := not canEditTemp;
	self.txtHumidity.readOnly := not canEditHumi;
	self.txtVentilation.readOnly := not canEditVenti;
	//TFS 4518 Ends
	
	self.chkNoCharge.readOnly := false;
	self.txtTemperature.setFocus();
	self.txtLocation.readOnly := true;
	self.btnSearchLocs.enabled := false;
	
	self.getSessionAgent().setMyProxy( self.myTrackedItem);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setForView" id="a9617996-4fc8-4c89-ba89-ba7f21decb69">
        <updating/>
        <source>setForView() updating, protected;
/*
Purpose:			

Date		Who		Reason
23/01/2009	cnwcp2	Initial creation
19/03/2015	cnwdap1		PAR #35874 TFS 265 Added humidity and ventilation fields
*/

vars

begin
	self.btnOne.caption := app.getErrorString(Edit);
	self.btnTwo.enabled := false;
	self.txtCargoId.enabled := true;
	self.btnPartCargoId.enabled := true;
	//self.cmbSearchItem.setFocus();
	self.txtTemperature.readOnly := true;
	self.txtHumidity.readOnly := true;					// PAR #35874
	self.txtVentilation.readOnly := true;				// PAR #35874
	self.chkNoCharge.readOnly := true;
	self.chkNoCharge.value := false;
	self.somethingChanged := false;
	self.getSessionAgent().setMyProxy( null );
	self.txtLocation.readOnly := false;
	self.btnSearchLocs.enabled := true;
	// only be able to go to next or previous if a current object is selected
	if self.myTrackedItem &lt;&gt; null then
		btnThree.enabled := self.getSessionAgent.getNextTI(self.myTrackedItem, self.isReeferOnlyForm) &lt;&gt; null;
		btnFour.enabled := self.getSessionAgent.getPreviousTI(self.myTrackedItem, self.isReeferOnlyForm) &lt;&gt; null;
		self.btnOne.enabled := true;
	else
		btnThree.enabled := false;
		btnFour.enabled := false;
		self.btnOne.enabled := false;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="8ea50b53-3b9c-4277-98e8-95a82b1f6aa9">
        <updating/>
        <source>setMyTrackedItem( _ti : CM_TrackedItem ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation	Par 31506

*/

vars

begin

	self.getSessionAgent().setMySelectedTI( _ti );
	app.myMobileCargoFindAgent.setMyTrackedItemToProcess( null );
	self.myTrackedItem := _ti;
	self.populateTrackedItem();
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="30b4d7b9-3db9-4e67-a8be-8579dbd3a041">
        <updating/>
        <source>setupControls() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/05/2013	cnwndl1	Initial creation
19/03/2015	cnwdap1	PAR #35874 TFS 265 Show default measurement type in Ventilation caption
*/
vars
	measure	: CM_MeasurementType;

begin

	self.doResizeControls(true);
	
	self.chkTraverseCol.caption:= app.getErrorString(Column_order);
	self.chkTraverseCol.value := self.getSessionAgent.traverseColumns;
	
	measure := app.getDefaultMeasurementForType(Type_Displacement);															// PAR #35874
	self.lblVentilation.caption := "Current Ventilation " &amp; Left_Round_Bracket &amp; measure.shortName &amp; Right_Round_Bracket &amp; Colon;	// PAR #35874
	self.txtVentilation.decimals := measure.getDecimalPrecision;															// PAR #35874
	
	self.populateTrackedItem();	
	self.txtCargoId.setFocus;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="91ed528b-c599-46a4-acab-f98940a9b5f5">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:	09 January 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
// adm 270509 Par 19504 traverseColumns
vars

	ti : CM_TrackedItem;
	
begin

	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	ti := app.myMobileCargoFindAgent.myTrackedItemToProcess;
	if ti &lt;&gt; null then
		//returning from a specific search
		self.setMyTrackedItem(  app.myMobileCargoFindAgent.myTrackedItemToProcess );
	else
		// populated on one of the other maint forms
		self.setMyTrackedItem( self.getSessionAgent().mySelectedTI );
	endif;
	
	self.setupCmdButtons( 5, app.getErrorString(Edit), app.getErrorString(Cancel), app.getErrorString(Next), app.getErrorString(Prev), BACK_BUTTON );
	
	self.btnThree.enabled := false;
	self.btnFour.enabled := false;
	
	inheritMethod();
	
	self.setupControls();
	
	
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
