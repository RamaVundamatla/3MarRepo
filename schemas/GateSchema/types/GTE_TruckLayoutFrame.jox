    </JadeMethod>
    <JadeMethod name="createContainerFrame" id="ec2780f1-c09d-405e-97fc-2021e5ee45dd">
        <source>createContainerFrame() : GTE_ContainerFrame protected;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	frmCont		: GTE_ContainerFrame;

begin

	create frmCont transient;
	frmCont.parent := self;
	form.addControl(frmCont);

	frmCont.height := 80;
	frmCont.visible := false;
	
	return frmCont;
	
end;</source>
        <access>protected</access>
        <ReturnType type="GTE_ContainerFrame"/>
    </JadeMethod>
    <JadeMethod name="displayContainers" id="f3d55907-c86e-4cdf-9842-274e07aa8fa7">
        <updating/>
        <source>displayContainers() updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	contFrm		: GTE_ContainerFrame;
	leftPos	: Integer;
	
begin

	if self.mySelectedContainer &lt;&gt; null and (not self.mySelectedContainer.visible) then
		self.mySelectedContainer.deSelect;
		self.mySelectedContainer := null;
	endif;
	
	self.setLengths();

	leftPos := self.myTruckBedLeftPic.left.Integer;

	foreach contFrm in self.allContainerFrames do

		if (not contFrm.visible) then
			continue;
		endif;

		contFrm.setWidth(self.length10, self.length20, self.length40);
		contFrm.left := leftPos;

		if self.mySelectedContainer = null then
			self.mySelectedContainer := contFrm;
			contFrm.select;
		endif;
			
		leftPos := (contFrm.left + contFrm.width + 1).Integer;
		
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="dragDropContainer" id="9b7e493e-1a15-4186-a19f-62b734f5558e">
        <updating/>
        <source>dragDropContainer(pToContainer : GTE_ContainerFrame) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	fromIdx,
	toIdx		: Integer;
	toContainer	: GTE_ContainerFrame;
		
begin

	if pToContainer = self.myDraggedContainer then
		// dropped back on itself so no need to swap!
		return;
	endif;

	fromIdx	:= self.allContainerFrames.indexOf(self.myDraggedContainer);
	toIdx 	:= self.allContainerFrames.indexOf(pToContainer);

	if toIdx &lt;&gt; 0 and fromIdx &lt;&gt; 0 then
		// Swap the containers.  This is done in this convulated fashion as a straight swap got
		// the inverses screwed and left one container with its inverse not set.

		toContainer := pToContainer;

		self.swapContainers(fromIdx, toIdx);

		toContainer.deSelect();
		self.myDraggedContainer.select();
		self.displayContainers();

		self.myDraggedContainer := null;

	endif;
	
end;</source>
        <Parameter name="pToContainer" type="GTE_ContainerFrame"/>
    </JadeMethod>
    <JadeMethod name="driveOff" id="0caa9b5d-8c57-49a9-b891-3eac6a43429d">
        <updating/>
        <source>driveOff() updating;
// ---------------------------------------------------------------------------
// Created:     17 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx,
	lag		: Integer;
	tmpSound	: Sound;
begin

	tmpSound := app.myRoot.getConfig(TruckDriveOffWav).Sound;

	if tmpSound &lt;&gt; null then
		tmpSound.play;
		app.doWindowEvents(1000);
	endif;

	lag := 100;
	
	while true do
		self.myTruckCabPicture.left 	:= self.myTruckCabPicture.left - 1;
		self.myTruckBedLeftPic.left		:= self.myTruckBedLeftPic.left - 1;
		self.myTruckBedMiddlePic.left	:= self.myTruckBedMiddlePic.left - 1;
		self.myTruckBedRightPic.left	:= self.myTruckBedRightPic.left - 1;
		self.displayContainers;
		self.refreshNow;
		if (self.myTruckBedRightPic.left + self.myTruckBedRightPic.width) &lt; 0 then
			break;
		endif;
		app.doWindowEvents(lag);
		idx := idx + 1;
		if idx = 40 then
			lag := 10;
		elseif idx = 100 then
			lag := 5;
		elseif idx = 200 then
			lag := 2;
		endif;
	endwhile;

	if tmpSound &lt;&gt; null then
		app.doWindowEvents(1000);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="driveOn" id="1650916d-fc96-4cba-b63a-a274ab278573">
        <updating/>
        <source>driveOn() updating;
// ---------------------------------------------------------------------------
// Created:     17 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	startPos,
	idx,
	lag			: Integer;
	tmpSound	: CM_Sound;

begin

	tmpSound := app.myRoot.getConfig(TruckDriveOnWav).CM_Sound;

	// set initial position off the screen
	startPos := self.parent.width.Integer;
	self.myTruckCabPicture.left 	:= startPos;
	self.myTruckBedLeftPic.left		:= self.myTruckCabPicture.left + self.myTruckCabPicture.width;
	self.myTruckBedMiddlePic.left	:= self.myTruckBedLeftPic.left + self.myTruckBedLeftPic.width;
	self.myTruckBedRightPic.left	:= self.myTruckBedMiddlePic.left + self.myTruckBedMiddlePic.width;
	self.displayContainers;
	self.refreshNow;

	lag := startPos - self.leftMargin;
	if lag &gt; 0 then
		lag := (lag / 2000).Integer;
	else
		lag := 1;
	endif;

	if tmpSound &lt;&gt; null then
		tmpSound.play;
		app.doWindowEvents(1);
	endif;
	
	while true do
		self.myTruckCabPicture.left 	:= self.myTruckCabPicture.left - 1;
		self.myTruckBedLeftPic.left		:= self.myTruckBedLeftPic.left - 1;
		self.myTruckBedMiddlePic.left	:= self.myTruckBedMiddlePic.left - 1;
		self.myTruckBedRightPic.left	:= self.myTruckBedRightPic.left - 1;
		self.displayContainers;
		self.refreshNow;
		if self.myTruckCabPicture.left &lt; self.leftMargin then
			break;
		endif;
		if lag &gt; 0 then
			app.doWindowEvents(lag);
		else
			if idx mod 3 = 0 then
				app.doWindowEvents(1);
			endif;
		endif;
		idx := idx + 1;
	endwhile;

end;</source>
    </JadeMethod>
    <JadeMethod name="hideTruck" id="4be3d197-c528-437f-99b3-869f3ed887f5">
        <source>hideTruck();
// ---------------------------------------------------------------------------
// Created:     20 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	contFrm	: GTE_ContainerFrame;

begin

	foreach contFrm in self.allContainerFrames do
		contFrm.visible := false;
	endforeach;

	self.myTruckCabPicture.visible 		:= false;
	self.myTruckBedLeftPic.visible 		:= false;
	self.myTruckBedMiddlePic.visible 	:= false;
	self.myTruckBedRightPic.visible 	:= false;

end;</source>
    </JadeMethod>
    <JadeMethod name="moveSelectedContainer" id="71547b1e-9569-4fac-84f6-73733bcbbdf5">
        <updating/>
        <source>moveSelectedContainer(pBtn : JadeMask) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pBtn = self.myMoveLeftBtn then
		self.moveSelectedLeft();
	elseif pBtn = self.myMoveRightBtn then
		self.moveSelectedRight();
	endif;

end;</source>
        <Parameter name="pBtn" type="JadeMask"/>
    </JadeMethod>
    <JadeMethod name="moveSelectedLeft" id="1ab1b7d9-3083-4fe3-83b5-35ccdb8d4a24">
        <updating/>
        <source>moveSelectedLeft() updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	oldIdx,
	newIdx	: Integer;
	
begin

	if self.mySelectedContainer = null then
		return;
	endif;
	
	oldIdx := self.allContainerFrames.indexOf(self.mySelectedContainer);
	newIdx := oldIdx - 1;
	
	if newIdx &lt;= 0 then
		return;
	endif;
	
	if (not self.allContainerFrames[newIdx].visible) then
		return;
	endif;
	
	self.swapContainers(oldIdx, newIdx);
	self.displayContainers();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="moveSelectedRight" id="f9128ba4-f602-462d-ada6-5900414ae922">
        <updating/>
        <source>moveSelectedRight() updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	oldIdx,
	newIdx	: Integer;
	
begin

	if self.mySelectedContainer = null then
		return;
	endif;
	
	oldIdx := self.allContainerFrames.indexOf(self.mySelectedContainer);
	newIdx := oldIdx + 1;
	
	if newIdx &gt; self.allContainerFrames.size then
		return;
	endif;
	
	if (not self.allContainerFrames[newIdx].visible) then
		return;
	endif;
	
	self.swapContainers(oldIdx, newIdx);
	self.displayContainers();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="numVisibleContainers" id="c316d9b1-10a0-4e15-9eee-07af18c88337">
        <methodInvocation>mapping</methodInvocation>
        <source>numVisibleContainers(set: Boolean; _value: Integer io) mapping, protected;
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	contFrm	: GTE_ContainerFrame;

begin

	if set then
		return;
	endif;
	
	_value := 0;
	foreach contFrm in self.allContainerFrames do
		if contFrm.visible then
			if contFrm.length = 40 then
				_value := _value + 4;
			elseif contFrm.length = 20 then
				_value := _value + 2;
			else
				_value := _value + 1;
			endif;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="paint" id="8dfb1ea3-fd8a-43cc-9380-61d53b9d96e3">
        <updating/>
        <source>paint(frame: Frame input) updating;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(frame);

	if isInPainter then
		if not self.isBuilt then
			self.isBuilt := true;
			self.buildSelf;
		endif;

	elseif not isBuilt then
		self.buildSelf;
		self.isBuilt := true;
	endif;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
