<Class name="CM_EDITrackedItem">
    <JadeMethod name="getColoursForEDITrackedItem" id="6a4a3dc7-05fb-4c7e-9c10-02ba7de9a11b">
        <source>getColoursForEDITrackedItem(_ediData :CM_EDIData; _localPort :String; _foreColor, _backColor :Integer output);
/*
Purpose:	Replace code in EDI forms for setting EDI tracked Item colours

Date		Who		Reason
05 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
// 20 Mar 2018	jlgrs1	TFS 37484 - QNS Allow DB Loading of Bay Plan files
*/
vars
	status	:Integer;
begin
	_foreColor	:= Black; 								
	_backColor	:=  CM_BaseForm.ColorGreenLight;
	
	if _ediData &lt;&gt; null and _ediData.status = CM_EDIFile.EDI_STATUS_DBLOADED then
		_foreColor	:= CM_BaseForm.ColorGreyDark;
		_backColor 	:= CM_BaseForm.ColorGreenLight;
	else
		status		:= self.getStatus;											

		if status = CM_EDITrackedItem.EDI_STATUS_UNPROCESSED then
			_backColor := LightRed;
			
		elseif status = CM_EDITrackedItem.EDI_STATUS_INVALID then
			_backColor 	:= White;
			_foreColor	:= CM_BaseForm.ColorGreyDark;
			
		elseif status = CM_EDITrackedItem.EDI_STATUS_DBLOADED then
			_foreColor	:= CM_BaseForm.ColorGreyDark;
			_backColor 	:= CM_BaseForm.ColorGreenLight;
			
		elseif status = CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS or	
			   status = CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS then
			_backColor 	:= LightRed;
			
		elseif status = CM_EDITrackedItem.EDI_STATUS_VERIFIED_WARNINGS then
			_backColor 	:= PalePink;

		elseif status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
			// black/light yellow
			_backColor 	:= CM_BaseForm.ColourYellowLight;
		elseif self.status = CM_EDITrackedItem.EDI_STATUS_LOCKERROR then
			_backColor 	:= Cosmos;
		elseif status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING then
			// dark grey/light yellow
			_backColor 	:= CM_BaseForm.ColourYellowLight;
			_foreColor	:= CM_BaseForm.ColorGreyDark;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_localPort" type="String"/>
        <Parameter name="_foreColor" type="Integer" usage="output"/>
        <Parameter name="_backColor" type="Integer" usage="output"/>
    </JadeMethod>
</Class>
