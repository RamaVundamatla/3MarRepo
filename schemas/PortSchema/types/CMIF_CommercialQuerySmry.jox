<Class name="CMIF_CommercialQuerySmry" id="b693a736-fd29-49c5-9d1c-5d371a048948">
    <superclass name="CMIF_CommercialQueryEntity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <ImplicitInverseRef name="allSumTIs" id="9b4646f1-4150-4ebe-b67e-26af9eb5a853">
        <memberTypeInverse/>
        <type name="CM_TISet"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="cargoType" id="2af11b0a-8de4-41f6-b42f-3be9dafaeecb">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="cntrType" id="afa40293-61e7-4035-bd2e-e6cb7fae87be">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>is 20' , 40' , 45' , or TEU</text>
    </PrimAttribute>
    <PrimAttribute name="contentsStatus" id="b7f354f8-5480-436c-aa7d-79a8b6bc3d96">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>EMPTY or FULL</text>
    </PrimAttribute>
    <PrimAttribute name="imexStatus" id="61391532-e4e7-4fc8-b9c0-741de24f56ca">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myFreightForwarder" id="27335c70-87c6-4899-b9ff-f3737ddb3916">
        <embedded/>
        <type name="CM_ConsigneeConsignor"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myHdr" id="6eb2e48e-a8ec-42ac-94a6-53b0018e4175">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CMIF_CommercialQueryHeader"/>
        <access>readonly</access>
        <Inverse name="CMIF_CommercialQueryHeader::allSums"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myOperator" id="91ef83d0-43bd-4b97-b585-b444db57e5f5">
        <embedded/>
        <type name="CM_Operator"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="num" id="d932ad04-40fc-4762-b974-c5d305152c46">
        <precision>16</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="rowSortCode" id="2eca9697-dd97-49ea-8d6d-d1028d6486fe">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>The sorting number for each Operator of FF when displaying on the table.</text>
    </PrimAttribute>
    <PrimAttribute name="rowType" id="75355cc4-2f8a-4560-a9f8-ccc1bac8729c">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>1. Freight Forwarder
2. Operator</text>
    </PrimAttribute>
    <JadeMethod name="addTI" id="f0be46b7-269e-444e-bfd7-2e8437cf2a60">
        <updating/>
        <source>addTI(_ti : CM_TrackedItem; _num : Decimal) updating;
// ---------------------------------------------------------------------------
// Created:     23 November 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars	
begin
	self.allSumTIs.add(_ti);
	self.num := self.num + _num;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_num" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTISet" id="83cf5654-dbb6-47c2-afc6-37d7eb8ca484">
        <source>getTISet(): CM_TISet;
// ---------------------------------------------------------------------------
// Created:     18 February 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
begin
	return self.allSumTIs;
end;</source>
        <ReturnType type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="init" id="124aa1fc-d5b0-4ba2-b9ec-f2108b8c450d">
        <updating/>
        <source>init(_rowType : Integer; _rowSortCode : String; _cargoType, _imexStatus, _contentsStatus, _cntrType : Integer; _hdr : CMIF_CommercialQueryHeader;operObj : CM_Operator; ffObj : CM_ConsigneeConsignor) updating;
// ---------------------------------------------------------------------------
// Created:     26 November 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.allSumTIs.clear;
	self.rowType := _rowType;
	self.rowSortCode := _rowSortCode;
	self.myFreightForwarder := ffObj;
	self.myOperator := operObj;
	self.cargoType := _cargoType;
	self.imexStatus := _imexStatus;
	self.contentsStatus := _contentsStatus;
	self.cntrType := _cntrType;
	self.myHdr := _hdr;
end;</source>
        <Parameter name="_rowType" type="Integer"/>
        <Parameter name="_rowSortCode" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="_contentsStatus" type="Integer"/>
        <Parameter name="_cntrType" type="Integer"/>
        <Parameter name="_hdr" type="CMIF_CommercialQueryHeader"/>
        <Parameter name="operObj" type="CM_Operator"/>
        <Parameter name="ffObj" type="CM_ConsigneeConsignor"/>
    </JadeMethod>
</Class>
