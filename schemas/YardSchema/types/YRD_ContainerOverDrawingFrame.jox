        <source>dblClick(frame: Frame input) updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
01 December 2008	consw1	SFW1030 - Initial creation

*/

vars

begin
	if not self.inEditMode and self.form.isKindOf(YRD_SatelliteViewForm) then
		self.myContainerViewingFrame.dblClick(self.myContainerViewingFrame);
	endif;
	
	inheritMethod(frame);

epilog

end;</source>
