<Class name="GC_RowAreaColumn" id="947ce38a-aa6f-4be7-be2b-99c012caac4f">
    <superclass name="CMUI_GridColumn"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
This is the equivalent of the CM_RowAreaRow because the
RowAreas are drawn with the rows as columns.</text>
    <DbClassMap file="Yard"/>
    <ImplicitInverseRef name="myRowAreaRow" id="a484f19f-d71f-4449-b1aa-647db368a997">
        <embedded/>
        <type name="CM_RowAreaRow"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="width" id="23c79f33-564e-487e-8d90-5f1e4fb12bfa">
        <embedded/>
        <type name="Real"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="drawSelf" id="cb6192bb-24be-4198-86c4-00d1e70a4cc4">
        <updating/>
        <source>drawSelf(pFrame: CMUI_Frame) updating;
// ---------------------------------------------------------------------------
