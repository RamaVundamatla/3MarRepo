    <JadeMethod name="getLineTypesStr" id="6d416b63-7485-4b9a-9961-c92bce5c9875">
        <source>getLineTypesStr():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2018	jlgndl1	Initial creation	TFS 37819

*/

vars

	invLineType: CM_InvoiceLineDesc;
	retString : String;

begin

	foreach invLineType in self.allAdditionChargeInvTypes do
		if retString &lt;&gt; null then
			retString := retString &amp; ", ";
		endif;
		retString := retString &amp; invLineType.narration;
	endforeach;
	
	return retString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNiceName" id="c335adbf-3afb-45e7-aca0-100079b2d687">
        <source>getNiceName(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 April 2018	jlgab1	Initial creation

*/

vars

begin
	if self.myDebtor &lt;&gt; null then
		return self.myDebtor.name &amp; ", Range = " &amp; self.getRangeStr();
	else
		return inheritMethod();
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRangeStr" id="5f55655d-2404-44a9-86b9-383dd7e2e507">
        <source>getRangeStr():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2018	jlgndl1	Initial creation	TFS 37819

*/

vars

	retString : String;

begin

	retString := self.rangeStart.asStringJMT &amp; " - " &amp; self.rangeEnd.asStringJMT;
	return retString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValueWithinRange" id="c876a932-0f85-4c3a-aa9d-766a00b0dbcc">
        <source>isValueWithinRange( _real : Real ) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2018	jlgndl1	Initial creation	TFS 37819

*/

vars

begin

	if _real &gt;= self.rangeStart then
		if _real &lt;= self.rangeEnd then
			return true;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_real" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
