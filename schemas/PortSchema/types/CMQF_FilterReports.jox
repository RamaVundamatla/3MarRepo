    <JadeMethod name="populateQryTerminalAreas" id="500e9da5-12eb-48b7-a498-0a1966737d98">
        <source>populateQryTerminalAreas() protected;
// ---------------------------------------------------------------------------
// Created:     09 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	taType	: CM_TerminalAreaType;
	termAreaType : Integer;
	ta		: CM_TerminalArea;
	iter	: Iterator;
	taColl	: CM_TAByTerminalIdDict;
	terminal			: CM_Terminal;
begin
	
	self.allQryTerminalAreas.clear;

	if self.getMyTerminalArea &lt;&gt; null then
		self.allQryTerminalAreas.add(self.getMyTerminalArea);
		return;
	endif;
	
	if self.terminalAreaTypes.size &lt;&gt; 0 then
		foreach termAreaType in self.terminalAreaTypes discreteLock do
			taType := app.myRoot.allTerminalAreaTypes[termAreaType];
			if taType = null then
				continue;
			endif;
			delete iter;
			iter := taType.allTerminalAreasByTerminal.createIterator;
			
			while iter.next(ta) do
				if ta.myType = taType then
					if ta.myTerminal &lt;&gt; null then //Protection, should not be null!!!!!!!!
						if self.allTerminals.includes(ta.myTerminal) then
							// 22/02/2010 cnwjre1a from CCMS 1101 extra terminal areas in CMUI_SelectISOSource
							//  was getting duplicates??
							if not self.allQryTerminalAreas.includes(ta) then
								self.allQryTerminalAreas.add(ta);
							endif;
						endif;
					endif;
				endif;
			endwhile;
		endforeach;
	else
		foreach terminal in self.allTerminals do
			terminal.allTerminalAreas.copy(self.allQryTerminalAreas);
		endforeach;
	endif;

epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
