<Class name="JSSChangeTrackingSchema" id="05a26fab-5d71-49f9-a403-7849f2828949">
    <superclass name="JSSCoreSchema"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="getJadeLogDir" id="1c36d55a-7515-46ec-b261-ec84d6526c60">
        <source>getJadeLogDir() : String;
// ---------------------------------------------------------------------------
// Created:     07 October 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	isAppServer	: Boolean;
	iniFileName,
	dirName		: String;
	ff			: FileFolder;
begin
	isAppServer	:= node.isApplicationServer;
	if isAppServer then
		iniFileName := self.getIniFileNameAppServer();
		dirName := self.getProfileStringAppServer(iniFileName, 'JadeLog', 'LogDirectory', null);
	else
		iniFileName := self.getIniFileName();
		dirName := self.getProfileString(iniFileName, 'JadeLog', 'LogDirectory', null);
	endif;
	
	if dirName = null then
		if isAppServer then
			return app.getTempDirAppServer();
		endif;
		return app.getTempDir();
	endif;
	
	create ff transient;
	ff.fileName := dirName;
	ff.usePresentationFileSystem := false;
	
	if (not ff.isAvailable) then
		if isAppServer then
			return app.getTempDirAppServer();
		endif;
		return app.getTempDir();
	endif;
	
	return dirName;

epilog
	delete ff;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleAppException" id="2492bbde-9833-448a-a934-0e48f740bb7c">
        <source>handleAppException(pException: Exception): Integer;
/*
*/
vars
	ts: TimeStamp;
	lMessage: String;
	processOidString: String;
begin
	processOidString := process.getOidString;
	if pException.currentMethodDesc = null then
		lMessage := app.name &amp; "." &amp; self.class.getName() &amp; "::handleAppException " &amp; pException.errorCode.String &amp; " - " &amp; pException.text &amp; " occurred.";
	else
		lMessage := app.name &amp; "." &amp; self.class.getName() &amp; "::handleAppException " &amp; pException.errorCode.String &amp; " - " &amp;
																				   pException.text &amp; " occurred in " &amp;
																				   pException.currentMethodDesc.method.name &amp; ' at position ' &amp;
																				   pException.currentMethodDesc.position.String;
	endif;
	JSSCTNotificationObject.firstInstance.causeEvent(JSSCT_Monitor_Note, true,
														ts.date.format("ddMMMyy ") &amp;
														ts.Time.String &amp; "." &amp; (ts.Time.milliSecond + 1000).String[2:3] &amp; " " &amp;
//														process.number.String &amp; " | " &amp;
														processOidString[processOidString.pos(".",1):end] &amp; " | " &amp;
														lMessage);

	return(Ex_Abort_Action);	//Ex_Pass_Back);
end;</source>
        <Parameter name="pException" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleDeletedObject" id="77841a7b-6cf4-4432-a205-cc0a7677dba9">
        <source>handleDeletedObject(_exc : Exception; _obj : Object; _invalidObject : Boolean io) : Integer;

/*

Purpose:			General exception handler to deal with invalid object references.  Needs to be
					armed with a specific object reference to be checked.


Return Value:		Standard Exception return codes, and _invalidObject set to true if
					the specified object reference caused the exception.


Date		Who		Reason
18 Mar 2008	cnwkpd1	PAR #16195 - Allow generic handling of invalid objects
03 Jun 2008	cnwkpd1	PAR #16718 - handle exclusive collection exceptions as well, as there are
					situations where an exclusive collection on the object we are interested in
					will be the error object in the exception
21 May 2009	cnwkpd1	Change to use new JADE Object::getOwnerForObject method
04 Feb 2011	cnwkpd1	PAR #27142 - Added code to handle null _obj, to protect against incorrect
					arming and therefore invalid resume for standard objects (with no owner)
					
// 17 Jun 2014	cnwrs1	Par 34413 lost updates in DSS
*/

constants
	ObjectNotFound	= 4;
	ObjectDeleted	= 1072;
	InvalidClass	= 1046;
	
vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;
	
	// PAR #27142 - if the handler has been armed for a local variable that has not yet been
	// initialised when the exception occurs, then it is not for us, so just pass back immediately
	if _obj = null then				
		return returnVal;
	endif;
	
	if _exc.errorCode = ObjectNotFound or _exc.errorCode = ObjectDeleted or _exc.errorCode = InvalidClass then
		if _exc.errorObject = _obj or self.getOwnerForObject(_exc.errorObject) = _obj then
			// Set _invalidObject, and resume in the calling method, which will then
			// interrogate excOccurred, to identify an invalid/deleted object
			_invalidObject := true;
			if _exc.resumable then
				returnVal := Ex_Resume_Next;
			endif;
		endif;
	endif;


epilog
	return returnVal;
	
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_invalidObject" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
