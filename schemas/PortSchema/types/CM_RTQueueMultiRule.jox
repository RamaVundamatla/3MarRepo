    <JadeMethod name="getDefaultRTMoveMethodRule" id="dcf58040-fcf1-45ed-95eb-36a042acba61">
        <source>getDefaultRTMoveMethodRule(): CM_RTMoveMethodRule;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwer1	Initial creation

*/

vars

begin
	return self.allDefaultRTMoveMethodRules.first;

epilog

end;</source>
        <ReturnType type="CM_RTMoveMethodRule"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="eaa7d08e-d80d-49c7-afeb-92513ad85d4f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

// Created by cnwdvb1 on 04 September 2006

vars

begin

	//ccms 1100 epr 10/2/10
	if _attrName = ETRow_DefaultMoveMethod then	
		if self.getDefaultRTMoveMethodRule &lt;&gt; null then
			return self.getDefaultRTMoveMethodRule.myRTMoveMethod.description;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMoveMethThatStartsWithMach" id="df02ce66-9333-44af-9010-b6b11cfb1e04">
        <source>getMoveMethThatStartsWithMach(_machineTypeGroup : CM_MachineTypeGroup input) : CM_RTMoveMethodRule;
/*

Date		Who		Reason
17 March 2015	cnwer1	Initial creation PAR

*/

vars
	moveMethodRule : CM_RTMoveMethodRule;
begin
	if _machineTypeGroup = null then
		return null;
	endif;
	
	foreach moveMethodRule in self.allOtherRTMoveMethodRules do
		if moveMethodRule.myRTMoveMethod.allMachineTypeGroups.first = _machineTypeGroup then
			return moveMethodRule;
		endif;
	endforeach;
	
	
	return null;
epilog

end;</source>
        <Parameter name="_machineTypeGroup" type="CM_MachineTypeGroup" usage="input"/>
        <ReturnType type="CM_RTMoveMethodRule"/>
    </JadeMethod>
    <JadeMethod name="getName" id="2581b5d8-819a-45c7-88fe-ee7c466c5111">
        <source>getName(): String;

// Created by cnwdvb1 on 18 September 2006

vars
	
begin
	
	//ccms 1110 epr 10/2/10
	if self.getDefaultRTMoveMethodRule &lt;&gt; null then
		return inheritMethod() &amp; ' ' &amp; self.getDefaultRTMoveMethodRule.myRTMoveMethod.description;
	endif;
	
	return inheritMethod();

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesRTMoveMethodRuleOfType" id="1bfeafd7-ff76-44d9-a8c3-b274cddb9364">
        <source>includesRTMoveMethodRuleOfType(_machineGrpType : Integer) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwer1	Initial creation

*/

vars
	rtMoveMethodRule : CM_RTMoveMethodRule;
	machineGrp  	: CM_MachineTypeGroup;
begin

	machineGrp:=app.myRoot.allMachineTypeGroups[_machineGrpType];
	foreach rtMoveMethodRule in self.allDefaultRTMoveMethodRules do
		if rtMoveMethodRule.myRTMoveMethod.allMachineTypeGroups.includes(machineGrp) then
			return true;
		endif;
	endforeach;
	
	foreach rtMoveMethodRule in self.allOtherRTMoveMethodRules do
		if rtMoveMethodRule.myRTMoveMethod.allMachineTypeGroups.includes(machineGrp) then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_machineGrpType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
