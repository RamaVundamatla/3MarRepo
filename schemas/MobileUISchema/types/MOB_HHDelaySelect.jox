begin
	self.myMachine := self.cmbMachine.listObject.CM_Machine;
	self.setActionButtons();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="3544b1c0-7062-45f2-abab-2182a507d1ba">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2015	cnwndl1	Initial creation	Par 35406

*/

vars
	stdLeft : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	tabIndex : Integer;
	btnHeight : Integer;

	machine	: CM_Machine;
	voyage : CM_Voyage;

begin

	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdHeight := self.getStdControlHeight;
	btnHeight := self.getSearcherHeight();
	
	if _initialSetup then
		self.btnEditDelay.enabled := false;
	endif;

	if _initialSetup then
		self.cmbVoyage.setAndIncrementTabIndex( tabIndex );
		self.cmbVoyage.visible := true;
	endif;
	self.cmbVoyage.move( self.resizedMargin,
						 self.resizedMargin,
						 self.clientWidth - self.resizedMargin - self.resizedMargin,
						 stdHeight );
						 
	if _initialSetup then
		self.cmbVoyage.clear();
		self.myMobileGenericAgent.setCurrentVoyages();
		self.cmbVoyage.addItem(lblVoyage.caption);
		foreach voyage in self.myMobileGenericAgent.allCurrentVoyages do
			if voyage.isNullVoyage then
				continue;
			endif;
			if self.myMobileGenericAgent.myTerminal.getConfig(VesselNameOnVoyageCombo).Boolean then //cnwrd1 nfs 31095
				self.cmbVoyage.itemObject[self.cmbVoyage.addItem(voyage.code &amp; Tab &amp; voyage.vesselName )] := voyage;
			else		
				self.cmbVoyage.itemObject[self.cmbVoyage.addItem(voyage.code)] := voyage;
			endif;
		endforeach;
		
		voyage := self.myMobileGenericAgent.myVoyage;
		if voyage &lt;&gt; null and cmbVoyage.findObject(voyage) &gt; 0 then
			cmbVoyage.listIndex := cmbVoyage.findObject(voyage);
			// if found, set myVoyage to match
			if cmbVoyage.listIndex &gt; 0 then
				self.myVoyage := voyage;
			endif;
		elseif cmbVoyage.listCount = 2 then
			cmbVoyage.listIndex := 2;
		else
			cmbVoyage.listIndex := 1;
		endif;
	endif;
	
	if _initialSetup then
		self.cmbMachine.setAndIncrementTabIndex( tabIndex );
		self.cmbMachine.visible := true;
	endif;
	self.cmbMachine.move( self.resizedMargin,
						 self.resizedMargin + self.cmbVoyage.height + self.cmbVoyage.top,
						 self.clientWidth - self.resizedMargin - self.resizedMargin,
						 stdHeight );
						 
	if _initialSetup then
		self.populateMachines();
	endif;

	stdWidth := self.width * 2 / 3;
	stdLeft :=  stdWidth / 4;
	top := ( self.height / 3 ) - stdHeight;
	top := self.cmbMachine.top + self.cmbMachine.height + 30;
	
	if _initialSetup then
		self.btnAddDelay.setAndIncrementTabIndex( tabIndex );
		self.btnAddDelay.visible := true;
	endif;
	self.btnAddDelay.move(	stdLeft,
							top,
							stdWidth,
							btnHeight );
						 
	top := self.resizedMargin + self.resizedMargin + self.btnAddDelay.height + self.btnAddDelay.top;
	if _initialSetup then
		self.btnEditDelay.setAndIncrementTabIndex( tabIndex );
		self.btnEditDelay.visible := true;
	endif;
	self.btnEditDelay.move( stdLeft,
							top,
							stdWidth,
							btnHeight );
							
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
