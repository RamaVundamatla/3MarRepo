    <JadeMethod name="valDocketTI" id="0caeb1d1-222f-4d8c-ac53-1c66dc795aed">
        <source>valDocketTI(pTISet : CM_TISet; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 05 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	updCntrl	: CMIF_TIUpdateController;
	ti			: CM_TrackedItem;
begin
	updCntrl := app.createTIUpdateControl(TI_UPDMODE_RECEIPT, null, null);	
	
	foreach ti in pTISet do
		ti.validateTrackedItem(updCntrl, _passport);
	endforeach;

epilog
	if updCntrl &lt;&gt; null then
		delete updCntrl;
	endif;
	
end;</source>
        <Parameter name="pTISet" type="CM_TISet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
