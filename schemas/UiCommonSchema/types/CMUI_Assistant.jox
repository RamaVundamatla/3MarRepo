    <JadeMethod name="showGeneralBlockAreaForm" id="1797aa5d-9cf2-454e-b2ae-ce86b5694731">
        <source>showGeneralBlockAreaForm(_gcArea: CM_IrregularBlockArea; _viewMode: Integer; _masterMenuAction: CMUI_MenuAction);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2013	cnwndl1	Initial creation	Par 32308

*/

constants
	
vars
	enqForm : Form;
	aClass : Class;
	assistClass : Class;
	sch : Schema;
	
	
begin

	sch := rootSchema.getSchema("GeneralCargoSchema");
	aClass := sch.getClass("GC_BlockAreaForm");
	assistClass := sch.getClass("GC_Assistant");
	
	enqForm := app.loadForm(aClass, assistClass, false, false, true, self.myTerminal, _masterMenuAction);
	if enqForm = null then
		return;
	endif;

	enqForm.sendMsgWithParams( "doInitializeWithTI", _gcArea, null, null );	
	enqForm.show(); 
	
epilog

end;</source>
        <Parameter name="_gcArea" type="CM_IrregularBlockArea"/>
        <Parameter name="_viewMode" type="Integer"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showGeneralCargoAreaForm" id="a88a12d5-caff-4601-a9dc-cfe03e13188b">
        <source>showGeneralCargoAreaForm(_object : CM_Object; _masterMenuAction : CMUI_MenuAction;
					_thumbnailOnly, _doEdit : Boolean);
//--------------------------------------------------------------
//Created: 30 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	generalCargoEnqForm : CM_BaseForm;
	menuAction : CMUI_MenuAction;
	ta: CM_TerminalArea;
begin
	
	if _object = null then
		return;
	endif;

	menuAction := app.myController.createMenuAction(PmGCGraphicalView, null, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	generalCargoEnqForm := menuAction.goToObject(null, null, false, null).CM_BaseForm;
	if generalCargoEnqForm = null then
		return;
	endif;
	
	ta := _object.CM_TerminalArea;
	generalCargoEnqForm.doInitializeWithTI(ta, null, null);
	generalCargoEnqForm.show();

end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_thumbnailOnly" type="Boolean"/>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showGraphicCommandForm" id="104b7b91-6f38-4da5-b18d-7e4bdb66e41d">
        <source>showGraphicCommandForm( _masterMenuAction : CMUI_MenuAction; _mode : Integer);
// ---------------------------------------------------------------------------
// Created:		November 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	graphicForm : Form;
begin
	if not app.isDevelopmentSystem then
		if not app.isSpecial() then
			return;
		endif;
	endif;
	
	graphicForm := app.loadForm(CMUI_GraphicCommandForm, CMUI_Assistant, false, false, true, self.myTerminal, _masterMenuAction);
	if graphicForm = null then
		return;
	endif;

	
	graphicForm.setPropertyValue("mode", _mode);	
	graphicForm.show(); 
	
epilog
end;</source>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showGridAreasForm" id="6334d244-18cf-4660-9706-7db2c8e3f13e">
        <source>showGridAreasForm(_terminalArea : CM_TerminalArea; _displayMode : Integer;_menuAction : CMUI_MenuAction );
// ---------------------------------------------------------------------------
// Created:		May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	yrdForm : Form;
	aClass : Class;
	jrw : Schema;
begin
	if _terminalArea = null then
		return;
	endif;

	if _terminalArea.isGridArea() then
		jrw := rootSchema.getSchema("YardSchema");
		aClass := jrw.getClass("YRD_GridAreasForm");
		yrdForm := app.loadForm(aClass, CMUI_Assistant, false, false, true, self.myTerminal, _menuAction);
		if yrdForm = null then
			return;
		endif;
	
		yrdForm.setPropertyValue("myInitializeObject", _terminalArea);
		yrdForm.show();
	else
		// Block Stacks etc. are shown in the Cargo Enquiry Form!
		self.showCargoEnquiryForm(_terminalArea, _menuAction, false, false);
	endif;

end;</source>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_displayMode" type="Integer"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
