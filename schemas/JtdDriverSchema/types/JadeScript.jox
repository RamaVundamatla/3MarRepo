    <JadeMethod name="th2CleanUpColourCoding" id="ac70830b-0f5a-492b-a7b1-c8c22cffb6bd">
        <source>th2CleanUpColourCoding();
constants
	VoyCode = 'PTN010002';
vars
	//ti			: CM_TrackedItem;
	voy			: CM_Voyage;
	
	
	bayVoy				: CM_BayVoyage;
	slotDefn			: CM_SlotDefn;
	aftSlot,
	slot				: CM_SlotController;
	ccAttr				: String;
	
	slotArray			: CM_SlotControllerArray;
	tmpLoadCC			: CMIF_LoadColorCode;
	editions			: CM_ObjectByOidEditionDict;
begin
	app.initialize();
	app.setMyTerminal(CM_Terminal.firstInstance);
	app.myPassport.setMyUser(app.myRoot.allUsers['SUPERUSER']);
	app.isGarbageCollectionProcess := true;
	
	voy := app.getMyTerminal.allVoyagesByCode.getAtKeyGeq(VoyCode, null);
	if voy = null or voy.code &lt;&gt; VoyCode then
		write aftSlot.allProductLocations.size.String;//barf
	endif;
	
	create slotArray transient;
	create tmpLoadCC transient;
	create editions transient;
	
	ccAttr := CM_SlotRequest.Attribute_Erase;
	foreach bayVoy in voy.myCellularVoyageStructure.allBayVoyagesByOrdinal do : bayLoop
		foreach slotDefn in bayVoy.allSlotsByOrdinal do : slotLoop
			if slotDefn.unavailable then
				continue slotLoop;
			endif;
			
			slot := slotDefn.CM_SlotDefnVoyage.mySlotController;
			if slot.isFortyBack then
				continue slotLoop;
			endif;
			
			
			slotArray.add(slot);
			editions.add(slot);
		endforeach;
	endforeach;
	if slotArray.isEmpty then
		return;
	endif;
	
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateSlotRequestAttribute(slotArray, null, true,
					editions, ccAttr, tmpLoadCC, app.myPassport);	
				
	if not app.myPassport.trxCompletedOK then
		app.myPassport.allErrorWarnings.inspect;
	endif;
	
	
epilog
	
	delete slotArray;
	delete editions;
end;
</source>
    </JadeMethod>
    <JadeMethod name="th2CleanUpJBLContainers" id="ebb8d1af-6f29-44e5-9dbd-69bd7f815b9c">
        <source>th2CleanUpJBLContainers();

vars
	
	ti			: CM_TrackedItem;
	objSet		: ObjectSet;
	obj			: Object;
	dict		: CM_TIByCargoTypeIdDict;
	iter		: Iterator;
	cargoTypeKey			: Integer;
	idKey			: String;
begin
	app.initialize();
	//special setting of terminal
	//app.myPassport.setMyTerminal(app.myRoot.allTerminals['T01']);
	app.isGarbageCollectionProcess := true;
	create objSet transient;
	dict := app.myPassport.myTerminal.allOnsiteTIsByCargoTypeId;
	iter := dict.createIterator;
	dict.startKeyGeq(TI_CargoType_Container, 'PTN', iter);
	
	while iter.next(ti) do
		dict.getIteratorKeys(cargoTypeKey, idKey, iter);
		if cargoTypeKey &lt;&gt; TI_CargoType_Container then
			break;
		endif;
		
		if (not idKey.startsWith('PTN')) then
			break;
		endif;
		
		objSet.add(ti);
	endwhile;
	
	foreach obj in objSet do
		beginTransaction;
		/*
		if (not app.isValidObject(obj.CM_TrackedItem.myVoyage)) then
			obj.CM_TrackedItem.setMyVoyage(app.getMyTerminal.getNullVoyage, app.myPassport);
			app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-' &amp; obj.CM_TrackedItem.id);
		endif;
		*/
		app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-deleting ' &amp; obj.CM_TrackedItem.id);
		obj.CM_TrackedItem.erase(NORMAL_ERASE);
		commitTransaction;
	endforeach;
					
			
epilog
	delete iter;
	delete objSet;
end;
</source>
    </JadeMethod>
    <JadeMethod name="th2CleanUpShip" id="f953335a-cf94-4409-b922-85a576f730bf">
        <source>th2CleanUpShip();

vars
	ti			: CM_TrackedItem;
	objSet		: CM_ObjectSet;
	voy			: CM_Voyage;
	globVoy		: CM_VoyageGlobal;
	vessel		: CM_Vessel;
	jobSheet	: CM_JobSheet;
	job			: CM_Job;
	
begin
	app.initialize();
	
	app.isGarbageCollectionProcess := true;
	
	//vessel := app.myRoot.allVessels['PTN'];
	
	create objSet transient;
	foreach voy in CM_Voyage.instances do
		if voy.myTerminal &lt;&gt; app.getMyTerminal then
			continue;
		endif;
		
		if voy.code[1:3] &lt;&gt; 'PTN' then
			continue;
		endif;
		
		if voy.code &lt;&gt; 'PTN010004' then
			continue;
		endif;
		
		beginTransaction;
		foreach jobSheet in voy.allJobSheets do
			foreach job in jobSheet.allJobsByOrder do
				//job.erase(NORMAL_ERASE);
				
			endforeach;
		endforeach;
		commitTransaction;
		
		beginTransaction;
		foreach ti in voy.allOnshipTIsByCargoTypeId do
			ti.allPlannedFutureMoves.purge();
			ti.allQueuedFutureMoves.purge();
			
			ti.erase(NORMAL_ERASE);
		endforeach;
		commitTransaction;
		
		beginTransaction;
		foreach ti in voy.allOnsiteTIsByCargoTypeId where (not ti.isChild) do
			ti.allPlannedFutureMoves.purge();
			ti.allQueuedFutureMoves.purge();
			app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-deleteing onsite TI ' &amp; ti.id);
			ti.erase(NORMAL_ERASE);
		endforeach;
		commitTransaction;
		
		objSet.add(voy);
	endforeach;
	
	beginTransaction;
	objSet.purge();
	commitTransaction;
	
	foreach globVoy in CM_VoyageGlobal.instances do
		if globVoy.code[1:3] &lt;&gt; 'PTN' then
			continue;
		endif;
		objSet.add(globVoy);
	endforeach;
	
	beginTransaction;
	objSet.purge();
	commitTransaction;
	
	beginTransaction;
	//app.getMyTerminal.inspect;//allVoyagesNew.rebuild();
	commitTransaction;
epilog
	delete objSet;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="th2CreateBookingRef" id="11e0c290-b15e-4d9e-9a25-db52db8794f2">
        <source>th2CreateBookingRef(_bookingRefId : String) : CM_BookingRef protected;
/*
----------   ----------  --------------------------------------------------
Created:	18 December 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	newBookingRef,
	pxyBookingRef		: CM_BookingRef;
	terminal			: CM_Terminal;
	root				: CM_Root;
	tmpHazards			: ObjectArray;
	disPorts			: StringArray;
	operator			: CM_Operator;
	isoTypeStr			: String;
begin
	
//	operator := jpCode to retrieve operator from file
//	isoTypeStr := jpCode to retrieve isoType from file
	
	create pxyBookingRef transient;
	create disPorts transient;
	create tmpHazards transient;
	/*pxyBookingRef.setProxy(_bookingRefId,
							null,
							TI_CargoType_Container,
							false,
							terminal.getConfig(EmptyCommodity).String.trimBlanks,
							null,
							"Cargo for JMT Benchmarking",
							'AUBNE',//destination brisbane
							'AUBNE',//also the discharge port
							disPorts,//optional discharge ports stringarray (empty)
							tmpHazards, //hazards
							null, //humidity
							false, //inspected
							"2200", //isoType
							root.allConsigneeConsignors.first, //consignor
							root.allConsigneeConsignors.first, //consignee
							app.myRoot.allOperators["PON"],//operator
							terminal.getNullVoyage,
							null,
							"Booking Ref for JMT Benchmarking",
							null,//remarks
							null,//temperature
							null,
							null,//height
							null,//length
							null,//width
							null,
							null,
							null,
							null,//type
							null,//density
							null,//volume
							null,//product quantity
							null,//weight
							null,//cubic meters
							terminal,
							null, //product
							false,
							false,
							null, null,
							null, // shippingRef
							null, null, null, null,
							null, null, null, null, 
							null, null, null, null, null, null
							);/**/
	app.myPassport.warningsAcknowledged := true;
	app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateBookingRef(pxyBookingRef, app.myPassport, null, newBookingRef);				
	
	if (not app.myPassport.trxCompletedOK) then
		app.msgBox('Booking reference creation failed for "' &amp; _bookingRefId &amp; '". Here comes the inspect of the errors...','Booking reference creation failure', MsgBox_Exclamation_Mark_Icon);
		
		app.myPassport.allErrorWarnings.inspectModal;
		return null;
	endif;
	
	return newBookingRef;
	
epilog
	delete pxyBookingRef;
	delete disPorts;
	delete tmpHazards;
	
end;

</source>
        <access>protected</access>
        <Parameter name="_bookingRefId" type="String"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="th2GetAndPrepareBookingRefs" id="e7e8c19a-72cc-44d6-9b06-d8412af07ad9">
        <source>th2GetAndPrepareBookingRefs();
/*
----------   ----------  --------------------------------------------------
Created:	18 December 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
constants
	NumberOfBookings		= 50;
vars
	
	terminal			: CM_Terminal;
	bookingRef			: CM_BookingRef;
	idx					: Integer;
	str,
	bookingRefId		: String;
					
begin

	beginTransaction;
	CM_BookingRef.instances.purge();
	commitTransaction;
	app.initialize();
	
	terminal := app.getMyTerminal;
	foreach idx in 1 to NumberOfBookings do
		bookingRefId := self.BOOKINGREF_PREFIX &amp; idx.String;
		bookingRef := terminal.allBookingRefsByRef[bookingRefId];
		if bookingRef = null then
			bookingRef := self.th2CreateBookingRef(bookingRefId);
		endif;
		
		str := str &amp; bookingRef.bookingReference &amp; ',';
	endforeach;
	
	str := str[1:str.length -1];
	write str;
	
epilog
	app.finalize();
end;





</source>
    </JadeMethod>
    <JadeMethod name="th2GetAndPrepareValidUsers" id="35e20b5b-1214-4486-b783-151f77087a6b">
        <source>th2GetAndPrepareValidUsers();
/*
----------   ----------  --------------------------------------------------
Created:	18 December 2006 By cnwth2

Purpose:	1) writes out the codes of users who have root level secruty at both a 
			system and terminal level
			2)resets their 'user window' objects to be only main form
			3)resets their passwords to 'password1' and never expire

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	user			: CM_User;
	str				: String;
	userTerminal	: CM_UserTerminal;
	userWindow		: CM_UserWindowForOpen;
begin
	app.initialize();

	beginTransaction;
	foreach user in app.myRoot.allUsers do :userLoop
		if (not CM_SecurityRoleSystemRoot.hasInstance(user.mySystemSecurityRole)) then
			continue;
		endif;
		
		//exlude superuser from the mix as he's treated differently throughout the code
		if user.code.trimBlanks.toUpper() = 'SUPERUSER' then
			continue;
		endif;
		
		foreach userTerminal in user.allUserTerminals do : userTerminalLoop
			if (not CM_SecurityRoleTerminalRoot.hasInstance(userTerminal.mySecurityRole)) then
				continue userLoop;
			endif;
		endforeach;
		
		//'userWindow' objects serve to 'remember' the users last open windows and their state
		//here we are getting rid of everything except the main form (which is required)
		user.recentPasswords.purge();
		user.setPassword('password1', false);
		user.updateNumberLogonAttempts(null);
		user.setPropertyValue('status', EnabledNormalUser);
		user.allUserWindows.purge();
		user.allUserWindowsForStartup.purge();
		
		foreach userWindow in user.allUserWindowsForOpen do
			if userWindow.windowClassName &lt;&gt; 'CMUI_SuperAppForm2' then
				userWindow.erase(NORMAL_ERASE);
			endif;
		endforeach;
		
		//user has top level security at system and terminal levels
		str := str &amp; user.code &amp; ',';
	endforeach;
	commitTransaction;
	
	str := str[1:str.length-1];
	write str;
epilog
	app.finalize();
end;


</source>
    </JadeMethod>
    <JadeMethod name="th2PrepareOperator" id="6138d705-1c86-4bd2-95f2-ea06e4352280">
        <source>th2PrepareOperator(_op : CM_Operator input) protected;

vars

begin
	beginTransaction;
	_op.setPropertyValue('requiresBookingReference', false);
	_op.setPropertyValue('requiresCVC', false);
	_op.setPropertyValue('requiresDeliveryRelease', false);
	_op.setPropertyValue('requiresHumidity', false);
	_op.setPropertyValue('requiresRequestNumber', false);
	_op.setPropertyValue('requiresVentilation', false);
	_op.setPropertyValue('requiresVoyage', false);
	_op.setPropertyValue('isNotAvailableForEntry', false);
	commitTransaction;
end;
</source>
        <access>protected</access>
        <Parameter name="_op" type="CM_Operator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="th2PrepareOperators" id="6691f02a-54cf-4d3c-9bef-c3af4d89dd70">
