    <JadeMethod name="sysNotify" id="ed4eb950-56b4-43f7-82aa-e36a85c1f8d2">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//----------------------------------------------------------------
//	Created:	14 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(eventType,theObject, eventTag);

	if CM_BlockStack.hasInstance(theObject) then
		//update TA display
		self.setFormHeading();
	endif;
	
	self.handleNoteForBoxcarCargo( eventType, theObject, eventTag );	//Par 31278

	self.showHideControls();	//	cnwvu1 06/09/2006

end;</source>
