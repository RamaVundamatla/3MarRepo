    <JadeMethod name="verifySelf" id="d938ab38-31db-4855-8242-0b3aa4bff553">
        <updating/>
        <source>verifySelf() updating;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
//
// 28 Nov 2018	jlgrs1	TFS 42276 STWR Make EDI MultiThreaded Stage 7
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 02 Oct 2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
// 04 Aug 2022	navma1	ChangeRequest 54219: EUP - Cargo Group to be mandatory
// 29 Nov 2022	jlika1	TFS 55586 HS Code User Defined EDI
// 11/01/2023	navkc1	TFS CR 55625 TASK 55660 Task 55660: Jade - Contract Id EDI TRX
// 20/06/2023	navdap1	TFS 57074 EUP Manifest EDI Load / Operations Task 58604
// 23/06/2023	navdap1	TFS 58813 EUP - Manifest Instructions
// 01/04/2025	navcs2	MTN-34491 EUP FR | 53824 - No errors when weights and quantities are zero
// 01/10/2025	navdap1	MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)

vars
	terminal			: CM_Terminal;
	voyage				: CM_Voyage;
	existingItem		: CM_TrackedItem;
	site				: Integer;
	trxStateEntered		: Boolean;
	allowDupPrenotes	: Boolean;
begin
	terminal := self.getMyTerminal();
	allowDupPrenotes := self.getMyTerminal.getConfig(AllowDuplicatePreNotes).Boolean;	//02.Nov.2023 navsp1 TFS 61067
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, 'null', null, null);
		return;
	endif;
	
	if self.isTransportManifestRelated then
		if self.totalQuantity &lt; 1 then																												// 01/04/2025	navcs2	MTN-34491
			app.raiseCMException1(Must_greater_than_zero, app.getErrorString(CM_Total_Quantity), app.getErrorString(CM_Total_Quantity), self);		// 01/04/2025	navcs2	MTN-34491
		endif;																																		// 01/04/2025	navcs2	MTN-34491
		
		if self.getTotalWeight &lt;= 0 then																											// 01/04/2025	navcs2	MTN-34491
			app.raiseCMException1(Must_greater_than_zero, app.getErrorString(Total_weight), app.getErrorString(Total_weight), self);				// 01/04/2025	navcs2	MTN-34491
		endif;																																		// 01/04/2025	navcs2	MTN-34491
		
		if self.myCargoType.isTrackByVolume then																									// 01/04/2025	navcs2	MTN-34491
			if self.volume &lt;= 0 then																												// 01/04/2025	navcs2	MTN-34491
				app.raiseCMException1(Must_greater_than_zero, app.getErrorString(Volume), app.getErrorString(Volume), self);						// 01/04/2025	navcs2	MTN-34491
			endif;																																	// 01/04/2025	navcs2	MTN-34491
		endif;																																		// 01/04/2025	navcs2	MTN-34491
	endif;	
	
	if id.trimBlanks = null then
		app.raiseCMException2(ERR_FIELD_ID,id, 'ID', ETRow_Id, self);
	endif;
	//cnwmc5 - 11 Dec 2013 - PAR 33088
	if self.id.length &gt; 20 then
		app.raiseCMException2(ContainerIdToLong, self.id, '20', ETRow_Id, self);
	endif;
	
	//cnwmc5 - 2 May 2014 - PAR 34057
	if self.messageMode = CM_EDITrackedItem.EDI_ACTION_MODIFY then
		return;
	endif;
	
	//No need to verify all the values if it's a "Cancel" request for the transport manifest request.					//25.Jan.24 navsp1 TFS 62193
	if self.myEDIData.isTransportManifestRelated and self.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
		return;
	endif;
	
	if CM_EDIDataCargo.hasInstance(self.myEDIData) then
		site := self.myEDIData.CM_EDIDataCargo.createToSite;
	elseif CM_EDIDataDeckPlan.hasInstance(self.myEDIData) then
		site := TI_SITE_ONSHIP;
	elseif self.myEDIData.isTransportManifestRelated and CM_EDIDataGateDoc.hasInstance(self.myEDIData) then	//02.Nov.2023 navsp1 TFS 61067
		site := TI_SITE_TBA;
	endif;
	//th2 for PAR13553 - can already be in transaction state if the user
	//clicks on the 'save and verify' button
	if (not process.isInTransactionState) then
		trxStateEntered := true;
		beginTransaction;	//par 13451 cnwrs1 Feb 2007 this should not be necassary as verifies should be non updating
	endif;
	self.verifyId();
	self.verifyISOType();
	self.verifyCargoType();

	self.verifyCarrier();
	self.verifyCommodity();
	self.verifyConsignee();
	self.verifyConsignor();
	self.verifyIMEXStatus(terminal);
	self.verifyBookingRef(); //jlier1 TFS 53621 30/5/22 - must verify after the imex is set because the booking validation checks IMEX
	self.verifyPorts(terminal);
	self.verifyHazards();
	self.verifyHumidity();
	self.verifyOperator();
	self.verifyProduct();
	self.verifyRelease();
	self.verifyVolume();
	self.verifyWeight();
	self.verifyTemperature();
	self.verifyAvailabilityGrade();	// cnwrl1 03/02/2010 PAR 21758
	self.verifyTrailerType(); 		// PAR 22476 cnwgb1 26.2.2010
	self.verifyCustomsAgent();		//31 Oct 2012	NDL	Par 30645
	self.verifyTransportMode();		//31 Oct 2012	NDL	Par 30645
	self.verifyAlternateId();		//06 May 2013	NDL	Par 31506
	self.verifyColour();			//14 Aug 2013	DMP Par 32123
	self.verifyVehicleMake();		//20 Sep 2013	DMP Par 32215
	self.verifyVehicleModel();		//20 Sep 2013	DMP Par 32215
	self.verifyVehicleType();		//20 Sep 2013	DMP Par 32215
	self.verifyVent();
	self.verifyStevedore();			//02.10.2020 cnwma1 TFS #50112
	self.verifyCargoGroup();		//04.08.2022 navma1 #54219
	self.verifyHSCode();
	self.verifyContractId();		// 11/01/2023	navkc1	TFS CR 55625 TASK 55660
	self.verifySortingMethod();		// TFS 57805
	self.verifyInstructionType();	// TFS 58813
	self.verifyCargoTypeAndProdContents();	// MTN-36141
	
	voyage := self.verifyVoyage(terminal, null);

	if trxStateEntered then
		commitTransaction;
	endif;
	
	if site = TI_SITE_ONSITE then
		existingItem := terminal.allOnsiteTIsByCargoTypeId[self.cargoType, self.id];
		if existingItem &lt;&gt; null then
			app.raiseCMException1(ERR_DUP_ONSITE_TI, self.id, ETRow_Id, self);
		endif;
	elseif site = TI_SITE_ONSHIP then
		voyage := terminal.lookupVoyage(self.getVoyageCode(), null, false);
		if voyage &lt;&gt; null then
			existingItem := voyage.allOnshipTIsByCargoTypeId[self.cargoType, self.id];
			if existingItem &lt;&gt; null then
				app.raiseCMException2(Ship_already_exists, self.id, self.getVoyageCode(), ETRow_Id, self); // cnwdb2 PAR 35364
				
			endif;
		endif;
	elseif site = TI_SITE_TBA then
		existingItem := terminal.allNotifiedTIsByCargoTypeId[self.cargoType, self.id];
		if existingItem &lt;&gt; null and not allowDupPrenotes and (self.cargoType &lt;&gt; null and not self.myCargoType.allowDuplicates) then					//02.Nov.2023 navsp1 TFS 61067
			app.raiseCMException1(ERR_DUP_NOTIFIED_TI, self.id, ETRow_Id, self);
		endif;
	endif;
	self.verifyParentage(terminal);
	
	self.verifyCountryOfOrigin(); //jlier1 TFS 54846 30/9/22
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="verifySortingMethod" id="6083a977-db29-4cca-a4db-a3919a1f4c59">
        <source>verifySortingMethod() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2023	navsp1	Initial creation TFS ChangeRequest 57805: EUP - Manifest Processing - Truck - Create

*/

vars

begin
	if self.sortingMethod = null then
		return;
	endif;
	
	if app.myRoot.allSortingMethods[self.sortingMethod] = null then
		app.raiseCMException1(Sorting_method_invalid, self.sortingMethod, null, null);
	endif;
epilog

end;</source>
