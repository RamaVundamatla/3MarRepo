    <JadeMethod name="addTIAvailable" id="00ec65f2-3142-4c94-9302-6edc170dd61d">
        <updating/>
        <source>addTIAvailable( _theTI : CM_TrackedItem) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jul 2009	cnwrd1	Initial creation
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars

begin

	if _theTI = null then
		return;
	endif;
	
	//check if we have somehow already done something with this ti.

	if self.allActionedTIs.includes(_theTI) then
		return;
	elseif self.allCompleteTIs.includes(_theTI) then
		return;
	elseif not self.allAvailableTIs.includes(_theTI) then
		self.allAvailableTIs.add(_theTI);	
	endif;
	

epilog

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addTransToWODetail" id="f31ecbf0-99cc-47b9-a049-41c9a52e3a04">
        <source>addTransToWODetail(_transaction : CM_TITransaction);
/*

Purpose:			 // TFS 43405 JLGAB1
						Release and Release Extension cargo WOs need to link to the storage, as it is prepay the transaction will be NOCHARGE = true.
						The combination of nocharge and link to WO allows the invoicing to work correctly.
Parameters:			

Return Value:		

Date		Who		Reason
26 March 2019	jlgab1	Initial creation

*/

vars

begin
	if _transaction = null
	or _transaction.type &lt;&gt; TRANS_TYPE_STORAGE then
		return;
	endif;
	
//	do not clear this collection out  - self.allTxnsCompleted.clear();
	self.allTxnsCompleted.add(_transaction);

epilog

end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
    </JadeMethod>
