    <JadeMethod name="importFromXMLDoc" id="0040b598-1398-47af-807a-5d5aef188a89">
        <updating/>
        <source>importFromXMLDoc(_jadeXMLElement : JadeXMLElement input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 April 2011	cnwer1	Initial creation

*/

vars
	xmlAttribute  : JadeXMLAttribute;
	childNode 	  : JadeXMLNode;
	childElement  : JadeXMLElement;
	iter   : Iterator;
	propertyName	: String;
	propertyValue : String;
	property		: Property;
	memberType 		: Type;
begin
	if _jadeXMLElement = null then
		return;
	endif;
	
	if not self.isTransient then
		return;
	endif;
	
	xmlAttribute:=_jadeXMLElement.getAttributeByName('type');
	if 	xmlAttribute.value &lt;&gt; self.class.name then
		//somethings wrong should be looking at ourself
		return;
	endif;
	
	iter:=_jadeXMLElement.childNodes.createIterator;
	while iter.next(childNode) do
		if not childNode.isKindOf(JadeXMLElement) then
			continue;
		endif;
		childElement:=childNode.JadeXMLElement;
		
		propertyName:=childElement.tagName;
		xmlAttribute:=childElement.getAttributeByName('type');
	
		property:=self.class.findProperty(propertyName);
		if property = null then
			continue;
		endif;
		
		if xmlAttribute &lt;&gt; null then
			self.importFromXMLDocReference(property,childElement);	
			continue;
		endif;
		
		if property.isKindOf(Attribute) then
			self.importFromXMLDocAttribute(property.Attribute,childElement);
		endif;
		
		
	endwhile;
	
	//we have found what we want to import
	
	
epilog
	delete iter;
end;</source>
        <Parameter name="_jadeXMLElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="importFromXMLDocAttribute" id="d544ec0a-d0d9-403b-8a3c-06ad3bf8db2e">
        <updating/>
        <source>importFromXMLDocAttribute(_attribute : Attribute input; _jadeXMLElement : JadeXMLElement input) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 April 2011	cnwer1	Initial creation

*/

vars
	
	value : Any;
	
begin
	
	value:=_jadeXMLElement.textData.Any;
	

	if  _attribute.type = Decimal then
		value:=value.Decimal;
	elseif  _attribute.type = Integer then
		value:=value.Integer;
	elseif  _attribute.type = Boolean then
		value:=value.Boolean;
	elseif  _attribute.type = Point then
		value:=value.Point;
	elseif  _attribute.type = Date then
		value:=value.Date;
	elseif  _attribute.type = Time then
		value:=value.Time;
	elseif  _attribute.type = TimeStamp then
		value:=value.TimeStamp;
	elseif  _attribute.type = Real then
		value:=value.Real;
	elseif _attribute.type = Character then
		value:=value.Character;
	elseif _attribute.type = Binary then
		value:=value.Binary;
	else
		value := value.String.xmlReplaceReservedChars(false);	//01 Apr 2016	NDL	TFS 1764
	endif;
	
	self.setPropertyValue(_attribute.name,value);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_attribute" type="Attribute" usage="input"/>
        <Parameter name="_jadeXMLElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
