    <JadeMethod name="doUpdateSubcargoWeight" id="8975f2bf-23bf-40ad-83fa-85fd0b8e9ac3">
        <source>doUpdateSubcargoWeight(_noOfItems : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 November 2013	cnwmc5	Initial creation	PAR 32953

*/

vars
	value,
	unitVolume,
	unitWeight : Decimal[14,4]; 
begin
	//epr TFS 1707 6/4/16
	if self.hasPreNote() and self.myTI.isBulkByQuantity then
		if not self.totalWeightVolumeChanged then
			unitWeight:= self.myTI.totalWeight/self.myTI.totalQuantity;
			self.tblTotalWeight.setValue(_noOfItems * unitWeight);
			unitVolume := self.myTI.totalVolume/self.myTI.totalQuantity;
			self.tblTotalVolume.setValue(_noOfItems * unitVolume);
		endif;
	endif;
	
	if self.myBookingRefItem = null then
		return;
	endif;
	
	if self.myBookingRefItem.productWeight &lt;&gt; null and self.myBookingRefItem.productWeight &lt;&gt; 0 then
		value := (self.myBookingRefItem.productWeight * _noOfItems);
		self.tblTotalWeight.setValue(value);
	endif;
epilog

end;</source>
        <Parameter name="_noOfItems" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doVoyageCodeLostFocus" id="79e084b1-02ae-4cb5-80f0-7501c34b93d7">
        <source>doVoyageCodeLostFocus();
/*
Date		    Who			Reason
06 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	voyage : CM_Voyage;
	structure : CM_ROROVoyageStructure;
	cargoType : CM_CargoType;
begin
	if self.isOnshipForm then
		if self.cmbVoyageCode.listObject &lt;&gt; null then
			voyage := self.cmbVoyageCode.listObject.CM_Voyage;
			if voyage &lt;&gt; null and voyage.myROROStructure &lt;&gt; null then
				structure := voyage.myROROStructure;
			endif;
		endif;
	
		self.frmCoordinates.visible := (structure &lt;&gt; null);
	//	self.frmCoordinates.isHidden :=structure = null;
		if not self.frmCoordinates.visible then
			self.txtX.text := null;
			self.txtY.text := null;
		endif;
		
		cargoType := cmbType.getObject.CM_CargoType;
		if cargoType &lt;&gt; null and cargoType.id = TI_CargoType_Container then
			self.chkOOTL.visible := (structure &lt;&gt; null);
		else
			self.chkOOTL.visible := false;
		endif;	
		
		
	endif;
epilog

end;</source>
    </JadeMethod>
