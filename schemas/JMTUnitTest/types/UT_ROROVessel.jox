    <JadeMethod name="tCreateROROVesselSubDeck" id="1669b0e6-03e9-49b1-a625-ad095a44ea78">
        <source>tCreateROROVesselSubDeck();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 March 2011	cnwer1	Initial creation

*/

vars
	vessel : CM_Vessel;
	parentDeck : CM_DeckVessel;
	pxyDeck	 : CM_DeckVesselSub;
	realDeck :  CM_Deck;
		
	code : String;
	description : String;
	remarks : String;
	maxClearHeight,
	totalArea : Decimal[12,2];
	ordinal: Integer;
	totalVolume : Decimal[12,2];
	totalTEU : Integer;
	totalLM,
	maxLoadStack20,
	maxLoadStack40,
	maxLoadAxel,
	maxLoadM2   : Decimal[12,2];
	numTier : Integer;
	heightFromBL : Decimal[12,2];
begin
	self.tCreateROROVesselDeck();
	vessel:=self.getVessel("UT_RORO" );
	parentDeck:=vessel.myROROVesselStructure.allDecks[1];
	
	create pxyDeck transient;
	
	code:="SUB1";
	description:="SUB1 Description";
	remarks:="Some sub decking remarks";
	maxClearHeight:=20.5;
	totalArea:=30000.67;
	totalVolume:=234.89;
	totalTEU:=10000;
	totalLM:=23423.45;
	maxLoadStack20:=12342.67;
	maxLoadStack40:=62423.56;
	maxLoadAxel:=87534.45;
	maxLoadM2:=234.56;
	numTier:=3;
	heightFromBL:=63455.67;
	ordinal:=1;
	//cnwmc5 - 20 Sep 2012
	if parentDeck.allSubDecks &lt;&gt; null then
		ordinal:=2;
	endif;
	
	pxyDeck.setProxy(	code ,
						description,
						remarks,
						maxClearHeight,
						totalArea,
						totalVolume,
						totalTEU,
						totalLM,
						maxLoadStack20,
						maxLoadStack40,
						maxLoadAxel,
						maxLoadM2 ,
						numTier ,
						heightFromBL );
	pxyDeck.setMyParentDeck(parentDeck);
	
	app.myTrxCA.trxCreateRORODeck(pxyDeck,realDeck,false,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertNotNullMsg(realDeck, " Sub deck = null");
	self.assertTrueMsg(realDeck.isKindOf(CM_DeckVesselSub)," sub vessel deck created incorrect type");
	self.assertEqualMsg(realDeck.CM_DeckVesselSub.myParentDeck, parentDeck, " myROROStructure ref = null");
	self.assertEqualMsg(realDeck.code, code,"code !=");
	self.assertEqualMsg(realDeck.description, description,"description !=");
	self.assertEqualMsg(realDeck.remarks, remarks,"remarks !=");
	self.assertEqualMsg(realDeck.maxClearHeight, maxClearHeight,"maxClearHeight !=");
	self.assertEqualMsg(realDeck.totalArea, totalArea,"totalArea !=");
	self.assertEqualMsg(realDeck.ordinal, ordinal,"ordinal !=");
	self.assertEqualMsg(realDeck.totalVolume, totalVolume,"totalVolume !=");
	self.assertEqualMsg(realDeck.totalTEU, totalTEU,"totalTEU !=");
	self.assertEqualMsg(realDeck.maxLoadStack20, maxLoadStack20,"maxLoadStack20 !=");
	self.assertEqualMsg(realDeck.maxLoadStack40, maxLoadStack40,"maxLoadStack40 !=");
	self.assertEqualMsg(realDeck.maxLoadAxel, maxLoadAxel,"maxLoadAxel !=");
	self.assertEqualMsg(realDeck.maxLoadM2, maxLoadM2,"maxLoadM2 !=");
	self.assertEqualMsg(realDeck.numTier, numTier,"numTier !=");
	self.assertEqualMsg(realDeck.heightFromBL, heightFromBL,"heightFromBL !=");

	
epilog
	delete pxyDeck;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateROROVoyageStructure" id="9f9f9e14-70c8-4ade-9dc4-aee8c8ba05d3">
        <source>tCreateROROVoyageStructure();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	vessel 		: CM_Vessel;	 
	voyage 		: CM_Voyage;
	vesselName 	, voyageName: String;
	voyageCellularStructure : CM_CellularVoyageStructure;
	voyageROROStructure 	: CM_ROROVoyageStructure;
	voyageDeck 				: CM_DeckVoyage;
	voyageStructuralElements : CM_VoyageStructuralElements;
	roroRampExternalVessel, realRamp : CM_RORORampExternalVessel;
	realDeckItem	: CM_DeckItem;
	section : CM_VesselSectionVessel;
	realSection: CM_VesselSection;
	tank 	: CM_VesselTankVessel;
	realTank	: CM_VesselTank;
	ct : CM_CargoType;
begin
	vesselName:="UT_RORO";
	voyageName:="UT_RORO001";
	self.deleteVessel(vesselName);
	self.deleteVoyage(voyageName);
	self.assertNull(self.getVessel(vesselName));
	
	vessel:=self.xCreateROROVesselStructure(vesselName);
	
//	self.addVesselDecks(vesselName);
	// AKB MOVED THIS TO DSL Layer self.xCreateROROVesselDeck();

	create roroRampExternalVessel transient;
	roroRampExternalVessel.setProxyDeckItem("External Ramp",null,null,null,null);
	roroRampExternalVessel.setMyROROStructure(vessel.myStructuralElements);
	
	app.myTrxCA.trxCreateRORODeckItem(roroRampExternalVessel,realDeckItem,app.myPassport);
	assertNoTrxErrorsOrWarnings();
	self.assertNotNull(	realDeckItem);
	
	create section transient;
	section.setProxy("Sec1",null,null);
	section.setMyVesselStructure(vessel.myStructuralElements);
	app.myTrxCA.trxCreateVesselSection(section,realSection,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realSection,"real CM_VesselSectionVessel is null");

	create tank transient;
	
	tank.setProxy("Tank",null,null,null,null);
	tank.setMyVesselStructure(vessel.myStructuralElements);
	
	app.myTrxCA.trxCreateVesselTank(tank,realTank,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realTank,"real CM_VesselTankVessel is null");
	
	voyage:=self.addVoyageWithConRORO(voyageName, vesselName, "ANL", "ANZ", null, 0, false, true);
	
	voyageCellularStructure:=voyage.myCellularVoyageStructure;
	//check cellularStructure created
	self.assertNotNullMsg(voyageCellularStructure,"has cellular structure");
	
	voyageStructuralElements := voyage.myStructuralElements;
	
	self.assertNotNullMsg(voyageStructuralElements, "has structural element");
	//section
	self.assertNotNullMsg(voyageStructuralElements.allSections["Sec1"],"has section");
	//tank
	self.assertNotNullMsg(voyageStructuralElements.allTanks["Tank"],"has Tank");
	//roro structure
	voyageROROStructure:=voyage.myROROStructure;
	self.assertNotNullMsg(voyageROROStructure,"has roro structure");
	//ext ramps
	self.assertNotNullMsg(voyageStructuralElements.allRamps["External Ramp"],"has ext ramp");
	
	//check the decks
	voyageDeck:=voyageROROStructure.allDecksByCode[DECK1];
	self.assertNotNullMsg(voyageDeck,"no Deck1 ");
	self.assertEqualMsg(voyageDeck.description, "DECK1 Description","description !=");
	self.assertEqualMsg(voyageDeck.remarks, "Some decking remarks","remarks !=");
	self.assertEqualMsg(voyageDeck.maxClearHeight, 20.50.Decimal,"maxClearHeight !=");
	self.assertEqualMsg(voyageDeck.totalArea, 30000.67.Decimal,"totalArea !=");
	self.assertEqualMsg(voyageDeck.ordinal, 1,"ordinal !=");
	self.assertEqualMsg(voyageDeck.totalVolume, 234.89.Decimal,"totalVolume !=");
	self.assertEqualMsg(voyageDeck.totalTEU, 10000,"totalTEU !=");
	self.assertEqualMsg(voyageDeck.totalLM, 23423.45.Decimal,"totalLM !=");
	self.assertEqualMsg(voyageDeck.maxLoadStack20, 50000.00.Decimal,"maxLoadStack20 !=");
	self.assertEqualMsg(voyageDeck.maxLoadStack40, 80000.00.Decimal,"maxLoadStack40 !=");
	self.assertEqualMsg(voyageDeck.maxLoadAxel, 87534.45.Decimal,"maxLoadAxel !=");
	self.assertEqualMsg(voyageDeck.maxLoadM2, 234.56.Decimal,"maxLoadM2 !=");
	self.assertEqualMsg(voyageDeck.numTier, 3,"numTier !=");
	self.assertEqualMsg(voyageDeck.heightFromBL, 63455.67.Decimal,"heightFromBL !=");
	
	voyageDeck:=voyageROROStructure.allDecksByCode[DECK2];
	self.assertNotNullMsg(voyageDeck,"no Deck2 ");
	
	// AKB ADDED
	voyageDeck:=voyageROROStructure.allDecksByCode[DECK1];
	if voyageDeck &lt;&gt; null then
		self.addROROVoyageContainers(voyageDeck,false, 0);
		self.addROROVoyageGC(voyageDeck);
		self.addROROVoyageOOTL(voyageDeck);
	endif;
epilog
	delete roroRampExternalVessel;
	delete section;
	delete tank;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateUpdateWorkPoints" id="2b019e6e-be2e-4e4d-9cca-57bbfbf93cd1">
        <source>tCreateUpdateWorkPoints();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2011	cnwer1	Initial creation CCMS MES 1116
02 Oct  2018    cnwma1  ChangeRequest 41234: SAP Integration - Mapping fields
26 Apr 2023 	navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types
*/

vars
	pxyWorkPoint , realWorkPoint: CM_WorkPoint;
	workPointType				: CM_WorkPointType;
begin

	realWorkPoint:=app.myPassport.myTerminal.allWorkPointsByCode["UT_WorkPoint"];
	workPointType := self.getTerminal.allWorkPointTypes[WORK_POINT_TYPE_SHIP,'SHIP'];													//04.5.2023 navhl20 #57712[54552]
	if realWorkPoint &lt;&gt; null then
		app.myTrxDA.trxDeleteWorkPoint(realWorkPoint,app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	create pxyWorkPoint transient;
	
	//pxyWorkPoint.setProxy("UT_WorkPoint","Work point 1 description",Green,100, 60, 400, app.myPassport.myTerminal,null);				//26.4.2023 navhl20 #57712[54552]
	pxyWorkPoint.setProxy("UT_WorkPoint","Work point 1 description",Green,100, 60, 400, app.myPassport.myTerminal,workPointType,null);	//26.4.2023 navhl20 #57712[54552]
	
	app.myTrxCA.trxCreateWorkPoint(pxyWorkPoint,realWorkPoint,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(realWorkPoint.code, "UT_WorkPoint", "Create Code !=");
	self.assertEqualMsg(realWorkPoint.description, "Work point 1 description", "Create Description !=");
	self.assertEqualMsg(realWorkPoint.colour, Green, "Create Colour !=");
	self.assertEqualMsg(realWorkPoint.jobSeed, 100, "Create Job Seed !=");
	self.assertEqualMsg(realWorkPoint.targetRatePHLM, 60, "Create Target rate LM !=");
	self.assertEqualMsg(realWorkPoint.targetRatePHWeight, 400, "Create Target rate Weight !=");
	self.assertNotNull(realWorkPoint.myWorkPointType);																					//04.5.2023 navhl20 #57712[54552]
	
	delete pxyWorkPoint;
	
	beginLoad;
	pxyWorkPoint:=realWorkPoint.pxyCreateUpdateProxy;
	endLoad;
	app.myTrxUA.trxUpdateWorkPoint(pxyWorkPoint,app.myPassport);
	
	delete pxyWorkPoint;
	
epilog
	endLoad;													// 19/04/2013 cnwmh5 #31457
	delete pxyWorkPoint;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateVoyageDeckJobSheet" id="2d550dea-ee50-4bc1-87c2-1a48b34236eb">
        <source>tCreateVoyageDeckJobSheet();
/*
Purpose:			
Parameters:			

Return Value:		


Date		Who		Reason
02 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	workPoints 		: ObjectArray;
	workPoint 		: CM_WorkPoint;
	voyage 			: CM_Voyage;
	operator 		: CM_Operator;
	vessel 			: CM_Vessel;
begin
	
	workPoint:=self.addWorkPoint("UT_WP", true);
	
	if workPoint = null then
		return;
	endif;
	
	self.deleteVessel("UT_ROROOP");
	operator := app.myRoot.allOperators["ANL"];
	vessel := self.addVesselLOLOholdsRORO("UT_ROROOP",operator);
	
	if vessel = null then
		return;
	endif;
	
	
	self.deleteVoyage("UT_ROROOP1");
	voyage := self.addVoyageWithConRORO("UT_ROROOP1", "UT_ROROOP", "ANL", "DOUG", null, 0, false, true);
	
	if voyage = null then
		return;
	endif;
	
	create workPoints transient;
	workPoints.add(workPoint);
	
	app.myTrxUA.trxUpdateVoyageJobSheet(workPoints,voyage,CM_VoyageDeckJobSheet,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings;
	
	//app.myTrxCA.trxCreateVoyageJob(
	
epilog
	delete workPoints;
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;WorkPointDeleteIssue&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tDeleteRORODeck" id="88bcf595-345c-4c3c-88e2-f3c1fcc85dc5">
        <source>tDeleteRORODeck();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 March 2011	cnwer1	Initial creation

*/

vars
	vessel : CM_Vessel;
	realDeck : CM_DeckVessel;
begin	
	self.tCreateROROVesselDeck();
	vessel:=self.getVessel("UT_RORO" );
	self.assertNotNullMsg(vessel, "vessel = null");
	realDeck:=vessel.myROROVesselStructure.allDecks[1];
	self.assertNotNullMsg(realDeck, "real deck = null");
	
	app.myTrxDA.trxDeleteRORODeck(realDeck,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertNullMsg(vessel.myROROVesselStructure.allDecks[1],"deck not deleted");
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tDeleteRORODecks" id="1dad2331-7114-4fdc-bf51-425a1763b1ce">
        <source>tDeleteRORODecks();
/*

Purpose:	delete Roro Vessel Decks		

Date		Who		Reason
15 May 2014	cnwma1	Initial creation

*/
constants
	VSLName ="UT MA RORO";
vars
	vessel : CM_Vessel;
	vesselDecks : ObjectArray;
	allDecks						: CM_DeckVesselByOrdinalDIct;
	deck							: CM_Deck;
begin
	// Delete Vessel
	self.deleteVessel(VSLName);
	vessel := addVesselLOLOholdsRORO(VSLName,self.getOperator("APL"));

	create allDecks transient;
	vessel.myROROVesselStructure.allDecks.copy(allDecks);
	
	// get the ordinals for the decks
	create vesselDecks transient;

	foreach deck in allDecks do
		vesselDecks.add(deck);
	endforeach;	
		
	app.myTrxDA.trxDeleteROROVesselDecks(vesselDecks,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqual(vessel.myROROVesselStructure.allDecks.size,0);
epilog
	delete vesselDecks;
	delete allDecks;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDischargeJobAndCCContainers" id="ad548e2b-46a3-4d0a-8ffd-ef869aea7395">
        <source>tDischargeJobAndCCContainers();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	voyage : CM_Voyage;
	deck 	: CM_DeckVoyage;
	voyageROROStructure 	: CM_ROROVoyageStructure;
	lcSet	: CM_LCSet;
	roroSlotController	: CM_ROROSlotController;
	theJobParams : CMIF_VoyageJobParams;
	workPoint : CM_WorkPoint;
	realVJob,pxyJob : CM_VoyageJob;
	theJobType : CM_JobType;
begin
	// should create containers in RORO container slots on the deck
	voyage := self.xCreateROROVoyageStructure;
	
	if voyage = null then
		return;
	endif;
	voyageROROStructure:=voyage.myROROStructure;
	deck:=voyageROROStructure.allDecksByCode[DECK1];
	create lcSet transient;
	deck.allROROSlotControllers.copy(lcSet);
	app.myTrxCA.trxCreateRORODischargeCCs(lcSet,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	workPoint:=self.addWorkPoint("UT_WP1", true);
	if workPoint = null then
		return;
	endif;
	
	
	create theJobParams transient;
	theJobParams.useNewMethod := true;
	theJobParams.isDischarge		:=	true;
	theJobParams.jobNumLinkedLoad	:=	null;
	theJobParams.myDeck				:= deck;

	theJobParams.myVoyage			:=	voyage;
	theJobParams.myProxyJob			:=	null;
	theJobParams.resquence			:=	true;		//set true whenever there's the posibility of slots added/removed from a job
	theJobParams.isSeqForJob		:=	false;
	theJobParams.myWorkPoint:=workPoint;
	theJobParams.craneID:=workPoint.code;
	
	foreach roroSlotController in deck.allROROSlotControllers where roroSlotController.allTrackedItems.size &gt; 0 do
		theJobParams.allROROControllers.add(roroSlotController);
		theJobParams.allObjectEditions.add(roroSlotController);
	endforeach;
	
	app.myTrxCA.trxCreateVoyageJob(theJobParams, realVJob, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	//test creating a user defined job
	delete theJobParams.myProxyJob;
	delete theJobParams;
	
	create pxyJob as CM_VoyageHatchLidJob transient;
	pxyJob.setProxyVoyage(voyage);
	theJobType:=app.myRoot.allJobTypes["BOOM UP"];
	pxyJob.setProxyVoyageJob(workPoint.code,"300H", null, null,  false, JOB_TYPE_USER,theJobType, 10, null, null, null);
	
	create theJobParams;
	theJobParams.myVoyage := pxyJob.myVoyage;
	theJobParams.myProxyJob := pxyJob;
	theJobParams.autoSortIntoOOW := true;
	theJobParams.craneID := workPoint.code;
	theJobParams.myJobType := theJobType;
	theJobParams.remarks := null;
	theJobParams.myWorkPoint:=workPoint; 
	theJobParams.myDeck				:= deck;
	
	realVJob:=null;
	app.myTrxCA.trxCreateVoyageJob(theJobParams, realVJob, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	if theJobParams &lt;&gt; null then
		delete theJobParams.myProxyJob;
	endif;
	delete theJobParams;
	delete lcSet;
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;WorkPointDeleteIssue&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tExportRORODeck" id="39bb522f-57d3-4453-86e0-6025623f0139">
        <source>tExportRORODeck();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 April 2011	cnwer1	Initial creation

*/

vars
	vessel : CM_Vessel;
	roroVesselStructure : CM_ROROVesselStructure;
	xmlDocument		: JadeXMLDocument;
	deckVessel 		: CM_DeckVessel;
	allProperties : PropertyColl;
	property 	: Property;
	xmlElement ,deckElement: JadeXMLElement;
	xmlAttribute : JadeXMLAttribute;
	theXMLFile : File;	
	xmlParser : JadeXMLDocumentParser;
	xmlString 	: String;
begin
	self.tCreateROROVesselSubDeck();
	vessel:=self.getVessel("UT_RORO" );
	self.assertNotNullMsg(vessel,"Vessel = null!");
	
	roroVesselStructure:=vessel.myROROVesselStructure;
	self.assertNotNullMsg(roroVesselStructure,"RORO Vessel Structure = null!");
	
	
	deckVessel:=roroVesselStructure.allDecks.first;
	
	
	create theXMLFile transient;
	//theXMLFile.mode:=File.Mode_IO;
	theXMLFile.mode :=	File.Mode_Output; // 25/2/16 cnwmp6 PAR 36286 unicode version
	//theXMLFile.fileName:="C:\Temp\" &amp; method.name &amp; ".xml";
	theXMLFile.fileName:="C:\Temp\" &amp; method.name &amp; "_" &amp; app.myRoot.getConfig(SystemTitle).String &amp; ".xml";
	theXMLFile.writeLine('&lt;?xml version="1.0"?&gt;');
	theXMLFile.writeLine(J_key_LessThan.Character &amp; deckVessel.class.name &amp; " " &amp; 'type="' &amp;  deckVessel.class.name &amp; '"'&amp;J_key_GreaterThan.Character);
	
	deckVessel.exportAsXMLDoc(theXMLFile);
	theXMLFile.writeString(self.formatAsXMLSuffix( deckVessel.class.name));
	theXMLFile.close;
	theXMLFile.mode := File.Mode_Input;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	theXMLFile.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	theXMLFile.open;
	xmlString:= theXMLFile.readString(theXMLFile.fileLength);
	create xmlParser transient;
	create xmlDocument transient;
	xmlParser.parseDocumentString(xmlDocument,xmlString);
	
	deckElement:=xmlDocument.rootElement;
	self.assertNotNullMsg(deckElement,"root element = null");
	self.assertEqualMsg(deckElement.tagName,  deckVessel.class.name, "RORO Deck Vessel not root element");
	
	allProperties:=deckVessel.class.allProperties();
	
	foreach property in allProperties do
		if deckVessel.exportAsXMLDocIgnoreAttr(property) then
			continue;
		endif;
		xmlElement:=deckElement.getElementByTagName(property.name);
		if  property.isKindOf(Attribute) then
			
			
			
			self.assertNotNullMsg(xmlElement,"Deck Vessel " &amp; property.name &amp; " element");
			self.assertEqualMsg(xmlElement.textData,deckVessel.getPropertyValue(property.name).String,"Deck Vessel " &amp; property.name &amp; " !=");
		elseif  property.isKindOf(Reference) then
			if property.name = CM_DeckVessel::myDeckLayout.name then
				xmlAttribute:=xmlElement.getAttributeByName('type');
				self.assertNotNullMsg(xmlAttribute,"CM_DeckVessel::myDeckLayout attribute = null");
				self.assertEqualMsg(xmlAttribute.value, CM_DeckLayout.name,"CM_DeckVessel::myDeckLayou type attribute !=");
	
			elseif property.name = CM_DeckVessel::allSubDecks.name then
				xmlAttribute:=xmlElement.getAttributeByName('type');
				self.assertNotNullMsg(xmlAttribute,"CM_DeckVessel::allSubDecks attribute = null");
				self.assertEqualMsg(xmlAttribute.value, CM_DeckVesselByOrdinalDIct.name,"CM_DeckVessel::allSubDecks  type attribute !=");
		/*	elseif property.name = CM_DeckVessel::myROROStructure.name then
				xmlAttribute:=xmlElement.getAttributeByName('type');
				self.assertNotNullMsg(xmlAttribute,"CM_DeckVessel::myROROStructure attribute = null");
				self.assertEqualMsg(xmlAttribute.value, CM_ROROVesselStructure.name,"CM_DeckVessel::myROROStructure type attribute !=");
				
				xmlElement:=xmlElement.getElementByTagName(CM_ROROVesselStructure::myVessel.name);
				xmlAttribute:=xmlElement.getAttributeByName('type');
				self.assertNotNullMsg(xmlAttribute,"CM_ROROVesselStructure::myVessel attribute = null");
				self.assertEqualMsg(xmlAttribute.value, CM_Vessel.name,"CM_ROROVesselStructure::myVessel  type attribute !=");
				
				xmlElement:=xmlElement.getElementByTagName(CM_Vessel::code.name);
				self.assertEqualMsg(xmlElement.textData, vessel.code, "CM_ROROVesselStructure::myVessel.code  != ");
	*/
			endif;
			
			
		endif;
		
	endforeach;
	
epilog
	delete xmlDocument;
	delete allProperties;
	delete theXMLFile;
	delete xmlParser;
end;</source>
    </JadeMethod>
    <JadeMethod name="tExportROROVesselStructure" id="5381b040-58c5-42bf-86ec-0e977e4a94b7">
        <source>tExportROROVesselStructure();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 April 2011	cnwer1	Initial creation

*/

vars
	vessel : CM_Vessel;
	roroVesselStructure : CM_ROROVesselStructure;
	xmlDocument : JadeXMLDocument;
	rootElement,
	allDeckElement,
	xmlElement ,deckElement: JadeXMLElement;
	xmlAttribute : JadeXMLAttribute;
	allDeckElements : JadeXMLElementArray;
	deckVessel 	: CM_DeckVessel;
	iter : Iterator;
	allProperties : PropertyColl;
	property 	: Property;
		theXMLFile : File;	
	xmlParser : JadeXMLDocumentParser;
	xmlString 	: String;
begin
	
	tCreateROROVesselSubDeck();
	vessel:=self.getVessel("UT_RORO" );
	self.assertNotNullMsg(vessel,"Vessel = null!");
	
	roroVesselStructure:=vessel.myROROVesselStructure;
	self.assertNotNullMsg(roroVesselStructure,"RORO Vessel Structure = null!");
	
	//export need fileName , obj to export 
	
	// for unit test sake will test the CM_Object method
	// in the trx i don't want to have to pass in the jadeXMLDocument that will be the reponsibility of the trx method
	// However i do want to validate that the jade xml document is correct
	
	///create xmlDocument transient;
	create theXMLFile transient;
	//theXMLFile.mode:=File.Mode_IO;
	theXMLFile.mode :=	File.Mode_Output;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	//theXMLFile.fileName:="C:\Temp\" &amp; method.name &amp; ".xml";
	theXMLFile.fileName:="C:\Temp\" &amp; method.name &amp; "_" &amp;app.myRoot.getConfig(SystemTitle).String &amp; ".xml";
	theXMLFile.writeLine('&lt;?xml version="1.0"?&gt;');
	theXMLFile.writeLine(J_key_LessThan.Character &amp; roroVesselStructure.class.name &amp; " " &amp; 'type="' &amp;  roroVesselStructure.class.name &amp; '"'&amp;J_key_GreaterThan.Character);
	
	roroVesselStructure.exportAsXMLDoc(theXMLFile);
	theXMLFile.writeString(self.formatAsXMLSuffix( roroVesselStructure.class.name));
	theXMLFile.close;
	theXMLFile.mode := File.Mode_Input;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	theXMLFile.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	theXMLFile.open;
	xmlString:= theXMLFile.readString(theXMLFile.fileLength);
	create xmlParser transient;
	create xmlDocument transient;
	xmlParser.parseDocumentString(xmlDocument,xmlString);
	
	rootElement:=xmlDocument.rootElement;
	self.assertNotNullMsg(rootElement,"root element = null");
	self.assertEqualMsg(rootElement.tagName,  roroVesselStructure.class.name, "ROROVesselStructure not root element");
	xmlAttribute:=rootElement.getAttributeByName('type');
	self.assertNotNullMsg(xmlAttribute,"root attribute = null");
	self.assertEqualMsg(xmlAttribute.value,  roroVesselStructure.class.name, "ROROVesselStructure not root element type attribute");

	
	xmlElement:=rootElement.getElementByTagName(CM_ROROVesselStructure::type.name);
	self.assertNotNullMsg(xmlElement,"RORO Structure type element = null");
	self.assertEqualMsg(xmlElement.textData.Integer,roroVesselStructure.type,"RORO Structure type !=");
	
	xmlElement:=rootElement.getElementByTagName(CM_ROROVesselStructure::myVessel.name);
	self.assertNotNullMsg(xmlElement,"RORO Structure myVessel element = null");
	xmlElement:=xmlElement.getElementByTagName(CM_Vessel::code.name);
	self.assertNotNullMsg(xmlElement,"RORO Structure myVessel.code = null");
	self.assertEqualMsg(xmlElement.textData.String,roroVesselStructure.myVessel.code,"RORO Structure myVessel.code  !=");
	
	allDeckElement:=rootElement.getElementByTagName(CM_ROROVesselStructure::allDecks.name);
	self.assertNotNullMsg(allDeckElement,"RORO Structure allDecks element = null");
	xmlAttribute:=allDeckElement.getAttributeByName('type');
	self.assertNotNullMsg(xmlAttribute,"RORO Structure allDecks attribute = null");
	self.assertEqualMsg(xmlAttribute.value, roroVesselStructure.allDecks.class.name,"RORO Structure allDecks type attribute !=");
	
	
	create allDeckElements transient;
	allDeckElement.getAllElementsByTagName(CM_DeckVessel.name,	allDeckElements);
	self.assertEqualMsg(allDeckElements.size, 2, "allDecks size  != 2");
	
	deckElement:=allDeckElements[1];
	
	deckVessel:=roroVesselStructure.allDecks.first;
	
	
	allProperties:=deckVessel.class.allProperties();
	
	foreach property in allProperties do
		if deckVessel.exportAsXMLDocIgnoreAttr(property) then
			continue;
		endif;
		xmlElement:=deckElement.getElementByTagName(property.name);
		if  property.isKindOf(Attribute) then
			
			
			
			self.assertNotNullMsg(xmlElement,"Deck Vessel " &amp; property.name &amp; " element");
			self.assertEqualMsg(xmlElement.textData,deckVessel.getPropertyValue(property.name).String,"Deck Vessel " &amp; property.name &amp; " !=");
		elseif  property.isKindOf(Reference) then
			if property.name = CM_DeckVessel::myDeckLayout.name then
				xmlAttribute:=xmlElement.getAttributeByName('type');
				self.assertNotNullMsg(xmlAttribute,"CM_DeckVessel::myDeckLayout attribute = null");
				self.assertEqualMsg(xmlAttribute.value, CM_DeckLayout.name,"CM_DeckVessel::myDeckLayou type attribute !=");
	
			elseif property.name = CM_DeckVessel::allSubDecks.name then
				xmlAttribute:=xmlElement.getAttributeByName('type');
				self.assertNotNullMsg(xmlAttribute,"CM_DeckVessel::allSubDecks attribute = null");
				self.assertEqualMsg(xmlAttribute.value, CM_DeckVesselByOrdinalDIct.name,"CM_DeckVessel::allSubDecks  type attribute !=");
			/*elseif property.name = CM_DeckVessel::myROROStructure.name then
				xmlAttribute:=xmlElement.getAttributeByName('type');
				self.assertNotNullMsg(xmlAttribute,"CM_DeckVessel::myROROStructure attribute = null");
				self.assertEqualMsg(xmlAttribute.value, CM_ROROVesselStructure.name,"CM_DeckVessel::myROROStructure type attribute !=");
				
				xmlElement:=xmlElement.getElementByTagName(CM_ROROVesselStructure::myVessel.name);
				xmlAttribute:=xmlElement.getAttributeByName('type');
				self.assertNotNullMsg(xmlAttribute,"CM_ROROVesselStructure::myVessel attribute = null");
				self.assertEqualMsg(xmlAttribute.value, CM_Vessel.name,"CM_ROROVesselStructure::myVessel  type attribute !=");
				
				xmlElement:=xmlElement.getElementByTagName(CM_Vessel::code.name);
				self.assertEqualMsg(xmlElement.textData, vessel.code, "CM_ROROVesselStructure::myVessel.code  != ");*/
	
			endif;
			
			
		endif;
		
	endforeach;
	

	
epilog
	delete xmlDocument;
	delete allDeckElements;
	delete allProperties;
	delete theXMLFile;
	delete xmlParser;
end;</source>
    </JadeMethod>
    <JadeMethod name="tGraphicAlignBottom" id="76718def-b0c7-4a9e-ad4b-b7a213561acb">
        <source>tGraphicAlignBottom();
// cnwmp6
// CNWMC5
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pxyItemLayout, realItemLayout: CM_DeckItemLayout;
	pointsPolygon : PointArray;
	pxyLayout : CM_DeckLayerLayout;
	pxyDeckLayout : CM_DeckLayout;
	controller : CMIF_RectangleAlignor;
	pxyGraphic : CM_Graphic;
	tmpPoint : Point;
	idx : Integer;
begin
	controller := self.xAlignController();

	controller.doAlignment(CMIF_RectangleAlignor.AlignMode_Bottom);
	
	// ALIGN TO THE FIRST GRAPHIC
	foreach pxyGraphic in controller.allPolygonGraphicObjects discreteLock do
		pxyDeckLayout := pxyGraphic.CM_DeckItemLayout.myDeckLayer.myDeckLayout;
		
		tmpPoint := pxyGraphic.getExtremePoint(CM_Graphic.Position_Bottom);
		self.assertTrueMsg(tmpPoint.y = controller.yBottom,  " Align Bottom FAILED");
	endforeach;

	
epilog
	delete pxyDeckLayout;
	delete controller;
end;</source>
    </JadeMethod>
