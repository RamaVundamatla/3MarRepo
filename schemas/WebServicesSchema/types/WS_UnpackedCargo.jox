    <JadeMethod name="delete" id="d431794c-fec4-45db-96ab-ee122ca1e558">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2017	jlghl1	Initial creation

*/

vars

begin
	delete self.cargoType;

