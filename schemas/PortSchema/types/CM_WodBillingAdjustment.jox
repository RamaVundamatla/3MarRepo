    <JadeMethod name="setForUpdate" id="05080c79-48a0-495d-97d5-852ca8c47222">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WodBillingAdjustment) updating;
/*
Purpose:	TFS 42241		
Date				Who			Reason
NOVEMBER 2018		CNWAB1		Initial creation
*/


vars

begin
	inheritMethod(_pxyWoDDtl);

	self.newFromDateTime := _pxyWoDDtl.newFromDateTime;
	self.newToDateTime := _pxyWoDDtl.newToDateTime;
	self.newUnitsUsed := _pxyWoDDtl.newUnitsUsed;
	self.oldUnitsUsed := _pxyWoDDtl.oldUnitsUsed;
	self.oldFromDateTime := _pxyWoDDtl.oldFromDateTime;
	self.oldToDateTime := _pxyWoDDtl.oldToDateTime;
	self.remarks := _pxyWoDDtl.remarks;
	

epilog

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WodBillingAdjustment"/>
    </JadeMethod>
    <JadeMethod name="setOldExtensionDetails" id="4a285837-a483-4b80-87cc-39467fe26e19">
        <updating/>
        <source>setOldExtensionDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2018	jlgab1	Initial creation

*/

vars
	voyage : CM_Voyage;
	totalExtension, imsrETMAL, adjETMAL : Integer;
	
	fromTS, toTS : TimeStamp;
	imsr : CM_WodMarineServicesInitial;
begin
	voyage := self.getMyVoyageObject;
	
	if voyage = null then
		return;
	endif;
	imsr := voyage.getWorkOrderForIMSR();
	if imsr &lt;&gt; null then
		imsrETMAL := (imsr.getCurrentLengthOfTime() * 1440).Integer; // IMSR ETMAL in minutes
		fromTS := voyage.arrivedDT.addMinutes(imsrETMAL); // Original Departure TS
		toTS := voyage.departedDT; // Current Departure TS
		
		self.oldFromDateTime := fromTS;
		self.oldToDateTime := toTS;
		self.oldUnitsUsed := imsr.getCurrentLengthOfTime();
		
		
		adjETMAL := (self.newUnitsUsed * 1440).Integer * -1; // NEW ETMAL in minutes
		fromTS := voyage.departedDT.addMinutes(imsrETMAL); 
		toTS := voyage.departedDT; 
		self.newFromDateTime := fromTS;
		self.newToDateTime := toTS;
		
		
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyBillingAdjustment" id="6480a3fc-61d8-4d27-8f72-c82118c05c16">
        <updating/>
        <source>setProxyBillingAdjustment(_remarks : String;_oldUnitsUsed, _newUnitUsed : Decimal; 
				_newFromDateTime, _newToDateTime, _oldFromDateTime, _oldToDateTime : TimeStamp) updating;
/*
Purpose:	TFS 42241		
Date				Who			Reason
NOVEMBER 2018		CNWAB1		Initial creation
*/


vars

begin
	self.remarks := _remarks;
	self.newUnitsUsed := _newUnitUsed;
	self.oldUnitsUsed := _oldUnitsUsed;
	self.newFromDateTime := _newFromDateTime;
	self.newToDateTime := _newToDateTime;
	self.oldFromDateTime := _oldFromDateTime;
	self.oldToDateTime := _oldToDateTime;

epilog

end;</source>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_oldUnitsUsed" type="Decimal"/>
        <Parameter name="_newUnitUsed" type="Decimal"/>
        <Parameter name="_newFromDateTime" type="TimeStamp"/>
        <Parameter name="_newToDateTime" type="TimeStamp"/>
        <Parameter name="_oldFromDateTime" type="TimeStamp"/>
        <Parameter name="_oldToDateTime" type="TimeStamp"/>
    </JadeMethod>
