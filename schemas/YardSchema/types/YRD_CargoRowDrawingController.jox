    </JadeMethod>
    <JadeMethod name="drawSelf" id="0fd54e03-0dcd-4521-8dc6-796218076d2c">
        <updating/>
        <source>drawSelf(_clearSelected: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 20/11/2012	cnwmh5	#30758 - Add creation of dummy tracked item
constants
	TopTextMargin	: Integer = 10;
	LeftTextMargin	: Integer = 5;

	TopMargin		: Integer = 10;
	BottomMargin	: Integer = 10;
	LeftMargin		: Integer = 10;
	RightMargin		: Integer = 10;
	RowSpacing		: Integer = 30;

vars
	obj : Object;
	tmpDrawingController	: SelfType;
	maxX,
	maxY	: Integer;
	tmpRow	: CM_GridRow;
	rowIdx,
	colIdx	: Integer;
	theRowHeight,
	theColWidth,
	yPos1, yPos2,
	xPos2	: Real;	
	tmpCaption	: String;
	tmpFrame	: CMUI_Frame;
	topLeftFiller : Frame;
	endOnTaProcessed : CM_TerminalAreaSet;
	dummyCont			: CM_Container;
begin
	self.drawFromNote := false;
	
	// 20/11/2012 cnwmh5 #30758
	create dummyCont transient;
	dummyCont.setPropertyValue("id","DUMMY");
	//create self.myTrackedItem as CM_Container transient; // dummy placeholder
	//self.myTrackedItem.setPropertyValue("id","DUMMY");
	
	self.allTempTIs.clear;

	if self.allGridRows.isEmpty then
		return;
	endif;

	if _clearSelected then
		self.clearAllSelectedObjects();
	endif;
	if self.myYardGridEnqForm &lt;&gt; null then
		useSelectorObjects := self.myYardGridEnqForm.useSelector;
	endif;
	
	self.allGridObjects.clear;
	self.allYARows.clear;
	
	self.myDrawingFrame.ignoreSkin := true;
	self.myDrawingFrame.clearGraphics();
	self.myDrawingFrame.autoRedraw := true;
	self.myVLabels.clearGraphics();
	self.myVLabels.width := YRD_ContainerDrawingController.LABEL_WIDTH;
	self.myVLabels.top := YRD_ContainerDrawingController.LABEL_WIDTH + 1;
	self.myVLabels.autoRedraw := true;
	
	self.myHLabels.clearGraphics();
	self.myHLabels.height := 0; //YRD_ContainerDrawingController.LABEL_WIDTH;
	self.myHLabels.autoRedraw := true;
	self.setFontDefaults();

	topLeftFiller := self.myDockBar.myScrollableFrame.myTopLeftFillerFrame;
	topLeftFiller.clearGraphics();
	topLeftFiller.autoRedraw := true;
	topLeftFiller.drawFontSize := 10; // ### PAR 10555
	topLeftFiller.drawTextAt("", 1, 8, Black); // ### PAR 10555
	topLeftFiller.visible := true;
	topLeftFiller.move(0,0,self.myDockBar.myScrollableFrame.myVLabels.clientWidth,self.myDockBar.myScrollableFrame.myHLabels.height);
	
	tmpDrawingController := self;
	tmpFrame := self.myDrawingFrame;
	tmpFrame.caption := null;
	theColWidth	 := self.getColumnWidthForScale();
	
	// draw the column headings
	tmpFrame := self.myHLabels;
	colIdx := 0;
//	xPos1 := self.LABELGAP;

	// Initial draw of whole area
	self.heightOfStack	:= self.allGridRows.first.CM_GridRow.myGridArea.heightOfStack;

	theRowHeight :=self.getRowHeightForScale();
	yPos1 := RowSpacing + 5;
	yPos2 := yPos1 + theRowHeight;

	tmpFrame := self.myVLabels;
	
	create endOnTaProcessed transient;
	
	foreach obj in self.allGridRows do
		tmpRow := obj.CM_GridRow;		
		self.myTrackedItem := dummyCont;									// 21/11/2012 cnwmh5 #30758
		
		if self.myYardGridEnqForm &lt;&gt; null then	// 25 May 2010	NDL	Par 24044
			if not self.myYardGridEnqForm.isAllDrawSideOn then // PAR 26858 Possibly user wants to see all side on, no end views
				if ( tmpRow.myGridArea.isForkliftStack or tmpRow.myGridArea.isRTGArea ) then	// We always want to see these end on.  
					if endOnTaProcessed.includes(tmpRow.myGridArea) then	// already processed all rows from this area.
						continue;
					else
						endOnTaProcessed.add(tmpRow.myGridArea);
						self.drawSelfRowsEndOn(tmpRow,yPos1,yPos2,xPos2,rowIdx);	// processes all rows from this area.
						maxX := maxX.max(xPos2.Integer);
						continue;
					endif;
				endif;
			endif;
		endif;

		self.drawSelfRow(tmpRow,yPos1,yPos2,xPos2,rowIdx);
		maxX := maxX.max(xPos2.Integer);
	
	endforeach;
	
	self.numRows := rowIdx;
	self.heightOfStack	:= self.allGridRows.last.CM_GridRow.myGridArea.heightOfStack;
	theRowHeight := RowHeight * self.getHeightOfStack * self.scaleFactor;	// PAR 21532 CCMS SFW 1025
	xPos2 := xPos2 + theColWidth;

	maxX := maxX + 10;
	maxY := (yPos2 + BottomMargin).Integer;


	self.myDockBar.resizeScrollingFrame(maxX, maxY);
	self.myDockBar.myScrollingFrame.left := self.LABEL_WIDTH + 1;
	self.myDockBar.myScrollingFrame.top := self.LABEL_WIDTH + 1;
	self.myDockBar.resetScrollValues();
	
	self.myDrawingFrame.visible := true;
	
epilog

	delete endOnTaProcessed;
	
end;</source>
        <Parameter name="_clearSelected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawSelfColumn" id="87481f37-77ec-4f50-bfeb-906ca54765fb">
        <updating/>
        <source>drawSelfColumn(_col : CM_GridColumn; _xpos1 : Real io) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	TopTextMargin	: Integer = 10;
	ColWidth		: Integer = 24;

vars
	tmpX, 
	theColWidth,
	xPos1, xPos2, yPos	: Real;	
	tmpCaption	: String;
	tmpFrame	: CMUI_Frame;	//YRD_ContainerDrawingFrame;
	gapWidth,gap : Integer;
begin


	tmpFrame := self.myDrawingFrame;
	tmpFrame.drawFontSize := 6 * self.scaleFactor;

	tmpFrame.drawFontSize := 10;
	theColWidth	 := ColWidth * self.scaleFactor;
	if _col.hasGap then
		theColWidth := self.getGapDrawWidth(_col);
	endif;

	xPos1 := _xpos1;
	xPos2 := xPos1 + theColWidth;
	
	tmpCaption := _col.label;

	if tmpCaption[1:1] = "_" then
		tmpCaption := null;
	endif;

	if tmpCaption = null then
		//don't return without updating _xpos1  PAR 10662
//		xPos1 := xPos1 + self.columnSpacing + theColWidth;
		_xpos1 := xPos1;
		return;
	endif;

	yPos := self.y1 - 20;
	tmpX := (xPos1 + ((xPos2 - xPos1) / 2)) - ((tmpCaption.length * 7) / 2); // all this puts the label in the middle
	tmpFrame.drawTextAt(tmpCaption, tmpX + 1, yPos + 1, White);
	tmpFrame.drawTextAt(tmpCaption, tmpX, yPos, Black);
end;</source>
        <Parameter name="_col" type="CM_GridColumn"/>
        <Parameter name="_xpos1" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawSelfColumnEndOn" id="6c886cba-8c7b-4567-95dc-acc1dd5be3da">
        <updating/>
        <source>drawSelfColumnEndOn(_row : CM_GridRow; _xpos1 : Real io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2010	cnwndl1	Initial creation	par 24044

*/

constants

	TopTextMargin	: Integer = 10;

vars

	tmpX, 
	theColWidth,
	xPos1, xPos2, yPos	: Real;	
	tmpCaption	: String;
	tmpFrame	: CMUI_Frame;
	
begin


	tmpFrame := self.myDrawingFrame;
	tmpFrame.drawFontSize := 10;
	theColWidth	 := self.RowHeight * self.scaleFactor;

	xPos1 := _xpos1;
	xPos2 := xPos1 + theColWidth;
	
	tmpCaption := _row.label;

	if tmpCaption[1:1] = "_" then
		tmpCaption := null;
	endif;
	
	if tmpCaption = null then
		_xpos1 := xPos1;
		return;
	endif;

	yPos := self.y1 - 20;
	tmpX := (xPos1 + ((xPos2 - xPos1) / 2)) - ((tmpCaption.length * 7) / 2); // all this puts the label in the middle
	tmpFrame.drawTextAt(tmpCaption, tmpX + 1, yPos + 1, White);
	tmpFrame.drawTextAt(tmpCaption, tmpX, yPos, Black);
	
end;</source>
        <Parameter name="_row" type="CM_GridRow"/>
        <Parameter name="_xpos1" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawSelfLC" id="b4727701-9d1c-4970-8d22-6479c5bf32b2">
        <updating/>
        <source>drawSelfLC(_lc: CM_GridController; _xpos1: Real io; _xpos2: Real io; _colIdx: Integer io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwndl1	Initial creation

*/

vars

begin
	inheritMethod(_lc, _xpos1, _xpos2, _colIdx);

epilog

end;</source>
        <Parameter name="_lc" type="CM_GridController"/>
        <Parameter name="_xpos1" type="Real" usage="io"/>
        <Parameter name="_xpos2" type="Real" usage="io"/>
        <Parameter name="_colIdx" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawSelfLCEndOn" id="95a0eeed-b983-4698-b34b-0bdee546bcdb">
        <updating/>
        <source>drawSelfLCEndOn(_lc: CM_GridController; _xpos1,_xpos2 : Real io; _colIdx	: Integer io; _reDraw : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2010	cnwndl1	Initial creation	par 24044	A version of 'drawSelfLc and drawLC' with specific changes
										to handle drawing TI's end on ...
06 Oct 2010	cnwdap1						PAR #25971 Tranship icon now dependent on Tranship Imex status as well as isTranship
*/
constants
	
	FONTSIZE = 6;

vars

	theColWidth : Real;
	
	startY,endX,
	endY, startX, numLCs, origX, tmpX	: Real;
	idx,
	tmpNumTIs, tmpNumQTIs, tmpNumPTIs,tmpNumATIs	: Integer;
	theOSTI, theTI: CM_TrackedItem;
	theDisplayMode,
	aColour, 
	theFillColour, 
	letterIndex	: Integer;
	aLetter,deckStr : String;
	theCellHeight, numHalfHeights, stackHght  : Integer;
	theFrame	: YRD_ContainerDrawingFrame;
	tmpLabourRestriction	: CM_LabourRestriction;
	tmpUsage,
	tmpAvail,
	tmpHeightNoStackFrom	: Integer;
	tmpBlockStack	: CM_BlockStack;
	isUnavailable,
	drawSolid, hasHeightRestriction, isPlaceholder	: Boolean;
	tmpPrimaryLC	: CM_LocationsController;
	tmpObj : Object;
	
begin

	theColWidth	 := self.RowHeight * self.scaleFactor;
//	if _lc.myGridRow.isGap() then
//		theColWidth := self.getGapDrawWidth(_lc.myGridColumn);
//	endif;

	if self.drawFromNote or _reDraw then
		// don't change x axis settings.
	else
		_colIdx := _colIdx + 1;
		_xpos1 := _xpos2 + self.columnSpacing;
		_xpos2 := _xpos1 + theColWidth;
	
		self.x1 := _xpos1;
		self.x2 := _xpos2;
	endif;
	
	self.heightOfStack := _lc.myGridRow.myGridArea.heightOfStack;

	beginLoad;
	
	if self.flipHorizontal then
		origX := self.x2;
	else
		origX := self.x1;
	endif;
	
	theFrame := self.myDrawingFrame;

	stackHght := self.getHeightOfStack;	// PAR 21532 CCMS SFW 1025
	if self.drawFromNote or _reDraw then
		self.gridObjectsRemove(self.x1.Integer,self.y1.Integer,self.x2.Integer,self.y2.Integer);
		// ### PAR 10593. Make an adjustment for the TI and the LC being the same size.
		if stackHght = 1 then
			self.y1 := self.y1 + 1;
		endif;
		self.drawBetweenColumns(theFrame);
	endif;
	self.myLocationsController := _lc;

	if self.yardGridAreaTranshipMark &lt;&gt; null then// CCMS 1574
		self.hasTranshipYardAllocation := _lc.includesYardAllocationCriteria(CM_YATypeIsTransShip, true, false) // CCMS 1574
										or _lc.includesYardAllocationCriteria(CM_YATypeImexStatus, app.myRoot.allImexStatuses[TI_IMEX_STATUS_TRANSHIP], false);	// PAR #25971
	endif;
	
	if _lc = null or stackHght = 0 then
		// Nothing to draw
		return;
	endif;
	theDisplayMode := self.displayMode;
	
	tmpLabourRestriction 	:= _lc.allLabourRestrictions.first;
	tmpHeightNoStackFrom 	:= _lc.getHeightNoStackFrom();
	tmpBlockStack			:= _lc.mySubBlockStack;
	
	_lc.getAvailUsageHeight(tmpUsage, tmpAvail, hasHeightRestriction);
	isUnavailable := (tmpUsage = UNAVAILABLE_USE or 
						 tmpAvail = PAD_USER_UNAVAILABLE or 
		   				 tmpAvail = PAD_UNAVAILABLE);

	theFrame.drawFontName := "Arial";
	theFrame.drawFontSize := FONTSIZE * self.scaleFactor;
	theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	if self.myLocationsController.hasPower() then 
		theFillColour := self.POWER_FILL_COLOUR;
	else
		theFillColour := Gray;
		if self.myLocationsController.isOverhang() then
			theFillColour := theFrame.backColor;
		endif;
	endif;

	self.setTICollections();
	
	tmpNumTIs := self.allTempTIs.size;
	theFrame.drawWidth	:= 1;
	tmpNumQTIs := self.allTIsQ.size;
	tmpNumPTIs := self.allTIsP.size;
	tmpNumATIs := self.allTIsA.size; 

	aColour := self.colour;
	aLetter := self.letter;
	
	if tmpBlockStack &lt;&gt; null then
		self.drawSubBlockStack(tmpBlockStack);
	elseif tmpUsage = BUILDING_USE then // BUILDING
		self.drawBuilding();

	elseif tmpUsage = LIGHT_TOWER_USE then // LIGHT
		self.drawLight();

	else

		self.cellHeight := theColWidth.Integer;
		
		numHalfHeights := 0;
		startY := self.y2;

		while true do
			idx := idx + 1;

			// PAR 11143 just incase of continious loop
			if idx &gt; 100 then
				break;
			endif;
			tmpPrimaryLC := null; // PAR 22614
			
			theTI := null;
			
			if idx &lt;= tmpNumTIs then
				theTI := self.allTempTIs[idx];
				isPlaceholder := (	theTI = self.myTrackedItem and (self.myTrackedItem &lt;&gt; null and self.myTrackedItem.id = "DUMMY")); // PAR 23409

				if isPlaceholder then
					startX := origX;
					if self.flipHorizontal then
						endX := self.x1;
					else
						endX := self.x2;
					endif;
					tmpPrimaryLC := _lc;
				else
					theOSTI := self.myLocationsController.hasOversizedBackendsByMode(self.displayMode, 1, self.allTrackedItems, false);
					startX := x1;
					endX := x2;	
	
					self.tiHeight := theTI.getHeightOfTI();
					self.tiLength := 1;	// cos we are drawing end on
			
					//if theDisplayMode = DISPLAY_MODE_ACTUAL then
					if self.allTIsA.includes(theTI) then
						tmpPrimaryLC := theTI.myPrimaryActualLocation;
					elseif self.allTIsQ.includes(theTI) then
						if _lc.isPrimaryLocationForFM(QUEUE_MODE, idx) then // PAR 18596
							tmpPrimaryLC := _lc;// PAR 18596
						endif;
					elseif self.allTIsP.includes(theTI) then
						// PAR 15340
						if theTI.isRehandle 
						and (not theTI.myPrimaryPlannedLocation.isGridLocation) 
						and theTI.allPlannedFutureMoves.size = 2 then
							tmpPrimaryLC := theTI.allPlannedFutureMoves.last.CM_FutureMovePlanned.allLocationsControllers.first; // LAST FM
							if tmpPrimaryLC &lt;&gt; null then
								if not tmpPrimaryLC.isGridLocation then
									tmpPrimaryLC := theTI.allPlannedFutureMoves.first.CM_FutureMovePlanned.allLocationsControllers.first; // FIRST FM
								endif;
							endif;
						endif;
	
						if tmpPrimaryLC = null then
							tmpPrimaryLC := theTI.myPrimaryPlannedLocation;
						endif;
					endif;
	
				endif;	
				
				if self.tiHeight = Ti_Half_Height then
					numHalfHeights := numHalfHeights + 1;
					theCellHeight := (self.cellHeight / 2).Integer;
				else
					theCellHeight := self.cellHeight.Integer;
				endif;
				startY 	:= startY - theCellHeight; 
				endY	:= startY + theCellHeight;

				if startY &lt;=0 then// PAR 11143 
					break;
				endif;
				if startY &lt; self.y1 then
					break;
				endif;

				drawSolid := 	(theDisplayMode = DISPLAY_MODE_ACTUAL and self.allTIsA.includes(theTI))
							or		(theDisplayMode = DISPLAY_MODE_QUEUE and self.allTIsQ.includes(theTI))
							or		(theDisplayMode = DISPLAY_MODE_PLAN and self.allTIsP.includes(theTI));

				self.drawBackEnd := false;

				if tmpPrimaryLC &lt;&gt; _lc then
					self.drawBackEnd := true;
					if drawSolid then
						self.drawTIEndOn(theTI, null, startX, startY, self.x2, endY, theFrame, null);
					else
						self.doDrawFMLetterForTI(theFrame, theTI, theFillColour, startX, startY,endX, endY);
					endif;
					continue;
				endif;
//write startX.String &amp; ", " &amp; endX.String &amp; ", " &amp; startY.String &amp; ", " &amp; endY.String;
				if drawSolid then
					self.setIconPositionsEndOn(startX, startY, endX, endY);
					if isPlaceholder then
						self.drawBlankSpace(theFrame, theFillColour, idx, startX, startY, endX, endY + 1, false);
					else
						self.drawTIEndOn(theTI, null, startX, startY, endX, endY, theFrame, null);	
					endif;
					
				else // no solid, draw A, Q, P
					if isPlaceholder then
						self.drawBlankSpace(theFrame, theFillColour, idx, startX, startY, endX, endY + 1, false);
					else
						self.doDrawFMLetterForTI(theFrame, theTI, theFillColour, startX, startY,endX, endY);
					endif;
				endif;
			
			// NO TIS JUST BLANKS AND RESTRICTIONS
			else
				theOSTI := self.myLocationsController.hasOversizedBackendsByMode(self.displayMode, idx, self.allTrackedItems, false);
				startX := x1;
				endX := x2;	
				// OK if going in here then we do not have any TIs in this view mode
				if numHalfHeights mod 2 = 0 then
					theCellHeight := self.cellHeight.Integer; // there have been an even number of 1/2s so reset now
				else
					theCellHeight := (self.cellHeight / 2).Integer;
				endif;

				numHalfHeights := 0;				
				startY 	:= startY - theCellHeight; 
	
				if startY &lt;=0 then// PAR 11143 
					break;
				endif;

				if startY &lt; self.y1 then
					break;
				endif;
				endY	:= startY + theCellHeight + 1;
				theCellHeight := self.cellHeight.Integer; // this may be half height to fill in, so reset it for next time
				
				// PAR 18682
				if self.myLocationsController.offsetFlexi &gt; 0 
				and self.hasGotItemAtHeight(idx, false) 
				and (self.myLocationsController.allTrackedItemOSBackEnds.isEmpty()
						and self.myLocationsController.allTrackedItemOSBackEndsQd.isEmpty()
						and self.myLocationsController.allTrackedItemOSBackEndsPd.isEmpty()) then
					self.drawBlankSpace(theFrame, theFillColour, idx, origX, startY, startX, endY, false);
				endif;

				// ## GAP	
				if self.myLocationsController.isKindOf(CM_GapController) then
					if self.myLocationsController.isKindOf(CM_OverhangController) then // PAR 18682
						self.drawBlankSpaceOverhang(theFrame, self.myDrawingFrame.backColor, idx, startX -1, startY, endX, endY - 1); 
					else
					
						if theFillColour &lt;&gt; POWER_FILL_COLOUR then
							theFillColour := self.myDrawingFrame.backColor;
						endif;
						self.drawBlankSpace(theFrame, theFillColour, idx, startX, startY, endX, endY - 1, true); 
					endif;
				// ## HEIGHT or LABOUR RESTRICTION
				elseif tmpLabourRestriction &lt;&gt; null and (not isUnavailable) then
					if hasHeightRestriction then // HEIGHT RESTRICTION
						if idx &gt;= tmpHeightNoStackFrom then
							self.drawBlankSpace(theFrame, theFillColour, idx, startX, startY, endX, endY - 1, true); 
							self.drawHeight(theFrame, aLetter, Red, startX, startY, endX, endY);
						else
							aColour := tmpLabourRestriction.colour;
							if idx &gt; (tmpNumQTIs + tmpNumPTIs + tmpNumTIs) then // PAR 18229
								self.drawBlankSpace(theFrame, theFillColour, idx, startX, startY, endX, endY - 1, true); 
								self.drawTranshipMark(theFrame, startX, startY, idx);
								self.drawLabour(theFrame, tmpLabourRestriction, startX, startY, endX, endY);
							endif;
						endif;
					else
						aColour := tmpLabourRestriction.colour;
						if idx &gt; (tmpNumQTIs + tmpNumPTIs + tmpNumTIs) then // PAR 18229
							self.drawBlankSpace(theFrame, theFillColour, idx, startX, startY, endX, endY - 1, true); 
							self.drawTranshipMark(theFrame, startX, startY, idx);
							self.drawLabour(theFrame, tmpLabourRestriction, startX, startY, endX, endY);
						endif;
					endif;
				// ## HEIGHT RESTRICTION
				elseif hasHeightRestriction then // HEIGHT RESTRICTION
					if idx &gt; (tmpNumQTIs + tmpNumPTIs + tmpNumTIs) then // PAR 17825
						self.drawBlankSpace(theFrame, theFillColour,idx, startX, startY , endX, endY, true); 
					endif;
					if idx &gt;= tmpHeightNoStackFrom then
						self.drawHeight(theFrame, aLetter, Red, startX, startY, endX, endY);
					else
						self.drawTranshipMark(theFrame, startX, startY, idx);
					endif;
				elseif theDisplayMode &lt;&gt; DISPLAY_MODE_ACTUAL 
				and idx &lt;= tmpNumTIs 
				and tmpNumTIs &gt; 0 then
					self.drawLetter(theFrame,"A", (startX+((self.x2-startX)/2)-5).Integer, (startY + 2).Integer, Black,startX, startY, self.x2, endY,theFillColour,REAL_MODE,idx);
				else
					if isUnavailable then
						theFillColour := theFrame.backColor;
					endif;
					
					// draw a back end cross for the overhang.
					if theOSTI &lt;&gt; null and self.myDockBar.isForEndView and tmpNumTIs = 0 then
						if theDisplayMode &lt;&gt; DISPLAY_MODE_ACTUAL  then
							self.drawFMLetterBackend(startX, startY, self.x2, endY);
						else
							self.drawBackEnd := true;
							self.drawTIEndOn(theOSTI, null, startX, startY, self.x2, endY, theFrame, null);
						endif;
						continue;
					endif;
//write startX.String &amp; ", " &amp; endX.String &amp; ", " &amp; startY.String &amp; ", " &amp; endY.String;					
					self.drawBlankSpace(theFrame, theFillColour,idx, startX, startY, endX, endY, true ); 

					if not isUnavailable then
						self.drawTranshipMark(theFrame, startX, startY, idx);
					endif;
				endif;
				
			endif;

		endwhile;
	endif;
	
	self.checkIfHeightExceeded(theFrame, tmpNumTIs);	// PAR 21532 CCMS SFW 1025 - Check if height exceeded

epilog

	endLoad;

	if not self.allGridObjects.includes(self.myLocationsController) and tmpBlockStack = null then
		// if the stack height is 1 then the LC rectangle and a 20 foot rectangle have the same Xs and Ys so need to jig the LC to be 1 pixel out
		// ### PAR 20119 added '+ self.columnSpacing'
		// ### PAR 20244 removed '+ self.columnSpacing'
		tmpObj := self.gridObjectsGetAtKeyForPut(self.x1.Integer,self.y1.Integer,self.x2.Integer,self.y2.Integer);
		if tmpObj = null then
			// ### PAR 10593. Make an adjustment for the TI and the LC being the same size. But the LC now being empty
			if self.drawFromNote and stackHght = 1 then
				self.y1 := self.y1 - 1;
			endif;

			self.gridObjectsPutAtKey(self.x1.Integer,self.y1.Integer,self.x2.Integer,self.y2.Integer, self.myLocationsController);
		else
			if not tmpObj.isKindOf(CM_LocationsController) then
				// ### PAR 10593 - the 'self.y1.Integer - 1' was 'self.y1.Integer + 1'
				// ### PAR 10593. Make an adjustment for the TI and the LC being the same size.
				self.gridObjectsPutAtKey(self.x1.Integer,self.y1.Integer - 1,self.x2.Integer,self.y2.Integer, self.myLocationsController); //
			endif;
		endif;
	endif;
	
	if theFrame &lt;&gt; null then
		theFrame.drawFontName := "Arial";
		theFrame.drawFontSize := FONTSIZE * self.scaleFactor;
		theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	endif;

end;
</source>
        <Parameter name="_lc" type="CM_GridController"/>
        <Parameter name="_xpos1" type="Real" usage="io"/>
        <Parameter name="_xpos2" type="Real" usage="io"/>
        <Parameter name="_colIdx" type="Integer" usage="io"/>
        <Parameter name="_reDraw" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawSelfRow" id="10e593b3-9d26-4618-a568-62b11a647119">
        <updating/>
        <source>drawSelfRow(_row : CM_GridRow; _yPos1 : Real io; _yPos2 : Real io; _xPos2 : Real io; _rowIdx : Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	TopTextMargin	: Integer = 10;
	LeftTextMargin	: Integer = 5;

	TopMargin		: Integer = 10;
	BottomMargin	: Integer = 10;
	LeftMargin		: Integer = 10;
	RightMargin		: Integer = 10;
	RowSpacing		: Integer = 30;

vars
	tmpDrawingController	: YRD_ContainerDrawingController;
	maxX,
	maxY	: Integer;
	tmpTA	: CM_GridArea;
	tmpRow	: CM_GridRow;
	tmpCol	: CM_GridColumn;
	tmpLC	: CM_GridController;
	rowIdx,
	colIdx	: Integer;
	tmpX, tmpY,
	theRowHeight,
	theColWidth,
	yPos1, yPos2,
	xPos1, xPos2	: Real;	
	tmpCaption, taID	: String;
	tmpFrame	: CMUI_Frame;	//YRD_ContainerDrawingFrame;

begin
	tmpTA := _row.myGridArea;
	self.heightOfStack	:= _row.myGridArea.heightOfStack;

	yPos1 := _yPos1;
	tmpRow := _row;
	tmpFrame := self.myVLabels;
	tmpFrame.drawTextAlign := Frame.DrawTextAlign_Center; // PAR 17589
	theColWidth	 := self.getColumnWidthForScale;
	theRowHeight := self.getRowHeightForScale();
	yPos2 := yPos1 + theRowHeight;

	xPos1 := LeftMargin;
	xPos2 := xPos1 + theColWidth;
	
	// Draw the row label
	tmpCaption := tmpRow.getLabel();
//	if tmpCaption[1:1] = "_" then
//		tmpCaption := null;
//	endif;
	if tmpCaption &lt;&gt; null then
		taID := tmpRow.myGridArea.id;
		if taID.length &lt;= 2 then
			tmpFrame.drawFontSize := 16;
		elseif taID.length &lt;= 4 then
			tmpFrame.drawFontSize := 10;
		else
			tmpFrame.drawFontSize := 8;
		endif;
		//tmpX := 5;// PAR 10484
		tmpX := (self.myVLabels.width / 2).Integer; // PAR 17589
		tmpY := (yPos1 + ((yPos2 - yPos1) / 2)) - 20; // the 10 is half the height of the text in pixels
		tmpFrame.drawTextAt(taID, tmpX + 1, tmpY + 1, White);
		tmpFrame.drawTextAt(taID, tmpX, tmpY, Black);
		tmpFrame.drawFontSize := 14;
		tmpY := (yPos1 + ((yPos2 - yPos1) / 2)) ; // the 10 is half the height of the text in pixels
		tmpCaption := tmpCaption; // PAR 17589
		tmpFrame.drawTextAt(tmpCaption, tmpX + 1, tmpY + 1, White);
		tmpFrame.drawTextAt(tmpCaption, tmpX, tmpY, Black);
		
	endif;	
	
	self.y1 := yPos1;
	self.y2 := yPos2;
//	xPos1 := self.LABELGAP;
//	xPos2 := xPos1 + theColWidth;
	xPos1 := self.LABELGAP - theColWidth;
	xPos2 := self.LABELGAP;
	// ### CCMS 1509 - draw a red line if no access
//	write tmpTA.id &amp; " X: " &amp; xPos2.String &amp; " " &amp; theColWidth.String;
	if tmpTA.isKindOf(CM_GridArea) then
		if not tmpTA.CM_GridArea.hasAccessLeft() then
			self.myDrawingFrame.drawWidth := 2;
			self.myDrawingFrame.drawLine(3,yPos1, 3 ,yPos2,Red);
		endif;
	endif;
	colIdx := 0;

	if self.flipHorizontal then
		foreach tmpLC in tmpRow.allControllersByColumn reversed do
			self.drawSelfLC(tmpLC, xPos1,xPos2,colIdx);
			self.drawSelfColumn(tmpLC.myGridColumn, xPos1);
			self.numColumns := self.numColumns.max(colIdx);
		endforeach;
	else
		tmpX := xPos2;
		foreach tmpLC in tmpRow.allControllersByColumn do
			self.drawSelfLC(tmpLC, xPos1,xPos2,colIdx);
			self.drawSelfColumn(tmpLC.myGridColumn, tmpX);
			if tmpLC.isGap() then	//16 Jul 2010	NDL Par 24965
				tmpX := tmpX + self.columnSpacing + self.getGapDrawWidth(tmpLC.myGridColumn);	//16 Jul 2010	NDL Par 24965
			else
				tmpX := tmpX + self.columnSpacing + theColWidth;
			endif;
			self.numColumns := self.numColumns.max(colIdx);
		endforeach;
	endif;
	if tmpTA.isKindOf(CM_GridArea) then
		if not tmpTA.CM_GridArea.hasAccessRight() then
			self.myDrawingFrame.drawWidth := 2;
			self.myDrawingFrame.drawLine(tmpX + 5 ,yPos1,tmpX + 5 ,yPos2,Red);
		endif;
	endif;
	_rowIdx := _rowIdx + 1;
	yPos1 := _yPos1 + RowSpacing + theRowHeight;
	yPos2 := yPos1 + theRowHeight; // NEW

	
	_yPos1 := yPos1;
	_yPos2 := yPos2;
	_xPos2 := _xPos2.max(xPos2);
	_xPos2 := xPos2;
	tmpFrame.drawTextAlign := Frame.DrawTextAlign_Left; // PAR 17589
end;</source>
        <Parameter name="_row" type="CM_GridRow"/>
        <Parameter name="_yPos1" type="Real" usage="io"/>
        <Parameter name="_yPos2" type="Real" usage="io"/>
        <Parameter name="_xPos2" type="Real" usage="io"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawSelfRowsEndOn" id="1f907413-b7e1-4f37-acae-ed264b8e9661">
        <updating/>
        <source>drawSelfRowsEndOn(	_row : CM_GridRow;
				_yPos1 : Real io;
				_yPos2 : Real io;
				_xPos2 : Real io;
				_rowIdx : Integer io
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2010	cnwndl1	Initial creation	par 24044	- Special version of the original drawself impemented to draw all rows
													used in an end on view for Forklifts and RTG's

*/
constants

	TopTextMargin	: Integer = 10;
	LeftTextMargin	: Integer = 5;

	TopMargin		: Integer = 10;
	BottomMargin	: Integer = 10;
	LeftMargin		: Integer = 10;
	RightMargin		: Integer = 10;
	RowSpacing		: Integer = 30;

vars
	
	tmpTA : CM_GridArea;
	tmpRow : CM_GridRow;
	tmpLC : CM_GridController;
	rowIdx : Integer;
	colIdx : Integer;
	tmpX : Real;
	tmpY : Real;
	theRowHeight : Real;
	theColWidth : Real;
	yPos1 : Real;
	yPos2 : Real;
	xPos1 : Real;
	xPos2 : Real;	
	tmpCaption : String;
	taID : String;
	tmpFrame : CMUI_Frame;	//YRD_ContainerDrawingFrame;
	
	allTis : ObjectArray;
	ti : CM_TrackedItem;
	iter : Iterator;
	gridCont : CM_GridController;
	allSelectedLCs : CM_GridControllersByColumnRow;
	column : Integer;
	row : Integer;
	columnArray : IntegerArray;
	dynaDict : DynaDictionary;
	obj : Object;
		
begin
	
	tmpRow := _row;
	tmpTA := _row.myGridArea;
	self.heightOfStack	:= _row.myGridArea.heightOfStack;
	yPos1 := _yPos1;

	// We are looking at a different view for (end on and by column for Forklifts and RTGS)
	
	if self.myYardGridEnqForm = null or self.myYardGridEnqForm.allTIs.isEmpty then
		return;
	endif;
	allTis := self.myYardGridEnqForm.allTIs;
	
	// need a list of all columns that contain tis we are interested in.
	create columnArray transient;
	iter := tmpTA.allGridControllersByName.createIterator;
	while iter.next(gridCont) do
		foreach ti in gridCont.allTrackedItems do
			if allTis.includes(ti) then
				column := gridCont.myGridColumn.column;
				row := gridCont.myGridRow.row;
				if not columnArray.includes(column) then
					columnArray.add(column);
				endif;
			endif;
		endforeach;
	endwhile;
	
	create dynaDict transient;	
	dynaDict.setMembership(CM_GridController);
	if self.flipVertically then
		if self.flipHorizontal then // flipped both ways
			dynaDict.addExternalKey(Integer, 8, true, true); // ROW
			dynaDict.addExternalKey(Integer, 8, true, true); // COL
		else
			dynaDict.addExternalKey(Integer, 8, true, true); // ROW
			dynaDict.addExternalKey(Integer, 8, false, true); // COL
		endif;
	else
		if self.flipHorizontal then // flipped Horizontal Only
			dynaDict.addExternalKey(Integer, 8, false, true); // ROW
			dynaDict.addExternalKey(Integer, 8, true, true); // COL
		else // not flipped at all
			dynaDict.addExternalKey(Integer, 8, false, true); // ROW
			dynaDict.addExternalKey(Integer, 8, false, true); // COL
		endif;
	endif;
	dynaDict.endKeys(true);

	foreach column in columnArray do // These are columns in the Terminal area Grid Controllers, but end on display as rows on the graphic
	
		dynaDict.clear();
		iter.reset;
		
		//add each grid controller with a column that matches any selected in our dyna dict (i.e. all positions we are going to show for the terminal area)
		tmpCaption := null;
		while iter.next(gridCont) do
			if gridCont.myGridColumn.column = column then
				if tmpCaption = null then	// set up the columns label
					tmpCaption := gridCont.myGridColumn.label;
				endif;
				dynaDict.putAtKey(gridCont.myGridRow.row,gridCont.myGridColumn.column,gridCont);
			endif;
		endwhile;
		
		// set up the area labels
		tmpFrame := self.myVLabels;
		tmpFrame.drawTextAlign := Frame.DrawTextAlign_Center; // PAR 17589
		theColWidth	 := self.RowHeight * self.scaleFactor;
		theRowHeight := self.getRowHeightForScale();
		yPos2 := yPos1 + theRowHeight;
	
		xPos1 := LeftMargin;
		xPos2 := xPos1 + theColWidth;
		
		// Draw the column label ( left hand margin )
		if tmpCaption &lt;&gt; null then
			taID := tmpTA.id;
			if taID.length &lt;= 2 then
				tmpFrame.drawFontSize := 16;
			elseif taID.length &lt;= 4 then
				tmpFrame.drawFontSize := 10;
			else
				tmpFrame.drawFontSize := 8;
			endif;
			
			tmpX := (self.myVLabels.width / 2).Integer; // PAR 17589
			tmpY := (yPos1 + ((yPos2 - yPos1) / 2)) - 20; // the 10 is half the height of the text in pixels
			tmpFrame.drawTextAt(taID, tmpX + 1, tmpY + 1, White);
			tmpFrame.drawTextAt(taID, tmpX, tmpY, Black);
			tmpFrame.drawFontSize := 14;
			tmpY := (yPos1 + ((yPos2 - yPos1) / 2)) ; // the 10 is half the height of the text in pixels
			tmpFrame.drawTextAt(tmpCaption, tmpX + 1, tmpY + 1, White);
			tmpFrame.drawTextAt(tmpCaption, tmpX, tmpY, Black);
		endif;	
		
		self.y1 := yPos1;
		self.y2 := yPos2;
		xPos1 := self.LABELGAP - theColWidth;
		xPos2 := self.LABELGAP;
		// ### CCMS 1509 - draw a red line if no access
		if tmpTA.isKindOf(CM_GridArea) then
			if not tmpTA.CM_GridArea.hasAccessLeft() then
				self.myDrawingFrame.drawWidth := 2;
				self.myDrawingFrame.drawLine(3,yPos1, 3 ,yPos2,Red);
			endif;
		endif;
		
		colIdx := 0;
		tmpX := 8;
		
		if self.flipHorizontal then
			foreach obj in dynaDict reversed do
				tmpLC := obj.CM_GridController;
				self.drawSelfLCEndOn(tmpLC, xPos1,xPos2,colIdx,false);	// add the tis in the column for the terminal area.
				self.drawSelfColumnEndOn(tmpLC.myGridRow, tmpX);	// add the column heading
				tmpX := tmpX + self.columnSpacing + theColWidth;
				self.numColumns := self.numColumns.max(colIdx);
			endforeach;
		else
			foreach obj in dynaDict do
				tmpLC := obj.CM_GridController;
				self.drawSelfLCEndOn(tmpLC, xPos1,xPos2,colIdx,false);
				self.drawSelfColumnEndOn(tmpLC.myGridRow, tmpX);	
				tmpX := tmpX + self.columnSpacing + theColWidth;
				self.numColumns := self.numColumns.max(colIdx);
			endforeach;

		endif;
		
		if tmpTA.isKindOf(CM_GridArea) then
			if not tmpTA.CM_GridArea.hasAccessRight() then
				self.myDrawingFrame.drawWidth := 2;
				self.myDrawingFrame.drawLine(tmpX + 5 ,yPos1,tmpX + 5 ,yPos2,Red);
			endif;
		endif;
		
		_rowIdx := _rowIdx + 1;
		yPos1 := _yPos1 + RowSpacing + theRowHeight;
		yPos2 := yPos1 + theRowHeight;
	
		
		_yPos1 := yPos1;
		_yPos2 := yPos2;
		_xPos2 := _xPos2.max(xPos2);
		_xPos2 := xPos2;
		tmpFrame.drawTextAlign := Frame.DrawTextAlign_Left;
		
	endforeach;	
	
epilog

	delete iter;
	delete columnArray;
	delete dynaDict;
	
end;</source>
        <Parameter name="_row" type="CM_GridRow"/>
        <Parameter name="_yPos1" type="Real" usage="io"/>
        <Parameter name="_yPos2" type="Real" usage="io"/>
        <Parameter name="_xPos2" type="Real" usage="io"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawTI" id="4accbfc0-7c2d-4705-8da5-14e05e443858">
        <updating/>
        <source>drawTI(_theTI: CM_TrackedItem; _theGridAttributes: CMUI_GridAttributes input; _x1: Real; _y1: Real; _x2: Real; _y2: Real; _frame: CMUI_GridAreaDrawingFrame input; _lc: CM_LocationsController) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwndl1	Initial creation

*/

vars

	theDisplayMode : Integer;
	drawingEndOn : Boolean;
	myLC : CM_LocationsController;
	
begin

	if self.myYardGridEnqForm &lt;&gt; null then
		theDisplayMode := self.displayMode;
		if theDisplayMode = DISPLAY_MODE_ACTUAL then
			myLC := _theTI.myPrimaryActualLocation;
		elseif theDisplayMode = DISPLAY_MODE_QUEUE then
			myLC := _theTI.myPrimaryQueuedLocation;
		elseif theDisplayMode = DISPLAY_MODE_PLAN then
			myLC := _theTI.myPrimaryPlannedLocation;
		endif;
		if not self.myYardGridEnqForm.isAllDrawSideOn then // PAR 26858 Possibly user wants to see all side on, no end views
			if myLC &lt;&gt; null and myLC.myTerminalArea &lt;&gt; null then
				if myLC.myTerminalArea.isForkliftStack or myLC.myTerminalArea.isRTGArea then
					drawingEndOn := true;
				endif;
			endif;
		endif;
	endif;
	
	if drawingEndOn then
		self.drawTIEndOn(_theTI, _theGridAttributes, _x1, _y1, _x2, _y2, _frame.YRD_ContainerDrawingFrame, _lc);
	else
		inheritMethod(_theTI, _theGridAttributes, _x1, _y1, _x2, _y2, _frame, _lc);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theGridAttributes" type="CMUI_GridAttributes" usage="input"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="drawTIEndOn" id="2147e5ef-c22b-4191-b4db-180507a5fada">
        <updating/>
        <source>drawTIEndOn(_theTI : CM_TrackedItem; _theGridAttributes : CMUI_GridAttributes input;
		_x1, _y1, _x2, _y2 : Real;
		_frame : YRD_ContainerDrawingFrame input;  _lc : CM_LocationsController) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2010	cnwndl1	Initial creation	Par 24044	- Specific end on version of 'drawTI' for drawing end on versions.
11 Nov 2019	jlgdap1	TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
*/

vars

	theFrame: YRD_ContainerDrawingFrame;
	lTIColour, theInverseColour, theCharacterWidth : Integer;
	lDisplayMode,idx,lViewMode,theAtt : Integer;
	lFactor : Real;
	tmpStr,
	theMainCode : String;
	aPort : CM_Port;
	theTI : CM_TrackedItem ;
	iAmPrinting : Boolean;
	tmpIcons	: StringArray;
	theWeight : Decimal[8,2];
	tmpSlotDefn	: CM_SlotDefnVoyage;
	tmpSlotRequest	: CM_SlotRequest;
	tmpNum,
	printStyle : Integer;
	fm : CM_FutureMove;
	
begin

	theTI := _theTI;
	
	if theTI = null then
		return;
	endif;
	
	if self.displayMode = DISPLAY_MODE_ACTUAL then
		if self.gridObjectsGetAtKeyForPut(_x1.Integer, _y1.Integer, _x2.Integer, _y2.Integer) = null then 
			self.gridObjectsPutAtKey(_x1.Integer, _y1.Integer, _x2.Integer, _y2.Integer, _theTI); 
		endif;
		
	elseif self.displayMode = DISPLAY_MODE_QUEUE then
		fm := _theTI.getFutureMoveForLC(QUEUE_MODE, self.myLocationsController); 
		if fm &lt;&gt; null then
			if self.gridObjectsGetAtKeyForPut(_x1.Integer, _y1.Integer, _x2.Integer, _y2.Integer) = null then		
				self.gridObjectsPutAtKey(_x1.Integer, _y1.Integer, _x2.Integer, _y2.Integer, fm); 
			endif;
		endif;
		
	elseif self.displayMode = DISPLAY_MODE_PLAN then
		fm := _theTI.getFutureMoveForLC(PLANNING_MODE, self.myLocationsController);
		if fm &lt;&gt; null then
//			self.allGridObjects.removeObjectFromDict(fm);
			if self.gridObjectsGetAtKeyForPut(_x1.Integer, _y1.Integer, _x2.Integer, _y2.Integer) = null then		
				self.gridObjectsPutAtKey(_x1.Integer, _y1.Integer, _x2.Integer, _y2.Integer, fm); 
			endif;
		endif;
	endif;

	theFrame := _frame;
	theFrame.drawFontSize := 8;
	
	self.myTrackedItem := theTI;
	lTIColour := self.getFillColourForTI(theTI);
	if self.useSelectorObjects and not self.allSelectorTIs.includes(theTI) then
		lTIColour := White;
	endif;
	
	theInverseColour := lTIColour.getInverseColour();

	self.drawBackground(theFrame,_x1, _y1, _x2, _y2);
	
	if self.drawBackEnd then
		self.drawBackendAtt(theTI, theFrame,_x1, _y1, _x2, _y2, theInverseColour);
		return;
	endif;

	lFactor := self.scaleFactor;
	lDisplayMode := self.displayMode;
	lViewMode := self.viewMode;

	
	theFrame.drawFillColor := lTIColour;

	self.drawMainCode(theTI, _x1, _y1, _x2, _y2 , theFrame,theInverseColour);

	// work out the width of the rectangle and split up, to get the even width for the attribute characters
	theCharacterWidth := ((_x2 - 1 - _x1) / 3 ).Integer;

	// #############
	if lFactor &lt; 2  then
		return;
	endif;
	if theTI &lt;&gt; null and theTI.isOverSizedContainer() then
		self.drawOverSizedMark(theFrame, theTI, lTIColour,  _x1, _y1, _x2,_y2); 
	endif;
	
	// Draw the attributes (if any)
	//self.drawIcons(theTI, theFrame,_x1,y1, theInverseColour);				// TFS 46405
	self.drawIcons(theTI, theFrame,_x1,y1, theInverseColour, false);		// TFS 46405
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theGridAttributes" type="CMUI_GridAttributes" usage="input"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_frame" type="YRD_ContainerDrawingFrame" usage="input"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getCurrentScrollingFrmValues" id="99e68079-abe9-4675-bf61-8cce48e1444d">
        <source>getCurrentScrollingFrmValues(_hScrollValue: Integer output; _vScrollValue: Integer output; _width: Real output; _height: Real output);
// ---------------------------------------------------------------------------
// Created:		14 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	numCol, numRow : Integer;
begin
	numCol := self.numColumns;
	numRow := self.numRows;
	
	self.myDockBar.getCurrentScrollingFrmValues(_hScrollValue, _vScrollValue, _width, _height);
	_width := (((self.ColumnWidth + 2) * self.scaleFactor) ) * numCol;
	_height := (((self.RowHeight +2)  * self.scaleFactor) * self.getHeightOfStack) * numRow;	// PAR 21532 CCMS SFW 1025

end;</source>
        <Parameter name="_hScrollValue" type="Integer" usage="output"/>
        <Parameter name="_vScrollValue" type="Integer" usage="output"/>
        <Parameter name="_width" type="Real" usage="output"/>
        <Parameter name="_height" type="Real" usage="output"/>
    </JadeMethod>
