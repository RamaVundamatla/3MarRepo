    <JadeMethod name="buildComboReason" id="0ec24d10-4995-40a0-9f56-ee978c3f942e">
        <source>buildComboReason();
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin

	self.myAssistant.comboBoxDeliveryReason(self.tblStatus, ETRow_DeliveryReason, DELSTR_SNT);	
