    <JadeMethod name="shouldAuditProperty" id="d223e703-c982-4550-af13-845c11a38242">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 December 2016	cnwma1	Initial creation

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_TIServiceMap::className.name or
		propName = CM_TIServiceMap::trackedItemClassNo.name or
		propName = CM_TIServiceMap::myChildQuantityMap.name  
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
