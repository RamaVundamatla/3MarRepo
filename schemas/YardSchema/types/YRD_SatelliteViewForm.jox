    <JadeMethod name="updateTableColumnFilters" id="b81270ed-33a1-40f3-86be-654ecf0ab454">
        <updating/>
        <source>updateTableColumnFilters(_table: Table; _allFilterColumns: CM_ColumnFilterDict) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

begin

	if self.allColumnFilters = null then
		create self.allColumnFilters transient;  // this is a non exclusive collection.
	endif;
	
	self.allColumnFilters.replaceAllFiltersForTable( _table, _allFilterColumns );

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_allFilterColumns" type="CM_ColumnFilterDict"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="cfc4d5e7-576a-4e57-8357-7eeb42d1966c">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2010	cnwer1	Initial creation

*/

vars
	userCode : String;
begin
	if userInfo &lt;&gt; null and userInfo.isKindOf(CM_User) then
		userCode := userInfo.CM_User.code;
	endif;
	if  eventType = self.myTerminal.getTerminalEvent(Event_TAView_Update) then
		app.msgBox(app.getErrorString2(AnotherUserHas_Upd_YourDetails,userCode,"Satellite View" ),app.getErrorString(Warning),MsgBox_OK_Only);
		
		self.doRefresh();
	elseif eventType = self.myTerminal.getTerminalEvent(Event_TAView_Delete) then
		app.msgBox(app.getErrorString2(AnotherUserHas_Del_YourDetails,userCode,"Satellite View" ),app.getErrorString(Warning),MsgBox_OK_Only);
		self.setMyTerminalAreaView(null);
		self.myCurrentDrawingController.YRD_GridOViewDrawingController.setMyTerminalAreaView(null);
		self.doRefresh();
	endif;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="viewForMode" id="2838c0ea-a391-4ebf-b3ff-866008f00877">
        <updating/>
        <source>viewForMode(_theIndex: Integer) updating, protected;
//11 August 2008	cnwdw1	
// 14 Nov 2010 		cnwer1 PAR 26189  Satellite view performance improvements
//
vars
	yardAllocationVisible: Boolean;
begin
	yardAllocationVisible := self.btnViewYardAlloc.value;
	
	if self.myCurrentDrawingController.viewMode = _theIndex then
		return;
	endif;
	
	self.xmlViewMode := _theIndex;
	self.myCurrentDrawingController.setViewMode(_theIndex);
	self.myCurrentDrawingController.YRD_GridOViewDrawingController.drawSelfAllChangeViewMode(_theIndex);
	if _theIndex = VIEW_IMPORT or 
	   _theIndex = VIEW_EXPORT then
	else
		self.setCaptionForModesGetView(_theIndex);
		self.doNotesForLegendStartStop(_theIndex,self.myCurrentDrawingController);
	endif;

	self.btnViewYardAlloc.value := yardAllocationVisible; 
	if self.btnViewYardAlloc.value then
		self.tblYAM_click(tblYAM);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_theIndex" type="Integer"/>
    </JadeMethod>
</GUIClass>
