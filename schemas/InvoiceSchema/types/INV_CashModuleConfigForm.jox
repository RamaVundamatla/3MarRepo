    <JadeMethod name="getResourceName" id="dd3259d6-7232-4564-bec9-0b0ce299367b">
        <source>getResourceName(_obj : Object):String;
/*
Purpose:			
Date				Who			Reason
MARCH 2018		JLGAB1		Initial creation
*/


vars
	resource : HMS_Resource;
begin
	if _obj.isKindOf(HMS_Resource) then
		resource := _obj.HMS_Resource;
		return resource.code &amp; " - '" &amp; resource.description &amp; "'";
	endif;
	
	return null;
