    <JadeMethod name="canUserAccessSelf" id="8872f650-bb40-40f8-a0ba-4194f50e2350">
        <source>canUserAccessSelf(_user : CM_User; _failedDAC  :CM_DataAccessController output; _passport: CM_Passport): Boolean;
//--------------------------------------------------
// Created:	18 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.myOrganisation &lt;&gt; null then
		if (not self.myOrganisation.canUserAccessSelf(_user, _failedDAC, _passport)) then
			return false;
		endif;
	endif;
	
	// cnwrl1 21/09/2009 PAR 20320 - MES 1011 New Messina Messages - start of coding
	// if the stop event request is for an EDI one then this user must
	// also have view access to the EDI operations form (CMUI_EDIForm)
	if self.isEDI then
		if _passport = null then
			return false;
		endif;
		if _user = null and app.getMyUser = null then
			return false;
		endif;
		if _user = null then
			if not app.getMyUser.canDo( _passport.myTerminal, PmAdmEdiopersView ) then
				return false;
			endif;
		else
			if not _user.canDo( _passport.myTerminal, PmAdmEdiopersView ) then
				return false;
			endif;
		endif;
	endif;
	// cnwrl1 21/09/2009 PAR 20320 - MES 1011 New Messina Messages - end of coding
	
	return inheritMethod(_user, _failedDAC, _passport);

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
