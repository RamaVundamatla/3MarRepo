    <JadeMethod name="doApplyScreenColors" id="88fef44b-1042-4c14-a6fe-f0e09623e188">
        <updating/>
        <source>doApplyScreenColors() updating;
// --------------------------------------------------------------------------------
// Created:		22 April 2008 by cnwdad1
//
// Purpose:		Standard method to apply screen colors to the receiver.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	grp_Colours.backColor	:=	app.colorBackGeneral;
	grp_Colours.foreColor	:=	app.colorForeGeneral;
	grp_General.backColor	:=	app.colorBackGeneral;
	grp_General.foreColor	:=	app.colorForeGeneral;
	grp_Tables.backColor	:=	app.colorBackGeneral;
	grp_Tables.foreColor	:=	app.colorForeGeneral;
end;</source>
    </JadeMethod>
    <JadeMethod name="doChangeToSelectedColors" id="01c328b5-26b6-44ae-b92c-03b703115985">
        <updating/>
        <source>doChangeToSelectedColors() updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 April 2008 by cnwdad1
//
// Purpose:		Applies the user's selected colors, not the ones held on APP.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.backColor			:=	self.aGeneralBack;
	grp_Colours.backColor	:=	self.aGeneralBack;
	grp_Colours.foreColor	:=	self.aGeneralFore;
	grp_General.backColor	:=	self.aGeneralBack;
	grp_General.foreColor	:=	self.aGeneralFore;
	grp_Tables.backColor	:=	self.aGeneralBack;
	grp_Tables.foreColor	:=	self.aGeneralFore;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doGetColor" id="b8939f87-2a44-4547-a8c3-7784fe187670">
        <source>doGetColor(_color:Integer io):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		24 January 2006 by cnwdad1
//
// Purpose:		Fetches a color using the Color Common Dialog.
//
// Parameters:	_color - The color that was selected by the user.
//
// Returns:		The selected color parameter, and true if a color was selected,
//				otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	colorObj	: CMDColor;
	
begin
	create colorObj transient;
	colorObj.preventFullOpen	:=	false;
	colorObj.color				:=	_color;
	
	if colorObj.open() = 0 then
		_color	:=	colorObj.color;
		return true;
	endif;
	
	return false;
epilog
	delete colorObj;
end;</source>
        <access>protected</access>
        <Parameter name="_color" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="12c5817b-c8aa-48f7-b124-90a655f269ad">
        <updating/>
        <source>doSave():Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		24 January 2006 by cnwdad1
//
// Purpose:		Standard save method.
//
// Parameters:	None
//
// Returns:		True if the save was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.myTrxRT.trxSetUserColors(self.aGeneralBack, self.aGeneralFore, self.aTablesBack, self.aTablesFore, app.myPassport);
	
	if app.myPassport.trxCompletedOK() then
		app.setApplicationColors(self.aGeneralBack, self.aGeneralFore, self.aTablesBack, self.aTablesFore);
//		app.writeSystemColorsToIni(self.aGeneralBack, self.aGeneralFore, self.aTablesBack, self.aTablesFore);
		self.modalResult	:=	self.MB_MODAL_UPDATE;
		return true;
	else
		self.checkAndShowErrors();
		return false;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
