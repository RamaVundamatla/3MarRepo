    <JadeMethod name="getDiameter" id="bbfbe645-351c-4a40-863d-5f3989b80d41">
        <source>getDiameter(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Sep 2024	navnk30	Bug 66204: EUP | 53308 - 1011 error when using and dimensions field in the Grouping criteria URGENT

*/

vars
	relCriteria			: CM_ReleaseByTypeCriteria;
	daimeterCriteria	: CM_YACriteria;
begin
	relCriteria := self.myReleaseCriteria;
	if relCriteria = null then
		return 0;
	endif;
	daimeterCriteria :=relCriteria.getCriteriaFor(YACriteriaType_Diameter);
	if daimeterCriteria = null or daimeterCriteria.myYAData = null then
		return 0;
	endif;
	return daimeterCriteria.myYAData.CM_YADataString.value.Decimal;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDisplayObject" id="2efb4115-ccf0-4890-b638-1d420db18da9">
