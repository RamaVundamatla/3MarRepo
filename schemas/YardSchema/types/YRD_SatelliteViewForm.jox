    <JadeMethod name="mnuMaintLabel_click" id="a8d30856-70ad-4252-90f0-4005e9aa38c3">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuMaintLabel_click(menuItem: MenuItem input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	lc : CM_GeneralCargoAllocController;
	group : CM_GeneralCargoAllocGroup;
	inputBox : CMUI_InputBox;
	labelText : String;
	result : Integer;

begin
	if menuItem.userObject = null then
		return;
	endif;
	
	lc := menuItem.userObject.CM_GeneralCargoAllocController;
	group := lc.myGroup;
	create inputBox transient;
	inputBox.init("Group Label", "", group.rangeLabel, 20, TextBox.DataType_AlphaNumeric, TextBox.Case_Upper, false, true);
	inputBox.myTerminal := self.myTerminal;
	inputBox.showModal;
	if inputBox.modalResult &lt;&gt; IDOK then
		return;
	endif;
	
	labelText := inputBox.txtInput.text.trimBlanks;
	if labelText &lt;&gt; group.rangeLabel then
		while true do
			app.myTrxUA.trxUpdateGCAllocGroupLabel(group, labelText, app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				return;
			else
				result := app.showErrorWarningDialog('Group Label', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
			
			return;
		endwhile;
	endif;
	
epilog
	// clear for next time
	self.userObject := null;
	delete inputBox;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuPref1_click" id="6c455de3-d0b6-4e9b-8757-38e30e043436">
