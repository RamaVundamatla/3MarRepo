    <JadeMethod name="initTableStats" id="3d021d36-9388-4cb9-8d58-291c8e8c24f2">
        <source>initTableStats();

/*

Purpose:		Initialise the stats table	

Date			Who		Reason
03/05/2012		cnwmh5	Initial creation

*/

vars

	tempDate					: Date;
	daysCount					: Integer;
	dateText					: String;
	index 						: Integer;
	
begin

	self.tblSStats.rows		:= 1;
	
	dateText := null;
	tempDate := self.txtSEndDate.text.Date;
	while tempDate &gt;= self.txtSStartDate.text.Date do
		daysCount := daysCount + 1;
		dateText := dateText &amp; tempDate.day.String.padLeadingZeros(2) &amp; "/" &amp; tempDate.month.String.padLeadingZeros(2) &amp; " " &amp; Tab;
		tempDate := tempDate.addDays(-1);
	endwhile;
	self.tblSStats.columns 	:= daysCount + 3;

	self.tblSStats.accessCell(1, 1).text := 
		'Class' &amp; Tab &amp;
		'Method' &amp; Tab &amp;
		'Total ' &amp; Tab &amp; 
		dateText;

	self.tblSStats.accessColumn(1).width := 200;
	self.tblSStats.accessColumn(2).width := 200;
	self.tblSStats.accessColumn(3).width := 100;
	
	foreach index in 3 to tblSStats.columns do
		self.tblSStats.accessColumn(index).alignment := Table.Alignment_Right;
	endforeach;	
	
	self.tblSStats.accessColumn(3).alignment := Table.Alignment_Right;
	
	self.tblSStats.selectMode := Table.SelectMode_WholeRows;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadAvgGraph" id="98270473-a2af-41cb-81df-ab2b2ada0203">
        <source>loadAvgGraph();

/*

Purpose:		Load up the Graph based on what is selected in the table above	

Date			Who		Reason
04/05/2012		cnwmh5	Initial creation

*/

vars
	
	graphObjStat				: CMUI_LineGraph;
	
	allXLabelsStat				: StringArray;
	allPlotValuesElapsed		: IntegerArray;
	allPlotValuesElapsed2		: RealArray;
	allPlotValuesAverage 		: IntegerArray;
	allPlotValuesAverage2 		: RealArray;
	
	title						: String;
	elapsedTime					: Real;
	smallestValue				: Real;
	yAxis						: String;
	value						: Real;
	numColumns					: Integer;
	colIndex					: Integer;
	tempEndDate					: Date;
	avgTotal					: Real;
	average						: Real;
	
begin

	// clear the graphs
	graphObjStat := self.graAStat;
	graphObjStat.clearGraph();

	// create the graph arrays
	create allXLabelsStat transient;
	create allPlotValuesElapsed transient;
	create allPlotValuesElapsed2 transient;
	create allPlotValuesAverage transient;
	create allPlotValuesAverage2 transient;
	
	// get the number of columns for the table
	numColumns := self.tblADetails.columns;
	
	title := self.tblADetails.accessCell(self.tblADetails.row, 1).text.trimBlanks() &amp; '::' &amp; 
		self.tblADetails.accessCell(self.tblADetails.row, 2).text.trimBlanks() &amp; ' Average Run Times';
	
	// get the details for the table
	smallestValue := 9999999.99999;
	foreach colIndex in 3 to numColumns step 1 do
		allXLabelsStat.add(self.tblADetails.accessCell(1, colIndex).text.trimBlanks());
		value := self.tblADetails.accessCell(self.tblADetails.row, colIndex).text.trimBlanks().Real;
		allPlotValuesElapsed2.add(value);
		allPlotValuesAverage2.add(value);
		if value &lt;&gt; 0 and smallestValue &gt; value then
			smallestValue := value;
		endif;
	endforeach;
	
	// check to see if anything is under 1 sec if is then multiple everything by 60.  Reason for doing this is that the
	// graph only does integers and that for timings under 1 sec it doesn't register.
	if smallestValue &lt; 1.00 then
		smallestValue := 60;
		yAxis := "Time (sec) * 60";
	else
		smallestValue := 1;
		yAxis := "Time (sec)";
	endif;
	// update the values that are displayed.
	foreach elapsedTime in allPlotValuesElapsed2 do
		allPlotValuesElapsed.add((elapsedTime * smallestValue).Integer);
	endforeach;
	
	// get the average value to plot
	foreach average in allPlotValuesAverage2 do
		avgTotal := avgTotal + (average * smallestValue);
	endforeach;
	avgTotal := avgTotal / (numColumns - 2);
	foreach colIndex in 3 to numColumns step 1 do
		allPlotValuesAverage.add(avgTotal.Integer);
	endforeach;
	
	// display the details on the graph
	graphObjStat.setAndShowGraphTitle(title);
	graphObjStat.init(title, "Date", yAxis);
	
	graphObjStat.addXLabels(allXLabelsStat, null);
	graphObjStat.addLineWithValues("", Blue, allPlotValuesElapsed);
	
	graphObjStat.addLineWithValues("", Green, allPlotValuesAverage);
	
	graphObjStat.drawGraph();
	graphObjStat.click(graphObjStat);
	graphObjStat.visible := true;
	
epilog

	delete allXLabelsStat;
	delete allPlotValuesElapsed;
	delete allPlotValuesElapsed2;
	delete allPlotValuesAverage;
	delete allPlotValuesAverage2;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadForList" id="0b7393f4-d574-4b1e-a4bb-d9b9047bf08e">
        <source>loadForList(_listbox : ListBox io);

/*

Purpose:		Load For List listbox	

Date			Who		Reason
04/05/2012		cnwmh5	Initial creation

*/

vars

	classMethod						: UM_UnitTestClassMethod;								// 10/09/2013 cnwmh5
	
begin

	//self.lstClassMethod.clear();
	_listbox.clear();

	foreach classMethod in self.myRoot.allRunnableUTClassesMethods do						// 10/09/2013 cnwmh5
		//self.lstClassMethod.addItem(classMethod.className &amp; '::' &amp; classMethod.methodName);
		//self.lstClassMethod.itemObject[self.lstClassMethod.listCount] := classMethod;
		_listbox.addItem(classMethod.className &amp; '::' &amp; classMethod.methodName);
		_listbox.itemObject[_listbox.listCount] := classMethod;
	endforeach;

epilog

end;</source>
        <Parameter name="_listbox" type="ListBox" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadStatsGraph" id="1665d240-63c9-4b21-8e9f-85f5d93fb5db">
        <source>loadStatsGraph();

/*

Purpose:		Load up the Graph based on what is selected in the table above	

Date			Who		Reason
04/05/2012		cnwmh5	Initial creation

*/

vars
	
	graphObjStat				: CMUI_LineGraph;
	
	allXLabelsStat				: StringArray;
	allPlotValuesElapsed		: IntegerArray;
	allPlotValuesElapsed2		: RealArray;
	
	title						: String;
	elapsedTime					: Real;
	smallestValue				: Real;
	yAxis						: String;
	value						: Real;
	numColumns					: Integer;
	colIndex					: Integer;
	tempEndDate					: Date;

begin

	// clear the graphs
	graphObjStat := self.graSStat;
	graphObjStat.clearGraph();

	// create the graph arrays
	create allXLabelsStat transient;
	create allPlotValuesElapsed transient;
	create allPlotValuesElapsed2 transient;
	
	// get the number of columns for the table
	numColumns := self.tblSStats.columns;
	
	title := self.tblSStats.accessCell(self.tblSStats.row, 1).text.trimBlanks() &amp; '::' &amp; 
		self.tblSStats.accessCell(self.tblSStats.row, 2).text.trimBlanks() &amp; ' Run Times for ' &amp; 
		self.txtSStartDate.text.Date.String &amp; ' to ' &amp; self.txtSEndDate.text.Date.String;
	
	// get the details for the table
	smallestValue := 9999999.99999;
	tempEndDate := self.txtSEndDate.text.trimBlanks().Date;
	foreach colIndex in 4 to numColumns step 1 do
		allXLabelsStat.add(self.tblSStats.accessCell(1, colIndex).text.trimBlanks());
		value := self.tblSStats.accessCell(self.tblSStats.row, colIndex).text.trimBlanks().Real;
		allPlotValuesElapsed2.add(value);
		if value &lt;&gt; 0 and smallestValue &gt; value then
			smallestValue := value;
		endif;
		tempEndDate := tempEndDate.addDays(-1);
	endforeach;
	
	// check to see if anything is under 1 sec if is then multiple everything by 60.  Reason for doing this is that the
	// graph only does integers and that for timings under 1 sec it doesn't register.
	if smallestValue &lt; 1.00 then
		smallestValue := 60;
		yAxis := "Time (sec) * 60";
	else
		smallestValue := 1;
		yAxis := "Time (sec)";
	endif;
	// update the values that are displayed.
	foreach elapsedTime in allPlotValuesElapsed2 do
		allPlotValuesElapsed.add((elapsedTime * smallestValue).Integer);
	endforeach;
	
	// display the details on the graph
	graphObjStat.setAndShowGraphTitle(title);
	graphObjStat.init(title, "Date", yAxis);
	
	graphObjStat.addXLabels(allXLabelsStat, null);
	graphObjStat.addLineWithValues("", Blue, allPlotValuesElapsed);
	
	graphObjStat.drawGraph();
	graphObjStat.click(graphObjStat);
	graphObjStat.visible := true;
	
epilog

	delete allXLabelsStat;
	delete allPlotValuesElapsed;
	delete allPlotValuesElapsed2;
	
end;</source>
    </JadeMethod>
