    <JadeMethod name="copyServerFileToClient" id="4063174d-60a6-49b8-aea4-335858ce75a4">
        <source>copyServerFileToClient(_serverFileName, _localFileName : String;
						_cmifMonitor : CMIF_Monitor input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     17 October 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	fileDisplayName : String;
	fileData,
	
	bin			: Binary;
	fileCopy	: File;
	idx,
	byteCount,
	binLength,
	chunkSize	: Integer;
begin
	//cnwjo3 par #19216
	//on FileException do fileExceptionHandler(exception, "Transfer");  //cnwrd1 par#16684 28.7.2008      
	on FileException do fileExceptionHandler(exception, ERR_FILETRANSFER);
	
	bin := self.loadBinaryFileServer(_serverFileName, _cmifMonitor);
	
	if bin = null then
		return false;
	endif;
	
	create fileCopy transient;
	fileCopy.usePresentationFileSystem := true;
	fileCopy.shareMode 	:= File.Share_Exclusive;
	fileCopy.kind 			:= File.Kind_Binary;
	fileCopy.readOnly 		:= false;
	fileCopy.allowCreate 	:= true;
	fileCopy.allowReplace 	:= true;
	fileCopy.mode 			:= File.Mode_Output;
	fileCopy.fileName 		:= _localFileName;
	binLength		:= bin.length;
	chunkSize		:= File_DownloadChunkSize;

	if _cmifMonitor &lt;&gt; null then
		idx := _localFileName.reversePos('\');
		fileDisplayName := _localFileName[idx + 1 : end];
		
		_cmifMonitor.partsInJob := (binLength / 1024).Integer;
		_cmifMonitor.partsDone := null;		
		_cmifMonitor.updateProgress('Writing file : ' &amp; fileDisplayName,
								_cmifMonitor.partsInJob, _cmifMonitor.partsDone);
	
		byteCount := 1;
		//while byteCount &lt;= binLength do
		while true do
			if byteCount &gt; binLength then
				break;
			endif;
			if byteCount + File_DownloadChunkSize &gt; binLength then
				fileData := bin[byteCount : end];
			else
				fileData := bin[byteCount : File_DownloadChunkSize];
			endif;

			fileCopy.writeBinary(fileData);
			
			_cmifMonitor.updateProgress('Writing file : ' &amp; fileDisplayName,
										(binLength / 1024).Integer, (byteCount / 1024).Integer);
			
			if _cmifMonitor.monitorReturnValue = _cmifMonitor.MonitorReturnValue_Cancel then
				return false;
			endif;
			
			byteCount := byteCount + File_DownloadChunkSize;
		endwhile;
	else		
		fileCopy.writeBinary(bin);
	endif;
	
	return true;

epilog
	if fileCopy &lt;&gt; null then
		fileCopy.close;
		delete fileCopy;
	endif;
end;</source>
        <Parameter name="_serverFileName" type="String"/>
        <Parameter name="_localFileName" type="String"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyServerFolderToClient" id="322fe446-1e6a-4793-abc1-4629021eb38a">
        <source>copyServerFolderToClient(_serverFolderName, _localFolderName: String;
						_cmifMonitor: CMIF_Monitor input): Boolean;
// ---------------------------------------------------------------------------
// Created:     17 October 2004 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	serverFileName, clientFileName: String;
	fileNode: FileNode;
	fileFolder: FileFolder;
begin
	create fileFolder transient;
	fileFolder.fileName := _localFolderName;
	fileFolder.usePresentationFileSystem := true;
	if not fileFolder.isAvailable then
		fileFolder.make;
	endif;
	fileFolder.fileName := _serverFolderName;
	fileFolder.mask := "*.*";
	fileFolder.usePresentationFileSystem := false;
	foreach fileNode in fileFolder.files do
		if fileNode.isKindOf(File) then
			serverFileName := fileNode.fileName;
			clientFileName := _localFolderName &amp;'\'&amp;fileNode.cnGetSimpleFileName;
			if not self.copyServerFileToClient(serverFileName, clientFileName, _cmifMonitor) then 
				return false;
			endif;
		endif;
	endforeach;	
	return true;
epilog
	delete fileFolder;
end;</source>
        <Parameter name="_serverFolderName" type="String"/>
        <Parameter name="_localFolderName" type="String"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="countProcesses" id="d92b9678-3c2f-4aa5-9bdf-d58efcc230ab">
        <source>countProcesses(_ignoreMinuteCheck : Boolean);
/*
------------------------------------------------------------------------
Created:			27 March 2003 by cnwdwq1
Purpose:			Creates a process/node counter whenever called. These are all added to
							a globalProcessRoot instance that is basically accessed by a first instance call.
							They are therefore "hanging".
							These things count the nodes and processes in the system, and are called on
							an as-required basis by the background processor. We use this to determine simple
							load stats at some stage.
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	gblR : CM_GlobalProcessRoot;
	minVal : Integer;
begin

	gblR := CM_GlobalProcessRoot.firstInstance;
	if gblR = null then
		beginTransaction;
		create gblR persistent;
		commitTransaction;
	endif;
	if _ignoreMinuteCheck then
		minVal := 0;
	else
		minVal := 30;
	endif;
	gblR.createProcessDetail(minVal, true);

end;</source>
        <Parameter name="_ignoreMinuteCheck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createTxnControllerForType" id="1d3e0b7a-f99e-457a-98f3-bbe603f46ce2">
        <source>createTxnControllerForType(_txnType : Integer; _txnController : CMIF_TITransactionController output);
// ---------------------------------------------------------------------------
// Created:     05 June 2003		cnwth2	
//
// Purpose:     		 
//
/****Changes

Date		Name	TFS#				Description
============================================================================
20/03/2015	cnwdap1	PAR #35874 TFS 265 	Added humidity and ventilation controllers
14/08/2017	cnwma1	TFS #5695:STWO 		Re-Calculate Volumes on Forms and EDI
14/05/2018	jlgdap1	TFS 38501 			PEL1 Work Order Changes
30/11/2018	jlgka1 TFS 41225			SNO - Repaired Transactions - Revisit.
12/11/2019	jlgdi1	46578				Added transaction controller for 'Receive Road Cancel' transaction type
23/09/2022  navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions
18/04/2023	navkc1	CR 56430 EUP Shortlanded Overlanded Jade
============================================================================*/
begin
	if _txnType = TRANS_TYPE_FUELED then
		create _txnController as CMIF_FuelTransController transient;
	
	elseif _txnType = TRANS_TYPE_SEALED then
		create _txnController as CMIF_SealTransController transient;

	elseif _txnType = TRANS_TYPE_MOVE or
		_txnType = TRANS_TYPE_MOVE_CRANE or // ### TFS 51855 04FEB2022 NAVAB1
		_txnType = TRANS_TYPE_MOVE_PICKUP or
		_txnType = TRANS_TYPE_MOVE_SETDOWN then
		create _txnController as CMIF_MoveTransactionController transient;

	elseif _txnType = TRANS_TYPE_HIRE then
		create _txnController as CMIF_HireTransController transient;
	elseif _txnType = TRANS_TYPE_CONNECT_POWER or
	   _txnType = TRANS_TYPE_CONNECT_TOWER or
	   _txnType = TRANS_TYPE_DISCONNECT_POWER or
	   _txnType = TRANS_TYPE_DISCONNECT_TOWER then
		create _txnController as CMIF_PowerTransController transient;
	
	elseif _txnType = TRANS_TYPE_PACK or _txnType = TRANS_TYPE_UNPACK then
		create _txnController as CMIF_PackTransController transient;
	elseif _txnType = TRANS_TYPE_STOWAGE_CONFIRM then 
	// epr tallyman CCMS 7/11/11
		create _txnController as CMIF_StowageConfirmController transient;
	elseif _txnType = TRANS_TYPE_FREE_STORAGE_ADJ then
		
		create _txnController as CMIF_FreeStorageAdjustment transient;
	elseif _txnType = TRANS_TYPE_TEMP_READING then
		//epr 2/8/12 
		create  _txnController as CMIF_TempTransController transient;
	elseif _txnType = TRANS_TYPE_SPLIT or
			_txnType = TRANS_TYPE_MERGE then
		//epr 2/8/12 
		create  _txnController as CMIF_SplitTransController transient;
	elseif _txnType = TRANS_TYPE_WORKORDER_ASSIGN or
		_txnType = TRANS_TYPE_WORKORDER_UNASSIGN then
		//epr 2/8/12 
		create  _txnController as CMIF_WorkOrderTransController transient;		
	elseif _txnType = TRANS_TYPE_HUMIDITYREADING then						// PAR #35874
		create _txnController as CMIF_HumidTransController transient;		// PAR #35874

	elseif _txnType = TRANS_TYPE_VENTILATIONREADING then					// PAR #35874
		create _txnController as CMIF_VentTransController transient;		// PAR #35874
	elseif _txnType = TRANS_TYPE_CONSUMED then								// TFS 456 36912
		create _txnController as CMIF_SplitTransController transient;
	elseif _txnType = TRANS_TYPE_STORAGE then
		//epr TFS 1693 23/3/16
		create _txnController as CMIF_StorageTransController transient;		
	elseif _txnType = TRANS_TYPE_AUTOVOLUME then						   // 14.8.2017 cnwma1 TFS #5695
		create _txnController as CMIF_VolumeDiscrepancyCont transient;
	elseif _txnType = TRANS_TYPE_BREAKBULK_OVERAGE or	//	23 Apr 2018	NDL	TFS 37558
		 _txnType = TRANS_TYPE_LocationDiscrep or	// 07 May 2021	NDL	TFS 50906
		 _txnType = TRANS_TYPE_DISCREPANCY_SHIP then	// 18/04/2023	navkc1	CR 56430
		create _txnController as CMIF_BBDiscrepancyController transient;
	elseif	_txnType = TRANS_TYPE_WO_TODO_VOY_CREATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TODO_VOY_UPDATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TODO_VOY_COMPLET or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TODO_TRK_CREATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TODO_TRK_UPDATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TODO_TRK_COMPLET or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TODO_TRN_CREATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TODO_TRN_UPDATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TODO_TRN_COMPLET or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TODO_WGN_CREATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TODO_WGN_UPDATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TODO_WGN_COMPLET or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TODO_VBS_CREATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TODO_VBS_UPDATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TODO_VBS_COMPLET or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TODO_NOP_CREATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TODO_NOP_UPDATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TODO_NOP_COMPLET or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TIMOVE_CREATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TIMOVE_UPDATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TIMOVE_COMPLET or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TICHGVOY_CREATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TICHGVOY_UPDATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TICHGVOY_COMPLET or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TIREC_CREATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TIREC_UPDATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TIREC_COMPLET or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TIRELEXT_CREATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TIRELEXT_UPDATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TIRELEXT_COMPLET or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TIREL_CREATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TIREL_UPDATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TIREL_COMPLET or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TITODO_CREATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TITODO_UPDATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TITODO_COMPLET or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TIEXPRET_CREATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TIEXPRET_UPDATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TIEXPRET_COMPLET or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TIPACK_CREATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TIPACK_UPDATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TIPACK_COMPLET or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TIUNPACK_CREATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TIUNPACK_UPDATED or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WO_TIUNPACK_COMPLET or // navcs2 #56633:[56211]
			_txnType = TRANS_TYPE_WORKORDER_MOVE or							// TFS 38501
			_txnType = TRANS_TYPE_WORKORDER_NULLVOY or						// TFS 38501
			_txnType = TRANS_TYPE_WORKORDER_RECEIVE or						// TFS 38501
			_txnType = TRANS_TYPE_WORKORDER_RELEASE or						// TFS 38501
			_txnType = TRANS_TYPE_WORKORDER_RETURNED or						// TFS 38501
			_txnType = TRANS_TYPE_WORKORDER_RELEXTEND or	//12 Mar 2019	NDL	TFS 43405
			_txnType = TRANS_TYPE_WORKORDER_EXTRATI or						// TFS 42221
			_txnType = TRANS_TYPE_WOJOBSTART or		//13/03/2024	navkc1 CR 62890 Task 62892
			_txnType = TRANS_TYPE_WOJOBSTOP or		//13/03/2024	navkc1 CR 62890 Task 62892
			_txnType = TRANS_TYPE_WOJOBRESUME or	//13/03/2024	navkc1 CR 62890 Task 62892
			_txnType = TRANS_TYPE_WOJOBCOMPLETE 	//13/03/2024	navkc1 CR 62890 Task 62892
			then
			
		create _txnController as CMIF_WorkOrderTransController transient;	// TFS 38501
	elseif _txnType = TRANS_TYPE_REPAIR_DETAILS then						// jlgka1  TFS 41225
		create _txnController as CMIF_RepairDetailsController transient;	// jlgka1  TFS 41225	
	elseif _txnType = TRANS_TYPE_RCVROADCANCELLED then 
		create _txnController as CMIF_RcvRoadCancelledCntlr transient;
	else
		create _txnController transient;
	endif;
	
	_txnController.type := _txnType;
end;</source>
        <Parameter name="_txnType" type="Integer"/>
        <Parameter name="_txnController" type="CMIF_TITransactionController" usage="output"/>
    </JadeMethod>
    <JadeMethod name="dataDumpFormatBin" id="f01f48db-14fc-4596-adf2-eacbfe75baa1">
        <source>dataDumpFormatBin(_obj: Object) : Binary;
// ---------------------------------------------------------------------------
// Created:     30 June 2003 by cnwsb1
//
// Performance:	Uses getOidStringForObject to avoid dereferencing _obj (as
//				_obj may be an invalid object, and we still want to dataDump
//				the hex OID in this case).
//              conkc1
//				Now replace by
//				getClassNumberForObject(_obj);
//				getInstanceIdForObject(_obj).Integer; - much faster
// ---------------------------------------------------------------------------
vars
	classId    : Integer;
	instanceId : Integer;
	bin        : Binary[6];

begin
	classId    := getClassNumberForObject(_obj);
	instanceId := getInstanceIdForObject(_obj).Integer;

	if classId = null then
		return null;
	endif;
		
	bin := classId.asBinary(2) &amp; instanceId.asBinary(4);
			
	return bin;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="dataDumpFormatHex" id="e898a355-9787-4e43-a5a8-4f4ae0b16142">
        <source>dataDumpFormatHex(_obj: Object) : String;
// ---------------------------------------------------------------------------
// Created:     30 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	classId      : Integer;
	instanceId   : Integer;
	hexFormatStr : String;
begin
	//
	// Much faster than previous code
	// self.getOidStringForObject(_obj).oidStringToDataDumpHex;
	//
	classId    := getClassNumberForObject(_obj);
	instanceId := getInstanceIdForObject(_obj).Integer;
	
	if classId = null then
		return null;
	endif;
	
	hexFormatStr := "0x" &amp; classId.asHex(4) &amp; instanceId.asHex(8);
	if hexFormatStr.length &gt; 14 then
		// cnwsb1: This should never happen.  If it does, we have a major
		// data conversion effort due with current external databases.
		app.raiseUnexpectedProgramError(String.name, method.name,
				"Data Dump Hex format string more than 14 characters: " &amp; hexFormatStr);
		return null;
	endif;
	
	return hexFormatStr;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="dataDumpFormatStr" id="b6da5e7d-20ca-44e1-a1d4-9717e1705d15">
        <source>dataDumpFormatStr(_obj : Object) : String;
// ---------------------------------------------------------------------------
// Created:     27 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	return self.getOidStringForObject(_obj);

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="fileExceptionHandler" id="1405bee0-05a1-41ba-94ec-6fc09a8e742d">
        <source>fileExceptionHandler(_ex : Exception; _translatableStringError : Integer) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 July 2008	cnwrd1	Initial creation
//cnwrd1 par#16684 28.7.2008 
*/

vars
	errorText: String;
	title : String;
begin
	//par #19216 cnwjo3
	//errorText := "Transfering file: '" &amp; _ex.FileException.file.fileName &amp; "' caused an error";
	//errorText := errorText &amp; Lf &amp; _ex.text &amp; Lf &amp; Lf &amp; "Aborting " &amp; _label &amp; " Operation!";
	
	errorText := app.getErrorString2(_translatableStringError,_ex.FileException.file.fileName,_ex.text);
	
	title := app.getErrorStringShortText(_translatableStringError);
	
	app.msgBox(errorText, title,
		MsgBox_OK_Only  + MsgBox_System_Modal + MsgBox_Exclamation_Mark_Icon);

	if process.isInTransactionState then
		app.cmsAbortTransaction;
	endif;

	return Ex_Abort_Action;
	
	epilog

end;</source>
        <Parameter name="_ex" type="Exception"/>
        <Parameter name="_translatableStringError" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="formatAsXML" id="c2fe76f6-9fae-4553-bbe9-0273f6f83e77">
        <source>formatAsXML(pTag, pValue : String) : String;
// ---------------------------------------------------------------------------
// Created:     27 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rtnStr	: String;
	
begin

	rtnStr := J_key_LessThan.Character &amp; pTag &amp; J_key_GreaterThan.Character &amp; 
			  pValue &amp; 
			  J_key_LessThan.Character &amp; J_key_Slash.Character &amp; pTag &amp; J_key_GreaterThan.Character &amp; CrLf;

	return rtnStr;
	
end;</source>
        <Parameter name="pTag" type="String"/>
        <Parameter name="pValue" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
