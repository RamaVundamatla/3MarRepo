    <JadeMethod name="addToolbarControls" id="86759b25-d414-406f-bfae-3ed9b6a8fb60">
        <updating/>
        <source>addToolbarControls() updating, protected;
// --------------------------------------------------------------------------------
// Created:		30 November 2009 by cnwjo3
//
// Purpose:		place the Edit, Save and Cancel buttons onto the toolbar
//
vars

begin
	inheritMethod();
	
	self.frmToolbar.addButton(self.btnEdit,CMUI_Toolbar.Control_Alignment_Left);
	self.frmToolbar.addButton(self.btnSaveBase,CMUI_Toolbar.Control_Alignment_Left);
	self.frmToolbar.addButton(self.btnCancelBase,CMUI_Toolbar.Control_Alignment_Right);
	self.frmToolbar.positionToolbarControls();
	self.frmToolbar.refresh();
end;
	</source>
        <access>protected</access>
    </JadeMethod>
