        <updating/>
        <source>btnAutoId_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2014	cnwndl1	Initial creation	Par 34460
04/01/2023		navkc1	TFS CR 55300 TASK 55525 UI - Business Unit Maint changes  for auto id

*/

vars

	form : CMUI_AutoIdConfiguration;
	term : CM_Terminal;
	
begin

	if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_Terminal) then
		term := self.myCurrentObject.CM_Terminal;
	endif;
	
	if term = null then
		return;
	endif;

	//create form; // 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	app.mousePointer := MousePointer_Default;
	// 04/01/2023	navkc1	TFS CR 55300 TASK 55525
	form := app.loadForm(CMUI_AutoIdConfiguration, CMUI_Assistant, false, false, false, term, null).CMUI_AutoIdConfiguration;
	
	if form = null then
		return;
	endif;
	
	form.setForIdType( 0, term );
	//form.showModal();
	form.myParentForm := self;
	form.show(); // 04/01/2023	navkc1	TFS CR 55300 TASK 55525

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
