    <JadeMethod name="isSameAs" id="e4f26efc-b93f-4180-bdda-4cab47c10015">
        <source>isSameAs(_allTestCriteria : CMIF_Array) : Boolean;
// -------------------------------------------
// Created 05 October 2005 by cnwdvb1
// -------------------------------------------
vars
	tmpObj			: CMIF_Object;
	realCriteria,
	testCriteria	: CM_YACriteria;
	tmpFound		: Boolean;	
begin

	if _allTestCriteria = null or
	   (_allTestCriteria.size &lt;&gt; self.allCriteria.size) then
		return false;
	endif;

	foreach realCriteria in self.allCriteria discreteLock do
		tmpFound := false;
		foreach tmpObj in _allTestCriteria do
			testCriteria	:= tmpObj.CMIF_YACriteriaPriority.myProxy.CM_YACriteria;
			if realCriteria.myYACriteriaType = testCriteria.myYACriteriaType then
				tmpFound := true;
				if (not realCriteria.myYAData.doDataComparison(testCriteria.myYAData)) then
					// data is different
					return false;
				else
					break;
				endif;
			endif;
		endforeach;
		if (not tmpFound) then
			return false;
		endif;
	endforeach;

	return true;

end;</source>
        <Parameter name="_allTestCriteria" type="CMIF_Array"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSameCriteria" id="fcb8fc4b-ed02-479f-84e1-56013d931204">
        <source>isSameCriteria(_yardAllocation: CM_YardAllocation): Boolean;

/*

Purpose:		Check if all the criteria specified for the yard allocation are the same, including all values.

Parameters:			

Return Value:	Returns true when all criteria are the same


Date			Who		Reason
19 August 2008	consw1	SFW1030 - Promoted method from sub-class CM_RailAllocation

*/

vars
	compareCriteria,
	criteria			: CM_YACriteria;
begin
	if _yardAllocation = self then
		return true;
	endif;
	
	if _yardAllocation.allCriteria.size &lt;&gt; self.allCriteria.size then
		return false;
	endif;
	
	foreach criteria in self.allCriteria do
		compareCriteria := _yardAllocation.getCriteriaOfType(criteria.myYACriteriaType);
		if compareCriteria = null then
			return false;
		endif;
		
		if (not criteria.myYAData.isSameCriteria(compareCriteria.myYAData)) then
			return false;
		endif;
	endforeach;

	return true;
end;


</source>
        <Parameter name="_yardAllocation" type="CM_YardAllocation"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSameCriteriaSubset" id="761eb348-32f5-45b9-aa64-7e7f9135bd05">
        <source>isSameCriteriaSubset(_yardAllocation: CM_YardAllocation; _yaAgent : CM_YAAutoplanAgent input; _cmifAutoPlan : CMIF_YAAutoPlan): Boolean;

/*

Purpose:	Check if all the criteria specified for the yard allocation are the same, if they exist	

			self is the YA we are testing against _yardAllocation
			if self has a criteria match with _yardAllocation we need to make sure they are compatible
			_yardAllocation can have more criteria ( be a more specific allocation)
			If either have unique criteria we can igcnore that
Parameters:			

Return Value:		


Date		Who		Reason
14 November 2012	cnwrd1	Initial creation
//cnwrd1 ccms 1303 14.11.2012
*/

vars
	compareCriteria,
	criteria			: CM_YACriteria;
begin
	if _yardAllocation = self then
		return true;
	endif;
	
	foreach criteria in self.allCriteria do
		compareCriteria := _yardAllocation.getCriteriaOfType(criteria.myYACriteriaType);
		if compareCriteria = null then
			continue;
		endif;
		
		if (not criteria.myYAData.isSameCriteria(compareCriteria.myYAData)) then
			if _yaAgent &lt;&gt; null then
				_yaAgent.addLogEntry(AP_Log_YA_No_Match,app.getErrorString1(Item_failed_match_criteri,criteria.getDescription()) , false);
			endif;
			if _cmifAutoPlan &lt;&gt; null and _cmifAutoPlan.raiseWarning then
				app.raiseCMWarning1(Item_failed_match_criteri, criteria.getDescription(), null, null, criteria);
			endif;
		
			return false;
		endif;
	endforeach;

	if _yaAgent &lt;&gt; null then
		_yaAgent.addLogEntry(AP_Log_YA_Match,app.getErrorString1(Item_matched_criteria,criteria.getDescription()), false);
	endif;

	
	return true;
end;</source>
        <Parameter name="_yardAllocation" type="CM_YardAllocation"/>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSimilarTo" id="68ab031e-bc2a-4a7f-a348-27e34e6cb5db">
        <source>isSimilarTo(_allTestCriteria : CMIF_Array) : Boolean;
// -------------------------------------------
// Created Nov 2007 cnwrs1 CCMS 1547
// -------------------------------------------
// do the matching criteria compare - not worried is one has more criteria than the other
vars
	tmpObj			: CMIF_Object;
	realCriteria,
	testCriteria	: CM_YACriteria;
	tmpFound		: Boolean;	
begin

	if _allTestCriteria = null or
	   self.allCriteria.size = 0 then //par15561 cnwrs1 Jan 2008
		return false;
	endif;

	foreach realCriteria in self.allCriteria discreteLock do
		tmpFound := false;
		foreach tmpObj in _allTestCriteria do
			testCriteria	:= tmpObj.CMIF_YACriteriaPriority.myProxy.CM_YACriteria;
			if realCriteria.myYACriteriaType = testCriteria.myYACriteriaType then
				tmpFound := true;
				if (not realCriteria.myYAData.doDataComparison(testCriteria.myYAData)) then
					// data is different
					return false;
				else
					break;
				endif;
			endif;
		endforeach;
		if (not tmpFound) then
			return false;
		endif;
	endforeach;

	return true;

end;
</source>
        <Parameter name="_allTestCriteria" type="CMIF_Array"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTranshipAllocation" id="aae88347-d123-48b3-8b0a-0f468b7f2224">
        <source>isTranshipAllocation() : Boolean;
// ---------------------------------------------------------------------------
// Created:     11 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	criteria : CM_YACriteria;
	imex : CM_IMEXStatus;
begin

	criteria := self.getCriteriaOfTypeValue(YACriteriaType_ImexStatus);
	if criteria = null then
		return false;
	endif;
	
	imex :=  criteria.myYAData.CM_YADataObjects.allObjects.first.CM_IMEXStatus;
	if imex &lt;&gt; null then
		return (imex.code = TI_IMEX_STATUS_TRANSHIP);
	endif;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
