    <JadeMethod name="setMyCurrentSDF" id="3cce881a-885a-4193-b77a-f40a9083aec6">
        <updating/>
        <source>setMyCurrentSDF(_theNewSDF : CMUI_ScrollableDrawingFrame input; _changeBackColour : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	
begin
	if self.myCurrentSDF = _theNewSDF then
		return;
	endif;
	if self.myCurrentSDF &lt;&gt; null and _changeBackColour then
		self.myCurrentSDF.changeBackColor(self.myTerminal.getConfig(DefYardBackColUnselected).Integer);
	endif;

	self.myPreviousSDF := self.myCurrentSDF;
	self.myCurrentSDF := _theNewSDF;

	if self.myCurrentSDF &lt;&gt; null and _changeBackColour then
		self.myCurrentSDF.changeBackColor(self.myTerminal.getConfig(DefYardBackColSelected).Integer);
	endif;

end;</source>
        <Parameter name="_theNewSDF" type="CMUI_ScrollableDrawingFrame" usage="input"/>
        <Parameter name="_changeBackColour" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSelector" id="9b73a1fc-4366-4659-bcf5-a56c3cc920b8">
        <updating/>
        <source>setSelector(_theSelector : CMUI_Selector input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	_theSelector.myTerminal := self.myTerminal;
	_theSelector.myEnquiryCollectionClass := CM_TIArray;
	_theSelector.defaultSiteStr := TI_SITE_ONSITE_str;

end;</source>
        <access>protected</access>
        <Parameter name="_theSelector" type="CMUI_Selector" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="08cf6930-a367-439e-b82b-39afaba42644">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     21 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
 	if not self.myTerminal.getConfig(ShowCargoPicture).Boolean and not self.areaType = self.Area_Type_Log then
 		self.sptBottom.hideRightControl(true);
 	endif;
	self.mnuGridAreaContext.visible := false;
	self.doInitInfoTable();
	// this sets the captions for some menus
	self.getXMLSettingsForSetup();
	
	if self.areaType = self.Area_Type_Log then
		if self.xmlLegend then // we are hiding
			self.mnuGridHideLegend.caption := self.MNU_LEGEND_SHOW;
			self.mnuWorkDisplayHideLgnd.caption := self.MNU_LEGEND_SHOW;
			self.sptBottom.hideRightControl(true);
		else
			self.mnuGridHideLegend.caption := self.MNU_LEGEND_HIDE;
			self.mnuWorkDisplayHideLgnd.caption := self.MNU_LEGEND_HIDE;
		endif;
	else
		if self.xmlLegend then
			self.mnuGridHideLegend.caption := self.MNU_LEGEND_HIDE;
			self.mnuWorkDisplayHideLgnd.caption := self.MNU_LEGEND_HIDE;
		else
			self.splMain.hideLeftControl(true);
			self.mnuGridHideLegend.caption := self.MNU_LEGEND_SHOW;
			self.mnuWorkDisplayHideLgnd.caption := self.MNU_LEGEND_SHOW;
		endif;
	
	endif;	
	if not self.xmlMacro then
		self.mnuGridHideMacro.caption := self.MNU_MACRO_SHOW;
	else
		self.mnuGridHideMacro.caption := self.MNU_MACRO_HIDE;
	endif;
	self.mnuGridHideMacro_click(self.mnuGridHideMacro); // this reverses the lines above and sets things correctly
	sdf01.myDrawingAttrController.myTerminal := self.myTerminal;
	sdf02.myDrawingAttrController.myTerminal := self.myTerminal;
	sdf03.myDrawingAttrController.myTerminal := self.myTerminal;
	
	self.frmStatusLine.initFrame();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showCargoPicture" id="e5d421b1-c61f-446b-9313-cd77b1962029">
        <source>showCargoPicture(_theTI : CM_TrackedItem) : Binary;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	thePicture : Binary;
begin
	
	
	if _theTI = null then
		return null;
	endif;
 	if not self.myTerminal.getConfig(ShowCargoPicture).Boolean then
 		return null;
 	endif;

	thePicture := _theTI.getPicture;
	return thePicture;
	
	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="showExtraAttributes" id="d7258b32-4624-4b8b-8135-efae5fa6d02a">
        <updating/>
        <source>showExtraAttributes(_theGridPoint	: CMUI_GridPoint; x: Real; y: Real;
		_dataContainer : CM_DataContainer) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theTIIndex : Integer;
	theAttributeArray : CMUI_GridAttributesArray;

begin
	if _theGridPoint &lt;&gt; null then
		theTIIndex := self.showExtraAttributesGetIndex(_theGridPoint, x, y, theAttributeArray);
		self.showExtraAttributesDisplay(theTIIndex, theAttributeArray, _dataContainer);
	endif;	
end;</source>
        <Parameter name="_theGridPoint" type="CMUI_GridPoint"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="showExtraAttributesDisplay" id="89d72599-f181-4b61-aedb-b1cf79fa397a">
        <updating/>
        <source>showExtraAttributesDisplay(_theTIIndex : Integer;_theAttributeArray : CMUI_GridAttributesArray input;
		_dataContainer : CM_DataContainer) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//17 Oct 2017	cnwma1  TFS #7431 JMT - Refactoring - Drawing Attributes Labels
// ---------------------------------------------------------------------------
vars
	theAttibuteString : String;
	aDrawingAttribute : CM_DrawingAttribute;
	aGridAttribute : CMIF_GridAttributes;
	block : CM_DataContainerBlock;
	
begin
	if _theTIIndex &lt; 1 then // see AKB. If you click on a point that is part of a TI that covers more than 1 point, the right hand points have no attributes
		return;
	endif;
	
	if _theAttributeArray = null then
		return;
	endif;
	
	if _theTIIndex &gt; _theAttributeArray.size then
		return;
	endif;
	aGridAttribute := _theAttributeArray[_theTIIndex];
	foreach theAttibuteString in aGridAttribute.allDisplayIcons do
		if theAttibuteString = null then
			continue;
		endif;
		aDrawingAttribute := self.sdf01.allDrawingAttributes[theAttibuteString];

		if aDrawingAttribute = null then
			continue;
		endif;
		if block = null then	
			block := _dataContainer.addNewBlock();
		endif;

		//block.addNewItem(aDrawingAttribute.getLabel(), DC_IconLabel, 1, null);  //17.10.2017	cnwma1  TFS #7431
		block.addNewItem(aDrawingAttribute.label, DC_IconLabel, 1, null);         //17.10.2017	cnwma1  TFS #7431
		block.addNewIcon(aDrawingAttribute.fontCharacter.Character, 1, null,
						aDrawingAttribute.fontName, aDrawingAttribute.colour);
	endforeach;

end;</source>
        <Parameter name="_theTIIndex" type="Integer"/>
        <Parameter name="_theAttributeArray" type="CMUI_GridAttributesArray" usage="input"/>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="showExtraAttributesGetIndex" id="83c732b7-edfe-45a4-930b-0e1a1d651b97">
        <updating/>
        <source>showExtraAttributesGetIndex(_theGridPoint	: CMUI_GridPoint; x: Real; y: Real;
				_attrArray : CMUI_GridAttributesArray io)  : Integer updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTI	: CM_TrackedItem;
	theStringArray : HugeStringArray;
	theObjectArray : ObjectArray;
	idx,theTIIndex,lDisplayMode : Integer;
	theLine,theAttibuteString : String;
	theSingle : Boolean;
	anObject : Object;
	
	aLeftDrawingAttribute,aRightDrawingAttribute : CM_DrawingAttribute;

begin
	// ######################
	// Display Attributes
	theTI := _theGridPoint.getTI(x, y);
	if theTI = null then
		return 0;
	endif;
	lDisplayMode := _theGridPoint.myGridArea.mySDF.displayMode;

	if lDisplayMode = DISPLAY_MODE_ACTUAL then
		_attrArray := _theGridPoint.allTrackedItemAttributes;
		theTIIndex := _theGridPoint.allTrackedItems.indexOf(theTI);
		// for cargo over more than 1 location
		if theTIIndex = 0 then
			theTIIndex := _theGridPoint.myLocationsController.getIndexOfTI(REAL_MODE,theTI);
		endif;

	elseif lDisplayMode = DISPLAY_MODE_QUEUE then
		_attrArray := _theGridPoint.allQueuedTrackedItemAttributes;
		theTIIndex := _theGridPoint.allQueuedTrackedItems.indexOf(theTI);
		// for cargo over more than 1 location
		if theTIIndex = 0 then
			theTIIndex := _theGridPoint.myLocationsController.getIndexOfTI(QUEUE_MODE,theTI);
		endif;
	elseif lDisplayMode = DISPLAY_MODE_PLAN then
		_attrArray := _theGridPoint.allPlanTrackedItemAttributes;
		theTIIndex := _theGridPoint.allPlannedTrackedItems.indexOf(theTI);
		// for cargo over more than 1 location
		if theTIIndex = 0 then
			theTIIndex := _theGridPoint.myLocationsController.getIndexOfTI(PLANNING_MODE,theTI);
		endif;
	endif;

	return theTIIndex;

end;</source>
        <Parameter name="_theGridPoint" type="CMUI_GridPoint"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="_attrArray" type="CMUI_GridAttributesArray" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showExtraInfo" id="1a257a4e-e6b8-4ba5-96cd-ab7d0a6d6b40">
        <updating/>
        <source>showExtraInfo(_theGridPoint	: CMUI_GridPoint; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 June 2003 sgp			Use transient CM_DataContainer instead of arrays
//							to pass data around.
// ---------------------------------------------------------------------------

vars
	dataContainer : CM_DataContainer;
	theTI	: CM_TrackedItem;
	numberOfColumns,idx,theIndex,theTIIndex,lDisplayMode,theWidth : Integer;
	theLine,theAttibuteString : String;
	theSingle : Boolean;
	anObject : Object;
	theAttributeArray : ObjectArray;
	aLeftDrawingAttribute,aRightDrawingAttribute : CM_DrawingAttribute;
	theObject : Object;
	
begin
	self.tblGridAreaInfo.rows := 0;
	numberOfColumns := self.getNumberOfColumns;

	if _theGridPoint &lt;&gt; null then
		self.tblGridAreaInfo.alignment := Table.Alignment_Left_Top;

		//######################
		// DISPLAY INFO
		create dataContainer transient;
		dataContainer.headerColour := self.colorHeadingColumn;
		dataContainer.valueColour := self.colorValueColumn;
		
		dataContainer.displayMode := _theGridPoint.myGridArea.mySDF.displayMode;
		theObject := _theGridPoint.getExtraInfoForPoint(x, y, dataContainer);
		
		self.tblGridAreaInfo.userObject := theObject; // this is used to redraw this info

		self.showExtraInformation(dataContainer, self.tblGridAreaInfo, false,
				self.mnuGridBigFont.checked, numberOfColumns, self.getNumberOfColsForData,
				self.getNumberOfColsForHeader, self.getNumberOfColsForIcon,
				self.getNumberOfColsForLabel);
			
		self.doResizeColumnWidths(self.tblGridAreaInfo, true);
	endif;

epilog
//	global.processDebug("CNWJC2", true);
	if dataContainer &lt;&gt; null then
//	global.processDebug("CNWJC2", true);
		delete dataContainer;
	endif;
end;</source>
        <Parameter name="_theGridPoint" type="CMUI_GridPoint"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="showExtraInfoForObject" id="ed31eb98-d176-4d38-9a08-eb6b996208bf">
        <updating/>
        <source>showExtraInfoForObject(_theObject : Object input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		This is used to update the macro info if a note comes thru for the object being displayed there
// ---------------------------------------------------------------------------

vars
	theLC : CM_LocationsController;
	theGridPoint : CMUI_GridPoint;
	theX, theY : Real;
	
	
	theTI	: CM_TrackedItem;
begin
	self.tblGridAreaInfo.rows := 0;
	if _theObject &lt;&gt; null then
		if _theObject.isKindOf(CM_LogController) then
			theGridPoint := self.myCurrentSDF.getPointFromLC(_theObject.CM_LogController);
		elseif _theObject.isKindOf(CM_TrackedItem) then
			theTI := _theObject.CM_TrackedItem;
			self.myCurrentSDF.getPointFromTI(theTI, theX, theY, theGridPoint);
		endif;

		if theGridPoint &lt;&gt; null then
			self.showExtraInfo(theGridPoint,theX,theY);
		endif;

	endif;
epilog
end;</source>
        <Parameter name="_theObject" type="Object" usage="input"/>
    </JadeMethod>
