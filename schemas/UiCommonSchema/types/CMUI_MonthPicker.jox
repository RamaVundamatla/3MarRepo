begin
	return self.myYearTextBox.text;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleButtonClick" id="635ec7d2-553d-48b4-9512-42cd7b0ac312">
        <updating/>
        <source>handleButtonClick( _btn : CMUI_PickerButton ) updating;
/*

Date		    Who			Reason
28 October 2010	cnwas3	  Initial creation

*/

vars
	currentYear 	: Integer;
	currentMonth 	: Integer;
	yearTxt 		: Integer;	
begin
	
	currentYear := self.systemDate.year();
	currentMonth := self.systemDate.month();
	if self.myYearTextBox.text &lt;&gt; null then
		yearTxt := self.myYearTextBox.text.asIntegerJMT();
	endif;	
	
	if _btn = self.myPreviousYearBtn then		
		if yearTxt = null or 
		   (yearTxt &lt; 1901 or yearTxt &gt; maximumYear + 1) then
			self.setYear(currentYear);
			return;		
		else
			self.setYear(yearTxt - 1);
		endif;
		
		return;
	endif;
	
	if _btn = self.myNextYearBtn then		
		if yearTxt = null or 
		   (yearTxt &lt; 1899 or yearTxt &gt; maximumYear - 1) then
			self.setYear(currentYear);
			return;		
		else
			self.setYear(yearTxt + 1);
		endif;
		return;
	endif;
	
	if _btn = self.myPreviousMonthBtn then				
			self.setMonth(selectedDate.Date.addMonths(-1));
			if selectedDate.month = 12 then
				self.handleButtonClick(self.myPreviousYearBtn);
			endif;
		return;
	endif;
	
	if _btn = self.myNextMonthBtn then				
			self.setMonth(selectedDate.Date.addMonths(1));	
			if selectedDate.month = 1 then
				self.handleButtonClick(self.myNextYearBtn);
			endif;
		return;
	endif;
	
	
	
epilog

	self.click(self);

end;</source>
        <Parameter name="_btn" type="CMUI_PickerButton"/>
    </JadeMethod>
    <JadeMethod name="paint" id="1162ef91-f5ca-4eb4-b50d-0ad5b10f7dbd">
        <controlMethod name="Frame::paint"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>paint(frame: Frame input) updating, clientExecution;
/*

Date		    Who			Reason
26 October 2010	cnwas3	  Initial creation

*/

vars

begin
	inheritMethod(frame);
	
	if isInPainter then
		if not self.isBuilt then
			self.isBuilt := true;
			self.buildSelf;
		endif;

	elseif not isBuilt then
		self.isBuilt := true;
		self.buildSelf;
	endif;

epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="refresh" id="dcfdd6b2-0f65-4ad5-bbe3-ced2f48ce3eb">
