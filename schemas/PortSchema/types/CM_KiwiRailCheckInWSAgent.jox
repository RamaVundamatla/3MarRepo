    <JadeMethod name="checkIn" id="121f4344-70e0-45a9-b874-e5d3909394ac">
        <updating/>
        <source>checkIn(_request : CMIF_KRFCheckInRequest) : CMIF_KRFCheckInResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Feb 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message

*/

vars
	realRequest : KRF_CheckInRequest;
	realResponse : KRF_ResultStatus;
	response : CMIF_KRFCheckInResponse;
	createdObjects	: ObjectSet;
	soapFault		: Boolean;
begin
	self.setupConsumerInstance(KRF_CheckIn);
	create createdObjects transient;
	create realRequest transient;
	createdObjects.add(realRequest);
	
	_request.copyToRealWSObject(realRequest, createdObjects);
	
	realResponse := self.doSendWebServiceRequest(self.myWebServiceConsumer,
												 method.name,
												 realRequest,
												 soapFault).KRF_ResultStatus;
												 
	if realResponse &lt;&gt; null then
		create response transient;
		response.setFromRealWSObject(realResponse);
	elseif soapFault then
		create response transient;
		response.setValuesForSOAPFault();
	endif;
	
	return response;
epilog
	if createdObjects &lt;&gt; null then
		createdObjects.purge();
		delete createdObjects;
	endif;
end;</source>
        <Parameter name="_request" type="CMIF_KRFCheckInRequest"/>
        <ReturnType type="CMIF_KRFCheckInResponse"/>
    </JadeMethod>
    <JadeMethod name="doSetupForWebServiceRequest" id="ba773c93-54e2-4124-9628-045ba2928b16">
        <source>doSetupForWebServiceRequest(_consumer: JadeWebServiceConsumer input; _request: ImportedWebServiceProxy input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message

*/

vars

begin
	inheritMethod(_consumer, _request);
	_consumer.userName := self.usercode;
	_consumer.password := self.password;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_consumer" type="JadeWebServiceConsumer" usage="input"/>
        <Parameter name="_request" type="ImportedWebServiceProxy" usage="input"/>
    </JadeMethod>
