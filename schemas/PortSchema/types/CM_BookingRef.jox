    <JadeMethod name="getISOTypeCode" id="a30c9eea-b3db-4eb6-abfb-a0ced8a75ce4">
        <source>getISOTypeCode() : String;
// ---------------------------------------------------------------------------
// Created:     19 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	bookItem : CM_BookingRefItem;
begin
	if self.myISOType = null then
		foreach bookItem in self.allBookingRefItems discreteLock do
			if bookItem.myISOType &lt;&gt; null then
				return bookItem.myISOType.code;
			endif;
		endforeach;
		return null;
	endif;
	
	return self.myISOType.code;
epilog

end;</source>
