    <JadeMethod name="utlCreateRateEntry" id="a52f3be7-3c46-41bd-afde-6488bbc01622">
        <source>utlCreateRateEntry(_pxyRateEntry:CM_RateEntry; _newRateEntry:CM_RateEntry output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 03/07/2018	jlgmd1	TFS 38937 - STWO Performance changes
// 09 Dec 2025 	navhl20 Bug MTN-35943: POL - Importing Rates from CSV takes too long
vars
	cancelSave : Boolean;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valRateEntry(_pxyRateEntry);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);

	create _newRateEntry as _pxyRateEntry.class persistent;
	_newRateEntry.setForCreate(_pxyRateEntry);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newRateEntry);
	endif;
	if _passport.noErrors then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_RATEENTRY_CREATE),false,_newRateEntry);
		if _newRateEntry.startTimestamp &lt; app.actualTimeAppServer then				//09.12.2025 navhl20 #35943
			_newRateEntry.rate.updateCharges(_newRateEntry.getMyDebtorNode);		// CCMS 1264
		endif;
	endif;

end;</source>
        <Parameter name="_pxyRateEntry" type="CM_RateEntry"/>
        <Parameter name="_newRateEntry" type="CM_RateEntry" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateRecRestrictionDef" id="b1383278-ab8e-4760-bdd8-c1f82897642d">
        <updating/>
        <source>utlCreateRecRestrictionDef(	_pxyRecCutoffDef : CM_ReceivalCutoffTermDef input; 
							_allTransientCriteriaObj : CMIF_Array;
							_realRecCutoffDef : CM_ReceivalCutoffTermDef output; 
							_passport : CM_Passport input) updating;

/*
Date		Who		Reason
21 May 2009	cnwar2	Initial creation
06/03/2012	cnwcs5	par 29158 - EDI booking cutoffs
30 Apr 2012		cnwer1	PAR 29487 only create for voyages which have override defaults because the rest will derive the values
05 May 2025		navrv30	MTN 34526 MTN | Auto Adjust Cutoffs - New Terminal Default Cut-offs for Current Voyages
*/
vars
	voyage					: CM_Voyage;
	receivalRestrict		: CM_ReceivalCutoffVoyage;
	earliestTSPN, cutoffTSPN, //04/03/2025	navkc1 JIRA Story MTN-34227
	earliestTS,
	cutoffTS				: TimeStamp;
	theVoyages 				: CM_VoyageSet;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	app.myValCA.valRecRestrictionDef(_pxyRecCutoffDef);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	// Update the restriction def object.
	create _realRecCutoffDef persistent;
	_realRecCutoffDef.setForCreate(_pxyRecCutoffDef);
	
	if _passport.noErrors() then
		_realRecCutoffDef.persistCriteria(_allTransientCriteriaObj, _passport);
	endif;
	//05 May 2025		navrv30	MTN 34526
	create theVoyages transient;
	_pxyRecCutoffDef.myTerminal.getAllCurrentVoyages(theVoyages, true, false, false);
	
	foreach voyage in theVoyages discreteLock where voyage.overrideDefaults  do	
		
		_realRecCutoffDef.getCutoffsForVoyage (voyage, earliestTS, cutoffTS);
		_realRecCutoffDef.getCutoffsPNForVoyage(voyage, earliestTSPN, cutoffTSPN); //04/03/2025	navkc1 JIRA Story MTN-34227
		
		create receivalRestrict persistent;
		receivalRestrict.setRecCutoffDef(_realRecCutoffDef);
		receivalRestrict.setProxy(_realRecCutoffDef.code, cutoffTS, earliestTS, voyage, null, 
								cutoffTSPN, 	//04/03/2025	navkc1 JIRA Story MTN-34227
								earliestTSPN,	//04/03/2025	navkc1 JIRA Story MTN-34227
								 _pxyRecCutoffDef.defaultCutoff, 
								 _pxyRecCutoffDef.defaultCutoffPN, 
								 _pxyRecCutoffDef.defaultEarliestReceival,
								 _pxyRecCutoffDef.defaultEarliestReceivalPN,_pxyRecCutoffDef.defaultRelativeTo);
	endforeach;
	
	
	if _passport.noErrors() then
		self.myCreateAuditAgent.audCreateGeneric(_realRecCutoffDef);
	endif;
epilog
	delete theVoyages;
end;</source>
        <Parameter name="_pxyRecCutoffDef" type="CM_ReceivalCutoffTermDef" usage="input"/>
        <Parameter name="_allTransientCriteriaObj" type="CMIF_Array"/>
        <Parameter name="_realRecCutoffDef" type="CM_ReceivalCutoffTermDef" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
