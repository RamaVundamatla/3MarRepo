        <source>setMode( _mode : Integer ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2012	cnwndl1	Initial creation	Par 27704

*/

vars

begin

	self.mode := _mode;
	
	if self.mode = self.Mode_Add then
		self.chkAdvanced.enabled := false;
