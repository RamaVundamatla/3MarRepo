    <JadeMethod name="auditId" id="ba3e3dda-0e55-46fb-83f9-2a18df903f51">
        <source>auditId(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 October 2022	navvt20	ChangeRequest 53424: MTN - MOB - Input Remarks - Jade

*/

vars

begin
	if  self.context &lt;&gt; null then
		return app.getDefTextIntToStr(self.context);
	else
		return null;
	endif;
	
epilog

end;</source>
