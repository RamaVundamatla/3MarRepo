<Class name="CM_RemoteRegradingHdrExt" id="d9a9771a-7476-4b71-958f-fcb8e161a2a1">
    <superclass name="CM_RemoteDataHdr"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Regrading External&lt;/display&gt;</text>
    <DbClassMap file="remoteDataProcessing"/>
    <JadeMethod name="getDescription" id="11b97302-95b4-49c8-8fae-4263797df12b">
        <source>getDescription(): String;

// cnwdvb1 27 March 2003 

vars

begin
	return 'Regrading External';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMessageResponseType" id="abfbc20a-524d-463c-8ced-7be8b1e05a3d">
