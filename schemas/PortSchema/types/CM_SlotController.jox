    <JadeMethod name="getPickupTasks" id="a2655776-66f0-485b-922a-d161148c71ee">
        <source>getPickupTasks(_arbiter: CM_RTQueueArbiter io; _isOverstowMove : Boolean);
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
/*
	method that returns the work required to pick up a TI. CRANE stuff..
*/
vars
	task : CM_RTQueueTask;
begin
	create task;
	//parent will be set higher up.
	task.setDetails(	self,
						_arbiter.ti.getPrimaryLocation(QUEUE_MODE),
						TASK_UNACTIONED,
						TASK_PICKUP,
						_arbiter.ti);
	task.isOverstowTask := _isOverstowMove;
	
	_arbiter.entry.addTask(task);
	
end;</source>
        <Parameter name="_arbiter" type="CM_RTQueueArbiter" usage="io"/>
        <Parameter name="_isOverstowMove" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPileWeightHeight" id="19e2f03d-8efa-448c-9856-9fb88809a3c1">
        <source>getPileWeightHeight(	_mode : Integer;
					_bottomTI : CM_TrackedItem io;
					_weight20s,
					_weightOthers : Integer io;
					_height : Real io);
/*

Date		Who		Reason
02 February 2017	cnwer1	Initial creation TFS 3284

*/

vars
	theTIs : CM_TIArray;
	ti : CM_TrackedItem;
	unitLength : Real;
begin
	create theTIs transient;
	if _mode = ShpDisplayMode_Actual then 
		self.allTrackedItems.copy(theTIs); 
	else
		self.getProposedTIs(theTIs);
	endif;
	
	foreach ti in theTIs do
		//epr TFS 3284 1/2/17
		if _bottomTI = null  then
			_bottomTI :=ti;
		endif;
	
		unitLength := ti.getLengthInUnits;
		if unitLength = 2 then	// 20 footer
			_weight20s := _weight20s + ti.totalWeight.Integer;
		else
			_weightOthers := _weightOthers + ti.totalWeight.Integer;
		endif;
		_height := _height + ti.getActualHeight();
	endforeach;
epilog
	delete theTIs;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_bottomTI" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_weight20s" type="Integer" usage="io"/>
        <Parameter name="_weightOthers" type="Integer" usage="io"/>
        <Parameter name="_height" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getProposedBulkRelease" id="8b1b76f2-b75f-4b00-b254-c4d0a0bdec3c">
        <source>getProposedBulkRelease(_tis : CM_TIArray input);
// If this is a bulk release then add a transient Tracked Item to the collection
// 08/06/2010 cnwmh5 #20661 - Add passing of slot controller
// 30/11/2010 cnwdap1 PAR #26426 CCMS MES 1102 add boolean "_transient" parameter
vars
	trans : Boolean;	// PAR #26426
begin
	if self.isBulkRelease() then
		if self.myTerminal.getConfig(ShowRelReqOnShipLoadList).Boolean then
			trans := false;
		else
			trans := true;
		endif;
		_tis.add(self.mySlotRequestLoad.myBulkReleaseReserveDetail.createPlanningTrackedItem(self.getStowageId(null), self.mySlotRequestLoad.mySlotController, trans));
	endif;
end;</source>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getProposedCargo" id="aee063bf-bf16-424a-a404-9735f05a271b">
        <source>getProposedCargo(_theTI : CM_TrackedItem output; _numTIs : Integer output) ;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTI,theDTI,theATI : CM_TrackedItem;
	theLoadReq, theFwdLoadReq : CM_SlotRequest;
begin
	theTI := self.getTIAtIndex(REAL_MODE, 1);
	theATI := theTI; // PAR 7226 DEC2003AKB -  ADDED
	if theTI &lt;&gt; null then
		// is this TI being discharged?
		if self.mySlotRequestDischarge &lt;&gt; null then
			theDTI := self.mySlotRequestDischarge.getTrackedItem();
			if theDTI = theTI then
				theTI := null;
			else
				_numTIs := self.allTrackedItems.size;
			endif;
		else
			// no discharge so get actual number of ti here
			_numTIs := self.allTrackedItems.size;
		endif;
		// theTI is being discharged, is some thing being loaded?
		if theTI = null then
			theLoadReq := self.mySlotRequestLoad;
			_numTIs := self.numPlannedTIs;
			// PAR 8207 . Whilst things are planned up this worked OK. However once the Load was complete, there were only actual TIs and no Planned
			if _numTIs = 0 then // PAR 8207
				_numTIs := self.numTIs; // PAR 8207
			endif;
			// if the LOAD is planned there will be a TI on the WLE, else if it has only been colour coded the TI is null
			if theLoadReq &lt;&gt; null then
				theTI := theLoadReq.getTrackedItem();
				//if theTI = theATI then // PAR 7226 DEC2003AKB -  ADDED
				//	theTI := null; // PAR 7226 DEC2003AKB -  ADDED
				//endif;
				// we do not attached the TI to the backend WLE so if we are a back end go to the front request to get the TI
				if theTI = null then
					// PAR 21746 if theLoadReq.fortyBack then
					if theLoadReq.getAttrIsBackend() then // PAR 21746

						theFwdLoadReq := theLoadReq.mySlotRequestForward;
						if theFwdLoadReq &lt;&gt; null then
							theTI := theFwdLoadReq.getTrackedItem();
							if theTI = theATI then // PAR 7226 DEC2003AKB -  ADDED
//								theTI := null; // PAR 7226 DEC2003AKB -  ADDED
							endif;
						endif;
					
					endif;
				endif;
			endif;
		endif;
	else
		theLoadReq := self.mySlotRequestLoad;
		// these is nothing here at the moment is some thing being loaded?
		if theLoadReq &lt;&gt; null then
			_numTIs := self.numPlannedTIs;
			// if the LOAD is planned there will be a TI on the WLE, else if it has only been colour coded the TI is null
			theTI := theLoadReq.getTrackedItem();
			// we do not attached the TI to the backend WLE so if we are a back end go to the front request to get the TI
			if theTI = null then
				if theLoadReq.getAttrIsBackend() then // PAR 21746
				// PAR 21746 if theLoadReq.fortyBack then
					theFwdLoadReq := theLoadReq.mySlotRequestForward;
					if theFwdLoadReq &lt;&gt; null then
						theTI := theFwdLoadReq.getTrackedItem();
					endif;
				
				endif;
			endif;
		endif;
	endif;

	_theTI := theTI;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_numTIs" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getProposedTIs" id="7fe23cde-11b5-45dd-a9c9-87f048fb4ba8">
        <source>getProposedTIs(_tis : CM_TIArray input);
//----------------------------------------------------------------
//	Created:	26 September 2003 by cnwdwq1
//	Purpose:	Populates a collection of TI's that will BE HERE when the ship sails.
//				The rules are: All current tracked items, LESS discharges PLUS loads == proposed
//
//	Changed:	24 March 2004	by Jason Chapman  (cnwjc2)		Redone to ignore old planning and look at the TIs
//																final planned locn rather than the next.
//
//
//----------------------------------------------------------------

vars

begin
	if _tis = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "No TI Array Reference", null, null);
		return;
	endif;
	//------------------------
	//Always clear 1st.
	//------------------------
	_tis.clear();
	
	if self.allTrackedItems.first = null then
	
		if self.allSlotRequestsLoad.first = null then
			//if we are empty and nothing is being loaded here it is 
			//not possible for anything to be discharged - return with _tis empty
			return;
		endif;

	else
	
		self.allTrackedItems.copy(_tis);
		
		if self.allSlotRequestsDischarge.first = null and self.allSlotRequestsLoad.first = null then
			//if we have TIs and nothing is being discharged/loaded
			//here we return with the current TIs
			return;
		endif;
	endif;
	//we have some loads and/or discharges - work out the final situation...
	self.getMyFutureTIs(_tis);
	
end;</source>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getProximity" id="4808a443-37cc-48bc-8784-17a747c0a3f9">
        <source>getProximity(_otherLC : CM_SlotController; vertProx : Integer output; horzProx: Integer output; depthProx: Integer output);
/*
----------   ----------  --------------------------------------------------
Created:	27 November 2006 By cnwth2

Purpose:	
			vertical span = accross bays
			horizontal span = accross cells
			depth span = accross tiers - FOR SELF'S DECK ONLY (this may need to be smarter depending on requirments)

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if myBayVoyage = null or _otherLC.myBayVoyage = null then
		return;
	endif;
	
	vertProx := (self.myBayVoyage.ordinalBay - _otherLC.myBayVoyage.ordinalBay).positive;
	horzProx := (self.ordinalCell - _otherLC.ordinalCell).positive;
	if self.ordinalDeck = 1 then
		if _otherLC.ordinalDeck = 2 then
			depthProx := ((self.myBayVoyage.allTiersUnderDeck.size - self.ordinalTier) - _otherLC.ordinalCell).positive;
		else
			depthProx := (self.ordinalTier - _otherLC.ordinalTier).positive;
		endif;
	elseif self.ordinalDeck = 2 then
		if _otherLC.ordinalDeck = 1 then
			depthProx := (self.ordinalTier - (self.myBayVoyage.allTiersUnderDeck.size - _otherLC.ordinalTier)).positive;
		else
			depthProx := (self.ordinalTier - _otherLC.ordinalTier).positive;
		endif;
	endif;
end;


</source>
        <Parameter name="_otherLC" type="CM_SlotController"/>
        <Parameter name="vertProx" type="Integer" usage="output"/>
        <Parameter name="horzProx" type="Integer" usage="output"/>
        <Parameter name="depthProx" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getQueueTasks" id="77e399a5-86c4-48d1-9770-08c642f9cd3c">
        <source>getQueueTasks(_arbiter: CM_RTQueueArbiter io; _isSource : Boolean);
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
//Returns the tasks required to do a unit of work. (move a TI)
//Called from the RTQueueArbiter.
vars
//	isSource: Boolean;
	crane: CM_Crane;
	ctaLC: CM_LocationsController;
	job: CM_Job;
	voyageJob: CM_VoyageJob;
	ti: CM_TrackedItem;
begin
	//--------------
	//Determine if the ti in the arbiter transient is here.
	//--------------

    // CCMS 2067 - updated to handle RoadJobs as well as voyage jobs
	
	job := _arbiter.job;
	if job = null then
		app.raiseCMException(ERR_INVALID_JOB, null, null);		
		return;
	endif;
	
	 // TFS 4859 if job.isVoyageJob then
	 if job.isVoyageTypeJob() then // TFS 4859
		voyageJob := job.CM_VoyageJob;
		crane := voyageJob.getJobCrane();
		if crane = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'No Crane found for Job');
			return;
		endif;
	endif;		
	
	if _isSource then
		//This lc is the source of all evil. (the move)
		//------------
		//Get our "pickup tasks" (CRANE)
		//------------
		self.getPickupTasks(_arbiter, false);
		
		//----------------
		//If the crane is working R/T, then...		
		//----------------
  		if crane &lt;&gt; null and crane.useRTForSetDown then
			ctaLC := voyageJob.getCraneTransAreaLC();
			if ctaLC &lt;&gt; null then
				//Get the CTA's set down tasks
				ctaLC.getSetdownTasks(_arbiter, false);
				//Get the CTA's pickup tasks
				ctaLC.getPickupTasks(_arbiter, false);
			endif;
		endif;
		return;
	endif;
	//---------------------------
	//We are the Target. Operation is CTA provides a set down task,
	//then a pickup task for the crane, then the machine provides a setdown task.
	//------------
	//Get the target to provide its "set-down tasks"
	//------------
	//----------------
	//If the crane is working R/T, then...		
	//----------------
	if crane &lt;&gt; null and crane.useRTForPickup then
		ctaLC := voyageJob.getCraneTransAreaLC;
		if ctaLC &lt;&gt; null then
			//Get the CTA's set down tasks
			ctaLC.getSetdownTasks(_arbiter, false);
			//Get the CTA's pickup tasks (for a crane)
			ctaLC.getPickupTasks(_arbiter, false);
		endif;
	endif;
	
	//We provide CRANE's SetDown task.
	self.getSetdownTasks(_arbiter, false);
epilog
	if ti &lt;&gt; null then
		unlock(ti);
	endif;
	if crane &lt;&gt; null then
		unlock(crane);
	endif;
end;</source>
        <Parameter name="_arbiter" type="CM_RTQueueArbiter" usage="io"/>
        <Parameter name="_isSource" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getQueues" id="e05e9c8b-0d46-4d97-ba2c-42d88004ad87">
        <source>getQueues(_queueSet: CM_RTQueueSet io);
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
//This is tricky. The only rtQueue available here
//is for the VOYAGE, or the master Queue.

vars
	queueObj : CM_RadioTelemetryQueue;
	queueItem	: CM_RadioTelemetryQueue;
	term : CM_Terminal;
begin
	_queueSet.clear;
	queueObj := self.myVoyage.myQueue;

	if queueObj = null then
		//Master Queue time
		term := self.myTerminal;	
		if term.radioTelemetry = null then
			return;
		endif;
		_queueSet.add(term.radioTelemetry.masterQueue);
		return;
	endif;
	//--------------
	//Return the Voyage queue
	//--------------
 	_queueSet.add(queueObj);
	//--------------
	//ALSO return any subCraneQueues
	//--------------
	if queueObj.allSubQueuesById.isEmpty then
		return;
	endif;

	foreach queueItem in queueObj.allSubQueuesById do
 		_queueSet.add(queueItem);
 	endforeach;
end;</source>
        <Parameter name="_queueSet" type="CM_RTQueueSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getRequest" id="97712c08-b766-4556-b0a6-cbcfb3c2469d">
        <source>getRequest(_isLoad : Boolean) : CM_Request;
/*
Purpose:			
Date		Who		Reason
02 April 2012	cnwab1	Initial creation
*/

vars

begin
	if _isLoad then 
		return self.mySlotRequestLoad;
	else
		return self.mySlotRequestDischarge;
	
	endif;
epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="getRowColumn" id="4ee56a42-6a43-497c-ac37-4b47917dfe86">
        <source>getRowColumn(_row: Integer output; _column: Integer output; _flippedH, _flippedV : Boolean);
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
