    <JadeMethod name="clear" id="f0e08e1d-ec92-4be1-9614-70738e8e8982">
        <updating/>
        <source>clear() updating;
// ---------------------------------------------------------------------------
// Created:     18 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpFrame				: Frame;

begin

	self.myVoyage := null;
	self.allHolds.clear;
	self.allBays.clear;

	foreach tmpFrame in self.allBayDrawingFramesById do
		tmpFrame.visible := false;
	endforeach;

	self.allBayDrawingFramesById.clear();

end;</source>
    </JadeMethod>
    <JadeMethod name="clearUpDragDrop" id="556d8015-e729-48e0-a26a-fc799bec4d2f">
        <source>clearUpDragDrop();
// ---------------------------------------------------------------------------
// Created:     28 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpFrame	: SHP_BayDrawingFrame;
begin

	foreach tmpFrame in self.allBayDrawingFramesById do
		tmpFrame.dragMode := Window.DragMode_None;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="cloneSelf" id="0a0f0539-ecce-4d40-bd95-ef8e5adc8e19">
        <source>cloneSelf(bTransient: Boolean): SelfType;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theClone : SelfType;
begin
	theClone :=  inheritMethod(bTransient);
	theClone.myVoyage := self.myVoyage;
	return theClone;
end;</source>
        <Parameter name="bTransient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="create" id="e454bb38-a519-4a01-9838-d1c897d628f7">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.displayMode := ShpDisplayMode_Actual;
	self.isSelectObjectsEnabled := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="00953ced-3da4-4f43-b927-a839bff94771">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 April 2009	cnwer1	Initial creation

*/

vars

begin
	//epr TFS 3284 perfomance improvements
	self.allColours.purge;
	self.allVoyageAllocCCAttributes.purge;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="drawAllRedraw" id="a2585e4d-0e6e-4ae8-9e04-f1ec9cd8c29f">
        <updating/>
        <source>drawAllRedraw() updating;
// ---------------------------------------------------------------------------
// Created:     04 May 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	frm : SHP_BayDrawingFrame;
	obj : Object;
	iter : Iterator;
	slotDefn : CM_SlotDefn; 
	x1, y1, x2, y2 : Integer ;
begin
	//ShpDisplayMode_Actual; //ShpDisplayMode_Defn;
	self.setDisplayMode(ShpDisplayMode_Actual);
	self.setAttrPositions(ShpDisplayMode_Actual);
	self.setViewMode	(VIEW_DISPORT);
	
	foreach frm in self.allBayDrawingFramesById discreteLock do
		delete iter;
		iter := frm.allObjectsOnDeck.createIterator();


		while iter.next(obj) do
			iter.getCurrentKeys(x1, y1, x2, y2);
			slotDefn := obj.CM_SlotController.mySlotDefnVoyage;
			self.setFromSlotDefn(slotDefn, x1, y1, x2, y2);
	self.isBackend := false;
			
			if self.displayMode = ShpDisplayMode_Actual then
				self.drawBayAct(frm);
			else
				self.drawBayDefn(frm);
			endif;
			
		endwhile;
		
		delete iter;
		iter := frm.allObjectsUnderDeck.createIterator();
		while iter.next(obj) do
			iter.getCurrentKeys(x1, y1, x2, y2);
			slotDefn := obj.CM_SlotController.mySlotDefnVoyage;
			self.setFromSlotDefn(slotDefn, x1, y1, x2, y2);
	self.isBackend := false;
			
			if self.displayMode = ShpDisplayMode_Actual then
				self.drawBayAct(frm);
			else
				self.drawBayDefn(frm);
			endif;
		endwhile;
	endforeach;
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawAttribute" id="d90c1392-1748-400e-9055-45ee42366ed9">
        <source>drawAttribute(_ti : CM_TrackedItem; _frame : CMUI_Frame input;_x1,y1 :Real;  _theAttColour : Integer; _theAttribute : String;_theAttributePosition : Integer io) protected;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// 09/01/2012	cnwmh5	PAR #30990 - remove code for rehandle icon	
// 13/05/2015	cnwdap1	PAR #36206 TFS 324/334 Graphical Representation of Hazard Class and Special Stow
// 01/09/2015	cnwdap1	PAR #36652 Avoid 1090 on cargo type when called with no TI
// 12/12/2017	MAP		TFS7493
//
vars
	theDrawingAttribute : CM_DrawingAttribute;
	tmpX, tmpY	: Real;
	theAttributePosition, theColour : Integer;
	theCharacter : Character;
	theFrame: CMUI_Frame;
	lDisplayMode	: Integer;
	drawingAttributes : CM_DrawingAttributesByCodeDict;
	hazClass : CM_HazardClass;										// PAR #36206
	specialStow : CM_SpecialStow;									// PAR #36206

begin

	//if _theAttribute = PicTIIsRehandle then						// 09/01/2013 cnwmh5 #30990 - Remove
	//	return;
	//endif;
	
	theFrame := _frame;
	drawingAttributes := self.allDrawingAttributes;

	lDisplayMode := self.displayMode;
	
	if lDisplayMode = ShpDisplayMode_EDI then
		if _theAttribute = PicTIPlanned or
		   _theAttribute = PicTIActual then
			return;
		endif;
	endif;

	//if _theAttribute = PicTIBreakBulk then							// PAR #36652
	if _theAttribute = PicTIBreakBulk and _ti &lt;&gt; null then				// PAR #36652
		theDrawingAttribute := _ti.myCargoType.myDrawingAttribute;
	elseif _theAttribute = PicTIHazard then								// PAR #36206
		hazClass := self.getHazardClass(_ti);							// PAR #36206
		if hazClass &lt;&gt; null then										// PAR #36206
			theDrawingAttribute := hazClass.myDrawingAttribute;			// PAR #36206
		endif;															// PAR #36206
	elseif _theAttribute = PicSpecialStow then							// PAR #36206
		specialStow := self.getSpecialStow(_ti);						// PAR #36206
		if specialStow &lt;&gt; null then										// PAR #36206
			theDrawingAttribute := specialStow.myDrawingAttribute;		// PAR #36206
		endif;															// PAR #36206
	endif;
	if theDrawingAttribute = null then
		theDrawingAttribute := drawingAttributes[_theAttribute]; //theForm.allDrawingAttributes[_theAttribute];
	endif;
	if theDrawingAttribute = null then
		return;
	endif;
	
	// #######################
	if lDisplayMode = ShpDisplayMode_Defn then
		// Defn mode has special positions for each attribute
		_theAttributePosition := self.getPositionForAttrbuteDefn(_theAttribute);
		if _theAttributePosition = 0 then

			return;
		endif;
	else
		// increment the attribute counter and check if
		// we still have room for this attibute
		_theAttributePosition := _theAttributePosition + 1;
	endif;

	if _theAttributePosition &gt; self.attrMaxNum then

		return;
	endif;
	
	// ################################
	// LEGEND LEGEND
	// Only do this is we are in VESSEL definition OR PRINTING
// Par 9448 the printing is done from the SHP_VoyageAreaForm so this must be done when
// the form is build so the printing has details for the attribute legend rs feb 2005
//	if lDisplayMode = ShpDisplayMode_Defn or self.amPrinting then
//		if self.amPrinting then
	if (hazClass &lt;&gt; null or specialStow &lt;&gt; null) and app.myRoot.allDrawingAttributes.includes(theDrawingAttribute) then
		if (not self.allAttributeCodes.includes(theDrawingAttribute.code)) then
			self.allAttributeCodes.add(theDrawingAttribute.code);
		endif;
	else
		if (not self.allAttributeCodes.includes(_theAttribute.trimBlanks)) then
			self.allAttributeCodes.add(_theAttribute.trimBlanks);
		endif;
//		endif;
	endif;

	self.getAttrXYforPosition(_theAttributePosition, tmpX, tmpY);

	theFrame.drawFontName := theDrawingAttribute.fontName;
	
	// #######################
	// DRAW THE CHARACTER
	
	theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	theCharacter := theDrawingAttribute.fontCharacter.Character;
	
	if _theAttColour &lt; 0 then
		theColour := theDrawingAttribute.colour;
	else	
		theColour := _theAttColour;
	endif;
	if theFrame.isBayDrawingFrame then	//04 July 2012	NDL	Par 29316
		theFrame.SHP_BayDrawingFrame.drawTextScaled(theCharacter, self.x1 + tmpX, self.y1 + tmpY, theColour);
	else
		theFrame.drawTextAt(theCharacter, self.x1 + tmpX, self.y1 + tmpY, theColour);
	endif;
		
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_frame" type="CMUI_Frame" usage="input"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="y1" type="Real"/>
        <Parameter name="_theAttColour" type="Integer"/>
        <Parameter name="_theAttribute" type="String"/>
        <Parameter name="_theAttributePosition" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawBackend" id="2b888618-4ab1-48f5-8279-687f7d9208d6">
        <updating/>
        <source>drawBackend(_frame : SHP_BayDrawingFrame input; _backEndColor : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theFrame: SHP_BayDrawingFrame;
	backEndPadding	: Integer;
begin
	theFrame := _frame;
	
	if self.scaleFactor &lt;= 1.5 then
		backEndPadding := 1;
		theFrame.drawWidth := 1;
	else
		backEndPadding := 5;
		theFrame.drawWidth := 2;
	endif;

	theFrame.drawLine(self.x1 + backEndPadding, self.y1 + backEndPadding, self.x2 - backEndPadding, self.y2 - backEndPadding, _backEndColor);
	theFrame.drawLine(self.x2 - backEndPadding, self.y1 + backEndPadding, self.x1 + backEndPadding, self.y2 - backEndPadding, _backEndColor);
	theFrame.drawWidth := 1;
	
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="_backEndColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawBackendAtt" id="a1325b46-b8d8-420f-8346-18f1c9e8ca0f">
        <source>drawBackendAtt(_frame : SHP_BayDrawingFrame input; _sr : CM_SlotRequest) protected;
// ---------------------------------------------------------------------------
// Created:		May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    22MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------
//21/03/2018 	Jlgns1	Bug 37525: SNO - (re Ticket 36886): Header in bay plan printing
vars
	theDrawingAttribute : CM_DrawingAttribute;
	tmpX, tmpY	: Real;
	 theColour : Integer;
	theCharacter : Character;
	theFrame: CMUI_Frame;
	lDisplayMode	: Integer;
	is45, is40, is30, is53 : Boolean; // PAR 17649
	drawingAttributes : CM_DrawingAttributesByCodeDict;
	voyageAllocCCAttributes : CMIF_VoyageAllocCCAttributes;
begin

	 // PAR 17649
	if _sr &lt;&gt; null then
		//epr TFS 3284 3/2/17 performance improvements
		if  _sr.useVoyageAllocations then		
			voyageAllocCCAttributes:=self.getVoyageAllocCCAttributes(_sr);
			if voyageAllocCCAttributes &lt;&gt; null then
				is40 := voyageAllocCCAttributes.is40 or _sr.fortyBack; // PAR 21746
				is45 := voyageAllocCCAttributes.is45; // PAR 18682 CCMS 1055
				is30 := voyageAllocCCAttributes.is30;
				is53 := voyageAllocCCAttributes.is53;
			endif;
			
		else
			is40 := _sr.getAttrIs40() or _sr.fortyBack; // PAR 21746
			is45 := _sr.getAttrIs45(); // PAR 18682 CCMS 1055
			is30 := _sr.getAttrIs30();
			is53 := _sr.getAttrIs53();		
		endif;	
		
	elseif self.myTrackedItem &lt;&gt; null then
		is40 := self.myTrackedItem.isForty(); //self.myTrackedItem.isAttributeTrue(TI_Attrib_IsForty);
		is45 := self.myTrackedItem.isAttributeTrue(TI_Attrib_IsFortyFive); // PAR 18682
		is30 := self.myTrackedItem.isAttributeTrue(TI_Attrib_IsThirty);
		is53 := self.myTrackedItem.isAttributeTrue(TI_Attrib_IsFiftyThree);
	else
		return;
	endif;
	theFrame := _frame;
	drawingAttributes := self.allDrawingAttributes;
	
	tmpX := self.x1 + ((self.x2 - self.x1) / 2);
	tmpY := self.y1; 
	
	lDisplayMode := self.displayMode;
	if is40 then // PAR 17649
		theDrawingAttribute := drawingAttributes[PicTI40FooterBackEnd]; 
	// PAR 16415 CCMS 1029
	elseif is30 then // PAR 17649
		theDrawingAttribute := drawingAttributes[PicTI30FooterBE]; 
	elseif is53 then // PAR 17649
		theDrawingAttribute := drawingAttributes[PicTI53FooterBE]; 
	elseif is45 then // PAR 18682 CCMS 1055
		theDrawingAttribute := drawingAttributes[PicTI45FooterBackEnd]; 
	endif;
	
	if theDrawingAttribute = null then
		return;
	endif;
	
	if self.scaleFactor &lt; 2 then								//Bug 37525
		tmpY := tmpY -3;										//Bug 37525
	endif;														//Bug 37525
	if self.amPrinting then										//Bug 37525
		if self.printOutputStyle = PrintOutput_Large then		//Bug 37525
			tmpY := tmpY - 6;									//Bug 37525
		endif;													//Bug 37525
	endif;														//Bug 37525
	
	theFrame.drawFontName := theDrawingAttribute.fontName;
	// #######################
	// DRAW THE CHARACTER
	theFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	theFrame.drawFontSize := (self.scaleFactor * 7);
	theCharacter := theDrawingAttribute.fontCharacter.Character;
	if _sr &lt;&gt; null then // PAR 17649
		theColour := theDrawingAttribute.colour;
	else
		theColour := Gray; // PAR 17649
	endif;
	theFrame.drawTextAt(theCharacter, tmpX, tmpY, theColour);
epilog
	if theFrame &lt;&gt; null then  // PAR 17030
		self.setDefaultFont(theFrame);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="_sr" type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="drawBayAct" id="bdcae075-6857-4aa4-8c7c-fce65c0143ac">
        <updating/>
        <source>drawBayAct(_frame : SHP_BayDrawingFrame input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theFrame: SHP_BayDrawingFrame;
	iAMPrinting : Boolean;
	theGridAttributes : CMUI_GridAttributes;
	theImexMode,
	lOuterColourUpper,
	lOuterColourLower, 
	tmpDrawFillColor	: Integer;
	myX2, myX1, myY1, myY2	: Real;
	smallOutput,
	drawTI 	: Boolean;
	theTI, tmpBETI	: CM_TrackedItem;
	tmpSR : CM_SlotRequest;
begin

	theFrame := _frame;
	drawTI := true;
	iAMPrinting := self.amPrinting;

	smallOutput := (self.printOutputStyle = PrintOutput_Small);
	theImexMode	:= self.imexMode;

	theTI := self.myTrackedItem;

	tmpDrawFillColor := White;

	if (theTI &lt;&gt; null) and
	   (not self.allSelectorTIs.isEmpty) and
	   (not self.allSelectorTIs.includes(theTI)) then

	elseif theImexMode = SHP_VoyageAreaForm2.ImexMode_Imports and (not self.isImport) then
		if iAMPrinting then
			drawTI := false;
		endif;
		tmpDrawFillColor := White;

	elseif theImexMode = SHP_VoyageAreaForm2.ImexMode_Exports and (not self.isExport) then
		if iAMPrinting then
			drawTI := false;
		endif;
		tmpDrawFillColor := White;

	elseif (iAMPrinting and self.showNoColours) then

	elseif self.isBackend then
		tmpBETI := theTI;
		//if tmpBETI &lt;&gt; null and tmpBETI.isAttributeTrue(TI_Attrib_IsThirty) then
		if tmpBETI &lt;&gt; null and tmpBETI.isAttributeTrue(TI_Attrib_IsThirty) and not self.myLocationsController.allTrackedItems.isEmpty then
			drawTI := true;
			self.isBackend := false;
			tmpDrawFillColor := self.getFillColourForTI(theTI);
			if tmpDrawFillColor = NullColour then
				tmpDrawFillColor := White;
			endif;
		else
			drawTI := false;
			tmpDrawFillColor := White;
		endif;
	else
		if theTI &lt;&gt; null then
			tmpDrawFillColor := self.getFillColourForTI(theTI);
			if tmpDrawFillColor = NullColour then
				tmpDrawFillColor := White;
			endif;
		endif;
	endif;

	self.setDrawStyleAndColors(self.myCurrentObject, theFrame, tmpDrawFillColor, lOuterColourUpper, lOuterColourLower);

	myX1 := self.x1;
	myX2 := self.x2;
	myY1 := self.y1;
	myY2 := self.y2;

	self.drawRectangle(theFrame, myX1, myY1, myX2, myY2, lOuterColourUpper, lOuterColourLower, iAMPrinting, smallOutput);

	if self.isBackend then
		// PAR 16415 CCMS 1029
		/*17 Nov 2020	NDL	TFS 49891 - No longer draw OS backends
		if tmpBETI = null then
			tmpBETI := self.myLocationsController.allTrackedItemOSBackEnds.first;
		endif;
		*/
		if tmpBETI &lt;&gt; null then
			create tmpSR transient;
			tmpSR.setTmpSRFromBETI(tmpBETI, self.myLocationsController.CM_SlotController);
			self.drawBackendAtt(theFrame, tmpSR);
		else
			self.drawBackend(theFrame, tmpDrawFillColor.getInverseColour());
		endif;
	elseif drawTI then
		//self.drawTI(theTI, theGridAttributes, myX1, myY1, myX2, myY2, theFrame);
		self.drawTI(theTI, theGridAttributes, myX1, myY1, myX2, myY2, theFrame, null);	// cnwjk3 PAR 23875 23/04/10
	endif;

	if (not amPrinting) and self.tiInfoNumTI &gt; 1 then
		self.drawMark(theFrame, Red, 1, iAMPrinting, self.scaleFactor);
	endif;
	if (not amPrinting) and theTI &lt;&gt; null and theTI.isTranshipItem then
		self.drawMark(theFrame, Yellow, 1, iAMPrinting, self.scaleFactor); // PINK 
	endif;
epilog
	delete tmpSR;
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="SHP_BayDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawBayDefn" id="a486ce70-9e56-4ebe-890d-b64e4dd2cd74">
        <updating/>
        <source>drawBayDefn(_frame : SHP_BayDrawingFrame input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theFrame: SHP_BayDrawingFrame;
	theAttribCount : Integer;
	tmpBay : CM_Bay;

	lOuterColourUpper,	
	lOuterColourLower, 
	theViewMode,
	tmpDrawFillColour : Integer;
	myX2, myX1, myY1, myY2	: Real;
	
	tmpSlotDefn	: CM_SlotDefn;
	tmpSlot		: CM_SlotController;
	smallOutput	: Boolean;	
begin

	tmpSlotDefn	:= self.mySlotDefn;
	tmpSlot := tmpSlotDefn.CM_SlotDefnVoyage.mySlotController;
	theFrame := _frame;
	theViewMode := self.viewMode;
	tmpBay := theFrame.myBay;
	smallOutput := (self.printOutputStyle = PrintOutput_Small);


	myX1 := self.x1;
	myX2 := self.x2;
	myY1 := self.y1;
	myY2 := self.y2;

	if tmpSlotDefn.unavailable then
		tmpDrawFillColour := Black; //DarkGray;
	else
		tmpDrawFillColour := White;
	endif;

	self.setDrawStyleAndColors(tmpSlot, theFrame, tmpDrawFillColour, lOuterColourUpper, lOuterColourLower);
	self.drawRectangle(theFrame, myX1, myY1, myX2, myY2, lOuterColourUpper, lOuterColourLower, self.amPrinting, smallOutput);

	if self.scaleFactor &lt;= ScaleFactor_1 and (not self.amPrinting) then
		return;
	endif;
	
	if self.showSeqNum then
/*
		// ###########
		// UNAVAILABLE	
		if tmpSlotDefn.unavailable then
			theFrame.drawFontSize := self.defaultFontSizeForAttributes;
			self.drawAttribute(theFrame, -1,PicTIUnavail,theAttribCount);
			self.setDefaultFont(theFrame);
		else
			theFrame.drawFontSize := 7;
			theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
			theFrame.drawTextAt(self.mySlotDefn.sequenceNumPortDis.String,myX1 + 3, myY1 + 2, Green);
			theFrame.drawTextAt(self.mySlotDefn.sequenceNumPortLoad.String,myX1 + 3, myY1 + 12, Blue);
	
			theFrame.drawTextAlign := Frame.DrawTextAlign_Right;
			theFrame.drawTextAt(self.mySlotDefn.sequenceNumStarDis.String,myX2 - 3, myY1 + 2, Green);
			theFrame.drawTextAt(self.mySlotDefn.sequenceNumStarLoad.String,myX2 -3, myY1 + 12, Blue);
		endif;
		return;
*/
	endif;

	theFrame.drawFontSize := self.defaultFontSizeForAttributes;

	// ###########
	// UNAVAILABLE	
	if tmpSlotDefn.unavailable then
		self.drawAttribute(null,theFrame,myX1,myY1, -1,PicTIUnavail,theAttribCount);
		return;
	endif;

	// ###########
	// DOORSFWD
	if (not tmpSlotDefn.doors20Aft) then
		self.drawAttribute(null,theFrame,myX1,myY1, -1,PicTIDoorsFwd,theAttribCount);
	endif;
	// ###########
	// DOORSAFT
	if tmpSlotDefn.doors20Aft then
		self.drawAttribute(null,theFrame,myX1,myY1, -1,PicTIDoorsAft,theAttribCount);
	endif;

	// ###########
	// FORTYFOOT
	if tmpSlotDefn.fortyFront then
		self.drawAttribute(null,theFrame,myX1,myY1, -1,PicTI40Footer,theAttribCount);
	elseif tmpSlotDefn.fortyBack then
		self.drawAttribute(null,theFrame,myX1,myY1,-1,PicTI40FooterBackEnd,theAttribCount);
	endif;

	// PAR 16415 CCMS 1029
	// ###########
	// THIRTY FOOT
	if tmpSlotDefn.is30 then
		if tmpSlotDefn.isBackend then
			self.drawAttribute(null,theFrame,myX1,myY1, -1,PicTI30FooterBE,theAttribCount);
		else
			self.drawAttribute(null,theFrame, myX1,myY1,-1,PicTI30Footer,theAttribCount);
		endif;
	endif;
	// ###########
	// FIFTY THREE FOOT
	if tmpSlotDefn.is53 then
		if tmpSlotDefn.isBackend then
			self.drawAttribute(null,theFrame,myX1,myY1, -1,PicTI53FooterBE,theAttribCount);
		else
			self.drawAttribute(null,theFrame,myX1,myY1, -1,PicTI53Footer,theAttribCount);
		endif;
	endif;
	
	// PAR  18682 CCMS SFW 1055
	// ###########
	// FORTY FIVEFOOT
	if tmpSlotDefn.is45 then
		if tmpSlotDefn.isBackend then
			self.drawAttribute(null,theFrame,myX1,myY1, -1,PicTI45FooterBackEnd,theAttribCount);
		else
			self.drawAttribute(null,theFrame,myX1,myY1, -1,PicTI45Footer,theAttribCount);
		endif;
	endif;
	
	
	
	// ###########
	// REEFER
	if tmpSlotDefn.reefer then
		self.drawAttribute(null,theFrame,myX1,myY1, -1,PicTIReefer,theAttribCount);
	endif;

	// ###########
	// POWERED
	if tmpSlotDefn.power then
		self.drawAttribute(null,theFrame,myX1,myY1, -1,PicTIConnected,theAttribCount);
	endif;
	

	// ###########
	// WATERCOOLED	
	if tmpSlotDefn.watercooled then
		self.drawAttribute(null,theFrame,myX1,myY1, -1,PicTIWaterCooled,theAttribCount);
	endif;

	// ###########
	// MTs ONLY
	if tmpSlotDefn.mtOnly then
		self.drawAttribute(null,theFrame, myX1,myY1,-1,PicTIMTOnly,theAttribCount);
	endif;
	
	// ###########
	// HEAVY
	if tmpSlotDefn.heavy then
		self.drawAttribute(null,theFrame,myX1,myY1, -1,PicTIHeavy,theAttribCount);
	endif;
	// ###########
	// Voltage
	if tmpSlotDefn.voltageType = 1 then
		self.drawAttribute(null,theFrame,myX1,myY1, -1,PicTIVoltageSingle,theAttribCount);
	endif;
	if tmpSlotDefn.voltageType = 2 then
		self.drawAttribute(null,theFrame,myX1,myY1, -1,PicTIVoltageDual,theAttribCount);
	endif;
	
	// #############
	// Leave these motor forward calls last

	if (not tmpSlotDefn.motor20Aft) then
		// MOTOR FORWARD
		self.drawAttribute(null,theFrame,myX1,myY1, -1,PicTIMotorFwd,theAttribCount);
	elseif (tmpSlotDefn.motor20Aft) then
		//  MOTOR AFT
		self.drawAttribute(null,theFrame,myX1,myY1, -1,PicTIMotorAft,theAttribCount);
	endif;

	// reset the font and size
	self.setDefaultFont(theFrame);

end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="SHP_BayDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawBayPro" id="ef39ee1a-fc03-4af3-a1c4-46b31a30fa3f">
        <updating/>
        <source>drawBayPro(_frame : SHP_BayDrawingFrame input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 30/11/2010	cnwdap1		PAR #26426 CCMS MES 1102 new _transient parameter for createPlanningTrackedItem method
// 07/12/2010	cnwdap1		PAR #26535 Don't create and show a transient TBA TI if we have a real one
//							Reversed the order of checking on the TI to default to actual first then
//							only create a TBA if we don't have an actual
vars
	theFrame						: SHP_BayDrawingFrame;
	theLabel						: String;
	theDrawingAttribute				: CMUI_GridAttributes;
	theX, theY, tmpX, tmpY,
	theAttribCount					: Integer;
	theTI, tmpBETI 							: CM_TrackedItem;
	tm_x2, tm_x1,tm_y1,tm_y2		: Real;
	theImexMode,
	tmpDrawFillColor,
	lOuterColourUpper,
	lOuterColourLower, theViewMode	: Integer;
	myX2, myX1, myY1, myY2			: Real;
	smallOutput, iAMPrinting,drawTI	: Boolean;
	tmpSlotDefn						: CM_SlotDefn;
	numTIs							: Integer;
	tmpRequestLoad, tmpSR					: CM_SlotRequest;
	tis								: CM_TIArray;
	bulkReleaseTrackedItem			: CM_TrackedItem;
	slotPosition					: String;
	reserveDetail					: CM_ReserveDetail;
	forwardSlot : CM_SlotController;
	tmpRequestDisc : CM_SlotRequest;
begin

	tmpSlotDefn := self.mySlotDefn;

	if tmpSlotDefn.unavailable then
		return;
	endif;

	myX1 := self.x1;
	myX2 := self.x2;
	myY1 := self.y1;
	myY2 := self.y2;
	drawTI := true;
	theFrame := _frame;
	theViewMode := self.viewMode;
	theImexMode	:= self.imexMode;
	iAMPrinting := self.amPrinting;
	smallOutput := (self.printOutputStyle = PrintOutput_Small);
	
	tmpRequestLoad := self.myLocationsController.CM_SlotController.mySlotRequestLoad;
	
	self.setIsBackend(theFrame.myBay, tmpRequestLoad);

	// 04/06/2010 cnwmh5 #20661 - Start
	// PAR #26535 default to actual TI first
	theTI := self.myTrackedItem;
	// PAR #26535 then only create a TBA TI if we don't have an actual TI
	if theTI = null then
		if tmpRequestLoad &lt;&gt; null and tmpRequestLoad.isBulkReleaseEDIDraw(reserveDetail) then
			if reserveDetail &lt;&gt; null then
				//bulkReleaseTrackedItem := reserveDetail.createPlanningTrackedItem(slotPosition, self.myLocationsController.CM_SlotController);		// PAR #26426
				bulkReleaseTrackedItem := reserveDetail.createPlanningTrackedItem(slotPosition, self.myLocationsController.CM_SlotController, true);	// PAR #26426
			endif;
			theTI := bulkReleaseTrackedItem;
			self.myTrackedItem := theTI;
			self.setIsBackend(theFrame.myBay, tmpRequestLoad);
		endif;							// PAR #26535
	//else								// PAR #26535
	//	theTI := self.myTrackedItem;	// PAR #26535
	endif;
	// 04/06/2010 cnwmh5 #02661 - End
	/*
	// 04/06/2010 cnmwh5 #20661 - Replaced
	if tmpRequestLoad &lt;&gt; null and tmpRequestLoad.isBulkRelease() then
		slotPosition := self.myLocationsController.CM_SlotController.getStowageId(null);
		bulkReleaseTrackedItem := tmpRequestLoad.getBulkReleaseReserveDetail().createPlanningTrackedItem(slotPosition, self.myLocationsController.CM_SlotController);
		theTI := bulkReleaseTrackedItem;
	else
		theTI := self.myTrackedItem;
	endif;
	*/ 
	
	tmpDrawFillColor := White;
	if (theTI &lt;&gt; null) and
	   (not self.allSelectorTIs.isEmpty) and
	   (not self.allSelectorTIs.includes(theTI)) then

	elseif theImexMode = SHP_VoyageAreaForm2.ImexMode_Imports and (not self.isImport) then
		if iAMPrinting then
			drawTI := false;
		endif;

	elseif theImexMode = SHP_VoyageAreaForm2.ImexMode_Exports and (not self.isExport) then
		if iAMPrinting then
			drawTI := false;
		endif;

	elseif (iAMPrinting and self.showNoColours) then

	elseif self.isBackend then
		drawTI := false;

	else
		if theTI &lt;&gt; null then
			tmpDrawFillColor := self.getFillColourForTI(theTI);
			if tmpDrawFillColor = NullColour then
				tmpDrawFillColor := White;
			endif;
		endif;
	endif;

	self.setDrawStyleAndColors(self.myCurrentObject, theFrame, tmpDrawFillColor, lOuterColourUpper, lOuterColourLower);

	myX1 := self.x1;
	myX2 := self.x2;
	myY1 := self.y1;
	myY2 := self.y2;

	self.drawRectangle(theFrame, myX1, myY1, myX2, myY2, lOuterColourUpper, lOuterColourLower, iAMPrinting, smallOutput);

	if self.isBackend then
		// PAR 16415 CCMS 1029
		/*	17 Nov 2020	NDL	TFS 4989 - No longer draw Oversize backends i.e. 30, 45, 53
		if tmpBETI = null then
			tmpBETI := self.myLocationsController.allTrackedItemOSBackEnds.first;
		endif;
		*/
		
/*		PAR 31619 The issue with PAR 29316 was that 45s were not creating a backend slotrequest which they should do.
		PAR 31619 has fixed the issue with 45s now creating backend slotrequests, so this code is unnessary.
		This code was actually wrong as it crashes planned load 45s.
		//5 July 2012	NDL	Par 29316
		if theTI &lt;&gt; null then
			if ( theTI.is45 or theTI.is53 ) then
				tmpBETI := theTI;
			endif;
		endif;
		//5 July 2012	NDL	Par 29316
		if tmpBETI &lt;&gt; null then
			if ( tmpBETI.is30 or tmpBETI.is45 or tmpBETI.is53 ) then
				forwardSlot := tmpBETI.myPrimaryActualLocation.CM_SlotController;
			endif;
			if forwardSlot &lt;&gt; null then
				tmpRequestDisc := forwardSlot.mySlotRequestDischarge;
			endif;
		endif;
		
		if tmpRequestDisc &lt;&gt; null then	//5 July 2012	NDL	Par 29316
			// don't draw it, its going to be coming off.
		else
		*/
		
		//17 Nov 2020	NDL	TFS 4989
		if theTI &lt;&gt; null then
			if ( theTI.is45 or theTI.is53 ) then
				tmpBETI := theTI;
			endif;
		endif;
		
		if tmpBETI &lt;&gt; null then
			create tmpSR transient;
			tmpSR.setTmpSRFromBETI(tmpBETI, self.myLocationsController.CM_SlotController);
			self.drawBackendAtt(theFrame, tmpSR);
		else
			self.drawBackend(theFrame, tmpDrawFillColor.getInverseColour());
		endif;
	elseif drawTI then
		//self.drawTI(theTI, theDrawingAttribute, myX1, myY1, myX2, myY2, theFrame);		// cnwjk3 PAR 23875 23/04/10
		self.drawTI(theTI, theDrawingAttribute, myX1, myY1, myX2, myY2, theFrame, null);	// cnwjk3 PAR 23875 23/04/10
	endif;
	if (not amPrinting) and self.tiInfoNumTI &gt; 1 then
		self.drawMark(theFrame, Red, 1, iAMPrinting, self.scaleFactor);
	endif;
epilog
	delete tmpSR;
	delete tis;
	delete bulkReleaseTrackedItem;
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="SHP_BayDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawCellPileWeight" id="bbcc7916-65ad-4eb8-9023-3e0665f5202b">
        <source>drawCellPileWeight(_frame : SHP_BayDrawingFrame input; _bay : CM_Bay; _weight : Integer; _isOverweight : Boolean; _x, _y : Real);
// ---------------------------------------------------------------------------
// Created:     10 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 12/08/2015	cnwdap1		PAR #36731 Correct display of negative numbers
vars
	textColor	: Integer;
	theWeightStr	: String;
begin

	textColor := Black;
	if _isOverweight then
		textColor := Red;
	endif;

	//epr 37334 if its centered then the redrawing on notes does not work correctly
	_frame.drawTextAlign := Frame.DrawTextAlign_Left;
		// 23 May 2011	NDL	Par 27535
	if self.scaleFactor &lt;= 2 then
		// not much room in this zoom scale.
		if _weight &lt; 100 then
			// just show two characters
			theWeightStr := _weight.String.padLeadingZeros(2);
		else
			// too big to show
			theWeightStr := "&gt;C"; // &lt;== apparently this stands for greater than 100.... obvious once you know!
		endif;
	else
		//zoom scale leaves room for at least 3 chars.
		if _weight &lt; 0 then													// PAR #36731
			theWeightStr := _weight.String;									// PAR #36731		
		else																// PAR #36731
			theWeightStr := _weight.String.padLeadingZeros(3);		
		endif;	
		
		// PAR #36731
	endif;
	
	_frame.drawTextAt(theWeightStr, _x, _y, textColor);
end;</source>
        <Parameter name="_frame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="_bay" type="CM_Bay"/>
        <Parameter name="_weight" type="Integer"/>
        <Parameter name="_isOverweight" type="Boolean"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawClearRectangle" id="6bb7159a-2bd9-4415-88c1-1a87cf028e52">
        <source>drawClearRectangle(_frame : Frame input; x1, y1, x2, y2 : Real) protected;
// ---------------------------------------------------------------------------
// Created:     12 February 2004 by cnwrs2
//
// Purpose:     Used before drawing cross-hatch patterns to hide
//				any text that maybe underneath
// ---------------------------------------------------------------------------
vars
	tmpColor	: Integer;
begin
//	tmpColor := _frame.backColor;
	tmpColor := White;
	_frame.drawFillColor := tmpColor;
	_frame.drawFilledRectangle(x1, y1, x2, y2, tmpColor); 
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="x1" type="Real"/>
        <Parameter name="y1" type="Real"/>
        <Parameter name="x2" type="Real"/>
        <Parameter name="y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawColCodeDisch" id="2fa74366-48c6-41dc-9280-8dd47003b685">
        <updating/>
        <source>drawColCodeDisch(_frame : SHP_BayDrawingFrame input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// 15/02/2010	cnwmh5		PAR21653 - Move the setting of the local variable theFrame
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 07/02/2016 	 cnwer1		TFS 3284 - QNS performance improvements
//27 Nov 2018			jlgrh7 TFS #41218 SNO - Bay Plan and drawing attribute
vars
	theFrame: SHP_BayDrawingFrame;
	theLabel : String;
	theAttribCount,theColour : Integer;
	dlrWidth : Integer;
	lOuterColourUpper,	lOuterColourLower : Integer;
	iAmPrinting : Boolean;
	tm_x2, tm_y1	: Real;
	tmpLoadPort, 
	tmpDischPort : CM_Port;
	smallOutput, mediumOutput,largeOutput : Boolean;
	myX2, myX1, myY1, myY2	: Real;
	tmpScaleFactor : Real;
	tmpSlotController, fwdSlotController	: CM_SlotController;
	tmpDischRequest,
	tmpLoadRequest, tmpSR	: CM_SlotRequest;
	isFortyFoot,
	isRehandle,
	isBackEnd,
	isSOB			: Boolean;
	tmpDischJob			: CM_Job;
	tmpCommodityGroup	: CM_CommodityGroup;
	dischPortCode		: String;
	tmpTI, tmpBETI			: CM_TrackedItem;
	tmpSlotDefn		: CM_SlotDefn;
	tmpBay			: CM_Bay;
	tmpPrintOutputStyle,
	tmpWorkingMode,
	tmpBackEndColor,
	tmpDrawFillColour	: Integer;
	invalidCommGrp,
	amSelected	: Boolean;
	cmifColour : CMIF_Colour;
	commodityCode : String;
	craneLine: String;
	totalWeight: Real;
	wle: CM_WorkListEntry;
begin
	theFrame := _frame; // 15/02/2010 cnwmh5 Par21653
	
	tmpSlotDefn := self.mySlotDefn;

	if tmpSlotDefn.unavailable then
		return;
	endif;
	
	if (not CM_SlotDefnVoyage.hasInstance(tmpSlotDefn)) then
		return;
	endif;
	
	tmpSlotController := tmpSlotDefn.CM_SlotDefnVoyage.mySlotController;
	if tmpSlotController = null then
		return;
	endif;

	tmpDischRequest := tmpSlotController.mySlotRequestDischarge;
	tmpLoadRequest := tmpSlotController.mySlotRequestLoad;
	tmpTI := self.myTrackedItem; // PAR 15662, this was being set inside an IF statement but is safe out here.

	iAmPrinting := self.amPrinting;
	////theFrame := _frame;					// 15/02/2010 cnwmh5 Par21653
	tmpScaleFactor := self.scaleFactor;
	tmpBay := theFrame.myBay;
	tmpPrintOutputStyle := self.printOutputStyle;
	tmpWorkingMode := self.workingMode;

	smallOutput := (tmpPrintOutputStyle = PrintOutput_Small);
	mediumOutput := (tmpPrintOutputStyle = PrintOutput_Medium);	
	largeOutput := (tmpPrintOutputStyle = PrintOutput_Large);	

	myX1 := self.x1;
	myX2 := self.x2;
	myY1 := self.y1;
	myY2 := self.y2;

	if tmpDischRequest &lt;&gt; null then
		isFortyFoot 	:= (self.isSlotRequest40(tmpDischRequest) or tmpDischRequest.fortyBack);// PAR 21746 in this case fortyBack is correct
		isRehandle		:= tmpDischRequest.isRehandle;
		isSOB			:= tmpDischRequest.isSOB;
		tmpDischPort 	:= tmpDischRequest.getAttrDischargePort();
		tmpDischJob 	:= tmpDischRequest.myJob;
		tmpCommodityGroup 	:= tmpDischRequest.getAttrCommodityGroup();
		on Exception do app.handleDeletedObject(exception,tmpCommodityGroup, invalidCommGrp);
		if tmpCommodityGroup &lt;&gt; null then
			commodityCode:= tmpCommodityGroup.code;
			if invalidCommGrp then
				tmpCommodityGroup := null;
			endif;
		endif;
		if tmpDischPort &lt;&gt; null then
			dischPortCode := tmpDischPort.code;
		else
			dischPortCode	:= tmpDischRequest.dischargePort.trimPortCode; //epr 9/10/06 par 12695
		endif;
		tmpBackEndColor := Black;
		if tmpDischJob &lt;&gt; null then
			craneLine := tmpDischJob.CM_VoyageJob.craneId &amp; Space &amp; tmpDischJob.getJobNum() &amp; Forward_Slash &amp; self.getSequenceNumForRequest(tmpDischRequest);
		endif;
	else
		tmpBackEndColor := Gray;
	endif;

	if tmpLoadRequest &lt;&gt; null then
		// ### IF they have a SOB job whose source (discharge) are from bay 1 and bay 2. And the target is bay 2, we were not drawing the source slots in bay 2.
		if self.myJobSeqSheet &lt;&gt; null   // PAR 8688
		and tmpLoadRequest.isSOB()    // PAR 8688
		and tmpLoadRequest.myJob = self.myJobSeqSheet then   // PAR 8688
			tmpDischJob 		:= tmpLoadRequest.myJob;   // PAR 8688
			tmpDischRequest := tmpLoadRequest;  // PAR 8688
		endif;
	endif;

	isBackEnd := self.setIsBackend(tmpBay, tmpDischRequest);

	// for Sequence Sheet, set job up for aft slot
	if isBackEnd and self.myJobSeqSheet &lt;&gt; null then
		fwdSlotController := tmpSlotController.myForwardSlot;
		if fwdSlotController &lt;&gt; null then
			tmpDischRequest := fwdSlotController.mySlotRequestDischarge;
			if tmpDischRequest &lt;&gt; null then
				tmpDischJob 	:= tmpDischRequest.myJob;
			endif;
		endif;
	endif;

	amSelected := (self.allSelectedObjects.includes(tmpSlotController) or
				  self.allSelectedObjectsAlt.includes(tmpSlotController));
	
	if tmpDischRequest = null and
	   self.showColorOthers = ShipShowOtherColor_None then
		tmpDrawFillColour := White;
		if (not amSelected) then
			tmpBackEndColor := White;
		endif;
	elseif isBackEnd or (iAmPrinting and self.showNoColours) then
		tmpDrawFillColour := White;
	elseif tmpDischPort &lt;&gt; null then
		tmpDrawFillColour := tmpDischPort.colour;
	else
		//tmpTI := self.myTrackedItem; now set at the beginning of method
		if tmpTI = null then
			tmpDrawFillColour := White;
		else
			tmpDrawFillColour := tmpTI.getDrawingColour(TI_ColourMode_DischargePort);
		endif;
	endif;

	if tmpDrawFillColour = NullColour then
		tmpDrawFillColour := White;
	endif;

	tm_y1 := myY1;
	tm_x2 := myX2;


	self.setDrawStyleAndColors(tmpSlotController, theFrame, tmpDrawFillColour, lOuterColourUpper, lOuterColourLower);

	// I am in DISCHARGE Colour Code mode. There is a TI in this point 
	// but it is not coded for discharge so draw non-solid
	if tmpDischRequest = null then
		if self.showColorOthers = ShipShowOtherColor_None then
			// do nothing
	//	elseif tmpSlotController.allTrackedItems.size &gt; then
	//	elseif tmpSlotController.allTrackedItems.size &gt; 0 or tmpSlotController.allTrackedItemOSBackEnds.size &gt; 0 then	//04 July 2012	NDL	Par 29316
		elseif tmpSlotController.allTrackedItems.size &gt; 0 then	//17 Nov 2020	NDL	TFS 49891 - No longer draw OS backends
			if not (isRehandle or isSOB) then
				if iAmPrinting then
					tmpDrawFillColour := White;
				elseif self.showColorOthers = ShipShowOtherColor_Hatched then
					self.drawClearRectangle(theFrame, x1, y1, x2, y2); 
					theFrame.drawFillStyle := Frame.DrawFillStyle_DiagonalCross;
				elseif self.showColorOthers = ShipShowOtherColor_Other and (not amSelected) then
					tmpDrawFillColour := self.otherSlotColor;
				endif;
			endif;
		else
			// the slot has no discharge colour coding but it has load colour coding, so show it
			if (not iAmPrinting) and
			   tmpLoadRequest &lt;&gt; null and
			   self.showColorOthers = ShipShowOtherColor_Hatched then
			   
				//16 Jul 2019	NDL	TFS 45603 - Allow for load requests not using discharge port!!
				if tmpLoadRequest.getVoyageLoadController &lt;&gt; null then 
					self.drawClearRectangle(theFrame, x1, y1, x2, y2); 
					theFrame.drawFillStyle := Frame.DrawFillStyle_Cross;
					tmpDrawFillColour := self.setColourFromAllocation( tmpLoadRequest.getVoyageLoadController );
				else
					tmpLoadPort :=tmpLoadRequest.getAttrDischargePort();
					if  tmpLoadPort &lt;&gt; null then
						self.drawClearRectangle(theFrame, x1, y1, x2, y2); 
						theFrame.drawFillStyle := Frame.DrawFillStyle_Cross;
						tmpDrawFillColour := tmpLoadPort.colour;
					endif;
				endif;

			endif;
		endif;
//	elseif tmpTI &lt;&gt; null then
	elseif tmpTI &lt;&gt; null and tmpTI.getDischargePortObject() &lt;&gt; null then	//11 Jan 2018	NDL	TFS 36417
		self.myDrawingAttrController.allDischargePorts.addNoDuplicates(tmpTI.getDischargePortObject(), false);		// 6/12/17 MAP TFS7494
	endif;
	
	self.theDrawFillColor := tmpDrawFillColour;
	theFrame.drawFillColor := tmpDrawFillColour;

	self.drawRectangle(theFrame, myX1, myY1, myX2, myY2, lOuterColourUpper, lOuterColourLower, iAmPrinting, smallOutput);

	if self.myJobSeqSheet = null then // not SeqSheet
		// PAR 16415 CCMS 1029
		if isBackEnd then
			/* //17 Nov 2020	NDL	TFS 49891 - No longer draw OS backends
			if tmpBETI = null then
				tmpBETI := self.myLocationsController.allTrackedItemOSBackEnds.first;
			endif; */
			if tmpBETI &lt;&gt; null then
				if tmpDischRequest = null then	//04 Jul 2012	NDL	Par 29316
					self.drawBackendAtt(theFrame, null);
				else
					create tmpSR transient;
					tmpSR.setTmpSRFromBETI(tmpBETI, self.myLocationsController.CM_SlotController);
					self.drawBackendAtt(theFrame, tmpSR);
				endif;
				return; // PAR 18823 was drawing a DLR green over the top of a 53 foot backend, backend
			else
				self.drawBackendAtt(theFrame, tmpDischRequest);
				return;
			endif;
		endif;
	elseif tmpDischJob = self.myJobSeqSheet 
	and isBackEnd then
		self.drawBackend(theFrame, tmpBackEndColor);
		return;
	endif;

	if self.myJobSeqSheet &lt;&gt; null and tmpDischJob &lt;&gt; self.myJobSeqSheet then
		return;
	endif;


	cmifColour := self.allColours[self.theDrawFillColor];
	if cmifColour = null then
		create cmifColour transient;
		cmifColour.setColour(self.theDrawFillColor);
		self.allColours.add(cmifColour);
	endif;
	theColour:= cmifColour.inverseColour; 

	if (isRehandle or isSOB) and theFrame.myJobSeqSheet = null then
		// draw a rectangle in the middle
		if isRehandle then
			theFrame.drawFillColor := COLOUR_DLR; //Green;
		elseif isSOB then
			theFrame.drawFillColor := COLOUR_SOB; //Blue;
		endif;
		
		theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
		dlrWidth := ((myX2 - myX1) / 3).Integer;

		theFrame.drawFilledRectangle(myX1 + dlrWidth , myY1 + dlrWidth, myX2 - dlrWidth, myY2 - dlrWidth, theFrame.drawFillColor); 

		// check if we are linked?
		// PAR 28968if (tmpDischRequest.mySlotRequestDLRSOBLoad &lt;&gt; null  or tmpDischRequest.myRequestLinkedLoad &lt;&gt; null) 
		if (tmpDischRequest.getLinkedRequest(false) &lt;&gt; null) // PAR 28968
		and theFrame.myJobSeqSheet = null then
			self.drawMark(theFrame, LightGreen, 1, iAmPrinting, tmpScaleFactor);
		endif;
	endif;

	if tmpScaleFactor &gt;= 2 then
		if (tmpDischRequest &lt;&gt; null and tmpDischRequest.isComplete) then
			if iAmPrinting and theFrame.myJobSeqSheet &lt;&gt; null then
				if tmpDischJob = theFrame.myJobSeqSheet then
					self.drawMark(theFrame, Black, 2, iAmPrinting, tmpScaleFactor);
				endif;
			else
				self.drawMark(theFrame, Black, 2, iAmPrinting, tmpScaleFactor);
			endif;
		endif;
	endif;
	
	if (not amPrinting) and tmpTI &lt;&gt; null and tmpTI.isTranshipItem then
		self.drawMark(theFrame, Yellow, 1, amPrinting, self.scaleFactor);
	endif;

	if theFrame.myJobSeqSheet = null then
		/*if smallOutput  then																																						//-TFS41218	Not print out Single letter lable for small print
			if tmpDischPort &lt;&gt; null then
				if tmpDischPort.ccodePrint.trimBlanks &lt;&gt; null then
					theLabel := tmpDischPort.ccodePrint[1:1];
				else
					theLabel := tmpDischPort.code[1:1];
				endif;
				self.setDefaultFont(theFrame);
				theFrame.drawFontSize := 6;
				theFrame.drawTextAt(theLabel,myX1,myY1,Black);
			endif;
		elseif self.scaleFactor &gt;= ScaleFactor_2 or mediumOutput then*/
		if self.scaleFactor &gt;= ScaleFactor_2 or mediumOutput then
			// only draw the actual TI info in the point if we have colour coded the point for discharge
			if tmpDischPort &lt;&gt; null and 
			   (not tmpWorkingMode = SHP_VoyageAreaForm2.WorkMode_CustomSeq) then

				if (not self.setIsBackend(tmpBay, tmpDischRequest)) then	
					if mediumOutput or largeOutput then
						theLabel := dischPortCode;
					else
						if tmpCommodityGroup &lt;&gt; null then
							theLabel := tmpCommodityGroup.code;
						endif;
					endif;
					if  tmpWorkingMode = SHP_VoyageAreaForm2.WorkMode_Plan then
						theLabel := null;
						if tmpScaleFactor = 2  or mediumOutput then
						elseif tmpScaleFactor = 3 then
							tm_y1 := myY1 + 6;
						elseif tmpScaleFactor = 4 then
							tm_y1 := myY1 + 8;
						elseif tmpScaleFactor = 6 then
							tm_y1 := myY1 + 14;
						elseif tmpScaleFactor = 9 then
							tm_y1 := myY1 + 22;
						endif;
					else
						tm_y1 := myY1;
					endif;
					self.drawColCodeLabel(theFrame, theColour,smallOutput, iAmPrinting, myX1, tm_y1, tmpScaleFactor,theLabel);
				endif;
			endif;
		endif;	
	endif;

	// ###############
	// DRAW THE JOB BOUNDARY
	if not iAmPrinting or
	   (iAmPrinting and theFrame.myJobSeqSheet &lt;&gt; null and  
	   theFrame.myJobSeqSheet = tmpDischJob) then
		self.drawJobBoundary(tmpSlotController, theFrame);	
	endif;
	
	if tmpScaleFactor &lt; 2 and not mediumOutput then
		return;
	endif;

	theFrame.drawWidth := 1;
	// ###################
	// SEQUENCE NUMBER
	if iAmPrinting and self.printSeparateODUD then
		if dischPortCode &lt;&gt; null then
			self.drawColCodeLabel(theFrame, theColour, smallOutput, iAmPrinting, myX1, myY1, tmpScaleFactor, dischPortCode);
		endif;
		self.drawColCodeLabel(theFrame, theColour, smallOutput, iAmPrinting, myX1, myY1 + 10, tmpScaleFactor, craneLine);
		if tmpDischRequest &lt;&gt; null then
			foreach wle in tmpDischRequest.allWorkListEntries do
				if wle.weight = 0 then
					tmpTI := wle.myTrackedItem;
					if tmpTI &lt;&gt; null then
						totalWeight := totalWeight + tmpTI.totalWeight;
					endif;
				else
					totalWeight := totalWeight + wle.weight;
				endif;
			endforeach;
		endif;
		if totalWeight &gt; 0 then
			self.drawColCodeLabel(theFrame, theColour, smallOutput, iAmPrinting, myX1, myY1 + 20, tmpScaleFactor, (totalWeight / 1000).Integer.String);
		endif;
	else
		self.drawSequenceNumber(tmpDischRequest, tmpLoadRequest, tmpDischJob, theFrame);
	endif;

	if tmpDischRequest = null then
		return;
	endif;
	
	if tmpWorkingMode = SHP_VoyageAreaForm2.WorkMode_CustomSeq or
	   (iAmPrinting and theFrame.myJobSeqSheet &lt;&gt; null) or
	   (tmpScaleFactor &lt; 2 and not mediumOutput) then
		return;
	endif;

	theFrame.drawFontSize := self.defaultFontSizeForAttributes;

	// ###########
	// FORTYFOOT
	if isFortyFoot then
		if isBackEnd then
			self.drawAttribute(null,theFrame,myX1,myY1, theColour,PicTI40FooterBackEnd,theAttribCount);
		else
			self.drawAttribute(null,theFrame,myX1,myY1, theColour,PicTI40Footer,theAttribCount);
		endif;
	endif;

	self.drawColCodeDischAttributes(theFrame,tmpDischRequest,myX1,myY1, theColour,theAttribCount);
	// ###########
	/*// FORTY FIVE FOOT
	if tmpDischRequest.getAttrIs45() and not tmpDischRequest.isBackend then
		self.drawAttribute(null,theFrame,myX1,myY1, theColour,PicTI45Footer,theAttribCount);
	endif;

	// PAR 16415 CCMS 1029
	// ###########
	// FIFTY THREE FOOT
	if tmpDischRequest.getAttrIs53() and not tmpDischRequest.isBackend then
		self.drawAttribute(null,theFrame,myX1,myY1, theColour,PicTI53Footer,theAttribCount);
	endif;
	// ###########
	// THIRTY FOOT
	if tmpDischRequest.getAttrIs30() and not tmpDischRequest.isBackend then
		// 30 BACKED IS DRAWN ELSEWHERE
		self.drawAttribute(null,theFrame,myX1,myY1, theColour,PicTI30Footer,theAttribCount);
		if tmpDischRequest.has30FootBackendSlotRequest(false) &lt;&gt; null then
			self.drawAttribute(null,theFrame,myX1,myY1, theColour,PicTI30FooterBE,theAttribCount);
		endif;
	endif;
	
	// ###########
	// POWERED
	if tmpDischRequest.getAttrPowerRequired() then
		self.drawAttribute(null,theFrame, myX1,myY1,theColour,PicTIConnected,theAttribCount);
	endif;
	// ###########
	// HAZARD
	if tmpDischRequest.getAttrHazardous() then
		self.drawAttribute(null,theFrame,myX1,myY1, theColour,PicTIHazard,theAttribCount);
	endif;
	
	// ###########
	// OVERSIZED
	if tmpDischRequest.getAttrOverDimensioned() then
		self.drawAttribute(null,theFrame,myX1,myY1, theColour,PicTIOversized,theAttribCount);
	endif;
	
	// ###########
	// HIGH CUBED	
	if tmpDischRequest.getAttrHiCubed() then
		self.drawAttribute(null,theFrame,myX1,myY1, theColour,PicTIHiCube,theAttribCount);
	endif;

	// ###########
	// WATERCOOLED	
	if tmpDischRequest.getAttrWaterCooled() then
		self.drawAttribute(null,theFrame,myX1,myY1, theColour,PicTIWaterCooled,theAttribCount);
	endif;

	// ###########
	// MTs ONLY
	if tmpDischRequest.getAttrEmpty() then
		self.drawAttribute(null,theFrame,myX1,myY1, theColour,PicTIEmpty,theAttribCount);
	endif;
*/
	
epilog
	self.setDefaultFont(theFrame);
	theFrame.drawWidth := 1;
	delete tmpSR;
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="SHP_BayDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawColCodeDischAttributes" id="43f0d62d-7d87-4113-ba8f-646dbd3fe219">
        <source>drawColCodeDischAttributes(_frame : SHP_BayDrawingFrame input;
							tmpDischRequest : CM_SlotRequest input;
							myX1, myY1	: Real;
							theColour : Integer;
							theAttribCount : Integer io) protected;
/*

Date		Who		Reason
07 February 2017	cnwer1	Initial creation TFS 3284 refactored from drawColCodeDisch 
                            improves preformance by caching voyage allocation attributes
11 January 2018		jlgmd1	TFS 36421 - Bay Discharge view generates 1090, 1013...
27 Nov 2018			jlgrh7 TFS #41218 SNO - Bay Plan and drawing attribute

*/
constants
	PrintOneAttribute = 1;							//+TFS41218

vars
	useVoyageAllocs 	: Boolean;
	voyageAllocCCAttributes : CMIF_VoyageAllocCCAttributes;
	isPrintSmallSize : Boolean;
begin
	isPrintSmallSize := self.printOutputStyle = CMUI_GridDrawingController.PrintOutput_Small;			//+TFS41218
	
	if tmpDischRequest = null then 
		return;
	endif;
	useVoyageAllocs:=tmpDischRequest.useVoyageAllocations;
	if useVoyageAllocs then
		voyageAllocCCAttributes:=self.getVoyageAllocCCAttributes(tmpDischRequest);
		if voyageAllocCCAttributes = null then // TFS 3631
			return;
		endif;
	endif;
	// ###########
	// FORTY FIVE FOOT
		
	if ((useVoyageAllocs and voyageAllocCCAttributes.is45) or (not useVoyageAllocs and tmpDischRequest.getAttrIs45())) and not tmpDischRequest.isBackend then
		self.drawAttribute(null,_frame,myX1,myY1, theColour,PicTI45Footer,theAttribCount);
	endif;
	if theAttribCount &gt;= self.attrMaxNum or (isPrintSmallSize and theAttribCount = PrintOneAttribute) then 						//+TFS41218		Not overlap other attributes but only one
		return;
	endif;
	
	//11 Jan 2018	MPD TFS #36421 moved
	//if voyageAllocCCAttributes = null then // TFS 3631
	//	return;
	//endif;
	
	// PAR 16415 CCMS 1029
	// ###########
	// FIFTY THREE FOOT
	if ((useVoyageAllocs and voyageAllocCCAttributes.is53) or (not useVoyageAllocs and tmpDischRequest.getAttrIs53())) and not tmpDischRequest.isBackend then
		self.drawAttribute(null,_frame,myX1,myY1, theColour,PicTI53Footer,theAttribCount);
	endif;
	
	if theAttribCount &gt;= self.attrMaxNum or (isPrintSmallSize and theAttribCount = PrintOneAttribute) then 						//+TFS41218		
		return;
	endif;
	// ###########
	// THIRTY FOOT
	if ((useVoyageAllocs and voyageAllocCCAttributes.is30) or (not useVoyageAllocs and tmpDischRequest.getAttrIs30())) and not tmpDischRequest.isBackend then
		// 30 BACKED IS DRAWN ELSEWHERE
		self.drawAttribute(null,_frame,myX1,myY1, theColour,PicTI30Footer,theAttribCount);
		if tmpDischRequest.has30FootBackendSlotRequest(false) &lt;&gt; null then
			self.drawAttribute(null,_frame,myX1,myY1, theColour,PicTI30FooterBE,theAttribCount);
		endif;
	endif;
	
	if theAttribCount &gt;= self.attrMaxNum  or (isPrintSmallSize and theAttribCount = PrintOneAttribute) then 						//+TFS41218		
		return;
	endif;
	
	// ###########
	// POWERED
	if ((useVoyageAllocs and voyageAllocCCAttributes.requiresPower) or (not useVoyageAllocs and tmpDischRequest.getAttrPowerRequired()))  then
		self.drawAttribute(null,_frame, myX1,myY1,theColour,PicTIConnected,theAttribCount);
	endif;
	
	if theAttribCount &gt;= self.attrMaxNum or (isPrintSmallSize and theAttribCount = PrintOneAttribute) then 						//+TFS41218		
		return;
	endif;
	// ###########
	// HAZARD
	if ((useVoyageAllocs and voyageAllocCCAttributes.isHazardous) or (not useVoyageAllocs and tmpDischRequest.getAttrHazardous())) then
		self.drawAttribute(null,_frame,myX1,myY1, theColour,PicTIHazard,theAttribCount);
	endif;
	
	if theAttribCount &gt;= self.attrMaxNum or (isPrintSmallSize and theAttribCount = PrintOneAttribute) then 						//+TFS41218		
		return;
	endif;
	
	// ###########
	// OVERSIZED
	if ((useVoyageAllocs and voyageAllocCCAttributes.isOD) or (not useVoyageAllocs and tmpDischRequest.getAttrOverDimensioned())) then
		self.drawAttribute(null,_frame,myX1,myY1, theColour,PicTIOversized,theAttribCount);
	endif;
	
	if theAttribCount &gt;= self.attrMaxNum or (isPrintSmallSize and theAttribCount = PrintOneAttribute) then 						//+TFS41218		
		return;
	endif;
	// ###########
	// HIGH CUBED	
	if ((useVoyageAllocs and voyageAllocCCAttributes.isHiCube) or (not useVoyageAllocs and tmpDischRequest.getAttrHiCubed()))  then
		self.drawAttribute(null,_frame,myX1,myY1, theColour,PicTIHiCube,theAttribCount);
	endif;

	if theAttribCount &gt;= self.attrMaxNum or  (isPrintSmallSize and theAttribCount = PrintOneAttribute) then 						//+TFS41218		
		return;
	endif;
	// ###########
	// WATERCOOLED	
	if ((useVoyageAllocs and voyageAllocCCAttributes.isWaterCooled) or (not useVoyageAllocs and tmpDischRequest.getAttrWaterCooled())) then
		self.drawAttribute(null,_frame,myX1,myY1, theColour,PicTIWaterCooled,theAttribCount);
	endif;
	
	if theAttribCount &gt;= self.attrMaxNum or  (isPrintSmallSize and theAttribCount = PrintOneAttribute) then 						//+TFS41218		
		return;
	endif;

	// ###########
	// MTs ONLY
	if ((useVoyageAllocs and voyageAllocCCAttributes.isEmpty) or (not useVoyageAllocs and tmpDischRequest.getAttrEmpty())) then
		self.drawAttribute(null,_frame,myX1,myY1, theColour,PicTIEmpty,theAttribCount);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="tmpDischRequest" type="CM_SlotRequest" usage="input"/>
        <Parameter name="myX1" type="Real"/>
        <Parameter name="myY1" type="Real"/>
        <Parameter name="theColour" type="Integer"/>
        <Parameter name="theAttribCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawColCodeLabel" id="f5941d7e-74fa-4629-b87e-114061914113">
        <source>drawColCodeLabel(theFrame : CMUI_GridAreaDrawingFrame input;
					 _theColour : Integer;
					_smallOutput, _iAmPrinting : Boolean;
					_myX1, _myY1,_scalefactor : Real; 
					_theLabel : String) protected;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpX, tmpY : Integer;
	theLabel : String;
begin
	theLabel := _theLabel;
	tmpX := (_myX1 + 3).Integer;
	tmpY := (_myY1 + 2).Integer;
	if _smallOutput then
		theFrame.drawFontSize := 6;
		theFrame.drawFontBold := true;
		tmpX := (_myX1 + 1).Integer;
		tmpY := (_myY1).Integer;
	elseif _scalefactor = 1 then // only when printing
		theFrame.drawFontSize := 6;
		tmpY := (_myY1 + 1).Integer;
	elseif _scalefactor = 1.5 then // only when printing
		theFrame.drawFontSize := 8;
		tmpY := (_myY1 + 1).Integer;
	elseif _scalefactor = 2  or (amPrinting and self.printOutputStyle = self.PrintOutput_Medium)   then
		if _iAmPrinting then
			tmpX := (_myX1 + 1).Integer;
			tmpY := (_myY1).Integer;
			theFrame.drawFontSize := 6;
		else
			theFrame.drawFontSize := 6;
		endif;
		theLabel := theLabel[1:3];
	elseif _scalefactor = 3 then
		if _iAmPrinting then
			tmpY := (_myY1).Integer;
			theFrame.drawFontSize := 8;
		else
			theFrame.drawFontSize := 7;
		endif;
	elseif _scalefactor = 4 then
		if _iAmPrinting then
			tmpY := (_myY1 + 3).Integer;
			theFrame.drawFontSize := 10;
		else
		theFrame.drawFontSize := 9;
		endif;
		tmpX := (_myX1 + 4).Integer;
	elseif _scalefactor = 6 then
		theFrame.drawFontSize := 14;
		tmpX := (_myX1 + 5).Integer;
	elseif _scalefactor = 9 then
		theFrame.drawFontSize := 18;
		tmpX := (_myX1 + 5).Integer;
	endif;
	theFrame.drawTextAt(theLabel, tmpX, tmpY,_theColour);
	theFrame.drawFontBold := false;

end;</source>
        <access>protected</access>
        <Parameter name="theFrame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_theColour" type="Integer"/>
        <Parameter name="_smallOutput" type="Boolean"/>
        <Parameter name="_iAmPrinting" type="Boolean"/>
        <Parameter name="_myX1" type="Real"/>
        <Parameter name="_myY1" type="Real"/>
        <Parameter name="_scalefactor" type="Real"/>
        <Parameter name="_theLabel" type="String"/>
    </JadeMethod>
    <JadeMethod name="drawColCodeLoad" id="36bb51e7-55b5-4380-9329-d58f7bbc16d1">
        <updating/>
        <source>drawColCodeLoad(_frame : SHP_BayDrawingFrame input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 14/05/2015	cnwdap1		PAR #36206 TFS 324/334 Graphical Representation of Hazard Class and Special Stow
// 31/08/2015	cnwdap1		PAR #36652 Cargo planned to a slot should show ALL the cargo attributes if ShowCargoIconsInPlan is set
// 02/12/2015	cnwdap1		PAR #37021 If ShowCargoIconsInPlan is set, ONLY show planned cargo icons
//27 Nov 2018			jlgrh7 TFS #41218 SNO - Bay Plan and drawing attribute
vars
	theFrame: SHP_BayDrawingFrame;
	theLabel : String;
	theAttribCount, theColour : Integer;
	dlrWidth,lOuterColourUpper,lOuterColourLower : Integer;
	iAmPrinting : Boolean;
	tmpScaleFactor	: Real;
	smallOutput : Boolean;
	myX2, myX1, myY1, myY2	: Real;
	tmpSlotController,fwdSlotController	: CM_SlotController;
	tmpDischRequest,
	tmpLoadRequest, tmpSR	: CM_SlotRequest;
	isFortyFoot,
	isRehandle,
	isDischRehandle,
	isDischSOB,
	isTranship,
	isBackEnd,
	isSOB,foundJob			: Boolean;
	tmpLoadJob,
	tmpDischJob: CM_Job;
	tmpCommodityGroup	: CM_CommodityGroup;
	dischPortCode		: String;
	tmpTI			: CM_TrackedItem;
	tmpLoadDischPort,
	tmpDischDischPort	: CM_Port;
	tmpSlotDefn		: CM_SlotDefn;
	tmpBay			: CM_Bay;
	tmpBackendColor,
	tmpDrawFillColour	: Integer;
	amSelected	: Boolean;
	useVA : Boolean;
	flexiWeightString : String;
	condensedStr : String;
	oldFontSize : Decimal[5,2];
	cmifColour : CMIF_Colour;
	craneLine: String;
	totalWeight: Real;
	wle: CM_WorkListEntry;
begin
	theFrame := _frame; // AKB2009SEPT was down lower, so epilog might error

	tmpSlotDefn	:= self.mySlotDefn;

	if tmpSlotDefn.unavailable then
		return;
	endif;

	if (not CM_SlotDefnVoyage.hasInstance(tmpSlotDefn)) then
		return;
	endif;
	
	tmpSlotController := tmpSlotDefn.CM_SlotDefnVoyage.mySlotController;
	if tmpSlotController = null then
		return;
	endif;
	
	useVA := self.myVoyage.useVoyageAllocations; // PAR 23426
	
	if self.myTrackedItem &lt;&gt; null then
		isTranship		:= self.myTrackedItem.isTranshipItem;
	endif;

	tmpDischRequest := tmpSlotController.mySlotRequestDischarge;
	tmpLoadRequest := tmpSlotController.mySlotRequestLoad;

	if tmpLoadRequest &lt;&gt; null then
		isFortyFoot := (self.isSlotRequest40(tmpLoadRequest) or tmpLoadRequest.fortyBack);// PAR 21746 in this case fortyBack is correct
		isRehandle	:= tmpLoadRequest.isRehandle;
		isSOB		:= tmpLoadRequest.isSOB;
		tmpLoadDischPort := tmpLoadRequest.getAttrDischargePort();
		if tmpLoadDischPort = null then // PAR 25833
			tmpLoadDischPort := tmpLoadRequest.getAttrDischargePortTS();// PAR 25833 maybe a tranship?
		endif;
		tmpLoadJob 		:= tmpLoadRequest.myJob;
		tmpCommodityGroup := tmpLoadRequest.getAttrCommodityGroup();
		if tmpLoadDischPort &lt;&gt; null then // PAR 25833
			dischPortCode	:= tmpLoadDischPort.code.trimPortCode; //	tmpLoadRequest.dischargePort.trimPortCode; //epr 9/10/06 par 12695
		endif;
		tmpBackendColor := Black;
		if tmpLoadJob &lt;&gt; null then
			craneLine := tmpLoadJob.CM_VoyageJob.craneId &amp; Space &amp; tmpLoadJob.getJobNum() &amp; Forward_Slash &amp; self.getSequenceNumForRequest(tmpLoadRequest);
		endif;
		// if there has been a rework job over the top of the last job we need to go through all the jobs to switch to the 1 we are printing
		if self.myJobSeqSheet &lt;&gt; null  then
			foundJob := false;
			foreach tmpSR in tmpSlotController.allSlotRequestsLoad do
				if self.myJobSeqSheet = tmpSR.myJob then
					foundJob := true;
					break;
				endif;
			endforeach;
			
			if foundJob and tmpLoadRequest &lt;&gt; tmpSR then
				tmpLoadRequest := tmpSR;
				isFortyFoot := (self.isSlotRequest40(tmpLoadRequest) or tmpLoadRequest.fortyBack);// PAR 21746 in this case fortyBack is correct
				isRehandle	:= tmpLoadRequest.isRehandle;
				isSOB		:= tmpLoadRequest.isSOB;
				tmpLoadDischPort := tmpLoadRequest.getAttrDischargePort();
				tmpLoadJob 		:= tmpLoadRequest.myJob;
				tmpCommodityGroup := tmpLoadRequest.getAttrCommodityGroup();
				if tmpLoadDischPort = null then // PAR 25833
					tmpLoadDischPort := tmpLoadRequest.getAttrDischargePortTS();// PAR 25833 maybe a tranship?
				endif;
				if tmpLoadDischPort &lt;&gt; null then // PAR 25833
					dischPortCode	:= tmpLoadDischPort.code.trimPortCode; //	tmpLoadRequest.dischargePort.trimPortCode; 
				endif;
			endif;			
		endif;
	else
		tmpBackendColor := Gray;
	endif;
	
	if tmpDischRequest &lt;&gt; null then
		tmpDischDischPort 	:= tmpDischRequest.getAttrDischargePort();
		isDischRehandle		:= tmpDischRequest.isRehandle;
		isDischSOB			:= tmpDischRequest.isSOB;
		tmpDischJob 		:= tmpDischRequest.myJob;
		// ### IF they have a SOB job whose source (discharge) are from bay 1 and bay 2. And the target is bay 2, we were not drawing the source slots in bay 2.
		if self.myJobSeqSheet &lt;&gt; null   // PAR 8688
		and isDischSOB    // PAR 8688
		and tmpDischRequest.myJob = self.myJobSeqSheet then   // PAR 8688
			tmpLoadJob 		:= tmpDischRequest.myJob;   // PAR 8688
			tmpLoadRequest := tmpDischRequest;  // PAR 8688
		endif;
	endif;

	myX1 := self.x1;
	myX2 := self.x2;
	myY1 := self.y1;
	myY2 := self.y2;

	tmpBay := theFrame.myBay;
	iAmPrinting := self.amPrinting;
	smallOutput := (self.printOutputStyle = PrintOutput_Small);	

	isBackEnd := self.setIsBackend(tmpBay, tmpLoadRequest);
	// for Sequence Sheet, set job up for aft slot
	if isBackEnd and self.myJobSeqSheet &lt;&gt; null then
		fwdSlotController := tmpSlotController.myForwardSlot;
		if fwdSlotController &lt;&gt; null then
			foundJob := false;
			// if there has been a rework job over the top of the last job we need to go through all the jobs to switch to the 1 we are printing
			foreach tmpLoadRequest in fwdSlotController.allSlotRequestsLoad do
				if self.myJobSeqSheet = tmpLoadRequest.myJob then
					tmpLoadJob := tmpLoadRequest.myJob;
					foundJob := true;
					break;
				endif;
			endforeach;
			if not foundJob then
				tmpLoadRequest := fwdSlotController.mySlotRequestLoad;
				if tmpLoadRequest &lt;&gt; null then
					tmpLoadJob 	:= tmpLoadRequest.myJob;
				endif;
			endif;
		endif;	
	endif;

	tmpScaleFactor := self.scaleFactor;
	tmpDrawFillColour := White;

	// if I am selected then draw highlighted
	if isBackEnd or (iAmPrinting and self.showNoColours) then
		tmpDrawFillColour := White;
	elseif (iAmPrinting and theFrame.myJobSeqSheet &lt;&gt; null) then
		tmpDrawFillColour := White;
	elseif useVA //then // PAR 23426
	and tmpSlotController.mySlotRequestLoad &lt;&gt; null then // PAR 26829

		tmpDrawFillColour := self.setColourFromAllocation(tmpSlotController); // PAR 23426

		if tmpDrawFillColour &lt;&gt; NullColour and theFrame.myBayDrawingController &lt;&gt; null and theFrame.myBayDrawingController.myDrawingAttrController &lt;&gt; null then		// 4/12/17 MAP TFS7494
			theFrame.myBayDrawingController.myDrawingAttrController.allYardAllocations.addNoDuplicates(tmpSlotController.mySlotRequestLoad.allAllocations.first(), false);
		endif;
	elseif tmpLoadDischPort &lt;&gt; null then		
		if tmpLoadRequest = null then
			tmpDrawFillColour := tmpLoadDischPort.colour;
		else
			tmpDrawFillColour := self.getFillColourForRequest(tmpLoadRequest);
		endif;
	else
		if self.myTrackedItem = null then
			tmpDrawFillColour := White;

		elseif (not iAmPrinting) then
			// we are going to draw an actual TI where we have no Load Colour coding. We will not draw in solid colour so we need to draw a white backgrnd first
			theFrame.drawFillColor := White;
			theFrame.drawFilledRectangle(myX1, myY1, myX2, myY2, White); 

			tmpTI := self.myTrackedItem;
			if tmpTI = null then
				tmpDrawFillColour := White;
			else
				tmpDrawFillColour := tmpTI.getDrawingColour(TI_ColourMode_DischargePort);
			endif;
		endif;
	endif;

	if tmpDrawFillColour = NullColour then
		tmpDrawFillColour := White;
	endif;

	amSelected := (self.allSelectedObjects.includes(tmpSlotController) or
				  self.allSelectedObjectsAlt.includes(tmpSlotController));

	self.setDrawStyleAndColors(tmpSlotController, theFrame, tmpDrawFillColour, lOuterColourUpper, lOuterColourLower);

	// I am in LOAD Colour Code mode. There is a TI in this point 
	// but there is no load colour coding. Show the actual TI  non solid
//	if not iAmPrinting and dischPortCode = null then 
	if not iAmPrinting and tmpSlotController.mySlotRequestLoad = null then  //16 Jul 2019	NDL	TFS 45603 - allow for a load request not based on discharge port
		// dischPortCode &lt;&gt; null this means that we have LOAD CC here which over rides any DISCHARGE DLR SOB stuff
		// We are in LOAD CC mode, but we have a TI here and it is DISCH CC for DLR or SOB
		if self.showColorOthers = ShipShowOtherColor_None then
			if (not amSelected) then
				tmpDrawFillColour := White;
				tmpBackendColor := White;
			endif;
		else
			if (isDischRehandle or isDischSOB) and (self.myTrackedItem &lt;&gt; null) then
				if self.showColorOthers = ShipShowOtherColor_Hatched then
					self.drawClearRectangle(theFrame, x1, y1, x2, y2);
					theFrame.drawFillStyle := Frame.DrawFillStyle_Cross; 
				elseif (not amSelected) then
					tmpDrawFillColour := White;
				endif;
			elseif tmpLoadDischPort = null and self.myTrackedItem &lt;&gt; null then
				// the slot has actual cargo that is colour coded for discharge show different from no load actual TI
				if self.showColorOthers = ShipShowOtherColor_Other then
					if (not amSelected) then
						// ### PAR 8668
						if tmpDischDischPort &lt;&gt; null then // there is disch CC so show it in the other colour
							 tmpDrawFillColour := White;//self.otherSlotColor;	PAR 10101  actually no, don't show it - special rule when using ShowOtherColour
						elseif self.myTrackedItem &lt;&gt; null  then // there is NO disch CC, but there is cargo so show it in the other colour
							 tmpDrawFillColour := self.otherSlotColor;
						else
							tmpDrawFillColour := self.otherSlotColor;// there is nothing here
						endif;
											
					endif;
				else
					if tmpDischDischPort &lt;&gt; null then
						self.drawClearRectangle(theFrame, x1, y1, x2, y2);
						theFrame.drawFillStyle := Frame.DrawFillStyle_Cross;
					else
						self.drawClearRectangle(theFrame, x1, y1, x2, y2);
						theFrame.drawFillStyle := Frame.DrawFillStyle_DiagonalCross;
					endif;
				endif;
			endif;
		endif;
	endif;
	if self.myJobSeqSheet &lt;&gt; null and tmpLoadJob &lt;&gt; self.myJobSeqSheet then
		tmpDrawFillColour := White;
	endif;

	self.theDrawFillColor := tmpDrawFillColour;
	theFrame.drawFillColor := tmpDrawFillColour;

	self.drawRectangle(theFrame, myX1, myY1, myX2, myY2, lOuterColourUpper, lOuterColourLower, iAmPrinting, smallOutput);
	
	if self.myJobSeqSheet = null then // not SeqSheet
		if isBackEnd then
//			self.drawBackend(theFrame, tmpBackendColor);
			
			tmpSR := tmpLoadRequest; // PAR 17030
//			if tmpLoadRequest = null then // PAR 17030
//				create tmpSR transient; // PAR 17030
//				tmpSR.setTmpSRFromBETI(self.myTrackedItem); // PAR 17030
//			endif;
			self.drawBackendAtt(theFrame,tmpSR); // PAR 17030
			return;
		endif;
	elseif tmpLoadJob = self.myJobSeqSheet 
	and isBackEnd then
		self.drawBackend(theFrame, tmpBackendColor);
		return;
	endif;

	if self.myJobSeqSheet &lt;&gt; null and tmpLoadJob &lt;&gt; self.myJobSeqSheet then
		return;
	endif;

	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	// ### indicate the Discharge CC SOB or DLR with a square
	if (not iAmPrinting) and self.showColorOthers = ShipShowOtherColor_Hatched then
		if (isDischRehandle or isDischSOB) and 
		   (self.myTrackedItem &lt;&gt; null) and 
		   tmpLoadDischPort = null then
			dlrWidth := ((myX2 - myX1) / 3).Integer;
			if isDischRehandle then
				theFrame.drawFillColor := COLOUR_DLR; //Green;
			elseif isDischSOB then
				theFrame.drawFillColor := COLOUR_SOB; //Blue;
			endif;
			theFrame.drawFilledRectangle(myX1 + dlrWidth , myY1 + dlrWidth, myX2 - dlrWidth, myY2 - dlrWidth, Black); 
		endif;
	endif;

	// ### indicate the Load CC SOB or DLR with a square
	if not (iAmPrinting and theFrame.myJobSeqSheet &lt;&gt; null) then
		if isRehandle or isSOB then //or (self.colLoadMyJob &lt;&gt; null and self.colLoadMyJobIsComplete) then
			if isRehandle then
				theFrame.drawFillColor := COLOUR_DLR; //Green;
			elseif isSOB then
				theFrame.drawFillColor := COLOUR_SOB; //Blue;
			endif;
			theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
			if tmpScaleFactor = 1 then
				dlrWidth := ((myX2 - myX1) / 3).Integer;
			else
				dlrWidth := ((myX2 - myX1) / 3).Integer;
			endif;
			if self.allSelectedObjects.includes(tmpSlotDefn) then
				lOuterColourUpper := White;
				lOuterColourLower := DarkGray;
			else
				lOuterColourUpper := DarkGray;
				lOuterColourLower := White;
			endif;
	
			theFrame.drawFilledRectangle(myX1 + dlrWidth , myY1 + dlrWidth, myX2 - dlrWidth, myY2 - dlrWidth, White); 
			if (not iAmPrinting) then
				// ### 3D Effects
				theFrame.drawLine(myX1 + dlrWidth, myY1 + dlrWidth, myX2 - dlrWidth, myY1 + dlrWidth,  lOuterColourUpper);
				theFrame.drawLine(myX1 + dlrWidth, myY1 + dlrWidth, myX1 + dlrWidth, myY2 - dlrWidth,  lOuterColourUpper);
				theFrame.drawLine(myX2 - dlrWidth - 1, myY1 + dlrWidth + 1, myX2 - dlrWidth - 1,  myY2 - dlrWidth - 1,  lOuterColourLower);
				theFrame.drawLine(myX1 + dlrWidth,  myY2 - dlrWidth, myX2 - dlrWidth,  myY2 - dlrWidth,  lOuterColourLower);
			endif;
		endif;
	endif;
	
	if tmpScaleFactor &gt;= 1 then
		if isRehandle or isSOB then
	 // PAR 28968		if (tmpLoadRequest.mySlotRequestDLRSOBDischarge &lt;&gt; null  or tmpLoadRequest.myRequestLinkedDischarge &lt;&gt; null)
			if (tmpLoadRequest.getLinkedRequest(true) &lt;&gt; null)
			and theFrame.myJobSeqSheet = null then
				self.drawMark(theFrame,LightGreen,1,iAmPrinting,tmpScaleFactor);
			endif;
		endif;
	endif;
	
	if tmpScaleFactor &gt;= 2 then
		if (tmpLoadRequest &lt;&gt; null and tmpLoadRequest.isComplete) then
			if iAmPrinting and theFrame.myJobSeqSheet &lt;&gt; null then
				if tmpLoadJob = theFrame.myJobSeqSheet then
					self.drawMark(theFrame,Black,2,iAmPrinting,tmpScaleFactor);
				endif;
			else
				self.drawMark(theFrame,Black,2,iAmPrinting,tmpScaleFactor);
			endif;
		endif;
	endif;
	

	if (not iAmPrinting) 
	and self.showColorOthers &lt;&gt; ShipShowOtherColor_None // PAR 14189
	and   isTranship then
		self.drawMark(theFrame, Yellow, 1, iAmPrinting, tmpScaleFactor);
	endif;

	// ###############
	// DRAW THE JOB BOUNDARY
	if (not iAmPrinting) or 
	   (iAmPrinting and theFrame.myJobSeqSheet &lt;&gt; null and  
	   theFrame.myJobSeqSheet = tmpLoadJob) then
		self.drawJobBoundary(tmpSlotController, theFrame);
	endif;
	if isBackEnd or 
	   (tmpScaleFactor &lt; ScaleFactor_2 and (not iAmPrinting)) then
		return;
	endif;
	
	// ####################
	// COMMODITY &amp; DISCHARGE PORT
	cmifColour := self.allColours[self.theDrawFillColor];
	if cmifColour = null then
		create cmifColour transient;
		cmifColour.setColour(self.theDrawFillColor);
		self.allColours.add(cmifColour);
	endif;
	theColour:= cmifColour.inverseColour;
	theFrame.drawFontName := Font_Helvetica;
	
	if iAmPrinting and tmpLoadDischPort &lt;&gt; null then
		/*if smallOutput then																								//-TFS41218	Not print out Single letter lable for small print
			if tmpLoadDischPort.ccodePrint.trimBlanks &lt;&gt; null then
				theLabel := tmpLoadDischPort.ccodePrint[1:1];
			else
				theLabel := dischPortCode[1:1];
			endif;
		else
			theLabel := dischPortCode[1:3];
		endif;*/
		if not smallOutput then 																							
			theLabel := dischPortCode[1:3];
		endif;
	else
		if tmpCommodityGroup &lt;&gt; null then
			theLabel := tmpCommodityGroup.code;
		elseif dischPortCode &lt;&gt; null then // PAR 22959
			theLabel := dischPortCode[1:3]; // PAR 22959
		endif;
	endif;

	if self.inPlaningOrSequenceMode or 
	   (iAmPrinting and theFrame.myJobSeqSheet &lt;&gt; null) then
		// ###################
		// SEQUENCE NUMBER
		if iAmPrinting and self.printSeparateODUD then
			if tmpLoadDischPort &lt;&gt; null then
				self.drawColCodeLabel(theFrame, theColour,smallOutput, iAmPrinting, myX1, myY1, tmpScaleFactor, tmpLoadDischPort.code);
			endif;
			self.drawColCodeLabel(theFrame, theColour,smallOutput, iAmPrinting, myX1, myY1 + 10, tmpScaleFactor, craneLine);
			if tmpLoadRequest &lt;&gt; null then
				foreach wle in tmpLoadRequest.allWorkListEntries do
					if wle.weight = 0 then
						tmpTI := wle.myTrackedItem;
						if tmpTI &lt;&gt; null then
							totalWeight := totalWeight + tmpTI.totalWeight;
						endif;
					else
						totalWeight := totalWeight + wle.weight;
					endif;
				endforeach;
			endif;
			if totalWeight &gt; 0 then
				self.drawColCodeLabel(theFrame, theColour, smallOutput, iAmPrinting, myX1, myY1 + 20, tmpScaleFactor, (totalWeight / 1000).Integer.String);
			endif;
		else
			self.drawSequenceNumber(tmpDischRequest, tmpLoadRequest, null, theFrame);
		endif;
	else	 
		self.drawColCodeLabel(theFrame, theColour,smallOutput, iAmPrinting,myX1, myY1,tmpScaleFactor,theLabel);
	endif;	
	
	if tmpLoadRequest = null then
		return;
	endif;
	
	if self.workingMode = SHP_VoyageAreaForm2.WorkMode_CustomSeq then
		return;
	endif;
	if (iAmPrinting and theFrame.myJobSeqSheet &lt;&gt; null) then
		return;
	endif;
	if tmpScaleFactor &lt; ScaleFactor_2 and 
	   (not (amPrinting and self.printOutputStyle = self.PrintOutput_Medium)) then
		return;
	endif;

	theFrame.drawFontSize := self.defaultFontSizeForAttributes;
	
	//epr TFS 3284 3/2/17 performance improvements refactored into method
	self.drawColCodeLoadAttributes(theFrame,tmpLoadRequest,isFortyFoot,myX1,myY1, theColour,theAttribCount);

	//23 Jun 2015	NDL	Par 36057
	flexiWeightString := tmpLoadRequest.getAttrFlexiWeightStr;
	if flexiWeightString &lt;&gt; null and self.scaleFactor &gt;= 4 then
		condensedStr := flexiWeightString.replaceString(" ", null);
		//22 Oct 2015	NDL	Par 36665
		if condensedStr.length &gt; 7 then
			condensedStr := condensedStr[1:7];
		endif;
		theFrame.drawFontName:=self.defaultFontName; //epr par 37323 13/1/16
		oldFontSize := theFrame.drawFontSize;
		theFrame.drawFontSize := scaleFactor * 2;
		theFrame.drawTextAt(condensedStr, myX1 + 2, myY1 + (scaleFactor * 3.5), theColour);
		theFrame.drawFontSize := oldFontSize;
	endif;
	

	// draw a red mark if more than 1 planned container
	if (not amPrinting) and self.tiInfoNumTI &gt; 1 then
		self.drawMark(theFrame, Red, 1, amPrinting, self.scaleFactor);
	endif;

epilog
	self.setDefaultFont(theFrame);
	theFrame.drawWidth := 1;
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="SHP_BayDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawColCodeLoadAttributes" id="7a1ad77b-ea53-425a-8b9a-068e9db08ea8">
        <updating/>
        <source>drawColCodeLoadAttributes(	_frame : SHP_BayDrawingFrame input;
							tmpLoadRequest : CM_SlotRequest input;
							isFortyFoot : Boolean io;
							myX1, myY1	: Real;
							theColour : Integer;
							theAttribCount : Integer io) updating, protected;
/*

Date		Who		Reason
01/02/2017	cnwer1	Initial creation TFS 3284 performance improvements refactored from drawColCodeLoad
27/11/2018	jlgrh7 	TFS #41218 SNO - Bay Plan and drawing attribute
11/11/2019	jlgdap1	TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen - rewritten to draw in priority order
27/11/2019	jlgdap1	TFS 47744 LOLO Voyage Discharge Planning - 1090 in printing
*/
constants
	PrintOneAttribute = 1;					//+TFS41218		
vars
	plannedTI : CM_TrackedItem;
	is30		: Boolean;
	tmpCargoTypeId,
	tmpMotorDirection,
	tmpDoorsDirection	: Integer;
	useVoyageAllocs 	: Boolean;
	voyageAllocCCAttributes : CMIF_VoyageAllocCCAttributes;
	isPrintSmallSize : Boolean;
	iter : Iterator;							// TFS 46405
	attr, startObject: CM_DrawingAttribute;		// TFS 46405
	iconArray : StringArray;					// TFS 46405
	attrCode : String;							// TFS 46405
	alloc : CM_YardAllocation;					// TFS 46405
	crit : CM_YACriteria;						// TFS 46405
	dispMode, workMode : Integer;				// TFS 46405
begin
	isPrintSmallSize := self.printOutputStyle = CMUI_GridDrawingController.PrintOutput_Small;
	
	if tmpLoadRequest = null then 
		return;
	endif;
	
	// ###########
	// UNAVAILABLE	
	if tmpLoadRequest.unavailable then
		self.drawAttribute(null, _frame, myX1, myY1, theColour, PicTIUnavail, theAttribCount);
		return;
	endif;
	
	// PAR #36652 moved up in code to get planned TI for all drawing attributes
	if self.workingMode = self.myVoyageAreaForm.WorkMode_Plan	 			// PAR #36652
	and self.myTerminal.getConfig(ShowCargoIconsInPlan).Boolean then		// PAR #36652
		plannedTI := tmpLoadRequest.getTIofMode(PLANNING_MODE);				// PAR #36652
	endif;
	if tmpLoadRequest.isComplete then
		plannedTI:=tmpLoadRequest.getTrackedItem;
	endif;
	
	//16 Jul 2019	NDL	TFS 45603 - Apparently if we have a ti we only display its icons, not the
	// the colour coded ones.
	if plannedTI &lt;&gt; null then
		//self.drawIcons(plannedTI, _frame, myX1, myY1, theColour);											// TFS 46405
		//self.myVoyageAreaForm.getShipVoyFormDispAndWorkModes(dispMode, workMode);							// TFS 46405	// TFS 47744
		//self.drawIcons(plannedTI, _frame, myX1, myY1, theColour, workMode = self.myVoyageAreaForm.WorkMode_Plan);			// TFS 47744
		self.drawIcons(plannedTI, _frame, myX1, myY1, theColour, self.workingMode = self.myVoyageAreaForm.WorkMode_Plan);	// TFS 47744
		return;
	endif;
	
	useVoyageAllocs:=tmpLoadRequest.useVoyageAllocations;
	if  useVoyageAllocs then //epr tfs 3579
		voyageAllocCCAttributes:=self.getVoyageAllocCCAttributes(tmpLoadRequest);	
	endif;
	
	//epr TFS 4511 25/5/17
	if useVoyageAllocs and voyageAllocCCAttributes = null then // TFS 3631
		return;
	endif;
	
	create iconArray transient;
	iter := app.myRoot.allDrawingAttributesByTypePri.createIterator;
	startObject := app.myRoot.allDrawingAttributesByTypePri.getAtKeyGtr(DrawingAttrType_TrackedItem, null);
	if startObject &lt;&gt; null then
		iter.startAtObject(startObject);
		while iter.next(attr) do
			if attr.drawingAttrType &lt;&gt; DrawingAttrType_TrackedItem then
				break;
			endif;
			
			attrCode := attr.code;
			// ###########
			// FORTYFOOT
			if attrCode = PicTI40Footer then
				if isFortyFoot then
					if self.isBackend then
						iconArray.add(PicTI40FooterBackEnd);
					else
						iconArray.add(PicTI40Footer);
					endif;
				endif;
			// ###########
			// FORTY FIVE FOOT
			elseif attrCode = PicTI45Footer then
				if ((useVoyageAllocs and voyageAllocCCAttributes.is45) or (not useVoyageAllocs and tmpLoadRequest.getAttrIs45())) then 
					iconArray.add(PicTI45Footer);
				endif;
			// ###########
			// FIFTY THREE FOOT
			elseif attrCode = PicTI53Footer then
				if ((useVoyageAllocs and voyageAllocCCAttributes.is53) or (not useVoyageAllocs and tmpLoadRequest.getAttrIs53())) then 
					iconArray.add(PicTI53Footer);
				endif;	
			// ###########
			// THIRTY FOOT
			elseif attrCode = PicTI53Footer then
				if ((useVoyageAllocs and voyageAllocCCAttributes.is30) or (not useVoyageAllocs and tmpLoadRequest.getAttrIs30())) then 
					is30:=true;	
				endif;	
				if 	is30 then
					iconArray.add(PicTI30Footer);
					if tmpLoadRequest.has30FootBackendSlotRequest(true) &lt;&gt; null then
						iconArray.add(PicTI30FooterBE);
					endif;
				endif;
			// ###########
			// Cargo Type Break-Bulk or Timber
			elseif attrCode.isOneOf(PicTIBreakBulk, PicTITimber) then
				tmpCargoTypeId := tmpLoadRequest.cargoType;
				if tmpCargoTypeId = TI_CargoType_BreakBulk then
					iconArray.add(PicTIBreakBulk);
				elseif tmpCargoTypeId = TI_CargoType_Timber then
					iconArray.add(PicTITimber);
				endif;
			// ###########
			// SPECIAL STOW
			elseif attrCode = PicSpecialStow then
				if ((useVoyageAllocs and voyageAllocCCAttributes.isSpecialStow) or (not useVoyageAllocs and tmpLoadRequest.getAttrIsSpecialStow())) then 
					iconArray.add(PicSpecialStow);
				endif;	
			// ###########
			// WATER COOLED
			elseif attrCode = PicTIWaterCooled then
				if ((useVoyageAllocs and voyageAllocCCAttributes.isWaterCooled) or (not useVoyageAllocs and tmpLoadRequest.getAttrWaterCooled())) then 
					iconArray.add(PicTIWaterCooled);
				endif;	
			// ###########
			// POWERED
			elseif attrCode = PicTIConnected then
				if ((useVoyageAllocs and voyageAllocCCAttributes.requiresPower) or (not useVoyageAllocs and tmpLoadRequest.getAttrPowerRequired())) then 
					iconArray.add(PicTIConnected);
				endif;	
			// ###########
			// CRIB
			elseif attrCode = PicTICrib then
				if ((useVoyageAllocs and voyageAllocCCAttributes.isCrib) or (not useVoyageAllocs and tmpLoadRequest.getAttrCrib())) then 
					iconArray.add(PicTICrib);
				endif;	
			// ###########
			// FRAME
			elseif attrCode = PicTIFrame then
				if ((useVoyageAllocs and voyageAllocCCAttributes.isFrame) or (not useVoyageAllocs and tmpLoadRequest.getAttrFrame())) then 
					iconArray.add(PicTIFrame);
				endif;	
			// ###########
			// TANK
			elseif attrCode = PicTITank then
				if ((useVoyageAllocs and voyageAllocCCAttributes.isTank) or (not useVoyageAllocs and tmpLoadRequest.getAttrTank())) then 
					iconArray.add(PicTITank);
				endif;	
			// ###########
			// OPEN TOP
			elseif attrCode = PicTIOpentop then
				if ((useVoyageAllocs and voyageAllocCCAttributes.isOpenTop) or (not useVoyageAllocs and tmpLoadRequest.getAttrOpenTop())) then 
					iconArray.add(PicTIOpentop);
				endif;	
			// ###########
			// FLAT
			elseif attrCode = PicTIFlat then
				if ((useVoyageAllocs and voyageAllocCCAttributes.isFlat) or (not useVoyageAllocs and tmpLoadRequest.getAttrFlatRack())) then 
					iconArray.add(PicTIFlat);
				endif;	
			// ###########
			// FANTAINER
			elseif attrCode = PicTIFantainer then
				if ((useVoyageAllocs and voyageAllocCCAttributes.isFantainer) or (not useVoyageAllocs and tmpLoadRequest.getAttrFantainer())) then 
					iconArray.add(PicTIFantainer);
				endif;	
			// ###########
			// HAZARD
			elseif attrCode = PicTIHazard then
				if ((useVoyageAllocs and voyageAllocCCAttributes.isHazardous) or (not useVoyageAllocs and tmpLoadRequest.getAttrHazardous())) then 
					iconArray.add(PicTIHazard);
				endif;	
			// ###########
			// OVERSIZED
			elseif attrCode = PicTIOversized then
				if ((useVoyageAllocs and voyageAllocCCAttributes.isOD) or (not useVoyageAllocs and tmpLoadRequest.getAttrOverDimensioned())) then 
					iconArray.add(PicTIOversized);
				endif;	
			// ###########
			// HIGH CUBED
			elseif attrCode = PicTIHiCube then
				if ((useVoyageAllocs and voyageAllocCCAttributes.isHiCube) or (not useVoyageAllocs and tmpLoadRequest.getAttrHiCubed())) then 
					iconArray.add(PicTIHiCube);
				endif;	
			// ###########
			// HALF HEIGHT
			elseif attrCode = PicTIHalfHeight then
				if ((useVoyageAllocs and voyageAllocCCAttributes.isHalfHeight) or (not useVoyageAllocs and tmpLoadRequest.getAttrHalfHeight())) then 
					iconArray.add(PicTIHalfHeight);
				endif;	
			// #############
			// MOTOR DIRECTION
			elseif attrCode.isOneOf(PicTIMotorFwd, PicTIMotorAft, PicTIMotorFwd40, PicTIMotorAft40) then
				if self.showOnlyDoorDirections then // PAR 8190
					continue;// PAR 8190
				endif;
				tmpMotorDirection := tmpLoadRequest.getMotorDirection;	
				
				if isFortyFoot then
					if tmpMotorDirection = Motor_Forward and not iconArray.includes(PicTIMotorFwd40) then
						iconArray.add(PicTIMotorFwd40);
					elseif tmpMotorDirection = Motor_Aft and not iconArray.includes(PicTIMotorAft40) then
						iconArray.add(PicTIMotorAft40);
					endif;
				else
					if tmpMotorDirection = Motor_Forward and not iconArray.includes(PicTIMotorFwd) then
						iconArray.add(PicTIMotorFwd);
					elseif tmpMotorDirection = Motor_Aft and not iconArray.includes(PicTIMotorAft) then
						iconArray.add(PicTIMotorAft);
					endif;
				endif;
			// ###########
			// DOORS DIRECTION
			elseif attrCode.isOneOf(PicTADoorAft, PicTADoorFwd, PicTIDoorsFwd40, PicTIDoorsAft40) then
				tmpDoorsDirection := tmpLoadRequest.doorsDirection;
				
				if isFortyFoot then
					if tmpDoorsDirection = TI_DOORSDIRN_FWD and not iconArray.includes(PicTIDoorsFwd40) then
						iconArray.add(PicTIDoorsFwd40);
					elseif  tmpDoorsDirection = TI_DOORSDIRN_AFT and not iconArray.includes(PicTIDoorsAft40) then
						iconArray.add(PicTIDoorsAft40);
					endif;
				else
					if tmpDoorsDirection = TI_DOORSDIRN_FWD and not iconArray.includes(PicTIDoorsFwd) then
						iconArray.add(PicTIDoorsFwd);
					elseif  tmpDoorsDirection = TI_DOORSDIRN_AFT and not iconArray.includes(PicTIDoorsAft) then
						iconArray.add(PicTIDoorsAft);
					endif;		
				endif;
			// ###########
			// MTs ONLY
			elseif attrCode = PicTIEmpty then
				if ((useVoyageAllocs and voyageAllocCCAttributes.isEmpty) or (not useVoyageAllocs and tmpLoadRequest.getAttrEmpty())) then 
					iconArray.add(PicTIEmpty);
				endif;	
			// ###########
			// FLAT RACK ENDS
			elseif attrCode = PicTIFlatRackEndsUp then
				self.getIconsForFlatRackEnds(attrCode, iconArray, tmpLoadRequest);
			elseif attrCode = PicTIFlatRackEndsDown then
				self.getIconsForFlatRackEnds(attrCode, iconArray, tmpLoadRequest);
			endif;
			
			if theAttribCount &gt;= self.attrMaxNum or (isPrintSmallSize and theAttribCount = PrintOneAttribute) then
				break;
			endif;
		endwhile;
		
		// now draw the attributes we have
		foreach attrCode in iconArray do
			self.drawAttribute(null, _frame, myX1, myY1, theColour, attrCode, theAttribCount);
		endforeach;
	endif;	
	
epilog
	delete iconArray;
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="tmpLoadRequest" type="CM_SlotRequest" usage="input"/>
        <Parameter name="isFortyFoot" type="Boolean" usage="io"/>
        <Parameter name="myX1" type="Real"/>
        <Parameter name="myY1" type="Real"/>
        <Parameter name="theColour" type="Integer"/>
        <Parameter name="theAttribCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawColCodeLoadWork" id="67c7c55d-dd8e-4802-ac1e-cbc0f8b3e7ef">
        <updating/>
        <source>drawColCodeLoadWork(_frame : SHP_BayDrawingFrame input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2018	jlgndl1	Initial creation 	- Bastardised copy of 'drawColCodeLoad' and 'drawColCodeDisch'
											Exclusively to handle the 'Print Worked' options.
14MAR18 - JLGAB1 - TFS 37556 refactor to make work properly and choose between Discharge Port and Commodity Group colours.
//27 Nov 2018			jlgrh7 TFS #41218 SNO - Bay Plan and drawing attribute
*/
vars
	theFrame: SHP_BayDrawingFrame;
	theLabel : String;
	theAttribCount, theColour : Integer;
	lOuterColourUpper,lOuterColourLower : Integer;
	tmpScaleFactor	: Real;
	smallOutput : Boolean;
	myX2, myX1, myY1, myY2	: Real;
	tmpSlotController	: CM_SlotController;
	tmpDischRequest,
	tmpLoadRequest,
	tmpTheRequest	: CM_SlotRequest;
	isFortyFoot,
	isRehandle,
	
	
	isTranship,
	isBackEnd,
	isSOB			: Boolean;
	tmpCommodityGroup	: CM_CommodityGroup;
	dischPortCode		: String;
	tmpTI			: CM_TrackedItem;
	tmpDischPort	: CM_Port;
	tmpSlotDefn		: CM_SlotDefn;
	tmpBay			: CM_Bay;
	tmpBackendColor,
	tmpDrawFillColour	: Integer;
	amSelected	: Boolean;
	useVA : Boolean;
	cmifColour : CMIF_Colour;
	craneLine: String;
	drawRemainOnBoard : Boolean;
	invalidCommGrp : Boolean;
	commodityCode : String;
	drawDischarge : Boolean;
	drawLoad : Boolean;
begin
	
	if not self.amPrinting then
		self.drawColCodeLoad( _frame );
	endif;
	
	theFrame := _frame;
	
	tmpSlotDefn	:= self.mySlotDefn;
	if tmpSlotDefn.unavailable then
		return;
	endif;

	if (not CM_SlotDefnVoyage.hasInstance(tmpSlotDefn)) then
		return;
	endif;
	
	tmpSlotController := tmpSlotDefn.CM_SlotDefnVoyage.mySlotController;
	if tmpSlotController = null then
		return;
	endif;
	
	useVA := self.myVoyage.useVoyageAllocations; // PAR 23426
	
	tmpTI := self.myTrackedItem;
	if tmpTI &lt;&gt; null then
		isTranship := tmpTI.isTranshipItem;
	endif;
	
	if self.printWorked = 1 then
		tmpLoadRequest := tmpSlotController.mySlotRequestLoad;
	elseif self.printWorked = 2 then
		tmpDischRequest := tmpSlotController.mySlotRequestDischarge;
	elseif self.printWorked = 3 then
		tmpDischRequest := tmpSlotController.mySlotRequestDischarge;
		tmpLoadRequest := tmpSlotController.mySlotRequestLoad;
	endif;

	if tmpLoadRequest &lt;&gt; null then
		tmpTheRequest := tmpLoadRequest;
		isFortyFoot := (self.isSlotRequest40(tmpLoadRequest) or tmpLoadRequest.fortyBack);// PAR 21746 in this case fortyBack is correct
		isRehandle	:= tmpLoadRequest.isRehandle;
		isSOB		:= tmpLoadRequest.isSOB;
		tmpDischPort := tmpLoadRequest.getAttrDischargePort();
		if tmpDischPort = null then // PAR 25833
			tmpDischPort := tmpLoadRequest.getAttrDischargePortTS();// PAR 25833 maybe a tranship?
		endif;
		tmpCommodityGroup := tmpLoadRequest.getAttrCommodityGroup();
		if tmpDischPort &lt;&gt; null then // PAR 25833
			dischPortCode	:= tmpDischPort.code.trimPortCode; //	tmpLoadRequest.dischargePort.trimPortCode; //epr 9/10/06 par 12695
		endif;
		tmpBackendColor := Black;
	
		// if there has been a rework job over the top of the last job we need to go through all the jobs to switch to the 1 we are printing
		drawLoad := true;
	else
		tmpBackendColor := Gray;
	endif;
	
	if tmpDischRequest &lt;&gt; null then
		if self.printWorked = 2 or ( self.printWorked = 3 and tmpLoadRequest = null ) then
			tmpTheRequest := tmpDischRequest;
			isFortyFoot 	:= (self.isSlotRequest40(tmpDischRequest) or tmpDischRequest.fortyBack);
			isRehandle		:= tmpDischRequest.isRehandle;
			isSOB			:= tmpDischRequest.isSOB;
			tmpDischPort 	:= tmpDischRequest.getAttrDischargePort();
			tmpCommodityGroup 	:= tmpDischRequest.getAttrCommodityGroup();
			on Exception do app.handleDeletedObject(exception,tmpCommodityGroup, invalidCommGrp);
			if tmpCommodityGroup &lt;&gt; null then
				commodityCode:= tmpCommodityGroup.code;
				if invalidCommGrp then
					tmpCommodityGroup := null;
				endif;
			endif;
			if tmpDischPort &lt;&gt; null then
				dischPortCode := tmpDischPort.code.trimPortCode;
			else
				dischPortCode	:= tmpDischRequest.dischargePort.trimPortCode; 
			endif;
			tmpBackendColor := Black;
		
			drawDischarge := true;
		endif;
	
	endif;
	
	if tmpLoadRequest = null and tmpDischRequest = null then
		if tmpTI &lt;&gt; null then
			if tmpTI.isROB then
				//we have a remain on board
				drawRemainOnBoard := true;
			endif;
			isBackEnd := tmpSlotController.isFortyBack and tmpTI.isForty;
		endif;
	else
		isBackEnd := self.setIsBackend(tmpBay, tmpTheRequest);
	endif;

	myX1 := self.x1;
	myX2 := self.x2;
	myY1 := self.y1;
	myY2 := self.y2;

	tmpBay := theFrame.myBay;
	smallOutput := (self.printOutputStyle = PrintOutput_Small);	


	tmpScaleFactor := self.scaleFactor;
	tmpDrawFillColour := White;

	
	if isBackEnd or  self.showNoColours then
		tmpDrawFillColour := White;
		
	elseif tmpTheRequest &lt;&gt; null then
			tmpDrawFillColour := self.getFillColourForRequest(tmpTheRequest);
	elseif tmpDischPort &lt;&gt; null then		
			tmpDrawFillColour := tmpDischPort.colour;
	
	endif;
	

	if tmpDrawFillColour = NullColour then
		tmpDrawFillColour := White;
	endif;

	amSelected := false;

	self.setDrawStyleAndColors(tmpSlotController, theFrame, tmpDrawFillColour, lOuterColourUpper, lOuterColourLower);
	
	
	if drawRemainOnBoard then	
		if self.showColorOthers = ShipShowOtherColor_Hatched then
			tmpDrawFillColour := self.otherSlotColor;
			theFrame.drawFillStyle := Frame.DrawFillStyle_Cross; 
		elseif self.showColorOthers = ShipShowOtherColor_Other then
			tmpDrawFillColour := self.otherSlotColor;
		elseif self.showColorOthers = ShipShowOtherColor_None then
			tmpDrawFillColour := White;
			tmpBackendColor := White;
		endif;
	endif;

	self.theDrawFillColor := tmpDrawFillColour;
	theFrame.drawFillColor := tmpDrawFillColour;

	self.drawRectangle(theFrame, myX1, myY1, myX2, myY2, lOuterColourUpper, lOuterColourLower, true, smallOutput);
	

	if isBackEnd then			
		self.drawBackendAtt(theFrame,tmpTheRequest);
		return;
	endif;

	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	
	// ####################
	// COMMODITY &amp; DISCHARGE PORT
	cmifColour := self.allColours[self.theDrawFillColor];
	if cmifColour = null then
		create cmifColour transient;
		cmifColour.setColour(self.theDrawFillColor);
		self.allColours.add(cmifColour);
	endif;
	theColour:= cmifColour.inverseColour;
	theFrame.drawFontName := Font_Helvetica;
	
	if tmpDischPort &lt;&gt; null then
		/*if smallOutput then																																			//-TFS41218	Not print out Single letter lable for small print
				if tmpDischPort.ccodePrint.trimBlanks &lt;&gt; null then
					theLabel := tmpDischPort.ccodePrint[1:1];
				else
					theLabel := dischPortCode[1:1];
				endif;
		else
				theLabel := dischPortCode[1:3];
		endif;*/
		if not smallOutput then
			theLabel := dischPortCode[1:3];
		endif;
	else
		if tmpCommodityGroup &lt;&gt; null then
			theLabel := tmpCommodityGroup.code;
		elseif dischPortCode &lt;&gt; null then 
			theLabel := dischPortCode[1:3]; 
		endif;
	endif;
	
	self.drawColCodeLabel(theFrame, theColour,smallOutput, true,myX1, myY1,tmpScaleFactor,theLabel);
	if tmpTheRequest = null then
			return;
	endif;
	theFrame.drawFontSize := self.defaultFontSizeForAttributes;
	self.drawColCodeLoadAttributes(theFrame,tmpTheRequest,isFortyFoot,myX1,myY1, theColour,theAttribCount);
	

epilog
	self.setDefaultFont(theFrame);
	theFrame.drawWidth := 1;
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="SHP_BayDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawCurrentObject" id="0ae6edbe-0b6f-4248-974c-ec60dc4f6382">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>drawCurrentObject(_frame : SHP_BayDrawingFrame input) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theFrame: SHP_BayDrawingFrame;
	theDrawTextAlign : Integer;
	backEndPadding, 
	theColour 	: Integer;
begin

	theFrame := _frame;
	
	theDrawTextAlign := theFrame.drawTextAlign;
	
	self.isBackend := false;
	
	if self.displayMode = ShpDisplayMode_Defn then
		self.drawBayDefn(theFrame);
	elseif self.displayMode = ShpDisplayMode_Actual or 
		   self.displayMode = ShpDisplayMode_EDI then
		self.setIsBackend(theFrame.myBay, null);
		self.drawBayAct(theFrame);

	elseif self.displayMode = ShpDisplayMode_Proposed then
		self.drawBayPro(theFrame);
	elseif self.displayMode = ShpDisplayMode_ColCodeLoad then
		if self.printWorked &gt; 0 then	//08 Feb 2018	NDL	TFS 36914
			self.drawColCodeLoadWork(theFrame);
		else
			self.drawColCodeLoad(theFrame);
		endif;
	elseif self.displayMode = ShpDisplayMode_ColCodeDisch then
		self.drawColCodeDisch(theFrame);
	elseif self.displayMode = ShpDisplayMode_VoyGlobActual then
		self.setIsBackend(theFrame.myBay, null);
		self.drawBayAct(theFrame);
	elseif self.displayMode = ShpDisplayMode_VoyGlobProposed then
		self.drawBayPro(theFrame);
	else
		app.raiseCMException2(ERR_INVALID_VALUE,"Drawing Mode", "Drawing Mode " &amp; self.displayMode.String &amp; " Is Invalid, it must be reset",null,null);
		return;
	endif;

epilog
	// Reset to how it was before drawing attributes
	theFrame.drawTextAlign := theDrawTextAlign;
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;

end;</source>
        <Parameter name="_frame" type="SHP_BayDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawHold" id="8cf9b18c-716f-4ca2-94e7-f0cd0c2e3338">
        <updating/>
        <source>drawHold(_hold : CM_Hold; _holdX, _holdY : Integer; _bay : CM_Bay; _colour : Integer; _numBays : Integer io) updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 21/05/2015	cnwdap1		PAR #36269 TFS 331 Visual Display Of Stack Weights
vars
	theHoldArray		: CM_HoldArray;
	tmpHold				: CM_Hold;
	tmpBay				: CM_Bay;
	tmpCell				: CM_CellDefn;
	theRow,
	theCol,
	colEnd,
	tmpBayWidth,
	tmpBayHeight,
	numColumns,
	numSyncs		: Integer;
	cellX,
	bayX,
	bayY		: Real;
	tmpForm			: SHP_VoyageAreaForm2;
	bayFrame		: SHP_BayDrawingFrame;
	theBays : CM_BayArray;
	
begin

	tmpForm := self.myVoyageAreaForm;

	if self.drawHoldVertical then
		numColumns := 1;
	elseif self.myVoyage.myCellularVoyageStructure.hasTripleBays then
		numColumns := 3;
	else
		numColumns := 2;
	endif;
	
	bayX := _holdX;
	bayY := _holdY;
	tmpBayWidth := self.bayWidth;
	tmpBayHeight := self.bayHeight;

	theRow := 0;
	theCol := 1;
	
	create theBays transient; // PAR 8715. Reversed bays if flipped port/starboard, but not vertical
	
	beginLoad;
	if self.drawInReverse and not self.drawHoldVertical then // PAR 8715. 
		foreach tmpBay in _hold.allBays reversed do // PAR 8715. 
			theBays.add(tmpBay); // PAR 8715. 
		endforeach; // PAR 8715. 
	else
		_hold.allBays.copy(theBays); // PAR 8715. 
	endif;
	
	foreach tmpBay in theBays do // PAR 8715. 
	
		if tmpForm.selectMode = SHP_VoyageAreaForm2.SelectModeMulti then
			if not tmpForm.allSelectedBays.includes(tmpBay.CM_BayVoyage) then
				continue;
			endif;
		else
			if _bay &lt;&gt; null and tmpBay &lt;&gt; _bay then
				// select individual bays
				continue;
			endif;
		endif;
		tmpForm.modalDialogUpdateInfo('Drawing Bay ' &amp; tmpBay.id);
		
		bayFrame := tmpForm.getBayDrawingFrame(_numBays);
		
		bayFrame.init(tmpBay, bayX, bayY, tmpBayWidth, tmpBayHeight, _colour, self);
		bayFrame.drawSelf(self,true,true);
		
		theCol := theCol + 1;
		if theCol &gt; numColumns then
			theCol := 1;

			bayX := _holdX;
			//bayY := bayY + tmpBayHeight;		// PAR #36269
			bayY := bayY + tmpBayHeight;		// PAR #36269 Allow for 2 more rows of weights
		else
			bayX := bayX + tmpBayWidth;
		endif;

		bayFrame.visible := true;

	endforeach;

epilog
	delete theBays;
	endLoad;
end;</source>
        <access>protected</access>
        <Parameter name="_hold" type="CM_Hold"/>
        <Parameter name="_holdX" type="Integer"/>
        <Parameter name="_holdY" type="Integer"/>
        <Parameter name="_bay" type="CM_Bay"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_numBays" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawHoldSeqSheet" id="ff887442-20eb-4e15-8e03-db2712cdda68">
        <updating/>
        <source>drawHoldSeqSheet(_hold : CM_Hold; _holdX, _holdY : Integer; _bay : CM_Bay; _colour : Integer; _numBays : Integer io;
					_bayFrame : SHP_BayDrawingFrame input; _onDeck : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theHoldArray		: CM_HoldArray;
	tmpHold				: CM_Hold;
	tmpBay				: CM_Bay;
	tmpCell				: CM_CellDefn;
	theRow,
	theCol,
	colEnd,
	tmpBayWidth,
	tmpBayHeight,
	numColumns,
	numSyncs		: Integer;
	cellX,
	bayX,
	bayY		: Real;
	bayFrame		: SHP_BayDrawingFrame;
	onDeck, underDeck : Boolean;
begin

	onDeck := _onDeck;
	underDeck := not _onDeck;

	if self.drawHoldVertical then
		numColumns := 1;
	elseif self.myVoyage.myCellularVoyageStructure.hasTripleBays then
		numColumns := 3;
	else
		numColumns := 2;
	endif;
	
	bayX := _holdX;
	bayY := _holdY;
	tmpBayWidth := self.bayWidth;
	tmpBayHeight := self.bayHeight;

	theRow := 0;
	theCol := 1;
	
	beginLoad;

	foreach tmpBay in _hold.allBays do
	
		if _bay &lt;&gt; null and tmpBay &lt;&gt; _bay then
			// select individual bays
			continue;
		endif;

		
		bayFrame := _bayFrame;
		
		bayFrame.init(tmpBay, bayX, bayY, tmpBayWidth, tmpBayHeight, _colour, self);
		bayFrame.setLeftRightCell(not _onDeck,null,null);
		bayFrame.drawSelf(self,onDeck, underDeck);
		
		theCol := theCol + 1;
		if theCol &gt; numColumns then
			theCol := 1;

			bayX := _holdX;
			bayY := bayY + tmpBayHeight;
		else
			bayX := bayX + tmpBayWidth;
		endif;

		bayFrame.visible := true;

	endforeach;

epilog
	endLoad;
end;</source>
        <access>protected</access>
        <Parameter name="_hold" type="CM_Hold"/>
        <Parameter name="_holdX" type="Integer"/>
        <Parameter name="_holdY" type="Integer"/>
        <Parameter name="_bay" type="CM_Bay"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_numBays" type="Integer" usage="io"/>
        <Parameter name="_bayFrame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="_onDeck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawJobBoundary" id="39378588-6eac-4af5-be23-91134820efe4">
        <updating/>
        <source>drawJobBoundary(_slotController : CM_SlotController; theFrame: CMUI_GridAreaDrawingFrame input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	offset1, 
	offset2,
	jobColour : Integer;
	myJob : CM_VoyageJob;
	inLoadMode : Boolean;
	tmpBoundary	: Integer;
	tmpStarboardBerthed	: Boolean;
begin
	tmpStarboardBerthed := self.isStarboardBerthed;

	// ###############
	// DRAW THE JOB BOUNDARY
	inLoadMode := (self.displayMode = ShpDisplayMode_ColCodeLoad);
	
	if self.myJobSeqSheet &lt;&gt; null then  // PAR 8688
		if inLoadMode then
			if _slotController.mySlotRequestDischarge &lt;&gt; null  // PAR 8688
			and _slotController.mySlotRequestDischarge.myJob = self.myJobSeqSheet then  // PAR 8688
				inLoadMode := false;  // PAR 8688
			endif;
		else
			if _slotController.mySlotRequestLoad &lt;&gt; null  // PAR 8688
			and _slotController.mySlotRequestLoad.myJob = self.myJobSeqSheet then  // PAR 8688
				inLoadMode := true;  // PAR 8688
			endif;
		endif;
	endif;
	
	tmpBoundary := _slotController.getJobBoundary(inLoadMode);
	if tmpBoundary = 0 then
		return;
	endif;

	jobColour := Black;

	if self.scaleFactor &lt; ScaleFactor_6 then
		theFrame.drawWidth := 2;
	else
		theFrame.drawWidth := 3;
	endif;

	offset1 := 1;
	offset2 := 1;
	
	if tmpBoundary.hasBoundary(BoundaryLeft) then
		theFrame.drawLine(self.x2 - offset2,self.y1,self.x2 - offset2,self.y2,jobColour);
	endif;

	if tmpBoundary.hasBoundary(BoundaryRight) then
		theFrame.drawLine(self.x1 + offset1,self.y1,self.x1 + offset1,self.y2,jobColour);
	endif;

	if tmpBoundary.hasBoundary(BoundaryOver) then
		theFrame.drawLine(self.x1,self.y1 + offset1,self.x2,self.y1 + offset1,jobColour);
	endif;

	if tmpBoundary.hasBoundary(BoundaryUnder) then
		theFrame.drawLine(self.x1,self.y2 - offset2,self.x2,self.y2 - offset2,jobColour);
	endif;

epilog
	theFrame.drawWidth := 1;
end;</source>
        <access>protected</access>
        <Parameter name="_slotController" type="CM_SlotController"/>
        <Parameter name="theFrame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawMark" id="d226ab60-43a2-466c-97c3-5947ca361eff">
        <source>drawMark(theFrame : CMUI_GridAreaDrawingFrame input; _markColour : Integer; _markPosition : Integer; _amPrinting : Boolean; _scale : Real);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	MARK_WIDTH = 6;
	MARK_GAP = 2;
vars
	myX2, myY2	: Real;

begin
	if _markPosition &gt; _scale then
		return;
	endif;
	
	if _amPrinting then
		return;
	endif;

	myY2 := self.y2;
	myX2 := self.x2 - ((MARK_WIDTH + MARK_GAP) * (_markPosition - 1));

	theFrame.drawFillColor := _markColour;
	theFrame.drawFilledRectangle(myX2 - 1, myY2 - MARK_WIDTH, myX2 - MARK_WIDTH, myY2 - 1,_markColour);

end;</source>
        <Parameter name="theFrame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_markColour" type="Integer"/>
        <Parameter name="_markPosition" type="Integer"/>
        <Parameter name="_amPrinting" type="Boolean"/>
        <Parameter name="_scale" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawMinature" id="c788c70c-c8ee-489b-8256-c16ba42a28d7">
        <source>drawMinature(_frame: Frame input; _scale: Integer);
// ---------------------------------------------------------------------------
// Created:     08 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	OFFSET = 4;
	ANGLE = 6;
	WIDTH = 35;
	HEIGHT = 25;
vars
	tmpBayDrawingFrame	: SHP_BayDrawingFrame;
	tmpBay				: CM_Bay;
	lastLeft, lastTop,
	tmpLeft, tmpTop,
	theHatchY,
	theX1, theY1,
	theX2, theY2		: Real;
	thePoly 			: RealArray;
	colNum,
	rowNum				: Integer;

begin

	_frame.drawFillColor := 16764573;
	_frame.drawFontSize := 8;
	_frame.drawFontName := Font_MicrosoftSansSerif;
	_frame.drawTextAlign := Frame.DrawTextAlign_Center;

	create thePoly transient;

	foreach tmpBayDrawingFrame in self.allBayDrawingFramesById do
		tmpBay := tmpBayDrawingFrame.myBay;
		tmpLeft := tmpBayDrawingFrame.left;
		tmpTop := tmpBayDrawingFrame.top;
		if _scale &gt; 0 then
			theX1 := (tmpLeft / _scale).Real;
			theX2 := ((tmpLeft + tmpBayDrawingFrame.width) / _scale).Real;
			theY1 := (tmpTop / _scale).Real;
			theY2 := ((tmpTop + tmpBayDrawingFrame.height) / _scale).Real;
		else
			if tmpLeft &gt; lastLeft then
				colNum := colNum + 1;
			else
				colNum := 1;
			endif;
			if tmpTop &gt; lastTop then
				rowNum := rowNum + 1;
			endif;
			theX1 := ((colNum) * WIDTH);
			theX2 := theX1 + WIDTH;
			theY1 := ((rowNum - 1) * HEIGHT);
			theY2 := theY1 + HEIGHT;
			
			lastLeft := tmpLeft;
			lastTop := tmpTop;
		endif;

		if tmpBay = null then
			// this should never happen but if it does
			// we still want to do the above to set the
			// row/col numbers
			continue;
		endif;

		theX1 := theX1  + OFFSET;
		theX2 := theX2  - OFFSET;
		theY1 := theY1  + OFFSET;
		theY2 := theY2  - OFFSET;
		
		theHatchY := theY1 + ((theY2 - theY1) / 2) - 2;
		
		if tmpBay.allCellsOnDeck.size &gt; 0 then
			thePoly.clear;
			_frame.drawFilledRectangle(theX1, theY1, theX2, theHatchY, Blue);
			_frame.drawTextAt(tmpBay.id,((theX2 - theX1) / 2) + theX1 , theY1 + 2, Black);
		endif;

		if tmpBay.allCellsUnderDeck.size &gt; 0 then
			thePoly.clear;
			theHatchY := theHatchY + 2;
			// draw the underdeck (if any)
			thePoly.add(theX1); thePoly.add(theHatchY); // 1
			thePoly.add(theX2); thePoly.add(theHatchY); // 2
			thePoly.add(theX2); thePoly.add(theY2 - ANGLE); // 3
			thePoly.add(theX2 - ANGLE); thePoly.add(theY2); // 4
			thePoly.add(theX1 + ANGLE); thePoly.add(theY2); // 5
			thePoly.add(theX1); thePoly.add(theY2 - ANGLE); // 6
			thePoly.add(theX1); thePoly.add(theHatchY); // 7
			
			_frame.drawFilledPolygon(thePoly,Blue);
		endif;
		
	endforeach;
	
epilog
	delete thePoly;

end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_scale" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawObject" id="07f916de-3add-4934-93ab-c029081590c2">
        <updating/>
        <source>drawObject(_frame : CMUI_GridAreaDrawingFrame input; _obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBay	: CM_Bay;
	tmpBays	: CM_BaySet;
	frame	: SHP_BayDrawingFrame;
	hasMultipleBays	: Boolean;

begin
	if _obj = null then
		return;
	endif;
	
	if _obj.isKindOf(CM_SlotController) then
		tmpBay := _obj.CM_SlotController.myBayVoyage;
	elseif _obj.isKindOf(CM_SlotDefn) then
		tmpBay := _obj.CM_SlotDefn.myBay;
	elseif _obj.isKindOf(CM_HatchLid) then
		// hatch lids can span multiple bays so
		// need to redraw each one
		hasMultipleBays := true;
		create tmpBays transient;
		_obj.CM_HatchLid.allBays.copy(tmpBays);
	else
		return;
	endif;

	if (not hasMultipleBays) then
		if tmpBay &lt;&gt; null then
			frame := self.allBayDrawingFramesById[tmpBay.id];
			if frame &lt;&gt; null then
				frame.drawObject(_obj, self);
			endif;
		endif;
		return;
	endif;
	
	if tmpBays.isEmpty then
		return;
	endif;
	
	foreach tmpBay in tmpBays do
		frame := self.allBayDrawingFramesById[tmpBay.id];
		if frame = null then
			continue;
		endif;
	
		frame.drawObject(_obj, self);
	endforeach;

epilog
	delete tmpBays;
end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="drawRectangle" id="5e0f1729-e955-4041-a7a0-380b0f81463d">
        <source>drawRectangle(_frame : Frame input; x1, y1, x2, y2 : Real; _outerColourUpper, _outerColourLower : Integer; _amPrinting, _smallOutput : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     12 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpColor	: Integer;
begin

	if _amPrinting and self.myJobSeqSheet = null then
		if _smallOutput then
			tmpColor := DarkGray;
		else
			tmpColor := Black;
		endif;
		_frame.drawFilledRectangle(x1 - 1, y1 - 1, x2, y2, tmpColor);  // PAR 8717 added -1
	else
		_frame.drawFilledRectangle(x1, y1, x2, y2, Black); 
	
		_frame.drawLine(x1, y1, x2, y1, _outerColourUpper);
		_frame.drawLine(x1, y1, x1, y2 - 1, _outerColourUpper);
		_frame.drawLine(x2 - 1, y1 + 1, x2 - 1, y2, _outerColourLower);
		_frame.drawLine(x1, y2 - 1, x2 - 1, y2 - 1, _outerColourLower);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="x1" type="Real"/>
        <Parameter name="y1" type="Real"/>
        <Parameter name="x2" type="Real"/>
        <Parameter name="y2" type="Real"/>
        <Parameter name="_outerColourUpper" type="Integer"/>
        <Parameter name="_outerColourLower" type="Integer"/>
        <Parameter name="_amPrinting" type="Boolean"/>
        <Parameter name="_smallOutput" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="a5f2b3f9-3bdb-4e42-bbdd-f5e4d207946c">
        <updating/>
        <source>drawSelf(_clearSelected : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     05 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theHoldArray		: CM_HoldArray;
	tmpHold				: CM_Hold;
	tmpBay				: CM_Bay;
	theRow,
	theCol,
	holdX,
	holdY,
	maxX,
	maxY,
	holdWidth,
	holdHeight,
	numColumns,
	st, et,
	aColour,
	numBays,numBayVisible,
	firstColour			: Integer;
	bayDrawn			: Boolean;
	tmpForm			: SHP_VoyageAreaForm2;
	tmpDrawingController	: SHP_BayDrawingController;
	tmpFrame				: Frame;
	tmpStr                  : String;
	processStackArray       : ProcessStackArray;
	methodCallDesc          : MethodCallDesc;
	
begin
	
	if self.myVoyage = null then
		// no need for error here as this can be called when initialising
		return;
	endif;

	// PAR 21787
	create processStackArray transient;
	process.currentStack(processStackArray);

	if processStackArray.size &gt; 2 then
		methodCallDesc := processStackArray[3];
		tmpStr := methodCallDesc.method.qualifiedName;
	else
		tmpStr := method.qualifiedName;
	endif;
	
	self.cnStartTransaction(tmpStr[1:50]);

	st := app.clock;

	inheritMethod(_clearSelected);

	tmpForm := self.myVoyageAreaForm;
	tmpDrawingController := self;
	
	tmpDrawingController.isTwinLiftSequenceView := (tmpForm.shtSeqBtns.visible and tmpForm.btnTwinLiftCrane.value);

	foreach tmpFrame in tmpDrawingController.allBayDrawingFramesById do
		tmpFrame.visible := false;
	endforeach;

	tmpDrawingController.allBayDrawingFramesById.clear();

//	if (not self.myConfig.shipSelectByHolds) 
	if (self.myConfig.shipSelectByBayOne) 
	and (not tmpForm.btnSelBayTwin.value) then // select individual bays
		tmpBay := tmpForm.cmbBays.listObject.CM_Bay;
		if tmpBay = null then
			return;
		endif;
	endif;

	theHoldArray := self.allHoldsInDrawingOrder;
	self.setHoldsInDrawingOrder(theHoldArray);			// look at just doing when view is changed

	tmpDrawingController.setBaySizeDetails();
	tmpDrawingController.setFontDefaults();
	tmpDrawingController.setFontSizeForAttribute();
	tmpDrawingController.setDrawingPositions();
	
	numColumns := self.getNumHoldColumns();
	
	holdX := 0;
	holdY := 0;
	holdWidth := self.holdDrawWidth;
	holdHeight := self.holdDrawHeight;

	theRow := 0;
	theCol := 0;
	bayDrawn := true;

	aColour := self.BayBackgroundColour1;
	firstColour := self.BayBackgroundColour1;

	foreach tmpHold in theHoldArray do
		// we have a new hold so change the back colour and the column
		theCol := theCol + 1;
		if theCol &gt; numColumns then
			theCol := 1;
			// new hold (new column) but we are going to a different row so make sure that we start off 
			// with the contrasting cray on the new row to get the check board efect
			aColour := firstColour;
			if firstColour = self.BayBackgroundColour1 then
				firstColour := self.BayBackgroundColour2;
			else
				firstColour := self.BayBackgroundColour1;
			endif;
			
			holdX := 1;
			holdY := holdY + holdHeight + 1;
		else
			if aColour = self.BayBackgroundColour1 then
				aColour := self.BayBackgroundColour2;
			else
				aColour := self.BayBackgroundColour1;
			endif;
		endif;
		
		self.drawHold(tmpHold, holdX, holdY, tmpBay, aColour, numBays);
		
		maxX := (holdX + holdWidth).max(maxX);
		maxY := (holdY + holdHeight).max(maxY);

		if tmpForm.selectMode = SHP_VoyageAreaForm2.SelectModeMulti then
			numBayVisible := 0;
			foreach tmpBay in tmpHold.allBays do
				if tmpForm.allSelectedBays.includes(tmpBay.CM_BayVoyage) then
					numBayVisible := numBayVisible + 1;
				endif;
			endforeach;
			if numBayVisible = 1 then
				holdX := holdX + self.bayWidth;
			else		
				holdX := holdX + holdWidth;
			endif;
		else
			holdX := holdX + holdWidth;
		endif;

	endforeach;

	tmpForm.dkbGridArea.resizeScrollingFrame(maxX, maxY);

//	foreach tmpFrame in tmpDrawingController.allBayDrawingFramesById do
//		tmpFrame.SHP_BayDrawingFrame.resizeOverlayFrames(maxX, maxY);
//	endforeach;

	et := app.clock;
	tmpForm.frmStatusLine.myFrameCaption.caption := ((et - st) / 1000).Integer.String &amp; " seconds to draw";

epilog
	// PAR 21787
	if processStackArray &lt;&gt; null then
		processStackArray.purge;
		delete processStackArray;
	endif;
		
	if tmpStr &lt;&gt; null then
		self.cnEndTransaction();
	endif;
end;</source>
        <Parameter name="_clearSelected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawSelfSeqSheet" id="8a1b9533-c812-4d4d-9d5f-0704df563d61">
        <updating/>
        <source>drawSelfSeqSheet(_clearSelected : Boolean; _bayFrame : SHP_BayDrawingFrame input; _bayToDraw : CM_Bay; _onDeck : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     05 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theHoldArray		: CM_HoldArray;
	tmpHold				: CM_Hold;
	tmpBay				: CM_Bay;
	theRow,
	theCol,
	holdX,
	holdY,
	maxX,
	maxY,
	holdWidth,
	holdHeight,
	numColumns,
	st, et,
	aColour,
	numBays,
	firstColour			: Integer;
	bayDrawn			: Boolean;
//	tmpForm			: SHP_VoyageAreaForm2;
	tmpDrawingController	: SHP_BayDrawingController;
	tmpFrame				: Frame;
	
begin

	if self.myVoyage = null then
		// no need for error here as this can be called when initialising
		return;
	endif;

	st := app.clock;

	tmpDrawingController := self;
	
	foreach tmpFrame in tmpDrawingController.allBayDrawingFramesById do
		tmpFrame.visible := false;
	endforeach;

	tmpDrawingController.allBayDrawingFramesById.clear();
	tmpBay := _bayToDraw;
	
	theHoldArray := self.allHoldsInDrawingOrder;
	self.setHoldsInDrawingOrder(theHoldArray);			// look at just doing when view is changed

	tmpDrawingController.setBaySizeDetails();
	if _onDeck then
		tmpDrawingController.maxTiersUnderDeck := 0;
	else
		tmpDrawingController.maxTiersOnDeck := 0;
	endif;	
	tmpDrawingController.setFontDefaults();
	tmpDrawingController.setFontSizeForAttribute();
	tmpDrawingController.setDrawingPositions();
	numColumns := self.getNumHoldColumns();
	
	holdX := 0;
	holdY := 0;
	holdWidth := self.holdDrawWidth;
	holdHeight := self.holdDrawHeight;

	theRow := 0;
	theCol := 0;
	bayDrawn := true;

	aColour := self.BayBackgroundColour1;
	firstColour := self.BayBackgroundColour1;

	foreach tmpHold in theHoldArray do
		// we have a new hold so change the back colour and the column
		theCol := theCol + 1;
		if theCol &gt; numColumns then
			theCol := 1;
			// new hold (new column) but we are going to a different row so make sure that we start off 
			// with the contrasting cray on the new row to get the check board efect
			aColour := firstColour;
			if firstColour = self.BayBackgroundColour1 then
				firstColour := self.BayBackgroundColour2;
			else
				firstColour := self.BayBackgroundColour1;
			endif;
			
			holdX := 1;
			holdY := holdY + holdHeight + 1;
		else
			if aColour = self.BayBackgroundColour1 then
				aColour := self.BayBackgroundColour2;
			else
				aColour := self.BayBackgroundColour1;
			endif;
		endif;
		
		self.drawHoldSeqSheet(tmpHold, holdX, holdY, tmpBay, aColour, numBays, _bayFrame,_onDeck);
		
		maxX := (holdX + holdWidth).max(maxX);
		maxY := (holdY + holdHeight).max(maxY);

		holdX := holdX + holdWidth;

	endforeach;


	et := app.clock;

epilog

end;</source>
        <Parameter name="_clearSelected" type="Boolean"/>
        <Parameter name="_bayFrame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="_bayToDraw" type="CM_Bay"/>
        <Parameter name="_onDeck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawSequenceNumber" id="60267fdc-c73a-452f-9d4f-3a873b5c555d">
        <source>drawSequenceNumber(_dischRequest, _loadRequest : CM_SlotRequest; _dischJob : CM_Job; _frame : SHP_BayDrawingFrame input) protected;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------

// *************** RJS *****************************
// need to check for efficiency!!!
// 12 May 2021	navma1	Bug 51149: SNO - Planning containers with mismatching weight
vars
	aFutureMove 						: CM_FutureMove;
	tmpY, theColour 					: Integer;
	theLabel 							: String;
	chopped, pLocn 						: Boolean;
	offset, offsetY, secondLineOffset 	: Integer;
	tmpScaleFactor 						: Real;
	theWLE 								: CM_WorkListEntry;
	tmpLoadJob,
	tmpDischJob							: CM_Job;
	tmpCommodityGroup					: CM_CommodityGroup;
	tmpTI								: CM_TrackedItem;
	tmpBay								: CM_Bay;
	isPrinting,
	tmpPlanOrSeqMode, 
	amCustSeq, 
	isFortyFront						: Boolean;
	tmpDisplayMode,
	printStyle							: Integer;
	array 								: CM_TIArray;
	theWeight 							: Integer;
	location 							: CM_LocationsController;
	commodityGroup 						: CM_CommodityGroup; //cnwas3 PAR 24273
	planLength 							: Integer;
	cmifColour 							: CMIF_Colour;
begin
	amCustSeq := self.workingMode = SHP_VoyageAreaForm2.WorkMode_CustomSeq;  // PAR 8771 AKB2004AUG
	
	printStyle			:= self.printOutputStyle;
	tmpDisplayMode		:= self.displayMode;
	tmpPlanOrSeqMode	:= self.inPlaningOrSequenceMode;
	isPrinting			:= self.amPrinting;

	tmpBay := _frame.myBay;
	
	if _loadRequest &lt;&gt; null then
		tmpLoadJob	:= _loadRequest.myJob;
	endif;
	if _dischRequest &lt;&gt; null and tmpDisplayMode = ShpDisplayMode_ColCodeDisch then
		isFortyFront := self.isSlotRequest40(_dischRequest);
	elseif _loadRequest &lt;&gt; null and tmpDisplayMode = ShpDisplayMode_ColCodeLoad then
		isFortyFront := self.isSlotRequest40(_loadRequest); 
	endif;
	
	//epr TFS 3284 3/2/17 performance improvements
	cmifColour := self.allColours[self.theDrawFillColor];
	if cmifColour = null then
		create cmifColour transient;
		cmifColour.setColour(self.theDrawFillColor);
		self.allColours.add(cmifColour);
	endif;
	theColour:= cmifColour.inverseColour;
	tmpScaleFactor := self.scaleFactor;

	if tmpScaleFactor &gt;= 2 or printStyle = self.PrintOutput_Medium then
		theLabel := null;
		if tmpPlanOrSeqMode and 
		   _dischJob &lt;&gt; null and 
		   tmpDisplayMode = ShpDisplayMode_ColCodeDisch or 
		   (_frame.myJobSeqSheet &lt;&gt; null and 
		   isPrinting and 
		   tmpDisplayMode = ShpDisplayMode_ColCodeDisch) then

			if _frame.myJobSeqSheet = null 
			and not amCustSeq then  // PAR 8771 AKB2004AUG
				tmpTI := _dischRequest.getTrackedItem();
				if tmpTI &lt;&gt; null then
//					theLabel := tmpTI.plannedLocnId;
					aFutureMove := tmpTI.getFutureMovePlanned(false);
					if aFutureMove &lt;&gt; null then
						location := aFutureMove.getPrimaryLocation();
						if location &lt;&gt; null then
							theLabel := location.getFullId();
						endif;
					endif;
					
					
					if theLabel &lt;&gt; null then
						/*
						if theLabel.length &gt; 6 then
							theLabel := "PLN";
						else
							theLabel := theLabel[1 :6];
						endif;
						*/
						// 05 Jul 2012	NDl	Par 29316
						if tmpScaleFactor &lt; ScaleFactor_3 then
							planLength := 3;
						elseif tmpScaleFactor = ScaleFactor_3 then
							planLength := 5;
						else
							planLength := 6;
						endif;
						if theLabel.length &gt; planLength then
							theLabel := "PLN";
						endif;
						
						pLocn := true;
					endif;
				endif;
			endif;
	
			if (not pLocn) then
				if _frame.myJobSeqSheet &lt;&gt; null then
					tmpDischJob := _dischRequest.myJob;
					if tmpDischJob = _frame.myJobSeqSheet then // we are printing the sequence sheet DISCHARGE
						if tmpBay.isAftBay and (_dischRequest.getAttrIs40() or _dischRequest.getAttrIsBackend()) // PAR 21746 
						and not tmpBay.isForwardBay then // PAR 8810
						else
							if self.seqNumKey = null then
								theLabel := self.getSequenceNumForRequest(_dischRequest);
							else
								if _dischRequest &lt;&gt; null then
									theWLE := _dischRequest.allWorkListEntries.first;
									theLabel := theWLE.getDisplayStringForAttribute(self.seqNumKey, false);
								endif;
							endif;
						endif;			
					endif;
				else
					theLabel := self.getSequenceNumForRequest(_dischRequest);
				endif;
				pLocn := false;
			endif;
		endif;
		if tmpPlanOrSeqMode and 
		   tmpDisplayMode = ShpDisplayMode_ColCodeLoad or 
		   (_frame.myJobSeqSheet &lt;&gt; null and isPrinting) then
			if tmpLoadJob &lt;&gt; null and _frame.myJobSeqSheet = null  
			and not amCustSeq then  // PAR 8771 AKB2004AUG

				// the TI is planned here
				if _loadRequest.mySlotController.hasTIsOfMode(PLANNING_MODE) then 
					if tmpScaleFactor &lt; ScaleFactor_3 then
						theLabel := "PLN";
					elseif tmpScaleFactor = ScaleFactor_3 then
						theLabel := "PL";
					else
						theLabel := "PLND";
					endif;
					pLocn := true;
				endif;
			endif;

			if (not pLocn) and 
			   tmpLoadJob &lt;&gt; null or 
			   (_frame.myJobSeqSheet &lt;&gt; null and isPrinting) then
				if _frame.myJobSeqSheet &lt;&gt; null and 
				   tmpLoadJob &lt;&gt; _frame.myJobSeqSheet then
				else 
					// we are printing the sequence sheet LOAD
					if self.seqNumKey = null then
						theLabel := self.getSequenceNumForRequest(_loadRequest);
					else
						if _loadRequest &lt;&gt; null then
							theWLE := _loadRequest.allWorkListEntries.first;
							theLabel := theWLE.getDisplayStringForAttribute(self.seqNumKey, false);
						endif;
					endif;
					commodityGroup := _loadRequest.getAttrCommodityGroup();		//cnwas3 PAR 24273
					if tmpScaleFactor &gt;= ScaleFactor_3 and (not isPrinting) 
					and commodityGroup &lt;&gt; null		//cnwas3 PAR 24273
					and commodityGroup.hasTemp then	//cnwas3 PAR 24273
						theLabel := theLabel &amp; " !";
					endif;
				endif;
				pLocn := false;
			endif;
		endif;
			
		if theLabel &lt;&gt; null then
			self.setDefaultFont(_frame);
			if tmpScaleFactor = 2  
			or printStyle = self.PrintOutput_Large  // ### AKB added in JMT731 testing
			or printStyle = self.PrintOutput_Medium then
				if pLocn then
					_frame.drawFontSize := 6;
					offsetY := 1;
					offset := 2;
				else
					_frame.drawFontSize := 7;
					offsetY := 1;
					offset := 3;
				endif;
				tmpY := (self.y1 + offsetY).Integer;
				if printStyle = self.PrintOutput_Large then // ### AKB added in JMT731 testing
					secondLineOffset := 8;
				endif;
			elseif tmpScaleFactor = 3 then
				offsetY := 0;
				if pLocn then
					if chopped then
						_frame.drawFontSize := 6;
					else
						_frame.drawFontSize := 7;
					endif;
					offset := 2;
				else
					_frame.drawFontSize := 7;
					offset := 3;
				endif;
				tmpY := (self.y1 + offsetY).Integer;
				secondLineOffset := 8;
			elseif tmpScaleFactor = 4 then
				if pLocn then
					if chopped then
						_frame.drawFontSize := 7;
					else
						_frame.drawFontSize := 7;
					endif;
					offset := 2;
					offsetY := 1;
				else
					_frame.drawFontSize := 9;
					offsetY := 1;
					offset := 2;
				endif;
				tmpY := (self.y1 + offsetY).Integer;
				secondLineOffset := 12;
			elseif tmpScaleFactor = 6 then
				if pLocn then
					_frame.drawFontSize := 11;
					tmpY := (self.y1 + 2).Integer;
					offset := 3;
				else
					_frame.drawFontSize := 14;
					tmpY := (self.y1 + 1).Integer;
					offset := 3;
				endif;
				secondLineOffset := 16;
			elseif tmpScaleFactor = 9 then
				if pLocn then
					_frame.drawFontSize := 16;
					tmpY := (self.y1 + 2).Integer;
					offset := 3;
				else
					_frame.drawFontSize := 22;
					tmpY := (self.y1 ).Integer;
					offset := 3;
				endif;
				secondLineOffset := 24;
			endif;
			
			_frame.drawTextAt(theLabel,self.x1 + offset, tmpY,theColour); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
			
			if (_frame.myJobSeqSheet &lt;&gt; null and isPrinting) then // printing SeqSheet
				// ### Add indicator if a 40 front slot
				if tmpBay.isForwardBay 
				and isFortyFront then
					_frame.drawFontSize := 6;
					secondLineOffset := 10;
					offset := 13;
					_frame.drawTextAt("4",self.x1 + offset, tmpY + secondLineOffset,theColour);
				endif;
			endif;
			
			// ### NOTE tmpScaleFactor = 2 when printing SeqSheet
			if tmpDisplayMode = ShpDisplayMode_ColCodeLoad and tmpScaleFactor &gt; 2 then				
				tmpCommodityGroup := _loadRequest.getAttrCommodityGroup();	
				  if tmpCommodityGroup &lt;&gt; null then
					 theLabel := tmpCommodityGroup.code;
					_frame.drawTextAt(theLabel,self.x1 + offset, tmpY + secondLineOffset,theColour);
				endif;
			endif;
			//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. tmpScaleFactor " &amp; tmpScaleFactor.String);			
			// ### NOTE tmpScaleFactor = 2 when printing SeqSheet
			if tmpPlanOrSeqMode and 
			   tmpLoadJob &lt;&gt; null and 
			   tmpDisplayMode = ShpDisplayMode_ColCodeLoad and 
			   tmpScaleFactor &gt; 2 and 
			   pLocn then
				if tmpScaleFactor = 2 then
					offset := -2;
				endif;
				//theWeight := _loadRequest.getWeight();               //12.05.2021 navma1 #51149
				theWeight   := _loadRequest.getWeightRounded();        //12.05.2021 navma1 #51149
				if theWeight &lt;&gt; null then
					theLabel := theWeight.asStringJMT;
					_frame.drawTextAlign := Frame.DrawTextAlign_Right;
					_frame.drawTextAt(theLabel,self.x2- 2, tmpY ,theColour);
					_frame.drawTextAlign := Frame.DrawTextAlign_Left;
				endif;
			endif;
		endif;
	endif;
epilog
	delete array;
end;</source>
        <access>protected</access>
        <Parameter name="_dischRequest" type="CM_SlotRequest"/>
        <Parameter name="_loadRequest" type="CM_SlotRequest"/>
        <Parameter name="_dischJob" type="CM_Job"/>
        <Parameter name="_frame" type="SHP_BayDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawTI" id="5bbb90ec-8d3b-4eaa-87da-0c999a862563">
        <updating/>
        <source>drawTI(_theTI : CM_TrackedItem; _theGridAttributes : CMUI_GridAttributes input;
		_x1, _y1, _x2, _y2 : Real;
		_frame : SHP_BayDrawingFrame input;  _lc : CM_LocationsController) updating, protected;
// ---------------------------------------------------------------------------
// Created:		January  2003 By Andrew Bishop cnwab1
//
// Purpose:	

// Modified:

// 				14/07/2009  cnwas3  PAR 15506	
// ---------------------------------------------------------------------------
// 11/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
// 20/04/2017 	cnwrh7  TFS3323       #Ship Release Request Scenario Issue
// 21/03/2018 	Jlgns1	Bug 37525: SNO - (re Ticket 36886): Header in bay plan printing
// 11/11/2019	jlgdap1	TFS 46405 AT Flat Rack and OOG in LOLO Planning Screen
// 17/12/2019	JLGNS1	Bug 48077: SNO - LOLO Planning issue		
vars
	theFrame: SHP_BayDrawingFrame;
	lTIColour, theInverseColour, theCharacterWidth : Integer;
	lDisplayMode,idx,lViewMode : Integer;
	lFactor : Real;
	tmpStr,
	theMainCode, isoDesc : String;
	aPort : CM_Port;
	theTI : CM_TrackedItem ;
	iAmPrinting : Boolean;
	invalidVoyage : Boolean;			//cnwas3  PAR 15506
	theWeight : Decimal[8,2];
	tmpSlotDefn	: CM_SlotDefnVoyage;
	tmpSlotRequest	: CM_SlotRequest;
	tmpJob			: CM_Job;
	tmpNum,
	printStyle		: Integer;
	iso : CM_ISOType;
	theISOCode : String;
	theTempString : String;
	tmpTemp		: Real;
	voyage		: CM_Voyage;
	cmifColour : CMIF_Colour;
	isoGroup : CM_ISOTypeGroup;																											//+TFS3323
	dispMode, workMode : Integer;			// TFS 46405
begin

	printStyle := self.printOutputStyle;
	if self.inPlaningOrSequenceMode then
		if self.displayMode = ShpDisplayMode_ColCodeLoad then
			tmpSlotRequest	:= tmpSlotDefn.mySlotController.mySlotRequestLoad;
		elseif self.displayMode = ShpDisplayMode_ColCodeDisch then
			tmpSlotRequest	:= tmpSlotDefn.mySlotController.mySlotRequestDischarge;
		endif;
		if tmpSlotRequest = null then
			return;
		endif;
		tmpJob	:= tmpSlotRequest.myJob;
		if tmpJob &lt;&gt; null then
			if (not tmpJob.areWLEsAllStatus(WLE_COMPLETED)) then
				theTI := tmpSlotRequest.getTrackedItem();
			endif;
		endif;
	else
		theTI := _theTI;
	endif;
	
	if theTI = null then
		return;
	endif;

	if CM_Container.hasInstance(theTI) then
		tmpTemp := theTI.CM_Container.getTemperature;
		if tmpTemp &lt;&gt; NULL_TEMPERATURE then
			on Exception do app.handleDeletedObject(exception, voyage, invalidVoyage); //cnwas3 PAR 15506
			voyage := self.myVoyage;			// 11/03/2011 cnwmh5 #27142
			if voyage.myOperator &lt;&gt; null // adm 150708 Par 17203
				and voyage.myOperator.displayTempFahrenheit then // PAR 9875
					theTempString := theTI.getDisplayTemperature(false, false); // PAR 9875
			else
				theTempString := theTI.getDisplayTemperature(false, true); // PAR 9875
			endif;
		endif;
	endif;
		
	if self.shipShowISOType then
		theISOCode := theTI.getISOType();
	else																														//+TFS3323 Starts The parameter is off then display ISOTypeGroup
		if  theTI.isoTypeGroup  = null then
			if theTI.isTBAorIsRRP then
				isoGroup := theTI.getISOGroupFromReleasedRequest();
				if isoGroup &lt;&gt; null then
					theISOCode := isoGroup.description;
				endif;
			endif;
		else
			theISOCode := theTI.isoTypeGroup;
		endif;
	endif;																															//+TFS3323 Ends
	
	theFrame := _frame;
	iAmPrinting := self.amPrinting;
	
	lFactor := self.scaleFactor;
	lDisplayMode := self.displayMode;
	lViewMode := self.viewMode;

	lTIColour := self.theDrawFillColor;
	
	//epr TFS 3284 3/2/17 performance improvements - see if we already have the inverse color
	cmifColour := self.allColours[lTIColour];
	if cmifColour = null then
		create cmifColour transient;
		cmifColour.setColour(lTIColour);
		self.allColours.add(cmifColour);
	endif;
	theInverseColour:= cmifColour.inverseColour;
	
	theFrame.drawFillColor := lTIColour;

	// #############
	if lFactor &lt; 2 and (not iAmPrinting) then
		return;
	endif;

	if lViewMode = VIEW_COMMODITY then
		theMainCode := theTI.commodityGroup;
	elseif lViewMode = TI_ColourMode_ISOTypeGroup  then
		theMainCode := theISOCode; //theTI.isoTypeGroup;
	elseif lViewMode = VIEW_OPERATOR then
		theMainCode := theTI.operatorCode;
	elseif lViewMode = VIEW_DISPORT then
		theMainCode := theTI.dischargePort;
		if theMainCode.length &gt;= 5 then
			theMainCode := theMainCode.trimPortCode;
		endif;
	elseif lViewMode = VIEW_LOADPORT then
		theMainCode := theTI.loadPort;
		if theMainCode.length &gt;= 5 then
			theMainCode := theMainCode.trimPortCode;
		endif;
	elseif lViewMode = VIEW_WEIGHT then
		theWeight := theTI.totalWeight / 1000;
		theMainCode := theWeight.rounded.asStringJMT;
	elseif lViewMode = VIEW_STATUS then
		if CM_Container.hasInstance(theTI) then
			theMainCode := theTI.CM_Container.contentsStatusCode();
		endif;
	elseif lViewMode = VIEW_TEMPERATURE then
		if CM_Container.hasInstance(theTI) then
			tmpTemp := theTI.CM_Container.getTemperature;
			if tmpTemp &lt;&gt; NULL_TEMPERATURE then
				theMainCode := 	theTempString; // PAR 9875
			endif;
		endif;
	else
		theMainCode := theTI.commodityGroup;
	endif;	

	if (not self.inPlaningOrSequenceMode) then
		if (iAmPrinting and printStyle = self.PrintOutput_Large) then
			theFrame.drawTextAt(theISOCode &amp; "   " &amp; theTI.operatorCode, _x1 + 2, _y1 + self.getLineHeight(0), theInverseColour); //Bug 37525
			theFrame.drawTextAt(theTI.id, _x1 + 2, _y1 + self.getLineHeight(1), theInverseColour);							      //Bug 37525
			
			tmpStr := theTempString; // PAR 9875
			
			if tmpStr &lt;&gt; null then //self.tiInfoReeferTemp &lt;&gt; null then
				theFrame.drawTextAt(theTI.commodity, _x1 + 2, _y1 + self.getLineHeight(2), theInverseColour);					 //Bug 37525
				theFrame.drawTextAt(tmpStr, _x1 + 30, _y1 + self.getLineHeight(2), theInverseColour);							 //Bug 37525
			else
				theFrame.drawTextAt(theTI.commodityGroup, _x1 + 2, _y1 + self.getLineHeight(2), theInverseColour);				 //Bug 37525
			endif;
			//epr 11/9/06 par 12436 - changed to 3 char port code
			tmpStr := theTI.dischargePort.trimPortCode;
			if tmpStr &lt;&gt; null then
				if self.columnWidth = self.PrintScaleLargeWidth then // PAR 22952
					//epr 11/9/06 par 12436 - changed to 3 char port code
					theFrame.drawTextAt(tmpStr &amp; " X " &amp; theTI.loadPort.trimPortCode &amp; "   " &amp; (theTI.totalWeight/1000).rounded.String, _x1 + 2 , _y1 + self.getLineHeight(3), theInverseColour);			 //Bug 37525
				else
					theFrame.drawTextAt(tmpStr &amp; " x " &amp; theTI.loadPort.trimPortCode &amp; " " &amp; (theTI.totalWeight/1000).rounded.String, _x1 + 2 , _y1 + self.getLineHeight(3), theInverseColour); // PAR 22952 //Bug 37525
				endif;
			endif;
			if self.printSeparateODUD then		// 29/11/17 MAP TFS7494
				self.y1 := self.y1 + 10;
				//self.drawIcons(theTI, theFrame, _x1, _y1, theInverseColour);			// TFS 46405
				self.drawIcons(theTI, theFrame, _x1, _y1, theInverseColour, false);		// TFS 46405
			endif;

		elseif lFactor = 20  then
			theFrame.drawFontSize := 16;
			theFrame.drawTextAt(theTI.id, _x1 + 5, _y1 + 5,theInverseColour);
			theFrame.drawFontSize := 10;
			iso := theTI.getISOTypeObject();
			if iso = null then
				isoDesc := theTI.getISOType();
			else
				isoDesc := iso.getDisplayDetails(false);
			endif;

			theFrame.drawTextAt(isoDesc[1:20],_x1 + 5, _y1 + 30, theInverseColour);
			theFrame.drawTextAt(theTI.operatorCode &amp; " - " &amp; theTI.operatorDescription[1:15],_x1 + 5, _y1 + 50, theInverseColour);
			theFrame.drawTextAt(theTI.commodity &amp; " - " &amp; theTI.getCommodityDesc(),_x1 + 5, _y1 + 70, theInverseColour);

			tmpStr := theTI.dischargePort.trimPortCode;
			if tmpStr &lt;&gt; null then
				theFrame.drawTextAt(tmpStr &amp; " X " &amp; theTI.loadPort.trimPortCode &amp; "   " &amp; (theTI.totalWeight/1000).rounded.String,_x1 + 5 , _y1 + 90, theInverseColour);
			endif;

		elseif lFactor = CMUI_GridDrawingController.ScaleFactor_9  then
//			theFrame.drawTextAt(theTI.isoTypeGroup &amp; "   " &amp; theTI.operatorCode,_x1 + 4, _y1 + 2, theInverseColour);
			theFrame.drawTextAt(theISOCode &amp; "   " &amp; theTI.operatorCode,_x1 + 4, _y1 + 2, theInverseColour);
			theFrame.drawTextAt(theTI.id, _x1 + 2, _y1 + 15,theInverseColour);

			tmpStr := theTempString; // PAR 9875
			if tmpStr &lt;&gt; null then //self.tiInfoReeferTemp &lt;&gt; null then
				theFrame.drawTextAt(theTI.commodity, _x1 + 2, _y1 + 30, theInverseColour);
				theFrame.drawTextAt(tmpStr, _x1 + 40, _y1 + 30, theInverseColour);
			else
				//epr par 32804 22/1/14
				tmpStr:=theTI.commodityGroup;
				if tmpStr = null then
					tmpStr:=theTI.commodity;
				endif;
				tmpStr:=tmpStr &amp; " " &amp;  theTI.getHazardsAsString;
				theFrame.drawTextAt(tmpStr, _x1 + 2, _y1 + 30, theInverseColour);
			endif;

			tmpStr := theTI.dischargePort.trimPortCode;
			if tmpStr &lt;&gt; null then
				theFrame.drawTextAt(tmpStr &amp; " X " &amp; theTI.loadPort.trimPortCode &amp; "   " &amp; (theTI.totalWeight/1000).rounded.String,_x1 + 2 , _y1 + 45, theInverseColour);
			endif;

		elseif lFactor = CMUI_GridDrawingController.ScaleFactor_6 then
//			theFrame.drawTextAt(theTI.isoTypeGroup &amp; " " &amp; theTI.operatorCode,_x1 + 4, _y1 + 2, theInverseColour);
			theFrame.drawTextAt(theISOCode &amp; " " &amp; theTI.operatorCode,_x1 + 4, _y1 + 2, theInverseColour);
			tmpStr := theTI.id;
			tmpNum := tmpStr.length;
			if tmpNum &lt;= 4 then
				theFrame.drawTextAt(tmpStr,_x1 + 2, _y1 + 15, theInverseColour);
			else
				if theTempString.length &gt; 5 then
					theTempString := theTempString[1:5];
				endif;
				theFrame.drawTextAt(tmpStr[1:4] &amp; " " &amp; theTempString,_x1 + 2, _y1 + 15, theInverseColour);
				theFrame.drawTextAt("- " &amp; tmpStr[5:end],_x1 + 5, _y1 + 27, theInverseColour);
			endif;

		elseif lFactor = CMUI_GridDrawingController.ScaleFactor_4 then
			theFrame.drawTextAt(theMainCode,_x1 + 2, _y1 + 2, theInverseColour);

		elseif lFactor = CMUI_GridDrawingController.ScaleFactor_3 then
			theFrame.drawTextAt(theMainCode,_x1 + 2, _y1 + 2, theInverseColour);

		elseif (amPrinting and printStyle = self.PrintOutput_Small) then
			if lViewMode = VIEW_DISPORT or lViewMode = VIEW_LOADPORT then
				theMainCode := theTI.dischargePort.trimPortCode;
				//aPort := app.myRoot.allPorts[theMainCode];
				aPort := app.myRoot.allPorts[theMainCode];
				if aPort &lt;&gt; null then
					if aPort.ccodePrint.trimBlanks &lt;&gt; null then
						theMainCode := aPort.ccodePrint.trimBlanks;
					endif;
				endif;
			endif;
			theFrame.drawTextAt(theMainCode[1:1], _x1, _y1 - 2, theInverseColour);

		elseif lFactor = CMUI_GridDrawingController.ScaleFactor_2 or (amPrinting and printStyle = self.PrintOutput_Medium)  then
			if theMainCode.length &gt;= 3 then
				theFrame.drawTextAt(theMainCode[1:3],_x1 + 1, _y1 + 1 , theInverseColour);
			else
				theFrame.drawTextAt(theMainCode,_x1 + 4, _y1 + 2, theInverseColour);
			endif;
		endif;
	endif;

	// work out the width of the rectangle and split up, to get the even width for the attribute characters
	theCharacterWidth := ((_x2 - 1 - _x1) / 3 ).Integer;

	// #############
	if lFactor &lt; CMUI_GridDrawingController.ScaleFactor_2 and not (printStyle = self.PrintOutput_Medium and iAmPrinting) then
		return;
	endif;
	
	idx := 1;
	if (iAmPrinting and printStyle = self.PrintOutput_Large) then
		return;
	endif;

	// Draw the attributes (if any)
	//self.drawIcons(theTI, theFrame,_x1,y1, theInverseColour);													// TFS 46405
//	self.myVoyageAreaForm.getShipVoyFormDispAndWorkModes(dispMode, workMode);									// TFS 46405
//	self.drawIcons(theTI, theFrame,_x1,y1, theInverseColour, workMode = self.myVoyageAreaForm.WorkMode_Plan);	// TFS 46405
	self.drawIcons(theTI, theFrame,_x1,y1, theInverseColour, self.workingMode = self.myVoyageAreaForm.WorkMode_Plan);	//Bug 48077
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theGridAttributes" type="CMUI_GridAttributes" usage="input"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_frame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="drawTierPileWeight" id="1ca9c49e-652d-444a-bd7c-c9a0b202d7c2">
        <updating/>
        <source>drawTierPileWeight(_frame : SHP_BayDrawingFrame input; _bay : CM_Bay; _ordinalDeck, _ordinalTier:Integer; _x, _y : Real) updating;
// ---------------------------------------------------------------------------
// Created:     10 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theWeight	: Integer;
	theWeightStr	: String;
	tmpX		: Real;
begin

	if (not CM_BayVoyage.hasInstance(_bay)) then
		return;
	endif;

	theWeight := _bay.CM_BayVoyage.getTierPileWeightRounded(self.displayMode, _ordinalDeck, _ordinalTier, self.myVoyageInterTerminal);

	theWeightStr := theWeight.asStringJMT;
	
	tmpX := _x + self.getTextExtent999(_frame);
	_frame.drawTextAlign := Window.DrawTextAlign_Right;
	_frame.drawTextAt(theWeightStr, tmpX, _y, Black);
	_frame.drawTextAlign := Window.DrawTextAlign_Left;
	
end;</source>
        <Parameter name="_frame" type="SHP_BayDrawingFrame" usage="input"/>
        <Parameter name="_bay" type="CM_Bay"/>
        <Parameter name="_ordinalDeck" type="Integer"/>
        <Parameter name="_ordinalTier" type="Integer"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
