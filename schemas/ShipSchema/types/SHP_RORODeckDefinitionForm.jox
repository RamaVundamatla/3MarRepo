    <JadeMethod name="getFrameForLayer" id="9a08a63c-dd35-459b-946e-9c32dad23657">
        <source>getFrameForLayer(_layer : CM_DeckLayerLayout) : CMUI_PointDrawingFrame;
// ---------------------------------------------------------------------------
// Created:     07 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	obj : Object;
	layerFrame : CMUI_PointDrawingFrame;
begin
	
	foreach obj in self.allBackgroundFrames discreteLock do
		if obj = null then
			continue;
		endif;
		
		layerFrame := obj.CMUI_PointDrawingFrame;
		if layerFrame.userObject = _layer then
			return layerFrame;
		endif;
	
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
        <ReturnType type="CMUI_PointDrawingFrame"/>
    </JadeMethod>
