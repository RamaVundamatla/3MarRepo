    <JadeMethod name="doDataComparison" id="f635721b-dd4b-49c2-9ec1-60e254f4f5fe">
        <source>doDataComparison(_yaData: SelfType): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
10 September 2008	consw1	Initial creation

*/

vars

begin

	// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1	default value is stored as null pattern - allow match of this
	if self.pattern = null then
		if _yaData.isKindOf(CM_YADataPattern) and
		   _yaData.CM_YADataPattern.pattern = null then
			return true;
		endif;
		return false;
	endif;

	if self.myCriteriaType.getPatternType &lt;&gt; null then
		if _yaData.isKindOf(CM_YADataObjects) then	//10 Feb 2016	NDL	Par 37510
			return self.doPatternComparison(_yaData);
		else
			return self.doPatternComparison(_yaData.CM_YADataPattern);
		endif;
	endif;

	return false;

epilog

end;</source>
        <Parameter name="_yaData" type="SelfType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDataComparisonWithResolution" id="55a2cf87-b7b5-4fb0-bd38-264950fbd9bd">
        <source>doDataComparisonWithResolution(_yaData: CM_YAData): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
15 August 2008	consw1	Initial creation

*/

vars

begin
	if self.myCriteriaType.getPatternType &lt;&gt; null then
		return self.doPatternComparison(_yaData.CM_YADataPattern);
	endif;

	//  Have not coded this method for performance reasons.
	//  This method is being used to compare search criteria data (self) to collection of real criteria data.
	//  Should resolve search criteria data before doing search - i.e. to avoid repeat a resolution each comparison.
	app.raiseUnexpectedProgramError(class.name, method.name, 'Unexpected comparison');
	
	return false;

epilog

end;</source>
        <Parameter name="_yaData" type="CM_YAData"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPatternComparison" id="44eda438-e7c0-4f0f-a6b6-6e9b1cb78f3c">
        <source>doPatternComparison(_yaData: CM_YADataPattern) : Boolean;

/*

Purpose:			Included for comparison of container lengths.
					Container lengths are stored as patterns.

Parameters:			

Return Value:		


Date				Who		Reason
10 September 2008	consw1	Initial creation

*/

vars
	token			: String;
	pattern			: CMIF_YAPattern;
	searchTokens 	: StringArray;
	dataTokens 		: StringArray;
	
begin

	// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1	default value is stored as null pattern - allow match of this
	if self.pattern = null then
		 if _yaData.pattern = null then
			return true;
		endif;
		return false;
	endif;

	//  Get tokens for search pattern

	create pattern transient;
	create searchTokens transient;
	pattern.setPattern( self.pattern, CMIF_YAPattern.YAPattern_Wildcard );
	//  Patterns not handled yet
	if pattern.hasWildcard() then
		return true;
	endif;
	pattern.getTokens(pattern.pattern, searchTokens );
	if searchTokens.isEmpty then
		return true;
	endif;
	delete pattern;
	
	//  Get tokens for yard allocation

	create pattern transient;
	create dataTokens transient;
	pattern.setPattern( _yaData.pattern, CMIF_YAPattern.YAPattern_Wildcard );
	//  Patterns not handled yet
	if pattern.hasWildcard() then
		return true;
	endif;
	pattern.getTokens(pattern.pattern, dataTokens );
	delete pattern;

	//  Do the comparison

	foreach token in dataTokens do
		if searchTokens.includes( token ) then
			return true;
		endif;
	endforeach;

	return false;
	
epilog
	delete pattern;
	delete searchTokens;
	delete dataTokens;
end;</source>
        <Parameter name="_yaData" type="CM_YADataPattern"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
