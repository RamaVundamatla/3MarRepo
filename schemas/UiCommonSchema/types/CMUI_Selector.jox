    <JadeMethod name="doRemoveQueryLine" id="efcbe97b-fda0-4223-a413-3703fa6f4bfe">
        <source>doRemoveQueryLine();
// ---------------------------------------------------------------------------
// Created:     17 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx		: Integer;
	crit	: CM_SelectorCriteriaLine;	
	tblSheet: JadeTableSheet;
begin
	tblSheet := self.tblCriteria.accessSheet(self.tblCriteria.topSheet);		// 11/6/19 MAP TFS45107
	//PAR 18087
	idx := tblSheet.row;
	if idx = 0 or not tblSheet.accessRow(idx).selected then
		app.msgBox(app.getErrorString2(CMUI_Please_Select, app.getErrorString(CMUI_Selector_Line), app.getErrorString(Delete)), app.getErrorString(CMUI_Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	crit := tblSheet.accessRow(idx).itemObject.CM_SelectorCriteriaLine;
	if not self.validateCriteriaLineRemoval(crit) then
		return;
	endif;

	delete crit;
	tblSheet.removeItem(idx);

	 // ### TFS BUG 61210 27FEB2024 NAVAB1
	 self.cmbAttr.listIndex := -1;
	 self.cmbOperator.listIndex := -1;
	 self.cmbArgument.listIndex := -1;
	 self.txtArgument.text := "";
	 self.txtArgument1.text := "";
	 
end;</source>
    </JadeMethod>
    <JadeMethod name="doRemoveSheet" id="d105a87e-8cb1-440d-910f-216a868044c4">
        <source>doRemoveSheet() protected;
// ---------------------------------------------------------------------------
// Created:     22 January 2004	cnwth2
//
// Purpose:     
//		
// 25/03/2024   navrv30		Bug 62640: MTN - Selector Translations	 
// ----------   ----------  --------------------------------------------------
vars
	sht			: JadeTableSheet;
	tbl			: CM_DataTable;
	idx			: Integer;
begin
	tbl := self.tblCriteria;
	sht := tbl.accessSheet(self.tblCriteria.topSheet);
	if sht.caption = self.SHEET_ONE_NAME then
		// 25/03/2024   navrv30		Bug 62640
		app.msgBox(app.getErrorString(Not_delete_first_sheet),app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	delete sht.itemObject;
	delete sht;
	
	foreach idx in 2 to tbl.sheets do
		sht:= tbl.accessSheet(idx);
		sht.caption := 'or Sheet ' &amp; idx.String;
	endforeach;

	self.btnRemoveSheet.enabled := (not self.tblCriteria.sheets = 1);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRemoveTIObject" id="fa28e167-ad9a-4efc-aceb-170d035c8ce3">
        <updating/>
        <source>doRemoveTIObject(_ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	row		: Integer;
	
	endRow	: Integer;
	obj		: Object;
	tbl		: CM_DataTable;
begin

	tbl := self.tblResults;
	endRow := tbl.rows;
	
	tbl.findObjectInRow(_ti,row);
	
	//Remove row and step back one to check if the following object is to be removed.
	tbl.removeItem(row);
			
	if self.myEnqController.allObjects.includes(_ti) then
		self.myEnqController.allObjects.remove(_ti);
	endif;

// cnwdad1 20/12/2005 - PAR #11151.
//	self.lblItemsFound.caption := (tbl.rows - tbl.fixedRows).String &amp; ' ' &amp; $CMUI_Selector_Items_Displayed;
	self.updateStatus();
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doRemoveTIs" id="2b706813-4d83-490b-9c69-4303aa62e1cb">
        <updating/>
        <source>doRemoveTIs() updating;
// ---------------------------------------------------------------------------
// Created:     04 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	row		: Integer;
	
	endRow	: Integer;
	obj		: Object;
	tbl		: CM_DataTable;
begin
	tbl := self.tblResults;
	endRow := tbl.rows;
	foreach row in endRow to tbl.fixedRows step -1 do
		if tbl.accessRow(row).selected then
			obj := tblResults.accessRow(row).itemObject;
			//Remove row and step back one to check if the following object is to be removed.
			tbl.removeItem(row);
			
			if self.myEnqController.allObjects.includes(obj) then
				self.myEnqController.allObjects.remove(obj);
			endif;
			
		endif;
	endforeach;

// cnwdad1 20/12/2005 - PAR #11151.
//	self.lblItemsFound.caption := (tbl.rows - tbl.fixedRows).String &amp; ' ' &amp; $CMUI_Selector_Items_Displayed;
	self.updateStatus();
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="c44696f5-e9a7-4a15-9986-f98c03e6f54f">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     03 March 2003		cnwth2	
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//	6/5/2010	cnwjo3		par 23349.  With the new ToDo Complete-XXXX combo box needed to be resized		 
//	31/01/2011	cnwdap1		PAR #26830 CCMS 2013 Allow queue move from selector
//  13/12/2019	jlgdap1		TFS 48011 PNL Selector reports missing
// -----------------------------------------------------------------------------
constants
	Gap = 5;
	ArgumentWidth : Integer = 325;
vars
	col				: Integer;
	numColumns		: Integer;
begin
	

	inheritMethod();
	//epr par 33058 30/4/14 - tidying up some resizing issues - status bar was overlapping the results table and query list
	self.sptMain.top := self.frmToolbar.height;
	self.sptMain.height := self.clientHeight - self.frmToolbar.clientHeight - self.frmStatusLine.clientHeight;
	//self.cmbArgument.width := self.cmbArgument.parent.width - 270;
	self.cmbArgument.width := self.cmbArgument.parent.width - ArgumentWidth;
	//self.cmbArgument.left := self.cmbArgument.parent.left;
	self.cmbAttr.width := 200;
	self.cmbOperator.left := self.cmbAttr.left + self.cmbAttr.width + Gap;
	self.cmbArgument.left := self.cmbOperator.left + self.cmbOperator.width + Gap;
	self.txtArgument.left := self.cmbOperator.left + self.cmbOperator.width + Gap;
	self.txtArgument1.left := self.cmbOperator.left + self.cmbOperator.width + Gap;
	//self.tblArgument.left := self.cmbOperator.left + self.cmbOperator.width + Gap;	//05 Sep 2019	NDL	TFS 45891

	self.lblArgument.left := self.cmbArgument.left;	
	self.lblOperation.left := self.cmbOperator.left;

	self.txtArgument.top := self.cmbAttr.top;
	
	self.txtFromDate.left := self.lblArgument.left;
	self.txtToDate.left := self.lblArgument.left;
	self.txtFromTime.left := self.lblArgument.left;
	self.txtToTime.left := self.lblArgument.left;
	self.lblAnd.left := (self.lblArgument.left - self.lblAnd.width) - Gap;
	self.lblAnd.top := self.txtArgument1.top + (self.txtArgument1.height/5);

	self.txtFromDate.top := self.txtArgument.top;
	self.txtFromTime.top := self.txtArgument.top;
	self.cmbArgument.top := self.txtArgument.top;
	//self.tblArgument.top := self.txtArgument.top;	//05 Sep 2019	NDL	TFS 45891
	self.frmArgument.top := self.txtArgument.top;	//05 Sep 2019	NDL	TFS 45891
	
	
	//self.tblArgument.width := self.tblArgument.parent.width - ArgumentWidth;
	self.frmArgument.width := self.frmArgument.parent.width - ArgumentWidth;	//05 Sep 2019	NDL	TFS 45891
	self.txtArgument.width := self.txtArgument.parent.width - ArgumentWidth;
	
	//self.tblArgument.height := self.btnAdd.top - self.tblArgument.top;
	self.frmArgument.height := self.cmbArgument.height;	//05 Sep 2019	NDL	TFS 45891
	
	//05 Sep 2019	NDL	TFS 45891
	self.frmArgument.left := self.cmbOperator.left + self.cmbOperator.width + Gap;	
	self.tblArgument.parent := grpTblArgument;
	self.tblArgument.top := 0;
	self.tblArgument.left := 0;
	self.tblArgument.width := grpTblArgument.width;
	self.tblArgument.height := grpTblArgument.height;
	
	self.lblargList.width := self.btnArgFind.left - 10;//05 Sep 2019	NDL	TFS 45891
	self.lblargList.top := 0;	//05 Sep 2019	NDL	TFS 45891
	self.lblargList.height := self.frmArgument.height - 4;	//05 Sep 2019	NDL	TFS 45891
	self.btnArgFind.top := 0;	//05 Sep 2019	NDL	TFS 45891
	self.btnArgFind.height := self.frmArgument.height - 4;	//05 Sep 2019	NDL	TFS 45891
	
	self.cmbSelectorMode.width := self.cmbSelectorMode.parent.width - (self.lblSelectorMode.width + (Gap * 2));
	foreach col in 1 to self.tblCriteria.columns do
		self.tblCriteria.accessColumn(col).width := self.tblCriteria.width.Integer;
	endforeach;
	
	self.tblQueryEnt.width := self.tblCriteria.width;
	
	//cnwmc5 - PAR 31051
	if app.isUsingSkin() then
		self.tblQueryEnt.width := self.frmSaveQuery.width - 10;
	endif;
	
	self.tblQueryEnt.cnEcResizeContents();

	self.chkUnavailable.width := 220;
	
	self.btnModalOpt2.left := self.btnModalOpt2.parent.width - (self.btnModalOpt2.width + Gap);
	
	self.frmStatusLine.doResize();			// PAR #26830
	
	self.chkShowAll.left := self.lstQuery.width - self.chkShowAll.width;		// TFS 48011
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doResultContext" id="8d3e7a6c-2ddd-4a54-9f0b-da52bd3b564e">
        <updating/>
        <source>doResultContext(
	cntrl	: Table input;
	conwin	: Window input;
	mouse	: Boolean;
	x		: Integer;
	y		: Integer ) : Boolean updating, protected;
	
// ---------------------------------------------------------------------------
// Created:     20 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 04 Nov 2019	NDL	TFS 47100
// 26 Dec 2022  navhl20 	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
// 10 May 2023 	navlw1   	ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW
vars
	x1				: Real;
	y1				: Real;
	tmpRelease		: CM_BulkRelease;
	obj				: Object;
	reportStr : String;
begin
	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if cntrl.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := cntrl.positionTop();
	    endif;
	endif;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	
	if (self.disableMnuEnquiry) or (self.isBaseFormModal) then
		self.mnuEnquire.visible := false;
	else
		self.mnuEnquire.visible := true;
		if ( self.myQDef.mode &gt;= CM_QueryDefinition.CargoTransaction_Query_Mode and self.myQDef.mode &lt;= CM_QueryDefinition.HMSTransaction_Query_Mode ) 
		or ( self.myQDef.type = CM_QueryDefinition.Cash_Query_Type
			or self.myQDef.type = CM_QueryDefinition.Invoicing_Query_Type
			or self.myQDef.mode = CM_QueryDefinition.BOLTransaction_Query_Mode
			or self.myQDef.mode = CM_QueryDefinition.WorkOrderTrans_Query_Mode	//26.12.2022 navhl20 #54350[54269]
			or self.myQDef.mode = CM_QueryDefinition.Location_Activity_Query_Mode	//14 Apr 2021 NDL	TFS 50906
			or self.myQDef.mode = CM_QueryDefinition.VehicleBookingSlot_Query_Mode // 10/05/2023 navlw1 tfs 53902
			or self.myQDef.type = CM_QueryDefinition.Audit_Query_Type )
		then
			self.mnuEnquire.visible := false;
		endif;
		
	endif;
	if ( self.myQDef.mode &gt;= CM_QueryDefinition.CargoTransaction_Query_Mode and self.myQDef.mode &lt;= CM_QueryDefinition.HMSTransaction_Query_Mode )
	or ( self.myQDef.type = CM_QueryDefinition.Cash_Query_Type
		or self.myQDef.type = CM_QueryDefinition.Invoicing_Query_Type
		or self.myQDef.mode = CM_QueryDefinition.BOLTransaction_Query_Mode
		or self.myQDef.mode = CM_QueryDefinition.WorkOrderTrans_Query_Mode	//26.12.2022 navhl20 #54350[54269]
		or self.myQDef.mode = CM_QueryDefinition.Location_Activity_Query_Mode	//14 Apr 2021 NDL	TFS 50906
		or self.myQDef.mode = CM_QueryDefinition.VehicleBookingSlot_Query_Mode // 10/05/2023 navlw1 tfs 53902
		or self.myQDef.type = CM_QueryDefinition.Audit_Query_Type )
	then
		self.mnuMoveItem.visible := false;
	else
		self.mnuMoveItem.visible := true;
	endif;
	if self.myQDef.type = CM_QueryDefinition.Audit_Query_Type
	or  self.myQDef.mode = CM_QueryDefinition.Location_Activity_Query_Mode	//10 May 2021	NDL	TFS 50906
	then		// 15/6/18 MAP TFS39243
		self.mnuSummarise.visible := false;
	endif;
	
	//10 May 2021	NDL	TFS 50906
	if self.myQDef.mode = CM_QueryDefinition.Location_Activity_Query_Mode then
		self.mnuSendToReport.enabled := false;
	endif;
	
	// ### TFS CR 65817 TASK 65818 27AUG2024 NAVAB1
	self.mnuReportProforma.visible := false;
	if self.myQDef.mode = CM_QueryDefinition.TrackedItem_Query_Mode then
		reportStr := self.myTerminal.getConfig(InvProformaInvoiceReport).String;
		self.mnuReportProforma.visible := reportStr &lt;&gt; null; 
	endif;
	
	if app.isAllowedToInspect() then
		self.mnuInspect.visible := true;
		self.mnuSep102.visible := true;
	else
		self.mnuInspect.visible := false;
		self.mnuSep102.visible := false;
	endif;
	tmpRelease := self.cmbBulkRelease.listObject.CM_BulkRelease;
	self.mnuAssignRelease.visible := false;
	
	// cnwrl1 12/02/2009
	// The "Summarised" "Selected..." should only be available if the number of selected items is &gt; null.
	self.mnuSummariseSelected.visible	:= not self.tblResults.allSelectedObjects.isEmpty;
	
	// PAR 18779 cnwrl1 22/01/2009 - start of coding.
	// The "Unassign from release.." context menu option on the selector form needs to be conditional.
	// 1) The actual query is for a Tracked Item Query Definition.
	// 2) One or more valid table row(s) has been the selected.
	self.mnuUnassignRelease.visible	:=	global.isValidObject( self.myQDef ) and self.myQDef.isCargoType and
										not self.tblResults.allSelectedObjects.isEmpty;
	// PAR 18779 cnwrl1 22/01/2009 - end of coding.
	
	//CCMS 1086 Anca Rosca 20/11/2007
	// 1. menu for editing the Export Tranships
	self.mnuEditTransExp.visible := false;
	self.mnuEditTransExp.caption := null;
	// PAR #23645 CCMS 1116 no longer required - tranships are now just one TI, not two													// PAR #23645 CCMS 1116
	
// 2. menu for making the selected tranship containers to be non Tranship
	self.mnuNonTrans.visible := false;
	self.mnuNonTrans.caption := null;
	if self.tblResults.allSelectedObjects &lt;&gt; null then
		foreach obj in self.tblResults.allSelectedObjects do
			if obj.isKindOf(CM_TrackedItem) and obj.CM_TrackedItem.isTranshipItem then //and obj.CM_TrackedItem.myTranshipExport &lt;&gt; null then --changed to work for Exports as well
				self.mnuNonTrans.visible := true;
				self.mnuNonTrans.caption := 'Make Selected Item(s) non Tranship';
				break;
			endif;
		endforeach;
	endif;
	
	self.mnuSep104.visible	:= self.mnuEditTransExp.visible or self.mnuNonTrans.visible;

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnMoveIt.visible := false; // TFS 2198
		self.mnuMove.enabled:= false; // TFS 2198
		self.mnuMoveItem.enabled:= false; // TFS 2198
		self.mnuUnassignRelease.enabled:= false; // TFS 2198

	endif;
	
	// now show the menu and terminate further processing
	return self.showContextMenu( self.mnuResultContext, cntrl, conwin, mouse, x, y );
	
end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveBulkTiNonTrans" id="6f40b94c-a4b7-4938-bd08-ca324b4e27e7">
        <updating/>
        <source>doSaveBulkTiNonTrans(_pxyTISet : CM_TISet input ) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 December 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------

vars
	
	updateController		: CMIF_TIUpdateController;
	tbl						: CM_EntryTable;
	idx,
	result,
	numDefs					: Integer;
	cbType					: CM_CargoBOLType;
	pxyTI					: CM_TrackedItem;
	propDict				: PropertyNDict;
	rowObj					: Object;
	theClass				: Class;
	prop					: Property;
	
begin

	while true do
	 	app.myTrxUA.trxUpdateTrackedItems(_pxyTISet,											
											TI_UPDMODE_NORMAL, 
											null, 
											app.myPassport);
											
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			return true;
		else
			result := app.showErrorWarningDialog('Tracked Item Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return false;
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="_pxyTISet" type="CM_TISet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveQuery" id="87d901c7-a8f7-46d1-82b4-0594fa5ca674">
        <updating/>
        <source>doSaveQuery()protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 April 2003		cnwth2	Initial creation
21 March 2019		jlgzm1	TFS43705 selector query column organiser out of date

*/
vars
	theName,
	theDescription			: String;
	shtIdx,
	numSheets,
	row						: Integer;
	realUserQuery,
	pxyUserQuery			: CM_MenuUserQuery;
	pxyCriteriaLine 		: CM_SelectorCriteriaLine;
	criteriaHolder			: CM_QueryCriteriaLineHolder;
	parentMenuEntity		: CM_MenuEntity;
	tbl						: CM_DataTable;
	tblSheet				: JadeTableSheet;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	tbl := self.tblCriteria;
	create pxyUserQuery transient;
	
	pxyUserQuery.setProxy(self.tblQueryEnt.getValueByName(ETRow_QueryName).String,
							self.tblQueryEnt.getValueByName(ETRow_QueryDescr).String,
							app.getMyUser.code,
							self.myQDef.mode,
							app.myRoot.myQueryMenuRoot,
							self.myTerminal,//self.myTerminal could be null - this is fine
							self.allVisibleColumns);
	
	pxyUserQuery.allCriteriaLineHolders.purge();
	numSheets := tbl.sheets;
	foreach shtIdx in 1 to numSheets do
		tblSheet := tbl.accessSheet(shtIdx);
		criteriaHolder := tblSheet.itemObject.CM_QueryCriteriaLineHolder;
		pxyUserQuery.allCriteriaLineHolders.add(criteriaHolder);
		
		foreach row in 1 to tblSheet.rows do
			pxyCriteriaLine := tblSheet.accessRow(row).itemObject.CM_SelectorCriteriaLine;
			if pxyCriteriaLine &lt;&gt; null then
				pxyCriteriaLine.setMyCriteriaLineHolder(criteriaHolder);
			endif;
		endforeach;
	endforeach;
		
	parentMenuEntity := app.myRoot.myQueryMenuRoot;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateSelectorQuery(pxyUserQuery,
										self.lstQuery.listCount + 300,
										parentMenuEntity, 
										realUserQuery,
										app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Selector Query', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	self.lstQuery.displayTree(true, "filterByMode"); // JLGAB1 30JUL19
	//go to the last entry in the list - this will be the newly saved query
	self.lstQuery.listIndex := self.lstQuery.listCount;
	
	self.showHideFrame(self.frmSaveQuery, false, true);
	
epilog
	pxyUserQuery.allCriteriaLineHolders.clear();
	
	delete pxyUserQuery;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSaveSingleTiNonTrans" id="7bbdcd00-3d91-4a73-8be0-a153ec2d8592">
        <updating/>
        <source>doSaveSingleTiNonTrans(_pxyTI : CM_TrackedItem input) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     18 December 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------

vars
	pxyTI					: CM_TrackedItem;
	result					: Integer;
	
begin
	
	while true do
		app.myTrxUA.trxUpdateTrackedItem(_pxyTI,
											null,
											TI_UPDMODE_NORMAL, 
											null, 
											app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			return true;
		else
			result := app.showErrorWarningDialog('Tracked Item Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return false;
	endwhile;
end;</source>
        <access>protected</access>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSendCargo" id="4f1e7437-da75-41a2-b0d6-bd6b2123d508">
        <updating/>
        <source>doSendCargo() updating;

vars
	obj	: Object;
begin
	obj := tblResults.allSelectedObjects.first;
	if obj = null then
		return;
	endif;
	if not obj.isKindOf(CM_TrackedItem) then
		return;
	endif;
	
	self.myParent.displaySelectorCargoItem(obj.CM_TrackedItem);
	
	unloadForm;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSendGridArea" id="65c6a7c9-093c-4d00-86e0-79038858a49f">
        <updating/>
        <source>doSendGridArea() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2011	cnwrd1	Initial creation

*/

vars
	obj	: Object;
	lc	: CM_LocationsController;
	ta	: CM_TerminalArea;
	aGO : CM_GridObject;
begin
	obj := tblResults.allSelectedObjects.first;
	if obj = null then
		return;
	endif;
	if not obj.isKindOf(CM_TrackedItem) then
		return;
	endif;
	
	lc := obj.CM_TrackedItem.getPrimaryLocation(REAL_MODE);
	ta := lc.getParent().CM_TerminalArea;
	if ta.isGridArea then
		if lc.isKindOf(CM_GridController) then
			if ta.CM_GridArea.areLocationIdsColThenRow then
				aGO := lc.CM_GridController.myGridColumn;
			else
				aGO := lc.CM_GridController.myGridRow;
			endif;
			if aGO &lt;&gt; null then
				self.myParent.displaySelectorGridObject(aGO);				
				unloadForm;
			endif;
		endif;
	else
		return;
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSendLocation" id="b9601ebf-4837-4971-b04a-a9b8f4bc6381">
        <updating/>
        <source>doSendLocation() updating;

vars
	obj	: Object;
	lc	: CM_LocationsController;
	ta	: CM_TerminalArea;
begin
	obj := tblResults.allSelectedObjects.first;
	if obj = null then
		return;
	endif;
	if not obj.isKindOf(CM_TrackedItem) then
		return;
	endif;
	
	lc := obj.CM_TrackedItem.getPrimaryLocation(REAL_MODE);
	ta := lc.getParent().CM_TerminalArea;
	
	self.myParent.displaySelectorLocation(ta);
	
	unloadForm;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSendToScreen_DisplayColl" id="25c24729-72ed-485b-a50d-facd78e8d273">
        <source>doSendToScreen_DisplayColl(_form :CM_BaseForm input; _coll :Collection; _mode :Integer)protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 06/11/2013	cnwdap1		PAR #32653 Avoid duplicates when sending collection to cargo enquiry screen
// 22 Dec 2022  navhl20 	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
// 18 May 2023 	navlw1   	ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW
// ---------------------------------------------------------------------------
vars
	mode	: Integer;
	coll	: ObjectSet;
	obj		: Any;
	ti		: CM_TrackedItem;
	
begin
	if _form.name = "YRD_GridAreaEnquiryForm" then
		self.showResultsInRowEnquiry(self.optSelectedOnly.value);
	elseif _form.name = "YRD_GridAreasForm" and self.myParent &lt;&gt; self then // has not been opened from that form so need dif method to handle.
		_form.displaySelectorResultsSpecial(self.myEnqController.allObjects, _mode, self);
	elseif _form.name = "YRD_RoRoLaneAreasForm" and self.myParent &lt;&gt; self then 				// cnwjk3 ccms 1018 08/02/2009
		_form.displaySelectorResultsSpecial(self.myEnqController.allObjects, _mode, self);	// cnwjk3 ccms 1018 08/02/2009
	elseif _form.name = CMUI_TransactionEnquiry.name then				// Feb 2012 CCMS 1262 transaction enquiry
		if self.myQDef.mode = CM_QueryDefinition.CargoTransaction_Query_Mode then
			mode := CMUI_TransactionEnquiry.Mode_Cargo_Transaction_Enquiry;
		elseif self.myQDef.mode = CM_QueryDefinition.EventTransaction_Query_Mode then
			mode := CMUI_TransactionEnquiry.Mode_Event_Transaction_Enquiry;
		elseif self.myQDef.mode = CM_QueryDefinition.HMSTransaction_Query_Mode then		
			mode := CMUI_TransactionEnquiry.Mode_HMS_Transaction_Enquiry;
		elseif self.myQDef.mode = CM_QueryDefinition.BOLTransaction_Query_Mode then	//04 Nov 2019	NDL	TFS 47100
			mode := CMUI_TransactionEnquiry.Mode_BOL_Transaction_Enquiry;
		elseif self.myQDef.mode = CM_QueryDefinition.WorkOrderTrans_Query_Mode then	//22.12.2022 navhl20 #54350[54269]
			mode := CMUI_TransactionEnquiry.Mode_WO_Transaction_Enquiry;	//22.12.2022 navhl20 #54350[54269]
		else
			return;
		endif;
		_form.CMUI_TransactionEnquiry.displayText := app.getErrorString(Selector_query_txt) &amp; ' - ' &amp;
													self.myQDef.modeDescription;
		_form.displaySelectorResults(_coll, mode);
		_form.show;
	
	//28 Apr 2021	NDL	TFS 50906
	elseif _form.name = CMUI_LocationActivityEnquiry.name then
		_form.CMUI_LocationActivityEnquiry.displayText := app.getErrorString(Selector_query_txt);
		_form.displaySelectorResults(_coll, mode);
		_form.show;
	
	// 18/05/2023 navlw1 tfs 53902
	elseif _form.name = CMUI_VehicleBookingEnqForm.name then
		_form.displaySelectorResults(_coll, mode);
		_form.show;
		
	// 18/05/2023 navlw1 tfs 53902
	elseif _form.name = CMUI_VehicleBookingDayView.name then
		_form.displaySelectorResults(_coll, mode);
		_form.show;
		
	// TFS 40336
	elseif _form.name = CMUI_SnapShotForm.name then		
		_form.displaySelectorResults(_coll, mode);
		_form.show;
		
	// 18/03/2013 cnwar2 #31042 - if transaction results being sent to cargo enquiry
	elseif _form.name = CM_ContainerEnqForm.name and
		(self.myQDef.mode = CM_QueryDefinition.CargoTransaction_Query_Mode or
		self.myQDef.mode = CM_QueryDefinition.EventTransaction_Query_Mode or
		self.myQDef.mode = CM_QueryDefinition.HMSTransaction_Query_Mode) then
		
		create coll transient;
		foreach obj in _coll discreteLock do
			if obj.isKindOf(CM_TITransaction) then
				ti := obj.CM_TITransaction.myTrackedItem;
				if ti &lt;&gt; null then
					if not coll.includes(ti) then				// PAR #32653
						coll.add(ti);
					endif;										// PAR #32653
				endif;
			endif;
		endforeach;
		
		_form.show();
		_form.CM_ContainerEnqForm.setFilterCargoTypeId (true);
		_form.displaySelectorResults(coll, _mode);
	
	//Start 26.12.2022 navhl20 #54350[54269]
	elseif _form.name = "YRD_WorkOrderEnquiry" then	
		_form.show();
		_form.displaySelectorResults(_coll, mode);
	//End 26.12.2022 navhl20 #54350[54269]
	
	else
		inheritMethod (_form, _coll, _mode);
	endif;
	
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="_form" type="CM_BaseForm" usage="input"/>
        <Parameter name="_coll" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSendToScreen_DisplayForm" id="883e16ff-cd9c-412a-ae50-c9a695c5928a">
        <source>doSendToScreen_DisplayForm(_table :CMUI_ListTable input; _form :Form)protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	formName	:String;
	row			:Integer;
begin
	formName := _form.caption;

	if formName.length &gt; 30 then
		formName := formName[1:27] &amp; '...';
	endif;
	
	if _form = self.myParent then
		//row := _table.addItem('1' &amp; Tab &amp; formName &amp; ' (screen that launched me)');
		row := _table.addItem('1' &amp; Tab &amp; '** ' &amp; formName);
		_table.accessRow(row).itemObject := _form;
		_table.accessedRow.selected := true;
		_table.allSelectedObjects.add(_form);
	else
		row := _table.addItem('0' &amp; Tab &amp; formName);
		_table.accessRow(row).itemObject := _form;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_form" type="Form"/>
    </JadeMethod>
    <JadeMethod name="doSendToScreen_DisplayForms" id="a960bb13-87e5-4c16-8db3-b77d412b251b">
        <source>doSendToScreen_DisplayForms(_table: CMUI_ListTable input; _forms: ObjectSet) protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.tblResults.allSelectedObjects.isEmpty then
		self.optAllResults.value := true;
		self.optSelectedOnly.enabled := false;
		self.optSelectedOnly.value := false;
	else
		self.optAllResults.value := false;
		self.optSelectedOnly.value := true;
		self.optSelectedOnly.enabled := true;	
	endif;
	
	inheritMethod(_table, _forms);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_forms" type="ObjectSet"/>
    </JadeMethod>
    <JadeMethod name="doSendToScreen_GetForms" id="b19ab310-d6d6-4a85-98c2-c4bbdeb0d11e">
        <source>doSendToScreen_GetForms(_forms: ObjectSet input; _defaultForms: ObjectSet input; _firstTerminal: CM_Terminal) protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26 Dec 2022 	navhl20 	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
// 10 May 2023 	navlw1   	ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW
// ---------------------------------------------------------------------------
vars
	scm					:Schema;
	cls,assisCls		:Class;
	form				:Form;
begin

	//05 Nov 2019	NDL	TFS 47100
	if self.myQDef &lt;&gt; null
	and ( self.myQDef.mode = CM_QueryDefinition.BOLTransaction_Query_Mode
	or self.myQDef.mode = CM_QueryDefinition.EventTransaction_Query_Mode	//07 Jan 2020	NDL	TFS 47780
	) then
		if self.myTerminal &lt;&gt; null then
			form := app.loadForm(CMUI_TransactionEnquiry, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction);
			if form &lt;&gt; null then
				form.CMUI_TransactionEnquiry.setMyTerminal(_firstTerminal);	
				_forms.add(form);
				_defaultForms.add(form);
				
				//22 Feb 2021	NDL	TFS 50835
				if self.myEnqController.allowsSnapShotEdit() then
					form := app.loadForm(CMUI_SnapShotForm, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction);	
					if form &lt;&gt; null then
						form.CMUI_SnapShotForm.setMyTerminal(_firstTerminal);	
						_forms.add(form);
						_defaultForms.add(form);
					endif;
				endif;
				
			endif;
		endif;
		return;
	endif;
	
	//13 Apr 2021	NDL	TFS 50906
	if self.myQDef &lt;&gt; null
	and self.myQDef.mode = CM_QueryDefinition.Location_Activity_Query_Mode then
		if self.myTerminal &lt;&gt; null then
			form := app.loadForm(CMUI_LocationActivityEnquiry, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction);
			if form &lt;&gt; null then
				form.CMUI_LocationActivityEnquiry.setMyTerminal(_firstTerminal);	
				_forms.add(form);
				_defaultForms.add(form);	
			endif; 
		endif;
		return;
	endif;
	
	//Start 26.12.2022 navhl20 #54350[54269]
	if self.myQDef &lt;&gt; null
	and self.myQDef.mode = CM_QueryDefinition.WorkOrderTrans_Query_Mode then
		if self.myTerminal &lt;&gt; null then
			scm		:= rootSchema.getSchema("YardSchema");
			cls		:= scm.getClass("YRD_WorkOrderEnquiry");
			assisCls := scm.getClass("YRD_Assistant");
			form 	:= app.loadForm(cls, assisCls, false, false, true, self.myTerminal, self.myMasterMenuAction);
			
			_forms.add(form);
			_defaultForms.add(form);
			
			form := app.loadForm(CMUI_TransactionEnquiry, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction);
			if form &lt;&gt; null then
				form.CMUI_TransactionEnquiry.setMyTerminal(_firstTerminal);	
				_forms.add(form);
				_defaultForms.add(form);	
			endif; 
		endif;
		return;
	endif;
	//End 26.12.2022 navhl20 #54350[54269]

	// 10/05/2023 navlw1 tfs 53902
	if self.myQDef &lt;&gt; null
	and self.myQDef.mode = CM_QueryDefinition.VehicleBookingSlot_Query_Mode then
		if self.myTerminal &lt;&gt; null then
			form := self.myAssistant.getMyVbsProcessForm(self.myTerminal, self.myMasterMenuAction);
			if form &lt;&gt; null then
				_forms.add(form);
				_defaultForms.add(form);	
			endif; 
		endif;
		return;
	endif;
	
	inheritMethod(_forms, _defaultForms, _firstTerminal);

	if self.myTerminal &lt;&gt; null then
		scm		:= rootSchema.getSchema("YardSchema");
		cls		:= scm.getClass("YRD_GridAreaEnquiryForm");
		form 	:= app.loadForm(cls, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction);
		
		_forms.add(form);
		_defaultForms.add(form);
		
		//01 Nov 2011	NDL	Par 28466
		form := app.loadForm(CMUI_OverstowsForm, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction);
		_forms.add(form);
		_defaultForms.add(form);
		
		// Feb 2012 CCMS 1262 transaction enquiry is also selector-capable
		form := app.loadForm(CMUI_TransactionEnquiry, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction);
		if form &lt;&gt; null then
			form.CMUI_TransactionEnquiry.setMyTerminal(_firstTerminal);	
			_forms.add(form);
			_defaultForms.add(form);
		endif;

		if self.myQDef.mode = CM_QueryDefinition.Audit_Query_Mode then	//24 Jul 2018	NDL	TFS 39689
			form := app.loadForm(CM_AuditViewForm, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction);		// 15/6/18 MAP TFS39243
			if form &lt;&gt; null then
				form.CM_AuditViewForm.setMyTerminal(_firstTerminal);	
				_forms.add(form);
				_defaultForms.add(form);
			endif;
		endif;
		
		// TFS 40336
		if self.myQDef.mode = CM_QueryDefinition.CargoTransaction_Query_Mode then	
			if self.myEnqController.isEnquiryForCargoRelRecTrans() then
				form := app.loadForm(CMUI_SnapShotForm, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction);	
				if form &lt;&gt; null then
					form.CMUI_SnapShotForm.setMyTerminal(_firstTerminal);	
					_forms.add(form);
					_defaultForms.add(form);
				endif;
			endif;
		endif;
		
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_forms" type="ObjectSet" usage="input"/>
        <Parameter name="_defaultForms" type="ObjectSet" usage="input"/>
        <Parameter name="_firstTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="doSendToScreen_Send" id="d3867afc-05d9-4f82-ac4a-60755b490dfa">
        <updating/>
        <source>doSendToScreen_Send(_table :CMUI_ListTable; _coll :Collection; _mode :Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
18 Sep 2008	cnwkpd1	PAR #16736 - Handle forms deleted after showing by refreshing
15 Dec 2008 concms1	CCMS SFW 1047 - moved selector code up to CM_BaseForm
*/

vars
	
begin
	app.mousePointer := Busy;
	
	inheritMethod (_table, _coll, _mode);

	self.showHideFrame(self.frmSendToScreen, false, true);
	
epilog
	app.mousePointer := Idle;
	
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CMUI_ListTable"/>
        <Parameter name="_coll" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSendToScreen_ShowPopup" id="18d88629-21e6-4bfc-acac-297f87cd1749">
        <source>doSendToScreen_ShowPopup(_collAll: Collection; _collSelected: Collection; _table: CMUI_ListTable input; _defaultForms: ObjectSet input) protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_collAll, _collSelected, _table, _defaultForms);

	self.showHideFrame(self.frmSendToScreen, true, true);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_collAll" type="Collection"/>
        <Parameter name="_collSelected" type="Collection"/>
        <Parameter name="_table" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_defaultForms" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doShowColourLegend" id="506bada0-39d7-404e-a61d-5abb50582a09">
        <source>doShowColourLegend();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2019	jlgndl1	Initial creation	TFS 45891

*/

vars
	colLegend	: CMUI_ColourLegend;
	
begin

	create colLegend;
	self.setNavigatorHeading(colLegend.caption); 
	colLegend.centreWindow;
	
	colLegend.addLegendItem("##  Query Performance Indicators  ##", Black, White, null, true);
	colLegend.addLegendItem("Query Criteria - " &amp; "Dictionary Key (Best Performance)", Black, CM_QueryProperty.CollKeyColour, null, false);
	colLegend.addLegendItem("Query Criteria - " &amp; "Simple Attribute Check", Black, CM_QueryProperty.SimpleColour, null, false);
	colLegend.addLegendItem("Query Criteria - " &amp; "Complex Attribute Check (Slowest Performance)", Black, CM_QueryProperty.ComplexColour, null, false);
	colLegend.addLegendItem("Query Criteria - " &amp; "Saved attribute value no longer available, please amend.", Black, LightGray, null, false);
	executeWhen JMTDevelopmentEnvironment;
//	colLegend.addLegendItem(null, Black, White, null, false);
//	colLegend.addLegendItem( "DMAST / WMAST ONLY message!!!", Black, LightGray, null, false);
//	colLegend.addLegendItem("NEW Fields where developer needs to set CM_QueryProperty::ratingPerformance", Black, LightGray, null, false);
	endExecuteWhen;
	colLegend.addLegendItem(null, Black, White, null, false);
	colLegend.addLegendItem("Generally more keys and fewer complex criteria improves performance.", Black, White, null, false);
	colLegend.addLegendItem("Query Criteria with an '*' in the first position, is a criteria line", Black, White, null, false);
	colLegend.addLegendItem("marked as 'line can not be updated at run-time'", Black, White, null, false);
	colLegend.addLegendItem(null, Black, White, null, false);
	colLegend.addLegendItem(null, Black, White, null, false);
	colLegend.addLegendItem("##  Results Performance Indicators  ##", Black, White, null, true);
	colLegend.addLegendItem("Results Column Heading - " &amp; "Simple Stored Data (Best)", Black, self.tblResults.accessCell(1,1).backColor, null, false);
	colLegend.addLegendItem("Results Column Heading - " &amp; "Complex Derived Value (Slowest)", Black, CM_QueryProperty.ComplexColour, null, false);
	colLegend.addLegendItem(null, Black, White, null, false);
	colLegend.addLegendItem("Generally fewer result columns and especially fewer 'complex derived values',", Black, White, null, false);
	colLegend.addLegendItem("improves performance. Less than 10 selected columns is recommended.", Black, White, null, false);
	
	
	
	colLegend.width := 500;
	colLegend.height := 350;
	
	
	colLegend.showModal;


epilog
	delete colLegend;

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowQueryAccessForm" id="29fbe51e-5ef5-44dd-879f-a3db266c6811">
        <source>doShowQueryAccessForm() protected;
// ---------------------------------------------------------------------------
// Created:     07 April 2008		cnwvu1	
// ---------------------------------------------------------------------------

vars
	theQueryAccessForm : CMUI_QueryAccessSetsForm;

begin
	
	//create theQueryAccessForm;
//	viewPerm := form.CM_BaseForm.permissionView;

	theQueryAccessForm := app.loadForm(CMUI_QueryAccessSetsForm, CMUI_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).CMUI_QueryAccessSetsForm;
