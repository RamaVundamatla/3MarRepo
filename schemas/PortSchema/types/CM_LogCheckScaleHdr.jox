    <JadeMethod name="getNextCheckScaleIndex" id="7cb2ec0a-e77d-48d7-a445-4515659dc47f">
        <source>getNextCheckScaleIndex() : Integer;
// ---------------------------------------------------------------------------
// Created:     13 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	checkScaleDtl			: CM_LogCheckScaleDtl;
	newIdx					: Integer;
begin
	checkScaleDtl := self.allCheckScaleDtls.last;
	if checkScaleDtl = null then
		newIdx := 1;
	else
		newIdx := checkScaleDtl.index + 1;
	endif;

	return newIdx;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTimeLocalTZ" id="472a287d-4c90-46f9-95ae-8deceaa889b4">
