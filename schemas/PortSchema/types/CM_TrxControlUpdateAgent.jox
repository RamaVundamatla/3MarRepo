    <JadeMethod name="trxUpdateRoadJobMobileLoadComp" id="361ebe39-1e03-4356-9953-1c1842e1387a">
        <updating/>
        <source>trxUpdateRoadJobMobileLoadComp(_job : CM_RoadJob io; _passport : CM_Passport input)updating;
//02 November 2009	cnwml2 PAR19692
vars
	blnComp : Boolean;
	wle		: CM_WorkListEntry;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;
	if _job &lt;&gt; null and _job.status &lt;&gt; JOB_COMPLETE then
		foreach wle in _job.workListEntries do
			if wle.myTrackedItem = null then
				wle.setStatus(WLE_COMPLETED);
			endif;
			
			if wle.status = WLE_COMPLETED then
				blnComp := true;
			else
				blnComp := false;
			endif;
		endforeach;

	endif;

	if blnComp then
		_job.changeStatus(JOB_COMPLETE);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_job" type="CM_RoadJob" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateRoadJobQueueOrder" id="6f21b784-0c30-41f5-904c-6fac27f72cb5">
        <updating/>
        <source>trxUpdateRoadJobQueueOrder(	_vvr : CM_VehicleVisitRecord input;
							_allReceivalGTEs : CMGTE_EntityArray input;
							_allReleaseGTEs :   CMGTE_EntityArray input;
							_passport : CM_Passport input) updating;
/*

Date		Who		Reason
16 July 2014	cnwer1	Initial creation PAR

*/

vars
	
begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;

	self.raiseExceptionIfNull(_vvr, "No Vehicle Visit Record");
	
	if _vvr = null then
		return;
	endif;
	_vvr.updateJobQueueOrder(_allReceivalGTEs,_allReleaseGTEs);
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
