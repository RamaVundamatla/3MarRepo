<CollClass name="CM_WagonSealBySealTypeDict" id="e4c320e7-be6a-4a77-8b74-c80e5a86be56">
    <loadFactor>66</loadFactor>
    <memberType name="CM_WagonSeal"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="sealObject"/>
    <MemberKey>
        <property name="CM_SealObject::sealType"/>
    </MemberKey>
    <JadeMethod name="getWagonSeal" id="be8efb99-8509-4a04-807d-58ef0fc40d78">
        <source>getWagonSeal(_sealType : CM_SealType): CM_WagonSeal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

	seal : CM_WagonSeal;
	invalidObject : Boolean;
	
begin

	on Exception do app.handleDeletedObject( exception, seal, invalidObject );

	foreach seal in self do
		if seal.sealType = _sealType.sealType then
			return seal;
		endif;
	endforeach;
	
	return null;
	
epilog

end;</source>
        <Parameter name="_sealType" type="CM_SealType"/>
        <ReturnType type="CM_WagonSeal"/>
    </JadeMethod>
</CollClass>
