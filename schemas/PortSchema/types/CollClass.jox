<Class name="CollClass">
    <JadeMethod name="isValidKey" id="f42ac594-79b6-4ece-9e0d-88e98bc26a11">
        <source>isValidKey(any: Any): Boolean;

vars
	valid:           Boolean;
	keyTypeConst:    Integer;
	anyTypeConst:    Integer;
begin
	if keys.size = 1 then
		anyTypeConst := any.getTypeJMT().typeConstant;
		keyTypeConst := keys.first.getKeyType().typeConstant;
		valid := anyTypeConst = keyTypeConst;
	endif;

	return valid;
end;</source>
        <Parameter name="any" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="totalKeyLength" id="e60b493f-c0a9-44c9-95ff-ce8472ef5b6e">
        <source>totalKeyLength() : Integer;

vars
	key:	Key;
	keyLength:	Integer;
begin
	foreach key in keys do
		keyLength := keyLength + key.getLength;
	endforeach;
	return keyLength;		
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
