    <JadeMethod name="mapCargoChainGetAuthToken" id="059dadb2-23b8-4abe-addc-6d70e6236b54">
        <source>mapCargoChainGetAuthToken();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2019	jlgmp6	Initial creation

*/


vars
	xml				: JadeXMLDocument;
	xmlElement		: JadeXMLElement;
	jsonPostData	: String;
	jsonHelper		: CMIF_JsonHelper;
	jsonResponse	: String;
	xmlHelper		: CM_XmlHelperAgent;
	conn			: JadeHTTPConnection;
	sendSuccess		: Boolean;
	token,
	errorMessage	: String;
	index			: Integer;
begin
	// Create a Json request for the authenticate parameters
	create jsonHelper transient;
	create xml transient;
	xml.outputDeclaration := false;
	xml.addElement("root").setText("EvuQlBvpZC1gZyMidT5N8LQNEYB3nb38");		// runaskey
//	xml.rootElement.addElement("client_id").setText(self.clientID);
//	xml.rootElement.addElement("client_secret").setText(self.clientSecret);
//	xml.rootElement.addElement("grant_type").setText("client_credentials");
	jsonPostData := jsonHelper.convertXMLToJson(xml.writeToString());
	jsonPostData := "EvuQlBvpZC1gZyMidT5N8LQNEYB3nb38";
	
	// Call authenticate
	create conn transient;
	conn.url := "https://portal-tests.cargochain.com/runAs";
	conn.setContentType("application/json", index);
	sendSuccess := conn.sendRequest("POST", "Authorization: Basic " &amp; (("CA-GF491-9XYKZ" &amp; Colon &amp; "F725CECA3307E7D1C688CF3BD8008013F4791C79DA9F2BBCA382B745D71E05F8").Binary.base64EncodeNoCrLf()).String, jsonPostData);
	if sendSuccess then
		conn.readBody(0);
		jsonResponse := conn.responseBody.StringUtf8.String;
	endif;
										   
//	"Authorization: Basic " &amp; (("CA-GF491-9XYKZ" &amp; ':' &amp; "F725CECA3307E7D1C688CF3BD8008013F4791C79DA9F2BBCA382B745D71E05F8").Binary.base64Encode()).String

	// Now need to interpret the response to see if the authentication worked
	create xmlHelper transient;
	delete xml;
	create xml transient;
	xmlHelper.tryParseToXMLDocument(jsonHelper.convertJsonToXML(jsonResponse), xml);
	
	// Find token in response
	xmlElement := xml.findElementByTagName("access_token");
	if xmlElement &lt;&gt; null then
		token := xmlElement.text();
//		return true;
	endif;
	
	// No token found, so look for an error message
	xmlElement := xml.findElementByTagName("errors");
	if xmlElement &lt;&gt; null then
		errorMessage := xmlElement.text();
	else
		errorMessage := 'Neither "token" nor "error" found in the response';
	endif;

	// And the authenticate did not work
//	return false;
	
epilog
	xml.inspectModal;
	delete xml;
	delete jsonHelper;
	delete conn;
end;</source>
    </JadeMethod>
    <JadeMethod name="mapCargoChainIniSection" id="c599cdf4-7320-4514-bd23-a95349766b37">
        <source>mapCargoChainIniSection();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2019	jlgmp6	Initial creation	TFS45230

*/

constants
	CargoChainSection:		String = "JMTCargoChain";
	WebServiceURL:			String = "WebServiceURL";
	WebServiceURLValue:		String = "http://jmtlocal/bin_public/jadehttp.dll";
	RestWSApplication:		String = "RestWSApplication";
	RestWSApplicationValue:	String = "JMTAppCargoChain";

vars
	iniFile: String;
	webServiceURL: String;

begin
//	if self.hasScriptBeenRunAtAll(method.name, _controller) then
//		return;
//	endif;

//	app.writeLog(method.qualifiedName &amp; " Creating [" &amp; CargoChainSection &amp; "] ini section", LogAlways);
//	if _controller &lt;&gt; null then
//		_controller.logEntry(" Creating [" &amp; CargoChainSection &amp; "] ini section") ;	
//	endif;
	
	iniFile := app.getIniFileNameAppServer();

	if app.getProfileStringAppServer(iniFile, CargoChainSection, WebServiceURL, null) = null and app.getProfileStringAppServer(iniFile, CargoChainSection, RestWSApplication, null) = null then
		webServiceURL := app.getProfileStringAppServer(iniFile, "JMTPushEvents", WebServiceURL, null);
		if webServiceURL = null then
			app.setProfileStringAppServer(iniFile, CargoChainSection, WebServiceURL, WebServiceURLValue);
		else
			app.setProfileStringAppServer(iniFile, CargoChainSection, webServiceURL, WebServiceURLValue);
		endif;
		app.setProfileStringAppServer(iniFile, CargoChainSection, RestWSApplication, RestWSApplicationValue);
	endif;

//	app.writeLog(method.qualifiedName &amp; " Creating [" &amp; CargoChainSection &amp; "] ini section complete", LogAlways);
//	if _controller &lt;&gt; null then
//		_controller.logEntry(" Creating [" &amp; CargoChainSection &amp; "] ini section complete") ;	
//	endif;
	
//	self.addScriptRun(method.name);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="mapCargoChainMeta" id="37382a6d-f260-4308-a2fe-cbd942ba2067">
        <source>mapCargoChainMeta();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2019	jlgmp6	Initial creation

*/
vars
	jsonResponse,
	url,
	httpHeader,
	cargoJSON 		: String;
	jsonHelper		: CMIF_JsonHelper;
	xml				: JadeXMLDocument;
	resultCode		: Integer;
	terminal		: CM_Terminal;
	element			: JadeXMLElement;
	metas			: JadeXMLElementArray;

begin

	create xml transient;
	create jsonHelper transient;
	xml.outputDeclaration := false;
	xml.addElement("root");

	create element transient;
	element.addAttribute("profileSecretId", "secret");
	element.addAttribute("key", "oid");
	element.addAttribute("value", "123.456");
	//xml.rootElement.addElement("profileSecretId").setText("secret");
	//xml.rootElement.addElement("key").setText("oid");
	//xml.rootElement.addElement("value").setText("123.456");
	metas.add(element);
	delete element;
	create element transient;
	element.addAttribute("profileSecretId", "secret");
	element.addAttribute("key", "TerminalCode");
	element.addAttribute("value", "MAP");
	//xml.rootElement.addElement("profileSecretId").setText("secret");
	//xml.rootElement.addElement("key").setText("oid");
	//xml.rootElement.addElement("value").setText("123.456");
	metas.add(element);
//	xml.rootElement.addElement("profileSecretId").setText("secret");
//	xml.rootElement.addElement("key").setText("TerminalCode");
//	xml.rootElement.addElement("value").setText("MAP");
//	xml.rootElement.a(metas, "root");

	cargoJSON := CN_LEFT_BRACKET &amp; CrLf &amp; jsonHelper.convertXMLToJson(xml.writeToString()) &amp; CrLf &amp; CN_RIGHT_BRACKET;

//	url := self.baseEndpoint &amp; '/setMetadata';
//	httpHeader := self.getAdditionalHeadersForHTTP() &amp; CrLf &amp; "Authorization: Bearer " &amp; _authToken;

//	jsonResponse := self.doSendHTTPRequest(url, "POST", httpHeader, cargoJSON, resultCode);
	
	write cargoJSON;
	
epilog
	delete element;
	delete xml;
	delete jsonHelper;
end;
</source>
    </JadeMethod>
    <JadeMethod name="mapCargoChainParse" id="d2ae8dc9-03a2-479b-bc42-7566d6aed1e9">
        <source>mapCargoChainParse();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2019	jlgmp6	Initial creation

*/

vars
	jsonResponse: String;
	str,
	secret: String;
	xml: JadeXMLDocument;
	xmlHelper: CM_XmlHelperAgent;
	jsonHelper: CMIF_JsonHelper;
	xmlElement: JadeXMLElement;
begin
	jsonResponse := '[
    {
        "profilePublicId": "C19-9SIGZ-0I9XX",
        "profileSecretId": "S19-NP8D4-PVI7I",
        "alias": "#MY_ID_1",
        "profileType": "the type of my profile",
        "isDead": false,
        "createdOnUtc": "2019-07-10T23:10:06.798184+00:00",
        "hasParent": false,
        "hasChildren": false,
        "authorizations": {
            "release": true,
            "accept": false,
            "reject": false,
            "addEvent": true,
            "reshare": false
        },
        "events": [
            {
                "createdBy": "rrowley@jadelogistics.com",
                "createdByOrg": "CO-4UC6A-QN63M",
                "createdOnUtc": "2019-07-10T23:10:02.7927804+00:00",
                "transactionId": "ffe1cdaea876448d9bcc670e7e2e5e66",
                "index": 0,
                "eventBody": {
