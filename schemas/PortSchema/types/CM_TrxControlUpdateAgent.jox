	if app.msgBox( app.getErrorString2(Sure_want_disasso_from, _vbts.getVehicleString, _vbts.getDescription(false)), app.getErrorString(Continue), MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
