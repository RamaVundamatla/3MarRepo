	def := app.myRoot.allDataDumpExtractDefs[DDxDefDescription];
	if def = null then
		app.writeStatement( "Definition not found");
		return;
	endif;
	create transExtractDef transient;
	transExtractDef.setForCreate(def, false);

	agent.initialise(EDB_PortDss, transExtractDef, null, false);

	app.writeStatement( "Number of vehicles in ext db: " &amp;
			agent.getExternalDictSize(CM_Vehicle).String);
	app.writeStatement( "Number of countries in ext db: " &amp;
			agent.getExternalDictSize(CM_Country).String);
		
epilog
	if agent &lt;&gt; null then
