    <ImplicitInverseRef name="allSpecialStowSumObjects" id="67e9d64d-4082-4ac1-93ae-e6452ca0480e">
        <memberTypeInverse/>
        <type name="CMIF_SpecialStowByDischSSCode"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="specialStowInfoByDischargePort" id="93833935-66cd-4c05-a6bd-21dceae9084c">
