    <JadeMethod name="getDefaultBuildPriorityJS" id="15acca83-66a0-457b-b40c-7145ea529c78">
        <source>getDefaultBuildPriorityJS() : CM_RailJSInOutRake;
// ---------------------------------------------------------------------------
// Created:     12 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	rail : CM_Rail;
begin
	rail := self.myTerminal.getDefaultRailTrack();
	
	return self.getJSForRailArea(rail, Rail_JSIO_Type_Build);
epilog

end;</source>
        <ReturnType type="CM_RailJSInOutRake"/>
    </JadeMethod>
    <JadeMethod name="getJSForRailArea" id="7ba289ea-a093-4e7c-947f-d426038db5e2">
        <source>getJSForRailArea(_railArea : CM_Rail; _ioType : Integer) : CM_RailJSInOutRake;
// ---------------------------------------------------------------------------
// Created:     26 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ioJS : CM_RailJSInOut;
	ioJSRail : CM_RailJSInOutRake;
begin
	ioJS := self.getRailJSInOut(_ioType);
	
	if ioJS = null then
		return null;
	endif;
	
	
	foreach ioJSRail in ioJS.inoutRakes discreteLock do
		if ioJSRail.myRail = _railArea then
			return ioJSRail;
		endif;
	endforeach;
	
	if _ioType = Rail_JSIO_Type_Build then
		ioJSRail :=  ioJS.inoutRakes.first;
	endif;
	if ioJSRail = null then
		if _ioType = Rail_JSIO_Type_Build then
			ioJS := self.getRailJSInOut(Rail_JSIO_Type_Out);
			if ioJS &lt;&gt; null then
				ioJSRail :=  ioJS.inoutRakes.first;
			endif;
		endif;
	endif;
	
	return ioJSRail;
epilog

end;</source>
        <Parameter name="_railArea" type="CM_Rail"/>
        <Parameter name="_ioType" type="Integer"/>
        <ReturnType type="CM_RailJSInOutRake"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="6321051e-c0f2-4605-8b19-979eb3da511d">
        <source>getMyTerminal(): CM_Terminal;

// Created by cnwdvb1 on 04 December 2006

vars

begin
	return self.myTerminal;

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getRailJSInOut" id="070adfe0-42d6-4648-bee0-6e6e71c1b57b">
        <source>getRailJSInOut(pType : Integer) : CM_RailJSInOut;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lRailJSInOut : CM_RailJSInOut;
begin

	foreach lRailJSInOut in self.inouts do
		if lRailJSInOut.outwards = pType then
			return lRailJSInOut;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="pType" type="Integer"/>
        <ReturnType type="CM_RailJSInOut"/>
    </JadeMethod>
    <JadeMethod name="getTypeString" id="d416cc54-d47d-4b7d-8b4a-c611b75b78f4">
