    <JadeMethod name="loadForm" id="d4d907a0-72c1-4328-b3c5-c6b9844f2fac">
        <updating/>
        <source>loadForm()updating, protected;

vars
	formatObj			: CnEcXmlFormat;
	xmlFormatCollObj	: CnEcXmlFormatDict;
	
begin
	self.centreWindow();
	
	// Force Hubble to only work against the schema it is called within. Otherwise 1010 s may happen due to attempting to
	// re-implement methods against an object in a schema below yourself.
	
	app.cnEcSetXmlSchema(currentSchema.name);
	app.cnEcSetBaseRoot(false);
	
	lblSchemaName.caption := "for schema: " &amp; app.myCnEcXmlSchema.name;
	
	create xmlFormatCollObj transient;
	app.myBaseRoot.getAllFormatsForSchema(xmlFormatCollObj, app.myCnEcXmlSchema.name );  
	
	foreach formatObj in xmlFormatCollObj do
		cmbInputFormat.addItem(formatObj.formatName);
	endforeach;
	
	cmbInputFormat.listIndex := cmbInputFormat.findStringExact(1, CNEC_DEFAULT_FULL);
	
	if cmbInputFormat.listCount &lt; 2 then
		app.msgBox("Need to run 'Formatter' to create Default Formats", "", MsgBox_OK_Only);
		self.unloadForm();
	endif;  
	
	self.populateInputKind();
	self.enableControls();
epilog 
	delete xmlFormatCollObj;	
end;</source>
        <access>protected</access>
    </JadeMethod>
