/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 September 2009	cnwrd1	Initial creation

*/

vars

	anObject : Object;
begin
	if (not app.isAllowedToInspect()) then
		return;
	endif;
	
	if self.tblJobs.row &gt; 0 and self.tblJobs.column &gt; 0 then
		anObject := self.tblJobs.accessRow(self.tblJobs.row).itemObject;
		if anObject &lt;&gt; null then
			anObject.inspect;
		endif;
	endif;
epilog

end;</source>
