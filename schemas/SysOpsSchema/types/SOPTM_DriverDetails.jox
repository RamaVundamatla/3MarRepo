	self.name := SOP_TableMaintForm.Table_DriverDetails;
	self.permissionView	 := PmAdmAddDriverView;
	self.permissionMaint := PmAdmAddDriverMaint;
	self.myDataClass := CM_DriverDetails;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="0aab3d0f-8111-40ef-b86d-f8475ca361cf">
        <updating/>
        <source>doDelete(pObj: Object io) updating;

vars

begin
	app.myTrxDA.trxDeleteDriverDetails(pObj.CM_DriverDetails, app.myPassport);
end;
</source>
        <Parameter name="pObj" type="Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="681aea1d-1ea4-4cad-91df-3f0dee2c5e4f">
        <updating/>
        <source>doSave(): Boolean updating;
//
// Changed On	By			Reason
// ----------	--------	----------------------------------------------
// 18/10/2019	jlgdap1		TFS 46854 SNO Driver Identity Checking for Cargo Release
// 18/03/2025	navhn30		Story MTN-34389: CUX | Terminal Admin - Drivers: Status "Allowed" as default
vars
	proxyDriver			: CM_DriverDetails;
	name,
	code,
	secondaryCode		: String;
	status				: Integer;
	externalId			: String;
	theForm 			: SOP_TableMaintForm;
	allCarriers			: CM_CarrierByCodeDict;
	allVehicleMachines	: CM_VehicleSet;
begin
	create allCarriers transient;
	create allVehicleMachines transient;
	
	theForm 		:= self.myForm; 
	
	name			:= theForm.tblInput1.getValueByName(ETRow_Name).String;
	code 			:= theForm.tblInput1.getValueByName(ETRow_Code).String;
	secondaryCode	:= theForm.tblInput1.getValueByName(ETRow_SecondaryCode).String;
	if theForm.mode = theForm.Mode_Add and theForm.comboBox1.text = "" then		//18.03.25	 navhn30	MTN-34389
		status 		:= CM_DriverDetails.Status_Allowed;
	else
		status		:= self.getStatus(theForm.comboBox1.text);
	endif;
	
	theForm.mulSelect1.getSelected(allCarriers);
	theForm.mulSelect2.getSelected(allVehicleMachines);
	removeInvalidVehicles(allCarriers, allVehicleMachines); 
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_DriverDetails transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyDriver := theForm.myProxyObject.CM_DriverDetails;
	externalId := proxyDriver.externalID;												// TFS 46854
	if app.getMyUser.canDo(app.myPassport.myTerminal, PmAdmDriverExternalIDMaint) then	// TFS 46854
		externalId := theForm.enteredPassword;											// TFS 46854
	endif;																				// TFS 46854
	proxyDriver.setProxy(	name,
							code,
							secondaryCode,				
							status,	
							externalId,													// TFS 46854
							self.myForm.myTerminal,			
							allCarriers,		
							allVehicleMachines );	
	
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateDriverDetails(proxyDriver, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateDriverDetails(proxyDriver, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK();
epilog
	delete allCarriers;
	delete allVehicleMachines;
end;

</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="f6b61da8-c51d-431c-a734-9ec6432f837b">
        <source>getCollection(): Collection;

vars

begin
	return self.myForm.myTerminal.allDriversbyName;
end;
</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
