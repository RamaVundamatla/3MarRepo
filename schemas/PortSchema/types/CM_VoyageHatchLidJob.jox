    <JadeMethod name="setForCreateVoyage" id="5761049f-70b4-46de-9e4c-e27a9687512d">
        <updating/>
        <source>setForCreateVoyage(_theJobParams: CMIF_VoyageJobParams input; _allWLEs : CM_WLEArray; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 07/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
vars

begin

	self.allHatchLids.clear;
	if not _theJobParams.allHatchLids.isEmpty then
		_theJobParams.allHatchLids.copy(self.allHatchLids);
	endif;

	//inheritMethod(_theJobParams, _passport);					// TFS 3516
	inheritMethod(_theJobParams, _allWLEs, _passport);			// TFS 3516
	
	if _theJobParams.myJobType &lt;&gt; null then // PAR 13052
		if _theJobParams.allHatchLids.size &gt; 0 then
			self.estimatedTimeToCompleteMins := _theJobParams.allHatchLids.size * _theJobParams.myJobType.estimatedTimeToCompleteMins;
		else
			self.estimatedTimeToCompleteMins := _theJobParams.myJobType.estimatedTimeToCompleteMins;
		endif;
	endif;
end;</source>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="_allWLEs" type="CM_WLEArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateVoyage" id="f56b7908-47ef-4dc9-850a-01c864bedcd7">
        <updating/>
        <source>setForUpdateVoyage(_theJobParams: CMIF_VoyageJobParams input; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin

	self.allHatchLids.clear;
	_theJobParams.allHatchLids.copy(self.allHatchLids);
	
	inheritMethod(_theJobParams, _passport);

end;</source>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setNumOfLidsFromHatches" id="0e765ec5-ccbe-467a-8fda-9c9adc7ec8b0">
        <updating/>
        <source>setNumOfLidsFromHatches(_hatchLids: CM_HatchLidArray) updating, protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	// PAR 6936 - AKB2003DEC - zero hatch lids if the job type says it is nothing to do with lids
	if self.jobType = JOB_TYPE_USER then
		if self.myUserJobType &lt;&gt; null then
			if not self.myUserJobType.isHatchType then
				self.numOfLids := 0;
				return;
			endif;
		endif;
	endif;

	self.numOfLids := _hatchLids.size;

end;</source>
        <access>protected</access>
        <Parameter name="_hatchLids" type="CM_HatchLidArray"/>
    </JadeMethod>
    <JadeMethod name="setSidesAndNumHatches" id="47c8c6ee-e775-4e82-973e-714d4e20bbd3">
        <updating/>
        <source>setSidesAndNumHatches() updating, protected;
// ---------------------------------------------------------------------------
// Created:     18 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.setSidesFromHatchLids(self.allHatchLids);
	self.setNumOfLidsFromHatches(self.allHatchLids);
end;</source>
        <access>protected</access>
    </JadeMethod>
