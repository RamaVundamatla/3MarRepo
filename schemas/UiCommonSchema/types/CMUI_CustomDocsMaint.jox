    <JadeMethod name="doSelectAll" id="b6f597a8-faa2-4616-9ac1-b46e3ca25f4d">
        <source>doSelectAll();
/*
Purpose - 	
Who - NAVAB1
Date - 24JUNE2024
ADO -  CR 64285 TASK 64286
//20.07.2024 navrv30 Bug 64858: MTN - Ownership Change Maint - Select All issues
*/

vars
	col, row : Integer;
	include : Boolean;
begin

	if self.tblData.rows = self.tblData.fixedRows then
		return;
	endif;
	
	
	include := self.chkSelectAll.value;
	col := self.tblData.getColumnByRowName(ETRow_IncludeChk);

	if col  &gt; 0 then
	
		foreach row in self.tblData.fixedRows + 1 to self.tblData.rows do
				self.tblData.accessRow(row);
				self.tblData.accessCell(row,col);
				self.tblData.accessedCell.text := include.cnReturnTickDisplayValue();
		endforeach;
	endif;
	
	self.createPxyDetailForUpdate();
	self.displayStatus(); 

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSetSelectAll" id="5ae9650d-82a3-4be1-8d72-b8ae59937a7d">
        <source>doSetSelectAll();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//20.07.2024 navrv30 Bug 64858: MTN - Ownership Change Maint - Select All issues

*/

vars
	col, row : Integer;	
	uncheck : Boolean;
begin

	if self.tblData.rows = self.tblData.fixedRows then
		return;
	endif;
	
	self.chkSelectAll.value := false;
	col := self.tblData.getColumnByRowName(ETRow_IncludeChk);
	
	if col  &gt; 0 then	
		foreach row in self.tblData.fixedRows + 1 to self.tblData.rows do
			if self.tblData.accessCell(row, 1).text = "0" then
				uncheck := true;
				break;
			endif;
		endforeach;
		if not uncheck then
			self.chkSelectAll.value := true;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowHSCodeSearcherForm" id="e1d9937d-7b58-414b-96f7-cebb2863d1f2">
        <source>doShowHSCodeSearcherForm();
/*
Purpose:			

Date		Who		Reason
14AUG2023	NAVAB1	 CR 59614 TASK 59619
*/

vars
	hsCode : CM_HarmonizedSystem;
begin

	hsCode := self.myAssistant.showHSCodeSearchForm(self, true);

	if hsCode &lt;&gt; null then		
