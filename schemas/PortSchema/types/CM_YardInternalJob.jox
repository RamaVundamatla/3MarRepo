    <JadeMethod name="getJobQueues" id="73d22033-59cf-4128-a524-5ece80afd172">
        <source>getJobQueues() : CM_RTQueueArray;
/*
06 Mar 2025 navma1 MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/
vars
	queues	: CM_RTQueueArray;
	wle	:	CM_WorkListEntry;
begin
	create queues transient;
	foreach wle in self.workListEntries discreteLock do		//06.03.2025 navma1 #MTN-34179
		if (wle.queue &lt;&gt; null) and not (queues.includes(wle.queue)) then
			queues.add(wle.queue);
		endif;
	endforeach;		
	return queues;

end;</source>
        <ReturnType type="CM_RTQueueArray"/>
    </JadeMethod>
    <JadeMethod name="getJobTypeForWLE" id="51391a14-c91d-435a-95d6-5d830b9de8a1">
        <source>getJobTypeForWLE(__wle : CM_WorkListEntry input) : String;
// ---------------------------------------------------------------------------
// Created:		02 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if type = Door_Turnaround then
	// PAR 25687 return "DOOR";
	return app.getErrorString(IntJob_DOOR);
		
	endif;
	// PAR 25687 return "INTERNAL";
	return app.getErrorString(IntJob_INT);
	

end;</source>
        <Parameter name="__wle" type="CM_WorkListEntry" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
