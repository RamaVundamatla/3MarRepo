    <JadeMethod name="unload" id="9cc39c1a-bf60-479e-9593-fec7c25fcd7c">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// ---------------------------------------------------------------------------
// Created:     11 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	// JIRA 14794 - NAVAB1 30OCT2024
	if self.useEntDefColumns then
		self.cleanUpEntDef();
	else
		self.cleanUp();
	endif;
	
	self.valuesCleanUp();
	
	delete self.myJRWRepresentationAgent;

	inheritMethod();

end;</source>
    </JadeMethod>
    <JadeMethod name="updateCriteriaLine" id="47387dbc-3de1-4cf6-b227-63c61b9bb807">
        <updating/>
        <source>updateCriteriaLine(_preValidated : Boolean) protected, updating;
// ---------------------------------------------------------------------------
// Created:     11 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tblSheet			: JadeTableSheet;
	row					: Integer;
	criteriaLine		: CM_SelectorCriteriaLine;

begin
	tblSheet := self.tblCriteria.accessSheet(self.tblCriteria.topSheet);
	row := tblSheet.row;
	if row = 0 then
		app.msgBox(app.getErrorString2(CMUI_MustSelect, app.getErrorString(CMUI_Selector_Criteria_Line), app.getErrorString(Update)), app.getErrorString(CMUI_Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	criteriaLine := tblSheet.accessRow(row).itemObject.CM_SelectorCriteriaLine;
	if criteriaLine = null then
		app.msgBox(app.getErrorString2(CMUI_MustSelect, app.getErrorString(CMUI_Selector_Criteria_Line), app.getErrorString(Update)), app.getErrorString(CMUI_Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if (not self.validateCriteriaLineUpdate(criteriaLine.myQueryProperty.propertyName)) then
		return;
	endif;
	
	self.setPropertyValueAndOperator(criteriaLine, _preValidated);
	tblSheet.removeItem(row);
	tblSheet.addItemAt(criteriaLine.getDescriptionString, row);
	tblSheet.accessRow(row).itemObject := criteriaLine;
	
	tblSheet.accessRow(row).backColor := criteriaLine.getPerformanceColour;	//02 Sep 2019	NDL	TFS 45891

	tblSheet.row := row; // ### TFS BUG 61210 23FEB2024 NAVAB1
	self.queryLineChanged := false; // ### TFS BUG 61210 23FEB2024 NAVAB1

end;</source>
        <access>protected</access>
        <Parameter name="_preValidated" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateProgress" id="9445c060-839c-4d87-911d-5d139478c6a1">
        <updating/>
        <source>updateProgress(_cmifMonitor: CMIF_Monitor input) updating;
// ---------------------------------------------------------------------------
// Created:     11 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 18/10/2022	navmd1		TFS 55110 Show updates on selector query progress by actually refreshing the monitor caption
//										Add only refreshing at most every 2 seconds
//
vars
	pb				: ProgressBar;
begin
	
	//inheritMethod(_cmifMonitor);
	//self.pbProgressBar.partsInJob := _cmifMonitor.partsInJob;	
	//self.pbProgressBar.partsDone := _cmifMonitor.partsDone;
	//self.lblModalInfo.caption := app.getErrorString(CMUI_Items_Searched) &amp; '=' &amp; _cmifMonitor.partsInJob.String &amp;
	//							'   ' &amp; app.getErrorString(CMUI_Items_Found) &amp; '=' &amp; _cmifMonitor.partsDone.String;

	
	// Need to call inherit method to update the progress every so often
	_cmifMonitor.message := app.getErrorString(CMUI_Items_Searched) &amp; '=' &amp; _cmifMonitor.partsInJob.String &amp;
						'   ' &amp; app.getErrorString(CMUI_Items_Found) &amp; '=' &amp; _cmifMonitor.partsDone.String;
						
	inheritMethod(_cmifMonitor);
	
	_cmifMonitor.monitorReturnValue := self.modalDialogReturnValue;	
	//self.frmModalDialog.doWindowEvents(0);
	//self.btnModalOpt1.doWindowEvents(0);
	//self.btnModalOpt2.doWindowEvents(0);

	if self.modalDialogReturnValue = ModalDialogReturn_Option2 then
		_cmifMonitor.monitorReturnValue := CMIF_Monitor.MonitorReturnValue_Cancel;
	elseif self.modalDialogReturnValue = ModalDialogReturn_Option1 then
		_cmifMonitor.monitorReturnValue := CMIF_Monitor.MonitorReturnValue_Return;
	endif;
	
	
end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateStatus" id="8c44f418-46a2-4b94-a62c-fefa789023aa">
        <source>updateStatus() protected;
// --------------------------------------------------------------------------------
// Created:		24 November 2005 by cnwdad1
//
// Purpose:		Updates the status line display.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 31/01/2011	cnwdap1		PAR #26830 CCMS 2013 allow move on selector
// --------------------------------------------------------------------------------
vars
	statusMsg		: String;
	tableObj		: Table;
	selectedCount	: Integer;
	
begin
	tableObj		:=	tblResults;
	statusMsg		:=	(tableObj.rows - tableObj.fixedRows).cnEcNumberFormat() &amp; " Items displayed";
	selectedCount	:=	tableObj.selectedCount();
	
	if selectedCount = 0 then
		statusMsg	:=	statusMsg &amp; " (0 Items selected)";
	else
		statusMsg	:=	statusMsg &amp; " (" &amp; tableObj.getSelectedRowCount.cnEcNumberFormat() &amp; " Items selected)";
	endif;
	
	staLine.cnEcSet(" " &amp; statusMsg);
	self.frmStatusLine.myFrameCaption.caption := (" " &amp; statusMsg);		// PAR #26830
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="userNotify" id="05fe2a11-bdd8-4b81-a9e5-1e85b52141a6">
