    <JadeMethod name="tMAPIPreProcessRequest" id="a8876f11-3165-464b-b04f-b31737c9c02d">
        <source>tMAPIPreProcessRequest();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 December 2023	navlw1	Bug 60597: CUX | EDBIC - Put /voyage/{id} RestAPI doesn't do what the swagger definition suggests
13 December 2023	navmd1	Moved to UT_WebFramework from UT_WebMasterTerminalAPI

*/
constants
Json = '{
"id": "UATEST1"
}';
ExpectedJson = '[{
"id": "UATEST1"
}]';
VoyageId = "UATEST";
vars
	terminal 			: CM_Terminal;
	loginJson,
	incomingJsonString,
	pathString,
	terminalCode		: String;
	expectFailure		: Boolean;
	
begin
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	
	terminal := app.myPassport.myTerminal;
	self.assertNotNullMsg(terminal.code, "Terminal Code not set in Unit Test Profile");
	
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	// testing that if we are a PUT and pass in params we want to add a json array around the request
	expectFailure := false;
	incomingJsonString := Json;
	pathString := "/voyage/"&amp;VoyageId;
	
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPreProcessRequest.name, loginJson, incomingJsonString, pathString, expectFailure);
	self.assertEqualMsg(incomingJsonString,ExpectedJson,"MasterTerminalAPI::preProcessRequest should wrap JSON objects in square brackets if we expect an array");
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tRESTAuthLogin" id="713a8317-5445-4c73-ad05-c41441d9683b">
        <source>tRESTAuthLogin();
/*

Purpose:			Test the OAUTH like REST /login method

Parameters:			

Return Value:		

Date				Who		Reason
13 April 2022		navmd1	Initial creation TFS 53378

*/

vars
	jsonStr,
	terminalCode,
	ret				: String;
	expectFailure	: Boolean;
begin
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");

// ########### 1. Successful Login ###########
	jsonStr := '{
	"userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
	"password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
	"scope": {
		"operatorId": "Navis",
		"complexId": "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
		"yardId": "MTN"
	},
	"applicationId": "c0769874-2092-493e-8956-04ea6cb0effc"
}';
	
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTAuthLogin.name, jsonStr, expectFailure);
	
// ########### 2. Bad Username ###########
	jsonStr := '{
	"userId": "baduser",
	"password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
	"scope": {
		"operatorId": "Navis",
		"complexId": "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
		"yardId": "MTN"
	},
	"applicationId": "c0769874-2092-493e-8956-04ea6cb0effc"
}';
	
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :91736. API Authentication Error (Invalid Username/Password)");
	expectFailure := true;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTAuthLogin.name, jsonStr, expectFailure);
	
// ########### 3. Bad Password ###########
	jsonStr := '{
	"userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
	"password": "badPass",
	"scope": {
		"operatorId": "Navis",
		"complexId": "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
		"yardId": "MTN"
	},
	"applicationId": "c0769874-2092-493e-8956-04ea6cb0effc"
}';
	
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :91736. API Authentication Error (Invalid Username/Password)");
	expectFailure := true;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTAuthLogin.name, jsonStr, expectFailure);
	
// ########### 4. No Scope ###########
	jsonStr := '{
	"userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
	"password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
	"applicationId": "c0769874-2092-493e-8956-04ea6cb0effc"
}';
	
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :91736. API Authentication Error (Invalid Scope)");
	expectFailure := true;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTAuthLogin.name, jsonStr, expectFailure);
	
// ########### 5. Bad Terminal ###########
	jsonStr := '{
	"userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
	"password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
	"scope": {
		"operatorId": "Navis",
		"complexId": "Master Terminal",
		"facilityId": "",
		"yardId": "MTN"
	},
	"applicationId": "c0769874-2092-493e-8956-04ea6cb0effc"
}';
	
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :91736. API Authentication Error (Invalid Scope)");
	expectFailure := true;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTAuthLogin.name, jsonStr, expectFailure);
	
// ########### 6. No applicationId ###########
	jsonStr := '{
	"userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
	"password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
	"scope": {
		"operatorId": "Navis",
		"complexId": "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
		"yardId": "MTN"
	}
}';
	
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :91736. API Authentication Error (applicationId not specified, and is required for JWT auth)");
	expectFailure := true;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTAuthLogin.name, jsonStr, expectFailure);
	
// ########### 7. Missing applicationId ###########
	jsonStr := '{
	"userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
	"password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
	"scope": {
		"operatorId": "Navis",
		"complexId": "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
		"yardId": "MTN"
	},
	"applicationId": ""
}';
	
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :91736. API Authentication Error (applicationId not specified, and is required for JWT auth)");
	expectFailure := true;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTAuthLogin.name, jsonStr, expectFailure);
	
// ########### 8. Crap ###########
	jsonStr := '{
}';
	
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :91736. API Authentication Error (Invalid Username/Password)");
	expectFailure := true;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTAuthLogin.name, jsonStr, expectFailure);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tRESTAuthLogout" id="1ae48753-5764-41f9-b5c0-0bd9a371d2f3">
        <source>tRESTAuthLogout();
/*

Purpose:			Test the OAUTH like REST /login method

Parameters:			

Return Value:		

Date				Who		Reason
16 April 2022		navmd1	Initial creation TFS 53378

*/

vars
	wsSchema		: Schema;
	agentCls		: Class;
	jwtClaimsClass	: Class;
	expectFailure	: Boolean;
	terminalCode	: String;
		
	user			: CM_User;
	terminal		: CM_Terminal;
	audience		: String;
	isRefreshToken	: Boolean;
	
	accessExpiry,
	refreshExpiry	: Integer;
	
	accessToken,
	refreshToken	: String;
	jwtClaims		: Object;
	appName			: String;		//TFS 53986, navam1
begin	
	// Create a 'normal' JWT
	wsSchema := rootSchema.getSchema(WebServicesSchemaName);
	agentCls := wsSchema.getClass("WS_WebServiceAgent");
	audience := "UnitTestAudience";
	
	// Create a dummy jwtClaims object
	jwtClaimsClass := wsSchema.getClass("CMIF_WSClaimsObj");
	create jwtClaims as jwtClaimsClass transient;
	jwtClaims.setPropertyValue("operatorId", "MTN");
	
	user := app.myRoot.allUsers[self.getProfileSetting(UT_Profile.P_USER).asString];
	self.assertNotNullMsg(user, "No user set, unable to run test");
	
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	terminal := app.myRoot.allTerminals[terminalCode];
	self.assertNotNullMsg(terminal, "No terminal set, unable to run test");
	
	// createJWT(_user: CM_User; _terminal: CM_Terminal; _audience: String; _expiryInSeconds: Integer io; _isRefreshToken: Boolean) : String typeMethod;
	accessToken := agentCls.sendTypeMsgWithIOParams("createJWT", user, terminal, audience, appName, accessExpiry, isRefreshToken, jwtClaims).String;
	self.assertNotNullMsg(accessToken, "AccessToken not created");
	self.logMessage("AccessToken: " &amp; accessToken);
	self.assertTrueMsg(accessExpiry &gt; 0, "AccessToken: Invalid Expiry - should be greater than 0");
	
	isRefreshToken := true;
	refreshToken := agentCls.sendTypeMsgWithIOParams("createJWT", user, terminal, audience, appName, refreshExpiry, isRefreshToken, jwtClaims).String;
	self.assertNotNullMsg(refreshToken, "RefreshToken not created");
	self.logMessage("RefreshToken: " &amp; refreshToken);
	self.assertTrueMsg(refreshExpiry &gt; 0, "RefreshToken: Invalid Expiry - should be greater than 0");
	self.assertTrueMsg(refreshExpiry &gt; accessExpiry, "RefreshToken must be after AccessToken");
	
	// Now send the access token to invalidate all other tokens
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTAuthLogout.name, accessToken, expectFailure);
	
	// Try using the Refresh token
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :91736. API Authentication Error (Token has been revoked)");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTAuthRefresh.name, refreshToken, terminal, expectFailure);
	
	// Create a 'short' JWT and wait for it to expire
	isRefreshToken := false;
	accessExpiry := 5;
	accessToken := agentCls.sendTypeMsgWithIOParams("createJWT", user, terminal, audience, appName, accessExpiry, isRefreshToken, jwtClaims).String;
	self.assertNotNullMsg(accessToken, "AccessToken not created");
	self.logMessage("AccessToken: " &amp; accessToken);
	self.assertTrueMsg(accessExpiry = 5, "AccessToken: Invalid Expiry - should be 5 seconds");
	
	isRefreshToken := true;
	refreshExpiry := 0;	//default
	refreshToken := agentCls.sendTypeMsgWithIOParams("createJWT", user, terminal, audience, appName, refreshExpiry, isRefreshToken, jwtClaims).String;
	self.assertNotNullMsg(refreshToken, "RefreshToken not created");
	self.logMessage("RefreshToken: " &amp; refreshToken);
	self.assertTrueMsg(refreshExpiry &gt; 0, "RefreshToken: Invalid Expiry - should be greater than 0");
	
	process.sleep(5000);	// Wait 5 seconds
	
	// Now send the access token and expect a failure
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :91736. API Authentication Error (Token expired or for the future)");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTAuthLogout.name, accessToken, expectFailure);
	
	// Send the refresh token and expect a failure
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :91736. API Authentication Error (Unable to verify token. Token may be invalid or has been tampered with: Validation Failed.)");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTAuthLogout.name, refreshToken, expectFailure);
	
	// Send no token
	accessToken := null;
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :91736. API Authentication Error (Token Not Found)");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTAuthRefresh.name, accessToken, terminalCode, expectFailure);
epilog
	delete jwtClaims;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRESTAuthRefresh" id="9704678f-f104-4f7d-9fb9-719c13dca822">
        <source>tRESTAuthRefresh();
/*

Purpose:			Test the OAUTH like REST /login method

Parameters:			

Return Value:		

Date				Who		Reason
16 April 2022		navmd1	Initial creation TFS 53378

*/

vars
	wsSchema		: Schema;
	agentCls		: Class;
	jwtClaimsClass	: Class;
	expectFailure	: Boolean;
	terminalCode	: String;
		
	user			: CM_User;
	terminal		: CM_Terminal;
	audience		: String;
	isRefreshToken	: Boolean;
	
	accessExpiry,
	refreshExpiry	: Integer;
	
	accessToken,
	refreshToken	: String;
	jwtClaims		: Object;
	appName			: String;		//TFS 53986, navam1
begin	
	
	wsSchema := rootSchema.getSchema(WebServicesSchemaName);
	agentCls := wsSchema.getClass("WS_WebServiceAgent");
	audience := "UnitTestAudience";
	
	// Create a dummy jwtClaims object
	jwtClaimsClass := wsSchema.getClass("CMIF_WSClaimsObj");
	create jwtClaims as jwtClaimsClass transient;
	jwtClaims.setPropertyValue("operatorId", "MTN");
	
	user := app.myRoot.allUsers[self.getProfileSetting(UT_Profile.P_USER).asString];
	self.assertNotNullMsg(user, "No user set, unable to run test");
	
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	terminal := app.myRoot.allTerminals[terminalCode];
	self.assertNotNullMsg(terminal, "No terminal set, unable to run test");
	
	// Create a 'short' JWT access token, and use the refesh one to get a new one
	accessExpiry := 5;	// seconds
	accessToken := agentCls.sendTypeMsgWithIOParams("createJWT", user, terminal, audience, appName, accessExpiry, isRefreshToken, jwtClaims).String;
	self.assertNotNullMsg(accessToken, "AccessToken not created");
	self.logMessage("AccessToken: " &amp; accessToken);
	self.assertTrueMsg(accessExpiry = 5, "AccessToken: Invalid Expiry - should be 5 seconds");
	
	isRefreshToken := true;
	refreshToken := agentCls.sendTypeMsgWithIOParams("createJWT", user, terminal, audience, appName, refreshExpiry, isRefreshToken, jwtClaims).String;
	self.assertNotNullMsg(refreshToken, "RefreshToken not created");
	self.logMessage("RefreshToken: " &amp; refreshToken);
	self.assertTrueMsg(refreshExpiry &gt; 0, "RefreshToken: Invalid Expiry - should be greater than 0");
	self.assertTrueMsg(refreshExpiry &gt; accessExpiry, "RefreshToken must be after AccessToken");
	
	process.sleep(5000);	// Wait 5 seconds
	
	// Call *something* to make sure an expired accessToken comes back with a 401 and a 91736 error
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :91736. API Authentication Error (Token expired or for the future)");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetDemo.name, accessToken, expectFailure);
	
	// Now send the refresh token to get a new set of tokens
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTAuthRefresh.name, refreshToken, terminalCode, expectFailure);
	
	// Now create a 'short' JWT refreshToken and wait for it to expire
	isRefreshToken := false;
	accessExpiry := 0;	// default
	accessToken := agentCls.sendTypeMsgWithIOParams("createJWT", user, terminal, audience, appName, accessExpiry, isRefreshToken, jwtClaims).String;
	self.assertNotNullMsg(accessToken, "AccessToken not created");
	self.logMessage("AccessToken: " &amp; accessToken);
	self.assertTrueMsg(accessExpiry &gt; 0, "AccessToken: Invalid Expiry - should be greater than 0");
	
	isRefreshToken := true;
	refreshExpiry := 5;	//seconds
	refreshToken := agentCls.sendTypeMsgWithIOParams("createJWT", user, terminal, audience, appName, refreshExpiry, isRefreshToken, jwtClaims).String;
	self.assertNotNullMsg(refreshToken, "RefreshToken not created");
	self.logMessage("RefreshToken: " &amp; refreshToken);
	self.assertTrueMsg(refreshExpiry = 5, "RefreshToken: Invalid Expiry - should be 5 seconds");
	
	process.sleep(5000);	// Wait 5 seconds
	
	// Now send the refresh token and expect a failure
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :91736. API Authentication Error (Token expired or for the future)");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTAuthRefresh.name, refreshToken, terminalCode, expectFailure);
	
	// 'Accidentally' use the access token instead
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :91736. API Authentication Error (Unable to verify token. Token may be invalid or has been tampered with: Validation Failed.)");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTAuthRefresh.name, accessToken, terminalCode, expectFailure);
	
	// Send no token
	refreshToken := null;
	expectFailure := true;
	self.opts.purge();
	self.opts.addAssoc("ExpectedResponse", "Code :91736. API Authentication Error (Token Not Found)");
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTAuthRefresh.name, refreshToken, terminalCode, expectFailure);
epilog
	delete jwtClaims;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRESTRejectQueryAndBody" id="8a576976-f0a2-4891-837a-72e036b38eee">
        <source>tRESTRejectQueryAndBody();
/*

Purpose:			If a request body expects an array, then its invalid to provide both that and path attributes to uniquely identify 1 object

Parameters:			

Return Value:		

Date					Who		Reason
13 December 2023		navmd1	Initial creation TFS 60597

*/

vars
	terminalCode		: String;
	operator			: CM_Operator;
	shippingLineCode	: String;
	loginStr			: String;
	expectFailure		: Boolean;
	request				: String;
	pathAndParams		: String;
	verb				: String;
begin
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	shippingLineCode := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	self.assertNotNullMsg(operator, "Operator not found/not set in Unit Test Profile");
	self.assertNotNullMsg(shippingLineCode, "Shipping Line not set in Unit Test Profile");	
	
	self.deleteVoyage("DUMMYID1");
	self.deleteVoyage("DUMMYID2");
	self.deleteVoyage("DUMMYID3");
	
	self.addVoyageWithContainerStructur("DummyId1", "UTHMSBERTHV", operator.code, shippingLineCode);
	self.addVoyageWithContainerStructur("DummyId2", "UTHMSBERTHV", operator.code, shippingLineCode);
	self.addVoyageWithContainerStructur("DummyId3", "UTHMSBERTHV", operator.code, shippingLineCode);

	loginStr := '{
	"userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
	"password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
	"scope": {
		"operatorId": "Navis",
		"complexId": "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
		"yardId": "MTN"
	},
	"applicationId": "c0769874-2092-493e-8956-04ea6cb0effc"
}';
	
	app.log("Test 1 - Both Request Body and Path Parameters (Expect 400)");
	expectFailure := true;
	request := '[{"id": "DummyId2"},{"id": "DummyId3"}]';
	pathAndParams := '/voyage/DummyId1';
	verb := JadeHTTPConnection.Verb_DELETE;
	
	// wsRESTRejectQueryAndBody(_login, _json, _verb : String; _pathParamString : String; _expectFailure : Boolean)
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTRejectQueryAndBody.name, loginStr, request, verb, pathAndParams, expectFailure);	
	
	app.log(CrLf &amp; "Test 2 - Just Request Body (Expect 200)");
	expectFailure := false;
	request := '[{"id": "DummyId2"},{"id": "DummyId3"}]';
	pathAndParams := '/voyage';
	verb := JadeHTTPConnection.Verb_DELETE;
	
	// wsRESTRejectQueryAndBody(_login, _json, _verb : String; _pathParamString : String; _expectFailure : Boolean)
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTRejectQueryAndBody.name, loginStr, request, verb, pathAndParams, expectFailure);
	
	app.log(CrLf &amp; "Test 3 - Just Path Parameters (Expect 200)");
	expectFailure := false;
	request := null;
	pathAndParams := '/voyage/DummyId1';
	verb := JadeHTTPConnection.Verb_DELETE;
	
	// wsRESTRejectQueryAndBody(_login, _json, _verb : String; _pathParamString : String; _expectFailure : Boolean)
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTRejectQueryAndBody.name, loginStr, request, verb, pathAndParams, expectFailure);	
	
	app.log(CrLf &amp; "Test 4 - PUT Request Body and Path (Expect 200)");
	expectFailure := false;
	request:= '{"id": "DummyId1"}';
	pathAndParams := '/voyage/DummyId1';
	verb := JadeHTTPConnection.Verb_PUT;
	
	// wsRESTRejectQueryAndBody(_login, _json, _verb : String; _pathParamString : String; _expectFailure : Boolean)
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTRejectQueryAndBody.name, loginStr, request, verb, pathAndParams, expectFailure);
	
	self.deleteVoyage("DUMMYID1");
	self.deleteVoyage("DUMMYID2");
	self.deleteVoyage("DUMMYID3");
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="unitTestBeforeClass" id="8d2ad299-b795-4490-a30f-77caaebf30e1">
        <updating/>
        <source>unitTestBeforeClass() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2022	navmd1	Initial creation

*/

vars
	user : CM_User;
begin
	inheritMethod();
		
	self.opts.purge();
	self.opts.addAssoc("UserPassword", UT_WebFramework.PASSWORD);
	self.addUser("UT REST Framework Test user", UT_WebFramework.USERCODE);
	self.opts.addAssoc("RequestedUser", UT_WebFramework.USERCODE);
	self.addUserTerminalToUser(null);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
