    <JadeMethod name="setForCreate" id="91b89579-1a22-4cd8-a5ce-33f3826684b9">
        <updating/>
        <source>setForCreate(pProxyObj:CM_YardAllocation) updating;
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Set the receiver's property values from the proxy object.
//
// Parameters:	pProxyObj - A reference to the proxy object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myTerminal	:=	pProxyObj.myTerminal;
	self.setForUpdate(pProxyObj);
end;</source>
        <Parameter name="pProxyObj" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="setForCreateFromTemplate" id="1f1be040-29e6-4c03-be41-28dbfa649db0">
        <updating/>
        <source>setForCreateFromTemplate(_yardAllocation : CM_YardAllocation; _terminal : CM_Terminal) updating;
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Set the receiver's property values from the proxy object.
//
// Parameters:	pProxyObj - A reference to the proxy object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 10/03/2021	navdap1		TFS 50889 PRP Yard Allocation Performance Improvement
// --------------------------------------------------------------------------------
begin

	// Standard set for update.	Builds blocks and primitives.
	self.setForUpdate(_yardAllocation);
	
	// Clone criteria using special method.
	self.cloneCriteria(_yardAllocation);
	
	// Set terminal reference.
	self.myTerminal	:=	_terminal;
	
	self.terminalMarkDictAdd();					// TFS 50889
end;</source>
        <Parameter name="_yardAllocation" type="CM_YardAllocation"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1809e765-7471-4c7b-9ed2-dc5eaa8f743f">
        <updating/>
        <source>setForUpdate(pProxyObj:CM_YardAllocation) updating;
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Updates the receiver's property values from the proxy object.
//
// Parameters:	pProxyObj - A reference to the proxy object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 12/08/2008	Simon Ward	SFW1030 - Allow for YA template properties
// 18/08/2011 	cnwmh5		#27980 - Change to handle add/update/deleting of locations
// 06/11/2024	navdap1		MTN-18897 EUP | FR 53485 EUP - Warehouse Yard Allocation
// --------------------------------------------------------------------------------
vars
	proxyGroupObj		: CM_YABlockGroup;
	groupObj			: CM_YABlockGroup;
	proxyBlockObj		: CM_YABlock;
	blockObj,
	blockObjIn,
	blockObjOut			: CM_YABlock;
	outGroupObj			: CM_YABlockGroup;
// The following is the proxy out Group that we use to get the correct array index
// when storing the persistent Group in the "OUT" list.  We need to do it this way
// because we are iterating thru the "IN" list when persisting the Blocks for both
// the "IN" list and the "OUT" list.
	groupName			: String;
	yaTemplate: CM_YATemplate;
	yaLC : CM_YardController;
	groupOutMatch : Boolean; //cnwjo3 par 19683
	groupOutIndex : Integer; //cnwjo3 par 19683
	colourChanged : Boolean;
	newYardAllocationSet : CM_YardControllerSet;  //par 19727
	yardAllocationCheckSet : CM_YardControllerSet;  //par 32308
	tmpObj : CM_YardController; //par 19727
	
	tmpTerminalAreaSet		: CM_TerminalAreaSet;		// 18/08/2011 cnwmh5 #27980
	tmpTerminalArea			: CM_TerminalArea;
	
begin
	// Set any attribute values.
	
	self.code					:=	pProxyObj.code;
	self.description			:=	pProxyObj.description;
	self.remarks				:=	pProxyObj.remarks;
	self.fillOptionIn			:=	pProxyObj.fillOptionIn;
	self.fillOptionOut			:=	pProxyObj.fillOptionOut;
	self.expiryType				:=	pProxyObj.expiryType;
	self.expiryDate				:=	pProxyObj.expiryDate;
	
	// PAR 27749
	colourChanged := ( pProxyObj.color &lt;&gt; self.color);
	
	self.color					:=	pProxyObj.color;
	if colourChanged then
		self.setForUpdateColour();
	endif;
	self.allowOthersOption		:=	pProxyObj.allowOthersOption;
	self.allowMultiRangeSplit	:=  pProxyObj.allowMultiRangeSplit; //16 Jun 2016	NDL	TFS 2172
	self.noLocationOption		:=	pProxyObj.noLocationOption;
	// CCMS 1357
	self.myYAOverstowRule		:=	pProxyObj.myYAOverstowRule;
	self.priorityAdjustment		:=	pProxyObj.priorityAdjustment;
	self.isTestOverstowWeight	:=	pProxyObj.isTestOverstowWeight;
	self.isDisabled				:=	pProxyObj.isDisabled;
	self.isAutomatic			:=	pProxyObj.isAutomatic;
	self.isTemplateModified		:=	pProxyObj.isTemplateModified;		// SFW1030 12/08/2008
	self.projected20 			:=  pProxyObj.projected20;
	self.projected30 			:=  pProxyObj.projected30;
	self.projected40 			:=  pProxyObj.projected40;
	self.projected45 			:=  pProxyObj.projected45;
	self.projected53 			:=  pProxyObj.projected53;
	self.projectedGC 			:=	pProxyObj.projectedGC;	//31 Mar 2021	NDL	TFS 49912
	self.displayHatched			:=	pProxyObj.displayHatched; //cnwjo3 par 24145
	
	self.isFullGCArea			:=	pProxyObj.isFullGCArea;		// MTN-18897
	
	// Set any key attribute values.
	
	self.priorityValue		:=	pProxyObj.priorityValue;
	
	// Set any inverse references.

	if pProxyObj.myYATemplate &lt;&gt; self.myYATemplate then
		yaTemplate := pProxyObj.myYATemplate;
		yaTemplate.setLastUsed();
	endif;
	self.myYATemplate		:=	pProxyObj.myYATemplate;		// SFW1030 12/08/2008

	// --- Now do any other stuff that needs attention ---
	
	// Finally, persist the YA Blocks and update the Decking Options for the inward
	// and outward Blocks.
	
	// save the terminal areas before they are cleared so can update Terminal Area Enquiry
	create tmpTerminalAreaSet transient;				// 18/08/2011 cnwmh5 #27980
	self.allTerminalAreas.copy(tmpTerminalAreaSet);
	
	create yardAllocationCheckSet transient;
	self.allYardControllers.copy(yardAllocationCheckSet);
	
	self.allYardControllers.clear();
	self.allYABlockGroupsIn.purge();
	self.allYABlockGroupsOut.purge();
	self.allYABlocksIn.purge();
	self.allYABlocksOut.purge();
	self.allTerminalAreas.clear();
	
	// Recreate the Block Groups, and their Blocks.  We'll do the "IN" and "OUT" Groups first,
	// then we'll do the "IN" and "OUT" Blocks last.
	// We do it this way because a Block can be in one Group in the "IN" list, and in another
	// Group in the "OUT" list, so we need to ensure the "OUT" Group exists before we can add
	// a Block to it.

	//cnwjo3 par 19683, does all groupIn objects exist in groupOut?
	groupOutMatch := true;
	foreach proxyGroupObj in pProxyObj.allYABlockGroupsIn do
		groupOutIndex := pProxyObj.allYABlockGroupsOut.indexOf(proxyGroupObj);
		if groupOutIndex = 0 then
			groupOutMatch := false;
		endif;
	endforeach;
	
	//cnwjo3 par 19683, if groupIn matches groupOut then keep order of groupOut
	//if groupOut array is missing items of groupIn then do a 'direct' copy
	foreach proxyGroupObj in pProxyObj.allYABlockGroupsIn do
		create groupObj as proxyGroupObj.class persistent;
		groupObj.setPropertyValue(CM_YABlockGroup::description.name, proxyGroupObj.description);
		
		self.allYABlockGroupsIn.atPut(pProxyObj.allYABlockGroupsIn.indexOf(proxyGroupObj), groupObj);
		if groupOutMatch then
			self.allYABlockGroupsOut.atPut(pProxyObj.allYABlockGroupsOut.indexOf(proxyGroupObj), groupObj);
		else
			self.allYABlockGroupsOut.atPut(pProxyObj.allYABlockGroupsIn.indexOf(proxyGroupObj), groupObj);
		endif;
	endforeach;
	
	
	foreach proxyGroupObj in pProxyObj.allYABlockGroupsIn do
	
		create groupObj as proxyGroupObj.class persistent;
		groupObj.setPropertyValue(CM_YABlockGroup::description.name, proxyGroupObj.description);
		
		self.allYABlockGroupsIn.atPut(pProxyObj.allYABlockGroupsIn.indexOf(proxyGroupObj), groupObj);
		if groupOutMatch then  //cnwjo3 par 19683
			self.allYABlockGroupsOut.atPut(pProxyObj.allYABlockGroupsOut.indexOf(proxyGroupObj), groupObj);
		else
			self.allYABlockGroupsOut.atPut(pProxyObj.allYABlockGroupsIn.indexOf(proxyGroupObj), groupObj);
		endif;
		
		if proxyGroupObj.myLastYABlockIn &lt;&gt; null then
			blockObjIn := proxyGroupObj.myLastYABlockIn;
		endif;
		
		if proxyGroupObj.myLastYABlockOut &lt;&gt; null then
			blockObjOut := proxyGroupObj.myLastYABlockOut;
		endif;
		
		foreach proxyBlockObj in proxyGroupObj.allYABlocksIn do
			create blockObj as proxyBlockObj.class persistent;
			
			if proxyBlockObj = blockObjIn then
				groupObj.setLastYABlock(blockObj, true);
			endif;
			
			// Could be on same one.
			if proxyBlockObj = blockObjOut then
				groupObj.setLastYABlock(blockObj, false);
			endif;
			
			// Add the Block to the ungrouped "IN" and "OUT" lists.
			
			self.allYABlocksIn.add(blockObj);
			self.allYABlocksOut.add(blockObj);

			blockObj.setForCreate(proxyBlockObj);
			
			// Add the Block to its "IN" list Group.
			
			groupName	:=	proxyBlockObj.myYABlockGroupIn.description;
			groupObj	:=	self.allYABlockGroupsIn.getGroupByName(groupName);
			groupObj.allYABlocksIn.atPut(proxyGroupObj.allYABlocksIn.indexOf(proxyBlockObj), blockObj);
			
			// Now add the Block to its "OUT" list Group.
			
			outGroupObj	:=	proxyBlockObj.myYABlockGroupOut;
			groupName	:=	outGroupObj.description;
			groupObj	:=	self.allYABlockGroupsOut.getGroupByName(groupName);
			groupObj.allYABlocksOut.atPut(outGroupObj.allYABlocksOut.indexOf(proxyBlockObj), blockObj);
			
			// Copy the Block's Yard Controllers and store it's Terminal Area.

			//par 19727 cnwjo3, sets can't have duplicates
// PAR 32308			if self.allYardControllers.size &gt; 0 then
				create newYardAllocationSet transient;
				blockObj.allYardControllers.copy(newYardAllocationSet);
				foreach tmpObj in newYardAllocationSet discreteLock do
					if tmpObj.allowAddToYardAllocation() then // PAR 32308 GC Shelves only allow 1 yard allocation
						if self.allYardControllers.includes(tmpObj) then
							newYardAllocationSet.remove(tmpObj);  //remove any duplicates from new set
						endif;
					else // GC Shelf LC
						newYardAllocationSet.remove(tmpObj);  // PAR 32308 remove GC Shelf LC as it already has a yard allocation
					endif;
				endforeach;
				newYardAllocationSet.copy(self.allYardControllers);  //copy new no-duplicates to self.allYardControllers
				delete newYardAllocationSet;
// PAR 32308			else
				//we know there won't be duplicates if the allYardControllers is size 0
// PAR 32308				blockObj.allYardControllers.copy(self.allYardControllers);
// PAR 32308			endif;
			
			if not self.allTerminalAreas.includes(blockObj.myTerminalArea) then
				self.allTerminalAreas.add(blockObj.myTerminalArea);
			endif;
			
			// check whether need to update the terminal area screen 
			if tmpTerminalAreaSet.includes(blockObj.myTerminalArea) then			// 18/08/2011 cnwmh5 #27980
				// remove as already exists so don't need to update
				tmpTerminalAreaSet.remove(blockObj.myTerminalArea);
			else
				// doesn't exist so needs adding to terminal area screen
				blockObj.myTerminalArea.causeEvent(self.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA), false, blockObj.myTerminalArea);
			endif;
			
		endforeach;
	endforeach;
	
	// if there is anything left then it has been delete so need to update the terminal area enquiry
	foreach tmpTerminalArea in tmpTerminalAreaSet do			// 18/08/2011 cnwmh5 #27980
		tmpTerminalArea.causeEvent(self.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA), false, tmpTerminalArea);
	endforeach;
	
	// Finally, check that the "IN" and "OUT" lists match in size.  If they don't, something's naffed.
	
	if self.allYABlockGroupsIn.size() &lt;&gt; self.allYABlockGroupsOut.size() then
		// This should never happen!!
		app.raiseUnexpectedProgramError(self.class.name, method.name, "The collections of In and Out Block Groups do not match!");
	endif;
	
	if self.allYABlocksIn.size() &lt;&gt; self.allYABlocksOut.size() then
		// This should never happen!!
		app.raiseUnexpectedProgramError(self.class.name, method.name, "The collections of In and Out Blocks do not match!");
	endif;

	// PAR 32308
	foreach yaLC in self.allYardControllers discreteLock do
		yaLC.setForUpdateFromYA(self);
	endforeach;
	
	self.setCargoMinMaxFromProjectedGC();	//31 Mar 2021	NDL	TFS 49912
	
epilog

	delete tmpTerminalAreaSet;				// 18/08/2011 cnwmh5 #27980
	delete yardAllocationCheckSet;
end;</source>
        <Parameter name="pProxyObj" type="CM_YardAllocation"/>
    </JadeMethod>
