    <JadeMethod name="translateForm" id="8392ff63-4998-49fe-baac-80333344fa89">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0009916, locale);
	chkNotify.translateCaption(Xlat_0009917, locale);
	fldCargoSheet1.translateCaption(Xlat_0009918, locale);
	fldCargoSheet2.translateCaption(Xlat_0009919, locale);
	lblCargoID.translateCaption(Xlat_0009920, locale);
	lblEventRequest.translateCaption(Xlat_0009921, locale);
	lblReference.translateCaption(Xlat_0009922, locale);
	lblReference_1.translateCaption(Xlat_0009923, locale);
	lblReference_1_1.translateCaption(Xlat_0009924, locale);
	lblRemarks.translateCaption(Xlat_0009925, locale);
	lblRemarks_1.translateCaption(Xlat_0009926, locale);
	lblRemarks_1_1.translateCaption(Xlat_0009927, locale);
	lblRemarks_1_1_1.translateCaption(Xlat_0009928, locale);
	lblReqestedTS.translateCaption(Xlat_0009929, locale);
	lblScheduledBy.translateCaption(Xlat_0009930, locale);
	lblScheduledTS.translateCaption(Xlat_0009931, locale);
	lblScheduledTS_1.translateCaption(Xlat_0009932, locale);
	txtCargoId.translateBubbleHelp(Xlat_0018779, locale);
	txtRemarks.translateBubbleHelp(Xlat_0018780, locale);
end;</source>
    </JadeMethod>
</GUIClass>
