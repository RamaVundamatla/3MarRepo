    <JadeMethod name="kpdLog" id="cac57930-dec5-491f-a3ff-4a4eb019f4f0">
        <source>kpdLog(_msg : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2016	cnwkpd1	TFS 488 - Multi Timezone Support


*/

vars

begin
	//write _msg;
	app.writeLog(_msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
epilog

