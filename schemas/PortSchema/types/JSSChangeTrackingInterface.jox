    <JadeMethod name="getClassList" id="11e3090b-b964-4e5f-bd4a-52a8f11008cd">
        <source>getClassList(pSchema : Schema) : ClassColl;
/*
			JSSChangeTrackingSchema Interface Method - DO NOT CHANGE
			
