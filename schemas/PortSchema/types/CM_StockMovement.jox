    <JadeMethod name="addFixup" id="a93ee8c9-2b89-4cbf-9871-6c88ca30aa53">
        <updating/>
        <source>addFixup(_quantity: Integer; _weight : Decimal; _volume : Decimal) updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  The ti to add and a flag to indicate if the move is in or out
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpStr	: String;
	ts		: TimeStamp;		
begin

	self.adjustQuantity	:= self.adjustQuantity + _quantity;
	self.adjustVolume	:= self.adjustVolume + _volume;
	self.adjustWeightKgs := self.adjustWeightKgs + _weight;
	
end;</source>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="addTrackedItem" id="d244dbeb-cc80-4458-b917-863d77b0d34b">
        <updating/>
        <source>addTrackedItem(_ti : CM_TrackedItem; _quantity: Integer; _weight : Decimal; _volume : Decimal;
			   _txn : CM_TITransaction input) updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  The ti to add and a flag to indicate if the move is in or out
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.adjustQuantity	:= self.adjustQuantity + _quantity;
	self.adjustVolume	:= self.adjustVolume + _volume;
	self.adjustWeightKgs := self.adjustWeightKgs + _weight;
	
	if self.myExtension &lt;&gt; null then
		self.myExtension.addTrackedItem(_ti, _quantity, _weight, _volume);
	endif;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_txn" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addTrackedItem_DocketCorrect" id="5a181639-c311-4813-b7b8-0ca9f208d9e2">
        <updating/>
        <source>addTrackedItem_DocketCorrect(_ti: CM_TrackedItem; _trnDateTime: TimeStamp; 
		_quantity: Integer; _weight: Decimal; _volume: Decimal; _txn: CM_TITransaction input) updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2008 by cnwvu1
// ---------------------------------------------------------------------------
vars

begin

	self.adjustQuantity	:= self.adjustQuantity + _quantity;
	self.adjustVolume	:= self.adjustVolume + _volume;
	self.adjustWeightKgs := self.adjustWeightKgs + _weight;
	
	// According to addTrackedItem(). However, this functionality is not used at all.
	//if self.myExtension &lt;&gt; null then
	//	self.myExtension.addTrackedItem(_ti, _quantity, _weight, _volume);
	//endif;
	if self.myExtension &lt;&gt; null then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Docket Correction. StockMovement myExtension &lt;&gt; null' );
	endif;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_trnDateTime" type="TimeStamp"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_txn" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
