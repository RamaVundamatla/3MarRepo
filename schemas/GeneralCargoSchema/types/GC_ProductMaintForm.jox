    <JadeMethod name="doDelete" id="547778c9-85e0-44b8-93ae-7c700960a824">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
// 10.JUN.2025  navsp1      JIRA-34555 MTN | Cargo Type warning form missing Save button
vars

	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteProduct(self.myCurrentObject.CM_Product, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			return true;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Product), app.myPassport, ErrWarnMode_Delete+ErrWarnMode_CanAckWarnings);          //JIRA-34555
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMenuEditAttributes" id="5699fe5d-1eae-45a1-a811-626730c2898c">
        <updating/>
        <source>doMenuEditAttributes() updating;
/* ---------------------------------------------------------------------------
Created:	26 August 2008	by cnwvu1

Purpose:	CCSM 1080 PAR19704
			Calls new CMUI_SubCargoTypeEdit form for attributes edit.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	form			: CMUI_ProductTypeEditForm;
	theTI			: CM_TrackedItem;
	currentProdAttr	: CM_ProductAttr;
	origProductType	: CM_Product;
	pxyProductType	: CM_Product;
	cargoType		: CM_CargoType;
	
begin

	self.mousePointer := Window.MousePointer_HourGlass;
	
	pxyProductType := self.myProxyObject.CM_Product;

	create origProductType transient;
	origProductType.setForUpdate(pxyProductType);
	
	create form;
	form.centreWindow;
	
	form.myProductType := pxyProductType;
	currentProdAttr := self.tblAttributes.accessRow(self.tblAttributes.row).itemObject.CM_ProductAttr;
	form.myCurrentProdAttr := currentProdAttr;

	// where is my cargo type?
	cargoType := pxyProductType.myCargoType;
	if cargoType = null then	// it is null, when adding a new product type - ?! despite the fact that cargo type exists ;(
		cargoType := self.cmbEntCargoType.listObject.CM_CargoType;
		if cargoType = null then
			return;		// when there is no cargo type selected in the combobox and table is empty - just return.
		endif;
	endif;
	form.myCargoType := cargoType;	// finally got cargo type
	pxyProductType.setMyCargoType(cargoType);	//PAR21339 Oct 2009
	
	//self.getAllAttribForSystemProdType(form.allAttributesForProductType);	// all prod attributes are to be included for the system dummy product type 
	form.setMyTerminal(self.myTerminal);
	//form.caption := "Attributes";
	form.setFormParent( self );
	form.myForm := self;	// for saving isCodesEdit need to call CM_TableViewForm :: setIsCodesEdit()
	form.showModal;
	
	if form.modalResult &lt;&gt; IDOK then
		//restore system product before changes
		pxyProductType.setForUpdate(origProductType);
		
	else	// display new product type attributes
		self.displayAttributes(pxyProductType);
		if form.isCodesEdited then	// the warning will be given, when codes were edited
			self.setIsCodesEdited();
		endif;
		
	endif;
	
epilog
	delete origProductType;
	
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
