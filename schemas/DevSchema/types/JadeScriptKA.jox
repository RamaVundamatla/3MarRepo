    <JadeMethod name="kaHarbour" id="20ccf99b-f844-4d04-8b9c-a48db05ecbc2">
        <source>kaHarbour();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 23 January 2023
TFS#		: 
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	origHarbour			: HMS_Harbour;
	harbour				: HMS_Harbour;	
	root 				: CM_Root;
	term 				: CM_Terminal;
begin
	app.initialize();	
	app.myPassport.setMyUserFromCode("JLIKA1");
	root := CM_Root.firstInstance;
	//term := root.allTerminals["JBL"];
	term := root.allTerminals["UT"];
	app.setMyTerminal(term);
	
	//harbour := app.myRoot.allHarbours["QSHIPS"];
	harbour := app.myRoot.allHarbours["UTQSHIP"];
	//origHarbour := app.myRoot.allHarbours["JBL"];
	origHarbour := app.myRoot.allHarbours["HMSAVON"];
	
	/*
	beginTransaction;
	origHarbour.allTerminalsByCode.remove(term);		
	harbour.allTerminalsByCode.add(term);		
	commitTransaction;
	*/
	//reset
	
	beginTransaction;
	harbour.allTerminalsByCode.remove(term);		
	origHarbour.allTerminalsByCode.add(term);		
	//origHarbour.allTerminalsByCode.remove(term);
	commitTransaction;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="notAdhocCamsRun" id="72b49df1-1193-483f-a35e-d119c6da4e7f">
        <source>notAdhocCamsRun();

/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 15 September 2023
TFS#		: 
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
constants
	Terminal1 : String = 'JBL';
vars
	terminal : CM_Terminal;
	bgpRequest : BGP_CamsRequest;
begin
	app.initialize;
	terminal := app.myRoot.allTerminals[Terminal1];
	if terminal = null then
		app.writeStatement('Can not find required terminal ' &amp; Terminal1);
		return;
	endif;
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	app.changeLogLevel(LogDEBUG);
	create bgpRequest transient;
	bgpRequest.setPropertyValue(BGP_CamsRequest::myTerminal.name, terminal);
	bgpRequest.setPropertyValue(BGP_CamsRequest::myUser.name, app.myPassport.myUser);
	bgpRequest.action();
epilog
	delete bgpRequest;
end;</source>
    </JadeMethod>
