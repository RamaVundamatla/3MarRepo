//
//11 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//
vars

begin
	self.transmissionNumber := _value;
end;
</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
</Class>
