/*
Purpose:			Close down ODBC server application

Parameters:			

Return Value:		

Date		Who		Reason
01/11/2012	cnwdap1	Initial creation PAR #30668 SQL Interface for APM Terminals
*/
vars

begin
	app.odbcWorkerFinalize();
	app.finalize();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="finalizeOdbcSelect" id="7b2b8442-07ad-497f-9598-dc434b8a8147">
        <source>finalizeOdbcSelect(rv: RelationalView; username: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Nov 2012	cnwkpd1	PAR #30668 - CCMS APM 2208 - ODBC access to HMS data

*/

vars

begin
