    <JadeMethod name="getMyTaskDesc" id="71038d9f-de7d-4731-b914-44d797f2283f">
        <source>getMyTaskDesc():CM_ToDoTaskDesc;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 October 2010	cnwndl1	Initial creation	Par 23800

*/

vars

	toDoTask : CM_ToDoTask;
	
begin
	
	if myTransaction &lt;&gt; null 
	and self.myTransaction.isKindOf(CM_TITransaction) then
		toDoTask := self.myTransaction.CM_TITransaction.myToDoTask;
		if toDoTask &lt;&gt; null then
			return toDoTask.toDoTaskDesc;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="getMyTaskDescFromType" id="b3bb2d76-9406-4fc5-a84d-fce7d24c97dc">
        <source>getMyTaskDescFromType() : CM_ToDoTaskDesc;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 03/06/2015	cnwdap1		Initial creation PAR #36231 new for this par
//
vars
	obj : CM_Object;
	type : CM_ResourceType;

begin
	type := self.myResourceType;
	foreach obj in type.allUsageContexts do
		if obj.isKindOf(CM_ToDoTaskDesc) then
			return obj.CM_ToDoTaskDesc;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyageCode" id="c967cafd-4fce-4e8e-b4fc-1f265c86c6c4">
        <source>getMyVoyageCode():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 October 2010	cnwndl1	Initial creation	Par 23800

*/

vars

	voyage : CM_Voyage;
	voyageCode : String;
	
begin

	if self.myTransaction &lt;&gt; null 
	and self.myTransaction.isKindOf(CM_TITransaction) then
		voyageCode := self.myTransaction.CM_TITransaction.voyageCode;
		if voyageCode &lt;&gt; null then
			return voyageCode;
		endif;
		voyage := self.myTransaction.getMyVoyage();
		if voyage &lt;&gt; null then
			return voyage.code;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
