    <JadeMethod name="setColorsFromController" id="343916e4-1ccb-4b17-9263-82109edd2aae">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
//--------------------------------------------------
// Created:	23 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_colorControl);
	self.setColorsForTable(self.tblData);
	self.frmSearch.backColor := self.backColor;	
	self.fldDetails.backColor := self.backColor;
	self.barGraph.backColor := self.backColor;
	self.pieGraph.backColor := self.backColor;
	self.lineGraph.backColor := self.backColor;

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setFilterDefaults" id="04245b6f-4d69-4941-be68-e0674a62b1cc">
        <updating/>
        <source>setFilterDefaults(_setDefaults : Boolean) updating, protected;
//--------------------------------------------------
// Created:	23 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	self.filterFromDT := null;
	self.filterToDT := null;

	if _setDefaults then
		self.cmbMonth.listIndex := app.actualTimeServer.date.month;
		self.cmbYear.listIndex := self.cmbYear.findString(1, app.actualTimeServer.date.year.String);		
		self.doSelectAll(self.lstHarbours);		
		self.doSelectAll(self.lstTerminals);		
	else
		self.lstTerminals.clearAllSelected();
	endif;
		
end;</source>
        <access>protected</access>
        <Parameter name="_setDefaults" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="f376eab2-09a4-44b1-9726-c78d3167bdf5">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	01 December 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.setTblDataColumnAlignment();
	self.displayVoyageAnalysis();
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTblDataColumnAlignment" id="c0ea0c52-87d3-497c-8099-591902a08f5e">
        <source>setTblDataColumnAlignment();
//--------------------------------------------------
// Created:	30 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	table : CM_DataTable;
begin
	table := self.tblData;
	table.sortColumn[1] := null;		
	table.accessColumn(table.getColumnByRowName(ETRow_CurrentMthThisYear)).alignment := Table.Alignment_Right_Middle;
	table.accessColumn(table.getColumnByRowName(ETRow_CurrentMthLastYear)).alignment := Table.Alignment_Right_Middle;
	table.accessColumn(table.getColumnByRowName(ETRow_CurrentMthThisFYTD)).alignment := Table.Alignment_Right_Middle;
	table.accessColumn(table.getColumnByRowName(ETRow_CurrentMthLastFYTD)).alignment := Table.Alignment_Right_Middle;
	table.accessColumn(table.getColumnByRowName(ETRow_CurrentMthThisCYTD)).alignment := Table.Alignment_Right_Middle;
	table.accessColumn(table.getColumnByRowName(ETRow_CurrentMthLastCYTD)).alignment := Table.Alignment_Right_Middle;
	table.accessColumn(table.getColumnByRowName(ETRow_ChangeThisLastCYTD)).alignment := Table.Alignment_Right_Middle;
	table.accessColumn(table.getColumnByRowName(ETRow_ChangeThisLastFYTD)).alignment := Table.Alignment_Right_Middle;
								
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="198f7d4f-4075-4261-94bb-44d20a8eb9e7">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	23 November 2005 By: cnwgd1
//--------------------------------------------------
vars
begin
	inheritMethod();

	self.frmToolbar.alignContainer	:=	Frame.AlignContainer_Top; // this will make the dkcMain line up its top	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	self.initTblData();	
	
	self.setNavigatorHeading(self.caption);

	self.beginClassNotification(HMS_Berth, false, Object_Create_Event, Response_Continuous, 0);
	self.beginClassNotification(HMS_Berth, false, Object_Update_Event, Response_Continuous, 0);
	self.beginClassNotification(HMS_Berth, false, Object_Delete_Event, Response_Continuous, 0);	
	
	// not use on this form, disable 
	self.btnSaveBase.enabled := false;

	self.shtLineGraph.visible := true;
	self.shtBarGraph.visible := true;
	self.shtPieGraph.visible := true;	
	
	self.fldDetails.useSheetBackColors := true;
	self.fldDetails.setDefaultSheetBackColors();
	self.fldDetails.initSheetBackColors();


end;</source>
    </JadeMethod>
    <JadeMethod name="showHideSearcher" id="344a448c-606e-4117-973a-1f49129670d6">
        <source>showHideSearcher() protected;
//--------------------------------------------------
// Created:	24 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.btnSearch.enabled := false;

	if self.frmSearch.visible then
		self.frmSearch.visible := false;
	else
		self.btnSearch.enabled := true;
		self.frmSearch.visible := true;
		self.frmSearch.zOrder(1);
		self.frmSearch.centreWindow();
		//We're showing the searcher, move to the first row ready for new values.
		self.cmbMonth.setFocus();
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showWithObjectMode" id="5cb1255e-0866-4e27-a01d-d2afef82a393">
        <updating/>
        <source>showWithObjectMode(_harbour : HMS_Harbour; _doMode: Boolean) updating;
//--------------------------------------------------
// Created:	23 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_harbour, _doMode);

	self.myHarbour := _harbour;

	self.show;

end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_doMode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblData_contextMenu" id="46be4913-5f13-4f2b-baa0-30004f5c9ce0">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------
// Created:	01 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	x1, y1 : Real;
begin

	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	popupMenu(self.mnuTblContext, x1.Integer, y1.Integer);
	return false;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="875618f3-ab60-4ed1-a029-947639bbd0df">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005983, locale);
	btnAllBerths.translateBubbleHelp(Xlat_0001858, locale);
	btnAllBerths.translateCaption(Xlat_0001861, locale);
	btnAllHarbour.translateBubbleHelp(Xlat_0014389, locale);
	btnAllHarbour.translateCaption(Xlat_0014390, locale);
	btnAllTerminals.translateBubbleHelp(Xlat_0001844, locale);
	btnAllTerminals.translateCaption(Xlat_0001846, locale);
	btnAllWharves.translateBubbleHelp(Xlat_0001853, locale);
	btnAllWharves.translateCaption(Xlat_0001856, locale);
	btnCloseSearch.translateBubbleHelp(Xlat_0014391, locale);
	btnCloseSearch.translateCaption(Xlat_0001850, locale);
	btnPrintOptions.translateBubbleHelp(Xlat_0001845, locale);
	btnPrintOptions.translateCaption(Xlat_0001847, locale);
	btnResetSearch.translateBubbleHelp(Xlat_0001849, locale);
	btnResetSearch.translateCaption(Xlat_0001851, locale);
	btnSearch.translateBubbleHelp(Xlat_0001871, locale);
	btnSearch.translateCaption(Xlat_0001872, locale);
	btnShowSearch.translateBubbleHelp(Xlat_0001854, locale);
	btnShowSearch.translateCaption(Xlat_0001857, locale);
	btnThisMonth.translateBubbleHelp(Xlat_0001859, locale);
	btnThisMonth.translateCaption(Xlat_0001862, locale);
	btnThisYear.translateBubbleHelp(Xlat_0001865, locale);
	btnThisYear.translateCaption(Xlat_0001867, locale);
	lblHarbours.translateCaption(Xlat_0005986, locale);
	lblMonth.translateCaption(Xlat_0001873, locale);
	lblTerminals.translateCaption(Xlat_0001863, locale);
	lblYear.translateCaption(Xlat_0001874, locale);
	lstHarbours.translateBubbleHelp(Xlat_0001866, locale);
	lstTerminals.translateBubbleHelp(Xlat_0001860, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0005987, locale);
	mnuPrintOptions.translateCaption(Xlat_0005988, locale);
	mnuTblContext.translateCaption(Xlat_0005989, locale);
	shtBarGraph.translateCaption(Xlat_0001869, locale);
	shtLineGraph.translateCaption(Xlat_0001864, locale);
	shtPieGraph.translateCaption(Xlat_0001870, locale);
	shtTblData.translateCaption(Xlat_0001875, locale);
end;</source>
    </JadeMethod>
