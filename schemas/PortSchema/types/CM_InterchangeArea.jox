    <JadeMethod name="validateRFIDTagReaders" id="186e71f3-8e10-45c3-ac28-345a30abd3b8">
        <source>validateRFIDTagReaders() protected;
// ---------------------------------------------------------------------------
// Created:     11 September 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes 
//				Checks an rfid tag reader isnot used twice on the proxy 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gateLanes	:CM_ObjectArray;
	obj			:Object;
	lane		:CM_LaneController;
	readers		:CM_RFIDTagReaderByCodeDict;
begin
	self.raiseExceptionIfNotTransient (method);
	
	create gateLanes transient;
	create readers transient;
	
	// get lanes for the receiver
	self.getAllLaneControllers (gateLanes);
	
	// now gateLanes contains every lane for every gate area that is part of the gate proxy
	foreach obj in gateLanes do
		lane := obj.CM_LaneController;
	
		if not lane.validateRFIDTagReaderUsage (readers) then
			// we got one that has ben used more than once
		endif;
	endforeach;
epilog
	delete gateLanes;
	delete readers;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
