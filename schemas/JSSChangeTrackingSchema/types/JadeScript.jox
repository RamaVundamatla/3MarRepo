end;</source>
    </JadeMethod>
    <JadeMethod name="getClassesTrackedAndSize" id="1bb82371-b207-4ce7-bda3-b2fb2eb0a22d">
        <source>getClassesTrackedAndSize();

vars
	root: JSSCTChangeTrackingRoot;
	chg: JSSCTChangeTrackingClass;
	file: File;

begin

	root := JSSCTChangeTrackingRoot.firstInstance;

	create file transient;
	file.fileName := "c:\temp\ChangeTrackingSize" &amp;  ".txt";
	file.mode := File.Mode_Output;
	file.open;
	foreach chg in root.allChangeClasses do
		file.writeLine (chg.className &amp; Tab &amp; chg.allChangesByOid.size.String);
	endforeach;
	file.close;

epilog
	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="getClassesTrackedByDate" id="5e012918-83e1-41d7-8b9c-04fe480e6ea0">
        <source>getClassesTrackedByDate();
//
//par 25828 cnwrs1 3 Feb 2011
//
vars
	root: JSSCTChangeTrackingRoot;
	chg: JSSCTChangeTrackingClass;
	changeInstance: JSSCTChangeTrackingObject;
	file: File;
	idx : Integer;
	date : Date;
begin
	root := JSSCTChangeTrackingRoot.firstInstance;
	create file transient;
	file.fileName := "c:\temp\ChangeTrackingSize" &amp;  ".txt";
	file.mode := File.Mode_Output;
	file.open;
	foreach chg in root.allChangeClasses do
		if chg.allChangesByTime.size &gt; 1 then
			file.writeLine(chg.className &amp; Tab &amp; chg.allChangesByOid.size.String);
			date := chg.allChangesByTime.first.changeTimestamp.date;
			idx := 0;
			foreach changeInstance in chg.allChangesByTime do
				if changeInstance.changeTimestamp.date = date then
					idx := idx + 1;
				else
					file.writeLine(chg.className &amp; Tab &amp; date.String&amp;Tab&amp;idx.String);
					date := changeInstance.changeTimestamp.date;
					idx := 1;
				endif;
			endforeach;
		endif;
	endforeach;
	file.close;
epilog
	delete file;
end;
</source>
    </JadeMethod>
    <JadeMethod name="handleException" id="d795837d-a8ca-479c-be3c-e5c6261d17b5">
        <updating/>
        <source>handleException(pException: Exception; pLastException: Integer io; pExceptionCount: Integer io): Integer updating;
/*
		Ignore an exception unless we have the same exception 10 times in a row
*/
begin
	if pException.errorCode = pLastException then
		pExceptionCount := pExceptionCount + 1;
	else
		pLastException := pException.errorCode;
		pExceptionCount := 1;
	endif;
	if pExceptionCount &gt; 10 then
		return (Ex_Abort_Action);
	else
		return (Ex_Continue);
	endif;
end;</source>
        <Parameter name="pException" type="Exception"/>
        <Parameter name="pLastException" type="Integer" usage="io"/>
        <Parameter name="pExceptionCount" type="Integer" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lookForMissingCTrackerObjs" id="0b4de1f2-b93e-4306-8d62-037d1b4f95b1">
        <source>lookForMissingCTrackerObjs();
//
//27 Jul 2016	cnwrs1	Par 38030 C3 Data Extract loosing updates
//
constants
	FileName = "ObjectFindAll";
	LogPath = "d:\Testdb\logs\";
vars
	changeInstance: JSSCTChangeTrackingObject;
	changeInstanceFirst: JSSCTChangeTrackingObject;
	changeInstanceLast: JSSCTChangeTrackingObject;
	changeClass: JSSCTChangeTrackingClass;
	file : File;
	fileCSV : File;
	msg : String;
	dynaDict : DynaDictionary;
	col : Collection;
	any : Any;
	numObjsTested : Integer;
	numObjsTestedTotal : Integer;
	numObjsFound : Integer;
	numObjsFoundTotal : Integer;
	numObjsNotFound : Integer;
	numObjsNotFoundTotal : Integer;
	numCCTObjsNotFound : Integer;
	numCCTObjsNotFoundTotal : Integer;
	numInvalidObj : Integer;
	numInvalidObjTotal : Integer;
	numOutSideTimeInterval : Integer;
	numOutSideTimeIntervalTotal : Integer;
	numUpdateObj : Integer;
	numUpdateObjTotal : Integer;
//	numTrxTimeStamp : Integer;
//	numTrxTimeStampTotal : Integer;
	totalCount : Integer;
	totalCountTotal : Integer;
	numClasses : Integer;
	instId : Integer;
	instIdFirst : Integer;
	instIdLast : Integer;
	classId : Integer;
	portSchema : Schema;
	oidString : String;
	portClass : Class;
	changeObject : Object;
	ts : TimeStamp;
	ts1 : TimeStamp;
	ts2 : TimeStamp;
	root: JSSCTChangeTrackingRoot;
	invalidObject : Boolean;
	trxTimeFirst : TimeStamp;
	trxTimeLast : TimeStamp;
	createdTime : TimeStamp;
	trxTimeStamp : TimeStamp;
//	logPath : String;
//	pos : Integer;
begin
	ts := app.actualTimeServer();
//	logPath	:= app.getProfileString(app.getIniFileName, "CardLog", "LogPath", app.dbPath[1 : pos -1] &amp; "/logs");
	create file transient;
	file.fileName := LogPath&amp;'\'&amp;FileName&amp;".log";
	file.mode := File.Mode_Output;
	create fileCSV transient;
	fileCSV.fileName := LogPath&amp;'\'&amp;FileName&amp;".csv";
	fileCSV.mode := File.Mode_Output;
	msg := "Date,Time,Class,numObjsTested,numObjsFound,numObjsNotFound,numCCTObjsNotFound,numInvalidObj,numObjUpdate,numOutSideTimeInterval,instIds,TotalCounted";
	fileCSV.writeLine(msg);
	root := JSSCTChangeTrackingRoot.firstInstance;
	portSchema := rootSchema.getSchema("PortSchema");
	write "";
	on Exception do app.handleDeletedObject(exception, changeObject, invalidObject);
	//check all classes in ChangeTracker
	foreach changeClass in root.allChangeClasses do
		changeInstanceFirst := changeClass.allChangesByOid.first;
		if changeInstanceFirst = null then
			// change tracker has no changes for that class
			continue;
		endif;
		numClasses := numClasses + 1;
		changeObject := changeInstanceFirst.changeObject;
		classId := self.getClassNumberForObject(changeObject);
		portClass := portSchema.getClassByNumber(classId);
//		if changeClass.className &lt;&gt; "CM_Log" then
//			continue;
//		endif;
//		if changeClass.className = "CM_Carrier" then
//			break;
//		endif;
		ts1 := app.actualTimeServer();
		msg := ts1.String&amp;" Start "&amp;method.name&amp;' for '&amp;changeClass.className;
		write msg;
		file.writeLine(msg);
		//clear out all totals
		numObjsTested := 0;
		numObjsFound := 0;
		numObjsNotFound := 0;
		numCCTObjsNotFound := 0;
		numInvalidObj := 0;
		numOutSideTimeInterval := 0;
		numUpdateObj := 0;
//		numTrxTimeStamp := 0;
		// find the earliest instance and the last instance for this class
		instIdFirst := 0;
		instIdLast := 0;
		trxTimeFirst := null;
		trxTimeLast := null;
		// this section is too slow but not sure how to speed it up as the collection is in oidString order which is not oid order as 2.2 and 2.12 will be in the wrong order
		create dynaDict transient;
		dynaDict.setMembership(JSSCTChangeTrackingObject);
		dynaDict.addMemberKey("changeObject", false, false);
		dynaDict.endKeys(false);
    	changeClass.allChangesByOid.copy(dynaDict);
    	col := dynaDict;
		foreach any in col do
			changeInstance := any.JSSCTChangeTrackingObject;
			invalidObject := false;
			changeObject := changeInstance.changeObject;
			instId := self.getInstanceIdForObject(changeObject).Integer;
			createdTime := changeObject.getPropertyValue("createdTime").TimeStamp;
			if not invalidObject then
				if changeObject.edition = 1 then
					// only interested in creates not updates
					if instIdFirst = 0 then	//first Time;
						instIdFirst := instId;
						trxTimeFirst := changeInstance.changeTimestamp;
						break;
					endif;
				endif;
			endif;
		endforeach;
		if instIdFirst = null then	// didnt find any single edition changeObjects
			continue;
		endif;
		foreach any in col reversed do
			changeInstance := any.JSSCTChangeTrackingObject;
			invalidObject := false;
			changeObject := changeInstance.changeObject;
			instId := self.getInstanceIdForObject(changeObject).Integer;
			createdTime := changeObject.getPropertyValue("createdTime").TimeStamp;
			if not invalidObject then
				if changeObject.edition = 1 then
					// only interested in creates not updates
					if instIdLast = 0 then	//first Time;
						instIdLast := instId;
						trxTimeLast := changeInstance.changeTimestamp;
						break;
					endif;
				endif;
			endif;
		endforeach;
		instId := instIdFirst;
		changeObject := portClass.lastInstance;
		ts2 := app.actualTimeServer();
		// list out the starting deatils first is the lowist instance number last is the highest instance number
		msg := ts2.String&amp;' '&amp;(ts1-ts2).String&amp;" First="&amp;instIdFirst.String&amp;' '&amp;trxTimeFirst.formatAsYYYYMMDDHHMMSSMMM&amp;" Last="&amp;instIdLast.String&amp;' '&amp;trxTimeLast.formatAsYYYYMMDDHHMMSSMMM&amp;' Last DB instance='&amp;self.getInstanceIdForObject(changeObject).Integer.String;
		write msg;
		file.writeLine(msg);
		
		// now we run thru every instance from the lowest istance to the highest instance
		while true do
			invalidObject := false;
			numObjsTested := numObjsTested + 1;
//			if numObjsTested &gt; 80000000 then
//				break;
//			endif;
			// turn the next instance number into anactual portachema object
			oidString := classId.String&amp;'.'&amp;instId.String;
			changeObject := oidString.asOid;
			// force the deleted object exception if the generated oid does not exist
			createdTime := changeObject.getPropertyValue("createdTime").TimeStamp;
			if not invalidObject then
				if changeObject &lt;&gt; null then 
					if changeObject.edition &lt;&gt; 1 then
						// change tracker updates not craete so just count them 
						numUpdateObj := numUpdateObj + 1;
					else
						changeInstance := changeClass.allChangesByOid[oidString];
						if changeInstance &lt;&gt; null then
							trxTimeStamp := changeInstance.changeTimestamp;	//.truncateToSecond;
							if trxTimeStamp &gt;= trxTimeFirst and
							   trxTimeStamp &lt;= trxTimeLast then
								// the object has been created and has a change tracker record this is the normal case
								numObjsFound := numObjsFound + 1 ;
							else
								// the object was created outside our change tracker time period wouldn't expect there to be any 
								msg := " Outside update period changeTimestamp="&amp;changeInstance.changeTimestamp.formatAsYYYYMMDDHHMMSSMMM&amp;' trxTimeStamp='&amp;changeInstance.trxTimestamp.formatAsYYYYMMDDHHMMSSMMM&amp;' '&amp;changeInstance.String;
								if numOutSideTimeInterval &lt; 10 then
									write msg;
								endif;
								file.writeLine(msg);
								numOutSideTimeInterval := numOutSideTimeInterval + 1;
							endif;
//							if changeInstance.trxTimestamp = null then
//								numTrxTimeStamp := numTrxTimeStamp + 1;
//							endif;
						else
							// this is the problem area we have an instid that was created in the time period that change tracker is covering but we dont have a change tracker record.
							if numCCTObjsNotFound &lt; 100 then
								msg := "No JSSCT Change object "&amp;changeObject.String&amp;' '&amp;oidString.String;
								file.writeLine(msg);
							endif;
							numCCTObjsNotFound := numCCTObjsNotFound + 1;
						endif;
					endif;
				else
					// not likly to happen so should be zero
					numObjsNotFound := numObjsNotFound + 1;
				endif;
			else
				// we count how many of the generated oids are invalid but we are not interested in then, it just means the object has been deletd in PortSchema after it has been created
				numInvalidObj := numInvalidObj + 1;
			endif;
			// increment the instance number for the next cycle
			instId := instId + 1;
			//if the next instance is greater then the last then break the while look and move on to the next class
			if instId &gt; instIdLast then
				break;
			endif;
			// is the log file is getter too big create another one
			if file.fileLength &gt;  (100 * 1048576) then
				file.close;
				file.fileName := LogPath&amp;'\'&amp;FileName&amp;".log";
				file.mode := File.Mode_Append;
				file.open;
				ts := app.actualTimeServer();
				msg := LogPath&amp;'\'&amp;FileName&amp;""&amp; "_" &amp; ts.Date.format('yyyMMdd') &amp; "_" &amp; ts.Time.format('HHmmss') &amp; ".log";
				file.rename(msg);
				file.close;
				file.fileName := LogPath&amp;'\'&amp;FileName&amp;".log";
				file.mode := File.Mode_Output;
				file.open;
			endif;
		endwhile;
		// wrapup the totals for the current class
		ts := app.actualTimeServer();
		totalCount := numObjsFound + numObjsNotFound + numCCTObjsNotFound + numInvalidObj + numUpdateObj + numOutSideTimeInterval;
		msg := ts.String&amp;" Fin  "&amp;changeClass.className&amp;' numObjsTested='&amp;numObjsTested.String&amp;' numObjsFound='&amp;numObjsFound.String&amp;' numObjsNotFound='&amp;numObjsNotFound.String&amp;' numCCTObjsNotFound='&amp;numCCTObjsNotFound.String&amp;' numInvalidObj='&amp;numInvalidObj.String&amp;' numObjUpdate='&amp;numUpdateObj.String&amp;' numOutSideTimeInterval='&amp;numOutSideTimeInterval.String&amp;' instIds='&amp;(instIdLast-instIdFirst+1).String&amp;' TotalCounted='&amp;totalCount.String;
		write msg;
		file.writeLine(msg);
		msg := ts.String&amp;','&amp;changeClass.className&amp;','&amp;numObjsTested.String&amp;','&amp;numObjsFound.String&amp;','&amp;numObjsNotFound.String&amp;','&amp;numCCTObjsNotFound.String&amp;','&amp;numInvalidObj.String&amp;','&amp;numUpdateObj.String&amp;','&amp;numOutSideTimeInterval.String&amp;','&amp;(instIdLast-instIdFirst+1).String&amp;','&amp;totalCount.String;
		fileCSV.writeLine(msg);
		// accumulate totals
		numObjsTestedTotal := numObjsTestedTotal + numObjsTested;
		numObjsFoundTotal := numObjsFoundTotal + numObjsFound;
		numObjsNotFoundTotal := numObjsNotFoundTotal + numObjsNotFound;
		numCCTObjsNotFoundTotal := numCCTObjsNotFoundTotal + numCCTObjsNotFound;
		numInvalidObjTotal := numInvalidObjTotal + numInvalidObj;
		numOutSideTimeIntervalTotal := numOutSideTimeIntervalTotal + numOutSideTimeInterval;
		numUpdateObjTotal := numUpdateObjTotal + numUpdateObj;
		totalCountTotal := totalCountTotal + totalCount;
//		numTrxTimeStampTotal := numTrxTimeStampTotal + numTrxTimeStamp;
	endforeach;
epilog
	ts := app.actualTimeServer();
	msg := ts.String&amp;" Fin  "&amp;method.name&amp;' numObjsTestedTotal='&amp;numObjsTestedTotal.String&amp;' numObjsFoundTotal='&amp;numObjsFoundTotal.String&amp;' numObjsNotFoundTotal='&amp;numObjsNotFoundTotal.String&amp;' numCCTObjsNotFoundTotal='&amp;numCCTObjsNotFoundTotal.String&amp;' numInvalidObjTotal='&amp;numInvalidObjTotal.String&amp;' numOutSideTimeIntervalTotal='&amp;numOutSideTimeIntervalTotal.String&amp;' totalCountTotal='&amp;totalCountTotal.String;
	write msg;
	file.writeLine(msg);
	file.close;
	delete file;
	msg := ts.String&amp;","&amp;"ALL"&amp;','&amp;numObjsTestedTotal.String&amp;','&amp;numObjsFoundTotal.String&amp;','&amp;numObjsNotFoundTotal.String&amp;','&amp;numCCTObjsNotFoundTotal.String&amp;','&amp;numInvalidObjTotal.String&amp;','&amp;numUpdateObjTotal.String&amp;','&amp;numOutSideTimeIntervalTotal.String&amp;','&amp;' '&amp;','&amp;totalCountTotal.String;
	fileCSV.writeLine(msg);
	fileCSV.close;
	delete fileCSV;
end;

</source>
    </JadeMethod>
    <JadeMethod name="lookForMissingCTrackerObjs_2" id="b4d72719-9ba3-41a7-8a27-6c61b370d7a2">
        <source>lookForMissingCTrackerObjs_2();
//
//27 Jul 2016	cnwrs1	Par 38030 C3 Data Extract loosing updates
//
constants
	FileName = "ObjectFindAll";
	LogPath = "g:\Testdb\logs\";
vars
	changeInstance: JSSCTChangeTrackingObject;
	changeInstanceFirst: JSSCTChangeTrackingObject;
	changeInstanceLast: JSSCTChangeTrackingObject;
	lastChangeInstance : JSSCTChangeTrackingObject;
	changeClass: JSSCTChangeTrackingClass;
	file : File;
	fileCSV : File;
	msg : String;
	dynaDict : DynaDictionary;
	col : Collection;
	any : Any;
	numObjsTested : Integer;
	numObjsTestedTotal : Integer;
	numObjsFound : Integer;
	numObjsFoundTotal : Integer;
	numObjsNotFound : Integer;
	numObjsNotFoundTotal : Integer;
	numCCTObjsNotFound : Integer;
	numCCTObjsNotFoundTotal : Integer;
	numInvalidObj : Integer;
	numInvalidObjTotal : Integer;
	numOutSideTimeInterval : Integer;
	numOutSideTimeIntervalTotal : Integer;
	numUpdateObj : Integer;
	numUpdateObjTotal : Integer;
	totalCount : Integer;
	totalCountTotal : Integer;
	numClasses : Integer;
	numCCTObjsNotFoundThisTime : Integer;
	instId : Integer;
	instIdFirst : Integer;
	instIdLast : Integer;
	classId : Integer;
	portSchema : Schema;
	oidString : String;
	portClass : Class;
	changeObject : Object;
	ts : TimeStamp;
	ts1 : TimeStamp;
	ts2 : TimeStamp;
	root: JSSCTChangeTrackingRoot;
	invalidObject : Boolean;
	trxTimeFirst : TimeStamp;
	trxTimeLast : TimeStamp;
	createdTime : TimeStamp;
	lastCreatedTime : TimeStamp;
	trxTimeStamp : TimeStamp;
begin
	ts := app.actualTimeServer();
	create file transient;
	file.fileName := LogPath&amp;'\'&amp;FileName&amp;".log";
	file.mode := File.Mode_Output;
	create fileCSV transient;
	fileCSV.fileName := LogPath&amp;'\'&amp;FileName&amp;".csv";
	fileCSV.mode := File.Mode_Output;
	msg := "Date,Time,Class,numObjsTested,numObjsFound,numObjsNotFound,numCCTObjsNotFound,numInvalidObj,numObjUpdate,numOutSideTimeInterval,instIds,TotalCounted";
	fileCSV.writeLine(msg);
	root := JSSCTChangeTrackingRoot.firstInstance;
	portSchema := rootSchema.getSchema("PortSchema");
	write "";
	on Exception do app.handleDeletedObject(exception, changeObject, invalidObject);
	//check all classes in ChangeTracker
	foreach changeClass in root.allChangeClasses do
		changeInstanceFirst := changeClass.allChangesByOid.first;
		if changeInstanceFirst = null then
			// change tracker has no changes for that class
			continue;
		endif;
		numClasses := numClasses + 1;
		changeObject := changeInstanceFirst.changeObject;
		classId := self.getClassNumberForObject(changeObject);
		portClass := portSchema.getClassByNumber(classId);
		// set this up if only wanting to run for that class
//		if changeClass.className &lt;&gt; "CM_ReceiveRoad" then
//			continue;
//		endif;
		// set this up if you want to stop at after that class
//		if changeClass.className = "CM_Carrier" then
//			break;
//		endif;
		ts1 := app.actualTimeServer();
		msg := ts1.String&amp;" Start "&amp;method.name&amp;' for '&amp;changeClass.className;
		write msg;
		file.writeLine(msg);
		//clear out all totals
		numObjsTested := 0;
		numObjsFound := 0;
		numObjsNotFound := 0;
		numCCTObjsNotFound := 0;
		numCCTObjsNotFoundThisTime := 0;
		numInvalidObj := 0;
		numOutSideTimeInterval := 0;
		numUpdateObj := 0;
		// find the earliest instance and the last instance for this class
		instIdFirst := 0;
		instIdLast := 0;
		trxTimeFirst := null;
		trxTimeLast := null;
		// this section determines the lowest and highest iod values
		create dynaDict transient;
		dynaDict.setMembership(JSSCTChangeTrackingObject);
		dynaDict.addMemberKey("changeObject", false, false);
		dynaDict.endKeys(false);
    	changeClass.allChangesByOid.copy(dynaDict);
    	col := dynaDict;
		foreach any in col do
			changeInstance := any.JSSCTChangeTrackingObject;
			invalidObject := false;
			changeObject := changeInstance.changeObject;
			instId := self.getInstanceIdForObject(changeObject).Integer;
			createdTime := changeObject.getPropertyValue("createdTime").TimeStamp;
			if not invalidObject then
				if changeObject.edition = 1 then
					// only interested in creates not updates
					if instIdFirst = 0 then	//first Time;
						instIdFirst := instId;
						trxTimeFirst := changeInstance.changeTimestamp;
						break;
					endif;
				endif;
			endif;
		endforeach;
		if instIdFirst = null then	// didnt find any single edition changeObjects
			continue;
		endif;
		foreach any in col reversed do
			changeInstance := any.JSSCTChangeTrackingObject;
			invalidObject := false;
			changeObject := changeInstance.changeObject;
			instId := self.getInstanceIdForObject(changeObject).Integer;
			createdTime := changeObject.getPropertyValue("createdTime").TimeStamp;
			if not invalidObject then
				if changeObject.edition = 1 then
					// only interested in creates not updates
					if instIdLast = 0 then	//first Time;
						instIdLast := instId;
						trxTimeLast := changeInstance.changeTimestamp;
						break;
					endif;
				endif;
			endif;
		endforeach;
		instId := instIdFirst;
		changeObject := portClass.lastInstance;
		ts2 := app.actualTimeServer();
		// list out the starting deatils first is the lowist instance number last is the highest instance number
		msg := ts2.String&amp;' '&amp;(ts1-ts2).String&amp;" First="&amp;instIdFirst.String&amp;' '&amp;trxTimeFirst.formatAsYYYYMMDDHHMMSSMMM&amp;" Last="&amp;instIdLast.String&amp;' '&amp;trxTimeLast.formatAsYYYYMMDDHHMMSSMMM&amp;' Last DB instance='&amp;self.getInstanceIdForObject(changeObject).Integer.String;
		write msg;
		file.writeLine(msg);
		
		// now we step thru every instance from the lowest istance to the highest instance
		while true do
			invalidObject := false;
			numObjsTested := numObjsTested + 1;
//			if numObjsTested &gt; 80000000 then
//				break;
//			endif;
			// turn the next instance number into an actual portschema object
			oidString := classId.String&amp;'.'&amp;instId.String;
			changeObject := oidString.asOid;
			// force the deleted object exception if the generated oid does not exist
			createdTime := changeObject.getPropertyValue("createdTime").TimeStamp;
			if not invalidObject then
				if changeObject &lt;&gt; null then 
					if changeObject.edition &lt;&gt; 1 then
						// change tracker updates not create so just count them 
						numUpdateObj := numUpdateObj + 1;
					else
						changeInstance := changeClass.allChangesByOid[oidString];
						if changeInstance &lt;&gt; null then
							trxTimeStamp := changeInstance.changeTimestamp;	//.truncateToSecond;
							if trxTimeStamp &gt;= trxTimeFirst and
							   trxTimeStamp &lt;= trxTimeLast then
								// the object has been created and has a change tracker record this is the normal case
								numObjsFound := numObjsFound + 1 ;
							else
								// the object was created outside our change tracker time period wouldn't expect there to be any 
								msg := " Outside update period changeTimestamp="&amp;changeInstance.changeTimestamp.formatAsYYYYMMDDHHMMSSMMM&amp;' trxTimeStamp='&amp;changeInstance.trxTimestamp.formatAsYYYYMMDDHHMMSSMMM&amp;' '&amp;changeInstance.String;
								if numOutSideTimeInterval &lt; 10 then
									write msg;
								endif;
								file.writeLine(msg);
								numOutSideTimeInterval := numOutSideTimeInterval + 1;
							endif;
							lastChangeInstance := changeInstance;
							numCCTObjsNotFoundThisTime := 0;
						else
							// this is the problem area we have an instid that was created in the time period that change tracker is covering but we dont have a change tracker record.
							if createdTime.date &gt; ts.jssAddDays(-10).date then
								msg := "No JSSCT Change object "&amp;changeObject.String&amp;' createdTime='&amp;createdTime.formatAsYYYYMMDDHHMMSSMMM;
								if lastChangeInstance &lt;&gt; null then
									lastCreatedTime := lastChangeInstance.changeObject.getPropertyValue("createdTime").TimeStamp;
									msg := msg&amp;' lastChangeInstance is '&amp;lastChangeInstance.String&amp;' changeTimeStamp='&amp;lastChangeInstance.changeTimestamp.formatAsYYYYMMDDHHMMSSMMM&amp;' creationTime='&amp;lastChangeInstance.creationTime.formatAsYYYYMMDDHHMMSSMMM&amp;' lastCreatedTime='&amp;lastCreatedTime.formatAsYYYYMMDDHHMMSSMMM;
								endif;
								file.writeLine(msg);
							endif;
							lastChangeInstance := null;
							numCCTObjsNotFound := numCCTObjsNotFound + 1;
							numCCTObjsNotFoundThisTime := numCCTObjsNotFoundThisTime + 1;
						endif;
					endif;
				else
					// not likly to happen so should be zero
					numObjsNotFound := numObjsNotFound + 1;
				endif;
			else
				// we count how many of the generated oids are invalid but we are not interested in then, it just means the object has been deletd in PortSchema after it has been created
				numInvalidObj := numInvalidObj + 1;
			endif;
			// increment the instance number for the next cycle
			instId := instId + 1;
			//if the next instance is greater then the last then break the while look and move on to the next class
			if instId &gt; instIdLast then
				break;
			endif;
			// is the log file is geting too big create another one
			if file.fileLength &gt;  (100 * 1048576) then
				file.close;
				file.fileName := LogPath&amp;'\'&amp;FileName&amp;".log";
				file.mode := File.Mode_Append;
				file.open;
				ts := app.actualTimeServer();
				msg := LogPath&amp;'\'&amp;FileName&amp;""&amp; "_" &amp; ts.Date.format('yyyMMdd') &amp; "_" &amp; ts.Time.format('HHmmss') &amp; ".log";
				file.rename(msg);
				file.close;
				file.fileName := LogPath&amp;'\'&amp;FileName&amp;".log";
				file.mode := File.Mode_Output;
				file.open;
			endif;
		endwhile;
		// wrapup the totals for the current class
		ts := app.actualTimeServer();
		totalCount := numObjsFound + numObjsNotFound + numCCTObjsNotFound + numInvalidObj + numUpdateObj + numOutSideTimeInterval;
		msg := ts.String&amp;' '&amp;(ts1-ts).String&amp;" Fin  "&amp;changeClass.className&amp;' numObjsTested='&amp;numObjsTested.String&amp;' numObjsFound='&amp;numObjsFound.String&amp;' numObjsNotFound='&amp;numObjsNotFound.String&amp;' numCCTObjsNotFound='&amp;numCCTObjsNotFound.String&amp;' numInvalidObj='&amp;numInvalidObj.String&amp;' numObjUpdate='&amp;numUpdateObj.String&amp;' numOutSideTimeInterval='&amp;numOutSideTimeInterval.String&amp;' instIds='&amp;(instIdLast-instIdFirst+1).String&amp;' TotalCounted='&amp;totalCount.String;
		write msg;
		file.writeLine(msg);
		msg := ts.String&amp;','&amp;changeClass.className&amp;','&amp;numObjsTested.String&amp;','&amp;numObjsFound.String&amp;','&amp;numObjsNotFound.String&amp;','&amp;numCCTObjsNotFound.String&amp;','&amp;numInvalidObj.String&amp;','&amp;numUpdateObj.String&amp;','&amp;numOutSideTimeInterval.String&amp;','&amp;(instIdLast-instIdFirst+1).String&amp;','&amp;totalCount.String;
		fileCSV.writeLine(msg);
		// accumulate totals
		numObjsTestedTotal := numObjsTestedTotal + numObjsTested;
		numObjsFoundTotal := numObjsFoundTotal + numObjsFound;
		numObjsNotFoundTotal := numObjsNotFoundTotal + numObjsNotFound;
		numCCTObjsNotFoundTotal := numCCTObjsNotFoundTotal + numCCTObjsNotFound;
		numInvalidObjTotal := numInvalidObjTotal + numInvalidObj;
		numOutSideTimeIntervalTotal := numOutSideTimeIntervalTotal + numOutSideTimeInterval;
		numUpdateObjTotal := numUpdateObjTotal + numUpdateObj;
		totalCountTotal := totalCountTotal + totalCount;
	endforeach;
epilog
	ts := app.actualTimeServer();
	msg := ts.String&amp;" Fin  "&amp;method.name&amp;' numObjsTestedTotal='&amp;numObjsTestedTotal.String&amp;' numObjsFoundTotal='&amp;numObjsFoundTotal.String&amp;' numObjsNotFoundTotal='&amp;numObjsNotFoundTotal.String&amp;' numCCTObjsNotFoundTotal='&amp;numCCTObjsNotFoundTotal.String&amp;' numInvalidObjTotal='&amp;numInvalidObjTotal.String&amp;' numOutSideTimeIntervalTotal='&amp;numOutSideTimeIntervalTotal.String&amp;' totalCountTotal='&amp;totalCountTotal.String;
	write msg;
	file.writeLine(msg);
	file.close;
	delete file;
	msg := ts.String&amp;","&amp;"ALL"&amp;','&amp;numObjsTestedTotal.String&amp;','&amp;numObjsFoundTotal.String&amp;','&amp;numObjsNotFoundTotal.String&amp;','&amp;numCCTObjsNotFoundTotal.String&amp;','&amp;numInvalidObjTotal.String&amp;','&amp;numUpdateObjTotal.String&amp;','&amp;numOutSideTimeIntervalTotal.String&amp;','&amp;' '&amp;','&amp;totalCountTotal.String;
	fileCSV.writeLine(msg);
	fileCSV.close;
	delete fileCSV;
	delete dynaDict;
end;

</source>
    </JadeMethod>
    <JadeMethod name="makeTestingData" id="c34aa0ce-9180-4330-a048-5e7db4c65a6e">
        <source>makeTestingData();

vars
	ta : JSSChangeTrackingObjectTA;
	idx : Integer;
	tranID : Integer;
	timestamp : TimeStamp;
	object : Object;
	tmpSchema : Schema;
	tmpClass : Class;
	className : String;
	changeClass : JSSCTChangeTrackingClass;
	cto : JSSCTChangeTrackingObject;
	ctRoot : JSSCTChangeTrackingRoot;
	objectOidString : String;
	date : Date;
begin
	date := "01/01/2008".asDate;
	timestamp.setDate(date);
	tmpSchema := rootSchema.getSchema("PortSchema");
	ctRoot := JSSCTChangeTrackingRoot.firstInstance;
	foreach changeClass in ctRoot.allChangeClasses do
		className := changeClass.className;
		write 'Started for Class='&amp;className&amp;'.';
		tmpClass := tmpSchema.getClass(className);
		object := tmpClass.firstInstance;
		create ta transient;
		ta.changeAction := JSSCTChangeTrackingObject.ACTION_CREATE;
		ta.myChangeTrackingRoot := ctRoot;
		ta.changeTimestamp := timestamp;
		ta.changeTransactionID := null;
		ta.className := className;
		ta.myChangeClass := changeClass;
		ta.myChangeObject := null;
		ta.trxTimestamp := timestamp;
		idx := 1;
		beginTransaction;
		foreach object in tmpClass.instances do
			objectOidString := object.getOidString();
			if changeClass.allChangesByOid[objectOidString] &lt;&gt; null then
				continue;
			endif;
			ta.changeObject := object;
			ta.changeObjectID := objectOidString;
			idx := idx + 1;
			ta.changeSequence := idx;
			create cto;
			cto.createEntity(ta);
			if idx mod 10000 = 0 then
				commitTransaction;
				write 'Created for Class='&amp;className&amp;' idx='&amp;idx.String;
				beginTransaction;
			endif;
		endforeach;
		commitTransaction;
	write 'Finished for Class='&amp;className&amp;' idx='&amp;idx.String;
	endforeach;
	write 'Finished.';
epilog
//	commitTransaction;
	delete ta;
end;
</source>
    </JadeMethod>
    <JadeMethod name="mapTFS46791" id="570c3c54-da8c-48e2-aff3-7a2e270e0483">
        <source>mapTFS46791();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 October 2019	jlgmp6	Initial creation

*/

vars
	ctInterface : JSSCTChangeTrackingInterface;
	pFromTimeStamp : TimeStamp;
	pToTimeStamp : TimeStamp;
	date : Date;
	ts : TimeStamp;
	idx,i : Integer;
	time : Time;
	pClassName : String;
	changeObject	: JSSChangeTrackingObjectTA;
	myChangeObjectTA: JSSChangeTrackingObjectTA;
	msg : String;
	changedTs : TimeStamp;
	result : Integer;
begin
	create ctInterface transient;
	create changeObject transient;
	pClassName := "CM_InvoiceLine";
	date := "18/09/2019".Date;
	time := "16:14:00".Time;
	ts.setDate(date);
	ts.setTime(time);
	pFromTimeStamp := ts;
	time := "16:35:00".Time;
	ts.setTime(time);
	pToTimeStamp := ts;
	idx := ctInterface.selectClassChanges(pClassName, pFromTimeStamp, pToTimeStamp, null);
	app.msgBox("From:"&amp;pFromTimeStamp.String&amp;" to:"&amp;pToTimeStamp.String&amp;' number='&amp;idx.String,"",0);
//	foreach i in 1 to idx do
	while ctInterface.getNextClassChange(changeObject) = 0 do
//		result := ctInterface.getNextClassChange(changeObject);
		if result = 0 then
			msg := msg&amp;changeObject.changeObjectID&amp;' '&amp;changeObject.changeTimestamp.String&amp;CrLf;
		else
		msg := msg&amp;'result='&amp;result.String;
		endif;
	endwhile;
	app.msgBox("",msg,0);
epilog
	delete ctInterface;
	delete changeObject;
end;</source>
    </JadeMethod>
    <JadeMethod name="polDeleteChangeTrackerOids" id="9801789a-f2df-4cb7-ba61-89a4cc369cd0">
        <source>polDeleteChangeTrackerOids();

constants

vars
	cls : JSSCTChangeTrackingClass;
	root : JSSCTChangeTrackingRoot;
	jssctObj : JSSCTChangeTrackingObject;
	className : String;
	inst : Integer;
	objInst : Integer;
	obj : Object;
	noTrans : Boolean;
	file : File;
	count : Integer;
begin
	create file transient;
	file.fileName := "C:\polpjmt\logs\cct_cleanup.txt";
	file.mode := File.Mode_Output;
	file.open;
	root := JSSCTChangeTrackingRoot.firstInstance;
	foreach cls in root.allChangeClasses do
		noTrans := false;
		inst := 0;
		count := 0;
		className := cls.className;
		if className = "CM_Attach" then
			inst := #4A23;
		elseif className = "CM_AvailableForRelease" then
		elseif className = "CM_BBDiscrepancy" then					
		elseif className = "CM_BOLCreate" then
		elseif className = "CM_BOLStatusMessageReceived" then
		elseif className = "CM_BOLStopCleared" then
		elseif className = "CM_BOLStopCreated" then
		elseif className = "CM_BusinessUnitReceive" then
		elseif className = "CM_BusinessUnitRelease" then
		elseif className = "CM_CAMSAudit" then
		elseif className = "CM_ChillTest" then
			inst := #03A2;
		elseif className = "CM_Connect" then
			inst := #01A7B7;
		elseif className = "CM_ConnectPower" then
			inst := #054522;
		elseif className = "CM_ConnectTower" then
			inst := #01343D;
		elseif className = "CM_Create" then
			inst := #053F75D;
		elseif className = "CM_CscInspect" then
			inst := #0207B;
		elseif className = "CM_Curtain" then
			inst := #07D;
		elseif className = "CM_CustomStopClear" then
			inst := #09C42;
		elseif className = "CM_DairyBoard" then
			inst := #0117B0;
		elseif className = "CM_Damage" then
			inst := #03EBF0;
		elseif className = "CM_Detach" then
			inst := #02FA1;
		elseif className = "CM_Dimension" then	
		elseif className = "CM_Disassembly" then
		elseif className = "CM_DisconnectPower" then
			inst := #0526BE;
		elseif className = "CM_DisconnectTower" then
			inst := #01310D;
		elseif className = "CM_DocketCorrection" then
		elseif className = "CM_DutyCharge" then	
		elseif className = "CM_Edit" then
			inst := #071581A;
		elseif className = "CM_EditOperator" then
			inst := #014C58;
		elseif className = "CM_EditProductCode" then
			inst := #04F2;
		elseif className = "CM_Erase" then
		elseif className = "CM_ExportReturned" then
			inst := #0F0;
		elseif className = "CM_ExternalClean" then
			inst := #0EB8;
		elseif className = "CM_FreeStorageAdjustment" then
		elseif className = "CM_Fuel" then
			inst := #03;
		elseif className = "CM_Fumigation" then
			inst := #02D1;
		elseif className = "CM_FutureStorage" then
		elseif className = "CM_Generic" then
		elseif className = "CM_HideLined" then
			inst := #05;
		elseif className = "CM_Hire" then
		elseif className = "CM_InfoEDISent" then
		elseif className = "CM_Information" then
			inst := #03AE17F;
		elseif className = "CM_Inspect" then
			inst := #0567CC;
		elseif className = "CM_InterStorageTransport" then
		elseif className = "CM_LogNoNumberOffload" then
		elseif className = "CM_LogNoNumberRetain" then
		elseif className = "CM_LogNoNumberSwap" then
		elseif className = "CM_Merge" then
		elseif className = "CM_Move" then
			inst := #05B7D8;
		elseif className = "CM_NeedsDairyBoard" then 
		elseif className = "CM_NeedsPreTrip " then
		elseif className = "CM_NeedsWash " then	
		elseif className = "CM_Offload" then
		elseif className = "CM_OperatorStopClear" then
		elseif className = "CM_Pack" then
			inst := #072EF2;
		elseif className = "CM_PackComplete" then
			inst := #028CD5;
		elseif className = "CM_PartRepair" then
			inst := #0E0F;
		elseif className = "CM_Pickup" then
			inst := #02E4733;
		elseif className = "CM_PreTrip" then
			inst := #058D76;
		elseif className = "CM_Probe" then
			inst := #0111;
		elseif className = "CM_Reassembly" then
		elseif className = "CM_ReceivalOutsideRestriction" then
			inst := #014A8;
		elseif className = "CM_Receive" then
			inst := #040549;
		elseif className = "CM_ReceivedPowerOffExceeded" then 
		elseif className = "CM_ReceiveRail" then
			inst := #059A4C;
		elseif className = "CM_ReceiveRailInterTerminal" then
			inst := #02CB;
		elseif className = "CM_ReceiveRoad" then
			inst := #069257;
		elseif className = "CM_ReceiveRoadInterTerminal" then
			inst := #05F70;
		elseif className = "CM_ReceiveShip" then
			inst := #0BD220;
		elseif className = "CM_ReceiveTranship" then
		elseif className = "CM_ReeferDaily" then
			inst := #025966;
		elseif className = "CM_ReeferFlatRate" then
		elseif className = "CM_ReeferMonitor" then
		elseif className = "CM_ReinstateReject" then
		elseif className = "CM_Reject" then
			inst := #01E4;
		elseif className = "CM_Release" then
			inst := #030D84;
		elseif className = "CM_ReleaseRail" then
			inst := #0398E6;
		elseif className = "CM_ReleaseRailInterTerminal" then
			inst := #0118A7;
		elseif className = "CM_ReleaseRoad" then
			inst := #05D085;
		elseif className = "CM_ReleaseRoadInterTerminal" then
			inst := #04848;
		elseif className = "CM_ReleaseShip" then	
			inst := #0CF32A;
		elseif className = "CM_ReleaseTranship" then
		elseif className = "CM_RelRequestAssign" then	
			inst := #08C56;
		elseif className = "CM_RelRequestUnassign" then
			inst := #0D15;
		elseif className = "CM_RemoveDoors" then
		elseif className = "CM_Repack" then
			inst := #022;
		elseif className = "CM_Repaint" then
		elseif className = "CM_Repair" then
			inst := #0E9EE;
		elseif className = "CM_RepairsApproved" then
		elseif className = "CM_RollBooking" then
			inst := #0A0;
		elseif className = "CM_Seal" then
			inst := #011821;
		elseif className = "CM_SealCheck" then
		elseif className = "CM_SetDown" then
			inst := #03089F6;
		elseif className = "CM_Split" then
		elseif className = "CM_SplitBooking" then
		elseif className = "CM_StatusMessageReceived" then
		elseif className = "CM_SteamClean" then
			inst := #03E52;
		elseif className = "CM_StopAdd" then
			inst := #0127583;
		elseif className = "CM_StopCancel" then
		elseif className = "CM_StopCleared" then
			inst := #0E8939;
		elseif className = "CM_StopOverride" then
		elseif className = "CM_StopUpdate" then
		elseif className = "CM_Storage" then
			inst := #0246028;
		elseif className = "CM_StowageConfirmation" then   
		elseif className = "CM_SubTerminalEdit" then
		elseif className = "CM_SubTerminalReceiveDepot" then
			inst := #05;
		elseif className = "CM_SubTerminalReceiveMarine" then
			inst := #0A75C;
		elseif className = "CM_SubTerminalReceiveWHouse" then
		elseif className = "CM_SubTerminalReleaseDepot" then
		elseif className = "CM_SubTerminalReleaseMarine" then
		elseif className = "CM_SubTerminalReleaseWHouse" then
		elseif className = "CM_SubTermReceiveDepotIntern" then
			inst := #04A50;
		elseif className = "CM_SubTermReceiveDepotRail" then
			inst := #01707;
		elseif className = "CM_SubTermReceiveDepotRoad" then
			inst := #04320;
		elseif className = "CM_SubTermReceiveDepotShip" then
			inst := #026437;
		elseif className = "CM_SubTermReceiveMarineIntern" then
			inst := #014BD6;
		elseif className = "CM_SubTermReceiveMarineRail" then
			inst := #0140A9;
		elseif className = "CM_SubTermReceiveMarineRoad" then
			inst := #010AD1;
		elseif className = "CM_SubTermReceiveMarineShip" then
			inst := #014DAD;
		elseif className = "CM_SubTermReceiveWHouseIntern" then
			inst := #0BE37;
		elseif className = "CM_SubTermReceiveWHouseRail" then
			inst := #04;
		elseif className = "CM_SubTermReceiveWHouseRoad" then
			inst := #0308;
		elseif className = "CM_SubTermReceiveWHouseShip" then
		elseif className = "CM_SubTermReleaseDepotIntern" then
			inst := #012BC9;
		elseif className = "CM_SubTermReleaseDepotRail" then
			inst := #015612;
		elseif className = "CM_SubTermReleaseDepotRoad" then
			inst := #0CEA6;
		elseif className = "CM_SubTermReleaseDepotShip" then
			inst := #0364;
		elseif className = "CM_SubTermReleaseMarineIntern" then
			inst := #03E1E;
		elseif className = "CM_SubTermReleaseMarineRail" then
			inst := #01C30;
		elseif className = "CM_SubTermReleaseMarineRoad" then
			inst := #059DF;
		elseif className = "CM_SubTermReleaseMarineShip" then
			inst := #03D97B;
		elseif className = "CM_SubTermReleaseWHouseIntern" then
			inst := #0D714;
		elseif className = "CM_SubTermReleaseWHouseRail" then
			inst := #05;
		elseif className = "CM_SubTermReleaseWHouseRoad" then
			inst := #0E;
		elseif className = "CM_SubTermReleaseWHouseShip" then
			inst := #0A9;
		elseif className = "CM_Survey" then
			inst := #0103E;
		elseif className = "CM_Sweep" then
			inst := #02B43;
		elseif className = "CM_TaskAdd" then
			inst := #0EDD7B;
		elseif className = "CM_TaskComplete" then
			inst := #020D4C;
		elseif className = "CM_TemperatureReading" then
			inst := #0E41B;
		elseif className = "CM_TemperatureSetting" then
			inst := #013CB;
		elseif className = "CM_ToDoTaskTransaction" then
			inst := #01F5CD;
		elseif className = "CM_Unpack" then
			inst := #067EA;
		elseif className = "CM_UnpackComplete" then
			inst := #0169E;
		elseif className = "CM_Wash" then
			inst := #068070;
		elseif className = "CM_Weighed" then
			inst := #0218B1;
		elseif className = "CM_Wharfage" then
			inst := #0189B08;
		elseif className = "CM_WorkOrderAssign" then  
		elseif className = "CM_WorkOrderUnassign" then
		else
			noTrans := true;
		endif;
		if not noTrans and
		   inst &gt; 0 then
		   beginTransaction;
			foreach jssctObj in cls.allChangesByOid do
				objInst := self.getInstanceIdForObject(jssctObj.changeObjectID.asOid).Integer;
				if objInst &lt; inst then
//					write "Delete "&amp;className&amp;' '&amp;jssctObj.changeObjectID&amp;' '&amp;objInst.String;
					delete jssctObj;
					count := count + 1;
				else
//					write "Ignore "&amp;className&amp;' '&amp;jssctObj.changeObjectID&amp;' '&amp;objInst.String;
				endif;
			endforeach;
			commitTransaction;
			file.writeLine("Deleted "&amp;className&amp;' '&amp;count.String);
			
		endif;
	endforeach;
epilog
	file.close;
	delete file;
end;


</source>
    </JadeMethod>
    <JadeMethod name="purgeClass" id="857411ed-cadb-4813-9319-f45b9b9d15b3">
