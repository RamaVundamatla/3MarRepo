    <JadeMethod name="exportDetails" id="fd10ae55-32ec-4aa3-8e67-b4172ed46a2f">
        <source>exportDetails();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2013	cnwmc5	Initial creation

*/

vars
	saveDialog 	: CMDFileSave;
	file		: File;
	
	row			: Integer;
	data		: String;
	hasFails	: Boolean;
	itemObject	: Object;
begin
	hasFails := false;
	
	if not self.tblResults.rows &gt; 1 then
		app.msgBox("No data to export!", app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	
	foreach row in 2 to self.tblResults.rows do
		if not self.tblResults.accessCell(row, 1).picture = picFailed.picture then
			continue;
		endif;
		hasFails := true;
	endforeach;
	
	if not hasFails then
		app.msgBox("No data to export!", app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;

	create saveDialog transient;
	saveDialog.filter := 'Text (.txt)|*.txt|All Files|*.*';
	saveDialog.defaultExt := 'txt';
	
	if saveDialog.open() = 0 then
		
		create file transient;
		file.mode := File.Mode_Output;
		file.allowCreate := true;
		file.openOutput(saveDialog.fileName);
		
		app.mousePointer := MP_HOURGLASS;
	
		foreach row in 2 to self.tblResults.rows do
			if not self.tblResults.accessCell(row, 1).picture = picFailed.picture then
				continue;
			endif;
			
			itemObject := self.tblResults.accessRow(row).itemObject;
			if itemObject &lt;&gt; null and itemObject.isKindOf(CnEcString) then
				data := itemObject.CnEcString.stringValue;
			else
				data := self.tblResults.accessCell(row, 8).text;
			endif;
			file.writeLine(data);
			file.writeLine("---------------------------------------------------------------------");
		endforeach;
		
		file.close;
				
		app.msgBox("File '" &amp; file.fileName &amp; "' created",app.getErrorString(Complete),MsgBox_OK_Only);
	endif;
epilog
	app.mousePointer := MP_DEFAULT;

	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="extractUNL" id="f087bf7e-10b1-4705-bee6-0107dbd464fe">
        <source>extractUNL();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 March 2013	cnwmc5	Initial creation

*/

vars
	saveDialog 			: CMDFileSave;
	file				: File;
	
	allClasses			: ClassColl;
	fullClasses			: ClassColl;
	subClasses			: ClassColl;
	allMethods			: MethodColl;
	methods				: MethodSet;
	
	klass				: Class;
	subClass			: Class;
	meth				: Method;
	obj					: Object;
	
	index, index1		: Integer;
	selectedMethCount	: Integer;
	totalMethCount		: Integer;
begin
	if self.lbxTests.selectedCount = 0 then
		app.msgBox("Nothing selected! Please select some methods or classes to extract.", app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	
	create saveDialog transient;
	saveDialog.filter := 'UNL (.unl)|*.unl';
	saveDialog.defaultExt := 'unl';
	
	if saveDialog.open() = 0 then
		
		create file transient;
		file.mode := File.Mode_Output;
		file.allowCreate := true;
		file.openOutput(saveDialog.fileName);
		
		app.mousePointer := MP_HOURGLASS;
		
		create allClasses transient;
		create fullClasses transient;
		create subClasses transient;
		create allMethods transient;
		create methods transient;
		
		foreach index in 1 to self.lbxTests.listCount do
			obj := self.lbxTests.itemObject[index];
			if obj.isKindOf(Class) then
				allClasses.add(obj.Class);
			endif;
			if obj.isKindOf(Method) then
				allMethods.add(obj.Method);
			endif;
		endforeach;
		
		foreach klass in allClasses do
			index1 := self.lbxTests.findObject(klass);
			if index1 &gt;= 0 then
				if self.lbxTests.itemSelected[index1] then
					if fullClasses.includes(klass.getSuperclass()) then
						continue;
					endif;
					klass.allLocalSubclasses(subClasses);
					foreach subClass in subClasses do
						if fullClasses.includes(subClass) then
							fullClasses.remove(subClass);
						endif;
					endforeach;
					klass.allMethods(methods);
					foreach meth in methods do
						totalMethCount := totalMethCount + 1;
						index := self.lbxTests.findObject(meth);
						if index &gt;= 0 then
							if self.lbxTests.itemSelected[index] then
								selectedMethCount := selectedMethCount + 1;
							endif;
						endif;						
					endforeach;
					if selectedMethCount &gt;= totalMethCount or selectedMethCount = 0 then
						fullClasses.add(klass);
					endif;
				endif;
			endif;
			selectedMethCount := 0;
			totalMethCount := 0;
		endforeach;
		
		foreach klass in fullClasses do
			file.writeLine( 'Class' &amp;' '&amp; klass.name );
		endforeach;
		
		foreach meth in allMethods do
			index1 := self.lbxTests.findObject(meth);
			if index1 &gt;= 0 then
				if self.lbxTests.itemSelected[index1] then
					if fullClasses.includes(meth.getSchemaType().Class) or fullClasses.includes(meth.getSchemaType().Class.getSuperclass) then
						continue;
					endif;
					file.writeLine('Method ' &amp; meth.getSchemaType().name &amp; ' ' &amp; meth.name);
				endif;
			endif;
		endforeach;
		
		file.commit;
		file.close;
		app.msgBox('Created ' &amp; file.fileName, app.getErrorString(Warning), MsgBox_OK_Only);
	
	endif;

epilog
	app.mousePointer := MP_DEFAULT;

	delete file;
	delete allClasses;
	delete fullClasses;
	delete subClasses;
	delete allMethods;
	delete methods;
end;</source>
    </JadeMethod>
    <JadeMethod name="findBookmarkedMethod" id="c6e02015-9875-4154-829f-6c42cfbf6fa2">
        <source>findBookmarkedMethod();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2023	navra1	Initial creation

*/

vars
	selectedMethod : UM_MethodName;
	obj : Object;
	i:Integer;
	bookMarkFolder:UM_BookmarkFolder;
	bookMarkMethodName : UM_MethodName;
	bookmarkedTests : UM_MethodNameArray;
	msg : String;
	
begin
	//if self.lstBookMarks.itemObject[lstBookMarks.listIndex].leve
	if self.lstBookMarks.itemLevel[lstBookMarks.listIndex] = 1 then	
		create bookmarkedTests transient;
		self.lstBookMarks.itemObject[lstBookMarks.listIndex].UM_BookmarkFolder.methodNames.copy(bookmarkedTests);		
		i:=1;
		foreach obj in lbxTests.itemObject do
			foreach bookMarkMethodName in bookmarkedTests do
				if obj.getNiceName()=bookMarkMethodName.methodNameString or obj.getNiceName()=bookMarkMethodName.methodNameString[2:end] then
					lbxTests.itemExpanded[i]:=true;	
					lbxTests.itemEnabled[i]:=true;	
					lbxTests.itemSelected [i] :=true;
					msg := msg &amp; bookMarkMethodName.methodNameString &amp; CrLf;
					break;
				endif;			
			endforeach;
			i:=i+1;
		endforeach;
		app.msgBox("Selected " &amp; bookmarkedTests.size().String &amp; " :" &amp; CrLf &amp; msg, "Selected Tests", MsgBox_OK_Only);
		delete bookmarkedTests ;
		return;
	endif;
		
	selectedMethod := self.lstBookMarks.itemObject[lstBookMarks.listIndex].UM_MethodName;
	
	i:=1;
	foreach obj in lbxTests.itemObject do		
			lbxTests.itemExpanded[i]:=false;	
			lbxTests.itemEnabled[i]:=true;	
			lbxTests.itemBackColor[i]:=White;
			lbxTests.itemSelected[i]:=false;
			
			i:=i+1;
	endforeach;
	i:=1;
	
	foreach obj in lbxTests.itemObject do
		if obj.getNiceName() = selectedMethod.methodNameString or obj.getNiceName()=selectedMethod.methodNameString[2:end] then
			lbxTests.itemExpanded[i]:=true;	
			lbxTests.itemEnabled[i]:=true;	
			lbxTests.itemSelected [i] :=true;		
		
			break;
		endif;
		i:=i+1;
	endforeach;
	
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="fldTestResults_sheetChg" id="55fb544d-81fe-4a9c-be3f-47171027ee25">
        <controlMethod name="Folder::sheetChg"/>
