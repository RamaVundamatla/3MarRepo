    <JadeMethod name="displaySelectorResults" id="8e1b3644-dd18-4429-89fd-640374da001a">
        <updating/>
        <source>displaySelectorResults(_resultCollection: Collection; _mode: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     05 September 2008 by concms1
// Purpose:     PAR 17884/CCMS 1742 - ToDoo tasks interim solution
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	iter			:Iterator;
	invalidObject	:Boolean;
	obj				:Object;
	strText, strId	:String;
begin
	on Exception do app.handleDeletedObject(exception, obj, invalidObject);

	strText	:= txtContainers.text.trimBlanks;
	iter 	:= _resultCollection.createIterator;
	
	while iter.next(obj) do
		invalidObject := false;
		
		strId := obj.CM_TrackedItem.id;
			
		// Skip any invalid objects
		if invalidObject then
			continue;
		endif;
			
		// Otherwise, append it to our text
		if strText = null then
			strText := strId;
		else
			strText := strText &amp; ', ' &amp; strId;
		endif;

	endwhile;	
	
	txtContainers.text := strText;
epilog
	delete iter;
end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="983ab0fd-76c9-466e-986e-a83018f47550">
        <updating/>
        <source>doSave():Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 September 2008 by concms1
// Purpose:     PAR 17884/CCMS 1742 - ToDoo tasks interim solution
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//12 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	strFrom, strTo, strDesc, strSubject, strMessage, strDateTime1, strDateTime2	: String;
	result	: Integer;
	date	: Date;
	time 	: Time;
	localRequiredTS,systemRequiredTS : TimeStamp;
begin
	// from email addres
	strFrom 		:= app.myRoot.getConfig(AutoSendersEmailAddress).String; 
	
	// to email address
	strTo			:= self.myTerminal.getConfig(IntJobReqTerminalEmail).String;
	
	if strTo = null then
		app.msgBox(	app.getErrorString(ERR_JobReqTargetEmail_Missing),
					app.getErrorString(Error),
					MsgBox_OK_Only + MsgBox_Stop_Icon); 
		return false;
	endif;
	
	if txtContainers.text.trimBlanks() = null then
		app.msgBox(	app.getErrorString(ERR_ContainerNo_Missing),
					app.getErrorString(Error),
					MsgBox_OK_Only + MsgBox_Stop_Icon); 
		return false;
	endif;
	
	// required by date/time
	date 			:= txtDate.getDate();
	time 			:= txtTime.getTime();

	localRequiredTS.setDate(date);
	localRequiredTS.setTime(time);
	
	// Convert from local to system
	systemRequiredTS := self.localToSystemTime(localRequiredTS);
	strDateTime1	:= systemRequiredTS.Date.asStringJMT() &amp; ' ' &amp; systemRequiredTS.Time.asStringJMT();

	strDateTime2	:= self.systemToLocalTime(app.cnGetServerTime).asStringJMT();
	
	if cmbTaskType.listIndex = -1 then
		app.msgBox(app.getErrorString(ERR_ServiceReqd_Missing), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon); 
		return false;
	endif;
	
	// service requested
	strDesc			:= cmbTaskType.listObject.CM_ToDoTaskDesc.description;
	
	strSubject		:= app.getErrorString2(	XLAT_JobReqEmailSubject, 
											app.getMyUser().myOrganisation.name, 
											app.getMyUserName());
	
	strMessage 		:= app.getErrorString2(XLAT_JobReqEmailBody, strDesc, strDateTime1);
	strMessage		:= strMessage &amp; CrLf &amp; CrLf &amp; app.getErrorString1(XLAT_JobReqEmailBody2, app.getMyUserCode);
	strMessage		:= strMessage &amp; CrLf &amp; app.getErrorString1(XLAT_JobReqEmailBody3, app.getMyUser.myOrganisation.name);
	strMessage		:= strMessage &amp; CrLf &amp; app.getErrorString1(XLAT_JobReqEmailBody4, strDateTime2); 
	strMessage		:= strMessage &amp; CrLf &amp; CrLf &amp; app.getErrorString1(XLAT_JobReqEmailBody5, strDesc);
	strMessage		:= strMessage &amp; CrLf &amp; CrLf &amp; app.getErrorString(XLAT_JobReqEmailBody6);
	strMessage		:= strMessage &amp; CrLf &amp; txtInstructions.text;
	strMessage		:= strMessage &amp; CrLf &amp; CrLf &amp; app.getErrorString1(XLAT_JobReqEmailBody7, strDateTime1);
	strMessage		:= strMessage &amp; CrLf &amp; CrLf &amp; txtContainers.text;
	
	while true do
		app.myTrxCA.trxCreateEmailSendRequest(	self.caption,
												strTo,
												strFrom,
												null,
												null,
												strSubject,
												strMessage,
												null,
												null,
												null,
												null,
												null,
												self,
												app.myPassport);
		
		if app.myPassport.trxCompletedOK() then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors()
			and result = IDOK
			then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return false;
	endwhile;
	
	//epr par 18069 2/10/08
	if app.myPassport.myUser.getAcknowledgeTodoStop() then
		app.msgBox(app.getErrorString(XLAT_JobRequestSuccess),app.getErrorString(XLAT_JobRequestSuccess), MsgBox_OK_Only);
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
