    <JadeMethod name="sysNotify" id="56c40bca-69f9-452f-8ee1-30849a0ac7e0">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
// 13/09/2109	jlgzm1		TFS 42872 Direct Delivery Between HOLD Voyages and Rail 
// 24/02/2024 	navcs2 		MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	wle : CM_WorkListEntry;
	ti 	: CM_TrackedItem; // TFS 42872
begin
	// handle deletes first
	if eventType = Object_Delete_Event then
		// must be the prenote table or the onship table
		if theObject.isKindOf(CM_WorkListEntry) then
			self.handleDeletedWLE(theObject.CM_WorkListEntry);
		elseif theObject.isKindOf(CM_VoyageHoldJob) then
			self.handleDeletedJob(theObject.CM_VoyageHoldJob);
		endif;
		return;
	endif;
	
	if theObject &lt;&gt; null then
		if theObject.isKindOf(CM_WorkListEntry) then
			wle := theObject.CM_WorkListEntry;
			self.updateWLE(wle);
		elseif theObject.isKindOf(CM_VoyageHoldJob) then
			self.updateJob(theObject.CM_VoyageHoldJob);
		elseif theObject.isKindOf(CM_TrackedItem) then	// TFS 42872
			ti := theObject.CM_TrackedItem;				// TFS 42872
			self.updateTI(ti);							// TFS 42872
		endif;
	endif;
epilog
	
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tableRowChange" id="307dd803-bb27-414b-8ec2-b357b0001048">
        <updating/>
        <source>tableRowChange(_table : CM_DataTable input; _newRow : Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
// 17/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
//
vars
	obj : CM_Object;
	
begin
	self.myCurrentWLE := null; // jlgzm1 TFS 42872 18/07/2019
	self.myCurrentTrackedItem := null;
	obj := _table.accessRow(_newRow).itemObject.CM_Object;
	if not global.isValidObject(obj) then
		return;
	endif;
	self.btnDischLoad.enabled := true;
	if obj.isKindOf(CM_WorkListEntry) then
		self.myCurrentWLE := obj.CM_WorkListEntry; // jlgzm1 TFS 42872 18/07/2019
		self.myCurrentTrackedItem := obj.CM_WorkListEntry.myTrackedItem;
		if self.myCurrentTrackedItem.hasBeenMovedForJob(self.myCurrentJob) then
			self.btnDischLoad.enabled := false;
		endif;
		self.populateJobDetailsLocation(obj.CM_WorkListEntry.job.CM_VoyageHoldJob);			// TFS 3516
	endif;
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_newRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblJobDetails_contextMenu" id="6b7f163c-3753-4e52-8dca-160414bc9a23">
