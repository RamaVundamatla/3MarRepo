    <JadeMethod name="initProgressDialog" id="5b7b3b8b-869e-4573-be46-b488c634cf50">
        <updating/>
        <source>initProgressDialog(_msg : String)updating, protected;
// ---------------------------------------------------------------------------
// Created:     12 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theVoyage	: CM_Voyage;
