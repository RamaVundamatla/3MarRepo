        <type name="TimeStamp"/>
        <access>protected</access>
    </PrimAttribute>
    <JadeMethod name="doCopy" id="2827ee92-fad6-4451-a783-5459ff469f1c">
        <source>doCopy(pTheFileAgent:JSSFMFileAgent input);
// --------------------------------------------------------------------------------
// Created:		18 September 2002 by cnwdad2
//
// Purpose:		sends a request to the File Agent to perform the file/directory copy.
//
// Parameters:	pTheFileAgent - The File Agent object which peforms file actions.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pTheFileAgent.setUnixFlags(self.isSourceUnix, self.isTargetUnix);
	
	if self.isFolder then
		pTheFileAgent.copyDirectory(self.sourcePath, self.targetPath, self.nodeOptions);
		
		if self.isCutAndPaste then
			pTheFileAgent.deleteDirectory(self.sourcePath, self.nodeOptions);
		endif;
	else
		pTheFileAgent.copyFile(self.sourcePath, self.targetPath, self.nodeOptions);
		
		if self.isCutAndPaste then
			pTheFileAgent.deleteFile(self.sourcePath, self.nodeOptions);
		endif;
	endif;
end;</source>
        <Parameter name="pTheFileAgent" type="JSSFMFileAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="2baef36f-1c91-4587-9ca5-98d0428ccfa2">
        <updating/>
        <source>updateMe(	pSourcePath:String;
			pTargetPath:String;
			pNodeOptions:Integer;
			pIsFolder:Boolean;
			pIsCutAndPaste:Boolean;
			pIsSourceUnix:Boolean;
			pIsTargetUnix:Boolean;
			pTheCopy:JSSFMBackgroundCopy) updating;
// --------------------------------------------------------------------------------
// Created:		17 September 2002 by cnwdad1
//
// Purpose:		Sets the properties and references on the receiver.
//
// Parameters:	pSourcePath - The file or directory to be copied.
//				pTargetPath - The destination of the file/directory.
//				pNodeOptions - Flags to identify the JADE nodes of the source and
//					target file/directiry.
//				pIsFolder - A flag to indicate whether we're copying a folder (if
//					false, then we're copying a file).
//				pIsCutAndPaste - A flag to indicate whether we're doing a cut and
//					paste (i.e. a move).  If false, then we're only pasting.
//				pIsSourceUnix - A flag to indicate whether the source platform is Unix.
//				pIsTargetUnix - A flag to indicate whether the target platform is Unix.
//				pTheCopy - The Paste File's owner Background Copy object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentTime		: TimeStamp;
	
begin
	// Set non-key properties.
	
	self.sourcePath		:=	pSourcePath;
	self.targetPath		:=	pTargetPath;
	self.nodeOptions	:=	pNodeOptions;
	self.isFolder		:=	pIsFolder;
	self.isCutAndPaste	:=	pIsCutAndPaste;
	self.isSourceUnix	:=	pIsSourceUnix;
	self.isTargetUnix	:=	pIsTargetUnix;
	
	// Set key properties.
	
	if self.timestamp &lt;&gt; currentTime then
		self.timestamp	:=	currentTime;
	endif;
	
	// Set any inverse references.
	
	if self.myCopy &lt;&gt; pTheCopy then
		self.myCopy		:=	pTheCopy;
	endif;
end;</source>
        <Parameter name="pSourcePath" type="String"/>
        <Parameter name="pTargetPath" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <Parameter name="pIsFolder" type="Boolean"/>
        <Parameter name="pIsCutAndPaste" type="Boolean"/>
        <Parameter name="pIsSourceUnix" type="Boolean"/>
        <Parameter name="pIsTargetUnix" type="Boolean"/>
        <Parameter name="pTheCopy" type="JSSFMBackgroundCopy"/>
    </JadeMethod>
</Class>
