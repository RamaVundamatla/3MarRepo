    <JadeMethod name="getMyMovement" id="14ce95ce-5e1a-4499-8dd1-651a043ffbcc">
        <source>getMyMovement() : HMS_VoyageMovement;
// ---------------------------------------------------------------------------
// Created:		04 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.myVoyageMovement &lt;&gt; null then
			return self.myVoyageMovement;
	endif;
	
	return self.myVoyageMovementArchive;
end;</source>
        <ReturnType type="HMS_VoyageMovement"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="ea65cd94-9c3b-4ea2-8261-343717f4782a">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2016	cnwmp6	Initial creation

*/

vars

begin
	if self.myVoyageMovement &lt;&gt; null then
		return self.myVoyageMovement.getMyTerminal;
	endif;
	if self.myVTMISTransaction &lt;&gt; null then
		return self.myVTMISTransaction.myTerminal;
	endif;
	if self.myHarbour &lt;&gt; null then
		return self.myHarbour.getMyTerminal;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getTetapVariabelInvoiceLine" id="ac4bf703-7bef-4a38-ac91-748a1666ca39">
        <source>getTetapVariabelInvoiceLine( _tetapInvoiceLine,
					  _variabelInvoiceLine : CM_InvoiceLine io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2018	jlger1	Initial creation

*/

vars
	
	invoiceLine 	: CM_InvoiceLine;
	calcType 		: CM_CalculationType;
begin
	if self.myVTMISTransaction = null then
		return;
	endif;
	
	foreach invoiceLine in self.myVTMISTransaction.allInvoiceLines discreteLock do
			if _tetapInvoiceLine = null and  invoiceLine.invoiceLineDesc.narration.pos("Tetap",1) &gt; 0 then
				_tetapInvoiceLine:= invoiceLine;
			endif;
			if _tetapInvoiceLine = null and  invoiceLine.invoiceLineDesc.narration.pos("Fixed",1) &gt; 0 then
				_tetapInvoiceLine:= invoiceLine;
			endif; 
			
			if _variabelInvoiceLine = null and
				invoiceLine.invoiceLineDesc.narration.pos("Variabel",1) &gt; 0 then
				_variabelInvoiceLine:= invoiceLine;					
			endif;	
			
			if _variabelInvoiceLine = null and
				invoiceLine.invoiceLineDesc.narration.pos("Variable",1) &gt; 0 then
				_variabelInvoiceLine:= invoiceLine;					
			endif;	
			
			if _tetapInvoiceLine &lt;&gt; null and _variabelInvoiceLine &lt;&gt; null then
				break;
			endif;	
	endforeach;
	
epilog

end;</source>
        <Parameter name="_tetapInvoiceLine" type="CM_InvoiceLine" usage="io"/>
        <Parameter name="_variabelInvoiceLine" type="CM_InvoiceLine" usage="io"/>
    </JadeMethod>
