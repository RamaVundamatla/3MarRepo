    <JadeMethod name="tCheckGetCargoDetailsCorrect2" id="71547f4b-2f2e-4e4c-8704-784e7d905b38">
        <updating/>
        <source>tCheckGetCargoDetailsCorrect2() updating;

/*

Purpose:		Check that CM_ROROLocnDefnVoyage::getCargoDetails returns the correct information

Date			Who		Reason
06/09/2012		cnwmh5	Initial creation

*/

constants

	VesselId				: String = "JGRIG";
	VoyageId				: String = "UT_MDHVOY12";
	OperatorId				: String = "UTOP";
	DeckName 				: String = "4";   						// WEATHER DECK

vars

	voyage					: CM_Voyage;
	deck					: CM_DeckVoyage;
	voyageJob				: CM_VoyageJob;
	locnDefnVoyage			: CM_ROROLocnDefnVoyage;
	tempTI					: CM_TrackedItem;
	bs						: CM_BlockStack;

	slots					: CM_LCArray;
	tiArray					: CM_TIArray;
	
	strs 					: StringArray;
	failedArray				: HugeStringArray;		//cnwmc5 - 8/10/2012
	
	detailsToCheck			: String;
	str1, str2				: String;				//cnwmc5 - 8/10/2012
	idx						: Integer;
	
begin

	// setup non ship cargo
	bs := self.addBlockStack("UTMHBSE", 100, null);
	self.assertNotNull(bs);

	// Create the voyage
	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithConRORO(VoyageId, VesselId, OperatorId, "UTSL", "Chief Tasman", 0, false, true);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	
	create slots transient;
	create tiArray transient;
	create failedArray transient;		//cnwmc5 - 8/10/2012
	
	// set up the areas and containers on the voyage
	if voyage.myROROStructure &lt;&gt; null then
		deck := voyage.myROROStructure.allDecksByCode[DeckName];
		self.assertNotNull(deck);
		
		// setup the cargo
		self.xSetupCargoForGCDC2(voyage, deck);
		
		// check that the details are correct
		self.xCheckGCDCorrect2(ShpDisplayMode_Actual, 0, deck, failedArray);
		self.xCheckGCDCorrect2(ShpDisplayMode_Proposed, 0, deck, failedArray);
		self.xCheckGCDCorrect2(ShpDisplayMode_Actual, ShpDisplayMode_ColCodeDisch, deck, failedArray);
		self.xCheckGCDCorrect2(ShpDisplayMode_Proposed, ShpDisplayMode_ColCodeLoad, deck, failedArray);
		
	endif;
	
	//cnwmc5 - 8/10/2012 - added new style of error handling
	foreach str1 in failedArray do
		str2 := str2 &amp; str1 &amp; CrLf;
	endforeach;

	self.assertEqualMsg(failedArray.size, 0, str2);
	
epilog
	
	delete failedArray;			//cnwmc5 - 8/10/2012
	
	delete slots;
	delete tiArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckStatusBarDetailsCorrect" id="aa2ad1f7-a79c-4a50-b8af-a4bc6c543538">
        <updating/>
        <source>tCheckStatusBarDetailsCorrect() updating;

/*

Purpose:		This test checks that the details in the status bar are correct after each step	


Date			Who		Reason
10/05/2013		cnwmh5	Initial creation

*/
constants

	VesselId							: String = "JROSO";
	VoyageId							: String = "VOY31367MDH";
	
vars

	operator							: CM_Operator;
	theSlot								: CM_LocationsController;
	
	tisToDelete							: CM_TISet;
	tisWithWarnSet						: CM_TISet;
	tmpStrArray							: StringArray;
	
	idx									: Integer;

begin

	app.writeLog("Creating voyage.  Please wait...", LogINFO);
	
	operator := app.myRoot.allOperators["UTOP"];
	self.assertNotNullMsg(operator, "Null Operator");
	
	// delete multiple tis 
	create tisWithWarnSet transient;
	
	self.myVoyage := self.getVoyage(VoyageId);
	self.assertNoTrxErrorsOrWarnings();
	
	create tisToDelete transient;
	if self.myVoyage &lt;&gt; null then
		self.myVoyage.getAllTrackedItems(tisToDelete);
		self.deleteTrackedItems(tisToDelete, tisWithWarnSet);
		self.assertNoTrxErrorsOrWarnings();
	endif;


	// Create the voyage
	self.deleteVoyage(VoyageId);
	self.myVoyage := self.addVoyageWithConRORO(VoyageId, VesselId, operator.code, "UTSL", "Chief Tasman", 0, false, true);
	self.assertNotNullMsg(self.myVoyage, 'Add voyage failed');
	self.assertNotNullMsg(self.myVoyage.myROROStructure, "RORO Structure is null");
	
	self.myDeck := self.myVoyage.myROROStructure.allDecksByCode["4"];
	self.assertNotNullMsg(self.myDeck, "Deck not found");

	cargoCountId := 0;

	/*******************************************************************************
		Step 1: Create discharge cargo and check that status bar details are correct
	********************************************************************************/
	self.xPAR31367StatusBarStep1();
	
	/*******************************************************************************
		Step 2: Colour code discharge slots and check that status bar details are correct
	********************************************************************************/
	self.xPAR31367StatusBarStep2();

	/*******************************************************************************
		Step 3: Plan discharge job and check that status bar details are correct
	********************************************************************************/
	self.xPAR31367StatusBarStep3();
	
	/*******************************************************************************
		Step 4: Put into a discharge job and check that status bar details are correct
	********************************************************************************/
	self.xPAR31367StatusBarStep4();
	
	/*******************************************************************************
		Step 5: Load colour code slot in same position as discharge and check that status bar details are correct
	********************************************************************************/
	self.xPAR31367StatusBarStep5();
	
	/*******************************************************************************
		Step 6: Create load job and check that status bar details are correct
	********************************************************************************/
	self.xPAR31367StatusBarStep6();
	
	/*******************************************************************************
		Step 7: Plan 2 x 20 and 2 x 40 and check that status bar details are correct
	********************************************************************************/
	self.xPAR31367StatusBarStep7();
		
	/*******************************************************************************
		Step 8: Plan 1 x 40 and check that status bar details are correct
	********************************************************************************/
	self.xPAR31367StatusBarStep8();
	
	/*******************************************************************************
		Step 9: Load the cargo to the voyage and check that status bar details are correct
	********************************************************************************/
	self.xPAR31367StatusBarStep9();
	
	/*******************************************************************************
		Step 10A: Colour code discharge slots (SOB) and check that status bar details are correct
	********************************************************************************/
	self.xPAR31367StatusBarStep10SOBA();
		
	/*******************************************************************************
		Step 10B: Put SOB in a job and check that status bar details are correct
	********************************************************************************/
	self.xPAR31367StatusBarStep10SOBB();
	
	/*******************************************************************************
		Step 10C: Work the job and check that status bar details are correct
	********************************************************************************/
	self.xPAR31367StatusBarStep10SOBC();
	
	
	/*******************************************************************************
		Discharge 40' and load 20' into the same slots
	/*******************************************************************************
		Step A1: Create discharge cargo and check that status bar details are correct
	********************************************************************************/
	self.xPAR31367StatusBarStepA1();
	
	/*******************************************************************************
		Step A2: Colour code discharge slots and check that status bar details are correct 
	********************************************************************************/
	self.xPAR31367StatusBarStepA2();

	/*******************************************************************************
		Step A3: Put into discharge job(s) and check that status bar details are correct 
	********************************************************************************/
	self.xPAR31367StatusBarStepA3();
	
	/*******************************************************************************
		Step A4: Plan Containers to discharge and check that status bar details are correct 
	********************************************************************************/
	self.xPAR31367StatusBarStepA4();

	/*******************************************************************************
		Step A5: Discharge containers and check that status bar details are correct
	********************************************************************************/
	self.xPAR31367StatusBarStepA5();

	/*******************************************************************************
		Step A6: Load Colour Code and check that status bar details are correct 
	********************************************************************************/
	self.xPAR31367StatusBarStepA6();
	
	/*******************************************************************************
		Step A7: Create load job and check that status bar details are correct 
	********************************************************************************/
	self.xPAR31367StatusBarStepA7();
	
	/*******************************************************************************
		Step A8: Plan load containers and check that status bar details are correct 
	********************************************************************************/
	self.xPAR31367StatusBarStepA8();

	/*******************************************************************************
		Step A9: Load the cargo to the voyage and check that status bar details are correct 
	********************************************************************************/
	self.xPAR31367StatusBarStepA9();
	
	
	/*******************************************************************************
		Step C1: Discharge CC using trxCreateRORODischargeCC
	********************************************************************************/
	create tmpStrArray transient;
	tmpStrArray.add("D40331");
	self.myVoyage.findLocation(tmpStrArray, false, theSlot, idx);
	app.myTrxCA.trxCreateRORODischargeCC(theSlot.CM_VoyageROROController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
	
	
	return;
	
	/*******************************************************************************
		Step B1: Create discharge cargo on voyage and check that status bar details are correct 
	********************************************************************************/
	self.xPAR31367StatusBarStepB1();
	
	/*******************************************************************************
		Step B2: Colour code discharge slots and check that status bar details are correct 
	********************************************************************************/
	self.xPAR31367StatusBarStepB2();
	
	/*******************************************************************************
		Step B3: Put into discharge job(s) and check that status bar details are correct 
	********************************************************************************/
	self.xPAR31367StatusBarStepB3();
	
	/*******************************************************************************
		Step B4: Plan Containers to discharge and check that status bar details are correct 
	********************************************************************************/
	self.xPAR31367StatusBarStepB4();
	
	/*******************************************************************************
		Step B5: Discharge containers and check that status bar details are correct
	********************************************************************************/
	self.xPAR31367StatusBarStepB5();
	
	/*******************************************************************************
		Step B6: Load colour code slot in same position as discharge and check that status bar details are correct
	********************************************************************************/
	self.xPAR31367StatusBarStepB6();
	//return;
	/*******************************************************************************
		Step B7: Create load job and check that status bar details are correct 
	********************************************************************************/
	self.xPAR31367StatusBarStepB7();
	
	/*******************************************************************************
		Step B8: Plan load containers and check that status bar details are correct 
	********************************************************************************/
	self.xPAR31367StatusBarStepB8();
		
	/*******************************************************************************
		Step B9: Load the cargo to the voyage and check that status bar details are correct 
	********************************************************************************/
	self.xPAR31367StatusBarStepB9();
	
	
	
	
epilog

	delete tisToDelete;
	delete tisWithWarnSet;
	delete tmpStrArray;

end;</source>
