	self.maxVolume := _proxy.maxVolume;							// 19/7/16 cnwmp6 TFS 1601
	self.maxHeight := _proxy.maxHeight;	//07 Feb 2017	NDL	TFS 3216
	self.onShipCrane := _proxy.onShipCrane;						// 13/7/16 cnwmp6 TFS 1601
	self.myGCVesselStructure := _proxy.myGCVesselStructure;

epilog

end;</source>
