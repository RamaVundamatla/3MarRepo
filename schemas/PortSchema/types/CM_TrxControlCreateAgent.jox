    <JadeMethod name="trxImportVehicleMakesFromFile" id="c9a75ff1-ad8c-48f2-b69a-ed8f4028a6af">
        <updating/>
        <source>trxImportVehicleMakesFromFile( _file : File; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189
*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 02 Jul 2018	jlgmd1	TFS 39058 - 1035 String to long
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	count				: Integer;
	numCodes			: Integer;
	noLines				: Integer;
	fieldNo				: Integer;
	fieldValue			: String;
	fileLine			: String;
	fieldArray			: CnStringArray;
	thePassport			: CM_Passport;
	err					: CM_Error;
	errorStore			: CM_ErrorSet;

	newVehicleMake		: CM_VehicleMake;
	currentVehicleMake	: CM_VehicleMake;
	pxyVehicleMake		: CM_VehicleMake;
	vehicleMakeColl		: CM_VehicleMakeByMake;
	theRoot				: CM_DutyDocRoot;
	
	make				: String;
	progressInt			: TimeStampInterval;
	progressTS 			: TimeStamp;
begin
	thePassport := _passport;
	theRoot 	:= app.myDutyDocRoot;

	// Always initialize the activity first
	self.initialiseActivityWithPassport(thePassport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, thePassport);
	on LockException do agtPassportLockExHandler(exception, thePassport);

	app.setContinueCMExceptions(false);
	
	if not _file.tryOpen() then
		app.raiseCMException(VB_FILE_ERROR, app.getErrorString(File_open), null);	
		return;
	endif;
	
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	create vehicleMakeColl transient;
	create fieldArray transient;
	create errorStore transient;
	
	//ignore first line
	fileLine 	:= _file.readLine();
	noLines		:= 1;
	
	while not _file.endOfFile() do
		fileLine 	:= _file.readLine;
		noLines		:= noLines + 1;
		if fileLine = null then
			continue;
		endif;
		
		fieldArray.clear();
		fileLine.csvToStringArray(fieldArray, ",");
		
		if fieldArray.isEmpty then
			continue;
		endif;
		
		make := null;
		
		/*
		The import layout for this table is exactly (or similar) to the column organiser "JMT Default".
		This is what has been supplied to Messina in document CCMS MES 1008, 1010 Interfaces Messages,
		also see the JMT User Guide section for System Codes Reference.
		*/
		fieldNo	:=	0;
		
		foreach fieldValue in fieldArray do
			fieldNo	:=	fieldNo + 1;
			
			// cnwrl1 06/07/2010 PAR 24606 - reorder import fields to match "JMT Default"
			if fieldNo = 1 then
				make :=	fieldValue.trimBlanks()[1:CM_VehicleMake::make.length-1];
			endif;
		endforeach;
		
		if not vehicleMakeColl.includesKey(make) then
			create pxyVehicleMake transient;
			pxyVehicleMake.setProxy(make);
			
			vehicleMakeColl.add(pxyVehicleMake);
		else
			create err transient;
			err.set(0,
					app.getErrorString(Vehicle_make) &amp; ' : ' &amp; app.getErrorString2(Line_duplicate_file, noLines.String, app.getErrorString(Vehicle_make)) &amp; make.String,
					false,
					'',
					null,
					null);
			errorStore.add(err);
		endif;
	endwhile;
	
	if thePassport.myCMIFMonitor &lt;&gt; null then
		thePassport.myCMIFMonitor.updateProgress(app.getErrorString(Reading_import_file), 10, 10);
	endif;
	
	if thePassport.hasErrors() then
		return;
	endif;
	
	count		:=	0;
	numCodes	:=	vehicleMakeColl.size();
	
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	foreach pxyVehicleMake in vehicleMakeColl do
		count := count + 1;
		
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, app.getErrorString(Vehicle_make)), numCodes, count);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		currentVehicleMake := theRoot.allVehicleMakes[pxyVehicleMake.make];
		
		if currentVehicleMake = null then
			app.myUtilityCA.utlCreateVehicleMake(pxyVehicleMake, newVehicleMake, thePassport);
		else
			app.myProxyManager.createProxyLink(currentVehicleMake, pxyVehicleMake);
			app.myUtilityUA.utlUpdateVehicleMake(pxyVehicleMake, thePassport);
		endif;
		
		if thePassport.hasErrors() then
			foreach err in thePassport.allErrors do
				err.setErrorText(app.getErrorString(Vehicle_make) &amp; ' : ' &amp; pxyVehicleMake.make &amp; '  ' &amp; err.text, false);
				errorStore.add(err);
			endforeach;
			
			foreach err in thePassport.allErrors do
				err.removeFromPassport();
			endforeach;
		endif;
	endforeach;
	
	trxWriteToLogFile(_file.fileName, noLines, count, thePassport, errorStore);
	
epilog
	delete pxyVehicleMake;
	if vehicleMakeColl &lt;&gt; null then
		vehicleMakeColl.purge();
		delete vehicleMakeColl;
	endif;
	
	delete fieldArray;
	_file.close();
	self.finaliseActivityWithPassport(thePassport);
	delete errorStore;
end;
</source>
