	self.trackingNumber2	:= pxyCar.trackingNumber2;		// PAR #32215
	self.docsReceived		:= pxyCar.docsReceived;			// PAR #32215
	self.docsSent			:= pxyCar.docsSent;				// PAR #32215
	self.docsCleared		:= pxyCar.docsCleared;			// PAR #32215
	self.docsReturned		:= pxyCar.docsReturned;			// PAR #32215
	self.nbrDoors			:= pxyCar.nbrDoors;				// PAR #32215
	self.isNew				:= pxyCar.isNew;				// PAR #32215
	
	// 04/12/2014 cnwar2 #3303
	self.engineNo			:= pxyCar.engineNo;
	self.certificate1		:= pxyCar.certificate1;
	self.certificate1Expiry	:= pxyCar.certificate1Expiry;
	self.certificate2		:= pxyCar.certificate2;
	self.certificate2Expiry	:= pxyCar.certificate2Expiry;
	self.chassisNo			:= pxyCar.chassisNo;
	self.registration		:= pxyCar.registration;
	self.vin				:= pxyCar.vin;
end;</source>
