    <JadeMethod name="isDetailRow" id="ffed4fb3-4de1-4a55-84c8-6e2f1b398899">
        <updating/>
        <source>isDetailRow(_row :Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     08 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _row &lt;= self.fixedRows then
		return false;
	endif;
	
	return self.getGroupLevel (_row) = 0;
epilog

end;</source>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isGroupingRow" id="9ae35326-e241-4bb0-8f76-5c5e5b5eed76">
        <updating/>
        <source>isGroupingRow(_row :Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     13 October 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return not self.isDetailRow (_row);
epilog

end;</source>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="refreshGroupHeadings" id="fa5ad162-d984-4a0e-aa35-7c349fb882af">
        <updating/>
        <source>refreshGroupHeadings()updating;
// ---------------------------------------------------------------------------
// Created:     09 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	int, size	:Integer;
	obj			:CM_Object;
begin
	if self.rows &lt;= self.fixedRows then
		return;	// nothing to do
	endif;
	
	size := self.rows;
	
	foreach int in fixedRows + 1 to size do
		if self.isDetailRow (int) then
			continue;
		endif;
		// heading
		obj := self.accessRow(int).itemObject.CM_Object;
		
		if obj &lt;&gt; null then
			// update text displayed
			self.accessCell (int, 1).text 	:= self.getDisplayForGroup (obj);
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="removeItem" id="1fe704c1-2c1c-482c-931c-888f22a1f09b">
        <updating/>
        <source>removeItem(_index: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     07 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	inheritMethod(_index);

/*	if the item being removed is the last one in the group we need
	to remove the grouping value for it */
	self.doCheckForEmptyGroup (_index - 1);
	
epilog

end;</source>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="resortTableByColumn" id="a1d4fc44-a022-4ab6-a7dd-4b125d08381a">
        <updating/>
        <source>resortTableByColumn(_column: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     12 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/11/2009	cnwcs5		par21590 - column organisor showing acscending when it should be descending
//							and vice versa after sorting by a single column
// ---------------------------------------------------------------------------
vars
	sortCol	:Integer;
	str		:String;
	entRow	:EntTableRow;
begin 
	if not self.hasGroups then 
		inheritMethod(_column);
		return;
	endif;
	
	// at this stage we only handle jade sorting so can only have one extra key at a time
	self.allTblDataSortColumns.clear();
	self.allTblDataSortDescending.clear();

	sortCol := self.sortColumn[3];
	
	self.clearSort;
	// we need to add our group columns into the sort order
	self.addGroupColsToJadeSortOrder;

	if sortCol &lt;&gt; _column then
		self.sortAscending := true;
	else
		self.sortAscending := not self.sortAscending;
	endif;
	
	sortCol := _column;
	entRow	:= self.allTblDataEntRows[sortCol];
	
	// insert new column in sort order
	self.allTblDataSortColumns.insert(1, entRow.name);
	self.allTblDataSortDescending.insert(1, not self.sortAscending);	// par 21590
	
	if sortCol &lt; self.columns and 
		sortCol &lt; (self.getColumnForGroupingETRow - 1) then	// par 21171
		// use the following column if it is an invisible sort column
		if (not self.accessColumn(sortCol + 1).visible) then
			str := self.accessCell(1, sortCol + 1).text;
			
			if str &lt;&gt; null and str[1:1] = SortColHeadingPrefix then
				sortCol := sortCol + 1;
			endif;
		endif;
	endif;

	self.sortColumn[3]	:= sortCol;    
	self.sortAsc[3]		:= self.sortAscending;
	self.sortCased[3]	:= false;

	if entRow &lt;&gt; null then
		self.sortType[3] := self.convertInputTypeToSortType(entRow.inputType);
	endif;

	self.resort; 
epilog

end;</source>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="rows" id="b2da36c4-d1a4-4fb2-8d56-9a2723f3b9de">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>rows(set: Boolean; value: Integer io) updating, mapping, clientExecution;
// ---------------------------------------------------------------------------
// Created:     07 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
/*	if they are removing all the rows in the table then
	we will clear the groups */
	if set and value &lt;= self.fixedRows then
		self.clearGroups;
	endif;
	
	inheritMethod(set, value);

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setColumnsFromOrganiser" id="6b4cd6c9-6444-43cd-9bed-81d70f93a6ca">
        <updating/>
        <source>setColumnsFromOrganiser(_entTblRowArray: EntTableRowArray; _hiddenTblRows: EntTableRowArray) updating;
// ---------------------------------------------------------------------------
// Created:     07 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_entTblRowArray, _hiddenTblRows);

	// they are going to have to re-load table so clear out saved groups
	self.clearGroups;
epilog

end;</source>
        <Parameter name="_entTblRowArray" type="EntTableRowArray"/>
        <Parameter name="_hiddenTblRows" type="EntTableRowArray"/>
    </JadeMethod>
    <JadeMethod name="setExpandCollapse" id="70a86c71-516d-4a8a-b1c2-5e47bca3609b">
        <updating/>
        <source>setExpandCollapse(_expand :Boolean; _row :Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     07 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _expand then
		// showing '+' so is actually collasped
		self.accessCell(_row, 1).picture 	:= app.myRoot.getConfig(PicYAMExpand).Binary;
	else
		// showing '-' so is actually expanded
		self.accessCell(_row, 1).picture := app.myRoot.getConfig(PicYAMCollapse).Binary;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_expand" type="Boolean"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setGroupLevel" id="3d2c8ba2-059b-463e-a8b5-19f33d4aa193">
        <updating/>
        <source>setGroupLevel(_row, _level :Integer) updating, protected;
// ---------------------------------------------------------------------------
