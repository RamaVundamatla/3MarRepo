	_value := DeckingLevel_Row;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="b23686f5-4532-44d4-ac89-23c200285b00">
        <source>pxyCreateUpdateProxy(): SelfType;
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyOptions		: CM_YADeckingOptionsRow;
	completedOK		: Boolean;
begin
	pxyOptions := inheritMethod();
	pxyOptions.myGridObject := self.myGridObject;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyOptions;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyOptions;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a503380a-e0c1-40c8-910f-59938301d57f">
        <updating/>
        <source>setForCreate(_pxyDeckingOpts: CM_YADeckingOptionsRow) updating;
//----------------------------------------------------------------
//	Created:	07 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.myGridObject := _pxyDeckingOpts.myGridObject;
	inheritMethod(_pxyDeckingOpts);

end;</source>
        <Parameter name="_pxyDeckingOpts" type="CM_YADeckingOptionsRow"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="cfc8293a-7c42-4d80-9687-254c47afa1d4">
        <updating/>
        <source>setForUpdate(_pxyDeckingOpts: CM_YADeckingOptions; _updateToLevel: Integer) updating;
//----------------------------------------------------------------
//	Created:	20 May 2005	by Jason Chapman  (cnwjc2)
//
//
//	When a row is updated the decking order flows through to the blocks
//
//----------------------------------------------------------------
vars
	yaBlock	: CM_YABlock;
	pxyBlockDO	: CM_YADeckingOptionsBlock;
begin
	inheritMethod(_pxyDeckingOpts, _updateToLevel);
	
	if _updateToLevel &lt;= self.myDeckingLevel then
		return;
	endif;

	foreach yaBlock in self.myGridObject.allYABlockGridAreas discreteLock do //allocation.allYABlocksIn do
		if yaBlock.CM_YABlockGridArea.getGridObject() &lt;&gt; self.myGridObject then
			//not one to update
			continue;
		endif;
		pxyBlockDO := yaBlock.myDeckingOptions.pxyCreateUpdateProxy();
		pxyBlockDO.allDeckingRulesIn.purge;

		pxyBlockDO.copyInRules(self);
		
		pxyBlockDO.allDeckingRulesOut.purge;

		pxyBlockDO.copyOutRules(self);
		
		app.myUtilityUA.utlUpdateDeckOptionsApplyRules(pxyBlockDO, _updateToLevel, app.myPassport);
		
		if app.myPassport.hasErrors then
			return;
		endif;	
		
		//delete pxyBlockDO;
	endforeach;
epilog
	if global.isValidObject(pxyBlockDO) then
		delete pxyBlockDO;	
	endif;
end;</source>
        <Parameter name="_pxyDeckingOpts" type="CM_YADeckingOptions"/>
        <Parameter name="_updateToLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="554009d3-452f-4031-b28e-d34c4d8f71c2">
        <updating/>
        <source>setProxy(_showHeights, _outUsesReverseIn: Boolean; _areaObject: CM_Object) updating;
//----------------------------------------------------------------
//	Created:	11 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(_showHeights, _outUsesReverseIn, _areaObject);

	if _areaObject &lt;&gt; null then
		self.myGridObject := _areaObject.CM_GridObject;
	endif;

end;</source>
        <Parameter name="_showHeights" type="Boolean"/>
        <Parameter name="_outUsesReverseIn" type="Boolean"/>
        <Parameter name="_areaObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setPxyRulesFrmHeightDirections" id="28540b12-0f2f-46e3-82cf-ea1af14f3b7c">
        <updating/>
        <source>setPxyRulesFrmHeightDirections(_heightDirections: IntegerArray) updating;
//----------------------------------------------------------------
//	Created:	19 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx,
	topIdx,
	endIdx,
	startIdx,
	currDir,
	prevDir		: Integer;
	rules		: CM_DeckingRuleByHeightFromAsc;
	rule		: CM_YADeckingRule;
	ruleType	: Integer;
begin
	
	create rules transient;
	topIdx	:= _heightDirections.size;
	idx		:= 0;
	startIdx := 1;


	
	foreach currDir in _heightDirections do
		idx := idx + 1;
		if prevDir = null then
			prevDir := currDir;
			continue;
		endif;
		
		if idx = topIdx then
			//end of the line - the rule must end here
			if currDir = Decking_Up then
				//impossible on top height
				app.raiseCMException2(INVALID_DECKING_CHANGE_HEIGHT, 'stack up', topIdx.String, null, null);
				return;
			elseif currDir = Decking_Right then
				if prevDir = Decking_Up then
					self.createPxyRule(Height_Then_Next_Row_Pos, startIdx, idx, true, rules);
				elseif prevDir = Decking_Left then
					if startIdx &lt; idx then
						self.createPxyRule(Layer_Then_Last_Row_Pos, startIdx, idx-1, true, rules);
					endif;
					self.createPxyRule(Layer_Then_First_Row_Pos, idx, idx, true, rules);
				else//right
					self.createPxyRule(Layer_Then_First_Row_Pos, startIdx, idx, true, rules);
				endif;
			elseif currDir = Decking_Down then
				//impossible
				return;
			elseif currDir = Decking_Left then
				if prevDir = Decking_Up then
					self.createPxyRule(Height_Then_Prev_Row_Pos, startIdx, idx, true, rules);
				elseif prevDir = Decking_Left then
					self.createPxyRule(Layer_Then_Last_Row_Pos, startIdx, idx, true, rules);
				else//right
					if startIdx &lt; idx then
						self.createPxyRule(Layer_Then_First_Row_Pos, startIdx, idx-1, true, rules);
					endif;
					self.createPxyRule(Layer_Then_Last_Row_Pos, idx, idx, true, rules);
				endif;
			else
				//possible but not allowed
				app.raiseCMException1(INVALID_DECKING_CHANGE_CUSTOM, 'Custom', null, null);
				return;
			endif;
			break;
		endif;
		if prevDir = currDir then
			prevDir := currDir;	//for completeness
			continue;
		endif;
		if startIdx &gt;= idx then
			prevDir := currDir;
			continue;
		endif;
		//need to create a rule if we end up here
		//rule may end on idx or idx-1
		if currDir = Decking_Up then
			if prevDir = Decking_Left then
				self.createPxyRule(Layer_Then_Last_Row_Pos, startIdx, idx-1, true, rules);
			else//right
				self.createPxyRule(Layer_Then_First_Row_Pos, startIdx, idx-1, true, rules);
			endif;
			startIdx := idx;
		elseif currDir = Decking_Right then
			if prevDir = Decking_Up then
				self.createPxyRule(Height_Then_Next_Row_Pos, startIdx, idx, true, rules);
				startIdx := idx+1;
			else//left
				self.createPxyRule(Layer_Then_Last_Row_Pos, startIdx, idx-1, true, rules);
				startIdx := idx;
			endif;
		elseif currDir = Decking_Down then
			//impossible
			return;
		elseif currDir = Decking_Left then
			if prevDir = Decking_Up then
				self.createPxyRule(Height_Then_Prev_Row_Pos, startIdx, idx, true, rules);
				startIdx := idx+1;
			else//right
				self.createPxyRule(Layer_Then_First_Row_Pos, startIdx, idx-1, true, rules);
				startIdx := idx;
			endif;

		else
			//possible but not allowed
			app.raiseCMException1(INVALID_DECKING_CHANGE_CUSTOM, 'Custom', null, null);
			return;
		endif;
		
		prevDir := currDir;
	endforeach;
	
	
	self.allDeckingRulesIn.purge;
	
	rules.copy(self.allDeckingRulesIn);
	
	
epilog
	
	delete rules;
end;</source>
        <Parameter name="_heightDirections" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="validateCellPositions" id="c16b80e5-465b-48d7-82ae-79b2901aff24">
        <source>validateCellPositions(_forIn: Boolean; _locnCellArray: CM_YALocationCellArray);
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	locnCtrl	: Object;
begin

	if _forIn then
		foreach locnCtrl in self.myGridObject.getDictForDecking() do
			locnCtrl.CM_YardController.validateLocnCellsAscInArray(_locnCellArray);
		endforeach;
	else
		foreach locnCtrl in self.myGridObject.getDictForDecking() do
			locnCtrl.CM_YardController.validateLocnCellsDescInArray(_locnCellArray);
		endforeach;
	endif;

end;</source>
        <Parameter name="_forIn" type="Boolean"/>
        <Parameter name="_locnCellArray" type="CM_YALocationCellArray"/>
    </JadeMethod>
</Class>
