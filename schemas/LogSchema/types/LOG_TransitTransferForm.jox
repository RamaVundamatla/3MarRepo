    <JadeMethod name="translateForm" id="6acdf9d4-5ca2-43e7-9b19-17c7c6add096">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006342, locale);
	btnNextT.translateCaption(Xlat_0002448, locale);
	btnResetT.translateCaption(Xlat_0002446, locale);
	btnSearchT.translateCaption(Xlat_0002445, locale);
	btnSelectAllT.translateCaption(Xlat_0002444, locale);
	btnSelectNoneT.translateCaption(Xlat_0002443, locale);
	optDocket.translateCaption(Xlat_0002447, locale);
	optLogID.translateCaption(Xlat_0002449, locale);
	optSED.translateCaption(Xlat_0002451, locale);
	optSpecs.translateCaption(Xlat_0002450, locale);
end;</source>
    </JadeMethod>
