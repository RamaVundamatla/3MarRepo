    <JadeMethod name="displayDoorDirectionRule" id="213f51e8-be82-4944-87ae-893d743124b3">
        <updating/>
        <source>displayDoorDirectionRule( _theDoorDirectionRule : CM_DoorDirectionRule ) updating;
// ---------------------------------------------------------------------------
// Created:		04/09/2007	By cnwvu1
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 
vars
	doorDirectionRule	: CM_DoorDirectionRule;
begin

	if _theDoorDirectionRule = null then
		return;
	endif;
	self.myCurrentDoorDirectionRule	:= _theDoorDirectionRule;
	doorDirectionRule := self.myCurrentDoorDirectionRule;

	if not self.myCurrentTerminalArea.isRestrictionBlockStack() then 
		self.frmGridArea.myGridArea.YRD_PadArea.doSelectDoorDirectionRule( doorDirectionRule );
	endif;
	
	//self.tblOther.setValueByName( ETRow_Description, doorDirectionRule.description );													//	-TFS3212												
	self.tblOther.setValueByName( ETRow_Id, doorDirectionRule.description );																		// +TFS3212
	self.tblOther.setValueByName( ETRow_DoorDirectionRuleWording, doorDirectionRule.doorDirectionWording );
	if doorDirectionRule.myISOTypeGroup &lt;&gt; null then 
		self.tblOther.setValueByName( ETRow_IsoTypeGroup, doorDirectionRule.myISOTypeGroup.description);
	else 
		self.tblOther.setValueByName( ETRow_IsoTypeGroup, null );
	endif;
	self.cmbISOTypeGroup.setObject( doorDirectionRule.myISOTypeGroup );

	self.tblOther.setValueByName( ETRow_Colour, doorDirectionRule.colour );

	
end;
</source>
        <Parameter name="_theDoorDirectionRule" type="CM_DoorDirectionRule"/>
    </JadeMethod>
    <JadeMethod name="displayEmailAddress" id="909ddbf1-83f2-49a7-9bc0-471fbd06b7f1">
        <source>displayEmailAddress(_theObject : Object) : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2015	cnwndl1	Initial creation	Par 36588

*/

vars

begin
	if _theObject = null or not _theObject.isKindOf(CM_EmailAddress2) then
		return null;
	else
		return _theObject.CM_EmailAddress2.getDisplayDetails(false);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_theObject" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayHazardDetails" id="7e6498a4-d1db-41f4-b883-c909086aed63">
        <updating/>
        <source>displayHazardDetails(_hazDetails : CM_TerminalAreaHazDetails) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 22/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	hazTemp : CM_HazTempRange;
	col, row : Integer;
	str : String;

begin
	if _hazDetails = null then
		return;
	endif;
	self.myCurrentHazardDetail := _hazDetails;
	self.tblOther.setValueByName(ETRow_Colour, _hazDetails.colour);
	self.tblOther.setValueByName(ETRow_Id, _hazDetails.id);
	if _hazDetails.myHazardClass &lt;&gt; null then
		self.tblOther.setValueByName(ETRow_HazardClass, _hazDetails.myHazardClass.code);
		self.cmbHazClass.setIndexFromObject(_hazDetails.myHazardClass);
	endif;
	if not _hazDetails.allHazTempRanges.isEmpty then
		self.tblOther.setValueByName(ETRow_Flashpoint, _hazDetails.getHazTempRangesDisplay);
		foreach hazTemp in _hazDetails.allHazTempRanges do
			self.tblFlashpoints.setSelectedString(hazTemp.getDisplayDetails(false));
			self.tblFlashpoints.allSelectedObjects.addExclusive(hazTemp);
		endforeach;
	endif;
	self.tblOther.setValueByName(ETRow_PackingGroup, _hazDetails.getPackingGroupsForDisplay);
	if not _hazDetails.packingGroups.isEmpty then
		foreach str in _hazDetails.packingGroups do
			self.tblPackGroups.setSelectedString(str);
		endforeach;
	endif;
	self.tblOther.setValueByName(ETRow_AcidsBases, _hazDetails.acidBase);
	if _hazDetails.acidBase &lt;&gt; null then
		self.cmbAcidBase.setIndex(self.cmbAcidBase.findStringExact(1, _hazDetails.acidBase));
	endif;
	self.tblOther.setValueByName(ETRow_AllowNonHazardous, _hazDetails.allowNonHazardous);
	self.tblOther.setValueByName(ETRow_ShowError, _hazDetails.showError);
	
	if not self.myCurrentTerminalArea.isRestrictionBlockStack() then 
		self.frmGridArea.myGridArea.YRD_PadArea.doSelectHazards(_hazDetails);
	endif;
epilog

end;</source>
        <Parameter name="_hazDetails" type="CM_TerminalAreaHazDetails"/>
    </JadeMethod>
    <JadeMethod name="displayISOGroup" id="f1f0c83e-038e-489a-8ecd-7526a7fafc8a">
        <source>displayISOGroup(pObj : CM_ISOTypeGroup) : String;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pObj &lt;&gt; null then
		return pObj.code &amp; Tab &amp; pObj.description;
	endif;

end;</source>
        <Parameter name="pObj" type="CM_ISOTypeGroup"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayLabour" id="069b1639-f5fe-47cd-98f8-6043a66c9c69">
        <updating/>
        <source>displayLabour(_theLR : CM_LabourRestriction) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
vars
	labourRestriction 	: CM_LabourRestriction;
	invalidOrg,
	invalidReason		: Boolean;
	
begin

	
	self.mulNotifyEmails.setSelected( null );
	
	if _theLR = null then
		return;
	endif;
	self.myCurrentLabourRestriction	:= _theLR;
	labourRestriction := self.myCurrentLabourRestriction;	

	if not self.myCurrentTerminalArea.isRestrictionBlockStack() then 
		self.frmGridArea.myGridArea.YRD_PadArea.doSelectLabour(labourRestriction);
	endif;

	self.tblOther.setValueByName(ETRow_Comment,labourRestriction.comment);
	self.tblOther.setValueByName(ETRow_Colour,labourRestriction.colour);
	self.tblOther.setValueByName(ETRow_Id,labourRestriction.id);
	
	if labourRestriction.myOrganisation &lt;&gt; null then 
		on Exception do app.handleDeletedObject(exception, labourRestriction.myOrganisation, invalidOrg);	// PAR #20528
		self.tblOther.setValueByName(ETRow_Organisation, labourRestriction.myOrganisation.name);
	endif;
	if labourRestriction.myOrganisation = null or invalidOrg then 
		self.tblOther.setValueByName(ETRow_Organisation, null);
	endif;
	self.cmbOrganisation.setObject(labourRestriction.myOrganisation);
	
	if labourRestriction.myReason &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, labourRestriction.myReason, invalidReason);		// PAR #20528
		self.tblOther.setValueByName(ETRow_Reason, labourRestriction.myReason.description);
	endif;
	if labourRestriction.myReason = null or invalidReason then
		self.tblOther.setValueByName(ETRow_Reason, null);
	endif;	
	self.cmbReason.setObject(labourRestriction.myReason);
	
//	self.tblOther.setValueByName(ETRow_DurationHours,labourRestriction.durationHours);
	if labourRestriction.durationHours.isValid then 
//		self.txtDurationHours.setTime(labourRestriction.durationHours);
		self.tblOther.setValueByName(ETRow_DurationHours, labourRestriction.durationHours);
	else 
		self.tblOther.setValueByName(ETRow_DurationHours, null);
	endif;
	self.tblOther.setValueByName(ETRow_DurationDays,labourRestriction.durationDays);

	if labourRestriction.expiryDateTime = null then 
		self.tblOther.setValueByName(ETRow_Expiry, 'Indefinite');
	else
		self.tblOther.setValueByName(ETRow_Expiry, labourRestriction.expiryDateTime.String);
	endif;
	
	self.tblOther.showRowByName(ETRow_Expiry,false);
	self.tblOther.disableRowByName(ETRow_Expiry);
	self.tblOther.hideRowByName(ETRow_HideFromOverView,false);
	
// cnwdad1 02/06/2010 - CCMS 1947.
	if labourRestriction.isOtagoStraddleAreaAorC() then
		self.tblOther.setValueByName(ETRow_IgnoreLights, labourRestriction.ignoreLights);
	endif;
	
	//08 Jul 2015	NDL	Par 36588
	// TFS 2198 self.mulNotifyEmails.setSelected( labourRestriction.allNotifyEmailEntities );
	
	// TFS 2198
	if labourRestriction.myOrganisation &lt;&gt; null then
		self.mulNotifyEmails.setAvailable(labourRestriction.myOrganisation.allSelectedEmailAddresses, true);
		self.mulNotifyEmails.setSelected( labourRestriction.allNotifyEmailEntities );
	endif;
	
end;</source>
        <Parameter name="_theLR" type="CM_LabourRestriction"/>
    </JadeMethod>
    <JadeMethod name="displayListBox" id="868907e9-5322-434f-a357-13108580b82f">
        <updating/>
        <source>displayListBox() updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 07/11/2012	cnwcs5	par 30475 - tidy up translations
// 22/11/2016	cnwdap1	TFS 2844 STWR Hazardous Details Enhancements
// 23/02/2017	cnwjre1	TFS 3422 add more area types, for hazards
// 30/06/2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
vars
	listbox			: CMUI_ListBox;
	theArea 		: CM_TerminalArea;
	lvl, idx, 
	areaMode		: Integer;
	aSBS 			: CM_SubBlockStack;
	aLR 			: CM_LabourRestriction;
	aDoor			: CM_DoorDirectionRule;
	tmpTermSubArea 	: CM_TerminalSubArea;
	hazArea 		: CM_TerminalAreaHazDetails;							// TFS 2844
begin
	listbox := self.lstRestrictions;
	
	listbox.clear;
	
	if self.myCurrentTerminalArea = null then
		return;
	endif;
	
	theArea := self.myCurrentTerminalArea ;
	
	lvl := 1;
	idx := listbox.addItem(theArea.id &amp; " Location Maintenance");
	
	listbox.itemLevel[idx] 		:= lvl;
	listbox.itemObject[idx] 	:= null;	
	listbox.itemPicture[idx] 	:= self.picForm.picture;
	listbox.itemData[idx] 		:= null;
	
	// ####################
	// HEIGHTS
// TFS 2198	if app.myCurrentUserCan(self.myTerminal,PmAdmPadeditMaint)  and theArea.isKindOf(CM_GridArea) then
	if theArea.isKindOf(CM_GridArea) then
		lvl 						:= 2;
		idx 						:= listbox.addItem(app.getErrorString (Pad_Edit));	// par 30475
		listbox.itemObject[idx]	 	:= theArea;
		listbox.itemLevel[idx] 		:= lvl;
		areaMode 					:= YRD_PadArea.AreaMode_Height;
		listbox.itemData[idx] 		:= areaMode;
		listbox.itemPicture[idx] 	:= self.picHeight.picture;
	endif;
		
	// ####################
	// LABOUR
// TFS 2198	if app.myCurrentUserCan(self.myTerminal,PmAdmLabrestrMaint) then
	if not self.isLimitedType(theArea.type) then
		lvl := 2;
		idx := listbox.addItem(app.getErrorString (Labour_restrictions));	// par 30475
		
		listbox.itemObject[idx] 	:= theArea;
		listbox.itemLevel[idx] 		:= lvl;
		areaMode 					:= YRD_PadArea.AreaMode_Labour;
		listbox.itemData[idx] 		:= areaMode;
		listbox.itemPicture[idx] 	:= self.picLabour.picture;
		
		foreach aLR in theArea.allRestrictionsLabour do
			lvl := 3;
			idx := listbox.addItem(aLR.id &amp; " " &amp; aLR.comment);
			listbox.itemObject[idx] 	:= aLR;
			listbox.itemLevel[idx] 		:= lvl;
			listbox.itemData[idx] 		:= areaMode;
			listbox.itemPicture[idx] 	:= null;
		endforeach;
	endif;
	
	// ####################
	// SUB BLOCK STACKS
// TFS 2198	if app.myCurrentUserCan(self.myTerminal,PmAdmBlockstackMaint) 
// TFS 2198	and theArea.isKindOf(CM_GridArea) then
	if theArea.isKindOf(CM_GridArea) 						// TFS 49453
	and not theArea.isGeneralCargoAllocArea then			// TFS 49453
		lvl := 2;
		idx := listbox.addItem(app.getErrorString (Sub_Block_stacks));
		
		listbox.itemObject[idx] 	:= theArea;
		listbox.itemLevel[idx] 		:= lvl;
		areaMode 					:= YRD_PadArea.AreaMode_SubBlock;
		listbox.itemData[idx] 		:= areaMode;
		listbox.itemPicture[idx]	:= self.picSBS.picture;
		
		foreach aSBS in theArea.CM_GridArea.allSubBlockStacks do
			lvl := 3;
			idx := listbox.addItem(aSBS.id &amp; " " &amp; aSBS.comment);
			
			listbox.itemObject[idx] 	:= aSBS;
			listbox.itemData[idx] 		:= areaMode;
			listbox.itemLevel[idx] 		:= lvl;
			listbox.itemPicture[idx] 	:= null;
		endforeach;
	endif;
	// ####################
	// TERMINAL SUB AREAS
	//cnwjo3 ccms 1018, don't need this selection for RoRos
// TFS 2198 	if app.myCurrentUserCan(self.myTerminal,PmAdmLabrestrMaint) and not theArea.isKindOf(CM_RoRoLaneArea) then
	if not theArea.isKindOf(CM_RoRoLaneArea)
	and not theArea.isGeneralCargoAllocArea					// TFS 49453
	and not self.isLimitedType(theArea.type) then
		lvl := 2;
		idx := listbox.addItem(app.getErrorString (Sub_Areas));	// par 30475
		
		listbox.itemObject[idx] 	:= theArea;
		listbox.itemLevel[idx] 		:= lvl;
		areaMode 					:= YRD_PadArea.AreaMode_TermSubArea;
		listbox.itemData[idx] 		:= areaMode;
		listbox.itemPicture[idx] 	:= self.picLabour.picture;
		
		foreach tmpTermSubArea in theArea.allSubAreas do
			lvl := 3;
			idx := listbox.addItem(tmpTermSubArea.id);
			
			listbox.itemObject[idx] 	:= tmpTermSubArea;
			listbox.itemLevel[idx] 		:= lvl;
			listbox.itemData[idx] 		:= areaMode;
			listbox.itemPicture[idx] 	:= null;
		endforeach;
	endif;
	
	// ####################
	// Door Directions ccms 1572
	// cnwjo3 ccms 1018, don't need this selection for RoRos
	// TFS 2198 if app.myCurrentUserCan(self.myTerminal, PmAdmDoorDirectionsUpdate ) and not theArea.isKindOf(CM_RoRoLaneArea) then
	if not theArea.isKindOf(CM_RoRoLaneArea) 
	and not theArea.isGeneralCargoAllocArea					// TFS 49453
	and not self.isLimitedType(theArea.type) then
		lvl 						:= 2;
		idx 						:= listbox.addItem(app.getErrorString (XLAT_LU_DoorDirRules));	// par 30475
		listbox.itemObject[idx] 	:= theArea;
		listbox.itemLevel[idx] 		:= lvl;
		areaMode 					:= YRD_PadArea.AreaMode_DoorDirection;
		listbox.itemData[idx] 		:= areaMode;
		listbox.itemPicture[idx] 	:= self.picDoorDirection.picture;
		foreach aDoor in theArea.allDoorDirectionRules do
			lvl := 3;
			idx := listbox.addItem( aDoor.description );
			listbox.itemObject[idx] := aDoor;
			listbox.itemLevel[idx] := lvl;
			listbox.itemData[idx] := areaMode;
			listbox.itemPicture[idx] := null;
		endforeach;
	endif;
	
	// TFS 2844 STWR Hazardous Details Enhancements										// TFS 2844
	// Allow hazard criteria on areas / partial areas (but not RORO lanes)				// TFS 2844
	if not theArea.isKindOf(CM_RoRoLaneArea) or											// TFS 2844
	   self.isLimitedType(theArea.type) then											// TFS 3422
		lvl							:= 2;												// TFS 2844
		idx 						:= listbox.addItem(app.getErrorString(Hazards));	// TFS 2844
		listbox.itemObject[idx]		:= theArea;											// TFS 2844
		listbox.itemLevel[idx]		:= lvl;												// TFS 2844
		areaMode					:= YRD_PadArea.AreaMode_Hazardous;					// TFS 2844
		listbox.itemData[idx]		:= areaMode;										// TFS 2844
		listbox.itemPicture[idx] 	:= self.picHazard.picture;							// TFS 2844
		foreach hazArea in theArea.allTerminalAreaHazDetails do							// TFS 2844
			lvl						:= 3;												// TFS 2844
			idx 					:= listbox.addItem(hazArea.id);						// TFS 2844
			listbox.itemObject[idx] := hazArea;											// TFS 2844
			listbox.itemLevel[idx] 	:= lvl;												// TFS 2844
			listbox.itemData[idx] 	:= areaMode;										// TFS 2844
			listbox.itemPicture[idx] := null;											// TFS 2844
		endforeach;																		// TFS 2844
	endif;																				// TFS 2844
	
	listbox.itemExpanded[1] := true;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="displayListBoxAdd" id="206658f8-16bb-4912-865e-60273b56bad9">
        <updating/>
        <source>displayListBoxAdd(_theCaption : String;_theObject : Object; _areaMode : Integer; _theLevel : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx,theIndex : Integer;
	areaMode, tmpSt, tmpEnd : Integer;
	itemText : String;
begin
	areaMode :=  _areaMode;
	tmpEnd := self.lstRestrictions.listCount;
	tmpSt := 1; 
	
	foreach idx in tmpSt to tmpEnd do
		if self.lstRestrictions.itemObject[idx] = self.myCurrentTerminalArea 
		and self.lstRestrictions.itemData[idx] = areaMode then
			theIndex := idx + 1;
			break;
		endif;
	endforeach;
	
	tmpSt := theIndex;
	foreach idx in tmpSt to tmpEnd do
		itemText := self.lstRestrictions.itemText[idx];
		if self.lstRestrictions.itemData[idx] &lt;&gt; areaMode then
			theIndex := idx;
			break;
		elseif _theCaption &lt; itemText then
			theIndex := idx;
			break;
		endif;
	endforeach;
	if theIndex &lt; tmpSt then
		theIndex := tmpSt;
	endif;

	lstRestrictions.addItemAt(_theCaption,theIndex);

	lstRestrictions.itemObject[theIndex] := _theObject;
	lstRestrictions.itemData[theIndex] := _areaMode;
	lstRestrictions.itemLevel[theIndex] := _theLevel;
	lstRestrictions.itemPicture[theIndex] := null;
	lstRestrictions.itemExpanded[theIndex] := true;
	
	lstRestrictions.listIndex := theIndex;
	self.myCurrentObject := _theObject;
	self.tblData.selectObject(_theObject, false);

end;</source>
        <Parameter name="_theCaption" type="String"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_areaMode" type="Integer"/>
        <Parameter name="_theLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="displayListBoxFindUpdate" id="115f39a0-85eb-4af7-b475-d69ef82a320d">
        <updating/>
        <source>displayListBoxFindUpdate(_theCaption : String;_theObject : Object; _areaMode : Integer; _theLevel : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theIndex : Integer;
begin
	theIndex := self.lstRestrictions.findObject(_theObject);

	lstRestrictions.removeItem(theIndex);
	lstRestrictions.addItemAt(_theCaption,theIndex);

	lstRestrictions.itemObject[theIndex] := _theObject;
	lstRestrictions.itemData[theIndex] := _areaMode;
	lstRestrictions.itemLevel[theIndex] := _theLevel;
	lstRestrictions.itemPicture[theIndex] := null;
	lstRestrictions.itemExpanded[theIndex] := true;
	
	lstRestrictions.listIndex := theIndex;
	
	self.myCurrentObject := _theObject;


end;</source>
        <Parameter name="_theCaption" type="String"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_areaMode" type="Integer"/>
        <Parameter name="_theLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="displayListBoxRemoveAdd" id="68ee4476-c982-4e70-a043-f6673e7bfb9a">
        <updating/>
        <source>displayListBoxRemoveAdd(_theCaption : String;_theIndex : Integer;_theObject : Object; _areaMode : Integer; _theLevel : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.mode = self.Mode_Add then
		lstRestrictions.addItemAt(_theCaption,_theIndex);
	else
		lstRestrictions.removeItem(_theIndex);
		lstRestrictions.addItemAt(_theCaption,_theIndex);
	endif;
	lstRestrictions.itemObject[_theIndex] := _theObject;
	lstRestrictions.itemData[_theIndex] := _areaMode;
	lstRestrictions.itemLevel[_theIndex] := _theLevel;
	lstRestrictions.itemPicture[_theIndex] := null;
	
	self.myCurrentObject := _theObject;

end;</source>
        <Parameter name="_theCaption" type="String"/>
        <Parameter name="_theIndex" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_areaMode" type="Integer"/>
        <Parameter name="_theLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="displaySBS" id="b38f7f74-73bb-4174-a139-b1d8556cf89c">
        <updating/>
        <source>displaySBS(_theSub : CM_BlockStack) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
vars

begin
	if _theSub = null then
		return;
	endif;
	self.myCurrentSubBlockStack	:= _theSub;
	self.tblOther.setValueByName(ETRow_Colour,_theSub.myLayoutGraphic.drawLineColour);
	self.tblOther.setValueByName(ETRow_Id,_theSub.id);
	self.tblOther.setValueByName(ETRow_AutoRestrictionsEnabled,_theSub.autoRestrictionsEnabled);
	self.tblOther.setValueByName(ETRow_HideFromOverView,_theSub.hideFromOverView);
	self.tblOther.setValueByName(ETRow_StockControlled,_theSub.isStockControlled);
	self.tblOther.setValueByName(ETRow_MaxCapacity,_theSub.maxCapacity); //par18840 cnwjo3
	
end;</source>
        <Parameter name="_theSub" type="CM_BlockStack"/>
    </JadeMethod>
    <JadeMethod name="displayTermSubArea" id="11355dc4-7d2c-49d7-957b-5bd0d2f391da">
        <updating/>
        <source>displayTermSubArea(_termSubArea : CM_TerminalSubArea)updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2005	cnwhjg1
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
vars
	tmpTermSubArea : CM_TerminalSubArea;
	
begin
	if _termSubArea = null then
		return;
	endif;
	self.myCurrentTermSubArea	:= _termSubArea;
	tmpTermSubArea := self.myCurrentTermSubArea;	

	if not self.myCurrentTerminalArea.isRestrictionBlockStack() then 
		self.frmGridArea.myGridArea.YRD_PadArea.doSelectTermSubArea(tmpTermSubArea);
	endif;

//	self.tblOther.setValueByName(ETRow_Comment,labourRestriction.comment);
	self.tblOther.setValueByName(ETRow_Colour,tmpTermSubArea.colour);
	self.tblOther.setValueByName(ETRow_Id,tmpTermSubArea.id);
	
	self.tblOther.hideRowByName(ETRow_HideFromOverView,false);
end;</source>
        <Parameter name="_termSubArea" type="CM_TerminalSubArea"/>
    </JadeMethod>
    <JadeMethod name="doBtnDoorDirectionRuleAdd" id="9a8f7c23-c531-4a2d-9d01-0317634a12d2">
        <updating/>
        <source>doBtnDoorDirectionRuleAdd() updating;
// ---------------------------------------------------------------------------
// Created:		04/09/2007  By cnwvu1
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 
//----------------------------------------------------------------------------
vars
	theArea : YRD_PadArea;

begin

//	app.msgBox( "Door direction rule ADD - under development", "doBtnDoorDirectionRuleAdd", MsgBox_OK_Only );

	if not self.myCurrentTerminalArea.isGridArea() then
		app.raiseCMWarning1( WARN_NOT_GRID_AREA, self.myCurrentTerminalArea.id, null, self,self.myTerminal );
		self.doBtnDoorDirectionRuleCancel();
		return;
	
	endif;

	theArea := self.frmGridArea.myGridArea.YRD_PadArea;
	
	self.tblOther.clearValues();
	self.frmGridArea.enabled := true;
	self.mousePointer := Window.MousePointer_HourGlass;
	self.doEnableControls(true);
	self.myCurrentDoorDirectionRule := null;
	
	theArea.paintColour := Yellow;
	theArea.editMode := true;	
	
	theArea.drawingMode := true;
	self.mySDF.drawSelf();
	theArea.drawingMode := false;

	//self.tblOther.goToRowByName(ETRow_Description);				//-TFS3212
	self.tblOther.goToRowByName(ETRow_Id);									//+TFS3212
	
epilog
	self.mousePointer := Window.MousePointer_Default;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doBtnDoorDirectionRuleCancel" id="6df37aef-c26d-4f56-8dec-7705ecc11c20">
        <updating/>
        <source>doBtnDoorDirectionRuleCancel() updating;
// ------------------------------------------------------------
// Created:     07/09/2007	by cnwvu1
// ------------------------------------------------------------
vars
	theArea : YRD_PadArea;
	theReturn : Integer;
	dataChanged : Boolean;
	
begin

	theArea := self.frmGridArea.myGridArea.YRD_PadArea;
	dataChanged := self.tblOther.hasChanged;
	if not dataChanged and theArea &lt;&gt; null then
		dataChanged := theArea.dataChanged;
	endif;
	if dataChanged  then
		theReturn := app.msgBox("You have changed data on this Terminal Area." &amp; Cr &amp; "Do you want to save now?","Confirm Save",
							MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second);
		if theReturn = MsgBox_Return_Yes then
			self.doBtnDoorDirectionRuleSave();
			return;
		endif;
	endif;

	self.tblOther.clearValues();
	self.mousePointer := Window.MousePointer_HourGlass;
	self.doEnableControls(false);

	self.frmGridArea.enabled := false;
	theArea.doLockAll(false);
	theArea.clearAllSelectedItems();
	theArea.editMode := false;	
	self.mySDF.drawSelf();

	self.displayDoorDirectionRule( self.myCurrentDoorDirectionRule );
		self.sptThumbEdit.showLeftControl(25, true);

epilog
	delete self.myProxyDoorDirectionRule;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnDoorDirectionRuleEdit" id="6c02f1aa-8be9-49cc-af0c-4c0d4e84f294">
        <updating/>
        <source>doBtnDoorDirectionRuleEdit() updating;
// ---------------------------------------------------------------------------
// Created:		04/09/2007  By cnwvu1
// ---------------------------------------------------------------------------
// 07/02/2017 cnwrh7         TFS3212      Tidy up other YardLocation bugs found duirng test
vars
	theArea : YRD_PadArea;

begin

	//self.lstRestrictions_click(self.lstRestrictions);										//-TFS3212

	if self.myCurrentDoorDirectionRule = null then
		app.msgBox("Please select a Door Direction to Edit","Edit Labour Restriction",MsgBox_OK_Only);
		return;
	endif;

	self.myProxyDoorDirectionRule := app.createUpdateProxy(self.myCurrentDoorDirectionRule).CM_DoorDirectionRule;

	theArea := self.frmGridArea.myGridArea.YRD_PadArea;
	self.mousePointer := Window.MousePointer_HourGlass;
	self.frmGridArea.enabled := true;

	theArea.paintColour := self.myCurrentDoorDirectionRule.colour;
	theArea.editMode := true;	
	theArea.drawingMode := true;
	self.mySDF.drawSelf();
	theArea.drawingMode := false;
	self.doEnableControls(true);

epilog
	self.mousePointer := Window.MousePointer_Default;

end;
</source>
    </JadeMethod>
    <JadeMethod name="doBtnDoorDirectionRuleRemove" id="9dbe7522-4828-475b-b4e1-116935cae4d2">
        <updating/>
        <source>doBtnDoorDirectionRuleRemove() updating;
// ---------------------------------------------------------------------------
// Created:		10/09/2007	by cnwvu1
// ---------------------------------------------------------------------------
// 08/03/2011	cnwcs5	CCMS CPL 2017/PAR 27126 - use new trx
vars
	theObject	: CM_Object;
	aTA			: CM_TerminalArea;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	self.lstRestrictions_click(self.lstRestrictions);

	if self.myCurrentDoorDirectionRule = null then
		return;
	endif;

	self.frmGridArea.enabled := false;
	
	self.mousePointer := Window.MousePointer_HourGlass;
	self.modalDialogShow(null, 'Cancel', null, null, "Door Direction Rule","Removing...");
	self.tblOther.clearValues();
	self.tblOther.showRowByName( ETRow_Id, false );											//+TFS3212
	
	theObject := self.myCurrentDoorDirectionRule;
	aTA := self.myCurrentDoorDirectionRule.myTerminalArea;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteDoorDirectionRule (theObject.CM_DoorDirectionRule, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Door Direction Rule', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	self.myCurrentDoorDirectionRule := null;

epilog

	self.frmModalDialog.visible := false;
	self.mousePointer := Window.MousePointer_Default;

end;
</source>
    </JadeMethod>
    <JadeMethod name="doBtnDoorDirectionRuleSave" id="b4c4ca61-7158-4e64-85ef-3f263f687d9c">
        <updating/>
        <source>doBtnDoorDirectionRuleSave() updating;
// ---------------------------------------------------------------------------
// Created:		05/09/2007  By cnwvu1
// ---------------------------------------------------------------------------

vars
	theIndex			: Integer;
	loadStateSet		: Boolean;
	theLocations		: CM_LCSet;
	aPoint		 		: CMUI_GridPoint;
	aController 		: CM_LocationsController;
	newDoorDirectionRule: CM_DoorDirectionRule;
	result				: Integer;
	
begin

	self.mousePointer := Window.MousePointer_HourGlass;
	self.modalDialogShow(null, 'Cancel', null, null, "Door Direction Rule","Saving...");
	
	if self.mode = self.Mode_Add then
		// Create a proxy
		create self.myProxyDoorDirectionRule as CM_DoorDirectionRule transient;
	elseif self.mode = self.Mode_Update then
		if self.myCurrentDoorDirectionRule = null then
			app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, "myCurrentDoorDirectionRule=null", null, self );
			return;
		endif;
	else
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, 'Unexpected form.mode=' &amp; self.mode.String, null, self );
		return;
	endif;	
	
	create theLocations transient;
	
	foreach aPoint in self.frmGridArea.myGridArea.allSelectedPoints do
		aController := aPoint.myLocationsController;
		if aController &lt;&gt; null then
			if not theLocations.includes(aController)then
				theLocations.add(aController);
			endif;
		endif;
	endforeach;

	self.myProxyDoorDirectionRule.setForProxy( 	self.myCurrentTerminalArea,
												self.tblOther.getValueByName(ETRow_DoorDirectionRuleWording).String,
												//self.tblOther.getValueByName(ETRow_Description).String,								//-TFS3212
												self.tblOther.getValueByName(ETRow_Id).String,													//+TFS3212
												self.tblOther.getValueByName(ETRow_Colour).Integer,
												self.cmbISOTypeGroup.myObject.CM_ISOTypeGroup );

	while true do
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateDoorDirectionRule(self.myProxyDoorDirectionRule, newDoorDirectionRule, theLocations, app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.myCurrentDoorDirectionRule := newDoorDirectionRule;
			endif;
		else
			app.myTrxUA.trxUpdateDoorDirectionRule(self.myProxyDoorDirectionRule, self.myCurrentDoorDirectionRule, theLocations, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Sub Area', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	

	// CLEAN UP GUI
	self.frmGridArea.enabled := false;
	self.doEnableControls(false);

epilog
	self.frmModalDialog.visible := false;

	if app.myPassport.trxCompletedOK then
		delete self.myProxyDoorDirectionRule;
	endif;
	delete theLocations;
	//delete theLCS;
	self.mousePointer := Window.MousePointer_Default;
	
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doBtnHazardsAdd" id="f47bd7a0-1a0d-40f5-8bcf-ca0828a7b6eb">
        <updating/>
        <source>doBtnHazardsAdd() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 22/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	area : YRD_PadArea;

begin
	area := self.frmGridArea.myGridArea.YRD_PadArea;
	self.tblOther.clearValues();
	
	self.tblOther.setValueByName(ETRow_DurationHours, null);
	
	self.frmGridArea.enabled := true;
	self.mousePointer := Window.MousePointer_HourGlass;
	self.doEnableControls(true);
	self.myCurrentHazardDetail := null;

	self.tblOther.disableRowByName(ETRow_Expiry);	
	self.tblOther.hideRowByName(ETRow_Expiry,false);
	
	if not self.myCurrentTerminalArea.isRestrictionBlockStack() then
		area.paintColour := Yellow;
		area.editMode := true;	
	endif;
	
	self.tblFlashpoints.clearSelected();
	self.tblPackGroups.clearSelected();

	self.tblOther.goToRowByName(ETRow_Code);

epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnHazardsCancel" id="07ea2c7a-94ad-4a58-b137-3204360eedef">
        <updating/>
        <source>doBtnHazardsCancel() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enancements
//
vars
	area : YRD_PadArea;
	result : Integer;
	dataChanged : Boolean;
	
begin
	area := self.frmGridArea.myGridArea.YRD_PadArea;
	dataChanged := self.tblOther.hasChanged;
	if not dataChanged and area &lt;&gt; null then
		dataChanged := area.dataChanged;
	endif;
	if dataChanged then
		result := app.msgBox("You have changed data on this Hazard." &amp; Cr &amp; "Do you want to save now?","Confirm Save",
							MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second);
		if result = MsgBox_Return_Yes then
			self.doBtnHazardsSave();
			return;
		endif;
	endif;

	self.tblOther.clearValues();
	self.mousePointer := Window.MousePointer_HourGlass;
	self.doEnableControls(false);
	self.mulNotifyEmails.visible := false;

	if not self.myCurrentTerminalArea.isRestrictionBlockStack() then
		self.frmGridArea.enabled := false;
		
		area.doLockAll(false);
		area.clearAllSelectedItems();
		area.editMode := false;	
		self.mySDF.drawSelf();

		self.displayHazardDetails(self.myCurrentHazardDetail);
	endif;
		
epilog
	delete self.myProxyHazardDetails;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnHazardsEdit" id="9ddf6e9d-e390-4614-9e72-3d961606bdc7">
        <updating/>
        <source>doBtnHazardsEdit() updating;
//
// Purpose:			
//
// Parameters:			
