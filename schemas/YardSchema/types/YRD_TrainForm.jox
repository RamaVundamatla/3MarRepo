    <JadeMethod name="doEnableForTrain" id="adf514eb-1a41-4de7-940b-db35e68d5b66">
        <source>doEnableForTrain(_enable : Boolean; _train : CM_Train);
// ---------------------------------------------------------------------------
// Created:     21 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//20 Apr 2022  navtnr20	TFS 53142 Cargo Forecast on Voyage &amp; Train
// ---------------------------------------------------------------------------

vars

begin
	self.btnNewTrain.enabled := _enable;
	self.btnEditTrain.enabled := _enable;
	self.btnCopyTrain.enabled := _enable;
	self.btnDeleteTrain.enabled := _enable;
	self.btnMoveToRail.enabled := _enable;
	self.btnConfirmTrainI.enabled := _enable;
	self.btnConfirmTrainO.enabled := _enable;
	self.btnDeparture.enabled := _enable;
	self.btnNewEvent.enabled := _enable;	//29 Oct 2009	NDL Par 21519
	self.btnWarnings.enabled := _enable;	//18 Feb 2010	RJS Par 21951
	self.btnRailOps.enabled := _enable;
	self.btnLoadList.enabled := _enable;
	self.btnOutOrder.enabled := _enable;
	
	self.btnCargoForecast.enabled := true;		//25-Apr-2022	TFS 53142

	// WAGON BUTTONS
	self.btnConfirmIn.enabled := _enable;
	self.btnConfirmOut.enabled := _enable;
	
	if _train &lt;&gt; null and _train.isDeparted then
		self.chkIncDeparted.value := true;
		self.btnDeparture.enabled := false;
		self.btnMoveToRail.enabled := false;
		self.btnConfirmTrainI.enabled := false;
		self.btnConfirmTrainO.enabled := false;
		self.btnOutOrder.enabled := false;
	endif;
	
	if _train &lt;&gt; null then
		if _train.isNullTrain() then
			self.btnNewTrain.enabled := true;
		endif;
		
		// 26/01/2012 cnwar2 #28704
		self.btnRailPlan.enabled := not _train.isDeparted();
	endif;
	

epilog

end;</source>
        <Parameter name="_enable" type="Boolean"/>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="doFrmWagonToolbarContext" id="6c365bcf-e398-40c3-a5d5-1258eb1a9e5c">
        <updating/>
        <source>doFrmWagonToolbarContext(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 October 2009	cnwndl1	Initial creation Par 21325

*/

vars
	x1, 
	y1					: Real;
begin

	x1 := x;
	y1 := y;
	if cntrl &lt;&gt; null then
		if (not mouse) then  // if keyboard, use current listIndex value
		    x1 := 20;
		    if cntrl.top &lt; 0 then
		        y1 := 5;
		    else
		        y1 := cntrl.top;
		    endif;
		endif;
		
		conwin.windowToScreen(x1, y1);
	endif;

	self.mnuShowBar2Caption.checked := self.frmWagonToolbar.showCaptions;
	self.mnuShowBar2Caption.visible := true;
	self.mnuShowBar2Caption.enabled := true;
	
	self.screenToWindow(x1, y1);
	self.popupMenu(self.mnuBar2Context, x1.Integer, y1.Integer);
	
	return false;                  // cancel further processing

end;</source>
        <Parameter name="cntrl" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMenuMoveClick" id="22a4a7ee-f1c8-4df2-8b30-6ec0ac584d1a">
        <updating/>
        <source>doMenuMoveClick(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Aug 2022 navsj20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars

	index : Integer;
	cntrl : Control;
	staLineMoveMode : CMUI_GridAreaStatusLine;

begin

	foreach index in 1 to controlCount do
		cntrl := controls(index);
		if cntrl.isKindOf(CMUI_GridAreaStatusLine) then
			staLineMoveMode :=  cntrl.CMUI_GridAreaStatusLine;
			break;
		endif;
	endforeach;

	if staLineMoveMode &lt;&gt; null then
		staLineMoveMode.doMenuMoveClick(menuItem.index);
	endif;

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuContextBuildTblTrans" id="8d8e01cf-ee2d-4859-86bd-fc1e17f8ca7a">
        <source>doMnuContextBuildTblTrans(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2009	cnwndl1	Initial creation	CCMS 1094

*/

vars
	anObject 	: Object;
	hasObject : Boolean;
begin
	anObject :=  table.accessRow(table.row).itemObject;
	if not app.isValidObject(anObject) then
		return false;
	endif;
	
	self.mnuInTransit.visible := false;
	self.mnuInTransitNO.visible := false;
	self.mnuWagonCargoEnOUT.visible := false;
	self.mnuWagonCargoEnqIN.visible := false;
	self.mnuWagonConfirmIN.visible := false;
	self.mnuWagonConfirmOUT.visible := false;
	self.mnuWagonDamage.visible := false;
	self.mnuWagonDelete.visible := false;
	self.mnuWagonEdit.visible := false;
	self.mnuWagonEnq.visible := false;
	self.mnuWagonNew.visible := false;
	self.mnuWagonTrans.visible := false;
	self.mnuSep1.visible := false;
	self.mnuSep2.visible := false;
	self.mnuSep3.visible := false;
	self.mnuWagonAudits.visible := false;
	
//	self.mnuContext.visible := true;	// PAR 20108
	self.mnuInspectObject.visible := app.isAllowedToInspect;
	self.mnuPrint.visible := true;
	self.mnuRefresh.visible := true;
	self.mnuColumnOrganiser.visible := true; 
	self.mnuSep4.visible := true; 
	
	return true;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuTrainConfirm" id="5db73cd9-5c24-4e19-8c98-6bd1de1e574e">
        <updating/>
        <source>doMnuTrainConfirm(_inward : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		November  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	railLine : CM_RailLine;
	autoPlan : Boolean;
	result	 : Integer;
	tmpStr : String;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	wagMoveController : CMIF_WagonMoveController;
	
begin
	if _inward then
		tmpStr := app.getErrorString(Inward_Rail);
	else
		tmpStr := app.getErrorString(Outward_Rail);
	endif;


	if self.mySelectedTrain = null then	
//		app.msgBox('Please select a train to confirm first','No train selected', MsgBox_Exclamation_Mark_Icon);
		app.msgBox(app.getErrorString(Please_select_train_confirm),app.getErrorString(Train_confirmation), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
//	if app.msgBox('Are you sure that you want to confirm all wagons for train ' &amp; self.myAssistant.displayEntryTrain(self.mySelectedTrain) &amp; ' onto the tracks?', "Train Confirmation", MsgBox_Question_Mark_Icon + MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
	if app.msgBox(app.getErrorString2(Confirm_Train_To_Tracks, self.myAssistant.displayEntryTrain(self.mySelectedTrain), tmpStr),  tmpStr &amp; " " &amp; app.getErrorString(Train_confirmation), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	if _inward then
			result := app.msgBox(app.getErrorString(Want_system_autopla_cargo), app.getErrorString(AutoPlan), MsgBox_Question_Mark_Icon + MsgBox_Yes_No);
		//	result := app.msgBox("Do you want the system to Autoplan the cargo?", "Auto Plan?", MsgBox_Question_Mark_Icon + MsgBox_Yes_No);
			if result = MsgBox_Return_Yes then
				autoPlan := true;
			endif;
	endif;
	
	//26 Feb 2021	NDL	TFS 50837
	create wagMoveController transient;
	wagMoveController.autoSetEffectiveTimeStamp();
	
	app.mousePointer := MousePointer_HourGlass;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateWagonConfirmTrain(wagMoveController, _inward, self.mySelectedTrain, autoPlan, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Train_confirmation), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	delete wagMoveController;
	app.mousePointer := MousePointer_Default;				
end;</source>
        <Parameter name="_inward" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuWagonAudits" id="100b05a7-b8f4-42e2-b9bc-4e4344193634">
        <source>doMnuWagonAudits();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2013	cnwndl1	Initial creation	Par 31687

*/

vars

	obj : Object;
	hasAudits : Boolean;
	wagon : CM_Wagon;

begin

	obj := self.tblWagons.accessedRow.itemObject;
	if obj &lt;&gt; null and CM_Wagon.hasInstance(obj) then
		wagon := obj.CM_Wagon;
		hasAudits := wagon.hasAudits;	//14 Jan 2021	NDL	TFS 50152
	endif;
	
	if not hasAudits then
		return;
	endif;
		
	app.viewAuditForm(wagon, self.myAssistant.class, self.myTerminal);

epilog

end;</source>
