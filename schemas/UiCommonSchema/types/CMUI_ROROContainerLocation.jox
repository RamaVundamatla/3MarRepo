        <controlMethod name="CMUI_HazardsListTable::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstHazard_lostFocus(table: Table input) updating;
/*
Purpose:			
Date		Who		Reason
05 May 2011	cnwab1	Initial creation
*/

vars
	hazs : CM_HazardByCodeDict;
begin
if self.myROROLocnDefn.isTransient() then
	create hazs transient;
	self.lstHazard.allSelectedObjects.copy(hazs);
	
	self.myROROLocnDefn.setProxyHazards(hazs);
