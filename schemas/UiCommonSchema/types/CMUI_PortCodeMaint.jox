    <JadeMethod name="tblCurrent_dblClick" id="acb7b77a-b679-449e-ad9c-c79c4c6ee3a3">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCurrent_dblClick(table: Table input) updating;

// Created by cnwdvb1 on 07 April 2006

vars

begin
	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		return;
	endif;

	if table.row = table.fixedRows then
		table.sortColumn[1] := table.column;
		table.sortType[1] := table.SortType_Alpha;
		table.sortAsc[1] := not table.sortAsc[1];
		self.tblCurrent.resort();
		return;
	endif;
	self.makeInactive();

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
