    <JadeMethod name="isReversed" id="781b1b0c-c3b1-4c0d-a16f-67db87351931">
        <source>isReversed():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2017	jlgndl1	Initial creation	TFS 6759

*/

vars

begin
	// LINX status APPROVED has the same value as INVOICE_PENDING_REVERSE
	if self.getMyInvoiceProcess.isLinxProcess() then
		return self.status = INVOICE_POSTED_REVERSE;
	else
		return self.status = INVOICE_POSTED_REVERSE or  self.status = INVOICE_PENDING_REVERSE; //31.10.2018 cnwma1 TFS #41703
	endif;
epilog

end;</source>
