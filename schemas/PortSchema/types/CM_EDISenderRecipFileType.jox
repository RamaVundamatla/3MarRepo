    <JadeMethod name="setProxy" id="c369a503-8003-4905-9371-b757563f282f">
        <updating/>
        <source>setProxy(_fileDataTime : TimeStamp;
_fileType, _fileVersion, _lastFileName, _recipient, _sender : String;
_processInDateOrder, _processInSeqOrder, _waitForMissingSeq : Boolean;
_seqNumber : String) updating;
//
//18 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
// 15 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
vars

begin
	self.fileDateTime := _fileDataTime;
	self.fileType := _fileType;
	self.fileVersion := _fileVersion;
	self.lastFileName := _lastFileName[1:60];
	self.recipient := _recipient;
	self.sender := _sender;
	self.processInDateOrder := _processInDateOrder; 
	self.processInSeqOrder := _processInSeqOrder;
	self.seqNumber := _seqNumber;
end;
</source>
        <Parameter name="_fileDataTime" type="TimeStamp"/>
        <Parameter name="_fileType" type="String"/>
        <Parameter name="_fileVersion" type="String"/>
        <Parameter name="_lastFileName" type="String"/>
        <Parameter name="_recipient" type="String"/>
        <Parameter name="_sender" type="String"/>
        <Parameter name="_processInDateOrder" type="Boolean"/>
        <Parameter name="_processInSeqOrder" type="Boolean"/>
        <Parameter name="_waitForMissingSeq" type="Boolean"/>
        <Parameter name="_seqNumber" type="String"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="201c9255-0d1f-4313-b79e-0bf5367d5765">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
//
//11 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
vars
	propName	: String;
begin
	propName := _property.name;

	if	propName = CM_EDISenderRecipFileType::fileDateTime.name then
		return false;
	elseif	propName = CM_EDISenderRecipFileType::lastFileName.name then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);
end;
</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
