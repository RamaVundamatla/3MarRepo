    <JadeMethod name="getTransactionCode" id="3e3e0b5a-049d-4e7c-9300-cebb3a5a5f34">
        <source>getTransactionCode() : String;
// 23659 Apr 2010 invoice transaction map extract to use codes instead of descriptions
vars
	str : String;
begin
	if self.contentsType = TI_CONTENTS_STATUS_NULL then
		str := CM_FinancialObject.Extract_Default;
	else
		str := self.contentsName;
	endif;
	return str;
end;
</source>
