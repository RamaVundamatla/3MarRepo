    <JadeMethod name="getMyTIDisplayDefNames" id="4bbf54be-68bc-47f2-af75-b0109ab419a3">
        <source>getMyTIDisplayDefNames(_names: StringArray input);
// ---------------------------------------------------------------------------
// Created:	18 September 2009 By Graeme Black cnwgb1
// Status: 	
// Purpose:	MES 1008 PAR 20320 Return a list of possible EDI TI EntTableDefs 
//			This implementation is sufficient for all subclasses with only 
//			one EDITrackedItem type.
// ---------------------------------------------------------------------------
vars
	tmpClass : Class;
	ediTI : CM_EDITrackedItem;
	types : ClassColl;
begin
//	_names.add(self.getMyTIDisplayDefName());
	create types transient;
	self.getEDITITypes(types);
	foreach tmpClass in types do
		ediTI := tmpClass.firstInstance.CM_EDITrackedItem;
		if ediTI = null then
			create ediTI as tmpClass transient;
			_names.add(ediTI.getMyTIDisplayDefName());
			delete ediTI;
		else
			_names.add(ediTI.getMyTIDisplayDefName());
		endif;
	endforeach;
epilog
	delete types;
end;</source>
        <Parameter name="_names" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="9cd5afe2-0509-4182-857f-fdcdd3f014ca">
        <source>getMyTerminal():CM_Terminal;
// ---------------------------------------------------------------------------
// Created:		27 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// Renamed from getEDITermanal 2/2/2010 - CNWRS2 - to be consistent with other class calls
vars
	term : CM_Terminal;
begin
	
	if self.ediConfig &lt;&gt; null then
		term := self.ediConfig.myTerminal; 
	endif;
	
	if term = null then
		term := app.myPassport.myTerminal;
	endif;

	return term;
		
end;</source>
