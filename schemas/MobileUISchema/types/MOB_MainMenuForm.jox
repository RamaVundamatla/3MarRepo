    <JadeMethod name="moveButtons" id="1b2659d9-c3ce-4d60-85ab-055c97239ad2">
        <source>moveButtons(_buttonArray : CnEcControlArray);

constants
	POSLEFT = 75;
	POSRIGHT = 341;
	POSMID = 235;
	SPACING = 72;//86;
	FIRST_TOP = 22;
	NUMFIT = 5;
	BTN_HEIGHT = 63;//73;
vars
	ctrl 		: Control;
	blnSingle 	: Boolean;
	btnLeft,
	topPos,
	offset,
	count		: Integer;
begin
	blnSingle := _buttonArray.size &lt;= NUMFIT;
//	topPos := (sht_Tasks.height - (NUMFIT * SPACING)).Integer;
	
	foreach ctrl in _buttonArray do 
		count := count + 1;
		if count &gt; NUMFIT then
			offset := (count - NUMFIT);
		else
			offset := count;
		endif;
		offset := offset - 1;
		topPos := FIRST_TOP + (offset * SPACING);
		if blnSingle then
			btnLeft := POSMID;
		elseif count &lt;= NUMFIT then
			btnLeft := POSLEFT;
		else
			btnLeft := POSRIGHT;
		endif;
		ctrl.move(btnLeft, topPos, ctrl.width, ctrl.height);
	endforeach; 
end;
</source>
        <Parameter name="_buttonArray" type="CnEcControlArray"/>
    </JadeMethod>
    <JadeMethod name="setupButtons" id="113a1e1e-eed9-465f-ace4-396e455b79e6">
        <source>setupButtons();
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------
// 23/03/2015	cnwdap1		PAR #35895 CCMS PNL 2461 Added new Pack Booking button
vars
	buttons : CnEcControlArray;
	term : CM_Terminal;
begin
	term := self.myMobileDataAgent.myTerminal;
	create buttons transient;
	checkButtonPermission(btn_Unload, PmMobUnloadTruck, term, buttons);
	checkButtonPermission(btn_Load, PmMobLoadTruck, term, buttons);
	checkButtonPermission(btn_Pack, PmMobPackCargo, term, buttons);
	checkButtonPermission(btn_Voyage, PmMobViewVoyages, term, buttons);
	checkButtonPermission(btn_LocSummary, PmMobLocSummary, term, buttons);
	checkButtonPermission(btn_Move, PmMobMoveCargo, term, buttons);
	checkButtonPermission(btn_Allocate, PmMobMaintainAllocations, term, buttons);
	checkButtonPermission(btn_Location, PmMobMaintainAllocations, term, buttons);
	checkButtonPermission(btn_CargoEnquiry, PmMobCargoEnquiry, term, buttons);
	checkButtonPermission(btn_PackBooking, PmMobPackCargo, term, buttons);				// PAR #35895
	moveButtons(buttons);
epilog
	delete buttons;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="aa2cc1eb-22b1-4363-8b8e-9b045d65d04e">
        <updating/>
        <source>setupForm() updating, protected;
// --------------------------------------------------------------------------------
// Created:		21 April 2008 by cnwdad1
//
// Purpose:		Standard form setup method that is invoked whenever a form is loaded
//				and displayed.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	//self.centreWindow(); cnwgb1 1872 PNL Prototype
	self.backColor := Black;
	self.setupButtons;
	self.pic_Logo.picture := app.myPassport.myTerminal.getConfig(RtPortLogoPic).Binary;
	self.adjustFormForDevice(); //cnwgb1 CCMS PNL 1872 Prototype 14.8.09
	self.tableOptionsDetailsPopulate();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tableOptionsDetailsPopulate" id="9626dc28-44eb-4e06-ab06-06c2cab7f67d">
        <source>tableOptionsDetailsPopulate() protected;
// --------------------------------------------------------------------------------
// Created:		23 April 2008 by cnwdad1
//
// Purpose:		Populate the table on the Options tab with session details.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 04 Mar 2008	cnwkpd1		PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements
// --------------------------------------------------------------------------------
// adm 270509 Par 19483 myTerminal
vars
	tableObj	: Table;//MB_TableNamedCols;
	columnObj	: JadeTableColumn;
	canScroll	: Boolean;
	mediatorObj	: CM_RadioTelemetryMediator;
	deviceObj	: CM_RadioTelemetryDevice;
	machineObj	: CM_Machine;
	queueObj	: CM_RadioTelemetryQueue;
	
begin
	tableObj					:=	tbl_OptionsDtl;
	tableObj.rows				:=	0;
	tableObj.partialTextIndication	:=	true;
	tableObj.gridLines			:= false;

	columnObj					:=	tableObj.accessColumn(1);
	columnObj.widthPercent		:=	40;
	if app.cnwgb1IsUser then
		columnObj.fontSize := tableObj.fontSize;
	endif;
		columnObj					:=	tableObj.accessColumn(2);
	if app.cnwgb1IsUser then
		columnObj.fontSize := tableObj.fontSize;
	endif;
	columnObj.fontBold			:=	true;
	
	if app.cnwgb1IsUser then
		tableObj.defaultRowHeight	:=	6;
	else
		tableObj.defaultRowHeight	:=	30;
	endif;
	
	mediatorObj	:=	self.myMobileDataAgent.myMediator;
	
	tableObj.readOnly			:= true;
	tableObj.addItem(app.getErrorString(CM_User_ID) &amp; Tab &amp; app.getMyUser().userName);
	
	if app.myMobileGUIAgent.strDevice &lt;&gt; null then
		tableObj.addItem(app.getErrorString(Device) &amp; Tab &amp; app.myMobileGUIAgent.strDevice);
	endif;
	
	tableObj.addItem(app.getErrorString(Terminal) &amp; Tab &amp; self.myTerminal().code);
	
	canScroll			:=	tableObj.mbCanScroll();
	btn_Up.visible		:=	canScroll;
	btn_Down.visible	:=	canScroll;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="386283cd-0717-42e4-8bdd-46409fc59b06">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 07 April 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017611, locale);
	btn_Allocate.translateCaption(Xlat_0013171, locale);
	btn_CargoEnquiry.translateCaption(Xlat_0013172, locale);
	btn_ChangePass.translateCaption(Xlat_0013173, locale);
	btn_Load.translateCaption(Xlat_0013174, locale);
	btn_LocSummary.translateCaption(Xlat_0013175, locale);
	btn_Location.translateCaption(Xlat_0013176, locale);
	btn_LogOff.translateCaption(Xlat_0013177, locale);
	btn_LogOffExit.translateCaption(Xlat_0013178, locale);
	btn_Move.translateCaption(Xlat_0013179, locale);
	btn_Pack.translateCaption(Xlat_0013180, locale);
	btn_PackBooking.translateCaption(Xlat_0020348, locale);
	btn_Preferences.translateCaption(Xlat_0013181, locale);
	btn_Unload.translateCaption(Xlat_0013182, locale);
	btn_Voyage.translateCaption(Xlat_0013183, locale);
	sht_Options.translateCaption(Xlat_0013184, locale);
	sht_Tasks.translateCaption(Xlat_0013185, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
