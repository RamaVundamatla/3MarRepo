end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="asFeetInchesForMask" id="036fd348-9632-420a-9e22-79eaf5b77448">
        <source>asFeetInchesForMask() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	newString : String;
	pos, pad : Integer;
	decimalSep : String;

begin
	// feet and inches mask is 4 characters for feet and two for inches
	// The mask must be padded to fill the 4 characters for inches, and cannot have a decimal
	newString := self;
	decimalSep := app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;
	pos := newString.pos(decimalSep, 1);
	if pos &lt;&gt; null then
		pad := 4 - pos + 1;
	else
		pad := 4 - newString.length;
	endif;
	newString := newString.removeString(decimalSep.Character);
	newString := newString.padLeftBlanks(pad + newString.length);
	return newString;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asHex" id="988055e1-ef27-4003-81f0-3fecdc54b4c2">
        <source>asHex(): String;

vars
	i:       Integer;
	hexstr:  String;
begin
	foreach i in 1 to self.length do
		hexstr[(2 * i) - 1:2] := self[i].Character.toHex;
	endforeach;

	return hexstr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asInteger64JMT" id="6fd0844e-3413-40ea-ab72-cdc2111fe3b5">
