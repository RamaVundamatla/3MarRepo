    <JadeMethod name="isSameStopsTypeSelected" id="81d7606f-a98e-4f63-9cf4-c6165c0b3e03">
        <source>isSameStopsTypeSelected():Boolean protected;
// ---------------------------------------------------------------------------
// Created:     13 September 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll			:ObjectArray;
	obj				:Object;
	type			:Integer;
	gotException	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, obj, gotException);
	
	coll := self.tblData.allSelectedObjects;
	
	foreach obj in coll do
		// get the type for the first edi data in the collection
		if type = null then
			type := obj.CM_EDIData.getEDIDataType;
			// type must be either a customs or an operator stop
			if type &lt;&gt; EDIDataType_CustomStop and
				type &lt;&gt; EDIDataType_OperatorStop then
				return false;
			endif;
		endif;
		// is this edi data the same as all the others in the collection?
		if obj.CM_EDIData.getEDIDataType &lt;&gt; type then
			return false;
		endif;
	endforeach;
		
	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSelectionOKForLoadToDB" id="bcea8137-b55c-4276-8c05-ac38cad4b007">
        <source>isSelectionOKForLoadToDB(_coll :CM_EDIDataByDateStatusDict):Boolean protected;
// ---------------------------------------------------------------------------
// Created:     25 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ediData			:CM_EDIData;
	count			:Integer;
	bayplan, 
	gotException	:Boolean;
begin
	if _coll.size = 1 then
		return true;
	endif;
	
	on Exception do app.handleDeletedObject (exception, ediData, gotException);
	
	foreach ediData in _coll do
		if ediData.isKindOf(CM_EDIDataBayPlan) then
			// cannot re-load multiple bay-plans
			bayplan := true;
			break;
		endif;
		
		if ediData.CM_EDIData.status = CM_EDIFile.EDI_STATUS_DBLOADED and
			ediData.canReDBLoad then
			count := count + 1;
		endif;
		// if we get an exception we will reumse here.
	endforeach;
	
	if bayplan then
		app.msgBox (app.getErrorString (BayPlan_Load_Single), self.mnuLoadToDB.caption,MsgBox_OK_Only);
		return false;
	endif;

	if count &gt; 0 then
		// the selection contains at least one file that has already been loaded to DB
		if app.msgBox(app.getErrorString1(Confirm_ReloadDB, count.String), self.mnuLoadToDB.caption, 
				MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
			return false;	// they did not confirm re-load
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="CM_EDIDataByDateStatusDict"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
