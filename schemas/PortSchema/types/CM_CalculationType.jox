    <JadeMethod name="isUseCargoWeight" id="114e8bce-da51-4ad0-b5e8-62e09949c6b5">
        <source>isUseCargoWeight() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type

*/

vars

begin
	return 	self.calculationType = INV_CALC_TYPE_CARGOWEIGHTCONVT and 
