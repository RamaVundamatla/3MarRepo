<Class name="CM_QStrAcidsBasesMethod" id="26de3246-677a-4338-9bad-a23e571a0d54">
    <superclass name="CM_QStringLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="3f5612b9-a1dc-41ca-8152-deb174b5db66">
        <updating/>
        <source>create() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 21/11/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then
		return;
	endif;
	
	create oper as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(oper);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getWebDataRowName" id="01c2739f-5090-4862-b98d-8419e140c7bd">
        <source>getWebDataRowName(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars

begin
	return ETRow_AcidsBases;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="df5913b1-efba-4512-840d-50f13d807421">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 21 November 2016	cnwdap1		Initial creation PAR #
//
vars
	selectStr : String;

begin
	_combo.clear;
	_combo.addItem(null);
	_combo.addItem(CM_TIHazard.ACID);
	_combo.addItem(CM_TIHazard.BASE);

	if CM_QStringLookup.hasInstance(_queryOperator) then
		selectStr := _queryOperator.CM_QStringLookup.selectionValue;
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		selectStr := _queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;
	
	_combo.text := selectStr;
epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="a994bf56-b12b-4891-81e0-e17bd541ebb4">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 21/11/2016	cnwdap1		Initial creation TFS 2844 Hazardous Details Enhancements
//
vars
	idx, selectionValue : Integer;

begin
	_tbl.rows := _tbl.fixedRows;
	
	if _params = null then
		return;
	endif;
	selectionValue := 0;
	if _operator &lt;&gt; null and _operator.CM_QStringIsOneOf.allSelectionValues.includes(CM_TIHazard.ACID) then
		selectionValue := 1;
	endif;
	idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; CM_TIHazard.ACID);
	_tbl.row := idx;
	_tbl.change(_tbl);
	selectionValue := 0;
	if _operator &lt;&gt; null and _operator.CM_QStringIsOneOf.allSelectionValues.includes(CM_TIHazard.BASE) then
		selectionValue := 1;
	endif;
	idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; CM_TIHazard.BASE);
	_tbl.row := idx;
	_tbl.change(_tbl);
epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="b3084a12-cdcb-45b0-b2c3-ad2423aeb32b">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 21/11/2016	cnwdap1		Initial creation TFS 2844 Hazardous Details Enhancements
//
vars
	str	: String;
	numRows, idx : Integer;
	codeArray : StringArray;
	code : String;
	
begin

	create codeArray transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			code := _tbl.accessCell(idx, 2).text;
			codeArray.add(code);
		endif;
	endforeach;
	
	_op.setSearchValue(codeArray);
	
epilog
	delete codeArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="e6310b02-30dc-4365-9072-2d5da4a70ce0">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web POrtal selector query parameters
//
vars
	str, returnVal : String;
	strArray : StringArray;

begin
	if _value.isKindOf(StringArray) then
		foreach str in _value.StringArray do
			returnVal := returnVal &amp; str &amp; CNEC_COMMA&amp; Space;
		endforeach;
		returnVal := returnVal[1:returnVal.length-2];
		return returnVal;
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			str := _value.String;
			create strArray transient;
			str.getTokensForDelimiter("|", strArray);
			return strArray;
		endif;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
