    <JadeMethod name="loadComboSeaRegion" id="bbd898bf-6a02-4884-a87c-da8290309205">
        <source>loadComboSeaRegion() protected;
// --------------------------------------------------------------------------------
// Created:		19 October 2006 by cnwdad1
//
// Purpose:		Populates the default "Sea" Harbour Region combobox control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	comboboxObj	: ComboBox;
	regionObj	: HMS_HarbourRegion;
	passportObj	: CM_Passport;
	listPointer	: Integer;
	failedDAC  :CM_DataAccessController;
	
begin
	passportObj	:=	app.myPassport;
	comboboxObj	:=	cmbSeaRegion;
	comboboxObj.automaticCellControl	:=	true;
	
	foreach regionObj in app.myRoot.allHMSHarbourRegions do
		if not regionObj.canUserAccessSelf(null, failedDAC, passportObj) then
			continue;
		endif;
		
		listPointer	:=	comboboxObj.addItem(regionObj.getDisplayString());
		comboboxObj.itemObject[listPointer]	:=	regionObj;
	endforeach;
	
	comboboxObj.cnEcSetObjectIndex(app.myRoot.getConfig(MySeaHarbourRegion).HMS_HarbourRegion);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadComboSsoProvider" id="dc7da03e-cfc2-4307-90ce-85b4066d9d6c">
        <source>loadComboSsoProvider() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 July 2022 navam1 ChangeRequest 52824: EUP - Azure Active Directory Single Sign On - MTN
25 Aug  2025 navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client

*/

vars
	idx	: Integer;
begin
	idx := self.cmbSSOProvider.addItem(app.mySSOAgent.SSO_Provider_DefaultDescr);
	self.cmbSSOProvider.itemData[idx] := app.mySSOAgent.SSO_Provider_Default;
	idx := self.cmbSSOProvider.addItem(app.mySSOAgent.SSO_Provider_MicrosoftDescr);
	self.cmbSSOProvider.itemData[idx] := app.mySSOAgent.SSO_Provider_Microsoft;
	idx := self.cmbSSOProvider.addItem(app.mySSOAgent.SSO_Provider_OktaDescr);  // MTN-35151 - navec1 - Okta SSO
	self.cmbSSOProvider.itemData[idx] := app.mySSOAgent.SSO_Provider_Okta;
		
	self.cmbSSOProvider.listIndex := 1;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadComboToDoTasks" id="8dea37fd-236e-487c-984b-dd6ded235c73">
        <source>loadComboToDoTasks();
// ---------------------------------------------------------------------------
// Created:		December 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lTask			: CM_ToDoTaskDesc;
	idx, 
	selectedItem	: Integer;
	toDoTaskRepair  : String;
begin

	selectedItem := 0;
	toDoTaskRepair := self.myTerminal.getConfig(ToDoTaskRepair).String;
	foreach lTask in app.myRoot.allToDoTaskDescriptions 
		where lTask.type = TODO_TYPE_GROUP_TI do							 // ### TFS  #56634[54259] 22NOV2022 NAVAB1

		idx := self.cmbToDoTasks.addItem(lTask.description);
		self.cmbToDoTasks.itemObject[idx] := lTask;
	endforeach;

	foreach idx in 1 to cmbToDoTasks.listCount do
		if toDoTaskRepair = cmbToDoTasks.itemText[idx] then
			self.cmbToDoTasks.listIndex := idx;
		    break;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadComboVessels" id="71764861-c7e9-47af-b946-e3ef5e0b2472">
        <source>loadComboVessels() protected;
// --------------------------------------------------------------------------------
// Created:		10 October 2006 by cnwdad1
//
// Purpose:		Populates the default "TBN" Vessel combobox control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	comboboxObj	: ComboBox;
	vesselObj	: CM_Vessel;
	passportObj	: CM_Passport;
	listPointer	: Integer;
	failedDAC  :CM_DataAccessController;
	
begin
	passportObj	:=	app.myPassport;
	comboboxObj	:=	cmbTBNVessel;
	comboboxObj.automaticCellControl	:=	true;
	
	foreach vesselObj in app.myRoot.allVessels do
		if not vesselObj.canUserAccessSelf(null, failedDAC, passportObj) then
			continue;
		endif;
		
		listPointer	:=	comboboxObj.addItem(vesselObj.getDisplayDetails(false));
		comboboxObj.itemObject[listPointer]	:=	vesselObj;
	endforeach;
	
	comboboxObj.cnEcSetObjectIndex(app.myRoot.getConfig(MyTBNVessel).CM_Vessel);
end;</source>
        <access>protected</access>
    </JadeMethod>
