    <JadeMethod name="createGeneratorFromTiMaster" id="1eb4be7c-5102-491b-aba3-04344ccd593c">
        <source>createGeneratorFromTiMaster();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
21/08/2018 	jlgns1	Bug 39807: PEN - Clip On Unit disappears from a container when a chassis is received at the same time
*/

vars
	pxyAttachedGen      : CMGTE_Receival;
	attachedGenCont     : CMIF_FlexiGateController;
	genMaster ,tiMaster: CM_TIMaster;
	toDoTaskDesc : CM_ToDoTaskDesc;
	genGte,foundGte : CMGTE_Entity;
	stop : CM_StopsTable;
begin
	
	if self.myCurrentVehicleVisit&lt;&gt; null then
		// Dont want to do this because the chassis generatir has already been setup by now
		//if self.myCurrentVehicleVisit.myInCMGTE_Chassis &lt;&gt; null then																								//Bug 39807
		//	tiMaster := app.myRoot.findTIMasterByCargoType(self.myCurrentVehicleVisit.myInCMGTE_Chassis.cargoType, self.myCurrentVehicleVisit.myInCMGTE_Chassis.id);//Bug 39807
		//elseif																																					//Bug 39807
		if self.myPxyGTEEntity &lt;&gt; null	 then
			if	self.myPxyGTEEntity.isKindOf(CMGTE_Receival) then
				tiMaster := app.myRoot.findTIMasterByCargoType(self.myPxyGTEEntity.CMGTE_Receival.cargoType, self.myPxyGTEEntity.id);
			endif;
		endif;
		
		if tiMaster = null then
			return;
		endif;
		
		if tiMaster  &lt;&gt; null and tiMaster.allTIMasterAttachees.isNotEmpty then
			genMaster :=tiMaster.allTIMasterAttachees.first.CM_TIMaster;
			if genMaster = null then
				return;
			endif;
		endif;
		
	endif;
	
	if genMaster &lt;&gt; null then
		if self.myPxyGTEEntity.allChildren.isNotEmpty then
			foreach genGte in self.myPxyGTEEntity.allChildren do
				 if genGte.id = genMaster.id  and genGte.CMGTE_Receival.cargoType = genMaster.cargoType then
					foundGte := genGte;
					break;
				endif;
			endforeach;	
			delete foundGte;
		endif;
		create pxyAttachedGen as CMGTE_Generator transient;
		create attachedGenCont transient;	
		
		attachedGenCont.id := genMaster.id;
		attachedGenCont.description := genMaster.description;
		attachedGenCont.cargoType := genMaster.cargoType;
		attachedGenCont.operatorCode := genMaster.myOperatorNew.code;
		attachedGenCont.myTerminal := self.myTerminal;
		attachedGenCont.myGeneratorType := genMaster.CM_TIMasterGenerator.myGeneratorType;		
		attachedGenCont.isoTypeCode := genMaster.getISOTypeString;
		attachedGenCont.weightTotal := genMaster.tWeight;
		attachedGenCont.weightTare := genMaster.tWeight;
		attachedGenCont.myVehicle := self.myCurrentVehicleVisit.vehicle;
		attachedGenCont.myCarrier := self.myCurrentVehicleVisit.getMyCarrier;
		attachedGenCont.myVehicleVisitRecord := self.myCurrentVehicleVisit;
	
	foreach toDoTaskDesc  in genMaster.allToDoTaskDesc do
			attachedGenCont.allToDoTasks.add(toDoTaskDesc);
		endforeach;
		
		pxyAttachedGen.setPxyToDoTasks(attachedGenCont.allToDoTasks);
		foreach stop in genMaster.allStopsNew do
			attachedGenCont.allStops.add(stop.id);
		endforeach;
		
		pxyAttachedGen.allStops.clear();
		attachedGenCont.allStops.copy(pxyAttachedGen.allStops);
		
		//if self.myCurrentVehicleVisit.myInCMGTE_Chassis &lt;&gt; null then	//Bug 39807
		//elseif														//Bug 39807
		if  self.myPxyGTEEntity &lt;&gt; null then							//Bug 39807
			attachedGenCont.voyageCode := self.myPxyGTEEntity.voyageCode;
			attachedGenCont.imexStatus := self.myPxyGTEEntity.CMGTE_Receival.imexStatus;
		
			pxyAttachedGen.setPXYFromController(attachedGenCont);
			
			pxyAttachedGen.setParentObject(myPxyGTEEntity);	
		endif;
	endif;
epilog
	
	delete attachedGenCont;
end;</source>
    </JadeMethod>
    <JadeMethod name="createNewProxy" id="9b9d7e9c-b551-4a16-aca7-e35476fd58ac">
        <updating/>
        <source>createNewProxy() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Nov 2019	jlgsl4	TFS 47373 - PEN - Save-Next prevents use of Remarks Additional
*/

vars
	cargoType : CM_CargoType;
begin
	cargoType := self.cmbType.getObject.CM_CargoType;
	if self.myProxyTrackedItem = null and cargoType &lt;&gt; null then
		create self.myProxyTrackedItem as cargoType.myClassToCreate transient;
	endif;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="decideEntDefType" id="7532d62e-2c5b-4277-a5fe-0bb2a678cf7d">
        <updating/>
        <source>decideEntDefType(_forceRebuild : Boolean) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/07/2009	cnwdap1	Initial creation
12/10/2009	cnwdap1	PAR #20814 New Ent Def for Rail cargo to allow entry of temperature for reefers
22/10/2009	cnwdap1	PAR #20814 Resubmit - ensure we actually have an isoType
01/12/2009	cnwdap1	CCNS 1007 Allow for general cargo reefer properties if the subproduct allows it
15/02/2010	cnwdap1	PAR #22088 Open Dimensions section for system cargo type Timber
17/02/2010	cnwdap1	PAR #22278 Decision to display/hide reefer fields depends on commodity selected, not ISO type
16/03/2001	cnwdap1	PAR #22600 lost focus on commodity combo was changing general cargo ent def to container ent def if no cargo type selected
01/07/2014	cnwdap1	PAR #34483 Show BOL instead of booking for On Ship Attachment form
*/
vars
	cargoType		: CM_CargoType;
	isoType			: CM_ISOType;
	subCargo		: CM_Product;
	commodity		: CM_Commodity;
	entDef			: String;

begin
	cargoType 	:= cmbType.getObject.CM_CargoType;
	isoType		:= cmbISOType.getObject.CM_ISOType;
	subCargo	:= cmbSubCargo.getObject.CM_Product;	// CCMS 1007
	commodity	:= cmbCommodity.getObject.CM_Commodity;
	
	// 30047 save existing seal values first
	self.saveSealControlValues();

	if cargoType &lt;&gt; null and not cargoType.id = TI_CargoType_Container then
		if self.isAttachmentForm() then
			if self.isOnshipForm then										// PAR #34483
				entDef := ETDef_AttachmentBOLGeneral;						// PAR #34483
			else															// PAR #34483
				entDef := ETDef_AttachmentGeneral;
			endif;															// PAR #34483
		else
			//if subCargo &lt;&gt; null and subCargo.isReefer then	// CCMS 1007	// PAR #22278
			if commodity &lt;&gt; null and commodity.hasTemp then	// PAR #22278
				entDef := ETDef_GeneralCargoReefer;			// CCMS 1007
			else											// CCMS 1007
				entDef := ETDef_GeneralCargo;
				self.doClearCarridgeTemp();  				//cnwrd1 par 22770 11/3/2010
			endif;
		endif;
	else
		if self.isAttachmentForm() then
			if self.isOnshipForm then								// PAR #34483
				entDef := ETDef_AttachmentBOLDetails;				// PAR #34483
			else													// PAR #34483
				entDef := ETDef_AttachmentDetails;
			endif;													// PAR #34483
		elseif commodity &lt;&gt; null then
			if commodity.isEmpty then
				entDef := ETDef_ContainerEmpty;
			elseif commodity.hasTemp then				// PAR #22278
				entDef := ETDef_ContainerFullReefer;	// PAR #22278
			else
				entDef := ETDef_ContainerFull;
				self.doClearCarridgeTemp(); 			//cnwrd1 par 22770 11/3/2010
			endif;
		else
			//entDef := ETDef_NewItem;
			if self.isGeneralCargo or self.isMakeLCLForm then					// PAR #22600
				entDef := ETDef_GeneralCargo;			// PAR #22600
			elseif self.isEmptyContainer() then			//cnwmc5 - 12 March 2015 - PAR 35839
				entDef := ETDef_ContainerEmpty;			//cnwmc5 - 12 March 2015 - PAR 35839
			else										// PAR #22600
				entDef := ETDef_ContainerFull;
			endif;										// PAR #22600
		endif;
	
	endif;
	
	if self.isRailPreNoteForm then
		if cargoType &lt;&gt; null and cargoType.id = TI_CargoType_Container then
			//if isoType &lt;&gt; null and isoType.isReefer then	// PAR #20814	// PAR #22278
			if commodity &lt;&gt; null and commodity.hasTemp then	// PAR #22278
				entDef := ETDef_RailPreNoteReefer;			// PAR #20814
			else											// PAR #20814
				entDef := ETDef_RailPreNote;
			endif;
		else
			entDef := ETDef_RailPreNoteCargo;
		endif;
	endif;
	
	// sometimes we want to force a rebuild of the form, even if the ent def hasn't changed
	// for instance on change of cargo type if we need to display previously-hidden sub cargo or commodity controls
	if entDef &lt;&gt; self.currentEntTableDef or _forceRebuild then
		// flexi gate form can only change between full and reefer, never to new item or empty to full
		if self.isFlexiGateForm and entDef = ETDef_NewItem then
		// rail cargo form can change between system cargo types and non-system cargo types
		// prenote form can change from/to new item, enmpty, full, reefer, general cargo
		else
			self.initFieldsForEntDefName(entDef, false);
			
			if entDef = ETDef_ContainerFullReefer or entDef = ETDef_GeneralCargoReefer then	// CCMS 1007
				self.doSetTemperatureLabels();
			endif;
			//20/2/18 epr tfs 7756 all this is done in doFilterAttributes 
			
			
		endif;
	endif;
	
	// show appropriate picture
	self.doShowPicture;
	self.doSetCaption;

	// 30047 restore seal control values
	self.restoreSealControlValues();

	if not app.getMyUser.canDo(self.myTerminal, PmAdmOpExpReleaseNumEdit) then //cnwrd1 par 29485 30.4.2012
		self.txtOpExRelNbr.visible := false;
	endif;
	
	
	
epilog
	
end;</source>
        <Parameter name="_forceRebuild" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteAttachment" id="559de3bc-ac97-48b8-9190-081ab1214a95">
        <updating/>
        <source>deleteAttachment(_attachment : Object) updating;
/*
Date		Who		Reason
14 Sep 2009	cnwdap1	Initial creation
24 Jun 2013	cnwcs5	par 31758
*/
vars
	coll	:ObjectArray;
	combo	:CMUI_ComboBox;
begin
	coll := self.allAttachments;
	
	if coll.includes(_attachment) then
		coll.remove(_attachment);
	endif;
	
	combo := self.cmbAttachments;
	
	combo.removeObject(_attachment);
	
	if combo.listCount &gt; 0 then
		combo.listIndex := 1;
	endif;
epilog

end;</source>
        <Parameter name="_attachment" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doAlignControlsInGenericFrames" id="0cfa3049-47ac-48a5-9905-b0faa5f4b399">
        <updating/>
        <source>doAlignControlsInGenericFrames() updating, protected;

/* Changes

Date		Name	TFS#		Description
============================================================================
19/12/2022	jlika1	TFS 55584  	HS Code Combobox Usage
============================================================================*/
vars

begin
	inheritMethod();
	// keep cargo id button beside the cargo id field now that the form has been re-drawn
	self.btnCargoId.top := self.txtCargoID.top;
	self.btnCargoId.left := self.txtCargoID.left + self.txtCargoID.width + 5;	// ** review the '5'
	
	if self.cmbHSCode.visible then
		self.btnHSCode.top := self.cmbHSCode.top;
		self.btnHSCode.left := self.cmbHSCode.left + self.cmbHSCode.width + 5;	// ** review the '5'
	else
		self.btnHSCode.visible:=false;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
