	elseif self.fldMain.topSheet = self.shtYA then
		self.tblYA.allSelectedObjects.copy(objArray);
	else
		return;
	endif;
	
	
	if objArray.isEmpty then
		global.beep;
		app.msgBox("Please select some cargo to enquire on","Enquiry",MsgBox_Exclamation_Mark_Icon);
	else
		ti := objArray.first.CM_TrackedItem;
		self.myAssistant.showCargoEnquiryForTIs(ti, objArray, self.myMasterMenuAction, false);
	endif;
epilog
	delete objArray;
end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="d5ec2ea4-f046-4563-80cc-b32603f09a99">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		if anObject.isKindOf(CM_TrackedItem) then
			endNotification(anObject, Object_Update_Event);
			endNotification(anObject, Object_Delete_Event);
			removedNotification := removedNotification + 1;
		endif;
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="98fd5868-a5f1-4158-b754-5b4e45990119">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:		10 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.fldMain.topSheet = self.shtHaz then
		self.doPrintOutTable(self.tblHaz,self.caption, true,true, false, false);
	elseif self.fldMain.topSheet = self.shtYA then
		self.doPrintOutTable(self.tblYA,self.caption, true,true, false, false);
	elseif self.fldMain.topSheet = self.shtSpace then
		self.doPrintOutTable(self.tblData,self.caption, true,true, false, true);
	elseif self.fldMain.topSheet = self.shtSpaceDtl then	//24 July 2014	NDL	Par 34335
		self.doPrintOutTable(self.tblSpaceDtl,self.caption, true,true, false, true);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="0ec1d962-ab09-42bb-b2ff-bf9bc07137cf">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		10 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//26 Feb 2015  cnwma1 PAR # 33352 Space Utilisation functionality for Block Stacks
// ---------------------------------------------------------------------------
begin
	if self.chkSpace.value 
	and self.lstTermArea.allSelectedObjects.isEmpty() then
		app.msgBox("You must select some terminal areas to perform the Space Utilisation query on.", "Query Problem", MsgBox_Exclamation_Mark_Icon);
		self.fldQuery.topSheet := shtQuery1;
		return;
	endif;

	app.mousePointer := Window.MousePointer_HourGlass;
	
	self.createMonitor();
	
	// ### DO QUERY
	self.setQueryAgent();
	self.myQueryAgent.doQuery();
	self.cmbKPITA.listIndex := -1;

	// ### YARD ALLOCATIONS
	self.displayYATable();
	self.btnHazSet.enabled := false;
	if self.isHazardousLicensed then
		// ### HAZARDOUS SEGREGATION
		self.displayHazTable();
	endif;
	
	// Reset table heading based on search result;
	self.initTableData(null); //05/09/2025	navkc1 JIRA 35623
	self.initTblSpaceDtl(null); //05/09/2025	navkc1 JIRA 35623
	
	// ### SPACE UTILISATION
	self.displaySpaceTable();
	
	// ### HIDE QUERY FRAME?
/*	if self.chkYalloc.value then											// - 26/02/2015  cnwma1 PAR #33352				
		self.fldMain.topSheet := self.shtYA;
		self.frmQuery.visible := (self.tblYA.rows = self.tblYA.fixedRows);
	elseif self.chkHaz.value and self.isHazardousLicensed then
		self.fldMain.topSheet := self.shtHaz;
		self.frmQuery.visible := (self.tblHaz.rows = self.tblHaz.fixedRows);
	else
		self.fldMain.topSheet := self.shtSpace;
		self.frmQuery.visible := (self.tblData.rows = self.tblData.fixedRows);
	endif;*/
	
	self.fldMain.topSheet := self.shtSpace;									//26/02/2015  cnwma1 PAR #33352
	self.frmQuery.visible := (self.tblData.rows = self.tblData.fixedRows);  //26/02/2015  cnwma1 PAR #33352
	app.mousePointer := Window.MousePointer_Default;
	
epilog
	self.deleteMonitor();
end;</source>
    </JadeMethod>
    <JadeMethod name="doResetSearch" id="7e3cdddd-4ec9-49bb-8cc7-f5c7787662fc">
        <source>doResetSearch();
// ---------------------------------------------------------------------------
// Created:		09 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aCargoType : CM_CargoType;
	idx : Integer;
	object			: Object;
	anArray : ObjectArray;
	today : Date;
begin
	today := self.systemToLocalTime(app.actualTimeServer()).Date;	// 23/5/16 cnwmp6 TFS 488 - Multi timezone support

	aCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	create anArray transient;
	anArray.add(aCargoType);
	self.lstCargoTypes.setSelected(anArray);

	if self.isHazardousLicensed then
		self.chkHaz.value := true;
	else
		self.chkHaz.value := false;
	endif;
	self.chkSpace.value := true;
	self.chkYalloc.value := true;
	
	self.chkContents.value := true;
	self.lstContents.setAllToTrue();

	self.chkISO.value := true;
	self.lstISO.setAllToTrue();

	self.chkImex.value := true;
	self.lstImEx.setAllToTrue();
	self.lstOperators.setAllToTrue();
	self.lstPorts.setAllToTrue();
	self.lstVoyages.setAllToTrue();
	self.lstTermArea.setAllToFalse();

	self.cmbKPITA.listIndex := -1;
	
	self.dteFrom.setDate(today);
	self.dteTo.setDate(today);
	
	//self.cmbTA.listIndex := -1;
epilog
	delete anArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="b89e549d-fde2-4057-b60e-d9cb722c2b2d">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		10 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpH : Integer;
begin
	tmpH := self.clientHeight - self.frmToolbar.clientHeight-10;
	self.fldMain.width := self.clientWidth;
	self.fldMain.height := tmpH;
	self.topMargin := 0;
	
	inheritMethod();

	self.fldMain.top := self.frmToolbar.clientHeight+2;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectAll" id="b8ce9db4-63aa-42a8-a39b-6c7965995c85">
        <source>doSelectAll();
// ---------------------------------------------------------------------------
// Created:		09 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	topSht : CMUI_Sheet;
begin
	inheritMethod();

	topSht := self.fldQuery.topSheet.CMUI_Sheet;
	
	if topSht = self.shtQuery1 then
		self.doSelectAllTable(self.lstTermArea);
	elseif topSht = self.shtQuery2 then
		self.doSelectAllTable(self.lstCargoTypes);
	elseif topSht = self.shtQuery3 then
		self.doSelectAllTable(self.lstOperators);
	elseif topSht = self.shtQuery4 then
		self.doSelectAllTable(self.lstPorts);
	elseif topSht = self.shtQuery5 then
		self.chkYalloc.value := not self.chkYalloc.value;
		if self.isHazardousLicensed then
			self.chkHaz.value :=  self.chkYalloc.value;
		endif;
		self.chkSpace.value :=  self.chkYalloc.value;
	elseif topSht = self.shtQuery6 then
		self.doSelectAllTable(self.lstISO);
	elseif topSht = self.shtQuery7 then
		self.doSelectAllTable(self.lstVoyages);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowKPI" id="d0c41785-59c3-46d4-93cb-8bca804dc53d">
        <source>doShowKPI();
// ---------------------------------------------------------------------------
// Created:		14 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpKPI : CM_KPI;
	table : CM_DataTable;
	line : String;
	idx : Integer;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	self.myQueryAgent.init();
	
	tmpKPI := self.cmbKPITA.listObject.CM_KPI;
	if tmpKPI = null then
		app.msgBox("Nothing to show","Query Issue",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.initTableData(null); //08/09/2025	navkc1 JIRA 35623
	self.initTblSpaceDtl(null); //08/09/2025	navkc1 JIRA 35623
	
	self.tblSpaceDtl.rows := self.tblSpaceDtl.fixedRows;
	self.displaySpaceTableDetail(tmpKPI.CM_KPITerminalArea, Red,true);

	line := tmpKPI.CM_KPITerminalArea.getDisplayLine();
	
	self.tblData.rows := self.tblData.fixedRows;
	idx := self.tblData.addItem(line.trimBlanks);
	self.tblData.accessRow(idx).itemObject := tmpKPI;
	self.frmQuery.visible := false;
	self.fldMain.topSheet := self.shtSpace;
	
	//epr par 33732 15/9/14
	self.tblYA.rows := self.tblYA.fixedRows;
	self.tblYAInfo.rows := 0;
	
	self.tblHaz.rows := self.tblHaz.fixedRows;
	self.tblHazInfo.rows := 0;
	
	
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTblContextMenu" id="bc133caa-63ae-41d3-87ac-c46d8aa0c9ac">
        <updating/>
        <source>doTblContextMenu(_colSort : Boolean; cntrl : Table input; conwin : Window input; mouse : Boolean; x : Integer; y : Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     23 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 28/01/13		cnwer1		PAR 30823 removed reference to old yard allocaton enquiry form
vars
	xLeft 			: Real;
	yTop			: Real;
	anObject		: Object;
	isYA, isHAZ 	: Boolean;
	tmpUser			: CM_User;
	canYAM		: Boolean;
	cloneCount		: Integer;
	clonedItem		: MenuItem;
	tiId			: String;
	
begin

	xLeft := x;
	yTop := y;
	isYA := (cntrl.name = "tblYA");
	isHAZ := (cntrl.name = "tblHaz");
	
	self.mnuColumnOrganiser.visible := _colSort;
	//self.mnuYardAllocEnq.visible := isYA;
	
	//par 19099 cnwjo3
	tmpUser := app.getMyUser();
	canYAM := tmpUser.canDo(self.myTerminal, PmYAManager);
	if canYAM then
		self.mnuYAM.visible := isYA;
	endif;
	
	
	self.mnuContextTIEnquire.visible:= isYA or isHAZ;
	self.mnuContextTIEdit.visible 	:= isYA or isHAZ;
	self.mnuContextHide.visible 	:= isYA or isHAZ;
	
	anObject := cntrl.CM_DataTable.accessRow(cntrl.row).itemObject;
	self.mnuContextTIEnquire.userObject := anObject;

	//Auto Plan and Test AutoPlan menus introduced. #25719 27/10/2010
	if isYA or isHAZ then
		self.mnuAutoPlanTest.visible	:= isYA or isHAZ;	
		self.mnuAutoPlan.visible		:= isYA or isHAZ;
		//epr par 36069 6/5/15
		if cntrl.CM_DataTable.allSelectedObjects.size = 1 then
			tiId := anObject.CM_TrackedItem.id;
			self.mnuAutoPlan.caption:=app.getErrorString1(Auto_queue, tiId);
		else
			tiId := app.getErrorString(Selected_ITEMSSS);
			self.mnuAutoPlan.caption := app.getErrorString(Auto_queue_selected_item);
		endif;
		self.mnuAutoPlanTest.caption	:= app.getErrorString(YRDTestAutoPlan) &amp; tiId &amp; "...";
	endif;
	
	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	self.mnuSummarise.visible	:= false;	// default this menu level to invisible, makes sub-menu invisible.
	
	if app.isAllowedToInspect then
		self.mnuInspectObject.visible := true;
	else
		self.mnuInspectObject.visible := false;	
	endif;	
	
	if self.mnuContextColourLegend.visible or	//#25719 27/10/2010
	   self.mnuColumnOrganiser.visible or
	   self.mnuInspectObject.visible
	then
		self.mnuCloneSep.visible := true;
	else
		self.mnuCloneSep.visible := false;
	endif;

	// Combining menu on CMUI_QueryEnquiry and mnuLocalContext into a big cloned one. #25719 27/10/2010
	cloneCount := 1;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuInspectObject, false, cloneCount);
	cloneCount := cloneCount + 1;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuColumnOrganiser, false, cloneCount);
	cloneCount := cloneCount + 1;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuContextHide, false, cloneCount);
	cloneCount := cloneCount + 1;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuCloneSep, false, cloneCount);
	cloneCount := cloneCount + 1;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuSendToReport, false, cloneCount);
	cloneCount := cloneCount + 1;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuAutoPlan, false, cloneCount);
	clonedItem.enabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198
	cloneCount := cloneCount + 1;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuAutoPlanTest, false, cloneCount);
	clonedItem.enabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // TFS 2198
	cloneCount := cloneCount + 1;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuYAM, false, cloneCount);
	cloneCount := cloneCount + 1;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuContextTIEnquire, false, cloneCount);
	cloneCount := cloneCount + 1;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuContextTIEdit, false, cloneCount);
	cloneCount := cloneCount + 1;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuContextTIEnquire, false, cloneCount);
	
	self.mnuAutoPlanTest.visible:= false;	//always hide this, because we are using cloned one. #25719 27/10/2010
	self.mnuAutoPlan.visible	:= false;	//always hide this, because we are using cloned one. #25719 27/10/2010
	self.mnuCloneSep.visible	:= false;	//always hide this, because we are using cloned one. #25719 27/10/2010

	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then

	endif;
	
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);

	
	self.popupMenu(mnuLocalContext, x.Integer, y.Integer);

	return false;

epilog

end;</source>
        <Parameter name="_colSort" type="Boolean"/>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
