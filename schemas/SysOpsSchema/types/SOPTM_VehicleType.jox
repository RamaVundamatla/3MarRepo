    <JadeMethod name="doSave" id="d6ef29b1-3414-44fe-86c3-9af4e5304efb">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars
	proxyVehicleType	: CM_VehicleType;
	theForm 			: SOP_TableMaintForm;
	
	lType				: String;
	
begin
	theForm := self.myForm; 
	
	lType := theForm.tblInput1.getValueByName(ETRow_Type).String;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_VehicleType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyVehicleType := theForm.myProxyObject.CM_VehicleType;
	proxyVehicleType.setProxy(lType);

	if theForm.mode = theForm.Mode_Add then
		 app.myTrxCA.trxCreateVehicleType(proxyVehicleType, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateVehicleType(proxyVehicleType, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
