        <source>buildFileExtra(_transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input; _camFile: CM_CamFile input) updating, protected;
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS Cams
//09/05/2016    cnwma1	TFS 1964 CPL - Missing EDI CAMS Report transaction line on VERMAS messages

//
vars
	camFile : CM_CamFile;
begin
