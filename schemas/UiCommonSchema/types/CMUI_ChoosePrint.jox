    <JadeMethod name="doOK" id="59637d77-bfad-4793-afbf-dac072b4e111">
        <updating/>
        <source>doOK() updating;
// save the result in modalDialogReturnValue
vars

begin
	self.modalDialogReturnValue := 0;
	if self.opt1.value then
		self.modalDialogReturnValue := 1;
	elseif self.opt2.value then
		self.modalDialogReturnValue := 2;
	elseif self.opt3.value then
		self.modalDialogReturnValue := 3;
	elseif self.opt4.value then
		self.modalDialogReturnValue := 4;
	elseif self.opt5.value then
		self.modalDialogReturnValue := 5;
	elseif self.opt6.value then
		self.modalDialogReturnValue := 6;
	endif;

	inheritMethod();
end;
</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="8553c3ee-852a-40a8-88aa-703ad8865a75">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 18 January 2016.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020753, locale);
//	lblExtName.translateCaption(Xlat_0020770, locale);
//	lblExtSystem.translateCaption(Xlat_0020771, locale);
//	lblHeading.translateCaption(Xlat_0020754, locale);
//	lblReportName.translateCaption(Xlat_0020755, locale);
//	opt1.translateCaption(Xlat_0020756, locale);
//	opt2.translateCaption(Xlat_0020757, locale);
//	opt3.translateCaption(Xlat_0020758, locale);
//	opt4.translateCaption(Xlat_0020759, locale);
//	opt5.translateCaption(Xlat_0020760, locale);
	opt6.translateCaption(Xlat_0021114, locale);
end;</source>
    </JadeMethod>
