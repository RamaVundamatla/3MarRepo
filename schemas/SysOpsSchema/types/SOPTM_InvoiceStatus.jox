    <JadeMethod name="showThumbnail" id="0fe9753f-d3f1-4be5-9173-5984dfec4506">
        <updating/>
        <source>showThumbnail(_status: CM_InvoiceStatus) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jan 2019	jlgsl4	TFS 39618 - LNX - Invoice Approved Status

*/

vars
	form : SOP_TableMaintForm;

begin
	form := self.myForm;
	form.tblInput1.clearValues();
	
	form.tblInput1.setValueByName(ETRow_Description, _status.description);
	form.tblInput1.setValueByName(ETRow_InvoiceProcess, _status.myInvoiceProcess.description);
	if form.mode = form.Mode_View then
		form.tblInput1.setValueByName(ETRow_EmailOptions, _status.getDisplayStringForAttribute(ETRow_EmailOptions, false));
	else
		form.tblInput1.setValueByName(ETRow_EmailOptions, app.getErrorString(Dbl_Click_To_Add_Update));
	endif;
	form.tblInput1.disableRowByName(ETRow_InvoiceProcess);
epilog

end;</source>
        <Parameter name="_status" type="CM_InvoiceStatus"/>
    </JadeMethod>
</Class>
