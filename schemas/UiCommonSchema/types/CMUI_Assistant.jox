    <JadeMethod name="showTableMaintForm" id="81397a33-5920-493e-bdc0-1a40260b3c6d">
        <source>showTableMaintForm(pObj : CM_Object; _masterMenuAction : CMUI_MenuAction;
					_thumbnailOnly, _doEdit : Boolean) : CM_TableViewForm;
//--------------------------------------------------------------
//Created: 30 April 2002 By: cnwfd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 03/02/2016	cnwdap1		PAR #36766 Bulk Graphical Representation - allow Cargo types form to be called
// 22/01/2019	jlgmd1		TFS #43007 - Remove Teklogix
vars
	theForm 	: CM_TableViewForm;
	menuAction 	: CMUI_MenuAction;
begin

	if pObj = null then
		return null;
	endif;

	// if the object is one of these it is TERMINAL BASED so show Terminal Admin, else use System Admin
	if app.getMyUser.canDo(app.getMyTerminalDO_NOT_USE, PmAdmSystemTableView)
	and (pObj.isKindOf(CM_CamGroup)
		or pObj.isKindOf(CM_CamProtocol)
		or pObj.isKindOf(CM_DriverDetails)
		or pObj.isKindOf(CM_MTThreshold)	// 20 Jun 2011	NDL	Par 27331
		or pObj.isKindOf(CM_Machine)
		or pObj.isKindOf(CM_RadioTelemetryDevice)
		or pObj.isKindOf(CM_Vehicle)
		or pObj.isKindOf(CM_VoyagePlanningCode)
		or pObj.isKindOf(CM_WorkPoint)	//05 Nov 2014	NDL	Par 35032
		)  then
		menuAction := app.myController.createMenuAction3(PmAdmTabledefineView, self.myTerminal);
	elseif app.getMyUser.canDo(app.getMyTerminalDO_NOT_USE, PmAdmCargoTypeView)						// PAR #36766
	and pObj.isKindOf(CM_CargoType) then															// PAR #36766
		menuAction := app.myController.createMenuAction3(PmAdmCargoTypeView, self.myTerminal);		// PAR #36766
	else
		menuAction := app.myController.createMenuAction3(PmAdmSystemTableView, self.myTerminal);
	endif;
	
	if menuAction = null then
		return null;
	endif;
	

	theForm := menuAction.goToObject(null, null, false, null).CM_TableViewForm;
	if theForm = null then
		return null;
	endif;
	
	theForm.showWithObject(pObj, _thumbnailOnly, _doEdit);

	return theForm;
end;</source>
        <Parameter name="pObj" type="CM_Object"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_thumbnailOnly" type="Boolean"/>
        <Parameter name="_doEdit" type="Boolean"/>
        <ReturnType type="CM_TableViewForm"/>
    </JadeMethod>
    <JadeMethod name="showTableMaintModalForm" id="226b94b2-6199-4d87-b6fe-8f8032994e37">
        <source>showTableMaintModalForm(pObj : CM_Object; _masterMenuAction : CMUI_MenuAction;
					_thumbnailOnly, _doEdit : Boolean);
//--------------------------------------------------------------
//Created: 9 December 2004 By: cnwgd1
//--------------------------------------------------------------
vars
	formCls,
	assistCls	: Class;
	theForm : CM_TableViewForm;
	subSys : CMUI_SubSystem;		
begin

	if pObj = null then
		return;
	endif;
	subSys := app.myController.allSubSystems['SysOpsSchema'];
	
	if subSys &lt;&gt; null then
		subSys.getFormDetails('SOP_TableMaintModalForm', formCls, assistCls);
	endif;

	create theForm as formCls;	
	theForm.setMyTerminal(self.myTerminal);
	theForm.createMyAssistant(assistCls);
	theForm.showWithObject(pObj, _thumbnailOnly, _doEdit);

epilog
	delete theForm;

end;</source>
        <Parameter name="pObj" type="CM_Object"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_thumbnailOnly" type="Boolean"/>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showTableViewForm" id="bfcd768f-bfe2-4c76-83db-abe8302fc69e">
        <source>showTableViewForm(pObj : CM_Object; _permView : Integer; _masterMenuAction : CMUI_MenuAction;
					_thumbnailOnly, _doEdit : Boolean);
//--------------------------------------------------------------
//Created: 30 April 2002 By: cnwfd1
//--------------------------------------------------------------
vars
	theForm 	: CM_TableViewForm;
	menuAction 	: CMUI_MenuAction;
begin

	menuAction := app.myController.createMenuAction(_permView, pObj, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	theForm := menuAction.goToObject(null, null, false, null).CM_TableViewForm;
	if theForm = null then
		return;
	endif;
	if pObj &lt;&gt; null then
		theForm.showWithObject(pObj, _thumbnailOnly, _doEdit);
	else
		theForm.show();
	endif;
	

end;</source>
        <Parameter name="pObj" type="CM_Object"/>
        <Parameter name="_permView" type="Integer"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_thumbnailOnly" type="Boolean"/>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showTasksForm" id="25dd2901-2250-4545-b38f-11ef47a316c1">
        <source>showTasksForm(_ti : CM_TrackedItem; _tiColl : Collection; _canUpdate : Boolean; _mode : Integer) : Integer;
// 36957
vars

	frm					: CMUI_TasksForm;
	menuAction 			: CMUI_MenuAction;
begin
	
	if _ti = null and _tiColl = null then
		app.msgBox(	app.getString( CannotUpdateTaskNothingSelectd ),
					app.getString( Please_Select_Cargo_Items ),
					MsgBox_Stop_Icon + MsgBox_OK_Only );
		return IDCANCEL;
	endif;
	
	frm := app.loadForm(CMUI_TasksForm, CMUI_Assistant, false, false, false, self.myTerminal, menuAction).CMUI_TasksForm;
	
	if frm = null then
		// should not happen
		return IDCANCEL;
	endif;
	// set references on form being displayed for tracked items for which tasks are to be maintained
	frm.setMyTerminal(self.myTerminal);	
	frm.mode := _mode;
	
	if _tiColl &lt;&gt; null then
		_tiColl.copy (frm.allTrackedItems);
	else
		frm.allTrackedItems.add (_ti);
	endif;

	frm.myTrackedItem	:= _ti;
	frm.canUpdate		:= _canUpdate;
	
	frm.showModal;
	
	return frm.modalResult;
epilog
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiColl" type="Collection"/>
        <Parameter name="_canUpdate" type="Boolean"/>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showTasksFormTasks" id="7b2442fd-7da4-4a12-aae9-7233a7819185">
        <source>showTasksFormTasks(_toDoTasks : Cm_ToDoTaskSet; _canUpdate : Boolean; _mode : Integer; _wodtl: CM_WorkOrderToDoDtl) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
7 December 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/


vars

	frm					: CMUI_TasksForm;
	menuAction 			: CMUI_MenuAction;
begin
	
	if _toDoTasks = null then
		app.msgBox(	app.getString( CannotUpdateTaskNothingSelectd ),
					app.getString( Please_Select_Cargo_Items ),
					MsgBox_Stop_Icon + MsgBox_OK_Only );
		return IDCANCEL;
	endif;
	
	frm := app.loadForm(CMUI_TasksForm, CMUI_Assistant, false, false, false, self.myTerminal, menuAction).CMUI_TasksForm;
	
	if frm = null then
		// should not happen
		return IDCANCEL;
	endif;
	// set references on form being displayed for tracked items for which tasks are to be maintained
	frm.setMyTerminal(self.myTerminal);	
	frm.mode := _mode;
	
	if _wodtl &lt;&gt; null then
		frm.setMyWodtl(_wodtl);
	endif;
	
	_toDoTasks.copy(frm.allToDoTasks);
	
	frm.setObjectString(_toDoTasks);
	
	frm.setToDoTasks(_toDoTasks);
	
	frm.canUpdate		:= _canUpdate;
	
	frm.showModal;
	
	return frm.modalResult;
epilog
	
end;</source>
        <Parameter name="_toDoTasks" type="Cm_ToDoTaskSet"/>
        <Parameter name="_canUpdate" type="Boolean"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_wodtl" type="CM_WorkOrderToDoDtl"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showTerminalAdminForMaintClass" id="91dc4742-8da9-4d03-889d-fe031ab3e7bb">
        <source>showTerminalAdminForMaintClass(_sopTableMaintClass : Class; _masterMenuAction : CMUI_MenuAction) : CM_TableViewForm;
/*
Purpose:			
Date				Who			Reason
May 2014		CNWAB1		Initial creation
*/
vars
	theForm 	: CM_TableViewForm;
	menuAction 	: CMUI_MenuAction;
begin

	if _sopTableMaintClass = null then
		return null;
	endif;

	// if the object is one of these it is TERMINAL BASED so show Terminal Admin, else use System Admin
	if app.getMyUser.canDo(app.getMyTerminalDO_NOT_USE, PmAdmSystemTableView) then
		menuAction := app.myController.createMenuAction3(PmAdmTabledefineView, self.myTerminal);
	endif;
	
	if menuAction = null then
		return null;
	endif;
	

	theForm := menuAction.goToObject(null, null, false, null).CM_TableViewForm;
	if theForm = null then
		return null;
	endif;
	
	theForm.showWithTerminalAdminItemClass(_sopTableMaintClass);

	return theForm;
end;</source>
        <Parameter name="_sopTableMaintClass" type="Class"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <ReturnType type="CM_TableViewForm"/>
    </JadeMethod>
    <JadeMethod name="showTerminalAreaAuditDetails" id="0923d178-de71-4f8f-b130-6ed940feb21e">
        <source>showTerminalAreaAuditDetails(_terminalArea :CM_TerminalArea; _masterMenuAction :CMUI_MenuAction);
// ---------------------------------------------------------------------------
// Created:     08 March 2011 by cnwcs5
// Purpose:     
