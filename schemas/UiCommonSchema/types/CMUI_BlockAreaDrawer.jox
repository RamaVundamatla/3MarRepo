begin
	self.mode := mode;
end;
</source>
        <Parameter name="mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setScale" id="6a871ef9-7e50-42fd-a63e-172fdc42c042">
        <updating/>
        <source>setScale(_factor : Real; _onDeck, _underDeck: Boolean) updating;
// Set the scale factor (zoom). All drawing is based on the size of the cell
// so just need to change it to do the zooming
begin
	inheritMethod(_factor, _onDeck, _underDeck);

	self.initCellSize();
	self.cellSize.setX((cellSize.x * self.scaleFactor).Integer);
	self.cellSize.setY((cellSize.y * self.scaleFactor).Integer);
end;</source>
        <Parameter name="_factor" type="Real"/>
        <Parameter name="_onDeck" type="Boolean"/>
        <Parameter name="_underDeck" type="Boolean"/>
    </JadeMethod>
