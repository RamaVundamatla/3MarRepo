<Class name="Notification">
    <JadeMethod name="display" id="706ef117-7687-41d2-adf7-172b662087f2">
        <source>display(): String;
//12 August 2009	cnwdw1	
//
vars

begin
	return "Subscriber: " &amp; self.subscriber.String &amp; " Target: " &amp; self.target.String &amp; " Tag: " &amp; self.userTag.String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="requester" id="0a57bf16-48c7-4510-94a4-473d0bf2e8f6">
        <source>requester(): Process;
//12 August 2009	cnwdw1	
//
vars

begin
	return self.requestedBy;
end;</source>
        <ReturnType type="Process"/>
    </JadeMethod>
</Class>
