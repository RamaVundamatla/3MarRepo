    <JadeMethod name="resize" id="4a7e7930-cd63-422e-94e4-125ac0790dea">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	cmbAddressFrom.move(cmbAddressFrom.left, cmbAddressFrom.top, (self.width - cmbAddressFrom.left - 18), cmbAddressFrom.height);
	cmbAddressTo.move(cmbAddressTo.left, cmbAddressTo.top, (self.width - cmbAddressTo.left - 18), cmbAddressTo.height);
	txtCaller.move(txtCaller.left, txtCaller.top, (self.width - txtCaller.left - 18), txtCaller.height);
	txtOf.move(txtOf.left, txtOf.top, (self.width - txtOf.left - 18), txtOf.height);
	txtPhone.move(txtPhone.left, txtPhone.top, (self.width - txtPhone.left - 18), txtPhone.height);
	txtMessage.move(txtMessage.left, txtMessage.top, (self.width - txtMessage.left - 18), (self.height - txtMessage.top - 93));
	fraBottomRuler.move(fraBottomRuler.left, (txtMessage.top + txtMessage.height + 6), (self.width - fraBottomRuler.left - 18), fraBottomRuler.height);
	btnClose.move((self.width - btnClose.width - 18), (self.height - btnClose.height - 56), btnClose.width, btnClose.height);
	btnClear.move((btnClose.left - btnClose.width - 3), (btnClose.top), btnClear.width, btnClear.height);
	btnSend.move((btnClear.left - btnClose.width - 3), (btnClose.top), btnSend.width, btnSend.height);
	btnSpellCheck.move(btnSpellCheck.left, (btnClose.top), btnSpellCheck.width, btnSpellCheck.height);
end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="4974259b-91fd-48b5-8bfd-9ca371c58ebf">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		05 August 2000 by cnwdad1
//
// Purpose:		Traps a timer to clear the Status Message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if eventTag = self.TIMER_STATUS_RESET then
		self.doShowStatus(null);
	endif;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="a418a228-8196-46eb-837c-0637c6a92540">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// --------------------------------------------------------------------------------
// Created:		05 August 2000 by cnwdad1
//
// Purpose:		Traps the result of a sent email.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	smtpConnectObj	: CnSmtpConnection;

begin
	smtpConnectObj	:=	theObject.CnSmtpConnection;

	// Show a message box if an error occurred.

	if smtpConnectObj.result.bitAnd(CnSmtpConnection.Error_Occurred) &lt;&gt; null then
		app.msgBox(	smtpConnectObj.extendedErrorText,
					$CNEC_ERROR &amp; " " &amp; smtpConnectObj.errorCode.String,
					MsgBox_Stop_Icon + MsgBox_OK_Only);

		self.doShowStatus("Message Failed!");
		beginTimer(5000, Timer_OneShot, self.TIMER_STATUS_RESET);
	else
		self.doSetDefaults();
		self.doShowStatus("Message Sent.");
		beginTimer(5000, Timer_OneShot, self.TIMER_STATUS_RESET);
	endif;
epilog
	delete self.aMySmtpConnect;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="xHandlerLdap" id="415e5ffe-7a8d-402c-be38-d3d7f3a1805e">
        <source>xHandlerLdap(pExceptionObj:CnLdapException):Integer protected;
// --------------------------------------------------------------------------------
// Created:		16 August 2000 by cnwdad1
//
// Purpose:		Exception handler to trap LDAP errors.
//
// Parameters:	pExceptionObj - The exception that was raised by CnLdap.
//
// Returns:		Abort return code.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	errorMessage	:=	"The following error occured while requesting information from the LDAP server:" &amp; CrLf &amp; CrLf &amp;
						"Error Item: " &amp; pExceptionObj.errorItem &amp; CrLf &amp;
						"Message : " &amp; pExceptionObj.extendedErrorText;
	
	app.msgBox(errorMessage, "LDAP Error: " &amp; pExceptionObj.errorCode.String, MsgBox_Information_Icon + MsgBox_OK_Only);
	return Ex_Abort_Action;
end;</source>
        <access>protected</access>
        <Parameter name="pExceptionObj" type="CnLdapException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xHandlerMessageValidate" id="7ab0b51d-dbe4-444a-866a-622b5a05bf99">
        <updating/>
        <source>xHandlerMessageValidate(pExceptionObj:CnSmtpConnectionException):Integer updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 August 2000 by cnwdad1
//
// Purpose:		Exception handler for the CnSmtpConnection class.
//
// Parameters:	pExceptionObj - The SMTP exception object.
//
// Returns:		Abort Action.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	message	: String;

begin
	message	:=	pExceptionObj.errorItem &amp; " " &amp;
				pExceptionObj.errorCode.String &amp; CrLf &amp; CrLf &amp;
				pExceptionObj.extendedErrorText;

	self.doShowStatus("Message Failed!");
	beginTimer(5000, Timer_OneShot, self.TIMER_STATUS_RESET);

	self.aError	:=	message;
	return Ex_Abort_Action;
end;</source>
        <access>protected</access>
        <Parameter name="pExceptionObj" type="CnSmtpConnectionException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</GUIClass>
