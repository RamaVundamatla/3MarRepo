    <JadeMethod name="doConfirmCargoItem" id="83d8da9c-7507-4ef4-9c1a-9361c154ff44">
        <updating/>
        <source>doConfirmCargoItem() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

begin

	if self.myCargo = null then
		return;
	endif;
	
	self.addUpdateCargoConfirmed( self.myCargo, false, true );
	
	self.txtCargoId.text := null;
	self.txtCargoId_lostFocus( self.txtCargoId );
	
epilog

	self.txtCargoId.setFocus();

end;</source>
    </JadeMethod>
    <JadeMethod name="doCreateTransactions" id="caaae772-c3b1-457a-8c0f-8ed5f16bc908">
        <source>doCreateTransactions():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	size : Integer;
	msg : String;
	obj : Object;
	ti : CM_TrackedItem;
	index : Integer;
	expected : Boolean;	// Column 2 ticked = expected, unticked = extra
	scanned : Boolean;	// Column 3 ticked = scanned
	retValue : Boolean;
	cmif : CMIF_LocationCheckController;
	here : String;
	txn : CM_TITransaction;
	trxCmifSet : CMIF_TITxnControllerSet;
	trxDict : CM_TITransactionSet;
	result : Integer;

begin

	here := self.myLocation.getFullId();
	
	create trxCmifSet transient;
	create trxDict transient;

	foreach index in 1 to self.tblCargo.rows do
		obj := self.tblCargo.accessRow(index).itemObject;
		if obj = null or not obj.isKindOf(CM_TrackedItem) then
			continue;
		endif;
		
		ti := obj.CM_TrackedItem;
		
		expected := self.tblCargo.accessCell(index,2).text = "1";
		scanned := self.tblCargo.accessCell(index,3).text = "1";
		
		create cmif transient;
		cmif.type := TRANS_TYPE_LocationCheck;
		cmif.userId := app.myPassport.userCode;
		cmif.dateTime := app.actualTimeServer();
		cmif.myTrackedItem := ti;
		
		if ( not expected ) and scanned then // should NOT be here, but is
			cmif.expectedLocation := ti.myPrimaryActualLocation.getFullId();
			cmif.actualLocation := here;
		elseif expected and ( not scanned ) then// NOT scanned, so apparently not here
			cmif.expectedLocation := here;
			cmif.actualLocation := null;
		elseif expected and scanned then	// should be here, and is
			cmif.expectedLocation := here;
			cmif.actualLocation := here;
		else
			//shouldn't be possible... but
			delete cmif;
			continue;
		endif;
		
		trxCmifSet.add( cmif );
		
	endforeach;
	
	size := trxCmifSet.size;
	
	if size = 0 then
		msg := app.getErrorString(Locatio_check_transac_create);
		retValue := false;
		return retValue;
	endif;

	msg := app.getErrorString1(Sure_want_creat_locat_check_tr, size.String);
	if not app.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No ) = MsgBox_Return_Yes then
		retValue := false;
		return retValue;
	endif;
	
	while true do
		app.myTrxCA.trxCreateLocationCheckTrans( trxCmifSet, trxDict, app.myPassport	);
		
		if app.myPassport.trxCompletedOK then
			retValue := true;
			break;
		else
			result := app.showErrorWarningDialog(app.getString(Create_locatio_check_transac), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		retValue := false;
		break;
	endwhile;
	
epilog

	if not trxCmifSet.isEmpty then
		trxCmifSet.purge();
	endif;

	delete trxCmifSet;
	delete trxDict;
	
	return retValue;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="0d527ad1-0b19-4633-9c54-2ec91e81a575">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	stdLeft : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	width : Real;
	tabIndex : Integer;
	thirdWidth : Real;
	tblHeight : Real;
	tblWidth : Real;

begin
	
	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdLeft :=  self.resizedMargin;
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	thirdWidth := ( stdWidth / 3 );
	stdHeight := self.getStdControlHeight;
	
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );
							
	top := self.txtCargoId.top + self.txtCargoId.height + self.resizedMargin;
	if _initialSetup then
		self.btnConfirm.setAndIncrementTabIndex( tabIndex );
		self.btnConfirm.visible := true;
	endif;
	self.btnConfirm.move(	stdLeft,
							top,
							thirdWidth,
							stdHeight );
							
	if _initialSetup then
		self.lblLocation.setAndIncrementTabIndex( tabIndex );
		self.lblLocation.visible := true;
	endif;
	self.lblLocation.move(	stdLeft + thirdWidth + self.resizedMargin,
							top,
							(thirdWidth * 2 ) - self.resizedMargin,
							stdHeight );
							
	top := self.btnConfirm.top + self.btnConfirm.height + self.resizedMargin;
	
	if self.myCargoGroup &lt;&gt; null then
		if _initialSetup then
			self.lblCargoGrpId.setAndIncrementTabIndex( tabIndex );
			self.lblCargoGrpId.visible := true;
		endif;
		self.lblCargoGrpId.move(	stdLeft,
									top,
									stdWidth,
									stdHeight );
									
		self.lblCargoGrpId.caption := self.myCargoGroup.id;
								
		top := self.lblCargoGrpId.top + self.lblCargoGrpId.height - self.resizedMargin;
	endif;
	

	if _initialSetup then
		self.lblVerified.setAndIncrementTabIndex( tabIndex );
		self.lblVerified.visible := true;
	endif;
	self.lblVerified.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );
							
	top := self.lblVerified.top + self.lblVerified.height - self.resizedMargin;
	
	if _initialSetup then
		self.lblMissing.setAndIncrementTabIndex( tabIndex );
		self.lblMissing.visible := true;
	endif;
	self.lblMissing.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );
							
	top := self.lblMissing.top + self.lblMissing.height - self.resizedMargin;
	
	if _initialSetup then
		self.lblExtras.setAndIncrementTabIndex( tabIndex );
		self.lblExtras.visible := true;
	endif;
	self.lblExtras.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );
							
	top := self.lblExtras.top + self.lblExtras.height + self.resizedMargin;
	
	tblHeight:= (self.clientHeight - top - self.getCMDButtonsHeight() - self.resizedMargin - self.resizedMargin);
	if _initialSetup then
		self.tblCargo.setAndIncrementTabIndex( tabIndex );
		self.tblCargo.visible := true;
	endif;
	self.tblCargo.move(	stdLeft, 
						top, 
						stdWidth, 
						tblHeight);

	if _initialSetup then
		self.setupTable();
	endif;
	
	if self.tblCargo.rows &gt; 1 then
		if self.tblCargo.accessRow(1).height &lt; self.tblCargo.accessRow(2).height then
			self.tblCargo.accessRow(1).height := self.tblCargo.accessRow(1).height;
		endif;
	endif;
	
	tblWidth := self.tblCargo.width - 18; // to allow for scroll bar.
	self.tblCargo.accessColumn(1).width := (tblWidth * 0.6).Integer;
	self.tblCargo.accessColumn(2).width := (tblWidth * 0.2).Integer;
	self.tblCargo.accessColumn(3).width := (tblWidth * 0.2).Integer;
	
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
