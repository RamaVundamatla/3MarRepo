	//tmpLocale	: CM_Locale;
	//tmpNum		: Integer;
	//tmpTrans	: XLAT_Translation;
begin

	// PAR 17779 - replace with call here
	return self.getTranslationForCategory(XLAT_Menus);
	
	/*
