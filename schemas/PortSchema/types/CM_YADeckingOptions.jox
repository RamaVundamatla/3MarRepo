    <JadeMethod name="isDeckingLeftToRight" id="b5d7001f-e2be-4502-b704-945a0ba9c9a3">
        <source>isDeckingLeftToRight():Boolean;
//----------------------------------------------------------------
//	Created:	18 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	inOption	: Integer;
begin

	inOption := self.allDeckingRulesIn.first.deckingRuleType;

	if inOption = DeckingRule_Default
	or inOption = Height_Then_Next_Row_Pos
	or inOption = Layer_Then_First_Row_Pos then
		return true;
	elseif inOption = Height_Then_Prev_Row_Pos
	or inOption = Layer_Then_Last_Row_Pos then
		return false;
	elseif inOption = DeckingRule_Custom then
		return self.isCustomLeftToRight();
	else
		return self.isAreaLeftToRight();
	endif;
	
	return true;


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
