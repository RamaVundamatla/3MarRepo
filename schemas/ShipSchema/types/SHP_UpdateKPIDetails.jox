<GUIClass name="SHP_UpdateKPIDetails" id="96f7b296-40d9-4d3a-9d6d-001d4c23aab3">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="chkRunBGP" id="fe33869f-681f-4fa1-b076-363350b2fcba">
        <embedded/>
        <type name="CMUI_CheckBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="endMonthPkr" id="ce503d7a-3077-4467-b3ee-105ace074594">
        <embedded/>
        <type name="CMUI_MonthPicker"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblEnd" id="56282508-4172-49c2-b784-74d7b57cf7c0">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblStart" id="d80fea7c-8fcc-409e-ab6b-f5a01fb9db58">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="startMonthPkr" id="adfabd4a-81ec-4346-8e0a-032914c92026">
        <embedded/>
        <type name="CMUI_MonthPicker"/>
    </ImplicitInverseRef>
    <JadeMethod name="doOK" id="d643f5ae-e366-416e-9449-6032b85de107">
        <updating/>
        <source>doOK() updating;
/*

Date		    Who			Reason
30 September 2010	cnwas3	  PAR #25163 CCMS SFW 1108

*/

vars
	startDate,endDate : Date;
begin	
	startDate := self.startMonthPkr.getSelectedDate().cnEcGetFirstDayOfMonth();
	endDate := self.endMonthPkr.getSelectedDate().cnEcGetLastDayOfMonth();
	
	if startDate &gt; endDate then	
		if app.msgBox(app.getErrorString(End_month_earlier_start_month),app.getErrorString(Caution), MsgBox_Yes_No + MsgBox_Information_Icon) = MsgBox_Return_No then
			return;
		else
			if self.chkRunBGP.value then
				app.myTrxCA.trxCreateKPICargoCountRequest(self.myTerminal,endDate,startDate,app.myPassport);
			else
				app.myTrxUA.trxUpdateTermKPICargoCountBGP(self.myTerminal,endDate,startDate,app.myPassport);		
			endif;
		endif;
	else
		if self.chkRunBGP.value then
			app.myTrxCA.trxCreateKPICargoCountRequest(self.myTerminal,startDate,endDate,app.myPassport);
		else	
			app.myTrxUA.trxUpdateTermKPICargoCountBGP(self.myTerminal,startDate,endDate,app.myPassport);		
		endif;
	endif;	
	
	inheritMethod();

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="10332be7-ad03-4fcc-aebd-c4fcb9cf6083">
        <updating/>
        <source>setupForm() updating;
/*

Date		    Who			Reason
29 September 2010	cnwas3	  Initial creation

*/

vars

begin
	inheritMethod();	
	self.btnOk.caption  := app.getErrorString(Update).cnEcFirstToUpper();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="5d178ce7-7d3b-48c9-a9de-9a967a306670">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 July 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015668, locale);
	chkRunBGP.translateCaption(Xlat_0020751, locale);
	lblEnd.translateCaption(Xlat_0015669, locale);
	lblStart.translateCaption(Xlat_0015670, locale);
end;</source>
    </JadeMethod>
</GUIClass>
