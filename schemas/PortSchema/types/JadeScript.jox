    <JadeMethod name="hazardCount" id="3fccb478-47fe-462a-b537-295854646751">
        <source>hazardCount();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2024	navhl20	Initial creation
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	newQty : Real;
	ti 		: CM_TrackedItem;
	hazard 	: CM_TIHazard;
	dict	: DynaDictionary;
	code,
	hazCode	: String;
	count	: Integer;
	transaction : CM_TITransaction;
	cargo : CM_TrackedItem;
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	//newQty := _cmif.origQty;
	if canLogExtra then	//28.02.2025 navah1	#34141
		app.invLog("******* Hook Code Start **********", LogINFO.String);
	endif;
	cargo := "2367.57352932".asOid.CM_TrackedItem;
	create dict transient;
	dict.setMembership(CM_TIHazard);
	dict.addMemberKey(CM_TIHazard::code.name, false, true);
	dict.endKeys(true);
	cargo.allTIHazards.copy(dict);
	count := 1;
	code := dict.first.CM_TIHazard.code.padTrimTo(1);
	foreach hazard in dict as CM_TIHazard do
		hazCode := hazard.code.padTrimTo(1);
		if not hazCode = code then
			code := hazCode;
			count := count+1;
		endif;
	endforeach;
	newQty := count;
	if canLogExtra then	//28.02.2025 navah1	#34141
		app.invLog("Unique HAZ class groups are : " &amp; newQty.String, LogINFO.String);
		app.invLog("******* Hook Code End **********", LogINFO.String);
	endif;
	write newQty;
epilog
	delete dict;
end;</source>
    </JadeMethod>
