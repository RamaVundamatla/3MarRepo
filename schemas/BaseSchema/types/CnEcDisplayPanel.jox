    <JadeMethod name="listCollection" id="7b30ebd0-9d84-45f5-b54a-d438cfb99143">
        <updating/>
        <source>listCollection(userColl:Collection; update:Boolean; showHow:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		12 August 1999 by cnwdad1
//
// Purpose:		Sets up the list collection for the Data Panel table control.
//
// Parameters:	Same as the standard JADE listCollection method signature.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
