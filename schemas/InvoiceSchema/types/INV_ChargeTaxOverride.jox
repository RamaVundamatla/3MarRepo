    <JadeMethod name="addServiceTaxToTable" id="4d1c090e-6f4f-437f-90a7-cc01128285ec">
        <source>addServiceTaxToTable(_service: CM_Service; _items:Integer; _taxCode: String; _overridden: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2022	navmv20	ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance

*/

vars
	str		 : String;
	row		 : Integer;
	theTable : Table;
begin
	theTable := self.tblInvTable;
	str := _service.name &amp; Tab;
	str := str&amp; _items.String &amp; Tab;
	str:= str &amp; _taxCode &amp; Tab;
	if _overridden then
		str := str &amp; "Yes" &amp; Tab;
		str := str &amp; _taxCode;
	else
		str := str &amp; "No" &amp; Tab;
	endif;
	
	row := theTable.addItem(str);
	theTable.accessRow(row).itemObject := _service;
epilog

end;</source>
        <Parameter name="_service" type="CM_Service"/>
        <Parameter name="_items" type="Integer"/>
        <Parameter name="_taxCode" type="String"/>
        <Parameter name="_overridden" type="Boolean"/>
    </JadeMethod>
