    <JadeMethod name="cnEcGetDuplicate" id="de0d5510-0ebd-4f49-a898-12c448b7e7f3">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	code : String;
	damage : CM_DamageSeverity;
begin

	code := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "code" ).String; 
	
	if level &lt;&gt; null then
		damage := self.myTerminal.allDamageSeverities.getAtKey( code );
	endif;

epilog

	return damage;
end;

</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
