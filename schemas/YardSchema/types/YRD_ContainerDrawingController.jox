    <JadeMethod name="drawSubBlockStack" id="3300b1e4-502d-44de-8ded-434431588575">
        <source>drawSubBlockStack(_tmpBlockStack : CM_BlockStack) protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	label: String;
	theSamePrev, theSameAbove : Boolean;
	myGC, prevGC, aboveGC : CM_GridController;
	colIdx, rowIdx,aColour : Integer;
begin
	// This is so that we can clear up when a SBS is deleted
	self.addLCbyOID(_tmpBlockStack);
	
	if self.gridObjectsGetAtKeyForPut(self.x1.Integer, self.y1.Integer,self.x2.Integer,self.y2.Integer) = null then
		self.gridObjectsPutAtKey(self.x1.Integer, self.y1.Integer,self.x2.Integer,self.y2.Integer, _tmpBlockStack);
	endif;

	myGC := self.myLocationsController.CM_GridController;

	theSamePrev := false;
	if self.flipHorizontal then
		prevGC := myGC.getNextControllerOfType(CM_GridController);
	else
		prevGC := myGC.getPreviousControllerOfType(CM_GridController);
	endif;
	if prevGC &lt;&gt; null then
		if prevGC.mySubBlockStack = _tmpBlockStack then
			theSamePrev := true;
		endif;
	endif;
	theSameAbove := false;
	
	colIdx := myGC.myGridColumn.myGridArea.allGridColumns.indexOf(myGC.myGridColumn);
	rowIdx := myGC.myGridRow.myGridArea.allGridRows.indexOf(myGC.myGridRow);
	if self.flipVertically then
		rowIdx := rowIdx + 1;
	else
		rowIdx := rowIdx -1;
	endif;
	aboveGC := myGC.myGridColumn.myGridArea.allGridControllersByRowColumn[rowIdx,colIdx];
	if aboveGC &lt;&gt; null then
		if aboveGC.mySubBlockStack = _tmpBlockStack then
			theSameAbove := true;
		endif;
	endif;
	
	aColour := LightYellow;
	if _tmpBlockStack.myLayoutGraphic &lt;&gt; null then
		aColour := _tmpBlockStack.myLayoutGraphic.drawLineColour;
	endif;
	self.drawOverLappingRectangle(theSamePrev,theSameAbove, DarkGray, aColour, self.myDrawingFrame);

end;</source>
        <access>protected</access>
        <Parameter name="_tmpBlockStack" type="CM_BlockStack"/>
    </JadeMethod>
    <JadeMethod name="drawSubBlockStackLabels" id="244dbf6f-7ab2-4893-934a-c30b2fcac750">
        <source>drawSubBlockStackLabels();
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpObj : Object;
	aLabel : String;
	theSBS : CM_SubBlockStack;
	pointX ,pointY,aColour : Integer;
	anIterator : Iterator;
	objs : ObjectSet;
begin
	create objs transient;
	anIterator := self.myGridObjectsIterator;
	anIterator.reset();

	while anIterator.next(tmpObj) do
		if tmpObj.isKindOf(CM_SubBlockStack) then
			theSBS := tmpObj.CM_SubBlockStack;
			if not objs.includes(theSBS) then
				objs.add(theSBS);
				aLabel := theSBS.id;
				if theSBS.myLayoutGraphic &lt;&gt; null then
					aColour := theSBS.myLayoutGraphic.drawLineColour.getInverseColour;
				else
					aColour := Black;
				endif;
				aLabel := aLabel &amp; Cr &amp; theSBS.getMenuDetails(true, self.displayMode);
				
				//added by cnwyl1 06062006 for PAR 11804
				if aLabel.length &lt;= 3 then
					self.myDrawingFrame.drawFontSize := 16;
				else
					self.myDrawingFrame.drawFontSize := 8; 
					if self.scaleFactor &lt; 2 then
						if aLabel.length &gt;= 6 then // ### PAR 10555
							self.myDrawingFrame.drawFontSize := 6; 
						endif;
					endif;
				endif;		
				//add end
				pointX := anIterator.getCurrentKey(1).Integer;
				pointY := anIterator.getCurrentKey(2).Integer;
				self.myDrawingFrame.drawTextAt(aLabel, pointX ,pointY, aColour);
			endif;
		endif;
	endwhile;
epilog
//PAR 19102	delete anIterator; //epr par 18417 3/11/08
	delete objs;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawTI" id="bdceb760-ee76-4c27-aaec-25512dc196f1">
        <updating/>
        <source>drawTI(_theTI: CM_TrackedItem; _theGridAttributes: CMUI_GridAttributes input; _x1: Real; _y1: Real; _x2: Real; _y2: Real; _frame: CMUI_GridAreaDrawingFrame input;  _lc : CM_LocationsController) updating, protected;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date			Who		Reason
01 Apr 2009		cnwkpd1	PAR #18982 - Fix X coordinates for flipped horizontal mode when viewing
								Queued or Planned mode
08 Apr 2009    	CNWAB1	PAR #19215 - flipping from notes
28/06/2018		jlgmd1	TFS #37853 - Fix drawing spaces around containers whos length doesn't fit the standard 20ft grid
*/

vars
	dictX1, dictX2, tm_x1,tm_x2, numLCs, endX, startX : Real;
	lTIColour, backColor  : Integer;
	key1, key2 : Point;
	fm : CM_FutureMove;
	okToGo : Boolean;
	osBackEndLocation : CM_LocationsController;
	theTIIndex, theFillColour, highlightcolouredge : Integer;
begin
	if self.myDockBar.isForOverview then
		//inheritMethod(_theTI, _theGridAttributes, _x1, _y1, _x2, _y2, _frame );	// cnwjk3 PAR 23875 23/04/10
		inheritMethod(_theTI, _theGridAttributes, _x1, _y1, _x2, _y2, _frame, _lc);	// cnwjk3 PAR 23875 23/04/10
		return;
	endif;

	tm_x1 := _x1;
	tm_x2 := _x2;
	
	backColor := self.myDockBar.myScrollableFrame.backColor;
	
	if not self.autoMask then // PAR 19505 do not re adjust for autoMask as the Xs are correct
		tm_x2 := self.adjustEndX(_theTI,tm_x1); // PAR 16415 AKB2008MAY
	endif;
	
	if self.drawFromNote or self.autoMask then // PAR 19505
		 // Have to do this cos the drawing of the backends relies on knowing where the XYs for the backend are, 
		 // however if doing a shift the following statement puts the TI in the DICT for a split second twice.
		 self.allGridObjects.removeObjectFromDict(_theTI);
		//self.removeObjectFromDict(_theTI);
	endif;

	// PAR 19505 if self.flipHorizontal and not self.autoMask then // PAR 19505 do not re adjust for autoMask as the Xs are correct
	if tm_x1 &gt; tm_x2 then // PAR 19505 NEW
		dictX1 := tm_x2;
		dictX2 := tm_x1;
	else
		dictX1 := tm_x1;
		dictX2 := tm_x2;
	endif;

	if self.displayMode = DISPLAY_MODE_ACTUAL then
		if self.gridObjectsGetAtKeyForPut(dictX1.Integer, _y1.Integer, dictX2.Integer, _y2.Integer) = null then // PAR 16415 AKB2008MAY
			self.gridObjectsPutAtKey(dictX1.Integer, _y1.Integer, dictX2.Integer, _y2.Integer, _theTI); // PAR 16415 AKB2008MAY
		endif;
	elseif self.displayMode = DISPLAY_MODE_QUEUE then
		fm := _theTI.getFutureMoveForLC(QUEUE_MODE, self.myLocationsController); // PAR 18682
		if fm &lt;&gt; null then
			self.allGridObjects.removeObjectFromDict(fm);
			if self.gridObjectsGetAtKeyForPut(dictX1.Integer, _y1.Integer, dictX2.Integer, _y2.Integer) = null then		// PAR #19892
// PAR 18970				self.notableFMArmNotes(fm);
				self.gridObjectsPutAtKey(dictX1.Integer, _y1.Integer, dictX2.Integer, _y2.Integer, fm); 
			endif;
		endif;
	elseif self.displayMode = DISPLAY_MODE_PLAN then
		fm := _theTI.getFutureMoveForLC(PLANNING_MODE, self.myLocationsController); // PAR 18682
		if fm &lt;&gt; null then
			self.allGridObjects.removeObjectFromDict(fm);
			if self.gridObjectsGetAtKeyForPut(dictX1.Integer, _y1.Integer, dictX2.Integer, _y2.Integer) = null then		// PAR #19892
// PAR 18970				self.notableFMArmNotes(fm);
				self.gridObjectsPutAtKey(dictX1.Integer, _y1.Integer, dictX2.Integer, _y2.Integer, fm); 
			endif;
		endif;
	endif;
	
	if _theTI.isPallet() then
		lTIColour := self.getFillColourForTI(_theTI);
		
		if self.allSelectedObjects.includes(_theTI) then
			_frame.drawFillColor := backColor;
			_frame.drawWidth := 3; //self.scaleFactor.Integer;
			
			highlightcolouredge := White; // ### TFS 50421 05NOV2021 NAVAB1
			
			 // ### TFS 50421 05NOV2021 NAVAB1
			if process.isJLGAB1() then 
				_frame.drawFillColor := White;
				highlightcolouredge := backColor.getInverseColour();
				_frame.drawWidth := 1;
			endif;
			
			_frame.drawFilledRectangle(_x1 + 1, _y1 + 2, _x2 - 3, _y2 - 2,  highlightcolouredge);  // ### TFS 50421 05NOV2021 NAVAB1
			_frame.drawWidth := 1;
		else
			_frame.drawWidth := 1;
			_frame.drawFillColor := backColor;
			if self.scaleFactor = 4 then
				_frame.drawFilledRectangle(_x1 - 2, _y1 - 2, _x2 + 1, _y2 + 1,  backColor); 
			else
				_frame.drawFilledRectangle(_x1 - 1, _y1 - 1, _x2 + 1, _y2 + 1,  backColor); 
			endif;
		
		endif;
		if _theTI.isPallet() then
			self.drawMelons(_frame, _x1, _y1, lTIColour);
		endif;
	elseif _theTI.getTIBehaviourGraphic &lt;&gt; null then
		//epr par 31328/33133 draw cars based on the behaviour graphic and draw it flipped horizontally correctly
		if self.allSelectedObjects.includes(_theTI) then
			_frame.drawFillColor := backColor;
			_frame.drawWidth := 3; 
			
			_frame.drawFilledRectangle(_x1 + 1, _y1 + 2, _x2 , _y2 ,  White); 
			_frame.drawWidth := 1;
		else
			_frame.drawWidth := 1;
			_frame.drawFillColor := backColor;
			if self.scaleFactor = 4 then
				_frame.drawFilledRectangle(_x1 - 2, _y1 - 2, _x2 + 1, _y2 + 1,  backColor);
			else
				_frame.drawFilledRectangle(_x1 - 1, _y1 - 1, _x2 + 1, _y2 + 1,  backColor); 
			endif;
		endif;

		self.drawTIBehaviourGraphic(_theTI,_frame, _x1.Integer , _y1.Integer,_x2.Integer, _y2.Integer);
	else

		inheritMethod(_theTI, _theGridAttributes, tm_x1-2, _y1, tm_x2, _y2, _frame, _lc); 						// cnwjk3 PAR 23875 23/04/10				
		// PAR 18682. This is a bit bodgy, but the notes are sorted and come in the wrong order and arrive in reverse. 
		//					For most everything this is fine, but if shifting right the backend is still visible.
	
		if self.drawFromNote then
			
			//epr par 30524 18/10/12 another go at refreshing gaps because of the odd container lengths after a container has moved
			// replaced block of code below with new method
			
			// No longer required, done in adjustStartX instead
			//theTIIndex:=self.myLocationsController.allTrackedItems.indexOf(_theTI);
			//self.drawBlankSpaceForOffsetFlexi(theTIIndex, _x1-2,_y1,_x1+2,_y2);
		else
			if self.flipHorizontal then
				if _lc &lt;&gt; null then
					theTIIndex:=self.myLocationsController.allTrackedItems.indexOf(_theTI);
					if _lc.CM_GridController.myPreviousController &lt;&gt; null and not _lc.CM_GridController.testMyPreviousController(CM_GapController) then
						if self.myLocationsController.hasPower() then 
							theFillColour := self.POWER_FILL_COLOUR;
						else
							if self.isForSatelliteView then
								theFillColour := self.satelliteViewCellColour;
							else
								theFillColour := Gray;
							endif;
						endif;
						self.drawBlankSpace(self.myDrawingFrame, theFillColour, theTIIndex, _x1, _y1, _x1+ ((_lc.offsetFlexi/20) * self.columnWidth), _y2+1,  false);
					endif;
				endif;
			endif;
		endif;
	endif;
	
epilog
	//cnwjo3 par 24145  need this here or background of YA hatch is white and not transparent
	//if self.myYardGridAreaForm &lt;&gt; null then															//-cnwml2 PAR26083
	if self.myYardGridAreaForm &lt;&gt; null and app.activeForm &lt;&gt; null and app.activeForm.name = YRD_GridAreasForm.name then			//+cnwml2 PAR26083
		if self.myYardGridAreaForm = app.activeForm then	//08 Aug 2011	NDL	Par 27393 &amp; 27394
			self.myYardGridAreaForm.zOrder(1);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theGridAttributes" type="CMUI_GridAttributes" usage="input"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="drawTIBehaviourGraphic" id="37077e08-a43d-4875-9b1a-4d9d07398e27">
        <source>drawTIBehaviourGraphic(_theTI : CM_TrackedItem; _frame : Frame input;_x1: Integer; _y1: Integer; _x2: Integer; _y2: Integer) protected;
/*

Date		Who		Reason
09 December 2013	cnwer1	Initial creation PAR 31328/33133

*/

vars
	theX: Integer;
	graphic 		: CM_TIBehaviourGraphic;
	tiWidth, 
	tiHeight,
	scale,
	scaleX,
	scaleY,tmpY1offset: Real;
	fill : Integer;
begin
	graphic :=_theTI.getTIBehaviourGraphic;
	if graphic = null then
		return;
	endif;
	fill:=self.getFillColourForTI(_theTI);
	_frame.drawFillColor := fill;
	
	if _x2 &gt; _x1 then
		tiWidth := (_x2 - _x1);
		theX:=_x1;
	else
		tiWidth := _x1 - _x2;
		theX:=_x2;
	endif;
	tiWidth:=tiWidth -2; //less some room for a border
	tiHeight := _y2 - _y1;
	
	scaleX := (tiWidth)  / graphic.maxX;
	scaleY := (tiHeight) / graphic.maxY;
	if scaleY &lt; scaleX then
		scale := scaleY;
	else
		scale := scaleX;
	endif;
	
	tmpY1offset := ((tiHeight - 1) - (scale * graphic.maxY)).Integer;

	graphic.drawGraphic(_frame,scale,theX, (_y1 + tmpY1offset).Integer, false,tiWidth.Integer,false,_theTI.id, _theTI,fill);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawTranshipMark" id="52b935a5-c3a7-4112-ab68-b3412fb55446">
        <source>drawTranshipMark(_frame : CMUI_GridAreaDrawingFrame; _x1, _y1 : Real; _idx : Integer);
// ---------------------------------------------------------------------------
// Created:		20 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	yAdjust		: Real;
	theFrame	: CMUI_GridAreaDrawingFrame;
begin
	theFrame := _frame;
	if self.hasTranshipYardAllocation then
		if self.myLocationsController.hasOversizedBackendsByMode(self.displayMode, _idx, self.allTrackedItems, false) = null then
			theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
			if self.scaleFactor &lt; 1 then
				theFrame.drawFontSize := 7;
				yAdjust := 0;
			elseif self.scaleFactor &lt; 2 then
				theFrame.drawFontSize := 8;
			else
				theFrame.drawFontSize := 10;
				yAdjust := 2;
			endif;
//	PAR 20047			theFrame.drawTextAt(self.yardGridAreaTranshipMark, _x1 + 2, _y1 + yAdjust, Black);
			if self.flipHorizontal then // PAR 20047
				theFrame.drawTextAt(self.yardGridAreaTranshipMark, _x1 - 15, _y1 + yAdjust, Black); // PAR 20047
			else
				theFrame.drawTextAt(self.yardGridAreaTranshipMark, _x1 + 2, _y1 + yAdjust, Black);
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawYardAllocationLinesForRow" id="9bd8107e-8cd4-4cf7-81b6-8934c0c73963">
        <source>drawYardAllocationLinesForRow(_row : CM_GridObject; _yaTop : Integer; _oldHeight : Integer) : Integer;

/*

Purpose:			Draw Yard Allocations for given Grid Row.
					Yard Allocations are also added to associated YAMTable.

Parameters:			_yaTop contains the position to commence drawing the Yard Allocation lines.
					_oldHeight contains the current height of the draw area for the given row's Yard Allocation lines.

Return Value:		The new height of the draw area for the given row's Yard Allocation lines.


Date				Who		Reason
12 November 2008	consw1	SWF1030 - Initial creation

*/

constants
	LineHeight 		= 3;

vars
	colDepthArray	: IntegerArray;
	controllers		: CM_GridControllersByColumn;
	idx				: Integer;
	lc1, lc2 		: CM_GridController;
	newHeight		: Integer;
	tmpLC			: CM_GridController;
	ya				: CM_YardAllocation;
	yaDepth			: Integer;
	yaDepthArray	: IntegerArray;
	yaSet			: CM_YardAllocationSet;
	yaByPriority	: CM_YAByPriorityDict;
	

begin
	create controllers transient;
	create colDepthArray transient;
	create yaDepthArray transient;
	create yaSet transient;
	create yaByPriority transient;
	
	//  Get Yard Allocations for row

	foreach tmpLC in _row.CM_GridRow.allControllersByColumn where tmpLC.column &gt;= self.minColumn do
		if tmpLC.column &gt; self.maxColumn then
			break;
		endif;
		controllers.add(tmpLC);
		foreach ya in tmpLC.allYardAllocations where ya.myTerminal &lt;&gt; null and not ya.isDisabled and not yaSet.includes(ya) do
			if self.allYardAllocationsFilter.isEmpty
			or self.allYardAllocationsFilter.includes(ya) then
				yaSet.add(ya);
			endif;
		endforeach;
		colDepthArray[tmpLC.column] := 0;
	endforeach;
	
	if yaSet.isEmpty then
		//  Old height retained when larger to avoid need to redraw whole frame
		newHeight := _oldHeight.max( LineHeight * 2 );
		self.allYARows.putAtKey(0, _yaTop, 0, _yaTop + newHeight, _row);
		return newHeight;
	endif;

	//  Update associated YAM table
	
	if self.myYAMTable &lt;&gt; null then
		foreach ya in yaSet where not self.myYAMTable.allYardAllocationsByPriority.includes(ya) do
			self.myYAMTable.addItemYardAllocation(ya);
		endforeach;
	endif;
	
	//  Yard Allocations are ordered in priority sequence when there are multiple occurrences for a location
	
	yaSet.copy(yaByPriority);

	if yaByPriority.size = 1 then
		yaDepthArray.add(1);
	else
	
		foreach ya in yaByPriority do
			yaDepth := 1;
			foreach tmpLC in controllers where tmpLC.allYardAllocations.includes(ya) do
				yaDepth := yaDepth.max( colDepthArray[tmpLC.column] + 1 );
			endforeach;
			foreach tmpLC in controllers where tmpLC.allYardAllocations.includes(ya) do
				colDepthArray[tmpLC.column] := yaDepth;
			endforeach;
			yaDepthArray.add(yaDepth);
		endforeach;
	endif;

	//  Display Yard Allocations
	
	idx := 0;
	newHeight := 0;
		
	foreach ya in yaByPriority do
		idx := idx + 1;
		lc1 := null;
		lc2 := null;
		foreach tmpLC in controllers where tmpLC.allYardAllocations.includes(ya) do
			if lc2 = null then
				lc1 := tmpLC;
			elseif tmpLC.column &lt;&gt; lc2.column + 1 then
				self.drawSelfYardAllocationLine( ya, lc1, lc2, _yaTop, yaDepthArray[idx], LineHeight, newHeight );
				lc1 := tmpLC;
			endif;
			lc2 := tmpLC;
		endforeach;
		if lc2 &lt;&gt; null then
			self.drawSelfYardAllocationLine( ya, lc1, lc2, _yaTop, yaDepthArray[idx], LineHeight, newHeight );
		endif;
	endforeach;

	//  Save off position details
	
	if newHeight &lt; _oldHeight then
		//  Old height retained when larger to avoid need to redraw whole frame
		newHeight := _oldHeight;
	elseif newHeight &gt; _oldHeight then
		//  Include an extra line to avoid need to redraw whole frame when next Yard Allocation created/extended
		newHeight := newHeight + LineHeight;
	endif;

	self.allYARows.putAtKey(0, _yaTop, 0, _yaTop + newHeight, _row);

	return newHeight;

epilog
	self.myDrawingFrame.drawWidth := 1; // PAR 18682
	
	delete controllers;
	delete colDepthArray;
	delete yaDepthArray;
	delete yaSet;
	delete yaByPriority;
end;</source>
        <Parameter name="_row" type="CM_GridObject"/>
        <Parameter name="_yaTop" type="Integer"/>
        <Parameter name="_oldHeight" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawYardAllocations" id="13c4f271-41e3-4a90-8df9-1e97cf9e2d9d">
