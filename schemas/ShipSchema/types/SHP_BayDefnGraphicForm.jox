        <source>cmbSelBay_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2009	cnwer1	Initial creation

*/

vars
	aBay : CM_Bay;
begin
	aBay := combobox.listObject.CM_Bay;
	self.doChangeBay(aBay);
epilog

end;</source>
