    <JadeMethod name="utlDeleteInvContractDtlRtEntry" id="1b8f72d9-e8e8-494d-b7cf-bca53be6f301">
        <source>utlDeleteInvContractDtlRtEntry(_obj : CM_InvoiceContractRateEntry io; _passport : CM_Passport input);
/*
Purpose:			

Date		Who		Reason
09DEC2022	NAVAB1	TFS CR 55623 TASK 55677
09-02-2023 		navtnr20 TFS CR 55646	Task 55665: UI - Contracts Details
*/
vars
	debtor : CM_Debtor;
	contractRate : CM_InvoiceContractRate;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	// note that validation agent locks object
	app.myValDA.valDeleteInvContractDtlRtEntry(_obj);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	// ### TFS BUG 64886 14AUG2024 NAVAB1
	if _passport.noErrors then
		contractRate := _obj.myInvoiceContractRate;
		debtor := contractRate.getDebtor();
		contractRate.updateCharges(debtor);
	endif;

	if _passport.noErrors then
		// only requierd if class is audited
		self.myDeleteAuditAgent.audDeleteGeneric(_obj);
		app.myEventManager.createSingleObjInfoNoteEvt(_obj.myInvoiceContractRate,app.myPassport.myTerminal.getTerminalEvent(Event_InvContractRateEntDelete),_obj);//09-02-2023 navtnr20 TFS CR 55646 TASK 55665
	endif;

	// ### TFS BUG 64886 14AUG2024 NAVAB1
	contractRate := _obj.myInvoiceContractRate;
	debtor := contractRate.getDebtor();
	
	if _passport.noErrors then
		_obj.setForDelete();
	endif;
	
	// ### TFS BUG 64886 14AUG2024 NAVAB1
	if _passport.noErrors then
		contractRate.updateCharges(debtor);
	endif;

end;</source>
        <Parameter name="_obj" type="CM_InvoiceContractRateEntry" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
