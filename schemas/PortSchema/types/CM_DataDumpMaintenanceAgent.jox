	xdbFeature.setupAndBuildSet(CM_Train::getStevedoreCodeRelease.name, "CM_Train", "stevedoreCodeRelease", "", _features);  //02.10.2020 cnwma1 TFS #50112
	
	//13 May 2021	NDL	TFS 51196
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_Train::getServiceDate.name, "CM_Train", "getServiceDate", "", _features);
	
	// ### TFS 53132 8Apr2022 NAVPW1
	create xdbFeature transient; 
