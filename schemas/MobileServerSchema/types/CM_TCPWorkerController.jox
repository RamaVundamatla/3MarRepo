    <JadeMethod name="setupFromInitializationFile" id="e6922759-acd3-4b57-a8e0-4d375c80b265">
        <updating/>
        <source>setupFromInitializationFile() updating, protected;

/*

Purpose:			Setup the receiver settings from the ini file

Parameters:			None

Return Value:		TCP attributes set from ini file


Date		Who		Reason
29 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition
24 Nov 2008	cnwkpd1	PAR #18526 - CCMS 1767 - TCP Interface ValidateMove changes

*/

constants
	SectionName			= "JMTTCPListener";
	StatistcsInterval	= "TCPStatisticsLogInterval";
	QueueDepthLimit		= "TCPQueueDepthLimit";
	QueueDepthTimeout	= "TCPQueueDepthLimitTimeout";
	WorkerIdleTimeout	= "TCPWorkerIdleTimeout";
	DumpCMException		= "CreateStackDumpOnCMException";
	SuppressWarnings	= "SuppressWarnings";
	ReturnErrorCodes	= "ReturnErrorCodes";
	DummyValue			= "Dummy";
	
vars
	iniValue,
	iniFileName		: String;
	integerValue	: String;
	
begin
	iniFileName := app.getIniFileNameAppServer;
	
	// Get each of the required values, setting the default for any not found
	
	// Statistics log interval
	iniValue := app.getProfileStringAppServer(iniFileName, SectionName, StatistcsInterval, DummyValue);
	if iniValue = DummyValue then
		app.setProfileStringAppServer(iniFileName, SectionName, StatistcsInterval, "0");
		self.tcpStatisticsLogInterval := 0;
	elseif iniValue.isInteger then
		self.tcpStatisticsLogInterval := iniValue.Integer;
	endif;
	
	// Queue depth limit
	iniValue := app.getProfileStringAppServer(iniFileName, SectionName, QueueDepthLimit, DummyValue);
	if iniValue = DummyValue then
		app.setProfileStringAppServer(iniFileName, SectionName, QueueDepthLimit, "0");
		self.tcpQueueDepthLimit := 0;
	elseif iniValue.isInteger then
		self.tcpQueueDepthLimit := iniValue.Integer;
	endif;
	
	// Queue depth limit timeout
	iniValue := app.getProfileStringAppServer(iniFileName, SectionName, QueueDepthTimeout, DummyValue);
	if iniValue = DummyValue then
		app.setProfileStringAppServer(iniFileName, SectionName, QueueDepthTimeout, "0");
		self.tcpQueueDepthLimitTimeout := 0;
	elseif iniValue.isInteger then
		self.tcpQueueDepthLimitTimeout := iniValue.Integer;
	endif;
	
	// Worker idle timeout
	iniValue := app.getProfileStringAppServer(iniFileName, SectionName, WorkerIdleTimeout, DummyValue);
	if iniValue = DummyValue then
		app.setProfileStringAppServer(iniFileName, SectionName, WorkerIdleTimeout, "0");
		self.tcpWorkerIdleTimeout := 0;
	elseif iniValue.isInteger then
		self.tcpWorkerIdleTimeout := iniValue.Integer;
	endif;
	
	// Dump CM Exceptions
	iniValue := app.getProfileStringAppServer(iniFileName, SectionName, DumpCMException, DummyValue);
	if iniValue = DummyValue then
		app.setProfileStringAppServer(iniFileName, SectionName, DumpCMException, "false");
		self.dumpCMExceptions := false;
	else
		self.dumpCMExceptions := iniValue.toLower.Boolean;
	endif;
	
	// Suppress Warnings - added for PAR #18526
	iniValue := app.getProfileStringAppServer(iniFileName, SectionName, SuppressWarnings, DummyValue);
	if iniValue = DummyValue then
		app.setProfileStringAppServer(iniFileName, SectionName, SuppressWarnings, "true");
		self.suppressWarnings := true;
	else
		self.suppressWarnings := iniValue.toLower.Boolean;
	endif;

	// Return Error Codes - added for PAR #18526
	iniValue := app.getProfileStringAppServer(iniFileName, SectionName, ReturnErrorCodes, DummyValue);
	if iniValue = DummyValue then
		app.setProfileStringAppServer(iniFileName, SectionName, ReturnErrorCodes, "false");
		self.returnErrorCodes := false;
	else
		self.returnErrorCodes := iniValue.toLower.Boolean;
	endif;

	
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="start" id="4b050183-5ab8-4ef7-8496-fed4f7f777ba">
        <updating/>
