    <JadeMethod name="cmbProduct_click" id="f57ecb85-c484-437c-9091-1fd2fb772f11">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbProduct_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     13 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	theRow 			: Integer;
	beforeTxt		: String;
	tmpProduct	: CM_Product;
begin

	theRow  := self.tblDataDetail.row;
	
	//find out what table text is to see if combo has changed.  
	beforeTxt := self.tblDataDetailSaveText;
	
	if combobox.text &lt;&gt; beforeTxt then 
		// this may be called alot but if left to lost focus method can get funny values 
		// in table when more than one row and changing rows. 
		tmpProduct := combobox.listObject.CM_Product;
		self.setupTblDtlRowForProduct(theRow, tmpProduct);
		// reset this in case change again
		self.tblDataDetailSaveText := combobox.text;
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbTI_click" id="4320db27-5dc4-442c-b96c-22c7612d4d7d">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTI_click(combobox: CMUI_ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	cmbPro		: CMUI_ComboProduct;
	cmb			: CMUI_ComboBox;
	tmpTI		: CM_TrackedItem;
	tbl			: CM_DataTable;
	theRow 		: Integer;
	tmpCell : JadeTableCell;
begin


	cmb 			:= combobox;
	tbl 			:= self.tblDataDetail;
	tmpTI 			:= cmb.listObject.CM_TrackedItem;
		
	theRow  := tbl.row;
	
	if (tmpTI &lt;&gt; null) then
		tmpCell := tbl.accessCell(theRow, self.colProduct);
		cmbPro := tmpCell.cellControl.CMUI_ComboProduct;
		// set product if it hasnt been set. 
			if cmbPro.listObject &lt;&gt; tmpTI.myProduct then 
				cmbPro.clear(); 
				cmbPro.setCargoType(tmpTI.myCargoType);
				cmbPro.setObject(tmpTI.myProduct);
			endif;
	// set rest of table data;		
	endif;			

	self.zDoTblDetailDataRowColChg(self.tblDataDetail);
//	self.doCmbItemLostFocus(combobox);
end;</source>
        <Parameter name="combobox" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
