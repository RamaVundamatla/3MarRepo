<GUIClass name="CMUI_EmptyAvailability" id="973ae012-c54a-4fde-af8a-48cab81b5b56">
    <superclass name="CMUI_ReportBaseForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="myJRWEmptySummary" id="85c739ec-3344-4baa-8600-54ca99e540e8">
        <embedded/>
        <type name="CM_JRWEmpty"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myReportGroupRoot" id="ab0ad893-7968-43ac-97b5-9dd4a5badbaf">
        <embedded/>
        <type name="CM_ReportGroupRoot"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="picJMTLogo" id="234e2d17-e5f4-49c5-a9bc-70b8061dee30">
        <embedded/>
        <type name="Picture"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="picPortLogo" id="a8695069-7e27-45d8-b5af-c1430558c8b8">
