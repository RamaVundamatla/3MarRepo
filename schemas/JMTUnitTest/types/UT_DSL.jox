    <JadeMethod name="deleteSubBlockStack" id="17ba4ae2-c6f9-4e73-9f03-ecd2bba5ea3e">
        <source>deleteSubBlockStack(_subBlockStack : CM_SubBlockStack);

/*

Purpose:		Delete subBlock Stack

Date			Who		Reason
07/02/2014		cnwmh5	Initial creation

*/

vars

begin

	if _subBlockStack = null then
		return;
	endif;
	
	app.myTrxDA.trxDeleteTerminalArea(_subBlockStack, app.myPassport);
