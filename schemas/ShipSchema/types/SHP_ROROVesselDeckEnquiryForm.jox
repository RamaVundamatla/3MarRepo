    <JadeMethod name="doCopyDeck" id="bbe13d45-cd60-4d67-ba20-eb960229f5ef">
        <source>doCopyDeck() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 March 2011	cnwer1	Initial creation CCMS 1031

*/

vars

	deck, copyDeck : CM_DeckVessel;
	
begin
	deck:=self.getSelectedDeck.CM_DeckVessel;
	
	if deck = null then
		return;
	endif;
	
	//epr par 27486 16/5/11
	if deck.isKindOf(CM_DeckVesselSub) then
		copyDeck:=deck.CM_DeckVesselSub.cloneMySelfSub(deck.CM_DeckVesselSub.myParentDeck, true, true);
	else
		copyDeck:=deck.cloneMySelf(deck.myROROStructure, true, true);
	endif;

	self.myAssistant.SHP_Assistant.showROROVesselDeckDefn(self.myROROVesselStructure,copyDeck,SHP_RORODeckDefinitionForm.Mode_Copy);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEditDeck" id="d4787e9c-4c27-41b4-ad9f-897c8019d4a5">
        <source>doEditDeck() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 March 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	deck : CM_DeckVessel;
begin

	if self.tbRoRolDecks.accessRow(self.tbRoRolDecks.row) = null then
		return;
	endif;
	deck:=self.tbRoRolDecks.accessRow(self.tbRoRolDecks.row).itemObject.CM_DeckVessel;

	if deck &lt;&gt; null then
		self.myAssistant.SHP_Assistant.showROROVesselDeckDefn(self.myROROVesselStructure,deck,SHP_RORODeckDefinitionForm.Mode_Edit);
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
