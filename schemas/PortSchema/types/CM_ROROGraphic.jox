    <JadeMethod name="copyMe" id="bdd111dd-3f8d-4aab-945e-5b5d396123e9">
        <source>copyMe(_newProxyGraphic : CM_ROROGraphic input; _layer : CM_ShipDeckLayer; _offset : Integer);
// ---------------------------------------------------------------------------
// Created:     21 December 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// assume SELF is a proxy. Assume that passed in proxy has been closed.
// ---------------------------------------------------------------------------

vars
	xyPoint : Point;
	x1, y1 : Integer;
	newPoints : PointArray;
begin
	create newPoints transient;
	foreach xyPoint in _newProxyGraphic.pointsPolygon do
		x1 := xyPoint.x;
		y1 := xyPoint.y;
		
		x1 := x1 + _offset;
		y1 := y1 + _offset;
		
		xyPoint.setX(x1);
		xyPoint.setY(y1);
		
		newPoints.add(xyPoint);
	endforeach;
	
	_newProxyGraphic.pointsPolygon.clear;
	newPoints.copy(_newProxyGraphic.pointsPolygon);
	_newProxyGraphic.label := self.label;
	_newProxyGraphic.myShipLayer := _layer; 
	_newProxyGraphic.myRepresentativeObject := self.myRepresentativeObject;
		
epilog
	delete newPoints;
end;</source>
        <Parameter name="_newProxyGraphic" type="CM_ROROGraphic" usage="input"/>
        <Parameter name="_layer" type="CM_ShipDeckLayer"/>
        <Parameter name="_offset" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDrawFillStyle" id="e61a5f00-cd09-460a-b9a6-4bdc392a457f">
