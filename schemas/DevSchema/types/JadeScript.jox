    <JadeMethod name="schCreateAllSQLTables" id="1ceaaaad-47f7-4865-a67e-4920a0c10964">
        <source>schCreateAllSQLTables();
/*

Purpose:			Create a SQL command to create all the tables for a named SQL 
					Native extract definition

Parameters:			

Return Value:		

Date		Who		Reason
31 Jan 2012	cnwkpd1	Initial creation

*/

vars
	def			: CM_DataDumpExtractDef;
	extractClass : CM_DataDumpExtractClass;
	file		: File;
	dump        : String;
	xdbAgent    : CM_ExternalDatabaseAgent;

begin
	app.initialize();
	
	create xdbAgent transient;
	
	foreach def in CM_DataDumpExtractDef.instances where def.description = "KC One Only" do
	
		delete file;
		create file transient;
		file.openOutput("c:\temp\" &amp; def.description &amp; "_create_all_tables.sql");
		
		foreach extractClass in def.allDataDumpExtractClasses do
			dump := xdbAgent.buildCreateTableString(extractClass);
			
			dump := dump.replace("[dbo]", "[" &amp; def.edbConnectionString &amp; "].[dbo]");
			
			file.writeLine(dump);
		endforeach;
		
		file.close;

	endforeach;

epilog
	delete file;
	delete xdbAgent;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="sdlCashCreditSequNum" id="022f1a33-aad4-4c18-a9b0-5bb968a95989">
        <updating/>
        <source>sdlCashCreditSequNum() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Sep 2019	jlgsl4	TFS 45872 - JMT - Cash Credit UI changes
*/

vars
	keySeries : CM_KeySeries;
	seriesKey : CM_SeriesKey;
	bank : CM_Bank;
	objectArray : ObjectArray; 
	iterator : Iterator;
	isOK : Boolean;
begin
	app.initialize();
	create objectArray transient;
	CM_Bank.allInstances(objectArray, 0, false);
	iterator := objectArray.createIterator;
	app.writeLog(method.qualifiedName &amp; "***** Started -&gt; Create Cash Credit sequence numbers for banks listed:-", LogINFO);
	while iterator.next(bank) do
		if not bank.isBusinessUnit then
			continue;
		endif;
		if bank.keySeries[SN_CashCredit] = null then
			beginTransaction;
			create keySeries;
			keySeries.set(SN_CashCredit, "Cash Credit External Id", null);
			create seriesKey;
			keySeries.nextKey := seriesKey;
			seriesKey.setForUpdate(null, "CTL", 10000, null, null);
			bank.keySeries.add(keySeries);
			commitTransaction;
			app.writeLog(method.qualifiedName &amp; " -&gt; terminal " &amp; bank.getMyTerminal().code &amp; ", bank " &amp; bank.code, LogINFO);
		endif;
	endwhile;
	isOK := true;
	app.writeLog(method.qualifiedName &amp; "***** Finished -&gt; Create Cash Credit sequence numbers", LogINFO);	
epilog
	if not isOK then
		abortTransaction;
	endif;
	delete objectArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="sdlCheckVoyageMovements" id="fb9567ed-766a-4425-bb2b-e32a43e0961d">
        <source>sdlCheckVoyageMovements();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	voyageMovement : HMS_VoyageMovement;
	pilot : HMS_Pilot;
	movementPilotDetails : HMS_MovementPilotDetails;
	voyage : CM_Voyage;
	voyageData : HMS_VoyageData;
	terminalCode : String;
	count : Integer;
begin
	app.initialize();// remove this for JMT script window use
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; "**** Script started ****", LogINFO);
	foreach voyageMovement in HMS_VoyageMovement.instances where voyageMovement.allMovementPilotDetails.isEmpty do
		if count &gt; 20 then
			break;
		elseif not voyageMovement.allPilots.isEmpty then
			voyageData := voyageMovement.getMyHMSVoyageData(); // get voyage details
			if voyageData &lt;&gt; null then
				voyage := voyageData.myVoyage;
				if voyage &lt;&gt; null then // voyage is valid
					terminalCode := "Unknown";
					if voyage.myTerminalActive &lt;&gt; null then
						terminalCode := voyage.myTerminalActive.code;
					endif;
					app.writeLog(class.name &amp; '::' &amp; method.name &amp; "Movement for voyage" &amp; voyage.code &amp; ", terminal " &amp; terminalCode &amp; " has " &amp;
						voyageMovement.allPilots.size.String &amp; " pilots", LogINFO);
					count := count + 1;
				endif;
			endif;		
		elseif voyageMovement.myPilot &lt;&gt; null then // Empty allPilots means the terminal's using now-deprecated myPilot...
			app.writeLog(class.name &amp; '::' &amp; method.name &amp; "*** A voyage movement using myPilot not allPilots", LogINFO);
		endif;
	endforeach;
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; "**** Script finished ****", LogINFO);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sdlCleanupIMEXtrans" id="f6befa22-a2d7-44d7-9613-01f6040df99c">
        <updating/>
        <source>sdlCleanupIMEXtrans() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2018	jlgsl4	Initial creation

*/

vars
	dudTransition : CM_IMEXTransitionCriteria;
	theObject : CM_Object;
	result : Integer;
begin
	app.initialize;
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	dudTransition := '14352.11'.asOid.CM_IMEXTransitionCriteria;
	theObject := dudTransition;
	write dudTransition.name;
	write dudTransition.myTerminal;
	while true do
		app.myTrxDA.trxDeleteCMObject(theObject, app.myPassport ); //trxDeleteDelay(selectedObj.CM_Delay, app.myPassport);
		if app.myPassport.trxCompletedOK then
			write "Deleted";
			break;
		else
			write "Not deleted...";
		endif;
		break;
	endwhile;

epilog

end;</source>
    </JadeMethod>
