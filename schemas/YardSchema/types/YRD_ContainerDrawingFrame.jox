    <JadeMethod name="handleMouseUp" id="8cbd8037-4187-4954-b8f4-6108bb16cdaa">
        <updating/>
        <source>handleMouseUp(_obj : Object; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theObj			: Object;
	tmpController	: YRD_ContainerDrawingController;
	tmpObject		: Object;
	isOnDeck,
	isSelect,
	isSelectAlt,
	isSlotController,
	isControlKey,
	isBlock			: Boolean;
	tmpSlotController	: CM_SlotController;
	y1,y2, tiIndex,cellHeight,stackHeight : Integer;
	theTI : CM_TrackedItem;
begin

	if _obj = null then
		return;
	endif;

	tmpController := self.myDockBar.myDrawingController;
	if tmpController = null then
		app.raiseCMException1(MethodWithNullParam, 'ContainerDrawingController', null, null);
		return;
	endif;

	if tmpController.isForGCRack then
		return;
	endif;
	
	if (not tmpController.isSelectObjectsEnabled) then
		return;
	endif;

	if (not shift.isShiftKeyPressed) and  
	   (not shift.isControlKeyPressed) and 
	   (not shift.isAltKeyPressed) then // NO SHIFT, ALT or CONTROL

		if button = Button.MouseButton_Left then
			// clear existing selection
			tmpController.clearAllSelectedObjects();
			self.myStartObject := null;
			isSelect := true;
		endif;

	elseif shift.isShiftKeyPressed then // SHIFT
		if shift.isAltKeyPressed then // ALT
			isSelectAlt := true;
			isBlock := true;
		else
			isSelect := true;
			isBlock := true;
		endif;

	elseif shift.isControlKeyPressed then // CONTROL
		isControlKey := true;
		if shift.isAltKeyPressed then // ALT
			isSelectAlt := true;
		else
			isSelect := true;
		endif;

	elseif shift.isAltKeyPressed then // ALT
		if button = Button.MouseButton_Left then
			tmpController.clearAllSelectedObjectsAlt();
			isSelectAlt := true;
		elseif button = Button.MouseButton_Right then
			self.myStartObjectAlt := null;
		endif;
	endif;

	if (not (isSelect or isSelectAlt)) then
		return;
	endif;
	
	if isSelect and tmpController.allSelectedObjects.includes(_obj) then
		tmpController.allSelectedObjects.remove(_obj);
		self.drawObject(_obj, tmpController);
		return;
	elseif isSelectAlt and tmpController.allSelectedObjectsAlt.includes(_obj) then
		tmpController.allSelectedObjectsAlt.remove(_obj);
		self.drawObject(_obj, tmpController);
		return;
	endif;

	if isSelect then
		if _obj.isKindOf(CM_LocationsController) then // empty location, check for 40 backends
			if not _obj.CM_LocationsController.allTrackedItems.isEmpty then
				if not self.myDockBar.myDrawingController.select40BackEnd(y,_obj.CM_LocationsController) then
					self.selectObject(_obj, self.myStartObject, false);
				endif;
			endif;
		else
			self.selectObject(_obj, self.myStartObject, false);
		
		endif;
	endif;

epilog
	self.enableEvent("mouseMove", false);
	app.isDragging := false;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="handleMouseUpGridMultiMove" id="e8da3ec5-4064-4488-af4a-0c07b9c66276">
        <updating/>
        <source>handleMouseUpGridMultiMove(_obj1 : Object; button: Integer; shift: Integer; x: Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars
	theObject : Object;
	tmpController : YRD_ContainerDrawingController;
	isSelect : Boolean;
	isSelectAlt : Boolean;
	isControlKey : Boolean;
	isBlock : Boolean;
	xy1, xy2	: Point;
	numInStack : Integer;
	offset : Real;
	drawnHeight : Real;
	yardCells : CM_YALocationCellArray;
	yardCell : CM_YALocationCell;
		
begin

	if _obj1 = null then
		return;
	endif;
	
	theObject := _obj1;
	
	if _obj1.isKindOf(CM_YardController) then	// If this has multiple positions choose the one we clicked on and
												// any that are available immediately below it.		
		numInStack := _obj1.CM_YardController.allYAYardLocationCells.size;
		if numInStack &gt; 1 then
			self.myDockBar.myDrawingController.getObjectAndPointsForPosition(x.Integer, y.Integer, xy1, xy2, CM_LocationsController);
			offset := xy2.y - y;
			drawnHeight :=  (( xy2.y ) - ( xy1.y ));
			create yardCells transient;	// the yard cells below me that are available for multi move
			yardCell := _obj1.CM_YardController.getRelativeLocationCell( yardCells, drawnHeight, offset );
			if yardCell = null or ( not yardCell.isAvailForMultiMove ) then
				//multi position with no space available for a multi move.
				return;
			endif;
		endif;
	
	endif;

	tmpController := self.myDockBar.myDrawingController;
	if tmpController = null then
		app.raiseCMException1(MethodWithNullParam, 'ContainerDrawingController', null, null);
		return;
	endif;

	if (not tmpController.isSelectObjectsEnabled) then
		return;
	endif;

	if (not shift.isShiftKeyPressed) and  
	   (not shift.isControlKeyPressed) and 
	   (not shift.isAltKeyPressed) then // NO SHIFT, ALT or CONTROL

		if button = Button.MouseButton_Left then
			// clear existing selection
			tmpController.clearAllSelectedObjects();
			self.myStartObject := null;
			isSelect := true;
		endif;

	elseif shift.isShiftKeyPressed then // SHIFT
		if shift.isAltKeyPressed then // ALT
			isSelectAlt := true;
			isBlock := true;
		else
			isSelect := true;
			isBlock := true;
		endif;

	elseif shift.isControlKeyPressed then // CONTROL
		isControlKey := true;
		if shift.isAltKeyPressed then // ALT
			isSelectAlt := true;
		else
			isSelect := true;
		endif;

	elseif shift.isAltKeyPressed then // ALT
		if button = Button.MouseButton_Left then
			tmpController.clearAllSelectedObjectsAlt();
			isSelectAlt := true;
		elseif button = Button.MouseButton_Right then
			self.myStartObjectAlt := null;
		endif;
	endif;

	if (not (isSelect or isSelectAlt)) then
		return;
	endif;
	
		
	if isSelect and tmpController.allSelectedObjects.includes(theObject) then
		tmpController.allSelectedObjects.remove(theObject);
		if yardCells &lt;&gt; null and not yardCells.isEmpty then
			foreach yardCell in theObject.CM_YardController.allYAYardLocationCells do
				if tmpController.allSelectedObjects.includes(yardCell) then
					tmpController.allSelectedObjects.remove(yardCell);
				endif;
			endforeach;
		endif;
		self.drawObject(theObject, tmpController);
		return;
	elseif isSelectAlt and tmpController.allSelectedObjectsAlt.includes(theObject) then
		tmpController.allSelectedObjectsAlt.remove(theObject);
		if yardCells &lt;&gt; null and not yardCells.isEmpty then
			foreach yardCell in theObject.CM_YardController.allYAYardLocationCells do
				if tmpController.allSelectedObjectsAlt.includes(yardCell) then
					tmpController.allSelectedObjectsAlt.remove(yardCell);
				endif;
			endforeach;
		endif;
		self.drawObject(theObject, tmpController);
		return;
	endif;

	if isSelect then
		self.selecteObjectGridMultiMove(theObject, self.myStartObject, false);
		if yardCells &lt;&gt; null and not yardCells.isEmpty then
			foreach yardCell in yardCells do
				self.selecteObjectGridMultiMove(yardCell, self.myStartObject, false);
			endforeach;
		endif;
	endif;

epilog
	self.enableEvent("mouseMove", false);
	app.isDragging := false;
	delete yardCells;
end;</source>
        <Parameter name="_obj1" type="Object"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="handleMouseUpRoRo" id="07a444b3-12b3-4e37-976b-1c792337b747">
        <updating/>
        <source>handleMouseUpRoRo(_obj : Object; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		December 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theObj			: Object;
	tmpController	: YRD_RoRoLaneDrawingController;
	tmpObject		: Object;
	isOnDeck,
	isSelect,
	isSelectAlt,
	isSlotController,
	isControlKey,
	isBlock			: Boolean;
	tmpSlotController	: CM_SlotController;
	y1,y2, tiIndex,cellHeight,stackHeight : Integer;
	theTI : CM_TrackedItem;
begin

	if _obj = null then
		return;
	endif;

	tmpController := self.myDockBar.myRoRoLaneDrawingController;
	if tmpController = null then
		app.raiseCMException1(MethodWithNullParam, 'RoRoLaneDrawingController', null, null);
		return;
	endif;

	if (not tmpController.isSelectObjectsEnabled) then
		return;
	endif;

	if (not shift.isShiftKeyPressed) and  
	   (not shift.isControlKeyPressed) and 
	   (not shift.isAltKeyPressed) then // NO SHIFT, ALT or CONTROL

		if button = Button.MouseButton_Left then
			// clear existing selection
			tmpController.clearAllSelectedObjects();	// cnwjk3 PAR 22733 08/03/2010
			self.myStartObject := null;
			isSelect := true;
		endif;

	elseif shift.isShiftKeyPressed then // SHIFT
		if shift.isAltKeyPressed then // ALT
			isSelectAlt := true;
			isBlock := true;
		else
			isSelect := true;
			isBlock := true;
		endif;

	elseif shift.isControlKeyPressed then // CONTROL
		isControlKey := true;
		if shift.isAltKeyPressed then // ALT
			isSelectAlt := true;
		else
			isSelect := true;
		endif;

	elseif shift.isAltKeyPressed then // ALT
		if button = Button.MouseButton_Left then
			tmpController.clearAllSelectedObjectsAlt();
			isSelectAlt := true;
		elseif button = Button.MouseButton_Right then
			self.myStartObjectAlt := null;
		endif;
	endif;

	if (not (isSelect or isSelectAlt)) then
		return;
	endif;

	if isSelect and tmpController.allSelectedObjects.includes(_obj) then
	
		tmpController.allSelectedObjects.remove(_obj);
		self.drawObject(_obj, tmpController);		// cnwjk3 PAR 22733 08/03/2010
		return;
	elseif isSelectAlt and tmpController.allSelectedObjectsAlt.includes(_obj) then
		tmpController.allSelectedObjectsAlt.remove(_obj);
		self.drawObject(_obj, tmpController);
		return;
	endif;

	if isSelect then	
		if not _obj.isKindOf(CM_LocationsController) then // empty location, check for 40 backends
			self.selectObjectRoRo(_obj, self.myStartObject, false);
		endif;
	endif;

epilog
	self.enableEvent("mouseMove", false);
	app.isDragging := false;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
