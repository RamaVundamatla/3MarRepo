    <JadeMethod name="doOfferTasks" id="3f4c19f5-53d4-44a9-913e-e68c046fc52c">
        <updating/>
        <source>doOfferTasks(rtQueueEntry : CM_RTQueueEntry) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2010	cnwer1	Initial creation

*/

vars
	rtQueueTask : CM_RTQueueTask;
	vehicleMachine : CM_VehicleMachine;
	allRTQueueTasks	 : CM_RTQueueTaskArray;
	error : CM_Error;
begin
	self.initialiseForNewRequest(null);  //cnwjo3 par 24636
	
	if not app.isDevelopmentSystem then
		return;
	endif;
	
	if rtQueueEntry = null then
		return;
	endif;
	
	create allRTQueueTasks transient;
	if rtQueueEntry.myJob.isKindOf(CM_RoadJob) then
		foreach rtQueueTask in rtQueueEntry.allTasks discreteLock do
			if rtQueueTask.taskType &lt;&gt; TASK_PICKUP and rtQueueTask.taskType &lt;&gt; TASK_DIRECTOR and rtQueueTask.taskType &lt;&gt; TASK_MOVE then
				continue;
			endif;
			allRTQueueTasks.add(rtQueueTask);
		endforeach;
	else
			
		//check imvs 
		if rtQueueEntry.myNextRelatedEntry &lt;&gt; null then
			if  rtQueueEntry.myNextRelatedEntry.allTasks.first.machine = null then
				self.writeLog(method.name &amp; " - related tasks machine is null ");
				app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-- related tasks machine is null ');
				return;
			endif;
				
			allRTQueueTasks.add(rtQueueEntry.allTasks.first);
			self.writeLog(method.name &amp; "adding task " &amp; rtQueueEntry.allTasks.first.String);
		elseif rtQueueEntry.myPreviousRelatedEntry &lt;&gt; null then
			if  rtQueueEntry.myPreviousRelatedEntry.allTasks.first.machine = null then
				self.writeLog(method.name &amp; " - related tasks machine is null ");
				return;
			endif;
			
			allRTQueueTasks.add(rtQueueEntry.allTasks.first);
			self.writeLog(method.name &amp; "adding task " &amp; rtQueueEntry.allTasks.first.String);
			
		endif;
	endif;

	self.setMyWorkedVehicleMachine(vehicleMachine);
	if allRTQueueTasks.size &gt; 0 then
		self.writeLog(method.name &amp; " - changing to offered " &amp; allRTQueueTasks.size.String);

		app.myTrxRT.trxChangeAllTasksStatus(allRTQueueTasks,myMachine,TASK_OFFERED,app.myPassport);
		if not app.myPassport.trxCompletedOK then
			//create hand held errors
			foreach error in app.myPassport.allErrors do
				self.writeLog(method.name &amp; " - errors: " &amp; error.errorCode.String &amp; " " &amp;error.text);
			endforeach;
			return;
		else
			self.setRTGState(PICKINGUP);
		endif;
	endif;
epilog
	
	delete allRTQueueTasks;

end;</source>
        <Parameter name="rtQueueEntry" type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="doOfferTasksOfVM" id="181cd967-e395-4bbb-80ef-05e912570d0c">
        <updating/>
        <source>doOfferTasksOfVM(_rfidTag : CM_RFIDTag) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	rtQueueEntry : CM_RTQueueEntry;
	rtQueueTask : CM_RTQueueTask;
	allRTQueueTasks	 : CM_RTQueueTaskArray;
	error : CM_Error;
	vehicleMachine : CM_VehicleMachine;
	info		: DTO_VehicleMountedInfo;
begin
	self.initialiseForNewRequest(null);  //cnwjo3 par 24636
	
	if _rfidTag.myRoadJob &lt;&gt; null then
		vehicleMachine:=_rfidTag.myRoadJob.myVehicle;
	else
		vehicleMachine:=_rfidTag.myMachine;
	endif;
	create allRTQueueTasks transient;
	foreach rtQueueEntry  in self.myRTQueue.allEntries discreteLock do
		if rtQueueEntry.myJob = null then
			self.writeLog(method.name &amp; " -No job");
			continue;
		endif;
		
		//check the road jobs vehicles have other rt tasks we have to set to offered
		if rtQueueEntry.myJob.isKindOf(CM_RoadJob) then
			if rtQueueEntry.myJob.CM_RoadJob.myRFIDTag = _rfidTag  then
				foreach rtQueueTask in rtQueueEntry.allTasks discreteLock do
					if rtQueueTask.taskType &lt;&gt; TASK_PICKUP and rtQueueTask.taskType &lt;&gt; TASK_DIRECTOR and rtQueueTask.taskType &lt;&gt; TASK_MOVE then
						continue;
					endif;
					allRTQueueTasks.add(rtQueueTask);
				endforeach;
			endif;	
		else
			
			if _rfidTag.myMachine = null then
				self.writeLog(method.name &amp; " -No machine on rfidTag ");
				continue;
			endif;
			//check imvs 
			if rtQueueEntry.myNextRelatedEntry &lt;&gt; null then
				if  rtQueueEntry.myNextRelatedEntry.allTasks.first.machine = null then
					self.writeLog(method.name &amp; " - related tasks machine is null ");
					app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-- related tasks machine is null ');
					continue;
				elseif rtQueueEntry.myNextRelatedEntry.allTasks.first.machine  &lt;&gt; _rfidTag.myMachine then
					continue;
				endif;
				
				allRTQueueTasks.add(rtQueueEntry.allTasks.first);
				self.writeLog(method.name &amp; "adding task " &amp; rtQueueEntry.allTasks.first.String);
			elseif rtQueueEntry.myPreviousRelatedEntry &lt;&gt; null then
				if  rtQueueEntry.myPreviousRelatedEntry.allTasks.first.machine = null then
					self.writeLog(method.name &amp; " - related tasks machine is null ");
					continue;
				elseif rtQueueEntry.myPreviousRelatedEntry.allTasks.first.machine  &lt;&gt; _rfidTag.myMachine then
					continue;
				endif;
			
				allRTQueueTasks.add(rtQueueEntry.allTasks.first);
				self.writeLog(method.name &amp; "adding task " &amp; rtQueueEntry.allTasks.first.String);
			endif;
		endif;
	endforeach;

	
	setMyWorkedVehicleMachine(vehicleMachine);
	if allRTQueueTasks.size &gt; 0 then
		self.writeLog(method.name &amp; " - changing to offered " &amp; allRTQueueTasks.size.String);

		app.myTrxRT.trxChangeAllTasksStatus(allRTQueueTasks,myMachine,TASK_OFFERED,app.myPassport);
		if not app.myPassport.trxCompletedOK then
			//create hand held errors
			foreach error in app.myPassport.allErrors do
				self.writeLog(method.name &amp; " - errors: " &amp; error.errorCode.String &amp; " " &amp;error.text);
			endforeach;
			return;
		else
			self.setRTGState(PICKINGUP);
		endif;
	else
		create info transient;
		info.event := Event_RFIDInfo + Event_Factor;
		info.eventMessage :="No machines in RT Queue have the RFID Tag " &amp; _rfidTag.code;
		self.causeEvent(self.Event_Server_Note, true, info);
	
	endif;
epilog
	delete allRTQueueTasks;
end;</source>
        <Parameter name="_rfidTag" type="CM_RFIDTag"/>
    </JadeMethod>
    <JadeMethod name="doRFIDTagRead" id="b527525c-1c00-42c0-92e6-2d376a6ddd43">
        <source>doRFIDTagRead() ;
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 May 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	
begin


	if not self.hasRFIDReader() then
		self.writeLog(self.class.name &amp; "::" &amp; method.name  &amp; " machine does not have rfid tag reader");
		self.myRfidReaderConnection.causeEvent(Event_RFIDInfo,true,"Machine does not have rfid tag reader");
		return ;
	endif;
	
	self.writeLog(self.class.name &amp; "::" &amp; method.name  &amp; " calling myRfidReaderConnection.init");
	self.myRfidReaderConnection.init(self.myMachine.myRFIDTagReader);
	
	
end;</source>
    </JadeMethod>
