    <JadeMethod name="validateForCreate" id="a8acf841-da17-4511-8f6d-136fa770eb68">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     02/09/2008 by concms1
//
// Purpose:     user definable forms - CCMS 1011
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/12/2014 cnwdb2	PAR 35364 
// ---------------------------------------------------------------------------
vars
	config	:CM_FormConfigForm;
begin
	if self.formName = null then
//		app.raiseCMException1(REQUIRED_FIELD,'Form',null,null);
		app.raiseCMException(Input_required_field_form,null,null); // cnwdb2	PAR 35364
		return;
	endif;
	
	foreach config in CM_FormConfigForm.instances do
		if config.formName = self.formName and
			config.myTerminal = self.myTerminal then
			app.raiseCMException3 (ERR_DUPLICATE_KEY, self.formName, self.getTerminalNameDisplay, null, null, null);
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
</Class>
