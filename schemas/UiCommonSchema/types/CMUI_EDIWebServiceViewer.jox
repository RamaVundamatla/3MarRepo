    <JadeMethod name="translateForm" id="d62f5169-a225-41bf-88b9-326e1429d771">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 25 June 2020 09:08:44.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023747, locale);
	btnHideSearcher.translateBubbleHelp(Xlat_0023759, locale);
	btnHideSearcher.translateCaption(Xlat_0023748, locale);
	btnMonitoringOnOff.translateCaption(Xlat_0023749, locale);
	btnResetSearch.translateBubbleHelp(Xlat_0023760, locale);
	btnResetSearch.translateCaption(Xlat_0023750, locale);
	btnSearch.translateBubbleHelp(Xlat_0023761, locale);
	btnSearch.translateCaption(Xlat_0023751, locale);
	btnShowSearcher.translateBubbleHelp(Xlat_0023762, locale);
	btnShowSearcher.translateCaption(Xlat_0023752, locale);
	mnuTblClear.translateCaption(Xlat_0023947, locale);
	mnuTblStopProcessing.translateCaption(Xlat_0023753, locale);
	mnuTblViewContext.translateCaption(Xlat_0023754, locale);
	mnuTblViewEDIData.translateCaption(Xlat_0023755, locale);
	mnuTblViewRawEDIMessage.translateCaption(Xlat_0023756, locale);
	mnuTblViewRequest.translateCaption(Xlat_0023757, locale);
	mnuTblViewResponse.translateCaption(Xlat_0023758, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="ced67cc6-3b0c-4ea8-9d7d-ebcebd447534">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
18/06/2020		jlgmd1	49599 Refactor search to make it faster and less lock prone

*/

vars

begin
	// Unregister any notifications if we exit without turning off monitoring mode
	if self.frmMode = self.Monitoring_Mode then
		self.btnMonitoringOnOff_click(self.btnMonitoringOnOff);
	endif;
	
	inheritMethod();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="unregisterNotifications" id="3beae344-ada8-4e3c-858c-13f4b29955ff">
        <source>unregisterNotifications();
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 09 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	table 	: CM_DataTable;
	object	: Object;
	row		: Integer;
begin	
	endClassNotification(CM_EDIFile, false, Object_Create_Event);
	endClassNotification(CM_EDIFile, false, Object_Update_Event);
	
	table := self.tblLogInformation;
	row := table.fixedRows + 1;
	
	while row &lt;= table.rows do
		object := table.accessRow(row).itemObject;
		if object.isKindOf(CM_EDIFile) then
			endNotification(object.CM_EDIFile, self.myTerminal.getTerminalEvent(EventEDIProgress));
			endNotification(object.CM_EDIFile, self.myTerminal.getTerminalEvent(EventDBLoading));
		endif;		
	endwhile;	
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="7f786be5-3d4f-4dbe-be49-d586b9163bad">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 10 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	localEventType : Integer;
begin
	localEventType := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if localEventType = EventEDIProgress or localEventType = EventDBLoading then		
		if theObject.isKindOf(CM_EDIFile) then
			self.doUserNotifications(eventType, theObject, eventTag, userInfo);
		endif;	
	endif;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
