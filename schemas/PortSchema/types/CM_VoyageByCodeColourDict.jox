<CollClass name="CM_VoyageByCodeColourDict" id="32a84704-62d4-49b9-9057-cc3e7852de73">
    <memberType name="CM_Voyage"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <MemberKey>
        <property name="CM_Voyage::code"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_Voyage::colour"/>
    </MemberKey>
    <JadeMethod name="removeObject" id="5285abf8-446f-40f3-8e5b-8f6c58802092">
        <lockReceiver/>
        <updating/>
        <source>removeObject(_obj : MemberType) : Boolean updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     27 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter	: Iterator;
	tmpObj	: MemberType;
	keyCode	: String;
	keyNum	: Integer;
begin
	iter := self.createIterator();
	
	while iter.next(tmpObj) do
		if tmpObj = _obj then
			self.getIteratorKeys(keyCode, keyNum, iter);
			self.removeKey(keyCode, keyNum);
			return true;
		endif;
	endwhile;

	return false;

epilog
	delete iter;
end;</source>
        <Parameter name="_obj" type="MemberType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
