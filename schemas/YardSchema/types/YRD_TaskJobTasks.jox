    <JadeMethod name="cmbBillingAdjPeriod_click" id="cf9f5192-8a70-4cb9-add0-edbac9059dd4">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBillingAdjPeriod_click(combobox: ComboBox input) updating;
/*
Purpose:	TFS 42241		
Date				Who			Reason
NOVEMBER 2018		CNWAB1		Initial creation
*/

vars
	voyage : CM_Voyage;
	newStart, tmpTS : TimeStamp;
	period : Decimal[12,2];
	mins : Integer;
begin

	voyage := self.cmbVoyage.listObject.CM_Voyage;
	
	newStart := voyage.departedDT;
	
	period := combobox.listIndex * 0.25;
	
	mins := ((period * 24) * 60).Integer;
	mins := mins * -1;
	newStart := newStart.addMinutes(mins);
	tmpTS := self.systemToLocalTime(newStart);

	self.lblBillingAdjStart.caption := app.getErrorString1(Extension_start,tmpTS.asStringJMT());
	
	if self.myCurrentProxyTask &lt;&gt; null then
		self.myCurrentProxyTask.CM_WodBillingAdjustment.setPropertyValue("newFromDateTime", tmpTS);
		self.myCurrentProxyTask.CM_WodBillingAdjustment.setPropertyValue("newUnitsUsed", period.Real);
	endif;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
