    <JadeMethod name="delete" id="d625f794-4aa8-4728-9366-29c66b066cae">
        <updating/>
        <source>delete() updating;
/*
Purpose:			
Date		Who		Reason
02 July 2015	cnwab1	Initial creation
*/

vars

begin
	delete myDelayType;
	delete self.myDriver;
	delete self.myMachine;
	delete self.myVoyage;
	delete self.myWorkpoint;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyDelay" id="6676c1bd-e137-4ef4-8e95-12b52c227349">
        <source>setProxyDelay(_delay : CM_Delay input);
/*
Purpose:			
Date				Who			Reason
JUNE 2015		CNWAB1		Initial creation
*/

vars
	voyage : CM_Voyage;
	delaytype : CM_DelayType;
	machine : CM_Machine;
	user : CM_User;
	workpoint : CM_WorkPoint;
begin
	voyage := app.myPassport.myTerminal.allVoyagesByCode.getAtKeyGeq( self.myVoyage.code,null);
	if voyage &lt;&gt; null then
		if voyage.code &lt;&gt; self.myVoyage.code then
			voyage := null;
		endif;
	endif;
	delaytype := app.myRoot.allDelayTypes[self.myDelayType.description];
	machine := app.myPassport.myTerminal.machines[self.myMachine.id];
	user := app.myRoot.allUsers[self.myDriver.code];
	workpoint := app.myPassport.myTerminal.allWorkPointsByCode[self.myWorkpoint.code];

	//epr TFS 38396 26/5/18 issues with saving date/times when server has MM/dd/yyyy format
	_delay.setProxy(app.myPassport.myTerminal,
							voyage,
							delaytype, 
							self.startDT.asTimeStampFromWebInterface,
							self.endEstDT.asTimeStampFromWebInterface, 
							self.endDT.asTimeStampFromWebInterface,
							machine,
							user, 
							workpoint, 
							self.remarks);
	
epilog

end;</source>
        <Parameter name="_delay" type="CM_Delay" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="d78cd8d5-8e32-4e7c-952c-cd68c306abfd">
        <updating/>
        <source>setProxyFromObject(_delay : CM_Delay) updating;
/*
Purpose:			
Date		Who		Reason
11 June 2015	cnwab1	Initial creation
15 Aug 2016		cnwer1  TFS 2508 - includeVoyage don't always add  if starting from voyage to avoid circular references
*/

vars
	delaytype : WS_DelayType;
	user : WS_User;
	machine : WS_Machine;
	voyage : WS_Voyage;
	workpoint : WS_WorkPoint;
begin
	

	inheritMethod(_delay);
	
	//cnwmc5 - 11 Jan 2016 - PAR 37326
	if _delay.endDT.isValid then
		self.endDT := _delay.endDT.asStringForWebInterface;
	endif;
	//cnwmc5 - 11 Jan 2016 - PAR 37326
	if _delay.estEndDT.isValid then
		self.endEstDT  := _delay.estEndDT.asStringForWebInterface;
	endif;
	//cnwmc5 - 11 Jan 2016 - PAR 37326
	if _delay.startDT.isValid then
		self.startDT := _delay.startDT.asStringForWebInterface;
	endif;
	
	self.remarks := _delay.remarks;
	
	
	if _delay.myDelayType&lt;&gt; null then
		create delaytype transient;
		delaytype.setProxyFromObject(_delay.myDelayType);
		self.myDelayType  := delaytype;
	endif;
	
	if _delay.myDriver&lt;&gt; null then
		create user transient;
		user.setProxyFromObject(_delay.myDriver);
		self.myDriver  := user;
	endif;
	
	if _delay.myMachine &lt;&gt; null then
		create machine transient;
		machine.setProxyFromObject(_delay.myMachine);
		self.myMachine  := machine;
	endif;
	
	if _delay.myVoyage &lt;&gt; null then
		create voyage transient;
		voyage.setProxyFromObject(_delay.myVoyage);
		self.myVoyage  := voyage;
	endif;
	
	if _delay.myWorkPoint &lt;&gt; null then
		create workpoint transient;
		workpoint.setProxyFromObject(_delay.myWorkPoint);
		self.myWorkpoint  := workpoint;
	endif;

epilog

end;</source>
        <Parameter name="_delay" type="CM_Delay"/>
    </JadeMethod>
</Class>
