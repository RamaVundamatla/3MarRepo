		or entRowName = ETRow_Stops
		or entRowName = ETRow_SubTerminal
		or entRowName = ETRow_TodoTasks
		or entRowName = ETRow_TrailerType
		or entRowName = ETRow_Train
		or entRowName = ETRow_TranshipDischPort
		or entRowName = ETRow_TranshiptoPort
