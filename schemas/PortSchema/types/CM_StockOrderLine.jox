    <JadeMethod name="validateMe" id="279962dc-2a97-4c9f-80b1-9bd6d183ebba">
        <source>validateMe(_passport : CM_Passport input) protected;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.raiseExceptionIfNotTransient(method);
	
	if self.myStockOrderHeader = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Stock Order', 'orderHeader', null);
		app.raiseCMException(Input_required_field_stckOrder, 'orderHeader', null); // cnwdb2	PAR 35364
		return;
	endif;

	if self.dischargePort &lt;&gt; null then
		app.raiseCMException1(DischargePortSetOnOrderLine,
				self.myStockOrderHeader.orderNo, null, null);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
