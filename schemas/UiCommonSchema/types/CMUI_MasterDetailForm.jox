    <JadeMethod name="keyDown" id="f06ee65a-692e-46ee-bc99-417fd3c57dad">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     05 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if keyCode = CMUI_Key_F3 then
		if self.mode = self.Mode_New or 
		   self.mode = self.Mode_Edit then
			return;
		endif;
		
		self.zShowHideSearcher(not self.frmSearch.visible);
		return;
	elseif keyCode = CMUI_Key_Enter then
		if self.frmDetailEnt.visible then
			self.btnAddDetail.click(self.btnAddDetail);
			keyCode := null;
			return;
		elseif self.frmSearch.visible then 
			self.btnSearch.click(self.btnSearch);
			return;
		else
			self.btnSaveBase.click(self.btnSaveBase);
			return;
		endif;
	endif;
	
	if keyCode = CMUI_Key_F5 then
		// F5 does a refresh of the screen.
		self.doRefresh;
		return;
	endif;

	inheritMethod(keyCode, shift);

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
