    <JadeMethod name="doMatch" id="ac3ca7a7-a53c-49c1-8363-a696f0eb3127">
        <source>doMatch(_value: Integer): Boolean;
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	return _value &lt; searchValue;


end;</source>
