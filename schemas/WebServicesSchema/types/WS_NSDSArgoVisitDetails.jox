    <JadeMethod name="setFromOpsViewTable" id="e2b5d850-8d3d-45c5-a057-8abf9a8ca392">
        <updating/>
        <source>setFromOpsViewTable(_detail : CMIF_ArgoVisitDetails; _seq : Integer io) updating;
/*
Purpose:			

Date		Who		Reason
09 December 2021	navab1	TFS 51853
*/

vars
	seq : Integer;
begin
	inheritMethod(_detail, _seq);
	
	self.tableName := _detail.tableName;
	self.gkey := _detail.gkey;
	self.eta := _detail.eta;
	self.etd := _detail.etd;
	self.service := _detail.service;

	if _detail.vslVesselVisitDetails &lt;&gt; null then // ### TFS 51855 06JAN2022 NAVAB1 only used for voyages, not trains
		create self.vslVesselVisitDetails transient;
		self.vslVesselVisitDetails.setFromOpsViewTable(_detail.vslVesselVisitDetails, seq);
	endif;

epilog

end;</source>
        <Parameter name="_detail" type="CMIF_ArgoVisitDetails"/>
        <Parameter name="_seq" type="Integer" usage="io"/>
    </JadeMethod>
