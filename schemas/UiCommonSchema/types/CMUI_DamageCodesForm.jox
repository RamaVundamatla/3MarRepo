    <JadeMethod name="setupForm" id="d219774e-31c0-46ed-9d2a-d3519c2e2f08">
        <updating/>
        <source>setupForm() updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 28 April 2009
//
// Implemented version:
// 
/* Changes

Date		Name	TFS#	Description
============================================================================
09/05/2019	jlgka1	44287	Set the minimumHeight and minimumWidth for resizing.
============================================================================*/
vars
	tbl : CM_Table;
	notReadOnly : Boolean;
begin
	notReadOnly := (self.mode = Mode_Add) or (self.mode = Mode_Update);
	
	inheritMethod();
	
	//epr par 31845 24/10/13	
	if self.myParentForm.class.implementsInterface(IF_DamageDetails) then
		self.myDamageInterface:=self.myParentForm.IF_DamageDetails;
	endif;
	// jlgka1 TFS 44287 --&gt;
	self.minimumHeight := 470;
	self.minimumWidth := 460;
	// jlgka1 TFS 44287 &lt;--
	
	self.handleMenusForModalDisplay();	
	self.initCombos();
	self.initDamageTable();
	self.btnUpdate.enabled := false;
	self.btnRemove.enabled := false;
	
	self.loadDamageItems();
	
	
	self.btnAdd.enabled := notReadOnly;
	
	self.cmbDamage.enabled := notReadOnly;
	self.cmbPosition.enabled := notReadOnly;
	self.cmbSeverity.enabled := notReadOnly;
	self.txtQuantity.enabled := notReadOnly;
	self.optNo.enabled := notReadOnly;
	self.optYes.enabled := notReadOnly;
	self.optYes.value := true;
	self.txtRemarks.enabled := notReadOnly;
	self.chkRepaired.enabled := notReadOnly; //+ cnwmd1 Par 23522
	
	//+ cnwmd1 Par 23522 - Allow for view only
	if self.mode = Mode_View then
		self.btnOk.visible := false;
		self.btnCancel.caption := app.getErrorString(Close);
	else
		self.btnOk.visible := true;
		self.btnCancel.caption := app.getErrorString(Cancel);
		if self.mode = Mode_Update then
			self.btnOk.caption := app.getErrorString(CM_OK);
		else
			self.btnOk.caption := app.getErrorString(SAVE_THAT_LADY_YO);
		endif;
	endif;
	
	if self.myProxyMasterItem.isKindOf(CM_Bulk) then
		self.lblQuantity.visible:=false;
		self.txtQuantity.visible:=false;
	endif;
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.frmControls.enabled:= false;
	endif;
	
	
epilog
end;</source>
    </JadeMethod>
