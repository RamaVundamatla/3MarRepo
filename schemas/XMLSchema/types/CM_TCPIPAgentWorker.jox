    </JadeMethod>
    <JadeMethod name="xHandleNull" id="5bda5751-789c-4ff5-9c3e-a50a791d1149">
        <source>xHandleNull(_exObj : SystemException; _errString : String output; _errNumber : Integer output) : Integer;
// -----------------------------------------------------------------------------
// Created:		12 August 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin

	if _exObj.errorCode = 1090 then
		_errNumber := Err_ParsingSession;
		_errString := app.getErrorString(Err_ParsingSession);
		return Ex_Resume_Next;
	endif;
	return Ex_Pass_Back;
end;</source>
        <Parameter name="_exObj" type="SystemException"/>
        <Parameter name="_errString" type="String" usage="output"/>
        <Parameter name="_errNumber" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
