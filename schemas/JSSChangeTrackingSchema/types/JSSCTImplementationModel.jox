    </JadeMethod>
    <JadeMethod name="tryShareLockingObject" id="4d53475b-744c-4f30-b28f-1e66bb2cb150">
        <source>tryShareLockingObject(pObject: Object): Boolean;
/*
	Try to get a lock on the Object, or return false after trying 10,000 times
*/
vars
	count: Integer;
begin
	return (self.tryLock(pObject, Share_Lock, Transaction_Duration, 60000));
