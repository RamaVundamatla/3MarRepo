    </JadeMethod>
    <JadeMethod name="isCoveredOnXMLImport" id="7b7856f9-4b8a-4fae-bc02-deac26283e25">
        <updating/>
        <source>isCoveredOnXMLImport(_allItems : CM_RORODeckItemLayoutArray input; _allCoveredCodes : StringArray input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2013	cnwmc5	Initial creation

*/

vars
	itemLayout : CM_DeckItemLayout;
	itemPoints, contPoints : PointArray;
	x1, y1, x2, y2 : Integer;

begin
	contPoints := self.myPolygonPixels;

	foreach itemLayout in _allItems do	
		if itemLayout.type &lt;&gt; self.type then
			continue;
		endif;
		
		itemPoints := itemLayout.myPolygonPixels;
		
		itemLayout.getExtremePoints(x1, y1, x2, y2);
	
		// Performance - IGNORE the container rectangles that are outside of the poly limits. 
		// The limits are a rectangle that the polygon fits in.
		if contPoints[1].x &gt; x2  // CONT x1 &gt; item x2
		or contPoints[2].x &lt; x1  // CONT x2 &lt; item x1
		or contPoints[1].y &gt; y2  // CONT y1 &gt; item y2
		or contPoints[2].y &lt; y1  // CONT y2 &lt; item y1
		then
			continue;
		endif;
	
		//Better detection of polygon intersection
		if itemPoints.intersectsPolygon(contPoints, false) then
			//an item is covered, add it to the error list
			if not _allCoveredCodes.includes(self.code) then
				_allCoveredCodes.add(self.code);
			endif;
			if not _allCoveredCodes.includes(itemLayout.code) then
				_allCoveredCodes.add(itemLayout.code);
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_allItems" type="CM_RORODeckItemLayoutArray" usage="input"/>
        <Parameter name="_allCoveredCodes" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isCovering" id="4a464e34-e90e-4e90-b22e-965557cbf547">
        <source>isCovering(_type : Integer) : Boolean;
/*
Purpose:			
Date		Who		Reason
07 September 2012	cnwab1	Initial creation
*/

vars
	deckItemlayout : CM_Graphic;
begin
	foreach deckItemlayout in self.allCoveredPolygons discreteLock do
		if deckItemlayout.CM_DeckItemLayout.type = _type then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
