Date		Who		Reason
08 January 2016	cnwndl1	Initial creation Par 37288

*/

vars
	xmlBlock : String;
	
begin
	xmlBlock :=
'&lt;CM_EDIFileTypeUser&gt;
&lt;CM_EDIFileTypeUserAttributes&gt;
