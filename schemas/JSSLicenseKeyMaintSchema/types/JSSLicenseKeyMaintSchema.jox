<Class name="JSSLicenseKeyMaintSchema" id="4af473d0-d9d5-4c6f-8e24-b6668052a453">
    <superclass name="JSSExtensionSchema"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="myRoot" id="d658bd8d-1186-445c-bfd7-6806b218a561">
        <embedded/>
        <type name="JSSLKProductRoot"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTA" id="20bf6b1b-7edf-4f69-b195-506f8f6157df">
        <embedded/>
        <type name="TransactionAgent"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="doImportGlobalConstants" id="cf821130-426c-419b-94ef-67b777e1ea02">
        <source>doImportGlobalConstants(pAllImportConstants:JSSLKImportConstantArray; pIsUpdateExisting:Boolean);
// --------------------------------------------------------------------------------
// Created:		23 January 2003 by cnwdad2
//
// Purpose:		Imports one or more Global Constants (from an application schema),
//				and creates Product Components for each one.  Optionally, any
//				Components already existing with a Global Constant Id can be
//				updated.
//
// Parameters:	pAllImportConstants - An array of Global Constant/Product pairs.
//				pIsUpdateExisting - If true, existing Components (with an Id that
//				matches a Global Constant value) will be updated.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.myTA.trxImportConstants(pAllImportConstants, pIsUpdateExisting);
end;</source>
        <Parameter name="pAllImportConstants" type="JSSLKImportConstantArray"/>
        <Parameter name="pIsUpdateExisting" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="finalize" id="81c6b8f3-2ed7-4497-ac6c-09d49b97e737">
        <updating/>
        <source>finalize() updating;
// --------------------------------------------------------------------------------
// Created:		21 March 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	delete self.myTA;
	
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="initialize" id="b190ffd6-2727-438b-a0c4-1faa9e7df71a">
        <updating/>
        <source>initialize() updating;
// --------------------------------------------------------------------------------
// Created:		21 March 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theRoot		: JSSLKProductRoot;
	
begin
	on Exception do self.xHandlerGlobal(exception) global;
//	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);

	inheritMethod();
	
	theRoot	:=	JSSLKProductRoot.firstInstance();
	
	if theRoot = null then
		beginTransaction;
		create theRoot;
		commitTransaction;
	endif;
	
	self.myRoot	:=	theRoot;
	
	create self.myTA transient;
end;</source>
    </JadeMethod>
    <JadeMethod name="isConstantImported" id="f6400a82-4302-4791-a011-86fa367330a8">
        <source>isConstantImported(pTheConstant:Constant):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		03 April 2003 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the specified Global
//				Constant should be used when importing it from anothr schema.
//
//				This method will always return true - it is provided so that it may
//				be reimplemented in a subschema should that be necessary.
//
// Parameters:	pTheConstant - THe Global Constant to import.
//
// Returns:		This implementation of the method always returns true.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="pTheConstant" type="Constant"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xHandlerGlobal" id="21bbcaef-640e-4e3a-8299-7a13cd4d5f13">
        <source>xHandlerGlobal(pTheException:Exception):Integer;
// --------------------------------------------------------------------------------
// Created:		21 March 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;
	
begin
	if pTheException.isError() then
		abortTransaction;
		errorMessage	:=	pTheException.errorItem;
		app.msgBox(errorMessage, "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		
		return Ex_Abort_Action;
	else
		return Ex_Pass_Back;
	endif;
end;</source>
        <Parameter name="pTheException" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
