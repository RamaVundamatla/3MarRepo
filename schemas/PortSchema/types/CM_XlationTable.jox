    <JadeMethod name="erase" id="2658243e-51d4-43b5-b921-7e26e3ad2c2c">
        <updating/>
        <source>erase(_eraseLevel:Integer) updating;
// ---------------------------------------------------------------------------
// Created:     02 July 2003 by cnwrs1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13/03/2013	cnwcs5		CCMS POL 2097 / par 31259				
// 03/07/2013	cnwcs5		par 31261 - no need to delete translations as there is a parent-child relationship			
// ---------------------------------------------------------------------------

vars
	xlation	:CM_Xlation;
	opTerm	:CM_OperatorTerminal;
begin
	self.exclusiveLock(self);
	
	if self.isTransient then
		opTerm := self.myOperatorTerminal;
		
		if opTerm.isTransient then
			opTerm.erase (_eraseLevel);
		endif;
	endif;
	
	inheritMethod(_eraseLevel);
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="b145d0c7-c0fd-427f-9afb-429dcb45800b">
        <source>getDisplayDetails(_short: Boolean): String;
//
//19 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
//
vars

begin
	if getMyOperator &lt;&gt; null then
		if getMyCargoType &lt;&gt; null then
			return getTypeString(_short)&amp;' '&amp;getMyOperator.code&amp;' '&amp;getMyCargoType.abbreviation&amp;' '&amp;self.allInwardTranslations.size.String&amp;' '&amp;self.allOutwardTranslations.size.String;
		else
			return getTypeString(_short)&amp;' '&amp;getMyOperator.code;
		endif;
	else
		return getTypeString(_short);
	endif;
end;
</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyCargoType" id="16d2e7a0-189c-488f-ada1-e09a5560143c">
        <source>getMyCargoType() : CM_CargoBOLType;
//
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
//
vars

begin
	if self.myCargoType &lt;&gt; null then
		return self.myCargoType;
	endif;
end;
</source>
        <ReturnType type="CM_CargoBOLType"/>
    </JadeMethod>
    <JadeMethod name="getMyOperator" id="8d420472-e51a-4a45-bb6e-238e8e03cd70">
        <source>getMyOperator() : CM_Operator;
//
// Par 18029 cmsrs1 Feb 2009
//
vars
	operator	: CM_Operator;
	opTerm		: CM_OperatorTerminal;
begin
	operator := self.myOperator;
	
	if operator = null then
		opTerm := self.myOperatorTerminal;
		
		if opTerm &lt;&gt; null then
			operator := opTerm.myOperator;
		endif;
	endif;
	
	return operator;
end;
</source>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="48e829e1-3e0f-4824-8a1e-63de0054a9c5">
        <source>getMyTerminal():CM_Terminal;
/*
Date		Who		Reason
12 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	opTerm		: CM_OperatorTerminal;
begin
	opTerm := self.myOperatorTerminal;
	
	if opTerm &lt;&gt; null then
		return opTerm.myTerminal;
	endif;
	
	return self.myTerminal; //epr TFS 42095 22/11/18
epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getTypeString" id="60cfeef9-6bb4-46e6-811f-a14e90d13b9c">
        <source>getTypeString(_short :Boolean):String;
/* Changes

Date		Name	TFS#		Description
============================================================================
11 Mar 2013	cnwcs5	Initial Creation - CCMS PNL 2243 / par 31185 
01 Jun 2013	cnwrs1	JMT821 cut, upgrade failing in Xlation conversion
15 Jul 2014	Par 34567	CCMS 2346 add EDI Xlation for Cargo Type and Cargo Sub Type
21 Mar 2017	cnwdap1	TFS 3734 AAT Vehicle make translation type
07 Jun 2023	jlika1	TFS 58320 58319 | Jade work for Translations
08 Jun 2023	navpw1	TFS: 57813 (58438) - Added sorting method to if statement
12 Jun 2023	jlizm1	TFS 58500 add EDI Xlation for Operational Instruction and trailer type
08 Nov 2023	jlika1	TFS 61129 61013 CUX | Cargo Priority - EDI Translation
============================================================================*/

vars
	code	:String;
	type	:Integer;
begin
	type := self.type;
	// by Operator
	if type = XLATION_TYPE_CUSTPRIORITY_BYOP then				
		code := app.getErrorString(CustomerPriority);		
	elseif type = XLATION_TYPE_CARGOSUBTYPE_BYOP then
		code := app.getErrorString(Product);
	elseif type = XLATION_TYPE_CARGOTYPE_BYOP then
		code := app.getErrorString(CargoType);
	elseif type = XLATION_TYPE_CARRIER_BYOP then
		code := app.getErrorString (Carriers);
	elseif type = XLATION_TYPE_COMMODITY_BYOP then
		code := app.getErrorString (Commodities);
	elseif type = XLATION_TYPE_CONSIGNEE_BYOP then
		code := app.getErrorString (Consignee_Consignors);
	elseif type = XLATION_TYPE_ISOTYPE_BYOP then
		code := app.getErrorString (ISOTypes);
	elseif type = XLATION_TYPE_MTGRADE_BYOP then
		code := app.getErrorString (Availability_Grades);
	elseif type = XLATION_TYPE_OPERATOR_BYOP then  
		code := app.getErrorString (Operators);	
	elseif type = XLATION_TYPE_PORT_BYOP then
		code := app.getErrorString (Ports);
	elseif type = XLATION_TYPE_TERMINAL_BYOP then
		code := app.getErrorString (Terminals);
	elseif type = XLATION_TYPE_VESSEL_BYOP then
		code := app.getErrorString (Vessels);
	// ### TFS 57813 (58438) 07Jun2023 NAVPW1
	elseif type = XLATION_TYPE_SORTINGMETHD_BYOP then
		code := app.getErrorString(SortingMethod);
	// ### TFS 57813 (58438) 07Jun2023 NAVPW1	
	endif;
	if code &lt;&gt; null then
		if _short then
			return code;
		else
			return self.myOperator.code &amp; ' - ' &amp; code;
		endif;
	endif;
	
	// system coded
	if type = XLATION_TYPE_CUSTOMSAGENT then
		code := app.getErrorString (Customs_Agents);
	elseif 	type = XLATION_TYPE_OPERATOR then
		code := app.getErrorString (Operators);
	elseif type = XLATION_TYPE_SHIPINGAGENT_BYOP then
		code := app.getErrorString (Shipping_Agent);
	elseif type = XLATION_TYPE_SHIPPINGLINE then
		code := app.getErrorString (Shipping_lines);
	elseif type = XLATION_TYPE_SHIPPINGLINE_BYOP then
		code := app.getErrorString (Shipping_lines);
	elseif type = XLATION_TYPE_TRAILER_TYPE then
		code := app.getErrorString(Trailer_Type);
	elseif type = XLATION_TYPE_VESSEL then
		code := app.getErrorString (Vessels);
	elseif type = XLATION_TYPE_VESSEL_TYPE then	//11 Sep 2018	NDL	TFS 40778
		code := app.getErrorString (VesselType);
	elseif type = XLATION_TYPE_VEHICLE_MAKE then				// TFS 3734
		code := app.getErrorString(Vehicle_make);				// TFS 3734			
	endif;
	if code &lt;&gt; null then
		return app.getErrorString1(System_Hyphen, code);
	endif;
	
	//voyage by terminal
	if type = XLATION_TYPE_VOYAGETERMINAL then
		code := app.getErrorString (Voyages);
		if _short then
			return code;
		else
			if self.myOperatorTerminal &lt;&gt; null then
				return self.myOperatorTerminal.myOperator.code &amp; " - " &amp; code;
			else
				return code;
			endif;
		endif;
	elseif type = XLATION_TYPE_COUNTRYTERMINAL then //jlier1 TFS 54846 11/10/22
		code := app.getErrorString (Country);
		if _short then
			return code;
		else
			if self.myOperatorTerminal &lt;&gt; null then
				return self.myOperatorTerminal.myOperator.code &amp; " - " &amp; code;
			else
				return code;
			endif;
		endif;
	elseif type = XLATION_TYPE_INSTRUCTTERMINAL then
		code := app.getErrorString(Instruction_types);
		if _short then
			return  code;
		else
			if self.myOperatorTerminal &lt;&gt; null then
				return self.myOperatorTerminal.myOperator.code &amp; " - " &amp; code;
			else
				return code;
			endif;
		endif;
	elseif type = XLATION_TYPE_OPERATOR_BYTERM then								//TFS 63842
		code := app.getErrorString(Operators);									//TFS 63842
		if _short then															//TFS 63842
			return  code;														//TFS 63842
		else																	//TFS 63842
			if self.myOperatorTerminal &lt;&gt; null then								//TFS 63842
				return self.myOperatorTerminal.myOperator.code &amp; " - " &amp; code;	//TFS 63842
			else																//TFS 63842
				return code;													//TFS 63842
			endif;																//TFS 63842
		endif;																	//TFS 63842
	endif;																		//TFS 63842
	
epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasXlation" id="dfeb2547-0ed0-4648-8813-fb6009537b5c">
        <source>hasXlation(_xlation: CM_Xlation): Boolean;
//----------------------------------------------------------------
//	Created:	22 March 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 03/04/2013	cnwcs5`	CCMS POL 2097 / par 31259 - xlation criteria
vars
	xlation		: CM_Xlation;
begin
	if _xlation.isKindOf (CM_Xlation_In) then 
		foreach xlation in self.allInwardTranslations where xlation.foreignCode = _xlation.foreignCode do
			if xlation.isSameAs (_xlation) then
				return true;
			endif;
		endforeach;
		
		return false;
	else
		// can only have one outward xlation per system code
		return self.allOutwardTranslations[_xlation.systemCode] &lt;&gt; null;
	endif;
end;</source>
        <Parameter name="_xlation" type="CM_Xlation"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOperatorTerminalXlation" id="b8249794-7412-452b-9f09-2d2770065f6d">
        <options>4</options>
        <source>isOperatorTerminalXlation(_type : Integer) : Boolean typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
05 October 2022	jlier1	Initial creation 54846
12 June 2023	jlizm1	TFS 58500 add EDI Xlation for Operational Instruction and trailer type
29 Aug  2024    navsp1  TFS ChangeRequest 63842: NSW | OnePort Integration Dev
*/

vars

begin
	return _type = XLATION_TYPE_COUNTRYTERMINAL or
			_type = XLATION_TYPE_INSTRUCTTERMINAL or
			_type = XLATION_TYPE_VOYAGETERMINAL or
			_type = XLATION_TYPE_OPERATOR_BYTERM;		//TFS 63842
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSystemXlation" id="c0bb0cd1-b8fb-4af2-be69-28a2b7d0cacb">
        <options>4</options>
        <source>isSystemXlation(_type : Integer)  : Boolean typeMethod;
/*

Purpose:				

Parameters:			

Return Value:		

Date				Who		Reason
30 September 2022	jlier1	Initial creation 54846
12 June 2023		jlizm1	TFS 58500 add EDI Xlation for Operational Instruction and trailer type

*/

vars

begin
	return _type = XLATION_TYPE_CUSTOMSAGENT or 
			_type = XLATION_TYPE_OPERATOR or
			_type = XLATION_TYPE_SHIPPINGLINE or
			_type = XLATION_TYPE_TRAILER_TYPE or
			_type = XLATION_TYPE_VESSEL or
			_type = XLATION_TYPE_VESSEL_TYPE or	//11 Sep 2018	NDL	TFS 40778
			_type = XLATION_TYPE_VEHICLE_MAKE; 
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
