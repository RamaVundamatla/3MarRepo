    <JadeMethod name="utlCreateStowageConfirmTrans" id="b6d664ce-898c-43d5-8eef-5560658396a3">
        <updating/>
        <source>utlCreateStowageConfirmTrans(	_stowageConfirmController : CMIF_StowageConfirmController input; 
								_newTITransaction:CM_TITransaction output;
								_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 November 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	ti 						: CM_TrackedItem;
	job						: CM_VoyageJob;
	stowageConfirmation 	: CM_StowageConfirmation;
	isLoad					: Boolean;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(false);

	ti:= _stowageConfirmController.myTrackedItem;
	job:=_stowageConfirmController.myVoyageJob;
	if job = null then
		isLoad := _stowageConfirmController.isLoad;	//02 Mar 2016	NDL	TFS 1593
	else
		isLoad:= not job.isDischarge;
	endif;
	stowageConfirmation := ti.getLastStowageConfirmForJob(job, isLoad);
	
	if stowageConfirmation &lt;&gt; null
	and job &lt;&gt; null		//02 Mar 2016	NDL	TFS 1593
	then
		
		if not isLoad or stowageConfirmation.confirmedLocation.trimBlanks = _stowageConfirmController.confirmedLocation.trimBlanks then
			// edit the existing stowage confirmation transaction
			app.myUtilityUA.utlUpdateTITransaction(_stowageConfirmController,stowageConfirmation,_passport);
		else
			//create a new stowage confirmation transaction		
			app.myUtilityCA.utlCreateTITransaction(_stowageConfirmController, _newTITransaction, _passport);
		endif;
	else
		// Perform the operation
		app.myUtilityCA.utlCreateTITransaction(_stowageConfirmController, _newTITransaction, _passport);
	endif;
	
epilog

end;</source>
        <Parameter name="_stowageConfirmController" type="CMIF_StowageConfirmController" usage="input"/>
        <Parameter name="_newTITransaction" type="CM_TITransaction" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateSubBlockStack" id="42489f6e-9218-4d71-979d-e3848688a9b9">
        <updating/>
        <source>utlCreateSubBlockStack(_theGridTARegion : CMIF_GridTARegion input;_theRealSubBlock : CM_SubBlockStack output; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aTA : CM_TerminalArea;

begin

	self.initialiseActivity();

	if _theGridTARegion = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CMIF_GridTARegion.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);
	app.myValUA.valSubBlockStack(_theGridTARegion, _passport); 
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	if _passport.noErrors then
		_theGridTARegion.myGridArea.convStackToSubBlock(_theGridTARegion,_theRealSubBlock, _passport); // CREATE IT
		
		aTA := _theRealSubBlock.myParent;
		aTA.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),false,aTA);
		aTA.causeEvent(aTA.myTerminal.getTerminalEvent(Event_TALocation_Create),false,_theRealSubBlock);
	endif;
end;</source>
        <Parameter name="_theGridTARegion" type="CMIF_GridTARegion" usage="input"/>
        <Parameter name="_theRealSubBlock" type="CM_SubBlockStack" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
