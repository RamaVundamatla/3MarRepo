    <JadeMethod name="handleTempRange" id="6bfe9445-fc13-4931-94a8-0abb2f817afa">
        <source>handleTempRange(_value: Real; _code : String output; _color :Integer output; _object : Object output) protected;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter		: Iterator;
	theCode		: String;
	valueKey	: Real;
	theColor,
	colorKey	: Integer;
	tmpRange	: CM_TempRange;
	theObject : Object;
begin

	iter := self.myIterTempRange;
	self.allTempRanges.startKeyGeq(_value, 0, iter);
	self.allTempRanges.getIteratorKeys(valueKey, colorKey, iter);
	
	theCode		:= null;
	theColor	:= NullColour;
	if valueKey = _value then
		// found the right one
		theCode		:= valueKey.String;
		theColor	:= colorKey;
		iter.next(theObject);
	else
		tmpRange := self.myRoot.getColourFromTempRange(_value);
//		tmpRange := self.myRoot.allTempRanges[_value];
		if tmpRange &lt;&gt; null then
			if not self.allTempRanges.includes(tmpRange) then
				self.allTempRanges.add(tmpRange);
				self.beginNotification(tmpRange, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
			endif;
			theCode		:= _value.String;
			theColor	:= tmpRange.colour;
			theObject := tmpRange;
		endif;
	endif;

	_code	:= theCode;
	_color	:= theColor;
	_object := theObject;

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="Real"/>
        <Parameter name="_code" type="String" usage="output"/>
        <Parameter name="_color" type="Integer" usage="output"/>
        <Parameter name="_object" type="Object" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleTempRange2" id="b3630b0d-4df5-4728-86e0-01a7ac76236b">
        <source>handleTempRange2(_value: Real; _codesStr, _colourStr, _objStr : String io);
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theCode		: String;
	theColour	: Integer;
	theObject : Object;

begin
	if _value = NULL_TEMPERATURE then
		theCode := "Null";
		theColour := NullColour;
	else
		self.handleTempRange(_value, theCode, theColour,theObject);
	endif;

	_codesStr := _codesStr &amp; theCode &amp; GridData_SubDelimiter;
	_colourStr	:= _colourStr &amp; theColour.String &amp; GridData_SubDelimiter;
//	_objStr := _objStr &amp; GridData_SubDelimiter;
	_objStr	:= _objStr &amp; self.getOidStringForObject(theObject) &amp; GridData_SubDelimiter;
end;</source>
        <Parameter name="_value" type="Real"/>
        <Parameter name="_codesStr" type="String" usage="io"/>
        <Parameter name="_colourStr" type="String" usage="io"/>
        <Parameter name="_objStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="handleTempRangeObj" id="bc1c3fc1-72d2-4284-af08-d3e206fd2608">
        <source>handleTempRangeObj(_value: Real; _codesArray : StringArray input; _colorArray :IntegerArray input;_objArray : ObjectArray input);
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter		: Iterator;
	theCode		: String;
	valueKey	: Real;
	theColor,
	colorKey	: Integer;
	tmpRange	: CM_TempRange;

begin

	iter := self.myIterTempRange;
	self.allTempRanges.startKeyGeq(_value, 0, iter);
	self.allTempRanges.getIteratorKeys(valueKey, colorKey, iter);
	
	theCode		:= null;
	theColor	:= NullColour;
	if valueKey = _value then
		// found the right one
		theCode		:= valueKey.String;
		theColor	:= colorKey;
	else
		tmpRange := self.myRoot.getColourFromTempRange(_value);
//		tmpRange := self.myRoot.allTempRanges[_value];
		if tmpRange &lt;&gt; null then
			if not self.allTempRanges.includes(tmpRange) then
				self.allTempRanges.add(tmpRange);
			endif;
			theCode		:= _value.String;
			theColor	:= tmpRange.colour;
		endif;
	endif;

	_codesArray.atPut(TI_ColourMode_Temperature, theCode);
	_colorArray.atPut(TI_ColourMode_Temperature, theColor);
	_objArray.atPut(TI_ColourMode_Temperature, tmpRange);

end;</source>
        <Parameter name="_value" type="Real"/>
        <Parameter name="_codesArray" type="StringArray" usage="input"/>
        <Parameter name="_colorArray" type="IntegerArray" usage="input"/>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleTempRangeXML" id="d8fc41e4-b237-47c0-b469-2ef40ccb4142">
        <source>handleTempRangeXML(_value: Real) : String;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theCode		: String;
	theColour	: Integer;
	theObject : Object;

begin

	self.handleTempRange(_value, theCode, theColour,theObject);
	return self.formatForXML(TI_ColourMode_Temperature, theCode, theColour,theObject);

end;</source>
        <Parameter name="_value" type="Real"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleTrain" id="bdf1ebf2-7ac8-4ee7-95d1-bc192a140041">
        <source>handleTrain(_train : CM_Train; _code : String output; _color :Integer output; _object : Object output) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 Jun 2009	consw1	PAR 19913 - SFW1067 Rail Simplifications

*/

vars
	iter		: Iterator;
	trimCode,
	theCode,
	codeKey		: String;
	theColor,
	colorKey	: Integer;
	theObject : Object;
begin

	if _train = null then
		_code 	:= null;
		_color	:= NullColour;
		return;
	endif;
	
	trimCode := _train.code.trimBlanks;

	iter := self.myIterTrain;
	self.allTrains.startKeyGeq(trimCode, 0, iter);
	self.allTrains.getIteratorKeys(codeKey, colorKey, iter);

	if codeKey = trimCode then
		// found the right one
		theCode		:= trimCode;
		theColor	:= colorKey;
		iter.next(theObject);
	else
		self.allTrains.add(_train);
		self.beginNotification(_train, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
		theCode		:= trimCode;
		theColor	:= _train.colour;
	endif;

	_code	:= theCode;
	_color	:= theColor;
	_object := _train;

end;</source>
        <access>protected</access>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_code" type="String" usage="output"/>
        <Parameter name="_color" type="Integer" usage="output"/>
        <Parameter name="_object" type="Object" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleTrainObj" id="8cb87915-ade0-4089-bd1a-f966efb0afc8">
        <source>handleTrainObj(_train : CM_Train; _codesArray : StringArray input; _colorArray :IntegerArray input;_objArray : ObjectArray input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 Jun 2009	consw1	Initial creation

*/

vars
	iter		: Iterator;
	trimCode,
	theCode,
	codeKey		: String;
	theColor,
	colorKey	: Integer;

begin

	if _train = null then
		return;
	endif;
	
	trimCode := _train.code.trimBlanks;

	iter := self.myIterTrain;
	self.allTrains.startKeyGeq(trimCode, 0, iter);
	self.allTrains.getIteratorKeys(codeKey, colorKey, iter);

	if codeKey = trimCode then
		// found the right one
		theCode		:= trimCode;
		theColor	:= colorKey;
	else
		self.allTrains.add(_train);
		theCode		:= trimCode;
		theColor	:= _train.colour;
	endif;

	_codesArray.atPut(TI_ColourMode_LoadPort, theCode);
	_colorArray.atPut(TI_ColourMode_LoadPort, theColor);
	_objArray.atPut(TI_ColourMode_LoadPort, _train);

end;</source>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_codesArray" type="StringArray" usage="input"/>
        <Parameter name="_colorArray" type="IntegerArray" usage="input"/>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleVoyage" id="889a029a-6bae-4ef3-96ee-838620f061cd">
        <source>handleVoyage(_voyageCode : String; _voyage : CM_Voyage; _viewModeCode : String; _code : String output; _color :Integer output; _object : Object output) protected;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter		: Iterator;
	trimCode,
	theCode,
	codeKey		: String;
	theColor,
	colorKey	: Integer;
	tmpVoyage	: CM_Voyage;
	invalid		: Boolean;
	
begin
//	if not global.isValidObject(_voyage) then
	if _voyage = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _voyage, invalid);
	
	trimCode := _voyageCode.trimBlanks;
	
	if invalid then
		return;
	endif;

	if trimCode = null or (_viewModeCode &lt;&gt; null and _viewModeCode &lt;&gt; trimCode) then
		_code 	:= null;
		_color	:= NullColour;
		return;
	endif;

	iter := self.myIterVoyage;
	self.allVoyages.startKeyGeq(trimCode, 0, iter);
	self.allVoyages.getIteratorKeys(codeKey, colorKey, iter);

	theCode		:= null;
	theColor	:= NullColour;
	
	if codeKey = trimCode then
		// found the right one
		theCode		:= trimCode;
		theColor	:= colorKey;
	else
		tmpVoyage := _voyage;
		if tmpVoyage &lt;&gt; null then
			if tmpVoyage.code.trimBlanks &lt;&gt; trimCode then
				// this can happen if invalid data 
				trimCode := tmpVoyage.code;
				self.allVoyages.startKeyGeq(trimCode, 0, iter);
				self.allVoyages.getIteratorKeys(codeKey, colorKey, iter);

				if codeKey = trimCode then
					// found the right one
					theCode		:= trimCode;
					theColor	:= colorKey;
				else
					self.allVoyages.add(tmpVoyage);
					self.beginNotification(tmpVoyage, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
					theCode		:= trimCode;
					theColor	:= tmpVoyage.colour;
				endif;
			else
				self.allVoyages.addNoDuplicates(tmpVoyage, false);
				self.beginNotification(tmpVoyage, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null); // ### PAR 9720
				theCode		:= trimCode;
				theColor	:= tmpVoyage.colour;
			endif;
		endif;
	endif;

	_code	:= theCode;
	_color	:= theColor;
	_object := _voyage;

end;</source>
        <access>protected</access>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_viewModeCode" type="String"/>
        <Parameter name="_code" type="String" usage="output"/>
        <Parameter name="_color" type="Integer" usage="output"/>
        <Parameter name="_object" type="Object" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleVoyage2" id="6b64cc47-fa59-4907-8124-8614d1db2492">
        <source>handleVoyage2(_code : String; _voyage : CM_Voyage; _codesStr, _colourStr, _objStr : String io);
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theCode		: String;
	theColour	: Integer;
	theObject : Object;

begin

	self.handleVoyage(_code, _voyage, null, theCode, theColour,theObject);

	_codesStr := _codesStr &amp; theCode &amp; GridData_SubDelimiter;
	_colourStr	:= _colourStr &amp; theColour.String &amp; GridData_SubDelimiter;
	_objStr	:= _objStr &amp; self.getOidStringForObject(theObject) &amp; GridData_SubDelimiter;
//	_objStr := _objStr &amp; GridData_SubDelimiter;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_codesStr" type="String" usage="io"/>
        <Parameter name="_colourStr" type="String" usage="io"/>
