    <JadeMethod name="isVoyage_Match" id="96491587-d156-4a8b-9507-d35034863213">
        <source>isVoyage_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------------
// 24/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars

begin

	// We don't have a voyage so no match.
	if self.myTrackedItem.myVoyage = null then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	// Check to see whether voyage matches priority selection.
	// PAR #23645 CCMS 1116 for tranships, use export voyage
	if self.myTrackedItem.isTranshipItem then							// PAR #23645 CCMS 1116 
		return _yaData.matches(self.myTrackedItem.myExportVoyage);		// PAR #23645 CCMS 1116 
	else																// PAR #23645 CCMS 1116 
		return _yaData.matches(self.myTrackedItem.myVoyage);
	endif;																// PAR #23645 CCMS 1116 


end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
