    <JadeMethod name="makeMessageRFF_BM" id="f368b2e4-7a89-4f28-8c88-6bc101192763">
        <source>makeMessageRFF_BM(_protocol :CM_CamProtocol; _group :HugeStringArray input; _ti :CM_TrackedItem):String protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	msg, value	:String;
begin
	value := _ti.billOfLading.trimRight;
	
	if value &lt;&gt; null then
		msg := self.makeRFFSegment (_protocol, _group, "BM", value);
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
