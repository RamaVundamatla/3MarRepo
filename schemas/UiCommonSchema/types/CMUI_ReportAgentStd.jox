    <JadeMethod name="doLoadLotHatchPlace" id="41cfb566-226f-4527-9bb0-ca699e04b109">
        <source>doLoadLotHatchPlace(_voyageGlobal : CM_VoyageGlobal);
// ---------------------------------------------------------------------------
// Created:     18 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	voyage			: CM_Voyage;
	hatchNum		: Integer;
	logLot			: CM_LogLot;
	multiTerminal	: Boolean;
	terminalCode,
	str				: String;
	lotCmb,
	hatchCmb,
	placeCmb		: CMUI_ComboBox;
begin
/* // moved to below so combos will be cleared in null passed through (in case already populated)
	if _voyageGlobal = null then
		return;
	endif;
*/
	lotCmb 			:= self.myCmbLot;
	hatchCmb 		:= self.myCmbHatch;
	placeCmb 		:= self.myCmbPlace;
	
	multiTerminal := (self.allTerminals.size &gt; 1);
	lotCmb.clear();
	lotCmb.addItem(Any_String);
	hatchCmb.clear();
	hatchCmb.addItem(Any_String);
	placeCmb.clear();
	placeCmb.addItem(Any_String);

	if _voyageGlobal = null then
		return;
	endif;
	
	foreach voyage in _voyageGlobal.allVoyages discreteLock where self.allTerminals.includes(voyage.myTerminal) do
		if (voyage.myLogVoyageStructure = null) then
			continue;
		endif;
		terminalCode := voyage.myTerminal.code;
		foreach logLot in voyage.myLogVoyageStructure.allLogLots discreteLock do
			if multiTerminal then
				str := logLot.lotNo &amp; ' -' &amp; terminalCode;
			else
				str := logLot.lotNo;
			endif;
			lotCmb.itemObject[lotCmb.addItem(str)] := logLot;
		endforeach;
		// 36563 this was incorrectly within the logLot loop so got too many combo entries
		foreach hatchNum in 1 to voyage.myLogVoyageStructure.numHatches do
			if multiTerminal then
				str := hatchNum.String &amp; ' -' &amp; terminalCode;
			else
				str := hatchNum.String;
			endif;
			hatchCmb.addItem(str);
		endforeach;	
	endforeach;
	
	placeCmb.addItem(app.vesselPlaceEnumToStr(PlaceHold));
	placeCmb.addItem(app.vesselPlaceEnumToStr(PlaceDeck));
epilog
	// placed in here so will set to ***Any** if Null passed as paramater	
	self.setValueByName(ETRow_Lot, Any_String);
	self.setValueByName(ETRow_Hatch, Any_String);
	self.setValueByName(ETRow_Place, Any_String);
	
end;</source>
        <Parameter name="_voyageGlobal" type="CM_VoyageGlobal"/>
    </JadeMethod>
    <JadeMethod name="doLoadMTPoolParties" id="d0a4b447-a158-44ad-9f3b-8c167b8a5a7e">
        <source>doLoadMTPoolParties(_cmb : CMUI_ComboBox input; _mtPoolCode : String) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On   Changed	TFS		Reason
// ----------   -------	-----	--------------------------------------------------
// 02/08/2017	jlgdap1			Initial creation TFS 5558 SNO Empty Release Report
// 25 Sep 2019	jlgdi1	46717	Used the actual object to determine the listIndex of the combobox, 
//								which also makes it independent from the sorting property of the control
// -------------------------------------------------------------------------------
vars
	terminal : CM_Terminal;
	passport : CM_Passport;
	idx : Integer;
	poolParty : CM_MTPoolingParty;
	failedDAC : CM_DataAccessController;
	selPoolParty : CM_MTPoolingParty;
	
begin
	if _cmb = null then
		return;
	endif;
	
	_cmb.clear();
	_cmb.addItem(Any_String);
	
	terminal := self.allTerminals.first;
	passport := app.myPassport;
	
	foreach poolParty in terminal.allMTPoolingParties do
		if (not poolParty.canUserAccessSelf(null, failedDAC, passport)) and (poolParty.code &lt;&gt; _mtPoolCode) then // is report so want to be able to run it on all data
			continue;
			
		endif;
		
		idx := _cmb.addItem(poolParty.code &amp; '  ' &amp; poolParty.description);
		_cmb.itemObject[idx] := poolParty;
		
		if poolParty.code = _mtPoolCode then
			selPoolParty := poolParty;
		endif;
	endforeach;
	
	if selPoolParty &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(selPoolParty);
	else
		_cmb.listIndex := 1;
	endif;
	
	self.setValueByName(ETRow_PoolParty, _cmb.text);
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_mtPoolCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadMachineTypes" id="0f208941-04e2-47ef-810e-76a01f51b6aa">
        <source>doLoadMachineTypes(_combo :CMUI_ComboBox input; _description :String) protected;
// ---------------------------------------------------------------------------
// Created:     10 November 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed	TFS		Reason
// ----------   -------	-----	--------------------------------------------------
// 25 Sep 2019	jlgdi1	46717	Used the actual CM_MachineType object to determine the listIndex of the combobox, 
//								which also makes it independent from the sorting property of the control
// -------------------------------------------------------------------------------
vars
	type : CM_MachineType;
	index : Integer;
	selectedMachineType : CM_MachineType;
	
begin
	_combo.clear();
	_combo.addItem(Any_String);
	
	foreach type in app.myRoot.allMachineTypes do
		index := _combo.addItem(type.description);
		_combo.itemObject[index] := type;
		
		if type.description = _description then
			selectedMachineType := type;
		endif;
	endforeach;
	
	if selectedMachineType &lt;&gt; null then
		_combo.listIndex := _combo.findObject(selectedMachineType);
	else
		_combo.listIndex := 1;
	endif;
	
	self.setValueByName(ETRow_MachineType, _combo.text);
end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_description" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadMachines" id="5ec5707d-b764-4946-beb6-8d3532d3039b">
        <source>doLoadMachines(_combo :CMUI_ComboBox input; _type :CM_MachineType; _description :String) protected;
// ---------------------------------------------------------------------------
// Created:     10 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed	TFS		Reason
// ----------   -------	-----	--------------------------------------------------
// 25 Sep 2019	jlgdi1	46717	Used the actual object to determine the listIndex of the combobox, 
//								which also makes it independent from the sorting property of the control
// -------------------------------------------------------------------------------
vars
	terminal :CM_Terminal;
	machine	: CM_Machine;
	index : Integer;
	selectedMachine : CM_Machine;
	
begin
	_combo.clear();
	_combo.addItem(Any_String);
	
	terminal := self.allTerminals.first;
	
	if terminal = null then 
		return;
	endif;
	
	foreach machine in terminal.machines do
		if _type &lt;&gt; null and 
			machine.getMachineType &lt;&gt; _type then
			continue;
		endif;
		index := _combo.addItem(machine.description);
		
		_combo.itemObject[index] := machine;
		
		if machine.description = _description then
			selectedMachine := machine;
		endif;
	endforeach;
	
	if selectedMachine &lt;&gt; null then
		_combo.listIndex := _combo.findObject(selectedMachine);
	else
		_combo.listIndex := 1;
	endif;
	
	self.setValueByName(ETRow_Machine, _combo.text);
end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_type" type="CM_MachineType"/>
        <Parameter name="_description" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadMasters" id="f002e3fc-707a-4f12-87c2-e404a56a279d">
        <source>doLoadMasters(_combo :CMUI_ComboBox input;_description :String) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Changed On  Changed	TFS		Reason
----------  -------	-----	--------------------------------------------------
01 May 2012	cnwndl1	Initial creation	Par 29496
25 Sep 2019	jlgdi1	46717	Used the actual object to determine the listIndex of the combobox, 
							which also makes it independent from the sorting property of the control
-------------------------------------------------------------------------------
*/

vars
	terminal : CM_Terminal;
	harbour : HMS_Harbour;
	master : HMS_Master;
	index : Integer;
	masterColl	: HMS_MasterByCodeDict;
	selMaster : HMS_Master;
	
begin
	_combo.clear();
	index := _combo.addItem(Any_String);
		
	create masterColl transient;
	
	if not self.allTerminals.isEmpty then 
		foreach terminal in self.allTerminals do
			harbour := terminal.myHarbour;
			if harbour &lt;&gt; null then
				foreach master in harbour.allMasters where not masterColl.includes(master) do
					
					masterColl.addNoDuplicates (master, false);
					index := _combo.addItem(master.getDisplayString);
			
					_combo.itemObject[index] := master;
					
					if master.getDisplayString = _description then
						selMaster := master;
					endif;
				endforeach;
			endif;
		endforeach;
	endif;
	
	if selMaster &lt;&gt; null then 
		_combo.listIndex := _combo.findObject(selMaster);
	elseif _description = Any_String then 
		_combo.listIndex := _combo.findStringExact(1, Any_String);
	else
		_combo.listIndex := 1;
	endif;
	
	self.setValueByName(ETRow_Master, _combo.text);
	
epilog
	delete masterColl;
end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_description" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadMenuEntity" id="e2c165e2-1845-4451-8eae-f3a5b816638e">
        <source>doLoadMenuEntity(_menuEntity : CM_MenuEntity) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/02/2018	jlgdap1		Initial creation TFS 37030 SSL Demurrage Report
//
vars
	subEntity : CM_MenuEntity;

begin
	if _menuEntity.isKindOf(CM_MenuUserQuery) then
		if _menuEntity.CM_MenuUserQuery.getQueryDefinition.isCargoType then
			self.myCmbQuery.addItemObject(_menuEntity.CM_MenuUserQuery.heading, _menuEntity);
		endif;
	else
		foreach subEntity in _menuEntity.allChildren do
			self.doLoadMenuEntity(subEntity);
		endforeach;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_menuEntity" type="CM_MenuEntity"/>
    </JadeMethod>
    <JadeMethod name="doLoadModeCombo" id="6b44d644-6d20-461b-893f-6ffcfedd77ad">
        <source>doLoadModeCombo(_cmb : CMUI_ComboBox input; _mode : String) protected;
// ---------------------------------------------------------------------------
// Created:     18 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _cmb = null then
		return;
	endif;
	
	_cmb.clear();
	
	_cmb.addItem(CMQF_VoyageSummary.MODE_OPT_PROPOSED);
	_cmb.addItem(CMQF_VoyageSummary.MODE_OPT_ACTUAL);
	
	if _mode &lt;&gt; null then
		_cmb.text := _mode;
	else
		_cmb.listIndex := 1;
	endif;
	
	self.setValueByName(ETRow_Mode, _cmb.text);

end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_mode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadMonths" id="5090138d-01db-4460-8274-0e4dd698d42a">
        <source>doLoadMonths(_cmb : CMUI_ComboBox input; _month : String io) protected;
//----------------------------------------------------------------
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

	index : Integer;
	date : Date;

begin

	_cmb.clear();
	_cmb.sorted := false;
	
	foreach index in 1 to 12 do
		date.setDate( 1, index, 2000 );
		_cmb.addItemAt( date.monthName, index );
	endforeach;
	
	if _month &lt;&gt; null then
		if _month.isInteger then
			if _month.Integer &gt; 0 and _month.Integer &lt; 13 then
				_cmb.listIndex := _month.Integer;
				_month := _cmb.text;
			endif;
		else
			_cmb.listIndex  := _cmb.findStringExact( 1, _month );
		endif;
	endif;
	
	self.setValueByName(ETRow_Month, _cmb.text);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_month" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doLoadOperatorGroups" id="10bf2b19-dff9-45c6-a77c-50a987cc6846">
        <source>doLoadOperatorGroups(_cmb : CMUI_ComboBox input; _entRowName, _opGrpCode : String) protected;
//----------------------------------------------------------------
//	Created:	02 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//
// Changed On   Changed	TFS		Reason
// ----------   -------	-----	--------------------------------------------------
// 25 Sep 2019	jlgdi1	46717	Used the actual object to determine the listIndex of the combobox, 
//								which also makes it independent from the sorting property of the control
// -------------------------------------------------------------------------------
vars
	opGrpDict : CM_OperatorGroupByCodeDict;
	opGrp : CM_OperatorGroup;
	idx	: Integer;
	passport : CM_Passport;
	failedDAC : CM_DataAccessController;
	selOperatorGroup : CM_OperatorGroup;
	
begin
	if _cmb = null then
		return;
	endif;
	
	_cmb.clear();
	_cmb.addItem(Any_String);
	
	opGrpDict := app.myRoot.allOperatorGroups;
	passport := app.myPassport;
	
	foreach opGrp in opGrpDict do
		if not opGrp.canUserAccessSelf(null, failedDAC, passport) then
			continue;
		endif;
		
		idx := _cmb.addItem(opGrp.code &amp; '  ' &amp; opGrp.description);
		_cmb.itemObject[idx] := opGrp;
		
		if opGrp.code = _opGrpCode then
			selOperatorGroup := opGrp;
		endif;
	endforeach;
	
	if selOperatorGroup &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(selOperatorGroup);
	else
		_cmb.listIndex := 1;
	endif;
	
	self.setValueByName(ETRow_OperatorGroup, _cmb.text);
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_opGrpCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadOperators" id="3e4af071-690c-47e8-8b11-acc0d3d113a2">
        <source>doLoadOperators(_cmb : CMUI_ComboBox input; _operatorCode : String) protected;
// ---------------------------------------------------------------------------
// Created:     18 December 2003	cnwth2
//
// Purpose:     
//
// Changed On   Changed	TFS		Reason
// ----------   -------	-----	--------------------------------------------------
// 25 Sep 2019	jlgdi1	46717	Used the actual object to determine the listIndex of the combobox, 
//								which also makes it independent from the sorting property of the control
// 20 Jun 2022	navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP
// -------------------------------------------------------------------------------
vars
	opDict : CM_OperatorByCodeDict;
	op : CM_Operator;
	idx	: Integer;
	passport : CM_Passport;
	failedDAC : CM_DataAccessController;
	selOperator : CM_Operator;
	byName : Boolean;				// TFS 53362
	
begin
	if _cmb = null then
		return;
	endif;
	
	_cmb.clear();
	_cmb.addItem(Any_String);
	
	opDict := app.myRoot.allOperators;
	passport := app.myPassport;
	byName := app.myRoot.getConfig(ComboByNameOperator).Boolean;	// TFS 53362
	if byName then													// TFS 53362
		_cmb.sorted := true;										// TFS 53362
	endif;															// TFS 53362
	
	foreach op in opDict do
//		if (not op.canUserAccessSelf(null, passport) or op.isNotAvailableForEntry) and (op.code &lt;&gt; _operatorCode) then
		if (not op.canUserAccessSelf(null, failedDAC, passport)) and (op.code &lt;&gt; _operatorCode) then // is report so want to be able to run it on all data
			continue;
			
		endif;
		
		if byName then												// TFS 53362
			idx := _cmb.addItem(op.description &amp; '  ' &amp; op.code);	// TFS 53362
		else														// TFS 53362
			idx := _cmb.addItem(op.code &amp; '  ' &amp; op.description);
		endif;														// TFS 53362
		_cmb.itemObject[idx] := op;
		
		if op.code = _operatorCode then
			selOperator := op;
		endif;
	endforeach;
	
	if selOperator &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(selOperator);
	else
		_cmb.listIndex := 1;
	endif;
	
	self.setValueByName(ETRow_Operator, _cmb.text);
	self.setValueByName(ETRow_OperatorCode, _cmb.text);
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_operatorCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadOrganisationUserList" id="67f19838-a24b-4425-a5c1-62cebf2091b3">
        <source>doLoadOrganisationUserList(_lstTable : CMUI_ListTable input; _organisation : CM_Organisation);

/*

Purpose:			Load the users for the given organisation

Parameters:			

Return Value:		


Date		Who		Reason
14 February 2013	cnwjre1	Initial creation

*/
vars
	
	user				: CM_User;
	idx					: Integer;
	select				: Integer;
	
begin
	
	if _lstTable = null then
		return;
	endif;
	
	_lstTable.rows := _lstTable.fixedRows;
	_lstTable.clearSelected();

	foreach user in _organisation.allUsers do
		select := 0;
		idx := _lstTable.addItem(select.String &amp; Tab &amp; user.code); 
		_lstTable.accessRow(idx).itemObject := user;
	endforeach;

end;</source>
        <Parameter name="_lstTable" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_organisation" type="CM_Organisation"/>
    </JadeMethod>
    <JadeMethod name="doLoadOrganisationUsers" id="0fcd337a-2d68-4ac3-a37f-656351ad55de">
        <source>doLoadOrganisationUsers(_lstTable	: CMUI_ListTable input; _defaultTemplate : CMQF_FilterReports) protected;
//----------------------------------------------------------------
//	Created:	5 Mar 2013	cnwjre1 CCMS HAT 2205 selected users from organisation
//----------------------------------------------------------------
vars
	
	user				: CM_User;
	idx					: Integer;
	defaultUsers		: CM_UserByCodeDict;
	organisation		: CM_Organisation;
	select				: Integer;
	
begin
	if _defaultTemplate.isKindOf(CMQF_OrganisationAccess) then
		defaultUsers := _defaultTemplate.CMQF_OrganisationAccess.allUsers;
		organisation := _defaultTemplate.CMQF_OrganisationAccess.getMyOrganisation;
	endif;
	
	if _lstTable = null then
		return;
	endif;
	
	_lstTable.rows := _lstTable.fixedRows;
	_lstTable.clearSelected();

	if organisation = null then
		if defaultUsers &lt;&gt; null then		// 31292 handle new report
			foreach user in defaultUsers do
				select := 1;
				_lstTable.allSelectedObjects.add(user);	
				idx := _lstTable.addItem(select.String &amp; Tab &amp; user.code); 
				_lstTable.accessRow(idx).itemObject := user;
			endforeach;
		endif;
	else
		foreach user in organisation.allUsers do
			select := 0;
			if defaultUsers &lt;&gt; null and defaultUsers[user.code] &lt;&gt; null then
				select := 1;
				_lstTable.allSelectedObjects.add(user);	
			endif;

			idx := _lstTable.addItem(select.String &amp; Tab &amp; user.code); 
			_lstTable.accessRow(idx).itemObject := user;
		endforeach;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_lstTable" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_defaultTemplate" type="CMQF_FilterReports"/>
    </JadeMethod>
    <JadeMethod name="doLoadOrganisations" id="d12a2dca-5101-4f6b-b071-07b854d71acc">
        <source>doLoadOrganisations(_combo : CMUI_ComboBox input; _name : String) protected;
// ---------------------------------------------------------------------------
// Created:     February 2013 by cnwjre1 par 31156/ccms HAT 2205
// Purpose:     Load organisations for the cargo marketting reports
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	failedDAC		: CM_DataAccessController;
	organisation	: CM_Organisation;
	index,
	findIndex		: Integer;
begin
	_combo.clear();
	
	foreach organisation in app.myRoot.allOrganisations do
		if (not organisation.canUserAccessSelf(null, failedDAC, app.myPassport)) and (organisation.name &lt;&gt; _name) then
			continue;
		endif;
		index := _combo.addItem(organisation.name);
		
		_combo.itemObject[index] := organisation;
		
	endforeach;
	
	if _combo.listCount() &gt; 0 then
		if _name &lt;&gt; null then
			findIndex := _combo.findString(1, _name);
		endif;
		if findIndex &gt; 0 then
			_combo.listIndex := findIndex;
		else
			_combo.listIndex := 1;
		endif;
	endif;
	
	self.setValueByName(ETRow_Organisation, _combo.text);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadPackArea" id="b1960d9f-321d-448c-8d53-bda926794270">
        <source>doLoadPackArea(_lstTable	: CMUI_ListTable input; _defaultTemplate : CMQF_FilterReports) protected;
//----------------------------------------------------------------
//	Created:	16 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
10 Jun 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	defaultAreas		: CM_TerminalAreaSet;
	packArea			: CM_TerminalArea;
	idx					: Integer;
	theCode				: String;
	select				: Integer;
	term				: CM_Terminal;
	
begin
	if CMQF_Container.hasInstance(_defaultTemplate) then
		defaultAreas := _defaultTemplate.CMQF_Container.allQryPackAreas;
	endif;

	term := app.getMyTerminalDO_NOT_USE;
	
	if _lstTable = null
	or term = null then
		return;
	endif;
	
	_lstTable.rows := _lstTable.fixedRows;
	_lstTable.clearSelected();

	foreach packArea in term.allTerminalAreasByTypeId discreteLock where 
			(packArea.type = TA_TYPE_DEPOT_LCL or packArea.type = TA_TYPE_IRREGULAR_BLOCK_AREA) do 		// was TA_TYPE_GENERAL_CARGO_AREA
		
		theCode := packArea.id;
		select := 0;
		if defaultAreas &lt;&gt; null and defaultAreas.includes(packArea) then
			select := 1;
			_lstTable.allSelectedObjects.add(packArea);	
		endif;
		
		idx := _lstTable.addItem(select.String &amp; Tab &amp; theCode); 
		_lstTable.accessRow(idx).itemObject := packArea;
	endforeach;		

end;</source>
        <access>protected</access>
        <Parameter name="_lstTable" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_defaultTemplate" type="CMQF_FilterReports"/>
    </JadeMethod>
    <JadeMethod name="doLoadPlanningState" id="2be8456c-990d-4c5d-ab18-a1b0bf4ee07f">
        <source>doLoadPlanningState(_cmb : CMUI_ComboBox input; _planningStateDescription : String) protected;
// ---------------------------------------------------------------------------
// Created:     18 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	str					: String;
begin
	if _cmb = null then
		return;
	endif;
	
	_cmb.clear();
	
	_cmb.itemData[_cmb.addItem(app.planningStateEnumToString(NULL_PLANSTATE))] := NULL_PLANSTATE;
	_cmb.itemData[_cmb.addItem(app.planningStateEnumToString(NOTIFIED_STATE))] := NOTIFIED_STATE;
	_cmb.itemData[_cmb.addItem(app.planningStateEnumToString(RECEIVED_STATE))] := RECEIVED_STATE;
	_cmb.itemData[_cmb.addItem(app.planningStateEnumToString(PLANNED_LOAD_STATE))] := PLANNED_LOAD_STATE;
	_cmb.itemData[_cmb.addItem(app.planningStateEnumToString(LOADED_STATE))] := LOADED_STATE;
	_cmb.itemData[_cmb.addItem(app.planningStateEnumToString(PLANNED_DISCHARGE_STATE))] := PLANNED_DISCHARGE_STATE;
	_cmb.itemData[_cmb.addItem(app.planningStateEnumToString(DISCHARGED_STATE))] := DISCHARGED_STATE;
	_cmb.itemData[_cmb.addItem(app.planningStateEnumToString(DELIVERED_STATE))] := DELIVERED_STATE;
	_cmb.itemData[_cmb.addItem(app.planningStateEnumToString(SHIFTED_STATE))] := SHIFTED_STATE;
	
	if _planningStateDescription &lt;&gt; null then
		_cmb.text := _planningStateDescription;
	else
		_cmb.listIndex := 1;
	endif;
	
	self.setValueByName(ETRow_State, _cmb.text);
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_planningStateDescription" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadPorts" id="082006c6-fd7f-40f0-8112-a4b1e70a35dd">
        <source>doLoadPorts(_cmb : CMUI_ComboBox input; _entRowName, _portCode : String) protected;
// ---------------------------------------------------------------------------
// Created:     18 December 2003	cnwth2
//
// Purpose:     
//			 
// Changed On   Changed	TFS		Reason
// ----------   -------	-----	--------------------------------------------------
// 25 Sep 2019	jlgdi1	46717	Used the actual object to determine the listIndex of the combobox, 
//								which also makes it independent from the sorting property of the control
// -------------------------------------------------------------------------------
vars
	portDict		: CM_PortByCodeDict;
	port			: CM_Port;
	idx				: Integer;
	portCmbOrderDescrFirst : Boolean;
	selPort : CM_Port;
	
begin
	if _cmb = null then
		return;
	endif;
	
	_cmb.clear();
	//portDict := app.myRoot.allPorts;
	portCmbOrderDescrFirst := app.myRoot.getConfig(PortCmbOrderDescrFirst).Boolean;
	portDict := app.myRoot.allActivePorts;
	_cmb.addItem(Any_String);
	
	foreach port in portDict do
		idx := _cmb.addItem(port.getDisplayFormatted(portCmbOrderDescrFirst));
		_cmb.itemObject[idx] := port;
		if port.code = _portCode then
			selPort := port;
		endif;
	endforeach;
	
	if selPort &lt;&gt; null then 
		_cmb.listIndex := _cmb.findObject(selPort);
	else
		_cmb.listIndex := 1;
	endif;
	
	self.setValueByName(_entRowName, _cmb.text);
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_portCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadProducts" id="2290afef-5ace-4910-a773-a0f583716af4">
        <source>doLoadProducts(_cmb : CMUI_ComboBox input; 
				_cargoType : CM_CargoBOLType;
				_loc : CM_LocationsController; 
				_productCode : String);
// ---------------------------------------------------------------------------
// Created:     18 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	sohLoc				: CM_SOHLocation;
	productCodeDict		: CM_ProductByOpCodeProCodeDict;
	operCode : String;
begin
	if _cmb = null then
		return;
	endif;
	
	create productCodeDict transient;
	_cmb.clear();
	
	if _loc &lt;&gt; null then
		foreach sohLoc in _loc.allProductLocations do
			if sohLoc.myOperator &lt;&gt; null then
				operCode := sohLoc.myOperator.code;
			endif;
			
			if not productCodeDict.includesKey(operCode, sohLoc.myProduct.code) then
				productCodeDict.add(sohLoc.myProduct);
			endif;
			operCode := null;
		endforeach;
	elseif CM_CargoType.hasInstance(_cargoType) then
		_cargoType.CM_CargoType.allProducts.copy(productCodeDict);
	endif;
	
	_cmb.listCollectionWithAny(productCodeDict, 'code');
	
	if productCodeDict[null, _productCode] &lt;&gt; null then
		_cmb.text := _productCode;
	else
		_cmb.text := Any_String;
	endif;
	
	self.setValueByName(ETRow_Product, _cmb.text);

epilog
	delete productCodeDict;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_cargoType" type="CM_CargoBOLType"/>
        <Parameter name="_loc" type="CM_LocationsController"/>
        <Parameter name="_productCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadProfiles" id="b719f59c-71a5-4c59-81d3-bc92b3c62f7d">
        <updating/>
        <source>doLoadProfiles(_cmb: CMUI_ComboBox input; _qryReport: CM_QryReport; _defaultValue: String) protected, updating;
//----------------------------------------------------------------
//	Created:	30 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	//get profiles
	self.doShowHideProfiles(self.myJRWReport, _defaultValue);
	
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_qryReport" type="CM_QryReport"/>
        <Parameter name="_defaultValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadQueries" id="b9398c3c-6ae8-4765-8d54-fbcf7565d66c">
        <updating/>
        <source>doLoadQueries(_cmbQuery : CMUI_ComboBox; _defaultValueStr : String) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/02/2018	jlgdap1		Initial creation TFS 37030 SSL Demurrage Report
//
vars
	queryRoot : CM_MenuRoot;
	menuEntity : CM_MenuEntity;

begin
	queryRoot := app.myRoot.myQueryMenuRoot;
	self.myCmbQuery.clear;
	self.myCmbQuery.addItem("");
	foreach menuEntity in queryRoot.allChildren do
		self.doLoadMenuEntity(menuEntity);
	endforeach;
	
	if _defaultValueStr &lt;&gt; null then
		self.myCmbQuery.listIndex := self.myCmbQuery.findStringExact(1, _defaultValueStr);
	endif;
	
	self.setValueByControlName(_cmbQuery.name, _cmbQuery.text);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cmbQuery" type="CMUI_ComboBox"/>
        <Parameter name="_defaultValueStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadReceiptModes" id="44e88479-6c8b-4f98-a07b-d06a911c9f71">
        <source>doLoadReceiptModes(_cmb : CMUI_ComboBox input; _mode : String) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 September 2010	cnwndl1	Initial creation	Par 25608

*/

vars

	combo : CMUI_ComboBox;
	
begin

	if _cmb = null then
		app.raiseUnexpectedProgramError(self.class.name, method.name, 'A cargo receipt mode combo box was expected but cannot be located.');
	endif;
	
	combo := _cmb;
	combo.clear();
	combo.sorted := false;
	
	combo.addItem(Any_String);
	combo.itemData[combo.newIndex] := 0;

	combo.addItem(TI_TRANSMODE_ROAD_STR);
	combo.itemData[combo.newIndex] := TI_TRANSMODE_ROAD;
	
	combo.addItem(TI_TRANSMODE_RAIL_STR);
	combo.itemData[combo.newIndex] := TI_TRANSMODE_RAIL;
	
	combo.addItem(TI_TRANSMODE_SHIP_STR);
	combo.itemData[combo.newIndex] := TI_TRANSMODE_SHIP;
	
	combo.addItem(TI_TRANSMODE_INTERNAL_STR);
	combo.itemData[combo.newIndex] := TI_TRANSMODE_INTERNAL;
	
	if _mode = null then
		combo.listIndex := combo.findStringExact(1,Any_String);
	else
		combo.listIndex := combo.findStringExact(1,_mode);
	endif;
	
	self.setValueByName(ETRow_ReceiptTransportMode, combo.text);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_mode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadReleaseTypes" id="e88bad07-6964-4f73-8569-eabc8eda9ae6">
        <source>doLoadReleaseTypes(_cmb : CMUI_ComboBox input; _passport: CM_Passport; _defaultValueStr : String) protected;
//----------------------------------------------------------------
//	Created:	30 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//
// 17 July 2018		jlgmd1	TFS 39407 SNO - Fixed Bulk Release criteria not saving on the template
//

vars
	combobox	: CMUI_ComboBox;
	road,
	rail,
	pack,
	ship,
	all			: Boolean;
	terminal	: CM_Terminal;
	user		: CM_User;
	idx			: Integer;
begin
	if _cmb = null then
		return;
	endif;
	
	combobox := _cmb;
	user := _passport.myUser;	
	if user = null then
		return;
	endif;
	
	terminal := _passport.myTerminal;
	combobox.clear();		// TFS 39407
	
	road := user.canDo(terminal, PmGteMTReleaseViewRd);
	rail := user.canDo(terminal, PmGteMTReleaseViewRail);
	pack := user.canDo(terminal, PmGteMTReleaseViewGen);
	ship := true;//would be updated in the future;
	
	all := road and rail and pack and ship;
	idx := -1;
	
	if all then
		idx := combobox.addItem(Any_String);
		combobox.listIndex := idx;
	endif;
		
	if road then
		idx := combobox.addItem("Road");
		combobox.itemData[idx] := BR_TYPE_ROAD;
		if _defaultValueStr = BR_TYPE_ROAD.String then
			combobox.listIndex := idx;
		endif;
	endif;
				
	if rail then	
		idx := combobox.addItem("Rail");
		combobox.itemData[idx] := BR_TYPE_RAIL;
		if _defaultValueStr = BR_TYPE_RAIL.String then
			combobox.listIndex := idx;
		endif;
	endif;
		
	if ship then
		idx := combobox.addItem("Ship");
		combobox.itemData[idx] := BR_TYPE_SHIP;
		if _defaultValueStr = BR_TYPE_SHIP.String then
			combobox.listIndex := idx;
		endif;
	endif;

	if pack then
		idx := combobox.addItem("Packing");
		combobox.itemData[idx] := BR_TYPE_PACKING;
		if _defaultValueStr = BR_TYPE_PACKING.String then
			combobox.listIndex := idx;
		endif;
	endif;
	
	if combobox.listCount &gt; 0 then
		if idx &lt; 0 then
			combobox.listIndex := 1;
		endif;
		self.setValueByName(ETRow_ReleaseType, combobox.text);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_defaultValueStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadRowIds" id="12a227d7-b2b4-450d-a52a-c6da9a39bd95">
        <source>doLoadRowIds(_cmb : CMUI_ComboBox input; _ta : CM_TerminalArea; _rowId : String);
// ---------------------------------------------------------------------------
// Created:     18 December 2003	cnwth2
//
// Purpose:     
//			 
// Changed On   Changed	TFS		Reason
// ----------   -------	-----	--------------------------------------------------
// 25 Sep 2019	jlgdi1	46717	Used the actual object to determine the listIndex of the combobox, 
//								which also makes it independent from the sorting property of the control
// -------------------------------------------------------------------------------
vars
	row				: CM_RowController;
	tmpRowDict		: CM_RowControllerByIdNoDupsDict;
	passport		: CM_Passport;
	ta				: CM_TerminalArea;
	idx : Integer;
	failedDAC  :CM_DataAccessController;
	selRowController : CM_RowController;
	
begin
	//PAR17151 cnwsh3  Structural changes for warehousing and general cargo
	//Now called by self.doLoadRowsOrArea so some of the code has been moved to this method.
	tmpRowDict := _ta.CM_RowArea.allRowControllersById;
	passport := app.myPassport;
	foreach row in tmpRowDict do
		if (not row.canUserAccessSelf(null, failedDAC, passport)) then
			continue;
		endif;
		idx := _cmb.addItem(row.id);
		_cmb.itemObject[idx] := row;
		
		if row.id = _rowId then
			selRowController := row;
		endif;
	endforeach;

	if selRowController &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(selRowController);
	else
		_cmb.text := Any_String; 
	endif;
	
	self.setValueByName(ETRow_RowId, _cmb.text);
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_rowId" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadRowsOrAreas" id="9e61a549-2a70-4dfe-a406-61e57c9c9bdf">
        <source>doLoadRowsOrAreas(_cmb : CMUI_ComboBox input; _ta : CM_TerminalArea; _rowId : String);
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 18 June 2008
//
// Implemented version: 7.6.2
//PAR17151 cnwsh3  Structural changes for warehousing and general cargo
// We need to check what kind of area we are passing in a get the correct LCs
//----------------------------------------------------------------------
vars

begin
	if _cmb = null then
		return;
	endif;
	
	_cmb.clear();
	_cmb.addItem(Any_String);
	
	if CM_RowArea.hasInstance(_ta) then
		self.doLoadRowIds(_cmb, _ta, _rowId);
	elseif CM_IrregularBlockArea.hasInstance(_ta) then
		self.doLoadGCIds(_cmb, _ta, _rowId);
	else
		self.setValueByName(ETRow_RowId, Any_String);
		return;
	endif;
	
epilog
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_rowId" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadSAPStatus" id="9f83aebb-42d5-481a-b844-1fa7247fc509">
        <source>doLoadSAPStatus(_combo : CMUI_ComboBox; _defaultValueStr : String) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 03/05/2019	jlgdap1		Initial creation TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
//
vars
	combo : CMUI_ComboBox;

begin
	if _combo = null then
		app.raiseUnexpectedProgramError(self.class.name, method.name, 'A SAP Activity Status combo box was expected but cannot be located.');
	endif;
	
	combo := _combo;
	combo.clear();
	combo.sorted := false;
	
	combo.addItem(Any_String);
	combo.itemData[combo.newIndex] := 0;

	combo.addItem(app.getErrorString(SAP_Hold));
	combo.itemData[combo.newIndex] := 1;
	
	combo.addItem(app.getErrorString(Debit));
	combo.itemData[combo.newIndex] := 2;
	
	combo.addItem(app.getErrorString(Cancelled));
	combo.itemData[combo.newIndex] := 3;
	
	if _defaultValueStr = null then
		combo.listIndex := combo.findStringExact(1, Any_String);
	else
		combo.listIndex := combo.findStringExact(1, _defaultValueStr);
	endif;
	
	self.setValueByName(ETRow_SapStatus, combo.text);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="CMUI_ComboBox"/>
        <Parameter name="_defaultValueStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadSAPTransactions" id="7f43f553-5757-458d-8606-d51747b5d1d7">
