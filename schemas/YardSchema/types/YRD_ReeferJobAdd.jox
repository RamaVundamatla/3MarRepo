    <JadeMethod name="btnBySelector_click" id="bf219b1c-809a-4415-bb29-ab28b3cc7062">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBySelector_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	theSelector : CMUI_Selector;
	transUserQuery : CM_MenuUserQuery;
	transCriteriaLineHolder : CM_QueryCriteriaLineHolder;

begin

	theSelector := app.getSelectorForm(self, self.myMasterMenuAction);
	if theSelector = null then
		return;
	endif;
	
	create transUserQuery transient;
	create transCriteriaLineHolder transient;
	transUserQuery.allCriteriaLineHolders.add(transCriteriaLineHolder);
	self.buildReeferQuery( transUserQuery, transCriteriaLineHolder );
	
	theSelector.show;
	theSelector.showQuery(transUserQuery);

epilog

	delete transUserQuery;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
