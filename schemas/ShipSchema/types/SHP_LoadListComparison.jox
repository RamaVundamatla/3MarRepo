    <JadeMethod name="doShowView" id="35e68c9c-be76-445a-bd73-7cd391347ee5">
        <updating/>
        <source>doShowView(_viewName: String; _isRefresh : Boolean) updating;
//----------------------------------------------------------------
//	Created:	23 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	viewConst	: String;
	coll,coll2	: Collection;
	msg : String;
	etRow : EntTableRow;
	rowName : String;
	
begin
	self.tblData.allSelectedObjects.clear;	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	
	viewConst := _viewName;
	self.btnSaveUpdate.enabled := false;	
	self.btnBulkEdit.enabled := false;	
	self.btnSelectAll.enabled := false;
	if not self.myLLCAgent.comparisonComplete then
		return;
	endif;
	
	if viewConst = self.VIEW_DISCREPS then
		coll := self.myLLCAgent.allDiscrepancyTIs;
		if coll.size &gt; 0 then
			self.btnSaveUpdate.enabled := true;	
			self.btnBulkEdit.enabled := true;	
			self.btnSelectAll.enabled := true;
		endif;
	elseif viewConst = self.VIEW_MATCHING then
		coll := self.myLLCAgent.allMatchingTIs;
	elseif viewConst = self.VIEW_NOT_IN_DB then
		coll := self.myLLCAgent.allUnmatchedLLTIs;
	elseif viewConst = self.VIEW_NOT_IN_LIST then
		coll := self.myLLCAgent.allUnmatchedDBTIs;
	elseif viewConst = self.VIEW_DUPLICATES then
		coll := self.myLLCAgent.allDuplicateTIsOnTerminal;
	elseif viewConst = null then					///ccms 1096
		coll := self.myLLCAgent.allDiscrepancyPortsTIs;
		coll2 := self.myLLCAgent.allDiscrepancyTranshipsTIs;
	else
		app.raiseCMException2(ERR_INVALID_VALUE, 'view name (' &amp; viewConst &amp; ')', 'Contact developer', null, null);
		return;
	endif;
	
	//clear extra info first
	self.tblInfo.rows := 0;
	self.numOfDiscrepTI := 0;
	if viewConst &lt;&gt; null then						//ccms 1096
		self.displayEDITIs(coll,_isRefresh, viewConst);				//navra1 - MTN-36125 - 24th Sep 2025
	else
		self.displayEDITIsVoyagePorts(coll,true,_isRefresh);
		self.displayEDITIsVoyagePorts(coll2,false,_isRefresh);
	endif;
	
	//26 Apr 2010	NDL	Par 23912
	if self.hasVoyageDiscreps then
		if not self.hasWarnedOfVoyageDiscreps then	
			msg := app.getErrorString(Different_Voyage);
			if self.tblData.getColumnByRowName(ETRow_VoyageCode) = 0 then
				if tblData.myEntTableDef &lt;&gt; null then
					etRow := tblData.myEntTableDef.getEntTableRow(ETRow_VoyageCode);
				endif;
				if etRow &lt;&gt; null then
					rowName := etRow.getHeading(null, null, app.myCurrentLocale);
				else
					rowName := ETRow_VoyageCode;
				endif;
				msg := msg &amp; CrLf &amp; app.getErrorString1(Select_column_organiser, rowName);
			endif;
			app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			self.hasWarnedOfVoyageDiscreps := true;
		endif;
		
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSaveUpdate.enabled := false;	
		self.btnBulkEdit.enabled := false;	
		self.btnSelectAll.enabled := false;

	endif;

	self.tblData.cnEcResizeContents();

end;</source>
        <Parameter name="_viewName" type="String"/>
        <Parameter name="_isRefresh" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblCargoListDBClick" id="19b32ecb-bc08-4155-a8e1-dd74a760ce0d">
        <source>doTblCargoListDBClick(table: Table input);
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theTI : CM_TrackedItem;
	theRow : Integer;
begin
	if table.row &lt;= table.fixedRows then
		return;
	endif;

	return;
	//have to get the ti from the list of query containers and if found display it.
	
	theTI := table.accessRow(table.row).itemObject.CM_TrackedItem;
	if theTI &lt;&gt; null then
		self.myAssistant.showCargoEnquiryForm(theTI, self.myMasterMenuAction, true, false);	
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
