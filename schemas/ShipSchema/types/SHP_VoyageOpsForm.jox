    <JadeMethod name="addDebtorTypes" id="48b86ddd-40f6-48a0-8c73-ab0465498269">
        <updating/>
        <source>addDebtorTypes() protected, updating;
//02 March 2018    jlgrh7    Initial creation TFS36564
vars
	debtorType : CM_DebtorType;
	
begin
	foreach debtorType in app.myRoot.allDebtorTypes discreteLock where not debtorType.isNotAvailableForEntry do
		if not debtorType.allDebtors.isEmpty then
			self.zAddTransientEntTblRow(debtorType.description, ETRow_DebtorTypes &amp; Tab &amp; debtorType.code, Table.InputType_None);
		endif;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="080fcce4-ab22-446a-9af5-131a32806ec0">
        <updating/>
        <source>addToolbarControls() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 08/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394
// 25/01/2017	cnwdap1		TFS 3219 LNX Voyage Operations Enhancements - add Hold Jobs button
// 07//02/2017	cnwdap1		TFS 3220 LNX Voyage Operations Enhancements - add Hold Operations button
// 03/06/2022	navcs2		Bug 53256: MTN - Voyage Operations Toolbar Issue
vars
	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	
	//30/07/2025	navkc1 JIRA MTN 35478
	toolbar.addButton(self.btnNotifications, CMUI_Toolbar.Control_Alignment_Right);
	self.btnNotifications.visible := true;
	
	toolbar.addButton(self.btnShowSelector, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnUserColours, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDischarge, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnLoad, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnDeleteCargo, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnImportTasks, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCustomsEDI, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEventTrans, CMUI_Toolbar.Control_Alignment_Left);
	
	if self.allowSummaryDefn then
		toolbar.addSeperator( CMUI_Toolbar.Control_Alignment_Left );
		toolbar.addButton( self.btnSummariseAll, CMUI_Toolbar.Control_Alignment_Left );
	endif;
	toolbar.addSeperator( CMUI_Toolbar.Control_Alignment_Left );
	toolbar.addButton(self.btnVesselDef, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnVoyageDef, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnLOLODef, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRORODef, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnHoldsDef, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator( CMUI_Toolbar.Control_Alignment_Left );
	toolbar.addButton(self.btnAlloc, CMUI_Toolbar.Control_Alignment_Left); 
	toolbar.addButton(self.btnBookings, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRelRequests, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPreNotes, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator( CMUI_Toolbar.Control_Alignment_Left );
	toolbar.addButton(self.btnOrderOfWorks, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnJobOps, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnLoadList, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnComparison, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCargoCounter, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShipCntrllr, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSideProfile, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShipDelays, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShipDelaysEnq, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCheckList, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator( CMUI_Toolbar.Control_Alignment_Left );						// TFS 3219
	toolbar.addButton(self.btnHoldPlan, CMUI_Toolbar.Control_Alignment_Left);			// TFS 3219
	toolbar.addButton(self.btnHoldOps, CMUI_Toolbar.Control_Alignment_Left);			// TFS 3220
	
 // ### TFS 50421 21SEP2021 NAVAB1 moved out of toolbar	toolbar.addSeperator( CMUI_Toolbar.Control_Alignment_Left );
 // ### TFS 50421 21SEP2021 NAVAB1 moved out of toolbar	toolbar.addFrame(self.frmRetroTop, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnNormal, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnVertical, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnHorizontal, CMUI_Toolbar.Control_Alignment_Left);	
	
	/* //30/07/2025	navkc1 JIRA MTN 35478 using standard notification framework, no longer needed
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	//05 Mar 2021	NDL	TFS 50796
	toolbar.addFrame(self.frmPerformMode, CMUI_Toolbar.Control_Alignment_Right);	//05 Mar 2021	NDL	TFS 50796
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	//05 Mar 2021	NDL	TFS 50796
	*/
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
	toolbar := self.frmQueryToolbar;
	toolbar.addButton(self.btnSelect, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnCloseSelector, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
	
	//08 Mar 2021	NDL	TFS 50796
	// 03/06/2022 	navcs2	53256
	
	/*
	toolbar := self.frmPerformToolbar;
	toolbar.addButton(self.btnClosePerform, CMUI_Toolbar.Control_Alignment_Right);	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	**/
	
	self.setToolbarSearch();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="adjustTableDispForMultiQueWle" id="21751aa6-ee0c-40ae-8a8c-8baea854a1e8">
        <source>adjustTableDispForMultiQueWle( _table : CM_DataTable input; _rowIdx : Integer io; _ti : CM_TrackedItem io  );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2013	cnwndl1	Initial creation	Par 32479
10 December 2025	jlier1	JIRA# 36738
*/

vars

	colIndex : Integer;
	dataStr : String;
	plannedWle : CM_WorkListEntry;
	idx, stridx : Integer;
    entrow : EntTableRow;
	measType : String;
	wle : CM_WorkListEntry;
begin

	if _table = self.tblOnship and _ti.canMergeBreakBulk then
		if self.displayModeOnShip = DISPLAY_MODE_QUEUE then
			colIndex := self.tblOnship.getColumnByRowName( ETRow_TotalQuantity );
			if colIndex &gt; 0 then
				dataStr := _ti.getMultiQueuedWleData(ETRow_TotalQuantity);
				_table.setCellText(_rowIdx,colIndex,dataStr);
			endif;
			colIndex := self.tblOnship.getColumnByRowName( ETRow_QueuedLocnId );
			if colIndex &gt; 0 then
				dataStr := _ti.getMultiQueuedWleData(ETRow_QueuedLocnId);
				_table.setCellText(_rowIdx,colIndex,dataStr);
			endif;
		elseif self.displayModeOnShip = DISPLAY_MODE_PLAN then
			colIndex := self.tblOnship.getColumnByRowName( ETRow_TotalQuantity );
			if colIndex &gt; 0 then
				if not _ti.allPlannedFutureMoves.isEmpty then
					plannedWle := _ti.allPlannedFutureMoves.first.myWorkListEntry;
					if plannedWle &lt;&gt; null then
						dataStr := plannedWle.getDisplayStringForAttribute(ETRow_TotalQuantity, false);
						_table.setCellText(_rowIdx,colIndex,dataStr);
					endif;
				endif;
			endif;
			
			 // TFS 3673
			// ####### WEIGHT
			if not _ti.allPlannedFutureMoves.isEmpty then
				plannedWle := _ti.allPlannedFutureMoves.first.myWorkListEntry;
				if plannedWle &lt;&gt; null then
					colIndex:= 0;
					foreach entrow in self.tblOnship.allTblDataEntRows discreteLock do
						colIndex := colIndex + 1;
						stridx := entrow.name.pos(Prefix_Weight,1);
						if stridx &gt; 0 then
							stridx := entrow.name.reversePos("_") + 1;
							measType := entrow.name[stridx:end];
							dataStr := app.convertMeasurementForDisplay(measType, plannedWle.weight);
							_table.setCellText(_rowIdx,colIndex,dataStr);
						
						endif;
					
					endforeach;
				
				
				
				endif;
			endif;
		endif;
	elseif _table = self.tblOnsite and _ti.isRRPforVoyage then
		colIndex := _table.getColumnByRowName( ETRow_QueuedLocnId );
		if colIndex &gt; 0 then
			dataStr := _ti.getMultiQueuedWleData(ETRow_QueuedLocnId);
			_table.setCellText(_rowIdx,colIndex,dataStr);
		endif;
		colIndex := _table.getColumnByRowName( ETRow_RadioTelemetry);
		if colIndex &gt; 0 then
			if not _table.getCellText(_rowIdx,colIndex) = "Q" then
				wle := _ti.allWorklistEntries.getFirstUnactionedWLE();
				if wle &lt;&gt; null and wle.isKindOf(CM_VoyageWLE) and wle.CM_VoyageWLE.getMyVoyageObject = self.myCurrentVoyage then
					if not wle.allRTQueueEntries.isEmpty then
						_table.setCellText(_rowIdx,colIndex,"Q");	
					endif;
				endif;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
    </JadeMethod>
    <JadeMethod name="allEntRowsIncludes" id="10e9d0b4-7e03-4449-b1c8-e863edd52abc">
        <source>allEntRowsIncludes(_row: EntTableRow): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 March 2018	jlgrh7	Initial creation 	TFS36564

*/

vars

begin
	if self.allTblDataTransientRows.includes(_row) then
		return true;
	endif;
	return inheritMethod(_row);
epilog

end;</source>
        <Parameter name="_row" type="EntTableRow"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="assignTIToReleaseRequest" id="f7623475-8b62-4130-9c9f-9982f3802905">
        <updating/>
        <source>assignTIToReleaseRequest(_wle : CM_WorkListEntry) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
03 November 2025	jlizm1	Initial creation MTN 36255 Rotabox Assign Release To Vessel

*/

vars
	result : Integer;
	moveController : CMIF_MoveController;
	targetLC : CM_LocationsController;
	
begin

	if app.myMoveController = null then
		return;
	endif;
	
	if _wle = null then
		return;
	endif;
	
	targetLC	:= _wle.getTargetLocation;
	if targetLC = null then
		return;
	endif;
	
	if not (targetLC.isGeneralCargoController() or targetLC.isShipBlockStack()) then
		return;
	endif;
	
	sharedLock(_wle);
	
	moveController := app.myMoveController;
	moveController.setMyToPrimaryLocation(targetLC);
	moveController.setMoveMode(PLANNING_MODE);
	
	if not _wle.myRequest.isKindOf(CM_HoldRequest) then
		app.msgBox(app.getErrorString2(Ti_release_not_assigned_hold, moveController.myTrackedItem.id, _wle.id), app.getErrorString(Problem), MsgBox_OK_Only);
		return;
	endif;

	if moveController.myTrackedItem &lt;&gt; null and moveController.myTrackedItem.isInTransitOnShip then
		app.msgBox(app.getErrorString2(YOU_NO_USE_TRANSIT_CARGO, moveController.myTrackedItem.id, _wle.id), app.getErrorString(Problem), MsgBox_OK_Only);
		return;
	endif;
	
	moveController.setMyWorkListEntry(_wle);

	while true do
		app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);	
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Assign To Release', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	
epilog
	if _wle &lt;&gt; null then
		unlock(_wle);
	endif;
	
	app.myDraggedTrackedItem := null;
	
	if app.myMoveController &lt;&gt; null then
		delete app.myMoveController;
	endif;
	
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
