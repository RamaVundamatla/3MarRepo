    <JadeMethod name="displayEntryRTQueues" id="f21dbcbf-c7c7-44aa-85fc-ee0251b98074">
        <source>displayEntryRTQueues(_queue : CM_RadioTelemetryQueue) : String;

// cnwdvb1 16 April 2003 

vars

	str : String;

begin

	str := _queue.id.toUpper;
	if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_Machine) then
		if self.myCurrentObject.CM_Machine.myPrimaryQueue = _queue then
			str := '** ' &amp; _queue.id.toUpper &amp; ' ** ' &amp; Tab &amp; 'PRIMARY';
		endif;
	endif;
	return str;

end;</source>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
        <ReturnType type="String"/>
    </JadeMethod>
