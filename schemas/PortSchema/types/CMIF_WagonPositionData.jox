<Class name="CMIF_WagonPositionData" id="4cbbdf4d-4469-4728-b9b9-335372b778e3">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="allTrackedItems" id="8789ae9f-7ce1-46ba-a379-4759fd236a45">
        <memberTypeInverse/>
        <type name="CM_TIArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="length" id="94200f3b-8a2d-4fcc-a1bb-fbaf4893e7ff">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="position" id="591f46f2-42d1-4578-8375-5c631b4dc27b">
