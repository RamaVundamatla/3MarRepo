    <JadeMethod name="attemptMatch" id="77399ee6-3816-4c97-8955-e70e34d6457f">
        <updating/>
        <source>attemptMatch(_logDocket : CM_BOLIn input;
				_alwaysMatch : Boolean;  //epr TFS 3769 3/4/17
				_passport : CM_Passport input
				) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     23 March 2002 by cnwrs2
//
// Purpose:     returns true if the match was successful
// ---------------------------------------------------------------------------
vars
	ext 		: CM_BOLExtLogIn;
	matchDocket,
	rtnValue	: Boolean;
	tmpTerminal	: CM_Terminal;
	realHdr		: CM_LogScalingHdr;
	amTransient	: Boolean;
	
	_logDocketNull : CM_BOLIn;
begin
                                                    
	amTransient := self.isTransient;
	
	if (not amTransient) then
		exclusiveLock(self);
	endif;

	// search for matching docket in self.myTerminal.allLogBOLsUnmatched dict
	// Need to check all relevent details match
	// If a match found then call a method on BOL that passes through self and sets SED/condition codes
	// on the logs on the BOL and return true
	// Note that when this is called for updating then the persistent CM_LogScalingHdr can be
	// deleted if a match is found
	
	tmpTerminal := _passport.myTerminal;

	if _alwaysMatch then   //epr TFS 3769 3/4/17 if from clicking the match button then always do this otherwise only if config option turned on
		matchDocket:=true;
	else
		matchDocket:= self.myTerminal.getConfig(LogDocketAutoMatch).Boolean;
	endif;
	
	//rtnValue := validateLocationRestrictions(_logDocket, _passport);
	
	if _logDocket &lt;&gt; null and matchDocket then
		// Do this way to avoid a possible deadlock when the matchDateTime is updated
		// This is ok as the docket will just get reprocessed
		if tryLock(_logDocket, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
			ext := _logDocket.myExtension.CM_BOLExtLogIn;
			if (not _logDocket.isMatched) and
			   _logDocket.number = self.bolNumber and
			   _logDocket.getOperatorCode() = self.operatorCode and
			   ext.isNumItemsSameForMatch(self.allLogScalingDtls.size) then

			   //par 19812 cnwjo3
				if validateLocationRestrictions(_logDocket, _passport) then
					if _logDocket.hasUnscaledLogs then
						app.writeLog('   updating unscaledLogs for ' &amp; self.bolNumber, LogINFO);
						rtnValue := ext.updateUnscaledLogsFromScaleHdr(self, _passport);
					else
						app.writeLog('   adding logs for ' &amp; self.bolNumber, LogINFO);
						rtnValue := ext.addLogsFromScaleData(self, _passport);					
					endif;
				endif;
			endif;
		endif;
	endif;

	
	
	if rtnValue  then
		app.writeLog('   Match found for ' &amp; self.bolNumber, LogINFO);
		// a match was found and sucessful 
		// now we set the match time only
		// will be removed from the unmatched dict by the complete road in process if moved successfully
		_logDocket.setMatchTime(app.serverTimestampAtTrxStart);
		// send note docket recon window to remove this docket
					
		tmpTerminal.causeEvent(tmpTerminal.getTerminalEvent(BOLRecon_Update_Event), false, _logDocket);
		
		if (not amTransient) then
			tmpTerminal.causeEvent(tmpTerminal.getTerminalEvent(BOLRecon_Delete_Event), false, self);	
			delete self;
		endif;
	else
		// no match was found so
		if amTransient then
			// convert self to a persistent
			app.writeLog(method.name &amp; ' no match found for ' &amp; self.bolNumber, LogINFO);
			create realHdr persistent;
			realHdr.setForCreate(self);
			if _passport.noErrors then
				tmpTerminal.causeEvent(tmpTerminal.getTerminalEvent(BOLRecon_Create_Event), false, realHdr);
			endif;
		endif;
	endif;
	
	return rtnValue;
	
end;</source>
        <Parameter name="_logDocket" type="CM_BOLIn" usage="input"/>
        <Parameter name="_alwaysMatch" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createDtls" id="93cccef1-696e-452a-a321-82bd1ba30c8f">
        <updating/>
        <source>createDtls(_pxy : CM_LogScalingHdr)updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pxyDtl,
	realDtl		: CM_LogScalingDtl;
	pxyExtra,
	realTmp,	
	realExtra	: CM_LogScalingExtra;
	isFound		: Boolean;
	tmpMaxSed,
	tmpMinSed,
	tmpMeanSed	: Decimal[12,2];
	numDtls		: Integer;

begin

	// Always clear out first
	self.allLogScalingDtls.purge;
	
	// Now create the real dtl records
	foreach pxyDtl in _pxy.allLogScalingDtls do
		create realDtl persistent;
		realDtl.setForCreate(pxyDtl, self);
		//accumulate total min/max/mean seds

		tmpMaxSed := (tmpMaxSed + realDtl.maxSED);
		tmpMinSed := (tmpMinSed + realDtl.minSED);
		tmpMeanSed := (tmpMeanSed + global.calcSEDMean(realDtl.minSED, realDtl.maxSED));
	endforeach;	
	
	numDtls := self.allLogScalingDtls.size;

	//Now set the averages for this header
	self.averageMaxSed := (tmpMaxSed / numDtls);
	self.averageMinSed := (tmpMinSed / numDtls);
	self.averageMeanSed := (tmpMeanSed / numDtls);
	
	self.allLogScalingExtra.purge();
	foreach pxyExtra in _pxy.allLogScalingExtra do
		isFound := false;
		foreach realTmp in  self.allLogScalingExtra do
			if	realTmp.scalerCode = pxyExtra.scalerCode and
				realTmp.scalingStartTime = pxyExtra.scalingStartTime and
				realTmp.scalingFinishTime = pxyExtra.scalingFinishTime then
				isFound := true;
				break;
			endif;
		endforeach;
		if not isFound then
			create realExtra persistent;
			realExtra.setForCreate(pxyExtra, self);
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_pxy" type="CM_LogScalingHdr"/>
    </JadeMethod>
    <JadeMethod name="createScalingExtra" id="267e90df-9832-45a7-b22d-492ee22f43e4">
        <source>createScalingExtra(_newHdr : CM_LogScalingHdr);

// cnwdvb1 11 June 2003 

vars

	oldPxyExtra,
	newPxyExtra	: CM_LogScalingExtra;

begin

	foreach oldPxyExtra in self.allLogScalingExtra do
		// Might as well just create as we need to call setProxy anyway.
		create newPxyExtra transient;
		newPxyExtra.setProxy(_newHdr, oldPxyExtra.scalerCode, oldPxyExtra.scalingStartTime, oldPxyExtra.scalingFinishTime);
	endforeach;	

end;</source>
        <Parameter name="_newHdr" type="CM_LogScalingHdr"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="00d49a90-a2fb-4f9b-a903-743372a63af6">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//-----------------------------------------
//Created: October 2002 By: cnwgd1
//-----------------------------------------
vars
	localTime: TimeStamp;
begin
	if _attrName = ETRow_DocketNumber then
		return self.bolNumber;
	elseif _attrName = ETRow_Supplier then
		return self.operatorCode;
	elseif _attrName = ETRow_MatchFound then
		return 'No';				
	elseif _attrName = ETRow_NoLogs then
		return self.allLogScalingDtls.size.String;		
	elseif _attrName = ETRow_DateTime then
		localTime := self.systemToLocalTime(self.inputDateTime);
		return localTime.Date.shortFormatJMT() &amp; ' ' &amp; localTime.Time.shortFormatJMT();	// 19/04/2016 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_IsReleaseDocket then
		return 'Receipt';								
	else
		return inheritMethod(_attrName, _short);
	endif;
	
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMatchingBOL" id="74617ca0-b221-4b8b-97d1-93ba91787def">
        <source>getMatchingBOL() : CM_BOLIn;
// ---------------------------------------------------------------------------
// Created:     23 March 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	
begin
	return self.myTerminal.getUnmatchedLogDocket(self.bolNumber, self.operatorCode, self.allLogScalingDtls.size, false);
end;</source>
        <ReturnType type="CM_BOLIn"/>
    </JadeMethod>
