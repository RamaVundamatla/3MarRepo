    <JadeMethod name="raiseAlert" id="7efb5001-5b5e-4a1c-a572-e86b73822af6">
        <source>raiseAlert(_shortMsg, _longMsg: String; _severity: Integer);
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	alert: CM_SystemAlert;
begin
	
	create alert transient;
	alert.details := _shortMsg;
	alert.setSeverity(_severity);
	alert.addLogEntry(_longMsg);
	alert.add;
	app.commitAlert();
end;</source>
        <Parameter name="_shortMsg" type="String"/>
        <Parameter name="_longMsg" type="String"/>
        <Parameter name="_severity" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="5c132b03-8c36-4eba-a572-f66769ed5d45">
        <updating/>
        <source>setForCreate(_movement : HMS_VoyageMovement; _resUsed : HMS_ResourceUsed; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	if _resUsed = null then
		app.raiseUnexpectedProgramError(class. name, method.name, 'null resource used');
		return;
	endif;

	if _movement = null then
		app.raiseUnexpectedProgramError(class. name, method.name, 'null _movement');
		return;
	endif;	
	
	self.myMovement := _movement;
	self.myHMSVoyageData := _movement.myHMSVoyageData;
	self.myVoyage := self.myHMSVoyageData.myVoyage;
	self.myTerminal := self.myVoyage.myTerminal;
		
	self.myResourceUsed := _resUsed;
	// 37145 Dec 2015 actually use the voyage movement "Movement not chargeable" option as set
	self.noCharge := not _movement.chargeForMove;
	
	if self.myResourceUsed.myResource = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'null resource');
		return;
	endif;
	
	self.transactionDT := app.serverTimestampAtTrxStart;
	self.partOfContract := 	_resUsed.partOfContract;
	self.userCode := _passport.userCode;
	self.userName := _passport.myUser.userName;
end;</source>
        <Parameter name="_movement" type="HMS_VoyageMovement"/>
        <Parameter name="_resUsed" type="HMS_ResourceUsed"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateResync" id="6ba22930-3f56-4296-b89c-fab2c7015a03">
        <updating/>
        <source>setForUpdateResync(_controller:CMIF_TiTransactionResync; _passport : CM_Passport input) updating;
// Feb 2012 CCMS 1262 transaction Enquiry add resync for voyage transactions
//Date			Who		Reason
//23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
vars
	message	: String;
	bu : CM_Bank;
begin
	
	bu := self.getBank();
	
	if bu = null then
		app.invLog("No business unit, no charge", LogTRACE.String);
		return;
	endif;
	
	bu.createChargeVoyageResync(self, message);
	message := message.trimBlanks;
	if message &lt;&gt; null then
		app.invLog("Resync Problem " &amp; message, LogTRACE.String);
	endif;
end;</source>
        <Parameter name="_controller" type="CMIF_TiTransactionResync"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
