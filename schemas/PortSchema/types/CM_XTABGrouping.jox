    <JadeMethod name="cloneSelf" id="b52390fc-f508-4540-9058-ef9c0cdd20e9">
        <source>cloneSelf(_transient: Boolean): SelfType;
// ---------------------------------------------------------------------------
// Created:     16 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/11/2009	cnwcs5		ccms 1028 - summary mappings can now be shared and 
//							don't belong to the xtab element
// ---------------------------------------------------------------------------
vars
	clone	:SelfType;
begin
	clone :=  inheritMethod(_transient);

	if self.myXTABMapping &lt;&gt; null then
		clone.myXTABMapping := self.myXTABMapping;	// 24/11/2009 - cnwcs5
	endif;

	return clone;
epilog

end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="getHeading" id="fd804f1f-b2be-4d9d-94a3-ccae1008e028">
        <source>getHeading():String;
// ---------------------------------------------------------------------------
// Created:     11 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.heading &lt;&gt; null then
		return self.heading;
	endif;
	
	return self.getQueryPropertyTerminology ();
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getKeyLength" id="bfe85c89-baae-407c-bac2-d3113389e96f">
        <source>getKeyLength(): Integer;
// ---------------------------------------------------------------------------
// Created:     16 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	value	:Integer;
begin
	value := inheritMethod();

	if self.myXTABMapping &lt;&gt; null then
		value := value.max (self.myXTABMapping.getMaxMappingValueLength);
	endif;
	// 36979 Dec 2015 the key values are 'put' and 'got' using a transient method which takes the individual key values in a StringArray parameter
	//			so limit the individual key lengths to 62 here.  Also handle max length (-1) the same way.
	if value &lt; 0 or 
	   value &gt; 62 then
		value := 62;
	endif;
	return value;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getName" id="4b312364-e525-47ba-8b29-9becc33a69f6">
        <source>getName() : String;

vars
	returnStr	: String;
	
begin
	returnStr	:= inheritMethod();
	
//	if myOutputFormat &lt;&gt; null then
//		returnStr	:= returnStr &amp; Tab &amp; myOutputFormat.name.padBlanks( 30 );
//	endif;
	
	returnStr	:= returnStr &amp; Tab &amp; descending.cnEcGetYesNo;
	
	return returnStr;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSummaryHeading" id="07562bbd-8e5c-4ce9-a275-cafcab60cb2b">
        <source>getSummaryHeading():String;
// ---------------------------------------------------------------------------
// Created:     15 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.summaryHeading &lt;&gt; null then
		return self.summaryHeading;
	endif;
	
	return self.heading;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isColumn" id="580d7d71-cd59-4bb8-ad30-f4ec6f9aad4f">
