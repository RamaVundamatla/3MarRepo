    <JadeMethod name="doAutoPlan" id="0f16e7e3-54be-422d-8b39-ea8418a9dbc2">
        <updating/>
        <source>doAutoPlan() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 March 2010	cnwndl1	Initial creation

*/

vars
	result : Integer;
	errMsg : String;
	job : CM_Job;
	wle : CM_WorkListEntry;
	
begin
	//return;  //14 May 2010	NDL	 Par 23603	disabled and hidden, 10 Jul 2012 Knew we'd need it again.... Par 29961 

	if self.myTrackedItem = null then
		return;
	endif;
	
	if self.msgBox( app.getErrorString1( Autoplan_Continue, self.myTrackedItem.id ) , app.getErrorString(Warning), MsgBox_Yes_No, false ) = MsgBox_Return_No then
		return;
	endif;
	
	//30 Mar 2010	NDL	Par 23486
	if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipDischargeCargo then
		job := self.myTrackedItem.getFirstAvailableDischargeJob();
		//11 Jul 2012	NDL	Par 29961
		wle := self.myTrackedItem.getVoyageWLEForJob(job.CM_VoyageJob);
		if wle &lt;&gt; null and wle.isCompleteForJob then
			job := null;
		endif;
	endif;
	result := self.myMobileGenericAgent.rePlanTi( self.myTrackedItem, job, 0 );
	
	if self.myTrackedItem.myPrimaryQueuedLocation &lt;&gt; null then
		errMsg := app.getErrorString2( Tracked_item_queued, self.myTrackedItem.id, self.myTrackedItem.myPrimaryQueuedLocation.getFullId);
	else
		errMsg := app.getErrorString1( Not_queued_anywhere, self.myTrackedItem.id);
	endif;
	
	//29 Apr 2010	NDL	Par 23945
	if self.myTrackedItem.myPrimaryQueuedLocation &lt;&gt; null then
		//self.txtLocation.text := self.myTrackedItem.myPrimaryQueuedLocation.getFullId;
		self.setTxtLocationDetails( self.myTrackedItem.myPrimaryQueuedLocation.getFullId, self.myTrackedItem.myPrimaryQueuedLocation );	//20 Oct 2011	NDL	Par 28254
	elseif self.myTrackedItem.myPrimaryPlannedLocation &lt;&gt; null then
		//self.txtLocation.text := self.myTrackedItem.myPrimaryPlannedLocation.getFullId;
		self.setTxtLocationDetails( self.myTrackedItem.myPrimaryPlannedLocation.getFullId, self.myTrackedItem.myPrimaryPlannedLocation );	//20 Oct 2011	NDL	Par 28254
	else
		self.resetLocationDisplay();
	endif;
	
	self.msgBox( errMsg, app.getErrorString(Warning), MsgBox_OK_Only, false );
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doChangeIsoType" id="61012086-b28c-4b2c-8f65-83cf22238862">
        <source>doChangeIsoType();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 March 2010	cnwndl1	Initial creation

*/

vars

	selectedIsoType : CM_ISOType;
	pxyTi : CM_TrackedItem;
	isLoadStateSet : Boolean;
	result : Integer;
	warning : String;
	job : CM_Job;
	
	updated : Boolean;
	ti : CM_TrackedItem;
	
begin

	//handle change to isotype
	selectedIsoType := cmbIsoType.listObject.CM_ISOType;
	ti := self.myTrackedItem;	//11 Oct 2010	NDL	Par 25836
	if selectedIsoType &lt;&gt; null and ti &lt;&gt; null and ti.getISOTypeObject &lt;&gt; selectedIsoType then
	
	/*	warning := app.getErrorString(Change_ISOType_Continue);
		if self.msgBox(warning ,app.getErrorString(Warning), MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;
		
		app.cmsBeginLoad(isLoadStateSet);
		pxyTi := self.myTrackedItem.pxyCreateUpdateProxy();
		app.cmsBeginLoad(isLoadStateSet);
		
		while true do
	
			app.myTrxUA.trxUpdateTrackedItem(	pxyTi,
												null,
												TI_UPDMODE_NORMAL, 
												null, 
												app.myPassport);
	
	
			
			if app.myPassport.trxCompletedOK then
				result := IDOK;
				break;
			else
				result := app.showErrorWarningDialog(app.getErrorString(Cargo_item_update), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
			
		endwhile; */
		
		result := self.doIsoTypeChange( 	selectedIsoType,	//_newIsoType : CM_ISOType;
											ti,	//_realTrackedItem : CM_TrackedItem io;
											updated	//_updated : Boolean output
											);
		
		//14 May 2010	NDL	Par 23603
		if updated and result = IDOK then
			if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.ShipDischargeCargo then
				job := self.myTrackedItem.getFirstAvailableDischargeJob();
			endif;
	//		delete pxyTi;
			self.myMobileGenericAgent.rePlanTi( self.myTrackedItem, job, 0 );
		endif;
	
	endif;
	
epilog

//	delete pxyTi;
	
end;</source>
    </JadeMethod>
