    <JadeMethod name="showVoyAllocScreens" id="aeb95213-35df-4f54-af0b-942173e3865b">
        <source>showVoyAllocScreens();
// ---------------------------------------------------------------------------
// Created:     01 February 2010 by cnwab1
//
// Changed On   Changed By  	Reason
// ----------   ----------  	--------------------------------------------------
// 02/03/2011	cnwmh5			#25151 - Change to check display mode being discharge rather than load
// ---------------------------------------------------------------------------

vars
	isExport : Boolean;
begin
	if self.myCurrentVoyage &lt;&gt; null then
	
		if self.myCurrentVoyage.useVoyageAllocations then		
		
			if self.myCCScreen = null then 
				self.myAssistant.SHP_Assistant.showCCVoyageRORO(self,self.myCurrentVoyage, self.myMasterMenuAction,null, (self.modeView = ShpDisplayMode_ColCodeLoad));	
			else
				self.myCCScreen.visible := true;
			endif;
			
			//24 Jan 2012	NDL	Par 28896
			isExport := (self.modeView = ShpDisplayMode_ColCodeLoad);
			if isExport then
				if self.myCCPaletteLoad = null then 
					self.myAssistant.SHP_Assistant.showCCPalletteRORO(self,self.myCurrentVoyage, self.myMasterMenuAction,null, isExport); 
				else
					self.myCCPaletteLoad.visible := true;
				endif;
				
			elseif not isExport then
				if self.myCCPalette = null then 
					self.myAssistant.SHP_Assistant.showCCPalletteRORO(self,self.myCurrentVoyage, self.myMasterMenuAction,null, isExport); 
				else
					self.myCCPalette.visible := true;
				endif;
				
			endif;
			/*
			if self.myCCPalette = null then 
				self.myAssistant.SHP_Assistant.showCCPalletteRORO(self,self.myCurrentVoyage, self.myMasterMenuAction,null, (self.modeView = ShpDisplayMode_ColCodeLoad)); 
			else
				self.myCCPalette.visible := true;
			endif;
				
			*/
		else
			// PAR 28513
			app.msgBox(app.getErrorString2(Voyag_does_not_voyag_alloc_ple, self.myCurrentVoyage.code, self.myCurrentVoyage.code),
								app.getErrorString(Voyage_issue), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		
		
	endif;


epilog

end;</source>
    </JadeMethod>
