    <JadeMethod name="addCamHistory" id="ea33ce62-d1a3-47cd-a934-6f2ebef327ef">
        <source>addCamHistory( camProtocol : CM_CamProtocol; seqNum : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 February 2020	jlgndl1	Initial creation	TFS 48545

*/

vars

	proxyCamHistory : CM_CamTaskHistory;
	camTaskHistory : CM_CamTaskHistory;
	now : TimeStamp;
	camAgent : CM_CamControllerAgent;

begin

	create camAgent transient;

	create proxyCamHistory transient;
	proxyCamHistory.set(now, now, now, false, camProtocol, seqNum, 1, "", CAM_COMPLETESTATUS, "");

	app.myTrxCA.trxCreateCamTaskHistory(proxyCamHistory, camTaskHistory, camProtocol, camAgent, app.myPassport);
	
epilog

	delete proxyCamHistory;
	delete camAgent;

end;</source>
        <Parameter name="camProtocol" type="CM_CamProtocol"/>
        <Parameter name="seqNum" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addRepair" id="e696dd81-8686-41da-b53e-148ba5adb7fc">
        <source>addRepair(_damageInstance: CM_DamageInstance; _repairReason: CM_RepairReason; _fixedTime: TimeStamp; _repairRemarks: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2023	navra1	Initial creation

*/

vars
	pxyTI		: CM_TrackedItem;
	pxyDamage	: CM_DamageInstance;
begin
	pxyTI := app.createUpdateProxy(_damageInstance.myTrackedItem).CM_TrackedItem;
	self.assertNotNullMsg(pxyTI, "Error creating TI Proxy");
	
	pxyDamage := app.myProxyManager.getProxyObject(_damageInstance).CM_DamageInstance;
	
	pxyDamage.setProxy(pxyTI, null, _damageInstance.myDamageDefinition, _damageInstance.myDamagePosition, _damageInstance.remarks, false,
						_damageInstance.quantity, _damageInstance.myDamageSeverity, _damageInstance.locationString, _damageInstance.myDamagePlace, _damageInstance.myDamageParty,
						_damageInstance.myDamageReason, _repairReason, _damageInstance.damageSize, _damageInstance.damageDateTime, DamageStatusRepaired, _repairRemarks,
						_fixedTime);
	
	
	app.myTrxUA.trxUpdateTrackedItem(pxyTI, method.qualifiedName, TI_UPDMODE_NORMAL, null, app.myPassport);

	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
epilog
	delete pxyDamage;
	delete pxyTI;
end;</source>
        <Parameter name="_damageInstance" type="CM_DamageInstance"/>
        <Parameter name="_repairReason" type="CM_RepairReason"/>
        <Parameter name="_fixedTime" type="TimeStamp"/>
        <Parameter name="_repairRemarks" type="String"/>
    </JadeMethod>
    <JadeMethod name="convertJsonKeysToLowerCase" id="4a8f14ae-28ae-4bb3-91ca-f24bb0a00b07">
        <source>convertJsonKeysToLowerCase(inputJson : String input);
/*

Purpose:			

Parameters:			
	This method is used to convert the first char of all the keys in the json to lower, for instance when a json string like this is passed in,
	{
		"Key1":"value1",
		"Key2":"value2"
	}
	it would be converted to,
	{
		"key1":"value1",
		"key2":"value2"
	}

Return Value:		

	The value is converted in the passed in string "input" parameter inputJson

Date		Who		Reason
23 February 2023	navra1	Initial creation for TFS - 55859

*/

vars
	jsonStringLength : Integer;
	i : Integer;
	valuePortion : Boolean;
	quotesNumber    : Integer;
	
	insideValueQuotes :Boolean;
begin
	quotesNumber   := 0;
	insideValueQuotes := false;
	valuePortion  := false;
	jsonStringLength := inputJson.length;
	i := 0;
	
	//write CrLf&amp; CrLf&amp; 'got' &amp;CrLf&amp; inputJson;
	
	while i &lt; jsonStringLength do
		i := i+1;
		
		if inputJson[i] = '"' and not valuePortion then //count the quotes encountered in the key portion alone
			quotesNumber := quotesNumber + 1;
		endif;
		
		if inputJson[i] = ':' then	//we are entering the value portion
			valuePortion  :=true;
		endif;	
		
		if valuePortion and inputJson[i]='"' then	//know when you are inside any string inside the value to avoid special chars( } or , or { )
			insideValueQuotes := not insideValueQuotes;
		endif;		
				
		if valuePortion then //if we are in the value portion
			if not insideValueQuotes then				//ignore any ',' or '}' or '{' inside the value - dont let it make you think the value is over
				if inputJson[i] = '}' or inputJson[i] = ',' or inputJson[i] = '{' then	//either the value portion has has ended with a ',' or a '}' 
																						//or we are starting a new subsection and entering the key section 
																						//again(even if its an array we will definitely encounter a '{'
																						//before the keys, and so we can use that as our mark
					valuePortion := false;
				endif;
			endif;
		endif;
		
		if inputJson[i] = '"' and quotesNumber mod 2 &lt;&gt; 0 and not valuePortion then	//every char after the odd numbered quotes in the key portion should be case-lowered
			if i &lt; jsonStringLength then 	//safety for index bounds
				inputJson[i+1] := inputJson[i+1].toLower();
			endif;
		endif;
	endwhile;	
	
	//write CrLf&amp;CrLf&amp; 'converted' &amp;CrLf&amp; inputJson;
epilog

end;</source>
        <Parameter name="inputJson" type="String" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createCamProtocol" id="6998b20f-9517-4e61-bd64-b7db75ff4730">
        <source>createCamProtocol(_name :String; _camGroup :CM_CamGroup; _portDesc :String; _operatorXlationCode : String;
					_camProtocolDesc :CM_CamProtocolDesc; _singleContainerPerBGM, _isSingleTransPerFile, _useContainerOperator_NAD_CF :Boolean;
					_transactions :StringArray; _cargoTypes: IntegerArray; _camTrainEventTypes : CM_EventTypeByNameDict; _camEditTriggerFields : CM_CamEditTriggerFieldDict;
					_jrwdReportName  : String) : CM_CamProtocol protected;
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
///19 Nov 2014	cnwrs1		CCMS 2405 - Alabama Steel Cams
// 26 May 2016	cnwrs1		Add Scedule for now
// 25 May 2017	cnwrs1		TFS 4465
// 05 May 2023	navmd1		TFS 57678 Added additional Opts
// ---------------------------------------------------------------------------
vars
	camProtocol				:CM_CamProtocol;
	emailEntity 			: CM_EmailEntity;
	scheduleTimes 			: TimeArray;
	freightForwarders 		: CM_ConsigneeConsignorSet;
	allCoarriExportPorts 	: CM_PortByCodeDict;
	emailCopyAddresses 		: CM_EmailEntityByTypeNameDict;
	packOperators 			: CM_OperatorByCodeDict;
	packExportConsignees 	: CM_ConsignByCodeDict;
//	camEditTriggerFields 	: CM_CamEditTriggerFieldDict;
//	camTrainEventTypes 		: CM_EventTypeByNameDict;
	allPackAreas 			: CM_TAByIdDict;
	firstRunDateTime,
	lastRunDateTime			: TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	singleBGMUNZTransactionPerFile : Boolean;
//	isSingleTransPerFile : Boolean;
	time : Time;
	useVoyageOp : Boolean;
	useTiOperator : Boolean;
	fileSuffix : String;
	useSpecialFileName : Boolean;
begin
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create scheduleTimes transient;
	time := app.actualTimeServer.Time;
	scheduleTimes.add(time);
//	create camEditTriggerFields transient;
//	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	if _cargoTypes = null then
		lRegisteredCargoTypes.add(TI_CargoType_Container);
	else
		_cargoTypes.copy(lRegisteredCargoTypes);
	endif;
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	singleBGMUNZTransactionPerFile := false;
	useTiOperator := true;
	if self.opts.includesKey('useTiOperator') then
		useVoyageOp :=  self.opts.bool('useTiOperator');
	endif;
	if self.opts.includesKey('useVoyageOp') then
		useVoyageOp :=  self.opts.bool('useVoyageOp');
	endif;
	
	fileSuffix := self.opts.strDef("fileSuffix", "txt");
	
	useSpecialFileName := true;
	if self.opts.includesKey('dontUseSpecialFileName') then
		useSpecialFileName := not self.opts.bool("dontUseSpecialFileName");
	endif;
	
	if self.opts.includesKey(CM_CamProtocol::firstRunDateTime.name) then
		firstRunDateTime := self.opts.timestamp(CM_CamProtocol::firstRunDateTime.name);
	endif;
	if self.opts.includesKey(CM_CamProtocol::lastRunDateTime.name) then
		lastRunDateTime := self.opts.timestamp(CM_CamProtocol::lastRunDateTime.name);
	endif;
	
//	isSingleTransPerFile := false;
// do not change these parameters - it will break all the unit tests !!!
	app.myPassport.setWarningsIgnored(true);	
	camProtocol 	:= self.addCamProtocol(_name, _name, allCoarriExportPorts, _camGroup, _portDesc, emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   firstRunDateTime, lastRunDateTime, useSpecialFileName, null, fileSuffix, _operatorXlationCode, packOperators, packExportConsignees, null, _camProtocolDesc, _transactions,
									   false, 1, useVoyageOp, scheduleTimes, 
									   false, false, false, false, false, false, false, false, false, false, _singleContainerPerBGM, singleBGMUNZTransactionPerFile, 
									   false, false, false, false, _useContainerOperator_NAD_CF, false, false, false, false, _isSingleTransPerFile, false, false,  
									   0, 0, 0, 0, '', '', _jrwdReportName, _camEditTriggerFields, _camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, true /* null voyage*/, useTiOperator, 
									   allPackAreas, null, null, lRegisteredCargoTypes);

	self.assertNotNullMsg(camProtocol, 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString());
	self.assertNotNull(camProtocol);
									   
	return camProtocol;
epilog
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete scheduleTimes;
//	delete camEditTriggerFields;
//	delete camTrainEventTypes;
	delete allPackAreas;
	delete lRegisteredCargoTypes;
end;</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
        <Parameter name="_camGroup" type="CM_CamGroup"/>
        <Parameter name="_portDesc" type="String"/>
        <Parameter name="_operatorXlationCode" type="String"/>
        <Parameter name="_camProtocolDesc" type="CM_CamProtocolDesc"/>
        <Parameter name="_singleContainerPerBGM" type="Boolean"/>
        <Parameter name="_isSingleTransPerFile" type="Boolean"/>
        <Parameter name="_useContainerOperator_NAD_CF" type="Boolean"/>
        <Parameter name="_transactions" type="StringArray"/>
        <Parameter name="_cargoTypes" type="IntegerArray"/>
        <Parameter name="_camTrainEventTypes" type="CM_EventTypeByNameDict"/>
        <Parameter name="_camEditTriggerFields" type="CM_CamEditTriggerFieldDict"/>
        <Parameter name="_jrwdReportName" type="String"/>
        <ReturnType type="CM_CamProtocol"/>
    </JadeMethod>
    <JadeMethod name="createCamProtocolCoarri" id="cba8626e-cf1c-4a63-ab9c-4e33c30933b4">
        <source>createCamProtocolCoarri(_name :String; _camGroup :CM_CamGroup; _desc,  _portDesc :String; _operatorXlationCode : String):CM_CamProtocol protected;
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	camProtocol				:CM_CamProtocol;
	registeredTransactions 	: StringArray;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
begin
	create camEditTriggerFields transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveShip).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseShip).asStringJMT);

	camProtocol := self.createCamProtocol (_name, _camGroup, _portDesc, _operatorXlationCode, app.myRoot.allCamProtocolDescs[_desc], false, false, true,
											registeredTransactions, null, null, camEditTriggerFields,null);

	self.assertNotNullMsg(camProtocol, 'Add failed ' &amp; CrLf &amp; app.myPassport.getErrorsAsString());
	self.assertNotNull(camProtocol);
									   
	return camProtocol;
epilog
	delete registeredTransactions;
	delete camEditTriggerFields;
end;</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
        <Parameter name="_camGroup" type="CM_CamGroup"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_portDesc" type="String"/>
        <Parameter name="_operatorXlationCode" type="String"/>
        <ReturnType type="CM_CamProtocol"/>
    </JadeMethod>
    <JadeMethod name="createCamProtocolCodeco" id="8299e351-e39f-46c8-b0c8-db65fd45e1e4">
        <source>createCamProtocolCodeco(_name :String; _camGroup :CM_CamGroup; _desc, _portDesc :String; _operatorXlationCode : String; _trxColl :StringArray; _singleContainerPerBGM, _isSingleTransPerFile : Boolean):CM_CamProtocol protected;
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwcs5
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09 Aug 2013	cnwcs5	par 32148
///19 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
// ---------------------------------------------------------------------------
vars
	camProtocol				:CM_CamProtocol;
	registeredTransactions 	: StringArray;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
begin
	create camEditTriggerFields transient;
	create registeredTransactions transient;
	
	if _trxColl &lt;&gt; null and _trxColl.size &gt; 0 then
		_trxColl.copy (registeredTransactions);
	else
		registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
		registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRoad).asStringJMT);
		registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRail).asStringJMT);
		registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRail).asStringJMT);
	endif;
	
	camProtocol := self.createCamProtocol (_name, _camGroup, _portDesc, _operatorXlationCode, app.myRoot.allCamProtocolDescs[_desc], _singleContainerPerBGM, _isSingleTransPerFile, true,
											registeredTransactions, null, null, camEditTriggerFields,null);

	self.assertNotNullMsg(camProtocol, 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString());
	self.assertNotNull(camProtocol);
									   
	return camProtocol;
epilog
	delete registeredTransactions;
	delete camEditTriggerFields;
end;</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
        <Parameter name="_camGroup" type="CM_CamGroup"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_portDesc" type="String"/>
        <Parameter name="_operatorXlationCode" type="String"/>
        <Parameter name="_trxColl" type="StringArray"/>
        <Parameter name="_singleContainerPerBGM" type="Boolean"/>
        <Parameter name="_isSingleTransPerFile" type="Boolean"/>
        <ReturnType type="CM_CamProtocol"/>
    </JadeMethod>
    <JadeMethod name="createCamProtocolCodecoBarge" id="35d67991-1d96-4ee6-b2ed-a1ba44dcf435">
        <source>createCamProtocolCodecoBarge(_name :String; _camGroup :CM_CamGroup; _desc, _portDesc :String; _operatorXlationCode : String; _trxColl :StringArray; _singleContainerPerBGM, _isSingleTransPerFile : Boolean):CM_CamProtocol protected;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 03 January 2019
TFS#		: 37102
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	camProtocol				: CM_CamProtocol;
	registeredTransactions 	: StringArray;
	camEditTriggerFields 	: CM_CamEditTriggerFieldDict;
begin
	create camEditTriggerFields transient;
	create registeredTransactions transient;
	
	if _trxColl &lt;&gt; null and _trxColl.size &gt; 0 then
		_trxColl.copy (registeredTransactions);
	else
		registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveShip).asStringJMT);		
		registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveDepotShip).asStringJMT);
		registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveMarineShip).asStringJMT);
		registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReceiveWHouseShip).asStringJMT);
		registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseShip).asStringJMT);
		registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseDepotShip).asStringJMT);
		registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseMarineShip).asStringJMT);
		registeredTransactions.add(global.getTiTxnTypeForClass(CM_SubTermReleaseWHouseShip).asStringJMT);
		
	endif;
	
	camProtocol := self.createCamProtocol (_name, _camGroup, _portDesc, _operatorXlationCode, app.myRoot.allCamProtocolDescs[_desc], _singleContainerPerBGM, _isSingleTransPerFile, true,
											registeredTransactions, null, null, camEditTriggerFields,null);

	self.assertNotNullMsg(camProtocol, 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString());
	self.assertNotNull(camProtocol);
									   
	return camProtocol;
epilog
	delete registeredTransactions;
	delete camEditTriggerFields;
end;</source>
        <access>protected</access>
