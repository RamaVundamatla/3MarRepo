    <JadeMethod name="utlCreateOpCarrierCrit" id="d1496424-c56c-4e52-a99c-f7bca434c55e">
        <updating/>
        <source>utlCreateOpCarrierCrit(_pxyOpCrit : CM_OperatorCarrierCriteria input; _realOpCrit : CM_OperatorCarrierCriteria output; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars
	updAgent : CM_UtilityUpdateAgent;

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	app.myValCA.valObjMatchCrit(_pxyOpCrit, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	if app.myPassport.noErrors then
		create updAgent transient;
		updAgent.myUpdateAuditAgent.audUpdateGeneric(_pxyOpCrit.myOperator, true);
	endif;
	
	app.setContinueCMExceptions(false);

	create _realOpCrit as _pxyOpCrit.class persistent;
	_realOpCrit.setForUpdate(_pxyOpCrit);
	
	if app.myPassport.noErrors and updAgent &lt;&gt; null then
		updAgent.myUpdateAuditAgent.audUpdateGeneric(_realOpCrit.myOperator, false);
	endif;

epilog
	delete updAgent;
end;</source>
        <Parameter name="_pxyOpCrit" type="CM_OperatorCarrierCriteria" usage="input"/>
        <Parameter name="_realOpCrit" type="CM_OperatorCarrierCriteria" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
