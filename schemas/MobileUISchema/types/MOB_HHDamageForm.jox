    <JadeMethod name="setupForm" id="94ab16bd-d4b7-4f92-ab1c-e11ec4041c9a">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:	09 January 2009 By Graeme Black cnwgb1
// Status: 	
// Purpose:	
// ---------------------------------------------------------------------------
vars

	ti : CM_TrackedItem;
	
begin

	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	ti := app.myMobileCargoFindAgent.myTrackedItemToProcess;
	if ti &lt;&gt; null then
		//returning from a specific search
		self.setMyTrackedItem(  app.myMobileCargoFindAgent.myTrackedItemToProcess );
	else
		// populated on one of the other maint forms
		self.setMyTrackedItem( self.getSessionAgent().mySelectedTI );
	endif;
	
	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;	//09 Apr 2014	Par 33934
	
	inheritMethod();
	// 37244 from to-do task completion
	if self.myToDoTaskDesc = null then
		self.setupCmdButtons( 3, app.getErrorString(Edit), app.getErrorString(Cancel), BACK_BUTTON, null, null );		//epr par 33025 
	else
		self.setupCmdButtons( 2, app.getErrorString(Save), app.getErrorString(Back), null, null, null );
	endif;
	self.setupControls();
	
	// 37244 from to-do task completion
	if self.myToDoTaskDesc &lt;&gt; null then
		self.setForEdit();
	endif;
	
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblDamages_change" id="590ebb12-a92e-4f7f-ac14-702ca55111a6">
        <controlMethod name="Table::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDamages_change(table: Table input) updating;
/*
Date		Who		Reason
29 January 2009	cnwcp2	Initial creation
*/

vars

begin
	somethingChanged := true;
	self.btnOne.enabled := true;
	self.btnOne.caption := app.getErrorString(Save);
	self.chkToDo.enabled := true; //cnwas3 par 24175
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblDamages_rowColumnChg" id="9c576997-0521-4b71-86e2-907e9fa875c1">
        <controlMethod name="Table::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDamages_rowColumnChg(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 October 2016	cnwndl1	Initial creation	TFS 2802

*/

vars

begin

	if table.row = table.rows and table.column = table.columns then
		if not self.myMobileGenericAgent.unpackChangeID then // becuase this causes auto prefilling
			self.tblDamages.addNewRow();
		endif;
		
	//21 Aug 2019	NDL	TFS 46193
	elseif table.row = table.rows and table.column = ( table.columns - 1 ) and not table.accessColumn( table.columns ).visible then
		//the last column is hidden and we are in the last visible cell, do the same thing
		if not self.myMobileGenericAgent.unpackChangeID then // becuase this causes auto prefilling
			self.tblDamages.addNewRow();
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c7c2c907-dcf9-4f5a-b378-916ae8959577">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 May 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013024, locale);
	chkToDo.translateCaption(Xlat_0014812, locale);
	lblCargoId.translateCaption(Xlat_0019051, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_gotFocus" id="4aebd1d9-ffbf-435a-bbc1-a282d91d4604">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation	Par 51506

*/

vars

begin

	if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		self.txtCargoId.selStart := 0;
		self.txtCargoId.selLength := self.lblCargoId.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_lostFocus" id="1663925a-cf38-47d8-b74f-c70da7f127ee">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation		Par 51506

*/

vars

begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275

	if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		self.setMyTrackedItem( null );
		//do nothing
	elseif self.txtCargoId.text.trimBlanks = null then
		self.setMyTrackedItem( null );
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
	else
		if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.id &lt;&gt; self.txtCargoId.text then
			self.selectCargoItem( false );
		endif;
	endif;
	
	self.txtCargoId.selStart := 0;
	self.txtCargoId.selLength := 0;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateDamageData" id="df687054-caf9-4418-83b5-67f0ad7b8bd2">
        <source>validateDamageData() : Boolean protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 05/10/2016	cnwdap1		Initial creation TFS 2788
// 22/11/2016   cnwma1		TFS #2944*:PAR38399 STWO - damage recording - cargo quantity
//
vars
	damageInstance : CM_DamageInstance;
	fixed,
	numberRows,
	row : Integer;
	posStr,
	codeStr,
	remarks,
	severityStr : String;
	quantity,
	position,
	severity : Integer;
	damageCode : CM_DamageDefinitionCode;
	damageCodeDict : CM_DamageDefinitionByCodeDict;
	damagePosition : CM_DamagePosition; 
	quantityStr : String;
	quantityInt : Integer;

begin
	on Exception do self.handleWarnings(exception, app.myPassport);
	
	numberRows := self.tblDamages.rows;
	fixed := self.tblDamages.fixedRows;

	damageCodeDict := app.myRoot.allDamageDefinitionCodes;
	foreach row in fixed + 1 to numberRows do
		posStr		:= self.tblDamages.getCellText(row, 1).trimBlanks;
		codeStr		:= self.tblDamages.getCellText(row, 2).trimBlanks.toUpper;
		severityStr	:= self.tblDamages.getCellText(row, 3).trimBlanks;
		quantityStr := self.tblDamages.getCellText(row,4).trimBlanks;
		damagePosition := app.myRoot.allDamagePositionsByCode[posStr]; //Need to do it this way as the combo listObject changes each time a new damage instance is entered.
		
		if quantityStr &lt;&gt; null and quantityStr.isInteger then
			quantityInt := quantityStr.Integer;
		else
			quantityInt := 0;
		endif;
		if posStr = null and codeStr = null and severityStr = null and quantityInt = 0 then
			continue;
		endif;
		
		if posStr = null or codeStr = null or severityStr = null or quantityStr = null then
			app.raiseCMWarning1(Incomplete_Damage_Info, (row - fixed).String, null, null, null);
			continue;
		endif;
		
		if damagePosition = null then
			app.raiseCMWarning1(No_Valid_Damage_Pos, posStr, null, null, null);
			continue;
		endif;
		
		damageCode := damageCodeDict[codeStr];
		if damageCode = null then
			app.raiseCMWarning1(No_Damage_Code_Found, codeStr, null, null, null);
			continue;
		endif;
		
		severity := severityStr.Integer;
		if severity = null then
			app.raiseCMWarning1(Invalid_Damage_Severity, (row - fixed).String, null, null, null);
			continue;
		endif;
		
		//if quantityInt = 0 or quantityInt &gt; 999 then   	 // 22/11/2016 cnwma1 TFS 2944
		if quantityInt = 0 or quantityInt &gt; 999999999 then    // 22/11/2016 cnwma1 TFS 2944
			app.raiseCMWarning1(Invalid_Damage_Quantity, (row - fixed).String, null, null, null);
			continue;
		endif;
	endforeach;
	
	if app.myPassport.hasErrorsOrWarnings then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
