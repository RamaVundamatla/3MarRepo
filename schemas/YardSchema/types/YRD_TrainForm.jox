*/

vars
	train : CM_Train;
	rail : CM_Rail;
begin
	train := self.mySelectedTrain;
	if train = null then
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;
	if train.isCompletelyConfirmed(false) then
		rail := train.getRailArea(true);
		train := null;
	endif;
	self.myAssistant.YRD_Assistant.showRailOps(rail, train, self.myMasterMenuAction, null);
	
epilog

	app.mousePointer := MousePointer_Default;
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
