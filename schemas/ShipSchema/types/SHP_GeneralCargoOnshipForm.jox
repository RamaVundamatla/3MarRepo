			self.allCurrentVoyages.add(voy);
//		endif;
	endforeach;
	
	self.cmbVoyages.clear;
	self.cmbVoyages.listCollection(self.allCurrentVoyages, false, 0);
	//if app.myCurrentVoyage &lt;&gt; null then
	//cnwjo3 par 23105
	voy := app.getMyCurrentVoyage();
	if voy &lt;&gt; null then
		if self.allCurrentVoyages.includes(voy) then
			self.cmbVoyages.listObject := voy;
