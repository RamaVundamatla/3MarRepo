    <JadeMethod name="mSetCaptureFile_click" id="5cbb947e-934c-4c7c-ad28-97ba4c915cd4">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mSetCaptureFile_click(menuItem: MenuItem input) updating;
/*
*/
vars
	fileCMD: CMDFileOpen;
begin
	create fileCMD;
	fileCMD.dialogTitle := "Set Capture File Name";
	fileCMD.fileTitle := "JSSMonitor.log";
	fileCMD.fileName := captureFileName;
	fileCMD.createPrompt := false;
	fileCMD.fileMustExist := false;
	fileCMD.filter := "log (*.log)|*.log|All files(*.*)|*.*";
	if fileCMD.open = 0 then
		captureFileName := fileCMD.fileName;
		monitorFile.fileName := captureFileName;
		monitorFile.mode := File.Mode_Append;
		monitorFile.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
		app.setProfileString(app.getIniFileName, "JSSChangeTrackingSchema", "MonitorFileName", captureFileName);
	endif;
	delete fileCMD;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mViewCaptureFile_click" id="77d99a54-6b2b-43ba-98fc-983633a88d52">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mViewCaptureFile_click(menuItem: MenuItem input) updating;
/*
*/
vars
	exitValue: Integer;
	args: StringArray;
begin
	create args transient;
	args[1] := captureFileName;
	node.createExternalProcess(".", "notepad", args, "notepad", true, false, exitValue);
epilog
	delete args;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeTrackerRow" id="3ba6392e-05a3-4984-bd67-e6d876ae2767">
        <source>removeTrackerRow(pXmlString: String);
/*
		Remove the row with all the necessary details of the Change Tracker
*/
vars
	theTable: Table;
	processString: String;
	row: Integer;
	xmlDocument: JSSXmlDocument;
	rootElement: JSSXmlElement;
begin
	create xmlDocument transient;
	xmlDocument.parseDocument(pXmlString);
	rootElement := xmlDocument.myRootElement;

	theTable := tblTracker;

	processString := rootElement.allChildElementsByName["process"].tagValue;

	row := self.findTrackerRow(processString);
	if row &gt; 0 then
		theTable.deleteRow(row);
		return;
	endif;
//	self.allListenManagers.add(lmp);

epilog
	delete xmlDocument;
end;</source>
        <Parameter name="pXmlString" type="String"/>
    </JadeMethod>
    <JadeMethod name="resize" id="28230030-60f6-495e-aede-8b75b3c00845">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
/*
*/
vars
	indx: Integer;
	tblWidth: Integer;
begin
	/*
	*/
	fldProcessors.move(fldProcessors.left, fldProcessors.top,
						self.clientWidth - (fldProcessors.left * 2),
						self.clientHeight - fldProcessors.top - btnClose.height - 3 * 2);
	btnClose.move((fldProcessors.left + fldProcessors.width) - btnClose.width,
					fldProcessors.top + fldProcessors.height + 4,
					btnClose.width, btnClose.height);
	btnStopTracker.move(btnClose.left - btnStopTracker.width - 5,
						btnClose.top, btnStopTracker.width, btnStopTracker.height);
	/*
	*/
	tblTracker.move(tblTracker.left, tblTracker.top,
					shtTracker.width - (tblTracker.left * 2),
					shtTracker.height - tblTracker.top - btnStop.height - 4 * 2);
	foreach indx in 1 to 5 do
		tblWidth := tblWidth + tblTracker.columnWidth[indx];
	endforeach;
	if tblWidth + 2 &gt;= tblTracker.width then
		if tblTracker.columnWidth[5] &gt;= tblTracker.width then
			tblTracker.columnWidth[6] := tblTracker.width.Integer;
		else
			tblWidth := tblTracker.width.Integer - 2;
			foreach indx in 5 to 1 step -1 do
				if tblWidth - tblTracker.columnWidth[indx] &gt; 0 then
					tblWidth := tblWidth - tblTracker.columnWidth[indx];
				else
					break;
				endif;
			endforeach;
			tblTracker.columnWidth[6] := tblWidth;
		endif;
	else
		tblTracker.columnWidth[6] := (tblTracker.width  - tblWidth - 2).Integer;
	endif;
	btnStop.move((tblTracker.left + tblTracker.width) - btnStop.width,
						tblTracker.top + tblTracker.height + 4,
						btnStop.width, btnStop.height);
	btnBounce.move(tblTracker.left, btnStop.top, btnBounce.width, btnBounce.height);
	/*
	*/
	txtMonitor.move(txtMonitor.left, txtMonitor.top,
					shtMonitor.width - (txtMonitor.left * 2),
					shtMonitor.height - txtMonitor.top - btnPause.height - 4 * 2);
	btnPause.move((txtMonitor.left + txtMonitor.width) - btnPause.width,
						txtMonitor.top + txtMonitor.height + 4,
						btnPause.width, btnPause.height);
	btnClear.move(btnPause.left - 6 - btnClear.width, btnPause.top, btnClear.width, btnClear.height);

end;</source>
    </JadeMethod>
    <JadeMethod name="setupTrackerTable" id="62ee4760-ea60-4095-b08f-93a5667186bd">
        <source>setupTrackerTable();
/*
*/
vars
	theTable: Table;
	aTableColumn: JadeTableColumn;
begin
	theTable :=	tblTracker;

	theTable.selectMode := 8;
	theTable.autoRedraw := false;

	theTable.columns :=	7;
	theTable.rows :=	2;

	theTable.accessCell(1, 1).text := "Tracker";
	theTable.accessCell(1, 2).text := "Journal";
	theTable.accessCell(1, 5).text := " ";

//	theTable.accessColumn(8).inputType := Table.InputType_ComboBox;

	theTable.accessCell(2, 1).text :=	"Name" &amp; Tab &amp;
										"Number" &amp; Tab &amp;
										"Started" &amp; Tab &amp;
										"Complete" &amp; Tab &amp;
										"State" &amp; Tab &amp;
										" ";


	theTable.columnWidth[1] := 210;
	theTable.columnWidth[2] := 50;
	theTable.columnWidth[3] := 150;
	theTable.columnWidth[4] := 50;
	theTable.columnWidth[5] := 280;
	theTable.columnWidth[6] := 10;

	theTable.columnVisible[7] := false;

	theTable.accessColumn(2).alignment := Table.Alignment_Center;
	theTable.accessColumn(4).alignment := Table.Alignment_Center;
//	theTable.accessCell(1,4).alignment := Table.Alignment_Center;

	theTable.accessCell(1, 2).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(1, 5).mergeCells := Table.MergeCells_Merge;
end;</source>
    </JadeMethod>
    <JadeMethod name="tblTracker_click" id="a18f83c1-5866-4012-9b2d-c3ed6f995916">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTracker_click(table: Table input) updating;
/*
*/
begin
	self.timerEvent(5);

	if table.row &gt; 2 then
		if table.accessRow(table.row).itemObject = null then
			btnBounce.enabled := false;
		else
			btnBounce.enabled := true;
		endif;
		btnStop.enabled := true;
	else
		btnBounce.enabled := false;
		btnStop.enabled := false;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblTracker_resizeColumn" id="de8b90e7-893b-4fb2-a258-40ab39059c06">
        <controlMethod name="Table::resizeColumn"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTracker_resizeColumn(table: Table input; column: Integer input; previousWidth: Integer input) updating;

begin
	self.resize();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="column" type="Integer" usage="input"/>
        <Parameter name="previousWidth" type="Integer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="9e8437ba-7af3-4841-9f48-467d6f5d0ab9">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

vars

begin
	if eventTag = 5 then

		//	cause the event to find out the state of the ChangeTrackers
		self.myNotificationObject.myPersistentInstance.causeEvent(JSSCT_Nibbler_Note, true, self.myNotificationObject.buildNibbler_Calling());

	endif;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="57182075-f59a-436a-91dc-0d706366e7ef">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
		Handles all user notifications from a NibblerManager

		All notifications should be for a specific notification,
		with the userInfo parameter being a string containing the
		remaining information required
*/
vars
	userNote: Integer;
begin
	//	process the notifications for the monitor
	if eventType = JSSCT_Monitor_Note then

		self.writeToMonitor(userInfo.String);

	else
		if self.myNotificationObject &lt;&gt; null then
			//	unbust the userInfo string parameter
			self.myNotificationObject.decodeUserInfo(userInfo.String);
			userNote := self.myNotificationObject.eventType;

			if eventType = JSSCT_Nibbler_Note then

				//	process the notifications that can occur any time
				if userNote = JSSCT_Nibbler_Started or  userNote = JSSCT_Nibbler_Respond then

					self.displayTrackerRow(self.myNotificationObject.paramOne);

				elseif userNote = JSSCT_Nibbler_Terminating then

					self.removeTrackerRow(self.myNotificationObject.paramOne);

				endif;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="writeToMonitor" id="4be8ea76-200b-4e0f-babb-032985708025">
        <source>writeToMonitor(pMonitorMessage: String);
/*
*/
constants

	TEXTBOX_SIZE_UPPER: Integer = 40000;
	TEXTBOX_SIZE_LOWER: Integer = 32000;

vars
	textboxLines: Integer;
	firstVisibleLine: Integer;
	textHeight: Integer;
	visibleLines: Integer;
	textbox: TextBox;
	testData: String;
	rowIndex: Integer;
	rowCount: Integer;
	isTextIncluded: Boolean;
	isIncludesUsed: Boolean;
	message: String;
	callingAppName: String;
	delimiterPos: Integer;
	excludedApp: String;
	includedApp: String;
begin
	message :=	pMonitorMessage.trimRight;
	message.replaceChar(Cr, " ");
	message.replaceChar(Lf, " ");
	message.replaceChar(Tab, " ");
	message :=	message.trimRight;

	if mCaptureToFile.checked then
		if monitorFile = null then
			return;
		endif;
		
		monitorFile.mode := File.Mode_Output;	// 1/3/16 cnwmp6 PAR 36286 unicode version
		monitorFile.open;
		monitorFile.writeLine(message);
		monitorFile.close;
	endif;
	if self.theMonitorIsPaused then
		return;
	endif;
	textbox :=	txtMonitor;

	// Check on the current size of the textbox contents and truncate if necessary.
	if textbox.text.length &gt; TEXTBOX_SIZE_UPPER then
		textbox.text :=	textbox.text[textbox.text.length - TEXTBOX_SIZE_LOWER:end];
	endif;
	textbox.text :=	textbox.text &amp; CrLf &amp; message;

	// Scroll the textbox so the last line is at the bottom of the box.
	textbox.scrollVertPos :=	textbox.lineCount;
end;</source>
        <Parameter name="pMonitorMessage" type="String"/>
    </JadeMethod>
</GUIClass>
