    <JadeMethod name="getVehicleMachine" id="c51dc484-ba78-4991-8ea4-cb319f604edb">
        <source>getVehicleMachine() : CM_VehicleMachine;
/*

Purpose:			


Return Value:		


Date		Who		Reason
27 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.myMachine &lt;&gt; null then
		return self.myMachine;
	elseif self.myRoadJob &lt;&gt; null then
		return self.myRoadJob.myVehicle;
	endif;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="CM_VehicleMachine"/>
    </JadeMethod>
