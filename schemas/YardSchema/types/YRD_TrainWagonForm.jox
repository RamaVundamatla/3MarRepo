    <JadeMethod name="setControlsForAddEditDelete" id="f60a9916-86d5-400a-b48b-974a2935e089">
        <updating/>
        <source>setControlsForAddEditDelete( _setFocus : Boolean ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jun 2009 cnwmd1	Initial creation
12 Oct 2016	cnwrs1	TFS 2829 Cams processing failure with Train Events
04 Nov 2016	cnwma1	TFS #2936:Unable to create wagon due to a 1090 error
04 Nov 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
22 Jul 2022	jlika1	TFS 53741 - EUP- Max Wagon Payload
18 Aug 2022	jlika1	TFS 54549 - EUP - Max Wagon Payload
*/

vars
	ti 					: CM_TrackedItem;
	hasTrackedItem  	: Boolean;
	wagonConfirmed  	: Boolean;
	bubHelp 			: String;
	invalidObject 		: Boolean;
	str 				: String;
	isAddOrUpdate   	: Boolean;
	allowWagonWeights 	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myCurrentWagon, invalidObject);
	
	if self.myTerminal &lt;&gt; null then
		allowWagonWeights := self.myTerminal.getConfig(AllowWagonWeightsToBeUpd).Boolean;
	endif;
	
	isAddOrUpdate := self.mode = Mode_Add or self.mode = Mode_Update; //02.10.2020 cnwma1 TFS #50112
	
	if self.myCurrentWagon &lt;&gt; null then
		str := self.myCurrentWagon.creationTime.String;   //  04/11/201cnwma1 TFS #2936
		if invalidObject then
			return;
		endif;
		if self.myCurrentWagon.confirmed then
			self.caption   := app.getErrorString1(Wagon_confirmed,self.myCurrentWagon.id);
			wagonConfirmed := true;
		elseif self.myCurrentWagon.isTransient then
			self.caption   := app.getErrorString1(WagonNotConfirmed,self.myCurrentWagon.id);
		else
			self.caption   := app.getErrorString1(WagonNotConfirmed,self.myCurrentWagon.id);
		endif;
	else
		self.caption := app.getErrorString(Wagon_maintenance);
	endif;
	
	self.caption := self.caption &amp; " " &amp; self.myTerminal.code;
	
	//Wagon
	
	self.btnSaveBase.enabled    := isAddOrUpdate;
	self.btnCCWagon.enabled     := self.mode = Mode_View  and self.myCurrentWagon &lt;&gt; null;
	self.btnCCWagonRem.enabled  := self.mode = Mode_View  and self.myCurrentWagon &lt;&gt; null;
	self.btnDeleteWagon.enabled := self.mode = Mode_View  and self.myCurrentWagon &lt;&gt; null;
	self.btnEditWagon.enabled   := self.mode = Mode_View  and self.myCurrentWagon &lt;&gt; null;
	if self.btnEditWagon.enabled then
		self.btnIntransit.enabled   := not self.myCurrentWagon.isInTransit;
		self.btnIntransitNO.enabled := self.myCurrentWagon.isInTransit;
		self.btnCCWagon.enabled     := true;
		self.btnCCWagonRem.enabled  := self.myCurrentWagon.getRailAllocation &lt;&gt; null;
	else
		self.btnIntransit.enabled   := false;
		self.btnIntransitNO.enabled := false;
		self.btnCCWagon.enabled 	:= false;
		self.btnCCWagonRem.enabled  := false;
	endif;
	
	self.btnNewWagon.enabled 	  := self.mode = Mode_View;
	self.btnNextWagon.enabled 	  := self.mode = Mode_Add;
	self.btnPrint.enabled 		  := self.mode = Mode_View and self.myCurrentWagon &lt;&gt; null;
	self.btnCancelBase.enabled 	  := self.mode = Mode_Add or self.mode = Mode_Update;
	self.cmbWagon.enabled 		  := self.mode = self.Mode_View;
	self.cmbTrainIncoming.enabled := isAddOrUpdate;
	self.cmbTrainOutgoing.enabled := isAddOrUpdate;
	self.cmbCarrier.enabled		  := isAddOrUpdate;
	self.cmbStevedoreRec.enabled  := isAddOrUpdate; 								  //02.10.2020 cnwma1 TFS #50112
	self.cmbStevedoreRel.enabled  := isAddOrUpdate; 								  //02.10.2020 cnwma1 TFS #50112
	self.cmbWagonClass.enabled    := isAddOrUpdate;
	self.cmbRailArea.enabled	  := isAddOrUpdate and not wagonConfirmed;			  //02 Feb 2011	NDL	Par 25181
	self.cmbRake.enabled	      :=isAddOrUpdate  and not wagonConfirmed;			  //02 Feb 2011	NDL	Par 25181
	//02 Feb 2011	NDL	Par 25181
	if wagonConfirmed then
		bubHelp := app.getErrorString(Update_from_Rail_Ops);
	else
		bubHelp := null;
	endif;
	self.cmbRailArea.bubbleHelp := bubHelp;
	self.cmbRake.bubbleHelp 	:= bubHelp;
	self.btnDamage.enabled 		:= not isAddOrUpdate;
	
	//13 Mar 2015	NDL	Par 35828
	if self.myCurrentWagon &lt;&gt; null and self.myCurrentWagon.hasSelectableSealTypes then
		self.btnSeals.enabled := not isAddOrUpdate;
	else
		self.btnSeals.enabled := false;
	endif;
	
	self.chkConfirmIn.readOnly  := self.mode = self.Mode_View;
	self.chkConfirmOut.readOnly := self.mode = self.Mode_View;
	
	
	if self.myCurrentWagon &lt;&gt; null then																	
		if not self.chkConfirmIn.readOnly and self.myCurrentWagon.myTerminalDeparted &lt;&gt; null then
			self.chkConfirmIn.readOnly  := true;	
		endif;
		if not self.chkConfirmOut.readOnly and self.myCurrentWagon.myTerminalDeparted &lt;&gt; null then
			self.chkConfirmOut.readOnly := true;		
		endif;
	endif;																							

	if self.mode = Mode_Add or self.mode = Mode_Update then
		lblWagClassNote.visible   := true;
		lblWagClassNote.foreColor := Red;
		lblTareWeight.foreColor   := Grey;
		lblMaxWeight.foreColor    := Grey;
		lblMaxHeight.foreColor    := Grey;
		if allowWagonWeights then
			lblTareWeight.foreColor   := Black;
			lblMaxWeight.foreColor    := Black;
		endif;
	else
		lblWagClassNote.visible   := false;
		lblTareWeight.foreColor   := Black;
		lblMaxWeight.foreColor    := Black;
		lblMaxHeight.foreColor    := Black;
	endif;
	
	if allowWagonWeights then
		lblWagClassNote.caption := app.getErrorString(Mainta_height_from_wagon_class);
	else
		lblWagClassNote.caption := app.getFormCaptionsString(Xlat_0014309);
	endif;
	
	self.txtRemaks.enabled 		 := isAddOrUpdate;
	self.txtWagonNumber.enabled  := isAddOrUpdate;
	self.cmbWagonPrenote.enabled := isAddOrUpdate;
	self.cmbDestTerm.enabled 	 := isAddOrUpdate;	// TFS 2533
	
	self.txtMaxWeight.enabled 	:= isAddOrUpdate and allowWagonWeights;
	self.txtTareWeight.enabled 	:= isAddOrUpdate and allowWagonWeights;
	self.tblMaxCWeight.enabled 	:= isAddOrUpdate and allowWagonWeights;
	self.tblTare.enabled		:= isAddOrUpdate and allowWagonWeights;

	if _setFocus then	// 21 Jul 2009	NDL - side effect is that this unconditionally brings form to the front as well
						// which we don't want during notifications.
		if self.cmbWagon.enabled then
			self.cmbWagon.setFocus();
		elseif self.cmbWagonPrenote.enabled then
			self.cmbWagonPrenote.setFocus();
		elseif self.txtWagonNumber.enabled then
			self.txtWagonNumber.setFocus();
		endif;
	endif;
	
	//Cargo display
	
	ti := self.getTrackedItem();
	hasTrackedItem := ti &lt;&gt; null;
	self.frmCargoToolbar.enabled  := self.mode = Mode_View;
	self.btnAddCargo.enabled  	  := self.mode = Mode_View  and self.myCurrentWagon &lt;&gt; null and self.optDirInTB.value; //+ cnwmd1 Par 25324
	self.btnEditCargo.enabled 	  := hasTrackedItem;
	self.btnEnquire.enabled 	  := hasTrackedItem;
	self.grpCargoDetail.enabled   := self.mode = Mode_View;
	self.mnuInspectObject.enabled := hasTrackedItem;
	self.mnuCargoEdit.enabled 	  := hasTrackedItem;
	self.mnuCargoEnquiry.enabled  := hasTrackedItem;
	self.mnuRemoveCargo.enabled   := self.mode = Mode_View and hasTrackedItem and self.optDirInTB.value and
									self.myCurrentWagon &lt;&gt; null and not self.myCurrentWagon.confirmed;
	if self.mnuRemoveCargo.enabled then
		self.mnuRemoveCargo.visible 	:= true;
		self.mnuRemoveCargo.caption 	:= app.getErrorString1(Remove_from_wagon, ti.id);
		self.mnuRemoveCargo.userObject  := ti;
	else
		self.mnuRemoveCargo.visible	    := false;
	endif;
	
	//05 Aug 2009	NDL	
	if not hasTrackedItem then
		self.mnuCargoInTransit.caption 	  := app.getErrorString(Set_All_cargo_in_transit);
		self.mnuCargoInTransitNOT.caption := app.getErrorString(Set_All_cargo_NOT_In_Transit);
	elseif self.tblCargo.allSelectedObjects.size &gt; 1 then
		self.mnuCargoInTransit.caption 	  := app.getErrorString(Set_Selected_cargo_in_transit);
		self.mnuCargoInTransitNOT.caption := app.getErrorString(Set_Selected_cargo_NOT_transit);
	else
		self.mnuCargoInTransit.caption 	  := app.getErrorString1(Set_In_Transit, ti.id);
		self.mnuCargoInTransitNOT.caption := app.getErrorString1(Set_not_in_Transit, ti.id);
	endif;
	self.mnuCargoInTransit.enabled := true;
	self.mnuCargoInTransit.visible := true;
	self.mnuCargoInTransitNOT.enabled := true;
	self.mnuCargoInTransitNOT.visible := true;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnIntransit.enabled	:= false;
		self.btnIntransitNO.enabled := false;
		self.btnNewWagon.enabled	:= false;
		self.btnEditWagon.enabled	:= false;
		self.btnDeleteWagon.enabled	:= false;
		self.btnCCWagon.enabled		:= false;
		self.btnAddCargo.enabled	:= false;
		self.btnCCWagonRem.enabled  := false;
		self.btnSeals.enabled		:= false; // TFS 2734
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_setFocus" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDefaults" id="78105b6f-02fb-49ed-91b1-bf75a2444234">
        <source>setDefaults() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 Jun 2009	cnwmd1	Initial creation
04 Nov 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	defCarrierCodeStr : String;
	currentTrain      : CM_Train;
begin
	currentTrain :=  self.myCurrentTrain;
	
	if currentTrain = null then
		defCarrierCodeStr := self.myTerminal.getConfig(DefRailCarrier).String;
		self.cmbCarrier.setObject(app.myRoot.allCarriers[defCarrierCodeStr]);
		return;
	endif;
	
	self.cmbTrainIncoming.listObject := currentTrain;
	self.cmbTrainOutgoing.listObject := currentTrain;
	
	if currentTrain.myCarrier &lt;&gt; null then
		self.cmbCarrier.setObject(self.myCurrentTrain.myCarrier);
	endif;
	
	if currentTrain.myStevedoreReceive &lt;&gt; null then                          //02.10.2020 cnwma1 TFS #50112
		self.cmbStevedoreRec.setObject(currentTrain.myStevedoreReceive);
	endif;
	
	if currentTrain.myStevedoreRelease &lt;&gt; null then                         //02.10.2020 cnwma1 TFS #50112
		self.cmbStevedoreRel.setObject(currentTrain.myStevedoreRelease);
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setEmptyWagonPositions" id="15a22df8-e117-4874-b9e2-af1cd4c8896b">
        <updating/>
        <source>setEmptyWagonPositions(_theWagonContainers : CMIF_TIWagonPositionArray input; _wagonPositions : CMIF_TIWagonPositionArray input) updating, protected;
//-----------------------------------------
//Created: April 2003 By: cnwgd1
//-----------------------------------------

//cnwmd1, CCMS 1067, Par 19913 Method copied from YRD_WagonForm and modified to suit
vars
	wagonLength,
	pos : Integer;
	found : Boolean;
	wagonPosition : CMIF_TIWagonPosition;
	wagonClass : CM_WagonClass;
begin
	wagonClass := self.myCurrentWagon.myWagonClass;
	if wagonClass = null then
		return;
	endif;
	
	wagonLength := wagonClass.getLenInUnits;
	
	foreach pos in 1 to wagonLength do
		found := false;
		foreach wagonPosition in _wagonPositions do
			if wagonPosition.position = pos then
				found := true;
				break;
			endif;
		endforeach;
		
		if found then
			continue;
		endif;
		
		create wagonPosition transient;
		_theWagonContainers.add(wagonPosition);
		wagonPosition.myRailLine := self.myCurrentWagon.myRailLine;
		wagonPosition.position := pos;
		wagonPosition.available := self.myCurrentWagon.allLocationsControllersArray[pos].isAvailable;//self.controllerAvailable[pos];
		wagonPosition.hasTwistLocks := self.myCurrentWagon.allLocationsControllersArray[pos].hasTwistlocks; //self.controllerHasTLs[pos];
		wagonPosition.twistLocksAreUp := self.myCurrentWagon.allLocationsControllersArray[pos].twistlocksAreUp; //self.controllerTLUp[pos];
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theWagonContainers" type="CMIF_TIWagonPositionArray" usage="input"/>
        <Parameter name="_wagonPositions" type="CMIF_TIWagonPositionArray" usage="input"/>
    </JadeMethod>
