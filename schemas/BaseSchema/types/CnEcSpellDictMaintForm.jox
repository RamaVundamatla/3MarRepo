    <JadeMethod name="deleteWord" id="0d28a24c-297c-4bdd-b955-e5e419966d60">
        <source>deleteWord() protected;

vars
	wordObj			: CnEcSpellWord;
	errorMessage	: String;
	
begin
	wordObj	:=	self.getSelectedWord();
	
	if wordObj &lt;&gt; null then
		errorMessage	:=	self.aMyTA.trxSpellWordDelete(wordObj);

		if errorMessage = null then
			self.selectWord();
		else
			app.msgBox(errorMessage, "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="export" id="6101832a-c99a-46b0-9e0b-2272d302d3d2">
        <source>export() protected;
// --------------------------------------------------------------------------------
// Purpose:		Exports all Spell Words to a disk file.
//
// Parameters:	None.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 17/08/2001	cnwdad1		Changed to instantiate the target file from this method
//							instead of from the model class.
// --------------------------------------------------------------------------------
vars
	spellRootObj	: CnEcSpellRoot;
	targetFileObj	: File;
	
begin
	create targetFileObj transient;
	
	if targetFileObj.cnEcSetOpenName(false, false, null) then
		app.mousePointer	:=	Busy;
		spellRootObj		:=	app.myBaseRoot.getSpellRoot();
		spellRootObj.bulkExport(targetFileObj);
	endif;
epilog
	delete targetFileObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getSelectedWord" id="c8942f2d-1d5e-4507-a8c9-b97a15d17691">
        <source>getSelectedWord():CnEcSpellWord protected;
// --------------------------------------------------------------------------------
// Created:		23 June 2001 by cnwdad1
//
// Purpose:		Returns the currently selected word object.
//
// Parameters:	None
//
// Returns:		The word object, or null if no word is selected.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	wordObj			: CnEcSpellWord;
	tableObj		: Table;
	tableRowObj		: JadeTableRow;
	currentRow		: Integer;
	numberOfRows	: Integer;
	fixedRows		: Integer;
	
begin
	tableObj		:=	tblSpellDict;
	numberOfRows	:=	tableObj.rows;
	currentRow		:=	tableObj.row;
	fixedRows		:=	tableObj.fixedRows;
	
	if currentRow &gt; fixedRows and currentRow &lt;= numberOfRows then
		tableRowObj	:=	tableObj.accessRow(tableObj.row);
		wordObj		:=	tableRowObj.itemObject.CnEcSpellWord;
	endif;
epilog
	return wordObj;
end;</source>
        <access>protected</access>
        <ReturnType type="CnEcSpellWord"/>
    </JadeMethod>
    <JadeMethod name="import" id="76cbee2a-f760-48da-b2d9-d73276c1ca1b">
        <source>import() protected;
// --------------------------------------------------------------------------------
// Purpose:		Imports Spell Words from a disk file.
//
// Parameters:	None.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 17/08/2001	cnwdad1		Changed to instantiate the target file from this method
//							instead of from the model class.
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// --------------------------------------------------------------------------------
vars
	spellRootObj	: CnEcSpellRoot;
	sourceFileObj	: File;
	
begin
	create sourceFileObj transient;
	
	if sourceFileObj.cnEcSetOpenName(true, false, null) then
		app.mousePointer	:=	Busy;
		spellRootObj		:=	app.myBaseRoot.getSpellRoot();
		spellRootObj.bulkLoad(sourceFileObj);
	endif;
epilog
	delete sourceFileObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="3b7c4faa-514d-434e-b960-8b82ad454cd3">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	app.mousePointer	:=	Busy;
	inheritMethod();
	self.loadForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadForm" id="dab6ea78-e5d2-4ec0-a909-a076c32e40d0">
        <updating/>
        <source>loadForm() updating, protected;

vars
	allKeyCodesObj	: CnEcKeyCodeArray;
	
begin
	self.centreWindow();
	create self.aMyTA transient;	// deleted in closeForm();
	btnReplace.enabled		:=	false;
	btnDelete.enabled		:=	false;

	if process.isUsingThinClient then
		create allKeyCodesObj transient;
		self.registerFormKeys(allKeyCodesObj);
	endif;

	self.setStartRow(null);
epilog
	delete allKeyCodesObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="replaceWord" id="30f1d1c1-99cc-461f-b7aa-f9314b0522c8">
        <source>replaceWord() protected;

vars
	spellWordObj		: CnEcSpellWord;
	replacementString	: String;
	
begin
	spellWordObj		:=	self.getSelectedWord();
	replacementString	:=	txtEditWord.text.trimBlanks();
		
	if spellWordObj &lt;&gt; null and replacementString &lt;&gt; null then
		self.aMyTA.trxSpellWordUpdate(	spellWordObj,
										spellWordObj.edition(),
										spellWordObj.myRoot,
										replacementString
										);
		self.selectWord();
//		self.setStartRow(replacementString);
//		btnReplace.enabled := false;
			
//		if lstSpellDict.listIndex &gt; 8 then
//			lstSpellDict.topIndex := lstSpellDict.listCount;//(lstSpellDict.listIndex - 5);
//		endif;
	endif; 
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="selectWord" id="f3f4ac76-922e-4b21-8f71-f92ca7ed038c">
        <source>selectWord() protected;

vars
	spellWordObj		: CnEcSpellWord;
	replacementString	: String;
	
begin
	spellWordObj	:=	self.getSelectedWord();

	if spellWordObj = null then
		tblSpellDict.clearAllSelected();
		txtEditWord.text	:=	null;
		btnReplace.enabled	:=	false;
		btnDelete.enabled	:=	false;
	else
		if app.isValidObject(spellWordObj) then
			txtEditWord.text	:=	spellWordObj.name;
			btnReplace.enabled	:=	true;
			btnDelete.enabled	:=	true;
		else
			txtEditWord.text	:=	null;
			btnReplace.enabled	:=	false;
			btnDelete.enabled	:=	false;
		endif;
	endif;
	
	txtStartFrom.text	:=	null;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setStartRow" id="631fdfc4-2955-4e16-b3df-2fa8eb872908">
        <source>setStartRow(pStartValue:String) protected;
// --------------------------------------------------------------------------------
// Created:		23 June 2001 by cnwdad1
//
// Purpose:		Sets the start row of the table based upon the specified word.  If
//				the word is null, the table will start at the very top.
//
// Parameters:	pStartValue - The word to start the list from.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: Table;
	wordObj		: CnEcSpellWord;
	allWordsObj	: CnEcSpellWordByName;
	
begin
	allWordsObj		:=	app.myBaseRoot.getSpellRoot().allSpellWords;
	tableObj		:=	self.tblSpellDict;
	tableObj.clear;
	tableObj.rows	:=	1;
	tableObj.setCellText(1, 1, "Word" &amp; Tab &amp; "Metaphone" &amp; Tab &amp; "Soundex");
	tableObj.partialTextIndication	:=	true;
	
	if pStartValue.trimBlanks() = null then
		wordObj	:=	null;
	else
		wordObj	:=	allWordsObj.getAtKeyGeq(pStartValue.toLower);
	endif;
	
	tableObj.displayCollection(allWordsObj, true, Collection.CNEC_DISPLAY_ORDER_COLLECTION, wordObj);
	txtEditWord.text	:=	null;
	self.setWordCount(allWordsObj);
end;</source>
        <access>protected</access>
        <Parameter name="pStartValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="setWordCount" id="9e2ff86f-39a2-462e-b87d-1bf975cedf58">
        <source>setWordCount(pAllWordsObj:CnEcSpellWordByName) protected;
// --------------------------------------------------------------------------------
// Created:		24 June 2001 by cnwdad1
//
// Purpose:		Updates the label capton with the number of words.
//
// Parameters:	pAllWordsObj - A reference to the collection of all words.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	wordCount	: Integer;
	
begin
	wordCount				:=	pAllWordsObj.size();
	lblWordCount.caption	:=	wordCount.userNumberFormat($CNEC_NO_DECIMALS) &amp; self.WORD_COUNT;
end;</source>
        <access>protected</access>
        <Parameter name="pAllWordsObj" type="CnEcSpellWordByName"/>
    </JadeMethod>
    <JadeMethod name="tblSpellDict_click" id="590f902c-fc1d-4adc-848c-eefd40f3b57b">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSpellDict_click(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		07 February 2003 by cnwdad1
