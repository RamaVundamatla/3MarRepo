    <JadeMethod name="createTIUpdateControl" id="bcc7f793-448e-443f-91ca-bec87fdffe5f">
        <source>createTIUpdateControl(_mode : Integer; _userCode : String; _userObject : Object) : CMIF_TIUpdateController;
// ---------------------------------------------------------------------------
// Created:     31 January 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	controller	: CMIF_TIUpdateController;
begin
	create controller transient;
	
	controller.dateTime := app.serverTimestampAtTrxStart;	
	
	controller.setMode(_mode);
	controller.setMyUserObject(_userObject);
	
	if _userCode &lt;&gt; null then
		controller.userCode := _userCode;
	else
		controller.userCode := app.getMyUserCode;	
	endif;
	
	return controller;
end;</source>
