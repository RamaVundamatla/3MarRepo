    <JadeMethod name="deleteStraddleAreas" id="aea1c765-1076-49c1-9ba4-f816f1bd73c5">
        <source>deleteStraddleAreas();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2008	cnwer1	Initial creation

*/

vars


begin
	self.deleteTerminalArea("UTSTRDA");
	self.assertTrue(self.getTerminal.allTerminalAreas["UTSTRDA"] = null);
	self.deleteTerminalArea("UTSTRDB");
	self.assertTrue(self.getTerminal.allTerminalAreas["UTSTRDB"] = null);
