    <JadeMethod name="getProducts" id="5d12f51a-6d4a-4025-aab5-f156075dcd98">
        <updating/>
        <source>getProducts(sa:StringArray input) updating;

begin
	sa.add("JCC");
	sa.add("CMIS");
	sa.add("mumbai");
	sa.add("muu");  // mumbai unicode
	sa.add("skidemo");
	sa.add("sku");  // skidemo unicode
	sa.add("skl");  // skidemo large (54gb instead of 34 gb)
	sa.add("slu");  // skidemo large unicode
	//sa.add("ews");
	sa.add("mtl");
	sa.add("JMT");
	sa.add("JadeStar");
	sa.add("Jasper");
	//sa.add("tpca");
	sa.add("tui");
	sa.add("up1");
	sa.add("Autodino");
	sa.add("StartStopTest");
	sa.add("ncs");
	
	sa.add("ujt"); //southport
	sa.add("upd"); // parsys
	sa.add("utu"); // twl
	
end;</source>
        <Parameter name="sa" type="StringArray" usage="input"/>
    </JadeMethod>
