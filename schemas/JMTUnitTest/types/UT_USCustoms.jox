    </Constant>
    <JadeMethod name="tCAMIRCustomsStatus" id="41fbb0ff-fc66-4e5c-8f5e-e7912f2f821d">
        <source>tCAMIRCustomsStatus();
// cnwrs1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 July 2014	cnwmc5	Initial creation
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
*/
// 21 Jun 2018	jlgrs1	TFS 39298 (TFS 36430) Penn Ship Manifest too many locks
// 10 Sep 2019	cnwrs1	TFS 46030
//6/11/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
//04 Mar 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation

constants
	EDIPartyName = "ICL";
	VESSEL_CODE			= "ICLAD";
	VOYAGE_CODE			= "UT_CAMIR";
	SHIPPING_LINE		= "ICL";
	OPER_ID				= "ICL";
	STOP_ID				= 304;
	STOP_CODE			= "UTCAM";
	STOP_HEAD			= "UT CAMIR CUSTOMS";
	STOP_ID_OTH			= 305;
	STOP_CODE_OTH		= "UTOTH";
	STOP_HEAD_OTH		= "UT CAMIR OTHER";
	STOP_ID_CONT		= 306;
	STOP_CODE_CONT		= "UTCNT";
	STOP_HEAD_CONT		= "UT CAMIR CUSTOMS CONT STOP";
	TODO_CODE_CONT		= "UTCNT";
	TODO_HEAD_CONT		= "UT CAMIR CUSTOMS CONT TASK";
	
	
	DISPO_CODE_SET_REL	= "3A";
	DISPO_NAME_SET_REL	= "UT Set Released";
	DISPO_CODE_SET_ENT	= "3B";
	DISPO_NAME_SET_ENT	= "UT Set Entries";
	DISPO_CODE_ADD_STO	= "3C";
	DISPO_NAME_ADD_STO	= "UT Add BOL Stop";
	DISPO_CODE_REM_STO	= "3D";
	DISPO_NAME_REM_STO	= "UT Remove BOL Stop";
	
	DISPO_CODE_ADD_C_STO	= "3E";
	DISPO_NAME_ADD_C_STO	= "UT Add CONT Stop";
	DISPO_CODE_REM_C_STO	= "3F";
	DISPO_NAME_REM_C_STO	= "UT Remove CONT Stop";	
	DISPO_CODE_ADD_TODO	 	= "3G";
	DISPO_NAME_ADD_TODO		= "UT Add TODO";
	DISPO_CODE_REM_TODO		= "3I";
	DISPO_NAME_REM_TODO		= "UT Remove TODO";
	
	
	BOL_NUM				= "MCBOL01";
	CARGO_ID			= "UTCAMIR0001";
	EDI_VOYAGE			= "UTCAM";
vars
	
	voyage				: CM_Voyage;
	operator			: CM_Operator;
	bol					: CM_BOL;
	stopsTable			: CM_StopsTable;
	stopsTableOther		: CM_StopsTable;
	stopsTableCont		: CM_StopsTable;
	ediAction			: CM_EDIAction;
	ediFileType			: CM_EDIFileType;
	thisPort			: CM_Port;
	container			: CM_Container;
	thisPortCode		: String;	
	numReleased			: Integer;
	origEntries			: Integer;
	newEntries			: Integer;
	strs				: StringArray;
	ediParty 			: CM_EDIParty;
	proxyEDIParty 		: CM_EDIParty;
	pxyRules 			: CM_EDIPartyRules;
	terminal 			: CM_Terminal;
	isDoClearanceCheck 	: Boolean;
	todoTaskDesc 		: CM_ToDoTaskDesc;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.setTerminalConfig(EdiShipManAllowPartial, true);
	terminal := self.getTerminal;
	//Before tidy-up
	self.deleteStopsTable(STOP_ID);
	self.deleteStopsTable(STOP_ID_OTH);
	self.deleteStopsTable(STOP_ID_CONT);	
	
	
	
	self.deleteEDIAction(DISPO_NAME_SET_REL, null, "R02");
	self.deleteEDIAction(DISPO_NAME_SET_ENT, null, "R02");
	self.deleteEDIAction(DISPO_NAME_ADD_STO, null, "R02");
	self.deleteEDIAction(DISPO_NAME_REM_STO, null, "R02");
	self.deleteEDIAction(DISPO_NAME_ADD_C_STO, null, "R02");
	self.deleteEDIAction(DISPO_NAME_REM_C_STO, null, "R02");
	self.deleteEDIAction(DISPO_NAME_ADD_TODO, null, "R02");
	self.deleteEDIAction(DISPO_NAME_REM_TODO, null, "R02");
	
	
	
	// delete todo taks
	todoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey(TODO_CODE_CONT);
	if todoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription(todoTaskDesc);
	endif;
	
	
	self.deleteBOL(BOL_NUM, null);
	self.deleteContainer(CARGO_ID);
	self.deleteVoyage(VOYAGE_CODE);
		
	//Setup
	thisPortCode := self.getTerminalConfig(PortDestCode).String;
	thisPort := self.getPort(thisPortCode);
	operator := self.getOperator(OPER_ID);
	
	//Ensure the Customs Stop is setup to auto apply
	stopsTable := self.uSetupAutomaticBOLStop(STOP_ID, STOP_CODE, STOP_HEAD);
	self.assertNotNull(stopsTable);
	
	//Create another stop
	stopsTableOther := self.uSetupAutomaticBOLStop(STOP_ID_OTH, STOP_CODE_OTH, STOP_HEAD_OTH);
	self.assertNotNull(stopsTableOther);
	
	//And Another
	self.opts.addAssoc("overRideCargoType",TI_CargoType_Container );
	stopsTableCont := self.uSetupAutomaticBOLStop(STOP_ID_CONT, STOP_CODE_CONT, STOP_HEAD_CONT);
	self.assertNotNull(stopsTableCont);
	self.opts.removeAssoc("overRideCargoType");
	
	todoTaskDesc := self.basicCreateCM_ToDoTaskDesc(TODO_HEAD_CONT, TODO_CODE_CONT, null, null, null); 
	self.assertNotNullMsg(todoTaskDesc, "To do task not created");
	
	
		
	//Ensure the Customs Stop is setup to be auto cleared (new terminal config option)
	self.setTerminalConfig(EdiCustomsStopsTable, stopsTable);
	self.assertEqual(self.getTerminalConfig(EdiCustomsStopsTable).CM_StopsTable, stopsTable);
	
	//Ensure the disposition codes are on the CAMIR EDI file type (create them if not)
	ediFileType := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileTypeCAMIR_CustomsStatus, null);
	self.assertNotNull(ediFileType);
	
	//Create EDI Action to Set Released
	ediAction := ediFileType.allEDIActions[DISPO_NAME_SET_REL];
	if ediAction = null then
		self.addEDIAction(DISPO_NAME_SET_REL, DISPO_CODE_SET_REL, "R02", EDIAction_SetReleased, null, ediFileType, "Unit Test CAMIR", null);
	endif;
	
	
	//Create EDI Action to Set Entries
	ediAction := ediFileType.allEDIActions[DISPO_NAME_SET_ENT];
	if ediAction = null then
		self.addEDIAction(DISPO_NAME_SET_ENT, DISPO_CODE_SET_ENT, "R02", EDIAction_SetEntries, null, ediFileType, "Unit Test CAMIR", null);
	endif;
	
	
	//Create EDI Action to Add a BOL Stop
	ediAction := ediFileType.allEDIActions[DISPO_NAME_ADD_STO];
	if ediAction = null then
		self.addEDIAction(DISPO_NAME_ADD_STO, DISPO_CODE_ADD_STO, "R02", EDIAction_PlaceHold, stopsTableOther, ediFileType, "Unit Test CAMIR", null);
	endif;
	
	
	//Create EDI Action to Remove a BOL Stop
	ediAction := ediFileType.allEDIActions[DISPO_NAME_REM_STO];
	if ediAction = null then
		self.addEDIAction(DISPO_NAME_REM_STO, DISPO_CODE_REM_STO, "R02", EDIAction_RemoveHolds, stopsTableOther, ediFileType, "Unit Test CAMIR", null);
	endif;

	//Create EDI Action to Add a Container Stop
	ediAction := ediFileType.allEDIActions[DISPO_NAME_ADD_C_STO];
	if ediAction = null then
		self.addEDIAction(DISPO_NAME_ADD_C_STO, DISPO_CODE_ADD_C_STO, "R02", EDIAction_PlaceContHold , stopsTableCont, ediFileType, "Unit Test CAMIR", null);
	endif;
	
	//Create EDI Action to Remove a Container Stop
	ediAction := ediFileType.allEDIActions[DISPO_NAME_REM_C_STO];
	if ediAction = null then
		self.addEDIAction(DISPO_NAME_REM_C_STO, DISPO_CODE_REM_C_STO, "R02", EDIAction_RemoveContHold , stopsTableCont, ediFileType, "Unit Test CAMIR", null);
	endif;
	
		//Create EDI Action to Add a TODO Task
	ediAction := ediFileType.allEDIActions[DISPO_NAME_ADD_TODO];
	if ediAction = null then
		self.addEDIAction(DISPO_NAME_ADD_TODO, DISPO_CODE_ADD_TODO, "R02", EDIAction_AddToDoTask , todoTaskDesc, ediFileType, "Unit Test CAMIR", null);
	endif;
	
	//Create EDI Action to Remove a TODO Task
	ediAction := ediFileType.allEDIActions[DISPO_NAME_REM_TODO];
	if ediAction = null then
		self.addEDIAction(DISPO_NAME_REM_TODO, DISPO_CODE_REM_TODO, "R02", EDIAction_DeleteToDoTask , todoTaskDesc, ediFileType, "Unit Test CAMIR", null);
	endif;
	
	
	
	
	
	//Create new voyage
	voyage := self.addVoyageWithContainerStructur(VOYAGE_CODE, VESSEL_CODE, operator.code, SHIPPING_LINE);
	self.assertNotNull(voyage);
	
	//create new EDI Party
	self.deleteEDIParty(EDIPartyName);
	ediParty := self.createEDIParty(EDIPartyName, EDIPartyName, EDIPartyName, operator);
	beginLoad;
	proxyEDIParty := ediParty.pxyCreateUpdateProxy;
	endLoad;
	create pxyRules as CM_EDIPartyCuscarRules transient;	
	pxyRules.setMyEDIParty(proxyEDIParty);
	pxyRules.setMyEDIConfig(terminal.myEdiConfig);
	pxyRules.setPropertyValue(CM_EDIPartyCuscarRules::ediTypeShipManifest.name, true);
	pxyRules.setPropertyValue(CM_EDIPartyCuscarRules::myChildCargoTypeDefault.name, app.myRoot.allCargoTypesById[TI_CargoType_LCL]);
	app.myTrxUA.trxUpdateEDIParty(proxyEDIParty, app.myPassport);
	
	delete proxyEDIParty;
	
	//Load a bay plan for the voyage
	self.uLoadBayPlan(voyage.code, thisPortCode);
	
	//Load a CUSCAR for the voyage - with a BOL
	self.uLoadCUSCAR(BOL_NUM, voyage.code, thisPortCode);
	
	//Check there is a customs stop on the BOL
	bol := self.getBOL(BOL_NUM, BOLType_GeneralBillOfLading, operator.code);
	self.assertTrue(bol.hasStopOfType(stopsTable));
	
	//Create the appropriate xlations
	self.deleteEDIInwardXlation(EDI_VOYAGE, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.createEDIXlation(EDI_VOYAGE, voyage.code, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);
	
	//Load a CAMIR file - this will set the entries
	origEntries := bol.customsQuantityEntered;
//	newEntries := 15;
	newEntries := 50;
	
	self.uLoadCAMIR(DISPO_CODE_SET_ENT, newEntries, BOL_NUM, "110000", false, false);
	self.assertEqual(bol.customsQuantityEntered, newEntries);
	
	
	
	
	//Load a CAMIR file - this will set the entries back to the original
	self.uLoadCAMIR(DISPO_CODE_SET_ENT, origEntries, BOL_NUM, "120000", false, false);
	self.assertEqual(bol.customsQuantityEntered, origEntries);
	
	//Load a CAMIR file - this will set the released - less than the entires
	numReleased := bol.customsQuantityEntered - 12;
	self.uLoadCAMIR(DISPO_CODE_SET_REL, numReleased, BOL_NUM, "130000", false, false);
	self.assertEqual(bol.customsQuantityReleased, numReleased);
	
	//Load a CAMIR file - this will also set the released - to now match the entries
	numReleased := bol.customsQuantityEntered;
	self.uLoadCAMIR(DISPO_CODE_SET_REL, numReleased, BOL_NUM, "140000", false, false);
	self.assertEqual(bol.customsQuantityReleased, numReleased);
	self.assertFalse(bol.hasStopOfType(stopsTable));
	
	//Load a CAMIR file - this will remove a stop
	self.uLoadCAMIR(DISPO_CODE_REM_STO, 10, BOL_NUM, "150000", false, false);
	self.assertFalse(bol.hasStopOfType(stopsTableOther));
	
	//Load a CAMIR file - this will add a stop again
	self.uLoadCAMIR(DISPO_CODE_ADD_STO, 10, BOL_NUM, "160000", false, false);
	self.assertTrue(bol.hasStopOfType(stopsTableOther));
	//Load a CAMIR file - ensure get an error when trying to load a file with the same timestamp
	self.uLoadCAMIR(DISPO_CODE_ADD_STO, 10, BOL_NUM, "160000", true, false);
	
	
		
	container := voyage.allOnshipTIsByCargoTypeId.getAtKey(TI_CargoType_Container,"ICUU2371952").CM_Container;
	//Load a CAMIR file - this will add a stop again
	self.uLoadCAMIR(DISPO_CODE_ADD_C_STO, 10, BOL_NUM, "170000", false, false);
	self.assertTrueMsg(container.hasStopOfType(stopsTableCont),"Container does not have the right stops");
	
//	//Load a CAMIR file - ensure get an error when trying to load a file with the same timestamp
	self.uLoadCAMIR(DISPO_CODE_REM_C_STO, 10, BOL_NUM, "180000", false, false);
	self.assertFalseMsg(container.hasStopOfType(stopsTableCont),"Container still has stops");
	
//	//Load a CAMIR file - ensure get an error when trying to load a file with the same timestamp
	self.uLoadCAMIR(DISPO_CODE_ADD_TODO, 10, BOL_NUM, "190000", false, false);
	self.assertTrueMsg(container.hasToDoTaskDesc(todoTaskDesc.description),"Container does not have the right Todo");	
	
	//	//Load a CAMIR file - ensure get an error when trying to load a file with the same timestamp
	self.uLoadCAMIR(DISPO_CODE_REM_TODO, 10, BOL_NUM, "200000", false, false);
	self.assertFalseMsg(container.hasToDoTaskDesc(todoTaskDesc.description),"Container still has ToDo Task");	
	//
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete strs;
	
	if process.isInTransactionState then
		abortTransaction;
	endif;
	
	beginTransaction;							// 28/07/2014 cnwmh5
		if stopsTable &lt;&gt; null then
			stopsTable.setPropertyValue("isNotAvailableForEntry", true);
		endif;
		if stopsTableOther &lt;&gt; null then
			stopsTableOther.setPropertyValue("isNotAvailableForEntry", true);
		endif;
		if stopsTableCont &lt;&gt; null then
			stopsTableCont.setPropertyValue("isNotAvailableForEntry", true);	
		endif;
	commitTransaction;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCAMIRCustomsStatus62335" id="88bdeb80-4677-4851-bd73-84e73993844d">
        <source>tCAMIRCustomsStatus62335();
// cnwrs1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 July 2014	cnwmc5	Initial creation
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
*/
// 21 Jun 2018	jlgrs1	TFS 39298 (TFS 36430) Penn Ship Manifest too many locks
// 10 Sep 2019	cnwrs1	TFS 46030
//6/11/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
//04 Mar 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation

constants
	EDIPartyName = "ICL";
	EDI_PORTFOREIGN = "1XX7";
	EDI_PORT = "USJAX";
	VESSEL_CODE			= "ICLAD";
	VOYAGE_CODE			= "UT_CAMIR";
	SHIPPING_LINE		= "ICL";
	OPER_ID				= "ICL";
	STOP_ID				= 304;
	STOP_CODE			= "UTCAM";
	STOP_HEAD			= "UT CAMIR CUSTOMS";
	STOP_ID_OTH			= 305;
	STOP_CODE_OTH		= "UTOTH";
	STOP_HEAD_OTH		= "UT CAMIR OTHER";
	STOP_ID_CONT		= 306;
	STOP_CODE_CONT		= "UTCNT";
	STOP_HEAD_CONT		= "UT CAMIR CUSTOMS CONT STOP";
	TODO_CODE_CONT		= "UTCNT";
	TODO_HEAD_CONT		= "UT CAMIR CUSTOMS CONT TASK";
	
	
	DISPO_CODE_SET_REL	= "3A";
	DISPO_NAME_SET_REL	= "UT Set Released";
	DISPO_CODE_SET_ENT	= "3B";
	DISPO_NAME_SET_ENT	= "UT Set Entries";
	DISPO_CODE_ADD_STO	= "3C";
	DISPO_NAME_ADD_STO	= "UT Add BOL Stop";
	DISPO_CODE_REM_STO	= "3D";
	DISPO_NAME_REM_STO	= "UT Remove BOL Stop";
	
	DISPO_CODE_ADD_C_STO	= "3E";
	DISPO_NAME_ADD_C_STO	= "UT Add CONT Stop";
	DISPO_CODE_REM_C_STO	= "3F";
	DISPO_NAME_REM_C_STO	= "UT Remove CONT Stop";	
	DISPO_CODE_ADD_TODO	 	= "3G";
	DISPO_NAME_ADD_TODO		= "UT Add TODO";
	DISPO_CODE_REM_TODO		= "3I";
	DISPO_NAME_REM_TODO		= "UT Remove TODO";
	BOL_NUM				= "MCBOL01";
	CARGO_ID			= "UTCAMIR0001";
	EDI_VOYAGE			= "UTCAM";
vars
	voyage				: CM_Voyage;
	operator			: CM_Operator;
	bol					: CM_BOL;
	stopsTable			: CM_StopsTable;
	stopsTableOther		: CM_StopsTable;
	stopsTableCont		: CM_StopsTable;
	ediAction			: CM_EDIAction;
	ediFileType			: CM_EDIFileType;
	thisPort			: CM_Port;
	port : CM_Port;
	container			: CM_Container;
	thisPortCode		: String;	
	numReleased			: Integer;
	origEntries			: Integer;
	newEntries			: Integer;
	strs				: StringArray;
	ediParty 			: CM_EDIParty;
	proxyEDIParty 		: CM_EDIParty;
	pxyRules 			: CM_EDIPartyRules;
	terminal 			: CM_Terminal;
	isDoClearanceCheck 	: Boolean;
	todoTaskDesc 		: CM_ToDoTaskDesc;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.setTerminalConfig(EdiShipManAllowPartial, true);
	terminal := self.getTerminal;
	self.deleteContainer(CARGO_ID);
	self.deleteVoyage(VOYAGE_CODE);
		
	//Setup
	thisPortCode := self.getTerminalConfig(PortDestCode).String;
	thisPort := self.getPort(thisPortCode);
	operator := self.getOperator(OPER_ID);
	port := self.getPort(EDI_PORT);
	
	//Create new voyage
	voyage := self.addVoyageWithContainerStructur(VOYAGE_CODE, VESSEL_CODE, operator.code, SHIPPING_LINE);
	self.assertNotNull(voyage);
	
	//create new EDI Party
	self.deleteEDIParty(EDIPartyName);
	ediParty := self.createEDIParty(EDIPartyName, EDIPartyName, EDIPartyName, operator);
	beginLoad;
	proxyEDIParty := ediParty.pxyCreateUpdateProxy;
	endLoad;
	create pxyRules as CM_EDIPartyCuscarRules transient;	
	pxyRules.setMyEDIParty(proxyEDIParty);
	pxyRules.setMyEDIConfig(terminal.myEdiConfig);
	pxyRules.setPropertyValue(CM_EDIPartyCuscarRules::ediTypeShipManifest.name, true);
	pxyRules.setPropertyValue(CM_EDIPartyCuscarRules::myChildCargoTypeDefault.name, app.myRoot.allCargoTypesById[TI_CargoType_LCL]);
	app.myTrxUA.trxUpdateEDIParty(proxyEDIParty, app.myPassport);
	
	delete proxyEDIParty;
	
	//Load a bay plan for the voyage
	self.uLoadBayPlan(voyage.code, thisPortCode);
	
	//Load a CUSCAR for the voyage - with a BOL
	self.uLoadCUSCAR(BOL_NUM, voyage.code, thisPortCode);
	
	//Check there is a customs stop on the BOL
	bol := self.getBOL(BOL_NUM, BOLType_GeneralBillOfLading, operator.code);
	self.assertTrue(bol.hasStopOfType(stopsTable));
	
	//Create the appropriate xlations
	self.deleteEDIInwardXlation(EDI_VOYAGE, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.createEDIXlation(EDI_VOYAGE, voyage.code, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);
	self.deleteEDIInwardXlation(EDI_PORTFOREIGN, XLATION_TYPE_PORT_BYOP, operator, null);
	self.createEDIXlation(EDI_PORTFOREIGN, port.code, XLATION_TYPE_PORT_BYOP, false, operator, null);
	
	//Load a CAMIR file - this will set the entries
	origEntries := bol.customsQuantityEntered;
//	newEntries := 15;
	newEntries := 50;
	
	self.uLoadCAMIR62335(DISPO_CODE_SET_ENT, newEntries, BOL_NUM, "110000", false, false);
	self.assertEqual(bol.customsQuantityEntered, newEntries);
	
	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete strs;
	
	if process.isInTransactionState then
		abortTransaction;
	endif;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="tCAMIRCustomsStatus63046" id="fd316e54-75f4-4b66-9f85-1e17edb846d5">
        <source>tCAMIRCustomsStatus63046();
// jlirs1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Mar 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
25 Mar 2024	jlirs1	TFS 63046 PENN CAMIR Test
*/

constants
	EDIPartyName = "ICL";
	VESSEL_CODE			= "ICLAD";
	VOYAGE_CODE			= "SPD155S";
	SHIPPING_LINE		= "ICL";
	OPER_ID				= "ICL";
	STOP_ID				= 304;
	STOP_CODE			= "UTCAM";
	STOP_HEAD			= "UT CAMIR CUSTOMS";
	TODO_CODE_CONT		= "UTCNT";
	DISPO_CODE_SET_REL	= "3";
	DISPO_NAME_SET_REL	= "UT Set Released";
	BOL_NUM				= "7976575A";
	CARGO_ID			= "UTCAMIR0001";
	EDI_VOYAGE			= "00154";
	VoyageCodeIn = "SPD154S";
vars
	voyage				: CM_Voyage;
	operator			: CM_Operator;
	bol					: CM_BOL;
	stopsTable			: CM_StopsTable;
	stopsTableOther		: CM_StopsTable;
	stopsTableCont		: CM_StopsTable;
	ediAction			: CM_EDIAction;
	ediFileType			: CM_EDIFileType;
	thisPort			: CM_Port;
	container			: CM_Container;
	thisPortCode		: String;	
	numReleased			: Integer;
	origEntries			: Integer;
	newEntries			: Integer;
	strs				: StringArray;
	ediParty 			: CM_EDIParty;
	proxyEDIParty 		: CM_EDIParty;
	pxyRules 			: CM_EDIPartyRules;
	terminal 			: CM_Terminal;
	isDoClearanceCheck 	: Boolean;
	todoTaskDesc 		: CM_ToDoTaskDesc;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.setTerminalConfig(EdiShipManAllowPartial, true);
	terminal := self.getTerminal;
	//Before tidy-up
	self.deleteStopsTable(STOP_ID);
	
	self.deleteEDIAction(DISPO_NAME_SET_REL, null, "R02");
	
	// delete todo taks
	todoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey(TODO_CODE_CONT);
	if todoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription(todoTaskDesc);
	endif;
	
	self.deleteBOL(BOL_NUM, null);
	self.deleteContainer(CARGO_ID);
	self.deleteVoyage(VOYAGE_CODE);
		
	//Setup
	thisPortCode := self.getTerminalConfig(PortDestCode).String;
	thisPort := self.getPort(thisPortCode);
	operator := self.getOperator(OPER_ID);
	
	//Ensure the Customs Stop is setup to auto apply
	stopsTable := self.uSetupAutomaticBOLStop(STOP_ID, STOP_CODE, STOP_HEAD);
	self.assertNotNull(stopsTable);
	
	//Ensure the Customs Stop is setup to be auto cleared (new terminal config option)
	self.setTerminalConfig(EdiCustomsStopsTable, stopsTable);
	self.assertEqual(self.getTerminalConfig(EdiCustomsStopsTable).CM_StopsTable, stopsTable);
	
	//Ensure the disposition codes are on the CAMIR EDI file type (create them if not)
	ediFileType := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileTypeCAMIR_CustomsStatus, null);
	self.assertNotNull(ediFileType);
	
	//Create EDI Action to Set Released
	ediAction := ediFileType.allEDIActions[DISPO_NAME_SET_REL];
	if ediAction = null then
		self.addEDIAction(DISPO_NAME_SET_REL, DISPO_CODE_SET_REL, "R02", EDIAction_SetReleased, null, ediFileType, "Unit Test CAMIR", null);
	endif;
	
	//Create new voyage
	self.opts.addAssoc(ETRow_InwardCode, VoyageCodeIn);
	voyage := self.addVoyageWithContainerStructur(VOYAGE_CODE, VESSEL_CODE, operator.code, SHIPPING_LINE);
	self.assertNotNull(voyage);
	
	//create new EDI Party
	self.deleteEDIParty(EDIPartyName);
	ediParty := self.createEDIParty(EDIPartyName, EDIPartyName, EDIPartyName, operator);
	beginLoad;
	proxyEDIParty := ediParty.pxyCreateUpdateProxy;
	endLoad;
	create pxyRules as CM_EDIPartyCuscarRules transient;	
	pxyRules.setMyEDIParty(proxyEDIParty);
	pxyRules.setMyEDIConfig(terminal.myEdiConfig);
	pxyRules.setPropertyValue(CM_EDIPartyCuscarRules::ediTypeShipManifest.name, true);
	pxyRules.setPropertyValue(CM_EDIPartyCuscarRules::myChildCargoTypeDefault.name, app.myRoot.allCargoTypesById[TI_CargoType_LCL]);
	app.myTrxUA.trxUpdateEDIParty(proxyEDIParty, app.myPassport);
	
	delete proxyEDIParty;
	
	//Load a bay plan for the voyage
	self.xLoadBayPlan63046(voyage.code, thisPortCode);
	
	//Load a CUSCAR for the voyage - with a BOL
	self.xLoadCUSCAR63046(BOL_NUM, voyage.code, thisPortCode);
	
	//Check there is a customs stop on the BOL
	bol := self.getBOL(BOL_NUM, BOLType_GeneralBillOfLading, operator.code);
	self.assertTrue(bol.hasStopOfType(stopsTable));
	
	//Create the appropriate xlations
	self.deleteEDIInwardXlation(EDI_VOYAGE, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.createEDIXlation(EDI_VOYAGE, VoyageCodeIn, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);
	
	//Load a CAMIR file - this will set the entries
	origEntries := bol.customsQuantityEntered;
	newEntries := 50;
	
	self.xLoadCAMIR63046(DISPO_CODE_SET_REL, newEntries, BOL_NUM, "110000", false, false);
	self.assertEqual(bol.customsQuantityEntered, newEntries);
	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete strs;
	
	if process.isInTransactionState then
		abortTransaction;
	endif;
	
	beginTransaction;							// 28/07/2014 cnwmh5
		if stopsTable &lt;&gt; null then
			stopsTable.setPropertyValue("isNotAvailableForEntry", true);
		endif;
		if stopsTableOther &lt;&gt; null then
			stopsTableOther.setPropertyValue("isNotAvailableForEntry", true);
		endif;
		if stopsTableCont &lt;&gt; null then
			stopsTableCont.setPropertyValue("isNotAvailableForEntry", true);	
		endif;
	commitTransaction;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCAMIRTestIsImport" id="802d6911-e84e-4824-a864-a1d5930e419a">
        <source>tCAMIRTestIsImport();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Mar 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
*/
constants
	EDIPartyName = "ICL";
	VESSEL_CODE			= "ICLAD";
	VOYAGE_CODE01		= "UTIR01";
	VOYAGE_CODE02		= "UTIR02";
	SHIPPING_LINE		= "ICL";
	OPER_ID				= "ICL";
//	STOP_ID				= 304;
//	STOP_CODE			= "UTCAM";
//	STOP_HEAD			= "UT CAMIR CUSTOMS";
//	STOP_ID_OTH			= 305;
//	STOP_CODE_OTH		= "UTOTH";
//	STOP_HEAD_OTH		= "UT CAMIR OTHER";
//	STOP_ID_CONT		= 306;
//	STOP_CODE_CONT		= "UTCNT";
//	STOP_HEAD_CONT		= "UT CAMIR CUSTOMS CONT STOP";
//	TODO_CODE_CONT		= "UTCNT";
//	TODO_HEAD_CONT		= "UT CAMIR CUSTOMS CONT TASK";
//	DISPO_CODE_SET_REL	= "3A";
//	DISPO_NAME_SET_REL	= "UT Set Released";
	DISPO_CODE_SET_ENT	= "3B";
//	DISPO_NAME_SET_ENT	= "UT Set Entries";
//	DISPO_CODE_ADD_STO	= "3C";
//	DISPO_NAME_ADD_STO	= "UT Add BOL Stop";
//	DISPO_CODE_REM_STO	= "3D";
//	DISPO_NAME_REM_STO	= "UT Remove BOL Stop";
//	DISPO_CODE_ADD_C_STO	= "3E";
//	DISPO_NAME_ADD_C_STO	= "UT Add CONT Stop";
//	DISPO_CODE_REM_C_STO	= "3F";
//	DISPO_NAME_REM_C_STO	= "UT Remove CONT Stop";	
//	DISPO_CODE_ADD_TODO	 	= "3G";
//	DISPO_NAME_ADD_TODO		= "UT Add TODO";
//	DISPO_CODE_REM_TODO		= "3I";
//	DISPO_NAME_REM_TODO		= "UT Remove TODO";
	BOL_NUM01 = "MCBOL01";
	BOL_NUM02 = "MCBOL02";
	CARGO_ID			= "UTCAMIR0001";
	EDI_VOYAGE			= "UTCAM";
vars
	voyage01 : CM_Voyage;
	voyage02 : CM_Voyage;
	operator			: CM_Operator;
//	bol1 : CM_BOL;
//	bol2 : CM_BOL;
//	stopsTable			: CM_StopsTable;
//	stopsTableOther		: CM_StopsTable;
//	stopsTableCont		: CM_StopsTable;
//	ediAction			: CM_EDIAction;
//	ediFileType			: CM_EDIFileType;
	thisPort			: CM_Port;
//	container			: CM_Container;
	thisPortCode		: String;	
//	numReleased			: Integer;
//	origEntries			: Integer;
	newEntries			: Integer;
	strs				: StringArray;
	ediParty 			: CM_EDIParty;
	proxyEDIParty 		: CM_EDIParty;
	pxyRules 			: CM_EDIPartyRules;
	pxyRulesCamir : CM_EDIPartyCAMIRRules;
	terminal 			: CM_Terminal;
	isDoClearanceCheck 	: Boolean;
//	todoTaskDesc 		: CM_ToDoTaskDesc;
	ediFile : CM_EDIFile;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.setTerminalConfig(EdiShipManAllowPartial, true);
	terminal := self.getTerminal;
	
	self.deleteBOL(BOL_NUM01, null);
	self.deleteBOL(BOL_NUM02, null);
	self.deleteContainer(CARGO_ID);
	self.deleteVoyage(VOYAGE_CODE01);
	self.deleteVoyage(VOYAGE_CODE02);
		
	//Setup
	thisPortCode := self.getTerminalConfig(PortDestCode).String;
	thisPort := self.getPort(thisPortCode);
	operator := self.getOperator(OPER_ID);
	
	//Create new voyage
	voyage01 := self.addVoyageWithContainerStructur(VOYAGE_CODE01, VESSEL_CODE, operator.code, SHIPPING_LINE);
	self.assertNotNull(voyage01);
	voyage02 := self.addVoyageWithContainerStructur(VOYAGE_CODE02, VESSEL_CODE, operator.code, SHIPPING_LINE);
	self.assertNotNull(voyage02);
	
	//create new EDI Party
	self.deleteEDIParty(EDIPartyName);
	ediParty := self.createEDIParty(EDIPartyName, EDIPartyName, EDIPartyName, operator);
	beginLoad;
	proxyEDIParty := ediParty.pxyCreateUpdateProxy;
	endLoad;
	create pxyRules as CM_EDIPartyCuscarRules transient;
	pxyRules.setMyEDIParty(proxyEDIParty);
	pxyRules.setMyEDIConfig(terminal.myEdiConfig);
	pxyRules.setPropertyValue(CM_EDIPartyCuscarRules::ediTypeShipManifest.name, true);
	pxyRules.setPropertyValue(CM_EDIPartyCuscarRules::myChildCargoTypeDefault.name, app.myRoot.allCargoTypesById[TI_CargoType_LCL]);
	app.myTrxUA.trxUpdateEDIParty(proxyEDIParty, app.myPassport);
	delete proxyEDIParty;
	
	//Create the appropriate xlations
	self.deleteEDIInwardXlation(EDI_VOYAGE, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.createEDIXlation(EDI_VOYAGE, voyage01.code, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);
	self.createEDIXlation(EDI_VOYAGE, voyage02.code, XLATION_TYPE_VOYAGETERMINAL, false, operator, null, true);
	newEntries := 50;
	
	ediFile := self.uLoadCAMIR(DISPO_CODE_SET_ENT, newEntries, BOL_NUM01, "110000", false, true);
	self.assertEqual(ediFile.ediData.allEDITrackedItems.first.getVoyageCode, VOYAGE_CODE01);
	
	//create new EDI Party
	self.deleteEDIParty(EDIPartyName);
	ediParty := self.createEDIParty(EDIPartyName, EDIPartyName, EDIPartyName, operator);
	beginLoad;
	proxyEDIParty := ediParty.pxyCreateUpdateProxy;
	endLoad;
	create pxyRules as CM_EDIPartyCuscarRules transient;	
	pxyRules.setMyEDIParty(proxyEDIParty);
	pxyRules.setMyEDIConfig(terminal.myEdiConfig);
	pxyRules.setPropertyValue(CM_EDIPartyCuscarRules::ediTypeShipManifest.name, true);
	pxyRules.setPropertyValue(CM_EDIPartyCuscarRules::myChildCargoTypeDefault.name, app.myRoot.allCargoTypesById[TI_CargoType_LCL]);
	create pxyRulesCamir transient;
	pxyRulesCamir.setMyEDIParty(proxyEDIParty);
	pxyRulesCamir.setMyEDIConfig(terminal.myEdiConfig);
	pxyRulesCamir.setPropertyValue(CM_EDIPartyCAMIRRules::isImport.name, true);
	app.myTrxUA.trxUpdateEDIParty(proxyEDIParty, app.myPassport);
	delete proxyEDIParty;

	ediFile := self.uLoadCAMIR(DISPO_CODE_SET_ENT, newEntries, BOL_NUM01, "110000", false, true);
	self.assertEqual(ediFile.ediData.allEDITrackedItems.first.getVoyageCode, VOYAGE_CODE02);

	//Create the appropriate xlations
	self.deleteEDIInwardXlation(EDI_VOYAGE, XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.createEDIXlation(EDI_VOYAGE, voyage01.code, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);
	self.createEDIXlation(EDI_VOYAGE, voyage02.code, XLATION_TYPE_VOYAGETERMINAL, false, operator, null, false);

	ediFile := self.uLoadCAMIR(DISPO_CODE_SET_ENT, newEntries, BOL_NUM01, "110000", false, true);
	self.assertEqual(ediFile.ediData.allEDITrackedItems.first.getVoyageCode, VOYAGE_CODE01);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete strs;
	
	if process.isInTransactionState then
		abortTransaction;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="uCAMIRCustomsStatusNew" id="e65a65d2-6f6b-4ad6-9f9b-c96a867f6c6f">
        <source>uCAMIRCustomsStatusNew();
// cnwrs1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 July 2014	cnwmc5	Initial creation
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
*/
// 21 Jun 2018	jlgrs1	TFS 39298 (TFS 36430) Penn Ship Manifest too many locks
// 10 Sep 2019	cnwrs1	TFS 46030
//6/11/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
//04 Mar 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
//
constants
	EDIPartyName = "ICL";
	VESSEL_CODE			= "ICLAD";
	VOYAGE_CODE01		= "UTIR01";
	VOYAGE_CODE02		= "UTIR02";
	SHIPPING_LINE		= "ICL";
	OPER_ID				= "ICL";
	STOP_ID				= 304;
	STOP_CODE			= "UTCAM";
	STOP_HEAD			= "UT CAMIR CUSTOMS";
	STOP_ID_OTH			= 305;
	STOP_CODE_OTH		= "UTOTH";
	STOP_HEAD_OTH		= "UT CAMIR OTHER";
	STOP_ID_CONT		= 306;
	STOP_CODE_CONT		= "UTCNT";
	STOP_HEAD_CONT		= "UT CAMIR CUSTOMS CONT STOP";
	TODO_CODE_CONT		= "UTCNT";
	TODO_HEAD_CONT		= "UT CAMIR CUSTOMS CONT TASK";
	
	
	DISPO_CODE_SET_REL	= "3A";
	DISPO_NAME_SET_REL	= "UT Set Released";
	DISPO_CODE_SET_ENT	= "3B";
	DISPO_NAME_SET_ENT	= "UT Set Entries";
	DISPO_CODE_ADD_STO	= "3C";
	DISPO_NAME_ADD_STO	= "UT Add BOL Stop";
	DISPO_CODE_REM_STO	= "3D";
	DISPO_NAME_REM_STO	= "UT Remove BOL Stop";
	
	DISPO_CODE_ADD_C_STO	= "3E";
	DISPO_NAME_ADD_C_STO	= "UT Add CONT Stop";
	DISPO_CODE_REM_C_STO	= "3F";
	DISPO_NAME_REM_C_STO	= "UT Remove CONT Stop";	
	DISPO_CODE_ADD_TODO	 	= "3G";
	DISPO_NAME_ADD_TODO		= "UT Add TODO";
	DISPO_CODE_REM_TODO		= "3I";
	DISPO_NAME_REM_TODO		= "UT Remove TODO";
	
	
	BOL_NUM01 = "MCBOL01";
	BOL_NUM02 = "MCBOL02";
	CARGO_ID			= "UTCAMIR0001";
	EDI_VOYAGE			= "UTCAM";
vars
	
	voyage01 : CM_Voyage;
	voyage02 : CM_Voyage;
	operator			: CM_Operator;
	bol1 : CM_BOL;
	bol2 : CM_BOL;
	stopsTable			: CM_StopsTable;
	stopsTableOther		: CM_StopsTable;
	stopsTableCont		: CM_StopsTable;
	ediAction			: CM_EDIAction;
	ediFileType			: CM_EDIFileType;
	thisPort			: CM_Port;
	container			: CM_Container;
	thisPortCode		: String;	
	numReleased			: Integer;
	origEntries			: Integer;
	newEntries			: Integer;
	strs				: StringArray;
	ediParty 			: CM_EDIParty;
	proxyEDIParty 		: CM_EDIParty;
	pxyRules 			: CM_EDIPartyRules;
	terminal 			: CM_Terminal;
	isDoClearanceCheck 	: Boolean;
	todoTaskDesc 		: CM_ToDoTaskDesc;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.setTerminalConfig(EdiShipManAllowPartial, true);
	terminal := self.getTerminal;
	//Before tidy-up
	self.deleteStopsTable(STOP_ID);
	self.deleteStopsTable(STOP_ID_OTH);
	self.deleteStopsTable(STOP_ID_CONT);	

	self.deleteEDIAction(DISPO_NAME_SET_REL, null, "R02");
	self.deleteEDIAction(DISPO_NAME_SET_ENT, null, "R02");
	self.deleteEDIAction(DISPO_NAME_ADD_STO, null, "R02");
	self.deleteEDIAction(DISPO_NAME_REM_STO, null, "R02");
	self.deleteEDIAction(DISPO_NAME_ADD_C_STO, null, "R02");
	self.deleteEDIAction(DISPO_NAME_REM_C_STO, null, "R02");
	self.deleteEDIAction(DISPO_NAME_ADD_TODO, null, "R02");
	self.deleteEDIAction(DISPO_NAME_REM_TODO, null, "R02");

	// delete todo taks
	todoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey(TODO_CODE_CONT);
	if todoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription(todoTaskDesc);
	endif;
	
	self.deleteBOL(BOL_NUM01, null);
	self.deleteBOL(BOL_NUM02, null);
	self.deleteContainer(CARGO_ID);
	self.deleteVoyage(VOYAGE_CODE01);
	self.deleteVoyage(VOYAGE_CODE02);
		
	//Setup
	thisPortCode := self.getTerminalConfig(PortDestCode).String;
	thisPort := self.getPort(thisPortCode);
	operator := self.getOperator(OPER_ID);
	
	//Ensure the Customs Stop is setup to auto apply
	stopsTable := self.uSetupAutomaticBOLStop(STOP_ID, STOP_CODE, STOP_HEAD);
	self.assertNotNull(stopsTable);
	
	//Create another stop
	stopsTableOther := self.uSetupAutomaticBOLStop(STOP_ID_OTH, STOP_CODE_OTH, STOP_HEAD_OTH);
	self.assertNotNull(stopsTableOther);
	
	//And Another
	self.opts.addAssoc("overRideCargoType",TI_CargoType_Container );
	stopsTableCont := self.uSetupAutomaticBOLStop(STOP_ID_CONT, STOP_CODE_CONT, STOP_HEAD_CONT);
	self.assertNotNull(stopsTableCont);
	self.opts.removeAssoc("overRideCargoType");
	
	todoTaskDesc := self.basicCreateCM_ToDoTaskDesc(TODO_HEAD_CONT, TODO_CODE_CONT, null, null, null); 
	self.assertNotNullMsg(todoTaskDesc, "To do task not created");
	
	
		
	//Ensure the Customs Stop is setup to be auto cleared (new terminal config option)
	self.setTerminalConfig(EdiCustomsStopsTable, stopsTable);
	self.assertEqual(self.getTerminalConfig(EdiCustomsStopsTable).CM_StopsTable, stopsTable);
	
	//Ensure the disposition codes are on the CAMIR EDI file type (create them if not)
	ediFileType := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileTypeCAMIR_CustomsStatus, null);
	self.assertNotNull(ediFileType);
	
	//Create EDI Action to Set Released
	ediAction := ediFileType.allEDIActions[DISPO_NAME_SET_REL];
	if ediAction = null then
		self.addEDIAction(DISPO_NAME_SET_REL, DISPO_CODE_SET_REL, "R02", EDIAction_SetReleased, null, ediFileType, "Unit Test CAMIR", null);
	endif;
	
	//Create EDI Action to Set Entries
	ediAction := ediFileType.allEDIActions[DISPO_NAME_SET_ENT];
	if ediAction = null then
		self.addEDIAction(DISPO_NAME_SET_ENT, DISPO_CODE_SET_ENT, "R02", EDIAction_SetEntries, null, ediFileType, "Unit Test CAMIR", null);
	endif;
	
	//Create EDI Action to Add a BOL Stop
	ediAction := ediFileType.allEDIActions[DISPO_NAME_ADD_STO];
	if ediAction = null then
		self.addEDIAction(DISPO_NAME_ADD_STO, DISPO_CODE_ADD_STO, "R02", EDIAction_PlaceHold, stopsTableOther, ediFileType, "Unit Test CAMIR", null);
	endif;
	
	//Create EDI Action to Remove a BOL Stop
	ediAction := ediFileType.allEDIActions[DISPO_NAME_REM_STO];
	if ediAction = null then
		self.addEDIAction(DISPO_NAME_REM_STO, DISPO_CODE_REM_STO, "R02", EDIAction_RemoveHolds, stopsTableOther, ediFileType, "Unit Test CAMIR", null);
	endif;

	//Create EDI Action to Add a Container Stop
	ediAction := ediFileType.allEDIActions[DISPO_NAME_ADD_C_STO];
	if ediAction = null then
		self.addEDIAction(DISPO_NAME_ADD_C_STO, DISPO_CODE_ADD_C_STO, "R02", EDIAction_PlaceContHold , stopsTableCont, ediFileType, "Unit Test CAMIR", null);
	endif;
	
	//Create EDI Action to Remove a Container Stop
	ediAction := ediFileType.allEDIActions[DISPO_NAME_REM_C_STO];
	if ediAction = null then
		self.addEDIAction(DISPO_NAME_REM_C_STO, DISPO_CODE_REM_C_STO, "R02", EDIAction_RemoveContHold , stopsTableCont, ediFileType, "Unit Test CAMIR", null);
	endif;
	
	//Create EDI Action to Add a TODO Task
	ediAction := ediFileType.allEDIActions[DISPO_NAME_ADD_TODO];
	if ediAction = null then
		self.addEDIAction(DISPO_NAME_ADD_TODO, DISPO_CODE_ADD_TODO, "R02", EDIAction_AddToDoTask , todoTaskDesc, ediFileType, "Unit Test CAMIR", null);
	endif;
	
	//Create EDI Action to Remove a TODO Task
	ediAction := ediFileType.allEDIActions[DISPO_NAME_REM_TODO];
	if ediAction = null then
		self.addEDIAction(DISPO_NAME_REM_TODO, DISPO_CODE_REM_TODO, "R02", EDIAction_DeleteToDoTask , todoTaskDesc, ediFileType, "Unit Test CAMIR", null);
	endif;
	
	//Create new voyage
	voyage01 := self.addVoyageWithContainerStructur(VOYAGE_CODE01, VESSEL_CODE, operator.code, SHIPPING_LINE);
	self.assertNotNull(voyage01);
	voyage02 := self.addVoyageWithContainerStructur(VOYAGE_CODE02, VESSEL_CODE, operator.code, SHIPPING_LINE);
	self.assertNotNull(voyage02);
	
	//create new EDI Party
	self.deleteEDIParty(EDIPartyName);
	ediParty := self.createEDIParty(EDIPartyName, EDIPartyName, EDIPartyName, operator);
	beginLoad;
	proxyEDIParty := ediParty.pxyCreateUpdateProxy;
	endLoad;
	create pxyRules as CM_EDIPartyCuscarRules transient;	
	pxyRules.setMyEDIParty(proxyEDIParty);
	pxyRules.setMyEDIConfig(terminal.myEdiConfig);
	pxyRules.setPropertyValue(CM_EDIPartyCuscarRules::ediTypeShipManifest.name, true);
	pxyRules.setPropertyValue(CM_EDIPartyCuscarRules::myChildCargoTypeDefault.name, app.myRoot.allCargoTypesById[TI_CargoType_LCL]);
	app.myTrxUA.trxUpdateEDIParty(proxyEDIParty, app.myPassport);
	delete proxyEDIParty;
	
	//Load a bay plan for the voyage 01
	self.uLoadBayPlan(voyage01.code, thisPortCode);
	
	//Load a CUSCAR for the voyage - with a BOL
	self.uLoadCUSCAR(BOL_NUM01, voyage01.code, thisPortCode);
	
	//Check there is a customs stop on the BOL
	bol1 := self.getBOL(BOL_NUM01, BOLType_GeneralBillOfLading, operator.code);
	self.assertTrue(bol1.hasStopOfType(stopsTable));
	
	//Create the appropriate xlations
	self.createEDIXlation(EDI_VOYAGE, voyage01.code, XLATION_TYPE_VOYAGETERMINAL, false, operator, null);

	//Load a bay plan for the voyage 02
	self.uLoadBayPlan(voyage02.code, thisPortCode);
	
	//Load a CUSCAR for the voyage - with a BOL
	self.uLoadCUSCAR(BOL_NUM02, voyage02.code, thisPortCode);
	
	//Check there is a customs stop on the BOL
	bol2 := self.getBOL(BOL_NUM02, BOLType_GeneralBillOfLading, operator.code);
	self.assertTrue(bol2.hasStopOfType(stopsTable));
	
	//Create the appropriate xlations
	self.createEDIXlation(EDI_VOYAGE, voyage02.code, XLATION_TYPE_VOYAGETERMINAL, false, operator, null, true);
	
	//Load a CAMIR file - this will set the entries
	origEntries := bol1.customsQuantityEntered;
//	newEntries := 15;
	newEntries := 50;
	
	self.uLoadCAMIR(DISPO_CODE_SET_ENT, newEntries, BOL_NUM01, "110000", false, false);
	self.assertEqual(bol1.customsQuantityEntered, newEntries);
	
	//Load a CAMIR file - this will set the entries back to the original
	self.uLoadCAMIR(DISPO_CODE_SET_ENT, origEntries, BOL_NUM01, "120000", false, false);
	self.assertEqual(bol1.customsQuantityEntered, origEntries);
	
	//Load a CAMIR file - this will set the released - less than the entires
	numReleased := bol1.customsQuantityEntered - 12;
	self.uLoadCAMIR(DISPO_CODE_SET_REL, numReleased, BOL_NUM01, "130000", false, false);
	self.assertEqual(bol1.customsQuantityReleased, numReleased);
	
	//Load a CAMIR file - this will also set the released - to now match the entries
	numReleased := bol1.customsQuantityEntered;
	self.uLoadCAMIR(DISPO_CODE_SET_REL, numReleased, BOL_NUM01, "140000", false, false);
	self.assertEqual(bol1.customsQuantityReleased, numReleased);
	self.assertFalse(bol1.hasStopOfType(stopsTable));
	
	//Load a CAMIR file - this will remove a stop
	self.uLoadCAMIR(DISPO_CODE_REM_STO, 10, BOL_NUM01, "150000", false, false);
	self.assertFalse(bol1.hasStopOfType(stopsTableOther));
	
	//Load a CAMIR file - this will add a stop again
	self.uLoadCAMIR(DISPO_CODE_ADD_STO, 10, BOL_NUM01, "160000", false, false);
	self.assertTrue(bol1.hasStopOfType(stopsTableOther));
	//Load a CAMIR file - ensure get an error when trying to load a file with the same timestamp
	self.uLoadCAMIR(DISPO_CODE_ADD_STO, 10, BOL_NUM01, "160000", true, false);
	
	container := voyage01.allOnshipTIsByCargoTypeId.getAtKey(TI_CargoType_Container, "ICUU2371952").CM_Container;
	//Load a CAMIR file - this will add a stop again
	self.uLoadCAMIR(DISPO_CODE_ADD_C_STO, 10, BOL_NUM01, "170000", false, false);
	self.assertTrueMsg(container.hasStopOfType(stopsTableCont),"Container does not have the right stops");
	
//	//Load a CAMIR file - ensure get an error when trying to load a file with the same timestamp
	self.uLoadCAMIR(DISPO_CODE_REM_C_STO, 10, BOL_NUM01, "180000", false, false);
	self.assertFalseMsg(container.hasStopOfType(stopsTableCont),"Container still has stops");
	
//	//Load a CAMIR file - ensure get an error when trying to load a file with the same timestamp
	self.uLoadCAMIR(DISPO_CODE_ADD_TODO, 10, BOL_NUM01, "190000", false, false);
	self.assertTrueMsg(container.hasToDoTaskDesc(todoTaskDesc.description),"Container does not have the right Todo");	
	
	//	//Load a CAMIR file - ensure get an error when trying to load a file with the same timestamp
	self.uLoadCAMIR(DISPO_CODE_REM_TODO, 10, BOL_NUM01, "200000", false, false);
	self.assertFalseMsg(container.hasToDoTaskDesc(todoTaskDesc.description),"Container still has ToDo Task");	
	//
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete strs;
	
	if process.isInTransactionState then
		abortTransaction;
	endif;
	
	beginTransaction;							// 28/07/2014 cnwmh5
		if stopsTable &lt;&gt; null then
			stopsTable.setPropertyValue("isNotAvailableForEntry", true);
		endif;
		if stopsTableOther &lt;&gt; null then
			stopsTableOther.setPropertyValue("isNotAvailableForEntry", true);
		endif;
		if stopsTableCont &lt;&gt; null then
			stopsTableCont.setPropertyValue("isNotAvailableForEntry", true);	
		endif;
	commitTransaction;

end;</source>
    </JadeMethod>
