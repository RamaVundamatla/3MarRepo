        <source>qlbDifferentMethods_contextMenu(listbox: ListBox input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 July 2022	navmd1	Initial creation

*/

vars
    x1 : Real;
    y1 : Real;
	devEnt	: DEV_SchemaObjectEntity;
begin
    x1 := x;
    y1 := y;
	
    listbox.windowToScreen(x1, y1);
    self.screenToWindow(x1, y1);   // convert x, y relative to form
    
	self.mnuUnresolve.visible := true;
	self.mnuUnresolve.enabled := false;
	self.mnuTableViewDiff.visible := true;  // ### JIRA 36455 23OCT2026 NAVAB1
	
	if listbox.listIndex &gt;= 1 then
		devEnt := listbox.itemObject[listbox.listIndex].DEV_SchemaObjectEntity;
		if devEnt &lt;&gt; null and devEnt.resolvedBy &lt;&gt; null then
			self.mnuUnresolve.enabled := true;
		endif;
	endif;
	
	self.mnuLBContext.userObject := listbox;
	self.popupMenu(self.mnuLBContext, x1.Integer, y1.Integer);
    
	return false;                  // cancel further processing
end;</source>
