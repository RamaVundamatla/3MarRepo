    <JadeMethod name="doDelete" id="8fe5cfe9-9b0f-4d39-9b44-9365d28cbd41">
        <updating/>
        <source>doDelete() updating, protected;
//--------------------------------------------------
// Created:	13 April 2005 By: RBarr
// Delete the selected XLAT_TranslatableText and the associated global constant
//--------------------------------------------------
// 17/09/2012		cnwmh5			#30275 - Change so that doesn't get into an endless loop.  Add additional logging to if happens again can see what went on.
vars
	result			: Integer;
	msgStr			: String;
	table			: CM_TextTranslationTable;
	partsDone		: Integer;
	globalConstant	: GlobalConstant;
begin

	table := zGetTopTable;
	 
	if self.myTranslatableText = null then
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), self.caption, MsgBox_OK_Only+MsgBox_Stop_Icon);
		return;	
	endif;

	if app.msgBox(app.getErrorString2(ConfirmDelete, 'the selected', 'translation'), self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
		return;
	endif;
	

	while true do

		app.writeLog('myTranslatableText: ' &amp; self.myTranslatableText.String &amp; Tab &amp; 'myTranslatableText.myGlobalConstant: ' &amp; 
			self.myTranslatableText.myGlobalConstant.String, LogINFO);															// 17/09/2012 cnwmh5 #30275													
			
		if app.isValidObject(self.myTranslatableText) and app.isValidObject(self.myTranslatableText.myGlobalConstant) then
		
			app.writeLog('myTranslatableText is valid and myTranslatableText.myGlobalConstant is valid', LogINFO);				// 17/09/2012 cwnmh5 #30275
			app.writeLog('myTranslatableText: ' &amp; self.myTranslatableText.String &amp; Tab &amp; self.myTranslatableText.vConstantName &amp; Tab &amp; 
				self.myTranslatableText.vConstantValue.String, LogINFO);															// 17/09/2012 cnwmh5 #30275
			app.writeLog('myTranslatableText.myGlobalConstant: ' &amp; self.myTranslatableText.myGlobalConstant.String &amp; Tab &amp; 
				self.myTranslatableText.myGlobalConstant.name &amp; Tab &amp; self.myTranslatableText.myGlobalConstant.getSource().String, LogINFO);	// 17/09/2012 cnwmh5 #30275
				
			globalConstant := self.myTranslatableText.myGlobalConstant;
			app.copyStringToClipboard(globalConstant.name);
			
			if app.isValidObject(globalConstant) and
			   app.msgBox('Please delete the global constant manually' &amp; CrLf &amp; 
						  'through the IDE (PortSchema, Global Constants browser), ' &amp; CrLf &amp; CrLf &amp; 
						  'Do not press OK until the constant has been deleted.' &amp; CrLf &amp; CrLf &amp; 
						  'ConstantCategory:		' &amp; globalConstant.getCategory.name &amp; CrLf &amp; 
						  'Name (in clipboard):		' &amp; globalConstant.name, caption, MsgBox_Information_Icon + MsgBox_OK_Cancel) = MsgBox_Return_Cancel then

				// watch out for the user deleting the constant, then pressing cancel anyway!
				if app.isValidObject(self.myTranslatableText.myGlobalConstant) then
					app.writeLog("Cancel pressed and user has deleted the constant", LogINFO);								// 15/04/2013 cnwmh5 #31432
					return;
				endif;
			endif;

		elseif app.isValidObject(self.myTranslatableText) and app.isValidObject(self.myTranslatableText.myGlobalConstant) = false then
		
			app.writeLog('myTranslatableText is valid and myTranslatableText.myGlobalConstant is invalid', LogINFO);				// 17/09/2012 cnwmh5 #30275
		
			self.myAgent.trxDeleteTranslatableText(self.myTranslatableText, app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
	
				// refresh the screen
				displayTranslatableText(table, partsDone);
				break;
			else
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
				if result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
		
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
			break;
		else									// 17/09/2012 cnwmh5 #30275
			break;
		endif;
		
		app.writeLog('Line before endwhile', LogINFO);																		// 17/09/2012 cnwmh5 #30275
		
	endwhile;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doExport" id="9329b945-2e2e-4ec9-b1db-97153566d124">
