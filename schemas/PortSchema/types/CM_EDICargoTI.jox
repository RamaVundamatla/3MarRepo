        <source>getManifestNumber() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Jan 2023	jlier1	Initial creation 55788
27 Jun 2023	navdap1	TFS 58813 EUP Manifest Instructions
*/

vars
	value : String;

begin
	value := self.manifestNumber;	// TFS 58813
	if value = null then			// TFS 58813
		global.getExtraData(self.allExtraData, ManifestNumber, value);
	endif;							// TFS 58813
	
	return value;

epilog

