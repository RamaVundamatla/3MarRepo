    <JadeMethod name="doAuditRateHistory" id="a63427cc-fad6-4d9d-ae80-6eaedc896e83">
        <updating/>
        <source>doAuditRateHistory(_newCosts : DecimalArray; pNewCost : Decimal; pNewStartTime : TimeStamp; _newExpiryTime : TimeStamp; _newIgnoreEntry : Boolean;
					pRate : CM_RateEntry; pDeleted : Boolean; _status : Integer) updating;
//----------------------------------------------
//Created: 9 October 2001 By: cnwgd1
// May 2010	23582 add expiry date and ignore options
//----------------------------------------------
vars
	auditRateChg	: CM_FinAuditRateHistory;
	now				: TimeStamp;
	rate			: CM_RateEntry;
	oldCPU, newCPU : Real;
	idx : Integer;
begin
	
	if pRate = null then
		return;
	endif;
	
	if _newCosts = null and
	  (not pDeleted) then	//par 10907 cnwrs1 mer 2006
		return;
	endif;
	
	if (not pDeleted) then		//No change so don't do audit	
		if pRate.startTimestamp = pNewStartTime and
		   pRate.expiryTimestamp = _newExpiryTime and
		   pRate.ignoreThisEntry = _newIgnoreEntry then
			if _newCosts.isEmpty then
				if pRate.getRawCostPerUnit = pNewCost then
					return;
				endif;
			else
				if _newCosts.membersSame(pRate.allCostPerUnits) then
					return;
				endif;
			endif;
		endif;
	endif;

	if _newCosts = null 
	or _newCosts.isEmpty //par 10907 cnwrs1 mer 2006
	or pRate.allCostPerUnits.isEmpty then
		self.doAuditRateHistoryCreate(pNewCost, pNewStartTime, _newExpiryTime, _newIgnoreEntry, pRate.getRawCostPerUnit, pRate.startTimestamp, pRate.expiryTimestamp, pRate.ignoreThisEntry, pDeleted, pRate, _status);
	else
		foreach oldCPU in pRate.allCostPerUnits do		
			idx := idx + 1;
			//epr par 11969
			if idx &gt; _newCosts.size then
				break;
			endif;
			
			newCPU := _newCosts[idx];
			if (newCPU &lt;&gt; oldCPU) 
			or (pNewStartTime &lt;&gt; pRate.startTimestamp)		// PAR 16503
			or (_newExpiryTime &lt;&gt; pRate.expiryTimestamp)
		    or (_newIgnoreEntry &lt;&gt; pRate.ignoreThisEntry) then
				self.doAuditRateHistoryCreate(newCPU, pNewStartTime, _newExpiryTime, _newIgnoreEntry, oldCPU, pRate.startTimestamp, pRate.expiryTimestamp, pRate. ignoreThisEntry, pDeleted, pRate, _status);
			endif;
		endforeach;
	endif;

end;</source>
        <Parameter name="_newCosts" type="DecimalArray"/>
        <Parameter name="pNewCost" type="Decimal"/>
        <Parameter name="pNewStartTime" type="TimeStamp"/>
        <Parameter name="_newExpiryTime" type="TimeStamp"/>
        <Parameter name="_newIgnoreEntry" type="Boolean"/>
        <Parameter name="pRate" type="CM_RateEntry"/>
        <Parameter name="pDeleted" type="Boolean"/>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doAuditRateHistoryCreate" id="19cd0092-e3f3-465a-9cea-bfad7f4b8326">
        <updating/>
        <source>doAuditRateHistoryCreate(_newCost : Decimal; _newStartTime : TimeStamp; _newExpiryTime : TimeStamp; _newIgnoreEntry : Boolean; _oldCost : Decimal; _oldStartTime : TimeStamp; 
						 _oldExpiryTime : TimeStamp; _oldIgnoreEntry : Boolean; pDeleted : Boolean; _auditedObject : CM_RateEntry; _status : Integer) protected, updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		JMH Invoice changes 
// May 2010	23582 add expiry date and ignore options
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
12 Oct 2016	cnwkpd1	TFS 2815 - JADE 7.1.08 causeEvent changes
	
*/

vars
	auditRateChg	: CM_FinAuditRateHistory;

begin
	create auditRateChg persistent;
	auditRateChg.auditedFOs.clear;
	auditRateChg.unauditedFOs.clear;
	auditRateChg.sequenceNum := app.getNextInvoiceSeqNumOnRootBank(SN_AUDIT); // PAR 15036
	auditRateChg.userId := app.getMyUserCode;
	auditRateChg.dateTime := app.actualTimeServer;
	auditRateChg.isDeleted := false;	
	auditRateChg.status := _status;
	
	if (not pDeleted) then
		auditRateChg.previousCost := _oldCost;
		auditRateChg.newCost := _newCost;
		auditRateChg.previousStartTime := _oldStartTime;
		auditRateChg.newStartTime := _newStartTime;
		auditRateChg.previousExpiryTime := _oldExpiryTime;
		auditRateChg.newExpiryTime := _newExpiryTime;
		auditRateChg.previousIgnoreEntry := _oldIgnoreEntry;
		auditRateChg.newIgnoreEntry := _newIgnoreEntry;
		auditRateChg.myRateEntry := _auditedObject;
	else 
		auditRateChg.isDeleted := true;
		auditRateChg.previousCost := _oldCost;
		auditRateChg.previousStartTime := _oldStartTime;
		auditRateChg.previousExpiryTime := _oldExpiryTime;
		auditRateChg.previousIgnoreEntry := _oldIgnoreEntry;
	endif;
	auditRateChg.auditedFOs.add(self);

//	self.causeEvent(Object_Update_Event, false, null);	
	self.updateObjectEdition(self);
			
end;</source>
        <access>protected</access>
        <Parameter name="_newCost" type="Decimal"/>
        <Parameter name="_newStartTime" type="TimeStamp"/>
        <Parameter name="_newExpiryTime" type="TimeStamp"/>
        <Parameter name="_newIgnoreEntry" type="Boolean"/>
        <Parameter name="_oldCost" type="Decimal"/>
        <Parameter name="_oldStartTime" type="TimeStamp"/>
        <Parameter name="_oldExpiryTime" type="TimeStamp"/>
        <Parameter name="_oldIgnoreEntry" type="Boolean"/>
        <Parameter name="pDeleted" type="Boolean"/>
        <Parameter name="_auditedObject" type="CM_RateEntry"/>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAuditOfClass" id="d893ae4f-9ec8-49fa-829e-972e04dd8b46">
        <source>getAuditOfClass(cls: Class): CM_Audit protected;
//----------------------------------------------
//Created: 9 October 2001 By: cnwgd1
//----------------------------------------------
vars
	audit:   CM_Audit;
begin
	foreach audit in qualifiedAudits do
		if audit.isKindOf(cls) then
			break;
		endif;
		audit := null;
	endforeach;

	if audit = null then
		foreach audit in unqualifiedAudits do
			if audit.isKindOf(cls) then
				break;
			endif;
			audit := null;
		endforeach;
	endif;

	return audit;
end;</source>
        <access>protected</access>
        <Parameter name="cls" type="Class"/>
        <ReturnType type="CM_Audit"/>
    </JadeMethod>
    <JadeMethod name="getBaseRateEntriesFrom" id="768063f6-ce47-4f43-b040-4555aa064e54">
        <source>getBaseRateEntriesFrom( _startTs : TimeStamp;  _endTs : TimeStamp; _rateEntries : CM_RateEntryByStartTsDict input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2012	cnwndl1	Initial creation	Par 30375

*/

vars

	baseRateEntry : CM_RateEntry;
	iter : Iterator;
	rateEntry : CM_RateEntry;

begin

	baseRateEntry := self.getBaseRateEntry( _startTs );
	
	if baseRateEntry &lt;&gt; null then
		iter := baseRateEntry.rate.rateEntries.createIterator;
		iter.startAtObject( baseRateEntry );
		
		while iter.next( rateEntry ) do
			if not _endTs.date.isValid then
				_rateEntries.add( rateEntry );
				continue;
			endif;
			if rateEntry.startTimestamp &gt; _endTs then
				//starts after our end time.
				break;
			endif;
			_rateEntries.add( rateEntry );
		endwhile;
	
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_startTs" type="TimeStamp"/>
        <Parameter name="_endTs" type="TimeStamp"/>
        <Parameter name="_rateEntries" type="CM_RateEntryByStartTsDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getBaseRateEntry" id="94bfbde2-7979-4bbe-85fb-a0cfbfab596b">
        <source>getBaseRateEntry( _ts : TimeStamp ):CM_RateEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2012	cnwndl1	Initial creation	Par 30375

*/

vars

	debtorNode : CM_DebtorNode;
	rootDebtorGroup : CM_RootDebtorGroup;
	baseRateEntry : CM_RateEntry;

begin

	debtorNode := self.getMyDebtorNode();
	if debtorNode = null or debtorNode.bank = null then
		return null;
	endif;
	
	rootDebtorGroup := debtorNode.bank.getRootDebtorGroup;
	baseRateEntry := rootDebtorGroup.getServiceTimeRate( self.service, _ts);
	
	return baseRateEntry;

epilog

end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="CM_RateEntry"/>
    </JadeMethod>
