//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 27/01/2022   navma1		Bug 52684: SAl - Cargo sub type description in Show Task details of Work Order
//


vars
	commodity : CM_Commodity;
	str		  : String;
begin
	commodity := obj.CM_Commodity;
	
	if commodity.isNotAvailableForEntry then
		return null;
	endif;
	
	//27.01.2022 navma1 #52684
	str := 	commodity.code.trimRight &amp; Tab &amp; commodity.description;

	return str;
epilog

end;</source>
