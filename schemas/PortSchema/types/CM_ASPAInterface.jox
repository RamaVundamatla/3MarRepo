<Class name="CM_ASPAInterface" id="1c647968-e05a-4e13-9eea-9f782e6f2353">
    <superclass name="CM_ExtFinanceIO"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>#######################
Alabama State Port Authority (ASPA)
#######################</text>
    <DbClassMap file="invoice"/>
    <JadeMethod name="createInvoiceXml" id="42fa4416-6ba5-4f0a-90ac-ab1496479b59">
        <source>createInvoiceXml(file : File input; _invoice : CM_Invoice);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
09 Sep 2019     cnwma1	Bug 46496: ASPA - AR Extract Customer Code

*/
vars
	invLine 	 	: CM_InvoiceLine;
	debtor     	 	: CM_Debtor;
	invLineType  	: CM_InvoiceLineDesc;
	postedCreditInv : CM_Invoice;
	debtorGrp		: CM_DebtorGroup;
	userCode,
	debtorGrpName,
	paymentCode,
	addressCode,
	trxType,
	postedInvNo		: String;
	
	
begin
	
	debtor 	 := _invoice.debtor;
	userCode := app.getMyUserCode;
	
	if _invoice.getTotalAmount &gt; 0 then
		trxType := 'INV';
	elseif _invoice.getTotalAmount &lt; 0 then
		trxType := 'CM';
	endif;
	
	if _invoice.myBillingAddress &lt;&gt; null then
		addressCode:=	_invoice.myBillingAddress.code;
	endif;
	
	if _invoice.myPostedCreditInvoice &lt;&gt; null then
		postedCreditInv := _invoice.myPostedCreditInvoice;
		postedInvNo     := postedCreditInv.sequenceNum.String;
	endif;
	
	if  debtor.myParentDebtorNode &lt;&gt; null and 
		debtor.myParentDebtorNode.isKindOf(CM_DebtorGroup) and 
		not debtor.myParentDebtorNode.CM_DebtorGroup.isRootDebtorGroup then
		debtorGrp 		:= debtor.myParentDebtorNode.CM_DebtorGroup;
		debtorGrpName	:= debtorGrp.name;
	endif;
	
	
	file.writeLine('&lt;?xml version="1.0"?&gt;');
	file.writeLine('&lt;Invoice&gt;');
	file.writeLine('&lt;InvoiceHeader&gt;');
	file.writeLine(self.formatAsXML("CustomerCode", 			debtor.decfinName));  //09.09.2019 cnwma1 Bug #46496
	file.writeLine(self.formatAsXML("InvoiceNo", 			    _invoice.sequenceNum.String));
	file.writeLine(self.formatAsXML("InvoiceDate", 			    _invoice.postedDT.Date.format("MM/dd/yyyy")));
	file.writeLine(self.formatAsXML("UserCode", 			    userCode.xmlReplaceReservedChars(true)));
	file.writeLine(self.formatAsXML("PaymentTOTCode", 			_invoice.termsOfTradeCode.String));
	file.writeLine(self.formatAsXML("AddressID", 			    addressCode));
	file.writeLine(self.formatAsXML("InvAmount", 			    _invoice.getTotalAmount.roundedTo(2).String));
	file.writeLine(self.formatAsXML("CostCenter",				_invoice.bank.code));
	file.writeLine(self.formatAsXML("TrxTypeName",				trxType));
	file.writeLine(self.formatAsXML("PaymentTOTName",			_invoice.termsOfTrade));
	file.writeLine(self.formatAsXML("PosteCreditInvNo",			postedInvNo));
	file.writeLine(self.formatAsXML("DebtorCode",				debtor.code));
	file.writeLine(self.formatAsXML("DebtorLongName",			debtor.longName));
	file.writeLine(self.formatAsXML("DebtorParent",				debtorGrpName));
//	file.writeLine(self.formatAsXML("PurchaseOrderNo",      	_invoice.purchaseOrderNumber));
	file.writeLine(self.formatAsXML("PurchaseOrderNo",      	debtor.purchaseOrderCode));	//12 Nov 2019	NDL	TFS 47370
	file.writeLine(self.formatAsXML("ExternalRefrence",     	debtor.externalReference));
	file.writeLine(self.formatAsXML("AddInfo1",					debtor.additionalInformation1));
	file.writeLine(self.formatAsXML("AddInfo2",					debtor.additionalInformation2));
	file.writeLine(self.formatAsXML("DebtorRef",				_invoice.debtorReference));
	file.writeLine(self.formatAsXML("Remarks",					debtor.remarks));
	file.writeLine(self.formatAsXML("InvoiceAttribute1",		""));
	file.writeLine(self.formatAsXML("InvoiceAttribute2",		""));
	file.writeLine(self.formatAsXML("InvoiceAttribute3",		""));
	
	file.writeLine('&lt;/InvoiceHeader&gt;');
	file.writeLine('&lt;InvoiceLines&gt;');
	
	foreach invLine in _invoice.invoiceLines discreteLock do
		
		invLineType := invLine.getInvoiceLineType;
		
		file.writeLine('&lt;Line&gt;');
		
		file.writeLine(self.formatAsXML("LineNo",			invLine.sequenceNum.String));
		file.writeLine(self.formatAsXML("Quantity",			invLine.quantity.String));
		file.writeLine(self.formatAsXML("UOM",				invLineType.unitNarration));
		file.writeLine(self.formatAsXML("Rate",				invLine.getRate.String));
		file.writeLine(self.formatAsXML("LineAmount",		invLine.lineTotal.roundedTo(2).String));
		file.writeLine(self.formatAsXML("LineGLCode",		invLine.getGLCodesString));
		file.writeLine(self.formatAsXML("ServiceName",		invLine.getServiceName));
		file.writeLine(self.formatAsXML("StevedoreID",		invLine.getStevedoreCode));
		file.writeLine(self.formatAsXML("InvoiceAttribute4",""));
		file.writeLine(self.formatAsXML("InvoiceAttribute5",""));
		file.writeLine(self.formatAsXML("InvoiceAttribute6",""));
		
		file.writeLine('&lt;/Line&gt;');
	endforeach;
	
	file.writeLine('&lt;/InvoiceLines&gt;');
	file.writeLine('&lt;/Invoice&gt;');
//	file.writeLine('&lt;/xml&gt;');		// 5/9/19 MAP TFS45926 not correct XML
epilog

end;</source>
        <Parameter name="file" type="File" usage="input"/>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="export" id="2d907ab2-b5c6-4c07-b104-76ce5fbaf784">
        <updating/>
        <source>export(_invoice: CM_Invoice input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 JuL 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
10 Sep 2019 cnwma1	Bug 46496: ASPA - AR Extract Customer Code
*/

vars
	file 	: File;
	path 	: String;
	fFolder : FileFolder;
	message : String;
	drive	: String;
	validDrive: Boolean;
begin
	validDrive := true;

	create fFolder transient;

	path := self.exportPath.normaliseDirectory().substituteDirectory();
	if path[2:1] = Colon then
		drive := path[1:2];
		fFolder.fileName := drive;
		if not fFolder.isAvailable() then
			validDrive := false;
		endif;
	endif;
	
	fFolder.fileName := path;
	fFolder.usePresentationFileSystem := false;  //10.09.2019 cnwma1 Bug#46496

	
	if validDrive and not fFolder.isAvailable() then
		fFolder.make();
	endif;
		
	if not fFolder.isAvailable then
	
		message := app.getErrorString2(Expor_path_does_not_exist_cann,path,_invoice.sequenceNum.String);
		app.msgBox(message,app.getErrorString(Export_error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	create file;
	file.fileName 	  := path &amp; getFileNameFormat(_invoice); 
	file.mode 	  	  := File.Mode_Output;
	file.hidden 	  := false;
	file.usePresentationFileSystem := false;  //10.09.2019 cnwma1 Bug#46496 
	
	self.createInvoiceXml( file,_invoice);
	file.close;
	_invoice.incrementExportCount(false);
	
epilog
	delete fFolder;
	delete file;
end;</source>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
    </JadeMethod>
    <JadeMethod name="exportToFile" id="24bdfef0-e691-403c-a1fa-78e1f28a8c0a">
        <source>exportToFile(invoice: CM_Invoice input; fileNameBase: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle

*/

vars
	file	: File;
begin
	
	create file;
	file.allowReplace := true;
	file.fileName     := fileNameBase; 
	file.mode         := File.Mode_Output;

	self.createInvoiceXml( file, invoice );
	
	file.close();

	invoice.incrementExportCount(false);
	
epilog
	
	delete file;
end;</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="fileNameBase" type="String"/>
    </JadeMethod>
    <JadeMethod name="getFileNameFormat" id="42e099c8-50fa-45f8-9bdf-c503fe7946e1">
        <source>getFileNameFormat(_invoice : CM_Invoice): String;
/*

Purpose:			
		Invoice Export for APSA the export file naming convention is INVnnnnnnnYYYYMMDDHHMM.xml if the transaction is an invoice 
		and CMnnnnnnnYYYYMMDDHHMM.xml if the transaction is a Credit Memo, 
		where nnnnnnn = Invoice Number and the Invoice Number is 7 digits long zero filled. Then the year month day hour minute. 
Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle

*/

vars
	prefix,
	fileName :  String;
	ts       : TimeStamp;
begin
	ts  := app.actualTimeServer;
	if _invoice.getTotalAmount() &lt; 0 then
		prefix := "CM";
	else
		prefix := "INV";
	endif;

	fileName := prefix &amp;
			   _invoice.sequenceNum.padTrailingZeros(7) &amp;
			   ts.Date.year.String &amp;
			   ts.Date.month.padLeadingWith("0",2)   &amp;
			   ts.Date.day().padLeadingWith("0",2)   &amp;
			   ts.Time.hour().padLeadingWith("0",2)  &amp;
			   ts.Time.minute().padLeadingWith("0",2)&amp;
			   '.xml';
	
	return fileName;
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNiceName" id="36703593-dd78-4b92-9db0-1e529c5be411">
        <source>getNiceName(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle

*/

vars

begin
	return "Oracle ASPA";

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
