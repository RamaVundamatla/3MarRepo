    </JadeMethod>
    <JadeMethod name="showThumbnail" id="cbd618b4-e05c-4d91-b0a9-9a091d8e08e8">
        <updating/>
        <source>showThumbnail(_cutOff: CM_ReceivalCutoffTermDef) updating;

/*
Date		Who		Reason
20 May 2009	cnwar2	Initial creation
23/02/2012	cnwcs5	Par 29158 - CCMS CPL 2086 - EDI Booking Cutoff
17/03/2012	cnwcs5	par 29257 - conversion of extension object properties
*/
vars
	form 			: SOP_TableMaintForm;
	table			: CM_EntryTable;
	str				: String;
	row				: JadeTableRow;
	rowIdx			: Integer;
	height			: Integer;
	criteria, 
	proxyCriteria	: CM_ReceivalCutoffCriteria;	
	array			: IntegerArray;	// par 29158 - Feb 2012
begin
	form 	:= self.myForm;
	table	:= form.tblInput1;
	
	table.clearValues;
	
	table.setValueByName(ETRow_Code, _cutOff.code);
	table.setValueByName(ETRow_Description, _cutOff.description);
	
	form.myAssistant.comboBoxCriteriaType(table, ETRow_CriteriaType, _cutOff.getCriteriaTypeDesc);	// par 29158
	
	table.setValueByName(ETRow_SortKey, _cutOff.sortKey);
	
	form.myAssistant.comboBoxDefaultRelativeTo(table, ETRow_DefaultRelativeTo, app.defRelativeToEnumToString(_cutOff.defaultRelativeTo), _cutOff.criteriaType);	// par 29257
	
	table.setValueByName(ETRow_DefaultCutoff, _cutOff.defaultCutoff);
	table.setValueByName(ETRow_DefaultEarliestReceival, _cutOff.defaultEarliestReceival);
	table.setValueByName(ETRow_DefaultCutoffPN, _cutOff.defaultCutoffPN);	//20/03/2025	navkc1 JIRA Story MTN-34231
	table.setValueByName(ETRow_DefaultEarliestReceivePN, _cutOff.defaultEarliestReceivalPN); //20/03/2025	navkc1 JIRA Story MTN-34231
	table.setValueByName(ETRow_IsAvailableForEntry, _cutOff.isAvailableForEntry);
	
	// 12/10/2012 cnwar2 #30508
	if _cutOff.isEDIType() then
		table.hideRowByName(ETRow_DefaultEarliestReceival, false);
		table.hideRowByName(ETRow_DefaultEarliestReceivePN, false); //20/03/2025	navkc1 JIRA Story MTN-34231
	else
		table.showRowByName(ETRow_DefaultEarliestReceival, false);
		table.showRowByName(ETRow_DefaultEarliestReceivePN, false); //20/03/2025	navkc1 JIRA Story MTN-34231
	endif;
	
	if not _cutOff.pxyIsProxy then		// new table row (not just refreshing from proxy), reload criteria
	
		self.allCriteria.purge();
		self.allEDIDataTypes.clear();	// par 29158 - Feb 2012
		
		if _cutOff.isCARGOType then
			foreach criteria in _cutOff.CM_ReceivalCutoffTermDef.allCriteria do
				create proxyCriteria transient;
				proxyCriteria.setProxy(criteria.myYACriteriaType, criteria.myYAData.getDataValue(), criteria.code);
				self.allCriteria.add( proxyCriteria.getTransient() );
			endforeach; 
		elseif _cutOff.isEDIType then
			_cutOff.allEDIDataTypes.copy (self.allEDIDataTypes);	// par 29257 - march 2012
		endif;
	endif;
		
	str := self.getCriteriaText();
	
	if str &lt;&gt; null then
		table.setValueByName(ETRow_CriteriaDblClick, str);
		rowIdx 		:= table.getRowByName(ETRow_CriteriaDblClick);
		table.accessCell(rowIdx, CM_EntryTable.ColumnValue).wordWrap := true;
		height 		:= table.getTextHeightForWidth(str, table.accessColumn(CM_EntryTable.ColumnValue).width - 18).Integer + 10;
		row 		:= table.accessRow(rowIdx);
		row.height 	:= height;
	endif;
	
	table.cnEcResizeContents();
end;</source>
        <Parameter name="_cutOff" type="CM_ReceivalCutoffTermDef"/>
    </JadeMethod>
</Class>
