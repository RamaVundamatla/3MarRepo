    <JadeMethod name="doInputTableChange" id="6122e9c4-7b98-4772-9702-4fa0e492fc8e">
        <updating/>
        <source>doInputTableChange(_tbl : CM_EntryTable input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 06/12/2016	cnwdap1		Initial creation TFS 3039 SNO Empty Container Pool Management
//
vars
	textbox : TextBox;

begin
	if _tbl.row = 1 and _tbl.column = _tbl.ColumnValue then
		textbox := _tbl.accessCell(_tbl.row, _tbl.column).cellControl.TextBox;
		if textbox &lt;&gt; null then
			if textbox.text.length &gt; 4 then
				textbox.text := textbox.text[1:4];
				textbox.selStart := 4;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="e12dce75-b079-4b5b-b80d-a75a1729dfef">
        <updating/>
        <source>doSave(): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/12/2016	cnwdap1		Initial creation TFS 3039 SNO Empty Container Pool Management
// 10/05/2017	cnwdap1		TFS 4370 SNO Allow pool parties across multiple terminals
//
vars
	form : SOP_TableMaintForm;
	code : String;
	description : String;
	terminal : CM_Terminal;
	pxyPoolParty : CM_MTPoolingParty;
	pxyPoolPartner : CM_MTPoolingPartner;
	poolingPartners : CM_MTPoolingPartnerByOperator;
	idx : Integer;
	table : CM_DataTable;
	opTerm : CM_OperatorTerminal;

begin
	form := self.myForm; 
	
	code := form.tblInput1.getValueByName(ETRow_Code).String;
	description := form.tblInput1.getValueByName(ETRow_Description).String;
	
	if form.myProxyObject = null then
		if form.mode = form.Mode_Add then
			create form.myProxyObject as CM_MTPoolingParty transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	pxyPoolParty := form.myProxyObject.CM_MTPoolingParty;
	create poolingPartners transient;
	table := form.tblData4;
	foreach idx in table.fixedRows + 1 to table.rows do
		opTerm := table.accessRow(idx).itemObject.CM_OperatorTerminal;
		if opTerm &lt;&gt; null then
			//pxyPoolPartner := pxyPoolParty.allPoolingPartners[opTerm.myOperator.code];							// TFS 4370
			pxyPoolPartner := pxyPoolParty.allPoolingPartners[opTerm.myOperator.code, opTerm.myTerminal];			// TFS 4370
			if pxyPoolPartner = null then
				create pxyPoolPartner transient;
			endif;
			//pxyPoolPartner.setProxy(opTerm.myOperator, table.accessCell(idx, 2).text.Decimal);					// TFS 4370
			pxyPoolPartner.setProxy(opTerm.myOperator, opTerm.myTerminal, table.accessCell(idx, 2).text.Decimal);	// TFS 4370
			poolingPartners.add(pxyPoolPartner);
		endif;
	endforeach;
	pxyPoolParty.setProxy(	code,
							description,
							form.myTerminal,
							poolingPartners	);
	
	if form.mode = form.Mode_Add then
		app.myTrxCA.trxCreateMTPoolParty(pxyPoolParty, form.myCurrentObject, app.myPassport);
	elseif form.mode = form.Mode_Update then
		app.myTrxUA.trxUpdateMTPoolParty(pxyPoolParty, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; form.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;

epilog
	delete poolingPartners;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
