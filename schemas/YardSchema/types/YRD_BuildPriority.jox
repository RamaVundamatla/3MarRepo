    <JadeMethod name="create" id="5b6d1e98-ae83-4d3c-8ad1-8d6ed6e170b5">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	//self.permissionView  := PmAdmRailbldprtyMaint;
	//self.permissionMaint := PmAdmRailbldprtyMaint;
	self.helpFileName := HelpFile_Yard;
end;</source>
    </JadeMethod>
    <JadeMethod name="doAdd" id="d132e849-ff24-4e32-95ef-1f281cca0ef3">
        <source>doAdd();
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ti	: CM_TrackedItem;
	row : Integer;
begin
	
	/*foreach idx in 2 to self.tblTIFrom.rows reversed do
		if self.tblTIFrom.accessRow(idx).selected then
			self.doMoveContainers(idx);
		endif;
	endforeach;*/
	
	row := self.tblRetrieved.rows;
	while row &gt; self.tblRetrieved.fixedRows do
		if self.tblRetrieved.accessRow(row).selected then
			ti := self.tblRetrieved.accessRow(row).itemObject.CM_TrackedItem;	
			self.doMoveContainers(row, ti, self.tblSelected, self.tblRetrieved);
		endif;
		row := row-1;
	endwhile;
	
	self.tblRetrieved.selectTheCurrentRow(self.tblRetrieved.row);
	
	//self.shtBuildStatus.caption := self.clrOne.caption.trimBlanks &amp; " "  &amp; (self.tblSelected.rows - 1).String &amp; " Selected";

end;</source>
    </JadeMethod>
    <JadeMethod name="doAddAll" id="1f30d995-cace-46fe-8320-807b2cb8b4ea">
        <source>doAddAll();
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	row,
	idx	: Integer; 
	ti	: CM_TrackedItem;
begin
	
	/*foreach idx in 2 to self.tblTIFrom.rows reversed do
		self.doMoveContainers(idx);
	endforeach;*/
	row := self.tblRetrieved.rows;
	while row &gt; self.tblRetrieved.fixedRows do
		ti := self.tblRetrieved.accessRow(row).itemObject.CM_TrackedItem;	
		self.doMoveContainers(row, ti, self.tblSelected, self.tblRetrieved);
		row := row-1;		
	endwhile;
	
	//self.shtBuildStatus.caption := self.clrOne.caption.trimBlanks &amp; " "  &amp; (self.tblSelected.rows - 1).String &amp; " Selected";
end;</source>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="24bb4da4-d78e-48a5-b068-19ab413ae122">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
//--------------------------------------------------
// Created:	08 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	rtValue : Integer;
begin
	if self.tblStatus.hasChanged then
		rtValue := app.msgBox("You have changed data on the Release By IMEX Staus table." &amp; Cr &amp; "Do you want to continue?","Confirm Cancel",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if rtValue = MsgBox_Return_No then
			return;
		endif;
	endif;
	if self.tblType.hasChanged then
		rtValue := app.msgBox("You have changed data on the Release By Type table." &amp; Cr &amp; "Do you want to continue?","Confirm Cancel",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if rtValue = MsgBox_Return_No then
			return;
		endif;
	endif;	
	inheritMethod();
	self.unloadForm();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnClearClick" id="266d09f6-ab80-4b13-a915-8410899cd3cf">
        <updating/>
        <source>doBtnClearClick() updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	
	self.myCurrentJob := null;
	self.myCurrentRequest := null;
	self.modeStatus := Mode_add;
	self.modeType := Mode_add;
	
	self.doRefresh();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnRetrieveClick" id="0a07bf6e-85c9-45ff-b86f-fc06f94ab789">
        <updating/>
        <source>doBtnRetrieveClick() updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lResult : Integer;
	lString : String;
begin

	lString := self.tblStatus.getValueByName(ETRow_StatusString).String; //status - import/export etc.

	if lString = null then
		app.msgBox("You must enter a status - import, export etc.","Retrieve Containers",MsgBox_OK_Only);
		return;
	endif;
	
	if self.fldBuild.topSheet = self.shtBuildStatus then
		if 	self.tblStatus.getValueByName(ETRow_FilterOperator).String = null // operator
		and self.tblStatus.getValueByName(ETRow_FilterVoyage).String = null then // voyage
			lResult := app.msgBox(app.getErrorString1(VB_BIG_SEARCH, "All " &amp; lString &amp; " Containers"),"Retrieve Containers",MsgBox_Yes_No);
			if lResult = MsgBox_Return_Yes then
				self.retrieveTIs();
			else
				return;
			endif;
		else
			self.retrieveTIs();
	
		endif;
	endif;	
	
	self.selectFirstRowOfTable(self.tblRetrieved);
end;</source>
    </JadeMethod>
    <JadeMethod name="doCheckBox" id="7c26fff7-5029-4c74-a70f-7302aacec735">
        <updating/>
        <source>doCheckBox(checkbox: CheckBox input) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if self.fldBuild.topSheet = self.shtBuildStatus then
		self.tblStatus.accessCell(self.tblStatus.row,self.tblStatus.column).text := app.getYesNo(checkbox.value.Boolean);
	else
		self.tblType.accessCell(self.tblType.row,self.tblType.column).text := app.getYesNo(checkbox.value.Boolean);
	endif;

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doComboBox" id="3f1f4834-0c03-4cdc-90a9-07622d0efd4f">
        <updating/>
        <source>doComboBox(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lStr : String;
begin

	lStr := combobox.text;
	lStr.replaceChar(Tab, " ");
	
	if combobox.parent = self.tblSelected then // destination/ supplier column on the container list
		self.tblSelected.accessCell(self.tblSelected.row,self.tblSelected.column).text := lStr;
		self.tblSelected.accessedCell.itemObject := combobox.itemObject[combobox.listIndex];

	elseif self.fldBuild.topSheet = self.shtBuildStatus then // on the Status tab - import/export
		//self.tblStatus.accessCell(self.tblStatus.row,self.tblStatus.column).text := lStr;
		self.tblStatus.setValueByControlName(combobox.name, lStr);		
		self.tblStatus.accessedCell.itemObject := combobox.itemObject[combobox.listIndex];
	else
		//self.tblType.accessCell(self.tblType.row,self.tblType.column).text := lStr;
		self.tblType.setValueByControlName(combobox.name, lStr);				
		self.tblType.accessedCell.itemObject := combobox.itemObject[combobox.listIndex];
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMoveContainers" id="208a4afc-b5cd-4e1e-a516-3a8379ca129e">
        <source>doMoveContainers(idx : Integer;	_ti : CM_TrackedItem; _toTbl, _fromTbl : CM_DataTable input);
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	str		: String;
	idxTo : Integer;
begin
	
	str := _ti.getAttributeStringForDefArray(_toTbl.allTblDataEntRows);	

	idxTo := _toTbl.addItem(str);
	_toTbl.accessRow(idxTo).itemObject:= _ti;
	_fromTbl.removeItem(idx);

end;</source>
        <Parameter name="idx" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_toTbl" type="CM_DataTable" usage="input"/>
        <Parameter name="_fromTbl" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="917d8f85-919c-4c31-babc-33c5eaf38abd">
        <updating/>
        <source>doRefresh() updating, protected;
//-----------------------------------------
// Created: January 2004 By: cnwgd1
//-----------------------------------------
begin
	self.tblType.clearValues();
	self.tblStatus.clearValues();

	self.buildComboCargoType();
	self.buildComboISOType();
	self.buildComboOperator();
	self.buildComboReason();
	self.buildComboStatus();
	self.buildComboConsignor();
	//par12903
	self.buildComboFreightForwarder();
	
	self.buildComboVoyage();
	self.buildLstMTGrade();
	self.buildComboTransferTerminals();
	
//	self.txtRequestDate.visible := false;
//	self.txtRequestDate2.visible := false;
	
	self.populateTables(false);
	/*if self.modeStatus = self.Mode_update then
		self.doSetJobStatus();
	else
		self.doSetDefaultStatus();
	endif;
	
	if self.modeType = self.Mode_update then
		self.doSetJobType();
	else
		self.doSetDefaultType();
	endif;*/
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRemove" id="c2c1fb9f-a592-4e7a-a8fa-4f5069b4aca2">
        <updating/>
        <source>doRemove() updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ti	: CM_TrackedItem;
	row : Integer;
begin
	
	/*foreach idx in 2 to self.tblTITo.rows reversed do
		if self.tblTITo.accessRow(idx).selected then
			self.tblTITo.removeItem(idx);
		endif;
	endforeach;*/
	
	row := self.tblSelected.rows;
	while row &gt; self.tblSelected.fixedRows do
		if self.tblSelected.accessRow(row).selected then	
			ti := self.tblSelected.accessRow(row).itemObject.CM_TrackedItem;	
			self.doMoveContainers(row, ti, self.tblRetrieved, self.tblSelected);
		endif;
		row := row-1;		
	endwhile;
		
	self.tblSelected.selectTheCurrentRow(self.tblSelected.row);		
	//self.shtBuildStatus.caption := self.clrOne.caption.trimBlanks &amp; " "  &amp; (self.tblSelected.rows - 1).String &amp; " Selected";
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="d6f43c74-0766-4905-b554-06aec991dea2">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		November  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	btnHeight,
	btnWidth,
	tmpTop	: Real;
begin
	inheritMethod();
	
	btnHeight := btnRetrieve.height;
	btnWidth := btnRetrieve.width;

	// FOLDER
	self.fldBuild.move(0, self.frmToolbar.height, self.clientWidth, self.clientHeight - self.frmToolbar.height);
	
	// TOP FRAME
	self.frmTop.move(3, 3,self.fldBuild.width - 6, 217);

	// TOP FRAMES TABLE
	tmpTop := self.frmTop.height - VerticalSpacing - btnHeight;
	self.btnRetrieve.move(self.frmTop.width - (btnWidth + 10), tmpTop - 5, btnWidth, btnHeight);
	self.btnAll.move(3, tmpTop - 5, btnWidth, btnHeight);
	self.btnAdd.move(self.btnAll.left + btnWidth + 5, tmpTop - 5, btnWidth, btnHeight);
	
	if self.tblStatus.accessedRow &lt;&gt; null then
		self.tblStatus.defaultRowHeight := self.tblStatus.accessedRow.height;
	endif;

	self.tblStatus.width := self.frmTop.width;
	self.tblStatus.height := self.btnRetrieve.top - VerticalSpacing;
	self.tblStatus.accessColumn(tblStatus.ColumnValue).width := (self.tblStatus.width - self.tblStatus.accessColumn(tblStatus.ColumnHeading).width).Integer;
//	self.txtRequestDate.width := self.tblStatus.accessColumn(tblStatus.ColumnValue).width;
//	self.txtRequestDate.height := self.tblStatus.defaultRowHeight;
//	self.txtRequestDate2.height := self.tblStatus.defaultRowHeight;
//	self.txtRequestDate2.width := self.txtRequestDate.width;	
	
	// SPLITTER
	splTI.move(self.frmTop.left,self.frmTop.height + self.frmTop.top + 3,
				self.frmTop.width - 3, self.shtBuildStatus.height - self.frmTop.height - 11);

	// SPLITTERS TABLES
	self.tblRetrieved.width := self.shtBuildStatus.width; // - 6;
	self.tblSelected.width := self.tblRetrieved.width;
	splTI.cnEcResizeContents();

	//TYPE TABLE
	self.tblType.width := self.shtBuildType.width;
	if self.tblType.accessedRow &lt;&gt; null then
		self.tblType.defaultRowHeight := self.tblType.accessedRow.height;
	endif;
	self.tblType.height := self.shtBuildType.height - self.lblMask.height - VerticalSpacing; //self.tblType.rows * self.tblType.defaultRowHeight;
	self.tblType.accessColumn(tblType.ColumnValue).width := (self.tblType.width - self.tblType.accessColumn(tblType.ColumnHeading).width).Integer;
//	self.txtRequestDate2.width := self.tblType.accessColumn(tblType.ColumnValue).width;
//	self.txtRequestDate2.height := self.tblType.defaultRowHeight;

	self.lblMask.left := self.tblType.left;
	self.lblMask.width := self.tblType.width;
	self.lblMask.top := self.tblType.top + self.tblType.height + VerticalSpacing;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSetDefaultStatus" id="43fe99d0-1274-406f-8dba-6b9e555e24a6">
        <source>doSetDefaultStatus();
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------

vars

begin

	self.btnDelete.enabled := false;
	self.btnAdd.enabled := false;
	self.btnAll.enabled := false;

	self.tblStatus.setValueByName(ETRow_RequestDate, self.systemToLocalTime(app.actualTimeServer).date);// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
//	self.txtRequestDate.lostFocus(self.txtRequestDate);
	
	self.tblRetrieved.rows := self.tblRetrieved.fixedRows;
	self.tblSelected.rows := self.tblSelected.fixedRows;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSetDefaultType" id="5dc15383-6724-4409-96ce-636e0cfa7c33">
        <source>doSetDefaultType();
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------

vars

begin
	self.tblType.setValueByName(ETRow_RequestDate2, self.systemToLocalTime(app.actualTimeServer).date);// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
//	self.txtRequestDate2.lostFocus(self.txtRequestDate2);

	self.tblType.setValueByName(ETRow_DoorsForward, false);
	self.tblType.setValueByName(ETRow_Clean, true);
	self.tblType.setValueByName(ETRow_DoISOGroupCheck, true);
	self.tblType.setValueByName(ETRow_HeavyRated, false);
	// PAR 7671 ADDED all these to clear out, leaving  Operator, Op Group, Voyage, Consignee Voyage populated
	self.tblType.setValueByName(ETRow_ReleaseNo, null);
	self.tblType.setValueByName(ETRow_QuantityTxt, null);
	self.tblType.setValueByName(ETRow_FreightPayerCode, null);
	self.tblType.setValueByName(ETRow_ConsigneeCode, null);
	self.tblType.setValueByName(ETRow_IsoType, null);
	self.tblType.setValueByName(ETRow_AllMTGrades, null);
	self.tblType.setValueByName(ETRow_IdMask, null);
	
	
	self.lstMTGrade.clearSelected();
end;</source>
    </JadeMethod>
    <JadeMethod name="doSetJobStatus" id="c47417e1-6b1a-4563-a62f-9148bb7724f1">
        <updating/>
        <source>doSetJobStatus()updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	imexDesc,
	str,
	lStr : String;
	lTI : CM_TrackedItem;
	lReq : CM_Request;
	theRow,
	idx : Integer;
	lCargo : CM_CargoType;
//	lAvGrade : CM_MTGrade;
	lOp	: CM_Operator;
	lVoy	: CM_Voyage;
	lCon : CM_ConsigneeConsignor;
	lISOType	: CM_ISOType;
	tiRequest	: CM_TIRequest;
	imexStatus : CM_IMEXStatus;
begin
	self.btnDelete.enabled := false;
	self.btnAdd.enabled := false;
	self.btnAll.enabled := false;

	if self.myCurrentJob = null then
		return;
	endif;

	foreach lReq in self.myCurrentJob.allRequests do
		if lReq.isKindOf(CM_TIRequest) then
			tiRequest := lReq.CM_TIRequest;
		endif;
	endforeach;
	
	self.fldBuild.topSheet := self.shtBuildStatus;	
	lTI := tiRequest.trackedItem;

	if lTI = null then
		return;
	endif;

	self.myCurrentRequest := tiRequest;

	str := lTI.getAttributeStringForDefArray(self.tblSelected.allTblDataEntRows);
	idx := self.tblSelected.addItem(str);
	self.tblSelected.accessRow(idx).itemObject := lTI;
	self.tblSelected.accessCell(idx,2).itemObject := app.myRoot.allConsigneeConsignors[lTI.consignor.trimBlanks];
	
	// STATUS - Import/Export etc
	imexStatus := lTI.getImExStatusObject();
	imexDesc := lTI.getImExStatusStringDesc(true);
	self.tblStatus.setValueByName(ETRow_StatusString,imexDesc);
	self.cmbImexStatus.listObject := imexStatus;

	// CARGO TYPE
	lCargo := lTI.myCargoType;
	lStr := lCargo.description;
	self.tblStatus.setValueByName(ETRow_FilterTiType, lStr);
	self.cmbTiType.lostFocus(self.cmbTiType);
	
	self.myAssistant.comboBoxOperator(self.cmbFiltOperator, lTI.myOperator, null);
	self.cmbFiltOperator.lostFocus(self.cmbFiltOperator);	
	
	self.myAssistant.comboBoxVoyageCurrent(	self.cmbFiltVoyage,
											lTI.myVoyage,
											true,
											false,
											true,
											true,
											true,
											true,
											true,
											false,
											false);
	
	self.cmbFiltVoyage.lostFocus(self.cmbFiltVoyage);
	
	self.myAssistant.comboBoxConsignor(self.cmbFiltConsignee, lTI.myConsignee,CONSIGNEE);		
	self.cmbFiltConsignee.lostFocus(self.cmbFiltConsignee);
		
	self.tblStatus.setValueByName(ETRow_FreightPayerCode,tiRequest.freightPayerCode);
	self.tblStatus.setValueByName(ETRow_ReleaseNo, tiRequest.deliveryNumber);	
	self.tblStatus.setValueByName(ETRow_DeliveryReason, tiRequest.reasonCodeDescr);
	self.tblStatus.setValueByName(ETRow_Remarks, tiRequest.remarks);
	

	// DVB changed to use new flags 05/04/05
	if tiRequest.myTransferToTerminal &lt;&gt; null and app.isInterTerminalTransferEnabled() then
		self.tblStatus.setValueByName(ETRow_MyTransferToTerminal ,tiRequest.myTransferToTerminal.code);
		self.cmbDestTerminal.listObject := tiRequest.myTransferToTerminal;
	endif;

	self.tblStatus.setValueByName(ETRow_RequestDate, self.myCurrentJob.CM_RailJob.date.date);
//	self.txtRequestDate.lostFocus(self.txtRequestDate);
	
	if CM_Container.hasInstance(lTI) then
		if tiRequest.doorsDirection = TI_DOORSDIRN_FWD then
			self.tblStatus.setValueByName(ETRow_DoorsForward,true);
		else
			self.tblStatus.setValueByName(ETRow_DoorsForward,false);
		endif;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSetJobType" id="19057ab9-3fc5-4e86-9de3-fb5b67294393">
        <updating/>
        <source>doSetJobType()updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	delRequest : CM_DeliveryRequest;
	lStr : String;
	lTI : CM_TrackedItem;
	lReq : CM_Request;
	idx : Integer;
	lCargo : CM_CargoType;
//	lAvGrade : CM_MTGrade;
	lOp	: CM_Operator;
	lVoy	: CM_Voyage;
	lCon : CM_ConsigneeConsignor;
	lISOType	: CM_ISOType;
	lReason : String;
begin

	if self.myCurrentJob = null then
		return;
	endif;
	

	foreach lReq in self.myCurrentJob.allRequests do	
		if lReq.isKindOf(CM_DeliveryRequest) then
			delRequest := lReq.CM_DeliveryRequest;
		endif;
	endforeach;
	
	self.myCurrentRequest := delRequest;

	self.fldBuild.topSheet := self.shtBuildType;	
	self.tblType.setValueByName(ETRow_RequestDate2, self.myCurrentJob.CM_RailJob.date.date);
//	self.txtRequestDate2.lostFocus(self.txtRequestDate2);
	
	lOp := app.myRoot.allOperators[delRequest.operatorCode];	
	self.myAssistant.comboBoxOperator(self.cmbOperator, lOp, null);
	self.cmbOperator.lostFocus(self.cmbOperator);	

	self.tblType.setValueByName(ETRow_ReleaseNo,self.myCurrentJob.CM_RailJob.requestNum);

	lVoy := self.myTerminal.lookupVoyage(delRequest.voyageCode, null, false);	
	
	self.myAssistant.comboBoxVoyageCurrent(	self.cmbFiltVoyage,
											lVoy,
											true,
											false,
											true,
											true,
											true,
											true,
											true,
											false,
											false);
	
	self.cmbVoyage.lostFocus(self.cmbVoyage);
	
	self.tblType.setValueByName(ETRow_ConsignorVoyageCode,delRequest.consignorVoyageCode);
	self.tblType.setValueByName(ETRow_DeliveryReason,delRequest.reasonCodeDescr);
	self.tblType.setValueByName(ETRow_DoorsForward,delRequest.doorsForward);
	self.tblType.setValueByName(ETRow_Remarks, delRequest.remarks);	
	
	lISOType := app.myRoot.allISOTypes[delRequest.isoType];
	self.myAssistant.comboBoxISOType(self.cmbISOType, lISOType);		
	self.cmbISOType.lostFocus(self.cmbISOType);			
	
	self.tblType.setValueByName(ETRow_QuantityTxt,delRequest.totalRequested);
	self.tblType.setValueByName(ETRow_Clean,delRequest.clean);
	self.tblType.setValueByName(ETRow_DoISOGroupCheck,delRequest.doISOGroupCheck);

	// CONSIGNOR/SUPPLIER/DESTINATION
	lCon := app.myRoot.allConsigneeConsignors[delRequest.consigneeCode];
	self.myAssistant.comboBoxConsignor(self.cmbConsignee, lCon,CONSIGNEE);			
	self.cmbConsignee.lostFocus(self.cmbConsignee);
	
	lCon := app.myRoot.allConsigneeConsignors[delRequest.freightForwarderCode];
	self.myAssistant.comboBoxConsignor(self.cmbFreightFwdr, lCon, FREIGHT_FORWARDER);			
	self.cmbFreightFwdr.lostFocus(self.cmbFreightFwdr);
	
//	process.debug;
// DVB changed to use new flags 05/04/05
	if delRequest.myTransferToTerminal &lt;&gt; null and app.isInterTerminalTransferEnabled() then
		self.tblType.setValueByName(ETRow_MyTransferToTerminal2 ,delRequest.myTransferToTerminal.code);
		self.cmbDestTerminal2.listObject := delRequest.myTransferToTerminal;
	endif;
	
	self.myAssistant.comboBoxOperatorGroup(cmbOperatorGroup, delRequest.myOperatorGroup, true);										
	self.cmbOperatorGroup.lostFocus(self.cmbOperatorGroup);	
	
	self.tblType.setValueByName(ETRow_FreightPayerCode,delRequest.freightPayerCode);
	self.tblType.setValueByName(ETRow_HeavyDuty,delRequest.heavyRated);


	if delRequest.allAvailabilityGrades &lt;&gt; null
	   		and delRequest.allAvailabilityGrades.size &gt; 0 then
		self.myAssistant.setListTableMTGrade(lstMTGrade, delRequest.allAvailabilityGrades);
		self.tblType.setValueByName(ETRow_AvailabilityGrade, self.lstMTGrade.getSelectedString('code'));						
	endif;
	self.tblType.setValueByName(ETRow_IdMask,delRequest.getIdsAsString);

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowCargoEnquiry" id="04b7418a-0c06-45e7-b4c3-7b8fe8cd8757">
        <source>doShowCargoEnquiry(ti : CM_TrackedItem) protected;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	if ti &lt;&gt; null then
		self.myAssistant.showCargoEnquiryForm(ti, self.myMasterMenuAction, true, false);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doTableContextMenu" id="4df6ef5a-a2a1-4961-a42d-295773dbaad3">
        <updating/>
        <source>doTableContextMenu(table: Table input; conwin: Window input; mouse: Boolean;
		x: Integer; y: Integer; selected : Boolean) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		12 August 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	xLeft 	: Real;
	yTop	: Real;
	obj	 	: CM_Object;
	visibleBeforeSep : Boolean;
	visibleAfterSep : Boolean;
	
begin
	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form

	obj := 	table.accessRow(table.row).itemObject.CM_Object;
	
	if obj = null or not obj.isKindOf(CM_TrackedItem) then
		return true;
	endif;
	
	self.mnuCargoEnquiry.userObject := obj;
	self.mnuCargoEnquiry.visible := true;
	
	if selected then
		self.mnuRemove.visible := true;
		self.mnuAdd.visible := false;
		self.mnuAddAll.visible := false;
	else
		self.mnuRemove.visible := false;
		self.mnuAdd.visible := true;
		self.mnuAddAll.visible := true;
	endif;
	
	self.popupMenu(mnuTableContext, xLeft.Integer, yTop.Integer);

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <Parameter name="selected" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getReasonCode" id="c5c4b598-ba69-450f-8abf-5a139a32bb03">
        <source>getReasonCode(pTI : CM_TrackedItem) :Integer;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
DEL_IST = 4;
DEL_MAX = 6 ;
DEL_NIB = 5;
DEL_NULL = 0;
DEL_PEX = 6;
DEL_RPK = 1;
DEL_SNT = 3;
DEL_TSC = 2;

vars
	lDlyReasonCode: Integer;

begin

	lDlyReasonCode := DEL_NULL;

	//#########
	// BY TYPE 
	/*if self.fldBuild.topSheet = self.shtBuildType then
			if cmbReasonT.text = DELSTR_SNT then
        			lDlyReasonCode := DEL_SNT;
        		elseif cmbReasonT.text = DELSTR_IST then
				lDlyReasonCode := DEL_IST;
        		elseif cmbReasonT.text = DELSTR_NIB then
				lDlyReasonCode := DEL_NIB;
        		else
				lDlyReasonCode := DEL_NULL;
			endif;
	//################
	// BY STATUS IMPORT/EXPORT etc
	elseif self.fldBuild.topSheet = self.shtBuildStatus then
		if pTI = null then
			lDlyReasonCode := DEL_NULL;
		elseif pTI.status.bitAnd(EX_MASK) = EX_MASK and
		   self.tblStatus.getValueByName(ETRow_StatusString).String = "Export" then
			if self.cmbReasonS.text = DELSTR_RPK then
        			lDlyReasonCode := DEL_RPK;
        		elseif self.cmbReasonS.text = DELSTR_TSC then
				lDlyReasonCode := DEL_TSC;
        		elseif self.cmbReasonS.text = DELSTR_PEX then
				lDlyReasonCode := DEL_PEX;
        		else
				lDlyReasonCode := DEL_NULL;
			endif;
		elseif pTI.status.bitAnd(STO_MASK) = STO_MASK and self.cmbStatus.text.trimBlanks = "Empties" then
			if self.cmbReasonS.text = DELSTR_SNT then
				lDlyReasonCode := DEL_SNT;
			elseif self.cmbReasonS.text = DELSTR_IST then
				lDlyReasonCode := DEL_IST;
			elseif self.cmbReasonS.text = DELSTR_NIB then
				lDlyReasonCode := DEL_NIB;
        		else
				lDlyReasonCode := DEL_NULL;
			endif;
		endif;
	endif;*/

	lDlyReasonCode := app.deliveryReasonStringToEnum(self.tblStatus.getValueByName(ETRow_DeliveryReason).String);
	return lDlyReasonCode;
	
end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="3640897d-3c47-462f-89ad-db78b0e02c16">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//----------------------------------------------------------------
//	Created:	29 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	theXML : String;
	theGridArea : CMUI_GridArea;
	hideMacro : Boolean;
begin

	theXML := inheritMethod();

	theXML := theXML &amp; global.formatAsXML(XMLTag_TopSheet, self.fldBuild.topSheet.name);

	return theXML;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="ddaaae83-ca88-49db-85a5-286c98cd0507">
        <source>getXMLSettingsForSetup();
//----------------------------------------------------------------
//	Created:	29 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	userWindow		: CM_UserWindow;
	value, theXML	: String;
begin

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;

	// #### Top Sheet
 	value := theXML.cnEcGetTagValueOfName(XMLTag_TopSheet);

	//Set it
	if self.shtBuildStatus.name = value then
		self.fldBuild.topSheet := self.shtBuildStatus;	
	else
		self.fldBuild.topSheet := self.shtBuildType;	
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="751eff50-a1b4-48cd-8c9a-ef4c2d530947">
        <updating/>
        <source>initForm(_job : CM_Job) updating;
//--------------------------------------------------------------
//Created: 27 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	lReq : CM_Request;
begin

	self.myCurrentJob := _job;
	
	if _job = null then
		self.modeStatus := self.Mode_add;
		self.modeType := self.Mode_add;
		return;	
	endif;
	
	foreach lReq in _job.allRequests do
		if lReq.isKindOf(CM_TIRequest) then
			self.modeStatus := self.Mode_update;
			self.modeType := self.Mode_add;
			break;
		else
			self.modeStatus := self.Mode_add;
			self.modeType := self.Mode_update;
			break;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="initTables" id="bc49abd8-191b-4c9e-adfa-4323a6a3ae77">
        <source>initTables();
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	entTableControl	: EntTableDef;
	theTable		: CM_EntryTable;
begin

	entTableControl := app.myController.getEntTableDef(ETDef_BuildPriorityCargo);	

	self.tblSelected.setTblDataEntRowsFromDef(entTableControl);
	self.tblSelected.selectionType := Table.SelectMode_FixedRow;
	self.tblSelected.multiSelect := 1;	


	self.tblRetrieved.setTblDataEntRowsFromDef(entTableControl);
	self.tblRetrieved.selectionType := Table.SelectMode_FixedRow;
	self.tblRetrieved.multiSelect := 1;					

	entTableControl := app.myController.getEntTableDef(ETDef_BuildPriorityStatus);
	theTable := self.tblStatus;
	theTable.setTerminologyRelevant(null,self.myTerminal);
	theTable.setEntTableDef(entTableControl, null, null);
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
	
	self.tblType.setTerminologyRelevant(null,self.myTerminal);
	entTableControl := app.myController.getEntTableDef(ETDef_BuildPriorityType);
	self.tblType.setEntTableDef(entTableControl, null, null);
	self.tblType.accessCell(self.tblType.getRowByName(ETRow_IdMask), tblType.ColumnHeading).text := "ID's";

end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="fd216522-1e4f-4b7a-875d-53f3e74ef1df">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------------------
//Created: 27 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	theActiveControl : Control;
	theTable : CM_EntryTable;
begin
	if keyCode = J_key_Tab then
		if self.fldBuild.topSheet = self.shtBuildStatus then
			self.tblStatus.handleFormTab(keyCode, shift, self.btnRetrieve, self.btnRetrieve);
		else
			return;
		endif;
		
		theActiveControl := app.activeControl;
		if theActiveControl.isKindOf(CM_EntryTable) then
			theTable := theActiveControl.CM_EntryTable;
		elseif theActiveControl.parent.isKindOf(CM_EntryTable) then
			theTable := theActiveControl.parent.CM_EntryTable;
		endif;

		if theTable &lt;&gt; null then		
			theTable.handleTableTab(shift);
		endif;
	else
		inheritMethod(keyCode, shift);		
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="0805bea8-1fdd-4a41-8ffe-92e1be5bdb02">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      03 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	self.doRefresh();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstMTGrade_displayRow" id="20c47457-9f4f-4327-920b-113adecd92d7">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstMTGrade_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
//--------------------------------------------------------------
//Created: 28 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars

	selected	: Boolean;
	
begin

	selected := table.CMUI_ListTable.allSelectedObjects.includes(obj);
	return self.myAssistant.displayEntryMTGradeList(obj.CM_MTGrade, selected);

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="lstMTGrade_lostFocus" id="643dbdfc-0364-434b-a264-365f3e0399cf">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstMTGrade_lostFocus(table: Table input) updating;
//--------------------------------------------------------------
//Created: 31 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
//	self.tblType.accessCell(tblType.getRowByName(ETRow_AllMTGrades),tblType.ColumnValue).text := self.lstMTGrade.getSelectedString('code');
	self.tblType.accessCell(tblType.getRowByName(ETRow_AllMTGrades),tblType.ColumnValue).text := self.lstMTGrade.getSelectedFromDisplay();
	self.tblType.optimiseValueRowHeights();
	self.tblType.scrollBars := Table.ScrollBars_Vertical;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
