        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createRecipeComponentPxys" id="86208dc4-1945-4820-b359-7302ba0b394d">
        <source>createRecipeComponentPxys(	_transientComponents : CM_RecipeComponentByCodeDict input;
							_componentCTorProd1 : CM_Object;
							_compAmount1 : Decimal;
							_componentCTorProd2 : CM_Object;
							_compAmount2 : Decimal;
							_componentCTorProd3 : CM_Object;
							_compAmount3 : Decimal;
							_recipeDesc : String;
							_recipeCargoType : CM_CargoType input;
							_recipeProduct : CM_Product
							):CM_Recipe;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	transientComp : CM_RecipeComponent;
	recipeCode : String;
	pxyRecipe : CM_Recipe;

begin

	if _recipeProduct &lt;&gt; null then
		recipeCode := _recipeProduct.code;
	else
		recipeCode := _recipeCargoType.abbreviation;
	endif;

	_transientComponents.clear();
	transientComp := self.addRecipeComponent( 1, _componentCTorProd1, _compAmount1 );
	self.assertTrueMsg( transientComp &lt;&gt; null, "Failed to create transient Recipe Component");
	_transientComponents.add(transientComp);
	
	transientComp := self.addRecipeComponent( 2, _componentCTorProd2, _compAmount2 );
	self.assertTrueMsg( transientComp &lt;&gt; null, "Failed to create transient Recipe Component");
	_transientComponents.add(transientComp);

	transientComp := self.addRecipeComponent( 3, _componentCTorProd3, _compAmount3 );
	self.assertTrueMsg( transientComp &lt;&gt; null, "Failed to create transient Recipe Component");
	_transientComponents.add(transientComp);
	
	self.opts.purge();
	self.opts.addAssoc("description", _recipeDesc);
	self.opts.addAssoc("instructions", "Add Sand, then Cement then the Aggregate to the mixer, mix for 3 minutes. Store in a dry hopper.");
	self.opts.addAssoc("canFactor", true );
	self.opts.addAssoc("defaultWeight", 1000.Decimal);
	self.opts.addAssoc("defaultVolume", 1.Decimal);
	self.opts.addAssoc("defaultQuantity", 0.Integer);
	pxyRecipe := self.addCargoTypeRecipeTransient( 	_recipeCargoType,	//_cargoType : CM_CargoType input;
													_recipeProduct,	//_product : CM_Product;
													recipeCode,	//_recipeCode : String;
													_transientComponents	//_transientComponents : CM_RecipeComponentByCodeDict
													); 
													
	return pxyRecipe;

epilog

end;</source>
        <Parameter name="_transientComponents" type="CM_RecipeComponentByCodeDict" usage="input"/>
        <Parameter name="_componentCTorProd1" type="CM_Object"/>
        <Parameter name="_compAmount1" type="Decimal"/>
        <Parameter name="_componentCTorProd2" type="CM_Object"/>
        <Parameter name="_compAmount2" type="Decimal"/>
        <Parameter name="_componentCTorProd3" type="CM_Object"/>
        <Parameter name="_compAmount3" type="Decimal"/>
        <Parameter name="_recipeDesc" type="String"/>
        <Parameter name="_recipeCargoType" type="CM_CargoType" usage="input"/>
        <Parameter name="_recipeProduct" type="CM_Product"/>
        <ReturnType type="CM_Recipe"/>
    </JadeMethod>
    <JadeMethod name="tBasicRecipeMaint" id="0a5fe2f0-ad1e-440f-b445-2f3288747efe">
        <source>tBasicRecipeMaint();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2021	navndl1	Initial creation	TFS 51243

*/

constants

	CargoTypeAgg : String = "AGGREGATES";	//Bulk Track by Weight
	ProductAgg10mm : String = "10MM";
	CargoTypeSand : String = "SAND";	//Bulk Track by Volume
	ProductSandYellow : String = "YELLOW";	//
	CargoTypeCement : String = "CEMENT";   //Break Bulk Track by quantity
	ProductCement20 : String = "CEMENT20";
	CargoTypeBuildMix : String = "BUILDMIX";	//Bulk Track by Volume
	ProductBuildMixWeak : String = "12 Kpa";	
	ProductBuildMixGen : String = "18 Kpa";
	ProductBuildMixStrong : String = "25 Kpa";
	
vars

	ctAggregate : CM_CargoType;
	ctSand : CM_CargoType;
	ctCement : CM_CargoType;
	ctBuildMix : CM_CargoType;
	
	term : CM_Terminal;
	productWeak : CM_Product;
	productMedium : CM_Product;
	productStrong : CM_Product;
	productYellowSand : CM_Product;
	productCement20Kg : CM_Product;
	productAggregate10mm : CM_Product;
	pxyRecipe : CM_Recipe;
	transientComponents : CM_RecipeComponentByCodeDict;
	transientComp : CM_RecipeComponent;
	
	pxyCargoType : CM_CargoType;
	pxyDraw : CM_DrawingAttribute;
	load : Boolean;
	pxyComp : CM_RecipeComponent;
	realRecipe : CM_Recipe;
	realRecipeComponent : CM_RecipeComponent;

begin

	term := self.getTerminal;
	create transientComponents transient;
	
	ctAggregate := term.getCargoTypeFromAbbrevOrDescr( CargoTypeAgg );
	self.assertTrueMsg( ctAggregate &lt;&gt; null, CargoTypeAgg &amp; " not found during setup" );
	ctSand := term.getCargoTypeFromAbbrevOrDescr( CargoTypeSand );
	self.assertTrueMsg( ctSand &lt;&gt; null, CargoTypeSand &amp; " not found during setup" );
	ctCement := term.getCargoTypeFromAbbrevOrDescr( CargoTypeCement );
	self.assertTrueMsg( ctCement &lt;&gt; null, CargoTypeCement &amp; " not found during setup" );
	
	ctBuildMix := term.getCargoTypeFromAbbrevOrDescr( CargoTypeBuildMix );
	if ctBuildMix = null then
		self.opts.purge();
		self.opts.addAssoc("Description", "Builders Mix");
		self.opts.addAssoc("TrackAs", ProductType_Bulk);
		self.opts.addAssoc("CanBeWeighed", true );
		ctBuildMix := self.addCargoType( CargoTypeBuildMix, true );
		self.assertTrueMsg( ctBuildMix &lt;&gt; null, CargoTypeBuildMix &amp; " not found and failed to create - " &amp; app.myPassport.getErrorsAndWarningsAsString );
		
		self.opts.purge();
		self.opts.addAssoc("Description", ProductBuildMixWeak &amp; " foot paths and garden edging");
		productWeak := self.addProduct( ProductBuildMixWeak, null, ctBuildMix);
		self.assertTrueMsg( productWeak &lt;&gt; null, CargoTypeBuildMix &amp; "/" &amp; ProductBuildMixWeak &amp; " not found and failed to create - " &amp; app.myPassport.getErrorsAndWarningsAsString );
		
		self.opts.purge();
		self.opts.addAssoc("Description", ProductBuildMixGen &amp; " general purpose and light vehicle driveways");
		productMedium := self.addProduct( ProductBuildMixGen, null, ctBuildMix);
		self.assertTrueMsg( productMedium &lt;&gt; null, CargoTypeBuildMix &amp; "/" &amp; ProductBuildMixGen &amp; " not found and failed to create - " &amp; app.myPassport.getErrorsAndWarningsAsString );
		
		self.opts.purge();
		self.opts.addAssoc("Description", ProductBuildMixStrong &amp; " road kerbing and heavy vehicle driveways");
		productStrong := self.addProduct( ProductBuildMixStrong, null, ctBuildMix);
		self.assertTrueMsg( productStrong &lt;&gt; null, CargoTypeBuildMix &amp; "/" &amp; ProductBuildMixStrong &amp; " not found and failed to create - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	else
		productWeak := ctBuildMix.getProductFromCode(ProductBuildMixWeak);
		self.assertTrueMsg( productWeak &lt;&gt; null, ctBuildMix.abbreviation &amp; "/" &amp; ProductBuildMixWeak &amp; " not found during setup" );
		productMedium := ctBuildMix.getProductFromCode(ProductBuildMixGen);
		self.assertTrueMsg( productMedium &lt;&gt; null, ctBuildMix.abbreviation &amp; "/" &amp; ProductBuildMixGen &amp; " not found during setup" );
		productStrong := ctBuildMix.getProductFromCode(ProductBuildMixStrong);
		self.assertTrueMsg( productStrong &lt;&gt; null, ctBuildMix.abbreviation &amp; "/" &amp; ProductBuildMixStrong &amp; " not found during setup" );
		
	endif;
	
	productYellowSand := ctSand.getProductFromCode(ProductSandYellow);
	self.assertTrueMsg( productYellowSand &lt;&gt; null, ctSand.abbreviation &amp; "/" &amp; ProductSandYellow &amp; " not found during setup" );
	productCement20Kg := ctCement.getProductFromCode(ProductCement20);
	self.assertTrueMsg( productCement20Kg &lt;&gt; null, ctCement.abbreviation &amp; "/" &amp; ProductCement20 &amp; " not found during setup" );
	productAggregate10mm := ctAggregate.getProductFromCode(ProductAgg10mm);
	self.assertTrueMsg( productAggregate10mm &lt;&gt; null, ctAggregate.abbreviation &amp; "/" &amp; ProductAgg10mm &amp; " not found during setup" );
	
	
	//Create a transient recipe and add it to the Builders Mix CargoType
	
	app.cmsBeginLoad( load );
	pxyCargoType := ctBuildMix.pxyCreateUpdateProxy();
	create pxyDraw transient;
	pxyDraw.drawingAttrType := DrawingAttrType_CargoType;
	pxyCargoType.setPropertyValue("myRoot",app.myRoot);
	app.cmsEndLoad( load );
	
	pxyRecipe := pxyCargoType.allRecipes.getAtKey( ProductBuildMixWeak );
	if pxyRecipe = null then
		pxyRecipe := self.createRecipeComponentPxys( transientComponents, productYellowSand, .75, productCement20Kg, 3, productAggregate10mm, 400, productWeak.description, ctBuildMix, productWeak );
		pxyRecipe.setMyCargoType( pxyCargoType );
	endif;
	
	pxyRecipe := pxyCargoType.allRecipes.getAtKey( ProductBuildMixGen );
	if pxyRecipe = null then
		pxyRecipe := self.createRecipeComponentPxys( transientComponents, productYellowSand, .70, productCement20Kg, 4, productAggregate10mm, 400, productMedium.description, ctBuildMix, productMedium );
		pxyRecipe.setMyCargoType( pxyCargoType );
	endif;
	
	pxyRecipe := pxyCargoType.allRecipes.getAtKey( ProductBuildMixStrong );
	if pxyRecipe = null then
		pxyRecipe := self.createRecipeComponentPxys( transientComponents, productYellowSand, .65, productCement20Kg, 6, productAggregate10mm, 375, productStrong.description, ctBuildMix, productStrong );
		pxyRecipe.setMyCargoType( pxyCargoType );
	endif;
	
	app.myTrxUA.trxUpdateCargoType(pxyCargoType, pxyDraw, null, app.myPassport);	
	self.assertTrueMsg( not app.myPassport.hasErrors, "Error updating Cargo Type to add x3 Recipes - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( ctBuildMix.allRecipes.size = 3, "Should be 3 Recipes - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	delete pxyDraw;
	delete pxyCargoType;
	
	///Try an update that removes a recipe
	app.cmsBeginLoad( load );
	pxyCargoType := ctBuildMix.pxyCreateUpdateProxy();
	create pxyDraw transient;
	pxyDraw.drawingAttrType := DrawingAttrType_CargoType;
	pxyCargoType.setPropertyValue("myRoot",app.myRoot);
	app.cmsEndLoad( load );
	
	pxyRecipe := pxyCargoType.allRecipes.getAtKey( ProductBuildMixWeak );
	delete pxyRecipe;
	app.myTrxUA.trxUpdateCargoType(pxyCargoType, pxyDraw, null, app.myPassport);	
	self.assertTrueMsg( not app.myPassport.hasErrors, "Error updating Cargo Type to delete x1 Recipe - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( ctBuildMix.allRecipes.size = 2, "Should be 2 Recipes - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	delete pxyDraw;
	delete pxyCargoType;
	
	///Try an update that removes a componenet from a recipe
	app.cmsBeginLoad( load );
	pxyCargoType := ctBuildMix.pxyCreateUpdateProxy();
	create pxyDraw transient;
	pxyDraw.drawingAttrType := DrawingAttrType_CargoType;
	pxyCargoType.setPropertyValue("myRoot",app.myRoot);
	app.cmsEndLoad( load );
	
	pxyRecipe := pxyCargoType.allRecipes.getAtKey( ProductBuildMixStrong );
	pxyComp := pxyRecipe.allComponentsByOrder.last;
	delete pxyComp;
	
	app.myTrxUA.trxUpdateCargoType(pxyCargoType, pxyDraw, null, app.myPassport);	
	self.assertTrueMsg( not app.myPassport.hasErrors, "Error updating Cargo Type to delete x1 Component from a recipe - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	realRecipe := ctBuildMix.allRecipes.getAtKey( ProductBuildMixStrong );
	self.assertTrueMsg( realRecipe &lt;&gt; null, "Recipe not found after component remove - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	self.assertTrueMsg( realRecipe.allComponentsByCode.size = 2, "Should be 2 Recipe Components - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	delete pxyDraw;
	delete pxyCargoType;
	
	///Remove updated recipe
	app.cmsBeginLoad( load );
	pxyCargoType := ctBuildMix.pxyCreateUpdateProxy();
	create pxyDraw transient;
	pxyDraw.drawingAttrType := DrawingAttrType_CargoType;
	pxyCargoType.setPropertyValue("myRoot",app.myRoot);
	app.cmsEndLoad( load );
	
	pxyRecipe := pxyCargoType.allRecipes.getAtKey( ProductBuildMixStrong );
	delete pxyRecipe;
	
	app.myTrxUA.trxUpdateCargoType(pxyCargoType, pxyDraw, null, app.myPassport);	
	self.assertTrueMsg( not app.myPassport.hasErrors, "Error updating Cargo Type to delete x1 Recipe - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	delete pxyDraw;
	delete pxyCargoType;
													
	
epilog

	app.cmsEndLoad( load );
	delete pxyDraw;
	delete pxyCargoType;
	delete transientComponents;

end;</source>
    </JadeMethod>
    <JadeMethod name="tBlendUsingRecipe" id="b294dc4e-f21a-47c7-8d04-debb5d81a4e0">
        <source>tBlendUsingRecipe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2021	navndl1	Initial creation	TFS 51243

*/

constants

	CargoTypeAgg : String = "AGGREGATES";	//Bulk Track by Weight
	ProductAgg10mm : String = "10MM";
	CargoTypeSand : String = "SAND";	//Bulk Track by Volume
	ProductSandYellow : String = "YELLOW";	//
	CargoTypeCement : String = "CEMENT";   //Break Bulk Track by quantity
	ProductCement20 : String = "CEMENT20";
	CargoTypeBuildMix : String = "BUILDMIX";	//Bulk Track by Volume	
	ProductBuildMixGen : String = "18 Kpa";
	BlendArea1 : String = "BLND1";
	BlendArea2 : String = "BLND2";
	
vars

	term : CM_Terminal;

	ctAggregate : CM_CargoType;
	ctSand : CM_CargoType;
	ctCement : CM_CargoType;
	ctBuildMix : CM_CargoType;
	
	productMedium : CM_Product;
	productYellowSand : CM_Product;
	productCement20Kg : CM_Product;
	productAggregate10mm : CM_Product;

	bs1 : CM_BlockStack;
	bs2 : CM_BlockStack;
	oper : CM_Operator;
	realRecipe : CM_Recipe;
	realRecipeComponent : CM_RecipeComponent;
	
	agent : CMIF_BlendingAgent;
	cmifBlendComp : CMIF_BlendingComponent;
	aggTi : CM_Cargo;
	sandTi : CM_Cargo;
	concTi : CM_Cargo;
	
	allBlendingCompCMIFs : CMIF_Array;
	newTi : CM_TrackedItem;
	tiTrx : CM_TITransaction;

begin

	self.deleteTerminalArea( BlendArea1 );
	self.deleteTerminalArea( BlendArea2 );

	term := self.getTerminal;
	
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertTrueMsg( oper &lt;&gt; null, "Operator not found in setup." );
	
	bs1 := self.addBlockStack( BlendArea1, 100, null);
	self.assertTrueMsg( bs1 &lt;&gt; null, BlendArea1 &amp; " not found in setup." );
	bs2 := self.addBlockStack( BlendArea2, 100, null);
	self.assertTrueMsg( bs2 &lt;&gt; null, BlendArea2 &amp; " not found in setup." );
	
	//Ingredients
	ctAggregate := term.getCargoTypeFromAbbrevOrDescr( CargoTypeAgg );
	self.assertTrueMsg( ctAggregate &lt;&gt; null, CargoTypeAgg &amp; " not found during setup" );
	productAggregate10mm := ctAggregate.getProductFromCode(ProductAgg10mm);
	self.assertTrueMsg( productAggregate10mm &lt;&gt; null, ctAggregate.abbreviation &amp; "/" &amp; ProductAgg10mm &amp; " not found during setup" );
	ctSand := term.getCargoTypeFromAbbrevOrDescr( CargoTypeSand );
	self.assertTrueMsg( ctSand &lt;&gt; null, CargoTypeSand &amp; " not found during setup" );
	productYellowSand := ctSand.getProductFromCode(ProductSandYellow);
	self.assertTrueMsg( productYellowSand &lt;&gt; null, ctSand.abbreviation &amp; "/" &amp; ProductSandYellow &amp; " not found during setup" );
	ctCement := term.getCargoTypeFromAbbrevOrDescr( CargoTypeCement );
	self.assertTrueMsg( ctCement &lt;&gt; null, CargoTypeCement &amp; " not found during setup" );
	productCement20Kg := ctCement.getProductFromCode(ProductCement20);
	self.assertTrueMsg( productCement20Kg &lt;&gt; null, ctCement.abbreviation &amp; "/" &amp; ProductCement20 &amp; " not found during setup" );
	
	//Blended Output
	ctBuildMix := term.getCargoTypeFromAbbrevOrDescr( CargoTypeBuildMix );
	self.assertTrueMsg( ctBuildMix &lt;&gt; null, CargoTypeCement &amp; " not found during setup" );
	productMedium := ctBuildMix.getProductFromCode(ProductBuildMixGen);
	self.assertTrueMsg( productMedium &lt;&gt; null, ctBuildMix.abbreviation &amp; "/" &amp; ProductBuildMixGen &amp; " not found during setup" );
	
	//Recipe
	realRecipe := ctBuildMix.allRecipes.getAtKey( ProductBuildMixGen );
	
	//create onsite ingredients
	aggTi := self.addCargoAtLocation( CargoTypeAgg, productAggregate10mm, oper, bs1.myLocationsController ).CM_Cargo;
	self.assertTrueMsg( aggTi &lt;&gt; null, CargoTypeAgg &amp; " not created in setup." );	
	beginTransaction;
	aggTi.setTotalWeightWithoutTrans(50000);
	commitTransaction;
	
	sandTi := self.addCargoAtLocation( CargoTypeSand, productYellowSand, oper, bs1.myLocationsController ).CM_Cargo;
	self.assertTrueMsg( sandTi &lt;&gt; null, CargoTypeSand &amp; " not created in setup." );	
	beginTransaction;
	sandTi.setTotalVolumeWithoutTrans(10);
	sandTi.setTotalWeightWithoutTrans(10000);
	commitTransaction;
	
	concTi := self.addCargoAtLocation( CargoTypeCement, productCement20Kg, oper, bs1.myLocationsController ).CM_Cargo;
	self.assertTrueMsg( concTi &lt;&gt; null, CargoTypeCement &amp; " not created in setup." );	
	beginTransaction;
	concTi.setTotalQuantity(300);
	concTi.setTotalWeightWithoutTrans(6000);
	commitTransaction;
	
	self.assertTrueMsg( sandTi.totalVolume = 10, "Sand should have volume of 10 m3 at start.");
	self.assertTrueMsg( concTi.totalQuantity = 300, "Concrete bags, qquantity should be 300 at start.");
	self.assertTrueMsg( aggTi.totalWeight = 50000, "Aggregate, should weigh 50,000 kgs at start.");
	
	
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	//First Blend will just use a recipe and create just one new cargo item
	create agent transient;
	
	//populate agent as we would on the CMUI_BlendForm	
	agent.myTerminal := term;
	agent.doUseRecipe := true;
	agent.doCreateNewCargoItem := true;
	agent.factor := 1;

	agent.newParentIdArray.add( "BM1" );
	agent.myNewCargoType := ctBuildMix;
	agent.myNewProduct := productMedium;
	agent.myNewOperator := oper;
	agent.myNewLocation := bs2.myLocationsController;
	agent.validateCreatingNewCargo( true );

	agent.myRecipe := realRecipe;
	if agent.factor &lt;&gt; 1 then
		agent.validateUsingRecipe( true );
	endif;
	
	agent.totalQuantity := ( agent.myRecipe.defaultQuantity * agent.factor ).Integer;
	agent.totalVolume := ( agent.myRecipe.defaultVolume * agent.factor ); 
	agent.totalWeight := ( agent.myRecipe.defaultWeight * agent.factor ); 

	agent.validateAmounts( true );
	
	//setup the selections of ingredients
	create allBlendingCompCMIFs transient;
	foreach realRecipeComponent in realRecipe.allComponentsByCode do
		create cmifBlendComp transient;
		cmifBlendComp.populateFromRecipeComp( agent.factor, realRecipeComponent, agent.newParentIdArray.size);
		if realRecipeComponent.myProduct = productAggregate10mm then
			cmifBlendComp.addTI( aggTi );
		elseif realRecipeComponent.myProduct = productYellowSand then
			cmifBlendComp.addTI( sandTi );
		elseif realRecipeComponent.myProduct = productCement20Kg then
			cmifBlendComp.addTI( concTi );
		endif;
		allBlendingCompCMIFs.add( cmifBlendComp );
	endforeach;

	allBlendingCompCMIFs.copy( agent.allBlendingComponents );
	agent.validateSufficientCompCargo( true );
	
	//do the deed, i.e, blend the selected ingredients associated with the recipe and make the the new blended item.
	app.myTrxCA.trxPerformBlending( agent, app.myPassport);
	self.assertTrueMsg( app.myPassport.getErrorsAndWarningsAsString = null, "Blend to create a new item from a recipe failed. " &amp; app.myPassport.getErrorsAndWarningsAsString );
	newTi := bs2.myLocationsController.allTrackedItemsById.getAtKey("BM1",ctBuildMix.id);
	self.assertTrueMsg( newTi &lt;&gt; null, "Blend to create a new item from a recipe failed. No new item in location." );
	
	delete agent;
	allBlendingCompCMIFs.purge();
	delete allBlendingCompCMIFs;
	
	tiTrx := newTi.allTransactions.getFirstTransOfType( TRANS_TYPE_Blend );
	self.assertTrueMsg( tiTrx &lt;&gt; null and tiTrx.CM_Blend.action = ACTION_BLEND_PARENT, "Blend transaction for first Blend test not found or not a parent." );
	self.assertTrueMsg( tiTrx.CM_Blend.allChildBlendTrxs.size = 3, "Parent Blend transaction for first Blend has incoorect number of child trxs, should have 3." );
	tiTrx := newTi.allTransactions.getFirstTransOfType( TRANS_TYPE_BlendComplete );
	self.assertTrueMsg( tiTrx &lt;&gt; null, "Blend Complete transaction for first Blend test not found or not a parent." );
	
	self.assertTrueMsg( sandTi.totalVolume = 9.300, "Sand should have volume of 9.300 m3 after the first blend.");
	self.assertTrueMsg( concTi.totalQuantity = 296, "Concrete bags, quantity should be 296 after the first blend.");
	self.assertTrueMsg( aggTi.totalWeight = 49600, "Aggregate, should weigh 49,500 kgs after the first blend.");
	
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	//Second Blend will use a recipe ( factored by .5 ) and create two new cargo items
	
	create agent transient;
	
	//populate agent as we would on the CMUI_BlendForm	
	agent.myTerminal := term;
	agent.doUseRecipe := true;
	agent.doCreateNewCargoItem := true;
	agent.factor := .5;

	agent.newParentIdArray.add( "BM2" );
	agent.newParentIdArray.add( "BM3" );
	agent.myNewCargoType := ctBuildMix;
	agent.myNewProduct := productMedium;
	agent.myNewOperator := oper;
	agent.myNewLocation := bs2.myLocationsController;
	agent.validateCreatingNewCargo( true );

	agent.myRecipe := realRecipe;
	if agent.factor &lt;&gt; 1 then
		agent.validateUsingRecipe( true );
	endif;
	
	agent.totalQuantity := ( agent.myRecipe.defaultQuantity * agent.factor ).Integer;
	agent.totalVolume := ( agent.myRecipe.defaultVolume * agent.factor ); 
	agent.totalWeight := ( agent.myRecipe.defaultWeight * agent.factor ); 

	agent.validateAmounts( true );
	
	//setup the selections of ingredients
	create allBlendingCompCMIFs transient;
	foreach realRecipeComponent in realRecipe.allComponentsByCode do
		create cmifBlendComp transient;
		cmifBlendComp.populateFromRecipeComp( agent.factor, realRecipeComponent, agent.newParentIdArray.size );
		if realRecipeComponent.myProduct = productAggregate10mm then
			cmifBlendComp.addTI( aggTi );
		elseif realRecipeComponent.myProduct = productYellowSand then
			cmifBlendComp.addTI( sandTi );
		elseif realRecipeComponent.myProduct = productCement20Kg then
			cmifBlendComp.addTI( concTi );
		endif;
		allBlendingCompCMIFs.add( cmifBlendComp );
	endforeach;

	allBlendingCompCMIFs.copy( agent.allBlendingComponents );
	agent.validateSufficientCompCargo( true );
	
	//do the deed, i.e, blend the selected ingredients associated with the recipe and make the the new blended item.
	app.myTrxCA.trxPerformBlending( agent, app.myPassport);
	self.assertTrueMsg( app.myPassport.getErrorsAndWarningsAsString = null, "Blend to create two new item from a recipe failed. " &amp; app.myPassport.getErrorsAndWarningsAsString );
	newTi := bs2.myLocationsController.allTrackedItemsById.getAtKey("BM2",ctBuildMix.id);
	self.assertTrueMsg( newTi &lt;&gt; null, "Blend to create two new item from a recipe failed. No new item BM2 in location." );
	newTi := bs2.myLocationsController.allTrackedItemsById.getAtKey("BM3",ctBuildMix.id);
	self.assertTrueMsg( newTi &lt;&gt; null, "Blend to create two new item from a recipe failed. No new item BM3 in location." );
	
	
	delete agent;
	allBlendingCompCMIFs.purge();
	delete allBlendingCompCMIFs;
	
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	//Third Blend use NO recipe and ADD to the first cargo item.
	create agent transient;
	
	//populate agent as we would on the CMUI_BlendForm	
	agent.myTerminal := term;
	agent.doUseRecipe := false;
	agent.doCreateNewCargoItem := false;

	newTi := bs2.myLocationsController.allTrackedItemsById.getAtKey("BM1",ctBuildMix.id);
	agent.myExistingParentCargo := newTi;
	agent.validateUseExistingCargo( true );
	
	agent.totalQuantity := 0;
	agent.totalVolume := 1; 
	agent.totalWeight := 1000; 

	agent.validateAmounts( true );
	
	//setup the selections of ingredients
	create allBlendingCompCMIFs transient;
	create cmifBlendComp transient;
	cmifBlendComp.setManual(	ctAggregate,	//_myCargoType : CM_CargoType; 
								productAggregate10mm,	//_myProduct : CM_Product;
								0,	//_quantity : Integer; 
								0,	//_volume : Decimal;
								400,	//_weight : Decimal;
								1	//_cargoIdCount : Integer
								);
	cmifBlendComp.addTI( aggTi );
	allBlendingCompCMIFs.add( cmifBlendComp );
	
	create cmifBlendComp transient;
	cmifBlendComp.setManual(	ctSand,	//_myCargoType : CM_CargoType; 
								productYellowSand,	//_myProduct : CM_Product;
								0,	//_quantity : Integer; 
								.7,	//_volume : Decimal;
								0,	//_weight : Decimal;
								1	//_cargoIdCount : Integer
								);
	cmifBlendComp.addTI( sandTi );
	allBlendingCompCMIFs.add( cmifBlendComp );
	
	create cmifBlendComp transient;
	cmifBlendComp.setManual(	ctCement,	//_myCargoType : CM_CargoType; 
								productCement20Kg,	//_myProduct : CM_Product;
								4,	//_quantity : Integer; 
								0,	//_volume : Decimal;
								0,	//_weight : Decimal;
								1	//_cargoIdCount : Integer
								);
	cmifBlendComp.addTI( concTi );
	allBlendingCompCMIFs.add( cmifBlendComp );
	
	allBlendingCompCMIFs.copy( agent.allBlendingComponents );
	agent.validateSufficientCompCargo( true );
	
	//do the deed, i.e, blend the selected ingredients associated with the recipe and make the the new blended item.
	app.myTrxCA.trxPerformBlending( agent, app.myPassport);
	self.assertTrueMsg( app.myPassport.getErrorsAndWarningsAsString = null, "Blend into existing item NO recipe failed. " &amp; app.myPassport.getErrorsAndWarningsAsString );
	newTi := bs2.myLocationsController.allTrackedItemsById.getAtKey("BM1",ctBuildMix.id);
	self.assertTrueMsg( newTi.totalWeight = 2000, "Blend into existing item NO recipe failed to update the weight " );
	
	delete agent;
	allBlendingCompCMIFs.purge();
	delete allBlendingCompCMIFs;
	
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	//Fourth Blend use NO recipe and create two new items item.
	create agent transient;
	
	//populate agent as we would on the CMUI_BlendForm	
	agent.myTerminal := term;
	agent.doUseRecipe := false;
	agent.doCreateNewCargoItem := true;

	agent.newParentIdArray.add( "BM4" );
	agent.newParentIdArray.add( "BM5" );
	agent.myNewCargoType := ctBuildMix;
	agent.myNewProduct := productMedium;
	agent.myNewOperator := oper;
	agent.myNewLocation := bs2.myLocationsController;
	agent.validateCreatingNewCargo( true );
	
	agent.totalQuantity := 0;
	agent.totalVolume := 1; 
	agent.totalWeight := 1000; 

	agent.validateAmounts( true );
	
	//setup the selections of ingredients
	create allBlendingCompCMIFs transient;
	create cmifBlendComp transient;
	cmifBlendComp.setManual(	ctAggregate,	//_myCargoType : CM_CargoType; 
								productAggregate10mm,	//_myProduct : CM_Product;
								0,	//_quantity : Integer; 
								0,	//_volume : Decimal;
								600,	//_weight : Decimal;
								2	//_cargoIdCount : Integer
								);
	cmifBlendComp.addTI( aggTi );
	allBlendingCompCMIFs.add( cmifBlendComp );
	
	create cmifBlendComp transient;
	cmifBlendComp.setManual(	ctSand,	//_myCargoType : CM_CargoType; 
								productYellowSand,	//_myProduct : CM_Product;
								0,	//_quantity : Integer; 
								.750,	//_volume : Decimal;
								0,	//_weight : Decimal;
								2	//_cargoIdCount : Integer
								);
	cmifBlendComp.addTI( sandTi );
	allBlendingCompCMIFs.add( cmifBlendComp );
	
	create cmifBlendComp transient;
	cmifBlendComp.setManual(	ctCement,	//_myCargoType : CM_CargoType; 
								productCement20Kg,	//_myProduct : CM_Product;
								6,	//_quantity : Integer; 
								0,	//_volume : Decimal;
								0,	//_weight : Decimal;
								2	//_cargoIdCount : Integer
								);
	cmifBlendComp.addTI( concTi );
	allBlendingCompCMIFs.add( cmifBlendComp );
	
	allBlendingCompCMIFs.copy( agent.allBlendingComponents );
	agent.validateSufficientCompCargo( true );
	
	//do the deed, i.e, blend the selected ingredients associated with the recipe and make the the new blended item.
	app.myTrxCA.trxPerformBlending( agent, app.myPassport);
	self.assertTrueMsg( app.myPassport.getErrorsAndWarningsAsString = null, "Blend to create two new item NO recipe failed. " &amp; app.myPassport.getErrorsAndWarningsAsString );
	newTi := bs2.myLocationsController.allTrackedItemsById.getAtKey("BM4",ctBuildMix.id);
	self.assertTrueMsg( newTi &lt;&gt; null, "Blend to create two new items NO recipe failed. No new item BM4 in location." );
	newTi := bs2.myLocationsController.allTrackedItemsById.getAtKey("BM5",ctBuildMix.id);
	self.assertTrueMsg( newTi &lt;&gt; null, "Blend to create two new items NO recipe failed. No new item BM5 in location." );
	
	delete agent;
	allBlendingCompCMIFs.purge();
	delete allBlendingCompCMIFs;
													
	
epilog

	if allBlendingCompCMIFs &lt;&gt; null and not allBlendingCompCMIFs.isEmpty then
		allBlendingCompCMIFs.purge();
	endif;
	delete allBlendingCompCMIFs;

end;</source>
    </JadeMethod>
</Class>
