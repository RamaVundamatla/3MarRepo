    <JadeMethod name="updateStatusBarCount" id="bfcdf58f-f679-4624-b7fb-89814c1c31c5">
        <source>updateStatusBarCount();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/03/2023	navcs2	ChangeRequest Task 57034:[57035]: EUP - Status bar to show work order count at Work order Enquiry Screen
27 Mar 2023 navhl20 ChangeRequest 57315:[57316] EUP - [Framework] - Allow Text filtering on the work order screen
*/

vars
	col	: Collection;
	size : Integer;
begin
	/*
	//27.3.2023 navhl20 #57315[57316]
	if self.optEnqTask.value = true then
		self.staStatusBar.caption := "Task count: " &amp; (self.tblData.rows-self.tblData.fixedRows).String;
	elseif self.optEnqWorkOrder.value = true then
		self.staStatusBar.caption := "Workorder count: " &amp; (self.tblData.rows-self.tblData.fixedRows).String;
	endif;*/

	//self.staStatusBar.caption := (self.tblData.rows-self.tblData.fixedRows).String &amp; " rows found.";				//27.3.2023 navhl20 #57315[57316]
	
	
	// 24/07/2025	navkc1	JIRA MTN-35497
	col := self.tblData.getCollection();
	
	// 24/07/2025	navkc1	JIRA MTN-35497 - Collection could be null if user hasn't done any query and we receive a notification that added a record to the table
	if col &lt;&gt; null then
		size := col.size();
	else
		size := self.tblData.rows - self.tblData.fixedRows;
	endif;
	
	//self.staStatusBar.caption := app.getErrorString1(Num_Rows_Found, self.tblData.getCollection().size().String) ; //23/06/2025	navkc1 JIRA MTN 34973
	self.staStatusBar.caption := app.getErrorString1(Num_Rows_Found, size.String); // 24/07/2025	navkc1	JIRA MTN-35497
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="39b85e1e-5338-4dec-ac0f-1233748eb756">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2024 navhl20 Bug 64275: MTN - Work Order Enquiry Screen Freeze due to notifications - Phase 2 

*/

vars
	invalid : Boolean;
	obj		: Object;
	idx		: Integer;
begin
	
	//07/05/2025	navkc1 JIRA MTN-34592
	if self.notificationLevel = self.NoteLevelDoNotes then
		self.beginTimerForNotifications(theObject, eventType, eventTag, null);
	endif;
	
/* //07/05/2025	navkc1 JIRA MTN-34592 Use notification framework
	//jlier1 29/5/25 MTN-34591 
	self.handleNotifications(eventType, theObject, eventTag);
	
	/*

	on Exception do app.handleDeletedObject(exception, theObject, invalid);	
	
	theObject.edition;
	
	if invalid then
		self.tblDataSysNotifyDelete(eventType, theObject, eventTag);
		return;
	endif;
	
	obj := theObject;
	if self.enquiryType = self.EnqType_WorkOrder and theObject.isKindOf(CM_WorkOrderDtl) then
		obj := theObject.CM_WorkOrderDtl.myParent;
	endif;
	
	if eventType = obj.getMyTerminal.getTerminalEvent(Event_WODtl_Update) then
		self.tblDataSysNotifyUpdate(eventType, obj, eventTag);
	endif;
*/

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
