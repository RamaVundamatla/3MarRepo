    <JadeMethod name="valMoveShipExport" id="0c02ee93-7b7d-4ee4-a89d-7a1dabc0522f">
        <source>valMoveShipExport(_machine : CM_Machine input;_ti : CM_TrackedItem input;_passport : CM_Passport input; 
								_task : CM_RTQueueTask output;	_job : CM_VoyageJob output);
// ---------------------------------------------------------------------------
// Created:		07 December 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
26 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	shipLC : CM_LocationsController;
	queue 	: CM_RadioTelemetryQueue;
	task : CM_RTQueueTask;
	job : CM_VoyageJob;
	invalid : Boolean;
	ed : Integer;
	
begin
	queue := _machine.myPrimaryQueue;
	//---------------------
	//Get the task
	//---------------------
	exclusiveLock(_ti);
	task := queue.locateTaskForTI(_ti, -1);
	if task = null then
		//-------------------
		//a Worry!!! Could NOT locate the TI in the Queue....
	//-------------------
		if queue.myParentQueue &lt;&gt; null then
			task := queue.myParentQueue.locateTaskForTI(_ti, -1);
		else
			task := queue.locateTaskForTI(_ti, -1);
		endif;

		if task = null then
			if  _ti.isQueued then //epr par 35597 30/1/15
				//msgStr := "Cannot find RDT task for " &amp; _ti.id &amp; " in RDT queue " &amp; queue.id &amp; ". Check with controller."; //- cnwmd1, Par 20524				
				app.raiseCMException2(Canno_find_task_queue_check_wi, _ti.id, queue.id, null,null);
			endif;
		endif;
	endif;

	if task = null then
		invalid := true;
	else
		invalid := false;
		on Exception do app.handleDeletedObject(exception, task, invalid);
		// Dereference to check it is valid
		ed := task.edition();
		on Exception do null;
	endif;
	
	if invalid then
		app.raiseCMException1(Task_been_deleted, _ti.id, null,null); //+ cnwmd1 Par 24310
		return;
	endif;
	
	job := _ti.getFirstAvailableLoadJob();
	if job = null then
		//msgStr := _ti.id &amp; " does not have a ship load job. " &amp; _ti.id &amp; " cannot be moved to voyage.";//- cnwmd1, Par 20524
		//app.raiseCMException1(Full_Replacement_Message, msgStr, null,null);//- cnwmd1, Par 20524
		app.raiseCMException1(Does_have_ship_load__tiid_cann, _ti.id, null,null);
		return;
	endif;
	if task.myEntry.myJob &lt;&gt; job then
		if task.myEntry.myJob = null then
			app.raiseCMException1(Does_exist_task_cannot_move, _ti.id, null,null);
			return;
		else
			//Error! Not a voyage Job
			app.raiseCMException3(Does_match_ship_load_canno_mov, task.myEntry.myJob.id, job.id, _ti.id, null,null);
			return;
		endif;
	endif;

	//--------------------
	//The task maybe in another crane queue for the voyage...
	//--------------------
	if task.queue &lt;&gt; queue then
		queue := task.queue;
	endif;
	
	// check IMV MOVE
	if task.taskType &lt;&gt; TASK_MOVE then
		//Error! Not an imv move task!
		app.raiseCMException1(Move_task_cannot_move, _ti.id, null,null);
	endif;
	//---------------
	//Is the job "released" to ops?
	//---------------
	if (not job.isLoadedToOperations) then
		app.raiseCMException1(Load_been_loade_voyag_opera_ch, job.id, null,null);
	endif;

	shipLC	:= _ti.getPrimaryLocation(PLANNING_MODE);
	if shipLC = null then
		app.raiseCMException2(Been_plann_stow_voyag_must_pla, _ti.id, job.myVoyage.code, null,null);
	endif;
	
	_task := task;
	_job := job;
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_task" type="CM_RTQueueTask" usage="output"/>
        <Parameter name="_job" type="CM_VoyageJob" usage="output"/>
    </JadeMethod>
    <JadeMethod name="valOpTerminalConfig" id="45f3d2a3-abd9-4b28-842c-5c23bdfe3274">
        <source>valOpTerminalConfig(_operator : CM_Operator; _terminal : CM_Terminal);

vars
	opTerm : CM_OperatorTerminal;

begin
	self.raiseExceptionIfNull(_operator, 'Operator');
	self.raiseExceptionIfNull(_terminal, 'Terminal');

	opTerm := _operator.getOperatorTerminal(_terminal, true);
	
	if opTerm &lt;&gt; null then
		opTerm.validateForUpdate();		// 05/06/2009 cnwar2 CCMS1040
	endif;
end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="valOperator" id="8f221938-9fcd-4889-9888-115c20f6dd68">
        <source>valOperator(pExistingOperator, pProxyOperator : CM_Operator);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/09/2015   cnwma1      PAR #36424 Model issue in handling of Operator code change for Bookings
// ---------------------------------------------------------------------------
vars
	aTerm 		: CM_Terminal;
	booking		: CM_BookingRef;
	iter: Iterator;
begin

	self.raiseExceptionIfNull(pProxyOperator, 'Operator Proxy');
	self.raiseExceptionIfNull(pExistingOperator, "Operator Existing");
	pProxyOperator.raiseExceptionIfNotProxy(method);
	
	if pExistingOperator.code = pProxyOperator.code then
		pProxyOperator.validateForUpdate();
	else
		
		pProxyOperator.validateForCreate();
		
	foreach aTerm in app.myRoot.allTerminals do
		delete iter;		
		iter := aTerm.allBookingRefsByOperatorRef.createIterator();
		 aTerm.allBookingRefsByOperatorRef.startKeyGeq( pExistingOperator.code, null, null,iter);
		 while iter.next(booking) do
			if booking.myOperator &lt;&gt; pExistingOperator then
				break;
			endif;
			if booking.myOperator = pExistingOperator then
				app.raiseCMException2(Operator_has_bookings, pExistingOperator.code, aTerm.code, null, null);
				break;
			endif;
		endwhile;
		
	endforeach;	
	endif;

epilog
	delete iter;
end;</source>
        <Parameter name="pExistingOperator" type="CM_Operator"/>
        <Parameter name="pProxyOperator" type="CM_Operator"/>
    </JadeMethod>
