    </JadeMethod>
    <JadeMethod name="doBtnLinesSaveClick" id="43c4c666-a93b-4bfc-bb12-911e4396d3f6">
        <updating/>
        <source>doBtnLinesSaveClick() updating, protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	ls : Boolean;
	theReturn : Integer;
	pxySB	: CM_ServiceBroker;
	pxyDM : CM_DebtorMap;
	pxyQR : CM_QuantityRangeMap;
	updateController :CMIF_TranMapLinesController;
begin
	on Exception do handleMappingSaveException(exception);
	
	if not self.validateGrouping() then
		return;
	endif;

	create updateController transient;

	if self.myCurrentMapQuantityRange &lt;&gt; null then 
		app.cmsBeginLoad(ls);
		pxyQR := app.createUpdateProxy(self.myCurrentMapQuantityRange).CM_QuantityRangeMap;
		pxyQR.clear();
		app.cmsEndLoad(ls);
		updateController.pxyQRMap := pxyQR;
		if self.myTranMapForm.myCurrentMapTM &lt;&gt; null then
			self.doQtyRangeMapSetProxy(updateController);
		elseif self.myTranMapForm.myCurrentMapTMEvent &lt;&gt; null then
			self.doQtyRangeMapSetProxyEvent(updateController);
		elseif self.myTranMapForm.myCurrentMapTMWorkOrder &lt;&gt; null then // TFS 39236
			self.doQtyRangeMapSetProxyWorkOrder(updateController);
		elseif self.myTranMapForm.myCurrentMapTMBOL &lt;&gt; null then // 04 Nov 2019	NDL	TFS 47100
			self.doQtyRangeMapSetProxyBOL(updateController);
		else
			self.doQtyRangeMapSetProxyVTMIS(updateController);
		endif;
	else
		app.msgBox("Please make a selection before attempting an update.", "Update Problem", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateInvoiceTMTransaction(updateController,app.myPassport);

		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			theReturn := app.showErrorWarningDialog("Invoice Line Mappings", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
			return;
		endif;
		break;
	endwhile;
	
	self.doClose();
	self.unloadForm();

epilog
	app.cmsEndLoad(ls);
	self.myTranMapForm.modePropertyUpdate := INV_TransactionMap.ModeProperty_QuantityRange;
	delete pxySB;
	delete pxyDM;
	delete updateController;
	delete pxyQR;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCheckLengthBooleans" id="c880a1b5-0ef4-4913-be9b-45673da1a8fb">
        <source>doCheckLengthBooleans(_row, _col : Integer) protected;
// ---------------------------------------------------------------------------
// Created:     29 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	isForShip : Boolean;
	col30, col40, col45, col53, colClicked : Integer;
begin
	if self.myTranMapForm.myCurrentMapTIService = null then		// 31226 - get here from clicking the fixed row in a voyage tran map
		return;
	endif;
	if self.myTranMapForm.myCurrentMapTIService.className &lt;&gt; CM_Container.name then
		return;
	endif;
	if self.myTranMapForm.myCurrentMapServiceBroker.isKindOf(CM_TransServiceBroker) then
		if self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.myTransactionType &lt;&gt; null and
		   self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.myTransactionType.isForShip() then
			isForShip := true;
		endif;
	endif;

	if isForShip then
		if _col = 3 then
			colClicked := 40;
		elseif _col = 7 then
			colClicked := 45;
		elseif _col = 8 then
			colClicked := 30;
		elseif _col = 9 then
			colClicked := 53;
		endif;
		col30 := 8;
		col40 := 3;
		col45 := 7;
		col53 := 9;
	else
		if _col = 3 then
			colClicked := 40;
		elseif _col = 6 then
			colClicked := 45;
		elseif _col = 7 then
			colClicked := 30;
		elseif _col = 8 then
			colClicked := 53;
		endif;
		col30 := 7;
		col40 := 3;
		col45 := 6;
		col53 := 8;
	
	endif;

	if colClicked = 40 then // Is 40
		self.tblLines.accessCell(_row,col45).text := "0"; // Is 45
		self.tblLines.accessCell(_row,col30).text := "0"; // Is 30
		self.tblLines.accessCell(_row,col53).text := "0"; // Is 53
	elseif colClicked = 45 then // Is 45
		self.tblLines.accessCell(_row,col40).text := "0"; // Is 40
		self.tblLines.accessCell(_row,col30).text := "0"; // Is 30
		self.tblLines.accessCell(_row,col53).text := "0"; // Is 53
	elseif colClicked = 30 then // Is 30
		self.tblLines.accessCell(_row,col40).text := "0"; // Is 40
		self.tblLines.accessCell(_row,col45).text := "0"; // Is 45
		self.tblLines.accessCell(_row,col53).text := "0"; // Is 53
	elseif colClicked = 53 then // Is 53
		self.tblLines.accessCell(_row,col40).text := "0"; // Is 40
		self.tblLines.accessCell(_row,col45).text := "0"; // Is 45
		self.tblLines.accessCell(_row,col30).text := "0"; // Is 30
	else
		return;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doClose" id="ca6033cf-752a-4807-b2af-a001ad362185">
        <updating/>
        <source>doClose() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2012	cnwjre1	Initial creation

*/

vars

begin
	// if the app is closing, the parent form may have been closed before this one- check if valid before using
	if global.isValidObject(self.myTranMapForm) then
		self.myTranMapForm.lstData.enabled := true;
		self.myTranMapForm.frmToolbar.enabled := true;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doComboCargoTypeBuild" id="271c5cd8-9925-40ae-b577-a19933f7a489">
        <source>doComboCargoTypeBuild(_cargotype : CM_CargoType; _subtype : CM_Product; _clone : Boolean; 	_combo, _combost, _combocomm: CMUI_ComboBox output) protected;
/*
Purpose - 	
Who - NAVAB1
Date - 06AUG2024
ADO - CR 65331 TASK 65332
*/
	// ### TFS BUG 66001 19SEP2024 NAVAB1 - clone the combos for each line

vars
	combo, combost, combocomm: CMUI_ComboBox;
	cargotype: CM_CargoType;
	cbolType : CM_CargoBOLType;
	prod : CM_Product;
	comm, selcomm : CM_Commodity;
	subs, comms : CM_ObjectSet;
	controlIdx : Integer;
begin

	controlIdx := self.tblLines.row;
	
	if _clone then
		combo := self.cmbCargoType.loadControl(controlIdx).CMUI_ComboBox;
		combost := self.cmbSubType.loadControl(controlIdx).CMUI_ComboBox;
		combocomm := self.cmbCommodity.loadControl(controlIdx).CMUI_ComboBox;
	
	else
		combo := self.tblLines.accessCell(self.tblLines.row, 1).cellControl.CMUI_ComboBox;
		combost := self.tblLines.accessCell(self.tblLines.row, 2).cellControl.CMUI_ComboBox;
		combocomm := self.tblLines.accessCell(self.tblLines.row, 3).cellControl.CMUI_ComboBox;
	endif;
	
	_combo := combo;
	_combost := combost;
	_combocomm := combocomm;

	
	if _cargotype = null then
		combo.clear;
		combo.sorted := true;
	endif;
	
	combost.clear;
	combost.sorted := true;
	
	combocomm.clear;
	combocomm.sorted := true;

	create comms transient;
	create subs transient;
	
	if _cargotype &lt;&gt; null then
		foreach cbolType in self.myTerminal.allCargoBOLTypes do
			if cbolType.isCargoType then
				cargotype:= cbolType.CM_CargoType;
				
				combo.addItemObject(cargotype.description, cargotype);
			endif;
		endforeach;
		
		cargotype := _cargotype;
		foreach prod in  cargotype.allProducts discreteLock do
			if _subtype &lt;&gt; null 
			and _subtype &lt;&gt; prod then
				continue;
			endif;
		
			subs.addNoDuplicates(prod, false);
		endforeach;
		
		foreach comm in  cargotype.allCommodities discreteLock do
			comms.addNoDuplicates(comm, false);
		endforeach;
		

	else
		foreach cbolType in self.myTerminal.allCargoBOLTypes do
			if cbolType.isCargoType then
				cargotype:= cbolType.CM_CargoType;
				
				combo.addItemObject(cargotype.description, cargotype);
				
				foreach prod in  cargotype.allProducts discreteLock do
					if _subtype &lt;&gt; null 
					and _subtype &lt;&gt; prod then
						continue;
					endif;
				
					subs.addNoDuplicates(prod, false);
				endforeach;
				
				foreach comm in  cargotype.allCommodities discreteLock do
					comms.addNoDuplicates(comm, false);
				endforeach;
			endif;
		endforeach;	
	endif;

	

	foreach prod in subs as CM_Product discreteLock do
		combost.addItemObject(prod.code, prod); // NAVAB1 20AUG2024 some Products do not have a description
	endforeach;
	foreach comm in comms as CM_Commodity discreteLock do
		combocomm.addItemObject(comm.description, comm);
	endforeach;
	
	if _cargotype = null then
		combo.sorted := false;
		combo.addItemAt(Any_String, 1);
		combo.listIndex := 1;
	endif;
	
	combocomm.sorted := false;
	combocomm.addItemAt(Any_String, 1);
	combocomm.listIndex := 1;


	combost.sorted := false;
	combost.addItemAt(Any_String, 1);
	combost.listIndex := 1;
epilog
	delete subs;
	delete comms;
end;</source>
        <access>protected</access>
        <Parameter name="_cargotype" type="CM_CargoType"/>
        <Parameter name="_subtype" type="CM_Product"/>
        <Parameter name="_clone" type="Boolean"/>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="output"/>
        <Parameter name="_combost" type="CMUI_ComboBox" usage="output"/>
        <Parameter name="_combocomm" type="CMUI_ComboBox" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doComboGroupingBuild" id="4416f0f2-b783-4a2e-8d9a-5e36e4cb67b1">
        <source>doComboGroupingBuild() protected;

vars
	aCombo : CMUI_ComboBox;
	mapType	: CM_TranMapInvoiceLineGroupType;
begin
	aCombo := self.cmbGrouping;
	
	aCombo.clear;
	aCombo.sorted := true; // ### TFS CR 56446 TASK 56447 13FEB2023 NAVAB1

	foreach mapType in app.myRoot.allTMInvLineGrpTypes discreteLock do // ### TFS CR 56446 TASK 56447 13FEB2023 NAVAB1
		aCombo.addItemObject(mapType.name, mapType);
	endforeach;
	
	aCombo.listIndex := 1;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doComboInvoiceLinesBuild" id="41eb4b06-c3e0-4cb9-b2b0-901a07654a42">
        <source>doComboInvoiceLinesBuild() protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//	CCMS SFW 1279 May 2012 Storage Escalating Charges - limit invoice line types to those
//				with a matching calculcation type if escalating storage
// ---------------------------------------------------------------------------

vars
	doFilter	: Boolean;
	aCombo : CMUI_ComboBox;
	aLine : CM_InvoiceLineDesc;
	calcType,
	invCalcType	: CM_CalculationType;
begin
	if self.myCurrentMapQuantity &lt;&gt; null then
		calcType := self.myCurrentMapQuantity.myCalculationType;
		if calcType &lt;&gt; null then
			doFilter := (calcType.allQuantityRanges.size &gt; 0);
		endif;
	endif;

	aCombo := self.cmbInvoiceLines;
	
	aCombo.clear;
	aCombo.sorted := true;
	
	// 35872 use parent form  business unit
	foreach aLine in self.myTranMapForm.myCurrentBank.invoiceLineDescriptors where not aLine.isNotAvailableForEntry do
		if doFilter 
		and not aLine.isVoid then
			invCalcType := aLine.getCalcType();
			if invCalcType = null then
				continue;
			elseif invCalcType &lt;&gt; calcType then
				continue;
			endif;
		endif;
		
		// TFS 39236
		if self.myTranMapForm.myCurrentMapTMWorkOrder &lt;&gt; null then
			if not aLine.isWorkOrderLine() 
			 and not aLine.isVoid then  // ### TFS BUG 58790 23JUN2023 NAVAB1
				continue;
			endif;
		elseif self.myTranMapForm.myCurrentMapTMBOL &lt;&gt; null then	//12 Nov 2019	NDL	TFS 47100
			if not aLine.isBolCalcType() and not aLine.isVoid then
				continue;
			endif;
		endif;
		aCombo.addItemObject(aLine.getComboDescription(), aLine); // ### TFS BUG 59913 31AUG2023 NAVAB1 
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doComboTransferTypeBuild" id="39a9547e-08ea-4957-a9ed-0007fae80ee4">
        <source>doComboTransferTypeBuild() protected;
/*

