    <JadeMethod name="displayRow" id="6a025218-702b-4628-b314-8acb59132af2">
        <updating/>
        <source>displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io): String updating;

vars
	columnOffset	: Integer;
	pos 			: Integer;
	returnValue		: String;
	offSetRetValue	: String;
	
begin
	returnValue := inheritMethod(table, theSheet, obj, theRow, bcontinue);
	
	if returnValue = "" then
		returnValue := "No output from '" &amp; self.name &amp; "::displayRow'";
	endif;

	columnOffset := table.fixedColumns;
	
	if columnOffset &gt; 0 then
		foreach pos in 1 to columnOffset do
			if theRow &lt;&gt; 0 then
				offSetRetValue := offSetRetValue &amp; getCellText(theRow, pos) &amp; Tab;
			else
				offSetRetValue := offSetRetValue &amp; "" &amp; Tab;
			endif;				
		endforeach;
	endif;
	
	return offSetRetValue &amp; returnValue;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doSelectColumn" id="95a14910-0b28-4097-b73e-fa728957fe3a">
        <updating/>
        <source>doSelectColumn() updating, protected;
// --------------------------------------------------------------------------------
// Created:		20 August 2000 by cnwdad1
//
// Purpose:		Selects all cells for the column which the currently selected cell is in.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 03/01/2001	cnwdad1		Changed to no longer clear currently selected cells so
//							that multi-row/column selection is possible.
// --------------------------------------------------------------------------------
vars
	rowIndex		: Integer;
	rowCount		: Integer;
	columnIndex		: Integer;
	firstNonFixed	: Integer;

begin
	firstNonFixed	:=	self.fixedRows + 1;
	rowCount		:=	self.rows;

	if self.selectMode = self.SelectMode_Multiple then
		// This is a multi-column selection.
		
		rowIndex	:=	0;
		columnIndex	:=	0;
		
		while self.selectedNext(rowIndex, columnIndex) do
			foreach rowIndex in firstNonFixed to rowCount do
				self.setCellSelected(rowIndex, columnIndex, true);	
			endforeach;
		endwhile;

	else
		// This is a single-column selection.

		self.clearAllSelected;

		if (self.column &gt; self.fixedColumns) then
			
			foreach rowIndex in firstNonFixed to rowCount do
				self.setCellSelected(rowIndex, self.column, true);	
			endforeach;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSelectRow" id="efc69f4b-3165-4d5a-932b-2b518646d002">
        <updating/>
        <source>doSelectRow() updating, protected;
// --------------------------------------------------------------------------------
// Created:		20 August 2000 by cnwdad1
//
// Purpose:		Selects all cells for the row which the currently selected cell is in.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 03/01/2001	cnwdad1		Changed to no longer clear currently selected cells so
//							that multi-row/column selection is possible.
// --------------------------------------------------------------------------------
vars
	rowIndex		: Integer;
	columnIndex		: Integer;
	columnCount		: Integer;
	firstNonFixed	: Integer;

begin
	columnCount		:=	self.columns;
	firstNonFixed	:=	self.fixedColumns + 1;

	if self.selectMode = self.SelectMode_Multiple then
		// This is a multi-row selection.
		
		rowIndex	:=	0;
		columnIndex	:=	0;
		
		while self.selectedNext(rowIndex, columnIndex) do
			foreach columnIndex in firstNonFixed to columnCount do
				self.setCellSelected(rowIndex, columnIndex, true);	
			endforeach;
		endwhile;
		
	else
		// This is a single-row selection.
		
		self.clearAllSelected;

		if (self.row &gt; self.fixedRows) then
			foreach columnIndex in firstNonFixed to columnCount do
				self.setCellSelected(self.row, columnIndex, true);	
			endforeach;
		endif;
		
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getAllColumnHeadings" id="43659aea-9f04-4ca5-97fa-cb0f91e18d70">
        <source>getAllColumnHeadings() : StringArray;
// --------------------------------------------------------------------------------
// Created:		19 August 2001 by cnwdad1
//
// Purpose:		Returns an array of all column headings.
//
// Parameters:	None
// Returns:		A string array where each element corresponds to a column, i.e.
//				element 1 is column 1 etc.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.allColumnHeadings;
end;</source>
        <ReturnType type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="getAllRowHeadings" id="acc01bfc-1e6c-4325-83d5-0b648dd436e1">
        <source>getAllRowHeadings() : StringArray;
// --------------------------------------------------------------------------------
// Created:		19 August 2001 by cnwdad1
//
// Purpose:		Returns an array of all row headings.
//
// Parameters:	None
// Returns:		A string array where each element corresponds to a row, i.e.
//				element 1 is row 1 etc.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.allRowHeadings;
end;</source>
        <ReturnType type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="getObject" id="b0173ca8-044d-43ab-9127-9d4d3b70faea">
        <updating/>
        <source>getObject(pRow:Integer):Object updating;

begin
	self.accessRow(pRow);
	return self.accessedRow.itemObject;
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="a2919634-aed7-4564-8081-766316f3eaaa">
        <updating/>
        <source>gotFocus(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(table);
	
	if self.isFocusColorUsed and self.backColor &lt;&gt; self.focusColor then
		self.colorNoFocus	:=	self.backColor;
		self.backColor		:=	self.focusColor;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initialize" id="294a9a4f-a3ad-4a40-9f86-1766e18d6e96">
        <updating/>
        <source>initialize() updating;

begin
	self.setColumnHeadings();
	self.setRowHeadings();
	self.setDefaults();
end;</source>
    </JadeMethod>
    <JadeMethod name="isSelectColumn" id="60a4bfe9-7f15-4545-b9ae-3bae5804bfa9">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>isSelectColumn(set: Boolean; _value: Boolean io) mapping, updating;

begin
	if set then
		if _value = true then
			self.isSelectColumn := true;
			self.isSelectRow := false;	
		endif;
	else
		_value := self.isSelectColumn;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isSelectRow" id="f0ca3d49-e3f1-4d5b-a7c2-dd7cf527d656">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>isSelectRow(set: Boolean; _value: Boolean io) mapping, updating;

begin
	if set then
		if _value = true then
			self.isSelectRow := true;
			self.isSelectColumn := false;	
		endif;
	else
		_value := self.isSelectRow; 
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="24b5746e-bf02-4b95-8aaa-64059352bdc1">
        <updating/>
        <source>lostFocus(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(table);
	
	if self.isFocusColorUsed and self.backColor &lt;&gt; self.colorNoFocus then
		self.backColor		:=	self.colorNoFocus;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="cc1b0f99-8dcb-4d5b-b753-2b6e8a4b6a21">
        <updating/>
        <source>mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		20 August 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(table, button, shift, x, y);
	
	if self.isSelectColumn then
		self.doSelectColumn();
	elseif self.isSelectRow then
		self.doSelectRow();
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setColumnHeadings" id="5f5f64a9-49b4-4157-9c2f-8f413c5d87bf">
        <updating/>
        <source>setColumnHeadings() updating, protected;

vars
	headingsArrayObj	: CnStringArray;
	heading				: String;
	pos					: Integer;
	columnOffset		: Integer;
	headingPos			: Integer;
		 
begin
	columnOffset := self.allRowHeadings.size();
	
	while pos &lt; self.allColumnHeadings.size() do
		pos := pos + 1; 
		headingsArrayObj	:=	self.allColumnHeadings[pos].cnGetTokens(Tab);
		
		if headingsArrayObj.size() &gt; 0 then
			headingPos := 0;
			
			foreach heading in headingsArrayObj do
				headingPos := headingPos + 1;
				
				if rows &lt; pos then
					rows := pos;
				endif;
				
				if columns &lt; headingPos + columnOffset then
					columns := headingPos + columnOffset;
				endif;		
						
				self.setCellText(pos, headingPos + columnOffset, heading);
			endforeach;
			
			self.columns := headingPos + columnOffset;
		endif;					
	endwhile;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setColumnsAndRows" id="6e28219c-f9d1-4cd2-82ce-f4f655aa6d40">
        <updating/>
        <source>setColumnsAndRows() updating, protected;

vars
	headingsArrayObj	: CnStringArray;
	columnCount			: Integer;
	
begin
	self.fixedColumns	:=	self.allRowHeadings.size();

	if self.allColumnHeadings.size() &gt; 0 then
		headingsArrayObj	:=	self.allColumnHeadings[1].cnGetTokens(Tab);
		columnCount			:=	headingsArrayObj.size();
	endif;
	
	columnCount		:=	columnCount + self.fixedColumns; 	
	self.columns	:=	columnCount;
	
	self.rows		:=	self.allColumnHeadings.size();
	self.fixedRows	:=	self.allColumnHeadings.size();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDefaults" id="596c764a-6996-48ce-b078-480323b6739e">
        <updating/>
        <source>setDefaults() updating, protected;

begin
	self.partialTextIndication	:=	true;
	self.autoSize				:=	Table.AutoSize_Column;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setRowHeadings" id="df0d8873-18bd-4dce-85a3-2bf23673c8ea">
        <updating/>
        <source>setRowHeadings() updating, protected;

vars
	headingsArrayObj	: CnStringArray;
	heading				: String;
	pos					: Integer;
	rowOffset			: Integer;
	headingPos			: Integer;	 
	
begin
	rowOffset := self.allColumnHeadings.size();
	
	while pos &lt; self.allRowHeadings.size() do
		pos := pos + 1; 
		headingsArrayObj	:=	self.allRowHeadings[pos].cnGetTokens(Tab);
		
		if headingsArrayObj.size() &gt; 0 then
			headingPos := 0;
			
			foreach heading in headingsArrayObj do
				headingPos := headingPos + 1;
				if rows &lt; headingPos + rowOffset then
					rows := headingPos + rowOffset;
				endif;
				if columns &lt; pos then
					columns := pos;
				endif;	
				self.setCellText(headingPos + rowOffset, pos, heading);
			endforeach;
		endif;					
	endwhile;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="e10cc12d-e7de-4d8f-a8c5-b92926994a38">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// -----------------------------------------------------------------------------
// Created:		26 November 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);
	
	if self.isRequired then
		self.autoRedraw	:=	true;
		self.drawSolidRectangle(self.clientWidth()-4, 0, self.clientWidth(), 4, Red);
	endif;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
