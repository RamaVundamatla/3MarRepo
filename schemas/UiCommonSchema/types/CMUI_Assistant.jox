    <JadeMethod name="showYAMaintForm" id="0406955a-2339-4111-ad54-620669642312">
        <source>showYAMaintForm(_yas : ObjectArray; 
				_ti: CM_TrackedItem; 
				_baseForm : CM_BaseForm input;
				_locations : String;
				_sheetIndex : Integer) : CM_YardAllocation;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theForm : CMUI_YAMaintForm;
	newYA 	: CM_YardAllocation;
begin

	theForm := app.loadForm(CMUI_YAMaintForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_YAMaintForm;
	if theForm = null then
		return null;
	endif;
	theForm.setYardAllocation(_yas);
	theForm.setTrackedItem(_ti);
	//epr par 28388 11/10/11
	if _locations &lt;&gt; null then
		theForm.setInitLocation(_locations);
	endif;
	theForm.setParentForm(_baseForm);
	theForm.setInitialSheetIndex(_sheetIndex);	//04 Jan 2012	NDL	Par 28889
	theForm.showModal();

	//par 23253 cnwjo3.  We don't directly add the item to the table.  
	newYA:=theForm.myYardAllocation;
	
	theForm.unloadForm();
	
	return newYA;
end;</source>
