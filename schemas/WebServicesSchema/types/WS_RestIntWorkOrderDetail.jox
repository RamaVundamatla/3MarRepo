<Class name="WS_RestIntWorkOrderDetail" id="eb5968ae-05b1-4409-ba48-fee5645ea6b2">
    <superclass name="WS_RestInternalProxyObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <PrimAttribute name="detailType" id="11aa4b86-393a-4002-acbf-8e8661e8936d">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="status" id="3adb9b10-bd6a-4df7-a848-25bfd87e204b">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="taskId" id="f25dcdb6-4c78-444e-ab5c-9e269da4c478">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="type" id="c2c60964-a34e-4f3f-aefb-f81e5d216787">
        <type name="String"/>
    </PrimAttribute>
    <ImplicitInverseRef name="workOrder" id="a7408da5-312a-48a7-96b3-fa69f072408a">
        <embedded/>
        <type name="WS_RestIntWorkOrder"/>
    </ImplicitInverseRef>
    <JadeMethod name="setProxyFromObject" id="b93d462f-248f-4a29-b0b1-794755a6352a">
        <updating/>
        <source>setProxyFromObject(_object: Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 June 2023		navma1	Initial creation

*/

vars
	wsWorkOrder : WS_RestIntWorkOrder;
	workOrder	: CM_WorkOrder;
begin
	inheritMethod(_object);
	
	self.detailType := _object.CM_WorkOrderDtl.detailType;
	self.type       := _object.CM_WorkOrderDtl.getDisplayString(true);
	self.taskId     := _object.CM_WorkOrderDtl.taskID;
	self.status		:= _object.CM_WorkOrderDtl.status;
	
	workOrder := _object.CM_WorkOrderDtl.myParent;
	
	if workOrder &lt;&gt; null then
		if workOrder.isKindOf(CM_WorkOrderTI) then
			create wsWorkOrder as WS_RestIntWorkOrderTI transient;
			wsWorkOrder.setProxyFromObject(workOrder);
			self.workOrder := wsWorkOrder;
		elseif workOrder.isKindOf(CM_WorkOrderToDo) then
			create wsWorkOrder as WS_RestIntWorkOrderToDo transient;
			wsWorkOrder.setProxyFromObject(workOrder);
			self.workOrder := wsWorkOrder;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
</Class>
