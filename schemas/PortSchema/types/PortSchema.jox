        <Parameter name="_oldValue" type="String"/>
        <Parameter name="_newValue" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="generalExceptionHandler" id="4f6d0348-49d3-44a1-9ec9-f31e2d290af8">
        <updating/>
        <source>generalExceptionHandler(exObj : Exception) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     07 August 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
08 Apr 2008	cnwkpd1	PAR #16487 - ensure transaction state is always aborted if we are going to
					return Ex_Abort_Action
// 04 Jul 2019	jlgrs1	TFS45051 JMT terminate on a SDS secondary exception ie a takeover has happened.
	19/07/2019 	JLGNS1	Bug 45458: PNL - Error 4 in global exception handler
*/

vars
	user,
	msgTitle,
	errStr				: String;
	tmpIsJSSException	: Boolean;
	msg 				: String;
	dumpError			: Boolean;
begin
	
	if exObj.errorCode = 1228 or 
	   exObj.errorCode = 1295 or 
	   exObj.errorCode = 3015 or 
	   exObj.errorCode = 3037 then
		abortTransaction;
		abortTransientTransaction;
		msg := class.name&amp;'::'&amp;method.name&amp;' SDS Exception, cant continue,'&amp;exObj.errorCode.String&amp;' '&amp;exObj.extendedErrorText&amp;' processApp= '&amp;process.persistentApp.name&amp;' '&amp;process.userInfo&amp;' ('&amp;process.node.String&amp;", "&amp;process.String&amp;')';
		app.writeLog(msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		
		terminate;
	endif;

	if exObj.errorCode = 1027 and LockException.hasInstance(exObj) then		// lock exception
		// object locked
		if app.lockExceptionHandlerMsgBox(exObj.LockException) then
			return Ex_Continue; // we got the lock
		else
			if app.passBackJadeExceptionsOnly then
//				process.debug;
			endif;
			abortTransientTransaction;			// PAR #16487
			abortTransaction;
			return Ex_Abort_Action;	//Added so we quit as they have asked to do so. DQ 15/09/03
		endif;
	endif;
		
	tmpIsJSSException := self.isJSSException(exObj);
	
	if self.isWarningException(exObj) then
		msgTitle := 'Warning';
	else
		msgTitle := 'Error';	
	endif;

	if tmpIsJSSException or exObj.isKindOf(CM_Exception) then
	   	if process.isInTransientTransactionState then
			commitTransientTransaction;
		endif;
		abortTransaction;
		if app.passBackAllExceptions then
			return Ex_Pass_Back;
		endif;
		if tmpIsJSSException and 
		   exObj.errorCode = 79 and
		   exObj.continuable then
			// ignore if the license key does not exist
			return Ex_Continue;
		endif;
		if exObj.extendedErrorText &lt;&gt; null then
			errStr := msgTitle &amp;  ' ' &amp; exObj.extendedErrorText;
		else
			errStr := msgTitle &amp;  ' (' &amp; exObj.errorCode.String &amp; '). ' &amp; exObj.text;
		endif;
		app.writeLog(msgTitle &amp; ' &gt;&gt; ' &amp; errStr, LogINFO);
		app.msgBox(errStr, msgTitle, MsgBox_OK_Only +MsgBox_Stop_Icon);
		return Ex_Abort_Action;
	endif;
	
	if exObj.errorCode = 1227 or	//Jade 5
	   exObj.errorCode = 1066 then	//Jade 6
		// We have a notification subscriber error.
		abortTransientTransaction;			// PAR #16487
		abortTransaction;
		return Ex_Abort_Action;
	endif;
	
	if exObj.errorCode &gt;= 15001 and exObj.errorCode &lt;= 15099 then
		// We have a printer error.
		if process.isInTransientTransactionState then
			commitTransientTransaction;
		endif;
		abortTransaction;
		app.printer.abort;	//18 July 2014	NDL	- locked printer during testing.
		errStr := 'Printer Error (' &amp; exObj.errorCode.String &amp; '). ' &amp; exObj.text; //. Extended info = ' &amp;  exObj.extendedErrorText;
		app.writeLog(msgTitle &amp; ' &gt;&gt; ' &amp; errStr, LogINFO);
		app.msgBox(errStr, msgTitle, MsgBox_OK_Only +MsgBox_Stop_Icon);
		return Ex_Abort_Action;	
	endif;

	// djc, 30 Nov 2000: If we have a fatal thin client error, we take a
	// stack dump and terminate. Bob said the app server process needs to
	// be shut down in the event of such an exception.
	if app.isFatalThinClientError(exObj) then
		// do not do dump stack as a 14144 can lead to recursive error in stack dump
		//app.doDumpStack(exObj);
		abortTransientTransaction;			// PAR #16487
		abortTransaction;
		
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' &gt;&gt; Terminating with FatalThinClientError');
		app.writeLog('Terminating with FatalThinClientError', LogINFO);
		terminate;
		return Ex_Abort_Action; // belts and braces - shouldn't get here
	endif;

	if app.passBackAllExceptions then
		// Don't handle any exceptions, just pass them back
		return Ex_Pass_Back;
	elseif app.passBackJadeExceptionsOnly and exObj.errorCode &lt; app.baseErrorNum then
		return Ex_Pass_Back;
	endif;
	
	// If we get an error 4 when dumping the stack, then ignore it										//Bug 45458
	on SystemException do app.cnHandleNullOrInvObjectRef(exception, null, dumpError);					//Bug 45458
	self.doDumpStack(exObj);																			//Bug 45458
	
	if dumpError then																					//Bug 45458
		app.writeLog('Error 4 when generating stack dump. Stack dump will be incomplete.', LogINFO);	//Bug 45458
	endif;																								//Bug 45458
	on SystemException do null;																			//Bug 45458

	// Abort transaction after dumping stack
   	if process.isInTransientTransactionState then
		commitTransientTransaction;
	endif;
	abortTransaction;

	if exObj.isKindOf(DeadlockException) then
		// Return ResourceLocked for deadlock exceptions
		errStr := 'Error (' &amp; exObj.errorCode.String &amp; '). ' &amp; app.getErrorString(LOCKED);
		app.writeLogLockException(exObj);

	else
		if exObj.errorCode &gt;= app.baseErrorNum then
			errStr := msgTitle &amp;' (' &amp; exObj.errorCode.String &amp; '). ' &amp; app.getErrorString(exObj.errorCode);
		else
			errStr := 'Error (' &amp; exObj.errorCode.String &amp; '). ' &amp; exObj.text;
		endif;
		app.writeLog(errStr, LogINFO);
	endif;

	if (not exObj.isKindOf(LockException) and not app.isJMTUnitTest) then
		// message handled above
		app.msgBox(errStr, msgTitle, MsgBox_OK_Only +MsgBox_Stop_Icon);
	endif;

	return Ex_Abort_Action;

end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="generatePinNo" id="397a994e-e703-4fae-b192-58dcbe2a9f4c">
        <source>generatePinNo(pPinNo : CM_PinNo output; pErrStr : String; _terminal : CM_Terminal) : Boolean;
// ---------------------------------------------------------------------------
// Created:     18 December 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
24 Feb 2009	cnwkpd1	PAR #18946 - Rework algorithm to generate a wider range of numbers
					that are truly random.
					Also prevent upgrade deadlocks on CM_Terminal.allPinNos collection
// 06 Nov 2023	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests reuse pinnos that are not being used.

*/

constants
	MaxTries		: Integer = 100;
	MinimumPinNo	= 1000;
	MaximumPinNo	= 9999;
	PinNoLength		= 4;
	
vars
	stringSeed		: String;
	seed,
	range,
	pinInt			: Integer;
	cnt				: Integer;
	pinNo			: CM_PinNo;
	pinStr			: String;
	embargoDays		: Integer;
	
begin
	//+cnwml2 PAR23668  if terminal config is set to No Pins do not generate pin number
	if _terminal.getConfig(NoPINs).Boolean then
		pPinNo := null;
		return false;
	endif;

	// Get a new seed using the last 9 digits of the current machine time (in microseconds)
	stringSeed := app.relativeMachineMicros().String.padZeros(20);
	seed := stringSeed[12:9].Integer;
	
	range := MaximumPinNo - MinimumPinNo;
	
	// Need to reserveLock this up front to prevent upgrade deadlocks
	reserveLock(_terminal.allPinNos);

	cnt := 0;
	//epr TFS 6680 5/9/17 moved out of loop for performance reasons
	embargoDays := _terminal.getConfig(PinEmbargoDays).Integer;
	
	while true do
		// Now letting JADE generate next seed each time around the loop, so we have a better
		// chance of getting a truly random number
		pinInt := app.random31(seed, range) + MinimumPinNo;
	
		pinStr := pinInt.String[1:PinNoLength];
		if (not _terminal.allPinNos.includesKey(pinStr)) then
			
			// 14/05/2009 cnwar2 CCMS1732/#??? - only create pin if not currently embargoed 		
		//	if embargoDays &lt;&gt; 0 and _terminal.allPinsEmbargoed.includesKey(pinStr)   then
			if _terminal.allPinsEmbargoed.includesKey(pinStr)   then	//05 Jun 2018	NDL	TFS 38940
				pinNo := _terminal.allPinsEmbargoed[pinStr];
				if pinNo.embargoedTS.addDays(embargoDays) &lt; app.actualTimeServer then
					pinNo.embargoedTS := null;		// embargo period has expired, reset pin
					pinNo.isEmbargoed := false;
					pinNo.allItems.clear();
					pinNo.allEmailRecipients.clear();
					pPinNo := pinNo;
					pPinNo.set(pinStr, _terminal);
					break;
				endif;
			else
				create pPinNo persistent;
				pPinNo.set(pinStr, _terminal);
				break;
			endif;
		else					// 06 Nov 2023	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests reuse unused pinNos
			pinNo := _terminal.allPinNos[pinStr];
			if pinNo &lt;&gt; null and 
			   pinNo.allItems.isEmpty and
			   pinNo.allEmailRecipients.isEmpty then
				pPinNo := pinNo;
				pPinNo.set(pinStr, _terminal);
				break;
			endif;
		endif;
		
		cnt := cnt + 1;
		if cnt &gt; MaxTries then
			pPinNo := null;
			app.raiseCMException1(CANNOT_GENERATE_PIN, pErrStr, null, null);
			return false;
			break;
		endif;
	endwhile;

	return true;
	
end;</source>
        <Parameter name="pPinNo" type="CM_PinNo" usage="output"/>
        <Parameter name="pErrStr" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllInvoiceCalcTypes" id="586d90e7-312b-4958-8618-78565534b23b">
        <source>getAllInvoiceCalcTypes(_clearFirst : Boolean; _lable : Boolean; _labels : StringArray input; _values : IntegerArray input; _type : String);
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	TagLabel = "LABEL";
	TagType = "TYPE";
	TagCaption = "CAPTION";

vars
	appScm : Schema;
	category : ConstantCategory;
	const : Constant;
	terminal	: CM_Terminal;
	bank		: CM_Bank;
	calTypeValue	: Integer;
	lenTagLabel		: Integer;
	label, type : String;

begin
	if _labels = null or _values = null then
		return;
	endif;
	
	if _clearFirst then
		_labels.clear;
		_values.clear;
	endif;
	
	appScm := rootSchema.getSchema(PortSchemaName);
	if appScm = null then
		return;
	endif;
	
	category := appScm.getCategory(InvoiceCalculationTypes);
	if category = null then
		return;
	endif;

	lenTagLabel := TagLabel.length;
	
	foreach const in category.getConstants do
	
		type := const.text.String.cnEcGetTagValueOfName(TagType);
		if _type = null or type = _type then
	
			calTypeValue := const.GlobalConstant.valueAsInteger;
			if _lable then
				label := const.text.String.cnEcGetTagValueOfName(TagLabel);
				
				if calTypeValue = INV_CALC_TYPE_DAYS_ONSITE_AT then
					// 35872 use default bank of 1st terminal
					terminal := self.myRoot.allTerminals.first;
					if terminal &lt;&gt; null then							// 01/07/2015 cnwmh5
						bank := terminal.getDefaultCompanyBank();
						if bank &lt;&gt; null then
							label := label &amp; " " &amp; bank.onsiteStorageChargeTime.String;
						endif;
					endif;
				endif;
			else
				label := const.text.String.cnEcGetTagValueOfName(TagCaption);
			endif;
	
			_labels.add(label);
			_values.add(calTypeValue);
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_clearFirst" type="Boolean"/>
        <Parameter name="_lable" type="Boolean"/>
        <Parameter name="_labels" type="StringArray" usage="input"/>
        <Parameter name="_values" type="IntegerArray" usage="input"/>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllWindowDetails" id="7d958f75-abd4-476e-9b2d-e1725d26dd97">
        <source>getAllWindowDetails() : String;
// ---------------------------------------------------------------------------
// Created:     16 September 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	numForms,
	idx		: Integer;
	tmpForm	: Form;
	tmpStr	: String;
begin
	numForms	:= app.formsCount;
	
	foreach idx in 1 to numForms do
		tmpForm := app.forms(idx);
		if tmpStr &lt;&gt; null then
			tmpStr := tmpStr &amp; CrLf;
		endif;
		tmpStr := tmpStr &amp; tmpForm.class.name &amp; Tab &amp; tmpForm.caption;
	endforeach;
	
	return tmpStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAppServerLogDir" id="e442ff8a-3e82-43c4-b9d8-731c59abe729">
