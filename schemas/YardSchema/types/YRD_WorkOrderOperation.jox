    <JadeMethod name="doBuildMenuWorkOrders" id="8ff9d8df-62e7-4d82-ac84-a80d540dcff6">
        <source>doBuildMenuWorkOrders(_selectedObj : Object);
/*
 
Purpose:			
 
Parameters:			
 
Return Value:		
 
Date		Who		Reason
18 Dec 2024	navbs1	Initial Creation Bug MTN-33554: EUP | 53729 - Show Work Order for multiple Work Orders
 
*/
 
vars
	mnuChild,
	mnuMaster	: MenuItem;
	mnuIndex	: Integer;
	woSet 		: CM_WorkOrderSet;
	wo 			: CM_WorkOrder;
 
begin
	create woSet transient;
	
	_selectedObj.CM_Job.getWorkOrders(woSet);
	
	mnuMaster := self.mnuWorkOrder;

	foreach wo in woSet do							
		mnuIndex := mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex); 		
		if mnuChild = null then
			mnuChild := mnuMaster.loadSubMenu(mnuIndex); 	
		endif;
		mnuChild.caption 	:= wo.id;
		mnuChild.visible 	:= true;
		mnuChild.enabled 	:= true;
		mnuChild.userObject := wo;
	endforeach;
	
	while true do
		mnuIndex := mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex);
		if mnuChild = null then
			break;
		endif;
		delete mnuChild;
	endwhile;
	
epilog
	delete woSet;
end;</source>
        <Parameter name="_selectedObj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuJobSheet" id="13f04eed-98d8-494a-b826-a2c1755c0f48">
        <source>doBuildMnuJobSheet(_objArr : ObjectArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2023	navhl20	ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
04 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 
20 Oct 2023 navhl20 ChangeRequest 60090: EUP | Ship Operations in DD - [54176.020] -[Receive] Allocate Jobs to Gangs and Gangs to Holds
27 Oct 2023 navhl20 ChangeRequest 60037: EUP | Ship Operations in DD - [54176.030] - [Receive] Additional Job Details
15 Dec 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
29 Mar 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work
09 Jul 2024	navbs1	ChangeRequest 64778: EUP | Delivery Dispatch Multi Select Search
27 Sep 2024	navnk30	Bug 66107: MTN | Work Order Operations Permissions
25 Feb 2025 navma1  MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
25 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.
*/

vars
	mnuChild,
	mnuMaster	 : MenuItem;
	mnuIndex	 : Integer;	
	jobsheet 	 : CM_WorkPointJobSheet;
	showMenu	 : Boolean;
	job			 : CM_Job;
	jobSheetDict : CM_WPJobSheetByDate;
begin
	if _objArr.isEmpty() then
		self.mnuAllocateJobSheet.visible := false;
		return;
	endif;
	
	if self.operationMode = app.getErrorString(WO_Ship) then				//27.10.2023 navhl20 #60037	//25.03.2025 navhl20 #34425
		if self.tblJobsUnallocated.allSelectedObjects.size &gt; 1 then			//25.02.2025 navma1 #MTN-34075
			self.mnuAllocateJobSheet.visible := false;
			return;
		endif;
	endif;
	
	showMenu 		  			   := false;
	mnuMaster 		  			   := self.mnuAllocateJobSheet;
	mnuMaster.visible 			   := true;
	mnuMaster.enabled 			   := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);	//27.09.2024 navnk30 #66107
	self.mnuJobSheetSub.visible    := false;
	
	create jobSheetDict transient;
	self.myTerminal.allJobSheetsForWorkPoints.copy(jobSheetDict);									//25.02.2025 navma1 #MTN-34075
	
	foreach jobsheet in jobSheetDict discreteLock do												//25.02.2025 navma1 #MTN-34075
		if self.includeObject(null,jobsheet) then													//29.03.2024 navhl20 #63251
			showMenu := true;
			mnuIndex := mnuIndex + 1;
			mnuChild := mnuMaster.getMenuItem(mnuIndex); 		// check if the menu is already cloned
			if mnuChild = null then
				mnuChild := mnuMaster.loadSubMenu(mnuIndex); 	// clone menu
			endif;
			
			mnuChild.caption 	:= jobsheet.externalName;
			mnuChild.visible 	:= true;
			mnuChild.enabled 	:= true;
			mnuChild.userObject := jobsheet;
		endif;
	endforeach;
	
	
	while true do
		mnuIndex := mnuIndex + 1;
		mnuChild := mnuMaster.getMenuItem(mnuIndex);
		if mnuChild = null then
			break;
		endif;
		mnuChild.visible := false;
	endwhile;
	
	self.mnuAllocateJobSheet.visible := showMenu;
	
	job := _objArr.first.CM_Job;												//15.12.2023 navhl20 #61092[61621]
	self.mnuAllocateJobSheet.visible := not (showMenu = job.isRBTAllocated());	//29.03.2024 navhl20 #63251
epilog
	delete jobSheetDict;
end;</source>
        <Parameter name="_objArr" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuShiftJobs" id="f7d1064d-3154-411a-9bb0-801ba8c94b6d">
        <source>doBuildMnuShiftJobs(_table : CM_DataTable);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Jul 2023 navhl20 ChangeRequest 58333: EUP | Delivery Dispatch Screen - Split Jobs

*/

vars
	job		: CM_Job;
begin
	if _table.allSelectedObjects.size &gt; 0 then
		self.mnuShiftJobs.visible := true;
		self.mnuShiftJobs.userObject := _table;
	else
		self.mnuShiftJobs.visible := false;
	endif;
	foreach job in _table.allSelectedObjects as CM_Job where job.status = JOB_COMPLETE do
		self.mnuShiftJobs.visible := false;
	endforeach;
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuUnAllocate" id="2e80a8b3-0a96-47f6-beab-5aa0c16e33c0">
        <source>doBuildMnuUnAllocate(_objArr : ObjectArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Jun 2023	navhl20	ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs

*/

vars
	job,
	firstJob	: CM_Job;
begin
	if _objArr.size &gt; 0 then
		self.mnuUnAllocateJobs.visible := true;
		self.mnuSetPriority.visible := true;
	else
		self.mnuUnAllocateJobs.visible := false;
		self.mnuSetPriority.visible := false;
	endif;
	firstJob 	:= _objArr.first.CM_Job;
	foreach job in _objArr as CM_Job do
		if firstJob.status &lt;&gt; JOB_COMPLETE then
			continue;
		endif;
		self.mnuUnAllocateJobs.visible := false;
		
	endforeach;
epilog

end;</source>
        <Parameter name="_objArr" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="doDblClkWle" id="840a5cdb-83b5-483e-8bd7-e10cae840500">
        <source>doDblClkWle(_table : CM_DataTable);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Jan 2024 navhl20 ChangeRequest 62066: EUP | Ship Operations in DD - FR - 01

*/

vars
	wle 	: CM_WorkListEntry;
	ti		: CM_TrackedItem;
begin
	if _table.row &lt;= _table.fixedRows then
		return;
	endif;
	
	wle := _table.allSelectedObjects.first.CM_WorkListEntry;
	
	if wle &lt;&gt; null then
		ti := wle.myTrackedItem;
	endif;
	
	if ti &lt;&gt; null then
		self.myAssistant.showCargoEnquiryForm(ti, self.myMasterMenuAction, true, false);
	endif;
epilog
	
end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doFilterTable" id="08385e4b-c648-4701-90e2-cd67e9e7f570">
        <updating/>
        <source>doFilterTable(_tbl : CM_DataTable; _txt : CMUI_TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Jun 2023 navhl20 ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
*/

vars
	filterText 	: String;
	rowIdx,
	colIdx,
	start,
	rows		: Integer;
	cell 		: JadeTableCell;
	cellText 	: String;
	tbl			: CM_DataTable;
	
begin
    rows		:= 0;
	filterText  := _txt.text.toUpper();	
	tbl			:= _tbl;
	
	if filterText = "" then
		self.clearFilterTbl(tbl,_txt);
		return;
	endif;
	
	start := tbl.fixedRows + 1;

	foreach rowIdx in start to tbl.rows do : rowLoop
		tbl.accessRow(rowIdx);
		
		foreach colIdx in 1 to tbl.columns do
			cell 	 := tbl.accessCell(rowIdx, colIdx);
			cellText := cell.text.toUpper;
			
			if cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then   
				tbl.accessedRow.visible := true;
				rows := rows+1;
				continue rowLoop;
			endif;
		endforeach;
		
		tbl.accessedRow.visible := false;
	endforeach;
	
	if rows = 0 then 
		self.tblInfo.rows := 0;          
	endif;
epilog

end;</source>
        <Parameter name="_tbl" type="CM_DataTable"/>
        <Parameter name="_txt" type="CMUI_TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doHideCriteria" id="9296fd6d-21c9-4d78-9b73-f801dd692829">
        <source>doHideCriteria();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Aug 2023 navhl20 ChangeRequest 59216: EUP | Delivery Dispatch - Adding Splitter to resize tables

*/

vars

begin
	self.grpFilter.visible 		:= false;
	self.grpJobs.top 			:= self.grpFilter.top+ 5;
	self.grpJobs.parentAspect 	:= 3;
	self.grpJobs.height 		:= self.grpJobs.height + 183;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doHideJobDetails" id="43a41498-ec3f-4f58-a6a3-ee9aace6d76c">
        <source>doHideJobDetails();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Jul 2023	navma1	ChangeRequest 59151: EUP | Delivery Dispatch - Hide Job Details
29 Aug 2023 navhl20 ChangeRequest 59216: EUP | Delivery Dispatch - Adding Splitter to resize tables
20 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.
*/

vars
	
begin
	self.tblWlesAllocated.visible 	 	:= false;
	self.tblWlesUnallocated.visible		:= false;
	self.dkbAllocBottom.minimumHeight	:= 0;
	self.dkbUnAllocBottom.minimumHeight	:= 0;
	/*
	incease table height
	*/
	self.dkbUnAllocTop.height 			:= self.dkbUnAllocTop.height + self.dkbUnAllocBottom.height;			//29.8.2023 navhl20 #59216
	self.dkbAllocTop.height   			:= self.dkbAllocTop.height + self.dkbAllocBottom.height;				//29.8.2023 navhl20 #59216
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuAllocateJob" id="1785d988-e7fe-4410-a0da-609aed21928c">
        <updating/>
        <source>doMnuAllocateJob(_jobSheet : CM_WorkPointJobSheet)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2023	navhl20	ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
04 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 
27 Oct 2023 navhl20 ChangeRequest 60037: EUP | Ship Operations in DD - [54176.030] - [Receive] Additional Job Details
21 Nov 2023	navmd1	TFS 61353 Make sure the jobs selected at the time of right clicking are the ones actually allocated
23 Nov 2023 navhl20 ChangeRequest 61361:[61424] MTN - Work Hold Jobs on Job Lander [React Version]
29 Nov 2023 navhl20 ChangeRequest 61510: EUP | Ship Operations in DD - [54176.020] - [Release] Allocate Jobs to Gangs and Gangs to Holds
20 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.
11 Apr 2025	navhl20 Bug MTN-34629: MTN | Getting 1090 When trying to Complete Job - Ship Receive WorkOrder
20 Jun 2025 navtr3  Bug MTN-35057: MTN - Error 4 Work Order Operation Screen
*/

vars
	pxyJobSheet		: CM_WorkPointJobSheet;
	allJobArr		: CM_JobSet;
	obj,
	job				: CM_Job;
	result			: Integer;
	voyage			: CM_Voyage;
	tblSelectedObjs	: ObjectArray;
	voyWPJob		: CM_VoyageWorkPointJob;
	jobArr			: CM_JobArray;	
	edition 		: Integer;
	invalidObj		: Boolean;
begin
	on Exception do app.handleDeletedObject(exception,obj, invalidObj);  									//20.06.2025 navtr3 #35057
	
	tblSelectedObjs := self.tblJobsUnallocated.allSelectedObjects;
	if _jobSheet = null or tblSelectedObjs.isEmpty then
		return;
	endif;
	
	// Save off the currently selected jobs in case the user pauses at the dialog for a while
	create allJobArr transient;
	foreach obj in tblSelectedObjs as CM_Job do
		edition := obj.edition;																				//20.06.2025 navtr3 #35057
		if invalidObj then // skip if object was deleted
			invalidObj := false;
			continue;
		endif;
	
		allJobArr.addNoDuplicates(obj,false);
	endforeach;
	
	if allJobArr.isEmpty then  // Check if we have any valid jobs left										//20.06.2025 navtr3 #35057
		return;
	endif;
		
	job := allJobArr.first;																					//20.03.2025 navhl20 #34425
	
	if not job.isShipJob() then																				//8.11.2023 navhl20 #60037	//25.03.2025 navhl20 #34425 	//11.04.2025 navhl20 #34629
		if app.msgBox(app.getErrorString1(Sure_want_alloca_select_jobs,_jobSheet.externalName), self.mnuAllocateJobSheet.caption , MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
			return;
		endif;
	endif;
		
	if job.isShipJob() then																					//27.10.2023 navhl20 #60037	//25.03.2025 navhl20 #34425 	//11.04.2025 navhl20 #34629
		voyage	:= job.getMyVoyage();
		jobArr := job.getAllVoyJobs();																		//20.03.2025 navhl20 #34425
		foreach voyWPJob in jobArr as CM_VoyageWorkPointJob discreteLock do									//23.11.2023 navhl20 #61361[61424]
			if voyWPJob.myJobSheetForWorkPoint = _jobSheet and not voyWPJob.status = JOB_COMPLETE then      //18.12.2023 navma1	 #61361[61424]
				app.raiseCMException2(Already_assigned_gang,job.id,_jobSheet.externalName,null,self);
			endif;
		endforeach;
		self.showJobUpdateForm(_jobSheet,job,voyage,YRD_WorkOrderUpdateJob.TO_GANG_CREATE);
	else
		pxyJobSheet := app.createUpdateProxy(_jobSheet).CM_WorkPointJobSheet;
		while true do
			app.myTrxUA.trxUpdateWOJobSheet(allJobArr,pxyJobSheet,app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				break;
			else
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			return;
		endwhile;
	endif;
epilog
	delete pxyJobSheet;
	delete allJobArr;
end;</source>
        <Parameter name="_jobSheet" type="CM_WorkPointJobSheet"/>
    </JadeMethod>
    <JadeMethod name="doMnuFormContextMenu" id="25aa7b1b-9f6d-477a-a10c-1f3f359730a3">
        <updating/>
        <source>doMnuFormContextMenu(table : CM_DataTable input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023	navhl20	ChangeRequest 57766:[57767] EUP - Delivery Dispatch – Define Job Sheet
22 May 2023 navhl20 ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate
25 May 2023 navhl20 ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
16 Jun 2023 navhl20 ChangeRequest 58344: EUP | Delivery Dispatch Screen - VAS Operation 
05 Jul 2023 navhl20 ChangeRequest 58333: EUP | Delivery Dispatch Screen - Split Jobs
18 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting
29 Aug 2023 navhl20 ChangeRequest 59216: EUP | Delivery Dispatch - Adding Splitter to resize tables
01 Sep 2023 navma1	ChangeRequest 60213: EUP | Delivery Dispatch - Enable Split Job on UnAllocation Tab
15 Sep 2023 navlc30 ChangeRequest 60211: EUP | Delivery Dispatch Colour Legend
01 Nov 2023 navhl20 ChangeRequest 60091: EUP | Ship Operations in DD - [54176.040] - [Receive] Allocation List
28 Nov 2023 navhl20 ChangeRequest 61508: EUP | Ship Operations in DD - [54176.010] - [Release] Ship Job List
13 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
16 Jan 2023 navhl20 ChangeRequest 62066: EUP | Ship Operations in DD - FR - 01
09 Feb 2023 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
11 Mar 2024 navhl20 ChangeRequest 60097: EUP | Ship Operations in DD - [54176.060] - [Receive] Retrospective Operations
13 Mar 2024 navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
18 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
20 Mar 2024 navnk30	Bug 62770: EUP - 1090 exception when clicking on the Instructions button on the Complete To Do Tasks form
27 Mar 2024 navhl20 Defect 63197: 1090 exception when completing the todo job
12 Apr 2024 navhl20 ChangeRequest 63583: EUP | 54014 - Cargo Work Orders Enhancements - Remedial
07 Aug 2024 navhl20	Bug 65424: EUP | 53729 - WO Jobs - Split Pack or Unpack job issues
26 Sep 2024 navhl20	ChangeRequest 14712: EUP - FR | 54176 - Ship operations in Delivery Dispatch screen (retrospective) - 1
26 Nov 2024 navbs1	Bug MTN-33482: EUP - Getting 1090 Error when completing Job From Unallocated tab
09 Dec 2024	navbs1	Bug MTN-33554: EUP | 53729 - Show Work Order for multiple Work Orders
20 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.
*/

vars
	isShowDataMenusJ,
	isShowDataMenusAW,
	isShowDataMenusUW,
	isShowDataMenusU,
	isShowDataMenusA	: Boolean;
	isDataValidRow		: Boolean;
	x1, y1				: Real;
begin
	if table = self.tblJobSheet then
		isShowDataMenusJ	:=	table = self.tblJobSheet;
	elseif table = self.tblJobsAllocated then
		isShowDataMenusA	:=	table = self.tblJobsAllocated;
	elseif table = self.tblJobsUnallocated then
		isShowDataMenusU	:=	table = self.tblJobsUnallocated;
	elseif table = self.tblWlesUnallocated then
		isShowDataMenusUW	:=	table = self.tblWlesUnallocated;
	elseif table = self.tblWlesAllocated then
		isShowDataMenusAW	:=	table = self.tblWlesAllocated;
	endif;
	
	self.mnuColOrganiser.visible	:= true;
	self.mnuColOrganiser.userObject := table;
	self.setDefaultVisiblity();
	
	if app.isAllowedToInspect and table.allSelectedObjects.isNotEmpty() then		//22.5.2023 navhl20 #57714[57764]
		self.mnuInspect.visible    := true;
		self.mnuInspect.userObject := table;
	endif;
	
	if isShowDataMenusJ then
		isDataValidRow	:=	(table.row &gt; table.fixedRows);
	endif;
	
	if isShowDataMenusJ then														//29.8.2023 navhl20 #59216
		self.mnuAddJobSheet.visible := true;
	endif;
	
	if isShowDataMenusU then														//25.5.2023 navhl20 #57747[57748]
		self.doBuildMnuJobSheet(table.allSelectedObjects);
		self.mnuLegendUnAllocated.visible := true;
	endif;
	
	if isShowDataMenusU or isShowDataMenusA then										//01.09.2023 navma1 #60213
		self.setShowMenus(table);														//20.03.2025 navhl20 #34425
	endif;

	x1	:=	x;
	y1	:=	y;
	
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1	:=	1;
	    y1	:=	1;
	endif;

	table.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	self.popupMenu(self.mnuWOOperation, x1.Integer, y1.Integer);
	return false;
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuInspectObject" id="41497fea-571c-4d7a-a423-24b653a44aea">
        <source>doMnuInspectObject();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navhl20	ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate

*/

vars
	anObject 	: Object;
	tbl			: CM_DataTable;
begin
	tbl := self.mnuInspect.userObject.CM_DataTable;
	if tbl.row &gt; tbl.fixedRows then
		anObject := tbl.accessRow(tbl.row).itemObject;
		if anObject &lt;&gt; null then
			anObject.inspect;
			return;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuReprint" id="fdc08e84-6266-495b-87de-8144d569fb67">
        <updating/>
        <source>doMnuReprint(_job : CM_Job) updating;
/*
Purpose:			Reprint the Driver Instructions for the selected Job

Parameters:			

Return Value:		

Date		Who		Reason
12 Apr 2024 navhl20 ChangeRequest 63583: EUP | 54014 - Cargo Work Orders Enhancements - Remedial
*/
vars
	printCopies			: Integer;
	printConfirm		: CMUI_Modal;
	vvr					: CM_VehicleVisitRecord;
	reportName,
	printerName			: String;
	msg					: String;
	defaultPrinterName 	: String;
	scm					: Schema;
	assistantClass,
	frmClass			: Class;
	form 				: Form;
begin
	if _job = null then
		return;
	endif;
	
	defaultPrinterName := app.printer.getPrinterName;
	
	vvr := _job.CM_RoadJob.myVehicleVisit.CM_VehicleVisitRecord;
	printCopies := 1;
	
	scm := rootSchema.getSchema('GateSchema');
	frmClass := scm.getClass('GTE_PrintConfirmationForm');
	assistantClass := scm.getClass('GTE_Assistant');
	
	if self.myTerminal.getConfig(DisplayPrintConfirmation).Boolean then
		form := app.loadForm(frmClass, assistantClass, false, false, true, self.myTerminal, self.myMasterMenuAction);
		if form = null then
			return;
		endif;
		form.sendMsgWithParams("setPrintDetails", printCopies,printerName,self);
		printCopies := form.showModal();
	endif;
	
	if printCopies &gt; 0 then 
		reportName := myTerminal.getConfig(GateReprintDriverIns).String;
		if reportName = null then
			reportName := DefRep_GateReprintDriverInst;
		endif;
		if not app.validatePrinterName( printerName, true, true ) then
			msg := app.getErrorString1( Printer_not_known_locally_2, printerName);
			app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only );
			printerName := null;
		endif;
		
		vvr.reprintDriverDetails(printCopies, self.myTerminal.getConfig(PrintPreview).Boolean, self.myTerminal, reportName, null, printerName);
	endif;
		
epilog
	app.printer.setPrinter( defaultPrinterName );
end;</source>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="doMnuSendToReportWO" id="a0d2a359-f3a7-4765-9c91-3fd5db1a3354">
        <updating/>
        <source>doMnuSendToReportWO(_selectedOnly : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting

*/

vars
	objArray : ObjectArray;
begin
	// Report writer throws exceptions when in transaction state.
	// Added flag to app to ignore any transaction calls that are not in 
	// the trx layer (Eg, CM_Charge.evaluateRate).
	app.isReportWriter := true;
	
	create objArray transient;
	
	self.getWOForReport(objArray, _selectedOnly);
	
	self.doSendToReport(objArray);
epilog
	delete objArray;
	app.isReportWriter := false;
end;</source>
        <Parameter name="_selectedOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuSetPriorityClick" id="b3d18529-c1d6-45b8-ad45-909a339e37c0">
        <updating/>
        <source>doMnuSetPriorityClick(_menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
02 Jun 2023 	navlw1 	CHangeRequest 58294: EUP | Delivery Dispatch Screen - Setting Priority

*/

vars
	jobArray 	: CM_JobArray;
	priority 	: Integer;
	theResult 	: Integer;
	obj 		: CM_Job;
begin
	if _menuItem = self.mnuSetPriority then
		return;
	endif;
	
	priority := _menuItem.caption.asIntegerJMT();
	
	if priority = null then
		return;
	endif;
	
	create jobArray transient;
	foreach obj in self.tblJobsAllocated.allSelectedObjects as CM_Job do
		jobArray.add(obj);
	endforeach;
	
	if jobArray.isEmpty() then
		return;
	endif;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
		app.myTrxUA.trxUpdateJobPriority(jobArray, priority, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(self.mnuSetPriority.caption, app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
	endwhile;
	
	_menuItem.checked := not _menuItem.checked;
	
epilog
	delete jobArray;
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuUnallocateJob" id="20dee9c9-089e-4f68-b4fc-4be3043fcda9">
        <updating/>
        <source>doMnuUnallocateJob()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2023	navhl20	ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
21 Nov 2023	navmd1	TFS 61353 Make sure the jobs selected at the time of right clicking are the ones actually unallocated
18 Jan 2024 navhl20 ChangeRequest 62066: EUP | Ship Operations in DD - FR - 01
25 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.
*/

vars
	allJobArr		: CM_JobSet;
	obj				: CM_Job;
	result			: Integer;
	tblSelectedObjs	: ObjectArray;
	mode			: Integer;
begin
	mode := self.operationModeInt;																		//25.03.2025 navhl20 #34425
	
	if mode = YRD_WorkOrderOperation.Mode_SHIP then														//18.01.2024 navhl20 #62066
		obj := self.tblJobsAllocated.allSelectedObjects.first.CM_Job;
		if app.msgBox(app.getErrorString(Sure_want_unall_selec_jobs_fro), self.mnuUnAllocateJobs.caption , MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
			return;
		endif;
		while true do
			app.myTrxDA.trxDeleteJob(obj,app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				break;
			else
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			return;
		endwhile;
	else
		tblSelectedObjs := self.tblJobsAllocated.allSelectedObjects;
		if tblSelectedObjs.isEmpty then
			return;
		endif;
		
		// Save off the currently selected jobs in case the user pauses at the dialog for a while
		create allJobArr transient;
		foreach obj in tblSelectedObjs as CM_Job do
			allJobArr.addNoDuplicates(obj,false);
		endforeach;
		
		if app.msgBox(app.getErrorString(Sure_want_unall_selec_jobs_fro), self.mnuUnAllocateJobs.caption , MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
			return;
		endif;
			
		while true do
			app.myTrxUA.trxUpdateWOJob(allJobArr,app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				break;
			else
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			return;
		endwhile;
	endif;
epilog
	delete allJobArr;
end;</source>
    </JadeMethod>
    <JadeMethod name="doModeChange" id="b6694318-43f3-49c8-bf7f-f2e21bce6d01">
        <updating/>
        <source>doModeChange(_cmb : CMUI_ComboBox)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2023	navhl20	ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
07 Jun 2023 navhl20 ChangeRequest 57745: EUP - Delivery Dispatch – Allocation List - Road
15 Jun 2023 navhl20 ChangeRequest 57762: EUP - Delivery Dispatch – Un Allocated Pack/UnPack
21 Jun 2023 navhl20 ChangeRequest 58767: EUP - Delivery Dispatch – Allocation List - Pack unpack
21 Jun 2023	navhl20	ChangeRequest 58769: EUP - Delivery Dispatch – Job’s Cargo Details - Pack unpack
22 Jun 2023 navhl20 ChangeRequest 57758: EUP - Delivery Dispatch – Un Allocated Rail
22 Jun 2023 navhl20 ChangeRequest 58771: EUP - Delivery Dispatch – Job’s Cargo Details - Rail
22 Jun 2023 navhl20 ChangeRequest 58765: EUP - Delivery Dispatch – Allocation List - Rail
04 Jul 2023 navhl20 Defect 58906: MTN - The Allocated and Unallocated list is not refreshing correctly using the filter criteria
03 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 
16 Oct 2023 navhl20 Bug 60863: EUP - Delivery Dispatch Remedial [1]
31 Oct 2023 navhl20 ChangeRequest 60091: EUP | Ship Operations in DD - [54176.040] - [Receive] Allocation List
31 Jan 2023 navhl20 ChangeRequest 62166: EUP | 53729 - Delivery Dispatch Screen - outstanding issues
17 Jun 2024 navhl20 ChangeRequest 64684: EUP - Add new filter criteria in Work Order Operations.
21 Jun 2024 navhl20 ChangeRequest 64602: EUP - FR | 54177 - Retrospective Operations
28 Jun 2024 navbs1  CR 64897 Task 64898: UI - Operation Combo add ALL
01 Jul 2024 navhl20	Bug 64958: MTN - Voyage combo incorrect in Work Order Operations screen
05 Mar 2025 navbs1	Story MTN-34213: MTN - Work Order Operations screen loading data twice on start-up
20 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.
*/

vars
	mode			: Integer;
begin
	if _cmb.listIndex &gt; -1 then
		mode := _cmb.itemData[_cmb.listIndex];
	endif;
	self.operationModeInt := mode;																				//25.03.2025 navhl20 #34425
	self.showShipFilter(false);																					//04.10.2023 navhl20 #60033
	self.showRoadFilter(false);																					//31.01.2023 navhl20 #62166
	self.showTransFilter(mode);																					//17.06.2024 navhl20 #64684
	
	if mode = YRD_WorkOrderOperation.Mode_TODO then
		self.loadTableView(self.tblJobsUnallocated,ETDef_WoJobUnAllocated,ETView_WoJobUnAllocatedToDo);
		self.loadTableView(self.tblJobsAllocated,ETDef_WoJobAllocated,ETView_WoJobAllocatedToDo);
		self.loadTableView(self.tblWlesUnallocated,ETDef_WoJobWle,ETView_WoJobWleToDo);
		self.loadTableView(self.tblWlesAllocated,ETDef_WoJobWle,ETView_WoJobWleToDo);
	elseif mode = YRD_WorkOrderOperation.Mode_ROAD then															//08.6.2023 navhl20 #57745
		self.showRoadFilter(true);																				//31.01.2023 navhl20 #62166
		self.buildCmbTruckStatus();																				//31.01.2023 navhl20 #62166
		self.loadTableView(self.tblJobsUnallocated,ETDef_WoJobUnAllocated,ETView_WoJobUnAllocatedRoad);
		self.loadTableView(self.tblJobsAllocated,ETDef_WoJobAllocated,ETView_WoJobAllocatedRoad);
		self.loadTableView(self.tblWlesUnallocated,ETDef_WoJobWle,ETView_WoJobWleRoad);
		self.loadTableView(self.tblWlesAllocated,ETDef_WoJobWle,ETView_WoJobWleRoad);
	elseif mode = YRD_WorkOrderOperation.Mode_PACKUNPACK then													//15.6.2023 navhl20 #57762
		self.loadTableView(self.tblJobsUnallocated,ETDef_WoJobUnAllocated,ETView_WoJobUnAllocatedPack);
		self.loadTableView(self.tblJobsAllocated,ETDef_WoJobAllocated,ETView_WoJobAllocatedPack);				//21.6.2023 navhl20	#58767
		self.loadTableView(self.tblWlesUnallocated,ETDef_WoJobWle,ETView_WoJobWlePack);							//21.6.2023 navhl20	#58769
		self.loadTableView(self.tblWlesAllocated,ETDef_WoJobWle,ETView_WoJobWlePack);							//21.6.2023 navhl20	#58769
	elseif mode = YRD_WorkOrderOperation.Mode_RAIL then															//22.6.2023 navhl20 #57758
		self.buildCmbTransport(false);																			//17.06.2024 navhl20 #64684
		self.loadTableView(self.tblJobsUnallocated,ETDef_WoJobUnAllocated,ETView_WoJobUnAllocatedRail);
		self.loadTableView(self.tblJobsAllocated,ETDef_WoJobAllocated,ETView_WoJobAllocatedRail);				//22.6.2023 navhl20 #58765
		self.loadTableView(self.tblWlesUnallocated,ETDef_WoJobWle,ETView_WoJobWleRail);							//22.6.2023 navhl20 #58771
		self.loadTableView(self.tblWlesAllocated,ETDef_WoJobWle,ETView_WoJobWleRail);							//22.6.2023 navhl20 #58771
	elseif mode = YRD_WorkOrderOperation.Mode_SHIP then															//03.10.2023 navhl20 #60033
		self.buildCmbTransport(false);																			//01.07.2024 navhl20 #64958
		self.showShipFilter(true);	
		self.loadTableView(self.tblJobsUnallocated,ETDef_WoJobUnAllocated,ETView_WoJobUnAllocatedShip);
		self.loadTableView(self.tblJobsAllocated,ETDef_WoJobAllocated,ETView_WoJobAllocatedShip);				//31.10.2023 navhl20 #60091
		self.loadTable(self.tblWlesUnallocated,ETDef_WoJobWle);
		self.loadTable(self.tblWlesAllocated,ETDef_WoJobWle);
	else																										//28.06.2024 navbs1 CR 64897 Task 64898
		self.loadTableView(self.tblJobsUnallocated,ETDef_WoJobUnAllocated,ETView_WoJobUnAllocatedAll);
		self.loadTableView(self.tblJobsAllocated,ETDef_WoJobAllocated,ETView_WoJobAllocatedAll);
		self.loadTableView(self.tblWlesUnallocated,ETDef_WoJobWle,ETView_WoJobWleAll);
		self.loadTableView(self.tblWlesAllocated,ETDef_WoJobWle,ETView_WoJobWleAll);
	endif;
	
	self.loadtblWorkPointTypes();																				//09.07.2024 navbs1 #64778
	self.buildCmbJobType();
	self.operationMode := self.cmbMode.text;																	//25.03.2025 navhl20 #34425
epilog

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox"/>
    </JadeMethod>
    <JadeMethod name="doNoteHandlingObject" id="086f4ace-1062-40c7-87fb-205bd7ceaff4">
        <updating/>
        <source>doNoteHandlingObject(_notificationObj: CMIF_NotificationRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/03/2025	navkc1 JIRA Story MTN-34154: MTN | Work Order Operations - Handle Notifications
25 Aug 2025 navhl20 Story MTN-35317: MTN | Pagination - Work Order Operations
28 Aug 2025 navhl20 Bug MTN-35804: Notifications are not handled on the Work Order Operations form and Work Order Enquiry form
*/

vars
	idx				: Integer;
	done,
	invalidObject,
	isAllocatted	: Boolean;
	theDataLine  	: String;
	tbl,
	tblWle			: CM_DataTable;
	job,
	jobChild		: CM_Job;
	wle				: CM_WorkListEntry;
	isAddable		: Boolean;
	selMode			: Integer;
	jobWo			: CM_Job;
	wod				: CM_WorkOrderTIDtl;
	theObj			: Object;
	eventType		: Integer;
	row				: Integer;
begin
	
	theObj := _notificationObj.myObject;
	eventType := _notificationObj.eventType;
	
	selMode := self.cmbMode.itemData[self.cmbMode.listIndex]; //27/05/2025	navkc1 JIRA MTN 34904
	
	on Exception do app.handleDeletedObject(exception, theObj, invalidObject);
	
	if theObj.isKindOf(CM_Job) then
		
		job := theObj.CM_Job;		
		tbl := self.tblJobsUnallocated;
		
		if job.myJobSheetForWorkPoint &lt;&gt; null then
			isAllocatted := true;
			tbl := self.tblJobsAllocated;
		endif;
		
		if eventType = Object_Update_Event or 
			eventType = self.myTerminal.getTerminalEvent(Object_Update_Event) or
			eventType = self.myTerminal.getTerminalEvent(WorkOrderJob_Update_Event) then
			if selMode = YRD_WorkOrderOperation.Mode_ALL or (selMode &lt;&gt; YRD_WorkOrderOperation.Mode_SHIP and job.isJobMatchingMode(selMode)) then
				
				if isAllocatted then
					if self.tblJobsUnallocated.allSelectedObjects.first = job then						//04.09.2025 navhl20 #35317
						self.tblWlesUnallocated.clearAllData;
					endif;
					self.tblJobsUnallocated.removeItemObject(job);
					self.allUnAllocatedJobs.tryRemove(job);												//25.08.2025 navhl20 #35317
				elseif not isAllocatted then
					if self.tblJobsAllocated.allSelectedObjects.first = job then						//04.09.2025 navhl20 #35317
						self.tblWlesAllocated.clearAllData;
					endif;
					self.tblJobsAllocated.removeItemObject(job);
					self.allAllocatedJobs.tryRemove(job);
				endif;
				
				if not tbl.findObjectInRow(job, idx) and (not self.allAllocatedJobs.includes(job) or not self.allUnAllocatedJobs.includes(job)) then
					if self.includeObject(job, null) then
						theDataLine := job.getAttributeStringForDefArray(tbl.allTblDataEntRows);
						tbl.addItemObject(job, theDataLine);
						if tbl = self.tblJobsAllocated then													//25.08.2025 navhl20 #35317
							self.allAllocatedJobs.tryAdd(job);
						else
							self.allUnAllocatedJobs.tryAdd(job);
						endif;
					endif;
				else
					if not job.canBeIncludedOnWOO() then
						tbl.removeItemObject(job);
						if tbl.allSelectedObjects.first = job then										//04.09.2025 navhl20 #35317
							self.tblWlesAllocated.clearAllData;
							self.tblWlesUnallocated.clearAllData;
						endif;
						if self.allUnAllocatedJobs.includes(job) then									//04.09.2025 navhl20 #35317
							self.allUnAllocatedJobs.tryRemove(job);
						elseif self.allAllocatedJobs.includes(job) then									//04.09.2025 navhl20 #35317
							self.allAllocatedJobs.tryRemove(job);
						endif;
					elseif tbl.findObjectInRow(job,idx) then
						tbl.setCellText(idx, 1, job.getAttributeStringForDefArray(tbl.allTblDataEntRows));
					endif;
				endif;
				
				idx:=0;
				if tbl.findObjectInRow(job, idx) then
					
					row := tbl.row; // 04/07/2025	navkc1	MTN-34619
					
					if job.myJobSheetForWorkOrder = null then
						tbl.removeItemObject(job);
						
						// 04/07/2025	navkc1	MTN-34619 Also refresh the WLE table if it's showing WLEs of the delete job
						if idx = row and tbl.allSelectedObjects.first = job then						//04.09.2025 navhl20 #35317
							if tbl = self.tblJobsAllocated then
								self.tblWlesAllocated.resetColumns(true);
							else
								self.tblWlesUnallocated.resetColumns(true);
							endif;
						endif;
					else
						self.setRowColourForWorkPoint(tbl, job, idx);
					endif;
				endif;
						
			elseif job.isJobMatchingMode(selMode) then
				if isAllocatted then
					tbl := self.tblJobsAllocated;
					if job.isKindOf(CM_VoyageWorkPointJob) then
						if job.CM_VoyageWorkPointJob.myWorkOrderReceiveJob &lt;&gt; null then
							jobWo := job.CM_VoyageWorkPointJob.myWorkOrderReceiveJob;
						else
							jobWo := job.CM_VoyageWorkPointJob.myWorkOrderReleaseJob;
						endif;
					endif;
					if tbl.findObjectInRow(job, idx) then
						tbl.setCellText(idx, 1, job.getAttributeStringForDefArray(tbl.allTblDataEntRows));
						self.setRowColourForWorkPoint(tbl , job, idx);
					elseif not self.allAllocatedJobs.includes(job) then														//28.08.2025 navhl20 #35804
						theDataLine := job.getAttributeStringForDefArray(tbl.allTblDataEntRows);
						tbl.addItemObject(job, theDataLine);
						self.allAllocatedJobs.tryAdd(job);
					endif;
					if jobWo &lt;&gt; null then
						tbl := self.tblJobsUnallocated;
						if tbl.findObjectInRow(jobWo, idx) then
							tbl.setCellText(idx, 1, jobWo.getAttributeStringForDefArray(tbl.allTblDataEntRows));
							self.setRowColourForWorkPoint(tbl , jobWo, idx);
						endif;
						if not jobWo.canBeIncludedOnWOO() then
							if tbl.allSelectedObjects.first = jobWo then											//04.09.2025 navhl20 #35317
								self.tblWlesAllocated.clearAllData;
								self.tblWlesUnallocated.clearAllData;
							endif;
							tbl.removeItemObject(jobWo);
							self.allUnAllocatedJobs.tryRemove(jobWo);												//25.08.2025 navhl20 #35317
						endif;
					else
						tbl := self.tblJobsUnallocated;
						if tbl.findObjectInRow(job, idx) then
							tbl.setCellText(idx, 1, job.getAttributeStringForDefArray(tbl.allTblDataEntRows));
							self.setRowColourForWorkPoint(tbl , job, idx);
						endif;
						if not job.canBeIncludedOnWOO() then
							if tbl.allSelectedObjects.first = job then												//04.09.2025 navhl20 #35317
								self.tblWlesAllocated.clearAllData;
								self.tblWlesUnallocated.clearAllData;
							endif;
							tbl.removeItemObject(job);
							self.allUnAllocatedJobs.tryRemove(job);													//25.08.2025 navhl20 #35317
						endif;
					endif;
				endif;
				
				tbl := self.tblJobsUnallocated;
				if not job.isVoyageWorkpointJob then
					if tbl.findObjectInRow(job, idx) then
						tbl.setCellText(idx, 1, job.getAttributeStringForDefArray(tbl.allTblDataEntRows));
						self.setRowColourForWorkPoint(tbl , job, idx);
					elseif not self.allUnAllocatedJobs.includes(job) then											//01.09.2025 navhl20 #35317
						theDataLine := job.getAttributeStringForDefArray(tbl.allTblDataEntRows);
						tbl.addItemObject(job, theDataLine);
						self.allUnAllocatedJobs.tryAdd(job);
					endif;
				endif;
			endif;
			
		elseif eventType = Object_Create_Event  then
			isAddable := false;
			tbl.clearAllSelected();
			
			if job.isJobMatchingMode(selMode) or selMode = YRD_WorkOrderOperation.Mode_ALL then
				if self.includeObject(job, null) then
					theDataLine := job.getAttributeStringForDefArray(tbl.allTblDataEntRows);
					idx := tbl.addItemObject(job, theDataLine);
					if tbl = self.tblJobsAllocated then																//25.08.2025 navhl20 #35317
						self.allAllocatedJobs.tryAdd(job);
					else
						self.allUnAllocatedJobs.tryAdd(job);
					endif;
					
					self.setRowColourForWorkPoint(tbl , job, idx);
				endif;
				
				if job.isKindOf(CM_WOPackJob) then
					foreach jobChild in job.myWODtl.allJobs do
						if not jobChild.CM_WOPackJob.isPackParentJob and jobChild.id &lt;&gt; job.id then
							if tbl.findObjectInRow(jobChild, idx) then
								tbl.setCellText(idx, 1, jobChild.getAttributeStringForDefArray(tbl.allTblDataEntRows));
								break;
							endif;
						endif;
					endforeach;
				endif;
			endif;
			
		elseif eventType = Object_Delete_Event or
			eventType = self.myTerminal.getTerminalEvent(WorkOrderJob_Delete_Event)  then
			job.edition;
			if invalidObject then
				if self.tblJobsUnallocated.allSelectedObjects.first = job then									//04.09.2025 navhl20 #35317
					self.tblWlesUnallocated.clearAllData;
				endif;
				self.tblJobsUnallocated.removeItemObject(job);
				self.allUnAllocatedJobs.tryRemove(job);															//25.08.2025 navhl20 #35317
				
				if self.tblJobsAllocated.allSelectedObjects.first = job then									//04.09.2025 navhl20 #35317
					self.tblWlesAllocated.clearAllData;
				endif;
				self.tblJobsAllocated.removeItemObject(job);
				self.allAllocatedJobs.tryRemove(job);															//25.08.2025 navhl20 #35317
			endif;
		endif;
		
		self.setShtCaption(self.tblJobsUnallocated);
		self.setShtCaption(self.tblJobsAllocated);
		
	elseif theObj.isKindOf(CM_WorkListEntry)
	and self.chkJobDetail.value then
		tbl := self.tblJobsUnallocated;
		tblWle	:= self.tblWlesUnallocated;
		wle := theObj.CM_WorkListEntry;
		job := wle.job;
		
		if job &lt;&gt; null and (selMode = YRD_WorkOrderOperation.Mode_ALL or job.isJobMatchingMode(selMode)) then
			if job &lt;&gt; null and job.myJobSheetForWorkPoint &lt;&gt; null then
				tbl := self.tblJobsAllocated;
				tblWle	:= self.tblWlesAllocated;
			endif;
			
			if selMode = YRD_WorkOrderOperation.Mode_SHIP then
				if (tbl = self.tblJobsAllocated and job.isKindOf(CM_WorkOrderJob)) or
				(tbl = self.tblJobsUnallocated and job.isKindOf(CM_VoyageWorkPointJob)) then
					return;
				endif;
			endif;
			
			if job.isKindOf(CM_WOPackJob) and job.CM_WOPackJob.isPackParentJob then
				wod := job.myWODtl;
				if wod &lt;&gt; null then
					foreach jobWo in wod.allJobs where not jobWo.CM_WOPackJob.isPackParentJob do
						if job.id = jobWo.id then
							job 	:= jobWo;
							tbl 	:= self.tblJobsAllocated;
							tblWle	:= self.tblWlesAllocated;
						endif;
					endforeach;
				endif;
			endif;
			
			if tbl.allSelectedObjects.first = job then
				if tbl.findObjectInRow(job, idx) then
					tbl.setCellText(idx, 1, job.getAttributeStringForDefArray(tbl.allTblDataEntRows));
					self.setRowColourForWorkPoint(tbl , job, idx);
					idx := 0;
				endif;
				
				if tblWle.rows &gt; 1 then
					if tblWle.findObjectInRow(wle,idx) and 
					eventType = self.myTerminal.getTerminalEvent(WLE_Update_Event) /*or eventType = Object_Update_Event)*/ then //10/07/2025	navkc1 JIRA MTN 34755 - not listening to Object_Update_Event, don't need it here
						tblWle.setCellText(idx, 1, wle.getAttributeStringForDefArray(tblWle.allTblDataEntRows));
						idx := 0;
						done := true; //10/07/2025	navkc1 JIRA MTN 34755 
					elseif not tblWle.findObjectInRow(wle,idx) and 
					(eventType = self.myTerminal.getTerminalEvent(WLE_Update_Event) or //10/07/2025	navkc1 JIRA MTN 34755  also handle update event, if it's not there then add it
					eventType = self.myTerminal.getTerminalEvent(WLE_Create_Event)) /* or eventType = Object_Create_Event)*/ then //10/07/2025	navkc1 JIRA MTN 34755 - not listening to Object_Create_Event, don't need it here
						theDataLine := wle.getAttributeStringForDefArray(tblWle.allTblDataEntRows);
						idx := tblWle.addItemObject(wle, theDataLine);
						done := true; //10/07/2025	navkc1 JIRA MTN 34755 
					endif;
					if done then //10/07/2025	navkc1 JIRA MTN 34755 
						if wle.status = WLE_COMPLETED then
							tblWle.accessedRow.foreColor := White;
							tblWle.accessedRow.backColor := Grey;
						else //15/04/2025	navkc1 JIRA Defect Sub-task MTN-34620
							tblWle.accessedRow.backColor := White;
							tblWle.accessedRow.foreColor := White.getInverseColour();
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_notificationObj" type="CMIF_NotificationRecord"/>
    </JadeMethod>
