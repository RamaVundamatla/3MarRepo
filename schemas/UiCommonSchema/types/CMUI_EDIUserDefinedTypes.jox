    <JadeMethod name="loadCmbFileTypes" id="8a538823-0a4b-4253-96f4-b285aa2bb25f">
        <source>loadCmbFileTypes() protected;
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
14/07/2025		naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  		
----------   ----------  --------------------------------------------------
*/
vars
	cmb				: CMUI_ComboBox;
	iter			: Iterator;
	typeKey,
	type			: Integer;
	nameKey			: String;
	fileType		: CM_EDIFileType;
	fileTypeDict	: CM_EDIFileTypeByTypeNameDict;
begin
	cmb := self.cmbFileDef;
	cmb.clear();
	cmb.sorted := true;
	
	type := EDIFileType_UserDefined;
	fileTypeDict := app.myRoot.allEDIFileTypes;
	iter := fileTypeDict.createIterator;
	fileTypeDict.startKeyGeq(type, null, iter);
	
	while iter.next(fileType) do
		iter.getCurrentKeys(typeKey, nameKey); //MTN-35226
		if typeKey &lt;&gt; type then
			break;
		endif;
		
		cmb.itemObject[cmb.addItem(fileType.name)] := fileType;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDateDelimeter" id="86e5a014-f1b4-4bf1-aa1f-2b8e1f5b09e4">
