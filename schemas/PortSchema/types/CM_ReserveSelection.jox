    <JadeMethod name="setProxyFromCMIF" id="75a35555-7fb8-4aa4-a48f-f79f1501bfe2">
        <updating/>
        <source>setProxyFromCMIF(_controller : CMIF_BulkReleaseByType) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
06 Jul 2015	cnwkpd1	PAR #36578 - Tidy up leaked CM_Strings objects
	
*/
vars

begin
	inheritMethod(_controller);
	self.myCargoType		:= _controller.myCargoType;
	self.myISOType			:= _controller.myISOType;
	
	if _controller.isoTypeGroup &lt;&gt; null then
		self.myISOGroup := app.myRoot.allISOTypeGroups[_controller.isoTypeGroup];
	else
		if self.myISOType &lt;&gt; null then
			self.myISOGroup			:= self.myISOType.myISOTypeGroup;
		endif;
	endif;
	
	self.clean				:= _controller.clean;
	self.heavyRated			:= _controller.heavyRated;
	self.totalRequested		:= _controller.totalRequested;
	self.allAvailabilityGrades.clear();
	_controller.allAvailabilityGrades.copy(self.allAvailabilityGrades);
	if self.maskIds &lt;&gt; null then
		self.maskIds.clear();
	endif;
	self.remarks := _controller.remarks.trimBlanks.removeTabCrLfs;
	self.setTerminalAreaId(_controller.terminalAreaId);	// 15/02/2010	cnwjre1	CCMS 1101 
	self.setMyBOLIn( _controller.myBOLIn );				// cnwrl1 14/06/2010 PAR 24150
	self.myProduct	:=	_controller.myProduct;			// cnwdad1 05/10/2010 - PAR #25748.
end;
</source>
        <Parameter name="_controller" type="CMIF_BulkReleaseByType"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromComparison" id="4d8da5e5-4d22-45c3-b6b8-3373e3dc117d">
        <updating/>
        <source>setProxyFromComparison(_attribute ,_value : String)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Aug 2017 cnwma1	TFs #4596 POL - Cannot ignore fields during EDI Release Request Update
19 Oct 2017 cnwma1  TFS #7475 POL - Missing functions under EDI Comparison
*/

vars
	isoType : CM_ISOType;
	isoTypeGroup : CM_ISOTypeGroup;
	cargoType : CM_CargoType;
	product : CM_Product;
	availGrade : CM_MTGrade;
	availGradeInt  : Integer;
begin
	if _attribute ="Quantity" then
		self.setTotalRequested(_value.Integer);
	endif;
	
	if _attribute ="ISO Type" then
		isoType := app.myRoot.allISOTypes[_value];
		if isoType &lt;&gt; null then
			self.myISOType := isoType;
		endif;
	endif;
	
	if _attribute ="ISO Group" then
		isoTypeGroup := app.myRoot.allISOTypeGroups[_value];
		if isoTypeGroup &lt;&gt; null then
			self.myISOGroup := isoTypeGroup;
		endif;
	endif;	
	
	if _attribute ="ISO Group" then
		isoTypeGroup := app.myRoot.allISOTypeGroups[_value];
		if isoTypeGroup &lt;&gt; null then
			self.myISOGroup := isoTypeGroup;
		endif;
	endif;	
	
	if _attribute = "colour" then
		if  _value &lt;&gt; null then
			self.colour := _value;
		endif;
	endif;	
	
	if _attribute = "Availability Grades" then
		if _value  &lt;&gt; null then
			self.allAvailabilityGrades.clear();
			availGradeInt := self.getAvailabilityGrade(_value); 
			if availGradeInt = null then
				availGrade := app.myRoot.allAvailabilityGrades[_value.Integer];
				if availGrade &lt;&gt; null then
					availGradeInt := availGrade.code;
				endif;
			endif;
			self.allAvailabilityGrades.add(availGradeInt);
		endif;
	endif;
	
	if _attribute = "Cargo Type Descr" then
		 cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(_value);
		if cargoType  &lt;&gt; null then
			self.myCargoType := cargoType;
		endif;
	endif;
	
	if _attribute = "Cargo Type Descr" then
		 cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(_value);
		if cargoType  &lt;&gt; null then
			self.myCargoType := cargoType;
		endif;
	endif;
	
	if _attribute = "Cargo Sub-Type" then
		//product := self.myCargoType.allpro
	
	endif;
	
	if _attribute = "Clean" then
		self.clean := _value.asBooleanJMT();
	endif;
	
	if _attribute = "Heavy Duty" then
		self.heavyRated := _value.asBooleanJMT();
	endif;
	
	if _attribute = "Remarks" then
		if _value = "???" then  //19.10.2017 cnwma1 TFS #7475 
			self.remarks := null;
		else
			self.remarks :=_value;
		endif;
	endif;
	
	if _attribute = "Weight kg" then
		self.weightSelection := _value.asDecimalJMT();
	endif;

epilog

end;</source>
        <Parameter name="_attribute" type="String"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromRestAPI" id="19ebcc47-4b01-4422-bca5-7ff7e21e4ecd">
        <updating/>
        <source>setProxyFromRestAPI(	_cargoType				: CM_CargoType;
						_bookingItemRef			: CM_BookingRefItem;
						_isoType				: CM_ISOType;
						_isoTypeGroup			: CM_ISOTypeGroup;
						_subType				: CM_Product;
						_remarks				: String;
						_totalRequested,
						_piecesRequested		: Integer;
						_clean,
						_heavyRated				: Boolean;
						_volumeRequested,
						_weightRequested,
						_maxWeightRequested		: Decimal;
						_locationByOldestDate	: Boolean
					) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 July 2024		navmd1	Initial creation TFS 63327 Only set values we know about from the API

*/

vars
	ti	: CM_TrackedItem;
begin
	self.remarks						:= _remarks;
	self.totalRequested					:= _totalRequested;
	self.quantitySelection				:= _piecesRequested;
	self.clean							:= _clean;
	self.heavyRated						:= _heavyRated;
	self.volumeSelection				:= _volumeRequested;
	self.weightRequested				:= _weightRequested;
	self.maxWeightRequested				:= _maxWeightRequested;
	self.locnByOldestTransportArrival	:= _locationByOldestDate;
	
	// References
	self.myCargoType					:= _cargoType;
	self.myISOType						:= _isoType;
	self.myISOGroup						:= _isoTypeGroup;
	
	// Inverses
	self.myProduct						:= _subType;
	self.myBookingRefItem				:= _bookingItemRef;
	
	// Special
	if self.myCargoGroup &lt;&gt; null and self.myCargoType = null then
		ti := self.myCargoGroup.allAssignedTrackedItems.first;
		if ti &lt;&gt; null then
			self.myCargoType := ti.myCargoType;
			self.myProduct := ti.myProduct;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_bookingItemRef" type="CM_BookingRefItem"/>
        <Parameter name="_isoType" type="CM_ISOType"/>
        <Parameter name="_isoTypeGroup" type="CM_ISOTypeGroup"/>
        <Parameter name="_subType" type="CM_Product"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_totalRequested" type="Integer"/>
        <Parameter name="_piecesRequested" type="Integer"/>
        <Parameter name="_clean" type="Boolean"/>
        <Parameter name="_heavyRated" type="Boolean"/>
        <Parameter name="_volumeRequested" type="Decimal"/>
        <Parameter name="_weightRequested" type="Decimal"/>
        <Parameter name="_maxWeightRequested" type="Decimal"/>
        <Parameter name="_locationByOldestDate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setPxyDefaults" id="4852b50d-21a7-404d-b828-13b9153a796d">
        <updating/>
        <source>setPxyDefaults() updating;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
05 Sep 2022	 navma1		 Bug 54714: MTN - Web Portal - Release Request - Unable to save due to error message about Line number already existing
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.packType 		:= self.PackType_Parent;
	self.myCargoType 	:= app.myRoot.allCargoTypesById[TI_CargoType_Container];
	self.totalRequested := 0;
	if self.myReserveHeader &lt;&gt; null then										// 05.09.2022 navma1 #54714
		self.lineNumber := self.myReserveHeader.getNextLineNumber(self);        // 05.09.2022 navma1 #54714
	endif;																		// 05.09.2022 navma1 #54714

end;</source>
    </JadeMethod>
    <JadeMethod name="setTerminalArea" id="0e328f95-c671-4a72-991c-caf5514cea77">
        <updating/>
        <source>setTerminalArea(_allTermAreaDict : CM_TAByIdDict) updating;
//setTerminalArea(_ta : CM_TerminalArea) updating;  // 01/07/2015 cnwma1 PAR #36555
// 15/02/2010	cnwjre1	CCMS 1101 + 22634
//01/07/2015	cnwma1	PAR #36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release
vars
	//oldTa	: CM_TerminalArea;
	oldTas	: CM_TAByIdDict;
	ta		: CM_TerminalArea;
begin

	if _allTermAreaDict = null then
		if not self.allTerminalAreas.isEmpty then
			oldTas := self.allTerminalAreas;
			foreach ta in oldTas do
					self.allTerminalAreas.remove(ta);
			endforeach;
		endif;
	else
		if self.allTerminalAreas.isEmpty then	
			foreach ta in _allTermAreaDict do
				self.allTerminalAreas.add(ta);
			endforeach;
		else
			oldTas := self.allTerminalAreas;
			if _allTermAreaDict &lt;&gt; oldTas then
				foreach ta in oldTas do
					self.allTerminalAreas.remove(ta);
				endforeach;
			
				foreach ta in _allTermAreaDict do
					self.allTerminalAreas.add(ta);
				endforeach;
			endif;
		endif;
	endif;
end;

	/*if _ta = null then
		if not self.allTerminalAreas.isEmpty then
			oldTa := self.allTerminalAreas.first;
			self.allTerminalAreas.remove(oldTa);
		endif;
	else
		if self.allTerminalAreas.isEmpty then
			self.allTerminalAreas.add(_ta);
		else
			oldTa := self.allTerminalAreas.first;
			if _ta &lt;&gt; oldTa then
				self.allTerminalAreas.remove(oldTa);
				self.allTerminalAreas.add(_ta);
			endif;
		endif;
	endif;*/
</source>
        <Parameter name="_allTermAreaDict" type="CM_TAByIdDict"/>
    </JadeMethod>
    <JadeMethod name="setTerminalAreaId" id="3d8aa027-c4cd-4647-a699-1bfbe33b18a7">
        <updating/>
        <source>setTerminalAreaId(_id : String) updating;
// 15/02/2010	cnwjre1	CCMS 1101 
vars
	ta,
	oldTa	: CM_TerminalArea;
begin
	if self.myReserveHeader &lt;&gt; null then
		//cnwjo3, i'll remove this later
		if self.myReserveHeader.myTerminal &lt;&gt; null then
			ta := self.myReserveHeader.myTerminal.lookupTerminalArea(_id);
		endif;
	endif;
	if ta &lt;&gt; null then
		if self.allTerminalAreas.isEmpty then
			self.allTerminalAreas.add(ta);
		else
			oldTa := self.allTerminalAreas.first;
			if ta &lt;&gt; oldTa then
				self.allTerminalAreas.remove(oldTa);
				self.allTerminalAreas.add(ta);
			endif;
		endif;
	endif;
end;
</source>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTotalRequested" id="ff41e4e4-59c3-43d6-b988-87532cda7e1d">
        <updating/>
        <source>setTotalRequested(_int : Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	05 June 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.totalRequested := _int;

end;


</source>
        <Parameter name="_int" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="shouldReleaseBeConsidered" id="a6b7a232-4f76-4029-a456-3b324374bd20">
        <source>shouldReleaseBeConsidered(_reserveDetail : CM_ReserveDetail) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/06/2025	navrv30	MTN 35029 TPT | Release Request via Cargo Review with an Ownership Change

*/

vars

begin
	if self.getOperator() &lt;&gt; _reserveDetail.getOperator() then
		return false;
	endif;
	return true;
epilog

end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testCandidateTI" id="fba12b73-0008-43d3-8497-8ebb5ea8a452">
        <source>testCandidateTI(_ti : CM_TrackedItem);
// Is this tracked item included in this release line?
/*
Date		Who		Reason
19 Feb 2010	consw1	PAR #22333 - Incorrect ISO Group error
08 Aug 2022	navkc1	Bug 54325: PNL-Can be Hi or Low Cube (in Releases) ignored when releasing a container to our packing Sub-Terminal
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/
vars
	isoTypeCode	: String;
	reason : String;
	queue	: CM_VoyageCraneQueue; // ### TFS 52866 17May2022 NAVPW1
	isISOGroupMatch	: Boolean;
	allTis	: CM_TISet; 
	tiCGId: String;
	raiseAlreadyAllocated : Boolean;
begin
	if _ti = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'Tracked Item',null, null);
		return;
	endif;
	
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	isoTypeCode := self.getISOCode();

	/* 08/08/2022	navkc1	#54325	---&gt;&gt; Moving this to below
	if self.myISOType &lt;&gt; null then
		// Check that the ISO Type is OK PAR 17187
		if not _ti.isSimilarToISOType(isoTypeCode) then
			app.raiseCMException3(TI_TestReqISO, _ti.id, _ti.getISOType(), isoTypeCode, null, _ti);
		endif;
	endif;
	*/ //  Moving this to below &lt;&lt;-- 08/08/2022	navkc1	#54325	

	if self.myISOType = null or _ti.getISOType() &lt;&gt; isoTypeCode then
		if self.myISOGroup &lt;&gt; null and		//CNWMC5 - PAR 29992
			_ti.isoTypeGroup &lt;&gt; self.myISOGroup.code then
			
			if not self.myReserveHeader.canBeHiLoCube then	// 08/08/2022	navkc1	#54325
				// canBeHiLoCube is false then do this
				// 08/08/2022	navkc1	#54325	---&gt; Moved from above
				if self.myISOType &lt;&gt; null then
					// Check that the ISO Type is OK PAR 17187
					if not _ti.isSimilarToISOType(isoTypeCode) then
						app.raiseCMException3(TI_TestReqISO, _ti.id, _ti.getISOType(), isoTypeCode, null, _ti);
					endif;
				endif;
				// &lt;&lt;-- 08/08/2022	navkc1	#54325	Moved from above
				app.raiseCMException3(TI_TestReqISOGroup, _ti.id, _ti.isoTypeGroupDesc, self.myISOGroup.code, null, null);
			else
				// caBeHiLoCube is true, match substitute ISO group here - 08/08/2022	navkc1	#54325
				if self.myISOGroup.allSubstitutingISOGroups.includes(_ti.getISOTypeGroup()) then
					// Found matching group
					isISOGroupMatch := true;
				endif;
				// Raise error if couldn't find a match
				if not isISOGroupMatch then
					app.raiseCMException3(TI_TestReqISOGroup, _ti.id, _ti.isoTypeGroupDesc, self.myISOGroup.code, null, null);
				endif;
				// &lt;&lt;--- 04/08/2022	navkc1	#54325
			endif;
		else
			// 04/08/2022	navkc1	#54325  --&gt;&gt; Moved from above - check iso type here as well
			if self.myISOType &lt;&gt; null then
				// Check that the ISO Type is OK PAR 17187
				if not _ti.isSimilarToISOType(isoTypeCode) then
					app.raiseCMException3(TI_TestReqISO, _ti.id, _ti.getISOType(), isoTypeCode, null, _ti);
				endif;
			endif;
			// &lt;&lt;--- 04/08/2022	navkc1	#54325			
		endif;
	endif;

	// If there are attached items then check to see if the tracked item is one of them.
	///if (not self.allTrackedItems.isEmpty) and (not self.allTrackedItems.includes(_ti)) then
	self.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	//if (not self.myReserveHeader.releaseByType) and (not self.allTrackedItems.isEmpty) and (not self.allTrackedItems.includes(_ti)) then  // 16/12/2010 cnwmh5 #26586
	if (not self.myReserveHeader.releaseByType) and (not allTis.isEmpty) and (not allTis.includes(_ti)) then //23/06/2023	navkc1	CR 58406 Task 58408
	    app.raiseCMException2(TINotAllocatedToRelease, _ti.id, self.myReserveHeader.code, 'Bulk Release', app.getMyUser());
	endif;
	
	// If there is a maskID then check that this tracked item matches
	if self.maskIds &lt;&gt; null and not self.maskIds.compareIDStrings(_ti.id) then
		app.raiseCMException1(TI_TestReqIDMatch, _ti.id, 'Bulk Release', app.getMyUser());
	endif;

	// check to see if the tracked item is already assigned to another release
	if not _ti.allBulkReleasesAssigned.isEmpty() then			// 21/12/2010 cnwmh5 #26649
		if not _ti.allBulkReleasesAssigned.includes(self.myReserveHeader) then 
			app.raiseCMException2(ERR_TI_ALREADY_ALLOCATED, _ti.id, _ti.allBulkReleasesAssigned.first.code, null, null);
		else	
				
			//jlier1 34415 3/4/25
			//different track here 52866 attempted to fix this but the problem was the ti was in CTA to load but ti allQueues was empty
			if _ti.myPrimaryActualLocation.isKindOf(CM_CraneLaneController) then
				raiseAlreadyAllocated:=true;
				if self.myReserveHeader.myVoyage &lt;&gt; null then
					if _ti.myPrimaryActualLocation.myTerminalArea.CM_CraneTransferArea.crane &lt;&gt; null then
						queue:= _ti.myPrimaryActualLocation.myTerminalArea.CM_CraneTransferArea.crane.getVoyageCraneQueueForVoyage(self.myReserveHeader.myVoyage);
						if queue &lt;&gt; null and  queue.loadMachinesMode = CM_VoyageCraneQueue.UseShipLanderApp then
							raiseAlreadyAllocated :=false;
						endif;
					endif;
				endif;
			endif;
		
			if raiseAlreadyAllocated then
				app.raiseCMException2(ERR_TI_ALREADY_ALLOCATED, _ti.id, _ti.allBulkReleasesAssigned.first.code, null, null);
			endif;
		
		endif;
	endif;
	
	//cnwrd1 par 32823 test bol
	if self.myBOLIn &lt;&gt; null then
		if _ti.billOfLading = null or self.myBOLIn.number &lt;&gt; _ti.billOfLading then
			app.raiseCMException2(Cargo_bill_ladin_does_not_matc, _ti.billOfLading, self.myBOLIn.number, null, null);
		
		endif;
	endif;
	
	//14 Jan 2016 epr par 37311 also test the release criteria 
	//  reserve selection implies Release by Type.
	if self.myReleaseCriteria &lt;&gt; null then
		if not self.myReleaseCriteria.matchesReason( _ti, reason, null ) then		
			app.raiseCMException2(Does_not_match_relea_reser_cri,_ti.id,reason,null,null);		
		endif;
	endif;
	
	//23/06/2023	navkc1	CR 58406 Task 58408
	if self.myCargoGroup &lt;&gt; null then
		if self.myCargoGroup &lt;&gt; _ti.myCargoGroup then
			tiCGId := "null";
			if _ti.myCargoGroup &lt;&gt; null then
				tiCGId := _ti.myCargoGroup.id;
			endif;
			app.raiseCMException3(CargoGroupMismatch, _ti.id, tiCGId, self.myCargoGroup.id, null, null);
		endif;
	endif;
	
epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validate" id="9fc4e377-79a9-4b71-ae9c-7d507c934009">
        <source>validate(_userObject: Object);
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
// ---------------------------------------------------------------------------

vars

	ti : CM_TrackedItem;
	reason : String;
	allTis	: CM_TISet; 
	
begin
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	inheritMethod(_userObject);
	self.validateCargoType(_userObject);
	self.validateISOType(_userObject);
	self.validateQuantity(_userObject); // readed by AER 08/02/2008
	self.validateBookRefItem(_userObject);
	self.validateExtraCriteriaFilters();	//02 Nov 2015	NDL	Par 37094
	
	self.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	//14 Dec 2015	NDL	Par 37288
	//foreach ti in self.allTrackedItems do
	foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
		ti.testAgainstReserveSelection( self, reason, false, null );
		if reason &lt;&gt; null then
			app.raiseCMWarning2(Warn_Request_Line_Match, reason, ti.id, null, ti, ti);
		endif;
	endforeach;
	
	
epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="_userObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateBOLAssigned" id="145f5dfe-a744-4cc0-a37b-462ba99a9183">
        <source>validateBOLAssigned();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//24/04/2025	navrv30	MTN 34319 EUP | Creating a Release Request from Cargo Review - Validation
12/06/2025	navrv30	MTN 35029 TPT | Release Request via Cargo Review with an Ownership Change
12/06/2025	navrv30	MTN 35033 TPT | Editing a Release Request that is created via the Cargo Review Screen.
28 Jul 2025 navrv30		MTN 35529 MTN - Cargo Review Screen not calculating/displaying values correctly.
10 Sep 2025 navrv30 MTN 35839 TPT| Release Requests are not updated when less cargo is Released
*/

vars
	ti : CM_TrackedItem;
	reason : String;
	matchTotalDisplay : String;
	bolTotal, // 05/08/2025	navkc1	JIRA MTN 35529
	matchTotal, reservedReleasedTotal : Integer;
	notAvailableQtyTotal : Integer; 	//16/04/2025	navkc1 JIRA Bug MTN-34513
	bolTotalVol, // 05/08/2025	navkc1	JIRA MTN 35529
	bolTotalWeight, // 05/08/2025	navkc1	JIRA MTN 35529
	notAvailableVolumeTot,	//16/04/2025	navkc1 JIRA Bug MTN-34513
	notAvailableWeightTot, 	//16/04/2025	navkc1 JIRA Bug MTN-34513
	matchWeightTotal : Decimal [23,4];
	matchVolumeTotal, volumeRequested,
	reservedReleasedVolTotal, reservedReleasedWeightTotal, weightPerDetail : Decimal [23,4]; //19/09/2023 navmv20 Bug 60218
	cargoType : CM_CargoType;
	reserveDetail, editedReserveDetail  : CM_ReserveDetail;
	tiCargoType : CM_CargoType;
	allReserveDetails : CM_ReserveDetailSet;
	releasedTiInRelReq,
	tiSet : CM_TISet;
	bol : CM_BOLIn;
	createdTiSet, // 05/08/2025	navkc1	JIRA MTN 35529
	tiIsBulkMulti,			//16/04/2025	navkc1 JIRA Bug MTN-34513
	tiIsBulkByVolume, 		//16/04/2025	navkc1 JIRA Bug MTN-34513
	stopsPrevent, editedRelease : Boolean; //16/04/2025	navkc1 JIRA Bug MTN-34513
	theVoyage : CM_Voyage;
	theCommodity : CM_Commodity;
	theCargoGroup : CM_CargoGroup;
	terminal : CM_Terminal; // 05/08/2025	navkc1	JIRA MTN 35529
	col	: Collection; // 05/08/2025	navkc1	JIRA MTN 35529
begin
	// only do this for release requests created by the cargo review form
	if self.myReserveHeader.context &lt;&gt; RelReqContext_CargoGroupReview then // ### BUG 56533 21FEB2023 NAVAB1
		return;
	endif;
	
	if self.myBOLIn &lt;&gt; null then			
		bol := self.myBOLIn;
	endif;
	
	if bol = null then
		return;
	endif;
	
	terminal := self.getMyTerminal(); // 05/08/2025	navkc1	JIRA MTN 35529
	
	create allReserveDetails transient;
	create releasedTiInRelReq transient; // 05/08/2025	navkc1	JIRA MTN 35529
	// 05/08/2025	navkc1	JIRA MTN 35529 - BOL allTrackedItems include cargo in other terminals.
	if terminal &lt;&gt; null then 
		col := bol.getTICollectionForTerminal(terminal);
		if col &lt;&gt; null then
			create tiSet transient;
			createdTiSet := true;
			col.copy(tiSet);
		endif;
	else
		tiSet := bol.allTrackedItems;	
	endif;
	theCommodity := self.myCommodity;
	theVoyage := self.getMyVoyage();
	theCargoGroup := self.myCargoGroup;
	if self.isReleaseEdit(editedReserveDetail) then //10 Sep 2025 navrv30 MTN 35839
		editedRelease := true;
	endif;
	foreach reserveDetail in bol.allReserveDetails do
		//12/06/2025	navrv30	MTN 35029
		if not self.shouldReleaseBeConsidered(reserveDetail) then
			continue;
		endif;
		if editedRelease and reserveDetail = editedReserveDetail then	
			/* 10 Sep 2025 navrv30 MTN 35839 ---- For scenarios where we are editing a release request and the cargo items on the release are all onsite, the reservedtotal
			need not be added to the reservedReleasedTotal as these items need to be available.
			For scenarios where we have partially moved the cargo items offsite, we need to make sure that the partial amount is 
			ignored or made as reserved if the release is not being edited, if being edited then those are to be considered as available for the release.
			*/
			reserveDetail.allTrackedItemsReleased.copyNoDuplicates(releasedTiInRelReq, false);		
			foreach ti in reserveDetail.allTrackedItemsReleased discreteLock do
				reservedReleasedTotal := reservedReleasedTotal + ti.totalQuantity;
				reservedReleasedWeightTotal := reservedReleasedWeightTotal + ti.totalWeight;
				reservedReleasedVolTotal := reservedReleasedVolTotal + ti.totalVolume; 				
			endforeach;			
			continue;
		endif;									
		reservedReleasedTotal := reservedReleasedTotal + reserveDetail.totalRequested;
		weightPerDetail := reserveDetail.weightRequested;
		reservedReleasedWeightTotal := reservedReleasedWeightTotal + weightPerDetail;		//12 Dec 2024 navrv30 JIRA 33097
		if weightPerDetail &lt;&gt; 0 and reserveDetail.getDensity() &lt;&gt; 0 then	//12 Dec 2024 navrv30 JIRA 33097
			reservedReleasedVolTotal := reservedReleasedVolTotal + weightPerDetail/reserveDetail.getDensity(); 
		endif;	
		reserveDetail.allTrackedItemsReleased.copyNoDuplicates(releasedTiInRelReq, false); // 05/08/2025	navkc1	JIRA MTN 35529
	endforeach;
	
	// Check for amount of items that are not available (i.e does not match release request or has stops)
	//foreach ti in cargoGroup.allAssignedTrackedItems where not ti.isOffSite do
	foreach ti in tiSet do  //16/04/2025	navkc1 JIRA Bug MTN-34513
		
		tiCargoType := ti.myCargoType; //16/04/2025	navkc1 JIRA Bug MTN-34513
		
		tiIsBulkMulti := tiCargoType.isBulkMulti(); //16/04/2025	navkc1 JIRA Bug MTN-34513
		tiIsBulkByVolume := tiCargoType.isBulkByVolume(); //16/04/2025	navkc1 JIRA Bug MTN-34513
		
		// 05/08/2025	navkc1	JIRA MTN 35529 - accumulate total amount of this BOL
		if not tiIsBulkMulti then
			bolTotal += ti.totalQuantity;
		else
			if tiIsBulkByVolume then
				bolTotalVol += ti.totalVolume;
			else
				bolTotalWeight += ti.totalWeight;
			endif;
		endif;
		
		//16/04/2025	navkc1 JIRA Bug MTN-34513 - Offsite TI are not available
		if ti.isOffSite() then		//28 Jul 2025 navrv30	MTN 35529
			// 05/08/2025	navkc1	JIRA MTN 35529 - Item is offsite, but not in any reserve details. Add this to reserved/released to mark as not available
			if not releasedTiInRelReq.includes(ti) then
				if not tiIsBulkMulti then
					reservedReleasedTotal += ti.totalQuantity;
				else
					if tiIsBulkByVolume then
						reservedReleasedVolTotal += ti.totalVolume;
					else
						reservedReleasedWeightTotal += ti.totalWeight;
					endif;
				endif;
			endif;
			continue;
		endif;
		//13/06/2025	navrv30	MTN 35027
		if theCommodity &lt;&gt; null and ti.commodity &lt;&gt; theCommodity.code then
			continue;
		endif;
		
		if theCargoGroup &lt;&gt; null and ti.myCargoGroup &lt;&gt; null then 
			if theCargoGroup &lt;&gt; ti.myCargoGroup then
				continue;
			endif;
		endif;
		//28 Jul 2025 navrv30	MTN 35529
		if theVoyage &lt;&gt; null and theVoyage &lt;&gt; ti.myVoyage then
			continue;
		endif;
		
		if ti.testAgainstReserveSelection(self,reason,true,null) then
			stopsPrevent := ti.isStopSetToBePrevented(StopPreventReleaseRequest); //16/04/2025	navkc1 JIRA Bug MTN-34513
				if stopsPrevent then
					if not tiIsBulkMulti then 
						notAvailableQtyTotal += ti.totalQuantity;
					else
						if tiIsBulkByVolume then
							notAvailableVolumeTot += ti.totalVolume;
						else
							notAvailableWeightTot += ti.totalWeight;
						endif;
					endif;
				endif;
		else
			// This is for cargo that does not match the release request //16/04/2025	navkc1 JIRA Bug MTN-34513
			if not tiIsBulkMulti then
				notAvailableQtyTotal += ti.totalQuantity;
			else
				if tiIsBulkByVolume then
					notAvailableVolumeTot += ti.totalVolume;
				else
					notAvailableWeightTot += ti.totalWeight;
				endif;
			endif;
		endif;
		/* // 05/08/2025	navkc1	JIRA MTN 35529
		// 07/07/2025	navrv30	MTN 35346
		matchTotal := matchTotal + ti.totalQuantity;
		if tiIsBulkByVolume then
			matchVolumeTotal += ti.totalVolume;
		else
			matchWeightTotal += ti.totalWeight;
		endif;
		*/
	endforeach;
	
	cargoType:=self.getCargoType;
	/*10 Sep 2025 navrv30 MTN 35839 --- Since we have added the offsite items for a partially done release request, we need to make those available for editing and saving,
	so we subtract the allTrackedItemsReleased from the  reservedReleasedTotal*/
	if editedRelease then		
		foreach ti in self.allTrackedItemsReleased do 
			reservedReleasedTotal := reservedReleasedTotal - ti.totalQuantity;
			reservedReleasedWeightTotal := reservedReleasedWeightTotal - ti.totalWeight;
			reservedReleasedVolTotal := reservedReleasedVolTotal - ti.totalVolume;
		endforeach;
	endif;
	if not cargoType.isBulkMulti then
		//matchTotal := matchTotal - notAvailableQtyTotal - reservedTotal; //16/04/2025	navkc1 JIRA Bug MTN-34513
		matchTotal := bolTotal - notAvailableQtyTotal - reservedReleasedTotal; // 05/08/2025	navkc1	JIRA MTN 35529
		matchTotal := matchTotal.max(0);
		//if self.totalRequested + reservedTotal &gt; cargoGroup.totalQuantity then
		if self.totalRequested &gt; matchTotal then //16/04/2025	navkc1 JIRA Bug MTN-34513
			
			//matchTotalDisplay:=cargoGroup.totalQuantity.asStringJMT &amp; "(Reserved " &amp; reservedTotal.String &amp; ")";    //12 Dec 2024 navrv30 JIRA 33097
			matchTotalDisplay:=matchTotal.asStringJMT &amp; ". It also has " &amp; reservedReleasedTotal.asStringJMT() &amp; " Reserved/Released, " &amp; notAvailableQtyTotal.asStringJMT() &amp; " Unavailable";    //12 Dec 2024 navrv30 JIRA 33097
			
			app.raiseCMException3(Total_reque_value_not_more_tha,self.getTotalRequestedDisplay,bol.number,matchTotalDisplay,null,null);
		endif;
	else
		 //19/09/2023 navmv20 Bug 60218 - start
		if cargoType.isBulkByVolume() then
			// 07/07/2025	navrv30	MTN 35346
			//matchVolumeTotal := matchVolumeTotal - notAvailableVolumeTot - reservedVolTotal; //16/04/2025	navkc1 JIRA Bug MTN-34513
			matchVolumeTotal := bolTotalVol - notAvailableVolumeTot - reservedReleasedVolTotal; // 05/08/2025	navkc1	JIRA MTN 35529
			matchVolumeTotal := matchVolumeTotal.max(0);
			volumeRequested := self.weightRequested/self.getDensity();
			
			//if volumeRequested + reservedVolTotal &gt; cargoGroup.totalVolume then   //12 Dec 2024 navrv30 JIRA 33097
			if volumeRequested &gt; matchVolumeTotal then   //16/04/2025	navkc1 JIRA Bug MTN-34513
				
				//matchTotalDisplay:= cargoType.getConvertedVolumeDisplay(cargoGroup.totalVolume,true) &amp; "(Reserved " &amp; cargoType.getConvertedVolumeDisplay(reservedVolTotal,true) &amp; ")";    //12 Dec 2024 navrv30 JIRA 33097;
				matchTotalDisplay:= cargoType.getConvertedVolumeDisplay(matchVolumeTotal,true) &amp; ". It also has " &amp; cargoType.getConvertedVolumeDisplay(reservedReleasedVolTotal,true) &amp; " Reserved/Released, " &amp; cargoType.getConvertedVolumeDisplay(notAvailableVolumeTot, true) &amp;  " Unavailable"; //16/04/2025	navkc1 JIRA Bug MTN-34513
				
				app.raiseCMException3(Volume_requested_value,cargoType.getConvertedVolumeDisplay(volumeRequested, true),bol.number,matchTotalDisplay,null,null);
			endif;
		else
			// 07/07/2025	navrv30	MTN 35346
			//matchWeightTotal := matchWeightTotal - notAvailableWeightTot - reservedWeightTotal; //16/04/2025	navkc1 JIRA Bug MTN-34513
			matchWeightTotal := bolTotalWeight - notAvailableWeightTot - reservedReleasedWeightTotal; // 05/08/2025	navkc1	JIRA MTN 35529
			matchWeightTotal := matchWeightTotal.max(0);
			
			//if self.weightRequested + reservedWeightTotal &gt; cargoGroup.totalWeight then    //12 Dec 2024 navrv30 JIRA 33097
			if self.weightRequested &gt; matchWeightTotal then    //16/04/2025	navkc1 JIRA Bug MTN-34513
				
				//19/09/2023 navmv20 Bug 60218 - start
				//matchTotalDisplay:= cargoType.getBulkTrackByDisplayForWeight(matchWeightTotal,self.getDensity,true); 
				//if matchTotalDisplay = null then
					//matchTotalDisplay:= app.getWeightForDefaultDisplay(matchWeightTotal);	
				//endif;
				//matchTotalDisplay:= cargoType.getConvertedWeightDisplay(cargoGroup.totalWeight, true) &amp; "(Reserved " &amp; cargoType.getConvertedWeightDisplay(reservedWeightTotal,true) &amp; ")";    //12 Dec 2024 navrv30 JIRA 33097
				matchTotalDisplay:= cargoType.getConvertedWeightDisplay(matchWeightTotal,true) &amp; ". It also has " &amp; cargoType.getConvertedWeightDisplay(reservedReleasedWeightTotal,true) &amp; " Reserved/Released, " &amp; cargoType.getConvertedWeightDisplay(notAvailableWeightTot, true) &amp;  " Unavailable"; //16/04/2025	navkc1 JIRA Bug MTN-34513
				
				//19/09/2023 navmv20 Bug 60218 - end
				app.raiseCMException3(Weigh_reque_value_not_more_tha,cargoType.getConvertedWeightDisplay(self.weightRequested, true),bol.number,matchTotalDisplay,null,null);
			endif;
		endif; //19/09/2023 navmv20 Bug 60218
		
	endif;
	
epilog
	delete allReserveDetails;
	// 05/08/2025	navkc1	JIRA MTN 35529
	if createdTiSet then
		delete tiSet;
	endif;
	delete releasedTiInRelReq;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateBookRefItem" id="325e1020-8a07-491e-bb22-62b6f18acd56">
        <source>validateBookRefItem(pUserObject : Object) protected;

vars

begin
	if self.myBookingRefItem &lt;&gt; null and self.myReserveHeader.type = BR_TYPE_PACKING then
		// cnwrd1 ccms pol 2103 par 27856 14.7.2011 removed 
		/*if self.myBookingRefItem.myReserveDetail &lt;&gt; null
		and self.myBookingRefItem.myReserveDetail &lt;&gt; self.pxyGetRealObject then
			app.raiseCMException1(BookingRefItemNotAvailable, 'Booking Ref Item', ETRow_MyBookingRefItem, pUserObject);	
		endif;*/
		if self.myBookingRefItem.myProduct &lt;&gt; null
		and self.myProduct &lt;&gt; self.myBookingRefItem.myProduct then
			app.raiseCMException1(BookingRefItemWrongProduct, 'Booking Ref Item', ETRow_MyBookingRefItem, pUserObject);	
		endif;
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateCanReleaseTI" id="525f84aa-7f57-4f3b-a94e-c772ac1785f1">
        <source>validateCanReleaseTI(_ti : CM_TrackedItem);
/*
----------   ----------  --------------------------------------------------
Created:	11 October 2007 By cnwth2

Purpose:	PAR 14873 - Incorrect containers been delivered out

Changed On   	Changed By  Reason
	
----------   	----------  --------------------------------------------------
18/05/2023		jlizm1		TFS 57945 Better error message when overloading rail wagon
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight

*/
vars
	assigned			,
	outstanding			: Decimal[14,4];
	reserveDetail		: CM_ReserveDetail;
	ti 					: CM_TrackedItem;
	isForBulkMulti 		: Boolean;
	desc				: String;
	allTis				: CM_TISet; 
begin
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	//epr par 34406 25/6/14
	isForBulkMulti:=self.isBulkMulti or self.byTypeByWeight;			// 6/12/2023 navcs2 ChangeRequest 57537
	if isForBulkMulti then
		outstanding:=self.getWeightOutstanding();
	else
		outstanding := self.getTotalOutstanding();
	endif;
	
	if outstanding &lt;= 0 then
		app.raiseCMException1(Reserve_detail_outstan_balance, outstanding.asStringJMT , null, self );
		return;
	endif;
	
	if self.isFullyLoaded then
		desc := self.getTotalRequestedDisplay() &amp; ' x ' &amp; self.getProductISOTypeDescr();
		app.raiseCMException1(Quant_weigh_relea_will_excee_r, desc, null, self );
		return;
	endif;
	
	self.getAllTrackedItems(allTis, false);//23/06/2023	navkc1	CR 58406 Task 58408	
	
	//foreach ti in self.allTrackedItems do 
	foreach ti in allTis do  //23/06/2023	navkc1	CR 58406 Task 58408
		if isForBulkMulti then
			assigned:=assigned + ti.totalWeight;
		else
			assigned:=assigned + ti.totalQuantity.max(1);
		endif;
	endforeach;
	
	
	if assigned &lt;= 0 then
		return;
	endif;
	
	if outstanding &lt;= assigned then
		//if self.allTrackedItems.includes(_ti) then
		if allTis.includes(_ti) then
			return;//no problem
		endif;
		
			//Par 15487 - clients need a red warning to avoid of releasing wrong containers, that haven't been added in attachment list of a release
		app.raiseCMException3(Reser_detai_outst_balan_there_, outstanding.asStringJMT, assigned.asStringJMT, _ti.id, null, self );
	
	else
		//the cargo item only has to match the release criteria, but it can be any item
		//warnings raised elsewhere for this
	endif;
epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;


</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateCargoGroup" id="26f75245-8e00-4fc7-9ad7-5c47ff199f4d">
        <source>validateCargoGroup();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/06/2023	navkc1	CR 57496 Task 58405: UI - Release Request Cargo Group
13/07/2023  navmv20 CR 59049 Task 59050: Jade - Check Cargo Type on Release Request

*/

vars
	cgOperator		: CM_Operator;
	reserveOperator	: CM_Operator;
	reserverHeader	: CM_BulkRelease;
	cgCargoType     : CM_CargoType; //13/07/2023  navmv20 CR 59049 Task 59050
	cgCargoTypeDesc,                //13/07/2023  navmv20 CR 59049 Task 59050
	myCargoTypeDesc : String; 		//13/07/2023  navmv20 CR 59049 Task 59050
	ti 				: CM_TrackedItem; //13/07/2023  navmv20 CR 59049 Task 59050
begin
	
	// Users can select Cargo group from either the direct reference OR criteria
	// Cannot be both
	if self.getMyCargoGroupIdCriteria() &lt;&gt; null and self.myCargoGroup &lt;&gt; null then
		app.raiseCMException(CargoGroupSpecifyCantBeBoth, null, null);
	endif;
	
	if self.myCargoGroup &lt;&gt; null then
		cgOperator := self.myCargoGroup.myOperator;
		reserverHeader := self.myReserveHeader;
		if reserverHeader &lt;&gt; null then
			reserveOperator := reserverHeader.myOperator;
		endif;
		if cgOperator &lt;&gt; reserveOperator then
		app.raiseCMWarning3(CgAndRelReqOpsMismatch, self.myCargoGroup.id, cgOperator.code, reserveOperator.code, null, null, null);
		endif;
		
		//13/07/2023  navmv20 CR 59049 Task 59050 - start
		ti := self.myCargoGroup.allAssignedTrackedItems.first;
		if ti &lt;&gt; null then
			cgCargoType := ti.myCargoType;
			cgCargoTypeDesc := cgCargoType.description;
		endif;
		if cgCargoType &lt;&gt; null
		and self.myCargoType &lt;&gt; cgCargoType then
			app.raiseCMException3(Cargo_type_does_not_match_carg, self.myCargoType.description, self.myCargoGroup.id, cgCargoTypeDesc, null, null);
		endif;
		//13/07/2023  navmv20 CR 59049 Task 59050 - end
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateCargoGroupAssigned" id="184975f3-0b89-402e-84b2-703a7699fd48">
        <source>validateCargoGroupAssigned();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 June 2022	jlier1	Initial creation TFS 53678
// ### BUG 56533 21FEB2023 NAVAB1 - rewrote as it was totally wrong, replaced all code.
//22/06/2023	navkc1	CR 57496 Task 58405: UI - Release Request Cargo Group
11/08/2023	navkc1	Bug 59687: EUP | Damage Stop Release Requests
19/09/2023 navmv20 Bug 60218: EUP - COO - Release Request - Message details incorrect when using Volume

09/11/2024 navrv30 JIRA MTN 23312 EUP | FR 53383 - Cargo Group Reservation - part IV
12 Dec 2024 navrv30 JIRA 33097: MTN - Invalid reserved amount value while creating release request
12/06/2025	navrv30	MTN 35029 TPT | Release Request via Cargo Review with an Ownership Change
12/06/2025	navrv30	MTN 35033 TPT | Editing a Release Request that is created via the Cargo Review Screen.
28 Jul 2025 navrv30		MTN 35529 MTN - Cargo Review Screen not calculating/displaying values correctly.
10 Sep 2025 navrv30 MTN 35839 TPT| Release Requests are not updated when less cargo is Released
*/

vars
	cargoGroupID : String;
	cargoGroup : CM_CargoGroup;
	ti : CM_TrackedItem;
	reason : String;
	matchTotalDisplay : String;
	notAvailableQtyTotal, 	//16/04/2025	navkc1 JIRA Bug MTN-34513
	matchTotal, reservedReleasedTotal : Integer;
	notAvailableVolumeTot,	//16/04/2025	navkc1 JIRA Bug MTN-34513
	notAvailableWeightTot, 	//16/04/2025	navkc1 JIRA Bug MTN-34513
	matchWeightTotal : Decimal [23,4];
	matchVolumeTotal, volumeRequested,
	reservedReleasedVolTotal, reservedReleasedWeightTotal, weightPerDetail : Decimal [23,4]; //19/09/2023 navmv20 Bug 60218
	cargoType : CM_CargoType;
	reserveDetail, editedReserveDetail : CM_ReserveDetail;
	tiCargoType : CM_CargoType;
	tiIsBulkMulti,			//16/04/2025	navkc1 JIRA Bug MTN-34513
	tiIsBulkByVolume, 		//16/04/2025	navkc1 JIRA Bug MTN-34513
	stopsPrevent, editedRelease : Boolean; //16/04/2025	navkc1 JIRA Bug MTN-34513
	theCommodity : CM_Commodity;
	theBol : CM_BOLIn;
	theVoyage : CM_Voyage;
	releasedTiInRelReq : CM_TISet; // 05/08/2025	navkc1	JIRA MTN 35529
begin
	// only do this for release requests created by the cargo review form
	if self.myReserveHeader.context &lt;&gt; RelReqContext_CargoGroupReview then // ### BUG 56533 21FEB2023 NAVAB1
		return;
	endif;
	
	//22/06/2023	navkc1	CR 57496 Task 58405
	/*cargoGroupID:= self.getMyCargoGroupId;
	if cargoGroupID = null then
		return;
	endif;*/
	cargoGroup:=self.getMyCargoGroupObj();
	if cargoGroup = null then
		return;
	endif;
	
	create releasedTiInRelReq transient; // 05/08/2025	navkc1	JIRA MTN 35529
	
	cargoGroupID := cargoGroup.id; //19/09/2023 navmv20 Bug 60218
	if self.isReleaseEdit(editedReserveDetail) then //10 Sep 2025 navrv30 MTN 35839
		editedRelease := true;
	endif;
	//09/11/2024 navrv30 JIRA MTN 23312
	foreach reserveDetail in cargoGroup.allReserveDetailAssigned do
		//12/06/2025	navrv30	MTN 35029
		if not self.shouldReleaseBeConsidered(reserveDetail) then
			continue;
		endif;
		//12/06/2025	navrv30	MTN 35033
		if editedRelease and reserveDetail = editedReserveDetail then	
			/* 10 Sep 2025 navrv30 MTN 35839 ------ For scenarios where we are editing a release request and the cargo items on the release are all onsite, the reservedtotal
			need not be added to the reservedReleasedTotal as these items need to be available.
			For scenarios where we have partially moved the cargo items offsite, we need to make sure that the partial amount is 
			ignored or made as reserved if the release is not being edited, if being edited then those are to be considered as available for the release.
			*/
			reserveDetail.allTrackedItemsReleased.copyNoDuplicates(releasedTiInRelReq, false);		
			foreach ti in reserveDetail.allTrackedItemsReleased discreteLock do
				reservedReleasedTotal := reservedReleasedTotal + ti.totalQuantity;
				reservedReleasedWeightTotal := reservedReleasedWeightTotal + ti.totalWeight;
				reservedReleasedVolTotal := reservedReleasedVolTotal + ti.totalVolume; 				
			endforeach;			
			continue;
		endif;
		reservedReleasedTotal := reservedReleasedTotal + reserveDetail.totalRequested;
		weightPerDetail := reserveDetail.weightRequested;
		reservedReleasedWeightTotal := reservedReleasedWeightTotal + weightPerDetail;		//12 Dec 2024 navrv30 JIRA 33097
		if weightPerDetail &lt;&gt; 0 and reserveDetail.getDensity() &lt;&gt; 0 then	//12 Dec 2024 navrv30 JIRA 33097
			reservedReleasedVolTotal := reservedReleasedVolTotal + weightPerDetail/reserveDetail.getDensity(); 
		endif;
		
		reserveDetail.allTrackedItemsReleased.copyNoDuplicates(releasedTiInRelReq, false); // 05/08/2025	navkc1	JIRA MTN 35529
	endforeach;
	
	// Check for amount of items that are not available (i.e does not match release request or has stops)
	//foreach ti in cargoGroup.allAssignedTrackedItems where not ti.isOffSite do
	foreach ti in cargoGroup.allAssignedTrackedItems do  //16/04/2025	navkc1 JIRA Bug MTN-34513
		
		tiCargoType := ti.myCargoType; //16/04/2025	navkc1 JIRA Bug MTN-34513
		
		tiIsBulkMulti := tiCargoType.isBulkMulti(); //16/04/2025	navkc1 JIRA Bug MTN-34513
		tiIsBulkByVolume := tiCargoType.isBulkByVolume(); //16/04/2025	navkc1 JIRA Bug MTN-34513	
		
		//16/04/2025	navkc1 JIRA Bug MTN-34513 - Offsite TI are not available
		//28 Jul 2025 navrv30		MTN 35529
		if ti.isOffSite() then			
			// 05/08/2025	navkc1	JIRA MTN 35529 - Item is offsite, but not in any reserve details. Add this to reserved/released to mark as not available
			if not releasedTiInRelReq.includes(ti) then
				if not tiIsBulkMulti then
					reservedReleasedTotal += ti.totalQuantity;
				else
					if tiIsBulkByVolume then
						reservedReleasedVolTotal += ti.totalVolume;
					else
						reservedReleasedWeightTotal += ti.totalWeight;
					endif;
				endif;
			endif;
			continue;
		endif;
		if theCommodity &lt;&gt; null and ti.commodity &lt;&gt; theCommodity.code then
			continue;
		endif;
		
		if theBol &lt;&gt; null and ti.myBOLDtl &lt;&gt; null then 
			if theBol &lt;&gt; ti.myBOLDtl.myBOL then
				continue;
			endif;
		endif;
		//28 Jul 2025 navrv30	MTN 35529
		if theVoyage &lt;&gt; null and theVoyage &lt;&gt; ti.myVoyage then
			continue;
		endif;
		
		if ti.testAgainstReserveSelection(self,reason,true,null) then
			stopsPrevent := ti.isStopSetToBePrevented(StopPreventReleaseRequest); //16/04/2025	navkc1 JIRA Bug MTN-34513
				if stopsPrevent then
					if not tiIsBulkMulti then 
						notAvailableQtyTotal += ti.totalQuantity;
					else
						if tiIsBulkByVolume then
							notAvailableVolumeTot += ti.totalVolume;
						else
							notAvailableWeightTot += ti.totalWeight;
						endif;
					endif;
				endif;
		else
			// This is for cargo that does not match the release request //16/04/2025	navkc1 JIRA Bug MTN-34513
			if not tiIsBulkMulti then
				notAvailableQtyTotal += ti.totalQuantity;
			else
				if tiIsBulkByVolume then
					notAvailableVolumeTot += ti.totalVolume;
				else
					notAvailableWeightTot += ti.totalWeight;
				endif;
			endif;
		endif;
	endforeach;
	/*10 Sep 2025 navrv30 MTN 35839 --- since we have added the offsite items for a partially done release request, we need to make those available for editing and saving,
	so we subtract the allTrackedItemsReleased from the  reservedReleasedTotal*/
	if editedRelease then		
		foreach ti in self.allTrackedItemsReleased do 
			reservedReleasedTotal := reservedReleasedTotal - ti.totalQuantity;
			reservedReleasedWeightTotal := reservedReleasedWeightTotal - ti.totalWeight;
			reservedReleasedVolTotal := reservedReleasedVolTotal - ti.totalVolume;
		endforeach;
	endif;
	cargoType:=self.getCargoType;
	if not cargoType.isBulkMulti then
		matchTotal := cargoGroup.totalQuantity - notAvailableQtyTotal - reservedReleasedTotal; //16/04/2025	navkc1 JIRA Bug MTN-34513
		matchTotal := matchTotal.max(0);
		//if self.totalRequested + reservedTotal &gt; cargoGroup.totalQuantity then
		if self.totalRequested &gt; matchTotal then //16/04/2025	navkc1 JIRA Bug MTN-34513
			
			//matchTotalDisplay:=cargoGroup.totalQuantity.asStringJMT &amp; "(Reserved " &amp; reservedTotal.String &amp; ")";    //12 Dec 2024 navrv30 JIRA 33097
			matchTotalDisplay:=matchTotal.asStringJMT &amp; ". It also has " &amp; reservedReleasedTotal.asStringJMT() &amp; " Reserved/Released, " &amp; notAvailableQtyTotal.asStringJMT() &amp; " Unavailable";    //12 Dec 2024 navrv30 JIRA 33097
			
			app.raiseCMException3(Total_reque_value_not_more_tha,self.getTotalRequestedDisplay,cargoGroupID,matchTotalDisplay,null,null);
		endif;
	else
		 //19/09/2023 navmv20 Bug 60218 - start
		if cargoType.isBulkByVolume() then
			matchVolumeTotal := cargoGroup.totalVolume - notAvailableVolumeTot - reservedReleasedVolTotal; //16/04/2025	navkc1 JIRA Bug MTN-34513
			matchVolumeTotal := matchVolumeTotal.max(0);
			volumeRequested := self.weightRequested/self.getDensity();
			
			//if volumeRequested + reservedVolTotal &gt; cargoGroup.totalVolume then   //12 Dec 2024 navrv30 JIRA 33097
			if volumeRequested &gt; matchVolumeTotal then   //16/04/2025	navkc1 JIRA Bug MTN-34513
				
				//matchTotalDisplay:= cargoType.getConvertedVolumeDisplay(cargoGroup.totalVolume,true) &amp; "(Reserved " &amp; cargoType.getConvertedVolumeDisplay(reservedVolTotal,true) &amp; ")";    //12 Dec 2024 navrv30 JIRA 33097;
				matchTotalDisplay:= cargoType.getConvertedVolumeDisplay(matchVolumeTotal,true) &amp; ". It also has " &amp; cargoType.getConvertedVolumeDisplay(reservedReleasedVolTotal,true) &amp; " Reserved/Released. " &amp; cargoType.getConvertedVolumeDisplay(notAvailableVolumeTot, true) &amp;  " Unavailable"; //16/04/2025	navkc1 JIRA Bug MTN-34513
				
				app.raiseCMException3(Volume_requested_value,cargoType.getConvertedVolumeDisplay(volumeRequested, true),cargoGroupID,matchTotalDisplay,null,null);
			endif;
		else
		//19/09/2023 navmv20 Bug 60218 - end
			matchWeightTotal := cargoGroup.totalWeight - notAvailableWeightTot - reservedReleasedWeightTotal; //16/04/2025	navkc1 JIRA Bug MTN-34513
			matchWeightTotal := matchWeightTotal.max(0);
			
			//if self.weightRequested + reservedWeightTotal &gt; cargoGroup.totalWeight then    //12 Dec 2024 navrv30 JIRA 33097
			if self.weightRequested &gt; matchWeightTotal then    //16/04/2025	navkc1 JIRA Bug MTN-34513
				
				//19/09/2023 navmv20 Bug 60218 - start
				//matchTotalDisplay:= cargoType.getBulkTrackByDisplayForWeight(matchWeightTotal,self.getDensity,true); 
				//if matchTotalDisplay = null then
					//matchTotalDisplay:= app.getWeightForDefaultDisplay(matchWeightTotal);	
				//endif;
				//matchTotalDisplay:= cargoType.getConvertedWeightDisplay(cargoGroup.totalWeight, true) &amp; "(Reserved " &amp; cargoType.getConvertedWeightDisplay(reservedWeightTotal,true) &amp; ")";    //12 Dec 2024 navrv30 JIRA 33097
				matchTotalDisplay:= cargoType.getConvertedWeightDisplay(matchWeightTotal,true) &amp; ". It also has " &amp; cargoType.getConvertedWeightDisplay(reservedReleasedWeightTotal,true) &amp; " Reserved/Released. " &amp; cargoType.getConvertedWeightDisplay(notAvailableWeightTot, true) &amp;  " Unavailable"; //16/04/2025	navkc1 JIRA Bug MTN-34513
				
				//19/09/2023 navmv20 Bug 60218 - end
				app.raiseCMException3(Weigh_reque_value_not_more_tha,cargoType.getConvertedWeightDisplay(self.weightRequested, true),cargoGroupID,matchTotalDisplay,null,null);
			endif;
		endif; //19/09/2023 navmv20 Bug 60218
		
	endif;

epilog
	delete releasedTiInRelReq; // 05/08/2025	navkc1	JIRA MTN 35529
end;</source>
    </JadeMethod>
    <JadeMethod name="validateCargoType" id="4d5cfd7a-f27b-4673-95a0-2b3908689062">
        <source>validateCargoType(pUserObject : Object) protected;
/*
----------   ----------  --------------------------------------------------
Created:	16 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.myCargoType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Cargo Type', ETRow_CargoType, pUserObject);	
		app.raiseCMException(Input_required_field_cargoType, ETRow_CargoType, pUserObject);	 // cnwdb2	PAR 35364
	endif;

end;


</source>
        <access>protected</access>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateCommodity" id="a5849a20-8402-41db-853f-bc49632cb546">
        <source>validateCommodity();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//24/04/2025	navrv30	MTN 34319 EUP | Creating a Release Request from Cargo Review - Validation

*/

vars
	reserveCommodity : CM_StringArray;
begin
	reserveCommodity := self.getMyCommodityCriteria();
	// Users can select commodity from either the direct reference OR criteria
	// Cannot be both
	if reserveCommodity &lt;&gt; null and reserveCommodity.size &gt; 1 and self.myCommodity &lt;&gt; null then
		app.raiseCMException(CargoGroupSpecifyCantBeBoth, null, null);   //Rama - Change error string
	endif;
	
	/*if self.myCommodity &lt;&gt; null then
				
		if self.myCommodity.allCargoTypes[ self.myCargoType.productType ] = null
		and self.myCargoType &lt;&gt; null and self.myCargoType.isCommodityRequired then		//cnwmc5 - 18 Feb 2016 - PAR 37522
			app.raiseCMWarning2(CargoType_NotValid4_Commodity, self.myCargoType.description, self.myCommodity.code, ETRow_CargoTypeDescr, self, self);	//par26681 cnwrs1 29 Decd 2010
		endif;
		//13/07/2023  navmv20 CR 59049 Task 59050 - end
	endif;*/
epilog
	delete reserveCommodity;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateCommodityAssigned" id="0b548f6e-e854-4484-a155-cc93791c7162">
        <source>validateCommodityAssigned();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//24/04/2025	navrv30	MTN 34319 EUP | Creating a Release Request from Cargo Review - Validation
12/06/2025	navrv30	MTN 35029 TPT | Release Request via Cargo Review with an Ownership Change
12/06/2025	navrv30	MTN 35033 TPT | Editing a Release Request that is created via the Cargo Review Screen.
11/07/2025  navrv30 MTN 35404 MTN - Cannot create release request from Cargo Review form
                                    when cargo available doesn't have a BOL and Cargo group
28 Jul 2025 navrv30		MTN 35529 MTN - Cargo Review Screen not calculating/displaying values correctly.
10 Sep 2025 navrv30 MTN 35839 TPT| Release Requests are not updated when less cargo is Released
*/


vars
	ti : CM_TrackedItem;
	reason : String;
	matchTotalDisplay : String;
	notAvailableQtyTotal,
	matchTotal, reservedReleasedTotal : Integer;
	notAvailableVolumeTot,	//16/04/2025	navkc1 JIRA Bug MTN-34513
	notAvailableWeightTot, 	//16/04/2025	navkc1 JIRA Bug MTN-34513
	matchWeightTotal : Decimal [23,4];
	matchVolumeTotal, volumeRequested,
	reservedReleasedVolTotal, reservedReleasedWeightTotal, weightPerDetail : Decimal [23,4]; //19/09/2023 navmv20 Bug 60218
	cargoType : CM_CargoType;
	reserveDetail, editedReserveDetail  : CM_ReserveDetail;
	tiCargoType : CM_CargoType;
	totalQuantity : Integer;
	tiDictByCommodityCode : CM_TiByCommodityCode;
	releasedTiInRelReq, // 05/08/2025	navkc1	JIRA MTN 35529
	tisToProcess	: CM_TISet;
	iterator : Iterator;
	tiIsBulkMulti,			//16/04/2025	navkc1 JIRA Bug MTN-34513
	tiIsBulkByVolume, 		//16/04/2025	navkc1 JIRA Bug MTN-34513
	stopsPrevent, editedRelease : Boolean; //16/04/2025	navkc1 JIRA Bug MTN-34513
	totalVolume, totalWeight : Decimal [23,4];
	theTerminal : CM_Terminal;
	theCargoGroup : CM_CargoGroup;
	theBol : CM_BOLIn;
	theVoyage : CM_Voyage;	
	theCommodity : CM_Commodity;
begin
	// only do this for release requests created by the cargo review form
	if self.myReserveHeader.context &lt;&gt; RelReqContext_CargoGroupReview then // ### BUG 56533 21FEB2023 NAVAB1
		return;
	endif;
	
	if self.myCommodity &lt;&gt; null then			
		theCommodity := self.myCommodity;
	endif;
	
	if theCommodity = null then
		return;
	endif;	
	
	theTerminal := self.getMyTerminal();
	theCargoGroup := self.myCargoGroup;
	theVoyage := self.getMyVoyage;
	theBol := self.myBOLIn;
	
	create tiDictByCommodityCode transient;
	create tisToProcess transient;
	create releasedTiInRelReq transient; // 05/08/2025	navkc1	JIRA MTN 35529
	
	if theCargoGroup &lt;&gt; null then
		theCargoGroup.allAssignedTrackedItems.copyNoDuplicates(tiDictByCommodityCode, false);
	elseif theBol &lt;&gt; null then
		theBol.allTrackedItems.copyNoDuplicates(tiDictByCommodityCode, false);
	elseif theVoyage &lt;&gt; null then		
		theVoyage.allOnshipTIsByCargoTypeId.copyNoDuplicates(tiDictByCommodityCode, false);
		//11/07/2025  navrv30 MTN 35404
		theVoyage.allOnsiteTIsByCargoTypeId.copyNoDuplicates(tiDictByCommodityCode, false);
	else 
		if theTerminal &lt;&gt; null and theTerminal.allOnsiteTIsByCargoTypeId &lt;&gt; null then
			theTerminal.allOnsiteTIsByCargoTypeId.copyNoDuplicates(tiDictByCommodityCode, false);		
		endif;		
	endif;
	
	
	ti := tiDictByCommodityCode[theCommodity.code];
		
	iterator := tiDictByCommodityCode.createIterator();
	if ti &lt;&gt; null then
		iterator.startAtObject(ti);
	endif;		
	
	
	while iterator.next(ti) do		
		if ti.commodity &lt;&gt; theCommodity.code then
			break;
		endif;
		
		if theBol &lt;&gt; null and ti.myBOLDtl &lt;&gt; null then 
			if theBol &lt;&gt; ti.myBOLDtl.myBOL then
				continue;
			endif;
		endif;
		if theVoyage &lt;&gt; null and theVoyage &lt;&gt; ti.myVoyage then
			continue;
		endif;		
		if theCargoGroup &lt;&gt; null and theCargoGroup &lt;&gt; ti.myCargoGroup then
			continue;
		endif;
		tisToProcess.addNoDuplicates(ti, false);		
	endwhile;	
	
	if self.isReleaseEdit(editedReserveDetail) then //10 Sep 2025 navrv30 MTN 35839
		editedRelease := true;
	endif;
	foreach reserveDetail in theCommodity.allReserveDetails do
		if not reserveDetail.getMyTerminal() =  theTerminal then
			continue;
		endif;		
		
		if theCargoGroup &lt;&gt; null and theCargoGroup &lt;&gt; reserveDetail.myCargoGroup then
			continue;
		endif;
		if theVoyage &lt;&gt; null and theVoyage &lt;&gt; reserveDetail.getMyVoyage then
			continue;
		endif;
		if theBol &lt;&gt; null and theBol &lt;&gt; reserveDetail.myBOLIn then
			continue;
		endif;
		//12/06/2025	navrv30	MTN 35029
		if not self.shouldReleaseBeConsidered(reserveDetail) then
			continue;
		endif;
		
		//12/06/2025	navrv30	MTN 35033
		if editedRelease and reserveDetail = editedReserveDetail then	
			/*10 Sep 2025 navrv30 MTN 35839  --- For scenarios where we are editing a release request and the cargo items on the release are all onsite, the reservedtotal
			need not be added to the reservedReleasedTotal as these items need to be available.
			For scenarios where we have partially moved the cargo items offsite, we need to make sure that the partial amount is 
			ignored or made as reserved if the release is not being edited, if being edited then those are to be considered as available for the release.
			*/
			reserveDetail.allTrackedItemsReleased.copyNoDuplicates(releasedTiInRelReq, false);		
			foreach ti in reserveDetail.allTrackedItemsReleased discreteLock do
				reservedReleasedTotal := reservedReleasedTotal + ti.totalQuantity;
				reservedReleasedWeightTotal := reservedReleasedWeightTotal + ti.totalWeight;
				reservedReleasedVolTotal := reservedReleasedVolTotal + ti.totalVolume; 				
			endforeach;			
			continue;
		endif;
		reservedReleasedTotal := reservedReleasedTotal + reserveDetail.totalRequested;
		weightPerDetail := reserveDetail.weightRequested;
		reservedReleasedWeightTotal := reservedReleasedWeightTotal + weightPerDetail;		//12 Dec 2024 navrv30 JIRA 33097
		if weightPerDetail &lt;&gt; 0 and reserveDetail.getDensity() &lt;&gt; 0 then	//12 Dec 2024 navrv30 JIRA 33097
			reservedReleasedVolTotal := reservedReleasedVolTotal + weightPerDetail/reserveDetail.getDensity();  
		endif;
				
		reserveDetail.allTrackedItemsReleased.copyNoDuplicates(releasedTiInRelReq, false); // 05/08/2025	navkc1	JIRA MTN 35529
		
	endforeach;
	
	// Check for amount of items that are not available (i.e does not match release request or has stops)
	//foreach ti in cargoGroup.allAssignedTrackedItems where not ti.isOffSite do
	foreach ti in tisToProcess do  //16/04/2025	navkc1 JIRA Bug MTN-34513
		
		tiCargoType := ti.myCargoType; //16/04/2025	navkc1 JIRA Bug MTN-34513
		
		tiIsBulkMulti := tiCargoType.isBulkMulti(); //16/04/2025	navkc1 JIRA Bug MTN-34513
		tiIsBulkByVolume := tiCargoType.isBulkByVolume(); //16/04/2025	navkc1 JIRA Bug MTN-34513
		
		//16/04/2025	navkc1 JIRA Bug MTN-34513 - Offsite TI are not available
		if ti.isOffSite() then		//28 Jul 2025 navrv30		MTN 35529	
			// 05/08/2025	navkc1	JIRA MTN 35529 - Item is offsite, but not in any reserve details. Add this to reserved/released to mark as not available
			if not releasedTiInRelReq.includes(ti) then
				if not tiIsBulkMulti then
					reservedReleasedTotal += ti.totalQuantity;
				else
					if tiIsBulkByVolume then
						reservedReleasedVolTotal += ti.totalVolume;
					else
						reservedReleasedWeightTotal += ti.totalWeight;
					endif;
				endif;
			endif;
			continue;
		endif;
		
		if theCargoGroup &lt;&gt; null and ti.myCargoGroup &lt;&gt; theCargoGroup then
			continue;
		endif;
		if theVoyage &lt;&gt; null and ti.myVoyage &lt;&gt; theVoyage then
			continue;
		endif;
		if theBol &lt;&gt; null and ti.myBOLDtl.myBOL &lt;&gt; theBol then
			continue;
		endif;
		
		if ti.testAgainstReserveSelection(self,reason,true,null) then
			stopsPrevent := ti.isStopSetToBePrevented(StopPreventReleaseRequest); //16/04/2025	navkc1 JIRA Bug MTN-34513
				if stopsPrevent then
					if not tiIsBulkMulti then 
						notAvailableQtyTotal += ti.totalQuantity;
					else
						if tiIsBulkByVolume then
							notAvailableVolumeTot += ti.totalVolume;
						else
							notAvailableWeightTot += ti.totalWeight;
						endif;
					endif;
				endif;
		else
			// This is for cargo that does not match the release request //16/04/2025	navkc1 JIRA Bug MTN-34513
			if not tiIsBulkMulti then
				notAvailableQtyTotal += ti.totalQuantity;
			else
				if tiIsBulkByVolume then
					notAvailableVolumeTot += ti.totalVolume;
				else
					notAvailableWeightTot += ti.totalWeight;
				endif;
			endif;
		endif;
	endforeach;
	
	cargoType:=self.getCargoType;
	/*10 Sep 2025 navrv30 MTN 35839 --- Since we have added the offsite items for a partially done release request, we need to make those available for editing and saving,
	so we subtract the allTrackedItemsReleased from the  reservedReleasedTotal*/
	if editedRelease then		
		foreach ti in self.allTrackedItemsReleased do 
			reservedReleasedTotal := reservedReleasedTotal - ti.totalQuantity;
			reservedReleasedWeightTotal := reservedReleasedWeightTotal - ti.totalWeight;
			reservedReleasedVolTotal := reservedReleasedVolTotal - ti.totalVolume;
		endforeach;
	endif;
	if not cargoType.isBulkMulti then
		totalQuantity := theCommodity.getTotalTIQty(tisToProcess);
		matchTotal := totalQuantity - notAvailableQtyTotal - reservedReleasedTotal; //16/04/2025	navkc1 JIRA Bug MTN-34513
		matchTotal := matchTotal.max(0);
		//if self.totalRequested + reservedTotal &gt; cargoGroup.totalQuantity then
		if self.totalRequested &gt; matchTotal then //16/04/2025	navkc1 JIRA Bug MTN-34513
			
			//matchTotalDisplay:=cargoGroup.totalQuantity.asStringJMT &amp; "(Reserved " &amp; reservedTotal.String &amp; ")";    //12 Dec 2024 navrv30 JIRA 33097
			matchTotalDisplay:=matchTotal.asStringJMT &amp; ". It also has " &amp; reservedReleasedTotal.asStringJMT() &amp; " Reserved/Released, " &amp; notAvailableQtyTotal.asStringJMT() &amp; " Unavailable";    //12 Dec 2024 navrv30 JIRA 33097
			
			app.raiseCMException3(Total_reque_value_not_more_tha,self.getTotalRequestedDisplay,theCommodity.code,matchTotalDisplay,null,null);
		endif;
	else
		 //19/09/2023 navmv20 Bug 60218 - start
		if cargoType.isBulkByVolume() then
			totalVolume := theCommodity.getTotalTIVolume(tisToProcess);
			matchVolumeTotal := totalVolume - notAvailableVolumeTot - reservedReleasedVolTotal; //16/04/2025	navkc1 JIRA Bug MTN-34513
			matchVolumeTotal := matchVolumeTotal.max(0);
			volumeRequested := self.weightRequested/self.getDensity();
			
			//if volumeRequested + reservedVolTotal &gt; cargoGroup.totalVolume then   //12 Dec 2024 navrv30 JIRA 33097
			if volumeRequested &gt; matchVolumeTotal then   //16/04/2025	navkc1 JIRA Bug MTN-34513
				
				//matchTotalDisplay:= cargoType.getConvertedVolumeDisplay(cargoGroup.totalVolume,true) &amp; "(Reserved " &amp; cargoType.getConvertedVolumeDisplay(reservedVolTotal,true) &amp; ")";    //12 Dec 2024 navrv30 JIRA 33097;
				matchTotalDisplay:= cargoType.getConvertedVolumeDisplay(totalVolume,true) &amp; ". It also has " &amp; cargoType.getConvertedVolumeDisplay(reservedReleasedVolTotal,true) &amp; " Reserved/Release, " &amp; cargoType.getConvertedVolumeDisplay(notAvailableVolumeTot, true) &amp;  " Unavailable"; //16/04/2025	navkc1 JIRA Bug MTN-34513
				
				app.raiseCMException3(Volume_requested_value,cargoType.getConvertedVolumeDisplay(volumeRequested, true),theCommodity.code,matchTotalDisplay,null,null);
			endif;
		else
		//19/09/2023 navmv20 Bug 60218 - end
			totalWeight := theCommodity.getTotalTiWeight(tisToProcess);
			matchWeightTotal := totalWeight - notAvailableWeightTot - reservedReleasedWeightTotal; //16/04/2025	navkc1 JIRA Bug MTN-34513
			matchWeightTotal := matchWeightTotal.max(0);
			
			//if self.weightRequested + reservedWeightTotal &gt; cargoGroup.totalWeight then    //12 Dec 2024 navrv30 JIRA 33097
			if self.weightRequested &gt; matchWeightTotal then    //16/04/2025	navkc1 JIRA Bug MTN-34513
				
				//19/09/2023 navmv20 Bug 60218 - start
				//matchTotalDisplay:= cargoType.getBulkTrackByDisplayForWeight(matchWeightTotal,self.getDensity,true); 
				//if matchTotalDisplay = null then
					//matchTotalDisplay:= app.getWeightForDefaultDisplay(matchWeightTotal);	
				//endif;
				//matchTotalDisplay:= cargoType.getConvertedWeightDisplay(cargoGroup.totalWeight, true) &amp; "(Reserved " &amp; cargoType.getConvertedWeightDisplay(reservedWeightTotal,true) &amp; ")";    //12 Dec 2024 navrv30 JIRA 33097
				matchTotalDisplay:= cargoType.getConvertedWeightDisplay(totalWeight,true) &amp; ". It also has " &amp; cargoType.getConvertedWeightDisplay(reservedReleasedWeightTotal,true) &amp; " Reserved/Released, " &amp; cargoType.getConvertedWeightDisplay(notAvailableWeightTot, true) &amp;  " Unavailable"; //16/04/2025	navkc1 JIRA Bug MTN-34513
				
				//19/09/2023 navmv20 Bug 60218 - end
				app.raiseCMException3(Weigh_reque_value_not_more_tha,cargoType.getConvertedWeightDisplay(self.weightRequested, true),theCommodity.code,matchTotalDisplay,null,null);
			endif;
		endif; //19/09/2023 navmv20 Bug 60218
		
	endif;


epilog	
	delete tiDictByCommodityCode;
	delete tisToProcess;
	delete iterator;
	delete releasedTiInRelReq; // 05/08/2025	navkc1	JIRA MTN 35529
end;</source>
    </JadeMethod>
    <JadeMethod name="validateExtraCriteriaFilters" id="c72e3819-b174-4266-bde0-bb844f9c25b4">
        <source>validateExtraCriteriaFilters();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2015	cnwndl1	Initial creation	Par 37094


*/

vars

begin

	if self.myReleaseCriteria &lt;&gt; null then
		if self.heavyRated then
			if self.myReleaseCriteria.includesCriteriaFor(YACriteriaType_HeavyDuty) then
				app.raiseCMException2( Heavy_rated_shoul_only_decla_e, app.getErrorString(Heavy_duty), self.getDescription, null, null );
			endif;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateISOType" id="538051c6-3506-49a0-934b-57671b0d5a77">
        <source>validateISOType(pUserObject : Object) protected;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpISOType	: CM_ISOType;
	
begin

	if self.myCargoType &lt;&gt; null and 
	 self.myCargoType.id = TI_CargoType_Container and 
	 self.myISOType = null and 
	 //self.myISOGroup &lt;&gt; self.myISOType.myISOTypeGroup then
	 self.myISOGroup = null then //cnwrd1 par 20810 9/10/09
	//	app.raiseCMException1(REQUIRED_FIELD, 'ISO Type', 'isoType', pUserObject);
		app.raiseCMException(Input_required_field_IsoType, 'isoType', pUserObject); // cnwdb2	PAR 35364
	else//potentially enforce product selection?? - probably not necessary
		
	endif;
		
end;</source>
        <access>protected</access>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateLoadCC" id="ca406709-0f20-49aa-82df-a60c24c1d2ce">
        <source>validateLoadCC( _loadCC : CM_VoyageAllocation input) ;
/*

Date		Who		Reason
11 November 2014	cnwer1	Initial creation PAR 35187

*/

vars
	scenario : CMIF_YAAutoPlanSenario;
	reserveCriteria,
	criteria : CM_YACriteria;
	noMatchReason : String;
	criteriaType		: CM_YACriteriaType;
	
	isotype : CM_ISOType;
	isotypegroup : CM_ISOTypeGroup;
	
	criterias : CM_YACriteriaByPriorityDict;
	objSet : ObjectSet;
	isoCriteria : CM_YACriteria;
begin
	if _loadCC = null then
		return ;
	endif;
	
	// ### PAR 37093
	create criterias transient;
	foreach criteria in _loadCC.allCriteria do
		criterias.addNoDuplicates(criteria,false);
	
		if criteria.myYACriteriaType.type = YACriteriaType_ISO then
			isotype := criteria.myYAData.CM_YADataObjects.allObjects.first.CM_ISOType;
		endif;
		
		if criteria.myYACriteriaType.type = YACriteriaType_ISOGroup then
			isotypegroup := criteria.myYAData.CM_YADataObjects.allObjects.first.CM_ISOTypeGroup;
		endif;
		
		
	endforeach;
	
	if isotypegroup = null and isotype &lt;&gt; null then
		if isotype.myISOTypeGroup &lt;&gt; null then
		
			create isoCriteria transient;
			create objSet transient;
			objSet.clear();
			objSet.add(isotype.myISOTypeGroup);
			isoCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_ISOGroup], objSet, null);
			criterias.add( isoCriteria );
			
		endif;
	
	endif;
	
	
	create scenario transient;
	scenario.populateCriteriaFromReserveSel( self );
	
	foreach criteria in criterias do
		if not scenario.isCriteriaMatch(criteria) then
			criteriaType:=criteria.myYACriteriaType;
			reserveCriteria:=scenario.allScenarioCriteria[criteriaType.type];
			if reserveCriteria = null then
				continue;
			endif;
			app.raiseCMWarning3(Does_not_match,criteriaType.description,criteriaType.getDataDisplay(reserveCriteria.myYAData) ,criteriaType.getDataDisplay(criteria.myYAData),null,  criteria,null);		
		endif; 
	endforeach;
	
	
epilog
	delete scenario;
	if isoCriteria &lt;&gt; null then	//18 Mar 2020	NDL	TFS 47004 existing transient leak.
		delete isoCriteria;
	endif;
	delete criterias;
	delete objSet;
end;</source>
        <Parameter name="_loadCC" type="CM_VoyageAllocation" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateQuantity" id="17a0bd94-db48-42c0-8add-8d8a6ab26ff7">
        <source>validateQuantity(pUserObject : Object) protected;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpCargoType	: CM_CargoType;
begin

	if self.totalRequested &lt; 1 then
		//epr TFS 41398 20/2/19
		tmpCargoType := self.getMyCargoType();
		if tmpCargoType &lt;&gt; null and tmpCargoType.isAllowDuplicates() then
			// PASHA total taken will not be known until the carrier has been loaded
		else
			if self.weightSelection = 0 and self.volumeSelection = 0 and self.weightRequested = 0 then	//08 Dec 2015	NDL	Par 
				app.raiseCMException(Input_required_field_totReqQua, ETRow_TotalRequested, pUserObject); // cnwdb2	PAR 35364
			endif;
		endif;
		
	endif;
	
	if self.allTrackedItemsReleased.isNotEmpty then
		if self.totalRequested &lt; self.allTrackedItemsReleased.size then
			app.raiseCMException(Input_required_field_totRQNTis, ETRow_TotalRequested, pUserObject);
		endif;
	endif;
	
	
end;</source>
        <access>protected</access>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateStatus" id="8fc3e2a0-dff4-4379-85f4-e9e7f0da344b">
        <source>validateStatus(pUserObject : Object) protected;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theBulkRelease	: CM_BulkRelease;
begin
	/*Par9444
	theBulkRelease := self.myReserveHeader;
	if theBulkRelease &lt;&gt; null then
		if theBulkRelease.status = BR_COMPLETE then
			//app.raiseCMException1(MTRequestExceedsNumBulkRequest, self.myOriginatingBulkRelease.code, 'quantity', pUserObject);
			app.raiseCMException1(MTRequestStatusAlreadyComplete, theBulkRelease.code, 'status', pUserObject);
		endif;
	endif;*/
	
end;</source>
        <access>protected</access>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateVoyageAssigned" id="34ce3e0b-880d-443f-bc12-61912656e611">
        <source>validateVoyageAssigned();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//24/04/2025	navrv30	MTN 34319 EUP | Creating a Release Request from Cargo Review - Validation
12/06/2025	navrv30	MTN 35029 TPT | Release Request via Cargo Review with an Ownership Change
12/06/2025	navrv30	MTN 35033 TPT | Editing a Release Request that is created via the Cargo Review Screen.
28 Jul 2025 navrv30		MTN 35529 MTN - Cargo Review Screen not calculating/displaying values correctly.
10 Sep 2025 navrv30 MTN 35839 TPT| Release Requests are not updated when less cargo is Released
23 September 2025	navrv30	MTN 36110 MTN | Cargo Review Validation with Voyage code as grouping criteria
*/


vars
	ti : CM_TrackedItem;
	reason : String;
	matchTotalDisplay : String;
	notAvailableQtyTotal, totalQuantity,
	matchTotal, reservedReleasedTotal : Integer;
	notAvailableVolumeTot,	//16/04/2025	navkc1 JIRA Bug MTN-34513
	notAvailableWeightTot, 	//16/04/2025	navkc1 JIRA Bug MTN-34513
	matchWeightTotal, totalVolume,
	totalWeight : Decimal [23,4];
	matchVolumeTotal, volumeRequested,
	reservedReleasedVolTotal, reservedReleasedWeightTotal, weightPerDetail : Decimal [23,4]; //19/09/2023 navmv20 Bug 60218
	cargoType : CM_CargoType;
	reserveDetail, editedReserveDetail : CM_ReserveDetail;
	tiCargoType : CM_CargoType;
	allReserveDetails : CM_ReserveDetailSet;
	bulkRelease : CM_BulkRelease;
	reserveDetailSet : CM_ReserveDetailSet;
	releasedTiInRelReq, // 05/08/2025	navkc1	JIRA MTN 35529
	tiSet : CM_TISet;
	voyage : CM_Voyage;
	iterator : Iterator;
	tiIsBulkMulti,			//16/04/2025	navkc1 JIRA Bug MTN-34513
	tiIsBulkByVolume, 		//16/04/2025	navkc1 JIRA Bug MTN-34513
	stopsPrevent, editedRelease : Boolean; //16/04/2025	navkc1 JIRA Bug MTN-34513
begin
	// only do this for release requests created by the cargo review form
	if self.myReserveHeader.context &lt;&gt; RelReqContext_CargoGroupReview then // ### BUG 56533 21FEB2023 NAVAB1
		return;
	endif;
	
	if self.myReserveHeader &lt;&gt; null and 
			self.myReserveHeader.myVoyage &lt;&gt; null then
		voyage := self.myReserveHeader.myVoyage;
	endif;
	
	if voyage = null then
		return;
	endif;
	
	create allReserveDetails transient;
	create releasedTiInRelReq transient; // 05/08/2025	navkc1	JIRA MTN 35529
	 // NAVAB1 UnitTests JIRA 34319 create tiSet transient;
	foreach bulkRelease in voyage.allBulkReleases do
		reserveDetailSet := bulkRelease.allReserveDetails;	
		//13/06/2025	navrv30	MTN 35027
		reserveDetail := reserveDetailSet.first;
		if reserveDetail &lt;&gt; null then
			if self.myCargoGroup &lt;&gt; null and reserveDetail.myCargoGroup &lt;&gt; null 
				and self.myCargoGroup &lt;&gt; reserveDetail.myCargoGroup then
				continue;
			endif;
			if self.myBOLIn &lt;&gt; null and reserveDetail.myBOLIn &lt;&gt; null 
				and self.myBOLIn &lt;&gt; reserveDetail.myBOLIn then
				continue;
			endif;
			if self.myCommodity &lt;&gt; null and reserveDetail.myCommodity &lt;&gt; null 
				and self.myCommodity &lt;&gt; reserveDetail.myCommodity then
				continue;
			endif;
			reserveDetailSet.copyNoDuplicates(allReserveDetails, false);
		endif;
	endforeach;	
	
	if self.isReleaseEdit(editedReserveDetail) then  //10 Sep 2025 navrv30 MTN 35839
		editedRelease := true;
	endif;
	//cargoGroupID := cargoGroup.id; //19/09/2023 navmv20 Bug 60218
	//09/11/2024 navrv30 JIRA MTN 23312
	if allReserveDetails &lt;&gt; null then
		foreach reserveDetail in allReserveDetails do
			//12/06/2025	navrv30	MTN 35029
			if not self.shouldReleaseBeConsidered(reserveDetail) then
				continue;
			endif;
			if editedRelease and reserveDetail = editedReserveDetail then	
			/*10 Sep 2025 navrv30 MTN 35839 --- For scenarios where we are editing a release request and the cargo items on the release are all onsite, the reservedtotal
			need not be added to the reservedReleasedTotal as these items need to be available.
			For scenarios where we have partially moved the cargo items offsite, we need to make sure that the partial amount is 
			ignored or made as reserved if the release is not being edited, if being edited then those are to be considered as available for the release.
			*/
			reserveDetail.allTrackedItemsReleased.copyNoDuplicates(releasedTiInRelReq, false);		
			foreach ti in reserveDetail.allTrackedItemsReleased discreteLock do
				reservedReleasedTotal := reservedReleasedTotal + ti.totalQuantity;
				reservedReleasedWeightTotal := reservedReleasedWeightTotal + ti.totalWeight;
				reservedReleasedVolTotal := reservedReleasedVolTotal + ti.totalVolume; 				
			endforeach;			
			continue;
		endif;
			reservedReleasedTotal := reservedReleasedTotal + reserveDetail.totalRequested;
			weightPerDetail := reserveDetail.weightRequested;
			reservedReleasedWeightTotal := reservedReleasedWeightTotal + weightPerDetail;		//12 Dec 2024 navrv30 JIRA 33097
			if weightPerDetail &lt;&gt; 0 and reserveDetail.getDensity() &lt;&gt; 0 then	//12 Dec 2024 navrv30 JIRA 33097
				reservedReleasedVolTotal := reservedReleasedVolTotal + weightPerDetail/reserveDetail.getDensity(); 
			endif;
			
			reserveDetail.allTrackedItemsReleased.copyNoDuplicates(releasedTiInRelReq, false); // 05/08/2025	navkc1	JIRA MTN 35529
		endforeach;
	endif;
	
	//iterator := voyage.allOnshipTIsByIdCargoType.createIterator();
	//voyage.allOnshipTIsByAlternativeId.startKeyGeq(null, iterator);
	//voyage.allOnshipTIsByIdCargoType.copyNoDuplicates(tiSet, true);
	
	create tiSet transient;
	voyage.getTrackedItemsAnywhere(tiSet);   //23 September 2025	navrv30	MTN 36110
	iterator := tiSet.createIterator();	
	while iterator.next(ti) do
		//23 September 2025	navrv30	MTN 36110
		//We need to filter for TIs that are not part of this grouping and only process those that are part of the grouping
		if self.myCargoGroup &lt;&gt; null and ti.myCargoGroup &lt;&gt; self.myCargoGroup then
			continue;
		endif;
		if self.myCommodity &lt;&gt; null and ti.commodity &lt;&gt; self.myCommodity.code then
			continue;
		endif;
		if self.myBOLIn &lt;&gt; null and ti.myBOLDtl &lt;&gt; null and ti.myBOLDtl.myBOL &lt;&gt; self.myBOLIn then
			continue;
		endif;
		tiCargoType := ti.myCargoType; //16/04/2025	navkc1 JIRA Bug MTN-34513
		
		tiIsBulkMulti := tiCargoType.isBulkMulti(); //16/04/2025	navkc1 JIRA Bug MTN-34513
		tiIsBulkByVolume := tiCargoType.isBulkByVolume(); //16/04/2025	navkc1 JIRA Bug MTN-34513	
		
		// 05/08/2025	navkc1	JIRA MTN 35529
		if not tiIsBulkMulti then
			totalQuantity := totalQuantity + ti.totalQuantity;
		else
			if tiIsBulkByVolume then
				totalVolume := totalVolume + ti.totalVolume;
			else
				totalWeight := totalWeight + ti.weight; // NAVAB1 UnitTests JIRA 34319
			endif;
		endif;
		//16/04/2025	navkc1 JIRA Bug MTN-34513 - Offsite TI are not available
		if ti.isOffSite() then		//28 Jul 2025 navrv30		MTN 35529		
			// 05/08/2025	navkc1	JIRA MTN 35529 - Item is offsite, but not in any reserve details. Add this to reserved/released to mark as not available
			if not releasedTiInRelReq.includes(ti) then
				if not tiIsBulkMulti then
					reservedReleasedTotal += ti.totalQuantity;
				else
					if tiIsBulkByVolume then
						reservedReleasedVolTotal += ti.totalVolume;
					else
						reservedReleasedWeightTotal += ti.totalWeight;
					endif;
				endif;
			endif;
			continue;
		endif;		
		
		if ti.testAgainstReserveSelection(self,reason,true,null) then
			stopsPrevent := ti.isStopSetToBePrevented(StopPreventReleaseRequest); //16/04/2025	navkc1 JIRA Bug MTN-34513
			if stopsPrevent then
				if not tiIsBulkMulti then 
					notAvailableQtyTotal += ti.totalQuantity;
				else
					if tiIsBulkByVolume then
						notAvailableVolumeTot += ti.totalVolume;
					else
						notAvailableWeightTot += ti.totalWeight;
					endif;
				endif;
			endif;
		else
			// This is for cargo that does not match the release request //16/04/2025	navkc1 JIRA Bug MTN-34513
			if not tiIsBulkMulti then
				notAvailableQtyTotal += ti.totalQuantity;
			else
				if tiIsBulkByVolume then
					notAvailableVolumeTot += ti.totalVolume;
				else
					notAvailableWeightTot += ti.totalWeight;
				endif;
			endif;
		endif;
		
	endwhile;
	//write totalQuantity;
	cargoType:=self.getCargoType;
	/*10 Sep 2025 navrv30 MTN 35839 --- Since we have added the offsite items for a partially done release request, we need to make those available for editing and saving,
	so we subtract the allTrackedItemsReleased from the  reservedReleasedTotal*/
	if editedRelease then		
		foreach ti in self.allTrackedItemsReleased do 
			reservedReleasedTotal := reservedReleasedTotal - ti.totalQuantity;
			reservedReleasedWeightTotal := reservedReleasedWeightTotal - ti.totalWeight;
			reservedReleasedVolTotal := reservedReleasedVolTotal - ti.totalVolume;
		endforeach;
	endif;
	if not cargoType.isBulkMulti then
		matchTotal := totalQuantity - notAvailableQtyTotal - reservedReleasedTotal; //16/04/2025	navkc1 JIRA Bug MTN-34513
		matchTotal := matchTotal.max(0);
		//if self.totalRequested + reservedTotal &gt; cargoGroup.totalQuantity then
		if self.totalRequested &gt; matchTotal then //16/04/2025	navkc1 JIRA Bug MTN-34513
			
			//matchTotalDisplay:=cargoGroup.totalQuantity.asStringJMT &amp; "(Reserved " &amp; reservedTotal.String &amp; ")";    //12 Dec 2024 navrv30 JIRA 33097
			matchTotalDisplay:=matchTotal.asStringJMT &amp; ". It also has " &amp; reservedReleasedTotal.asStringJMT() &amp; " Reserved/Released, " &amp; notAvailableQtyTotal.asStringJMT() &amp; " Unavailable";    //12 Dec 2024 navrv30 JIRA 33097
			
			app.raiseCMException3(Total_reque_value_not_more_tha,self.getTotalRequestedDisplay,voyage.identity,matchTotalDisplay,null,null);
		endif;
	else
		 //19/09/2023 navmv20 Bug 60218 - start
		if cargoType.isBulkByVolume() then
			matchVolumeTotal := totalVolume - notAvailableVolumeTot - reservedReleasedVolTotal; //16/04/2025	navkc1 JIRA Bug MTN-34513
			matchVolumeTotal := matchVolumeTotal.max(0);
			volumeRequested := self.weightRequested/self.getDensity();
			
			//if volumeRequested + reservedVolTotal &gt; cargoGroup.totalVolume then   //12 Dec 2024 navrv30 JIRA 33097
			if volumeRequested &gt; matchVolumeTotal then   //16/04/2025	navkc1 JIRA Bug MTN-34513
				
				//matchTotalDisplay:= cargoType.getConvertedVolumeDisplay(cargoGroup.totalVolume,true) &amp; "(Reserved " &amp; cargoType.getConvertedVolumeDisplay(reservedVolTotal,true) &amp; ")";    //12 Dec 2024 navrv30 JIRA 33097;
				matchTotalDisplay:= cargoType.getConvertedVolumeDisplay(matchVolumeTotal,true) &amp; ". It also has " &amp; cargoType.getConvertedVolumeDisplay(reservedReleasedVolTotal,true) &amp; " Reserved/Released, " &amp; cargoType.getConvertedVolumeDisplay(notAvailableVolumeTot, true) &amp;  " Unavailable"; //16/04/2025	navkc1 JIRA Bug MTN-34513
				
				app.raiseCMException3(Volume_requested_value,cargoType.getConvertedVolumeDisplay(volumeRequested, true),voyage.identity,matchTotalDisplay,null,null);
			endif;
		else
		//19/09/2023 navmv20 Bug 60218 - end
			matchWeightTotal := totalWeight - notAvailableWeightTot - reservedReleasedWeightTotal; //16/04/2025	navkc1 JIRA Bug MTN-34513
			matchWeightTotal := matchWeightTotal.max(0);
			
			//if self.weightRequested + reservedWeightTotal &gt; cargoGroup.totalWeight then    //12 Dec 2024 navrv30 JIRA 33097
			if self.weightRequested &gt; matchWeightTotal then    //16/04/2025	navkc1 JIRA Bug MTN-34513
				
				//19/09/2023 navmv20 Bug 60218 - start
				//matchTotalDisplay:= cargoType.getBulkTrackByDisplayForWeight(matchWeightTotal,self.getDensity,true); 
				//if matchTotalDisplay = null then
					//matchTotalDisplay:= app.getWeightForDefaultDisplay(matchWeightTotal);	
				//endif;
				//matchTotalDisplay:= cargoType.getConvertedWeightDisplay(cargoGroup.totalWeight, true) &amp; "(Reserved " &amp; cargoType.getConvertedWeightDisplay(reservedWeightTotal,true) &amp; ")";    //12 Dec 2024 navrv30 JIRA 33097
				matchTotalDisplay:= cargoType.getConvertedWeightDisplay(matchWeightTotal,true) &amp; ". It also has " &amp; cargoType.getConvertedWeightDisplay(reservedReleasedWeightTotal,true) &amp; " Reserved/Released, " &amp; cargoType.getConvertedWeightDisplay(notAvailableWeightTot, true) &amp;  " Unavailable"; //16/04/2025	navkc1 JIRA Bug MTN-34513
				
				//19/09/2023 navmv20 Bug 60218 - end
				app.raiseCMException3(Weigh_reque_value_not_more_tha,cargoType.getConvertedWeightDisplay(self.weightRequested, true),voyage.identity,matchTotalDisplay,null,null);
			endif;
		endif; //19/09/2023 navmv20 Bug 60218
		
	endif;	
	
epilog
	delete allReserveDetails;
	delete iterator; // NAVAB1 UnitTests JIRA 34319
	delete tiSet; // NAVAB1 UnitTests JIRA 34319
	delete releasedTiInRelReq; // 05/08/2025	navkc1	JIRA MTN 35529
end;</source>
    </JadeMethod>
    <JadeMethod name="validateWeightAndQuantity" id="07d1bcca-55e9-48f1-be7b-c62789fda7ac">
        <source>validateWeightAndQuantity( _moveControl : CMIF_MoveController input );
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
11 November 2015	cnwndl1	Initial creation	Par 37092
14 November 2022	jlizm1	TFS 54118 Assigning Releases to Wagons
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
*/

vars

	outstanding : Decimal[14,4];
	isForBulkMulti : Boolean;
	desc : String;

begin

	inheritMethod(_moveControl);
	
	if _moveControl.weight = 0 and _moveControl.quantity &lt; 0 then
		return;
	endif;
	
	self.validateWeightQuantityAdd(	_moveControl.quantity, _moveControl.weight, true );
	
	// TFS 54118
	if _moveControl.isWagonMove then
		isForBulkMulti := self.isBulkMulti or self.byTypeByWeight;			// 6/12/2023 navcs2 ChangeRequest 57537
		if isForBulkMulti then
			outstanding := self.weightRequested - self.getWeightLoaded();
		else
			outstanding := self.totalRequested - self.getTotalLoaded();
		endif;
		
		if outstanding &lt;= 0 then
			app.raiseCMException1(Reserve_detail_outstan_balance, outstanding.asStringJMT, null, self );
			return;
		endif;
		
		if isForBulkMulti then
			outstanding := outstanding - _moveControl.weight;
		else
			outstanding := outstanding - _moveControl.quantity;
		endif;
		
		if outstanding &lt; 0 then
			desc := self.getTotalRequestedDisplay() &amp; ' x ' &amp; self.getProductISOTypeDescr();
			app.raiseCMException1(Quant_weigh_relea_will_excee_r, desc, null, self );
			return;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_moveControl" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateWeightQuantityAdd" id="15efe758-e8f0-487f-8d7d-a015afa3c18f">
        <source>validateWeightQuantityAdd(	_moveQuantity : Integer; _moveWeight : Decimal; _raiseError : Boolean ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2015	cnwndl1	Initial creation	Par 37092
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
24/10/2024	navpw1	JIRA MTN-12518 - Added a check for the weight outstanding

*/

vars

	outstanding : Decimal[14,4];
	isForBulkMulti : Boolean;
	desc : String;

begin
	
	if _moveWeight = 0 and _moveQuantity &lt; 0 then
		return null;
	endif;
	
	//outstanding = requested - released
	isForBulkMulti:= self.isBulkMulti or self.byTypeByWeight;	// 6/12/2023 navcs2 ChangeRequest 57537		
	// ### JIRA MTN-12518 22Oct2024 NAVPW1
	if self.byTypeByWeight and app.myPassport.isVASEnabled then
		//outstanding = requested - released - assigned/loaded
		outstanding := self.getWeightOutstanding() - self.getWeightLoaded();
	// ### JIRA MTN-12518 22Oct2024 NAVPW1
	elseif isForBulkMulti or self.byTypeByWeight then
		outstanding := self.getWeightOutstanding();
	else
		outstanding := self.getTotalOutstanding();
	endif;
	
	if outstanding &lt;= 0 then
		if _raiseError then
			app.raiseCMException1(Reserve_detail_outstan_balance, outstanding.asStringJMT, null, self );
			return null;
		else
			return app.getErrorString1(Reserve_detail_outstan_balance, outstanding.asStringJMT );
		endif;
	endif;
	
	if isForBulkMulti then
		outstanding := outstanding - _moveWeight;
	else
		outstanding := outstanding - _moveQuantity;
	endif;
	
	if outstanding &lt; 0 then
		desc := self.getTotalRequestedDisplay() &amp; ' x ' &amp; self.getProductISOTypeDescr();
		if _raiseError then
			app.raiseCMException1(Quant_weigh_relea_will_excee_r, desc, null, self );
			return null;
		else
			return app.getErrorString1(Quant_weigh_relea_will_excee_r, desc );
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_moveQuantity" type="Integer"/>
        <Parameter name="_moveWeight" type="Decimal"/>
        <Parameter name="_raiseError" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wouldBeOverSelected" id="e726c05f-927d-405b-8bc4-f5650f781967">
        <source>wouldBeOverSelected(_ti : CM_TrackedItem; _quantity: Integer; _weight: Decimal): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2021	jlier1	Initial creation 52626

*/

vars
	outstandingCount : Integer;
	stagedWeight : Decimal [16,4];
	outstandingWeight : Decimal [16,4];
	stagedCount : Integer;
begin

	self.getTotalStagedOrSelected(stagedCount,stagedWeight);
	if self.weightRequested &gt; 0 then
		outstandingWeight := self.getWeightOutstanding;
		return stagedWeight + _weight &gt; outstandingWeight;
	else
		outstandingCount := self.getTotalOutstanding;
		if _quantity &lt;&gt; 0 then																																							
			return ( stagedCount + _quantity ) &gt; outstandingCount;		
		else
			if _ti &lt;&gt; null then																																							//+TFS38573
				return ( stagedCount + _ti.totalQuantity ) &gt; outstandingCount;	
			endif;
		endif;
		return stagedCount &gt; outstandingCount;			
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="wouldBeOverStaged" id="9bd20645-961d-483e-bef1-73acab389d9e">
        <source>wouldBeOverStaged(_ti: CM_TrackedItem; _quantity: Integer; _weight: Decimal): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2015	cnwndl1	Initial creation	Par 37288
28 May 2018	jlgrh7	Initial creation TFS38573

*/

vars

	tiSet : CM_TISet;
	firstStagingLC : CM_LocationsController;
	stagedCount : Integer;
	outstandingCount : Integer;
	stagedWeight : Decimal [16,4];
	outstandingWeight : Decimal [16,4];

begin

	create tiSet transient;
	
	
	stagedCount := self.getTotalStaged( tiSet, firstStagingLC, null );
	outstandingCount := self.getTotalOutstanding;
	
	if self.weightRequested &gt; 0 then
		outstandingWeight := self.getWeightOutstanding;
		stagedWeight := self.getWeightStaged;
		return stagedWeight + _weight &gt; outstandingWeight;
	else
		outstandingCount := self.getTotalOutstanding;
		if _quantity &lt;&gt; 0 then																																							
			return ( stagedCount + _quantity ) &gt; outstandingCount;
		else
			//return ( stagedCount + _ti.totalQuantity ) &gt; outstandingCount;	//09 May 2016	NDL						- TFS38573
			if _ti &lt;&gt; null then																																							//+TFS38573
				return ( stagedCount + _ti.totalQuantity ) &gt; outstandingCount;	
			endif;
		endif;
		return stagedCount &gt; outstandingCount;																												//+TFS38573
	endif;

epilog

	delete tiSet;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
