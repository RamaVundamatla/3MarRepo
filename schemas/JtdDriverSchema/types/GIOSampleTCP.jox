    <JadeMethod name="handleShowModal" id="e2f54dfc-ad15-483d-b9db-49a3e0b21b52">
        <updating/>
        <source>handleShowModal():Integer updating;

vars
	sa:StringArray;
	meth:String;
	atcgModalCount:Integer;
begin
	create sa transient;
	app.atcgModalCount:=app.atcgModalCount+1;
	atcgModalCount:=app.atcgModalCount;

	if atcgModalCount = 1 then
		myCMUI_ErrorWarningDialog_1:=app.getForm('CMUI_ErrorWarningDialog').CMUI_ErrorWarningDialog;
		myCMUI_ErrorWarningDialog_1.show;
		myCMUI_ErrorWarningDialog_1.activate;
		sa.add('tp032m_CEWD_btnCancel_click');
	endif;

	foreach meth in sa do
		if meth[6:3] &lt;&gt; "mv_" then
			app.doWindowEvents(longPause);
		endif;
		userPreTransaction(meth);
		retCode:=self.sendMsg(meth).Integer;
		userPostTransaction(meth);
		if retCode = 0 then
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" succeeded");
		else
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" failed with error code "&amp;retCode.String);
			app.atcgReplayFailure:=true;
			break;
		endif;
	endforeach;

	if atcgModalCount = 1 then
		if app.isValidObject(myCMUI_ErrorWarningDialog_1) then
			myCMUI_ErrorWarningDialog_1.unloadForm;  // 16:06:35
		endif;
		myCMUI_ErrorWarningDialog_1:=null;
		return -1;
	endif;
epilog
	delete sa;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
