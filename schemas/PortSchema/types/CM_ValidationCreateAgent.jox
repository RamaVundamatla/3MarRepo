        <source>valCM_Object(_pxyCMObject : CM_Object; _passport : CM_Passport input);
//-----------------------------------------
//Created: April 2005 By: cnwgd1
//-----------------------------------------
begin

	self.raiseExceptionIfNull(_pxyCMObject, 'CM_Object Proxy');
	_pxyCMObject.raiseExceptionIfNotTransient(method);
   
	_pxyCMObject.validateCreate(_passport);

