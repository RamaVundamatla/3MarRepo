vars

begin
	return 10;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLastPoint" id="fab3b917-ebef-41a1-afc9-a163eb1f14e6">
        <source>getLastPoint(_onDeck : Boolean;_flipH : Boolean) : SHP_BayPoint;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		return last on deck
//
// ---------------------------------------------------------------------------

vars
	tmpPoint,aBayPoint : SHP_ProfilePoint;
	aPoint : CMUI_GridPoint;
	aCol : CMUI_GridColumn;
	found : Boolean;
begin
	// PAR 28701
	if self.isVoyageDecksOnly() then
		return self.allGridPoints.first.SHP_BayPoint;
	endif;

	if _flipH then
		if _onDeck then 
			foreach aCol in self.allGridColumns  do
				foreach aPoint in aCol.allGridPointsByRow do
					aBayPoint := aPoint.SHP_ProfilePoint;
					
					if  aBayPoint.onDeck then
						found := true;
					endif;
					if not  aBayPoint.onDeck and found then
						return tmpPoint;
					endif;
					
					tmpPoint := aBayPoint;
				endforeach;
				if found then
					return aBayPoint;
				endif;
			endforeach;
		else
			foreach aCol in self.allGridColumns  do
				foreach aPoint in aCol.allGridPointsByRow do
					aBayPoint := aPoint.SHP_ProfilePoint;
					
					if not aBayPoint.onDeck then
						return aBayPoint;
					endif;
					
				endforeach;
			
			endforeach;
		
		endif;
	
	else
		if _onDeck then 
			foreach aCol in self.allGridColumns reversed do
				foreach aPoint in aCol.allGridPointsByRow do
					aBayPoint := aPoint.SHP_ProfilePoint;
					
					if  aBayPoint.onDeck then
						found := true;
					endif;
					if not  aBayPoint.onDeck and found then
						return tmpPoint;
					endif;
					
					tmpPoint := aBayPoint;
				endforeach;
				if found then
					return aBayPoint;
				endif;
			endforeach;
		else
			foreach aCol in self.allGridColumns reversed do
				foreach aPoint in aCol.allGridPointsByRow do
					aBayPoint := aPoint.SHP_ProfilePoint;
					
					if not aBayPoint.onDeck then
						return aBayPoint;
					endif;
					
				endforeach;
			
			endforeach;
		
		endif;
	endif;	
		

	return null;
	
end;</source>
        <Parameter name="_onDeck" type="Boolean"/>
        <Parameter name="_flipH" type="Boolean"/>
        <ReturnType type="SHP_BayPoint"/>
    </JadeMethod>
    <JadeMethod name="getLastUnderdeckX" id="0d9fb71f-87dd-44f1-8ef3-ee36d207e1f0">
        <source>getLastUnderdeckX() : Real;

vars
	x	: Real;
	column	: CMUI_GridColumn;
	bayColumn	: SHP_BayColumn;
begin
	// PAR 28701
	if self.isVoyageDecksOnly() then
		return self.allGridPoints.first.SHP_BayPoint.x1;
	endif;

	foreach column in self.allGridColumns do
		bayColumn := column.SHP_BayColumn;
		if bayColumn.hasUnderdeckBays then
			x := bayColumn.x2;
		endif;
	endforeach;
	
	return x;
end;
</source>
        <ReturnType type="Real"/>
    </JadeMethod>
