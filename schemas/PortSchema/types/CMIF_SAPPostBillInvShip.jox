        <source>copyToRealWSObject(_realRequest: SAP17_PostBilllnvoiceRequest_DT_T_Ship_Item input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	inheritMethod(_realRequest, _createdObjects);
	
	_realRequest.basePort := self.basePort;
	_realRequest.callSign := self.callSign;
	_realRequest.countryID := self.countryID;
	_realRequest.dataSource := self.dataSource;
	_realRequest.destinationPort := self.destinationPort;
