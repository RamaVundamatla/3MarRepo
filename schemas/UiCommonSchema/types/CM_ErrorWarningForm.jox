    <JadeMethod name="tblData_displayRow" id="ca7e340f-e576-404c-a87a-f29d20bbc0a2">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	err			: CM_Error;
	errStr,
	outStr		: String;
	cellHeight	: Integer;
	tableRow	: JadeTableRow;

begin

	err := obj.CM_Error;
	
	// arm an exception handler to catch an error 4
	on Exception do self.displayRowExceptionHandler(exception);
		
	errStr := self.displayError(err);
	
	// disarm exception handler
	on Exception do null;
	
	if errStr = null then	
		return errStr;
	endif;

/*	
	if err.text = null then
		errStr := 'Unknown error ' &amp; err.errorCode.String;
	else
		errStr := err.text;
	endif;
*/
	table.CM_BaseTable.fitTextToCell(errStr, outStr, table.width.Integer, cellHeight);
	tableRow := table.accessRow(theRow);
	tableRow.height := cellHeight;
	
	if err.warningOnly then
		tableRow.foreColor := Blue;
	else
		tableRow.foreColor := Red;
	endif;
	
	return outStr;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="9a2d2701-b7af-4316-946b-837dc940440b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008356, locale);
	mnuFloating.translateCaption(Xlat_0008357, locale);
	mnuLockBottom.translateCaption(Xlat_0008358, locale);
	mnuLockLeft.translateCaption(Xlat_0008359, locale);
	mnuLockRight.translateCaption(Xlat_0008360, locale);
	mnuProperties.translateCaption(Xlat_0008361, locale);
end;</source>
    </JadeMethod>
