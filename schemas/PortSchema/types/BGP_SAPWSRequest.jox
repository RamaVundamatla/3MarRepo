        <source>isSAPWSRequest(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2019	jlgndl1	Initial creation	TFS 44248

*/

vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processSAPAutoEstReq" id="bd849426-4ac8-45f6-b76c-bee775021ac6">
        <source>processSAPAutoEstReq(_agent : CM_SAPWSConsumerAgent input) : Boolean protected;
/*

Purpose:			
	37189.001 Perform Credit Check for Auto-Collection Customer 
	WSDL 1.1: Auto-Collection - Credit Limit + Hold Amount
	PaymentType_AutoCollection		

Return Value:		

Date		Who		Reason
25/06/2018   cnwma1		ChangeRequest 38635: PEL1 - SAP Cancellations
*/
vars
	request   	: CMIF_SAPAutoEstReq;
	response  	: CMIF_SAPWSResponse;
	respStatus  : String;
	result    	: Boolean;
	msg       	: String;
begin
	
	create request transient;
	request.copyToSAPAutoEstReq(self.myCashReceipt);
	response := _agent.autocollEstimationRequest_SI(request);
	//01 Oct 2019	NDL	TFS 46758
	result := request.handleSAPResponse(	response,	//_response : CMIF_SAPWSResponse;
											self.myCashReceipt,	//_cashReceipt : CM_CashReceipt input;
											null,	//_invoice : CM_Invoice input;
											null,	//_invoiceLines : CM_InvoiceLineSet input;
											_agent.myLastActivityHistory	//_activityHistory : CM_ActivityHistoryExtInterface input
											);
	
	if response &lt;&gt; null then
		respStatus := response.status;
	endif;
	
	msg :=	method.qualifiedName &amp; 
			' ' &amp; BGP_SAPWSRequest.WSDL11  &amp; 
			' ' &amp; "CashReceipt : "     	&amp; self.myCashReceipt.externalInvoiceNumber &amp;
			' ' &amp; "Response Status :"  	&amp; respStatus &amp;
			' ' &amp; "isProcessed : "     	&amp; self.isProcessed.asStringJMT &amp;
			' ' &amp; "Result :"           	&amp; result.asStringJMT;
	app.writeLog(msg,LogINFO );
					
	return result;
epilog
	delete request;
	delete response;
end;</source>
        <access>protected</access>
        <Parameter name="_agent" type="CM_SAPWSConsumerAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processSAPAutoInvoiceReq" id="e07bcf53-bd02-4436-82ab-b55c40533e6b">
        <source>processSAPAutoInvoiceReq(_agent : CM_SAPWSConsumerAgent input) : Boolean protected;
/*

Purpose:			
	37189.005 Send Invoice / Data for Auto-Collection Customer
	WSDL 1.3: Auto-Collection - Revenue Journal + Incoming Cash Journal
	PaymentType_AutoCollection
Parameters:			

Return Value:		

Date		Who		Reason
02/07/2018  cnwma1	ChangeRequest 38633: PEL1 - SAP Send Invoice and Associated Data Interfaces

*/

vars
	request			: CMIF_SAPAutoInvReq;
	response		: CMIF_SAPWSResponse;
	result 		    : Boolean;
	respStatus,
	msg				: String;

begin
		
	create request transient;
	request.copyToSAPAutoInvReq(self.myInvoice);
	response := _agent.autocollInvoiceRequest_SI(request);
	//01 Oct 2019	NDL	TFS 46758
	result := request.handleSAPResponse(	response,	//_response : CMIF_SAPWSResponse;
											null,	//_cashReceipt : CM_CashReceipt input;
											self.myInvoice,	//_invoice : CM_Invoice input;
											null,	//_invoiceLines : CM_InvoiceLineSet input;
											_agent.myLastActivityHistory	//_activityHistory : CM_ActivityHistoryExtInterface input
											);
	
	if response &lt;&gt; null then
		respStatus := response.status;
	endif;
	
	msg:=  method.qualifiedName &amp; 
			' ' &amp; BGP_SAPWSRequest.WSDL13  &amp;
			' ' &amp; "Invoice : " 	           &amp; self.myInvoice.exportCurrencyCode &amp;
			' ' &amp; "Response Status :" 	   &amp; respStatus &amp;
			' ' &amp; "isProcessed : "    	   &amp; self.isProcessed.asStringJMT &amp;
			' ' &amp; "Result :" 		   	   &amp; result.asStringJMT;
	app.writeLog(msg,LogINFO);
	
	return result;
epilog
	delete request;
	delete response;
end;</source>
        <access>protected</access>
        <Parameter name="_agent" type="CM_SAPWSConsumerAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processSAPCancelEstimate" id="35ecb204-3e44-4790-8b90-03f6a8669b8b">
        <source>processSAPCancelEstimate(_agent : CM_SAPWSConsumerAgent input) : Boolean protected;
/*

Purpose:			
	37189.009 Cancel Estimation
	WSDL 1.10: Auto-Collection - Estimation Cancellation
	PaymentType_AutoCollection
Parameters:			

Return Value:		

Date		Who		Reason
25/06/2018   cnwma1		ChangeRequest 38635: PEL1 - SAP Cancellations

*/

vars
	request			: CMIF_SAPAutoCancelReq;
	response		: CMIF_SAPWSResponse;
	result          : Boolean;
	respStatus,
	msg				: String;
begin
	
	create request transient;
	request.copyToSAPAutoCancelReq(self.myCashReceipt);

	response := _agent.autocollCancellationRequest_SI(request);
	//01 Oct 2019	NDL	TFS 46758
	result := request.handleSAPResponse(	response,	//_response : CMIF_SAPWSResponse;
											self.myCashReceipt,	//_cashReceipt : CM_CashReceipt input;
											null,	//_invoice : CM_Invoice input;
											null,	//_invoiceLines : CM_InvoiceLineSet input;
											_agent.myLastActivityHistory	//_activityHistory : CM_ActivityHistoryExtInterface input
											);
	
	if response &lt;&gt; null then
		respStatus := response.status;
	endif;
	msg := method.qualifiedName &amp; 
		   ' ' &amp; BGP_SAPWSRequest.WSDL110  &amp; 
		   ' ' &amp; "CashReceipt : " 	 	 &amp; self.myCashReceipt.externalInvoiceNumber &amp;
		   ' ' &amp; "Response Status :"   	 &amp; respStatus &amp;
		   ' ' &amp; "isProcessed : "      	 &amp; self.isProcessed.asStringJMT &amp;
		   ' ' &amp; "Result :"            	 &amp; result.asStringJMT;
	
	app.writeLog(msg,LogINFO );
	
	return result;
epilog
	delete request;
	delete response;
end;</source>
        <access>protected</access>
        <Parameter name="_agent" type="CM_SAPWSConsumerAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processSAPCancelPaymentCode" id="d1b2d6b8-ce06-4df6-ad8d-0c2b9c66b332">
        <source>processSAPCancelPaymentCode(_agent : CM_SAPWSConsumerAgent input) : Boolean protected;
/*

Purpose:			
	37189.010 Cancel Payment Code
	WSDL 1.11: Pre-Billing - Cancellation
	PaymentType_PrePay
Parameters:			

Return Value:		

Date		Who		Reason
25/06/2018   cnwma1		ChangeRequest 38635: PEL1 - SAP Cancellations

*/

vars
	request			: CMIF_SAPPreBillCancelReq;
	response		: CMIF_SAPWSResponse;
	result          : Boolean;
	respStatus,
	msg				: String;
begin
	
	create request transient;
	request.copyToSAPPreBillCancelReq(self.myInvoice);
	response := _agent.preBillCancellationRequest_SI(request);
	//01 Oct 2019	NDL	TFS 46758
	result := request.handleSAPResponse(	response,	//_response : CMIF_SAPWSResponse;
											null,	//_cashReceipt : CM_CashReceipt input;
											self.myInvoice,	//_invoice : CM_Invoice input;
											null,	//_invoiceLines : CM_InvoiceLineSet input;
											_agent.myLastActivityHistory	//_activityHistory : CM_ActivityHistoryExtInterface input
											);
	
	if response &lt;&gt; null then
		respStatus := response.status;
	endif;

	msg :=  method.qualifiedName            &amp; 
			' ' &amp; BGP_SAPWSRequest.WSDL111  &amp;
			' ' &amp; "Invoice : " 	            &amp; self.myInvoice.exportCurrencyCode &amp;
			' ' &amp; "Response Status :"       &amp; respStatus &amp;
			' ' &amp; "isProcessed : "          &amp; self.isProcessed.asStringJMT &amp;
			' ' &amp; "Result :"                &amp; result.asStringJMT;
	
	app.writeLog(msg,LogINFO);
	
	return result;
epilog
	delete request;
	delete response;
end;</source>
        <access>protected</access>
        <Parameter name="_agent" type="CM_SAPWSConsumerAgent" usage="input"/>
        <ReturnType type="Boolean"/>
