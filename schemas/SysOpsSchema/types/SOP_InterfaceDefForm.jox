    <JadeMethod name="create" id="b1b08da5-4ad0-4554-a817-a7bcd7deaf5d">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.permissionView		:=	PmAdmInterfaceDefView;
	self.permissionMaint	:=	PmAdmInterfaceDefMaint;
	
//	cmbLocales.visible := false;
//	btnDelete.visible := false;
//	btnSave.visible := false;
//	btnSetDefault.visible := false;
	
	self.isReadOnly	:=	not app.getMyUser.canDo(app.getMyTerminalDO_NOT_USE(), PmAdmInterfaceDefMaint);
//	plinthLocale.enabled := canDo;
//	btnNew.visible := canDo;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="065b32fc-590d-408a-b97c-0728dd1c8072">
        <updating/>
        <source>doDelete() updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 September 2008 by cnwdad1
//
// Purpose:		Deletes the currently selected Interface Definition.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	definitionObj	: CM_TCPInterfaceDefinition;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	definitionObj	:=	self.myDefinition;
	
	if definitionObj = null then
		return;
	else
		if global.cnEcConfirmDelete(definitionObj.name) then
		
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxDA.trxDeleteInterfaceDefinition(definitionObj, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					self.doPopulateWithDefinition(null, true);
					break;
				else
					theResult := app.showErrorWarningDialog("Interface Definition", app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				break;
				
			endwhile;
	
			
		endif;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEnableControls" id="85c5a809-054f-46a0-9aac-1d81a9904dc8">
        <source>doEnableControls() protected;
// --------------------------------------------------------------------------------
// Created:		08 September 2008 by cnwdad1
//
// Purpose:		Enables/disables the receiver's controls based upon the current state
//				of the data/form.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isReadOnly then
		btnSave.enabled			:=	false;
		btnNew.enabled			:=	false;
		btnDelete.enabled		:=	false;
		btnTAdd.enabled			:=	false;
		btnTRemove.enabled		:=	false;
		btnHookConAttr.enabled			:=	false; // TFS 2198
		btnHookConUniq.enabled:= false; // TFS 2198
		btnHookLocTran.enabled:= false; // TFS 2198
		btnResetInterfac.enabled:= false; // TFS 2198
		
		txtName.readOnly		:=	true;
		cmbLocale.enabled		:=	false;
		txtTcpAddress.readOnly	:=	true;
		txtTcpPort.readOnly		:=	true;
		txtTcpTimeout.readOnly	:=	true;
		txtSessionTO.readOnly	:=	true;
		txtAppCopies.readOnly	:=	true;
	else
		txtName.readOnly		:=	false;
		cmbLocale.enabled		:=	true;
		txtTcpAddress.readOnly	:=	false;
		txtTcpPort.readOnly		:=	false;
		txtTcpTimeout.readOnly	:=	false;
		txtSessionTO.readOnly	:=	false;
		txtAppCopies.readOnly	:=	false;
		btnNew.enabled			:=	true;
		btnTAdd.enabled			:=	true;
		
		if self.myDefinition = null then
			btnSave.enabled			:=	(self.myProxy &lt;&gt; null);
			btnDelete.enabled		:=	false;
		else
			btnSave.enabled			:=	true;
			btnDelete.enabled		:=	true;
		endif;
		
		if tblTranslations.cnEcIsValidRow(tblTranslations.row) then
			btnTRemove.enabled		:=	true;
		else
			btnTRemove.enabled		:=	false;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPopulateWithDefinition" id="caf0eca4-21e4-4ee0-9ea9-7b62f9313600">
        <updating/>
        <source>doPopulateWithDefinition(_tcpDefinitionObj:CM_TCPInterfaceDefinition; _isNewDefinition:Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Populates the receiver's controls with data from the specified TCP
//				Interface Definition.
//
// Parameters:	_tcpDefinitionObj - A reference to the TCP Interface Definition to
//					populate from.
//				_isNewDefinition - True if a new Interface Definition is being created.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	proxyObj	: CM_TCPInterfaceDefinition;
	
begin
	delete self.myProxy;
	
	if _tcpDefinitionObj = null then
		self.myDefinition	:=	null;
		self.tablePopulateTranslations(null);
		
		txtName.cnEcSet(null);
		cmbType.cnEcSetTextIndex(TCPListener);
		cmbLocale.cnEcSet(CNEC_NULL_INDEX);
		txtTcpAddress.cnEcSet(null);
		txtTcpPort.cnEcSet(null);
		txtTcpTimeout.cnEcSet(null);
		txtSessionTO.cnEcSet(null);
		txtAppCopies.cnEcSet(null);
		txtMaxQEntries.cnEcSet(null);
		txtMessageACKTO.cnEcSet(null);
		
		if _isNewDefinition then
			create proxyObj transient;
			self.myProxy	:=	proxyObj;
			cmbDefinition.listIndex	:=	CNEC_NULL_INDEX;
			fldDefinition.topSheet	:=	shtDetails;
			txtName.setFocus();
		endif;
	else
		cmbDefinition.cnEcSetObjectIndex(_tcpDefinitionObj);
		txtName.cnEcSet(_tcpDefinitionObj.name);
		cmbLocale.cnEcSetObjectIndex(_tcpDefinitionObj.myLocale);
		txtTcpAddress.cnEcSet(_tcpDefinitionObj.localAddress);
		txtTcpPort.cnEcSet(_tcpDefinitionObj.localPortNumber.asStringJMT());
		txtTcpTimeout.cnEcSet(_tcpDefinitionObj.tcpTimeout.asStringJMT());
		txtSessionTO.cnEcSet(_tcpDefinitionObj.sessionTimeout.asStringJMT());
		txtAppCopies.cnEcSet(_tcpDefinitionObj.applicationCopies.asStringJMT());
		//05/01/2010 cnwdz2 21593 
		if _tcpDefinitionObj.isKindOf(CM_ITSInterfaceDefinition) then
			self.cmbType.cnEcSetTextIndex(ITSRNSServer);
			self.txtMaxQEntries.cnEcSet(_tcpDefinitionObj.CM_ITSInterfaceDefinition.maxQEntriesPerMachine.asStringJMT());
			self.txtMessageACKTO.cnEcSet(_tcpDefinitionObj.CM_ITSInterfaceDefinition.messageTimeout.asStringJMT());
		else
			self.cmbType.cnEcSetTextIndex(TCPListener);
		endif;
		
		self.myDefinition	:=	_tcpDefinitionObj;
		self.doSaveEdition();
		proxyObj			:=	_tcpDefinitionObj.pxyCreateUpdateProxy();
		self.myProxy		:=	proxyObj;
		self.tablePopulateTranslations(proxyObj);
	endif;
	self.cmbType.click(self.cmbType);
	
	if self.myProxy = null then
		self.setNavigatorHeading(app.getString(New));
	else
		if self.myProxy.name = null then
			self.setNavigatorHeading(app.getString(New));
		else
			self.setNavigatorHeading(self.myProxy.name);
		endif;
	endif;
	
	self.getGetUserHookSources();
	self.setFormChanged(false, btnNew, btnSave, btnDelete, btnCancel);
	self.resetFirstChange();	// Need this, otherwise Jade doesn't know to track changes.
end;</source>
        <access>protected</access>
        <Parameter name="_tcpDefinitionObj" type="CM_TCPInterfaceDefinition"/>
        <Parameter name="_isNewDefinition" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQueryUnload" id="e0f31d52-44da-46bc-ac9b-5c4d9d84d980">
        <source>doQueryUnload(_cancel:Integer output; _reason:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		19 September 2008 by cnwdad1
//
// Purpose:		Checks whether the user wishes to abandon data changes.
//
// Parameters:	_cancel - A return code to indicate whether or not to proceede with
//					the form unload.
//				_reason - A code indicating the reason why the form is unloading.
//
// Returns:		The "cancel" return code, via the output parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	CANCEL_UNLOAD	: Integer = 1;
	
vars
	userResponse	: Integer;
	
begin
	if self.isFormChanged then
		if _reason = Form.QueryUnload_User 
		or _reason = Form.QueryUnload_UnloadMethod
		or _reason = Form.QueryUnload_MdiChild
		then
			userResponse	:=	app.msgBox(	app.getErrorString(EditChangedAndClosing),
											self.caption &amp; " Window Closing !",
											MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
			
			if userResponse = MsgBox_Return_No then
				_cancel	:=	CANCEL_UNLOAD;	//Do not close form.
			endif;			
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_cancel" type="Integer" usage="output"/>
        <Parameter name="_reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doResetInterface" id="762c0f83-2444-4cef-b7a2-b22c7431e1df">
        <source>doResetInterface();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 January 2010	#cnwdz2	 par21593

*/

vars

	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxITSInterfaceReset(self.myDefinition.CM_ITSInterfaceDefinition, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog("Interface Definition", app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="0cc1aa07-49ab-4da3-a9ea-b97374dd0ca3">
        <updating/>
        <source>doSave() updating, protected;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Standard form update method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	definitionObj	: CM_TCPInterfaceDefinition;
	proxyObj		: CM_TCPInterfaceDefinition;
	itsProxyObj	 	: CM_ITSInterfaceDefinition;
	proxyTransObj	: CM_InterfaceTranslationTA;
	termAreaObj		: CM_TerminalAreaMaster;
	defName			: String;
	localeObj		: CM_Locale;
	tcpAddress		: String;
	tcpPort			: Integer;
	tcpTimeout		: Integer;
	sessionTO		: Integer;
	appCopies		: Integer;
	
	tableObj		: CM_BaseTable;
	rowObj			: JadeTableRow;
	cellObj			: JadeTableCell;
	startRow		: Integer;
	maxRow			: Integer;
	rowPointer		: Integer;
	tranString		: String;
	destination		: String;
	
	interfaceType   : String;
	maxQEntriesPerMachine : Integer;
	messageTimeout : Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	if not self.validateForm() then
		return;
	endif;
	
	definitionObj	:=	self.myDefinition;
	//05/012010 cnwdz2 par21593
	interfaceType := self.cmbType.text;
	if definitionObj = null and interfaceType = ITSRNSServer then
		delete self.myProxy;
		create itsProxyObj transient;
		self.myProxy := itsProxyObj;
	endif;
	proxyObj		:=	self.myProxy;
	
	// Fetch the definition properties.
	defName		:=	txtName.cnEcString();
	localeObj	:=	cmbLocale.listObject.CM_Locale;
	tcpAddress	:=	txtTcpAddress.cnEcString();
	tcpPort		:=	txtTcpPort.cnEcInteger();
	tcpTimeout	:=	txtTcpTimeout.cnEcInteger();
	sessionTO	:=	txtSessionTO.cnEcInteger();
	appCopies	:=	txtAppCopies.cnEcInteger();
	
	//05/012010 cnwdz2 par21593
	if interfaceType = ITSRNSServer then
		maxQEntriesPerMachine := self.txtMaxQEntries.cnEcInteger();
		messageTimeout := self.txtMessageACKTO.cnEcInteger();
		proxyObj.CM_ITSInterfaceDefinition.setITSProxy(	defName,
														appCopies,
														tcpAddress,
														tcpPort,
														sessionTO,
														tcpTimeout,
														localeObj,
														self.myTerminal,
														self.sourceContainerAttr,
														self.sourceLocationTrans,
														self.sourceContainerUnique,
														maxQEntriesPerMachine,
														messageTimeout);
	else
		proxyObj.setProxy(	defName,
							appCopies,
							tcpAddress,
							tcpPort,
							sessionTO,
							tcpTimeout,
							localeObj,
							self.myTerminal,
							self.sourceContainerAttr,
							self.sourceLocationTrans,
							self.sourceContainerUnique
							);
	endif;
	
	// Fetch the Interface Translations.
	
	tableObj	:=	tblTranslations;
	startRow	:=	tableObj.fixedRows + 1;
	maxRow		:=	tableObj.rows;
	
	foreach rowPointer in startRow to maxRow do
		rowObj			:=	tableObj.accessRow(rowPointer);
		proxyTransObj	:=	rowObj.itemObject.CM_InterfaceTranslationTA;
		
		cellObj			:=	tableObj.accessCell(rowPointer, 1);
		termAreaObj		:=	cellObj.itemObject.CM_TerminalAreaMaster;
		
		tranString		:=	tableObj.getCellText(rowPointer, 2);
		destination		:=	tableObj.getCellText(rowPointer, 3);
		
		proxyTransObj.setProxy(tranString, destination, proxyObj, termAreaObj);
	endforeach;
	
	// Call the create/update transaction.
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if definitionObj = null then
			// Creating a new Interface Definition.
			app.myTrxCA.trxCreateInterfaceDefinition(proxyObj, definitionObj, app.myPassport);
		else
			// Updating an existing Interface Definition.
			app.myTrxUA.trxUpdateInterfaceDefinition(proxyObj, app.myPassport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			self.doPopulateWithDefinition(definitionObj, false);
			break;
		else
			theResult := app.showErrorWarningDialog("Interface Definition", app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSaveEdition" id="216b2fa3-6e58-48cc-9223-6fd8af0d7010">
        <updating/>
        <source>doSaveEdition() updating, protected;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Stores the object edition of the currently selected Interface
//				Definition.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// --------------------------------------------------------------------------------
begin
	self.objEdition	:=	self.myDefinition.edition;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowHookCodeEditor" id="adf6e1ca-8a38-455e-b471-4829b722c6c8">
        <updating/>
        <source>doShowHookCodeEditor(_hookTypeCode:Integer) updating, protected;
// --------------------------------------------------------------------------------
// Created:		16 September 2008 by cnwdad1
//
// Purpose:		Opens the User Hook Code editor for the specified Hook Type.
//
// Parameters:	_hookTypeCode - The code type of user hook to use (refer to the
//					"HookTypes" category of Global Constants).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	hookTypeObj	: CM_HookType;
	sourceCode	: String;
	
begin
	hookTypeObj	:=	app.myRoot.allHookTypes[_hookTypeCode];
	
	if hookTypeObj = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "User Hook type not found: " &amp; _hookTypeCode.String);
		return;
	endif;
	
	if _hookTypeCode = HookType_ContainerAttributes then
		sourceCode	:=	self.sourceContainerAttr;
	elseif _hookTypeCode = HookType_ContainerUnique then	//29 Mar 2011	NDL	Par 27290
		sourceCode	:=	self.sourceContainerUnique;
	elseif _hookTypeCode = HookType_LocationTranslation then
		sourceCode	:=	self.sourceLocationTrans;
	endif;
	
	if app.showHookCodeMaintForm(hookTypeObj, sourceCode, false) then
		self.setFormChanged(true, btnNew, btnSave, btnDelete, btnCancel);
		
		if _hookTypeCode = HookType_ContainerAttributes then
			self.sourceContainerAttr	:=	sourceCode;
		elseif _hookTypeCode = HookType_ContainerUnique then	//29 Mar 2011	NDL	Par 27290
			self.sourceContainerUnique	:=	sourceCode;
		elseif _hookTypeCode = HookType_LocationTranslation then
			self.sourceLocationTrans	:=	sourceCode;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_hookTypeCode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTranslationAdd" id="37c4c1c8-2b11-4ad1-8ef6-ea22ac420f2e">
        <source>doTranslationAdd() protected;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Adds a new Interface Translation object for the current Interface
//				Definition.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj		: CM_BaseTable;
	rowPointer		: Integer;
	translationObj	: CM_InterfaceTranslationTA;
	
begin
	tableObj	:=	tblTranslations;
	create translationObj transient;
//	translationObj.setInterfaceDefinition(self.aMyProxy);
	
	rowPointer		:=	tableObj.addItem(null);
	tableObj.accessRow(rowPointer).itemObject	:=	translationObj;
	tableObj.row	:=	rowPointer;
	tableObj.column	:=	1;
	tableObj.setFocus();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTranslationRemove" id="51dacd18-1441-483a-97d9-4e5194f2986d">
        <source>doTranslationRemove() protected;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Removes the currently selected Interface Translation.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj		: CM_BaseTable;
	rowPointer		: Integer;
	translationObj	: CM_InterfaceTranslationTA;
	
begin
	tableObj	:=	tblTranslations;
	rowPointer	:=	tableObj.row;
	
	if tableObj.cnEcIsValidRow(rowPointer) then
		translationObj	:=	tableObj.accessRow(rowPointer).itemObject.CM_InterfaceTranslationTA;
		
		if translationObj &lt;&gt; null then
			delete translationObj;
		endif;
		
		tableObj.removeItem(rowPointer);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="firstChange" id="412969ed-05d6-4f8a-be09-e204e58ec76e">
        <controlMethod name="Form::firstChange"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>firstChange(cntrl: Control input) updating;
// --------------------------------------------------------------------------------
// Created:		19 September 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if cntrl &lt;&gt; cmbDefinition then
		//self.isFormChanged	:=	true;
		self.setFormChanged(true, btnNew, btnSave, btnDelete, btnCancel);
	endif;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getGetUserHookSources" id="341d7ae6-1d8f-4f03-8298-584b002c030a">
        <updating/>
        <source>getGetUserHookSources() updating, protected;
// --------------------------------------------------------------------------------
// Created:		18 September 2008 by cnwdad1
//
// Purpose:		Fetches the latest jade source code from the User Hooks that are
//				maintained from this form.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	definitionObj	: CM_TCPInterfaceDefinition;
	
begin
	definitionObj	:=	self.myProxy;
	
	if definitionObj = null then
		self.sourceContainerAttr	:=	null;
		self.sourceLocationTrans	:=	null;
	else
		self.sourceContainerAttr	:=	definitionObj.getJadeHookCode(HookType_ContainerAttributes);
		self.sourceContainerUnique	:=	definitionObj.getJadeHookCode(HookType_ContainerUnique);//29 Mar 2011	NDL	Par 27290
		self.sourceLocationTrans	:=	definitionObj.getJadeHookCode(HookType_LocationTranslation);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getSelectedIntTranslation" id="c9816b82-ef00-4b17-ae51-672fee95855c">
        <source>getSelectedIntTranslation():CM_InterfaceTranslationTA protected;
// --------------------------------------------------------------------------------
// Created:		05 September 2008 by cnwdad1
//
// Purpose:		Returns a reference to the currently selected Interface Translation
//				object.
//
// Parameters:	None
//
// Returns:		A reference to the selected Interface Translation object, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj		: CM_BaseTable;
	rowObj			: JadeTableRow;
	rowPointer		: Integer;
	translationObj	: CM_InterfaceTranslationTA;
	
begin
	tableObj	:=	tblTranslations;
	rowPointer	:=	tableObj.row;
	
	if tableObj.cnEcIsValidRow(rowPointer) then
		rowObj	:=	tableObj.accessRow(rowPointer);
		translationObj	:=	rowObj.itemObject.CM_InterfaceTranslationTA;
		
		return translationObj;
	endif;
	
	return null;
end;</source>
        <access>protected</access>
        <ReturnType type="CM_InterfaceTranslationTA"/>
    </JadeMethod>
