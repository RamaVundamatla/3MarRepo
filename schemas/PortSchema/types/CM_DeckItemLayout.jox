    </JadeMethod>
    <JadeMethod name="isSelectableByMode" id="396de970-d584-46a3-a6bd-ba20e40c5eca">
        <source>isSelectableByMode(_modeView : Integer) : Boolean;
/*
Purpose:			
Date		Who		Reason
11 October 2011	cnwab1	Initial creation
*/

vars

begin
	if _modeView = ShpDisplayMode_Actual then
		// if covered by an actual GC Location, will be invisible when cargo is discharged
		if self.isCoveredByVisible(DeckItemLayoutType_GCDischarge)  then 
			return false;
		endif;
		if self.isCoveredByDefnWithCCCompleted(DeckItemLayoutType_GCLoad, true)  then  // PAR 29807
			return false;
		endif;
	elseif _modeView = ShpDisplayMode_ColCodeDisch then
		// if covered by an actual GC Colour Coding
		if self.isCovered(DeckItemLayoutType_CCDischarge,true)  then
			return false;
		endif;
	elseif _modeView = ShpDisplayMode_ColCodeLoad then
		// if covered by an actual GC Colour Coding
		if self.isCovered(DeckItemLayoutType_CCLoad,true)  then
			return false;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_modeView" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVerticalOrientation" id="b73aeec7-a2a4-44d0-8a73-5cb48e813de3">
        <source>isVerticalOrientation() : Boolean;
/*
Purpose:			
Date		Who		Reason
22 February 2013	cnwab1	Initial creation
*/

vars

	x1,x2,y1, y2, lenW, lenH : Integer;
begin
		x1 := self.myPolygonPixels[1].x;
		x2 := self.myPolygonPixels[2].x;
		y1 := self.myPolygonPixels[2].y;
		y2 := self.myPolygonPixels[3].y;
		
		lenW := x2 - x1;
		lenH := y2-y1;
		
		return (lenH &gt; lenW); // higher than the width


epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveAftWithForward" id="fe48e4de-ee20-4005-b507-cf49d8f20a11">
        <source>moveAftWithForward(_rotate : Boolean) : Boolean;
/*
Purpose:			
Date		Who		Reason
14 October 2011	cnwab1	Initial creation
*/
//24 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
//
vars
	allStateData : CM_StateDataDict;
	locnGap, locnLength, locnWidth : Decimal[12,2];
	newPoints: PointArray;
	newPoint : Point;
begin
	if self.myDeckItem = null then
		return false;
	endif;
	
	if not self.myDeckItem.isOOTL() then
		return false;
	endif;
		
	if self.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotAft = null then
		return false;  // is a 20 OOTL
	endif;
	
	allStateData := self.getStateData();
	if allStateData = null then
		return false;
	endif;
	
	global.getExtraData(allStateData,RoRoLocationGap,locnGap);
	global.getExtraData(allStateData,RoRoLocationWidth,locnWidth);
	global.getExtraData(allStateData,RoRoLocationLength,locnLength);

	locnGap := locnGap * ROROStructurePixelsPerMetre;
	locnWidth := (locnWidth * ROROStructurePixelsPerMetre) - 1;
	locnLength := (locnLength * ROROStructurePixelsPerMetre) - 1; 

	if _rotate then	// if we are doing this for a rotation save off the pre rotated points
		self.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotAft.setMyPreRotatePoints(self.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotAft.myLayout);	//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
	endif;

 	self.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotAft.setIsPlannedRotated(self.myDeckItem.CM_ROROLocnDefn.isPlannedRotated); // PAR 29990
	self.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotAft.setOrientation(self.myDeckItem.CM_ROROLocnDefn.orientation); // PAR 29990
	
	create newPoints transient;

	// PAR 28886
	if self.myDeckItem.CM_ROROLocnDefn.isVerticalOrientation() then
		newPoint.set(self.myPolygonPixels[1].x ,(self.myPolygonPixels[1].y - locnGap - locnLength).Integer - 1 ); // PAR 29990 added -1
		newPoints.add(newPoint);
		newPoint.set(self.myPolygonPixels[2].x ,(self.myPolygonPixels[1].y - locnGap - locnLength).Integer - 1 );
		newPoints.add(newPoint);
		newPoint.set(self.myPolygonPixels[2].x ,(self.myPolygonPixels[1].y - locnGap).Integer - 1 );
		newPoints.add(newPoint);
		newPoint.set(self.myPolygonPixels[1].x ,(self.myPolygonPixels[1].y - locnGap).Integer - 1 );
		newPoints.add(newPoint);
		newPoint.set(self.myPolygonPixels[1].x ,(self.myPolygonPixels[1].y - locnGap - locnLength).Integer - 1 );
		newPoints.add(newPoint);
	else
		newPoint.set((self.myPolygonPixels[1].x - locnGap - locnLength).Integer - 1  ,self.myPolygonPixels[1].y);
		newPoints.add(newPoint);
		newPoint.set((self.myPolygonPixels[1].x - locnGap).Integer - 1 , self.myPolygonPixels[1].y);
		newPoints.add(newPoint);
		newPoint.set((self.myPolygonPixels[4].x - locnGap).Integer - 1 , self.myPolygonPixels[4].y);
		newPoints.add(newPoint);
		newPoint.set((self.myPolygonPixels[4].x - locnGap - locnLength).Integer - 1 , self.myPolygonPixels[4].y);
		newPoints.add(newPoint);
		newPoint.set((self.myPolygonPixels[1].x - locnGap - locnLength).Integer - 1  ,self.myPolygonPixels[1].y);
		newPoints.add(newPoint);
	endif;
	
	// Move the aft 20 slot to be in line with this forward 20 foot slot.
	 self.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotAft.myLayout.setPointsPolygon(newPoints);
	
	// PAR 28886
//	if self.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotAft.orientation &lt;&gt; self.myDeckItem.CM_ROROLocnDefn.orientation then
//		self.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotAft.setOppositeOrientation();
//	endif;
	 
	 return true;
epilog
	delete newPoints;
end;</source>
        <Parameter name="_rotate" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveForwardWithAft" id="75307b53-d7ef-47ba-b233-8e997802ed9b">
        <source>moveForwardWithAft(_rotate : Boolean) : Boolean;
/*
Purpose:			
Date		Who		Reason
14 October 2011	cnwab1	Initial creation
*/
//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
//
vars
	allStateData : CM_StateDataDict;
	locnGap, locnLength, locnWidth : Decimal[12,2];
	newPoints: PointArray;
	newPoint : Point;
begin
	if self.myDeckItem = null then
		return false;
	endif;
	
	if not self.myDeckItem.isOOTL() then
		return false;
	endif;
		
	if self.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotFwd = null then
		return false;  // is a 20 OOTL
	endif;
	
	allStateData := self.getStateData();
	if allStateData = null then
		return false;
	endif;
	
	global.getExtraData(allStateData,RoRoLocationGap,locnGap);
	global.getExtraData(allStateData,RoRoLocationWidth,locnWidth);
	global.getExtraData(allStateData,RoRoLocationLength,locnLength);

	locnGap := locnGap * ROROStructurePixelsPerMetre;
	locnWidth := (locnWidth * ROROStructurePixelsPerMetre) - 1;
	locnLength := (locnLength * ROROStructurePixelsPerMetre) - 1; 

	if _rotate then	// if we are doing this for a rotation save off the pre rotated points
		self.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotFwd.setMyPreRotatePoints(self.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotFwd.myLayout);	//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
	endif;

	self.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotFwd.setIsPlannedRotated(self.myDeckItem.CM_ROROLocnDefn.isPlannedRotated); // PAR 29990
	self.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotFwd.setOrientation(self.myDeckItem.CM_ROROLocnDefn.orientation); // PAR 29990
	
	create newPoints transient;


	// PAR 28886
	if self.myDeckItem.CM_ROROLocnDefn.isVerticalOrientation() then
		newPoint.set(self.myPolygonPixels[1].x ,(self.myPolygonPixels[3].y + locnGap).Integer + 1); // PAR 29990 added +1
		newPoints.add(newPoint);
		newPoint.set(self.myPolygonPixels[2].x ,(self.myPolygonPixels[3].y + locnGap).Integer + 1);
		newPoints.add(newPoint);
		
		newPoint.set(self.myPolygonPixels[2].x, (self.myPolygonPixels[3].y + locnGap + locnLength).Integer + 1);
		newPoints.add(newPoint);
		newPoint.set(self.myPolygonPixels[1].x, (self.myPolygonPixels[3].y + locnGap + locnLength).Integer + 1);
		newPoints.add(newPoint);
		newPoint.set(self.myPolygonPixels[1].x ,(self.myPolygonPixels[3].y + locnGap).Integer + 1);
		newPoints.add(newPoint);
	
	else
		newPoint.set((self.myPolygonPixels[2].x + locnGap).Integer + 1 ,self.myPolygonPixels[1].y);
		newPoints.add(newPoint);
		newPoint.set((self.myPolygonPixels[2].x + locnGap + locnLength).Integer + 1, self.myPolygonPixels[1].y);
		newPoints.add(newPoint);
		newPoint.set((self.myPolygonPixels[3].x + locnGap + locnLength).Integer + 1, self.myPolygonPixels[4].y);
		newPoints.add(newPoint);
		newPoint.set((self.myPolygonPixels[3].x + locnGap).Integer + 1, self.myPolygonPixels[4].y);
		newPoints.add(newPoint);
		newPoint.set((self.myPolygonPixels[2].x + locnGap).Integer + 1 ,self.myPolygonPixels[1].y);
		newPoints.add(newPoint);
	endif;
	
	// Move the aft 20 slot to be in line with this forward 20 foot slot.
	 self.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotFwd.myLayout.setPointsPolygon(newPoints);

//	// PAR 28886
//	if self.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotFwd.orientation &lt;&gt; self.myDeckItem.CM_ROROLocnDefn.orientation then
//		self.myDeckItem.CM_ROROLocnDefn.myAdjacentSlotFwd.setOppositeOrientation();
//	endif;
	 
	 return true;
epilog
	delete newPoints;
end;</source>
        <Parameter name="_rotate" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="e46e9482-45c1-440b-8cda-7fcb8f44b0a8">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 20/04/2011		cnwmh5			PAR #27401 - Add code to handle prossible exceptions occurring when
//									trying to create the proxy
// ---------------------------------------------------------------------------

vars
	likeMe : SelfType;
	completedOK		: Boolean;
begin
	likeMe :=  inheritMethod();

	likeMe.myDeckItem := self.myDeckItem; // REAL - this is set to the proxy on the pxyCreateUpdateProxy of the deck item
	if self.myDeckLayer &lt;&gt; null then
		likeMe.myDeckLayer := self.myDeckLayer.pxyGetProxyObject();
	endif;
	if likeMe.myDeckLayer = null then
		likeMe.myDeckLayer := self.myDeckLayer;
	endif;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return likeMe;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete likeMe;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
