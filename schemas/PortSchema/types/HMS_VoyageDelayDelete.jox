<Class name="HMS_VoyageDelayDelete" id="4700619e-c7a2-4ceb-b8ae-5b36743e9da7">
    <superclass name="HMS_Transaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="hmsTrans"/>
    <ImplicitInverseRef name="myVoyageDelay" id="3a25e48b-a3cd-4ce8-9383-a3ad51d4a7fc">
        <embedded/>
        <type name="HMS_VoyageDelay"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="createPropertyChanges" id="628bd590-a82a-4e81-86ff-16bcf4b6ea75">
        <updating/>
        <source>createPropertyChanges(_cmifTrans: CMIF_HMS_TransactionController) updating, protected;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
 	propertyChange:	HMS_PropertyChange;
begin
	inheritMethod(_cmifTrans);

	create propertyChange;
	propertyChange.set(self, "Delay DELETED", null, null);

end;</source>
        <access>protected</access>
        <Parameter name="_cmifTrans" type="CMIF_HMS_TransactionController"/>
    </JadeMethod>
    <JadeMethod name="setGeneralProperties" id="589ba5fd-b3a2-4dcb-9dfa-9c83c8a7e67d">
        <updating/>
        <source>setGeneralProperties(_transController: CMIF_HMS_TransactionController; _passport: CM_Passport input) updating, protected;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_transController, _passport);
	if _transController.myPersistentVoyageDelay.archived then
		self.myVoyageDelay := _transController.myPersistentVoyageDelay;
	endif; 
end;</source>
        <access>protected</access>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTypeDetails" id="65a5cd92-59eb-4932-bcaa-fb9ed29d4db6">
        <updating/>
        <source>setTypeDetails() updating, protected;

vars

begin
 	// Set type and typeString
	type:=TRANS_TYPE_DeleteVoyageDelay;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validate" id="0a2cf857-b27b-4378-8bf6-af00e504b514">
        <source>validate(_transController: CMIF_HMS_TransactionController): Boolean;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	rtnValue : Boolean;
begin
	rtnValue := inheritMethod(_transController);
	if (not rtnValue) then
		return rtnValue;
	endif;
	
	if _transController.myPersistentVoyageDelay = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'Voyage Delay', 'Null', null, null);
		return false;
	endif;		
	return rtnValue;
end;</source>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
