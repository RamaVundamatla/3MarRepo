    <JadeMethod name="doPrintTblThumb" id="ee9318a0-8e05-4689-9370-a0da4ab60ed7">
        <source>doPrintTblThumb();
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	gtpthumbTable:        CM_GenericTablePrint;
	now:                 TimeStamp;
	hdrStr				: String;
	thumbTable : Table;
	tmpJadeReport  : JadeReport;
begin
	thumbTable := self.tblThumb;
	now := self.systemToLocalTime(app.actualTimeServer());	// 10/6/16 cnwmp6 TFS 488 - Multi timezone support
	app.mousePointer := MP_HOURGLASS;
	app.printer.suppressDialog := true;

	create gtpthumbTable;
	app.printer.setMargins(Print_Landscape,0,0,10,10);

	gtpthumbTable.frHeader.width := app.printer.pageWidth;
	hdrStr := "Thumbnail Print";

	gtpthumbTable.setHeaders(hdrStr, null);
	create tmpJadeReport transient;
	tmpJadeReport.description := hdrStr;
	app.printer.setReport(tmpJadeReport);

	app.printer.setHeader(gtpthumbTable.frHeader);

	gtpthumbTable.frFooter.width := app.printer.pageWidth;
	gtpthumbTable.lblTheUser.caption := app.getMyUserCode;
	gtpthumbTable.lblTheDatePrinted.caption := now.String;
	app.printer.setFooter(gtpthumbTable.frFooter);

	gtpthumbTable.printTable(thumbTable, true, null);

epilog
	app.printer.close;
	app.printPreview(tmpJadeReport, true);
	delete gtpthumbTable;
	app.mousePointer := MP_DEFAULT;



end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryUnload" id="fad3518e-0353-4d46-a57c-d3a0a070a607">
        <updating/>
        <source>doQueryUnload(cancel: Integer io; reason: Integer) updating, protected;
// -------------------------------------------
// Created 08 November 2004 by cnwdvb1
// -------------------------------------------
/* AA 29/6/01: If adding or editing then ask user if they want to abandon edits.
This happens when the form itself is closed or the MDI frame is closed. When the
MDI frame is closed, the user gets a message box for each window being edited.

*/
constants
	CANCEL_UNLOAD = 1;
vars
	result : Integer;
begin

	if self.mode = Mode_Add or self.mode = Mode_Update then
		if reason = QueryUnload_User or
		   reason = QueryUnload_UnloadMethod or
		   reason = QueryUnload_MdiChild then
		   if self.checkHasChanged() then
				result := app.msgBox(app.getErrorString(EditChangedAndClosing), self.caption &amp; " Window Closing !", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
				if result = MsgBox_Return_No then
					cancel := CANCEL_UNLOAD;	//Do not close form
				endif;			
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="e56303e1-7506-46d8-9316-92f6a01d15a9">
        <updating/>
        <source>doRefresh() updating, protected;

vars

begin
	
	if self.amInitialisingWithObject
	and self.myCurrentObject &lt;&gt; null //&lt;---Is null after adding a new terminal 
	and (self.mode = self.Mode_View) then	
		self.showThumbnailData(self.myCurrentObject);
		
	elseif (self.mode = self.Mode_View) and
			((not self.isSearcherFloating) or 
			(not (self.isSearcherFloating and self.isSearcherVisible))) then
		app.mousePointer := MousePointer_HourGlass;
		self.zTblDataSortAndShow(true);
	endif;
	
	inheritMethod();

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
