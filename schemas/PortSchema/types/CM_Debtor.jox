    <JadeMethod name="hasNoOtherRelatedEntities" id="43223799-d79c-49b6-9bee-e9ba70337149">
        <source>hasNoOtherRelatedEntities(_entity : CM_Object) : Boolean;
// CCMS GLT 2342 check if this debtor has allCarriers/allCustomsAgents/consignors etc other than the entered parameter - return true if so.
//  Used in SOP_AgentMaintenanceForm to decide whether to delete the associated debtor for a consignee/agent together.
//  If this debtor is only for the given agent, it can be deleted as well, otherwise not.
vars
	result	: Boolean;
	consignee	: CM_ConsigneeConsignor;
	customsAgent	: CM_CustomsAgent;
begin
	if self.isRDT() then
		return false;
	endif;
	
	if not self.allCarriers.isEmpty() or
	   not self.operators.isEmpty() then
		return false;
	endif;
	
	if _entity.isKindOf(CM_ConsigneeConsignor) then
		if self.consignors.size &gt; 1 then
			return false;
		endif;
		result := self.consignors.includes(_entity.CM_ConsigneeConsignor);
	
	elseif _entity.isKindOf(CM_CustomsAgent) then
		if self.allCustomsAgents.size &gt; 1 then
			return false;
		endif;
		result := self.allCustomsAgents.includes(_entity.CM_CustomsAgent);
		
	endif;
	
	return result;
end;
</source>
        <Parameter name="_entity" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasReeferDaily" id="87da6fbb-4b56-4225-8f68-5e64e7efca98">
        <source>hasReeferDaily():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 October 2017	jlgma1	TFS #7174 ADP - Access Debtor fields in Report Writer ///USED By Report Designer///
*/

vars
	txnType	: Integer;
begin
	if self.allSpecialReleaseTxnTypes.size&gt;0 then
		foreach txnType in self.allSpecialReleaseTxnTypes do
			if txnType = TRANS_TYPE_ReeferDaily then
				return true;
			endif;
		endforeach;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
