    <JadeMethod name="showLotDetails" id="d3ea6483-b897-4fc0-9027-073cdb25e99e">
        <updating/>
        <source>showLotDetails()updating;
//--------------------------------------------------------------
//Created: 11 September 2002 By: cnwgd1
//--------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars
	loadStateSet	: Boolean;
	str				: String;
	colPieces,
	idx				: Integer;
	sohLocn			: CM_SOHLocation;
begin

//TEMP FIX UNTIL SORTED OUT WITH ALAN HOW HE WANTS THINGS DISPLAYED FOR INTER-TERMINAL

	app.cmsBeginLoad(loadStateSet);
	self.tblSelectData.rows := self.tblSelectData.fixedRows;

	self.tblSelectData.resortTableByColumn(0);
	colPieces := self.tblSelectData.getColumnByRowName(ETRow_Pieces);
	
	foreach sohLocn in self.allSOHLocationsForLot do
		
		str := sohLocn.getAttributeStringForDefArray(self.tblSelectData.allTblDataEntRows);
		idx := tblSelectData.addItem(str);	
		tblSelectData.accessRow(idx).itemObject := sohLocn;
		self.tblSelectData.accessCell(idx, colPieces).text := sohLocn.numTIs.String;
	endforeach;	

	self.tblSelectData.userInputEnabled := true;
	self.setButtons(true);
	//self.btnSelectAllT.enabled	:= false;
	//self.btnSelectNoneT.enabled	:= false;	
	//Par11860 cnwyl1 07/02/2008
	
epilog
	app.cmsEndLoad(loadStateSet);
end;</source>
    </JadeMethod>
    <JadeMethod name="showSummaries" id="3a71942d-55f2-4dd4-a20f-ca6928982fed">
        <updating/>
        <source>showSummaries()updating;
//--------------------------------------------------------------
//Created: 11 September 2002 By: cnwgd1
//--------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	loadStateSet	: Boolean;
	str				: String;
	theProduct		: CM_Product;
	volume 			: Decimal[16,4];
	idx,
	colPieces,
	colVol,
	pieces	 		: Integer;
	sohLocn,
	sohLocn2 		: CM_SOHLocation;	
begin
	app.cmsBeginLoad(loadStateSet);
	self.tblSelectData.rows := self.tblSelectData.fixedRows;
	colPieces := tblSelectData.getColumnByRowName(ETRow_Pieces);
	colVol := tblSelectData.getColumnByRowName(ETRow_Volume);
	self.tblSelectData.resortTableByColumn(0);
	self.allSOHLocationsByProduct.clear();
	foreach sohLocn in self.allSOHLocationsForLot do
		
		if (not self.allSOHLocationsByProduct.includesKey(sohLocn.myProduct)) then
			self.allSOHLocationsByProduct.add(sohLocn);
		endif;
	endforeach;	

	foreach sohLocn in self.allSOHLocationsByProduct do
		
		theProduct := sohLocn.myProduct;
		pieces := 0;
		volume := 0;
		str := sohLocn.getAttributeStringForDefArray(self.tblSelectData.allTblDataEntRows);
		idx := tblSelectData.addItem(str);	
		foreach sohLocn2 in self.allSOHLocationsForLot do
			if sohLocn2.myProduct &lt;&gt; theProduct then
				continue;
			else
				pieces := pieces + sohLocn2.numTIs;
				volume := volume + sohLocn2.currentVolume;
			endif;
		endforeach;						
		tblSelectData.accessRow(idx).itemObject := sohLocn;
		tblSelectData.accessCell(idx, colPieces).text := pieces.String;
		tblSelectData.accessCell(idx, colVol).text := volume.jasVolumeString;				
	endforeach;	

	self.tblSelectData.userInputEnabled := true;
	self.setButtons(true);
	self.btnSelectAllT.enabled	:= false;
	self.btnSelectNoneT.enabled	:= false;	
	
epilog
	app.cmsEndLoad(loadStateSet);
end;</source>
    </JadeMethod>
