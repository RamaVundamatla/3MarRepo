    <JadeMethod name="doCmbEDIDataClick" id="3cded324-b486-4670-959c-683b99919550">
        <source>doCmbEDIDataClick();
//----------------------------------------------------------------
//	Created:	07 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ediConfig		: CM_EDIConfig;
	class			: Class;
	field			: CM_Field;
	tmpEDITI		: CM_EDITrackedItem;
	ediFile			: CM_EDIFile;
	itemFieldClass	: Class;
	ediDataType : Integer; //ccms 1976 cnwrs1 10 dec 2010
begin
	self.allFieldsOfType.purge;
	self.allFieldsOfFile.purge;
	
	if self.cmbEDIDataType.listIndex &lt; 1 then
		return;
	endif;
	ediDataType := self.cmbEDIDataType.listIndex;	// ccms 1976 cnwrs1 10 dec 2010
	if ediDataType = 7 then
		ediDataType := EDIDataType_Pack;
	endif;
	class := CM_EDIConfig.firstInstance.getEDITIClassFromEDIDataType(ediDataType);
	
	self.getItemFieldClass(itemFieldClass);
	
	if itemFieldClass = null then
		app.msgBox("Load a File or Format before selecting an EDIData type from the list.",null,null);
		return;
	endif;
	
	create tmpEDITI as class transient;
	tmpEDITI.getItemFields(self.allFieldsOfType, itemFieldClass);
	self.lstEDITIFields.listCollection(self.allFieldsOfType, false, 0); 

	create ediFile transient;
	ediFile.getItemFields(self.allFieldsOfFile, itemFieldClass);
	self.lstEDIFileFields.listCollection(self.allFieldsOfFile, false, 0); 

//	self.lstBox3.clear();
//	foreach field in fileFields do 
//		self.lstBox3.addTreeObject(field.systemTypeName &amp; " - " &amp; field.systemName, field, 1, true);	
//	endforeach;
	
epilog
	delete tmpEDITI;
	delete ediFile;
//	delete fileFields;
end;</source>
    </JadeMethod>
    <JadeMethod name="doListBoxXMLClick" id="2eefeab2-d26d-4885-95cc-3a018d5464a7">
        <source>doListBoxXMLClick();
//----------------------------------------------------------------
//	Created:	08 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	fieldObj		: CM_EDIItemField;
	tagName			: String;
	xmlElem			: JadeXMLElement;
	parentElem		: JadeXMLElement;
	xmlNode			: JadeXMLElement;
begin
	self.resetTagChkBoxes();
	
	if self.lstXMLDisplay.listObject = null then
		app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " null listObject");
		return;
	endif;
	
	xmlElem := self.lstXMLDisplay.listObject.JadeXMLElement;
	
	if JadeXMLElement.hasInstance(xmlElem.parentNode) then
		parentElem := xmlElem.parentNode.JadeXMLElement;
		if not parentElem.attributes.isEmpty then
			//we need to take notice of this when mathcing up
			app.writeStatement( xmlElem.tagName &amp; " parent : " &amp; xmlElem.parentNode.JadeXMLElement.writeToString());	
		endif;
	endif;
	
	tagName := xmlElem.tagName;
	
	if tagName = self.fileRootTagName then
		self.chkRootTag.value := true;
	elseif tagName = self.msgRootTagName then
		self.chkMsgTag.value := true;
	elseif tagName = self.tiRootTagName then
		self.chkTITag.value := true;
	endif;   
	
	//check to see if we've already matched this one
	
	fieldObj := self.allMatchedFileFields.getAtKeyGeq(tagName, null);

	if fieldObj &lt;&gt; null 
	and fieldObj.name = self.lstXMLDisplay.listObject.JadeXMLElement.tagName then
		if fieldObj.className = "CM_EDIFile" then
			self.lstEDIFileFields.listObject := fieldObj;
			self.lstEDIFileFields.topIndex := self.lstEDIFileFields.listIndex;
		else
			self.lstEDITIFields.listObject := fieldObj;
			
			self.lstEDITIFields.topIndex := self.lstEDITIFields.listIndex - 5;
			
		endif;
	else
		app.writeStatement( 'CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " fieldObj not matched yet");
	endif;	

end;</source>
    </JadeMethod>
    <JadeMethod name="doLoadCSVFile" id="c89156b9-0395-4ef7-91f3-426c876d6e0b">
        <updating/>
        <source>doLoadCSVFile(_delimiter:Character) updating;
//----------------------------------------------------------------
//	Created:	15 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 16/03/2015	cnwmh5	Transient Leak
vars
	csvFile			: File;
	strField,
	strLine			: String;
	oa				: ObjectArray;
	sa				: StringArray;
	fieldArray		: StringArray;
	idx, lineIdx	: Integer;
begin
	self.fileType := FileTypeCSV;
	
	create oa transient;
	create sa transient;
	create csvFile transient;
	csvFile.kind := File.Kind_Unknown_Text;	// 24/2/16 cnwmp6 PAR 36286 unicode version
	csvFile.openInput(self.currentFileName);
	lineIdx := 0;
	while not csvFile.endOfFile do
		lineIdx := lineIdx + 1;
		strLine := csvFile.readLine();
		strLine.csvToStringArray(sa, _delimiter);		// cnwdad1 25/11/2009 - PAR #21720 Added delimiter parameter.


		idx := 0;
		foreach strField in sa do
			idx := idx + 1;
			
			if oa.size &lt; idx then
				create fieldArray transient;
				oa.add(fieldArray);
			else
				fieldArray := oa[idx].StringArray;
			endif;
			fieldArray.atPut(lineIdx, strField);
			
		endforeach;
	
	endwhile;

	self.loadCSV(oa);
	
epilog
	delete csvFile;
	oa.purge;
	delete fieldArray;
	delete oa;
	delete sa;
end;</source>
        <Parameter name="_delimiter" type="Character"/>
    </JadeMethod>
    <JadeMethod name="doLoadFile" id="29c9e19b-31f4-4fc4-af3e-2cb562ae0936">
        <updating/>
        <source>doLoadFile() updating;
//----------------------------------------------------------------
//	Created:	15 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	fileGet		 		: CMDFileOpen;
	fileName, ext		: String;

begin
	create fileGet;
	fileGet.filter := '*.*';
	fileGet.fileName := '';
	fileGet.initDir := "c:\edi";
	if fileGet.open = 0 then	//user clicked OK
		self.currentFileName := fileGet.fileName;
	else
		return;
	endif;
	app.mousePointer := Window.MousePointer_HourGlass;
		
	self.lblXMLFileName.caption := self.currentFileName;
	
	self.cmbFileFormats.text := null;
	self.cmbFileFormats.listObject := null;

	ext := self.currentFileName.reverse[1:3].reverse.toUpper;

	if ext = "XML" then
		self.fileType := FileTypeXML;
	elseif ext = "CSV" then
		self.fileType := FileTypeCSV;
	else
		app.writeStatement( 'CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " unsupported file format");
	endif;	

	self.resetControls();
	
	if ext = "XML" then
		self.doLoadXMLFile();
	elseif ext = "CSV" then
		self.doLoadCSVFile(",");		// cnwdad1 25/11/2009 - PAR #21720.
	endif;
	
epilog
	app.mousePointer := Window.MousePointer_Default;

	delete fileGet;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doLoadXMLFile" id="dddd5e88-b65c-4526-aa11-05872e1986aa">
        <updating/>
        <source>doLoadXMLFile() updating;
//----------------------------------------------------------------
//	Created:	07 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.fileType := FileTypeXML;
	
	delete self.myXMLDoc;
	create self.myXMLDoc;
	
	self.myXMLDoc.parseFile(self.currentFileName);
			
	self.loadXMLDoc();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doMatchField" id="2b0f1d5b-4d4a-4787-bb4c-94e77e45b609">
        <updating/>
        <source>doMatchField() updating;
//----------------------------------------------------------------
//	Created:	07 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	heading		: String;
	fieldIndex	: Integer;
	rowIdx		: Integer;
	numRows		: Integer;
	arrIdx		: Integer;
	fieldItem	: CM_EDIItemField;
	xmlElem,
	parentElem,
	primaryElem,
	secondryElem: JadeXMLElement;
	useParent	: Boolean;
begin

	if self.lstXMLDisplay.visible then
		
		if self.currentFieldObject = null 
		or self.lstXMLDisplay.listObject = null then
			//hasn't selected the right stuff
			return;
		endif;
		
		//reset fields first
		self.currentFieldObject.resetFieldsAdditional();	
		
		rowIdx := self.allSelectedFieldRows.first;
		xmlElem := self.lstXMLDisplay.itemObject[rowIdx].JadeXMLElement;
	
/*	
		if JadeXMLElement.hasInstance(xmlElem.parentNode) then
			parentElem := xmlElem.parentNode.JadeXMLElement;
			if not parentElem.attributes.isEmpty then
				//match the parent and make the selected element the sub element
				write xmlElem.tagName &amp; " parent : " &amp; xmlElem.parentNode.JadeXMLElement.display;	
				useParent := true;
			endif;
		endif;
*/		
//		if useParent then
			//primaryElem := parentElem;
		primaryElem := self.currentFieldObject.setSubField(xmlElem);
//		else
//			primaryElem := xmlElem;
//		endif;
	
			
		self.currentFieldObject.setNonSystemAttributes(primaryElem.localName, self.cmbFormatMethod.text, primaryElem);
		
		numRows := self.allSelectedFieldRows.size;
	
		if numRows &gt; 1 then
			foreach arrIdx in 2 to numRows do
				rowIdx := self.allSelectedFieldRows[arrIdx];
				
				create fieldItem as CM_EDIItemFieldXML transient;
				secondryElem := self.lstXMLDisplay.itemObject[rowIdx].JadeXMLElement; 
				//set it
				fieldItem.setNonSystemAttributes(secondryElem.localName, self.cmbFormatMethod.text, secondryElem);
				//add it to collection
				self.currentFieldObject.addFieldAdditional(fieldItem);
			endforeach;
		endif;
	
	else
		if self.currentFieldObject = null 
		or self.tblCSVDisplay.row &lt; 1 then
			//hasn't selected the right stuff
			return;
		endif;
		
		if self.csvHeadingsColumn &lt; 1 then 
			self.csvHeadingsColumn := 1;
		endif;
		
		rowIdx := self.allSelectedFieldRows[1];
		heading := self.tblCSVDisplay.accessCell(rowIdx, self.csvHeadingsColumn).text;
		fieldIndex := self.tblCSVDisplay.accessCell(rowIdx, 1).text.Integer; 
		//set it
		self.currentFieldObject.setNonSystemAttributes(heading.removeEDIInvalidChars(), self.cmbFormatMethod.text, fieldIndex);
		//clear additional fields
		self.currentFieldObject.resetFieldsAdditional();	
		
		numRows := self.allSelectedFieldRows.size;
		
		if numRows &gt; 1 then
			foreach arrIdx in 2 to numRows do
				create fieldItem as CM_EDIItemFieldCSV transient; 
				heading := self.tblCSVDisplay.accessCell(self.allSelectedFieldRows[arrIdx], self.csvHeadingsColumn).text;
				fieldIndex := self.tblCSVDisplay.accessCell(self.allSelectedFieldRows[arrIdx], 1).text.Integer;
				//set it
				fieldItem.setNonSystemAttributes(heading.removeEDIInvalidChars(), self.cmbFormatMethod.text, fieldIndex);
				//add it to collection
				self.currentFieldObject.addFieldAdditional(fieldItem);
			endforeach;
		endif;
		
		
	endif;
	
	if self.allMatchedFileFields.includes(self.currentFieldObject) then
		self.allMatchedFileFields.remove(self.currentFieldObject);
	endif;
	
	self.allMatchedFileFields.add(self.currentFieldObject);
		
epilog
	self.allSelectedFieldRows.clear;
	self.lblAllSelected.caption := self.allSelectedFieldRows.asCSV(false);

	self.updateMatchedDisplay();
end;</source>
    </JadeMethod>
    <JadeMethod name="doRootTagsForFormat" id="4cec9230-1f30-4a66-882e-d14ddf9cb1fe">
        <source>doRootTagsForFormat();
//----------------------------------------------------------------
//	Created:	18 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx			: Integer;
	aTagName	: String;
begin
	
	if self.lstXMLDisplay.listCount &lt; 1 then
		return;
	endif;
	
	foreach idx in 1 to self.lstXMLDisplay.listCount do
		aTagName := self.lstXMLDisplay.itemObject[idx].JadeXMLElement.tagName;
		
		if aTagName = self.fileRootTagName then
			self.lstXMLDisplay.listIndex := idx;
			self.chkRootTag.value := true;
			self.chkRootTag.click(self.chkRootTag);
		elseif aTagName = self.msgRootTagName then
			self.lstXMLDisplay.listIndex := idx;
			self.chkMsgTag.value := true;
			self.chkMsgTag.click(self.chkMsgTag);		
		elseif aTagName = self.tiRootTagName then
			self.lstXMLDisplay.listIndex := idx;
			self.chkTITag.value := true;
			self.chkTITag.click(self.chkTITag);
		endif;
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSysFieldListClick" id="b589713b-327c-4d5a-ae0f-5c2a708fe627">
        <updating/>
        <source>doSysFieldListClick(_listBox: ListBox) updating;
//----------------------------------------------------------------
//	Created:	07 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	field,
	otherField	: CM_EDIItemField;
	xmlField	: CM_EDIItemFieldXML;
	intRow		: Integer;
begin
	
	field := _listBox.listObject.CM_EDIItemField;

	self.currentFieldObject := field;

	self.cmbDataType.text := field.systemTypeName;
	
	if _listBox = self.lstEDITIFields then
		self.lstEDIFileFields.listObject := null;	
	else
		self.lstEDITIFields.listObject := null;	
	endif;
	
	if field.name &lt;&gt; null then
		//has been matched try to find it in the list
		if CM_EDIItemFieldXML.hasInstance(field) then
			xmlField := field.CM_EDIItemFieldXML;
			if xmlField.mySubField &lt;&gt; null then
				xmlField := xmlField.mySubField;
			endif;
			self.lstXMLDisplay.listObject := xmlField.myXMLElement;
			self.lstXMLDisplay.topIndex := self.lstXMLDisplay.listIndex - 5;
			self.lstXMLDisplay.clearAllSelected();
			self.lstXMLDisplay.itemSelected[self.lstXMLDisplay.listIndex] := true;
			
		elseif CM_EDIItemFieldCSV.hasInstance(field) then
			foreach intRow in 2 to self.tblCSVDisplay.rows do
				if self.tblCSVDisplay.accessCell(intRow,1).text.Integer = field.CM_EDIItemFieldCSV.columnIndex then
					self.tblCSVDisplay.row := intRow;
					self.tblCSVDisplay.clearAllSelected();
					self.tblCSVDisplay.accessRow(intRow).selected := true;
					break;
				endif;
			endforeach;
		else
			//other types
		endif;
	endif;	
	
	
epilog
	if self.currentFieldObject &lt;&gt; null then
		self.caption := self.currentFieldObject.systemName;
	endif;
end;</source>
        <Parameter name="_listBox" type="ListBox"/>
    </JadeMethod>
    <JadeMethod name="fillFormats" id="a850e623-3aa1-418b-bd43-2ccde568fb3a">
        <updating/>
        <source>fillFormats() updating;
//----------------------------------------------------------------
//	Created:	08 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	category	: ConstantCategory;
	constant	: Constant;
begin
	
	category := currentSchema.getCategory(EDIFileFormats);		
	
	foreach constant in category.getConstants do
	app.writeStatement( constant.getSource);
		if constant.getSource.Integer &gt; self.maxConstValue then
			self.maxConstValue := constant.getSource.Integer;
		endif;
	endforeach;
	self.cmbFileFormats.listCollection(category.getConstants, true, 0);	


end;</source>
    </JadeMethod>
