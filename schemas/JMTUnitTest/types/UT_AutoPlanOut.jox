    <JadeMethod name="createRequest" id="860d6925-0584-46cb-8043-850e72cdd25d">
        <source>createRequest(_operator: String; _terminalArea: CM_TerminalArea): CM_Request;
//24 February 2010	cnwdw1	
//
vars
	request: CM_DeliveryRequest;
	tas: CM_TerminalAreaArray;
begin

	create request transient;
	request.setFromFlexiGate(null, null, null, 
					   null, null, _operator,
					   null,
					   null,
					   null, null, null, null,
					   false,
					   false, 	/* isReceipt */
					   false, false,
					   false, 0,
					   null,	/* reasonCode */
					   null, null, null, 
					   null,	/* ids */
					   null,//for par13816
					   null,
					   null,
					   null,// cnwdad1 02/07/2009 - CCMS 1735.
					   
					   // New fields for flexi-gate 			
					   null,
					   null,
					   null,
					   null,
					   null,
					   null,
					   null,
					   null,
					   null,
					   null,
					   null,
					   null,
					   null,
					   null,
					   null,
					   null,
					   null,
					   null,
					   null,
					   null,
					   null,
					   null,
					   null,
					   null,
					   null
					   ); 	
	if _terminalArea &lt;&gt; null then
		create tas transient;
		tas.add(_terminalArea);
		request.setNominatedTAs(tas, null); //added allgridobjects array
	endif;
	return request;
epilog
	delete tas;
end;</source>
        <Parameter name="_operator" type="String"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <ReturnType type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="sFIFORelease" id="7232d75d-755f-4fda-8969-3b845c53a4fa">
        <source>sFIFORelease();
//27 Jan 2010	cnwdw1	
// Test FIFO release on a block stack

// TODO set the received date of the containers to different days, and make sure the blocks stack FIFO date is updated
// currently all tis have same received date so test doesn't work :-)
constants
	RELEASE = "UTRRBYTYPE";
vars
	releaseRequest: CM_BulkRelease;
	ti1, ti2, ti3: CM_TrackedItem;
	ya: CM_YardAllocation;
	locations : CM_LCArray;
	source: CM_LocationsController;
	yaName: String;
begin
	self.disableAllYA(true);
	deleteReleaseRequest(RELEASE);
	self.deleteContainer("TEST0000001");
	self.deleteContainer("TEST0000002");
	self.deleteContainer("TEST0000003");

	// Setup a YA over a block stack that has a cvontainer that could be released
	ti1 := self.addContainer("TEST0000001", operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	ti2 := self.addContainer("TEST0000002", operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	ti3 := self.addContainer("TEST0000003", operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	
	create locations transient;
	locations.add(bs1.allLocationsControllers.first.CM_YardController);
	locations.add(bs2.allLocationsControllers.first.CM_YardController);
	yaName := self.getProfileSetting(UT_Profile.P_YA).asString;
	self.deleteYA(yaName);
	ya := self.addYA1WithFill(yaName, YACriteriaType_OperatorItem, operator.code, locations, YAFillOption_InOrder, YAFillOption_FIFO,false);
	assertFalse(ya.isDisabled);
	self.move(ti1, locations.last);	 //bs2
	self.move(ti2, locations.first); // bs1
	self.move(ti3, locations.first); // bs1
	
	// Create the Release
	self.opts.purge;
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", false);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	releaseRequest := addReleaseByTypeRequestOpts(RELEASE, BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	// Make sure that the expected source is found by autoplan
	source := app.sourceTisForRequestYA(self.getTerminal(), releaseRequest.requests.first);
	assertNotNullMsg(source, getYAAutoPlanMessages);
	assertEqual(source.getName(), locations.last.getName());
	
epilog
	delete locations;
	self.disableAllYA(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="sSelectISOSource6" id="bd7b6181-6906-4951-8d73-4b0c8596d1a6">
        <source>sSelectISOSource6();
//cnwrd1
/*

Purpose:	to test otago ccms 2185 , iso group substitutes.		

Parameters:			

Return Value:		


Date		Who		Reason
26 September 2012	cnwrd1	Initial creation

*/

vars
	containers : String;
	taSource : CM_ForkLiftStack;
	taSource2 : CM_StraddleStack;
	ti, nextTI, osTI,
	otherTI : CM_TrackedItem;
	releaseRequest: CM_BulkRelease;
	wle : CM_WorkListEntry;
	qe : CM_RTQueueEntry;
	ya : CM_YardAllocation;
	lc : CM_LocationsController;
	locations : CM_LCArray;
	source: CM_LocationsController;
	yaName: String;
begin
	self.disableAllYA(true);
	deleteTerminalArea("UTFORK");
	deleteTerminalArea("UTFORK2");
	taSource := self.addForkLiftStack("UTFORK", 6, 5, 2);
	assertNotNullMsg(taSource, "UTFORK");

	deleteTerminalArea("UTSTRD");
	taSource2 := addStraddleStack("UTSTRD", 3, 8, 2);
	assertNotNullMsg(taSource2, "UTSTRD");
	
	self.deleteContainer("TEST0000011");
	self.deleteContainer("TEST0000002");
	self.deleteContainer("TEST0000003");
	self.deleteContainer("TEST0000004");



	self.opts.addAssoc("Width", "200");
	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	ti := self.addContainerOpts("TEST0000011", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000011");
	self.move(ti ,taSource.allGridControllersByRowColumn[1, 1]);
	self.assertEqualMsg(ti.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[1, 1], "Did not move TEST0000011 to correct location");
	
	osTI:= self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(osTI, "TEST0000002");
	self.move(osTI ,taSource.allGridControllersByRowColumn[2, 2]);
	self.assertEqualMsg(osTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 2], "Did not move TEST0000002 to correct location");
	
	nextTI:= self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000003");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[3, 3]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[3, 3], "Did not move TEST0000003 to correct location");
	
	// into the second area
	otherTI:= self.addContainerOpts("TEST0000004", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(otherTI, "TEST0000004");
	self.move(otherTI ,taSource2.allGridControllersByRowColumn[1, 1]); // was 2, 5
	self.assertEqualMsg(otherTI.myPrimaryActualLocation, taSource2.allGridControllersByRowColumn[1, 1], "Did not move TEST0000004 to correct location");

	// Create the Release
	self.opts.purge();
	self.opts.addAssoc("ISOGroup", "1001");
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CanBeHiLoCube", true);
	self.opts.addAssoc("CreateDeliveryRequest", true); //this?
	self.opts.addAssoc("TerminalArea",taSource ); //this?	
	releaseRequest := addReleaseByTypeRequestOpts("UTRINMOV", BR_TYPE_PACKING, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	


	// actual test
	// create yard allocations to be used in set setISOSource
	//locations are Top Left &amp; bottom Right
	create locations transient;
	locations.add(taSource2.allGridControllersByRowColumn[1, 4]);
	locations.add(taSource2.allGridControllersByRowColumn[3, 6]);
	
	self.deleteYA("UT");
	containers := "20";
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, containers, locations);
	assertNotNullMsg(ya, "UT Yard Allocation");

	wle := releaseRequest.allRequestsBeingActioned.first.allWorkListEntries.first;
	// Apr 2010 the failure now raises an error message
	self.expectTrxError(Must_unque_befor_sourc_loc);  // 86030. This job must be unqueued before a new source location can be selected.
	self.expectTrxError(Request_failed_auto_plan);  // 84880. Request failed to auto plan
	self.setISOSource(wle, taSource2);

	// should be a single queue entry from setISOSource, with source location of UTSTRD
	// currently the auto-plan fails and nothing is queued
	//qe := wle.allRTQueueEntries.first;
	//assertEqual(qe.allTasks.first.sourceLocation.ident, taSource2.id);
	self.assertNoTrxErrorsOrWarnings();

epilog
	delete locations;
	self.disableAllYA(false);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tAutoPlanForShipRelease" id="715c48f6-75c8-4b6b-9abd-7c654ebe34cd">
        <source>tAutoPlanForShipRelease();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2015	cnwndl1	Initial creation	Par 37094

*/

constants

	BULK_NAME = "UTSHIPBYTYPE";
	TI_ID1 = "UTSR3709401";
	TI_ID2 = "UTSR3709402";
	TI_ID3 = "UTSR3709403";
	TI_ID4 = "UTSR3709404";
	TI_ID5 = "UTSR3709405";
		
vars

	bulkRel : CM_BulkRelease;
	ti : CM_TrackedItem;
	ya : CM_YardAllocation;
	locations : CM_LCArray;
	source : CM_LocationsController;
	yaName : String;
	cg : CM_CargoGroup;
	allCargoToAssign : CM_TISet;
	pxyReleaseMatchCrit : CM_ReleaseByTypeCriteria;
	pxyCriteria : CM_YACriteria;
	reserveDet : CM_ReserveDetail;
	reserveSel : CM_ReserveSelection;
	term : CM_Terminal;
	cmifYARequest : CMIF_YAAutoPlan;
	transUserQuery : CM_MenuUserQuery;
	transCriteriaLineHolder : CM_QueryCriteriaLineHolder;
	msg : String;
	qDef : CM_QueryDefinition;
	enqController : CM_EnqControllerTI;
	
begin

	term := self.getTerminal;

	self.setTerminalConfig(UseBestPickDirector, false);
	self.disableAllYA(true);
	self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyYA);
	
	self.deleteReleaseRequest(BULK_NAME);
	self.deleteContainer(TI_ID1);
	self.deleteContainer(TI_ID2);
	self.deleteContainer(TI_ID3);
	self.deleteContainer(TI_ID4);
	self.deleteContainer(TI_ID5);
	
	yaName := self.getProfileSetting(UT_Profile.P_YA).asString;
	self.deleteYA(yaName);
	
	create allCargoToAssign transient;
	
	//create Yard Allocation
	create locations transient;
	locations.add(bs1.allLocationsControllers.first.CM_YardController);
	ya := self.addYA1(yaName, YACriteriaType_OperatorItem, operator.code, locations);
	assertFalse(ya.isDisabled);
	
	//create Cargo items
	ti := self.addContainer(TI_ID1, operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti, locations.first);
	assertEqual(ti.myPrimaryActualLocation, locations.first);
	allCargoToAssign.add(ti);
	
	ti := self.addContainer(TI_ID2, operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti, locations.first);
	assertEqual(ti.myPrimaryActualLocation, locations.first);
	allCargoToAssign.add(ti);
	
	ti := self.addContainer(TI_ID3, operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti, locations.first);
	assertEqual(ti.myPrimaryActualLocation, locations.first);
	allCargoToAssign.add(ti);
	
	ti := self.addContainer(TI_ID4, operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti, locations.first);
	assertEqual(ti.myPrimaryActualLocation, locations.first);
	allCargoToAssign.add(ti);
	
	ti := self.addContainer(TI_ID5, operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(ti, locations.first);
	assertEqual(ti.myPrimaryActualLocation, locations.first);
	allCargoToAssign.add(ti);
	
	
	//create bulk release with reserve selection (release by type) that includes Match criteria for Ids starting with a value.
	
	create pxyReleaseMatchCrit transient;
	create pxyCriteria transient;
	pxyReleaseMatchCrit.allCriteria.add(pxyCriteria);
	pxyCriteria.setProxy(	CM_YATypeID.firstInstance,	//pCriteriaTypeObj:CM_YACriteriaType;
							"UTSR370940*",	//pDataValue:Any;
							"Id"	//pCode:String
							);
	
	self.opts.purge;
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc(ETRow_SetCriteria, pxyReleaseMatchCrit);
	bulkRel := self.addReleaseByTypeRequestOpts(BULK_NAME, BR_TYPE_SHIP, TI_CargoType_Container);
	self.assertTrueMsg( bulkRel &lt;&gt; null, "BulkRelease not created" );
	self.assertTrueMsg( not bulkRel.allReserveDetails.isEmpty, "Reserve Details not created" );
	reserveDet := bulkRel.allReserveDetails.first;
	self.assertTrueMsg( reserveDet.isKindOf(CM_ReserveSelection), "No Reserve Selection found" );
	reserveSel := reserveDet.CM_ReserveSelection;
	self.assertTrueMsg( reserveSel.myReleaseCriteria &lt;&gt; null, "No Match Criteria on Reserve Selection" );

	// Make sure that the expected source is found by autoplan
	source := app.sourceTisForRequestYA(self.getTerminal(), bulkRel.requests.first);
	assertNotNullMsg(source, getYAAutoPlanMessages);
	assertEqual(source.getName(), locations.first.getName());
	self.assertTrueMsg( app.myYAAgent &lt;&gt; null, "No YAAgent for 'request'" );
	cmifYARequest := app.myYAAgent.myCMIFYAAutoPlan;
	self.assertTrueMsg( cmifYARequest &lt;&gt; null, "No CMIF on the YA Agent for 'request'" );
	self.assertTrueMsg( cmifYARequest.allKeepTrackedTis.first.id = TI_ID1, "First Ti found for 'request' should be " &amp; TI_ID1 );
	
	// Check the test auto plan for Reserve implemented on the Bulk Release form.
	app.testAutoplanReseveDetails(term, reserveSel);
	self.assertTrueMsg( app.myYAAgent &lt;&gt; null, "No YAA gent for 'reserve selection'" );
	cmifYARequest := app.myYAAgent.myCMIFYAAutoPlan;
	self.assertTrueMsg( cmifYARequest &lt;&gt; null, "No CMIF on the YAAgent for 'reserve selection'" );
	self.assertTrueMsg( cmifYARequest.allKeepTrackedTis.first.id = TI_ID1, "First Ti found for 'reserve selection' should be " &amp; TI_ID1 );
	
	
	create transUserQuery transient;
	create transCriteriaLineHolder transient;
	transUserQuery.allCriteriaLineHolders.add(transCriteriaLineHolder);
	msg := reserveSel.buildQueryToMatchDetails( transUserQuery, transCriteriaLineHolder );
	self.assertTrueMsg( msg = null, "YA to Selector query conversion message - " &amp; msg );
	qDef := app.myRoot.allQueryDefinitionObjects[transUserQuery.getType, transUserQuery.queryMode];
	
	create enqController;
	create enqController.allObjects as  CM_TISet transient;
	
	enqController.myTerminal := term;
	enqController.myCriteriaLineHolder := transCriteriaLineHolder;
	
	enqController.doQuery( qDef );
	self.assertTrueMsg( allCargoToAssign.size = enqController.allObjects.size, "Queries found different number of items " &amp; allCargoToAssign.size.String &amp; "/" &amp; enqController.allObjects.size.String );
	foreach ti in allCargoToAssign do
		self.assertTrueMsg( enqController.allObjects.includes(ti), "Selector query missed out " &amp; ti.id );
	endforeach;

epilog

	delete locations;
	delete allCargoToAssign;
	self.disableAllYA(false);
	delete transUserQuery;
	delete enqController.allObjects;
	delete enqController;

end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
