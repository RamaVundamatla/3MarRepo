    </JadeMethod>
    <JadeMethod name="updateFromCondition" id="00003413-49b3-4c61-9984-4f1ddfe04e37">
        <updating/>
        <source>updateFromCondition(_segCondition : CM_SegregationCondition; _hazardClass : CM_HazardClass) updating;
/*
----------   ----------  --------------------------------------------------
Created:	27 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	
	self.myHazardClass := _hazardClass;
	if (not _segCondition.allowedSameArea) then
		self.notAllowedSameArea := true;
	endif;
		
	if _segCondition.proximityDepth &gt; self.largestDepthSpan then
		self.largestDepthSpan := _segCondition.proximityDepth;
	endif;
	
	if _segCondition.proximityHorizontal &gt; self.largestHorizontalSpan then
		self.largestHorizontalSpan := _segCondition.proximityHorizontal;
	endif;
	
	if _segCondition.proximityVertical &gt; self.largestVerticalSpan then
		self.largestVerticalSpan := _segCondition.proximityVertical;
	endif;
	
	
end;


</source>
        <Parameter name="_segCondition" type="CM_SegregationCondition"/>
        <Parameter name="_hazardClass" type="CM_HazardClass"/>
    </JadeMethod>
</Class>
