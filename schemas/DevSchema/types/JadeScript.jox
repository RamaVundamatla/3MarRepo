    <JadeMethod name="rh_testIscaleWeightData" id="bb94c112-6bad-4db9-8d08-f466bcea0514">
        <source>rh_testIscaleWeightData();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2016	cnwrh7	Initial creation

*/
constants
	Delimiter 								: String = " ";
	WeightDataStartPoint	 	: Integer = 109;
vars
	t 										: CMIF_IscaleWeightDataWrap;
	int,int2							: Integer;
	weightDataBinary	: Binary;
	weightDataReal 		: Real;
	weightDataInKg		: Decimal[15,3];
	byteArray					: ByteArray;
	byteInt							:  Integer;
	binaryInt						: Integer;
	weightDataString		: String;
begin
	app.initialize();
	byteInt := 1;
	create byteArray transient;				//sample data from Iscale Byte[108] to Byte[111]  Each 4 Bytes for A Real 
	byteArray.atPut(509, null);				//make data size as 509;
	byteArray[109] := 42.Byte;
	byteArray[110] :=	28.Byte;
	byteArray[111] :=	00.Byte;
	byteArray[112] := 00.Byte;
	while byteInt &lt;= byteArray.size do
		weightDataBinary := weightDataBinary &amp; byteArray[byteInt].Binary;			//so far we have Bianry data ready
		byteInt := byteInt +1;
	endwhile;
	
	binaryInt := 0;
	while binaryInt &lt;=3 do 
		weightDataString := weightDataString &amp; weightDataBinary[WeightDataStartPoint + binaryInt : 1].Byte.String &amp; Delimiter;		
		binaryInt := binaryInt +1;
	endwhile;
	weightDataString := weightDataString.trimRight();
	
	create t transient;
	weightDataReal :=  t.myWeightDataConvertion.convertFunction(weightDataString.trimRight.StringUtf8);
	weightDataInKg := weightDataReal.Decimal *1000;
	write " weightDataInKg is &gt;&gt;" &amp; weightDataInKg.String;
	
epilog
	delete t;
	delete byteArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="rh_testIscaleWeightDataInArray" id="306b1c5e-99c1-44f3-8ff8-30b61a7819fc">
        <source>rh_testIscaleWeightDataInArray();

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2016	cnwrh7	Initial creation

*/
constants
	Delimiter 					: String = " ";
	WeightDataStartPoint : Integer = 0;
vars
	t 										: CMIF_IscaleWeightDataWrap;
	int,int2							: Integer;
	weightDataBinary	: Binary;
	weightDataString		: String;
	weightDataReal 		: Real;
	weightDataInKg		: Decimal[15,3];
	byteArray					: ByteArray;
begin
	app.initialize();
	create byteArray transient;				//sample data from Iscale Byte[108] to Byte[111]  Each 4 Bytes for A Real
	byteArray[1] := 	 42.Byte;
	byteArray[2] :=	28.Byte;
	byteArray[3] :=	00.Byte;
	byteArray[4] := 00.Byte;

	create t transient;
	int :=1;
	while int &lt;= byteArray.size do			//we need 4 Byte in the return buffer binary start from postion 109
		weightDataBinary := weightDataBinary &amp; byteArray[int].Binary;
		int := int +1;
	endwhile;
	//write "weightDataBinary First One Convert to String is &gt;&gt;" &amp;"0x" &amp;  weightDataBinary[1:1].Byte.String;
	int2 :=1;
	while int2 &lt;=4 do
		//write weightDataBinary [WeightDataStartPoint+int2: 1].ansiToString;
			weightDataString := weightDataString &amp; weightDataBinary [WeightDataStartPoint+int2: 1].Byte.String &amp; Delimiter ;
			int2 := int2 +1 ;
	endwhile;
	weightDataString := weightDataString.trimRight;
	write "The passing weight data converted in string is &gt;&gt; " &amp; weightDataString;
	//weightDataString	:= weightDataString.trimRight;
	weightDataReal :=  t.myWeightDataConvertion.convertFunction(weightDataString.trimRight.StringUtf8);
	weightDataInKg := weightDataReal.Decimal *1000;
	write "The weight figure is &gt;&gt; " &amp; weightDataInKg.String &amp; " kgs";
epilog
	delete t;
	delete byteArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="rh_testIscaleWeightDataInHex" id="87d50ecc-1ce7-4755-ad5f-89163c714de0">
        <source>rh_testIscaleWeightDataInHex();
/*

Purpose:			

