    <JadeMethod name="rel821_par30558" id="b368677f-c404-45bc-b2c2-8b49ce05341e">
        <source>rel821_par30558();
/*
Purpose:			
Date		Who		Reason
13 February 2013	cnwab1	Initial creation
*/

vars
	iter01 : Iterator;
	theVoyage : CM_Voyage;
	oArray : ObjectArray;
	idx : Integer;
begin
	app.initialize();
	
	create oArray transient;
	CM_Voyage.allInstances(oArray,0,false);
	iter01 := oArray.createIterator;
	theVoyage := CM_Voyage.lastInstance;
	iter01.startAtObject(theVoyage);
	
	while iter01.back(theVoyage) do
	
		if theVoyage.myVessel &lt;&gt; null then
			continue;
		endif;
		idx := idx + 1;
		beginTransaction;
		theVoyage.setMyVessel(theVoyage.getMyVessel());
		commitTransaction;
		
//		if idx mod 100 = 0 then
//			write idx.String &amp; " " &amp; theVoyage.code;
//		endif;
	endwhile;

end;</source>
    </JadeMethod>
