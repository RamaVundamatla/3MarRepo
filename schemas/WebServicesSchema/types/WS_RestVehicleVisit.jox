    <JadeMethod name="setProxyFromObject" id="75dad3b4-ce33-4fb0-b624-ebc91aa2f3d2">
        <updating/>
        <source>setProxyFromObject(_vvr: CM_VehicleVisitRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Nov 2025	navbs1	Initial creation Story MTN-36661: MTN | KPI REST API - Truck Turn Around

*/

vars
	carrier			: CM_Carrier;
	driver			: CM_DriverDetails;
	
begin
	self.visitNumber := _vvr.visitNumber;
	self.regNumber := _vvr.regNumber;
	self.timeIn := _vvr.timeIn.asJSONFormat();		
	self.timeOut := _vvr.timeOut.asJSONFormat();
	self.gateName := _vvr.getGateInName();
	
	carrier := _vvr.getCarrier();
	if carrier &lt;&gt; null then
		self.carrierId := carrier.code;
	endif;
	
	driver := _vvr.myDriverDetails;
	if driver  &lt;&gt; null then
		self.driverId := driver.code;
	endif;
	
epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
</Class>
