    <JadeMethod name="getOverrideQueue" id="c695dad2-0016-4a4f-9575-0178a67e37a2">
        <source>getOverrideQueue(): CM_SubQueue;

// Created by cnwdvb1 on 04 September 2006

vars

begin

	if self.isDualGate and not self.allSubRTQueues.isEmpty() then
		return self.allSubRTQueues.first.CM_SubQueue;
	endif;
	return null;

end;</source>
        <ReturnType type="CM_SubQueue"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="8a9a651b-7b2c-49f1-af82-c261388e1e6d">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			


Return Value:		


Date			Who		Reason
04 August 2006	cnwer1	Initial creation - PAR#xxxx
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy

*/
vars
	pxyVTA : CM_VehicleTransferArea;
	glc, pGlc		: CM_GateLaneController;
	preBC,pPreBC,
	postBC,pPostBC	: CM_LocationsController;
	completedOK		: Boolean;
begin
	pxyVTA := inheritMethod();
	foreach glc in self.allGateLaneControllers discreteLock do
		pGlc := glc.pxyCreateUpdateProxy;
		pGlc.setMyLaneVTA(pxyVTA);
	endforeach;
	
	foreach preBC in self.allPreGateControllers discreteLock do
		pPreBC := preBC.pxyCreateUpdateProxy;
		pPreBC.CM_BlockController.setMyPreGateVTA(pxyVTA);
	endforeach;

	foreach postBC in self.allPostGateControllers discreteLock do
		pPostBC := postBC.pxyCreateUpdateProxy;
		pPostBC.CM_BlockController.setMyPostGateVTA(pxyVTA);
	endforeach;	
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyVTA;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyVTA;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b06699a6-7aec-48dc-99e4-c7b52b224941">
        <updating/>
        <source>setForCreate(_proxy :CM_VehicleTransferArea input; _passport : CM_Passport input) updating;
//setForCreate(_proxy: CM_VehicleTransferArea; _passport: CM_Passport input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
04 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin	
	inheritMethod(_proxy, _passport);
	
	self.autoPlanEnabled := _proxy.autoPlanEnabled;
	
	self.setMaxCapacity(_proxy.maxCapacity);
	self.setIsDualGate(_proxy.isDualGate);
	self.setNumGateLanes(_proxy.numGateLanes);
	
	// create the pre gate area
	self.createPreGate; 
	//create the post gate area
	self.createPostGate;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_VehicleTransferArea" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="bb565b95-0f4c-4b60-87c1-297cfdca8be5">
        <updating/>
        <source>setForUpdate(_proxy :CM_VehicleTransferArea) updating;
//setForUpdate(_proxy: CM_VehicleTransferArea) updating;
/*

Purpose:			


Return Value:		


Date			Who		Reason
04 August 2006	cnwer1	Initial creation - PAR#xxxx
23/06/2009		concms1	ccms 1061 - Changed method signature to use proxy rather than controller

*/
vars
	queue : CM_RadioTelemetryQueue;
begin
	inheritMethod(_proxy);
	
	self.autoPlanEnabled := _proxy.autoPlanEnabled;
	self.setMaxCapacity(_proxy.maxCapacity);
	self.setIsDualGate(_proxy.isDualGate);
	self.setNumGateLanes(_proxy.numGateLanes);
	// create the pre gate area
	self.createPreGate; 
	//create the post gate area
	self.createPostGate;
	
	
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_VehicleTransferArea"/>
    </JadeMethod>
    <JadeMethod name="setIsDualGate" id="6ad71ccc-455a-4237-9a2c-3643a140c879">
        <updating/>
        <source>setIsDualGate(_isDualGate : Boolean) updating;
/*

Purpose:			


Return Value:		


Date			Who		Reason
31 July 2006	cnwer1	Initial creation  - gdansk Gate work
	adm 130608 Par 16951	delete existing Gates
*/

vars

begin
	if self.isDualGate &lt;&gt; _isDualGate then
		isDualGate := _isDualGate;
/* config flag has changed to being USE MACHINE RULES
		//th2 added 2/10/06 - keeping config flag in synch with VTA area behaviour
		//still unknown what happens if more than one VTA and only some are duel gate?
		self.myTerminal.setConfig(GateAllowDualGate, _isDualGate);
		*/
		if not _isDualGate 
		and not self.allGateLaneControllers.isEmpty then
			self.allGateLaneControllers.purge;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_isDualGate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMaxCapacity" id="911b6ada-f2e8-4fda-90ab-4957641374e0">
        <updating/>
        <source>setMaxCapacity(_maxCapacity : Integer) updating;
/*

Purpose:			


Return Value:		


