<GUIClass name="MOB_HHITSTruckUnloaderAllCargo" id="3c583a43-5c8e-4ed1-b78b-6497330dbc74">
    <superclass name="MOB_HHTruckUnloaderAllCargo"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="clickInYardItem" id="c8f10269-cec6-44ab-9594-2a60960f268b">
        <updating/>
        <source>clickInYardItem(_obj: Object) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 February 2010	cnwndl1	Initial creation

*/

vars

	ti : CM_TrackedItem;
	
begin

	// reload an item we just unloaded that was actually targetted for this terminal...

	if CM_TrackedItem.hasInstance( _obj ) then
		ti := _obj.CM_TrackedItem;
	endif;
	
	if ti = null then
		return;
	endif;
	
	self.myMobileGenericAgent.setMyNextTiToAction(ti);
	//self.myHandHeldCheckerAgent.setChecksState(MOB_HandHeldCheckerAgent.GateReceipt);
	self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.TruckUnload);//28 May 2010	NDL	Par 23698
	self.gotoForm( MOB_HHTruckLoaderCargo, false );

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="51c7bc4a-6436-4e5c-af93-287f0b60cda5">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 February 2010	cnwndl1	Initial creation

*/

vars

	easyGateController : CMIF_EasyGateController;
	term : CM_Terminal;
	interTermJob : CM_InterTermVehicleJob;
	interMove : CM_InterTerminalMove;
	result : Integer;
	truck : CM_Vehicle;

	
begin

	//user clicked 'Complete' for inter terminal unload.

	//call Rob's the easy gate unload complete trx - which should take those moves that are in a state of 'unloading'
	//for this terminal, and remove them from the job, It should move the ti's to their real locations in the
	//target terminal, complete the VVR, and exit the truck....
	//

	create easyGateController transient;
	
	term := self.myMobileGenericAgent.myInterTerminal;
	easyGateController.myTerminal := term;
	easyGateController.driver := self.myMobileGenericAgent.driver;
	
	truck := self.myMobileGenericAgent.myTruck;
	interTermJob := truck.getInterTerminalJob();
	easyGateController.myInterTermVehicleJob := interTermJob;
	
	foreach interMove in interTermJob.allInterTerminalMoves do
		if interMove.status &lt;&gt; ITT_UNLOADING then
			// not one we are in the process of unloading
			continue;
		endif;
		if interMove.myTargetTerminal &lt;&gt; term then
			// not one unloaded at this terminal
			continue;
		endif;
		easyGateController.allMovesForOffloading.add( interMove );
	endforeach;
	
	while true do
		app.myTrxCA.trxCreateEasyGateIn( easyGateController, app.myPassport ); 
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			break;
			
		else
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog(app.getErrorString(Inter_Terminal_Transfer), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
		endif;
		return;
	endwhile;
	
	//if successfull
	self.doBackButtonClick();

epilog

	delete easyGateController;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupInYard" id="b127651c-b863-438c-b705-3dd14d37eaef">
        <updating/>
        <source>setupInYard() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 February 2010	cnwndl1	Initial creation

*/

constants

	TAB_INDEX_START = 1000;
	
vars

	menuButton : MOB_Button;
	buttonOffset : Integer;
	buttonNumber : Integer;
	buttonWidth : Real;
	tiArray: CM_TIArray;
	ti : CM_TrackedItem;
	size : Integer;
	interTermJob : CM_InterTermVehicleJob;
	interMove : CM_InterTerminalMove;
	term : CM_Terminal;
	errMess : String;
	truck : CM_Vehicle;
	buttonHeight : Integer;
	
begin

	create tiArray transient;
	
	term := self.myMobileGenericAgent.myInterTerminal;
	if term = null then
		errMess := "developer error,  no Terminal";
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true);
		return;
	endif;
	
	truck := self.myMobileGenericAgent.myTruck;
	interTermJob := truck.getInterTerminalJob();
	foreach interMove in interTermJob.allInterTerminalMoves do
		if interMove.myTargetTerminal &lt;&gt; term then
			//Can only unload Inter terminal job at the target terminal
			continue;
		endif;
		if interMove.status &lt;&gt; ITT_UNLOADING then
			// we only want to see the ones that are in the process
			continue;
		endif;
		ti := interMove.mySourceTI;
		if ti &lt;&gt; null then
			tiArray.addExclusive(ti);
		endif;
	endforeach;
	
	size := tiArray.size;
	buttonHeight := self.getScrollingButtonHeight();
	self.btnInYardTemp.height := buttonHeight;
	buttonWidth := getButtonWidthSetScrollBar( size, self.frmCargoInYard, self.btnInYardTemp.height, self.scrCargoInYard );

	foreach ti in tiArray do
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnInYardTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		if ti.myPrimaryActualLocation &lt;&gt; null then  //cnwrd1 fix for ITT 19.2.2010
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		else
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id;
		endif;
		
		self.addHazDetailsToButton( menuButton, ti, null ); //30 May 2017	NDL	TFS 4587
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
	endforeach;
	
	self.btnInYardTemp.visible := false;
	self.frmCargoInYard.caption := null;
	
	if tiArray.isEmpty then
		lblNoCargoYard.visible := true;
	else
		lblNoCargoYard.visible := false;
	endif;
	
epilog

	delete tiArray;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupOnTruck" id="20028daa-5d34-4069-ba5a-f04ff0a50623">
        <updating/>
        <source>setupOnTruck() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2010	cnwndl1	Initial creation

*/

constants

	TAB_INDEX_START = 1000;
	
vars

	errMess : String;
	truck : CM_Vehicle;
	term : CM_Terminal;
	interTerminalJob : CM_InterTermVehicleJob;
	interTerminalMove : CM_InterTerminalMove;
	size : Integer;
	buttonWidth : Real;
	tiArray : CM_TIArray;
	buttonNumber : Integer;
	menuButton : MOB_Button;
	buttonOffset : Integer;
	ti  : CM_TrackedItem;
	buttonHeight : Integer;
	
begin
	
	// get the truck
	truck := self.myMobileGenericAgent.myTruck;
	if truck = null then
		errMess := "developer error,  no Truck";
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true);
		return;
	endif;
	
	// get inter terminal job
	interTerminalJob := truck.getInterTerminalJob();
	if interTerminalJob = null then
		errMess := app.getErrorString(No_Inter_Term_Job_Unload);
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true);
		return;
	endif;
	
	term := self.myMobileGenericAgent.myInterTerminal;
	if term = null then
		errMess := "developer error,  no Terminal";
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true);
		return;
	endif;

	// find the prenotes at the target terminal related to the 'ti's on the truck. 
	create tiArray transient;
	foreach interTerminalMove in interTerminalJob.allInterTerminalMoves do
		if interTerminalMove.status = ITT_UNLOADING then
			// in the process, from the hand held point of view no longer on the truck...
			continue;
		endif;
		ti := interTerminalMove.myTargetTI;
		if ti = null then
			continue;
		endif;
		tiArray.addExclusive( ti );
	endforeach;
		
	// create the buttons on the form
	size := tiArray.size;

	buttonHeight := self.getScrollingButtonHeight();
	self.btnOnTruckTemp.height := buttonHeight;
	buttonWidth := getButtonWidthSetScrollBar( size,  self.frmCargoOnTruck, self.btnOnTruckTemp.height, self.scrCargoOnTruck );


	foreach interTerminalMove in interTerminalJob.allInterTerminalMoves do
	
		ti := interTerminalMove.myTargetTI;
		if ti = null then
			continue;
		endif;
		
		if interTerminalMove.status = ITT_UNLOADING then
			// in the process, from the hand held point of view no longer on the truck... skip it
			continue;
		endif;
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnOnTruckTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		if interTerminalMove.myTargetTerminal = term or ( interTerminalMove.mySourceTerminal = term  and interTerminalMove.status = ITT_LOADING ) then
			//Can only unload Inter terminal job at the target terminal ( or if we are still at the source terminal)
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id;
		else
			menuButton.enabled := false;
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id;
		endif;
		
		self.addHazDetailsToButton( menuButton, ti, CrLf ); //30 May 2017	NDL	TFS 4587
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
	endforeach;
	
	self.btnOnTruckTemp.visible := false;
	self.frmCargoOnTruck.caption := null;
	
	if tiArray.isEmpty then
		lblNoCargoTruck.visible := true;
	else
		lblNoCargoTruck.visible := false;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="55bfa7d5-3ffe-42de-8135-b97c220aee99">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014245, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
