    <JadeMethod name="mnuRemoveOperator_click" id="0fc1698c-a962-4e34-b885-77b4dbbc5ad0">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuRemoveOperator_click(menuItem: MenuItem input) updating;
/*
Purpose:	

Date		Who		Reason
19 March 2025	navab1	JIRA 34233
*/

vars
	cutoff,rowCutoff : CM_ReceivalCutoffVoyage;
	row, idx, idy : Integer;
	oper : CM_Operator;
	table : CM_DataTable;
begin
	
	cutoff := menuItem.userObject.CM_ReceivalCutoffVoyage;
	
	if cutoff &lt;&gt; null then
		oper := cutoff.myOperator;
		if oper = null then
			return;
		endif;

		if app.msgBox(app.getErrorString1(WARNING_REMOVE_ITEM,oper.code), "Confirm", MsgBox_Yes_No) = MsgBox_Return_No then
			return;
		endif;

	table :=  self.tblVoyageCutoffs;
		
		idx := table.fixedRows + 1;
		idy := table.rows;
		
		foreach row in idx to idy reversed do
			rowCutoff := table.accessRow(row).itemObject.CM_ReceivalCutoffVoyage;
			
			if rowCutoff &lt;&gt; null
			and rowCutoff.myOperator = oper then
				table.removeItem(row);
				self.allProxyCutoffs.remove(rowCutoff);
				delete rowCutoff;
			endif;
		
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
