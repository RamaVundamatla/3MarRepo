    <JadeMethod name="drawRoRoObjectAt" id="24fc28cf-8364-4644-8ce4-deb9b468ab55">
        <updating/>
        <source>drawRoRoObjectAt(_obj: Object; _x1: Integer; _y1: Integer; _x2: Integer; _y2: Integer; _drawingController: CMUI_GridDrawingController input) updating;
// ---------------------------------------------------------------------------
// Created:		cnwjk3 PAR 22733 08/03/2010
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpCDC : YRD_RoRoLaneDrawingController;
	theTI : CM_TrackedItem;
begin
	
	if _obj = null then
		return;
	endif;

	tmpCDC := _drawingController.YRD_RoRoLaneDrawingController;

	if _obj.isKindOf(CM_TrackedItem) then
		theTI := _obj.CM_TrackedItem;
	endif;

	if not _drawingController.drawFromNote and theTI &lt;&gt; null then
		tmpCDC.setForRedraw(theTI, _x1, _y1, _x2, _y2);
		tmpCDC.setMyCurrentObject(theTI);
		tmpCDC.drawCurrentObject(self);
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_drawingController" type="CMUI_GridDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawRoRoObjectAtPolygon" id="6e54dcd1-deb5-4849-92ce-8acc490d3f43">
        <updating/>
        <source>drawRoRoObjectAtPolygon(_obj: Object; _points : PointArray; _drawingController: CMUI_GridDrawingController input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpLC : CM_LocationsController;
	tmpCDC : YRD_RoRoLaneDrawingController;
	x1, y1, x2, y2 : Integer;
begin
	if _obj = null then
		return;
	endif;

	tmpCDC := _drawingController.YRD_RoRoLaneDrawingController;

	if _obj.isKindOf(CM_LocationsController) then
		tmpLC := _obj.CM_LocationsController;
	elseif _obj.isKindOf(CM_TrackedItem) then
		if tmpCDC.displayMode = DISPLAY_MODE_ACTUAL then
			tmpLC := _obj.CM_TrackedItem.myPrimaryActualLocation;
		elseif tmpCDC.displayMode = DISPLAY_MODE_PLAN then
			tmpLC := _obj.CM_TrackedItem.myPrimaryPlannedLocation;
		elseif tmpCDC.displayMode = DISPLAY_MODE_QUEUE then
			tmpLC := _obj.CM_TrackedItem.myPrimaryQueuedLocation;
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled object ' &amp; _obj.String);
	endif;

	if tmpLC &lt;&gt; null 
	and tmpLC.isKindOf(CM_RoRoController) then
		tmpCDC.getXYsFromRectanglePolygon(_points,x1, y1, x2, y2);
		// Adjust x if there is a start offset
		if tmpLC.CM_RoRoController.startOffset &gt; 0 then
			if _drawingController.flipHorizontal then
				x2 := x2 +  tmpLC.CM_RoRoController.getGLVDrawStartOffsetInPixels(_drawingController.scaleFactor);
			else
				x1 := x1 -  tmpLC.CM_RoRoController.getGLVDrawStartOffsetInPixels(_drawingController.scaleFactor);
			endif;
		endif;
		
		tmpCDC.setForRedraw(tmpLC,x1, y1, x2, y2);
		tmpCDC.setMyCurrentObject(tmpLC);
		tmpCDC.drawCurrentObject(self);
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_points" type="PointArray"/>
        <Parameter name="_drawingController" type="CMUI_GridDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawSolidRectangle" id="ae88ea7f-3a78-40d5-ac69-663ee190080a">
        <executionLocation>client</executionLocation>
        <source>drawSolidRectangle(_x1: Real; _y1: Real; _x2: Real; _y2: Real; _color: Integer) clientExecution;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen fro Flexible Terminal Areas
//
vars

begin
	if self.swapXY then
		inheritMethod(_y1 + self.swapYadjustment, _x1 + self.swapXadjustment, _y2 + self.swapYadjustment, _x2 + self.swapXadjustment, _color);
	else
		inheritMethod(_x1, _y1, _x2, _y2, _color);
	endif;

epilog

end;</source>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_color" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawSolidRectangleNoFlip" id="ac805770-16f1-4c00-90fd-b8d53a1062aa">
        <updating/>
        <source>drawSolidRectangleNoFlip(_x1, _y1, _x2, _y2 : Real; _colour : Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/06/2020	jlgdap1		Initial creation TFS 49453
//
vars
	currentSwap : Boolean;
	x1, x2, y1, y2 : Real;

begin
	currentSwap := self.swapXY;
	self.swapXY := false;
	if currentSwap then
		self.drawSolidRectangle(_y1 + self.swapYadjustment, _x1 + self.swapXadjustment, (_y1 + self.swapYadjustment + (_x2 - _x1)), (_x1 + self.swapXadjustment + (_y2 - _y1)), _colour);
	else
		self.drawSolidRectangle(_x1, _y1, _x2, _y2, _colour);
	endif;
	self.swapXY := currentSwap;
epilog

end;</source>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawTextAt" id="9bdbfd13-9264-4b81-9af9-dcf442172111">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>drawTextAt(_text: String; _x1: Real; _y1: Real; _color: Integer) clientExecution, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
26 November 2008	consw1	Initial creation

*/

vars
	alignAdjustment : Real;
	
begin
	if self.swapXY then
 		if self.drawTextAlign = Frame.DrawTextAlign_Center then
			alignAdjustment := self.drawTextHeight(_text) * 0.5;
		endif;
		inheritMethod(_text, _y1 + self.swapYadjustment + alignAdjustment, _x1 + self.swapXadjustment - alignAdjustment, _color);
	else
		inheritMethod(_text, _x1, _y1, _color);
	endif;

epilog

end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_color" type="Integer"/>
    </JadeMethod>
