    <JadeMethod name="findInvoiceType" id="3f10be01-0b78-4341-bc0f-7254bb8e0945">
        <source>findInvoiceType(_description : String) : CM_InvoiceDesc;
/*

Purpose:			Return the invoice type for a given description  (no suitable dictionary so look at each one)

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2015	cnwjre1	Initial creation

*/

vars
	invType	: CM_InvoiceDesc;
begin
	foreach invType in self.invoiceTypes  discreteLock do
		if invType.description = _description then
			return invType;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_description" type="String"/>
        <ReturnType type="CM_InvoiceDesc"/>
    </JadeMethod>
    <JadeMethod name="findMatchedVoyageWorkOrders" id="8ebaa5b5-7b3c-47af-a124-8ff683a38a6b">
        <source>findMatchedVoyageWorkOrders(_trans	: HMS_VTMISTransaction;
							_woSet  : CM_WorkOrderSet io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Feb 2022 navma1	ChangeRequest 52580: SAL - Work Order and Invoicing link

*/

vars
	voyage			: CM_Voyage;
	movement,
	shiftMovement	: HMS_Movement;
	wo				: CM_WorkOrder;
	imsr 			: CM_WodMarineServicesInitial;
	dmsr 			: CM_WodMarineServicesDepart;
	
begin
	
	if _trans  = null then
		return;
	endif;
	
	voyage := _trans.myVoyage;
	
	if voyage = null then
		return;
	endif;
	
	if voyage.myVoyageProcess = null or not voyage.myVoyageProcess.isMTNWOProcess then
		return;
	endif;
	
	if voyage.allWorkOrders.isEmpty then
		return;
	endif;
	
	movement := _trans.myMovement;
	
	if movement = null then
		return;
	endif;
	
	// Arrival Movement 	- Link To IMSR Wo
	// Shit Movment 		- Link To Shit  Wo
	// Departure Movement	= Link To Departure Wo
	
	if movement.moveType = HMSMovementTypeArrival then
		imsr := voyage.getWorkOrderForIMSR;
		if imsr &lt;&gt; null and imsr.myParent &lt;&gt; null then
			wo := imsr.myParent;
			_woSet.add(wo);
		endif;
		
	elseif movement.moveType = HMSMovementTypeShift then
		foreach wo in voyage.allWorkOrders discreteLock do 
			if not wo.isWorkOrderForShift then
				continue;
			endif;
			
			shiftMovement := wo.getMyHMSVoyageMovement();
			
			if shiftMovement = null then
				continue;
			endif;	
			
			if shiftMovement = movement then
				_woSet.add(wo);
				break; 
			endif;
		endforeach;
				
				
		
	elseif movement.moveType =  HMSMovementTypeDeparture then
		dmsr := voyage.getWorkOrderForDMSR();
		if dmsr &lt;&gt; null and dmsr.myParent &lt;&gt; null then
			wo := dmsr.myParent;
			_woSet.add(wo);
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_trans" type="HMS_VTMISTransaction"/>
        <Parameter name="_woSet" type="CM_WorkOrderSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findMatchedWorkOrders" id="0d3edec2-0be9-41b1-9912-77d2281f6ba9">
        <source>findMatchedWorkOrders(_trans  : CM_TITransaction ;
					  _debtor : CM_Debtor;
					  _woSet  : CM_WorkOrderSet io );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Dec 2021 navma1	ChangeRequest 52580: SAL - Work Order and Invoicing link

*/

vars
	ti 				: CM_TrackedItem;
	wo 				: CM_WorkOrder;
	proforma		: CM_ProformaDetails;
	payment			: CM_CashPayment;
	cashRec     	: CM_CashReceipt;
	cashPayments	: CM_CashPaymentSet;
begin
	
	if _trans.myTrackedItem  = null then
		return;
	endif;
	
	ti := _trans.myTrackedItem;
	
	create cashPayments transient;
	
	ti.allCashPayments.copyNoDuplicates(cashPayments,false);
	
	if not ti.allWorkOrders.isEmpty then
		foreach wo in ti.allWorkOrders do
			if  wo.allCashReceipts.isEmpty then
				continue;
			endif;
			
			foreach cashRec in wo.allCashReceipts do
				cashRec.allCashPayments.copyNoDuplicates(cashPayments,false);
			endforeach;
			
		endforeach;
		
	endif;
	
	foreach payment in cashPayments discreteLock do 
		
		cashRec := payment.myCashReceipt;
		
		if payment.isTaxPayment then
			continue;
		endif;
		
		if cashRec = null then
			continue;
		endif;
		
		if cashRec.myWorkOrder = null then
			continue;
		endif;
		
		if cashRec.getDebtor &lt;&gt; _debtor then
			continue;
		endif;
		
		if payment.myProformaDetail = null then
			continue;
		endif;
		
		proforma := payment.myProformaDetail;
		
		if proforma.transactionType &lt;&gt; _trans.type then
			continue;
		endif;
		
		wo := cashRec.myWorkOrder;
		
		_woSet.addNoDuplicates(wo,false);
		
	endforeach;
	
	if _woSet.size &gt; 1 then
		foreach wo in _woSet do 
			if not wo.allInvoices.isEmpty then
				if not wo.allInvoices.isAllMatchingStatus(CM_Invoice.INVOICE_OPEN) then
					_woSet.remove(wo);
				endif;
			endif;
		endforeach;
	endif;
epilog
	delete cashPayments;
end;</source>
        <Parameter name="_trans" type="CM_TITransaction"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_woSet" type="CM_WorkOrderSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="generateNextCrdExtNumber" id="3f4c9c9d-7890-4885-b5e3-42daeed35670">
        <source>generateNextCrdExtNumber() : String;
/*

Purpose:			
		This method returns the next Credit Note External number by calling the Auto Id generator "CM_AutoCreditExtNumberGen"
		If Auto Id generator "CM_AutoCreditExtNumberGen" is not configured yet, return null
Parameters:			

Return Value:		

Date		Who		Reason
30 December 2022	navkc1	Initial creation TFS CR 55300 TASK 55526

*/

vars
	cnExtNumGenerator		: CM_AutoCreditExtNumberGen;
	terminal				: CM_Terminal;
	cnExtNumber,
	terminalCode			: String;
	
begin
	
	cnExtNumGenerator := self.getMyAutoIdGenerator(CM_AutoCreditExtNumberGen).CM_AutoCreditExtNumberGen;
	
	if cnExtNumGenerator = null then
		return null;
	endif;
	
	terminal := self.terminal;
	
	if terminal &lt;&gt; null then
		terminalCode := terminal.code;
	endif;
	
	cnExtNumber := cnExtNumGenerator.getNextId(null, terminalCode);
	
	return cnExtNumber;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="generateNextCrdInvExtNumber" id="f1bcb1e4-33ec-4308-b49a-80fcecb42da1">
        <source>generateNextCrdInvExtNumber() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
11 September 2024		jlizm1	Initial creation TFS 65953 NSW Dynamics Integration - Auto Generate ID

*/

vars
	generator		: CM_AutoIdCrdInvExtNumberGen;
	terminal		: CM_Terminal;
	id				:String;
	terminalCode	: String;
	
begin
	
	generator := self.getMyAutoIdGenerator(CM_AutoIdCrdInvExtNumberGen).CM_AutoIdCrdInvExtNumberGen;

	if generator = null then
		return null;
	endif;
	
	terminal := self.terminal;
	
	if terminal &lt;&gt; null then
		terminalCode := terminal.code;
	endif;
	
	id := generator.getNextId(null, terminalCode);
	
	return id;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="generateNextInvExtNumber" id="e700d289-97ce-4959-950f-13b6373cf193">
        <source>generateNextInvExtNumber() : String;
/*

Purpose:			
		This method returns the next Invoice External number by calling the Auto Id generator "CM_AutoInvoiceExtNumberGen"
		If Auto Id generator "CM_AutoInvoiceExtNumberGen" is not configured yet, return null
Parameters:			

Return Value:		

Date		Who		Reason
30 December 2022	navkc1	Initial creation TFS CR 55300 TASK 55526

*/

vars
	invExtNumGenerator		: CM_AutoInvoiceExtNumberGen;
	terminal				: CM_Terminal;
	invExtNumber,
	terminalCode			: String;
	
begin
	
	invExtNumGenerator := self.getMyAutoIdGenerator(CM_AutoInvoiceExtNumberGen).CM_AutoInvoiceExtNumberGen;
	
