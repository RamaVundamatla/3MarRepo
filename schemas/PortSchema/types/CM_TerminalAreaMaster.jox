    <JadeMethod name="setProxyTerminalArea" id="5317dc21-bf96-4b3d-80db-b420b88b3b62">
        <updating/>
        <source>setProxyTerminalArea(_id: String;
					_comment: String; 
					_type: Integer; 
					_actAsReleasePoint: Boolean; 
					_terminal: CM_Terminal; 
					_autoRestrictions: Boolean; 
					_stockControlled: Boolean; 
					_hideFromOverView: Boolean; 
					_allInterchangeAreas	:CM_InterchangeAreaArray;	// par 24292
					_defaultInterchangeArea: CM_InterchangeArea) updating, protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date			Who		Reason
17 August 2009	cnwer1	Initial creation
26/05/2010		cnwcs5	par 24292 - change _allInterchangeAreas parameter from set to array
*/

vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.comment			:= _comment;
	self.id					:= _id.toUpper;
	self.type				:= _type;
	
	self.myType				:= app.myRoot.allTerminalAreaTypes[_type];
	self.myTerminal			:= _terminal;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_actAsReleasePoint" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_autoRestrictions" type="Boolean"/>
        <Parameter name="_stockControlled" type="Boolean"/>
        <Parameter name="_hideFromOverView" type="Boolean"/>
        <Parameter name="_allInterchangeAreas" type="CM_InterchangeAreaArray"/>
        <Parameter name="_defaultInterchangeArea" type="CM_InterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="setPxyProductMinMax" id="7ba20338-44df-46f5-bc5d-76acae53d55f">
        <source>setPxyProductMinMax(_pxyTA : SelfType);
// ---------------------------------------------------------------------------
// Created:		03 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	realMinMax, pxyMinMax : CM_TerminalAreaProductMinMax;
	realProduct : CM_Product;
	realCargoType : CM_CargoType;
	objs : ObjectSet;
	realLocation : CM_LocationsController;
begin
	// MinMax to Delete
	create objs transient;
	foreach realMinMax in self.allProductMinMax discreteLock do
		//realProduct := realMinMax.myProduct;
		//if realProduct &lt;&gt; null then
			if realMinMax.myLocationsController = null then	//29 Mar 2021	NDL	TFS 49912
				pxyMinMax := _pxyTA.getProductMinMaxObject(realMinMax.myCargoType,realMinMax.myProduct );
			else	//29 Mar 2021	NDL	TFS 49912
				//The 'mylocation' is always deleted so always re-created fresh
			endif;
			if pxyMinMax = null then
				objs.add(realMinMax);
			endif;
		//endif;
	endforeach;

	objs.purge();
	
	// Min Max to Create or Update
	foreach pxyMinMax in _pxyTA.allProductMinMax discreteLock do
		//realProduct := pxyMinMax.myProduct;
		//if realProduct &lt;&gt; null then
			if pxyMinMax.myLocationsController = null then	//29 Mar 2021	NDL	TFS 49912
				realMinMax := self.getProductMinMaxObject(pxyMinMax.myCargoType,pxyMinMax.myProduct );		
			else	//29 Mar 2021	NDL	TFS 49912
				//The 'mylocation' is always deleted so always re-created fresh
				//but this needs to happen seperately against the real location, after it has been created.
				//See CM_GeneralCargoAllocRowArea::setForUpdateAllocArea
				continue;
			endif;
			if realMinMax = null then
				create realMinMax;
				pxyMinMax.setMyTerminalAreaMaster(self); //also done in 'setForUpdate' below
			endif;
			
			realMinMax.setForUpdate(pxyMinMax, app.myPassport);
				
		//endif;
		
	endforeach;
epilog
	delete objs;
end;</source>
        <Parameter name="_pxyTA" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setStateObject" id="4518c256-3b3c-4a6a-b640-32bc9c0e896d">
        <updating/>
        <source>setStateObject(_stateObj : CM_StateObject) updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
