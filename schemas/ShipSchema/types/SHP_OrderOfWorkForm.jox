    <JadeMethod name="getData" id="4a0ddf64-3767-4c99-804c-9f31b85c88db">
        <updating/>
        <source>getData(pText: String input; pType: Integer input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/08/2010	cnwdap1		PAR #25240 Cater for two hatch jobs in sequence when renumbering jobs
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 02/11/12		PJS			PAR #30631 - Voyage Rationalisation
// 08/05/13		cnwpjs		PAR # 31415 - renumbering issue
// ---------------------------------------------------------------------------

vars	
	theReturn: Integer;
	jobs : CM_VoyageJobArray;
begin
	if pText.trimBlanks = null then
		return;
	endif;
	if pType = self.GetData_Renumber then
		
		//epr TFS 830 13/4/17 refactored for reuse with order of work monitor
		create jobs transient;
		self.getSelectedJobs(jobs,false);
		while true do
			app.myTrxUA.trxUpdateVoyageJobsRenumber(pText,jobs,app.myPassport);
			if  not app.myPassport.trxCompletedOK then
				theReturn := app.showErrorWarningDialog(app.getErrorString(Order_Of_Work), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
	endif;
epilog
	delete jobs;

end;</source>
        <Parameter name="pText" type="String" usage="input"/>
        <Parameter name="pType" type="Integer" usage="input"/>
    </JadeMethod>
