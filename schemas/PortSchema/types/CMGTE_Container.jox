// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_booking);

	self.clean := _booking.clean;
	self.isoType := _booking.isoType;
	
epilog

end;</source>
        <Parameter name="_booking" type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="setPXYFromController" id="0ba54b06-9f39-48ef-a4c8-67b4dede5e59">
        <updating/>
        <source>setPXYFromController(_flexi : CMIF_FlexiGateController) updating;
// ---------------------------------------------------------------------------
// Created:     19 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 03/12/2009		cnwdap1			CCMS MES 1007 Moved reefer properties up to CMGTE_Receival level
// ---------------------------------------------------------------------------

vars

begin

	inheritMethod(_flexi);
	
	self.placardShowing := _flexi.hasPlacard;
	self.scaleWeight := _flexi.scaleWeight;
	self.coolingType := _flexi.coolingType;
	self.voltageType := _flexi.voltageType;
	self.availabilityGrade := _flexi.availabilityGrade;
	self.offsitePreTrip := _flexi.offsitePreTrip;
	self.offsiteCleaned := _flexi.offsiteCleaned;
	
	if _flexi.weightTotal &gt; 0 then
		self.weight := _flexi.weightTotal;
	endif;
	
	
	// ### For IN FULLs and MTs
	self.cargoType := TI_CargoType_Container;
	
	self.isoType := _flexi.isoTypeCode; // If receival full may have an ISO on the book reference
	
	if self.myParent &lt;&gt; null then
		self.myTerminal := null;
	endif;
	
	if _flexi.mtOnly then
		self.commodity := self.getMyTerminal().getDefaultEmptyCommodity();	//app.myRoot.getMTCommodity().code;
	elseif _flexi.jobType = self.JobType_FullIN then	//10 July 2014	NDL	Par 33788
		self.contentsStatus := TI_CONTENTS_STATUS_FCL;	//10 July 2014	NDL	Par 33788
	endif;
	
epilog

end;</source>
        <Parameter name="_flexi" type="CMIF_FlexiGateController"/>
    </JadeMethod>
    <JadeMethod name="setParamsOnJRWGateTicket1" id="bde7741d-bcc8-45be-9279-48400cb17354">
        <updating/>
        <source>setParamsOnJRWGateTicket1(_jrwReport	: JadeReportWriterReport) updating;
// ---------------------------------------------------------------------------
// Created:     26 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	contID, bookNum, contISO, contTemp, contWeight, contCool, contSeals, contGenID, contLen : String;

begin
	bookNum := self.bookingReference;
	contID := self.id;
	contISO := self.isoType;
	
	contTemp := self.getDisplayTemperature(false, true);
	contWeight := self.weightTotal.asStringJMT;
	contCool := app.coolingTypeENumToString(self.coolingType, true);
	contSeals := self.getAllSeals();
	contGenID :=	self.getGenID();
	contLen := self.getActualLength.Integer.String;

	//if self.ownerChassisID &lt;&gt; null then
	//	_jrwReport.setParameter('chassisID', self.ownerChassisID);
	//endif;
	
	_jrwReport.setParameter('containerID', contID);
	_jrwReport.setParameter('containerLen', contLen);
	_jrwReport.setParameter('containerISO', contISO);
	_jrwReport.setParameter('contGenID', contGenID);
	_jrwReport.setParameter('contTemp', contTemp);
	_jrwReport.setParameter('contCool', contCool);
	_jrwReport.setParameter('contWeight', contWeight);
	_jrwReport.setParameter('contSeals', contSeals);
		

epilog

end;</source>
        <Parameter name="_jrwReport" type="JadeReportWriterReport"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromTI" id="b1afcfe5-59ec-4c11-9718-6500e87fb09a">
        <updating/>
        <source>setPxyFromTI(_ti: CM_Container) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 March 2010	cnwjk3	PAR 22502

*/

vars

begin
	inheritMethod(_ti);
	self.availabilityGrade 		:= _ti.availabilityGrade;
	self.isoType 				:= _ti.isoType;
	self.isOverDimensions		:= _ti.isOverDimensions;		//+cnwml2 PAR25277
	self.dimLenFront			:= _ti.overLengthFront;
	self.dimLenRear				:= _ti.overLengthRear;
	self.dimWidthLeft			:= _ti.overWidthLeft;
	self.dimWidthRight			:= _ti.overWidthRight;
	self.height					:= _ti.overHeight;
	self.length					:= _ti.length;
	self.width					:= _ti.width;
	self.height					:= _ti.height;
	self.offsiteCleaned 		:= _ti.offsiteCleaned;
	self.offsitePreTrip			:= _ti.offsitePreTrip;
	self.clean					:= _ti.isClean;
		
	

epilog

end;</source>
        <Parameter name="_ti" type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="validateCargoTypeContents" id="78f9a747-151b-491b-a6a8-bf0a3aaf59f4">
        <source>validateCargoTypeContents();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/10/2025	navdap1		Initial creation MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
//
vars
	isoTypeObj : CM_ISOType;
	cargoTypeObj : CM_CargoType;

begin
	// Do we have an ISO type, and are we a container?
	if self.isoType = null or self.cargoType &lt;&gt; TI_CargoType_Container then
		return;
	endif;
	
	// Is the ISO type a Rotatable type?
	isoTypeObj := app.myRoot.allISOTypes[self.isoType];
	if isoTypeObj = null or not isoTypeObj.isRotatable() then
		return;
	endif;
	
	// Is the Commodity MT, or is the Contents Statsu Empty?
	if self.contentsStatus = TI_CONTENTS_STATUS_EMPTY or (self.commodity &lt;&gt; null and self.commodity = self.myTerminal.getConfig(DefCommodity).String) then
		return;
	endif;
	
	// We need a Cargo Type for Contents if we're rotatable
	if self.cargoTypeContents = null then
		app.raiseCMException(Cargo_Type_Contents_Required, null, null);
		return;
	endif;
	cargoTypeObj := app.myRoot.allCargoTypesById[self.cargoTypeContents];
	if cargoTypeObj = null then
		app.raiseCMException1(Cargo_Type_Invalid, self.cargoTypeContents.String, null, null);
		return;
	endif;
	
	// The Cargo Type for Contents must be valid for this terminal
	if not self.myTerminal.allCargoBOLTypes.includes(cargoTypeObj) then
		app.raiseCMException2(Cargot_not_valid_cargot_termin, cargoTypeObj.description, self.myTerminal.name, null, null);
		return;
	endif;
	
	// The product (cargo subtype) must be supplied if the cargo type requires cargo sub types
	if cargoTypeObj.isSubCargoTypeRequired and self.myProduct = null then
		app.raiseCMException(Must_select_cargo_subtype, null, null);
		return;
	endif;
	
	// The product (cargo subtype) must be valid for the Cargo Type for Contents
	if self.myProduct &lt;&gt; null and self.myProduct.myCargoType &lt;&gt; cargoTypeObj then
		app.raiseCMException2(CargoSubtype_Invalid, cargoTypeObj.description, self.myProduct.code, null, null);
		return;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="808f0d58-cbb3-4a12-bff7-a209989af942">
        <updating/>
        <source>validateForCreate(_passport: CM_Passport input; _pxyTI : CM_TrackedItem io): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     22 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	------------------------------------------
// 06/10/2025		navdap1			MTN-36141 AAT | Rotabox Creation (EDI/API/Manual)
// ---------------------------------------------------------------------------

vars
	theIsoType : CM_ISOType;
	theCargoType : CM_CargoType;
	str : String;
begin

	inheritMethod(_passport, _pxyTI);
		
	// cnwjk3 22/01/09 CCMS 1620
	self.validateISOType();	
		
		
	theCargoType := app.myRoot.allCargoTypesById[self.cargoType];
	theIsoType := app.myRoot.allISOTypes[self.isoType];
	if theIsoType &lt;&gt; null and theIsoType.myCargoType &lt;&gt; theCargoType then
		app.raiseCMException2(CargoTypeDoesNotMatchIsoType, theIsoType.myCargoType.description, theCargoType.description, null,self);
		return _passport.noErrors();
	endif;
	
	//10 July 2014	NDL	Par 33788 - Raise a warning for Full containers if no commodity entered. ( Will default 
	//                              to empty during CM_TrackedItem::setContentsStatus if nothing entered )
	if self.contentsStatus = TI_CONTENTS_STATUS_FCL and self.commodity = null then
		str := self.myTerminal.getDefaultEmptyCommodity();
		app.raiseCMWarning1(CommodityWillDefaultMT, str, null, null, null);
	endif;
	
	self.validateCargoTypeContents();		// MTN-36141
	
epilog
	return _passport.noErrors;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateISOType" id="ab9f558e-da98-4b0d-a7b3-5cb5986ad893">
        <source>validateISOType();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Jan 2009	cnwjk3	CCMS 1620
16 Mar 2010	consw1	PAR #22886 - Leaking transients
*/

vars
	iter 	: Iterator;
	ti 		: CM_TrackedItem; 
	items 	: ObjectArray;
	isoType : String;
	term	: CM_Terminal;
	size	: Integer;
begin
	
	if self.cargoType = TI_CargoType_Container then
		term := self.myTerminal;
		
		if term.getConfig(GateInCheckISOTypes).Boolean then
			create items transient;
			iter := term.allOffsiteTIsByIdCargoType.createIterator();
			term.allOffsiteTIsByIdCargoType.startKeyGeq(self.id, self.cargoType, null, iter);
			while iter.next(ti) do
				if ti.id &lt;&gt; self.id then
					break;
				endif;
				items.add(ti);
			endwhile;
			
			size := items.size();
			if size &gt; 0 and items[size].isKindOf(CM_Container) then
				// Check the isoType of the last entry in the array, as this would be the last time that it visited the terminal
				if items[size].CM_Container.isoType &lt;&gt; self.isoType then
					if  self.isoType = null then
						isoType := "UNSPECIFIED";
					else 
						isoType := self.isoType; 
					endif;
					app.raiseCMWarning4(ISO_Types_Differ, self.id, isoType, items[size].CM_Container.isoType, null, null, null, null);
				endif;
			endif;
		endif;
	endif;
epilog
	delete items;	
	delete iter;
end;</source>
    </JadeMethod>
</Class>
