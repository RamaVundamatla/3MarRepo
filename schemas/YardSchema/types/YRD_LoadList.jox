        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkReceivalHalt" id="4a8c165e-93c9-48c7-9892-276a0941c4aa">
        <source>checkReceivalHalt(_theController : CMIF_OpCargoRecController) : Boolean;
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	ops, label, trainCode : String;
	anOp : CM_Operator;
	invalidTrain : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myCurrentTrain, invalidTrain); //10/10/08 cnwdz2 Par 17732
	if _theController.stopReceival then
		label := app.getErrorString(SHP_Unavailable);
	else
		label := app.getErrorString(SHP_Available);
	endif;
	trainCode := self.myCurrentTrain.code;
	//10/10/08 cnwdz2 Par 17732
	if invalidTrain then		
		app.msgBox(app.getErrorString(ERR_DELETED_VOYAGE),"",MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	if self.lstOperators.allSelectedObjects.isEmpty then
		return app.msgBox(app.getErrorString(SHP_Voyage) &amp; trainCode &amp; ". " &amp;  app.getErrorString(SHP_Make_All_Operators) &amp; ' ' &amp; label &amp; app.getErrorString(SHP_For_Cargo_Receival),app.getErrorString(SHP_Confirm_Cargo_Receive), MsgBox_Yes_No) = MsgBox_Return_Yes;
	else
		foreach anOp in _theController.allOperators do
			if ops = null then
				ops := anOp.code;
			else
				ops := ops &amp; ", " &amp;  anOp.code;
			endif;
		endforeach;
		
		return app.msgBox(app.getErrorString(SHP_Voyage) &amp; trainCode &amp; ". " &amp; app.getErrorString(SHP_Make) &amp; ' ' &amp; ops &amp; " "  &amp; label &amp; app.getErrorString(SHP_For_Cargo_Receival),app.getErrorString(SHP_Confirm_Cargo_Receive), MsgBox_Yes_No) = MsgBox_Return_Yes;
		
	endif;
end;</source>
        <Parameter name="_theController" type="CMIF_OpCargoRecController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
