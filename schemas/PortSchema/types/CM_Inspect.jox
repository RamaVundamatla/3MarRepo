        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="6ede6530-661b-4197-b060-6a23cdce1f83">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isKindOf(CM_Log) then	// 10/09/2009 cnwar2 CCMS-1107/#20627
		// Log inspection/fumigation for C3 not associated with Todo Task
				return null;
			else
				return self.getCompletedTaskString;
			endif;
			
		endif;
							
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="8c04f0a4-cd75-44fe-be8f-e02725e516aa">
        <source>getEnquiryRow(): String;
//----------------------------------------------------------------
//	Created:	31 October 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	lDetail : String;

begin
	lDetail := inheritMethod();
	
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isKindOf(CM_Log) then	// 10/09/2009 cnwar2 CCMS-1107/#20627
		// Log inspection/fumigation for C3 not associated with Todo Task
	else
		lDetail := lDetail &amp; self.getCompletedTaskString;
	endif;
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="49193b98-f90d-4457-b9ba-fa3b86d23f8a">
        <updating/>
        <source>updateTI(_passport : CM_Passport input) updating;
begin
	inheritMethod(_passport);
	if self.myTrackedItem = null then
		return;
	endif;
	
	self.myTrackedItem.setInspectDetails();

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
