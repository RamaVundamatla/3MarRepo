    <JadeMethod name="cnwdad1_Test_EncodeWebData" id="b724800f-2fd9-49e2-bc93-1a282f3f5741">
        <source>cnwdad1_Test_EncodeWebData();
// --------------------------------------------------------------------------------
// Created:		30 January 2001 by cnwdad1
//
// Purpose:		This method will test the String::jssUrlEncode method.
//
//	*****************************************************************************
//	** Refer to the text of this method for a sample XML message for testing. ***
//	*****************************************************************************
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theDataFile		: File;
	dataString		: String;
	startTime		: Integer;
	
begin
	create theDataFile transient;
	
	theDataFile.kind		:=	File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	theDataFile.mode		:=	File.Mode_Input;
	theDataFile.fileName	:=	"c:\temp\tradehub\292830.txt";
	
	if theDataFile.isAvailable() then
		write "Reading the data file...";
		
		while not theDataFile.endOfFile() do
			if dataString = null then
				dataString	:=	theDataFile.readLine();
			else
				dataString	:=	dataString &amp; theDataFile.readLine();
			endif;
		endwhile;
		
		theDataFile.close();
		
		if dataString = null then
			write "The data string is empty !";
		else
			write "Encoding the data string of " &amp; dataString.length().String &amp; " bytes...";
			startTime	:=	app.clock();
			dataString	:=	dataString.jssUrlEncode(String.JSS_URL_ENCODE_JADE);
			write "Size of result string = " &amp; dataString.length().String &amp; " bytes.";
			write "String encoded in " &amp; startTime.jssClockDifference().String &amp; " seconds.";
		endif;
	else
		write "Cannot open the data file.";
	endif;
epilog
	delete theDataFile;
end;</source>
