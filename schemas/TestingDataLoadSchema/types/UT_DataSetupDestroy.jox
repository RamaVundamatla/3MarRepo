    <JadeMethod name="processSystemISOGroups" id="fc124a3f-a1ab-4742-a762-970374847b30">
        <source>processSystemISOGroups(_isoGroupXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the iso groups

Date			Who		Reason
29/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	isoTypesArray			: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;
	code					: String;
	isoTypes				: String;
		
begin

	varsStr := 'isoTypes 			: CM_ISOTypeByCodeDict;' &amp; CrLf;
	
	codeStr := codeStr &amp; 'create isoTypes transient;' &amp; CrLf;
	
	epilogStr := 'delete isoTypes;';

	create isoTypesArray transient;
	
	foreach obj in _isoGroupXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		code := self.returnElementText(xmlElement.getElementByTagName('code')).String;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		
		codeStr := codeStr &amp; Tab &amp; 'isoTypes.clear();' &amp; CrLf;
		
		isoTypesArray.clear();
		isoTypes := self.returnElementText(xmlElement.getElementByTagName('isoTypes')).String;
		isoTypes.cnReplaceString('"', '');
		isoTypesArray.clear();
		isoTypes.getTokensForDelimiter(';', isoTypesArray);
		foreach isoTypes in isoTypesArray do
			codeStr := codeStr &amp; Tab &amp; 'isoTypes.add(app.myRoot.allISOTypes["' &amp; isoTypes &amp; '"]);' &amp; CrLf;
		endforeach;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addISOGroup("' &amp; code &amp; '", "' &amp; description &amp; '", isoTypes);' &amp; CrLf; 
		codeStr.cnReplaceString('""', '"');
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	delete isoTypesArray;
end;
</source>
        <Parameter name="_isoGroupXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemISOTypes" id="77356ba8-61a9-4349-848f-f7fcd509fffa">
        <source>processSystemISOTypes(_operatorXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the iso types

Date			Who		Reason
28/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	code					: String;
	isReefer				: Boolean;
	is20ft					: Boolean;
	is8ft6					: Boolean;
	canBeTwinLifted			: Boolean;
	isGeneral				: Boolean;
	tareWeight				: Integer;
	is8ft					: Boolean;
	isCrib					: Boolean;
	is30ft					: Boolean;
	is9ft6					: Boolean;
	is40ft					: Boolean;
	is45ft					: Boolean;
	is53ft					: Boolean;
	isIntegral				: Boolean;
	isPowered				: Boolean;
	isOpenTop				: Boolean;
	cargoType				: String;
	
begin

	varsStr := 'cargoType			: CM_CargoType;' &amp; CrLf;
	
	codeStr := CrLf;
	//codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'cargoType := app.myRoot.allCargoTypesById[1];' &amp; CrLf;
	
	foreach obj in _operatorXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		code := self.returnElementText(xmlElement.getElementByTagName('code')).String;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		cargoType := self.returnElementText(xmlElement.getElementByTagName('cargoType')).String;
		isReefer := self.returnElementText(xmlElement.getElementByTagName('isReefer')).Boolean;
		is20ft := self.returnElementText(xmlElement.getElementByTagName('is20ft')).Boolean;
		is8ft6 := self.returnElementText(xmlElement.getElementByTagName('is8ft6')).Boolean;
		canBeTwinLifted	:= self.returnElementText(xmlElement.getElementByTagName('canBeTwinLifted')).Boolean;
		isGeneral := self.returnElementText(xmlElement.getElementByTagName('isGeneral')).Boolean;
		tareWeight := self.returnElementText(xmlElement.getElementByTagName('tareWeight')).Integer;
		is8ft := self.returnElementText(xmlElement.getElementByTagName('is8ft')).Boolean;
		isCrib := self.returnElementText(xmlElement.getElementByTagName('isCrib')).Boolean;
		is30ft := self.returnElementText(xmlElement.getElementByTagName('is30ft')).Boolean;
		is9ft6 := self.returnElementText(xmlElement.getElementByTagName('is9ft6')).Boolean;
		is40ft := self.returnElementText(xmlElement.getElementByTagName('is40ft')).Boolean;
		is45ft := self.returnElementText(xmlElement.getElementByTagName('is45ft')).Boolean;
		is53ft := self.returnElementText(xmlElement.getElementByTagName('is53ft')).Boolean;
		isIntegral := self.returnElementText(xmlElement.getElementByTagName('isIntegral')).Boolean;
		isPowered := self.returnElementText(xmlElement.getElementByTagName('isPowered')).Boolean;
		isOpenTop := self.returnElementText(xmlElement.getElementByTagName('isOpenTop')).Boolean;

		if cargoType = null then
			cargoType := 1.String;
		endif;
		codeStr := codeStr &amp; Tab &amp; 'cargoType := app.myRoot.allCargoTypesById[' &amp; cargoType &amp; '];' &amp; CrLf;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addISOType("' &amp; code &amp; '", "' &amp; description &amp; '", cargoType,  ' &amp; isGeneral.String &amp; ', false, ' &amp; 
			isCrib.String &amp; ', false, ' &amp; isOpenTop.String &amp; ', ' &amp; isReefer.String &amp; ', false, ' &amp; isIntegral.String &amp; ', false, ' &amp; 
			isPowered.String &amp; ', ' &amp; is20ft.String &amp; ', ' &amp; is30ft.String &amp; ', ' &amp; is40ft.String &amp; ', ' &amp; is45ft.String &amp; ', ' &amp; 
			is53ft.String &amp; ', ' &amp; is8ft.String &amp; ', ' &amp; is8ft6.String &amp; ', ' &amp; is9ft6.String &amp; '
			, false, false, ' &amp; canBeTwinLifted.String &amp; ', ' &amp; tareWeight.String &amp; ');' &amp; CrLf;
		codeStr.cnReplaceString('""', '"');
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	
end;
</source>
        <Parameter name="_operatorXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemInvoiceLineDesc" id="844e4a39-1adb-4d75-a61d-8284592ac13a">
        <source>processSystemInvoiceLineDesc(_invLineDescXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the invoice line desc

Date			Who		Reason
01/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	element					: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;
	name					: String;
	isoTypes				: String;
	type					: String;
	debtorType				: String;
		
begin

	varsStr := 'cargoType		: CM_CargoType;' &amp; CrLf &amp;
		Tab &amp; 'theService		: CM_Service;' &amp; CrLf &amp;
		Tab &amp; 'calType1			: CM_CalculationType;' &amp; CrLf &amp;
		Tab &amp; 'invType			: CM_InvoiceDesc;' &amp; CrLf &amp;
		Tab &amp; 'invLineType1		: CM_InvoiceLineDesc;' &amp; CrLf &amp; 
		Tab &amp; 'services			: CM_ServiceByNameDict;' &amp; CrLf;
		
	codeStr := 'self.deleteInvoiceType("Extra Services");' &amp; CrLf &amp;
		Tab &amp; 'self.deleteInvoiceService("Extra Service");' &amp; CrLf &amp;
		Tab &amp; 'self.deleteInvoiceLineType("Extra Services");' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'create services transient;' &amp; CrLf;
		
	epilogStr := 'delete services;';
	
	foreach obj in _invLineDescXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		name := self.returnElementText(xmlElement.getElementByTagName('name')).String;
		
		// create invoice type
		element := xmlElement.getElementByTagName('invoiceType');
		if element &lt;&gt; null then
			type := self.returnElementText(element.getElementByTagName('type')).String;
			type.cnReplaceString('"', '');
			if type = null then
				type := 'InvoiceTypeStorage';
			endif;
			codeStr := codeStr &amp; Tab &amp; 'invType := self.createInvoiceType(' &amp; 
				self.returnElementText(element.getElementByTagName('description')).String &amp; ', ' &amp; type &amp; ');' &amp; CrLf;
		endif;
		
		// create calculation type
		element := xmlElement.getElementByTagName('calculationType');
		if element &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'calType1 := app.myRoot.allCalculationTypesByCode[' &amp; 
				self.returnElementText(element).String &amp; '];' &amp; CrLf;
		endif;
		
		// create invoice service
		element := xmlElement.getElementByTagName('invoiceService');
		if element &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'theService := self.createInvoiceService(' &amp; 
				self.returnElementText(element.getElementByTagName('description')).String &amp; ', "", calType1, null);' &amp; CrLf &amp; CrLf &amp;
				Tab &amp; 'services.add(theService);' &amp; CrLf;
		endif;
				
		// create invoice line type
		element := xmlElement.getElementByTagName('debtorType');
		if element &lt;&gt; null then
			debtorType := self.returnElementText(element).String;
		endif;
		if debtorType = null then
			debtorType := "UT_DT1";
		endif;
		codeStr := codeStr &amp; Tab &amp; 'self.createInvoiceLineType(' &amp; name &amp; ', calType1, invType, services, ' &amp; debtorType &amp; ');' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	
end;
</source>
        <Parameter name="_invLineDescXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemJobTypes" id="94009f77-f787-456d-862e-e29ad7dd5bae">
        <source>processSystemJobTypes(_jobTypesXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the job types

Date			Who		Reason
01/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
		
	cargoTypesArray			: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	name					: String;	
	hatchType				: Boolean;
	timeToComplete			: Integer;
	
begin

	codeStr := codeStr &amp; CrLf;
	
	foreach obj in _jobTypesXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		name := xmlElement.tagName;
		name.cnReplaceString('_', ' ' );
		
		hatchType := self.returnElementText(xmlElement.getElementByTagName('hatchType')).Boolean;
		timeToComplete := self.returnElementText(xmlElement.getElementByTagName('timeToComplete')).Integer;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addJobType("' &amp; name &amp; '", ' &amp; hatchType.String &amp; ', ' &amp; timeToComplete.String &amp; ');' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	
end;
</source>
        <Parameter name="_jobTypesXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemMisc" id="77057506-e56b-4ae2-b457-4de3f6637e13">
        <source>processSystemMisc();

/*

Purpose:		Process any miscellaneous system stuff	

Date			Who		Reason
09/03/2012		cnwmh5	Initial creation

*/

vars

	yaTypeContainerLength 		: CM_YATypeContainerLength;
	yaTypeOperatorItem			: CM_YATypeOperatorItem;
	
begin

	yaTypeContainerLength := CM_YATypeContainerLength.instances.first.CM_YATypeContainerLength;
	beginTransaction;
	yaTypeContainerLength.setPropertyValue("description", "Container Length");
	commitTransaction;

	yaTypeOperatorItem := CM_YATypeOperatorItem.instances.first.CM_YATypeOperatorItem;
	beginTransaction;
	yaTypeOperatorItem.setPropertyValue("description", "Operator (Item)");
	commitTransaction;

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="processSystemOperators" id="e1dff726-4a22-407b-bb3b-46e2eb31a8f7">
        <source>processSystemOperators(_operatorXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the Admin Details	

Date			Who		Reason
22/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	requiresImportOpPIN		: Boolean;
	requiresBooking			: Boolean;
	requiresDeliveryRelease	: Boolean;
	requiresHumidity		: Boolean;
	requiresVentilation		: Boolean;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'configOperatorCMIF		: CMIF_ConfigOperator;' &amp; CrLf &amp; 
		Tab &amp; 'codeGroupsColl			: CM_CodeGroupsByTypeDict;' &amp; CrLf &amp;	
		Tab &amp; 'emailAddresses			: CM_EmailEntityByTypeNameDict;';

	epilogStr := CrLf &amp; Tab &amp; 'delete configOperatorCMIF;' &amp; CrLf &amp;		
		Tab &amp; 'delete codeGroupsColl;' &amp; CrLf &amp;
		Tab &amp; 'delete emailAddresses;' &amp; CrLf;
	
	codeStr := CrLf &amp; Tab &amp; 'create configOperatorCMIF transient;' &amp; CrLf &amp;
		Tab &amp; 'create codeGroupsColl transient;' &amp; CrLf &amp;
		Tab &amp; 'create emailAddresses transient;' &amp; CrLf &amp; CrLf;
			
	foreach obj in _operatorXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		description.cnReplaceString('"', '');
		requiresImportOpPIN := self.returnElementText(xmlElement.getElementByTagName('requiresImportOpPIN')).Boolean;
		requiresBooking	:= self.returnElementText(xmlElement.getElementByTagName('requiresBooking')).Boolean;
		requiresDeliveryRelease	:= self.returnElementText(xmlElement.getElementByTagName('requiresDeliveryRelease')).Boolean;
		requiresHumidity := self.returnElementText(xmlElement.getElementByTagName('requiresHumidity')).Boolean;
		requiresVentilation := self.returnElementText(xmlElement.getElementByTagName('requiresVentilation')).Boolean;
		codeStr := codeStr &amp; Tab &amp; 'self.addOperator("' &amp; xmlElement.tagName &amp; '", "' &amp; description &amp; 
			'", false, 0, 0, null, false, false, false, false, ' &amp; requiresDeliveryRelease.String &amp; 
			', ' &amp; requiresHumidity.String &amp; ', false, ' &amp; requiresVentilation.String &amp; 
			', false, false, null, null, codeGroupsColl, false, false, ' &amp; requiresImportOpPIN.String &amp; ', null, 
			emailAddresses, 0, configOperatorCMIF, false, false);' &amp; CrLf;
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_operatorXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemPorts" id="547cccc7-4465-4c40-9244-ce529e0ebff2">
        <source>processSystemPorts(_portXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Load the ports up

Date			Who		Reason
02/03/2012		cnwmh5	Initial creation

*/

vars

	obj						: Object;
	xmlElement				: JadeXMLElement;
	activeElement			: JadeXMLElement;
	
	tmpForm					: Form;
	cntrl					: Control;
	file					: File;
	agent					: CM_LocodePortLoader;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	numControls				: Integer;
	idx						: Integer;
	text					: Binary;
	portDetails				: String;
	line					: String;

begin

	foreach tmpForm in Form.instances do
		if tmpForm.name = "PictureResourcesForm" then
			break;
		endif;
	endforeach;

	if tmpForm = null then
		return;
	endif;
	
	// get the ports 
	numControls := tmpForm.controlCount;
	foreach idx in 1 to numControls do
		cntrl := tmpForm.controls(idx);
		if cntrl.isKindOf(TextBox) then
			if cntrl.name = "txtPortDetails" then
				portDetails := cntrl.TextBox.text.Binary.uncompressToString();
				break;
			endif;
		endif;
	endforeach;
	
	// write to a file
	create file transient;
	file.fileName := app.getTempDirAppServer() &amp; "\tempPorts.txt";
	if file.isAvailable then
		file.purge;
	endif;
	file.writeLine(portDetails);
	file.close;
	
	// load the file
	create agent transient;
	agent.updateForUnitTests(file.fileName);
	
	// set the active ports
	activeElement := _portXMLElement.getElementByTagName("ActivePorts");
	if activeElement &lt;&gt; null then
		self.processActivePorts(activeElement, _methodStr);
	endif;

epilog
	delete file;
	delete agent;
end;
</source>
        <Parameter name="_portXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processSystemROROConfig" id="7aa5717d-3f0e-4a8a-bc64-4f58729749ea">
        <source>processSystemROROConfig(_roroConfigXMLElement : JadeXMLElement; _typeStr, _codeStr : String io);

/*

Purpose:		setup the roro config stuff

Date			Who		Reason
09/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement						: JadeXMLElement;
	obj								: Object;
		
	varsStr							: String;
	codeStr							: String;
	epilogStr						: String;
	
begin
	
	xmlElement := _roroConfigXMLElement.getElementByTagName("RoRoDeckLabelPrefix");
	if xmlElement &lt;&gt; null then
		_codeStr := codeStr &amp; Tab &amp; Tab &amp; _typeStr &amp; '.setConfig("' &amp; xmlElement.tagName &amp; '", ' &amp; 
			self.returnElementText(xmlElement).String &amp; ');' &amp; CrLf;
	endif;
	xmlElement := _roroConfigXMLElement.getElementByTagName("RoRoLaneCodeIsZeroFilled");
	if xmlElement &lt;&gt; null then
		_codeStr := codeStr &amp; Tab &amp; Tab &amp; _typeStr &amp; '.setConfig("' &amp; xmlElement.tagName &amp; '", ' &amp; 
			self.returnElementText(xmlElement).String &amp; ');' &amp; CrLf;
	endif;
	xmlElement := _roroConfigXMLElement.getElementByTagName("RoRoLaneLabelPrefix");
	if xmlElement &lt;&gt; null then
		_codeStr := codeStr &amp; Tab &amp; Tab &amp; _typeStr &amp; '.setConfig("' &amp; xmlElement.tagName &amp; '", ' &amp; 
			self.returnElementText(xmlElement).String &amp; ');' &amp; CrLf;
	endif;
	xmlElement := _roroConfigXMLElement.getElementByTagName("RoRoLaneNumberLength");
	if xmlElement &lt;&gt; null then
		_codeStr := codeStr &amp; Tab &amp; Tab &amp; _typeStr &amp; '.setConfig("' &amp; xmlElement.tagName &amp; '", ' &amp; 
			self.returnElementText(xmlElement).Integer.asStringJMT() &amp; ');' &amp; CrLf;
	endif;
	xmlElement := _roroConfigXMLElement.getElementByTagName("RoRoLocationCodeIsZeroFilled");
	if xmlElement &lt;&gt; null then
		_codeStr := codeStr &amp; Tab &amp; Tab &amp; _typeStr &amp; '.setConfig("' &amp; xmlElement.tagName &amp; '", ' &amp; 
			self.returnElementText(xmlElement).String &amp; ');' &amp; CrLf;
	endif;
	xmlElement := _roroConfigXMLElement.getElementByTagName("RoRoLocationNumberLength");
	if xmlElement &lt;&gt; null then
		_codeStr := codeStr &amp; Tab &amp; Tab &amp; _typeStr &amp; '.setConfig("' &amp; xmlElement.tagName &amp; '", ' &amp; 
			self.returnElementText(xmlElement).Integer.asStringJMT() &amp; ');' &amp; CrLf;
	endif;
	xmlElement := _roroConfigXMLElement.getElementByTagName("RoRoRotatedLabel");
	if xmlElement &lt;&gt; null then
		_codeStr := codeStr &amp; Tab &amp; Tab &amp; _typeStr &amp; '.setConfig("' &amp; xmlElement.tagName &amp; '", ' &amp; 
			self.returnElementText(xmlElement).String &amp; ');' &amp; CrLf;
	endif;
	xmlElement := _roroConfigXMLElement.getElementByTagName("RoRoSubDeckLabelPrefix");
	if xmlElement &lt;&gt; null then
		_codeStr := codeStr &amp; Tab &amp; Tab &amp; _typeStr &amp; '.setConfig("' &amp; xmlElement.tagName &amp; '", ' &amp; 
			self.returnElementText(xmlElement).String &amp; ');' &amp; CrLf;
	endif;
	xmlElement := _roroConfigXMLElement.getElementByTagName("RoRoOutOfTwistLockSuffix");
	if xmlElement &lt;&gt; null then
		_codeStr := codeStr &amp; Tab &amp; Tab &amp; _typeStr &amp; '.setConfig("' &amp; xmlElement.tagName &amp; '", ' &amp; 
			self.returnElementText(xmlElement).String &amp; ');' &amp; CrLf;
	endif;
	xmlElement := _roroConfigXMLElement.getElementByTagName("RoRoGeneralCargoSuffix");
	if xmlElement &lt;&gt; null then
		_codeStr := codeStr &amp; Tab &amp; Tab &amp; _typeStr &amp; '.setConfig("' &amp; xmlElement.tagName &amp; '", ' &amp; 
			self.returnElementText(xmlElement).String &amp; ');' &amp; CrLf;
	endif;
	xmlElement := _roroConfigXMLElement.getElementByTagName("RoRoLaneWidth");
	if xmlElement &lt;&gt; null then
		_codeStr := codeStr &amp; Tab &amp; Tab &amp; _typeStr &amp; '.setConfig("' &amp; xmlElement.tagName &amp; '", ' &amp; 
			self.returnElementText(xmlElement).Decimal.asStringJMT() &amp; ');' &amp; CrLf;
	endif;
	xmlElement := _roroConfigXMLElement.getElementByTagName("RoRoLaneLength");
	if xmlElement &lt;&gt; null then
		_codeStr := codeStr &amp; Tab &amp; Tab &amp; _typeStr &amp; '.setConfig("' &amp; xmlElement.tagName &amp; '", ' &amp; 
			self.returnElementText(xmlElement).Decimal.asStringJMT() &amp; ');' &amp; CrLf;
	endif;
	xmlElement := _roroConfigXMLElement.getElementByTagName("RoRoLaneGap");
	if xmlElement &lt;&gt; null then
		_codeStr := codeStr &amp; Tab &amp; Tab &amp; _typeStr &amp; '.setConfig("' &amp; xmlElement.tagName &amp; '", ' &amp; 
			self.returnElementText(xmlElement).Decimal.asStringJMT() &amp; ');' &amp; CrLf;
	endif;
	xmlElement := _roroConfigXMLElement.getElementByTagName("RoRoLocationWidth");
	if xmlElement &lt;&gt; null then
		_codeStr := codeStr &amp; Tab &amp; Tab &amp; _typeStr &amp; '.setConfig("' &amp; xmlElement.tagName &amp; '", ' &amp; 
			self.returnElementText(xmlElement).Decimal.asStringJMT() &amp; ');' &amp; CrLf;
	endif;
	xmlElement := _roroConfigXMLElement.getElementByTagName("RoRoLocationLength");
	if xmlElement &lt;&gt; null then
		_codeStr := codeStr &amp; Tab &amp; Tab &amp; _typeStr &amp; '.setConfig("' &amp; xmlElement.tagName &amp; '", ' &amp; 
			self.returnElementText(xmlElement).Decimal.asStringJMT() &amp; ');' &amp; CrLf;
	endif;
	xmlElement := _roroConfigXMLElement.getElementByTagName("RoRoLocationGap");
	if xmlElement &lt;&gt; null then
		_codeStr := codeStr &amp; Tab &amp; Tab &amp; _typeStr &amp; '.setConfig("' &amp; xmlElement.tagName &amp; '", ' &amp; 
			self.returnElementText(xmlElement).Decimal.asStringJMT() &amp; ');' &amp; CrLf;
	endif;
	xmlElement := _roroConfigXMLElement.getElementByTagName("RoRoAutoGenerateStartEnd");
	if xmlElement &lt;&gt; null then
		_codeStr := codeStr &amp; Tab &amp; Tab &amp; _typeStr &amp; '.setConfig("' &amp; xmlElement.tagName &amp; '", ' &amp; 
			self.returnElementText(xmlElement).Integer.asStringJMT() &amp; ');' &amp; CrLf;
	endif;
	
	
epilog

end;
</source>
        <Parameter name="_roroConfigXMLElement" type="JadeXMLElement"/>
        <Parameter name="_typeStr" type="String" usage="io"/>
        <Parameter name="_codeStr" type="String" usage="io"/>
