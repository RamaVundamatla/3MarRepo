    <JadeMethod name="canSeeQueue" id="fab85e1e-2638-4582-b1a4-8aaa8fcdfd1e">
        <updating/>
        <source>canSeeQueue(_queue : CM_RadioTelemetryQueue) : Boolean updating, protected;
// adm PAR 19781 May 2009. 
// 08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
vars
	isInvalid,
	returnValue: Boolean;
	rtQueue	: CM_RadioTelemetryQueue;
begin
	on Exception do app.handleDeletedObject(exception, rtQueue, isInvalid);

	rtQueue := self.myRTQueue;
	returnValue := rtQueue &lt;&gt; null and rtQueue.includesQueue(_queue);
	
	if not returnValue then
		if self.canDisplaySecondaryQueues then
			if self.myMachine.allQueues.includes(_queue) then
				returnValue:=true;
			endif;
		endif;
	endif;
	
	if isInvalid then
		return false;
	else
		return returnValue;
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canTwinLift" id="f76bc66f-0507-4f30-9a6a-451b01e22050">
        <source>canTwinLift(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2009	cnwer1	Initial creation

*/

vars

begin
