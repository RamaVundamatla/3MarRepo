    <JadeMethod name="trxCreateCargoCheckItem" id="73696342-83b9-486c-b09b-bcfcf4e7f3d6">
        <updating/>
        <source>trxCreateCargoCheckItem(_pxyCargoCheckItem : CM_CargoCheckItem input; _allCriteria : CMIF_Array input; _cargoCheck : CM_CargoCheck input; _newCargoCheckItem : CM_CargoCheckItem output; _passport : CM_Passport input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2010	cnwdap1	Initial creation
20/04/2023	navkc1	Bug 57628: CUX-Adding Criteria to Transaction Mapping allocation configuration results in error
*/
vars
	sortValue		: Real;	//20/04/2023	navkc1	Bug 57628 Needs to be the same type as receive
	cmifObject		: CMIF_Object;
	transientObj	: CMIF_YACriteriaPriority;
	proxyObj		: CM_YACriteriaPriority;
	priorityValue	: Real;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	sortValue := 0;
	
	// Now calculate the criteria priority values on the proxy objects, working
	// backwards from the least important.
	foreach cmifObject in _allCriteria reversed do
		transientObj	:=	cmifObject.CMIF_YACriteriaPriority;
		
		if transientObj.isDeleted then
			continue;
		endif;
		
		proxyObj		:=	transientObj.myProxy;
		priorityValue	:=	2 ^ sortValue;
		proxyObj.setPriorityValue(priorityValue);
		sortValue		:=	sortValue + 1;
	endforeach;
	
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateCargoCheckItem(_pxyCargoCheckItem, _allCriteria, _cargoCheck, _newCargoCheckItem,  _passport);
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyCargoCheckItem" type="CM_CargoCheckItem" usage="input"/>
        <Parameter name="_allCriteria" type="CMIF_Array" usage="input"/>
        <Parameter name="_cargoCheck" type="CM_CargoCheck" usage="input"/>
        <Parameter name="_newCargoCheckItem" type="CM_CargoCheckItem" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateCargoDamageRecordWeb" id="da9c0b6e-10cc-4009-88b9-e1c0836f0384">
        <updating/>
        <source>trxCreateCargoDamageRecordWeb(	_realTi : CM_TrackedItem input;
								_damagePos : CM_DamagePosition input;
								_damageType : CM_DamageDefinitionCode input;
								//_damageSeverity : Integer input;
								_damageSeverity : CM_DamageSeverity input;
								_passport : CM_Passport input
								) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2011	cnwndl1	Initial creation	Par 28303
11 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details
*/

vars

	proxyTIObj : CM_TrackedItem;
	isLoadStateSet : Boolean;
	damageObj : CM_DamageInstance;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	app.cmsBeginLoad(isLoadStateSet);
	proxyTIObj		:=	_realTi.pxyCreateUpdateProxy();
	app.cmsEndLoad(isLoadStateSet);
	
	proxyTIObj.setDamaged(true);
	
	create damageObj transient;
		
		damageObj.setProxy(	proxyTIObj,	//_pxyTI 			: CM_TrackedItem;
						null,	//_pxyTIMaster 	: CM_TIMaster;
						_damageType,	//_damageDefCode 	: CM_DamageDefinitionCode;
						_damagePos,	//_damagePosition : CM_DamagePosition;
						null,	//_remarks 		: String;
						false,	//_isNewDamage	: Boolean;
						1,	//_quantity		: Integer;
						_damageSeverity,	//_severity		: Integer;
						//false,	//_repaired		: Boolean		//July 1, 2022 navak20 TFS 53862
						null,	//_locationStr 	: String	01 Mar 2016	NDL	TFS 1593
						null, null, null, null, null, null, null, null, null	//July 1, 2022 navak20 TFS 53862
						);				
	
	beginTransaction;
	app.myPassport.setWarningsIgnored(true);
	app.myUtilityUA.utlUpdateTIDamage(proxyTIObj, app.myPassport);

epilog

	if proxyTIObj &lt;&gt; null then
		delete proxyTIObj;
	endif;

	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_realTi" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_damagePos" type="CM_DamagePosition" usage="input"/>
        <Parameter name="_damageType" type="CM_DamageDefinitionCode" usage="input"/>
        <Parameter name="_damageSeverity" type="CM_DamageSeverity" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
