    <JadeMethod name="getWidthOfAllFrames" id="1ad09c24-ae34-4609-8dad-13fe643cc49f">
        <source>getWidthOfAllFrames() : Real;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	aReal : Real;
	
begin
	foreach aReal in self.allColumnEndPositions reversed do
		if aReal &gt; 0 then
			return aReal;
		endif;
	endforeach;
	
	return 0;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="handleInvalidMethodCall" id="a887c08c-6007-44ba-9812-44fb51740b44">
        <source>handleInvalidMethodCall(_exc : Exception) : Integer;
// ---------------------------------------------------------------------------
// Created:     Dec 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

constants
	InvalidMethod	= 1010;
	
vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;
	if _exc.errorCode = InvalidMethod then
			if _exc.resumable then
				returnVal := Ex_Resume_Next;
			endif;
	endif;


epilog
	return returnVal;
	
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleLabelFrameMouseDown" id="50acf706-2ee7-4acb-9185-5bbc599d4b42">
        <updating/>
        <source>handleLabelFrameMouseDown(frame: CMUI_ScrollableLabelsFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     12 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gridArea	: CMUI_GridArea;
	gridCol		: CMUI_GridColumn;
	gridRow		: CMUI_GridRow;
	x1 : Real;
	y1 : Real;

begin
	//gridArea := self.allGridAreasByRowColumn.first;
	if frame = self.myHLabels then
		gridArea:=self.getGridAreaForHLabel;
	elseif frame = self.myVLabels then
		gridArea:=self.getGridAreaForVLabel;
	endif;
	if gridArea = null then
		return;
	endif;

	if frame = self.myHLabels and self.hasHLabels then
		foreach gridCol in gridArea.allGridColumns do
			if x &gt;= gridCol.x1 and x &lt;= gridCol.x2 then

				// Convert position to be relative to the main frame.
				x1 := x;
				y1 := y;
				frame.windowToScreen(x1, y1);
				self.screenToWindow(x1, y1);   // convert x, y relative to form
				gridArea.setSelected(0, gridCol.column);
				// cnwjk3 02 Dec 2008 CCMS 1032
				//gridCol.handleMouseDownEvent(button, shift, x1, y1);
				if gridArea.isMultiRowColSelectEnabled() then
					gridArea.doColumnSelection( gridCol, button, shift, x1, y1 );
				else
					gridCol.handleMouseDownEvent(button, shift, x1, y1);
				endif;				

			endif;
		endforeach;

	elseif frame = self.myVLabels and self.hasVLabels then
		foreach gridRow in gridArea.allGridRows do
			if y &gt;= gridRow.y1 and y &lt;= gridRow.y2 then
				// Convert position to be relative to the main frame.
				x1 := x;
				y1 := y;
				frame.windowToScreen(x1, y1);
				self.screenToWindow(x1, y1);   // convert x, y relative to form
				gridArea.setSelected(gridRow.row, 0);
				// cnwjk3 02 Dec 2008 CCMS 1032
				//gridRow.handleMouseDownEvent(button, shift, x1, y1);
				if gridArea.isMultiRowColSelectEnabled() then
					gridArea.doRowSelection( gridRow, button, shift, x1, y1 );
				else
					gridRow.handleMouseDownEvent(button, shift, x1, y1);
				endif;
			endif;
		endforeach;
	endif;
end;</source>
        <Parameter name="frame" type="CMUI_ScrollableLabelsFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="hasHLabels" id="34f7344f-027d-4973-8735-a04af3e53235">
        <methodInvocation>mapping</methodInvocation>
        <source>hasHLabels(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.labels = ScrollBars_Horizontal or
	   self.labels = ScrollBars_Both then
	   	_value := true;
	else
	   	_value := false;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
