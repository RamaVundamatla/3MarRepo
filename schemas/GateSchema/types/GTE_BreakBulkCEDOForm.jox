    <JadeMethod name="doCmbVoyageClick" id="f936eb83-508c-4751-a520-c243101242e1">
        <updating/>
        <source>doCmbVoyageClick() updating;
//----------------------------------------------------------------
//	Created:	20 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ediDatas	: CM_EDIDataArray;
begin
	if self.mode &lt;&gt; self.Mode_Enquire then
		//only set when searching
		return;
	endif;
	
	if cmbVoyage.text = self.VoyageNotSet then
		self.filterVoyageCode := self.VoyageNotSet ;
	elseif cmbVoyage.listObject &lt;&gt; null then
		self.filterVoyageCode := cmbVoyage.listObject.CM_Voyage.code;
	else
		self.filterVoyageCode := null;
	endif;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="1d07a317-deae-4488-a9bb-2036faa67d0b">
        <updating/>
        <source>doDelete() updating;
//----------------------------------------------------------------
//	Created:	27 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	table		: CM_DataTable;
	lineText	: String;
	result		: Integer;
	row			: Integer;
	ediTIDict	: CM_EDITIById;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	
	if self.tblData.allSelectedObjects.isEmpty
	or (app.msgBox(app.getErrorString2(ConfirmDelete, app.getErrorString(The_Selected_Items), ""), "", MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes) then	
		return;
	endif;
	
	//delete allSelectedObjects
	create ediTIDict transient;
	
	self.tblData.allSelectedObjects.copy(ediTIDict);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteEDITrackedItems(ediTIDict, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.tblData.allSelectedObjects.clear();
			break;
		else
			theResult := app.showErrorWarningDialog('Save EDI Details', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

epilog
	delete ediTIDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="doEditItem" id="30854582-560b-41f4-86b0-4ab752914c0a">
        <updating/>
        <source>doEditItem() updating;
//----------------------------------------------------------------
//	Created:	26 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	table		: CM_DataTable;
	theObject	: CM_EDICustomStopTI;
begin
	table := self.tblData;
	
	if table.allSelectedObjects.isEmpty then
		return;
	endif;
	
	inheritMethod();

	self.setControlsForEdit();

	//preset the controls with the selected rows objects details
	if table.allSelectedObjects.size &lt; 2 
	and table.row &gt; table.fixedRows then
		theObject := table.accessRow(table.row).itemObject.CM_EDICustomStopTI;
		self.txtComment.text := theObject.userNotes;
//		self.cmbVoyage.listObject := theObject.myVoyage;	// cnwrl1 13/05/2010 PAR 24221 - what it was
		self.cmbVoyage.listObject := theObject.getMyVoyage();
	endif;
	
	self.frmQuery.visible := true;
end;
</source>
    </JadeMethod>
