    <PrimAttribute name="clearSystemAlerts" id="9d8b60c1-f553-4299-8913-1b94e5154c87">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="numberOfDaysOld" id="7c13b601-5268-4510-b986-948eb22c7300">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="numberOfDaysOldRpts" id="b57f52ce-eed4-4fcd-91b6-179124ba637e">
