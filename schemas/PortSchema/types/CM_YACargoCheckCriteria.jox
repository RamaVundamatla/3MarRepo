<Class name="CM_YACargoCheckCriteria" id="cd9b068d-f219-481f-a115-ee52f53b43df">
    <superclass name="CM_YACriteria"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="misc"/>
    <ExplicitInverseRef name="myCargoCheckItem" id="dcb48abb-f70a-4193-92d2-84269aec6b39">
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_CargoCheckItem"/>
        <access>readonly</access>
        <Inverse name="CM_CargoCheckItem::allCriteria"/>
    </ExplicitInverseRef>
    <JadeMethod name="pxyCreateUpdateProxy" id="408dede1-103f-4fb8-bac3-3dfb5e2d5526">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
26 February 2010	cnwdap1	Initial creation
20/04/2011			cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
							trying to create the proxy
*/
vars
	proxyObj		: SelfType;
	completedOK		: Boolean;
	
begin
	proxyObj					:= inheritMethod();
	proxyObj.myCargoCheckItem	:= self.myCargoCheckItem;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setCargoCheckItem" id="23ad5038-1eb4-400e-afc0-e0406185b8b4">
        <updating/>
        <source>setCargoCheckItem(_cargoCheckItem : CM_CargoCheckItem) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2010	cnwdap1	Initial creation
*/
vars

begin
	self.myCargoCheckItem := _cargoCheckItem;
epilog

end;</source>
        <Parameter name="_cargoCheckItem" type="CM_CargoCheckItem"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d86d0166-315c-46ff-a977-15950ed03690">
        <updating/>
        <source>setForCreate(pProxyObj: SelfType) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 February 2010	cnwdap1	Initial creation
*/
vars

begin
	self.setForUpdate(pProxyObj);
	
	self.myCargoCheckItem	:= pProxyObj.myCargoCheckItem;
epilog

end;</source>
        <Parameter name="pProxyObj" type="SelfType"/>
    </JadeMethod>
</Class>
