    <JadeMethod name="rotateLine" id="8a723901-f9d0-4ae4-94d1-d2130c0e0876">
        <updating/>
        <source>rotateLine() updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx, x1, x2, y1, y2, length : Real;
	x1o, x2o, y1o, y2o: Real;
	centre : Point;
	degree : Real;
begin

	//       X = cosine(angle) * R
	//      Y = sine  (angle) * R

	self.frmPoint.move(5,5,200,200);
	
	centre.set(100,100);
	self.frmPoint.drawLine(50,150,150,150,Black);
	x1 := 50;
	y1 := 150;
	x2 := 50;
	y2 := 50;
	self.frmPoint.drawLine(x1,y1,x2,y2,Black);
	
	degree := 180;
//	self.rotatePoint(x1,y1,x1o,y1o,degree.cos(),degree.sin());
//	degree := degree + 180;
	self.rotatePoint(x2,y2,x2o,y2o,degree.cos(),degree.sin());
	self.frmPoint.drawLine(x1,y1,x2o,y2o,Red);
/*
	x1 := x1o;
	y1 := y1o;
	x2 := x2o;
	y2 := y2o;
	degree := 45;
	self.rotatePoint(x1,y1,x1o,y1o,degree.cos(),degree.sin());
	degree := degree + 180;
	self.rotatePoint(x2,y2,x2o,y2o,degree.cos(),degree.sin());
	self.frmPoint.drawLine(x1o,y1o,x2o,y2o,Black);

	x1 := x1o;
	y1 := y1o;
	x2 := x2o;
	y2 := y2o;
*/	
/*
	foreach idx in 1 to 90 do
		
		x1 := x1 + idx;
		y1 := y1 - 1;
	
		x2 := x1 + 100;
		y2 := y1 + 1;	
		self.frmPoint.drawLine(x1,y1,x2,y2,Black);
	
	endforeach;
	*/
end;</source>
    </JadeMethod>
    <JadeMethod name="rotatePoint" id="9299d28b-6d91-47cd-b2ec-97cda8c53e80">
        <updating/>
        <source>rotatePoint(_origX, _origY : Real; _newX : Real output; _newY : Real output; _cosVal : Real; _sinVal : Real) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpX : Real;
	tmpY : Real;
begin

	tmpX := ((_cosVal * _origX) + (_sinVal * _origX));

	if ( tmpX &lt; 0.0 ) then
		_newX := tmpX - 1;//0.5;
	else
		_newX := tmpX + 1;//0.5;
	endif;
	

	tmpY := ((_cosVal * _origY) + (_sinVal * _origY));
	if ( tmpY &lt; 0.0 ) then
		_newY := tmpY - 1;//0.5;
	else
		_newY := tmpY + 1;//0.5;
	endif;

end;</source>
        <Parameter name="_origX" type="Real"/>
        <Parameter name="_origY" type="Real"/>
        <Parameter name="_newX" type="Real" usage="output"/>
        <Parameter name="_newY" type="Real" usage="output"/>
        <Parameter name="_cosVal" type="Real"/>
        <Parameter name="_sinVal" type="Real"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4526b7f8-a279-4deb-933e-2d45a586e930">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007241, locale);
	btnClear.translateCaption(Xlat_0004140, locale);
	btnRefresh.translateCaption(Xlat_0004141, locale);
	btnUndo.translateCaption(Xlat_0004142, locale);
end;</source>
    </JadeMethod>
</GUIClass>
