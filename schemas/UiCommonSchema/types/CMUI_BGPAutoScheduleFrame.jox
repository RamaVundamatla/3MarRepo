    <JadeMethod name="setColor" id="110ae2a8-4442-41c0-8939-589bbf611108">
        <updating/>
        <source>setColor(_color, _backColor : Integer) updating;
// -------------------------------------------
// Created 26 March 2004 by cnwdvb1
// -------------------------------------------
vars

	form	: CM_BaseForm;
	parent	: Window;
	count	: Integer;

begin

	parent := self.parent;
	while parent &lt;&gt; null and count &lt; 10 do
		count := count + 1;
		if parent.isKindOf(CM_BaseForm) then
			break;
		endif;
		parent := parent.Control.parent;
	endwhile;

	if parent &lt;&gt; null and parent.isKindOf(CM_BaseForm) then
		form := parent.CM_BaseForm;
		form.setColorsForEntryTable(self.tblD);
		form.setColorsForEntryTable(self.tblM);
		form.setColorsForEntryTable(self.tblT);
		form.setColorsForEntryTable(self.tblE);
		form.setColorsForTable(self.tblStartTimes);
	endif;
//	self.tblD.backColor := _color;
//	self.tblM.backColor := _color;
//	self.tblT.backColor := _color;
//	self.tblE.backColor	:= _color;
//	self.tblStartTimes.backColor := _color;
	self.txtTimeCopy.backColor := _color;
	self.backColor		:= _backColor;
	self.frD.backColor	:= _backColor;
	self.frE.backColor	:= _backColor;
	self.frT.backColor	:= _backColor;
	self.frM.backColor	:= _backColor;


end;</source>
        <Parameter name="_color" type="Integer"/>
        <Parameter name="_backColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxyForDate" id="8da17d32-33b8-4777-8902-e1db8ee163c1">
        <source>setProxyForDate(_proxy : CM_AutoSchedule input) protected;

// cnwdvb1 18 December 2002 
/* Changes

Date		Name	TFS#	Description
============================================================================
16/04/2019	jlgka1 	43863	Added Recurring Value.
============================================================================*/
vars
	theStartTime	: Time;
	dayOfMonth,
	theDescription	: String;	
	recurValue		: Integer;
begin

	dayOfMonth		:= self.tblM.getValueByName(ETRow_DayOfMonth).String;
	theStartTime	:= self.tblM.getValueByName(ETRow_StartTime).Time;
	theDescription	:= self.tblM.getValueByName(ETRow_BgpAutoDescription).String;	
	//jlgka1 TFS 43863 --&gt;	
	recurValue	:= self.tblM.getValueByName(ETRow_RecurNumber).Integer;
	if recurValue = null then	
		app.raiseCMWarning(Input_required_field_recurValu,null, null, null);
	endif;
	//jlgka1 TFS 43863 &lt;--
	if dayOfMonth = null or
		(dayOfMonth &lt;&gt; 'START' and
		dayOfMonth &lt;&gt; 'END' ) and
		(dayOfMonth.Integer &gt; 31 or dayOfMonth.Integer = 0) or not theStartTime.isValid then
		app.raiseCMWarning1(AutoScheduleDateError, 'Problem with day of month or run time', null, null,self.myProxyAutoSchedule);		
	endif;
	_proxy.setForDate(theDescription, dayOfMonth, theStartTime, recurValue); //jlgka1 TFS 43863
end;</source>
        <access>protected</access>
        <Parameter name="_proxy" type="CM_AutoSchedule" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyForDay" id="73765156-99d2-4943-84a9-af025b8c5e5c">
        <source>setProxyForDay(_proxy : CM_AutoSchedule input) protected;

// cnwdvb1 18 December 2002 

vars

	startDate,
	endDate			: Date;
	startTimeStamp,
	endTimeStamp	: TimeStamp;
	theTime			: Time;
	mon, tue, wed,
	thur, fri, sat,
	sun				: Boolean;
	bArray			: BooleanArray;
	row, rows, fixed: Integer;
	allTimes		: TimeArray;
	theDescription	: String;

begin

	create bArray transient;
	create allTimes transient;
	theDescription		:= self.tblD.getValueByName(ETRow_BgpAutoDescription).String;
	//Par 15564 - CNWAER1 16/01/2008
	startDate 		:= self.tblD.getValueByName(ETRow_StartDateD).Date;	// the asDateJMT() is already done in the getValueByName()-&gt; getValue()
	endDate			:= self.tblD.getValueByName(ETRow_EndDateD).Date; 	// formating run twice was causing the los of the Date, falling in to the validation as incorrect
	if not startDate.isValid then
		app.raiseCMWarning1(AutoScheduleDateError, 'Start date needs revising', null, null, self.myProxyAutoSchedule);		
	endif;
	theTime.setTime(0,0,0,0);
	startTimeStamp.setDate(startDate);
	startTimeStamp.setTime(theTime);
	
	mon := self.tblD.getValueByName(ETRow_BgpMonday).Integer.Boolean;
	bArray.add(mon);
	tue := self.tblD.getValueByName(ETRow_BgpTuesday).Integer.Boolean;
	bArray.add(tue);
	wed := self.tblD.getValueByName(ETRow_BgpWednesday).Integer.Boolean;
	bArray.add(wed);
	thur := self.tblD.getValueByName(ETRow_BgpThursday).Integer.Boolean;
	bArray.add(thur);
	fri := self.tblD.getValueByName(ETRow_BgpFriday).Integer.Boolean;
	bArray.add(fri);
	sat := self.tblD.getValueByName(ETRow_BgpSaturday).Integer.Boolean;
	bArray.add(sat);
	sun := self.tblD.getValueByName(ETRow_BgpSunday).Integer.Boolean;
	bArray.add(sun);
	rows 	:= self.tblStartTimes.rows;
	fixed	:= self.tblStartTimes.fixedRows;
	theTime := null;
	foreach row in fixed to rows do
		self.tblStartTimes.row := row;
		theTime := self.tblStartTimes.text.Time;
		if theTime.isValid and not allTimes.includes(theTime) then
			allTimes.add(theTime);
		endif;
	endforeach;
	
	if allTimes.size = 0 then
	//	app.raiseCMWarning1(REQUIRED_FIELD, 'Run Times', null, null, null);		
		app.raiseCMWarning(Input_required_field_runTimes, null, null, null); // cnwdb2	PAR 35364
	endif;
	if endDate = null then
		endTimeStamp := null;
	else
		endTimeStamp.setDate(endDate);	
		endTimeStamp.setTime(theTime);
	endif;
	_proxy.setForDay(theDescription,  startTimeStamp, endTimeStamp, bArray, allTimes);

epilog
	delete bArray;
	delete allTimes;
end;</source>
        <access>protected</access>
        <Parameter name="_proxy" type="CM_AutoSchedule" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyForEvent" id="70c22e15-1454-46e6-b091-44859cd0a341">
        <source>setProxyForEvent(_proxy : CM_AutoSchedule input) protected;
// -------------------------------------------
// Created 29 June 2004 by cnwdvb1
// -------------------------------------------
vars

	theDescription	: String;
	theType			: Integer;

begin

	theDescription	:= self.tblE.getValueByName(ETRow_BgpAutoDescription).String;
	theType 		:= self.cmbEventType.itemData[self.cmbEventType.listIndex];

	_proxy.setForEvent(theDescription, theType);


end;</source>
        <access>protected</access>
        <Parameter name="_proxy" type="CM_AutoSchedule" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyForTime" id="6da0df3b-e5e2-4c01-8a54-715bea979d31">
        <source>setProxyForTime(_proxy : CM_AutoSchedule input) protected;

// cnwdvb1 18 December 2002 

vars

	theDate 		: Date;
	theStartTime	: Time;
	startTimeStamp,
	endTimeStamp	: TimeStamp;
	recurValue		: Integer;
	recurUnit,
	theDescription	: String;

begin

	theDescription	:= self.tblT.getValueByName(ETRow_BgpAutoDescription).String;
	//th2 removed call to asDateJMT as this already happens in the getValueByName method
	//parsing for current local twice causes problems when ammerican
	theDate 		:= self.tblT.getValueByName(ETRow_StartDateT).Date;
	theStartTime	:= self.tblT.getValueByName(ETRow_StartTimeT).Time;
	if not theDate.isValid or not theStartTime.isValid then
		app.raiseCMWarning1(AutoScheduleDateError,'Start date/time needs revising',  null, null, self.myProxyAutoSchedule);		
	endif;
	startTimeStamp.setDate(theDate);
	startTimeStamp.setTime(theStartTime);	
	//th2 removed call to asDateJMT as this already happens in the getValueByName method
	//parsing for current local twice causes problems when ammerican
	theDate 		:= self.tblT.getValueByName(ETRow_EndDateT).Date;
	theStartTime	:= self.tblT.getValueByName(ETRow_EndTime).Time;
	
	endTimeStamp.setDate(theDate);
	endTimeStamp.setTime(theStartTime);
	if not endTimeStamp.isValid then
		endTimeStamp := null;
	endif;
	recurValue	:= self.tblT.getValueByName(ETRow_RecurNumber).Integer;
	if recurValue = null then
	//	app.raiseCMWarning1(REQUIRED_FIELD,  'Recur Value',null, null, null);	
		app.raiseCMWarning(Input_required_field_recurValu,null, null, null);		// cnwdb2	PAR 35364
	endif;
	
	recurUnit := self.tblT.getValueByName(ETRow_RecurType).String;	
	if recurUnit = null then
	//	app.raiseCMWarning1(REQUIRED_FIELD,  'Recur Type',null, null, null);
		app.raiseCMWarning(Input_required_field_recurType,null, null, null); // cnwdb2	PAR 35364
	endif;
	_proxy.setForTime(theDescription, startTimeStamp, endTimeStamp, recurValue, recurUnit);

end;</source>
        <access>protected</access>
        <Parameter name="_proxy" type="CM_AutoSchedule" usage="input"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="2bf622bd-2a9e-449a-91ca-24e47a938749">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;

// cnwdvb1 17 December 2002 

vars

begin
	
	inheritMethod(cntrl, persistCntrl);
//	self.width 	:= 275;
//	self.height	:= 400;
//	self.width 	:= 270;
//	self.height	:= 344;
	self.caption := null;
	self.bevelInner := 0;
	self.bevelOuter := 0;
	self.bevelInnerWidth := 0;
	self.boundaryWidth := 0;
	self.borderStyle := 1;
	self.autoRedraw := true;
	
	self.createEntControls();
	self.createOtherFrames();
	self.createOptionButtons();
	self.createTables();
	
	if not self.isInPainter then
		self.doCombos();
		self.doTables();
	endif;
	self.tblStartTimes.selectionType := CM_BaseTable.SelectionType_Row;
	
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
