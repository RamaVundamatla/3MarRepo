    <JadeMethod name="getSpannedToLCsNEW" id="fe8ededf-4bbc-41b1-aebc-e69d784d55f8">
        <source>getSpannedToLCsNEW(control: CMIF_MoveController input): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2020	jlgndl1	Initial creation	TFS 50164

*/

vars

begin
	if self.isThereRoomForTI(self,control,control.myTrackedItem) &lt;&gt; null then
		return app.getErrorString1(ERR_No_Room, null);
	endif;
	
	return null;

epilog

end;</source>
