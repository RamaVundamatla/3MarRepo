<Class name="CMIF_CommercialQueryDtl" id="c04cfcef-126e-4dfe-825b-339f950a439a">
    <superclass name="CMIF_CommercialQueryEntity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <ImplicitInverseRef name="allDtlTIs" id="fadf7dc0-32b5-4164-b7e8-f31502554af4">
        <memberTypeInverse/>
        <type name="CM_TISet"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="cargoType" id="7d7cf30a-2df5-43c2-bf5b-36a65d4f296b">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="cargoTypeDescr" id="af0b51aa-3d3e-4bb1-bd81-5b2d58aea0ce">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="columnType" id="4af54fb1-2ca3-45a6-b88d-0abe3dc18786">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ExplicitInverseRef name="myHdr" id="ba1328c2-c6c8-4e0b-9603-8669ac496646">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CMIF_CommercialQueryHeader"/>
        <access>readonly</access>
        <Inverse name="CMIF_CommercialQueryHeader::allDtls"/>
    </ExplicitInverseRef>
    <PrimAttribute name="num" id="58b25bc5-9fe9-4ecd-9678-b55a6fb98c97">
        <precision>16</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="subType" id="1e1b6efa-16c4-4204-bc2b-7580e5f2e63c">
        <embedded/>
        <type name="Integer"/>
        <text>This is the TI_TransactionType for services
 - class constant for Road/Rail/Sea/Transship</text>
    </PrimAttribute>
    <PrimAttribute name="type" id="a794abe9-e81e-454c-856c-84ae2edfc74e">
        <embedded/>
        <type name="Integer"/>
        <text>This is for
 - Receive		Constant CMIF_CommercialQueryEntity::DtlType_Receival
 - Release		Constant CMIF_CommercialQueryEntity::DtlType_Release
 - Service		Constant CMIF_CommercialQueryEntity::DtlType_Services</text>
    </PrimAttribute>
    <JadeMethod name="addTI" id="3e159b70-8821-47e1-914e-ebd3409731c9">
        <updating/>
        <source>addTI(_ti : CM_TrackedItem; _num : Decimal) updating;
// ---------------------------------------------------------------------------
// Created:     23 November 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	
begin

	self.allDtlTIs.add(_ti);
	
	self.num := self.num + _num;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_num" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTISet" id="a9b7a2d9-d690-4bf0-8e4f-cee7ddcf522f">
        <source>getTISet(): CM_TISet;
// ---------------------------------------------------------------------------
// Created:     18 February 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.allDtlTIs;
end;</source>
        <ReturnType type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="init" id="98ad3357-f9ea-459f-8c98-d98061b0a093">
        <updating/>
        <source>init(_cargoTypeDescr : String; _cargoType, _type, _subType, _columnType : Integer; _hdr : CMIF_CommercialQueryHeader) updating;
// ---------------------------------------------------------------------------
// Created:     26 November 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.allDtlTIs.clear;
	self.cargoTypeDescr := _cargoTypeDescr;
	self.cargoType	:= _cargoType;
	self.columnType := _columnType;
	self.type := _type;
	self.subType := _subType;
	self.myHdr := _hdr;
end;</source>
        <Parameter name="_cargoTypeDescr" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_subType" type="Integer"/>
        <Parameter name="_columnType" type="Integer"/>
        <Parameter name="_hdr" type="CMIF_CommercialQueryHeader"/>
    </JadeMethod>
</Class>
