    <JadeMethod name="doTblDataContextMenu" id="2672bb9e-7d33-438b-b82c-e16c4c05440f">
        <updating/>
        <source>doTblDataContextMenu(_table: Table input; _conwin: Window input; _mouse: Boolean; _x: Integer; _y: Integer): Boolean updating;
/*	
Date		Who		Reason
18 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	xLeft 	: Real;
	yTop	: Real;
begin
	xLeft 	:= _x;
	yTop 	:= _y;
	
	_conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	
	self.popupMenu(self.munContext, xLeft.Integer, yTop.Integer);
	
	return false;
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="68e00e8e-829b-4a89-95c9-52a310e90136">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
18 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	xml			:String;
	sa			:StringArray;
begin 
	xml := inheritMethod();
	
	self.myCargoCounterOutputAgent.saveColoursToXML (xml);

	xml := xml &amp; global.formatAsXML(self.XML_isActual, self.optActual.value.asStringJMT());
	xml := xml &amp; global.formatAsXML(self.XML_isContainerCount, self.chkContainerTI.value.asStringJMT());
	xml := xml &amp; global.formatAsXML(self.XML_isContainerTEU, self.chkContainerTEU.value.asStringJMT());
	xml := xml &amp; global.formatAsXML(self.XML_isGCCount, self.chkGCCount.value.asStringJMT());
	xml := xml &amp; global.formatAsXML(self.XML_isGCArea, self.chkArea.value.asStringJMT());
	xml := xml &amp; global.formatAsXML(self.XML_isGCLM, self.chkLM.value.asStringJMT());
	xml := xml &amp; global.formatAsXML(self.XML_isGCQty, self.chkQty.value.asStringJMT());
	xml := xml &amp; global.formatAsXML(self.XML_isGCVolume, self.chkVolume.value.asStringJMT());
	xml := xml &amp; global.formatAsXML(self.XML_isGCWeight, self.chkWeight.value.asStringJMT());

	xml := xml &amp; global.formatAsXMLPrefix(self.XML_CargoTypes);
	
	create sa transient;
	sa.add (CM_CargoType::id.name);
	
	xml := xml &amp; self.mulCargoTypes.getXMLStringForSelected(sa);
	xml := xml &amp; global.formatAsXMLSuffix(self.XML_CargoTypes);
	
	return xml;
epilog
	delete sa;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="6c769cf3-1182-4bc4-8137-7bf5f7c8db0d">
        <source>getXMLSettingsForSetup();
/*
Date		Who		Reason
18 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	userWindow	: CM_UserWindow;
	xml, value, key 	: String;
	coll		:CM_CargoTypeSet;
	cargoType	: CM_CargoType;
	lastPos		:Integer;
begin
	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		// colours will default to default colours for KPI output format agent
		// actual/proposed defaults to actual
		// container attributes default to TI/TEU
		// General cargo attributes default to Count/Qty/Weight/LM/Area/Volume
		// voyage defaults to app.myCurrentVoyage unless already set
		// cargoTypes default to none
		return;
	endif;
	
	xml := userWindow.xmlInfo;
	
	self.myCargoCounterOutputAgent.setColoursFromXML (xml);
	
	value := xml.cnEcGetTagValueOfName(self.XML_isActual);
	
	if value &lt;&gt; null then
		self.optActual.value	:= value.Boolean;
		self.optProposed.value	:= not value.Boolean;
	endif;
	
	value := xml.cnEcGetTagValueOfName(self.XML_isContainerCount);
	
	if value &lt;&gt; null then
		self.chkContainerTI.value	:= value.Boolean;
	endif;

	value := xml.cnEcGetTagValueOfName(self.XML_isContainerTEU);
	
	if value &lt;&gt; null then
		self.chkContainerTEU.value	:= value.Boolean;
	endif;

	value := xml.cnEcGetTagValueOfName(self.XML_isGCCount);
	
	if value &lt;&gt; null then
		self.chkGCCount.value	:= value.Boolean;
	endif;

	value := xml.cnEcGetTagValueOfName(self.XML_isGCArea);
	
	if value &lt;&gt; null then
		self.chkArea.value	:= value.Boolean;
	endif;

	value := xml.cnEcGetTagValueOfName(self.XML_isGCLM);
	
	if value &lt;&gt; null then
		self.chkLM.value	:= value.Boolean;
	endif;

	value := xml.cnEcGetTagValueOfName(self.XML_isGCQty);
	
	if value &lt;&gt; null then
		self.chkQty.value	:= value.Boolean;
	endif;

	value := xml.cnEcGetTagValueOfName(self.XML_isGCVolume);
	
	if value &lt;&gt; null then
		self.chkVolume.value	:= value.Boolean;
	endif;

	value := xml.cnEcGetTagValueOfName(self.XML_isGCWeight);
	
	if value &lt;&gt; null then
		self.chkWeight.value	:= value.Boolean;
	endif;

	create coll transient;
	value := xml.cnEcGetTagValueOfName(self.XML_CargoTypes); 	
 	
	if xml &lt;&gt; null then
 		value 	:= value.trimCharacters(CrLf);
		lastPos := 1;
		
		while true do
			key := value.cnEcGetNextTagValueOfName(CMUI_MultiSelectGroupBox.XMLTag_SelectedValue, lastPos);
			
			if key = null then
				break;
			endif;
			
			cargoType := app.myRoot.allCargoTypesById.getAtKey(key.Integer);
			
			if cargoType &lt;&gt; null then
				coll.addNoDuplicates(cargoType,false);
			endif;
			
			if lastPos = 0 then
				break;
			endif;			
		endwhile;
		
		self.mulCargoTypes.setSelected(coll);
 	endif;
	
epilog
	delete coll;
end;</source>
    </JadeMethod>
    <JadeMethod name="initQueryFrame" id="04381474-ebeb-4e53-9fd6-ddf901638fd8">
        <updating/>
        <source>initQueryFrame() updating, protected;
/*
Date		Who		Reason
18 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	frm			: CMUI_Frame;
	sht			: CMUI_Sheet;
	lstTable	: CMUI_ListTable;
	grp			: CMUI_MultiSelectGroupBox;
	parent		: Control;
	coll		: CM_CargoTypeSet;
begin 
	frm	:= self.frmQuery;
	frm.width	:= 400;
	frm.height	:= 315;
	
	sht := self.shtQuery1;
	sht.caption := app.getErrorString(Criteria);
	sht.visible := true;

	
	sht := self.shtQuery2;
	sht.caption := app.getErrorString(CargoTypes);
	sht.visible := true;
	
	grp		:= self.mulCargoTypes;
	parent	:= grp.parent.Control;
	
	grp.move (0, 0, parent.clientWidth, parent.clientHeight);
	
	grp.availableHeading 			:= app.getErrorString(Available);
	grp.selectedHeading 			:= app.getErrorString(Selected);
	grp.formDisplayEntryMethodName 	:= SHP_VoyageCargoCounterForm::displayCargoType.name; 
	grp.myBaseForm 					:= self;
	grp.mySelectedListBox.sorted 	:= true;
	
	grp.multiSelect := ListBox.MultiSelect_Extended;	
	
	create coll transient;
	
	//self.myTerminal.getAllCargoTypes (coll, false);
	self.myTerminal.getAllCargoTypes (coll, true);
	
	grp.setAvailable(coll, true);
	
	self.cmbVoyage.initialise(true);
	self.doResetSearch;
epilog
	delete coll;
end;</source>
        <access>protected</access>
    </JadeMethod>
