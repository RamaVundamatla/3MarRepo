    <JadeMethod name="setProxyFromObject" id="29f674b1-308d-43c7-ad1d-7d5d60ebabe2">
        <updating/>
        <source>setProxyFromObject(_realCustomsReference : CM_CustomsReference) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2023	navpw1	Initial creation TFS: 56851
22 July 2024  navhn30 ChangeRequest 64906: CUX | EDBIC Stop type information on GET/ customs status

*/

vars
	wsPackages : WS_RestPackagesObject;
	
begin
	self.id					:= _realCustomsReference.referenceNumber;
	self.alternateId		:= _realCustomsReference.objectName;
	self.typeId				:= _realCustomsReference.referenceType;
	self.position			:= _realCustomsReference.positionNumber;
	self.remarks			:= _realCustomsReference.customsContol;
	self.status				:= _realCustomsReference.status;
	
	/*retentionPeriodTs.setDate(_realCustomsReference.retentionPeriod);
	retentionPeriodTs.setTime(null);
	retentionPeriodTso.setFromLocalTimeStamp(retentionPeriodTs, retentionPeriodTso.getUTCBias);*/
	self.retentionPeriod	:= _realCustomsReference.retentionPeriod;	//22.07.24	navhn30	TFS 64906
	
	create wsPackages transient;
	wsPackages.total		:= _realCustomsReference.packagesTotal;
	wsPackages.remaining	:= _realCustomsReference.packagesRemaining;
	self.packages			:= wsPackages;
	
end;</source>
        <Parameter name="_realCustomsReference" type="CM_CustomsReference"/>
    </JadeMethod>
</Class>
