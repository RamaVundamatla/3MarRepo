end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUpdateDetails" id="2eb7c2fe-f3c8-44c5-90b2-0a8d5f8864d8">
        <source>getUpdateDetails() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2019	jlger1	Initial creation 47319

*/

vars

begin
	if eventType &lt;&gt; null then
		
		return eventType &amp;  " - " &amp; self.eventName;
	endif;
	
	return self.eventName;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="matchesSearchCriteria" id="9b86fa6d-a02c-466c-8c15-c183fc5724cf">
        <source>matchesSearchCriteria(_search: CMIF_SearchEventRequest): Boolean;
//--------------------------------------------------
// Created:	06 May 2005 By: cnwgd1
//--------------------------------------------------
vars
begin
	if (not inheritMethod(_search)) then
		return false;
	endif;

	if _search.allTransactionTypes.isEmpty then
		//epr TFS 47319 11/11/19
		if _search.eventType = null then
		
			return true;
		elseif _search.eventType = CM_EventRequestNotification.Event_Type_Transaction then
			if self.eventTypeNew = CM_EventRequestNotification.Event_Type_Transaction or
				self.eventTypeNew = CM_EventRequestNotification.Event_Type_IsAvailable then
				return true;
			else
				return false;
			endif;
		else
			return _search.eventType = self.eventTypeNew;
		endif;
						
	elseif _search.allTransactionTypes.includes(self.getActivityDisplayString()) then
		return true;
	endif;
	return false;
end;</source>
        <Parameter name="_search" type="CMIF_SearchEventRequest"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="16163fde-899f-47b2-b91a-d3ff163e44a6">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy 			: SelfType;
	completedOK		: Boolean;
	
begin
	proxy := inheritMethod();
	proxy.myTrackedItem := self.myTrackedItem;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="bee78792-5fef-4886-84a0-fd2f04cd571a">
        <updating/>
        <source>setForUpdate(_pxyEventRequest: CM_EventRequestNotification; _passport: CM_Passport input) updating;
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
// 16/11/2022 	navcs2	Bug 55099: MTN - Cargo Update Request - No audits on update
//--------------------------------------------------
vars
	saveTransName		: String;
	tmpTI				: CM_TrackedItem;
	tiTransaction		: CM_TITransaction;
	failedDAC  :CM_DataAccessController;
	beforeAudit,
	afterAudit	:	String;
begin
	beforeAudit := self.getAuditText(); // 21/11/2022 	navcs2	Bug 55099
	
	inheritMethod(_pxyEventRequest, _passport);
	
	saveTransName := self.eventName;
	self.eventName := _pxyEventRequest.eventName;
	self.eventType := _pxyEventRequest.eventType;	
	
	self.eventKey		:= _pxyEventRequest.eventKey;
	self.eventTypeNew	:= _pxyEventRequest.eventTypeNew;
	
	tmpTI := self.myTrackedItem;
	
	if tmpTI = null then
		//See if tracked item can be found on site
		//5/11/2009 cnwdz2 par21272 
		tmpTI := self.myTerminal.lookupTrackedItem(self.cargoId, self.myCargoType.id, TI_STATE_NORMAL, null, false);	
		
		if tmpTI &lt;&gt; null then
		//	if self.setMyTrackedItem(tmpTI, _passport) then
				// TI has been set and we have access to it
				//if tmpTI.hasTransactionOfClassName(self.eventName) then
				foreach tiTransaction in tmpTI.allTransactions discreteLock do
					//cnwjo3 19890 
					if self.enteredDT &lt; tiTransaction.dateTime then
						self.actionEventRequestNotification(tmpTI, tiTransaction, _passport);
					endif;
				endforeach;
				
		endif;
	
	// Not really sure what GD is trying to achieve here as saveTransName is set above.
	elseif self.eventName &lt;&gt; saveTransName
	and self.canUserAccessSelf(self.myUser, failedDAC, _passport)
	and tmpTI.hasTransactionOfClassName(self.eventName) then
		// Trans has been updated and it already exists
		self.updateStatusAndStatusInfo(EventRequestActioned, null);				
		//self.sendEmail(self.myUser.allEventRequestEmail[self.type], _passport);
		self.sendEmail(_passport);
		
	endif;
	
	afterAudit := self.getAuditText();  // 16/11/2022 	navcs2	Bug 55099
	app.myAA.auditUpdateTrx(self, beforeAudit, afterAudit);  // 16/11/2022 	navcs2	Bug 55099
end;</source>
        <Parameter name="_pxyEventRequest" type="CM_EventRequestNotification"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyEventNameType" id="b1cfa352-0bb3-4dff-a78c-950acbf1ca86">
        <updating/>
        <source>setProxyEventNameType(_eventName, _eventType : String; _key, _type : Integer)updating;
//--------------------------------------------------
// Created:	17 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.eventName		:= _eventName;
	self.eventType		:= _eventType;	
	self.eventKey		:= _key;
	self.eventTypeNew	:= _type;
	self.isClear := _eventType = app.getErrorString(ClearUpper);
end;</source>
        <Parameter name="_eventName" type="String"/>
        <Parameter name="_eventType" type="String"/>
        <Parameter name="_key" type="Integer"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxyRequestNotify" id="5a2732dc-c95e-4597-a72e-deaf97be142e">
        <updating/>
        <source>setProxyRequestNotify(	_addresses		: CM_StringArray; 
						_remarks, 
						_cargoId		: String;
						_user			: CM_User;
						_cargoType		: CM_CargoType;
						_trackedItem	: CM_TrackedItem;
						_organisation	: CM_Organisation;
						_terminal		: CM_Terminal;
						_status			: Integer;
						_eventType,
						_eventName		: String;
						_eventKey,                                //10/09/2009 cnwdz2 20629
						_eventTypeNew	: Integer;
						_ref			: String;
						_cleanup		: Boolean;
						_isEDI			: Boolean ) updating;	// cnwrl1 21/09/2009 PAR 20320 - MES 1011 New Messina Messages
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
//	self.setProxyRequestTI(_addresses, _remarks, _cargoId, _user, _cargoType, _organisation, _terminal, _status, (_eventType = app.getErrorString(ClearUpper)), _ref,_cleanup);
	self.setProxyRequestTI(	_addresses, _remarks, _cargoId, _user, _cargoType, _organisation,
							_terminal, _status, (_eventType = app.getErrorString(ClearUpper)),
							_ref, _cleanup, _isEDI );
	self.myTrackedItem := _trackedItem;
	self.eventName := _eventName;
	self.eventType := _eventType;
	
	// DVB added
	
	self.eventKey 		:= _eventKey;
	self.eventTypeNew	:= _eventTypeNew;
end;</source>
        <Parameter name="_addresses" type="CM_StringArray"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_organisation" type="CM_Organisation"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_eventType" type="String"/>
        <Parameter name="_eventName" type="String"/>
        <Parameter name="_eventKey" type="Integer"/>
        <Parameter name="_eventTypeNew" type="Integer"/>
        <Parameter name="_ref" type="String"/>
        <Parameter name="_cleanup" type="Boolean"/>
        <Parameter name="_isEDI" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="typeString" id="3b881349-e6f8-4d1f-831d-835f88de261e">
        <source>typeString(): String;
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	//epr TFS 47319 31/10/19
	if self.eventTypeNew = CM_EventRequestNotification.Event_Type_Transaction or
		self.eventTypeNew = CM_EventRequestNotification.Event_Type_IsAvailable then
			return app.getErrorString(Transactions);
	elseif self.eventTypeNew =  CM_EventRequestNotification.Event_Type_Stop then
			return app.getErrorString(Stops);
	elseif self.eventTypeNew = CM_EventRequestNotification.Event_Type_TodoTask then
			return app.getErrorString(To_Do_Tasks);
	endif;
	
	return EventRequestTypeNotifyStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="5ad95c8a-b9dc-44eb-9601-764583ade7be">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_passport);
	if self.eventName = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Event Notification Request', ETRow_Event, null);
		app.raiseCMException(Input_required_field_evtNotReq, ETRow_Event, null); // cnwdb2	PAR 35364
	endif;

	if self.eventType &lt;&gt; null then
		if self.eventType &lt;&gt; app.getErrorString(ClearUpper)
		and self.eventType &lt;&gt; app.getErrorString(AddUpper) then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid eventType');
		endif;
		if self.eventType = app.getErrorString(ClearUpper)
		and (not self.isClear) then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Is clear not set for clear event type');
		endif;		
	endif;	
	
	// 04/02/2013 cnwar2 #25329 - these errors picked up in earlier validation
	/*if self.eventKey = 0 then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Event Key Missing', null, null);
	endif;
	
	if self.eventTypeNew = 0 then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Event Type New Missing', null, null);
	endif;*/

	if self.type &lt;&gt; EventRequestTypeNotify then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid Type');
	endif;

	if self.allEmailAddresses.isEmpty then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Recipients', ETRow_EmailAddress, null);
		app.raiseCMException(Input_required_field_recipient, ETRow_EmailAddress, null); // cnwdb2	PAR 35364
	endif;		
		
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
