    <JadeMethod name="setComboValues" id="1c16a837-0ce5-4f1d-b152-77602b253615">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars
	op		: CM_TerminalAreaType;
	coll	: CM_TATypeByTypeDict;
	qrl		: CM_QReferenceLookup;
begin
	_combo.clear();
	
	coll := app.myRoot.allTerminalAreaTypes;
	
	foreach op in coll do
		_combo.itemObject[_combo.addItem( op.description )] := op;
	endforeach;

	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		if global.isValidObject(qrl.mySelectionValue) then
			_combo.listObject := qrl.mySelectionValue;
		endif;
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="ba4262e9-2f57-4abd-809c-73bb6220fe62">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QReferenceIsOneOf; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36228

*/

vars
	selectionValue : Integer;
	taType : CM_TerminalAreaType;
	idx : Integer;
begin
	_tbl.clear;
	_tbl.rows := 0;
	_tbl.sortColumn[1] := 2; // TFS 7821


	foreach taType in app.myRoot.allTerminalAreaTypes do
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(taType) then
			selectionValue := 1;
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; taType.description);
		_tbl.accessRow(idx).itemObject := taType;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="0f370513-46e2-4e5e-b533-ee6b9cb9dd97">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars
	str : String;
	numRows,
	idx	 : Integer;
	taTypeSet : CM_ObjectSet;
	taType : CM_TerminalAreaType;
begin

	create taTypeSet transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			taType := _tbl.accessRow(idx).itemObject.CM_TerminalAreaType;
			taTypeSet.add(taType);
		endif;
	endforeach;
	
	_op.setSearchValue(taTypeSet);
	
epilog
	delete taTypeSet;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="f1cacd13-d7de-42ba-bb7f-26f43c7179f4">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

begin 
	if _value.isKindOf(CM_TerminalAreaType) then
		if _value &lt;&gt; null then
			return _value.CM_TerminalAreaType.description;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="b64258a0-38c5-415f-84aa-b115622d40b0">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	taType : CM_TerminalAreaType;
		
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;
	
		if _value.isKindOf(CM_TerminalAreaType) then
			return _value.CM_TerminalAreaType;
		endif;
	endif;
	
	
	if _value.isKindOf(Integer) then
		return app.myRoot.allTerminalAreaTypes[_value.Integer];
	else
		foreach taType in app.myRoot.allTerminalAreaTypes do
			if taType.description = _value.String then
				return taType;
			endif;
		endforeach;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="b738fdb6-7387-4d73-90e9-9bf58d8b52b2">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	areaType : CM_TerminalAreaType;
	objSet : ObjectSet;
	obj : Object;
	rtnValue : String;
	taTypeCode : Integer;
	collStr, str : String;
	strArray : StringArray;
	typeDict : CM_TATypeByTypeDict;

begin
	if _value.isKindOf(CM_TerminalAreaType) then
		return _value.CM_TerminalAreaType.type;
		
	elseif _value.isKindOf(Integer) then
		areaType := app.myRoot.allTerminalAreaTypes[_value.Integer];
		if areaType &lt;&gt; null then
			return areaType.type;
		endif;
		
	elseif _value.isKindOf(Collection) then
		objSet := _value.ObjectSet;
		foreach obj in objSet do
			areaType := obj.CM_TerminalAreaType;
			rtnValue := rtnValue &amp; areaType.type.String &amp; CNEC_COMMA &amp; Space;
		endforeach;
		rtnValue := rtnValue[1:rtnValue.length-2];
		return rtnValue;
		
	elseif _value.isKindOf(String) and _value.String.isInteger then
		taTypeCode := _value.String.Integer;
		return app.myRoot.allTerminalAreaTypes[taTypeCode];
		
	elseif _value.isKindOf(String) and _value.String.cnContains("|") then
		collStr := _value.String;
		create strArray transient;
		create typeDict transient;
		collStr.getTokensForDelimiter("|", strArray);
		foreach str in strArray do
			areaType := str.asOid.CM_TerminalAreaType;
			if areaType &lt;&gt; null then
				typeDict.addNoDuplicates(areaType, false);
			endif;
		endforeach;
		return typeDict;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
