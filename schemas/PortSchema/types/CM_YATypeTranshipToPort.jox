    <JadeMethod name="getObjects" id="e5a47aed-c7db-47ee-bb76-1c71068bf199">
        <source>getObjects(objects: ObjectLongNameDict input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwas3	Initial creation

*/

vars
	port: CM_Port;
begin
	foreach port in app.myRoot.allActiveDestinations do
		objects[port.getYAIdentifier] := port;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
