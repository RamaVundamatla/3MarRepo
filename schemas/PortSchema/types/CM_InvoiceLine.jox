    <JadeMethod name="getTrackedItem" id="eb13743a-819d-4d5f-b58f-7ff13316c0e5">
        <source>getTrackedItem() : CM_TrackedItem;
/* ---------------------------------------------------------------------------
Created:     18 September 2008 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	tmpTI	: CM_TrackedItem;
begin

	if self.trackedItem &lt;&gt; null then
		return self.trackedItem;
	endif;
	
	if self.myTransactionEvent &lt;&gt; null then
		tmpTI := self.myTransactionEvent.getTrackedItem();
		if tmpTI &lt;&gt; null then
			return tmpTI;
		endif;
	endif;
	
	return null;
	

epilog

end;</source>
