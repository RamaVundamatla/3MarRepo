    <JadeMethod name="tblRoles_dblClick" id="b0be1bfb-877d-4afc-9aef-e853a49446c1">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblRoles_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2014	cnwndl1	Initial creation

*/

vars

	obj : Object;
	menuAction : CMUI_MenuAction;
	baseForm : CM_BaseForm;

begin

	obj := self.tblRoles.accessRow( self.tblRoles.row ).itemObject; 

	menuAction := app.myController.createMenuAction(PmSecurityRoleView, null, null, self.myTerminal);
	if menuAction &lt;&gt; null then
		baseForm := menuAction.goToObject(null, null, false, null).CM_BaseForm;
		if baseForm &lt;&gt; null then
			baseForm.show();
			if obj &lt;&gt; null then
				baseForm.setFromQuickFind(obj.CM_Object,null);
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblUsers_dblClick" id="ed7c1aa3-0555-4cc7-b356-ad81e8099be9">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblUsers_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2014	cnwndl1	Initial creation

*/

vars

	obj : Object;
	form : SOP_TableMaintForm;

begin

	obj := self.tblUsers.accessRow( self.tblUsers.row ).itemObject; 
	self.myAssistant.showTableViewForm(obj.CM_User, PmAdmSystemTableView, null, false, true);
	if obj = null then
		form := app.getForm("SOP_TableMaintForm").SOP_TableMaintForm;
		if form &lt;&gt; null then
			form.setFromQuickFind(null,"User");
		endif;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="11e7e837-e5a9-4908-91e9-9fa8ce6b2a31">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 28 September 2022 14:06:19.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019905, locale);
	btnClose1.translateCaption(Xlat_0019906, locale);
	btnCompRole.translateBubbleHelp(Xlat_0019907, locale);
	btnCompTerm.translateBubbleHelp(Xlat_0019908, locale);
