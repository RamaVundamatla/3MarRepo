<Class name="CM_RemoteBOLEntryHdr" id="ab4296f8-23bd-4f04-b039-285d0e962c19">
    <superclass name="CM_RemoteDataHdr"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="remoteDataProcessing"/>
    <JadeMethod name="getMessageResponseType" id="a9f385d8-dca6-4106-a9bf-5863dc1809a9">
        <source>getMessageResponseType(): String;

// Created by cnwdvb1 on 06 August 2007

vars

begin
	return CM_RemoteDataManager.BOLENTRYRSP;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processExternal" id="f86360c0-78d8-4c21-8727-fee3e9f6b508">
        <updating/>
        <source>processExternal(_parseAgent: CM_RemoteParseAgent io): String updating;

// Created by cnwdvb1 on 03 August 2007

vars
	response		: String;
	err				: Integer;
	errTxt,
	tmpTxt			: String;
	realRemoteHdr	: CM_RemoteDataHdr;
	headerCast		: CM_RemoteDataHdr;
	
begin
	response	:=	inheritMethod(_parseAgent);
	
	if response = null then
		if _parseAgent.createBOLEntryDetail(self) then
			app.myTrxCA.trxCreateRemoteData(self, realRemoteHdr, false, app.myPassport);
			
			if app.myPassport.trxCompletedOK() then
				tmpTxt	:=	self.runFromXMLWorker();
				
				if tmpTxt = null then
					return self.doBuildMessage(self.xmlResponse(err, errTxt));	
				else
					return self.doBuildMessage(self.xmlResponse(Err_XML, tmpTxt));
				endif;
			endif;
		endif;
		
		response	:=	app.getErrorString1(Err_XML, 'Docket Entry');
		
		return self.doBuildMessage(self.xmlResponse(Err_XML , response));
	endif;
	
	headerCast := self;
	return self.doBuildMessage(self.xmlDefaultResponse(headerCast, Err_XML , response));
end;</source>
        <Parameter name="_parseAgent" type="CM_RemoteParseAgent" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="runFromXMLWorker" id="4285cbd1-3ffc-4580-b3d5-8e5927d23754">
        <source>runFromXMLWorker() : String protected;

// Created by cnwdvb1 on 06 August 2007

vars

	entryDtl	: CM_RemoteDataDtl;
	str			: String;
	

begin

	app.myPassport.setIsBackgroundWarningsIgnored(true);
	foreach entryDtl in self.allRemoteDataDtl where not entryDtl.isProcessed do
		str := str &amp; entryDtl.CM_RemoteBOLEntryDtl.doCreateBOL();
		process.sleep(2000);
	endforeach;
	return str;

epilog
	app.myPassport.setIsBackgroundWarningsIgnored(false);
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="runProcess" id="92041d36-bd8e-4862-a6ad-f9d1f1487d78">
        <source>runProcess(_errorSet: CM_ErrorSet input; _isBackGround: Boolean): Boolean;

// Created by cnwdvb1 on 03 August 2007

vars

begin
	return inheritMethod(_errorSet, _isBackGround);

end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_isBackGround" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
