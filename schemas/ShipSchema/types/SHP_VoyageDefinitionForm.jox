/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2018	jlgndl1	Initial creation	TFS 37447

*/

vars

	wodVoyageCargoRequest : CM_WodVoyageCargoRequest;	//14 Jun 2018	NDL	TFS 39197

begin

	if self.myCurrentVoyage &lt;&gt; null then
		wodVoyageCargoRequest := self.myCurrentVoyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_CARGOINITIAL).CM_WodVoyageCargoRequest;
	else
		return;
	endif;

	if wodVoyageCargoRequest = null then
		return;
	endif;

	self.myAssistant.SHP_Assistant.showOOWorkConfirmationForm( wodVoyageCargoRequest,self.myMasterMenuAction);

epilog

end;</source>
