<Class name="WS_NMessage" id="c47c5f14-f6d1-4284-8cfa-8a3b6f31c65f">
    <superclass name="WS_NAPIObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <PrimAttribute name="key" id="52e247c1-f93d-4b7a-8c4f-f575733263e0">
        <length>121</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="level" id="06541d27-c4c3-4729-a08f-747299f57d03">
        <length>121</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="message" id="59d75324-f227-4bee-9941-8a9ff32bfe8e">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="04069bbb-6277-4f0d-8fe2-471b831fe2d8">
        <updating/>
        <source>setProxyFromObject(error : CM_Error; isError : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2020	jlgrr1	Initial creation

*/

vars

begin
	self.key := error.errorCode.String;
	self.message := error.text;
	if isError then
		self.level := NavisAPI_MessageLevel_ERROR;
	else	
		self.level := NavisAPI_MessageLevel_WARNING;
	endif;
epilog

end;</source>
        <Parameter name="error" type="CM_Error"/>
        <Parameter name="isError" type="Boolean"/>
    </JadeMethod>
</Class>
