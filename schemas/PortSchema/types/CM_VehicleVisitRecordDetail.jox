    <JadeMethod name="delete" id="5f10030b-ee4a-4663-9b54-1bc9e9cbab98">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 August 2015	cnwndl1	Initial creation

*/

vars
	isInvalid : Boolean;
begin
//	on Exception do app.handleDeletedObject(exception, self.myExtraInfoObject, isInvalid);
	if self.recordType = VisitRecord_WayBillPrint then
		if self.myExtraInfoObject &lt;&gt; null and global.isValidObject( self.myExtraInfoObject )  then	// 10 Jan 2018	NDL fix for unit test use isValidObject, handler causes 1048.
			delete self.myExtraInfoObject;	// CM_WaybillPrintDetail;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDepartureEvent" id="b6ea6ce3-5780-4f76-8d00-2d2ef52a1ecb">
        <source>getDepartureEvent() : CMEVT_TruckEvent;
// Get the departure event - Not Inversed so need to check for deleted objects
// CCMS 2346 34936
vars
	ev				:CMEVT_TruckEvent;
	invalidObject	:Boolean;
	edition			:Integer;
begin
	on Exception do app.handleDeletedObject (exception, ev, invalidObject);
	
	if not CMEVT_TruckEvent.hasInstance(self.myEvent) then
		return null;
	endif;
	
	ev := self.myEvent.CMEVT_TruckEvent;	
	if ev = null then
		return null;
	endif;
	
	// access property to force exception if ti is invalid
	edition := ev.edition;
	if invalidObject then
		return null;
	endif;
	
	return ev;
epilog

end;</source>
        <ReturnType type="CMEVT_TruckEvent"/>
    </JadeMethod>
    <JadeMethod name="getElapsedTimeStage" id="3c0b9ade-2f45-45a6-b10a-9508637961fd">
        <source>getElapsedTimeStage() : Integer;
/*

Purpose:			


Return Value:		


Date			Who		Reason
16 August 2006	cnwer1	Initial creation - PAR#xxxx
21 May 2009		concms1 Par 19715 - VVRD changes
12/11/2009		cnwcs5	par 21327 - use getDifferenceInMinutes instead of differenceAsTime
*/
vars
	ts		: TimeStamp;
	aT		: Time;
	isPos 	: Integer;
	numDays	: Integer;
begin
	ts := self.getEndTime;	// par 19715
	
	if ts = null then		// par 19715 - changed to use ts instead of self.timeEnd	
		// par 21327 - aT := app.actualTimeServer.differenceAsTime(self.timeStart, isPos, numDays);
		return app.actualTimeServer.getDifferenceInMinutes (self.timeStart);	// PAR 21327
	else
		// par 21327 - aT := ts.differenceAsTime(self.timeStart, isPos, numDays);	// par 19715 - changed to use ts instead of self.timeEnd
		return ts.getDifferenceInMinutes (self.timeStart);	// par 21327
	endif;
	
	// par 21327 - return (numDays * 24 * 60) + (aT.hour * 60) + aT.minute + 1;


epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getEndTime" id="97cb00f4-e250-48ca-8d1f-12211b3b5c0b">
        <source>getEndTime():TimeStamp;
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by concms1
// Purpose:     Par 19715 - Vehicle Visit Record Detail Changes
// Parameters:  None
// Returns:     The end time for current stage - based on start time of next stage
//				Replaces old endTime property
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11 Jan 2011	cnwkpd1		PAR #26678 - Tidy up transient leaks
// ---------------------------------------------------------------------------
vars
	iter	:Iterator;
	detail	:CM_VehicleVisitRecordDetail;
	ts		:TimeStamp;
begin
	iter 	:= self.myVehicleVisitRecord.allVehicleVisitRecordDetails.createIterator;
	
	iter.startAtObject (self);	
	
	while iter.next (detail) do
		if detail = self then
			continue;
		endif;
		
		if not detail.isVisitStage then
			continue;
		endif;
		
		// we have the next stage in the visit
		return detail.timeStart;
	endwhile;
	
	// if we get to here there was no subsequent detail stage so just use
	// the end time for the visit
	return self.myVehicleVisitRecord.timeOut;

epilog
	delete iter;		// PAR #26678
	
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
