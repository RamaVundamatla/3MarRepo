    <JadeMethod name="includeObject" id="ea207035-2c58-45c3-9fd6-3a3bb95103e2">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/08/2023	navkc1	CR 59552   Task 59555: UI CustDocs - Country Region Maint

*/

vars

begin
	
	if self.includeNotAvailableEntries then
		return true;
	else
		return not _obj.CM_CountryRegion.notAvailForEntry;
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
