<Class name="CMIF_KPICounter" id="f28a3ecf-9496-4759-b431-d2577b2102b0">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="allKPICounterCargoTypes" id="ac5c0f38-d43c-49af-a314-37b4e44866b7">
        <kind>parent</kind>
        <updateMode>automatic</updateMode>
        <type name="CMIF_KPICounterCargoTypeDict"/>
        <Inverse name="CMIF_KPICounterCargoType::myKPICounter"/>
    </ExplicitInverseRef>
    <PrimAttribute name="endMonth" id="33b0a308-c363-4b95-81dc-6d808e947de8">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myTerminal" id="5ab481b9-396f-4a84-b9c0-043ea6d5c817">
        <embedded/>
        <type name="CM_Terminal"/>
    </ImplicitInverseRef>
    <PrimAttribute name="startMonth" id="f4a72ead-cd37-4c17-bc9a-cb0c364f4598">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <JadeMethod name="getAllTIs" id="5ee8e918-8ab8-4405-866d-cce8dce0b559">
        <source>getAllTIs(_tiSet : Collection input);
/*

Date		Who		Reason
14 July 2015	cnwer1	Initial creation PAR

*/

vars
	cargoType 	: CMIF_KPICounterCargoType;
	kpiMonth 	: CMIF_KPICounterMonth;
	ti 			: CM_TrackedItem;
begin
	foreach cargoType in self.allKPICounterCargoTypes do
		foreach kpiMonth in cargoType.allKPICounterMonths do
			kpiMonth.allTIs.copy(_tiSet);
		endforeach;		
	endforeach;
epilog

end;</source>
        <Parameter name="_tiSet" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="f4c67a62-b264-4338-aae6-21d6cae4a002">
        <updating/>
        <source>setDetails( _terminal : CM_Terminal;
			_startMonth,
			_endMonth : TimeStamp;
			 _cargoTypes : CM_CargoTypesByIdDict input ) updating;
/*

Date		Who		Reason
09 July 2015	cnwer1	Initial creation PAR

*/

vars
	cargoType 	: CM_CargoType;
begin
	self.myTerminal:=_terminal;
	self.startMonth:=_startMonth;
	self.endMonth:=_endMonth;
	
	foreach cargoType in _cargoTypes do
		cargoType.getKPITotalsPerMonths(self);
	endforeach;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_startMonth" type="TimeStamp"/>
        <Parameter name="_endMonth" type="TimeStamp"/>
        <Parameter name="_cargoTypes" type="CM_CargoTypesByIdDict" usage="input"/>
    </JadeMethod>
</Class>
