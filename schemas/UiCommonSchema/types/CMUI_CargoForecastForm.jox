    <JadeMethod name="doSave" id="f0ad1a26-8d6c-4860-bbd4-17746f7d126e">
        <updating/>
        <source>doSave()updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2022	navtnr20	Initial creation

*/

vars
	realCargoForecast,
	proxyCargoForecast : CM_CargoForecast;
	result : Integer;
	operator : CM_Operator;
	cargoType : CM_CargoType;
	commodity : CM_Commodity;
	mode	: String;
begin

	create proxyCargoForecast transient;
	if self.cmbOperator.listIndex &lt;&gt; -1 then
		operator := self.cmbOperator.itemObject[self.cmbOperator.listIndex].CM_Operator;
	endif;
	if self.cmbCargoType.listIndex &lt;&gt; -1 then
		cargoType := self.cmbCargoType.itemObject[self.cmbCargoType.listIndex].CM_CargoType;
	endif;
	
	if self.cmbCommodity.listIndex &lt;&gt; -1 then
		commodity := self.cmbCommodity.itemObject[self.cmbCommodity.listIndex].CM_Commodity;
	endif;
	
	if self.cmbMode.listIndex &lt;&gt; -1 then
		mode := self.cmbMode.itemText[self.cmbMode.listIndex].String;
	endif;
	
	proxyCargoForecast.setProxyForCreate(cargoType,
			commodity,
			mode,
			operator,
			self.txtQuantity.text.Integer,		
			self.txtCargoWeight.getConvertedValue,
			self.txtCargoVolume.getConvertedValue,
			self.myObject);
		
	   while true do
			if self.myObject &lt;&gt; null then
				if  isNewBtnClicked = true then
					app.myTrxCA.trxCreateCargoForecast(proxyCargoForecast, realCargoForecast , app.myPassport);
				else
					self.setCmbForEdit(self.myTblItem);
				endif;
			endif;
			if app.myPassport.trxCompletedOK then
					self.clearErrorWarnings();
					if tblCargoForecast &lt;&gt; null then
						tblCargoForecast.clearAllData();
					endif;
					self.loadCargoForecastTable();
					self.clearCmbData();
					self.disableCmbControls();
					break;
			else
				if isNewBtnClicked = true then
					result := app.showErrorWarningDialog(app.getErrorString(Cargo_Forecast_Create), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				else
					result := app.showErrorWarningDialog(app.getErrorString(Cargo_Forecast_Update), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				endif;
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);
			endif;
			break;
	endwhile;
epilog
	delete proxyCargoForecast;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTblCFContMenu" id="9d026e92-59bb-410d-828c-69094d9adbf8">
        <updating/>
        <source>doTblCFContMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 April 2022	navtnr20	Initial creation	TFS 53142 Cargo Forecast on Voyage &amp; Train

*/

vars
	canEdit		: Boolean;
	x1,
	y1			: Real;
begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	self.mnuColumnOrganiser.visible := true;
	self.mnuColumnOrganiser.userObject := self.tblCargoForecast;
	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
