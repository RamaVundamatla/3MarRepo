    <JadeMethod name="getETDefName" id="de5668e7-76bf-4f48-9bb5-5c7fa7db1e06">
        <source>getETDefName(_reportType : Integer )  :String protected;
// -----------------------------------------------------------------------------
// Created:		17 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 01/11/2010	cnwcs5		par 23714/ccms 1132 - new report type (machine history)
// 02/08/2017	jlgdap1		TFS 5558 SNO Empty Release Reports
// 01/05/2019	jlgdap1		TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
// 03/08/2022	navkc1		Bug 54342: PRP - VVR Report
// 16 March 2023 navhl20 	Defect 57144: Send to Report showing Error
// 24/04/2023	navkc1		CR 55654 Task 55670: Jade - Contract reporting
// 16 Aug 2023 	navhl20 	ChangeRequest 58568: EUP - Delivery Dispatch – Reporting
// -----------------------------------------------------------------------------
begin

	if app.getMyUser.canDo(null, Mod_Logs) then
		if _reportType = CM_QryReportUser.ReportType_LogDocket then
			return ETDef_LogReports;
		elseif _reportType = CM_QryReportUser.ReportType_LogLocation then
			return ETDef_LogLocationReports;
		elseif _reportType = CM_QryReportUser.ReportType_LogProductLocation then
			return ETDef_LogProductLocReport;
		elseif _reportType = CM_QryReportUser.ReportType_LogSummary then
			return ETDef_LogSummary;
		elseif _reportType = CM_QryReportUser.ReportType_LogVoyageRowSummary then //21 January 2010	#cnwdz2	 CCMS 1108 par22177 
			return ETDef_LogVoyageRowSummary;
		elseif _reportType = CM_QryReportUser.ReportType_LogTransaction then
			return ETDef_LogTxnReport;
		elseif _reportType = CM_QryReportUser.ReportType_LogCheckScaling then
			return ETDef_ScaleQry;
		endif;
	endif;
	
	if _reportType = CM_QryReportUser.ReportType_BR_Discrepancy then	//07 Sep 2009	NDL CCMS 1609 Par 20521
		return ETDef_DiscrepancyReport;
	elseif _reportType = CM_QryReportUser.ReportType_CargoReport then
		return ETDef_CargoReport;
	//th2 for PAR 13924 - TrackedItem view although for logs is used for some container reports by Otago
	elseif _reportType = CM_QryReportUser.ReportType_TrackedItem then
		return ETDef_LogWharfStorage;
	elseif _reportType = CM_QryReportUser.ReportType_TransactionReport then
		return ETDef_TransactionReport;
		
	elseif _reportType = CM_QryReportUser.ReportType_TrxResource then	// 18 Jan 2010 NDL CCMS MES 1006
		return ETDef_TrxResourceReport;
		
	elseif _reportType = CM_QryReportUser.ReportType_TrxSealChecks then	// 30 Sep 2010 NDL Par 25608
		return ETDef_SealChecksReport;
		
	elseif _reportType = CM_QryReportUser.ReportType_HMSVoyage then
		return ETDef_HMSVoyages;
	elseif _reportType = CM_QryReportUser.ReportType_HMSMovements then
		return ETDef_HMSMovementRpts;
	elseif _reportType = CM_QryReportUser.ReportType_HMSGlobalVoyage then
		return ETDef_HMSGlobalVoyages;
	elseif _reportType = CM_QryReportUser.ReportType_Events then
		return ETDef_EventsReport;
	elseif _reportType = CM_QryReportUser.ReportType_BookingRef then	//Par17601. July 2008
		return ETDef_BookingRefQry;
	elseif _reportType = CM_QryReportUser.ReportType_VehicleDetails then
		return ETDef_VehicleReport;
	elseif _reportType = CM_QryReportUser.ReportType_Train then		//Par 19913
		return ETDef_TrainRep;
	elseif _reportType = CM_QryReportUser.ReportType_DateSorter then  //CCMS 1869 cnwjo3
		return ETDef_DateSorterRep;
	elseif _reportType = CM_QryReportUser.ReportType_Invoice then  // SFW CCMS 1115 PAR23680 - cnwsh3. Invoice JRW Interface
		return ETDef_InvoiceReport;
	elseif _reportType = CM_QryReportUser.ReportType_InvoiceRate then  // SFW CCMS 1155 PAR23583 - cnwrd1. Invoice Rate JRW Interface
		return ETDef_InvoiceRateReport;		
	elseif _reportType = CM_QryReportUser.ReportType_MachineHistory then	// 01/11/2010 cnwcs5 par 23714/ccms 1132
		return ETDef_MachineHistoryReport;									// 01/11/2010 cnwcs5 par 23714/ccms 1132
	elseif _reportType = CM_QryReportUser.ReportType_CraneKPI then			// Dec 2010 CCMS 1134
		return ETDef_CraneKPI;
		
	elseif _reportType = CM_QryReportUser.ReportType_CargoChgs then	//28 Feb 2012	NDL	Par 29118
		return ETDef_CargoChgs;
		
	elseif _reportType = CM_QryReportUser.ReportType_Vessels then	//01 May 2012	NDL	Par 29496
		return ETDef_HMSVesselReport;
		
	elseif _reportType = CM_QryReportUser.ReportType_HMSMasters then	//01 May 2012	NDL	Par 29496
		return ETDef_HMSMasters;
		
	elseif _reportType = CM_QryReportUser.ReportType_CashTrx then	// 14 Aug 2012	NDL	Par 29968
		return ETDef_CashTrxReport;
		
	elseif _reportType = CM_QryReportUser.ReportType_OrgAccess then	// 14 Feb 2012	jre	CCMS HAT 2205
		return ETDef_OrganisationAccess;
		
	elseif _reportType = CM_QryReportUser.ReportType_VehicleBooking then	// 16 Apr 2013	NDL	Par 31393
		return ETDef_VehicleBookingReport;
		
	elseif _reportType = CM_QryReportUser.ReportType_CashReceipt then		// 22/05/2014 cnwjre1	CCMS 2348 Financial Reporting
		return ETDef_CashReceiptReport;
		
	elseif _reportType = CM_QryReportUser.ReportType_InvoiceLine then		// 22/05/2014 cnwjre1	CCMS 2348 Financial Reporting
		return ETDef_InvoiceLineReport;

	elseif _reportType = CM_QryReport.ReportType_InvoiceProforma then //epr par 36778 18/8/15 CCMS 2368
		return ETDef_InvoiceProformaReport;
		
	elseif _reportType = CM_QryReportUser.ReportType_CashCredit then		// 3/02/2016 cnwjre1	TFS 985 cash credits
		return ETDef_CashCreditReport;

	elseif _reportType = CM_QryReport.ReportType_BOLTransaction then 		// 2/05/2016 cnwjre1  TFS 1904
		return ETDef_BOLTransaction;
		
	elseif _reportType = CM_QryReport.ReportType_BulkReleases then		// TFS 5558
		return ETDef_ContainerReport;									// TFS 5558
		
	elseif _reportType = CM_QryReport.ReportType_Audit then				// 6/6/18 MAP TFS 37718
		return ETDef_AuditReport;										// 6/6/18 MAP TFS 37718

	elseif _reportType = CM_QryReportUser.ReportType_Selector then	//19 Feb 2018	NDL	TFS 37091
		return ETDef_CargoReport;
		
	elseif _reportType = CM_QryReportUser.ReportType_SAPActivity then	// TFS 44298
		return ETDef_SAPActivityReport;									// TFS 44298
		
	elseif _reportType = CM_QryReportUser.ReportType_SpecialVoySumm  then	//14 Aug 2019	NDL	TFS 46131
		return ETDef_SpecialVoySum;									
		
	elseif _reportType = CM_QryReportUser.ReportType_EventTransaction  then	//06 Jan 2020	NDL	TFS 47780
		return ETDef_EventsReport;	
		
	elseif _reportType = CM_QryReportUser.ReportType_WOTransaction  then	//16.3.2023 navhl20	#57144
		return ETDef_WoReport;	
		
	elseif _reportType = CM_QryReportUser.ReportType_LocActivity then	//01 Jun 2021 NDL	TFS 51245
		return ETDef_LocActivityRep;
		
	elseif _reportType = CM_QryReportUser.ReportType_LocInventory then	//01 Jun 2021 NDL	TFS 51245
		return ETDef_LocInventoryRep;
	
	elseif _reportType = CM_QryReportUser.ReportType_GateReceipt then	// 03/08/2022	navkc1	#54342
		return ETDef_CargoReport;										// 03/08/2022	navkc1	#54342
	
	elseif _reportType = CM_QryReportUser.ReportType_InvoiceContract then // 20/04/2023	navkc1	CR 55654 Task 55670
		return ETDef_InvContractReport;
		
	elseif _reportType = CM_QryReportUser.ReportType_WorkOrder then 		//16.8.2023 navhl20 #58568
		return ETDef_WorkOrderReports;
	
	endif;

	return null;
end;</source>
        <access>protected</access>
        <Parameter name="_reportType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedFormats" id="7a70edf5-4faa-4eaf-9d28-e566d7220169">
        <source>getSelectedFormats(_selectedFormats : IntegerArray input) protected;
// -------------------------------------------
// Created 01 November 2004 by cnwdvb1
// -------------------------------------------
vars

	obj		: Object;
	
begin

	_selectedFormats.clear();
	foreach obj in self.lstFormats.allSelectedObjects do
		_selectedFormats.add(obj.CMIF_ReportFormats.formatType);
	endforeach;

	_selectedFormats.cnEcSort(false);

end;</source>
        <access>protected</access>
        <Parameter name="_selectedFormats" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="bd01e8e1-96c9-4559-a1f1-c15dbb2293ab">
        <updating/>
        <source>initDataTable() updating;
// -----------------------------------------------------------------------------
// Created:		13 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin

	self.allowMultiSelectEdit := true;

	self.setTblDataEntRows(ETDef_ReportData);

	self.zClearSortColumns();
	self.zAddSortColumn(ETRow_ReportName, false);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initEntryTable" id="ff9633e9-9c24-48e1-a914-59cc23fbc03b">
        <source>initEntryTable(_table : CM_EntryTable input; _entDefName : String) protected;
// ---------------------------------------------------------------------------
// Created:     19 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	entTableControl	: EntTableDef;
	
begin

	_table.rows := 0;
		
	_table.optimiseRowHeight := true;
	
	entTableControl := app.myController.getEntTableDef(_entDefName);
	_table.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');

	_table.top := self.VerticalSpacing;
	_table.left := self.HorizontalSpacing;
	_table.lockRight := true;
	_table.setDistanceFromRight(5);
	_table.stretchWidth := true;
	_table.optimiseHeadingColumn();

	_table.resetSize();
	
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_entDefName" type="String"/>
    </JadeMethod>
    <JadeMethod name="initForm" id="9f202339-2660-469f-a73d-1bbadbd07469">
        <updating/>
        <source>initForm() updating;
// -----------------------------------------------------------------------------
// Created:		13 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 03/12/2024	jlizm1		MTN 33460 Report date fields not modifyable with filter setting
// 23 Oct 2025	navec1		MTN-36160: NSWP | Implement Date String Parsing and Conversion Logic
// -----------------------------------------------------------------------------
vars

begin

	//delete self.myJRWRepresentationAgent;
	//create self.myJRWRepresentationAgent transient;
	//self.myJRWRepresentationAgent.loadJRWRepresentationObjects();
	self.allowMultiSelectDelete := false;
	self.allowMultiSelectEdit := false;
	self.useTblThumb 		:= false;
	self.useTblData			:= true;
	self.allowSearch	:= false;
	self.allowPrint		:= false;
	self.allowExportCSV	:= false;
	
	self.showDataOnStartup 	:= true;
	
	self.fldInput.useSheetBackColors := true;
	self.fldInput.setDefaultSheetBackColors();
	self.fldInput.initSheetBackColors();
	
	self.setupControls();
	self.initEntryTable(self.tblReportDtl, ETDef_ReportEntry);
	self.initEntryTable(self.tblParamEnt, ETDef_ParamEntry);
	
	self.initTblParamData();
	self.initTblCriteria();
	self.loadJRWViews();
	self.loadCmbReportType();
	self.loadParamTypes();
	self.loadSelectorQueries();
	self.loadReportFilterTypes();
	self.setDefaultDateTimes();
	
	self.doLoadTemplateDateTypes(self.cmbDefaultValDate);  //24.10.2025 navec1 #36160
	
	// ### TFS BUG 65190 12JUL2024 NAVAB1
	if app.doNotFIlterCombos then
		self.cmbArriveDFrom.style := 0;
		self.cmbArriveDTo.style := 0;
		self.cmbBaseDate.style := 0;
		self.cmbCloseDate.style := 0;
		self.cmbDepartDFrom.style := 0;
		self.cmbDepartDTo.style := 0;
		self.cmbExpArrDFrom.style := 0;
		self.cmbExpArrDTo.style := 0;
		self.cmbExpDepDFrom.style := 0;
		self.cmbExpDepDTo.style := 0;
		self.cmbExpArrDTo.style := 0;
		self.cmbInPortDFrom.style := 0;
		self.cmbInPortDTo.style := 0;
		self.cmbMatchEnd.style := 0;
		self.cmbMatchStart.style := 0;
		self.cmbOnDate.style := 0;
		self.cmbOpenDate.style := 0;
		self.cmbPackByDate.style := 0;
		self.cmbProcDate.style := 0;
	endif;
	
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initReportAvailabilityCmb" id="e4fa88cc-83f3-4cd8-95e6-b73f3ad17f30">
        <source>initReportAvailabilityCmb() protected;
// -------------------------------------------
// Created 01 November 2004 by cnwdvb1
// -------------------------------------------
vars

	idx		: Integer;

begin

	self.cmbRptAvail.clear();
	
	// Keep these in this order as item data should be same as listIndex;
	idx := self.cmbRptAvail.addItem('JMT');
	self.cmbRptAvail.itemData[idx] := CM_QryReport.ReportAvailability_JMT;
	
	idx := self.cmbRptAvail.addItem('WEB');
	self.cmbRptAvail.itemData[idx] := CM_QryReport.ReportAvailability_Web;
	
	idx := self.cmbRptAvail.addItem('WEB/JMT');
	self.cmbRptAvail.itemData[idx] := CM_QryReport.ReportAvailability_WebAndJMT;
	


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initReportFormatArray" id="4261b337-57ef-4ca2-9839-b19d28af73a2">
        <source>initReportFormatArray() protected;
// -------------------------------------------
// Created 29 October 2004 by cnwdvb1
// -------------------------------------------
vars

	format	: CMIF_ReportFormats;

begin


	self.allFormats.purge();
	
	create format transient;
	format.formatType 			:= JadeReportWriterReport.PRINTER;
	format.formatDescription	:= CMUI_ReportAgent.FORMAT_OPTION_STANDARD;
	self.allFormats.add(format);
	create format transient;
	format.formatType 			:= JadeReportWriterReport.HTML;
	format.formatDescription	:= CMUI_ReportAgent.FORMAT_OPTION_HTML;
	self.allFormats.add(format);
	create format transient;
	format.formatType 			:= JadeReportWriterReport.CSV;
	format.formatDescription	:= CMUI_ReportAgent.FORMAT_OPTION_CSV;
	self.allFormats.add(format);
	create format transient;
	format.formatType := JadeReportWriterReport.RTF;
	format.formatDescription	:= CMUI_ReportAgent.FORMAT_OPTION_RTF;
	self.allFormats.add(format);
	create format transient;
	format.formatType := JadeReportWriterReport.XML;
	format.formatDescription	:= CMUI_ReportAgent.FORMAT_OPTION_XML;
	self.allFormats.add(format);
	create format transient;
	format.formatType := CM_QryReport.PDF_Format;
	format.formatDescription	:= CMUI_ReportAgent.FORMAT_OPTION_PDF;
	self.allFormats.add(format);
	// 28218 Sep 2011 CCMS 2120 electronic invoicing, add text option
	create format transient;
	format.formatType := JadeReportWriterReport.TEXT;
	format.formatDescription	:= CMUI_ReportAgent.FORMAT_OPTION_TEXT;
	self.allFormats.add(format);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initReportProcessAvail" id="91153613-8785-4fd0-812c-d76575a40c03">
        <source>initReportProcessAvail() protected;
// -------------------------------------------
// Created 01 November 2004 by cnwdvb1
// -------------------------------------------
vars

	idx		: Integer;

begin

	self.cmbBackground.clear();
	
	// Keep these in this order as item data should be same as listIndex;
	idx := self.cmbBackground.addItem('Foreground');
	self.cmbBackground.itemData[idx] := CM_QryReport.ReportProcessType_Foreground;
	
	idx := self.cmbBackground.addItem('Background');
	self.cmbBackground.itemData[idx] := CM_QryReport.ReportProcessType_Background;
	
	idx := self.cmbBackground.addItem('Foreground/Background');
	self.cmbBackground.itemData[idx] := CM_QryReport.ReportProcessType_Both;
	


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTblCriteria" id="70cede15-772c-4f35-9d77-8a8a3245e572">
        <source>initTblCriteria() protected;
// ---------------------------------------------------------------------------
// Created:     19 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	table		: CM_BaseTable;
	entDef		: EntTableDef;
	
begin
	table := self.tblCriteria;
	table.autoSize := Table.AutoSize_Column;
	entDef := app.myController.getEntTableDef(ETDef_QryCriteria);
	
	table.setColumnHeadingsFromDef(entDef.name, false);	
	table.left		:=	self.HorizontalSpacing;
	table.tabKey	:=	J_key_Tab;
	
	self.cmbArriveDFrom.automaticCellControl	:=	true;
	self.cmbArriveDTo.automaticCellControl		:=	true;
	self.cmbDepartDFrom.automaticCellControl	:=	true;
	self.cmbDepartDTo.automaticCellControl		:=	true;
	self.cmbInPortDFrom.automaticCellControl	:=	true;
	self.cmbInPortDTo.automaticCellControl		:=	true;
	self.cmbBaseDate.automaticCellControl		:=	true;
	self.cmbOnDate.automaticCellControl			:=	true;
	self.cmbOpenDate.automaticCellControl		:=	true;
	self.cmbCloseDate.automaticCellControl		:=	true;
	self.cmbMatchEnd.automaticCellControl		:=	true;
	self.cmbMatchStart.automaticCellControl		:=	true;
	self.cmbPackByDate.automaticCellControl		:=	true;
	self.cmbProcDate.automaticCellControl		:=	true;	// 16 Nov 2009	NDL	Par 21519
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTblParamData" id="58f4db0d-8c7c-4da0-b897-bc56c3029bb9">
        <source>initTblParamData() protected;
// ---------------------------------------------------------------------------
// Created:     19 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	table		: CM_DataTable;
	entDef		: EntTableDef;
	
begin
	
	table := self.tblParamData;
	entDef := app.myController.getEntTableDef(ETDef_ParamData);
	
	table.setColumnHeadingsFromDef(entDef.name, false);
	table.setTblDataEntRowsFromDef(entDef);
	table.autoSize := Table.AutoSize_Column;
	table.left	:= self.HorizontalSpacing;
	table.top := self.HorizontalSpacing;
	table.setDistanceFromRight(5);
	table.stretchWidth := true;
	table.accessColumn(1).width := 45;
	table.selectionType := CM_EntryTable.SelectionType_Row;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadCmbReportType" id="2e1cfb4f-61f2-49c9-8481-3d1512d31b11">
        <updating/>
        <source>loadCmbReportType() updating,protected;
// -----------------------------------------------------------------------------
// Created:		17 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 12/12/2013	cnwdap1		PAR #33188 Don't put Log-type reports in the combo if we're not licensed for logs
//							(this caused problems later where no proxy was created when trying to update a report
//							that had been created as a Log-type report in a system not licensed for logs)
// 02/08/2017	jlgdap1		TFS 5558 SNO Empty Release Reports
// 01/05/2019	jlgdap1		TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
// 03/08/2022	navkc1		Bug 54342: PRP - VVR Report
// 16 March 2023 navhl20 	Defect 57144: Send to Report showing Error
// 24/04/2023	navkc1		CR 55654 Task 55670: Jade - Contract reporting
// 16 Aug 2023 	navhl20 	ChangeRequest 58568: EUP - Delivery Dispatch – Reporting
// -----------------------------------------------------------------------------
begin
	self.cmbReportType.sorted := true;	// Feb 2013 from 31156, sort the entries to make them easier to find

	if app.getMyUser.canDo(self.myTerminal, Mod_Logs)  then						// PAR #33188
		if self.getETDefName(CM_QryReportUser.ReportType_LogDocket ) &lt;&gt; null then 
			self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_LogDocket)]			:= CM_QryReportUser.ReportType_LogDocket;			//1
		endif;
		if self.getETDefName( CM_QryReportUser.ReportType_LogLocation ) &lt;&gt; null then
			self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_LogLocation)] 		:= CM_QryReportUser.ReportType_LogLocation;			//2
		endif;
		if self.getETDefName( CM_QryReportUser.ReportType_LogProductLocation ) &lt;&gt; null then
			self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_LogProductLoc)] 	:= CM_QryReportUser.ReportType_LogProductLocation;	//3
		endif;
		if self.getETDefName(CM_QryReportUser.ReportType_TrackedItem) &lt;&gt; null then 
			self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_TrackedItem)] 		:= CM_QryReportUser.ReportType_TrackedItem;			//4
		endif;
		if self.getETDefName( CM_QryReportUser.ReportType_LogVoyageRowSummary ) &lt;&gt; null then
			self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_LogVoyRowSum)] 		:= CM_QryReportUser.ReportType_LogVoyageRowSummary;	//5
		endif;
		if self.getETDefName( CM_QryReportUser.ReportType_LogTransaction ) &lt;&gt; null then
			self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_LogTransaction)] 	:= CM_QryReportUser.ReportType_LogTransaction;		//6
		endif;
		//21 January 2010	#cnwdz2	 CCMS 1108 par22177 
		if self.getETDefName( CM_QryReportUser.ReportType_LogSummary ) &lt;&gt; null then
			self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_LogSummary)] 	:= CM_QryReportUser.ReportType_LogSummary;		//6
		endif;
		if self.getETDefName( CM_QryReportUser.ReportType_LogCheckScaling ) &lt;&gt; null then
			self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_LogCheckScale)] 	:= CM_QryReportUser.ReportType_LogCheckScaling;		//8
		endif;
	endif;
	
	if self.getETDefName( CM_QryReportUser.ReportType_CargoReport ) &lt;&gt; null then
		self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_CargoReport)] 		:= CM_QryReportUser.ReportType_CargoReport;			//7
	endif;
	
	if self.getETDefName( CM_QryReportUser.ReportType_TransactionReport ) &lt;&gt; null then
		self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_TransReport)] 		:= CM_QryReportUser.ReportType_TransactionReport;	//9
	endif;
	
	if self.getETDefName( CM_QryReportUser.ReportType_HMSVoyage ) &lt;&gt; null then
		self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_HMSVoyage)] 		:= CM_QryReportUser.ReportType_HMSVoyage;			//10
	endif;
	if self.getETDefName( CM_QryReportUser.ReportType_HMSMovements ) &lt;&gt; null then
		self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_HMSMovements)] 		:= CM_QryReportUser.ReportType_HMSMovements;		//11
	endif;
	if self.getETDefName( CM_QryReportUser.ReportType_HMSGlobalVoyage) &lt;&gt; null then
		self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_HMSGlobalVoy)] 		:= CM_QryReportUser.ReportType_HMSGlobalVoyage;			//12
	endif;
	if self.getETDefName( CM_QryReportUser.ReportType_Events) &lt;&gt; null then
		self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_Events)] 			:= CM_QryReportUser.ReportType_Events;			//13
	endif;
	if self.getETDefName(CM_QryReportUser.ReportType_BookingRef) &lt;&gt; null then		// Par17601. July 2008
		self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_BookingRef)] 		:= CM_QryReportUser.ReportType_BookingRef;			//14
	endif;
	
	// PAR 18183 - Do not display for 7.6.3 release as not implemnted fully.  PAR 18183 is there to implement correctly
	if self.getETDefName(CM_QryReportUser.ReportType_VehicleDetails) &lt;&gt; null then		// Par17601. July 2008
		self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_VehicleDetails)] 		:= CM_QryReportUser.ReportType_VehicleDetails;			//15
	endif;
	if self.getETDefName(CM_QryReportUser.ReportType_Train) &lt;&gt; null then			// Par 19913
		self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_Train)] 			:= CM_QryReportUser.ReportType_Train;			//16
	endif;
	if self.getETDefName( CM_QryReportUser.ReportType_BR_Discrepancy ) &lt;&gt; null then	//07 Sep 2009	NDL CCMS 1609 Par 20521
		self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_BR_Discrepancy)] 		:= CM_QryReportUser.ReportType_BR_Discrepancy;			//17
	endif;
	
	if self.getETDefName( CM_QryReportUser.ReportType_TrxResource ) &lt;&gt; null then	// 18 Jan 2010 NDL CCMS MES 1006
		self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_TrxResource)] 		:= CM_QryReportUser.ReportType_TrxResource;	//18
	endif;
	
	if self.getETDefName( CM_QryReportUser.ReportType_TrxSealChecks ) &lt;&gt; null then	// 30 Sep 2010 NDL par 25608
		self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_TrxSealChecks)] 		:= CM_QryReportUser.ReportType_TrxSealChecks;	//23
	endif;
	
	if self.getETDefName( CM_QryReportUser.ReportType_Invoice ) &lt;&gt; null then	// SFW CCMS 1115 PAR23680 - cnwsh3. Invoice JRW Interface
		self.cmbReportType.itemData[self.cmbReportType.addItem(CM_QryReportUser.ReportTypeDescr_Invoice)] 		:= CM_QryReportUser.ReportType_Invoice;	//21
	endif;
	
	if self.getETDefName( CM_QryReportUser.ReportType_InvoiceRate ) &lt;&gt; null then	// SFW CCMS 1155 PAR23583 - cnwrd1. Invoice rate JRW Interface
