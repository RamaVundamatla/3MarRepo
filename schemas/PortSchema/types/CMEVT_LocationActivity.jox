vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createCharge" id="9279d5ce-434d-4682-a5a1-32db1a3992ca">
        <updating/>
        <source>createCharge(_passport: CM_Passport): Boolean updating;
/*
Purpose:			

Date		Who		Reason
31MAY2021	NAVAB1	TFS 51219
31 Jan 2025	navlw1 	JIRA-33865: MTN | Logging only displays that financials aren't enabled in logging level is TRACE
*/

vars
	bank	      : CM_Bank;
	term      : CM_Terminal;
	theDebtor : CM_DebtorNode;
	aMess     : String;
begin


	if self.myEventType = null then	
		app.raiseUnexpectedProgramError(class. name, method.name, 'null event type used');
		return false;
	endif;
	
	term := self.getTerminal();
	if term = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null self.myTerminal');
		return false;
	endif;

	// Start navlw1 #JIRA-33865 31/01/2025
	if self.noCharge then
		app.invLog("Transaction is not chargeable",LogINFO.String); // navlw1 #JIRA-33692
		return false;
	endif;
	if not term.getConfig(FinancialsEnabled).Boolean then
		app.invLog("Financials Are Not Enabled, No Charging Will Occur",LogTRACE.String); // navlw1 #JIRA-33692  // ### JIRA 35228 11JUL2025 NAVAB1
		return false;
	endif;
	if not app.myRoot.canDo(Mod_Invoicing) then
		app.invLog("Invoice Module is not licensed",LogINFO.String); // navlw1 #JIRA-33692
		return false;
	endif;
	// End navlw1 #JIRA-33865 31/01/2025
	
	bank := self.getBank();
	if bank = null 
	and _passport &lt;&gt; null then	
		bank := _passport.myTerminal.getDefaultCompanyBank();
	endif;

	if bank = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null business unit');
		return false;
	endif;
	
	bank.createChargeInventory(self, false);
	


end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createNextBalance" id="1e340702-e86f-494c-890b-5bd16d5a0b61">
        <source>createNextBalance(	_summedLas : CMEVT_LocationActivityByDate input;
					_totQuantity : Integer;
					_totWeight : Decimal;
					_totVolume : Decimal;
					_endTS : TimeStamp;
					_reCalcBalanceSet : CMEVT_LocationActivityByDate input
					):CMEVT_LocationActivity;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2021	navndl1	Initial creation	TFS	50906 

*/

vars

	pxyLa : CMEVT_LocationActivity;
	newLa : CMEVT_LocationActivity;

begin

	if not self.isLocationBalance then
		return null;
	endif;

	create pxyLa transient;
	
	pxyLa.type := self.type;
	pxyLa.setCargoType( self.cargoType );
	pxyLa.setOperatorCode( self.operatorCode );
	
	pxyLa.quantity := _totQuantity;
	pxyLa.weight := _totWeight;
	pxyLa.volume := _totVolume;
	pxyLa.dateTime := self.dateTime.cnEcAddDays( 1 );
	pxyLa.setLocalDateTime( null, pxyLa.dateTime, self.myTerminal );
	
	pxyLa.setMyPrevBalance( self ); 
	
	pxyLa.sourceLocationStr := self.sourceLocationStr;
	
	pxyLa.mySourceLocation := self.mySourceLocation;
	pxyLa.mySourceTA := self.mySourceTA;
	
	pxyLa.myTerminal := self.myTerminal;
	
	if self.needsRecalculation then
		pxyLa.setNeedsRecalculating(true, null );
	endif;
	
	app.myTrxCA.trxCreateLocActBalance( pxyLa, newLa, _summedLas, _reCalcBalanceSet, app.myPassport );
	
	if newLa &lt;&gt; null and newLa.myNextBalance = null and newLa.dateTime &lt; _endTS then
		//This should only occur during the agent re-calculation phase while creating NIL activity balances.
		//We are still earlier than the end date time that we are creating balances until
		//And the new balance we have created is not linked to a pre-existing later one,
		//so, create the next one.
		_summedLas.clear();
		newLa.createNextBalance( _summedLas, _totQuantity, _totWeight, _totVolume, _endTS, _reCalcBalanceSet );
	endif;
	
	return newLa;
	
epilog

	delete pxyLa;

end;</source>
        <Parameter name="_summedLas" type="CMEVT_LocationActivityByDate" usage="input"/>
        <Parameter name="_totQuantity" type="Integer"/>
        <Parameter name="_totWeight" type="Decimal"/>
        <Parameter name="_totVolume" type="Decimal"/>
        <Parameter name="_endTS" type="TimeStamp"/>
        <Parameter name="_reCalcBalanceSet" type="CMEVT_LocationActivityByDate" usage="input"/>
        <ReturnType type="CMEVT_LocationActivity"/>
    </JadeMethod>
    <JadeMethod name="createTemporaryAuditObject" id="052c1e94-8ea9-4605-8eb2-7753c84deda6">
        <source>createTemporaryAuditObject();
/*

Purpose:			
						This sucker can be deleted when the new "allAuditObjectsForClass" finally makes it to
						WMAST. Location Activity will get there first, and we will need to know what the customer has done
						when they ring us in the middle of the night with queries..... hence this temporary HACK.
						
						Need to substitute this hack with real auditing as soon as it is available in prod.
Parameters:			

Return Value:		

Date		Who		Reason
06 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	audit : CM_AuditObject;
	allAuditObjects : CM_AuditObjectDictByTimestamp;
	stateData : Any;

begin

	process.isNDLAudits;

	stateData := self.getExtraData("allAuditObjects");
	if stateData = null then
		create allAuditObjects persistent;
		self.setExtraData("allAuditObjects", allAuditObjects );
	else
		allAuditObjects := stateData.CM_AuditObjectDictByTimestamp;
	endif;

	create audit persistent;
	audit.setFromLocationActivityTemp( self, allAuditObjects );
	

epilog

end;</source>
    </JadeMethod>
