//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 15 July 2003
//
//----------------------------------------------------------

vars

begin
	inheritMethod(_passport);

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="61bc676f-dbd2-4dd4-b29d-a9abb566f8a2">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 14 July 2003
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//----------------------------------------------------------

vars
	tmpDelay	:	HMS_Delay;
	
begin
	inheritMethod(_passport);
	
	if self.code = null then
	//	app.raiseCMException1( REQUIRED_FIELD, 'Code', ETRow_Code, null );
		app.raiseCMException( Input_required_field_code, ETRow_Code, null ); // cnwdb2	PAR 35364


	endif;
	
	if self.description = null then
	//	app.raiseCMException1( REQUIRED_FIELD, 'Description', ETRow_Description, null );
		app.raiseCMException( Input_required_field_desc, ETRow_Description, null ); // cnwdb2	PAR 35364
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	
	tmpDelay := self.myRoot.allHMSDelays.getAtKey(self.code);
	if tmpDelay &lt;&gt; null then
		if self.isTransient and tmpDelay &lt;&gt; self.pxyGetRealObject() then
			//app.raiseCMException2(DuplicateItem, 'Delay', self.code, ETRow_Code, null); //14.06.2022 navds20 53760
			// Delay already exists for %1 : Delay_already_exists
			app.raiseCMException1(Delay_already_exists, self.code, ETRow_Code, null); //14.06.2022 navds20 53760
		endif;
	endif;

epilog


end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
