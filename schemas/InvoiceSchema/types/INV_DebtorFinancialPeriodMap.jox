    <JadeMethod name="initQueryFrameDebtor" id="0dfa7061-c9c6-46a0-abf2-33c5437566ec">
        <updating/>
        <source>initQueryFrameDebtor() updating, protected;

vars
	sht			: CMUI_Sheet;
begin
	
	sht := self.shtQuery1;
	sht.caption := "Period Mappings";
	
	// 35872 get business unit from user if more than one
	if self.cmbBank.listCount &gt; 1 then
		self.setQueryControl(self.cmbBank);
		self.setQueryControl(self.cmbDebtor);
		self.cmbBank.setFocus();
	else
		self.cmbBank.visible := false;
		self.lblCompany.visible := false;
		self.lblDebtorQ.top := self.lblCompany.top;
		self.cmbDebtor.top := self.cmbBank.top;
		self.setQueryControl(self.cmbDebtor);
		self.cmbDebtor.setFocus();
	endif;

	sht.visible := true;

end;</source>
        <access>protected</access>
