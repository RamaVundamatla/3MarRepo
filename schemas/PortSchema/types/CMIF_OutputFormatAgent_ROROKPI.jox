    <JadeMethod name="setup_DecksTable" id="16af3d40-8377-498e-a8e8-e1d9bf68be7a">
        <source>setup_DecksTable()protected;
/*
Date		Who		Reason
08 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	dd :DynaDictionary;
begin
	// keep track of all work points/decks to display in the table
	// we will use this to display column headings
	dd := self.allColumnHeadings;
	
	if dd.isValid then
		dd.clear;
		dd.clearKeys;
	endif;
	
	dd.setMembership (CM_KPIVoyageDeckWorkPoint);
	
	dd.addExternalKey (String, 100, false, true);	// work point
	dd.addExternalKey (String, 20, false, true);	// deck
	
	dd.endKeys (false);
	
	// now the collection to keep track of container KPI
	dd := self.allData_Containers;
	
	if dd.isValid then
		dd.purge;
		dd.clearKeys;
	endif;
	
	dd.setMembership (ObjectArray);	// will be array discharge/load/dlr/sob/ts
	
	dd.addExternalKey (Integer, null, false, true);						// Length
	dd.addExternalKey (String, 100, false, true);						// work point
	dd.addExternalKey (String, 20, false, true);						// deck
	dd.addExternalKey (CM_KPIVoyageDeckWorkPoint, null, false, true);	// just so we have a reference to this because it is stored as item object in the table
	
	dd.endKeys (false);
	
	// now the collection to keep track of general cargo KPI
	dd := self.allData_GeneralCargo;
	
	if dd.isValid then
		dd.purge;
		dd.clearKeys;
	endif;
	
	dd.setMembership (ObjectArray);	// will be array containing discharge/load/dlr/sob/ts
	
	dd.addExternalKey (CM_CargoType, null, false, true);				// Cargo type
	dd.addExternalKey (String, 100, false, true);						// work point
	dd.addExternalKey (String, 20, false, true);						// deck
	dd.addExternalKey (CM_KPIVoyageDeckWorkPoint, null, false, true);	// just so we have a reference to this because it is stored as item object in the table

	dd.endKeys (false);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setup_ROROMovesTable" id="c224be12-8957-4d87-a49c-f90d23b13ff2">
        <source>setup_ROROMovesTable()protected;
/*
Date		Who		Reason
08 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	dd :DynaDictionary;
begin
	// keep track of all shifts/work points to display in the table
	// we will use this to display column headings
	dd := self.allColumnHeadings;
	
	if dd.isValid then
		dd.clear;
		dd.clearKeys;
	endif;
	
	dd.setMembership (CM_KPIVoyageWorkPointShift);
	
	dd.addExternalKey (TimeStamp, null, false, null);		// shift start date/time
	dd.addExternalKey (String, 100, false, true);			// work point
	
	dd.endKeys (false);
	
	// now the collection to keep track of container KPI
	dd := self.allData_Containers;
	
	if dd.isValid then
		dd.purge;
		dd.clearKeys;
	endif;
	
	dd.setMembership (ObjectArray);	// will be array containing discharge/load/DLR/SOB/tranship
	
	dd.addExternalKey (Integer, null, false, true);						// Length
	dd.addExternalKey (TimeStamp, null, false, null);					// shift start date/time
	dd.addExternalKey (String, 100, false, true);						// work point
	dd.addExternalKey (CM_KPIVoyageWorkPointShift, null, false, true);	// just so we have a reference to this because it is stored as item object in the table
	
	dd.endKeys (false);
	
	// now the collection to keep track of general cargo KPI
	dd := self.allData_GeneralCargo;
	
	if dd.isValid then
		dd.purge;
		dd.clearKeys;
	endif;
	
	dd.setMembership (ObjectArray);	// will be array containing discharge/load/DLR/SOB/tranship
	
	dd.addExternalKey (CM_CargoType, null, false, true);				// Cargo type
	dd.addExternalKey (TimeStamp, null, false, null);					// shift start date/time
	dd.addExternalKey (String, 100, false, true);						// work point
	dd.addExternalKey (CM_KPIVoyageWorkPointShift, null, false, true);	// just so we have a reference to this because it is stored as item object in the table

	dd.endKeys (false);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tableHasTrackedItems" id="990b7828-f4cf-41b7-880d-35e01ecec82f">
        <source>tableHasTrackedItems(_table :Table input; _row, _col :Integer):Boolean;
/*
Date		Who		Reason
17 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	obj, first	:Object;
	result	:Boolean;
begin
	if _table &lt;&gt; self.myTable then
		// can't change table
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Cannot change KPI table');
	endif;
	
	obj := _table.accessCell (_row, _col).itemObject;
	
	if obj &lt;&gt; null and  obj.isKindOf (CM_KPIVoyageEntity) then
		if not obj.CM_KPIVoyageEntity.allTrackedItems.isEmpty then
			result := true;
		endif;
		
	elseif obj &lt;&gt; null and obj.isKindOf (Collection) and not obj.Collection.isEmpty then
		first := obj.Collection.first.Object;
		
		if first.isKindOf (CM_TrackedItem) or
			first.isKindOf (CM_Request) then
			result := true;
		elseif first.isKindOf (CM_KPIVoyageMoveDtl) then
			result := true;
		endif;
	endif;
	
	return result;
epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateCellCollection" id="c04cc9f5-3624-4fc4-9d54-47b5710a6552">
        <source>updateCellCollection(_table :Table input; _coll :Collection)protected;
/*
Date		Who		Reason
01 September 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	obj		:Object;
	coll	:Collection;
begin
	if _coll = null or _coll.size = 0 then 
		return;
	endif;
	
	obj := _table.accessedCell.itemObject;
	
	if obj = null then
		create coll as CM_KPIVoyageMoveDtlDict transient;
		
		_table.accessedCell.itemObject := coll;
		
		self.allObjectsToGarbageCollect.add (coll);
		
	elseif obj.isKindOf (CM_KPIVoyageMoveDtlDict) then
		coll := obj.CM_KPIVoyageMoveDtlDict;
	endif;

	if coll = null then
		// should not happen :-)
		return;
	endif;
	
	_coll.copy (coll);	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_coll" type="Collection"/>
    </JadeMethod>
</Class>
