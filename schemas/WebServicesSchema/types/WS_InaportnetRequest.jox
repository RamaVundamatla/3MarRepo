    <JadeMethod name="getOperator" id="c04fd747-987c-4d40-bc31-faf089fcc567">
        <source>getOperator( _rawValue : String ):CM_Operator;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2018	jlgndl1	Initial creation	TFS 38135
	Look up the operator using the value passed in, if doesn't match one try again using
	the EDI Translations.

*/

vars

	operator : CM_Operator;
	translatedCode : String;
	found : Boolean;

begin

	operator := app.myRoot.allOperators[ _rawValue ];
		
	if operator = null then
		translatedCode := app.myRoot.getXlationSystemCode( _rawValue, XLATION_TYPE_OPERATOR, found );
		if found then
			operator := app.myRoot.allOperators[ translatedCode ];
		endif;
	endif;
	
	return operator;

epilog

end;</source>
        <Parameter name="_rawValue" type="String"/>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
