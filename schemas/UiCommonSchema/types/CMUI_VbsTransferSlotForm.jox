    <JadeMethod name="doOK" id="feb1636d-7eb5-43c9-b767-3a8501326291">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Sep 2022	navak20	ChangeRequest 54048: EUP - VBS MTN - [8] - Transfer Slots
25 Aug 2023 navhl20 ChangeRequest 60058: FR | 53429 - VBS Slot transfer - Multiple Slot types
*/

vars
	vbsTimeSlot,
	pxyObject		: CM_VehicleBookingTimeSlot;
	newStartTS, 
	newEndTS 	: TimeStamp;
	remarks 	: String;
	result 		: Integer;
begin
	if self.validateTransferSlotTime() then
		newStartTS.setDate(self.txtStartDate.getDate());
		//newStartTS.setTime(self.txtStartTime.getTime());
	
		newEndTS.setDate(self.txtEndDate.getDate());
		//newEndTS.setTime(self.txtEndTime.getTime());
		
		remarks := self.txtRemarks.text;
		foreach vbsTimeSlot in self.allSelectedObject do
			pxyObject := app.createUpdateProxy(vbsTimeSlot).CM_VehicleBookingTimeSlot;
			newStartTS.setTime(vbsTimeSlot.bookingTSstart.Time);								//25.8.2023 navhl20 #60058
			newEndTS.setTime(vbsTimeSlot.bookingTSend.Time);									//25.8.2023 navhl20 #60058
			while true do
				app.myTrxUA.trxUpdateVbsTransferSlot(pxyObject, newStartTS, newEndTS, remarks, app.myPassport);
				if app.myPassport.trxCompletedOK then
					self.unloadForm;
					break;
				else
					result :=	app.showErrorWarningDialog(app.getErrorString(Transfer_slots), app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and
					   result = IDOK then
						// there must have just been warnings that the user has acknoledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				break;
			endwhile;
			delete pxyObject;
		endforeach;
	endif;
	self.modalResult := IDOK;
epilog
	delete pxyObject;
end;</source>
    </JadeMethod>
    <JadeMethod name="initStartEndTS" id="f1476cd6-bff5-4601-8ef4-c57144a3392d">
        <source>initStartEndTS();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Jan 2023	navak20 Task 55835: EUP - VBS MTN - [8] - Transfer Slots - Validate Transferring slots to future
25 Aug 2023 navhl20 ChangeRequest 60058: FR | 53429 - VBS Slot transfer - Multiple Slot types
*/

vars
	vbsObj	: CM_VehicleBookingTimeSlot;
begin
	vbsObj := self.allSelectedObject.first;
	self.txtStartDate.setDate(vbsObj.bookingTSstart.date);
	//self.txtStartTime.setTime(vbsObj.bookingTSstart.time);			//25.8.2023 navhl20 #60058
	self.txtEndDate.setDate(vbsObj.bookingTSend.date);
	//self.txtEndTime.setTime(vbsObj.bookingTSend.time);				//25.8.2023 navhl20 #60058
	
	self.txtEndDate.enabled := false;
	//self.txtEndTime.enabled := false;									//25.8.2023 navhl20 #60058
	//self.txtStartTime.enabled := false;								//25.8.2023 navhl20 #60058
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblTransferSlot" id="a04fa4d9-4195-4dd2-8280-2d2cd94ee5a6">
        <source>initTblTransferSlot(_theEntDef : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Sep 2022	navak20	ChangeRequest 54048: EUP - VBS MTN - [8] - Transfer Slots

*/

vars
	theTable		: CM_DataTable;
	entTableDef		: EntTableDef;
begin
	theTable := self.tblTransferSlot;
	theTable.allSelectedObjects.clear;
	
	if _theEntDef &lt;&gt; null then
		theTable.userInputEnabled := false;
		theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
		theTable.selectionType := CM_EntryTable.SelectionType_Row;
		theTable.rows := theTable.fixedRows;		
		entTableDef := app.myController.getEntTableDef(_theEntDef);
		theTable.setTblDataEntRowsFromDef(entTableDef);
		theTable.setMyDataClass(CM_VehicleBookingTimeSlot);
		theTable.readOnly := false;	
		theTable.fixedColumns := 0;
		theTable.fixedRows := 1;
		self.setColorsForTable(self.tblTransferSlot);
	else
		theTable.rows := 1;	
	endif;
end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="setCollection" id="2256772b-e2b3-48c7-9e86-e8e1274521ce">
        <source>setCollection(_vbsObjSelected : ObjectArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Sep 2022	navak20 ChangeRequest 54048: EUP - VBS MTN - [8] - Transfer Slots

*/

vars

begin
	_vbsObjSelected.copy(self.allSelectedObject);
epilog

end;</source>
        <Parameter name="_vbsObjSelected" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="75629004-69f5-4ad3-b43b-71d152a3c828">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Sep 2022	navak20 ChangeRequest 54048: EUP - VBS MTN - [8] - Transfer Slots
23 Jan 2023	navak20 Task 55835: EUP - VBS MTN - [8] - Transfer Slots - Validate Transferring slots to future
*/

vars

begin
	inheritMethod();
	self.handleMenusForModalDisplay();
	self.initTblTransferSlot(ETDef_VehicleSlotDisplay);
	self.tblDataDisplayRow();
	self.initStartEndTS();		// 23.01.2023 navak20 TFS 55835
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblDataDisplayRow" id="9b7e3f5b-e146-4f0d-941d-600986c7270f">
        <source>tblDataDisplayRow();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Sep 2022	navak20	ChangeRequest 54048: EUP - VBS MTN - [8] - Transfer Slots

*/

vars
	tbl					: CM_DataTable;
	vbsTimeSlot			: CM_VehicleBookingTimeSlot;
	idx					: Integer;
	str 				: String;
begin

	tbl := self.tblTransferSlot;
	tbl.rows := tbl.fixedRows;
	
	foreach vbsTimeSlot in self.allSelectedObject do
		str := vbsTimeSlot.getAttributeStringForDefArray(tbl.allTblDataEntRows);
		idx := tbl.addItem(str);
		tbl.accessRow(idx).itemObject := vbsTimeSlot;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d1d50b23-e043-4cdd-a2b4-014f45a1df20">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 16 February 2023 14:12:38.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025581, locale);
	lblEndDT.translateCaption(Xlat_0025582, locale);
	lblRemarks.translateCaption(Xlat_0025583, locale);
	lblStartDT.translateCaption(Xlat_0025584, locale);
end;</source>
    </JadeMethod>
