    <JadeMethod name="getDisplayStringForAttribute" id="32bd4066-51a5-487d-abe5-7ed9de5a28f1">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	if _attrName = ETRow_Type then
		return app.getErrorString(Section);
		
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
