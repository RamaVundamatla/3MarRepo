end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="2e5efc1e-742d-4039-92eb-acdf3dbb28ee">
        <updating/>
        <source>setProxy(_code:String; _name:String;  _isNotAvailableForEntry : Boolean; _d : CM_Debtor) updating;
// ---------------------------------------------------------------------------
// Created:		February 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.code := _code;
	self.name := _name[1:70]; //epr par 35304 2/12/14
	self.isNotAvailableForEntry := _isNotAvailableForEntry;
	self.myRoot := app.myRoot;
	self.myDebtor := _d;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_d" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="53552c22-e843-42f0-aed8-56927025f0d7">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		February 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin	
	if app.myRoot.allCustomsAgents[self.code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code.String, null, null);
	endif;

	self.validateMe();
end;</source>
    </JadeMethod>
