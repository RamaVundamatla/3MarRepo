    <JadeMethod name="setControlsForAddEdit" id="e4d5c842-ba56-49e9-8ccc-02e831a6cbee">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI
02 November 2023	navmd1	TFS 61072 Fix clearing password on edit after we've masked it

*/

constants
	DEFAULT_RETRIES : Integer = 5;
	
vars
	theForm		: SOP_TableMaintForm;
	tblInput	: CM_EntryTable;
	infoRow		: Integer;
	
	eventTypes : CM_EventTypeSet;	//07 Jul 2020	NDL	TFS 49590
	transTypes : CM_TransactionTypeSet;	//07 Jul 2020	NDL	TFS 49590
	hmsTypes : CM_TransactionTypeSet;	//14 Jul 2020	NDL	TFS 49747
	
begin
	
	theForm := self.myForm;
	tblInput := theForm.tblInput1;
	
	tblInput.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := true;
	theForm.mulSelect2.userInputEnabled := true;
	theForm.mulSelect3.userInputEnabled := true;
	theForm.mulSelect6.userInputEnabled := true;	//14 Jul 2020	NDL	TFS 49747
	
	theForm.chkAnyTriggField.visible := false;
	
	if theForm.btnReplay.visible then
		theForm.btnReplay.enabled := false;
	endif;
	
	if theForm.mode = theForm.Mode_Add then
		tblInput.clearValues;
		theForm.tblInput1.setValueByName(ETRow_NumberOfRetries, DEFAULT_RETRIES);
		
		// info row is read only, so don't realy need to show it during an add
		infoRow := theForm.tblInput1.getRow(ETRow_Info);
		theForm.tblInput1.hideRow(infoRow);
		theForm.tblInput1.fitTableHeight();
		// need to add a couple of pixels to the height to account for the border on the table
		theForm.tblInput1.height := theForm.tblInput1.height+2;
		
		theForm.mulSelect1.setSelected(null);
		theForm.mulSelect2.setSelected(null);
		theForm.mulSelect3.setSelected(null);
		theForm.mulSelect6.setSelected(null);		//14 Jul 2020	NDL	TFS 49747
	else
	
		//07 Jul 2020	NDL	TFS 49590
		create eventTypes transient;
		theForm.myCurrentObject.CM_EventStreamDefinition.getSelectedEventTypes( eventTypes );
		create transTypes transient;
		theForm.myCurrentObject.CM_EventStreamDefinition.getSelectedTransTypes( transTypes );
		create hmsTypes transient;
		theForm.myCurrentObject.CM_EventStreamDefinition.getSelectedHmsTypes( hmsTypes );
		
		theForm.mulSelect1.setSelected( eventTypes );	//07 Jul 2020	NDL	TFS 49590
		theForm.mulSelect2.setSelected( transTypes );	//07 Jul 2020	NDL	TFS 49590
		theForm.mulSelect3.setSelectedDisplayStringMatch(theForm.myCurrentObject.CM_EventStreamDefinition.allEventStreamEventTypes);
		theForm.mulSelect6.setSelected( hmsTypes );		//14 Jul 2020	NDL	TFS 49747  24 Nov 2020	- TFS 50403 correct typo
		
		theForm.setEnteredPassword(theForm.myCurrentObject.CM_EventStreamDefinition.authToken);
	endif;
	
epilog

	delete eventTypes;	//07 Jul 2020	NDL	TFS 49590
	delete transTypes;	//07 Jul 2020	NDL	TFS 49590

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="b15f72f8-8c2b-4590-9dda-3f529e232b92">
        <updating/>
        <source>setCtrlsForView() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars
	theForm : SOP_TableMaintForm;
	
begin
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.cmbSecurityRole.enabled := false;
	theForm.cmbCargoBOLType.enabled := false;
	
	if theForm.btnReplay.visible then
		theForm.btnReplay.enabled := true;
	endif;
	
	theForm.chkAnyTriggField.visible := false;
	
	inheritMethod();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="5b78d97c-0e54-478a-9bf5-6096d2a86476">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars
	theForm			: SOP_TableMaintForm;
	tmpMenu			: MenuItem;
begin
	inheritMethod(conwin);

	theForm := self.myForm;
	if theForm.mode = SOP_TableMaintForm.Mode_View then
		return;
	endif;
	
	
	theForm.mnuContext1.visible	:= true;
	theForm.mnuContext1.caption	:= app.getErrorString( Generate_auth_token );
	tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext1, false );

epilog

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="251b7a84-710f-464e-a2ca-04a80bc1f061">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars
	theForm 		: SOP_TableMaintForm;
	transactions	: CM_TransactionTypeSet;
	hmsTransTypes	: CM_TransactionTypeSet;	//14 Jul 2020	NDL	TFS 49747
	txnType			: CM_TransactionType;
	auditTypes		: IntegerArray;
	auditType		: Integer;
	auditConfig		: CM_AuditConfig;
	auditCol		: CM_ObjectArray;

begin
	theForm := self.myForm;
	theForm.setTblDataEntRows(ETDef_EventStreamTbl);

	self.myForm.shtTblInput1.caption := 'Details';
	self.myForm.initTblInput(self.myForm.tblInput1, ETDef_EventStreamDef);	
	self.myForm.shtTblInput1.visible := true;

	// setup events multi select
	self.setupMultiSelect1(app.getErrorString(Events), app.myRoot.allEventTypesByType, SOP_TableMaintForm::displayEntryEventStreamEvent.name); 
	
	// setup transactions multi select
	create transactions transient;
	create hmsTransTypes transient;
	app.myRoot.allTransactionTypesByDesc.copy(transactions);
	foreach txnType in transactions where txnType.trxGroup &lt;&gt; TRANS_TYPE_GROUP_TI do
		transactions.remove(txnType);
		if txnType.trxGroup = TRANS_TYPE_GROUP_HMS then	 //14 Jul 2020	NDL	TFS 49747
			hmsTransTypes.add( txnType );
		endif;
	endforeach;
	
	self.setupMultiSelect2(app.getErrorString(Transactions), transactions, SOP_TableMaintForm::displayEntryEventStreamEvent.name);
	
	// setup audits multi select
	self.initAuditTypes();
	self.setupMultiSelect3(app.getErrorString(Audits), self.allAuditTypes, SOP_TableMaintForm::displayEntryEventStreamEvent.name);
	
	self.setupMultiSelect6(app.getErrorString(HMS_Transactions), hmsTransTypes, SOP_TableMaintForm::displayEntryEventStreamEvent.name);	 //14 Jul 2020	NDL	TFS 49747
	
epilog
	delete transactions;
	delete auditCol;
	delete auditTypes;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="459013ee-5184-4a70-a06d-6778038307b2">
        <updating/>
        <source>showThumbnail(pDef: CM_EventStreamDefinition) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars
	theForm 		: SOP_TableMaintForm;
	infoCell		: JadeTableCell;
	rowIdx			: Integer;
	tmpHeight		: Integer;
	
	eventTypes : CM_EventTypeSet;	//07 Jul 2020	NDL	TFS 49590
	transTypes : CM_TransactionTypeSet;	//07 Jul 2020	NDL	TFS 49590
	hmsTypes : CM_TransactionTypeSet;	//14 Jul 2020	NDL	TFS 49747
	
begin

	theForm := self.myForm;
	theForm.tblInput1.clearValues;
	
	theForm.tblInput1.setValueByName(ETRow_Name, pDef.name);
	theForm.tblInput1.setValueByName(ETRow_Target, pDef.targetURL);
	theForm.tblInput1.setValueByName(ETRow_IsActive, pDef.isActive);
	theForm.tblInput1.setValueByName(ETRow_NumberOfRetries, pDef.numRetries);
	theForm.tblInput1.setValueByName(ETRow_EmailAddress, pDef.email);
//	theForm.tblInput1.setValueByName(ETRow_Password, pDef.authToken);
	
	//25 Aug 2021	NDL	TFS 51632
	theForm.tblInput1.setValueByName(ETRow_Password, " ");
	theForm.setEnteredPassword(null);
	if pDef.authToken &lt;&gt; null then
		theForm.setEnteredPassword(pDef.authToken);
		theForm.tblInput1.setValueByName(ETRow_Password, '******');
	endif;
	
	rowIdx := theForm.tblInput1.getRow(ETRow_Target);
	theForm.tblInput1.accessCell(rowIdx,CM_EntryTable.ColumnValue).wordWrap := true;
	
	rowIdx := theForm.tblInput1.getRow(ETRow_Info);
	if pDef.disabledTS &lt;&gt; null then
		theForm.tblInput1.setValueByName(ETRow_Info, app.getErrorString(System_disabled) &amp; " " &amp; pDef.disabledTS.date.shortFormatJMT() &amp; ' ' &amp; pDef.disabledTS.time.shortFormatJMT);
		infoCell := theForm.tblInput1.accessCell(rowIdx,CM_EntryTable.ColumnValue);
		// highlight row
		infoCell.backColor := Red;
		infoCell.foreColor := White;
		infoCell.wordWrap := true;
		theForm.tblInput1.showRow(rowIdx);
	else
		// if disabled timestamp has not been set then hide this row
		theForm.tblInput1.hideRow(rowIdx);
	endif;
	
	//07 Jul 2020	NDL	TFS 49590
	create eventTypes transient;
	pDef.getSelectedEventTypes( eventTypes );
	create transTypes transient;
	pDef.getSelectedTransTypes( transTypes );
	//14 Jul 2020	NDL	TFS 49747
	create hmsTypes transient;
	pDef.getSelectedTransTypes( hmsTypes );

	theForm.mulSelect1.setSorted(true);
	//theForm.mulSelect1.setSelectedStringOrObject(pDef.allEventStreamEventTypes);
	theForm.mulSelect1.setSelected( eventTypes );	//07 Jul 2020	NDL	TFS 49590
	self.disableMulSelect1Contents();
	
	theForm.mulSelect2.setSorted(true);
	//theForm.mulSelect2.setSelectedStringOrObject(pDef.allEventStreamEventTypes);
	theForm.mulSelect2.setSelected( transTypes );	//07 Jul 2020	NDL	TFS 49590
	self.disableMulSelect2Contents();
	
	theForm.mulSelect3.setSorted(true);
	theForm.mulSelect3.setSelectedDisplayStringMatch(pDef.allEventStreamEventTypes);
	self.disableMulSelect2Contents();
	
	//14 Jul 2020	NDL	TFS 49747
	theForm.mulSelect6.setSorted(true);
	theForm.mulSelect6.setSelectedDisplayStringMatch(pDef.allEventStreamEventTypes);
	
	// TargetURL column has maximum text length. If it trys to display the whole string
	// and it is larger than the width of the table, it can be impossible (or just difficult)
	// to resize it manually. Set size to a reasonable width to prevent this
	theForm.tblData.accessColumn(2).width := ( theForm.tblData.width/3).Integer;
	
epilog

	delete eventTypes;	//07 Jul 2020	NDL	TFS 49590
	delete transTypes;	//07 Jul 2020	NDL	TFS 49590
	delete hmsTypes;	//14 Jul 2020	NDL	TFS 49747

end;</source>
        <Parameter name="pDef" type="CM_EventStreamDefinition"/>
    </JadeMethod>
</Class>
