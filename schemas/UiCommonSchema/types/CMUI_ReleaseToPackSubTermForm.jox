    <JadeMethod name="translateForm" id="c2ad2979-0aaf-407f-b401-c348afb67d90">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0010906, locale);
	btnCancel.translateCaption(Xlat_0014593, locale);
	btnOK.translateCaption(Xlat_0014594, locale);
	chkRelease.translateCaption(Xlat_0010909, locale);
	chkUpdateVoyDet.translateCaption(Xlat_0010910, locale);
	lAssignTo.translateCaption(Xlat_0010911, locale);
	lBookingRef.translateCaption(Xlat_0014595, locale);
	lBookingRefDet.translateCaption(Xlat_0014596, locale);
	lDestination.translateCaption(Xlat_0010914, locale);
	lDischarge.translateCaption(Xlat_0010915, locale);
	lPackingItem.translateCaption(Xlat_0010916, locale);
	lPackingReq.translateCaption(Xlat_0010917, locale);
	lReleaseItem.translateCaption(Xlat_0010918, locale);
	lReleaseNo.translateCaption(Xlat_0010919, locale);
	lUpdateIDtobe.translateCaption(Xlat_0010920, locale);
	lVoyage.translateCaption(Xlat_0010921, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateTI" id="3ef6fba2-6cd6-46d6-bb0f-98037b7210d3">
        <source>updateTI();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2009	cnwrd1	Initial creation

*/

/*If the user clicks "Save" and the "Release" checkbox is ticked, 
1.	The cargo will be released on the Road Release, and the "Delivery Release" field will be updated with the Road Release number.
If the cargo is already assigned to the Road Release, then continue with the release.
If the cargo is already assigned to a different Road Release, remove it from that release.
	Validation:
		·	If the cargo does not match the Release Request item then display a Warning.
		·	If the cargo does not match the Booking Item, then display a Warning.
		
2.	The cargo will be attached to the Export Booking, and the "Booking Reference" field will be updated with the Export Booking Reference. 
	If the cargo is already attached to a booking it will be removed from that booking.
	
3.	The cargo will be assigned to a matching Packing Request Parent.
	If the cargo is already assigned to the Packing Request, nothing is updated.
	Validation:
		·	If the container does not match a Packing  Request Parent then display a Warning.
		
4.	If the checkbox is ticked, the cargo will be updated with voyage details from the export booking. This will include the Voyage, Discharge Port, Destination ???
5.	If the Voyage of the Release, Booking and Packign Request do not match display a Warning message.
6.	A CAMS message will be generated for the Shipper with Road Release number and cargo.
*/
vars
	booking				: CM_BookingRef;
	release,
	packing				: CM_BulkRelease;
	bookingRefItem 		: CM_BookingRefItem;	
	packingItem,
	releaseItem			: CM_ReserveSelection;	
	theTI				: CM_Container;
	
begin
	booking := self.cmbBookingRef.listObject.CM_BookingRef;
	packing := self.cmbPackingReq.listObject.CM_BulkRelease;
	release := self.cmbReleaseNumber.listObject.CM_BulkRelease;
	
	bookingRefItem := self.cmbBookingRefDet.listObject.CM_BookingRefItem;
	packingItem := self.cmbPackingItem.listObject.CM_ReserveSelection;
	releaseItem := self.cmbReleaseItem.listObject.CM_ReserveSelection;
	
	theTI := self.myCurrentTrackedItem.CM_Container;
	
//1
// if we have a selected release (road)
// update delivery release field
// if we are assigned to release continue with release
// if we are assigned to a different road release remove from that release

	if  release &lt;&gt; null then
		self.myTIUpdateInfo.myRoadRelease := release;
		self.myTIUpdateInfo.myReleaseItem := releaseItem;
	endif;

//2
//if we have a booking
//if already attached to a booking remove from that booking
// attach to the booking
// update booking reference
	
	if booking &lt;&gt; null then
		self.myTIUpdateInfo.myBookingReference := booking;
		self.myTIUpdateInfo.myBookingRefItem := bookingRefItem;
	endif;

//3
//if already assigned to a packing request do nothing
//else assign to packing request if we have one

	if packing &lt;&gt; null then
		self.myTIUpdateInfo.myPackingRelease := packing;
		self.myTIUpdateInfo.myPackingItem := packingItem;
	endif;
	
//4 
// if update voyage checkbox
// update cargo with export booking voyage details
	if self.chkUpdateVoyDet.value then		
		
		if booking &lt;&gt; null then // only do the voyage details update if we have a booking
			self.myTIUpdateInfo.doUpdateVoyageDetails := true;
			self.myTIUpdateInfo.myVoyage := booking.myVoyage;			
			self.myTIUpdateInfo.destinationPort := booking.destinationPort;
			self.myTIUpdateInfo.dischargePort := booking.dischargePort;
		else
			self.myTIUpdateInfo.doUpdateVoyageDetails := false;
		endif;
		
	endif;

//5 - should be done already &amp; 6 should happen automaticaly.
end;</source>
    </JadeMethod>
    <JadeMethod name="validateAgainstBookingItem" id="459ccdd0-8c6e-44ce-b4f4-d582dc1e0238">
        <source>validateAgainstBookingItem();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2009	cnwrd1	Initial creation
19/02/2010	cnwmh5	Par22417 - add handle deleted object
10/03/2011	cnmwh5	PA#27142 - Change where handleDeleteObject is armed
*/

vars


	obj 			: Object;
	reserveDet 		: CM_ReserveSelection;	
	reserveISOCode	: String;
	bookingRefItem 		: CM_BookingRefItem;
	invalidObject	: Boolean;
begin
	
	bookingRefItem := self.cmbBookingRefDet.listObject.CM_BookingRefItem;
	
	if bookingRefItem = null then
		//raise warning no release item selected
		app.raiseCMException(No_booking_item_selected, null, null);
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, bookingRefItem, invalidObject);
		
	if self.myCurrentTrackedItem.CM_Container.isoType &lt;&gt; bookingRefItem.isoType then
		// warn wrong ISO type 
		//Track_item_ISOType_mismatch
		app.raiseCMWarning4(Track_item_ISOType_mismatch, self.myCurrentTrackedItem.id, self.myCurrentTrackedItem.CM_Container.isoType, "Booking Ref Detail's", bookingRefItem.isoType, null, null, null);
	endif;	

		

epilog
	if invalidObject then
		app.raiseCMException2(PACK_SUB_TERM_DEL_OBJ, "Booking Item", self.cmbBookingRefDet.text, null, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateAgainstPackingItem" id="c8f4b821-0151-40dc-a743-67abf4f5ea08">
        <source>validateAgainstPackingItem();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2009	cnwrd1	Initial creation
19/02/2010	cnwmh5	PAR22417 - add handle delete object
10/03/2011	chwmh5	PAR #27142 - change where handleDeletedObject is armed
*/

vars


	obj 			: Object;
	reserveDet 		: CM_ReserveSelection;	
	reserveISOCode	: String;
	invalidObject	: Boolean;
begin
	
	obj := self.cmbPackingItem.listObject;
	
	if obj = null then
		//raise warning no release item selected
		app.raiseCMException(No_packing_item, null, null);
		return;
	endif;
	
	if obj.isKindOf(CM_ReserveSelection) then
		on Exception do app.handleDeletedObject(exception, reserveDet, invalidObject);
		reserveDet := obj.CM_ReserveSelection;
		
		if reserveDet.myISOType &lt;&gt; null then
			reserveISOCode := reserveDet.myISOType.code;
		else
			reserveISOCode := null;
		endif;
		
		if self.myCurrentTrackedItem.CM_Container.isoType &lt;&gt; reserveISOCode then
			// warn wrong ISO type
			app.raiseCMWarning4(Track_item_ISOType_mismatch, self.myCurrentTrackedItem.id, self.myCurrentTrackedItem.CM_Container.isoType, "Packing Item's", reserveISOCode, null, null, null);
		endif;	
		
	else
	
	// raise warning no valid release item
	endif;
	
epilog
	if invalidObject then
		app.raiseCMException2(PACK_SUB_TERM_DEL_OBJ, "Packing Item", self.cmbPackingItem.text, null, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateAgainstReleaseItem" id="62c52c7c-bd87-42d9-b69d-e16cff4c1d8b">
        <source>validateAgainstReleaseItem();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2009	cnwrd1	Initial creation
19/02/2010	cnwmh5	PAR22417 - Add handle deleted object
10/03/2011	cnwmh5	PAR #27142 - Change where handleDeletedObject is armed
*/

vars

	obj 			: Object;
	reserveDet 		: CM_ReserveSelection;	
	reserveISOCode	: String;
	invalidObject	: Boolean;		// 19/02/2010 cnwmh5 #22417
begin
	
	obj := self.cmbReleaseItem.listObject;
	
	if obj = null then
		//raise warning no release item selected
		
		app.raiseCMException(No_release_item_selected, null, null);
		return;
	endif;
	
	if obj.isKindOf(CM_ReserveSelection) then
	
		on Exception do app.handleDeletedObject(exception, reserveDet, invalidObject);
		reserveDet := obj.CM_ReserveSelection;
		
		reserveDet.testCandidateTI(self.myCurrentTrackedItem); //cnwrd1 par 20037
		
	/*	
		if reserveDet.myISOType &lt;&gt; null then
			reserveISOCode := reserveDet.myISOType.code;
		else
			reserveISOCode := null;
		endif;
		
		if self.myCurrentTrackedItem.CM_Container.isoType &lt;&gt; reserveISOCode then
			// warn wrong ISO type
			app.raiseCMWarning4(Track_item_ISOType_mismatch, self.myCurrentTrackedItem.id, self.myCurrentTrackedItem.CM_Container.isoType, "Release Item's", reserveISOCode, null, null, null);
		endif;	
		*/
	else
		// raise warning no valid release item(??) -- 
		app.raiseCMException2(ERR_IsNotValid, 'Release Item','', null,null) ;
	endif;
		
epilog
	if invalidObject then
		app.raiseCMException2(PACK_SUB_TERM_DEL_OBJ, "Reserve Detail", self.cmbReleaseItem.text, null, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateReleaseVoyage" id="801cbfd6-1984-4669-b798-e39a7d028b86">
        <source>validateReleaseVoyage();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2009	cnwrd1	Initial creation
//check voyage on release vs booking vs packing + add warning
*/

vars
	booking				: CM_BookingRef;
	release,
	packing				: CM_BulkRelease;
	releaseVoyage, 
	packingVoyage		: CM_Voyage;
	releaseVoyageCode,
	bookingVoyageCode,
 	packingVoyageCode	: String;
	voyageMissmatch		: Boolean;
begin

	voyageMissmatch := false;

	booking := self.cmbBookingRef.listObject.CM_BookingRef;
	packing := self.cmbPackingReq.listObject.CM_BulkRelease;
	release := self.cmbReleaseNumber.listObject.CM_BulkRelease;
	
	
	if booking &lt;&gt; null then
		bookingVoyageCode := booking.voyageCode;
	else
		bookingVoyageCode := null;
	endif;
	
	
	if release &lt;&gt; null then		
		releaseVoyage := release.myVoyage;	
		if releaseVoyage &lt;&gt; null then
			releaseVoyageCode := releaseVoyage.code;
		else
			releaseVoyageCode := null;
		endif;
	endif;
	
	if packing &lt;&gt; null then
		packingVoyage := packing.myVoyage;
	
		if packingVoyage &lt;&gt; null then
			packingVoyageCode := packingVoyage.code;
		else
			packingVoyageCode := null;
		endif;
	endif;
	
	if bookingVoyageCode &lt;&gt; null then
		if releaseVoyageCode &lt;&gt; null and releaseVoyageCode &lt;&gt; bookingVoyageCode then
			voyageMissmatch := true;
		endif;
		
		if packingVoyageCode &lt;&gt; null and packingVoyageCode &lt;&gt; bookingVoyageCode then
			voyageMissmatch := true;
		endif;		
	endif;
	
	
	if releaseVoyageCode &lt;&gt; null then
		if bookingVoyageCode &lt;&gt; null and bookingVoyageCode &lt;&gt; releaseVoyageCode then
			voyageMissmatch := true;
		endif;
		
		if packingVoyageCode &lt;&gt; null and packingVoyageCode &lt;&gt; releaseVoyageCode then
			voyageMissmatch := true;
		endif;		
	endif;
	
	if packingVoyageCode &lt;&gt; null then
		if bookingVoyageCode &lt;&gt; null and bookingVoyageCode &lt;&gt; packingVoyageCode then
			voyageMissmatch := true;
		endif;
		
		if releaseVoyageCode &lt;&gt; null and releaseVoyageCode &lt;&gt; packingVoyageCode then
			voyageMissmatch := true;
		endif;		
	endif;
	

	
	if voyageMissmatch then
	//raise warning - or do so individualy above..?
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateSave" id="0a9f3050-141f-4c2f-a97a-4bb9c5af8537">
        <source>validateSave() ;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2009	cnwrd1	Initial creation
19/02/2010	cnwmh5	PAR22417 - add handing of delete object
*/

/*If the user clicks "Save" and the "Release" checkbox is ticked, 
1.	The cargo will be released on the Road Release, and the "Delivery Release" field will be updated with the Road Release number.
If the cargo is already assigned to the Road Release, then continue with the release.
If the cargo is already assigned to a different Road Release, remove it from that release.
	Validation:
		·	If the cargo does not match the Release Request item then display a Warning.
		·	If the cargo does not match the Booking Item, then display a Warning.
2.	The cargo will be attached to the Export Booking, and the "Booking Reference" field will be updated with the Export Booking Reference. 
	If the cargo is already attached to a booking it will be removed from that booking.
3.	The cargo will be assigned to a matching Packing Request Parent.
	If the cargo is already assigned to the Packing Request, nothing is updated.
	Validation:
		·	If the container does not match a Packing  Request Parent then display a Warning.
4.	If the checkbox is ticked, the cargo will be updated with voyage details from the export booking. This will include the Voyage, Discharge Port, Destination ???
5.	If the Voyage of the Release, Booking and Packign Request do not match display a Warning message.
6.	A CAMS message will be generated for the Shipper with Road Release number and cargo.
*/

vars
	booking				: CM_BookingRef;
	release,
	packing				: CM_BulkRelease;
	invalidObject		: Boolean;
	deletedObjFound		: Boolean;
begin
	
	on Exception do app.handleDeletedObject(exception, booking, invalidObject);
	on Exception do app.handleDeletedObject(exception, packing, invalidObject);
	on Exception do app.handleDeletedObject(exception, release, invalidObject);
	
	booking := self.cmbBookingRef.listObject.CM_BookingRef;
	packing := self.cmbPackingReq.listObject.CM_BulkRelease;
	release := self.cmbReleaseNumber.listObject.CM_BulkRelease;
	
	//check me against my release number item + add warning
	if release &lt;&gt; null then
		release.edition;
		if invalidObject then
			app.raiseCMException2(PACK_SUB_TERM_DEL_OBJ, "Release", self.cmbReleaseNumber.text, null, null);
			invalidObject := false;
			deletedObjFound := true;
		else
			self.myCurrentTrackedItem.validateForBulkRelease(release.code);  //doesnt seem to do what I want here?
			
			if  release.myOperator &lt;&gt; self.myCurrentTrackedItem.myOperator then // manualy check the operator...
				app.raiseCMWarning2(ERR_INVALID_VALUE, 'Cargo Item ' &amp; self.myCurrentTrackedItem.id, 'Operator different to road release.', null, null, self.myCurrentTrackedItem);
			endif;
	
			self.validateAgainstReleaseItem();		
		endif;
	endif;
	
	//check me against my booking item + add warning
	if booking &lt;&gt; null then
		booking.edition;
		if invalidObject then
			app.raiseCMException2(PACK_SUB_TERM_DEL_OBJ, "Booking", self.cmbBookingRef.text, null, null);
			invalidObject := false;
			deletedObjFound := true;
		else		
			self.validateAgainstBookingItem();
		endif;
	endif;
	
	//check me against my selected packing parent = add warning
	if packing &lt;&gt; null then
		packing.edition;
		if invalidObject then
			app.raiseCMException2(PACK_SUB_TERM_DEL_OBJ, "Packing Request", self.cmbPackingReq.text, null, null);
			invalidObject := false;
			deletedObjFound := true;
		else
			self.validateAgainstPackingItem();
		endif;
	endif;

	//check voyage on release vs boking vs packing + add warning
	if not deletedObjFound then						// 19/02/2010 cnwmh5 #22417
		self.validateReleaseVoyage();
	endif;
	
//	app.raiseCMException2(ERR_TI_ALREADY_ALLOCATED, self.myCurrentTrackedItem.id ,'spam', null, null);
	//app.raiseCMWarning2(WarningDamageOverwrite,'morespam', 'Duh' , null, null, null);
				
epilog

end;</source>
    </JadeMethod>
</GUIClass>
