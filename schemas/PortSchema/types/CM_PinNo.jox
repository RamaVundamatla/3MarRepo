    <JadeMethod name="isWorkOrderPin" id="ec69b617-078b-4398-8040-9e79d63ad177">
        <source>isWorkOrderPin() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
//
vars
	item : Object;
	wo : CM_WorkOrderTI;

begin
	foreach item in self.allItems where item.isKindOf(CM_WorkOrderTI) do
		return true;
	endforeach;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeItem" id="e71daa7d-730a-4389-8353-bc74d8a6fb77">
        <updating/>
        <source>removeItem(pItem : CM_Object; _isDelete :Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     26 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------

// 26/09/2008	concms1	par 16130 - new parameter to indicate if PIN being removed due to delete
vars

begin
	exclusiveLock(self);

	if self.allItems.includes(pItem) then
		pItem.emailNotify(null, _isDelete, self);	// par 16130 was :pItem.emailNotify(null, true, self);
		self.allItems.remove(pItem);
	endif;
	
	if self.allItems.isEmpty then
		delete self;
	endif;

end;</source>
        <Parameter name="pItem" type="CM_Object"/>
        <Parameter name="_isDelete" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="replaceItem" id="be58c589-1a93-4620-976e-56091d0169f2">
        <source>replaceItem(_oldItem : CM_Object;_newItem : CM_Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2018	jlgns1	Initial creation
//3/12/2018 	JLGNS1	Bug 41555: STWR - Inbound delete process for Steinweg Huntsman does not work no more in version 8.5.1.230 (deleting cargo in Road Ops and triggering CAMS). Issue found in Rotterdam UAT
*/

vars

begin
	if _oldItem = null or _newItem = null or _oldItem = _newItem then
		return;
	endif;
	
	exclusiveLock(self);

	if self.allItems.includes(_oldItem) then
		self.allItems.remove(_oldItem);
	endif;
		
	
	if (not self.allItems.includes(_newItem)) then
		self.allItems.add(_newItem);
	endif;
	
	
epilog

end;</source>
        <Parameter name="_oldItem" type="CM_Object"/>
        <Parameter name="_newItem" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="set" id="573e84e6-24ca-4160-aa22-12127ecb2f47">
        <updating/>
        <source>set(pPinNo : String; _terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     18 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02/12/2011	cnwdap1		PAR #28766 Explicitly set status to Pin_Normal - otherwise
//							an embargoed pin that is being reused could have a status
//							of Pin_Processing and prevent the PIN being used in the gate
// ---------------------------------------------------------------------------
vars

begin

	self.pinNo		:= pPinNo;
	self.created	:= app.serverTimestampAtTrxStart;
	self.status		:= PIN_Normal;						// PAR #28766
	
	self.myTerminal := _terminal;
	
end;</source>
        <Parameter name="pPinNo" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="updateStatus" id="423a1db4-5505-4897-8842-b6317688211b">
