    <JadeMethod name="uMergeIteratorRepro" id="ef9568eb-e6f4-4b10-88fc-38edfb7a1aec">
        <source>uMergeIteratorRepro();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 October 2023		navmd1	Initial creation

*/

vars
	veh : CM_Vehicle;
	mergeIter : MergeIterator;
	terminal : CM_Terminal;
	itm : CM_InterTerminalMove;
	iter : Iterator;
	itvj : CM_InterTermVehicleJob;
begin
	terminal := self.getTerminal();
	veh := self.getVehicle("GEL639");
	if veh = null then
		veh := self.addVehicle("GEL639", CM_Carrier.firstInstance, terminal);
	endif;
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(veh);
	
	create mergeIter;
	mergeIter.addCollection(terminal.allInterTerminalMovesIn);
	mergeIter.addCollection(terminal.allInterTerminalMovesOut);
	mergeIter.startKeyGeq(null, null, veh.regNumber);
	while mergeIter.next(itm) do
		if itm.vehicleID &lt;&gt; veh.regNumber then
				continue;
			endif;
	endwhile;
	
	/*iter := app.myRoot.allInterTerminalVehicleJobs.createIterator;
	app.myRoot.allInterTerminalVehicleJobs.startKeyGeq(veh.regNumber, veh.state, iter);
	while (iter.next(itvj) and itvj.vehicleID = veh.regNumber) do
		// do nothing
	endwhile;*/
	
	//self.deleteVehicle("GEL639");
	
epilog
	delete mergeIter;
	self.assertTrue(false);
	delete iter;
	write "hw";
end;</source>
    </JadeMethod>
