        <controlMethod name="Table::dragOver"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblPrefBerth_dragOver(table: Table input; win: Window input; x: Real; y: Real; state: Integer) updating;

vars

begin
	if tblPrefBerth.dragRow&lt;&gt;lastValidRow then
		// Row has changed - move row to new position
		if tblPrefBerth.dragRow&gt;1 then
			tblPrefBerth.moveRow(lastValidRow,tblPrefBerth.dragRow);
			lastValidRow:=tblPrefBerth.dragRow;
		endif;
	endif;
end;</source>
