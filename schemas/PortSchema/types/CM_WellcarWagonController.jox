    <JadeMethod name="getSpannedToLCsNEW" id="5221a065-106f-49f7-a55b-d798e7736489">
        <source>getSpannedToLCsNEW(control: CMIF_MoveController input): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars

	units 	: Real;
	tArray 	: CM_LCArray;
	lc 		: CM_WagonController;
	count 	: Integer;

begin

	if control.myTrackedItem.getActualLength = 10 then 
		return null;				
	endif;
	
	units := self.myWagon.getLengthInUnitsForWagon(control.myTrackedItem);
	
	create tArray transient;
	lc := self.myNextController;
	if lc = null then
		return app.getErrorString1(ERR_No_Room, null);
	endif;
	
	count := 1;
	while true do
		tArray.add(lc);
		count := count + 1;
		if count &gt;= units then
			break;
		endif;	
		if lc.myNextController = null then
			break;
		endif;
		lc := lc.myNextController;
	endwhile;	
	
	control.setMyToSecondaryLocations(tArray);
	
	return null;

epilog

	delete tArray;

end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
