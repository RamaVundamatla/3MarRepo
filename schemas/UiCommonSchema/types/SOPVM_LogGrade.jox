    <JadeMethod name="setControlsForAddEdit" id="7dd5d6d8-b4c5-449d-976d-36afa2fd2ad0">
        <updating/>
        <source>setControlsForAddEdit() updating;
// -----------------------------------------------------------------------------
// Created:		19 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	
	inheritMethod();
	self.myForm.mulSelect1.readOnly := false;
	self.myForm.mulSelect2.readOnly := false;
	self.myForm.mulSelect3.readOnly := false;
	self.myForm.tblInput1.userInputEnabled := true;
	if self.myForm.mode = self.myForm.Mode_Update then
		if self.myForm.mulSelect1.isMySheetVisible then
	
			self.myForm.mulSelect1.setFocus();	
		elseif self.myForm.mulSelect2.isMySheetVisible then
			self.myForm.mulSelect2.setFocus();	
		elseif self.myForm.mulSelect3.isMySheetVisible then
			self.myForm.mulSelect3.setFocus();	
		else
			self.myForm.tblInput1.setFocus();
		endif;

	else
		self.myForm.tblInput1.setFocus();

	endif;	 
	self.myForm.tblInput1.moveFirst();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="10eea3b4-0e3d-47f9-9110-137300d8dcd4">
