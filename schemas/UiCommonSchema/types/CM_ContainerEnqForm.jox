        <source>tblFilterCellInputReady(table: Table; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2019	jlger1	Initial creation  TFS 47132

*/

vars

begin
	if table = self.tblSearch and  inputControl = self.frmArgument then
		self.lblArgue.caption:=self.tblSearch.accessedCell.text;	
	endif;

epilog

end;</source>
