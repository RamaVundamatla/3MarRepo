    <JadeMethod name="verifyIDandISO" id="8f2874d3-8c59-4838-8f79-e56ecfe9f9a0">
        <source>verifyIDandISO();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2008	cnwrd1	Initial creation

*/
vars
	isoTypeCode	: CM_ISOType;

begin
	
	isoTypeCode := app.myRoot.allISOTypes[self.isoType];	
	if isoTypeCode = null then
		app.raiseCMWarning3(ERR_INVALID_ISOTYPE, self.isoType, 'ID', self.id , 'ISO', self, self);
	endif;	
	
	if id.trimBlanks = null then
		app.raiseCMWarning2(ERR_FIELD_VALUE,id, 'container id', 'ID', self, self);
	endif;
		
			
	if not app.checkDigitContainerId(self.id) then
		app.raiseCMWarning2(ERR_CONTAINER_NO,  "Container Id", self.id, 'id', self, self);
	endif;	

epilog

end;</source>
    </JadeMethod>
