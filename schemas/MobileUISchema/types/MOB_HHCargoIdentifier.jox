	self.doResizeControls(true);
	
	self.populateTrackedItem();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="26d7064c-c2c0-4fb7-b7ff-70a639e9b9f2">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2013	cnwndl1	Initial creation	Par 31506

*/

vars

	ti : CM_TrackedItem;

begin

	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	ti := app.myMobileCargoFindAgent.myTrackedItemToProcess;
	if ti &lt;&gt; null then
		//returning from a specific search
		self.setMyTrackedItem(  app.myMobileCargoFindAgent.myTrackedItemToProcess );
	else
		// populated on one of the other maint forms
		self.setMyTrackedItem( self.getSessionAgent().mySelectedTI );
	endif;

	self.setupCmdButtons( 3, app.getErrorString(Edit), app.getErrorString(Cancel), BACK_BUTTON, null, null );

	inheritMethod();
	
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b65560a0-0d82-459a-8caf-8d9f9eb2cfe7">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 May 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019046, locale);
	lblAltId.translateCaption(Xlat_0019047, locale);
	lblCargoId.translateCaption(Xlat_0019048, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtAltId_gotFocus" id="552bb24d-28a2-4237-bf53-5cc92c2ace80">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtAltId_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2013	cnwndl1	Initial creation	Par 31506

*/

vars

begin

	if self.txtAltId.text = self.lblAltId.caption.toUpper then
		self.txtAltId.selStart := 0;
		self.txtAltId.selLength := self.lblAltId.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
