<Class name="CM_WONonOperationalToDoRequest" id="4cc3aa47-b653-4e79-ae8f-e41ff53ffb92">
    <superclass name="CM_WOToDoRequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="workorder"/>
    <ExplicitInverseRef name="allDebtors" id="4c0f54b9-7f51-411e-9ce7-788a8710f50c">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <type name="CM_DebtorSet"/>
        <access>readonly</access>
        <Inverse name="CM_Debtor::allWorkOrderRequests"/>
    </ExplicitInverseRef>
    <JadeMethod name="createWLEs" id="a1c286a0-d401-4839-b1e8-3776a85a84e6">
        <source>createWLEs();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars
	aWLE			:	CM_WONonOperationalToDoWLE;
	debtor			:	CM_Debtor;
	toDoTask		: 	CM_ToDoTask;
	iter			: 	Iterator;
begin
	iter := self.myJob.CM_WOToDoNonOperationalJob.allDebtors.createIterator();
	
	while iter.next(debtor) do
		create aWLE persistent;
		aWLE.setForCreate(self.myJob, self); 
		aWLE.setDebtor(debtor);
	endwhile;
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreateInternal" id="814aa370-7436-417a-8408-7fa3b6449839">
        <updating/>
        <source>setForCreateInternal(_myJob: CM_WOToDoTaskJob; _toDoInternalJobParam: CMIF_WorkOrderJobParams) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jan 2023 navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs (Task 54263)

*/

vars

begin
	inheritMethod(_myJob, _toDoInternalJobParam);
	
	self.myJob.CM_WOToDoNonOperationalJob.allDebtors.copy(self.allDebtors);
epilog

end;</source>
        <Parameter name="_myJob" type="CM_WOToDoTaskJob"/>
        <Parameter name="_toDoInternalJobParam" type="CMIF_WorkOrderJobParams"/>
    </JadeMethod>
</Class>
