    <JadeMethod name="initialise" id="ff63a0d6-bae3-4512-9773-d0f3115f4227">
        <updating/>
        <source>initialise(_groupCount : Integer io) updating;
vars
	imexsm : CM_ImexServiceMap;
	tmcImex : CMIF_TMCImexGroup;
	cnt : Integer;
	imx : CM_CargoStatus;
	root : CM_Root;
begin
	root := app.myRoot;
	
	self.myTMCController := self.myGroup.myTMCController;	// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
	self.hidePictures := self.myTMCController.hidePictures;
	foreach imexsm in self.myProductMap.allImExMaps do
		if imexsm.imexStatus = CM_ImexServiceMap.DEFAULT_IMEX_MAP then
			create tmcImex as CMIF_TMCImexDefault;
		else
			create tmcImex;
		endif;
		imx := root.allImexStatuses[imexsm.imexStatus];
		if imx = null then
			imx := root.allTransitStatuses[imexsm.imexStatus];
		endif;
		// 23659 add .extractName code
		if imx = null then
			cnt := cnt + 1;
			tmcImex.itemName := "Unknown Imex"; // &amp; Tab &amp; cnt.String;
			tmcImex.extractName := CM_FinancialObject.Extract_Unknown;
		else
			tmcImex.itemName := imx.description; // &amp; Tab &amp; imx.code.String;
			tmcImex.extractName := imx.description;
		endif;
		if imexsm.imexStatus = CM_ImexServiceMap.DEFAULT_IMEX_MAP then
			tmcImex.itemName := "Default (ImEx)";
			tmcImex.extractName := CM_FinancialObject.Extract_Default;
		endif;
		tmcImex.myImexMap := imexsm;
		tmcImex.myGroup := self;
		tmcImex.initialise(_groupCount);
	endforeach;

	_groupCount := _groupCount + 1;
end;</source>
        <Parameter name="_groupCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setControllerCurrent" id="0291c1b1-6d6e-46a3-9e4d-b7d9ba094713">
        <source>setControllerCurrent() ;
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
vars

begin
	inheritMethod();

	myTMCController.myCurrentMapProduct := self.myProductMap;
	myTMCController.myCurrentMapProdGrp := myTMCController.myCurrentMapProduct.myProductGroupMap;
	myTMCController.myCurrentMapTIService := myTMCController.myCurrentMapProdGrp.myCargoTypeMap;
	myTMCController.myCurrentMapTM := myTMCController.myCurrentMapTIService.transactionMap;
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="74a87db1-21f7-4fbe-9356-4c322f07faf8">
        <source>setEnableObjects(form: INV_TransactionMap io);

vars

begin

	inheritMethod(form);

	form.menuSItemNew.visible := true;  // MAIN CARGO NEW MENU
	form.menuTMVnew.visible := false;  // MAIN VTMIS NEW MENU
	form.mnuTMExport.visible := false;
	form.menuMappingSetActive.visible := false;
	form.modePropertyUpdate := INV_TransactionMap.ModeProperty_Product;
	form.modePropertyDelete := INV_TransactionMap.ModeProperty_Product;
	form.modePropertyNew := INV_TransactionMap.ModeProperty_IMEX;

	form.btnNew.enabled := true;
	form.menuSItemNew.enabled := true;

	form.menuSINewImExStatus.visible := true;
	form.mnuCopy.visible := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
	form.btnCopy.enabled := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
	form.mnuReplace.visible := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;
	form.btnReplace.enabled := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2198 CNWAB1;

	form.menuSItemDelete.visible := true;
	form.btnDelete.enabled := true;

end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrent" id="2b91bbb3-1393-491e-94e7-d689dea61096">
