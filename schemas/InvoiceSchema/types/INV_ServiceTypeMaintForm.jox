    <JadeMethod name="doDelete" id="18c941c9-2f09-42e6-af79-0fddd41eb013">
        <updating/>
        <source>doDelete(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2022	navkc1	Initial creation

*/

vars
	theReturn : Integer;
	
begin	
	
	while true do
		
		app.myTrxDA.trxDeleteServiceType(self.myCurrentObject.CM_ServiceType, app.myPassport);
		
		if app.myPassport.trxCompletedOK() then
			self.clearErrorWarnings();
			
			global.beep;
			
			return true;
		else
			theReturn := app.showErrorWarningDialog("Service Type", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors() and theReturn = IDOK then
				app.myPassport.warningsAcknowledged := true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);
			
			return false;
		endif;
	endwhile;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
