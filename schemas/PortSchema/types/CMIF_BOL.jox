        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateSubItems" id="650aacfe-e31b-4804-9581-d0266107bd09">
        <source>validateSubItems(_passport : CM_Passport input) protected;
//--------------------------------------------------------------
//Created: 04 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	idx,
	numRows		: Integer;
	origTIs		: CM_TIArray;
	subItem		: CMIF_TIObject;
	matchFound	: Boolean;
	child		: CM_TrackedItem;
	attach		: CMIF_InOutAttachment;

begin
	create origTIs transient;
	self.myProxyBOL.allTrackedItems.copy(origTIs);

	// Check if Attachment sub-items have a proxy.  If not then try and match
	// to an existing child on self.myProxyTrackedItem
	foreach subItem in self.allSubItems do
		if (not subItem.isKindOf(CMIF_InOutAttachment)) then
			continue;
		endif;
		attach := subItem.CMIF_InOutAttachment;
		
		// Check to see if the attachment already has a proxy and that the
		// user has not changed the Id and/or type.
		
		if attach.myProxyTrackedItem &lt;&gt; null and
		   attach.myProxyTrackedItem.id = attach.id and
		   attach.myProxyTrackedItem.cargoType = attach.cargoType then
			if origTIs.includes(attach.myProxyTrackedItem) then
			   origTIs.remove(attach.myProxyTrackedItem);
			endif;
		   	continue;
		endif;
		
		// Search through proxy children to see if have one with the same id/type
		matchFound := false;
		numRows := origTIs.size;
		foreach idx in 1 to numRows do
			child := origTIs[idx];
			
			if child.id = attach.id and
			   child.cargoType = attach.cargoType then
			   	// A match has been found
			   	matchFound := true;
			   	if attach.myProxyTrackedItem &lt;&gt; null then
			   		// found a match but for a different proxy so treat as a delete
			   		if (not self.myProxyBOL.allTrackedItems.includes(attach.myProxyTrackedItem)) then
			   			// attachment proxy is not in the list here to be erased so
			   			// delete here.
			   			attach.myProxyTrackedItem.erase(NORMAL_ERASE);
			   		endif;
			   	endif;
			   	
			   	// Attach this child to the attachment
			   	attach.setMyProxyTrackedItem(child);
			   	origTIs.remove(attach.myProxyTrackedItem);
			   	break;
			endif;
			
			if (not matchFound) and
		   	   attach.myProxyTrackedItem &lt;&gt; null then
			  	// User has updated id or type so delete proxy
		   		if (not self.myProxyBOL.allTrackedItems.includes(attach.myProxyTrackedItem)) then
		   			// attachment proxy is not in the list here to be erased so
		   			// delete here.
		   			attach.myProxyTrackedItem.erase(NORMAL_ERASE);
			   	endif;
			   	attach.setMyProxyTrackedItem(null);
			endif;
		endforeach;
	endforeach;
	
	// delete any remaing proxies in origTIs
	while origTIs.size &gt; 0 do
		child := origTIs.last;
		self.myProxyBOL.detachTI(child);
		origTIs.remove(child);
		child.erase(NORMAL_ERASE);
	endwhile;
	
	// Finally validate the sub-items

	foreach subItem in self.allSubItems do
		if subItem.CMIF_InOutAttachment.myLocationsController = null
		and self.transportMode = TI_TRANSMODE_SHIP then
		//	app.raiseCMException1(REQUIRED_FIELD, 'location on ship', null, null);
			app.raiseCMException(Input_required_field_locnOnShp, null, null); // cnwdb2	PAR 35364
		endif;
		subItem.validateForCreate(_passport);
	endforeach;
		
epilog
	delete origTIs;

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
