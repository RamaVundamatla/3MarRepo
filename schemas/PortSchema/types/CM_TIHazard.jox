    <JadeMethod name="setForCreate" id="ad124844-2cbb-423e-9fd6-f909e48408a6">
        <updating/>
        <source>setForCreate(_pxyHaz: CM_Hazard; _ti: CM_TrackedItem; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	01 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	inheritMethod(_pxyHaz, _ti, _passport);
	self.myTrackedItem := _ti;
	if self.myTrackedItem &lt;&gt; null then
//		self.myTrackedItem.setHazardLocations(); // PAR 16097
		self.myTrackedItem.setHazardLocationsForMode(REAL_MODE, false);

	endif;
end;</source>
        <Parameter name="_pxyHaz" type="CM_Hazard"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="cc24ff29-9e0f-4d53-8c75-d09534ce31c8">
        <updating/>
        <source>setForUpdate(_pxyHaz: CM_TIHazard; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	01 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 19/06/2015	cnwdap1		PAR #36421 Hazardous Materials Handling
// 15/11/2016	cnwdap1		TFS 2842 STWR Hazardous Details Enhancements
// 22/03/2017	cnwdap1		TFS 3486 marine Pollutant changes
vars
	undgStr : String;
	undgCode : CM_UNDangerousGoods;

begin
	inheritMethod(_pxyHaz, _passport);
	self.allUNDGCodes.clear;
	_pxyHaz.allUNDGCodes.copy(self.allUNDGCodes);
	self.limitedQuantity := _pxyHaz.limitedQuantity;
	self.packingGroup := _pxyHaz.packingGroup;					// PAR #36421
	
	self.acidsBases := _pxyHaz.acidsBases;										// TFS 2842
	self.flashpointTemperature := _pxyHaz.flashpointTemperature;				// TFS 2842
	self.isMarinePollutant := _pxyHaz.isMarinePollutant;						// TFS 2842
	foreach undgStr in self.allUNDGCodes do										// TFS 2842
		undgCode := app.myRoot.allUNDangerousGoodsCodes[undgStr.trimBlanks];	// TFS 2842
		if undgCode &lt;&gt; null and undgCode.isMarinePollutantMandatory 			// TFS 2842
		and self.isMarinePollutant = null then				// TFS 3486
			self.isMarinePollutant := undgCode.isMarinePollutant;				// TFS 2842
		endif;																	// TFS 2842
	endforeach;																	// TFS 2842
end;</source>
        <Parameter name="_pxyHaz" type="CM_TIHazard"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
