<GUIClass name="CMUI_VScroll" id="9c3f943b-4050-4008-a4c4-d415392401c2">
    <superclass name="VScroll"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <PrimAttribute name="distanceFromBottom" id="c52c6252-51a6-4034-91f0-aa042520c72c">
        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <PrimAttribute name="distanceFromRight" id="0259a411-8d65-4059-8ea0-4e28e1cf3727">
        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <PrimAttribute name="lockBottom" id="a2e7befc-ae2e-4d4a-847b-be33efe8403e">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="lockRight" id="c1cb51b8-d7c9-4dbc-adfc-05be661d7c1c">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="stretchHeight" id="bdb99ff2-26dd-40a5-a8fb-df36d5c110d3">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="repositionAfterResize" id="a7a8c52d-c7a6-4eb7-9e30-bda9e7be81d6">
        <updating/>
        <source>repositionAfterResize() updating;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
   	newLeft, newTop, newWidth, newHeight,
   	parentWidth,
   	parentHeight	: Real;

begin

	if self.parent.isKindOf(Form) then
		parentWidth  := self.parent.Form.clientWidth;
		parentHeight := self.parent.Form.clientHeight;
	elseif self.parent.isKindOf(Control) then
		parentWidth  := self.parent.Control.clientWidth;
		parentHeight := self.parent.Control.clientHeight;
	else
		parentWidth  := self.parent.width;
		parentHeight := self.parent.height;
	endif;
	
	newLeft := self.left;
	newTop := self.top;
	newWidth := self.width;
	newHeight := self.height;

	if self.lockRight then
		newLeft := (parentWidth - newWidth - self.distanceFromRight).max(0);
	endif;
	if self.lockBottom then
		newTop := (parentHeight - newHeight - self.distanceFromBottom).max(0);
	endif;
	if stretchHeight then
		newHeight := (parentHeight - newTop - self.distanceFromBottom).max(0);
	endif;
	
	if newHeight &lt;&gt; self.height then
		// Readjust the max to take into account the new height
		self.max := (self.max + self.height - newHeight).Integer;
	endif;
		
	if newLeft &lt;&gt; self.left or newTop &lt;&gt; self.top or newWidth &lt;&gt; self.width or newHeight &lt;&gt; self.height then
		self.move(newLeft, newTop, newWidth, newHeight);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="stretchHeight" id="cdc41fd2-93f1-48bd-9cf2-8a143b2bccbe">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>stretchHeight(set: Boolean; _value: Boolean io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     21 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set and _value then
		if self.lockBottom then
			self.lockBottom := false;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="fce4c6c3-130d-4c55-afef-cb51ff11e9ec">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     21 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(cntrl, persistCntrl);

	if self.lockBottom or self.stretchHeight then
		self.distanceFromBottom := persistCntrl.parent.height - persistCntrl.height - persistCntrl.top;
	endif;

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
