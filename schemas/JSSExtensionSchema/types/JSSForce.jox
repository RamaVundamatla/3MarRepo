    <JadeMethod name="convertBaseToTarget" id="ab2a6fb9-bf49-42ef-9dbf-25312fc1e027">
        <source>convertBaseToTarget(pMeasure: Real; pUnitTo: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitTo = self.DYNES then
		convertedMeasure	:=	pMeasure * 100000;

	elseif pUnitTo = self.KILOGRAMS_FORCE then
		convertedMeasure	:=	pMeasure / 9.80665;

	elseif pUnitTo = self.KILONEWTONS then
		convertedMeasure	:=	pMeasure / 1000;

	elseif pUnitTo = self.KIPS then
		convertedMeasure	:=	pMeasure / 4448.222;

	elseif pUnitTo = self.MEGANEWTONS then
		convertedMeasure	:=	pMeasure / 1000000;

	elseif pUnitTo = self.NEWTONS then
		convertedMeasure	:=	pMeasure;

	elseif pUnitTo = self.POUNDALS then
		convertedMeasure	:=	pMeasure / 0.138255;

	elseif pUnitTo = self.POUNDS_FORCE then
		convertedMeasure	:=	pMeasure / 4.448222;

	elseif pUnitTo = self.STHENES then
		convertedMeasure	:=	pMeasure / 1000;

	elseif pUnitTo = self.TONNES_FORCE then
		convertedMeasure	:=	pMeasure / 9806.65;

	elseif pUnitTo = self.TONS_UK_FORCE then
		convertedMeasure	:=	pMeasure / 9964.016;

	elseif pUnitTo = self.TONS_US_FORCE then
		convertedMeasure	:=	pMeasure / 8896.443;
		
	else
		JSSException.raise_(JSS_X_03004, "[" &amp; pUnitTo.String &amp; "] is an unknown unit of force to convert to.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertToBaseUnit" id="dc8fccf9-291a-4282-b2a9-b8cd7b0f4beb">
        <source>convertToBaseUnit(pUnitFrom: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitFrom = self.DYNES then
		convertedMeasure	:=	self.measure / 100000;

	elseif pUnitFrom = self.KILOGRAMS_FORCE then
		convertedMeasure	:=	self.measure * 9.80665;

	elseif pUnitFrom = self.KILONEWTONS then
		convertedMeasure	:=	self.measure * 1000;

	elseif pUnitFrom = self.KIPS then
		convertedMeasure	:=	self.measure * 4448.222;

	elseif pUnitFrom = self.MEGANEWTONS then
		convertedMeasure	:=	self.measure * 1000000;

	elseif pUnitFrom = self.NEWTONS then
		convertedMeasure	:=	self.measure;

	elseif pUnitFrom = self.POUNDALS then
		convertedMeasure	:=	self.measure * 0.138255;

	elseif pUnitFrom = self.POUNDS_FORCE then
		convertedMeasure	:=	self.measure * 4.448222;

	elseif pUnitFrom = self.STHENES then
		convertedMeasure	:=	self.measure * 1000;

	elseif pUnitFrom = self.TONNES_FORCE then
		convertedMeasure	:=	self.measure * 9806.65;

	elseif pUnitFrom = self.TONS_UK_FORCE then
		convertedMeasure	:=	self.measure * 9964.016;

	elseif pUnitFrom = self.TONS_US_FORCE then
		convertedMeasure	:=	self.measure * 8896.443;
		
	else
		JSSException.raise_(JSS_X_03003, "[" &amp; pUnitFrom.String &amp; "] is an unknown unit of force to convert from.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pUnitFrom" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
</Class>
