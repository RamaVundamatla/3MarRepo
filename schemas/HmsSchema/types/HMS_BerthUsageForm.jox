vars

begin
	inheritMethod(_colorControl);
	self.setColorsForTable(self.tblData);
	self.frmSearch.backColor := self.backColor;	
	self.fldMain.backColor := self.backColor;
	self.barGraph.backColor := self.backColor;
	self.barGraph2.backColor := self.backColor;	//15 Feb 2012	NDL	Par 29120
	self.barGraph3.backColor := self.backColor;	//15 Feb 2012	NDL	Par 29120
	self.barGraph4.backColor := self.backColor;	//15 Feb 2012	NDL	Par 29120
	self.pieGraph.backColor := self.backColor;
