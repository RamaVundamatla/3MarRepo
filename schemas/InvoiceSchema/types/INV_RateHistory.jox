    <JadeMethod name="doQuery" id="8b545e09-f87b-4b4a-b708-2d041189a36d">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 28/03/2018	jlgdap1		TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
vars

begin

	self.tblInfo.rows := 0;

	tblData.rows := tblData.fixedRows; // PAR 31657
	
	if self.myCurrentService = null then
		app.msgBox("Please select a service","Query Error",MsgBox_OK_Only);
		return;
	endif;
	if self.modeDisplay = self.Mode_Debtor then
		if self.doQueryDebtor() then
			self.frmQuery.visible := false;
		endif;
	elseif self.modeDisplay = self.Mode_Vessel then		// TFS 37794
		if self.doQueryVessel() then					// TFS 37794
			self.frmQuery.visible := false;				// TFS 37794
		endif;											// TFS 37794
	//07.06.2018 cnwma1 ChangeRequest #38953
	elseif self.modeDisplay = self.Mode_VesselType then		
		if self.doQueryVesselType() then					
			self.frmQuery.visible := false;				
		endif;
	//07.06.2018 cnwma1 ChangeRequest #38953
	elseif self.modeDisplay = self.Mode_VisitType then		
		if self.doQueryVisitType() then					
			self.frmQuery.visible := false;				
		endif;	
	//07.06.2018 cnwma1 ChangeRequest #38953
	elseif self.modeDisplay = self.Mode_Berth then		
		if self.doQueryBerth() then					
			self.frmQuery.visible := false;				
		endif;	
	else
		if self.doQueryShippingLine() then
			self.frmQuery.visible := false;
		endif;
	endif;
	if self.myParentForm = null then
		inheritMethod();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryBerth" id="c827ff85-51ac-4de4-a9e6-a2f51647f934">
        <updating/>
        <source>doQueryBerth():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018 cnwma1	ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
*/

vars
	table : Table;
	savedChargedEffTS : TimeStamp;
	bank : CM_Bank;
	str : String;
	mp : Integer;
	rate : CM_Rate;

begin
	table := self.tblData;

	savedChargedEffTS := app.getChargeRateEffectiveDate();
	app.setChargeRateEffectiveDate(self.effectiveDate.TimeStamp);
	
	self.myCurrentBerth := self.cmbBerth.listObject.HMS_Berth;
	bank := self.cmbBank.listObject.CM_Bank;       //07.06.2018 cnwma1 ChangeRequest #38953
	self.myCurrentBank := bank;
	
	if self.myCurrentBerth = null then
		app.msgBox("Please select a Berth", "Query Error", MsgBox_OK_Only);
		return false;
	endif;
	//07.06.2018 cnwma1 ChangeRequest #38953
	if self.myCurrentBank = null then
		app.msgBox("Please select a Business Unit", "Query Error", MsgBox_OK_Only);
		return false;
	endif;
	str := "Rate History - ";

	str := str &amp; self.myCurrentBerth.description;

	self.setCaption(str &amp; " /" &amp; self.myCurrentService.name &amp; " " &amp; self.myCurrentBank.code);
	self.setNavigatorHeading(self.caption);

	mp := app.mousePointer;
	app.mousePointer := MP_HOURGLASS;
	self.setMyCurrentRateEntry(null);

	table.rows := 1;
	rate := self.myCurrentBerth.allServiceRates[self.myCurrentService];
	self.loadRateHistoryBerth(self.myCurrentBerth, table, self.myCurrentService);
	
	return true;
	
epilog
	app.mousePointer := mp;
	app.setChargeRateEffectiveDate(savedChargedEffTS);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQueryDebtor" id="5c383e2e-2574-445c-bf47-2bf28e6894f9">
        <updating/>
        <source>doQueryDebtor()  : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	rate : CM_Rate;
	bank	: CM_Bank;
	mp : Integer;
	theTable : Table;
	savedChargedEffTS : TimeStamp;

begin
	theTable := self.tblData;

	//19 Sep 2012	NDL	Par 30375
	savedChargedEffTS := app.getChargeRateEffectiveDate();
	app.setChargeRateEffectiveDate( self.effectiveDate.TimeStamp );
	
	self.myCurrentDebtor := self.cmbDebtor.listObject.CM_DebtorNode; // PAR 16503
	bank := self.cmbBank.listObject.CM_Bank;			// 35872
	if bank &lt;&gt; self.myCurrentBank then
//		self.doComboServicesBuild();
	endif;
	self.myCurrentBank := bank;
	
	if self.myCurrentDebtor = null then
		app.msgBox("Please select a debtor","Query Error",MsgBox_OK_Only);
		return false;
	endif;


	self.setCaption("Rate History - " &amp; self.myCurrentDebtor.getListName() &amp; " /" &amp; self.myCurrentService.name &amp; " " &amp; self.myCurrentBank.code); // 	TFS 2682// so default debtor is not 'RDG'
	self.setNavigatorHeading(self.caption);

	mp := app.mousePointer;
	app.mousePointer := MP_HOURGLASS;
	self.setMyCurrentRateEntry(null);	//17 Sep 2012	NDL	Par 30375

	theTable.rows := 1;
	rate := self.myCurrentDebtor.serviceRates[self.myCurrentService];

	self.loadRateHistoryDebtor(self.myCurrentDebtor,theTable, self.myCurrentService);
	return true;
epilog
	app.mousePointer := mp;
	app.setChargeRateEffectiveDate( savedChargedEffTS );	//19 Sep 2012	NDL	Par 30375
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQuerySheetChange" id="6c50a13b-d118-4875-a2d2-68b9b321ef13">
        <updating/>
        <source>doQuerySheetChange() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 28/03/2018	jlgdap1		TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
vars

begin
	if  self.fldQuery.topSheet = self.shtQuery1 then
		self.modeDisplay := self.Mode_Debtor;
		self.cmbTrade.listIndex := -1;
		self.cmbTradeService.listIndex := -1;
		self.cmbTradeGroup.listIndex := -1;
		self.cmbTradeDebtor.listIndex := -1;
		self.cmbVessel.listIndex := -1;						// TFS 37794
		self.cmbVesselService.listIndex := -1;				// TFS 37794
		//07.06.2018 cnwma1 ChangeRequest #38953
		self.cmbVesselType.listIndex := -1;				    
		self.cmbVesselTypeService.listIndex := -1;			
		
		self.cmbVisitType.listIndex := -1;				    			
		self.cmbVisitTypeService.listIndex := -1;		
		
		self.cmbBerth.listIndex := -1;				  	  			   
		self.cmbBerthService.listIndex := -1;			   
		//07.06.2018 cnwma1 ChangeRequest #38953
	elseif self.fldQuery.topSheet = self.shtQuery2 then
		self.modeDisplay := self.Mode_Trade;
		self.cmbDebtor.listIndex := -1;
		self.cmbDebtorService.listIndex := -1;
		self.cmbVessel.listIndex := -1;						// TFS 37794
		self.cmbVesselService.listIndex := -1;				// TFS 37794
		//07.06.2018 cnwma1 ChangeRequest #38953
		self.cmbVesselType.listIndex := -1;					
		self.cmbVesselTypeService.listIndex := -1;			
		
		self.cmbVisitType.listIndex := -1;					
		self.cmbVisitTypeService.listIndex := -1;
		
		self.cmbBerth.listIndex := -1;				
		self.cmbBerthService.listIndex := -1;
		//07.06.2018 cnwma1 ChangeRequest #38953
	elseif self.fldQuery.topSheet = self.shtQuery3 then		// TFS 37794
		self.modeDisplay := self.Mode_Vessel;				// TFS 37794
		self.cmbTrade.listIndex := -1;						// TFS 37794
		self.cmbTradeService.listIndex := -1;				// TFS 37794
		self.cmbTradeGroup.listIndex := -1;					// TFS 37794
		self.cmbTradeDebtor.listIndex := -1;				// TFS 37794
		self.cmbDebtor.listIndex := -1;						// TFS 37794
		self.cmbDebtorService.listIndex := -1;				// TFS 37794
		//07.06.2018 cnwma1 ChangeRequest #38953
		self.cmbVesselType.listIndex := -1;			 
		self.cmbVesselTypeService.listIndex := -1;
		
		self.cmbVisitType.listIndex := -1;			 
		self.cmbVisitTypeService.listIndex := -1;	
		
		self.cmbBerth.listIndex := -1;			 
		self.cmbBerthService.listIndex := -1;	
	//07.06.2018 cnwma1 ChangeRequest #38953
	elseif self.fldQuery.topSheet = self.shtQuery4 then		
		self.modeDisplay := self.Mode_VesselType;			
		self.cmbTrade.listIndex := -1;						
		self.cmbTradeService.listIndex := -1;				
		self.cmbTradeGroup.listIndex := -1;					
		self.cmbTradeDebtor.listIndex := -1;				
		self.cmbDebtor.listIndex := -1;						
		self.cmbDebtorService.listIndex := -1;				
		//07.06.2018 cnwma1 ChangeRequest #38953
		self.cmbVessel.listIndex := -1;								
		self.cmbVesselService.listIndex := -1;				
		
		self.cmbVisitType.listIndex := -1;											
		self.cmbVisitTypeService.listIndex := -1;	
		
		self.cmbBerth.listIndex := -1;										
		self.cmbBerthService.listIndex := -1;	
		
	//07.06.2018 cnwma1 ChangeRequest #38953
	elseif self.fldQuery.topSheet = self.shtQuery5 then		
		self.modeDisplay := self.Mode_VisitType;						
		self.cmbTrade.listIndex := -1;						
		self.cmbTradeService.listIndex := -1;				
		self.cmbTradeGroup.listIndex := -1;					
		self.cmbTradeDebtor.listIndex := -1;				
		self.cmbDebtor.listIndex := -1;						
		self.cmbDebtorService.listIndex := -1;				
		//07.06.2018 cnwma1 ChangeRequest #38953
		self.cmbVessel.listIndex := -1;							
		self.cmbVesselService.listIndex := -1;				
		
		self.cmbVesselType.listIndex := -1;										
		self.cmbVesselTypeService.listIndex := -1;	
		
		self.cmbBerth.listIndex := -1;											
		self.cmbBerthService.listIndex := -1;	
	//07.06.2018 cnwma1 ChangeRequest #38953
	elseif self.fldQuery.topSheet = self.shtQuery6 then		
		self.modeDisplay := self.Mode_Berth;	
		self.cmbTrade.listIndex := -1;						
		self.cmbTradeService.listIndex := -1;				
		self.cmbTradeGroup.listIndex := -1;					
		self.cmbTradeDebtor.listIndex := -1;				
		self.cmbDebtor.listIndex := -1;						
		self.cmbDebtorService.listIndex := -1;				
		//07.06.2018 cnwma1 ChangeRequest #38953
		self.cmbVessel.listIndex := -1;								
		self.cmbVesselService.listIndex := -1;				
		
		self.cmbVesselType.listIndex := -1;											
		self.cmbVesselTypeService.listIndex := -1;	
		
		self.cmbVisitType.listIndex := -1;										
		self.cmbVisitTypeService.listIndex := -1;	
	//07.06.2018 cnwma1 ChangeRequest #38953
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryShippingLine" id="cacc589f-b15d-490d-b226-8e687eeb8417">
        <updating/>
        <source>doQueryShippingLine() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	rateEntry : CM_RateEntry;
	rate : CM_Rate;
	i, mp : Integer;
	str : String;

	theTable : Table;
	savedChargedEffTS : TimeStamp;
begin

	//19 Sep 2012	NDL	Par 30375
	savedChargedEffTS := app.getChargeRateEffectiveDate();
	app.setChargeRateEffectiveDate( self.effectiveDate.TimeStamp );
	
	if self.myCurrentLineGroupDebtor = null then
		app.msgBox("Please select a Trade","Query Error",MsgBox_OK_Only);
		return false;
	endif;
	theTable := self.tblData;
	// 35872 
	self.setCaption("Rate History - " &amp; self.myCurrentLineGroupDebtor.code &amp; "/" &amp; self.myCurrentService.name &amp; " " &amp; self.myCurrentService.bank.code); // 	TFS 2682
	self.setNavigatorHeading(self.caption);



	mp := app.mousePointer;
	app.mousePointer := MP_HOURGLASS;
	//self.myCurrentRateEntry := null;
	self.setMyCurrentRateEntry(null);	//17 Sep 2012	NDL	Par 30375

	theTable.rows := 1;
	rate := self.myCurrentLineGroupDebtor.serviceRates[self.myCurrentService];
	if rate &lt;&gt; null then
		i := 2;
		theTable.column := 1;
		foreach rateEntry in rate.rateEntries do
			//str := rateEntry.getDisplayString();
			str := rateEntry.getAttributeStringForDefArray(theTable.CM_DataTable.allTblDataEntRows);	// 23582
			i := theTable.addItem(str);
			theTable.accessRow(i).itemObject := rateEntry;
		endforeach;
	endif;
	return true;
epilog
	app.mousePointer := mp;
	app.setChargeRateEffectiveDate( savedChargedEffTS );	//19 Sep 2012	NDL	Par 30375

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQueryVessel" id="28f0c6d8-5fbb-45c8-8e34-031df620c167">
        <updating/>
        <source>doQueryVessel() : Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/03/2018	jlgdap1		Initial creation TFS 37794 PEL1 Vessel Rates
//
vars
	table : Table;
	savedChargedEffTS : TimeStamp;
	bank : CM_Bank;
	str : String;
	mp : Integer;
	rate : CM_Rate;

begin
	table := self.tblData;

	savedChargedEffTS := app.getChargeRateEffectiveDate();
	app.setChargeRateEffectiveDate(self.effectiveDate.TimeStamp);
	
	self.myCurrentVessel := self.cmbVessel.listObject.CM_Vessel;
	bank := self.cmbBank.listObject.CM_Bank;		//07.06.2018 cnwma1 ChangeRequest #38953
	self.myCurrentBank := bank;
	
	if self.myCurrentVessel = null then
		app.msgBox("Please select a Vessel", "Query Error", MsgBox_OK_Only);
		return false;
	endif;
	
	//07.06.2018 cnwma1 ChangeRequest #38953
	if self.myCurrentBank = null then
		app.msgBox("Please select a Business Unit", "Query Error", MsgBox_OK_Only);
		return false;
	endif;
	str := "Rate History - ";
	if self.myTerminal.getConfig(VesselComboByName).Boolean then
		str := str &amp; self.myCurrentVessel.name &amp;  " - (" &amp; self.myCurrentVessel.code &amp; ")";
	else
		str := str &amp; self.myCurrentVessel.code &amp;  " - (" &amp; self.myCurrentVessel.name &amp; ")";
	endif;
	self.setCaption(str &amp; " /" &amp; self.myCurrentService.name &amp; " " &amp; self.myCurrentBank.code);
	self.setNavigatorHeading(self.caption);

	mp := app.mousePointer;
	app.mousePointer := MP_HOURGLASS;
	self.setMyCurrentRateEntry(null);

	table.rows := 1;
	rate := self.myCurrentVessel.allServiceRates[self.myCurrentService];
	self.loadRateHistoryVessel(self.myCurrentVessel, table, self.myCurrentService);
	
	return true;
	
epilog
	app.mousePointer := mp;
	app.setChargeRateEffectiveDate(savedChargedEffTS);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQueryVesselType" id="dec2c71b-10a1-4349-b864-445697aed328">
        <updating/>
        <source>doQueryVesselType(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
