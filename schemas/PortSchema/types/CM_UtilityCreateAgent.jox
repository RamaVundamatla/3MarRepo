        <source>utlCreateInterfaceDefinition(	_pxyObject:CM_TCPInterfaceDefinition;
								_realObject:CM_TCPInterfaceDefinition output;
								_passportObj:CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2008 by cnwdad1
//
// Purpose:		Creates a new Interface Definition object.
//
// Parameters:	_pxyObject - A reference to a proxy Interface Definition object.
//				_realObject - A reference to the real Interface Definition object
//					that is returned to the calling method.
//				_passportObj - A reference to the current user's Passport object.
//
// Returns:		A reference to the new Interface Definition object, via the _realObject
//				parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCreateInterfaceDefinition(_pxyObject, _passportObj);

	if (not self.checkValidationWithPassport(_passportObj)) then
		return;
	endif;

	create _realObject as _pxyObject.class persistent;
	_realObject.setForCreate(_pxyObject);
end;</source>
        <Parameter name="_pxyObject" type="CM_TCPInterfaceDefinition"/>
        <Parameter name="_realObject" type="CM_TCPInterfaceDefinition" usage="output"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
