	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//cargo id
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Cargo Id', CM_InvoiceLine::getTrackedItemId.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//posted invoice id
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('External Invoice Number', CM_InvoiceLine::getExternalInvoiceNumber.name, self.className);
	tmpProp.needToUpperCase := true;
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//bill of lading
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Bill of Lading', CM_InvoiceLine::getTrackedItemBOL.name, self.className);
