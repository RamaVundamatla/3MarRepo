	leftMMs := 90;	rightMMs := 108;	self.moveLabel( self.lblD, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 109;	rightMMs := 139;	self.moveLabel( self.lblE, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 140;	rightMMs := 178;	self.moveLabel( self.lblF, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 179;	rightMMs := 199;	self.moveLabel( self.lblG, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 114;
	bottomMMs := 122;
	leftMMs := 0;	rightMMs := 41;		self.moveLabel( self.lblH, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 42;	rightMMs := 72;		self.moveLabel( self.lblI, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 73;	rightMMs := 85;		self.moveLabel( self.lblJ, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 86;	rightMMs := 98;		self.moveLabel( self.lblK, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 99;	rightMMs := 113;	self.moveLabel( self.lblL, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 114;	rightMMs := 178;	self.moveLabel( self.lblM, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 179;	rightMMs := 199;	self.moveLabel( self.lblN, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 134;
	bottomMMs := 142;
	leftMMs := 0;	rightMMs := 92;		self.moveLabel( self.lblO, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 93;	rightMMs := 199;	self.moveLabel( self.lblP, topMMs, leftMMs, rightMMs, bottomMMs );
	
	topMMs := 150;
	bottomMMs := 158;
	leftMMs := 0;	rightMMs := 92;		self.moveLabel( self.lblQ, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 93;	rightMMs := 119;	self.moveLabel( self.lblR, topMMs, leftMMs, rightMMs, bottomMMs );
	//leftMMs := 120;	rightMMs := 144;	self.moveLabel( self.lblS, topMMs, leftMMs, rightMMs, bottomMMs );
	leftMMs := 119;	rightMMs := 149;	self.moveLabel( self.lblS, topMMs, leftMMs, rightMMs, bottomMMs ); //02 Apr 2013	NDL	Par 31373
	leftMMs := 145;	rightMMs := 199;	self.moveLabel( self.lblT, topMMs, leftMMs, rightMMs, bottomMMs );
	
