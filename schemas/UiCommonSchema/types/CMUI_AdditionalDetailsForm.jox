    <JadeMethod name="cmbCtryOfOrigin_displayEntry" id="69e26cd3-785c-46ae-86bc-7f69481d1830">
        <controlMethod name="CMUI_FieldComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCtryOfOrigin_displayEntry(_combobox: CMUI_FieldComboBoxControl input; _obj: Any; _index: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin

*/

vars

begin
	if _obj.CM_Country.isNotAvailableForEntry then													
		return null;																			
	endif;																				

	return _obj.CM_Country.code &amp; "    " &amp; _obj.CM_Country.description;
epilog

end;</source>
        <Parameter name="_combobox" type="CMUI_FieldComboBoxControl" usage="input"/>
        <Parameter name="_obj" type="Any"/>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
