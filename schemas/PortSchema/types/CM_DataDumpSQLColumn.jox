    <JadeMethod name="buildSQLDataType" id="0ffb4777-088f-44e5-a0ec-edd8965a432d">
        <updating/>
        <source>buildSQLDataType(_withBrackets : Boolean) : String updating;
/*
Purpose:			Build the SQL datatype for SQLColumn

Parameters:			Are Square Brackets required

Return Value:		Actual SQL Datatype

Date			Who		Reason
22 April 2010	conkc1	Initial creation

*/
vars
	dataTypeString : String;
	lengthModifier : String;
begin

	if _withBrackets = true then
		dataTypeString := "[" &amp;  self.myDataDumpSQLDataType.name &amp; "] ";
	else
		dataTypeString := self.myDataDumpSQLDataType.name;
	endif;

	if self.isMaximumLength = true then
		lengthModifier := "(MAX)";
	elseif self.length &lt;&gt; 0 then
		lengthModifier := "(" &amp; self.length.String;
		if self.myDataDumpSQLDataType.name.toUpper = "NUMERIC" or
			self.myDataDumpSQLDataType.name.toUpper = "DECIMAL" then
			lengthModifier := lengthModifier &amp; "," &amp; self.decimalDigits.String;
		endif;
		lengthModifier := lengthModifier &amp; ")";
	endif;
		
	dataTypeString := dataTypeString &amp; lengthModifier;

	return dataTypeString;
	
epilog

end;</source>
        <Parameter name="_withBrackets" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="changeOIDFormat" id="6aa7aa8f-9476-4659-81eb-829dc59a212b">
