    <DbClassMap file="JtdCntrl"/>
    <ImplicitInverseRef name="myProfileTextMethod" id="bf0191da-b6df-4455-bd19-bd72599170f8">
        <embedded/>
        <type name="Method"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="mySchema" id="6de84cb0-8a0b-454b-81e5-cbfb1e9159f7">
        <embedded/>
        <type name="Schema"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="schemaName" id="9d2ba98e-dfb1-40ff-8cab-6f8d6e255b76">
        <length>41</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
