    <JadeMethod name="doSave" id="5eaa32d5-8ae2-4e73-aa28-1580e04d85ea">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
31 Aug 2023	jlizm1	TFS 59567 Kiosk instruction type maint

*/


vars
	theForm 				: SOP_TableMaintForm;
	tbl						: CM_EntryTable;
	code,
	description				: String;
	notAvailableForEntry 	: Boolean;
	pxyInstructionType,
	realInstructiontype		: CM_InstructionType;
	terminal				:CM_Terminal;
	alwaysToGateOffice		: Boolean;
	selectedTrailerTypes	: CM_TILCTypeByCodeDict;
	
begin
	theForm := self.myForm;
	tbl := theForm.tblInput1;
	
	code := tbl.getValueByName(ETRow_Code).String;
	description := tbl.getValueByName(ETRow_Description).String;
	notAvailableForEntry := tbl.getValueByName(ETRow_NotAvailableForEntry).Boolean;
	terminal			   := self.myForm.myTerminal;
	alwaysToGateOffice := tbl.getValueByName(ETRow_AlwaysToGateOffice).Boolean;
	
	create selectedTrailerTypes transient;
	theForm.mulSelect1.getSelected(selectedTrailerTypes);
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_InstructionType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object null for update');
			return false;
		endif;
	endif;
	
	pxyInstructionType := theForm.myProxyObject.CM_InstructionType;
	pxyInstructionType.setProxy(code, description, notAvailableForEntry, alwaysToGateOffice, selectedTrailerTypes, terminal);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateInstructionType(pxyInstructionType, realInstructiontype, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateInstructiontype(pxyInstructionType, app.myPassport);
	endif;
	
	return app.myPassport.trxCompletedOK();
epilog
	delete selectedTrailerTypes;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
