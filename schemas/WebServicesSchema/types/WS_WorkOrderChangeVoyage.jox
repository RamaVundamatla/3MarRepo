    <JadeMethod name="setProxyFromObject" id="1b435830-98e0-4386-8609-9feac26043c2">
        <updating/>
        <source>setProxyFromObject(_object: CM_WodNullVoyage) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2018	jlger1	Initial creation 38520

*/

vars

begin
	inheritMethod(_object);
	if _object.myNewVoyage &lt;&gt; null then
		self.voyageOid := _object.myNewVoyage.getOidAsString;
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_WodNullVoyage"/>
    </JadeMethod>
    <JadeMethod name="updateProxyWorkOrder" id="451f346a-360e-4f26-8320-63a305f232c2">
        <source>updateProxyWorkOrder(_pxyWorkOrder: CM_WorkOrderTIDtl input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2018	jlger1	Initial creation

*/

vars
	voyage 		: CM_Voyage;
begin
	inheritMethod(_pxyWorkOrder);
		voyage := app.myPassport.getObjectOfTypeFromOid(self.voyageOid,CM_Voyage).CM_Voyage;
	if voyage &lt;&gt; null then
		_pxyWorkOrder.CM_WodNullVoyage.setProxyWodNullVoyage(voyage);
	endif;
epilog

end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrderTIDtl" usage="input"/>
    </JadeMethod>
</Class>
