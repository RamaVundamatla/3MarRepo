    <JadeMethod name="initSearcher" id="fa1d3d4e-7d56-485d-aefe-e6e54a2b66f3">
        <source>initSearcher();
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	now : Date;
begin
	now := self.systemToLocalTime(app.actualTimeServer).Date;	// 18/4/16 cnwmp6 TFS 488 - Multi timezone support
	
	self.tblSearch.setEntTableDef(app.myController.getEntTableDef(ETDef_EventRequestSearch), null, null);
	self.setColorsForEntryTable(self.tblSearch);
	
	self.myAssistant.comboBoxEventRequestStatus(self.tblSearch, ETRow_Status);
	
	self.tblSearch.setValueByName(ETRow_FromDate, (now-30));
	self.tblSearch.setValueByName(ETRow_ToDate, now);
	self.tblSearch.top := 45; // TFS 52462 NAVAB1 25NOV2021
	
	self.myAssistant.comboBoxCargoTypes(self.cmbCargoType, app.myPassport.getDefaultCargoType());
	self.cmbCargoType.lostFocus(self.cmbCargoType);	
end;
</source>
