    <JadeMethod name="updateXlatTableTypeConst" id="5f022a36-6f9b-42e3-b7f0-2d9242ec9ed0">
        <source>updateXlatTableTypeConst(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
14 March 2023		jlizm1	Initial creation TFS 56987 update incorrect constant value

*/
constants
	OLD_VALUE 	: Integer = 25;
	
vars
	xlatTable  	: CM_XlationTable;
	objArray	: ObjectArray;
	iter		: Iterator;
	bothExist	: Boolean;
	obj			: Object;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; "Xlation Type Country constant update", LogINFO); 
	if _controller &lt;&gt; null then
		_controller.logEntry("Xlation Type Country constant update") ;	
	endif;
	
	create objArray transient;

	foreach xlatTable in CM_XlationTable.instances discreteLock do
		if xlatTable.type = XLATION_TYPE_COUNTRYTERMINAL then
			bothExist := true;
			break;
		endif;
		if xlatTable.type &lt;&gt; OLD_VALUE then
			continue;
		endif;
		objArray.add(xlatTable);
	endforeach;
	
	if not bothExist then
		beginTransaction;
		foreach obj in objArray discreteLock do
			obj.setPropertyValue(CM_XlationTable::type.name, XLATION_TYPE_COUNTRYTERMINAL);
		endforeach;
		commitTransaction;
	endif;
	
	app.writeLog(method.qualifiedName &amp; "Xlation Type Country constant update completed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Xlation Type Country constant update completed");
	endif;
	
	self.addScriptRun(method.name);
	
epilog
	delete objArray;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
</Class>
