end;</source>
    </JadeMethod>
    <JadeMethod name="createProductFromSelf" id="8f2f3e6e-529c-4d2b-9b07-a30870dc8c9d">
        <source>createProductFromSelf(_code : String; _passport : CM_Passport input): CM_Product;
// ---------------------------------------------------------------------------
// Created:     20 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pxyProduct	: CM_ProductLog;
	realProduct	: CM_Product;
		
begin

	create pxyProduct transient;
	pxyProduct.setProxyLogProductFromCodes(	_code,
											self.myOperator,
											self.speciesCode,
								 			self.gradeCode,
								 			self.typeCode,
								 			self.treatmentCode,
											self.lengthCode,
											_passport,
											null);

	app.myUtilityCA.utlCreateProduct(pxyProduct, realProduct, _passport);
	if _passport.noErrors then
		return realProduct;
	endif;
	
	return null;
	
epilog
	delete pxyProduct;
	
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="displayDetail" id="53f329df-cccd-4df2-a270-77c9c9b4a703">
        <source>displayDetail() : String;

vars

	display,
	theOperator,
	species,
	grade,
	type,
	treatment,
	theId,
	theLength			: String;

begin

	if self.myOperator &lt;&gt; null then
		theOperator := self.myOperator.code;
	endif;
//	if self.isNoNumber then
//		theId := 'NN';
//	else
		theId := self.id;
//	endif;

	display := false.Integer.String &amp; Tab &amp; theId &amp; Tab &amp; theOperator &amp; Tab &amp;  self.speciesCode &amp; '/' &amp; self.gradeCode &amp; '/' &amp; self.typeCode &amp; '/' &amp;
				self.treatmentCode &amp; Tab  &amp;  self.lengthCode &amp; Tab &amp;  self.sedMean.String &amp; Tab &amp;  self.getMyTotalVolume.jasVolumeString;
	return display;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayLogDetail" id="88d318c8-37c3-4b2b-8e20-4a78f2dc7119">
        <source>displayLogDetail(_operatorTerminology : String; _textPixelsWidth : Integer) : String;

vars
	origBol		: CM_BOLIn;
	theLocation	: CM_LocationsController;
	display		: String;

	
begin

	// Get self.myLog details for display.
	if self.myOperator &lt;&gt; null then
//	par 10009 - need terminology for logs // old code was displaying terminology for Log Dockets
	//	display := _operatorTerminology &amp; Tab &amp; Tab &amp; self.myOperator.code &amp; CrLf;	
		// as terminology can be any size need to be able to format text apropirately
		if _textPixelsWidth  &lt; 48 then 
			display := _operatorTerminology &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.myOperator.code &amp; CrLf;	
		elseif _textPixelsWidth  &lt; 96 then 
			display := _operatorTerminology &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.myOperator.code &amp; CrLf;
		elseif _textPixelsWidth  &lt; 144 then 
			display := _operatorTerminology &amp; Tab &amp; Tab &amp; Tab &amp; self.myOperator.code &amp; CrLf;
		elseif _textPixelsWidth  &lt; 192 then 
			display := _operatorTerminology &amp; Tab &amp; Tab &amp; self.myOperator.code &amp; CrLf;
		else // should not be any larger 
			display := _operatorTerminology &amp; Tab &amp; self.myOperator.code &amp; CrLf;	
		endif;
		
	endif;
	origBol := self.myReceivalBOL;
	if origBol &lt;&gt; null then
		display := display &amp; 'Docket' &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; origBol.number &amp; CrLf;
	endif;
	theLocation := self.getPrimaryLocation(REAL_MODE);
	if theLocation &lt;&gt; null then
		display := display &amp; 'Location' &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab&amp; theLocation.getID &amp; CrLf;
	endif;
	display := display &amp; 'Minimum SED' &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.sedMin.String &amp; CrLf;
	display := display &amp; 'Maximum SED' &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.sedMax.String &amp; CrLf;
	display := display &amp; 'Condition Code' &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.conditionCode &amp; CrLf;
	display := display &amp; 'Species' &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.speciesCode &amp; CrLf;
	display := display &amp; 'Grade' &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.gradeCode &amp; CrLf;
	display := display &amp; 'Type' &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.typeCode &amp; CrLf;
	display := display &amp; 'Treatment' &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.treatmentCode &amp; CrLf;
	display := display &amp; 'Length' &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.lengthCode &amp; CrLf;
	display := display &amp; 'Volume' &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; self.getMyTotalVolume.jasVolumeString;

	return display;
	
end;</source>
        <Parameter name="_operatorTerminology" type="String"/>
        <Parameter name="_textPixelsWidth" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="docketCorrectionCreateTrans" id="0827ccad-dcd3-48d6-b528-6bd117cd0a3e">
        <updating/>
        <source>docketCorrectionCreateTrans( 	_tiUpdateCntrl : CMIF_TIUpdateController input;
								_theSupplierHasBeenChanged,	_theProductHasBeenChanged : Boolean;
								_locationOld,		_locationNew, 
								_theSupplierOld,	_theSupplierNew,
								_theProductOld,		_theProductNew,
								_theOldJasVolume,	_theNewJasVolume  : String ) updating, protected;
// --------------------------------------------------------------------------------------------------------
// Created:     10 Jan 2008 by cnwvu1
//
// Purpose:     ccms1089. Docket Correction.
// 				a) corrects the old transactions: Moved, Supplier and Product Changed.
// 				b) creatings a new Docket Correction transaction
// ----------------------------------------------------------------------------------------------------------

vars
	txnParams	: CMIF_TITransactionController;
	trans		: CM_DocketCorrection;
	passport	: CM_Passport;
	
begin

	// -----------------------------------------------------------------------
	// creating the new transaction Docket Correction
	// -----------------------------------------------------------------------
	_tiUpdateCntrl.transactionType := TRANS_TYPE_DocketCorrection;
	_tiUpdateCntrl.isDocketCorrection := true;	// for managing CM_TrackedItem :: endUpdate() - we don't need CM_Edit. stockMovements will be created here
	
	create txnParams transient;
	passport := app.myPassport;
	txnParams.type 		:= TRANS_TYPE_DocketCorrection;

	trans := self.createTransaction(txnParams, passport).CM_DocketCorrection;
	trans.setFieldsValues( _locationOld,_locationNew, _theSupplierOld,_theSupplierNew, _theProductOld,_theProductNew, _theOldJasVolume,_theNewJasVolume );
epilog
	delete txnParams;
end;
</source>
        <access>protected</access>
        <Parameter name="_tiUpdateCntrl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_theSupplierHasBeenChanged" type="Boolean"/>
        <Parameter name="_theProductHasBeenChanged" type="Boolean"/>
        <Parameter name="_locationOld" type="String"/>
        <Parameter name="_locationNew" type="String"/>
        <Parameter name="_theSupplierOld" type="String"/>
        <Parameter name="_theSupplierNew" type="String"/>
        <Parameter name="_theProductOld" type="String"/>
        <Parameter name="_theProductNew" type="String"/>
        <Parameter name="_theOldJasVolume" type="String"/>
        <Parameter name="_theNewJasVolume" type="String"/>
    </JadeMethod>
    <JadeMethod name="docketCorrectionStockMove_locn" id="65716396-aa35-4797-9af5-863cddc21b09">
        <updating/>
        <source>docketCorrectionStockMove_locn( _bol : CM_BOLIn; _trnRoadToLocation: CM_Move; _trnLocation1ToLocation2 : CM_TITransaction; _oldLocation, _newLocation : CM_LocationsController ) updating, protected;
// --------------------------------------------------------------------------------------------------------------------
// Created:     25 March 2008 by cnwvu1
//
// Purpose:		Corrects stock move for the log. 
//				The method is called when Location has been changed by the docket correction.
//				It goes through 2 affected Move transactions and corrects stock move.
//				It also corrects stock move for all old transactions between these 2 Move transactions:
//					SED or weigth changed, product changed or reassembley log.
//				Note. Stock move is not corrected for all transactions following after the second Move transaction.
//					Stock Move correction begins for MovementIn on the _trnRoadToLocation
//					and ends for MovementOut on the _trnLocation1ToLocation2
//
// Parameters:	_trnRoadToLocation - the first Move transaction from Road To Location when Docket Correction occurs.
//				_trnLocation1ToLocation2 - the second move transaction (From Location1 To Location2) affected by Docket Correction.
//								_trnLocation1ToLocation2 &lt;&gt; null, when a log has been regraded and moved to another location.
//				_oldLocation, _newLocation - locations changed by Docket Correction
// --------------------------------------------------------------------------------------------------------------------

vars
	trn		: CM_TITransaction;
	trnMove	: CM_Move;
	trnEdit	: CM_Edit;
	trnDisa	: CM_Disassembly;
	trnRejectFound	: Boolean;
//	stockOnHandToBeChanged	: Boolean;
	theFirstMoveFound		: Boolean;
	
begin

	theFirstMoveFound := false;
	
	foreach trn in self.allTransactions do
	
		if not theFirstMoveFound then	// looking for the firstMove transaction
		
			if trn.isKindOf( CM_Move ) then
				trnMove := trn.CM_Move;
				if trnMove = _trnRoadToLocation then
					theFirstMoveFound := true;
					trnMove.docketCorrectionLocn_stockMove( _trnRoadToLocation, _trnLocation1ToLocation2, _oldLocation, _newLocation );
				endif;
				
			endif;
			
		else	// all transactions following the first Move transaxction

			if trn.isKindOf( CM_Move ) then
				// do stock move for the second Move Transaction
				trnMove := trn.CM_Move;
				trnMove.docketCorrectionLocn_stockMove( _trnRoadToLocation, _trnLocation1ToLocation2.CM_Move, _oldLocation, _newLocation );
				break;
				
			elseif trn.isKindOf( CM_EditProductCode ) or trn.isKindOf( CM_EditOperator) then
				// do stock move for product changed
				trn.CM_EditProductCode.docketCorrectionLocn_stockMove( _oldLocation, _newLocation );

			elseif trn.isKindOf( CM_Edit) then	// can be either SED (Volume) or weight changed
				trnEdit := trn.CM_Edit;
				// Weight can be changed in CM_Edit (Docket Maintenance screen) 
				// Volume can be changed (SED is changed in Regrade screen). We should correct stock move for CM_Edit
				if trnEdit.totalWeight &lt;&gt; trnEdit.fromWeight or trnEdit.totalVolume &lt;&gt; trnEdit.fromVolume then	//weight has been changed
					trnEdit.docketCorrectionLocnWV_stock( _oldLocation, _newLocation );
				else
					if trnEdit.hasStockMovements() then
						app.raiseUnexpectedProgramError( class.name, method.name, 'Unexpected stock movement in the trn CM_Edit ' &amp; trnEdit.String );
						return;
					endif;
				endif;
				
			elseif trn.isKindOf( CM_Disassembly ) then
				trnDisa := trn.CM_Disassembly;
				trnDisa.docketCorrectionLocn_stockMove( _oldLocation, _newLocation );
				if self.allTransactions.last &lt;&gt; trnDisa then
					if not self.allTransactions.last.isKindOf( CM_DocketCorrection ) then
						app.raiseUnexpectedProgramError( class.name, method.name, 'There are more unexpected transactions after log disassembly. Log ' &amp; self.String );
						return;
					endif;
				endif;
				break;	// this transaction should be the last. In all cases, there is no stock move affected after this transaction.
				
			elseif trn.isKindOf( CM_Reject ) then
				trnRejectFound	:= true;
				trn.CM_Reject.docketCorrectionLocn_stockMove( _oldLocation, _newLocation );

			elseif trn.isKindOf( CM_ReinstateReject ) then
				if not trnRejectFound then
					app.raiseUnexpectedProgramError( class.name, method.name, 'Error - Reinstate Reject. Previous Reject has not been found for the log ' &amp; self.String);
					return;
				endif;
				if trn = _trnLocation1ToLocation2 then	// #24462 06/07/2010. When a log was reinstated back to another location, this transaction is considered as a second move transaction from locn1 to locn2.
					break;	// This trn has only stockMovementIn for another location. It doesn't touch the old location. We don't need to check the following transactions, too.
				endif;
				trn.CM_ReinstateReject.docketCorrectionLocn_stockMove( _oldLocation, _newLocation );
				
			else
				if trn.hasStockMovements() then
					app.raiseUnexpectedProgramError( class.name, method.name, 'Location changed. Unknown stock movement for the transaction ' &amp; trn.String );
					return;
				endif;
				
			endif;
		
		endif;
		
	endforeach;

	if not theFirstMoveFound then 
		app.raiseUnexpectedProgramError( class.name, method.name, 'The Move transaction From Road To Location not found for the log ' &amp; self.String );
	endif;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_bol" type="CM_BOLIn"/>
        <Parameter name="_trnRoadToLocation" type="CM_Move"/>
        <Parameter name="_trnLocation1ToLocation2" type="CM_TITransaction"/>
        <Parameter name="_oldLocation" type="CM_LocationsController"/>
        <Parameter name="_newLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="docketCorrectionStockMove_prod" id="d3f953e8-243d-4ee2-9a35-9b11aa2e16f8">
        <updating/>
        <source>docketCorrectionStockMove_prod( _oldProduct, _newProduct : CM_Product; _newQuantity: Integer; _newWeight : Decimal; _newVolume : Decimal	) updating, protected;
// --------------------------------------------------------------------------------------------------------------------
// Created:     15 Feb 2008 by cnwvu1
//
// Purpose:		Corrects stock move for the log. 
//				The method is called when Product has been changed by docket correction.
//				It goes through all transactions, from the first Move transaction from Road To Location and changes
//					stock move until finds the first trn having regraded product (product changed).
//					If there is no Product Changed transaction, it corrects stockOnHand
//
// Parameters:	_newVolume - corrected by DocketCorrection
//				_newQuantity, _newWeight - are untouched by docket correction.
//					_newQuantity = 1 always for the log
//					_newWeight - if it is changed, changes reflected in a new transaction CM_Edit 
//						(which is created before DocketCorrection)
// --------------------------------------------------------------------------------------------------------------------

vars
	trnFromRoadToLocation		: CM_Move;
	trnFromLocation1ToLocation2 : CM_TITransaction;	//#24462 06/07/2010
	stockOnHandToBeChanged	: Boolean;
	trn		: CM_TITransaction;
	trnMove	: CM_Move;
	trnEdit	: CM_Edit;
	trnDisa : CM_Disassembly;
	trnRejectFound	: Boolean;
	trnFound_FromRoadToLocn,
	trnFound_FromLocn1ToLocn2	: Boolean;
	
begin
	
	if _newQuantity &lt;&gt; 1 then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Quantity for the log should be 1. Log ' &amp; self.String );
		return;
	endif;
	
	// getting move transactions: the starting point is the first trn - From Road To Location
	self.getTransMovedForDocketCorrect( trnFromRoadToLocation, trnFromLocation1ToLocation2 );
	
	trnFound_FromRoadToLocn := false;
	
	foreach trn in self.allTransactions do
	
		if not trnFound_FromRoadToLocn then 
		
			if trn.isKindOf( CM_Move ) then
				trnMove := trn.CM_Move;
				if trnMove = trnFromRoadToLocation then
					trnFound_FromRoadToLocn := true;
					trnFromRoadToLocation.docketCorrectionProd_stockMove( _oldProduct, _newProduct, _newQuantity, _newWeight, _newVolume );
				endif;
			endif;
		
		else
		
			if trn.isKindOf( CM_Move ) then
				trnMove := trn.CM_Move;
				if trnMove = trnFromLocation1ToLocation2 then	//trnFromLocation1ToLocation2 - the last Move Transaction before productChanged trn
					trnFound_FromLocn1ToLocn2 := true;
				endif;
				trnMove.docketCorrectionProd_stockMove( _oldProduct, _newProduct, _newQuantity, _newWeight, _newVolume );
			
			elseif trn.isKindOf( CM_EditProductCode ) then
				trn.CM_EditProductCode.docketCorrectionProd_stockMove( _oldProduct, _newProduct, _newQuantity, _newWeight, _newVolume );
				break;	// log has been regraded, and have new current product
				
			elseif trn.isKindOf( CM_Edit ) then
				trnEdit := trn.CM_Edit;
				// Weight can be changed in CM_Edit (Docket Maintenance screen) 
				// Volume can be changed (SED is changed in Regrade screen). We should correct stock move for CM_Edit
				if trnEdit.totalWeight &lt;&gt; trnEdit.fromWeight or trnEdit.totalVolume &lt;&gt; trnEdit.fromVolume then	//weight has been changed
					trnEdit.docketCorrectionProdWV_stock( _oldProduct, _newProduct );
				else
					if trnEdit.hasStockMovements() then
						app.raiseUnexpectedProgramError( class.name, method.name, 'Unexpected stock movement in the trn CM_Edit ' &amp; trnEdit.String );
						return;
					endif;
				endif;
				
			elseif trn.isKindOf( CM_Disassembly ) then
				trnDisa := trn.CM_Disassembly;
				trnDisa.docketCorrectionProd_stockMove( _oldProduct, _newProduct, _newQuantity, _newWeight, _newVolume );
				if self.allTransactions.last &lt;&gt; trnDisa then
					if not self.allTransactions.last.isKindOf( CM_DocketCorrection ) then
						app.raiseUnexpectedProgramError( class.name, method.name, 'There are more unexpected transactions after log disassembly. Log ' &amp; self.String );
						return;
					endif;
				endif;
				break;	// this transaction should be the last. In all cases, there is no stock move affected after this transaction.
				
			elseif trn.isKindOf( CM_Reject ) then
				trnRejectFound	:= true;
				trn.CM_Reject.docketCorrectionProd_stockMove( _oldProduct, _newProduct, _newQuantity, _newWeight, _newVolume );
			
			elseif trn.isKindOf( CM_ReinstateReject ) then
				if not trnRejectFound then
					app.raiseUnexpectedProgramError( class.name, method.name, 'Error - Reinstate Reject. Previous Reject has not been found for the log ' &amp; self.String);
					return;
				endif;
				trn.CM_ReinstateReject.docketCorrectionProd_stockMove( _oldProduct, _newProduct, _newQuantity, _newWeight, _newVolume );
				
			endif;
			
		endif;
		
	endforeach;

	if not trnFound_FromRoadToLocn then 
		app.raiseUnexpectedProgramError( class.name, method.name, 'The Move transaction From Road To Location not found for the log ' &amp; self.String );
	endif;

end;
</source>
        <access>protected</access>
        <Parameter name="_oldProduct" type="CM_Product"/>
        <Parameter name="_newProduct" type="CM_Product"/>
        <Parameter name="_newQuantity" type="Integer"/>
        <Parameter name="_newWeight" type="Decimal"/>
        <Parameter name="_newVolume" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="docketCorrectionTransMoved" id="c389477a-8a2f-4b6a-a69a-dc016a74c904">
        <updating/>
        <source>docketCorrectionTransMoved( _bol : CM_BOLIn; _transMoveFromRoadToLocation1: CM_Move input; _transMoveFromLocn1ToLocn2 : CM_TITransaction input) updating, protected;
// --------------------------------------------------------------------------------------------------------
// Created:     01 Feb 2008 by cnwvu1
//
// Purpose:		a) corrects 2 old Move transactions: From Road To Location1 and From Location1 To Location2
//				b) fixes stock move for changed locations
// ----------------------------------------------------------------------------------------------------------

vars
	oldLocation, 
	newLocation		: CM_LocationsController;
	stockMovementIn	: CM_StockMoveLocation;
	
begin

	// -----------------------------------------------------------------------
	// 					old Move Transactions correction
	// -----------------------------------------------------------------------
	// _transMoveFromRoadToLocation1: From Road =&gt; Location1
	if _transMoveFromRoadToLocation1 &lt;&gt; null then
		_transMoveFromRoadToLocation1.docketCorrection( true, _bol.getLocationOriginal() );
	endif;
	// _secondMoveTransaction: From Location1 =&gt; Location2
	// There can be only two types of transactions, when moving from locn1 to locn2: CM_Move and CM_ReinstateReject #24462 06/07/2010
	if _transMoveFromLocn1ToLocn2 &lt;&gt; null then
		if _transMoveFromLocn1ToLocn2.isKindOf(CM_Move) then
		_transMoveFromLocn1ToLocn2.CM_Move.docketCorrection( false, _bol.getLocationOriginal() );
		elseif _transMoveFromLocn1ToLocn2.isKindOf(CM_ReinstateReject) then	// #24462 06/07/2010
			// when reinstateReject, there is no old location to bb corrected. This transaction keeps only new (the last location).
		else
			app.raiseUnexpectedProgramError( class.name, method.name, 'Second move transaction is not kind of CM_Move or CM_ReinstateReject' );
		endif;
	endif;

	// -----------------------------------------------------------------------
	//		 					Stock Move correction
	// -----------------------------------------------------------------------
	// getting old location
	stockMovementIn	:= _transMoveFromRoadToLocation1.myStockMovementIn.myStockMoveBucket.CM_StockMoveLocation; 
	oldLocation		:= stockMovementIn.myLocationsController;
	
	if oldLocation = null then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Location ' &amp; oldLocation.CM_LogController.id &amp; ' is deleted' );
	endif;
	
	newLocation	:= _bol.getLocationOriginal();				// _bol has new location. It has been edited when DocketCorrection

	self.docketCorrectionStockMove_locn( _bol, _transMoveFromRoadToLocation1, _transMoveFromLocn1ToLocn2, oldLocation, newLocation );
	
end;
</source>
        <access>protected</access>
        <Parameter name="_bol" type="CM_BOLIn"/>
        <Parameter name="_transMoveFromRoadToLocation1" type="CM_Move" usage="input"/>
        <Parameter name="_transMoveFromLocn1ToLocn2" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
    <JadeMethod name="docketCorrectionTransOperProd" id="3139c591-d065-41a4-a3b5-f3618a9f9495">
        <updating/>
        <source>docketCorrectionTransOperProd(	_bol : CM_BOLIn; _oldProduct : CM_Product; _newJasVolume : Decimal;
								_theSupplierHasBeenChanged, 
								_theProductHasBeenChanged : Boolean; 
								_theFirstSupplierChangedTrans : CM_EditOperator input; 
								_theFirstProductChangedTrans : CM_EditProductCode input) updating, protected;
// --------------------------------------------------------------------------------------------------------
// Created:     05 Feb 2008 by cnwvu1
//
// purpose: If there are the Supplier and the Product changed, we have to correct old transactions:
//			For the Supplier we have to correct the Supplier changed transaction:
//				There are 2 ways: to change either Product or Supplier and Product
//			For the Product changed we have to correct the first (the oldest) transaction 
//				among two transactions: the Supplier changed and the Product Changed.
// ----------------------------------------------------------------------------------------------------------

vars
	tmpNewProduct	: CM_Product;
	tmpNewQuantity	: Integer;
	tmpNewVolume	: Decimal[16,4];
	tmpNewWeight	: Decimal[14,4];
	
begin

	if not _theSupplierHasBeenChanged and not _theProductHasBeenChanged then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Method should not be called' );
		return;		//there are neither the Supplier nor the Product changed
	endif;

	tmpNewProduct	:= _bol.myProduct;
	tmpNewQuantity	:= self.totalQuantity;
	tmpNewVolume	:= _newJasVolume.Real;
	//tmpNewWeight	:= self.weight;	// after validation, the log has its new weight here				//-cnwml2 MSL CCMS 1017
	tmpNewWeight := self.totalWeight;

	if _theFirstSupplierChangedTrans = null and _theFirstProductChangedTrans = null then
		//there are no OLD transactions to be edited
		
	elseif not _theSupplierHasBeenChanged and _theProductHasBeenChanged then
	// -------------------------------------------------------------------------------------------------
	// 								the Product has been changed only
	// -------------------------------------------------------------------------------------------------
			// there is only the Product changed. We have to find the oldest transaction among the Supplier Changed and the Product Changed transactions

		if _theFirstSupplierChangedTrans = null then

			if _theFirstProductChangedTrans &lt;&gt; null then
				// we have to correct the Product in _theFirstProductChangedTrans
				_theFirstProductChangedTrans.docketCorrection( _bol );
			endif;
			
		else
			
			if _theFirstProductChangedTrans = null then	//there is the Supplier Changed transaction only
				// we have to correct the Product in _theFirstSupplierChangedTrans
				_theFirstSupplierChangedTrans.docketCorrectionForSupplier( _bol, false, true );
			else 
				//there are both transactions &lt;&gt; null
				if _theFirstSupplierChangedTrans.createdTime &lt; _theFirstProductChangedTrans.createdTime then
					// we have to correct the Product in the _theFirstSupplierChangedTrans
					_theFirstSupplierChangedTrans.docketCorrectionForSupplier( _bol, false, true );
				else
					// we have to correct the Product  in _theFirstProductChangedTrans
					_theFirstProductChangedTrans.docketCorrection( _bol );
				endif;
			endif;
		endif;

	elseif _theSupplierHasBeenChanged then	// the Supplier changed means the Product changed, too.
	// -------------------------------------------------------------------------------------------------
	// 								the Supplier has been changed
	// -------------------------------------------------------------------------------------------------
		
		if _theFirstSupplierChangedTrans = null or _theFirstProductChangedTrans = null then
		
			if _theFirstSupplierChangedTrans = null then
				// we have to change the Product  in _theFirstproductChangedTrans
				_theFirstProductChangedTrans.docketCorrection( _bol );
			else
				// we have to change the Supplier (and Product automatically) in _theFirstSupplierChangedTrans
				_theFirstSupplierChangedTrans.docketCorrectionForSupplier( _bol, true, true );
			endif;
		
		else	// both transactions &lt;&gt; null
		
		
			if _theFirstSupplierChangedTrans.createdTime &lt; _theFirstProductChangedTrans.createdTime then
				
				if _theFirstSupplierChangedTrans &lt;&gt; null then
					// we have to change the Supplier and the Product in _theFirstSupplierChangedTrans
					_theFirstSupplierChangedTrans.docketCorrectionForSupplier( _bol, true, true );
				endif;
				
			else
				// we have to change the Supplier in _theFirstSupplierChangedTrans
				// we have to change the Product  in _theFirstproductChangedTrans
				if _theFirstSupplierChangedTrans &lt;&gt; null then
					// we have to change the Supplier in _theFirstSupplierChangedTrans
					_theFirstSupplierChangedTrans.docketCorrectionForSupplier( _bol, true, false );
				endif;
				if _theFirstProductChangedTrans &lt;&gt; null then
					// we have to change the Product  in _theFirstproductChangedTrans
					_theFirstProductChangedTrans.docketCorrection( _bol );
				endif;
			endif;

		endif;
		
	endif;

	// correcting stock movement
	self.docketCorrectionStockMove_prod( 	_oldProduct, 
											tmpNewProduct, tmpNewQuantity, tmpNewWeight, tmpNewVolume );

end;
</source>
        <access>protected</access>
        <Parameter name="_bol" type="CM_BOLIn"/>
        <Parameter name="_oldProduct" type="CM_Product"/>
        <Parameter name="_newJasVolume" type="Decimal"/>
        <Parameter name="_theSupplierHasBeenChanged" type="Boolean"/>
        <Parameter name="_theProductHasBeenChanged" type="Boolean"/>
        <Parameter name="_theFirstSupplierChangedTrans" type="CM_EditOperator" usage="input"/>
        <Parameter name="_theFirstProductChangedTrans" type="CM_EditProductCode" usage="input"/>
    </JadeMethod>
    <JadeMethod name="docketCorrection_getCurrentSED" id="867b6b2f-e98a-4caa-9cec-b06788225e29">
        <source>docketCorrection_getCurrentSED( _currentTrn : CM_TITransaction; _oldSedMean, _newSedMean : Decimal output);
// --------------------------------------------------------------------------------------------------------------------
// Created:     19 Feb 2008 by cnwvu1
//
// Purpose:		Gives the current sedMean for the old transaction when docket correction occurs.
//				Method is called when changing stock move in old transactions.
//				By default, sedMean = log.sedMean 	
//				However, if there are old following CM_Edit transactions with the volume (SED) changes
//					(also CM_EditProductCode (product changed) - it is subclass),
//					we should figure out the current sedMean for the current old Move transaction at that moment.
// --------------------------------------------------------------------------------------------------------------------

vars
	tmpNewSED		: Decimal[6,2];
	currentTrnFound	: Boolean;
	trn				: CM_TITransaction;
	trnEdit			: CM_Edit;
	tmpOldSedMean,
	tmpNewSedMean		: String;
	
begin
	
	if not _currentTrn.isKindOf( CM_Edit ) 
	and not _currentTrn.isKindOf( CM_Move ) 
	and not _currentTrn.isKindOf( CM_Reject ) 
	and not _currentTrn.isKindOf( CM_ReinstateReject ) 
	then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Wrong transaction type ' &amp; _currentTrn.String );
		return;
	endif;
	
	foreach trn in self.allTransactions do
	
		if not currentTrnFound then
			if trn = _currentTrn then
				currentTrnFound := true;
				if trn.isKindOf( CM_Edit ) then	// maybe, this CM_Edit has SED changed. If so, we don't need to check following transactions
					if trn.CM_Edit.hasSedChanged( _oldSedMean, _newSedMean ) then
						break;
					endif;
				endif;
			endif;
		else
			if trn.isKindOf( CM_Edit ) then
				if trn.CM_Edit.hasSedChanged( _oldSedMean, _newSedMean ) then
					break;
				endif;
			endif;
		endif;
	
	endforeach;
	
	if not currentTrnFound then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Transaction CM_Edit cannot find itself ' &amp; self.String );
		return;
	endif;
	
	if _oldSedMean = null and _newSedMean = null then
		_oldSedMean := self.sedMean;
		_newSedMean := self.sedMean;
	endif;
	
end;
</source>
        <Parameter name="_currentTrn" type="CM_TITransaction"/>
        <Parameter name="_oldSedMean" type="Decimal" usage="output"/>
        <Parameter name="_newSedMean" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="docketCorrection_getNewVolume" id="1feb0f0c-6bd1-487d-8679-483b9067683d">
        <source>docketCorrection_getNewVolume( _newBOLVolume : Decimal; _oldProduct, _newProduct : CM_Product; _currentTrn : CM_TITransaction ) : Decimal;
// --------------------------------------------------------------------------------------------------------------------
// Created:     19 Feb 2008 by cnwvu1
//
// Purpose:		Gives the new volume for the newProduct changed by docket correction.
//				Method is called when changing stock move in old transactions.
//				By default, newVolume = _bol.volume,	
//				However, if there are old following CM_Edit transactions with the volume changes
//					(also CM_EditProductCode (product changed) - it is subclass),
//					we should figure out the current volume for the current old Move transaction.
//					I.e. the current historical volume at that historical time period for this _currentTrn.
// --------------------------------------------------------------------------------------------------------------------

vars
	currentTrnFound	: Boolean;
	trn				: CM_TITransaction;
	trnEdit			: CM_Edit;
	volumeIsChanged	: Boolean;
	tmpOldSedMean,
	tmpNewSedMean	: Decimal[6,2];

begin

	if not _currentTrn.isKindOf( CM_Move ) 
	and not _currentTrn.isKindOf( CM_Reject ) 
	and not _currentTrn.isKindOf( CM_ReinstateReject ) 
	then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Wrong transaction type ' &amp; _currentTrn.String );
		return null;
	endif;
	
	foreach trn in self.allTransactions do
	
		if not currentTrnFound then
			if trn = _currentTrn then
				currentTrnFound := true;
			endif;
		else
			if trn.isKindOf( CM_Edit ) then
				trnEdit := trn.CM_Edit;
				//if trnEdit.fromVolume &lt;&gt; trnEdit.totalVolume	//commented by PAR21780 Jan 2010
				if (trnEdit.fromVolume &lt;&gt; trnEdit.totalVolume) and (trnEdit.fromVolume &gt; 0 and trnEdit.totalVolume &gt; 0)	//Inspection/Fumigation also creates CM_Edit: fromVolume=0 and totalVolume = currentVolume PAR21780 Jan 2010
				or trnEdit.hasSedChanged( tmpOldSedMean, tmpNewSedMean ) then
					volumeIsChanged	:= true;
					break;
				endif;
			endif;
		endif;
	
	endforeach;
	
	if not currentTrnFound then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Transaction CM_Edit cannot find itself ' &amp; self.String );
		return null;
	endif;
	
	if volumeIsChanged then
		if trnEdit.hasSedChanged( tmpOldSedMean, tmpNewSedMean ) then
			// count new volume with tmpOldSedMean
			return global.calcJASVolume( tmpOldSedMean, _newProduct.CM_ProductLog.logLength );
		else
			//if _oldProduct.length &lt;&gt; _newProduct.length then	// length is null always for logs system. Commented by #24462 08/07/2010
			if _oldProduct.CM_ProductLog.logLength &lt;&gt; _newProduct.CM_ProductLog.logLength then	//#24462 08/07/2010
				return global.calcJASVolume( self.sedMean, _newProduct.CM_ProductLog.logLength );
			else
				// there are no SED and no length changes
				return _currentTrn.totalVolume;
			endif;
		endif;
	else
		return _newBOLVolume;
	endif;
	
end;
</source>
        <Parameter name="_newBOLVolume" type="Decimal"/>
        <Parameter name="_oldProduct" type="CM_Product"/>
        <Parameter name="_newProduct" type="CM_Product"/>
        <Parameter name="_currentTrn" type="CM_TITransaction"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="docketCorrection_getNewWeigth" id="6e40b3d3-52df-4fc5-bf0e-165bdfee3acb">
        <source>docketCorrection_getNewWeigth( _newBOLWeight : Decimal; _currentTrn : CM_TITransaction ) : Decimal;
// --------------------------------------------------------------------------------------------------------------------
// Created:     19 Feb 2008 by cnwvu1
//
// Purpose:		Gives the new weight for the newProduct changed by docket correction.
//				Method is called when changing stock move in old transactions.
//				By default, newWeight = log.weight,	
//				However, if there are old CM_Edit transactions with the weight changes,
//					we should figure out the current weight for the current old Move transaction.
//					I.e. the current historical weight at that historical time period for this _currentTrn.
// --------------------------------------------------------------------------------------------------------------------

vars
	tmpNewWeight	: Decimal[14,4];
	currentTrnFound	: Boolean;
	trn				: CM_TITransaction;
	trnEdit			: CM_Edit;
	weightIsChanged	: Boolean;
	
begin
	
	if not _currentTrn.isKindOf( CM_Move ) 
	and not _currentTrn.isKindOf( CM_Reject ) 
	and not _currentTrn.isKindOf( CM_ReinstateReject ) 
	then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Wrong transaction type ' &amp; _currentTrn.String );
		return null;
	endif;

	
	foreach trn in self.allTransactions do
	
		if not currentTrnFound then
			if trn = _currentTrn then
				currentTrnFound := true;
			endif;
		else
			if trn.isKindOf( CM_Edit ) then
				trnEdit := trn.CM_Edit;
				//if trnEdit.fromWeight &lt;&gt; trnEdit.totalWeight then	commented by par PAR21780 Jan 2010
				if (trnEdit.fromWeight &lt;&gt; trnEdit.totalWeight) and (trnEdit.fromWeight &gt; 0 and trnEdit.totalWeight &gt; 0) then	//Inspection/Fumigation also creates CM_Edit: fromWeight=0 and totalWeight = currentWeight. PAR21780 Jan 2010
					weightIsChanged := true;
					break;
				endif;
			endif;
		endif;
	
	endforeach;
	
	if not currentTrnFound then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Transaction CM_Move cannot find itself ' &amp; self.String);
		return null;
	endif;
	
	if weightIsChanged then
		return _currentTrn.totalWeight;
	else
		return _newBOLWeight;
	endif;
	
end;
</source>
        <Parameter name="_newBOLWeight" type="Decimal"/>
        <Parameter name="_currentTrn" type="CM_TITransaction"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="endUpdate" id="6bebdc6d-31f2-462c-9803-a7cd6c805883">
        <updating/>
        <source>endUpdate(_tiUpdateCntrlr: CMIF_TIUpdateController input; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     24 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.setMyTerminalIfUnscaled();

	//ccms1089. Docket Corection transaction has been created already having Location changes
/*	if self.myReceivalBOL &lt;&gt; null 
		and self.myReceivalBOL.isMatchedToday() 
		and _tiUpdateCntrlr.myLocationFrom &lt;&gt; self.getPrimaryLocation( REAL_MODE )
	then
		// Docket Corection transaction has been created already having Location changes
		// Somehow CM_Edit transaction are created for the field myPrimaryActualLocation too.
		// So, we are returning here - the CM_Edit transaction for the Location won't be created
		return;	
			
	endif;*/

	inheritMethod(_tiUpdateCntrlr, _passport);

end;</source>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="executeControlPostMove" id="3d4d57f2-934d-49df-a6ab-cc7afe7b7ea0">
        <updating/>
        <source>executeControlPostMove(control: CMIF_MoveController io; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/08/2021	navdap1	TFS 51710 C3 Rejected Logs being reinstated by move
// ---------------------------------------------------------------------------
vars
	logRowTo 	: CM_LogController;
	
begin
	// TFS 51710 If I've been rejected, don't create any move transactions (done in inheritMethod)
	// and don't do any fumigated / inspected checks
	if self.isRejected then
		return;
	endif;
	
	if control.moveMode = REAL_MODE then
		if control.myOriginatingLocation &lt;&gt; null and
		   control.myToPrimaryLocation &lt;&gt; null and
		   control.myOriginatingLocation.isKindOf(CM_LogController) then
		   
			if control.myToPrimaryLocation.isKindOf(CM_LogVoyageController) then
				// This always gets set if we are moving from a yard location
				// may need to refine the setting of this (rjs)
				self.myLoadOutSOHLocation := control.myOriginatingLocation.allProductLocations[self.myProduct];
			endif;
		endif;
		
		// 09/09/2009 cnwar2 CCMS-1107/#20627
		// If a log that is not inspected/fumigated is moved into a row that is inspected/fumigated then
		// need to update row to flag as not inspected/fumigated, and update all logs accordingly 
		if control.myToPrimaryLocation.isKindOf(CM_LogController) then
			logRowTo 	:= control.myToPrimaryLocation.CM_LogController;
			self.setInspectedFumigated(logRowTo, _passport);	//PAR 21514 Nov 2009
		endif;
	endif;

	inheritMethod(control, _passport);
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAgeForType" id="f53e3a9f-258b-4481-96ea-618be6755481">
        <source>getAgeForType(_baseDate : Date; _ageType : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     19 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	if _ageType = null then //call it properly
		app.raiseUnexpectedProgramError(class.name, method.name, 'Age Type constant passed in was null');
		return null;
	endif;
	
	if _ageType = TI_AGE_FELLDATE then
		return (_baseDate - self.fellDate).Integer + 1;//considered 1 day old on the day it was felled
	
	elseif _ageType = TI_AGE_MATCHDATE then
		if self.myReceivalBOLOrig &lt;&gt; null then
			return (_baseDate - self.myReceivalBOLOrig.matchTime.date).Integer + 1; //also considered 1 day old on the day it was matched
		endif;
	endif;
	
	return inheritMethod(_baseDate, _ageType);
	
end;</source>
        <Parameter name="_baseDate" type="Date"/>
        <Parameter name="_ageType" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllDrawingIconsByPriority" id="4444e362-8b85-4e26-be68-90a49579c2e4">
        <source>getAllDrawingIconsByPriority(_iconArray: StringArray input; _maxIcons: Integer; _planning : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07/12/2017	jlgmp6	Initial creation	TFS7493
11/11/2019	jlgdap1	TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
*/

vars
	root: CM_Root;
	attr,
	startObject: CM_DrawingAttribute;
	lController: CM_LocationsController;
	iter: Iterator;
	attrCode: String;
begin
	root := app.getMyRoot();
	if root = null then
		return;
	endif;
	lController := self.getPrimaryLocation(QUEUE_MODE);
	
	iter := root.allDrawingAttributesByTypePri.createIterator();
	startObject := root.allDrawingAttributesByTypePri.getAtKeyGtr(DrawingAttrType_TrackedItem, null);
	if startObject &lt;&gt; null then
		iter.startAtObject(startObject);
		while iter.next(attr) and attr.drawingAttrType = DrawingAttrType_TrackedItem do
			attrCode := attr.code;
			// Tracked item
			if attrCode = PicTIInTransit then
				if self.isInTransitOnShip and self.isOnWagon() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIReadyToShip then
				if self.readyToShip then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTICustomHold then
				if self.isStopSetToBeProcessed(StopProcessEDICustomExport) then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIHazard then
				if self.isHazardous then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicSpecialStow then
				if self.specialStow &lt;&gt; null then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTITBA then
				if self.myMatchedTBA &lt;&gt; null then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIQueued then
				if lController &lt;&gt; null or self.hasMembers(self.allQueuedFutureMoves) then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIPlanned then
				if _planning then					// TFS 46405
					continue;						// TFS 46405
				endif;								// TFS 46405
				if self.hasMembers(self.allPlannedFutureMoves) then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIActual then
				if self.getFirstAvailableLoadJob() &lt;&gt; null then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIControlledAtmos then
				if self.isControlledAtmosphere then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIReefer then
				if self.isReefer then
					_iconArray.add(attrCode);
				endif;
			// Log
			elseif attrCode = PicTITimber then
				_iconArray.add(attrCode);
			endif;
	
			if _maxIcons &lt;&gt; 0 and _iconArray.size() &gt;= _maxIcons then
				break;
			endif;
		endwhile;
	endif;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_iconArray" type="StringArray" usage="input"/>
        <Parameter name="_maxIcons" type="Integer"/>
        <Parameter name="_planning" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCloneForInterTerminalMove" id="08afe44f-8e29-4db6-a40b-e9cc381b6f37">
        <updating/>
        <source>getCloneForInterTerminalMove(_toTerminal: CM_Terminal; _passport: CM_Passport input): CM_TrackedItem updating;
