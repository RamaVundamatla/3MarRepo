    <JadeMethod name="translateForm" id="c6523d89-3fe8-4dbd-91fe-da4c6df411e5">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 August 2018 16:45:46.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022932, locale);
	btnCancel.translateCaption(Xlat_0012939, locale);
	btnMoveLeft.translateCaption(Xlat_0012940, locale);
	btnMoveRight.translateCaption(Xlat_0012941, locale);
	btnOK.translateCaption(Xlat_0012942, locale);
	btnShowCargo.translateCaption(Xlat_0012943, locale);
	lblInstructions.translateCaption(Xlat_0012944, locale);
	mnuMain.translateCaption(Xlat_0012945, locale);
	mnuShowCargo.translateCaption(Xlat_0012946, locale);
	mnuViewBooking.translateCaption(Xlat_0012947, locale);
end;</source>
    </JadeMethod>
