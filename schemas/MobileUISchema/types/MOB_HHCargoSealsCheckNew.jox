    <JadeMethod name="setTableForViewMode" id="147a89c0-8816-4dec-a7b2-864cc68c5e00">
        <source>setTableForViewMode( allSealTypes : CM_SealTypeSet; ti : CM_TrackedItem; _wagon : CM_Wagon );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2010	cnwndl1	Initial creation	Par 25608	part of SFW CCMS 1131

*/

vars

	sealType : CM_SealType;
	index : Integer;
	sealTi : CM_SealTI;
	sealObj : CM_SealObject;

begin

	tblSeals.selectMode := Table.SelectMode_None;
	tblSeals.columns := 3;
	tblSeals.rows := 2;
	
	tblSeals.fixedRows := 2;
	tblSeals.fixedColumns := 1;
	
	tblSeals.accessColumn(1).width := (tblSeals.width * 3 / 5).Integer;
	tblSeals.accessColumn(2).width := (tblSeals.width / 5).Integer;
	tblSeals.accessColumn(3).width := (tblSeals.width / 5).Integer;
	
	tblSeals.accessCell(1,1).mergeCells := Table.MergeCells_Merge;

	tblSeals.setCellText(1,1,app.getErrorString1(Seal_check_mode, app.sealCheckTypeEnumToString(SEAL_CHECK_VIEW) ) );
	tblSeals.accessCell(1,1).alignment := Table.Alignment_Center_Middle;
	tblSeals.accessRow(2).alignment := Table.Alignment_Center_Middle;
	tblSeals.accessRow(2).fontBold := true;
	tblSeals.accessCell(2,2).mergeCells := Table.MergeCells_Merge;
	tblSeals.setCellText(2,1,app.getErrorString(CM_Type) );
	tblSeals.accessCell(2,1).alignment := Table.Alignment_Center_Middle;
	tblSeals.setCellText(2,2,"Viewed");
		
	if _wagon &lt;&gt; null then
		foreach sealType in allSealTypes do
			index := tblSeals.addItem(sealType.description);
			sealObj := _wagon.getWagonSeal(sealType);
			if sealObj &lt;&gt; null then
				tblSeals.accessRow(index).itemObject := sealObj;
			else
				tblSeals.accessRow(index).itemObject := sealType;
			endif;
			self.myHandHeldCheckerAgent.setupCargoCheckTableYesNoBtns(tblSeals, index, self.btnTick, self.btnCross);
			tblSeals.accessRow(index).height := 24;
		endforeach;
		
	elseif ti &lt;&gt; null then
		foreach sealType in allSealTypes do
			index := tblSeals.addItem(sealType.description);
			sealTi := ti.getSealTI(sealType);
			if sealTi &lt;&gt; null then
				tblSeals.accessRow(index).itemObject := sealTi;
			else
				tblSeals.accessRow(index).itemObject := sealType;
			endif;
			self.myHandHeldCheckerAgent.setupCargoCheckTableYesNoBtns(tblSeals, index, self.btnTick, self.btnCross);
			tblSeals.accessRow(index).height := 24;
		endforeach;
		
	endif;

epilog

end;</source>
        <Parameter name="allSealTypes" type="CM_SealTypeSet"/>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="c27842bd-ea45-4d16-99f9-d1db487854a3">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2010	cnwndl1	Initial creation	Par 25608	part of SFW CCMS 1131

*/

vars

	stdLeft : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	tblHeight : Real;
	tabIndex : Integer;
	
	ti : CM_TrackedItem;
//	wagon : CM_Wagon;
	hasToDoTask : Boolean;
//	context : Integer;

begin

	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdLeft :=  self.resizedMargin;
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin - 8 ;
	stdHeight := self.getStdControlHeight;
	
	self.caption := app.getErrorString(Seals);
	
	self.myCargoCheckItem := app.myMobileAgent.myCargoCheckItem;
	if self.myCargoCheckItem &lt;&gt; null then
		if self.myCargoCheckItem.myToDoTaskDesc &lt;&gt; null then
			self.chkToDoTask.caption := self.myCargoCheckItem.myToDoTaskDesc.description;
			hasToDoTask := true;
		endif;
	endif;
	
	self.lblCargoId.setAndIncrementTabIndex( tabIndex );
	self.lblCargoId.visible := true;
	self.lblCargoId.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );
							
/*	context := self.myHandHeldCheckerAgent.checksState;
	if context.isOneOf( WAGON_CHECK_CONTEXT_REC, WAGON_CHECK_CONTEXT_REL ) then
		wagon := self.myHandHeldCheckerAgent.myCurrentWagon;
		if wagon = null then
			lblCargoId.caption := app.getErrorString(Unknown);
		else
			lblCargoId.caption := wagon.id;
		endif;
	else
		ti := self.myHandHeldCheckerAgent.myNextTiToAction;
		if ti = null then
			lblCargoId.caption := app.getErrorString(Unknown);
		else
			lblCargoId.caption := ti.id;
		endif;
	endif; */
	
	
	top := self.lblCargoId.top + self.lblCargoId.height + self.resizedMargin;
	// total form height - height of button area at bottom - room for to opt buttons below - some spare room + offset.
	//tblHeight := self.height - self.getCMDHeight() - top - stdHeight +  self.getSessionAgent().deviceHeightOffset;
	tblHeight := self.clientHeight - self.getCMDHeight() - top - stdHeight;	//26 Jun 2017	NDL	TFS 4647
	if hasToDoTask then
		tblHeight := tblHeight - stdHeight - self.resizedMargin;
	endif;
	
	self.tblSeals.setAndIncrementTabIndex( tabIndex );
	self.tblSeals.visible := true;
	self.tblSeals.move(	stdLeft,
						top,
						stdWidth,
						tblHeight );
						
	
	self.lblNoChecks.setAndIncrementTabIndex( tabIndex );
	self.lblNoChecks.visible := false;
	self.lblNoChecks.move(	stdLeft,
							top,
							stdWidth,
							tblHeight );
						
	if hasToDoTask then
		top := self.tblSeals.top + self.tblSeals.height + self.resizedMargin;
		self.chkToDoTask.setAndIncrementTabIndex( tabIndex );
		self.chkToDoTask.visible := true;
		self.chkToDoTask.move(	stdLeft,
								top,
								stdWidth,
								stdHeight );
	else
		self.chkToDoTask.visible := false;
	endif;
	
	self.doResizeControls(true);
								
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d24dd4b8-53bf-4e35-9b92-960024cc6ebf">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


