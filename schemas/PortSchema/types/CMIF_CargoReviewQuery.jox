    <JadeMethod name="createPxyBulkRelease" id="2b34b1b6-8150-45a4-afc0-58c7174482ee">
        <source>createPxyBulkRelease(relType : Integer;_jdo : JadeDynamicObject;_terminal : CM_Terminal) : CM_BulkRelease;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request
10 Apr 2024  navbs1  Bug 63606: TPT | [Consulting] Create Release Request via Cargo Review
15 Apr 2024	jlika1	TFS 63077 EUP* | FR - 54026 LOADNA LOADCO - Freight Forwarder on Cargo Level Not Copied to Release Request from Cargo Review
*/

vars
	pxyBulkRelease		: CM_BulkRelease;
	operator 			: CM_Operator;
	voyage 				: CM_Voyage;
	index 				: Integer;
	type 				: Type;
	value 				: Any;
	consignee, 
	consignor,
	ff 					: CM_ConsigneeConsignor;
	destinationPort, 
	loadPort, 
	dischargePort 		: CM_Port;
	consigneeCode,
	consigneeDesc,
	consignorCode,
	consignorDesc,
	operatorCode,
	voyageCode			: String;
	ffCode				: String;
	bookingRef 			: CM_BookingRef;
	iter 				: Iterator;
	ti 					: CM_TrackedItem;
	productTypeID, 
	lastProductTypeID	: String;
	allTisByCargoType 	: DynaDictionary;
	reserveSelection 	: CM_ReserveSelection;
	defReleaseSubTerm,
	defTargetSubTerm	: CM_SubTerminal;
	tisInGrouping 		: CM_TIByCargoTypeIdDict;
	cargoGrp 			: CM_CargoGroup;
	trackedItemArray 	: Any;
	tis					: CM_TIByCargoTypeIdDict;
	trackedItem 		: CM_TrackedItem;
begin
	
	//get operator from grouping	
	if  _jdo.getPropertyInfoByName(ETRow_OperatorCode,index,type,value) then
		//it is the operatorCode 
		operator:=app.myRoot.allOperators[value.String];
		if operator &lt;&gt; null then
			operatorCode:=operator.code;
		else
			operator := app.myRoot.getOperatorByDesc(value.String);
		endif;
	else
		if _jdo.getPropertyInfoByName(CMIF_CargoReviewQuery.CargoReviewAllTrackedItems,index,type,value) then		
			tisInGrouping := value.CM_TIByCargoTypeIdDict;
			ti := tisInGrouping.first;
			if ti &lt;&gt; null then
				cargoGrp := ti.myCargoGroup;
			endif;
			if cargoGrp &lt;&gt; null then
				operator := cargoGrp.myOperator;
			endif;
		endif;
	endif;
		
	//consignee
	if  _jdo.getPropertyInfoByName(ETRow_Consignee,index,type,value) then
		if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then			//10.04.2024 navbs1 #63606
			consignee:= app.myRoot.allConsigneeConsignorsForDescr[value.String];
		else
			consignee:= app.myRoot.allConsigneeConsignors[value.String];
		endif;
		if consignee &lt;&gt; null then
			consigneeCode:=consignee.code;
			consigneeDesc:=consignee.description;
		endif;
	endif;	
	//consignor
	if  _jdo.getPropertyInfoByName(ETRow_Consignor,index,type,value) then
		if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then			//10.04.2024 navbs1 #63606
			consignor:= app.myRoot.allConsigneeConsignorsForDescr[value.String];
		else
			consignor:= app.myRoot.allConsigneeConsignors[value.String];
		endif;
		if consignor &lt;&gt; null then
			consignorCode:=consignor.code;
			consignorDesc:=consignor.description;
		endif;
	endif;	
	//destination port
	if  _jdo.getPropertyInfoByName(ETRow_DestinationPort,index,type,value) then
		destinationPort:=app.myRoot.allPorts[value.String];
	endif;
	//discharge port
	if  _jdo.getPropertyInfoByName(ETRow_DischargePort,index,type,value) then
		dischargePort:=app.myRoot.allPorts[value.String];
		
	endif;
	
	//--&gt; jlika1 TFS 63077
	//freight forwarder		
	if  _jdo.getPropertyInfoByName(ETRow_FreightForwarderCode,index,type,value) then
		ff:=app.myRoot.allConsigneeConsignors[value.String];
		if ff &lt;&gt; null then
			ffCode:=ff.code;
		endif;
	else 
		if _jdo.getPropertyInfoByName("allTrackedItems",index,type,trackedItemArray) then
			create tis transient;		
			if trackedItemArray.isKindOf(CM_TIByCargoTypeIdDict) then
				trackedItemArray.CM_TIByCargoTypeIdDict.copy(tis);
			endif;		
			
			if not tis.isEmpty then
				trackedItem := tis.first;
			endif;
			
			if trackedItem &lt;&gt; null then
				ff:=app.myRoot.allConsigneeConsignors[trackedItem.freightForwarderCode];
				if ff &lt;&gt; null then
					ffCode:=ff.code;
				endif;
			endif;		
		endif;		
	endif;
	//&lt;-- jlika1 TFS 63077
	
	//load port
	if  _jdo.getPropertyInfoByName(ETRow_LoadPort,index,type,value) then
		loadPort:=app.myRoot.allPorts[value.String];
	endif;
	if loadPort = null then
		loadPort:= app.myRoot.allPorts[_terminal.getConfig(PortDestCode).String];	
	endif;
	//voyage code
	if  _jdo.getPropertyInfoByName(ETRow_VoyageCode,index,type,value) then
		voyage:=_terminal.lookupVoyage(value.String,null,false);
		if voyage &lt;&gt; null then
			voyageCode:=voyage.code;
		endif;
	endif;	
	
	//booking ref
	if  _jdo.getPropertyInfoByName(ETRow_BookingRef,index,type,value) then
		bookingRef:=_terminal.getBookingReferenceExact(operatorCode, value.String,voyage);
	endif;
	
	if app.isSubTerminalsOn(_terminal) then
		defReleaseSubTerm 	:= _terminal.getDefaultSubTerminalForRel(relType);
		defTargetSubTerm 	:= _terminal.getConfig(MySubTerminalForTargetBulk).CM_SubTerminal;
	endif;
	
	
	create pxyBulkRelease transient;
	pxyBulkRelease.setProxy(null,relType,true,BR_ACTIVE,null,null,null,null,consigneeCode,consigneeDesc,
							consignorCode,consignorDesc,null,app.actualTimeServer,null,null,null,null,null,
							null,bookingRef,loadPort,destinationPort,dischargePort,ffCode,null,_terminal
							,operator,null,voyage,null,true,null,null,null,defReleaseSubTerm,defTargetSubTerm,null,false,null,
							false,false,false,false,null,null,null,
							RelReqContext_CargoGroupReview
							);
	return pxyBulkRelease;
epilog
	delete tis;
end;</source>
        <Parameter name="relType" type="Integer"/>
        <Parameter name="_jdo" type="JadeDynamicObject"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="createPxyReserveSelection" id="30a1ae24-c09f-4485-85a8-eb6b2c905b8e">
        <source>createPxyReserveSelection(_jdoArray : ObjectArray; _pxyBulkRelease: CM_BulkRelease input; _terminal : CM_Terminal);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 June 2023 	navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request
19 July 2023	jlizm1	TFS 58461 Change release mark number to string
24 November 2023 navmv20 Bug 61267: FR | EUP - Release Request by Type - Cargo Group &lt;&lt;53383&gt;&gt;
31 November 2023 navmv20 Bug 61502: FR | EUP - Release Request by Type - Cargo Group Change Defaults
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
07 Apr 2025 navrv30 JIRA 34239 Resolve Cargo Group being displayed from Grouping Criteria which doesnt have a Cargo Group
24/04/2025	navrv30	MTN 34319 EUP | Creating a Release Request from Cargo Review - Validation
*/

vars
	jdo : JadeDynamicObject;
	pxyBulkRelease	: CM_BulkRelease;
	index : Integer;
	type : Type;
	value : Any;
	undgCodes: String;
	operator : CM_Operator;
	receivedDT, releasedDT : TimeStamp;
	bol : CM_BOLIn;
	mark, markNumber,
	clientRef, orderNumber, purchaseOrder,
	remarks,vesselCode: String;
	iter : Iterator;
	ti : CM_TrackedItem;
	reserveSelection : CM_ReserveSelection;
	cargoGroup: CM_CargoGroup;
	colour : String;
	voyage : CM_Voyage;
	tisInGrouping : CM_TIByCargoTypeIdDict;
	
	cargoType : CM_CargoType;
	subCargoType : CM_Product;
	iso : CM_ISOType;
	bolCode : String;
	totalV, totalW : Decimal[23,4];
	totalQ : Integer;
	totalAvailable,
	totalReserved : Integer; //24/11/2023 navmv20 Bug 61267
	weightAvailable, volumeAvailable,
	weightReserved, volumeReserved : Decimal[23,4]; //24/11/2023 navmv20 Bug 61267
	commodity : CM_Commodity;
begin
	foreach jdo in _jdoArray as JadeDynamicObject do
	
		if   jdo.getPropertyInfoByName(ETRow_VoyageCode,index,type,value) then
			
			voyage := _terminal.allVoyagesByCode.getAtKeyGeq(value.String,null);
			if voyage &lt;&gt; null 
			and voyage.code &lt;&gt; value.String then
				voyage := null;
			endif;
		endif;
		
		if  jdo.getPropertyInfoByName(ETRow_BillOfLading,index,type,bolCode) then
			//if voyage &lt;&gt; null then //31/11/2023 navmv20 Bug 61502
			if voyage &lt;&gt; null and bolCode &lt;&gt; null then //31/11/2023 navmv20 Bug 61502
				bol := voyage.getBOL(bolCode.String);
			endif;
		endif;
		
		if   jdo.getPropertyInfoByName(ETRow_Mark,index,type,value) then
			mark:=value.String;
		endif;
		if   jdo.getPropertyInfoByName(ETRow_MarkNumber,index,type,value) then
			markNumber:=value.String;
		endif;
		if   jdo.getPropertyInfoByName(ETRow_ClientRef,index,type,value) then
			clientRef:=value.String;
		endif;
		if   jdo.getPropertyInfoByName(ETRow_OrderNumber,index,type,value) then
			orderNumber:=value.String;
		endif;
		if   jdo.getPropertyInfoByName(ETRow_PurchaseOrder,index,type,value) then
			purchaseOrder:=value.String;
		endif;
		receivedDT:=null;
		if   jdo.getPropertyInfoByName(ETRow_ReceivedDT,index,type,value) then
			if value.String &lt;&gt; null then
				receivedDT:=value.String.asTimeStampJMT;
			endif;
		endif;
		releasedDT:=null;
		if   jdo.getPropertyInfoByName(ETRow_ReleasedDT,index,type,value) then
			if value.String &lt;&gt; null then
				releasedDT:=value.String.asTimeStampJMT;
			endif;
		endif;
		if jdo.getPropertyInfoByName(ETRow_Remarks,index,type,value) then
			remarks:=value.String;
		endif;
		if jdo.getPropertyInfoByName(ETRow_Vessel,index,type,value) then
			vesselCode:=value.String;
		endif;
		if jdo.getPropertyInfoByName(ETRow_AllIMDGCodes,index,type,value) then
			undgCodes:=value.String;
		endif;
		
		if jdo.getPropertyInfoByName(ETRow_Colour,index,type,value) then
			colour := value.String;
		endif;

		if jdo.getPropertyInfoByName(CMIF_CargoReviewQuery.CargoReviewAllTrackedItems,index,type,value) then		
			tisInGrouping := value.CM_TIByCargoTypeIdDict;
			ti := tisInGrouping.first;
			iter:= tisInGrouping.createIterator;

			if ti &lt;&gt; null then
				cargoType := ti.myCargoType;
				subCargoType := ti.myProduct;
				if ti.isContainer then
					iso := ti.getISOTypeObject();
				endif;
				//07 Apr 2025 navrv30 JIRA 34239  Do not display cargo group/BOL information on the release request if
				//they are not part of the grouping criteria from the cargo review screen
				if self.allGroupingRows.getEntRowNamed(ETRow_BillOfLading) &lt;&gt; null then
					//if bol = null then //31/11/2023 navmv20 Bug 61502
					if bol = null and bolCode &lt;&gt; null then //31/11/2023 navmv20 Bug 61502
						if ti.myVoyage &lt;&gt; null then
							bol := ti.myVoyage.getBOL(bolCode);
						endif;
					endif;				
					if ti.myBOLDtl &lt;&gt; null then
						bol := ti.myBOLDtl.myBOL.CM_BOLIn;
					endif;
				endif;				
				if jdo.getPropertyInfoByName(ETRow_CargoGroupId,index,type,value) then
					cargoGroup := ti.myCargoGroup;
				endif;
				//24/04/2025	navrv30	MTN 34319
				if self.allGroupingRows.getEntRowNamed(ETRow_Commodity) &lt;&gt; null then
					if jdo.getPropertyInfoByName(ETRow_Commodity,index,type,value) then
						commodity := ti.getCommodityObject();
					endif;
				endif;
			endif;
		endif;
	
		create reserveSelection transient;
		reserveSelection.setProxy(null,cargoType,null,iso,null,subCargoType,null,null,
											0,null,false,false,false,null,0,colour,null,null,null,markNumber,0,null,0,0,0,mark,0,null,null,bol,false,null,
											null,null,null,null,null,false,false,clientRef,undgCodes,orderNumber,purchaseOrder,receivedDT,releasedDT,remarks,vesselCode,
											null,
											null,null,
											cargoGroup,
											false,				// 6/12/2023 navcs2 ChangeRequest 57537
											false,				//19/02/2023	navkc1 CR 60078 Task 62450
											commodity,			//24/04/2025	navrv30	MTN 34319
											null);
		reserveSelection.setMyHeader(_pxyBulkRelease);
		reserveSelection.setLineNumber(reserveSelection.myReserveHeader.getNextLineNumber(reserveSelection));
		self.createReserveExtraCriteria(reserveSelection,ti);
		
		totalQ := 0;
		totalW := 0;
		totalV := 0;
		
		while iter.next(ti) do
			if ti.isOnSiteOnShipPre() then //24/11/2023 navmv20 Bug 61267
				totalQ := totalQ +  ti.totalQuantity;
				totalW := totalW +  ti.totalWeight;
				totalV := totalV +  ti.totalVolume;
			endif; //24/11/2023 navmv20 Bug 612677
		endwhile;
		
		//24/11/2023 navmv20 Bug 61267 - start
		totalReserved := self.getRelReqReservedQty(jdo);  //06 Sep 2024 navrv30 Bug 65073
		totalAvailable := totalQ - totalReserved;
		weightReserved := self.getReserveWtWithSite(tisInGrouping);
		weightAvailable := totalW - weightReserved;
		volumeReserved := self.getReserveVolWithSite(tisInGrouping);
		volumeAvailable := totalV - volumeReserved;
		//reserveSelection.setWeightRequested(totalW);
		//reserveSelection.setTotalRequested(totalQ);
		if weightAvailable &gt;= 0 then
			reserveSelection.setWeightRequested(weightAvailable);
		endif;
		if totalAvailable &gt;= 0 then
			reserveSelection.setTotalRequested(totalAvailable);
		endif;
		
		//reserveSelection.setMeasurementValue(ETRow_MyVolume,totalV);
		if volumeAvailable &gt;= 0 then
			reserveSelection.setMeasurementValue(ETRow_MyVolume,volumeAvailable);
		endif;
		//24/11/2023 navmv20 Bug 61267 - end
	endforeach;
epilog

end;</source>
        <Parameter name="_jdoArray" type="ObjectArray"/>
        <Parameter name="_pxyBulkRelease" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="createReleaseReqForGroup" id="99cbb3d7-c6bc-4737-8392-a66c438a05ef">
        <source>createReleaseReqForGroup(relType : Integer; jdo : JadeDynamicObject input ) : CM_BulkRelease;


//28/06/2023 navmv20 CR 58410 Task 58411
// NO LONGER USED see createReleaseRequestForGroup


















/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 June 2022	jlier1	Initial creation
19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level																	
*/

vars
	pxyBulkRelease	: CM_BulkRelease;
	operator 	: CM_Operator;
	voyage 		: CM_Voyage;
	index : Integer;
	type : Type;
	value : Any;
	consignee, consignor,ff : CM_ConsigneeConsignor;
	destinationPort, loadPort, dischargePort : CM_Port;
	consigneeCode, consigneeDesc,
	consignorCode, consignorDesc,
	operatorCode, voyageCode,
	undgCodes: String;
	bol : CM_BOLIn;
	ffCode, mark, markNumber,
	clientRef, orderNumber, purchaseOrder,
	remarks,vesselCode: String;
	bookingRef : CM_BookingRef;
	iter : Iterator;
	ti : CM_TrackedItem;
	productTypeID, lastProductTypeID: String;
	allTisByCargoType : DynaDictionary;
	reserveSelection : CM_ReserveSelection;
	defReleaseSubTerm,
	defTargetSubTerm	: CM_SubTerminal;	
	receivedDT,
	releasedDT : TimeStamp;
	terminal : CM_Terminal;
begin
	terminal:=self.myEnqController.myTerminal;
	create allTisByCargoType transient;
	allTisByCargoType.setMembership(CM_TrackedItem);
	allTisByCargoType.addExternalKey(String,200,false,false);
	allTisByCargoType.endKeys(true);
	
	if jdo.getPropertyInfoByName(CMIF_CargoReviewQuery.CargoReviewAllTrackedItems,index,type,value) then		
		foreach ti in value.CM_TIByCargoTypeIdDict do 
			allTisByCargoType.putAtKey(ti.getProductOrISODescr,ti);
		endforeach; //.copy(allTisByCargoType);
	endif;
	
	
	if  allTisByCargoType.isEmpty then
		return null;
	endif;
	
	//get operator from grouping
	if  jdo.getPropertyInfoByName(ETRow_OperatorCode,index,type,value) then
		//it is the operatorCode 
		operator:=app.myRoot.allOperators[value.String];
		if operator &lt;&gt; null then
			operatorCode:=operator.code;
		// ### BUG 56533 21FEB2023 NAVAB1
		else
			operator := app.myRoot.getOperatorByDesc(value.String);
		endif;
	endif;	
	//consignee
	if  jdo.getPropertyInfoByName(ETRow_Consignee,index,type,value) then
		//it is the operatorCode 
		consignee:= app.myRoot.allConsigneeConsignors[value.String];
		if consignee &lt;&gt; null then
			consigneeCode:=consignee.code;
			consigneeDesc:=consignee.description;
		endif;
	endif;	
	//consginor
	if  jdo.getPropertyInfoByName(ETRow_Consignor,index,type,value) then
		//it is the operatorCode 
		consignor:=app.myRoot.allConsigneeConsignors[value.String];
		if consignor &lt;&gt; null then
			consignorCode:=consignor.code;
			consignorDesc:=consignor.description;
		endif;
	endif;	
	//destination
	if  jdo.getPropertyInfoByName(ETRow_DestinationPort,index,type,value) then
		//it is the operatorCode 
		destinationPort:=app.myRoot.allPorts[value.String];
	endif;
	//discharge port
	if  jdo.getPropertyInfoByName(ETRow_DischargePort,index,type,value) then
		//it is the operatorCode 
		dischargePort:=app.myRoot.allPorts[value.String];
		
	endif;
	//freight forewarder
	if  jdo.getPropertyInfoByName(ETRow_FreightForwarderCode,index,type,value) then
		//it is the operatorCode 
		ff:=app.myRoot.allConsigneeConsignors[value.String];
		if ff &lt;&gt; null then
			ffCode:=ff.code;
		endif;
	endif;
	//load port
	if  jdo.getPropertyInfoByName(ETRow_LoadPort,index,type,value) then
		//it is the operatorCode 
		loadPort:=app.myRoot.allPorts[value.String];
	endif;
	if loadPort = null then
		loadPort:= app.myRoot.allPorts[terminal.getConfig(PortDestCode).String];	
	endif;
	//voyage code
	if  jdo.getPropertyInfoByName(ETRow_VoyageCode,index,type,value) then
		voyage:=terminal.lookupVoyage(value.String,null,false);
		if voyage &lt;&gt; null then
			voyageCode:=voyage.code;
		endif;
	endif;	
	
	//booking ref
	if  jdo.getPropertyInfoByName(ETRow_BookingRef,index,type,value) then
		bookingRef:=terminal.getBookingReferenceExact(operatorCode, value.String,voyage);
	endif;
	
	if app.isSubTerminalsOn(terminal) then
		defReleaseSubTerm 	:= terminal.getDefaultSubTerminalForRel(relType);
		defTargetSubTerm 	:= terminal.getConfig(MySubTerminalForTargetBulk).CM_SubTerminal;
	endif;
	
	
	create pxyBulkRelease transient;
	pxyBulkRelease.setProxy(null,relType,true,BR_ACTIVE,null,null,null,null,consigneeCode,consigneeDesc,
							consignorCode,consignorDesc,null,app.actualTimeServer,null,null,null,null,null,
							null,bookingRef,loadPort,destinationPort,dischargePort,ffCode,null,terminal
							,operator,null,voyage,null,true,null,null,null,defReleaseSubTerm,defTargetSubTerm,null,true,null,
							false,false,false,false,null,null,null,
							RelReqContext_CargoGroupReview // ### TFS BUG 56530 21FEB2023 NAVAB1	// ### TFS 53953 27June2022 NAVPW1
							);
							
// ### TFS BUG 56530 21FEB2023 NAVAB1	pxyBulkRelease.setContext(RelReqContext_CargoGroupReview);
	
	if   jdo.getPropertyInfoByName(ETRow_BillOfLading,index,type,value) then
		if voyage &lt;&gt; null then
			bol:=voyage.getBOL(value.String);
		elseif allTisByCargoType.first.CM_TrackedItem.myVoyage &lt;&gt; null then
			bol:=allTisByCargoType.first.CM_TrackedItem.myVoyage.getBOL(value.String);
		endif;
	endif;
	
	if   jdo.getPropertyInfoByName(ETRow_Mark,index,type,value) then
		mark:=value.String;
	endif;
	if   jdo.getPropertyInfoByName(ETRow_MarkNumber,index,type,value) then
		markNumber:=value.String;
	endif;
	if   jdo.getPropertyInfoByName(ETRow_ClientRef,index,type,value) then
		clientRef:=value.String;
	endif;
	if   jdo.getPropertyInfoByName(ETRow_OrderNumber,index,type,value) then
		orderNumber:=value.String;
	endif;
	if   jdo.getPropertyInfoByName(ETRow_PurchaseOrder,index,type,value) then
		purchaseOrder:=value.String;
	endif;
	receivedDT:=null;
	if   jdo.getPropertyInfoByName(ETRow_ReceivedDT,index,type,value) then
		if value.String &lt;&gt; null then
			receivedDT:=value.String.asTimeStampJMT;
		endif;
	endif;
	releasedDT:=null;
	if   jdo.getPropertyInfoByName(ETRow_ReleasedDT,index,type,value) then
		if value.String &lt;&gt; null then
			releasedDT:=value.String.asTimeStampJMT;
		endif;
	endif;
	if jdo.getPropertyInfoByName(ETRow_Remarks,index,type,value) then
		remarks:=value.String;
	endif;
	if jdo.getPropertyInfoByName(ETRow_Vessel,index,type,value) then
		vesselCode:=value.String;
	endif;
	if jdo.getPropertyInfoByName(ETRow_AllIMDGCodes,index,type,value) then
		undgCodes:=value.String;
	endif;

	iter:=allTisByCargoType.createIterator;
	
	while iter.next(ti) do
		productTypeID:=iter.getCurrentKey(1).String;
		if productTypeID &lt;&gt; lastProductTypeID then
			create reserveSelection transient; 
			reserveSelection.setProxy(null,ti.myCargoType,null,ti.getISOTypeObject,null,ti.myProduct,null,null,
										0,null,false,false,false,null,0,null,null,null,null,markNumber,0,null,0,0,0,mark,0,null,null,bol,false,null,
										null,null,null,null,null,false,false,clientRef,undgCodes,orderNumber,purchaseOrder,receivedDT,releasedDT,remarks,vesselCode,
										null,	// ### TFS 53953 11July2022 NAVPW1
										null, null, null  //12-07-2022 navtnr20 53974
										, false,
										false, //19/02/2023	navkc1 CR 60078 Task 62450
										null, //24/04/2025	navrv30	MTN 34319
										null);
			reserveSelection.setMyHeader(pxyBulkRelease);						
			lastProductTypeID:=productTypeID;
					
			self.createReserveExtraCriteria(reserveSelection,ti);
		endif;
		reserveSelection.addTI(ti);
		/* // ### BUG 56533 21FEB2023 NAVAB1
		if ti.isBulkByWeight or ti.isBulkByVolume then
			reserveSelection.setWeightRequested(reserveSelection.totalRequested + ti.totalWeight);
		else
			reserveSelection.setTotalRequested(reserveSelection.totalRequested + ti.quantity);
		endif;
		*/
		
		 // ### BUG 56533 21FEB2023 NAVAB1 - Always show the weight and the quantity. When coming from the Cargo Review screen the Weight Requested is always shown.
		reserveSelection.setWeightRequested(reserveSelection.weightRequested + ti.totalWeight);
		reserveSelection.setTotalRequested(reserveSelection.totalRequested + ti.totalQuantity);
		
	endwhile;
	
	return pxyBulkRelease;
epilog
	delete allTisByCargoType;
	delete iter;
end;</source>
        <Parameter name="relType" type="Integer"/>
        <Parameter name="jdo" type="JadeDynamicObject" usage="input"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="createReleaseRequestForGroup" id="60b8a4da-7df0-410b-b8cd-224b5c28a7cb">
        <source>createReleaseRequestForGroup(_relType : Integer; _jdoArray : ObjectArray input) : CM_BulkRelease;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request																	
*/

vars
	pxyBulkRelease	: CM_BulkRelease;
	terminal : CM_Terminal;
	jdo : JadeDynamicObject;
begin
	terminal:=self.myEnqController.myTerminal;
	
	jdo := _jdoArray.first.JadeDynamicObject;
	
	pxyBulkRelease :=self.createPxyBulkRelease(_relType,jdo,terminal);
	self.createPxyReserveSelection(_jdoArray,pxyBulkRelease,terminal);
	
	return pxyBulkRelease;
epilog
end;</source>
        <Parameter name="_relType" type="Integer"/>
        <Parameter name="_jdoArray" type="ObjectArray" usage="input"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="createReserveExtraCriteria" id="c8371e12-c1db-4294-a79e-395c99fa8d90">
        <source>createReserveExtraCriteria(pxyReserveDetail : CM_ReserveSelection input; _ti : CM_TrackedItem input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 June 2022	jlier1	Initial creation

*/

vars
entTableRow : EntTableRow;
	yaCritTypeInt : Integer;
	yaCritType : CM_YACriteriaType;
	allCriteria				: CMIF_Array;
	tmpObjectSet : CM_ObjectSet;
	pxyObjMatch : CM_ReleaseByTypeCriteria;
begin
	create allCriteria transient;
	create tmpObjectSet transient;

	foreach entTableRow in self.allGroupingRows discreteLock do 
		yaCritTypeInt:=self.getYACriteriaTypeForRow(entTableRow.name);
		if yaCritTypeInt &lt;&gt; null then
			 yaCritType:=app.myRoot.allYACriteriaTypes[yaCritTypeInt];
			 if yaCritType &lt;&gt; null then
				_ti.setYardAllocationCriteriaType(yaCritType,allCriteria,tmpObjectSet);
			endif;
		endif;
	endforeach;
	
	if allCriteria.first &lt;&gt; null then
		create pxyObjMatch as CM_ReleaseByTypeCriteria transient;
		pxyObjMatch.setProxy( 	allCriteria,	0	);
		pxyObjMatch.setProxyBaseData(pxyReserveDetail);
	endif;
	allCriteria.purge();
	tmpObjectSet.clear;
epilog
	if allCriteria &lt;&gt; null then
		allCriteria.purge();
		delete allCriteria;
	endif;
	if tmpObjectSet &lt;&gt; null then
		delete tmpObjectSet;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pxyReserveDetail" type="CM_ReserveSelection" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="delete" id="c4f699ab-5bd0-4039-8b98-f47a39a992a0">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2022	jlier1	Initial creation 53515

*/

vars

begin
	
	delete self.myEnqController;
	self.deleteGroupings();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="deleteGroupings" id="6eecab1e-0014-46e9-8896-cf96d347e89f">
        <source>deleteGroupings();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2022	jlier1	Initial creation 53515
//15.07.2024 navrv30 Bug 65073: FR | 53383 - Cargo Group Reservation - part IV
06 Aug 2025 navrv30 MTN 35150 MTN | Unit Tests for Cargo Review Release Requests and COO Validation
*/

vars

begin
	if self.allGroupings &lt;&gt; null then
		self.allGroupings.purge;
		self.allGroupings.clear;
	endif;
	//15.07.2024 navrv30 Bug 65073
	if self.allReleaseGroupings &lt;&gt; null then
		self.allReleaseGroupings.purge;     //06 Aug 2025 navrv30 MTN 35150  - Handle leaks
		self.allReleaseGroupings.clear;
	endif;
	self.allTransients.purge;	
	self.allGroupedRelRequests.purge;
	self.allReleaseTransients.clear;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSearch" id="269b3f2a-5b46-4c95-ad49-2ddaf281fc6d">
        <updating/>
        <source>doSearch() : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2022	jlier1	Initial creation 53515

*/

vars
	startTime			: TimeStamp;
	
begin

		
	on CM_BreakOutException do app.myQAFilter.xHandlerBreakOut(exception);
	startTime := app.actualTimeServer;
	app.lockKeeperNotifyStartActivity(startTime, method, null, 'Selector criteria: ' &amp; self.myEnqController.myCriteriaLineHolder.getFullDescription(), app.myPassport);
	
	self.myEnqController.doQuery(null);	
	
	self.setAllGroupings();


epilog

	app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
	
	if app.myPassport.myCMIFMonitor &lt;&gt; null then
		return app.myPassport.myCMIFMonitor.monitorReturnValue;	
	else
		return null;
	endif;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDataFromCargoGroup" id="19dad985-e337-4b7e-9291-96c9e7243484">
        <source>getDataFromCargoGroup(attrName : String; _ti : CM_TrackedItem) : Boolean;
/*
Purpose:			

Date		Who		Reason
//18/09/2023 navmv20 Bug 60482: EUP | Cargo Review Quantity Columns
//23/04/2024 navra1  BUG 63499 - FR | 53383 - Cargo Group Reservation - part III
*/

vars

begin
	if _ti.myCargoGroup = null then
		return false;
	endif;
	
	//if attrName = ETRow_Reservations 								//navra1 - BUG 63499 - 22nd April 2024
	//or (_ti.myCargoGroup.allOwnershipChange.isNotEmpty			//navra1 - BUG 63499 - 22nd April 2024
	if (_ti.myCargoGroup.allOwnershipChange.isNotEmpty				//navra1 - BUG 63499 - 22nd April 2024
		and (attrName = ETRow_COONumber
			or attrName = ETRow_COODateTime
			or attrName = ETRow_COOINCOCode
			or attrName = ETRow_OperatorPreviousCode
			or attrName = ETRow_OperatorReceiveCode
			or attrName = ETRow_COOINCODesc
			or attrName = ETRow_OperatorPreviousDesc
			or attrName = ETRow_OperatorReceiveDesc
			or attrName = ETRow_OperatorStorageCode 
			or attrName = ETRow_OperatorStorageDesc 
			or attrName = ETRow_FreeDaysOperatorOld
			or attrName = ETRow_CooFreeDaysConfigered
			or attrName = ETRow_FreeDaysOperatorNew
			or attrName = ETRow_FreeStorageExpiryDate
			or attrName = ETRow_FutureStorageDate
			or attrName = ETRow_FreeDaysAdditional
			or attrName = ETRow_CustDocSequence))  // ### TFS CR 59942 TASK 59943 23AUG2023 NAVAB1
		 then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="attrName" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getGrouping" id="62a1c4dc-74b9-471e-a747-33bcd2b93a1b">
        <source>getGrouping(_name : String) : JadeDynamicObject protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2022	jlier1	Initial creation 53515
15/03/2023	navkc1	Bug 56481: EUP - 1035 Error (String Too Long) when trying to group the results with 20+ Grouping Criteria.
*/

vars
	jdo: JadeDynamicObject;	
begin

	//foreach jdo in  self.allGroupings discreteLock where jdo.name = _name  do // 15/03/2023	navkc1	#56481
	foreach jdo in  self.allGroupings discreteLock where jdo.getPropertyValue(GroupingName).String = _name  do	// 15/03/2023	navkc1	#56481
		return jdo;
	endforeach;

	return null;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
        <ReturnType type="JadeDynamicObject"/>
    </JadeMethod>
    <JadeMethod name="getRelReqReservedOffsite" id="e56a36c4-b39f-42f7-ae93-c23c597f29df">
        <source>getRelReqReservedOffsite(_grouping : JadeDynamicObject) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2025	navrv30	 MTN 35904 MTN | Cargo Review Quantities
Reserved Offsite- How many on a release request but off site. 
The quantity of cargo on matching release requests, that has been released. 
The opposite of above. Again, you don't need to do any cargo counts,
the release requests only need to be reviewed to see how much has been released.
*/

vars
	reserveDetail : CM_ReserveDetail;
	returnVal : Integer;	
	relGrouping : JadeDynamicObject;
	index : Integer;
	type : Type;
	value : Any;
	relValue : Any;
	relRequests : CM_ReserveDetailSet;
begin
	_grouping.getPropertyInfoByName(GroupingName,index,type,value);
	
	foreach  relGrouping in self.allReleaseGroupings do
		relGrouping.getPropertyInfoByName(GroupingName,index,type,relValue);
		if relValue = value then
			relRequests:=relGrouping.getPropertyValue(CargoReviewAllRelReqs).CM_ReserveDetailSet;
			foreach reserveDetail in relRequests do	
				returnVal := returnVal + reserveDetail.getTotalReleased();
			endforeach;
		endif;
	endforeach;	
	return returnVal;

epilog

end;</source>
        <Parameter name="_grouping" type="JadeDynamicObject"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRelReqReservedPending" id="7c172e0d-9f0f-453c-9cd7-9a7fb8d92bc6">
        <source>getRelReqReservedPending(_grouping : JadeDynamicObject) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2025	navrv30	 MTN 35904 MTN | Cargo Review Quantities
Reserved Pending- How many on a release request but still onsite. 
The quantity of cargo on matching release requests, that is yet to be released. 
Again, you don't to look at the cargo items on site, 
just the release request and see how many of the total is not yet fulfilled.
*/

vars
	reserveDetail : CM_ReserveDetail;
	returnVal : Integer;	
	relGrouping : JadeDynamicObject;
	index : Integer;
	type : Type;
	value : Any;
	relValue : Any;
	relRequests : CM_ReserveDetailSet;
begin
	_grouping.getPropertyInfoByName(GroupingName,index,type,value);
	
	foreach  relGrouping in self.allReleaseGroupings do
		relGrouping.getPropertyInfoByName(GroupingName,index,type,relValue);
		if relValue = value then
			relRequests:=relGrouping.getPropertyValue(CargoReviewAllRelReqs).CM_ReserveDetailSet;
			foreach reserveDetail in relRequests do	
				//04/07/2025 navrv30	MTN 35029
				if reserveDetail.myReserveHeader.status = BR_COMPLETE then
					continue;
				endif;
				returnVal := returnVal + reserveDetail.totalRequested;
				returnVal := returnVal - reserveDetail.getTotalReleased();
			endforeach;
		endif;
	endforeach;	
	return returnVal;

epilog

end;</source>
        <Parameter name="_grouping" type="JadeDynamicObject"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRelReqReservedPotential" id="34d24566-87b2-403e-944b-96fe7f571d50">
        <source>getRelReqReservedPotential(_grouping : JadeDynamicObject) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2025	navrv30	 MTN 35904 MTN | Cargo Review Quantities
Reserved Potential - How many not on a release request at 
all but match the grouping (this would only be on site stuff).
*/

vars	
	quantityTotal, reservedTotal : Integer;
	value : Any;
	index : Integer;
	type : Type;
begin
	_grouping.getPropertyInfoByName(ETRow_TotalQuantity,index,type,value);
	quantityTotal := value.Integer;
	_grouping.getPropertyInfoByName(ETRow_ReservedTotal,index,type,value);
	reservedTotal := value.Integer;
	return quantityTotal - reservedTotal;
epilog

end;</source>
        <Parameter name="_grouping" type="JadeDynamicObject"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRelReqReservedQty" id="5a6a22f2-1c4e-4ead-8261-1050cb88c74e">
        <source>getRelReqReservedQty(_grouping : JadeDynamicObject) : Integer;
/*
Purpose:			

Date		Who		Reason
21 February 2023	navab1 TFS BUG 56530 21FEB2023 NAVAB1
//15.07.2024 navrv30 Bug 65073: FR | 53383 - Cargo Group Reservation - part IV
*/

vars
	reserveDetail : CM_ReserveDetail;
	returnVal : Integer;	
	relGrouping : JadeDynamicObject;
	index : Integer;
	type : Type;
	value : Any;
	relValue : Any;
	relRequests : CM_ReserveDetailSet;
begin
	_grouping.getPropertyInfoByName(GroupingName,index,type,value);
	
	foreach  relGrouping in self.allReleaseGroupings do
		relGrouping.getPropertyInfoByName(GroupingName,index,type,relValue);
		if relValue = value then
			relRequests:=relGrouping.getPropertyValue(CargoReviewAllRelReqs).CM_ReserveDetailSet;
			foreach reserveDetail in relRequests do	
				//04/07/2025 navrv30	MTN 35029
				if reserveDetail.myReserveHeader.status = BR_COMPLETE then
					continue;
				endif;
				returnVal  := returnVal + reserveDetail.totalRequested;
			endforeach;
		endif;
	endforeach;	
	return returnVal;

epilog

end;</source>
        <Parameter name="_grouping" type="JadeDynamicObject"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRelReqReservedTotal" id="80c1e724-4311-4ac0-8bc0-a36a7fd29ee1">
        <source>getRelReqReservedTotal(_grouping : JadeDynamicObject) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2025	navrv30	 MTN 35904 MTN | Cargo Review Quantities
Reserved Total - How many on a release request matching the grouping wherever they are.
It is looking at release requests only, looks at the grouping and says, 
"This is how many cargo items have been reserved on all the release requests that match the grouping".

*/
vars
	reserveDetail : CM_ReserveDetail;
	returnVal : Integer;	
	relGrouping : JadeDynamicObject;
	index : Integer;
	type : Type;
	value : Any;
	relValue : Any;
	relRequests : CM_ReserveDetailSet;
begin
	_grouping.getPropertyInfoByName(GroupingName,index,type,value);
	
	foreach  relGrouping in self.allReleaseGroupings do
		relGrouping.getPropertyInfoByName(GroupingName,index,type,relValue);
		if relValue = value then
			relRequests:=relGrouping.getPropertyValue(CargoReviewAllRelReqs).CM_ReserveDetailSet;
			foreach reserveDetail in relRequests do					
				returnVal := returnVal + reserveDetail.totalRequested;
			endforeach;
		endif;
	endforeach;	
	return returnVal;

epilog

end;</source>
        <Parameter name="_grouping" type="JadeDynamicObject"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRelReqReservedWeight" id="b2575fca-263a-433d-a759-9e648592d4a1">
        <source>getRelReqReservedWeight(_tis : CM_TIByCargoTypeIdDict) : Decimal;
/*
Purpose:			

Date		Who		Reason
21 February 2023	navab1 TFS BUG 56530 21FEB2023 NAVAB1
*/

vars
	ti : CM_TrackedItem;
	totReq : Decimal[23,4];
	bulkReleases : CM_BulkReleaseSet;
	bulkRelease : CM_BulkRelease;
	cg : CM_CargoGroup;
	reserveSelection : CM_ReserveSelection;
begin
	 //05/07/2023 navmv20 CR 58410 Task 58414 - use the cargo group reference
	ti := _tis.first;
	if ti &lt;&gt; null then
		cg := ti.myCargoGroup;
		if cg &lt;&gt; null then
			foreach reserveSelection in ti.myCargoGroup.allReserveDetailAssigned as CM_ReserveSelection discreteLock do
				totReq := totReq + reserveSelection.weightRequested;
			endforeach;	
		else

			create bulkReleases transient;
			foreach ti in _tis discreteLock do
				foreach bulkRelease in ti.allBulkReleasesAssigned discreteLock do
					if not bulkReleases.includes(bulkRelease) then
						bulkReleases.add(bulkRelease);
					endif;
				endforeach;
			
			endforeach;
			
			foreach bulkRelease in bulkReleases discreteLock do
				totReq := totReq + bulkRelease.getWeightRequested();
			endforeach;
		endif;
	endif;
	return totReq;
epilog
	delete bulkReleases;
end;</source>
        <Parameter name="_tis" type="CM_TIByCargoTypeIdDict"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getReleaseGrouping" id="c2af991e-7472-4612-a84e-39c30cd6920b">
        <source>getReleaseGrouping(_name : String) : JadeDynamicObject protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//15.07.2024 navrv30 Bug 65073: FR | 53383 - Cargo Group Reservation - part IV
*/

vars
	jdo: JadeDynamicObject;	
begin

	foreach jdo in  self.allReleaseGroupings discreteLock do //where jdo.getPropertyValue(ReleaseGroupingName).String = _name  do
		if jdo.getPropertyValue(GroupingName).String = _name then
			return jdo;
		endif;
	endforeach;

	return null;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
        <ReturnType type="JadeDynamicObject"/>
    </JadeMethod>
    <JadeMethod name="getResFrmCGBOLVoyOrBooking" id="f503a378-12dc-42c0-ac3a-20504c67876f">
        <source>getResFrmCGBOLVoyOrBooking(	_ti : CM_TrackedItem; 
							_grouping : JadeDynamicObject		//21/05/2024	navkc1 Bug 64182
							
							) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2024 navra1 - BUG 63499 - FR | 53383 - Cargo Group Reservation - part III
//15.07.2024 navrv30 Bug 65073: FR | 53383 - Cargo Group Reservation - part IV
*/

vars
	reserveDetail : CM_ReserveDetail;
	returnStr : String;	
	relGrouping : JadeDynamicObject;
	index : Integer;
	type : Type;
	value : Any;
	relValue : Any;
	relRequests : CM_ReserveDetailSet;
begin
	_grouping.getPropertyInfoByName(GroupingName,index,type,value);
	
	foreach  relGrouping in self.allReleaseGroupings do
		relGrouping.getPropertyInfoByName(GroupingName,index,type,relValue);
		if relValue = value then
			relRequests:=relGrouping.getPropertyValue(CargoReviewAllRelReqs).CM_ReserveDetailSet;
			foreach reserveDetail in relRequests do
				if returnStr = null then
					returnStr := returnStr &amp; reserveDetail.myReserveHeader.code &amp; "(" &amp; reserveDetail.totalRequested.String &amp; ")";
				else 
					returnStr := returnStr &amp; Comma &amp; reserveDetail.myReserveHeader.code &amp; "(" &amp; reserveDetail.totalRequested.String &amp; ")";
				endif;
			endforeach;
		endif;
	endforeach;	
	return returnStr;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_grouping" type="JadeDynamicObject"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getResStrFrmResDetSet" id="17a4d1bf-28a9-4918-a673-f1fdd9dbdd95">
        <source>getResStrFrmResDetSet(	_reserveDetailSet : CM_ReserveDetailSet;
						_ti : CM_TrackedItem;
						_grouping : JadeDynamicObject //21/05/2024	navkc1 Bug 64182
						) : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 April 2024 navra1 - BUG 63499 - FR | 53383 - Cargo Group Reservation - part III

*/

vars
	reserveDetail : CM_ReserveDetail;
	returnStr : String;
	reserveHeader : CM_BulkRelease;
	detailCode : String;
	includeReserveHeader : Boolean;

begin
	foreach reserveDetail in _reserveDetailSet do	
		reserveHeader := reserveDetail.myReserveHeader;
		
		//21/05/2024	navkc1 Bug 64182 - When displaying the "Reserves" column in the Group table, we want to match the JDO with existing Release Request so that the column displays the correct release requests
		if not self.isReleaseRequestMatchGrouping(reserveHeader, reserveDetail, _grouping) then
			continue;
		endif;
		
		if reserveHeader.releaseByType then
			if reserveHeader.getMatchingReserveSelection(_ti) &lt;&gt; null then
				includeReserveHeader := true;				
			endif;
		else
			if reserveHeader.getReserveTIforTI(_ti) &lt;&gt; null then
				includeReserveHeader := true;				
			endif;
		endif;
		
		if includeReserveHeader then
			detailCode := reserveHeader.code;
			if detailCode&lt;&gt; null then
				if returnStr.pos(detailCode,1) = 0 then
					if returnStr = null then
						returnStr := detailCode &amp; " (" &amp; reserveDetail.totalRequested.asStringJMT() &amp; ")" ; //24/11/2023 navmv20 Bug 61267
					else
						returnStr := returnStr &amp; ", " &amp; detailCode &amp; " (" &amp; reserveDetail.totalRequested.asStringJMT() &amp; ")" ; //24/11/2023 navmv20 Bug 61267
					endif;
				endif;
			endif;
			
			includeReserveHeader := false;		//reset the flag for the next iteration
		endif;
	endforeach;
			
	return returnStr;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_reserveDetailSet" type="CM_ReserveDetailSet"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_grouping" type="JadeDynamicObject"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReserveQtyWithSite" id="44511bec-b1d0-4e01-968c-45f3a169dd02">
        <source>getReserveQtyWithSite(_tis : CM_TIByCargoTypeIdDict) : Integer;
/*
Purpose:			

Date		Who		Reason
24 November 2023 navmv20 Bug 61267: FR | EUP - Release Request by Type - Cargo Group &lt;&lt;53383&gt;&gt;
*/

vars
	ti : CM_TrackedItem;
	totReq : Integer;
	bulkReleases : CM_BulkReleaseSet;
	bulkRelease : CM_BulkRelease;
	cg : CM_CargoGroup;
	reserveSelection : CM_ReserveSelection;
begin

	ti := _tis.first;
	if ti &lt;&gt; null then
		cg := ti.myCargoGroup;
		if cg &lt;&gt; null then
			foreach reserveSelection in ti.myCargoGroup.allReserveDetailAssigned as CM_ReserveSelection discreteLock where ti.isOnSiteOnShipPre() do
				totReq := totReq + reserveSelection.totalRequested;
			endforeach;	
		else
			create bulkReleases transient;
			foreach ti in _tis discreteLock where ti.isOnSiteOnShipPre() do
				foreach bulkRelease in ti.allBulkReleasesAssigned discreteLock do
					if not bulkReleases.includes(bulkRelease) then
						bulkReleases.add(bulkRelease);
					endif;
				endforeach;	
			endforeach;
			foreach bulkRelease in bulkReleases discreteLock do
				totReq := totReq + bulkRelease.totalRequested;
			endforeach;
		
		endif;
	endif;
	
	return totReq;
epilog
	delete bulkReleases;
end;</source>
        <Parameter name="_tis" type="CM_TIByCargoTypeIdDict"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getReserveVolWithSite" id="f360f1ba-7499-44c6-8c39-32b19b5f27ca">
        <source>getReserveVolWithSite(_tis : CM_TIByCargoTypeIdDict) : Decimal;
/*
Purpose:			

Date		Who		Reason
24 November 2023 navmv20 Bug 61267: FR | EUP - Release Request by Type - Cargo Group &lt;&lt;53383&gt;&gt;
*/

vars
	ti : CM_TrackedItem;
	myVolume,
	density      : Decimal[23,4];
	bulkReleases : CM_BulkReleaseSet;
	bulkRelease : CM_BulkRelease;
	cg : CM_CargoGroup;
	reserveSelection : CM_ReserveSelection;
	reserveDetail : CM_ReserveDetail;
begin

	ti := _tis.first;
	if ti &lt;&gt; null then
		cg := ti.myCargoGroup;
		if cg &lt;&gt; null then
			foreach reserveSelection in ti.myCargoGroup.allReserveDetailAssigned as CM_ReserveSelection discreteLock where ti.isOnSiteOnShipPre() do
				density:= reserveSelection.getDensity();
				if density = 0 then
					density := 1;
				endif;
				myVolume := myVolume + (reserveSelection.weightRequested/density);
			endforeach;	
		else
			create bulkReleases transient;
			foreach ti in _tis discreteLock where ti.isOnSiteOnShipPre() do
				foreach bulkRelease in ti.allBulkReleasesAssigned discreteLock do
					if not bulkReleases.includes(bulkRelease) then
						bulkReleases.add(bulkRelease);
					endif;
				endforeach;	
			endforeach;
			foreach bulkRelease in bulkReleases discreteLock do
				
				if reserveDetail.isKindOf(CM_ReserveSelection) then
					density:= reserveDetail.getDensity();
				else
					density:= ti.getDensity();
				endif;
				if density = 0 then
					density := 1;
				endif;
				foreach reserveDetail in bulkRelease.allReserveDetails do
					myVolume := myVolume + (reserveDetail.weightRequested /density);
				endforeach;
			endforeach;
		
		endif;
	endif;
	
	return myVolume;
epilog
	delete bulkReleases;
end;</source>
        <Parameter name="_tis" type="CM_TIByCargoTypeIdDict"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getReserveWtWithSite" id="75247080-f3ac-4c10-9b9a-d58cb5f45929">
        <source>getReserveWtWithSite(_tis : CM_TIByCargoTypeIdDict) : Decimal;
/*
Purpose:			

Date		Who		Reason
24 November 2023 navmv20 Bug 61267: FR | EUP - Release Request by Type - Cargo Group &lt;&lt;53383&gt;&gt;
*/

vars
	ti : CM_TrackedItem;
	weightRequested : Decimal[23,4];
	bulkReleases : CM_BulkReleaseSet;
	bulkRelease : CM_BulkRelease;
	cg : CM_CargoGroup;
	reserveSelection : CM_ReserveSelection;
begin

	ti := _tis.first;
	if ti &lt;&gt; null then
		cg := ti.myCargoGroup;
		if cg &lt;&gt; null then
			foreach reserveSelection in ti.myCargoGroup.allReserveDetailAssigned as CM_ReserveSelection discreteLock where ti.isOnSiteOnShipPre() do
				weightRequested := weightRequested + reserveSelection.weightRequested;
			endforeach;	
		else
			create bulkReleases transient;
			foreach ti in _tis discreteLock where ti.isOnSiteOnShipPre() do
				foreach bulkRelease in ti.allBulkReleasesAssigned discreteLock do
					if not bulkReleases.includes(bulkRelease) then
						bulkReleases.add(bulkRelease);
					endif;
				endforeach;	
			endforeach;
			foreach bulkRelease in bulkReleases discreteLock do
				weightRequested := weightRequested + bulkRelease.getWeightRequested();
			endforeach;
		
		endif;
	endif;
	
	return weightRequested;
epilog
	delete bulkReleases;
end;</source>
        <Parameter name="_tis" type="CM_TIByCargoTypeIdDict"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getReservedQtyMode" id="4d82eee5-fae0-4355-a57d-65a8ee5956ec">
        <source>getReservedQtyMode(_grouping : JadeDynamicObject; _mode : Integer ) : Integer;
/*
Purpose:			

Date		Who		Reason
24 November 2023 navmv20 Bug 61267: FR | EUP - Release Request by Type - Cargo Group &lt;&lt;53383&gt;&gt;
//15.07.2024 navrv30 Bug 65073: FR | 53383 - Cargo Group Reservation - part IV
*/

vars
	reserveDetail : CM_ReserveDetail;
	returnVal : Integer;	
	relGrouping : JadeDynamicObject;
	index : Integer;
	type : Type;
	value : Any;
	relValue : Any;
	relRequests : CM_ReserveDetailSet;
begin
	_grouping.getPropertyInfoByName(GroupingName,index,type,value);
	
	foreach  relGrouping in self.allReleaseGroupings do
		relGrouping.getPropertyInfoByName(GroupingName,index,type,relValue);
		if relValue = value then
			relRequests:=relGrouping.getPropertyValue(CargoReviewAllRelReqs).CM_ReserveDetailSet;
			foreach reserveDetail in relRequests do
				if reserveDetail.myReserveHeader.type = _mode then
					returnVal  := returnVal + reserveDetail.totalRequested;
				endif;
			endforeach;
		endif;
	endforeach;	
	return returnVal;

epilog

end;</source>
        <Parameter name="_grouping" type="JadeDynamicObject"/>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getReservedWtMode" id="2ad57d0c-b15e-4359-84ea-0c78044d643d">
        <source>getReservedWtMode(_tis : CM_TIByCargoTypeIdDict; _mode : Integer) : Decimal;
/*
Purpose:			

Date		Who		Reason
24 November 2023 navmv20 Bug 61267: FR | EUP - Release Request by Type - Cargo Group &lt;&lt;53383&gt;&gt;
*/

vars
	ti : CM_TrackedItem;
	totReq : Decimal[23,4];
	bulkReleases : CM_BulkReleaseSet;
	bulkRelease : CM_BulkRelease;
	cg : CM_CargoGroup;
	reserveSelection : CM_ReserveSelection;
begin
	
	ti := _tis.first;
	if ti &lt;&gt; null then
		cg := ti.myCargoGroup;
		if cg &lt;&gt; null then
			foreach reserveSelection in ti.myCargoGroup.allReserveDetailAssigned as CM_ReserveSelection discreteLock do
				bulkRelease := reserveSelection.myReserveHeader;
				if bulkRelease.type = _mode then
					totReq := totReq + reserveSelection.weightRequested;
				endif;
			endforeach;	
		else

			create bulkReleases transient;
			foreach ti in _tis discreteLock do
				foreach bulkRelease in ti.allBulkReleasesAssigned discreteLock where bulkRelease.type = _mode do
					if not bulkReleases.includes(bulkRelease) then
						bulkReleases.add(bulkRelease);
					endif;
				endforeach;
			
			endforeach;
			
			foreach bulkRelease in bulkReleases discreteLock do
				totReq := totReq + bulkRelease.getWeightRequested();
			endforeach;
		endif;
	endif;
	return totReq;
epilog
	delete bulkReleases;
end;</source>
        <Parameter name="_tis" type="CM_TIByCargoTypeIdDict"/>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getUniqueGroupingName" id="76cd6c11-d1ed-47c8-a096-b839dff0eaaa">
        <source>getUniqueGroupingName(_ti : CM_TrackedItem) : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2022	jlier1	Initial creation 53515

*/

vars
	entTableRow : EntTableRow;
	attrVal,
	keyStr: String;
begin
	foreach entTableRow in self.allGroupingRows discreteLock do
		
		attrVal := _ti.getDisplayStringForAttribute(entTableRow.name,false);
		if attrVal = null then
			attrVal:="NULL";
		endif;
		
		keyStr :=  keyStr &amp; attrVal.String.trimBlankCharacters();

	endforeach;
	
	
	return keyStr;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
