    <JadeMethod name="deleteVoyageJobSheet" id="ffe2d0ab-d876-49d6-aaf4-632c9feb8155">
        <source>deleteVoyageJobSheet(_jobSheet : CM_VoyageJobSheet io);
/*

Purpose:		Delete a voyage job sheet	

Parameters:			

Return Value:		

Date		Who		Reason
04/12/2017	jlgmh5	Initial creation

*/

vars

	realVJob				: CM_VoyageJob;
	queueEntry				: CM_RTQueueEntry;


begin

	foreach	realVJob in _jobSheet.allJobsByJobNum do
		foreach queueEntry in realVJob.allEntries do
			beginTransaction;
				queueEntry.allTasks.purge;
			commitTransaction;
		endforeach;
		beginTransaction;
			realVJob.allEntries.purge;
			realVJob.workListEntries.purge;
		commitTransaction;
		self.loadVoyJobToOps(realVJob, false, false);
		app.myTrxDA.trxDeleteVoyageJob(realVJob, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endforeach; 
	
	if _jobSheet &lt;&gt; null then
		beginTransaction;
		_jobSheet.erase(NORMAL_ERASE);
		commitTransaction;	
	endif;
	
	

epilog

end;</source>
        <Parameter name="_jobSheet" type="CM_VoyageJobSheet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="deleteVoyageJobTransferType" id="427c60a8-7feb-4b1c-bb8a-a2c0c1f47fb1">
        <source>deleteVoyageJobTransferType( _desc : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2019	jlgndl1	Initial creation	TFS 44773

*/

vars

	type : CM_VoyageJobTransferType;
	obj : CM_Object;

begin

	type := app.myRoot.allVoyageJobTransferTypes.getMatchesDescription( _desc );
	if type = null then
		return;
	endif;
	if type.id &lt; 10000 then
		// don't delete system created ones
		return;
	endif;

	obj := type;
		
	app.myTrxDA.trxDeleteCMObject( obj, app.myPassport );

epilog

end;</source>
        <Parameter name="_desc" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteVoyageJobs" id="9ff07504-b43e-42de-9110-88a4ec2cc83d">
        <source>deleteVoyageJobs(_voyage : CM_Voyage) ;

vars
	jobSheet : CM_VoyageJobSheet;
	theRealVJob : CM_VoyageJob;
	queueEntry: CM_RTQueueEntry;
	queueTask: CM_RTQueueTask;
begin
	foreach jobSheet in _voyage.allJobSheets do
		foreach	theRealVJob in jobSheet.allJobsByJobNum do
			foreach queueEntry in theRealVJob.allEntries do
				beginTransaction;
					queueEntry.allTasks.purge;
				commitTransaction;
			endforeach;
			beginTransaction;
				theRealVJob.allEntries.purge;
				theRealVJob.workListEntries.purge;
			commitTransaction;
			self.loadVoyJobToOps(theRealVJob, false, false);
			app.myTrxDA.trxDeleteVoyageJob(theRealVJob, app.myPassport);
			//self.assertNoTrxErrorsOrWarnings();
		endforeach;
	endforeach;

epilog

end;</source>
