Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 May 2009	cnwrd1	Initial creation

*/

vars
	
begin
	inheritMethod();
	
	self.centreWindow();
		
	self.setupBookingRefTable();

epilog

end;</source>
    </JadeMethod>
