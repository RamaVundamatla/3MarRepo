    <DbClassMap file="jssfm_default"/>
    <Constant name="COPY_CHUNK_SIZE" id="1d7fb77a-55df-4ea9-aa63-129463ca17d0">
        <source>500000</source>
        <type name="Decimal"/>
        <text>When files are copied between nodes, they will be copied in small chunks of binary
data to prevent overflowing the object cache.  This constant represents the number
of bytes for each chunk.</text>
    </Constant>
