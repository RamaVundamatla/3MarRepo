    <JadeMethod name="convertToArabic" id="67ce99fd-00d4-4926-9fd0-c98d75840a0c">
        <source>convertToArabic(_amount : Decimal; _currencyCode : StringUtf8):StringUtf8;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Nov 2021 navma1	ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements

*/

vars
	excOccurred		: Boolean;
	returnVal		: StringUtf8;
begin
	if not app.isUnicode then
		return null;
	endif;
	
	on Exception do self.handleExceptions(exception, excOccurred);
	returnVal := self.myNumberToArabicWords.convertToArabic(_amount ,_currencyCode);
	
	return returnVal;
epilog

end;</source>
        <Parameter name="_amount" type="Decimal"/>
        <Parameter name="_currencyCode" type="StringUtf8"/>
        <ReturnType type="StringUtf8"/>
    </JadeMethod>
    <JadeMethod name="create" id="ac599eb2-75b8-4ca5-9221-37049805d977">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Nov 2021 navma1	ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements

*/

vars
	hadException	: Boolean;
begin
	on Exception do self.handleExceptions(exception, hadException);
	
	create self.myNumberToArabicWords transient;
	if self.myNumberToArabicWords &lt;&gt; null then
		self.myNumberToArabicWords.usePresentationClient := self.usePresentationClient;
	endif;
epilog

end;</source>
    </JadeMethod>
