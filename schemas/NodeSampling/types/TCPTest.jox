    <JadeMethod name="checkForCacheCoherency" id="715aedca-fb8b-4a9b-ab8f-010f8e1d5f35">
        <updating/>
        <source>checkForCacheCoherency() : Boolean updating;

vars
	appServerCacheCoherency       : Boolean;
	dbServerCacheCoherency        : Boolean;
	dbServerCacheCoherencyDefault : Boolean;
	appServerCacheCoherencyData   : String;
	appServerIni                  : String;
	dbServerIni                   : String;
	valid                         : Boolean;
	myNode                        : Node;
	log                           : JadeLog;

begin
	//
	// Single thread to ensure only 1 sharedTransient
	//
	lock(system, Reserve_Lock, Transaction_Duration, LockTimeout_Infinite);
	myNode := Node.firstSharedTransientInstance;
	if myNode &lt;&gt; null then
		if myNode.name = 'CacheCoherencyOn' then
			return true;
		endif;
		if myNode.name = 'CacheCoherencyOff' then
			return false;
		endif;
	endif;
	//
	// Check Server Node
	//
	valid := checkForCacheCoherencyOnServer(dbServerCacheCoherency, dbServerCacheCoherencyDefault, dbServerIni);
	if valid = false then
		if app.applicationType = ApplicationType_GUI then
			app.msgBox('Invalid Cache Coherency parameter in Server ini file' &amp; CrLf &amp; dbServerIni, app.name, MsgBox_OK_Only);
		else
			create log transient;
			//
			// Persuade Jade to let me log this in the jommsg.log
			//
			log.fileName := #'00 30';
			log.log(app.name &amp; ' - Invalid Cache Coherency parameter in Server ini file - ' &amp;  dbServerIni);

		endif;
		return false;
	endif;
	//
	// Check our Node
	//
	appServerIni                := app.getIniFileNameAppServer;
	appServerCacheCoherencyData := app.getProfileStringAppServer(appServerIni, "JadeClient", "AutomaticCacheCoherency", "empty").toLower;
	if appServerCacheCoherencyData = 'true' then
		appServerCacheCoherency := true;
	elseif appServerCacheCoherencyData = 'false' then
		appServerCacheCoherency := false;
	elseif appServerCacheCoherencyData = 'serverdefault' then
		appServerCacheCoherency := dbServerCacheCoherencyDefault;
	else
		if app.applicationType = ApplicationType_GUI then
			app.msgBox('Invalid Cache Coherency parameter' &amp; CrLf &amp; '"' &amp; appServerCacheCoherencyData &amp; '"' &amp; CrLf &amp;
			           'in Client ini file' &amp; CrLf &amp; appServerIni, app.name, MsgBox_OK_Only);
		else
			create log transient;
			log.fileName := #'00 30';
			log.log(app.name &amp; ' - Invalid Cache Coherency parameter in Server ini file - ' &amp;  '"' &amp; 
					appServerCacheCoherencyData &amp; '"' &amp; ' in Client ini file ' &amp; appServerIni);
		endif;
		return false;
	endif;
	//
	// All is valid with the ini files (not Necessarily on) so now create the shared transient - 
	// this is many times quicker than looking in the ini file each time
	//
	beginTransientTransaction;
	create myNode sharedTransient;
	if appServerCacheCoherency = true and dbServerCacheCoherency = true then
		//
		// On in both the server and our Node
		//
		myNode.setPropertyValue ('name', 'CacheCoherencyOn');
		commitTransientTransaction;
		return true;
	else
		//
		// Not on in both the server and our Node
		//
		myNode.setPropertyValue ('name', 'CacheCoherencyOff');
		commitTransientTransaction;
		return false;
	endif;
epilog

	unlock(system);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkForCacheCoherencyOnServer" id="5cfdea40-d2e1-4181-b371-99558aa081c6">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>checkForCacheCoherencyOnServer(_server : Boolean io; _serverDefault : Boolean io;
                               _dbServerIni : String io) : Boolean serverExecution, updating;

vars
	serverDefault : String;
	serverCacheCoherency : String;
	valid         : Boolean;
begin
	valid         := true;
	_dbServerIni  := app.getIniFileName;
	serverDefault := app.getProfileString(_dbServerIni, "JadeServer", "AutomaticCacheCoherencyDefault", "false").toLower;
	serverCacheCoherency := app.getProfileString(_dbServerIni, "JadeServer", "AutomaticCacheCoherency", "empty").toLower;
	if serverDefault = 'true' then
		_serverDefault := true;
	elseif serverDefault = 'false' then
		_serverDefault := false;
	else
		valid := false;
	endif;
	if serverCacheCoherency = 'serverdefault' then
		_server := _serverDefault;
	elseif serverCacheCoherency = 'true' then
		_server := true;
	elseif serverCacheCoherency = 'false' then
		_server := false;
	else
		valid := false;	
	endif;
	return valid;
end;</source>
        <Parameter name="_server" type="Boolean" usage="io"/>
        <Parameter name="_serverDefault" type="Boolean" usage="io"/>
        <Parameter name="_dbServerIni" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getMachineMemorySize" id="f9a2228c-a776-43d7-81af-c1e519ebdc9a">
        <updating/>
        <source>getMachineMemorySize() : Integer updating;

vars
	lngMemoryLoad    : Integer;
	lngTotalPhys     : Integer;
	lngAvailPhys     : Integer;
	lngTotalPageFile : Integer;
	lngAvailPageFile : Integer;
	lngTotalVirtual  : Integer;
	lngAvailVirtual  : Integer;

	memoryStructure  : Binary;

begin
	memoryStructure [ 28 : 4 ] := 0.Binary;
	memoryStructure [  1 : 4 ] := 32.Binary;
    call getMemoryValues(memoryStructure);

    lngMemoryLoad    := memoryStructure [  5 : 4 ].Integer;    
    lngTotalPhys     := memoryStructure [  9 : 4 ].Integer;
    lngAvailPhys     := memoryStructure [ 13 : 4 ].Integer;
    lngTotalPageFile := memoryStructure [ 17 : 4 ].Integer;
    lngAvailPageFile := memoryStructure [ 21 : 4 ].Integer;
    lngTotalVirtual  := memoryStructure [ 25 : 4 ].Integer;
    lngAvailVirtual  := memoryStructure [ 29 : 4 ].Integer;
    return lngTotalPhys div 1024000;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
