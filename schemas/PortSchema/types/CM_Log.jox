    <JadeMethod name="sedMean" id="146b3480-2698-4cb9-a68b-530b16aef69c">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>sedMean(set: Boolean; _value: Decimal io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     08 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not set) then
		// Jade will return the correct value
		return;
	endif;
	
	exclusiveLock(self);
	if self.sedMean &lt;&gt; _value then
		self.sedMean := _value;
		self.recalcJASVolume();
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
