    <JadeMethod name="getVoyageArrival" id="0bc19c0c-96e3-48b1-b834-51c4c363a154">
        <source>getVoyageArrival() : String;
//
// Purpose:			NOT REFERENCED BUT USED IN SQL EXTRACTS - DO NOT DELETE
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/06/2016	cnwdap1		Initial creation POL TFS #1963
//
vars
	voyage : CM_Voyage;
	gotException : Boolean;

begin
	voyage := self.myVoyage;
	if voyage = null then 
		return null;
	else 
		on Exception do app.handleDeletedObject(exception, voyage, gotException);
		return voyage.arrivedDT.asStringJMT;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWagonLoadWleFor" id="be153c5c-50b3-488a-aaa8-d32e20dec307">
        <source>getWagonLoadWleFor( _ti : CM_TrackedItem ):CM_YardWLE;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2017	cnwndl1	Initial creation	TFS 3192 / 2877

*/

vars

	wle : CM_WorkListEntry;
	req : CM_Request;

begin

	if not self.isRailType then
		return null;
	endif;

	foreach wle in _ti.allWorklistEntries discreteLock do
		if wle.status &lt;&gt; WLE_UNACTIONED then
			continue;
		endif;
		req := wle.myRequest;
		if req = null then
			continue;
		endif;
		if not self.allRequestsBeingActioned.includes(req) then
			continue;
		endif; 
		if not wle.isKindOf( CM_YardWLE ) then
			continue;
		endif;
		return wle.CM_YardWLE;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_YardWLE"/>
    </JadeMethod>
    <JadeMethod name="getWeightOutstanding" id="f5f7900d-8ab4-4e32-9969-dd921b002c7f">
        <source>getWeightOutstanding() : Decimal;
/*

Date		Who		Reason
19 June 2014	cnwer1	Initial creation PAR 34406
18 April 2016	cnwdap1	TFS #1843 Allow for rounding / calculation error in weight comparisons
*/

vars
	outstanding : Decimal[14,4];
begin
	outstanding := self.getWeightRequested() - self.getWeightReleased();
	if outstanding.abs &lt;= Measure_AllowableDifference then					// TFS #1843
		return 0;															// TFS #1843
	endif;																	// TFS #1843
	return outstanding;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getWeightReleased" id="cfc00926-428e-4afb-aefd-fa7a6422080a">
        <source>getWeightReleased() : Decimal;
/*

Date		Who		Reason
19 Jun 2014	cnwer1	Initial creation PAR 34406
22 Apr 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	reserveDetail			: CM_ReserveDetail;
	weightReleased			: Decimal[14,4];
begin
	foreach reserveDetail in self.allReserveDetails discreteLock do				//22.04.2025 navma1 #MTN-34387
		weightReleased := weightReleased + reserveDetail.getWeightReleased;
	endforeach;

	return weightReleased;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getWeightRequested" id="7b76d010-077f-4018-84b7-7fd5beba9411">
        <source>getWeightRequested() : Decimal;
/*

Date		Who		Reason
19 Jun 2014	cnwer1	Initial creation PAR 34406
11 Apr 2025 navma1  MTN-34621 MTN - 1081 dead lock on CM_EIRNumberDict
*/

vars
	reserveDetail			: CM_ReserveDetail;
	total					: Decimal[14,4];
begin
	
	foreach reserveDetail in self.allReserveDetails discreteLock do
		total := total + reserveDetail.weightRequested;
	endforeach;

	return total;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
