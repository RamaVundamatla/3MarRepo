    <JadeMethod name="comboBoxRoadExitSortColumn" id="855b236f-7e06-461e-b1f8-66cb30f59ea1">
        <source>comboBoxRoadExitSortColumn(pCmb : CMUI_ComboBox input; _sortCol : String);
//----------------------------------------------------------------
//	Created:	16 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	
	clsCol			: ClassColl;
	cls				: Class;
	str				: String;
	entTableDef		: EntTableDef;
	entTabelRow		: EntTableRow;
begin

	pCmb.clear;
	entTableDef := app.myController.getEntTableDef(ETDef_RoadExitTblData);

	pCmb.addItem("");
	foreach entTabelRow in entTableDef.allEntTableRows do
		pCmb.addItem(entTabelRow.getHeading(null, self.myTerminal, app.myCurrentLocale));
	endforeach;
	
	if _sortCol &lt;&gt; null then
		pCmb.text := _sortCol;
	endif;

end;</source>
