    <JadeMethod name="utlCreatePDFEmailFileRequest" id="440a8c6f-94a3-4fd0-8681-9092a8e3bf31">
        <updating/>
        <source>utlCreatePDFEmailFileRequest(_user			: CM_User;
							_terminal		: CM_Terminal;
							_reportName		: String;
							_jadeReport		: JadeReport;
							_emailTemplate	: CM_EmailTemplate;
							_allFilePaths	: HugeStringArray input;
							_passport : CM_Passport input) updating;
//-----------------------------------------
// Created: 22 November 2005 By: cnwgd1
//-----------------------------------------
vars
	request : BGP_RptPDFEmailerFileRequest;
	tmpUser : CM_User;
begin
	
	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	self.raiseExceptionIfNull(_emailTemplate, 'Email Template');
	
	// validate the user
	tmpUser := _user;
	if tmpUser = null then
		// try the passport
		tmpUser := _passport.myUser;
	endif;
	self.raiseExceptionIfNull(tmpUser, 'User');

	_emailTemplate.validate();
	
	if _passport.hasErrors() then
		return;
	endif;
	
//	if _jadeReport &lt;&gt; null then
		// check permission
//		if (not tmpUser.canDo(_terminal, PmPDFBackground)) then
//			app.raiseCMException1(Unabl_email_repor_user_does_ha, tmpUser.code, null, null);
//		endif;
//	endif;	

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);	
	
	create request persistent;
	request.initPDFEmailerFile(tmpUser, _terminal, _reportName, _jadeReport, _emailTemplate, _allFilePaths);
	request.initRequestEvent(true, false, null);

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_reportName" type="String"/>
        <Parameter name="_jadeReport" type="JadeReport"/>
        <Parameter name="_emailTemplate" type="CM_EmailTemplate"/>
        <Parameter name="_allFilePaths" type="HugeStringArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreatePDFEmailRequest" id="87aa33b2-8832-4b06-8964-d2315a25c4bf">
        <updating/>
        <source>utlCreatePDFEmailRequest(	_user			: CM_User;
							_terminal		: CM_Terminal;
							_reportName		: String;
							_jadeReport		: JadeReport;
							_emailTemplate	: CM_EmailTemplate) updating;


// cnwdvb1 10 February 2003 

vars

	request : BGP_ReportPDFEmailerRequest;

begin

	create request persistent;
	request.initPDFEmail(_user, _terminal, _reportName, _jadeReport, _emailTemplate);
	request.initRequestEvent(true, false, null);

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_reportName" type="String"/>
        <Parameter name="_jadeReport" type="JadeReport"/>
        <Parameter name="_emailTemplate" type="CM_EmailTemplate"/>
    </JadeMethod>
