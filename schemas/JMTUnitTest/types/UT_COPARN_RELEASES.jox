<Class name="UT_COPARN_RELEASES" id="086ff6ea-f521-4fb9-9354-cdcff4910afb">
    <superclass name="UT_EDI"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="doCheckEDITIReleaseRequest" id="892f718b-2228-4711-8c20-774fd787c963">
        <source>doCheckEDITIReleaseRequest(_ediTI :CM_EDIReleaseRequestTI; _mode, _releaseNo, _voyageCode, _vesselName, _operatorCode, _consignorCode, _consigneeCode, 
						_isoType, _extraTextAAI, _extraTextSIN,_extraTextHAN  :String;
						_quantity :Integer; _ediPartyRules :CM_EDIPartyCoparnRules; _reqTS, _estReqTS :TimeStamp; 
						_isUnknownVoyage, _checkDefaultGrades, _checkGenerator, _checkDates, _heavyRated, _releaseByType :Boolean) protected;
/*
Date		Who		Reason
01/12/2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
05/03/2012	cnwcs5	par 29210 - include vessel name in consignor voyage
23/04/2012	cnwcs5	CCMS POL 2172 / par 29480 - coparn release updates
19/02/2012	cnwcs5	CCMS pnl 2243 / PAR 31185
21/02/2013	cnwcs5	CCMS PNL 2243 / par 31185
// 14 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
vars
	isoType	:CM_ISOType;
	tokens	:StringArray;
	today	:Date;
	str		:String;	// par 29210 - March 2012
begin
	self.assertEqualMsg (_ediTI.messageMode, _mode, _releaseNo &amp; ' Type should be ' &amp; _mode);
	self.assertEqualMsg (_ediTI.releaseRequestNumber, _releaseNo, _releaseNo &amp; ' Release number incorrect');
	self.assertEqualMsg (_ediTI.releaseByType, _releaseByType, _releaseNo &amp; ' Release by type not set');
	self.assertEqualMsg (_ediTI.cargoType, TI_CargoType_Container, _releaseNo &amp; ' Cargo type incorrect');
	self.assertEqualMsg (_ediTI.cargoSubType, null, _releaseNo &amp; ' Cargo sub type incorrect');
	self.assertEqualMsg (_ediTI.bookingRef, null, _releaseNo &amp; ' Booking incorrect');
	
	if _isUnknownVoyage then
		self.assertEqualMsg (_ediTI.getVoyageCode, _ediPartyRules.myDefaultVoyage.code, _releaseNo  &amp; '(' &amp; _mode &amp; ')  Voyage is incorrect');
	else
		self.assertEqualMsg (_ediTI.getVoyageCode, _voyageCode, _releaseNo &amp; '(' &amp; _mode &amp; ')  Voyage is incorrect');
	endif;
	
	self.assertEqualMsg (_ediTI.vesselName, _vesselName, 'Vessel is incorrect');
	self.assertEqualMsg (_ediTI.billOfLading, null, 'BOL is not null');
	self.assertEqualMsg (_ediTI.releaseType, _ediPartyRules.defaultReleaseType, 'Release type incorrect');
	self.assertEqualMsg (_ediTI.statusBulkRelease, app.releaseStatusEnumToString(_ediPartyRules.defaultReleaseStatus), 'Status incorrect');		// par 31185 Feb 3012
	
	if _checkDates then 
		if _reqTS &lt;&gt; null then
			self.assertEqualMsg (_ediTI.requestDate, _reqTS, _releaseNo &amp; ' Request date incorrect'); 
		endif;
		
		if _estReqTS &lt;&gt; null then
			self.assertEqualMsg (_ediTI.estimatedRequiredDate, _estReqTS, _releaseNo &amp; ' Estimated required date incorrect'); 
		endif;
	else
		self.assertNotNullMsg (_ediTI.requestDate, _releaseNo &amp; ' Request date should have a value');
		self.assertEqualMsg (_ediTI.requestDate.date, today, _releaseNo &amp; ' Request date should be today');
	endif;
	
	self.assertEqualMsg (_ediTI.carrierCode,_ediPartyRules.myDefaultCarrier.code, ' Carrier incorrect');
	// self.assertEqualMsg (_ediTI.dischargePort, ???, ' Discharge port incorrect');
	// self.assertEqualMsg (_ediTI.loadPort, ???, 'Load port incorrect');
	self.assertEqualMsg (_ediTI.operatorCode, _operatorCode, ' Operator incorrect');
	self.assertEqualMsg (_ediTI.operatorGroup, null, 'Operator group incorrect');
	self.assertEqualMsg (_ediTI.consignee, _consigneeCode, _releaseNo &amp; ' Consignee incorrect');
	self.assertEqualMsg (_ediTI.consignor, _consignorCode, 'Consignor incorrect');
	// consignor voyage should be set as follows:
	// - voyage code if file contained xlation for voyage
	// - code from file if voyage was not xlated
	if _isUnknownVoyage then
		str := _voyageCode &amp; ' ' &amp; _vesselName;	// par 29210 - March 2012
		
		if str.length &gt; 20 then					// par 29210 - March 2012
			str := str [1:20];					// par 29210 - March 2012
		endif;									// par 29210 - March 2012
		
		self.assertEqualMsg (_ediTI.getConsignorVoyage, str, 'Consignor voyage incorrect - should equal voyage code from file');	// par 29210 - March 2012	
	else
		str := _ediTI.getVoyageCode &amp; ' ' &amp; _ediTI.vesselName;	// par 29210 - March 2012
		
		if str.length &gt; 20 then					// par 29210 - March 2012
			str := str [1:20];					// par 29210 - March 2012
		endif;									// par 29210 - March 2012

		self.assertEqualMsg (_ediTI.getConsignorVoyage, str, 'Consignor voyage incorrect - should match voyage code');	// par 29210 - March 2012
	endif;
	
	self.assertEqualMsg (_ediTI.freightForwarder, null, 'Freight forwarder incorrect');
	self.assertEqualMsg (_ediTI.businessUnit, null, 'Business unit incorrect');
	self.assertEqualMsg (_ediTI.deliveryReason, _ediPartyRules.defaultDeliveryReasonCode, 'delivery reason incorrect');// delivery reason
	//self.assertEqualMsg (_ediTI.???, ????, 'Additional required information incorrect');// additional req information
// TFS 2686	self.assertEqualMsg (_ediTI.removeStops, false, 'Remove stops incorrect');// remove stops
	self.assertEqualMsg (_ediTI.mtRelease, true, _releaseNo &amp; ' MT Release should be true');// MTs only
	//self.assertEqualMsg (_ediTI.???, ???, 'Destination terminal incorrect');// destination terminal
	self.assertEqualMsg (_ediTI.isoType, _isoType, _releaseNo &amp; ' ISO Type incorrect');// ISO type
	
	isoType := app.myRoot.allISOTypes [_isoType];
	
	self.assertNotNullMsg (isoType, 'ISO type not defined');
	
	if _ediPartyRules.useISOGroupForReleaseRequests then
		// check ISO group
		self.assertEqualMsg (_ediTI.checkISOGroup, true, 'Check ISO group incorrect');
		
		// ISO Group
		if isoType.myISOTypeGroup &lt;&gt; null then
			self.assertEqualMsg (_ediTI.isoTypeGroup, isoType.myISOTypeGroup.code, 'ISO Type Group incorrect'); 
		endif;
	endif;
	
	if _checkDefaultGrades then
		tokens := _ediTI.availabilityGrades.getTokens (); 
		
		if isoType.isReefer then
			self.assertTrueMsg (tokens.includes (_ediPartyRules.defaultAvailabilityGradeReefer.String) ,_releaseNo &amp; ' Default Reefer Availability grade incorrect'); 
		else
			self.assertTrueMsg (tokens.includes(_ediPartyRules.defaultAvailabilityGrade.String),_releaseNo &amp; ' Default Availability grade incorrect'); 
		endif;	
	else
		// must have come from file - TBA
		// ???
	endif;
	// clean should default to true for reefers and false otherwise
	if isoType.isReefer then													// par 29137
		self.assertEqualMsg (_ediTI.clean, true, 'Clean setting incorrect- should be true for reefer');	// par 29137
	else																		// par 29137
		self.assertEqualMsg (_ediTI.clean, false, 'Clean setting incorrect - should false for non-reefer');	// par 29137
	endif;																		// par 29137
	
	self.assertEqualMsg (_ediTI.heavyDuty, _heavyRated, _ediTI.releaseRequestNumber &amp; ' - Heavy duty incorrect');
    if _quantity = 0 then
       str := "Humbug";
    endif;
	self.assertEqualMsg (_ediTI.quantity, _quantity, 'Quantity incorrect');
	
	if _extraTextAAI &lt;&gt; null then	
		self.assertNotNull (_ediTI.remarks);
		self.assertTrueMsg (_ediTI.remarks.pos (_extraTextAAI, 1) &gt; 0, _releaseNo &amp; ' Additional text from FTX+AAI not stored in cargo remarks');
	endif;
	if _extraTextSIN &lt;&gt; null then
		self.assertNotNull (_ediTI.remarks);
		self.assertTrueMsg (_ediTI.remarks.pos (_extraTextAAI, 1) &gt; 0, _releaseNo &amp; ' Additional text from FTX+SIN not stored in cargo remarks');
	endif;
	if _extraTextHAN &lt;&gt; null then
		self.assertNotNull (_ediTI.remarks);
		self.assertTrueMsg (_ediTI.remarks.pos (_extraTextHAN, 1) &gt; 0, _releaseNo &amp; ' Additional text from FTX+HAN not stored in cargo remarks');
	endif;

	
	self.assertEqualMsg (_ediTI.ids, null, 'ID mask incorrect');
	self.assertEqualMsg (_ediTI.customsAgent, null, 'Customa agent incorrect');
	self.assertEqualMsg (_ediTI.customsAssistance, false, 'Customa assistance incorrect');
	self.assertEqualMsg (_ediTI.allowCargoMultiReleases, false, 'Allow multi-release cargo incorrect');

epilog
	delete tokens;
end;</source>
