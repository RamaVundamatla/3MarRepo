    <JadeMethod name="hideAndResizeNotUsed" id="268fc975-41d1-4070-ab23-41b55b8d700d">
        <updating/>
        <source>hideAndResizeNotUsed() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2019	jlgndl1	Initial creation	TFS 43918

*/

constants

	Spacing = 8;

vars

	controlTop : Real;

begin

	self.handleMenusForModalDisplay();

	self.lblCargoType.visible := false;
	self.cmbCargoType.visible := false;
	
	self.lblCargoIDs.visible := false;
	self.txtCargoIDs.visible := false;

	self.grpStops.visible := false;
	
	//within grpDetails
	self.lblTrxRemarks.visible := false;
	self.txtTrxRemarks.visible := false;
	self.lblOrg.visible := false;
	self.cmbOrganisation.visible := false;
	self.lblAutoCleanup.visible := false;
	self.chkAutoCleanup.visible := false;
	//now move up the rest in grpDetails
	controlTop := 1;
	self.lblRef.top := controlTop;
	self.txtCertName.top := controlTop;
	controlTop := controlTop + self.txtCertName.height + Spacing;
	self.lblCertName.top := controlTop;
	self.txtAuthName.top := controlTop;
	controlTop := controlTop + self.txtAuthName.height + Spacing;
	self.lblNotify.top := controlTop;
	self.chkNotify.top := controlTop;
	controlTop := controlTop + self.lblNotify.height + Spacing;
	self.grpDetails.height := controlTop;
	
	
	//within grpEmail
	self.lblTimes.visible := false;
	self.timeMask.visible := false;
	self.lstTime.visible := false;
	self.btnTimeAdd.visible := false;
	self.btnTimeRemove.visible := false;
	self.btnSaveNext.visible := false;
//	just resize these were at the end anyway

	self.grpEmail.height := self.txtRecipients.height + Spacing;
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadEventRequest" id="7a502b3c-f041-483d-af76-6cdce5e39d3f">
        <updating/>
        <source>loadEventRequest() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

begin

	self.hideAndResizeNotUsed();

	self.populateCmbUpdateType();
	
	if self.myCurrentEventRequest = null then
	
		self.cmbUpdateType.enabled := true;
		self.doChangeUpdateType();

	else
	
		self.cmbUpdateType.setIndexForItemData(self.myCurrentEventRequest.type);
		self.cmbUpdateType.enabled := false;
		self.doChangeUpdateType();
		
		if self.grpToDo.visible then
			self.loadToDoTasks();
		endif;
		
		if self.grpRemarks.visible then
			self.txtRemarks.text:=self.myCurrentEventRequest.cargoRemarks;
		endif;
		
		if self.grpGrade.visible then
			self.cmbGrade.listObject := self.myCurrentEventRequest.myGrade;
		endif;
		
		if self.grpWeight.visible then
			self.tblWeight.setValueDefault(self.myCurrentEventRequest.totalWeight.asStringJMT);
			self.chkIsCertified.value := self.myCurrentEventRequest.isWeightCertified;
			self.txtRef.text:=self.myCurrentEventRequest.reference;
			self.txtCertName.text := self.myCurrentEventRequest.reference;
			self.txtAuthName.text := self.myCurrentEventRequest.weightCertifiedName;
		endif;
		
		self.chkNotify.value := self.myCurrentEventRequest.isNotify;
		self.txtRecipients.text := self.myCurrentEventRequest.getEmailAddresses(null);
		
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateCmbUpdateType" id="2b302264-8471-4c12-b919-9909ed1368ca">
        <updating/>
        <source>populateCmbUpdateType() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

begin

	self.cmbUpdateType.clear;

	self.cmbUpdateType.addItemWithData(app.getErrorString(To_Do_Tasks), EventRequestTypeToDo);
	self.cmbUpdateType.addItemWithData(app.getErrorString(Remarks), EventRequestTypeRemarks);
	self.cmbUpdateType.addItemWithData(app.getErrorString(Grade), EventRequestTypeGrade);
	self.cmbUpdateType.addItemWithData(app.getErrorString(CM_Total_Weight),EventRequestTypeWeight);
	
	self.doChangeUpdateType();

epilog

end;</source>
    </JadeMethod>
