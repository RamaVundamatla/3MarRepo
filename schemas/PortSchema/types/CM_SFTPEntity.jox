    <JadeMethod name="validateMe" id="8d742908-5651-43ae-b2f6-2cd8153e0f84">
        <source>validateMe() protected;
//
// 09 Dec 2019	jlgrs1	TFS 46528 password or private key are required
//
vars

begin
	if self.destinationDirectory = null then
//		app.raiseCMException1(REQUIRED_FIELD, app.getString(DestinationDirectory), self.destinationDirectory, null);
	endif;
	if self.id = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getString(Id), self.id, null);
		app.raiseCMException1(Input_required_field_Required, app.getString(Id), self.id, null); // cnwdb2	PAR 35364
	endif;
	if self.password = null and self.privateKey = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getString(Password), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getString(Password_private), null, null);
	//06 Sep 2021	NDL	TFS 51165
	elseif self.privateKey &lt;&gt; null then
		self.validatePrivateKey( self.privateKey );
	endif;
	if self.serverName = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getString(ServerName), self.serverName, null);
		app.raiseCMException1(Input_required_field_Required, app.getString(ServerName), self.serverName, null);
	endif;
	if self.sourceDirectory = null then
//		app.raiseCMException1(REQUIRED_FIELD, app.getString(SourceDirectory), self.sourceDirectory, null);
	endif;
	if self.userId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getString(UserId), self.userId, null);
		app.raiseCMException1(Input_required_field_Required, app.getString(UserId), self.userId, null);
	endif;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validatePrivateKey" id="7ac8454b-cc8f-474b-a344-110bd208e653">
        <source>validatePrivateKey( _privateKey : String ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2021	navndl1	Initial creation	TFS 51165
26 Novemeber 2021	navpw1	Bug 52416: PNL - Errors while Saving the SFTP Entity (Added trimming of line breaks from end of key)

	Rules applied for format of 'Key'
	see https://crypto.stackexchange.com/questions/46893/is-there-a-specification-for-the-begin-rsa-private-key-format)

*/

constants
	RsaPubBegin 	: String = "-----BEGIN RSA PUBLIC KEY-----";
	RsaPubEnd 		: String = "-----END RSA PUBLIC KEY-----";
 
	RsaPrivBegin 	: String = "-----BEGIN RSA PRIVATE KEY-----";
	RsaPrivEnd 		: String = "-----END RSA PRIVATE KEY-----";
 
	PubBegin 		: String = "-----BEGIN PUBLIC KEY-----";
	PubEnd 			: String = "-----END PUBLIC KEY-----";
 
	PrivBegin 		: String = "-----BEGIN PRIVATE KEY-----";
	PrivEnd 		: String = "-----END PUBLIC KEY-----";
 
	CertBegin 		: String = "-----BEGIN CERTIFICATE-----";
	CertEnd 		: String = "-----END CERTIFICATE-----";

vars
	msg 			: String;
	errorInteger 	: Integer;
	privateKey		: String;
begin
	privateKey := _privateKey;						// ### TFS 52416 26Jan2022 NAVPW1
	privateKey := privateKey.trimBlankCharacters(); // ### TFS 52416 26Nov2021 NAVPW1
	
	if privateKey.trimBlanks = null then
		return true;
	endif;
	
	if privateKey.pos( RsaPubBegin , 1 ) = 1 then
		if privateKey.pos( RsaPubEnd , 1) &lt;&gt; ( privateKey.length - ( RsaPubEnd.length - 1 )) then
			errorInteger := Privat_missin_END_statem;
		endif;
		
	elseif privateKey.pos( RsaPrivBegin , 1 ) = 1 then
		if privateKey.pos( RsaPrivEnd , 1) &lt;&gt; ( privateKey.length - ( RsaPrivEnd.length - 1 )) then
			errorInteger := Privat_missin_END_statem;
		endif;
		
	elseif privateKey.pos( PubBegin , 1 ) = 1 then
		if privateKey.pos( PubEnd , 1) &lt;&gt; ( privateKey.length - ( PubEnd.length - 1 )) then
			errorInteger := Privat_missin_END_statem;
		endif;
		
	elseif privateKey.pos( PrivBegin , 1 ) = 1 then
		if privateKey.pos( PrivEnd , 1) &lt;&gt; ( privateKey.length - ( PrivEnd.length - 1 )) then
			errorInteger := Privat_missin_END_statem;
		endif;
		
	elseif privateKey.pos( CertBegin , 1 ) = 1 then
		if privateKey.pos( CertEnd , 1) &lt;&gt; ( privateKey.length - ( CertEnd.length - 1 )) then
			errorInteger := Privat_missin_END_statem;
		endif;
		
	else
		errorInteger := Priva_missi_BEGIN_statem;
		
	endif;

	if errorInteger &gt; 0 then
		app.raiseCMException( errorInteger, null, null);
		return false;
	endif;

	return true;

epilog

end;</source>
        <Parameter name="_privateKey" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
