    <JadeMethod name="trxUpdateWLEsSetDirectRelease" id="dcde3904-e3a9-408d-9699-c32a8971f2db">
        <updating/>
        <source>trxUpdateWLEsSetDirectRelease(_wleSet, _wlesWithWarnings : CM_WLESet input; _passport : CM_Passport input) updating; //_moveControl : CMIF_MoveController input; _passport : CM_Passport input) updating;
/*

Purpose:			Assigns the WLE as a Direct Release if possible

Parameters:			

Return Value:		

Date				Who		Reason
19 August 2019		jlgzm1	Initial creation TFS 42872 Direct Release Between HOLD Voyages and Rail 

*/

vars
	hadException	: Boolean;
	errorSet		: CM_ErrorSet;
	wle				: CM_WorkListEntry;
	otherWLE		: CM_WorkListEntry;
	theTI			: CM_TrackedItem;
	alertCreated 	: Boolean;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	create errorSet transient;
	
	on Exception do app.handleDeletedObject (exception, wle, hadException);
	
	// handle each wle in its own transaction so each WLE fails or succeeds on its own
	// and not cause everything to fail because of just one
	foreach wle in _wleSet do
		hadException := false;
		wle.edition;
		if hadException then
			continue;
		endif;
		
		if wle.isDRLinkedByFM or wle.status &lt;&gt; WLE_UNACTIONED then
			continue;
		endif;
		
		beginTransaction;
		if _passport.noErrors() then
			app.myUtilityUA.utlUpdateWLESetDirectRelease(wle, _passport);
		endif;
		
		if _passport.isOkToCommit(false) then
			app.cmsCommitTransaction(_passport);
		else
			app.cmsAbortTransaction;
			if _passport.hasErrors then
				app.convertErrorsWarningsToAlert('Entry ' &amp; wle.getFullDescription() &amp; ' could not be assigned to Direct Release', _passport.allErrorWarnings);		
				alertCreated := true;
			elseif _passport.hasWarnings then
				_wlesWithWarnings.add(wle);
			endif;

			_passport.moveErrorsToSet(errorSet);
			_passport.initialiseTransaction();	
		endif;	
		
	endforeach;
	
	if _passport.noErrors and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;
	
	_passport.addErrorsFromSet(errorSet);
	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, 'work list entries', null, self);
	endif;

epilog
	delete errorSet;
	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_wleSet" type="CM_WLESet" usage="input"/>
        <Parameter name="_wlesWithWarnings" type="CM_WLESet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWLEsUnassignTI" id="320e99e8-d51d-4183-ad84-6b4fad5d81e5">
        <updating/>
        <source>trxUpdateWLEsUnassignTI(_wleSet : CM_WLESet; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		22 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 22/12/2010	cnwdap1		PAR #26636 Enable "Unassign Cargo" menu item for voyage ops screen
vars
	hadException	: Boolean;
	id		: String;
	wle : CM_WorkListEntry;
	alertCreated : Boolean;
	tmpJobSet : CM_JobSet;
	tmpJob : CM_Job;
	moveController : CMIF_MoveController;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	// 36290 handle deleted WLEs in the input
	on Exception do app.handleDeletedObject (exception, wle, hadException);
	create tmpJobSet transient;
	create moveController transient;
	moveController.setMoveMode(PLANNING_MODE);
	
	foreach wle in _wleSet do
		// 36290 check for invalid WLE and skip if any
		hadException := false;
		id := wle.id;
		if hadException then
			continue;
		endif;
		exclusiveLock(wle);
		if wle.myTrackedItem = null then
			continue;
		endif;
		tmpJobSet.addNoDuplicates(wle.job,false);
		
		exclusiveLock(wle.myTrackedItem);		
		beginTransaction;				
		moveController.setMyWorkListEntry(wle);				
		moveController.setMyTrackedItem(wle.myTrackedItem);
		app.myUtilityUA.utlUpdateWLEUnassignTI(moveController, _passport);
		if _passport.noErrors then
			app.myEventManager.dispatchAllEvents;
			app.cmsCommitTransaction(_passport);
//			self.initialiseActivityWithPassport(_passport, method);						
		else
			app.convertErrorsWarningsToAlert('Entry ' &amp; wle.getFullDescription() &amp; ' could not be unplanned', _passport.allErrorWarnings);		
			alertCreated := true;
			app.cmsAbortTransaction;
		endif;
	endforeach;

	// PAR #26636 the setRemarks method does nothing at the CM_Job level, but at the CM_VoyageJob level
	// it does do something - and at this point in the method we're not in transaction state.
	// Move this code to below the beginTransaction;
	//foreach tmpJob in tmpJobSet do
	//	tmpJob.setRemarks(null);
	//endforeach;
	
	if _passport.noErrors and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;
	
	// PAR #26636 now update job remarks now that we're in transaction state again
	if _passport.noErrors then
		foreach tmpJob in tmpJobSet do
			tmpJob.setRemarks(null);
		endforeach;
	endif;
	// PAR #26634 end

	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, 'work list entries', null, self);
	endif;	

epilog
	delete moveController;
	delete tmpJobSet;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_wleSet" type="CM_WLESet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWLEsUnplan" id="e2747365-38dd-4417-ba39-6a10c2ec7b99">
        <updating/>
        <source>trxUpdateWLEsUnplan(_wleArray : CM_WLEArray;  _wlesWithWarnings : CM_WLEArray input; _moveMode : Integer; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 7/5/3		cnwgd1		to take a set of wle's
//	Dec 2011	cnwjre1		28636 add moveMode parameter for RORO unplanning of queued load moves
//	14/5/14			epr 		par 34115 can have a wle completed with planned moves 
// 31/05/2019	jlgzm1		MSL - Direct Delivery Between LOLO RORO Voyages and Rail
// 05/07/2019	jlgzm1		TFS 42863 MSL - Direct Release Between LOLO RORO Voyages and Rail - Break Bulk
// ---------------------------------------------------------------------------
vars
	hadException	: Boolean;
	id		: String;
	ti 				: CM_TrackedItem;
	wle,
	drWle			: CM_WorkListEntry; // tfs42863
	alertCreated 	: Boolean;
	moveController 	: CMIF_MoveController;
	errorSet		: CM_ErrorSet;
	tmpJobs : CM_JobSet;
	tmpJob : CM_Job;
	fmIndex : Integer;
	invalidJob : Boolean;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	app.myEventManager.setMultiTransactionTrx();
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	create errorSet transient;
	create moveController transient;
	create tmpJobs transient;
	// 36290 handle deleted WLEs in the input
	on Exception do app.handleDeletedObject (exception, wle, hadException);
	
	foreach wle in _wleArray do
		// 36290 check for invalid WLE and skip if any
		hadException := false;
		id := wle.id;
		if hadException then
			continue;
		endif;
		exclusiveLock(wle);
		drWle := null;		// tfs42863
		//epr par 34406 unplanning the wles future move ti can be null 
		if wle.myFutureMove = null then
			if wle.myFutureMoveDR = null then						//tfs42840
				continue;											
			else
				// if is direct release, then try the other WLE
				drWle := wle;									//tfs42863
				wle := wle.getDRLinkedWLE;						//tfs42840
				if wle = null then								//tfs42840
					continue;									//tfs42840
				endif;											//tfs42840
			endif;
		else
			drWle := wle.getDRLinkedWLE();						//tfs42863
		endif;
		
		 // TFS TFS 4859 if wle.job.isVoyageJob() then // PAR 19913 not for rail jobs
		 if wle.job.isVoyageTypeJob() then // TFS TFS 4859
			tmpJobs.addNoDuplicates(wle.job,false);
		endif;
		
		ti := wle.myFutureMove.getTrackedItem;		
		
		exclusiveLock(ti);
		
		if _passport.hasErrors() then
			//drop through		
		elseif _moveMode &lt;&gt; NO_MODE then		// Dec 2011 28636 unplan queued ship moves, pass in PLANNING_MODE 
			moveController.setMoveMode(_moveMode);
		else
			moveController.setMoveMode(wle.myFutureMove.getMoveMode);
		endif;
		//epr par 34406 
		moveController.isFullyUnplan := true; 
		if moveController.moveMode = PLANNING_MODE then
			fmIndex := ti.allPlannedFutureMoves.indexOf(wle.myFutureMove);
		elseif moveController.moveMode = QUEUE_MODE then
			fmIndex := ti.allQueuedFutureMoves.indexOf(wle.myFutureMove);
		endif;
	
		moveController.setMoveIndex(fmIndex);
	
		moveController.setMyWorkListEntry(wle);						
		// moveCtrl.setMyWorkListEntry automatically assigns myDDWorkListEntry if wle
		// is a direct release, so need to set it back to null here so it can be used
		// later in unplanning
		moveController.myDDWorkListEntry := null;
		moveController.setMyTrackedItem(ti);

		if ti &lt;&gt; null then
			moveController.isRehandleMove := ti.isRehandle;
			// if wle is for direct release, and cargo is splittable 
			// and has been planned with multiple wles, then try to 
			// find an unplanned wle to merge this one's quantity into.
			if wle.isDRLinkedByFM and															// tfs42863
			   ti.canMergeBreakBulk and															// tfs42863
			   // for direct release move if  ti.allWorklistEntries.size = 2 it means
			   // there is only one planned move
			   ti.allWorklistEntries.size &gt; 2 then												// tfs42863
				moveController.myDDWorkListEntry := wle.job.getUnplannedWLEForTI(ti);			// tfs42863
				if moveController.myDDWorkListEntry = null then									// tfs42863
					if drWle &lt;&gt; null then														// tfs42863
						moveController.myDDWorkListEntry := drWle.job.getUnplannedWLEForTI(ti);	// tfs42863
						if moveController.myDDWorkListEntry = null then							// tfs42863
							moveController.myDDWorkListEntry := drWle;
						endif;
					endif;
				endif;
			endif;
		endif;
		
		beginTransaction; 		
		if _passport.noErrors() then
			app.myUtilityUA.utlUpdateWLEUnplan(wle, moveController, _passport);
		endif;

		if _passport.isOkToCommit(false) then
			app.cmsCommitTransaction(_passport);
		else
			app.cmsAbortTransaction;
			if _passport.hasErrors then
				app.convertErrorsWarningsToAlert('Entry ' &amp; wle.getFullDescription() &amp; ' could not be unplanned', _passport.allErrorWarnings);		
				alertCreated := true;
			elseif _passport.hasWarnings then
				_wlesWithWarnings.add(wle);
			endif;

			_passport.moveErrorsToSet(errorSet);
			_passport.initialiseTransaction();	
		endif;		
	endforeach;

	if _passport.noErrors and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;
	
	//epr TFS 4699 28/6/17 if its voyage roro wle then wle and job will get deleted
	on Exception do app.handleDeletedObject(exception,tmpJob,invalidJob);
	
	foreach tmpJob in tmpJobs do
		tmpJob.setRemarks(null);
	endforeach;
	
	_passport.addErrorsFromSet(errorSet);
	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, 'work list entries', null, self);
	endif;	

epilog
	delete errorSet;
	delete moveController;
	delete tmpJobs;
	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray"/>
        <Parameter name="_wlesWithWarnings" type="CM_WLEArray" usage="input"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWLEsUnqueue" id="a2884506-d90c-4920-860b-8e5dd4c2b67f">
        <updating/>
        <source>trxUpdateWLEsUnqueue(_wleArray : CM_WLEArray; _wlesWithWarnings : CM_WLEArray input; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: May 2003 By: cnwgd1
// call to utlUpdateWLEUnqueue added Apr 2010 for par 23023 patch
// 14 Oct 2025	navtr3	MTN-36090 MTN | Deferred Update Required trxUpdateWLEsUnqueue 
//-----------------------------------------
vars
	hadException	: Boolean;
	id		: String;
	wle : CM_WorkListEntry;
	alertCreated : Boolean;
	errorSet	: CM_ErrorSet;
	lMoveControl : CMIF_MoveController;
	invalidWLE		: Boolean;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);	
	
	app.myEventManager.setMultiTransactionTrx();
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	on Exception do app.handleDeletedObject(exception, wle, invalidWLE); 

	app.setContinueCMExceptions(false);
	
	// 36290 handle deleted WLEs in the input
	on Exception do app.handleDeletedObject (exception, wle, hadException);
	create errorSet transient;	
	
	foreach wle in _wleArray do
		// 36290 check for invalid WLE and skip if any
		hadException := false;
		id := wle.id;
		if hadException then
			continue;
		endif;
	
		// Enable deferred updates					 						//14-10-2025 navtr3 MTN-36090
		_passport.useTIDictDeferUpdate := true;
		_passport.useTITransactionDeferUpdate := true;
	
		beginTransaction;

		if wle.isPlanOnPickup then	 //cnwrd1 ccms 2014	
			create lMoveControl transient;
			lMoveControl.setMoveMode(QUEUE_PLAN_ON_PICKUP);
			lMoveControl.setMyTrackedItem(wle.myTrackedItem);
			lMoveControl.setMyWorkListEntry(wle);

			app.myUtilityUA.utlUpdateMoveTIUndo(lMoveControl, _passport);
			delete lMoveControl;
		else
			app.myUtilityUA.utlUpdateWLEUnqueue(wle, _passport);
		endif;
		
		if _passport.noErrors then										//14-10-2025 navtr3 MTN-36090
			_passport.doDeferredUpdates();
		endif;
	
		if _passport.isOkToCommit(false) then
			app.cmsCommitTransaction(_passport);
		else
			app.cmsAbortTransaction;
			if _passport.hasErrors then
				app.convertErrorsWarningsToAlert('Entry ' &amp; wle.getFullDescription() &amp; ' could not be unqueued', _passport.allErrorWarnings);		
				alertCreated := true;
			elseif _passport.hasWarnings then
				_wlesWithWarnings.add(wle);
			endif;

			_passport.moveErrorsToSet(errorSet);
			_passport.initialiseTransaction();	
		endif;
	endforeach;

	if _passport.noErrors and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly		
		beginTransaction;
	endif;	
		
	_passport.addErrorsFromSet(errorSet);

	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, 'work list entries', null, self);
	endif;	

epilog
	self.finaliseActivityWithPassport(_passport);	
	delete errorSet;
	delete lMoveControl;
end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray"/>
        <Parameter name="_wlesWithWarnings" type="CM_WLEArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWOApproved" id="bbdf75e2-3434-4692-bcac-2346b807a0aa">
        <updating/>
        <source>trxUpdateWOApproved(	_realWoVoy 	    : CM_WorkOrder input;
						_approveCashRec : Boolean;	
						_lengthOfTime   : Decimal;
						_grpMethod		: CM_WorkOrderJobGroupMethod input;
						_passport 	    : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date   		Who		Reason
18 Aug 2018	jlger1	Initial creation
28 Feb 2019 cnwma1	Bug 43514: PEL1 - SAP Credit check approval option
09 Mar 2024 navma1	ChangeRequest 62741: MTN - EUP Performance Test - Deferred updates when approving Work Orders
02 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
09 Dec 2024 navma1	MTN-19927 EUP - Error 1081 When using Rail Lander
*/
vars
	trxAA 	   		: CM_UpdateTransactionAuditAgent;
	cashRec,
	pxyCashRec 		: CM_CashReceipt;
	workOrderDtl	: CM_WorkOrderDtl;
	wo				: CM_WorkOrder;
begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;

	_passport.useTITransactionDeferUpdate := true;			//09.03.2024 navma1	#62741
	_passport.useWOTransactionDeferUpdate := true;			//09.12.2024 navma1	#MTN-19927
	
	if _approveCashRec then  								//28.02.2019 cnwma1 #43514
		foreach cashRec in _realWoVoy.allCashReceipts do
			if cashRec.paymentStatus &lt;&gt; CM_CashReceipt.CREDIT_CHECK_APPROVED then
				pxyCashRec := app.createUpdateProxy(cashRec).CM_CashReceipt;
				
				app.myUtilityUA.utlUpdateCashRecPaymentStatus(pxyCashRec,CM_CashReceipt.CREDIT_CHECK_APPROVED, _passport);
				
				if _passport.hasErrors then
					return;
				endif;
				delete pxyCashRec;
			endif;
		endforeach;
	endif;
	
	create trxAA transient;
	trxAA.audUpdateGeneric(_realWoVoy, true);
	
	if _lengthOfTime &lt;&gt; null then
		_realWoVoy.setLengthOfTime(_lengthOfTime);
	endif;
	
	workOrderDtl := _realWoVoy.allWoDtls.first;				//02.05.2024 navhl20 #63971
	if _grpMethod &lt;&gt; null and workOrderDtl.isKindOf(CM_WorkOrderTIDtl) then
		workOrderDtl.myParent.setMyWOJobGrpMethod(_grpMethod);
		workOrderDtl.CM_WorkOrderTIDtl.updateWObyJobGrp(_grpMethod,wo);
	endif;
	
	_realWoVoy.setTaskStatus(WO_STATUS_APPROVED);
	
	if _passport.noErrors then
		trxAA.audUpdateGeneric(_realWoVoy, false);
	endif;
	
	if _passport.noErrors() then								//09.03.2024 navma1	#62741
		_passport.doDeferredUpdates();							//09.03.2024 navma1	#62741
	endif;
	
epilog
	delete trxAA;
	delete pxyCashRec;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_realWoVoy" type="CM_WorkOrder" usage="input"/>
        <Parameter name="_approveCashRec" type="Boolean"/>
        <Parameter name="_lengthOfTime" type="Decimal"/>
        <Parameter name="_grpMethod" type="CM_WorkOrderJobGroupMethod" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWODTIToDoNoTIComplete" id="047687c7-b4e5-40c0-a2d0-97453b0ddecf">
        <updating/>
        <source>trxUpdateWODTIToDoNoTIComplete( _woTODOWLE : CM_WOToDoWLE input; _toDoTask: CM_TiToDoTask input;_resourceUsageProxys : CM_ResourceTypeUsageSet input; _passport : CM_Passport input) updating;
/*
Purpose:			

Date		Who		Reason
24 May 2023  navmv20 CR 57925 Task 57921: UI - WO Enquiry To Do Tasks
 // ### TFS CR 54345 TASK 58281 14JUN2023 NAVAB1 - trxUpdateWODTransaction renamed to trxUpdateWODTIToDoNoTIComplete
22 Oct 2024 navnk30 JIRA 19927: EUP - Error 1081 When using Rail Lander
*/
vars

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	_passport.useWOTransactionDeferUpdate := true;		//22.10.2024 navnk30 JIRA 19927
	
	beginTransaction;

	app.myUtilityUA.utlUpdateWODTIToDoNoTIComplete(_woTODOWLE,_toDoTask,_resourceUsageProxys, _passport);
	
	_passport.doDeferredUpdates();						//22.10.2024 navnk30 JIRA 19927

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
