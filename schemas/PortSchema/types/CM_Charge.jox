    <JadeMethod name="cloneForConsolidation" id="944a35a1-c3f6-43a0-a72f-d9c8600d4f5c">
        <source>cloneForConsolidation(_cloneInvLine : CM_InvoiceLine) : CM_Charge;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2024	navrv30	Initial creation  for CR 61911/ Task 61391

*/

vars

	cloneCharge : CM_Charge;
	dummyInvLine : CM_InvoiceLine;

begin

	cloneCharge := self.cloneSelf( true );

	cloneCharge.service := self.service;
	cloneCharge.myOverrideTaxCode := self.myOverrideTaxCode;
	
	cloneCharge.invoiceLine := _cloneInvLine;
	//cloneCharge.bank := self.bank;
	
	return cloneCharge;

epilog

	delete dummyInvLine;

end;</source>
        <Parameter name="_cloneInvLine" type="CM_InvoiceLine"/>
        <ReturnType type="CM_Charge"/>
    </JadeMethod>
    <JadeMethod name="cloneForCopy" id="1c5d9aa2-1110-41db-91c2-07954cbba568">
        <source>cloneForCopy(_cloneInvLine : CM_InvoiceLine) : CM_Charge;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/05/2023 navmv20 Bug 57664: EUP - Copy function does not include overridden rates

*/

vars

	cloneCharge : CM_Charge;
	dummyInvLine : CM_InvoiceLine;

begin

	cloneCharge := self.cloneSelf( false );

	cloneCharge.sequenceNum := app.getNextInvoiceSeqNumOnRootBank(SN_CHARGE);
	cloneCharge.service := self.service;
	cloneCharge.myOverrideTaxCode := self.myOverrideTaxCode;
	
	cloneCharge.invoiceLine := _cloneInvLine;
	cloneCharge.bank := self.bank;
	
	return cloneCharge;

epilog

	delete dummyInvLine;

end;</source>
        <Parameter name="_cloneInvLine" type="CM_InvoiceLine"/>
        <ReturnType type="CM_Charge"/>
    </JadeMethod>
    <JadeMethod name="cloneForReturn" id="8be75b2d-e518-40e0-a3d7-ed644197a663">
        <source>cloneForReturn( _cloneInvLine : CM_InvoiceLine; _asCredit : Boolean ) : CM_Charge;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 September 2017	jlgndl1	Initial creation	TFS 6759

*/

vars

	cloneCharge : CM_Charge;
	dummyInvLine : CM_InvoiceLine;

begin

	cloneCharge := self.cloneSelf( false );
	
	if _asCredit then
		create dummyInvLine;
		cloneCharge.invoiceLine := dummyInvLine;
		cloneCharge.total := ( self.total * -1 );	// mapping method with special code, need sdummy line to allow set
	endif;
	
	cloneCharge.sequenceNum := app.getNextInvoiceSeqNumOnRootBank(SN_CHARGE);
	cloneCharge.service := self.service;
	
	cloneCharge.invoiceLine := _cloneInvLine;
	cloneCharge.bank := self.bank;
	
	return cloneCharge;

epilog

	delete dummyInvLine;

end;</source>
        <Parameter name="_cloneInvLine" type="CM_InvoiceLine"/>
        <Parameter name="_asCredit" type="Boolean"/>
        <ReturnType type="CM_Charge"/>
    </JadeMethod>
