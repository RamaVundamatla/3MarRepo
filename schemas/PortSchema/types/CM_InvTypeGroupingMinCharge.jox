    <JadeMethod name="getAllSelectedInvLineTypes" id="eaa1f30a-fd56-4811-9a10-75a3738d8604">
        <source>getAllSelectedInvLineTypes( _selected : CM_InvoiceLineDescSet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2019	jlgndl1	Initial creation

*/

vars

	lineType : CM_InvoiceLineDesc;
	edition : Integer;
	invalid : Boolean;
	
begin

	_selected.clear();
	
	on Exception do app.handleDeletedObject( exception, lineType, invalid );
	
	
	foreach lineType in self.allLineTypesForMinimumCharge do
		invalid := false;
		edition := lineType.edition;
		if invalid then
			continue;
		endif;
		_selected.add( lineType );
	endforeach;

epilog

end;</source>
        <Parameter name="_selected" type="CM_InvoiceLineDescSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getLineTypesDisplay" id="63c21083-3ae0-4c33-9a4c-fcdcda8f9fd5">
        <source>getLineTypesDisplay():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2019	jlgndl1	Initial creation	TFS 43687

*/

vars

	selected : CM_InvoiceLineDescSet;
	lineType : CM_InvoiceLineDesc;
	retStr : String;

begin

	create selected transient;
	self.getAllSelectedInvLineTypes( selected );
	
	foreach lineType in selected do
		if retStr &lt;&gt; null then
			retStr := retStr &amp; ", " &amp; lineType.narration;
		else
			retStr := lineType.narration; 
		endif;
	endforeach;
	
	return retStr;

epilog

	delete selected;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMatchingLines" id="44685645-e296-44b5-82dc-ed930d1a0380">
        <source>getMatchingLines( inputColl : CM_InvoiceLineSet; _matching : CM_InvoiceLineBySeqNumDict input; _moveType : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 March 2019	jlgndl1	Initial creation	TFS 43687

*/

vars

	iter : Iterator;
	invLine : CM_InvoiceLine;
	movement : HMS_VoyageMovement;
	movementType : String;

begin

	if inputColl = null or inputColl.isEmpty then
		return;
	endif;

	iter := inputColl.createIterator;	
	while iter.next( invLine ) do
		if self.allLineTypesForMinimumCharge.includes( invLine.invoiceLineDesc ) then
			if self.moveType &lt;&gt; null then
				if _moveType &lt;&gt; null then	// used for proforma
					if _moveType = self.moveType then
						_matching.add( invLine );
					endif;
				else	// used for real invoicing
					movement := invLine.getMyMovementObject;
					if movement &lt;&gt; null then
						if movement.isArrival or movement.isMoveTypeArrCancelled then
							movementType := app.getMoveTypeDescription(HMSMovementTypeArrival);
						elseif movement.isMovementTypeShift or movement.isMoveTypeShiftCancelled then
							movementType := app.getMoveTypeDescription(HMSMovementTypeShift);
						elseif movement.isMovementTypeDeparture or movement.isMoveTypeDepCancelled then
							movementType := app.getMoveTypeDescription(HMSMovementTypeDeparture);
						endif;
						if movementType = self.moveType then
							_matching.add( invLine );
						endif;
					endif;
				endif;
			else
				_matching.add( invLine );
			endif;
		endif;
	endwhile;
	

epilog

	delete iter;
	
end;</source>
        <Parameter name="inputColl" type="CM_InvoiceLineSet"/>
        <Parameter name="_matching" type="CM_InvoiceLineBySeqNumDict" usage="input"/>
        <Parameter name="_moveType" type="String"/>
    </JadeMethod>
    <JadeMethod name="getMinimumChargeInvLineType" id="7d904d55-6d25-445e-9c1d-5a347ed647ed">
        <source>getMinimumChargeInvLineType():CM_InvoiceLineDesc;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2019	jlgndl1	Initial creation	TFS 43687

*/

vars

	lineType : CM_InvoiceLineDesc;
	edition : Integer;
	invalid : Boolean;

begin

	lineType := self.myMinimumChargeInvoiceLineType;
	if lineType = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, lineType, invalid );
	edition := lineType.edition;
	if invalid then
		return null;
	endif;
	
	return lineType;

epilog

end;</source>
        <ReturnType type="CM_InvoiceLineDesc"/>
    </JadeMethod>
