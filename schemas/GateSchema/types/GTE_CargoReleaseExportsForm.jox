    <JadeMethod name="setDefaults" id="0f26a590-c343-443c-9654-eafbc220cdca">
        <updating/>
        <source>setDefaults() updating, protected;
// ---------------------------------------------------------------------------
// Created:     20 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//20 Oct 2022	navsj20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
// ---------------------------------------------------------------------------
vars
	rowName				: String;
	theTi, theRealTi	: CM_TrackedItem;
	aStopTable				: CM_StopsTable;
	passport			: CM_Passport;
	stopTablesDict			: CM_StopsTableByIdDict;
	viewOpExpNo 		: Boolean;	  
begin

	if self.mode = Mode_Add then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to add a cargo release - this is not permitted');
		return;
	endif;
	
	passport := app.myPassport;
	
	theTi := self.myProxyObject.CM_TrackedItem;
	theRealTi := self.myCurrentObject.CM_TrackedItem;
	tblMain.setValueByName(ETRow_CustomExportEntryNumber, theTi.customExportEntryNumber);
	
	//1/11/2011 cnwdz2 par28473
	viewOpExpNo := app.getMyUser.canDo(self.myTerminal, PmAdmOpExpReleaseNumEdit);
	if viewOpExpNo then
		self.tblMain.setValueByName(ETRow_ExportReleaseNumber, theTi.getOperatorExpReleaseNo);
		self.tblMain.showRowByName(ETRow_ExportReleaseNumber, false);		
	else
		self.tblMain.hideRowByName(ETRow_ExportReleaseNumber, false);
	endif;

	if passport.myUser &lt;&gt; null then
		if self.mode = self.Mode_Update then
			stopTablesDict := passport.myUser.getStopsToMaintForTerminal(self.myTerminal);
		else
			stopTablesDict := passport.myUser.getStopsToViewForTerminal(self.myTerminal);
		endif;
	else
		// DVB 
		stopTablesDict := app.myRoot.allAvailableStopsTables;
	endif;
	
	foreach aStopTable in app.myRoot.allStopsTable do
	
		//rowName := aStop.heading &amp; " Stop";
		rowName := aStopTable.getAttrName();
		tblMain.setValueByName(rowName, theRealTi.isStopSet(aStopTable.id));
		//if not aStopTable.isValidForCargoType(theRealTi.cargoType) or not stopTablesDict.includesKey(aStopTable.id) then	//20.10.2022	navsj20	TFS 53862
		if not aStopTable.isValidForStopCriteria(theRealTi) or not stopTablesDict.includesKey(aStopTable.id) then			//20.10.2022	navsj20	TFS 53862
			tblMain.hideRowByName(rowName, false);
		endif;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFilterDefaults" id="4b75b06c-8bd3-492d-adce-fc8d32fd7ac8">
        <updating/>
        <source>setFilterDefaults() updating;
// ---------------------------------------------------------------------------
// Created:     06 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.filterCEDO				:= null;
	self.filterCEDOSet			:= null;
	self.filterOperatorCode		:= null;
	self.myFilterOperator		:= null;
	cmbFiltOperator.setObject(null);
	
	self.myFilterVoyage			:= null;
	cmbFiltVoyage.listObject	:= null;

	self.filterDateFrom := null;
	self.filterDateTo := null;
	self.tblSearch.setValueByName(ETRow_ReceivedDateFrom, null);
	self.tblSearch.setValueByName(ETRow_ReceivedDateTo, null);
end;</source>
    </JadeMethod>
    <JadeMethod name="setFilterValues" id="0d03f868-51d2-42ef-bdf7-faf4e9cb7317">
        <updating/>
        <source>setFilterValues() updating;
//-----------------------------------------
// Created: February 2004 By: cnwgd1
//-----------------------------------------
vars
	str	: String;
begin
	
	self.filterCEDO			:= tblSearch.getValueByName(ETRow_FilterCEDO).String;
	str						:= tblSearch.getValueByName(ETRow_FilterCEDOSet).String;
	
	if str = 'Yes' then
		self.filterCEDOSet := self.View_Has_CEDO;
	elseif str = 'No' then
		self.filterCEDOSet := self.View_No_CEDO;		
	else
		self.filterCEDOSet := self.View_All;
	endif;
	
	self.myFilterOperator	:= cmbFiltOperator.myObject.CM_Operator;
	self.myFilterVoyage		:= cmbFiltVoyage.listObject.CM_Voyage;

	if self.myFilterVoyage &lt;&gt; null then
		//app.myCurrentVoyage := self.myFilterVoyage;
		//cnwjo3 par 23105
		app.setMyCurrentVoyage(self.myFilterVoyage);
	endif;
	
	if self.myFilterOperator &lt;&gt; null then
		self.filterOperatorCode := self.myFilterOperator.code.trimRight;
	else
		self.filterOperatorCode := null;
	endif;

//	self.filterDateFrom := self.tblSearch.getValueByName(ETRow_ReceivedDateFrom).Date;
//	self.filterDateTo := self.tblSearch.getValueByName(ETRow_ReceivedDateTo).Date;
	self.filterDateFrom := self.tblSearch.getValueAsDate(ETRow_ReceivedDateFrom);
	self.filterDateTo := self.tblSearch.getValueAsDate(ETRow_ReceivedDateTo);

end;</source>
    </JadeMethod>
