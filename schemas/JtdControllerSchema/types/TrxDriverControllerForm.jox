    <JadeMethod name="mnuViewSetFontSelect_click" id="51e3e4ac-106e-4999-b7d4-ae8d2101dc9f">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuViewSetFontSelect_click(menuItem: MenuItem input) updating;

vars
	tbl : Table;
	f : CMDFont;
	
begin
	create f transient;

	f.showEffects := false;
	f.fontName := tblDrivers.fontName;
	f.fontSize := tblDrivers.fontSize;
	f.fontBold := tblDrivers.fontBold;
	f.fontItalic := tblDrivers.fontItalic;
	
	if f.open = 0 then
		tbl := self.tblDrivers;
	
		tbl.fontName := f.fontName;
		tbl.fontSize := f.fontSize;
		tbl.fontBold := f.fontBold;
		tbl.fontItalic := f.fontItalic;
		tbl.fontStrikethru := false;
		tbl.fontUnderline := false;

		tbl := self.tblTrans;
	
		tbl.fontName := f.fontName;
		tbl.fontSize := f.fontSize;
		tbl.fontBold := f.fontBold;
		tbl.fontItalic := f.fontItalic;
		tbl.fontStrikethru := false;
		tbl.fontUnderline := false;

		tbl := self.tblStats;

		tbl.fontName := f.fontName;
		tbl.fontSize := f.fontSize;
		tbl.fontBold := f.fontBold;
		tbl.fontItalic := f.fontItalic;
		tbl.fontStrikethru := false;
		tbl.fontUnderline := false;
	endif;

epilog
	delete f;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuViewStatsTable_click" id="9bc21b36-1187-486d-96d7-18d25f89045c">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuViewStatsTable_click(menuItem: MenuItem input) updating;

begin
	if self.tblStats.visible then
		if self.tblTrans.visible then
			self.saveSplitVertLeftPercentage;
		endif;
		self.tblStats.visible := false;
		self.tblStats.enabled := false;
	else
		if self.tblTrans.visible then
			self.splitterVert.left := self.clientWidth * self.savedSplitVertLeftPercentage;
		endif;
		self.tblStats.visible := true;
		self.tblStats.enabled := true;
	endif;

	self.resizeTheLot;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuViewStatusLine_click" id="34aac4ed-0e68-4eaa-ad59-1c7749fdb580">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuViewStatusLine_click(menuItem: MenuItem input) updating;

vars
	rv, rh : Real;

begin
	self.statusLine.visible := not self.statusLine.visible;
	
	if self.statusLine.visible then
		// we have just turned the status line back on so we need
		// to adjust the top position of all splitter bars before
		// resizing everything
		rv := self.splitterVert.top - self.splitterHorz1.top;
		rh := self.splitterHorz2.top - self.splitterHorz1.top;

		self.splitterHorz1.top := self.splitterHorz1.top - self.statusLine.height;
		if self.splitterHorz1.top &lt; 0 then
			self.splitterHorz1.top := 0;
		endif;

		self.splitterVert.top := self.splitterHorz1.top + rv;
		self.splitterHorz2.top := self.splitterHorz1.top + rh;
	endif;
	
	self.resizeTheLot;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
