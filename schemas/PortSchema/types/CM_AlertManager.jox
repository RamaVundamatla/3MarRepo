    <JadeMethod name="addAlert" id="381d2c24-74d9-488b-b1ee-5af3d944e75b">
        <updating/>
        <source>addAlert(alert	:	CM_SystemAlert) updating;

vars

begin
	if alert.logDetails &lt;&gt; null then
		self.logAlert := alert;
	else
		self.normalAlert := alert;
	endif;
	self.alerts.add(alert);
end;</source>
        <Parameter name="alert" type="CM_SystemAlert"/>
    </JadeMethod>
    <JadeMethod name="addLogAlert" id="20346e0e-4b72-48d3-92c9-ed95cc52fd0f">
        <updating/>
        <source>addLogAlert(str	:	String) updating;

vars
	isNew	:	Boolean;
	invalidLA : Boolean;
begin
	/*
	Date		 Who	Reason
	13 Oct. 2008 cnwdz2	Par17852 - Create a new log alert if the current one has been deleted.
	*/
	
	if self.logAlert = null or not global.isValidObject(self.logAlert) then
		create self.logAlert transient;
		self.logAlert.details := "System Logging Display. Double-click to view details...";
		isNew := true;
	endif;
	self.logAlert.addLogEntry(str);
	if isNew then
		self.addAlert(logAlert);
	endif;

end;</source>
        <Parameter name="str" type="String"/>
    </JadeMethod>
    <JadeMethod name="addLogAlertYAFromLogging" id="1e2cf55d-7adf-47f9-a22e-f0272c8caa4d">
        <updating/>
        <source>addLogAlertYAFromLogging( 	_cmif_YAAutoPlan : CMIF_YAAutoPlan;
							_verbose,
							_hasFailed : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 March 2009	cnwer1	Initial creation

*/

vars
	ti					: CM_TrackedItem;
	newLogAlert 		: CM_SystemAlert;
	log 				: String;
	failedToAutoplan	: CM_FailedToAutoplan;
	
begin
	create newLogAlert transient;
	newLogAlert.myTerminal := _cmif_YAAutoPlan.myTerminal;
	// This should be put in for ccms 1023
	// Change so no transient get set here.
	ti := _cmif_YAAutoPlan.getMyTrackedItem();
	// can get here after exception where ti has already been deleted
	if ti &lt;&gt; null and not ti.isTransient() then
		newLogAlert.setMyTrackedItem(ti);
	endif;
	//self.logAlert.setMyTrackedItem(_yaAgent.getMyCurrentTrackedItem());
	if _hasFailed then
		// 23676 logging
		if _cmif_YAAutoPlan.isKindOf(CMIF_YARequest) and _cmif_YAAutoPlan.CMIF_YARequest.bestPick then
			newLogAlert.details := "Item - " &amp; _cmif_YAAutoPlan.getID() &amp; ' Failed Best Pick';
		else
			newLogAlert.details := "Item - " &amp; _cmif_YAAutoPlan.getID() &amp; ' Failed Auto Plan';
		endif;
		newLogAlert.setSeverity(SEVERE_ERROR);
		if _cmif_YAAutoPlan.isKindOf(CMIF_YARequest) then	//11 Jan 2012	NDL	Par 28953
			newLogAlert.setLinkedTo(_cmif_YAAutoPlan.CMIF_YARequest.myDeliveryRequest);
			newLogAlert.setMySystemAlertType(app.myRoot.allSystemAlertTypes[EVENT_AT_FailedAutoPlanRequest]);
		else
		
			create failedToAutoplan transient;
			failedToAutoplan.myFirstYAFailure 	:= _cmif_YAAutoPlan.myFirstYAFailure;
			failedToAutoplan.myJob				:= _cmif_YAAutoPlan.myJob;
			if ti &lt;&gt; null then
				failedToAutoplan.autoplanIMEXStatus	:= ti.getReceivalIMEXStatus();
			endif;
			//newLogAlert.setLinkedTo(_cmif_YAAutoPlan.myFirstYAFailure);
			newLogAlert.setLinkedTo(failedToAutoplan);	// 27/04/2009 cnwar2 #19401, #19524, #19522
			newLogAlert.setMySystemAlertType(app.myRoot.allSystemAlertTypes[EVENT_AT_FailedAutoPlan]);
		endif;
		
	elseif _cmif_YAAutoPlan.isKindOf(CMIF_YARequest) then
		newLogAlert.details := "Auto planning for item - " &amp; _cmif_YAAutoPlan.getID() &amp; " double-click to view details...";
	else
		newLogAlert.details := "Auto planning for delivery request " &amp; _cmif_YAAutoPlan.getID() &amp; " double-click to view details...";
	endif;
	
	self.addAlert(newLogAlert);

	if _verbose then
		foreach log in _cmif_YAAutoPlan.allVerboseLogging do
			newLogAlert.addLogEntry(log);
		endforeach;
	else
		foreach log in _cmif_YAAutoPlan.allLogging do
			newLogAlert.addLogEntry(log);
		endforeach;
	endif;
			
epilog

end;</source>
        <Parameter name="_cmif_YAAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_verbose" type="Boolean"/>
        <Parameter name="_hasFailed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="allLogAlertYA" id="df437686-324f-42fa-96b7-d5e41a5425d5">
        <updating/>
        <source>allLogAlertYA(_yaAgent : CM_YAAutoplanAgent; str	:	String; _isNew, _hasFailed : Boolean) updating;

vars
	isNew				: Boolean;
	ti					: CM_TrackedItem;
	failedToAutoplan	: CM_FailedToAutoplan;
begin

	if self.logAlert = null or _isNew then
		create self.logAlert transient;
		self.logAlert.myTerminal := _yaAgent.myCurrentTerminal;
		// This should be put in for ccms 1023
		// Change so no transient get set here.
		ti := _yaAgent.getMyCurrentTrackedItem();
		// can get here after exception where ti has already been deleted
		if ti &lt;&gt; null and not ti.isTransient() then
			self.logAlert.setMyTrackedItem(ti);
		endif;
		//self.logAlert.setMyTrackedItem(_yaAgent.getMyCurrentTrackedItem());
		if _hasFailed then
			self.logAlert.details := "Item - " &amp; _yaAgent.myCurrentCMIFYAAutoPlan.getID() &amp; ' Failed Auto Plan';
			self.logAlert.setSeverity(SEVERE_ERROR);
			
			create failedToAutoplan persistent;
			failedToAutoplan.myFirstYAFailure 	:= _yaAgent.myFirstYAFailure;
			failedToAutoplan.myJob				:= _yaAgent.myCurrentJob;
			if ti &lt;&gt; null then
				failedToAutoplan.autoplanIMEXStatus	:= ti.getReceivalIMEXStatus();
			endif;
			//self.logAlert.setLinkedTo(_yaAgent.myFirstYAFailure);
			self.logAlert.setLinkedTo(failedToAutoplan);	// 27/04/2009 cnwar2 #19401, #19524, #19522
			self.logAlert.setMySystemAlertType(app.myRoot.allSystemAlertTypes[EVENT_AT_FailedAutoPlan]);
		elseif _yaAgent.isFindLocationForBox then
			self.logAlert.details := "Auto planning for item - " &amp; _yaAgent.myCurrentCMIFYAAutoPlan.getID() &amp; " double-click to view details...";
		else
			self.logAlert.details := "Auto planning for delivery request " &amp; _yaAgent.myCurrentCMIFYAAutoPlan.getID() &amp; " double-click to view details...";
		endif;
		self.addAlert(logAlert);
	endif;

	self.logAlert.addLogEntry(str);


end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent"/>
        <Parameter name="str" type="String"/>
        <Parameter name="_isNew" type="Boolean"/>
        <Parameter name="_hasFailed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="commitAlert" id="b0d0f80b-3a39-41d7-b843-a0db934d29e8">
        <updating/>
        <source>commitAlert() updating;
//Takes the current log alert object, and clones it to a persistant instance.
/*

Date		Who		Reason
26 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
11 Jun 2010	cnwkpd1	PAR #17097 - Handle exceptions in Alert creation

*/

vars
	sysAlert			: CM_SystemAlert;
	alert				: CM_SystemAlert;
	newLogDetails		: CM_Strings;
	localTrans 			: Boolean;
	theLogAlert 		: CM_SystemAlert;
	theNormAlert 		: CM_SystemAlert;
	obj					: CM_Object;
	failedToAutoplan 	: CM_FailedToAutoplan;
	completedOK			: Boolean;
	invalid 			: Boolean;
	ti					: CM_TrackedItem;
	id					: String;
	
begin
	if logAlert = null and normalAlert = null and alerts.size = 0 then
		// Nothing to do.
		return;
	endif;

	//------------------
	//Enable an exception handler to catch any problems writing this alert
	//------------------
	//on NormalException do self.noMessageException(exception);
	on Exception do app.alertExceptionHandlerFinal(exception);			// PAR #17097 - added these two handlers in
	on LockException do app.alertLockExceptionHandler(exception);
		
	if not process.isInTransactionState then
		beginTransaction;
		localTrans := true;
	endif;

	on Exception do app.handleDeletedObject(exception, ti, invalid);
	
	// Clone the alerts sitting here, and create persistent instances.
	foreach alert in self.alerts do
		
		sysAlert := alert.cloneSelf(false);	//Persistent instance.
		// Determine whether the transient was a log or normal alert, set a reference on me
		// to the NEW persistent object. DQ 15/06/2001
		if alert = logAlert then
			theLogAlert := sysAlert;
		elseif alert = normalAlert then
			theNormAlert := sysAlert;
		endif;
		
		if alert.mySystemAlertType &lt;&gt; null then
			sysAlert.setMySystemAlertType(alert.mySystemAlertType);
		endif;
		
		obj := alert.getLinkedTo();
		if obj &lt;&gt; null then
			if obj.isKindOf(CM_FailedToAutoplan) then	// 27/04/2009 cnwar2 #19401, #19524, #19522
				failedToAutoplan := obj.cloneSelf(false).CM_FailedToAutoplan;	// make persistent
				failedToAutoplan.myFirstYAFailure 	:= obj.CM_FailedToAutoplan.myFirstYAFailure;
				failedToAutoplan.myJob 				:= obj.CM_FailedToAutoplan.myJob;
				
				failedToAutoplan.addToAlerts(sysAlert);
				sysAlert.setLinkedTo(failedToAutoplan);
			else
				obj.addToAlerts(sysAlert);		// 13/05/2009 cnwar2 #19676
				sysAlert.setLinkedTo(obj);		// ensure objects of type other than CM_FailedToAutoplan are linked
			endif;
		endif;
		
		// Stop gate crash hopefully.
		invalid := false;
		ti := alert.myTrackedItem;
		if ti &lt;&gt; null then
//		and
//			global.isValidObject(alert.myTrackedItem) then
			// Dereference to check it is still valid
			id := ti.id;
			if not invalid then
				sysAlert.setMyTrackedItem(ti);
			endif;
		endif;
		
		if alert.myTerminal &lt;&gt; null then
			sysAlert.myTerminal := alert.myTerminal;//CNWTH2 - was app.getMyTerminal();
		endif;
		if alert.myRemoteDataHdr &lt;&gt; null then
			sysAlert.setMyRemoteDataHdr(alert.myRemoteDataHdr);
		endif;
		
		if alert.logDetails &lt;&gt; null then
			create newLogDetails;
			alert.logDetails.clone(newLogDetails);
			sysAlert.logDetails := newLogDetails;
		endif;
		self.reviewDuplicateAutoPlanFailure(sysAlert);  // PAR 19442
		sysAlert.commitAlert();
	endforeach;
	//----------------
	//This is all transient stuff from here on...
	//----------------
	self.lastLogAlert := theLogAlert;
	self.lastNormalAlert := theNormAlert;
	logAlert := null;
	normalAlert := null;
	//----------------
	//Cleanup the transient instances
	//----------------
	self.alerts.purge();
	/*
	while alerts.size &gt; 0 do
		alert := alerts[1];
		if alert.logDetails &lt;&gt; null then
			delete alert.logDetails;
		endif;
		alerts.remove(alert);
		delete alert;
	endwhile;
	*/
	if localTrans then
		commitTransaction;	//&lt;-- use the proper Commit here.
	endif;
	completedOK := true;
	
epilog
	if localTrans and not completedOK then
		abortTransaction;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getLastLogEntry" id="96165df2-4ea6-4ffb-88f7-adcef0e41d47">
        <source>getLastLogEntry() : String;
/*
 ------------------------------------------------------------------------
Created:			16 October 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	if self.logAlert = null then
		return null;
	endif;
	return self.logAlert.getLastLogEntry;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeForTransaction" id="51459b59-3dc1-4646-b894-d106aa10b304">
        <updating/>
        <source>initializeForTransaction() updating;
// ---------------------------------------------------------------------------
// Created:     06 December 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.alerts = null then
		return;
	endif;
	
	self.alerts.purge();

end;</source>
    </JadeMethod>
    <JadeMethod name="noMessageException" id="e1f0ff54-04cc-4fa7-96c9-145f82e8838e">
        <source>noMessageException(exObj: Exception): Integer;
//
// 11 Jul 2019	jlgrs1	TFS45051 JMT terminate on a SDS secondary exception ie a takeover has happened.
//
vars
	msg : String;
begin
	msg := class.name&amp;'::'&amp;method.name&amp;' Exception handler called,'&amp;exObj.errorCode.String&amp;' '&amp;exObj.extendedErrorText&amp;' processApp= '&amp;process.persistentApp.name&amp;' '&amp;process.userInfo&amp;' ('&amp;process.node.String&amp;", "&amp;process.String&amp;')';
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	abortTransaction;
	app.writeLog('*** THE ALERT MANAGER EXCEPTION HANDLER HAS ABORTED THE PROCESSING - check stack dump ***', LogINFO);
	app.doDumpStack(exObj);
	return Ex_Abort_Action;
end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="reviewDuplicateAutoPlanFailure" id="e43627b9-5845-4504-94ca-c9f69d07cf39">
        <source>reviewDuplicateAutoPlanFailure(_newAlert: CM_SystemAlert);
/*

Purpose:			Review any existing AutoPlan failure alerts that match _newAlert  

Parameters:			Newly created alert

Return Value:		None


Date		Who		Reason
09 Apr 2009	cnwdw1	PAR 19442
25 May 2009	cnwkpd1	PAR #19765 - improve performance by using Alert Type collection, and using the 	dictionary keys
*/

vars
	alert			: CM_SystemAlert;
	alertType		: CM_SystemAlertType;
	iter			: Iterator;
	newAlertTI      : CM_TrackedItem; 
begin
	
	if _newAlert.isType(EVENT_AT_FailedAutoPlan) then
	
		
		alertType  := app.myRoot.allSystemAlertTypes[EVENT_AT_FailedAutoPlan];
		
		if alertType &lt;&gt; null then
			newAlertTI := _newAlert.myTrackedItem;
			iter 	   := alertType.allSystemAlerts.createIterator;
			
			// Primary key is "reviewed"
			alertType.allSystemAlerts.startKeyGeq(false, null, iter);
			
			while iter.next(alert) do
				if alert.reviewed then		// No more unreviewed ones
					break;
				endif;
				
				if alert &lt;&gt; _newAlert and alert.myTrackedItem = newAlertTI then
					alert.setReviewed(true);
				endif;
			endwhile;
		endif;
	endif;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_newAlert" type="CM_SystemAlert"/>
    </JadeMethod>
</Class>
