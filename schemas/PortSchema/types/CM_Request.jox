    <JadeMethod name="archive" id="6a152658-fb1a-4e40-a711-55cec8d3de25">
        <updating/>
        <source>archive() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 August 2011	cnwer1	Initial creation CCMS MES 1033
					moved from CM_SlotRequest up to CM_Request
*/

vars
	wle : CM_WorkListEntry;	
begin
	exclusiveLock(self);
	foreach wle in self.allWorkListEntries do
		wle.archive();
	endforeach;
	self.setJob(null);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="areWLEsAllStatus" id="57816860-20fa-40cc-a07b-f34241d4bad0">
        <source>areWLEsAllStatus(_status : Integer) : Boolean;
//--------------------------------------------------------------
//Created: 05 May 2003 By: cnwgd1
//--------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	wle	:	CM_WorkListEntry;
begin
	if self.allWorkListEntries.isEmpty then
		return false;
	endif;
	foreach wle in self.allWorkListEntries do
		if wle.status &lt;&gt; _status then
			return false;
		endif;
	endforeach;
	return true;
end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="areWLEsAssignedToMachine" id="42bb18cb-8840-41c5-bf8a-40e8884a274f">
        <source>areWLEsAssignedToMachine() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:		20 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// 23 Mar 2011 cnwer1	PAR 25573 - changed from assigned to part complete
// ---------------------------------------------------------------------------

vars
	wle : CM_WorkListEntry;
begin
	if (self.areWLEsAllStatus(WLE_PART_COMPLETE)) then
		wle := self.allWorkListEntries.first;
		if wle = null then
			return false;
		endif;
		// is on machine
		if wle.machineId &lt;&gt; null then
			return true;
		endif;
	else
		return false;
	endif;

	return false;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canLinkWorkOrderJobs" id="3c2c537d-c9fa-48dd-bfa3-ec8b61454425">
        <source>canLinkWorkOrderJobs(_operationWle: CM_WorkListEntry): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Jun 2023	navma1	ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
17 Jul 2023	navma1	ChangeRequest 58342: EUP | Delivery Dispatch Screen - Rail Operation
*/

vars
	term : CM_Terminal;
	job  : CM_Job;
begin

	if not app.myPassport.isVASEnabled then
		return false;
	endif;
	
	term := self.myTerminal;
	
	if term = null then
		return false;
	endif;
	
	if _operationWle = null then
		return false;
	endif;
	
	job := _operationWle.job;
	
	if not job.canBeLinkedToWOJob then				//17.07.2023 navma1 #58342
		return false;
	endif;
	
	if not term.isUseYardJobsForCargoWo then
		return false;
	endif;
	
	return true;	
epilog

end;</source>
        <Parameter name="_operationWle" type="CM_WorkListEntry"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
