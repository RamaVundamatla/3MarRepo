    <JadeMethod name="setLogonIspec" id="3cad6569-6ccf-4a15-919c-4c45f83c4857">
        <updating/>
        <source>/*******************************************************
*
* Description : Set the logon ispec value for the system
*
* Parameters :	None
*
* Return :		None
*
* History :		pjs	16/12/96	Initial version
*
*******************************************************/
setLogonIspec(newLogonIspec : CnEcLincIspecDef ) updating;

vars
    ispec		: CnEcLincIspecDef;
    validIspec	: Boolean;

begin
	// Handle database create and update exceptions
	on SystemException do saveExceptionHandler(exception);
	on LockException   do saveExceptionHandler(exception);

	if newLogonIspec = null then 

		logonIspec := null; 
	else

		foreach ispec in allLincIspecDefs do
    		if (newLogonIspec = ispec) then
    			validIspec := true;
    		endif;
		endforeach;	

		if (validIspec = true) then
			logonIspec :=  newLogonIspec;
		else
			app.msgBox ("Error! Invalid ISPEC reference", "setLogonIspec", 0);
		endif;

	endif; // on newlogonIspec = null
end;</source>
        <Parameter name="newLogonIspec" type="CnEcLincIspecDef"/>
    </JadeMethod>
    <JadeMethod name="setNewTimeoutValues" id="9a2c3d3b-1ce8-46dd-9eee-905f34078528">
        <updating/>
        <source>/*******************************************************
*
* Description : Set the timeout to user defined values
*				for a Linc transaction Priority (1-5)
*
* Parameters :	time : Integer
*				priority : Integer
*
* Return :		None
*
* History :		rmb	16/12/96	Initial version
*
*******************************************************/
setNewTimeoutValues(time, priority : Integer) updating;

begin
	// Handle database create and update exceptions
	on SystemException do saveExceptionHandler(exception);
	on LockException   do saveExceptionHandler(exception);

	if (priority &lt; 1 or priority &gt; 5) then
		app.msgBox ("Error! Invalid Priority (" &amp; priority.String &amp; ")", "setNewTimeoutValues", 0);
	endif;

    timeoutValues.replace(priority, time);
end;</source>
        <Parameter name="time" type="Integer"/>
        <Parameter name="priority" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTimeoutsToDefaults" id="cebe75f8-0584-4dcd-9ba9-4be5a5046598">
        <updating/>
        <source>/*******************************************************
*
* Description : Set the timeout values to the defaults
*				for each Linc transaction Priority (1-5)
*
* Parameters :	None
*
* Return :		None
*
* History :		rmb	16/12/96	Initial version
*
*******************************************************/
setTimeoutsToDefaults() updating;

begin
	// Handle database create and update exceptions
	on SystemException do saveExceptionHandler(exception);
	on LockException   do saveExceptionHandler(exception);

	// Remove existing array values if any
	timeoutValues.purge();
   	timeoutDefaults.purge();

   	timeoutDefaults.add (Timeout_default_priority_1); 
   	timeoutDefaults.add (Timeout_default_priority_2); 
   	timeoutDefaults.add (Timeout_default_priority_3); 
   	timeoutDefaults.add (Timeout_default_priority_4); 
   	timeoutDefaults.add (Timeout_default_priority_5); 

   	timeoutValues.add (timeoutDefaults.at(1));
   	timeoutValues.add (timeoutDefaults.at(2));
   	timeoutValues.add (timeoutDefaults.at(3));
   	timeoutValues.add (timeoutDefaults.at(4));
   	timeoutValues.add (timeoutDefaults.at(5));
end;</source>
    </JadeMethod>
    <JadeMethod name="toggleDiagnosticLogOption" id="ac3ae107-5e7c-43cb-af23-21a5d557fd2c">
        <updating/>
        <source>/*******************************************************
*
* Description : Set the transport type for this Linc 
*				System definition. Options are :
*
* Parameters :	Transport_type_infoConnect |
*				Transport_type_tcp
*
* Return :		None
*
* History :		rmb	17/12/96	Initial version
*
*******************************************************/
toggleDiagnosticLogOption( index : Integer ) updating;

begin
	// Handle database create and update exceptions
	on SystemException do saveExceptionHandler(exception);
	on LockException   do saveExceptionHandler(exception);

	// Check the index is within the required range
	if ( index &lt; 1 or index &gt; Diagnostic_option_count ) then
		app.msgBox("Error! Diagnostic options array index out of range", "", 0);
	endif;

	// Has the array been initialised?
	if (diagnosticLogOptions.size() &lt;&gt; Diagnostic_option_count) then
		// If not, initialise all elements to false
		initDiagnosticOptions();
	endif;

	diagnosticLogOptions[index] := not diagnosticLogOptions[index];
end;</source>
        <Parameter name="index" type="Integer"/>
    </JadeMethod>
</Class>
