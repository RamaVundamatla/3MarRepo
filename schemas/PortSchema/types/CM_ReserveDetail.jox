    <JadeMethod name="getTotalPacked" id="2702155e-3af3-4efa-80e8-01104df348ba">
        <source>getTotalPacked() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2015	cnwndl1	Initial creation	Par 37288
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	result : Integer;
	ti : CM_TrackedItem;
	parent : CM_TrackedItem;
	allTis	: CM_TISet; 
begin
	
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	self.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	
	//foreach ti in self.allTrackedItems where ti.isChild do
	foreach ti in allTis where ti.isChild do //23/06/2023	navkc1	CR 58406 Task 58408
	
		parent := ti.myParent;
		if not self.myReserveHeader.allTrackedItemsReleased.includes(parent)
		and  not self.myReserveHeader.allTrackedItemsAssigned.includes(parent)
		then
			continue;
		endif;
		
		if ti.isBulkByVolume or ti.isBulkByWeight then	
			continue;
		endif;
		
		result := result + ti.totalQuantity.max(1);
	endforeach;
	
	return result;
epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalPackedDisplay" id="9f2753f4-200a-4449-a654-e11035150fd7">
