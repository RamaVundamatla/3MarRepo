    <JadeMethod name="calculateLostWeight" id="8731331a-91fa-41a3-9e3e-b9a674846771">
        <source>calculateLostWeight();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 August 2023	navcs2	ChangeRequest 59565: EUP - Damage | Discrepancy form fields overhaul
30/07/2023		navcs2	Bug 60155: EUP | FR 54536 - Damage and Repair CAMS - Items found WP1
18/10/2023		navcs2	ChangeRequest 59995: EUP | Damage Recording - Updating Cargo Details
05/06/2025      navsp1  JIRA-34508 EUP | 53489 Damage Recording Extra Details - new issues
*/

vars
	lostWeight : Decimal[23];
begin
	if not self.isFirstRun then
		lostWeight := self.myTrackedItem.totalWeight - self.mskTotalWeight.getConvertedValue(); // 18/10/2023 navcs2 ChangeRequest 59995 		//JIRA-34508
		
		// 30/07/2023 navcs2 Bug 60155 Start
		if lostWeight &gt;= 0 then
			self.mskLostWeight.setValue(lostWeight);
		else
			self.mskLostWeight.setValue(0);
			self.mskTotalWeight.setValue(self.myTrackedItem.totalWeight);
			//self.btnOk.enabled := false;
			//app.raiseCMException(Total_weigh_canno_incre_disc, "Lost Weight", null);
		endif;
		// 30/07/2023 navcs2 Bug 60155 End
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="calculateNewCargoWeight" id="5dfc43aa-dcc3-45c4-b870-5f39b5c43913">
        <source>calculateNewCargoWeight();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
17 October 2023	navcs2	ChangeRequest 59995: EUP | Damage Recording - Updating Cargo Details
05 June    2025 navsp1  JIRA-34508 EUP | 53489 Damage Recording Extra Details - new issues
*/

vars
	trackedItem : CM_TrackedItem;
	newCargoWeight : Decimal[12];
begin
	trackedItem := self.myTrackedItem;
	
	newCargoWeight := trackedItem.weightCargo - self.mskLostWeight.getConvertedValue();		//JIRA-34508
	if self.myCargoType.useTareCargoWeight and not self.isFirstRun then
		if newCargoWeight &gt;= 0 then
			self.mskCargoWeight.setValue(newCargoWeight);
		else
			self.mskCargoWeight.setValue(self.myTrackedItem.weightCargo);
			//app.raiseCMException(Cargo_weight_should_not_zero, null, null);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="calculateNewTotalWeight" id="375b986d-b671-425e-8075-2663ad3876c7">
        <source>calculateNewTotalWeight();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 August 2023	navcs2	ChangeRequest 59565: EUP - Damage | Discrepancy form fields overhaul
30/07/2023		navcs2	Bug 60155: EUP | FR 54536 - Damage and Repair CAMS - Items found WP1
18/10/2023		navcs2	ChangeRequest 59995: EUP | Damage Recording - Updating Cargo Details
08/04/2025      navsp1  JIRA-34508 EUP | 53489 Damage Recording Extra Details - new issues
*/

vars
	newTotalWeight : Decimal[12];
begin
	if not self.isFirstRun then
		if self.myCargoType.useTareCargoWeight and (self.mskCargoWeight.getRawValue.Decimal &lt;&gt; 0 or self.mskTareWeight.getRawValue.Decimal &lt;&gt; 0) then
			newTotalWeight := self.mskCargoWeight.getConvertedValue() + self.mskTareWeight.getConvertedValue(); 					//JIRA-34508
		else
			newTotalWeight := self.myTrackedItem.totalWeight - self.mskLostWeight.getConvertedValue(); 								//JIRA-34508
		endif;
			
		// 30/07/2023	navcs2	Bug 60155 Start
		if newTotalWeight &gt;= 0 then
			self.mskTotalWeight.setValue(newTotalWeight);
		else
			self.mskTotalWeight.setValue(self.myTrackedItem.totalWeight);					// 18/10/2023	navcs2	ChangeRequest 59995
			//app.raiseCMException(Total_weight_should_not_zero, "Total Weight", null);		// 18/10/2023	navcs2	ChangeRequest 59995
		endif;
		// 30/07/2023	navcs2	Bug 60155 Start
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="calculateRollingLength" id="51c3f7b0-2be4-450a-b2a7-ea372cc49703">
        <source>calculateRollingLength(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
17/07/23		navcs2	Bug 59045: FR | 54536 EUP - Repair Data Processing Timing - Old Weights for Repair Messages

*/

vars
	percentWeightChanged : Decimal[14,4];
	rollingLength, oldRolLength : Decimal[14,4];
	newTotal, oldTotal : Decimal[14,4];
	trackedItem	: CM_TrackedItem;
begin				
	if self.myTrackedItem &lt;&gt; null then
		trackedItem := self.myTrackedItem;
	elseif self.pxyTrackedItem &lt;&gt; null then
		trackedItem := self.pxyTrackedItem;
	endif;

	if trackedItem &lt;&gt; null and trackedItem.myCargoType.isBreakBulk then
		oldTotal := trackedItem.totalWeight;
		newTotal := self.mskTotalWeight.getConvertedValue();
		oldRolLength := trackedItem.getRollingLength();
		if oldTotal &lt;&gt; null then
			if newTotal &gt; oldTotal then
				percentWeightChanged := (newTotal - oldTotal)/oldTotal;
				rollingLength := oldRolLength + (percentWeightChanged * oldRolLength);
			else
				percentWeightChanged := (oldTotal - newTotal)/oldTotal;
				rollingLength := oldRolLength - (percentWeightChanged * oldRolLength);
			endif;
		endif;
		self.mskRollingLength.setValueDefault(rollingLength.String);
		return rollingLength;
	endif;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="calculateTotalWeight" id="9e1edb1f-df45-451a-8bde-19969cf9106f">
        <updating/>
        <source>calculateTotalWeight(_formControl : Control) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
17/07/23		navcs2	Bug 59045: FR | 54536 EUP - Repair Data Processing Timing - Old Weights for Repair Messages

*/

vars
	weightTotal, weightCargo, weightTare, weightLost	: Decimal[23,10];		
	hasTotal, hasCargo, hasTare, hasLost		: Boolean;
	trackedItem	: CM_TrackedItem;
begin				
	if self.myTrackedItem &lt;&gt; null then
		trackedItem := self.myTrackedItem;
	elseif self.pxyTrackedItem &lt;&gt; null then
		trackedItem := self.pxyTrackedItem;
	endif;
	
	hasLost		:= self.mskLostWeight.getRawValue &lt;&gt; null;
	
	if hasLost and _formControl = self.mskLostWeight then
		weightLost := self.mskLostWeight.getConvertedValue(); // ### TFS BUG 58864 28JUN2023 NAVAB1
		
		weightTotal := trackedItem.totalWeight - weightLost;			// 18.11.2022 navak20 TFS 55429 // ### TFS 55429 30NOV2022 NAVAB1
		if weightTotal &gt; 0 then
			self.mskTotalWeight.setValueDefault(weightTotal.String);
		endif;
		
		 // ### TFS BUG 58864 28JUN2023 NAVAB1
		weightCargo := trackedItem.weightCargo - weightLost;	
		if weightCargo &gt; 0 then
			self.mskCargoWeight.setValueDefault(weightCargo.String);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_formControl" type="Control"/>
    </JadeMethod>
    <JadeMethod name="checkCargoType" id="685834b7-9ba6-4227-a9b9-9245290b04bf">
        <source>checkCargoType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
17/07/23		navcs2	Bug 59045: FR | 54536 EUP - Repair Data Processing Timing - Old Weights for Repair Messages

*/

vars
	trackedItem : CM_TrackedItem;
begin
	if self.myTrackedItem &lt;&gt; null then
		trackedItem := self.myTrackedItem;
	elseif self.pxyTrackedItem &lt;&gt; null then
		trackedItem := self.pxyTrackedItem;
	endif;
	
	if(trackedItem &lt;&gt; null and trackedItem.myCargoType.isBreakBulk) then
		if trackedItem.myCargoType.useTareCargoWeight then
			self.tareCargoWeightForBreakBulk(true);
		else
			self.tareCargoWeightForBreakBulk(false);
		endif;
			
	elseif (trackedItem &lt;&gt; null and trackedItem.myCargoType.isBulk) then
		if trackedItem.myCargoType.useTareCargoWeight then
			self.tareCargoWeightForBulk(true);
		else
			self.tareCargoWeightForBulk(false);
		endif;
		
	endif;
epilog

end;</source>
    </JadeMethod>
